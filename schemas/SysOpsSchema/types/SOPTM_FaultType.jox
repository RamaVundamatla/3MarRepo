    <JadeMethod name="setupThumbnailDetails" id="8a04749d-9e2c-413d-a53e-7b1fc40052c8">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_FaultTypeMaint);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code,false);


	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_FaultTypeMaint);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="c662f268-0b86-4056-a0d8-c4d360c65d89">
        <updating/>
        <source>showThumbnail(pFaultType: CM_FaultType) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	theForm				: SOP_TableMaintForm;
begin
	theForm	:=	self.myForm;
	theForm.tblInput1.clearValues();
	theForm.tblInput1.showRowByName(ETRow_Code, false);
	theForm.tblInput1.setValueByName(ETRow_Code, pFaultType.code);
	theForm.tblInput1.setValueByName(ETRow_Description, pFaultType.description);
	theForm.tblInput1.setValueByName(ETRow_EmailRecipient,	pFaultType.emailRecipient);	
	theForm.tblInput1.setValueByName(ETRow_EmailToCC,pFaultType.emailRecipientCC);
	theForm.tblInput1.setValueByName(ETRow_EmailToBCC,pFaultType.emailRecipientBCC);
	theForm.tblInput1.setValueByName(ETRow_EmailSubject, pFaultType.emailSubject);
	theForm.tblInput1.setValueByName(ETRow_EmailBody, pFaultType.emailBody);

epilog

end;</source>
        <Parameter name="pFaultType" type="CM_FaultType"/>
    </JadeMethod>
</Class>
