    <JadeMethod name="getNextCraneLaneForTwin" id="ab2c6117-5601-40eb-a4e5-c8ede120719e">
        <source>getNextCraneLaneForTwin(_isAllocateCraneLane : Boolean; _lastCraneId : Integer io) : Integer;
// -------------------------------------------
// Created 29 September 2005 by cnwdvb1
// -------------------------------------------
vars

	crane	: CM_Crane;

begin

	// Easier to look here than all the calling methods.
	if not _isAllocateCraneLane then
		return 0;
	endif;

	// Only load jobs.
	if not self.jobType = JOB_TYPE_LOAD then
		return 0;
	endif;
	
	// Need to know the job sheet to get the crane.
	if self.myVoyageJobSheet = null then
		return 0;
	endif;
	
	crane := self.myVoyageJobSheet.getMyCrane();
	
	// Need to know the crane.
	if crane = null then
		return 0;
	endif;
	
	// Ask crane about lanes.
	return crane.getNextCraneLaneForTwin(_lastCraneId);
end;</source>
        <Parameter name="_isAllocateCraneLane" type="Boolean"/>
        <Parameter name="_lastCraneId" type="Integer" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextFreeVoyageWLE" id="1aaabcce-f2d4-4ac7-b462-2c16cdd545bb">
        <source>getNextFreeVoyageWLE(): CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 November 2012	cnwrd1	Initial creation

*/

vars
	aWLE,
	theWLE: CM_WorkListEntry;
	wleArray : CM_WLEArray;
begin
	
	create wleArray transient;
	self.getSequenceSortedWLEs(wleArray);
	
	foreach aWLE in wleArray do
		//if aWLE.myTrackedItem &lt;&gt; null then // removed for #33446 cnwrd1
		if aWLE.isCompleteForJob then // added for #33446 cnwrd1
			continue;
		else
			theWLE := aWLE;
			break;
		endif;	
	endforeach;
	
	return theWLE;

epilog
	delete wleArray;
end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="98f9e795-3552-40d5-878e-a5744c1f7249">
        <source>getNiceName(): String;
// ---------------------------------------------------------------------------
// Created:     04 July 2013 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	desc : String;
begin
	// PAR 31878 - logging
	if self.isDischarge then
		desc := "DISCHARGE";
	else
		desc := "LOAD";
	endif;
	
	if self.isTwinLift then
		desc := desc &amp; " TL";
	else
		desc := desc &amp; " SL";
	endif;
	
	desc := desc &amp; " " &amp; self.craneId &amp; " " &amp; self.jobNum.String &amp; " " &amp; self.workListEntries.size.String &amp; " ITEMS";
	
	return desc;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNonPlannedCargoDesc" id="1c47ba21-58e8-48e0-8cb3-561194ce34ac">
        <source>getNonPlannedCargoDesc(): String;
//----------------------------------------------------------------
//	Created:	05 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intCounts			: IntegerArray;
	allDescriptions		: StringArray;
	entryObj			: CM_WorkListEntry;
	returnValue			: String;
	entryDescription	: String;
	entryIndex			: Integer;
	intIdx, qty				: Integer;
	
begin
	create intCounts transient;
	create allDescriptions transient;
	
	foreach entryObj in self.workListEntries do
		if entryObj.isReceipt or
				entryObj.myFutureMove &lt;&gt; null or
				entryObj.myRequest.isBulkRelease() then
			continue;
		endif;
		
		entryDescription	:=	entryObj.getRequestDesc();
		
		if entryDescription = null then
			continue;
		endif;
		
		entryIndex	:=	allDescriptions.indexOf(entryDescription);
		qty := 1; //entryObj.myRequest.getQuantityOnRequest().Integer; // PAR 27749
		if entryIndex = 0 then
			allDescriptions.add(entryDescription);
			intCounts.add(qty);
		else
			intCounts[entryIndex]	:=	intCounts[entryIndex] + qty;
		endif;
	endforeach;
	
	if intCounts.isEmpty() then
		return null;
	endif;
	
	foreach intIdx in 1 to intCounts.size do
		if returnValue = null then
			returnValue	:=	intCounts[intIdx].String &amp; 'x' &amp; allDescriptions[intIdx];	
		else
			returnValue	:= 	returnValue &amp; ", " &amp; intCounts[intIdx].String &amp; 'x' &amp; allDescriptions[intIdx];	
		endif;
		
//		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. returnValue: ' &amp; returnValue.String);
	endforeach;
	
	return returnValue;
epilog
	delete intCounts;
	delete allDescriptions;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNum20sAnd40s" id="b2bd1608-1d85-4da7-bdfe-2f256ce5afe9">
        <source>getNum20sAnd40s(r_num20s, r_num40s, _num20s, _num40s : Integer output);
// r_num20s/40s = rehandled numbers of container for 20/40 long
//	_num20s/40s = numbers of 20/40 foot long containers 
vars
    req : CM_Request;
	ti		: CM_TrackedItem;
	wle		: CM_WorkListEntry;
begin

    foreach req in self.allRequests do
		if req.getIsRehandle() then 
			foreach wle in req.allWorkListEntries do
					ti := wle.myTrackedItem;
					if ti &lt;&gt; null and ti.isForty then
						r_num40s := r_num40s + 1;
					else
						r_num20s := r_num20s + 1;
					endif;
			endforeach;
		else
			foreach wle in req.allWorkListEntries do
				ti := wle.myTrackedItem;
				if ti &lt;&gt; null and ti.isForty then
					_num40s := _num40s + 1;
				else
					_num20s := _num20s + 1;
				endif;
			endforeach;
		endif;	
    endforeach;

end;</source>
        <Parameter name="r_num20s" type="Integer" usage="output"/>
        <Parameter name="r_num40s" type="Integer" usage="output"/>
        <Parameter name="_num20s" type="Integer" usage="output"/>
        <Parameter name="_num40s" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getNumReefersLoading" id="11b1c84b-399c-4aa7-a574-ebf57427ea11">
        <source>getNumReefersLoading() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2012	cnwer1	Initial creation SFW 1295

*/

vars
	theWLE : CM_WorkListEntry;
	numReefers : Integer;
	ti : CM_TrackedItem;
	aReq : CM_Request;
begin
	if self.isDischarge then
		return 0;
	endif;
	
	foreach theWLE in self.workListEntries discreteLock  do
		aReq := theWLE.myRequest;
		if not aReq.isValidForJobStats() then
			continue;
		endif;
		ti := theWLE.myTrackedItem ;
		if ti &lt;&gt; null and (not self.isDischarge and ti.isReefer and not ti.isEmpty) then	// 17/01/2013 cnwar2 #31030 - do not count MT's
			numReefers:=numReefers + 1;
		endif;
	endforeach;
	
	return numReefers;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
