    <JadeMethod name="ndlTFS49598" id="30d3f074-e883-4719-81ce-246840262c8b">
        <source>ndlTFS49598();

vars

	parentContainer : CM_Container; 
	child : CM_TrackedItem;
	
	response : WS_UnpackedCargoResponse;
	completedOK : Boolean;
	proxyUnpackedCargo : WS_UnpackedCargo;
	allPackedCargo : ObjectSet;
	
	allTrx : CM_TITransactionByTypeDateDict;
	childTrans : CM_TITransaction;

begin

//	parentContainer := "2367.45130426".asOid.CM_Container;
	parentContainer := "2367.279392".asOid.CM_Container;
	
	app.initialize();
	
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(parentContainer.myTerminal); 
	
	create response transient;
	
	create allTrx transient;	//27 Aug 2020	NDL	TFS 47356
	parentContainer.allTransactions.getAllTransactionsOfClass( CM_Unpack, allTrx, false );		//27 Aug 2020	NDL	TFS 47356

	create allPackedCargo transient;
//	foreach childTrans in objectArray do
	foreach childTrans in allTrx do	//27 Aug 2020	NDL	TFS 47356
		child := childTrans.CM_Unpack.getOtherTrackedItem;
		if child = null then	//14 Sep 2020	NDL	TFS 48662
			continue;
		endif;
		child := child.getMergedIntoCargo;
		if child = null then
			continue;
		endif;
if child.id = "SK_BB_2010070" then
//write child.String &amp; " Unpack";	
endif;		
		//epr TFS 37510 14/3/18 
		
	//	proxyUnpackedCargo:=response.allUnpackedCargo.findUnpackedProxyWithId( child.id );
		proxyUnpackedCargo := response.allUnpackedCargo.findUnpackedProxyIdTypeLoc( child.id, child.myCargoType, child.locationId );	//27 Aug 2020	NDL	TFS 47356
	
		if proxyUnpackedCargo &lt;&gt; null then
			proxyUnpackedCargo.totalAmount := proxyUnpackedCargo.totalAmount + childTrans.CM_Unpack.totalQuantity;
if proxyUnpackedCargo.id = "SK_BB_2010070" then
write proxyUnpackedCargo.id &amp; " " &amp; proxyUnpackedCargo.amountString &amp; " A";
endif;
			proxyUnpackedCargo.totalWeight := proxyUnpackedCargo.totalWeight + childTrans.CM_Unpack.totalWeight;
			if child.myCargoType.isBreakBulkMulti then
				proxyUnpackedCargo.amountString := proxyUnpackedCargo.totalAmount.asStringJMT;

			elseif child.myCargoType.isBulkMulti then
				proxyUnpackedCargo.amountString := child.myCargoType.getBulkTrackByDisplayForWeight( proxyUnpackedCargo.totalWeight,child.getDensity,true) ;	
			endif;
			continue;
		endif;
		
		create proxyUnpackedCargo transient;
		proxyUnpackedCargo.setProxyFromObject(childTrans.CM_Unpack);
		proxyUnpackedCargo.setDetailsFromChild(child);
		if child.getDensity &gt; 0 then
			proxyUnpackedCargo.totalVolume := proxyUnpackedCargo.totalWeight / child.getDensity;
		endif;
if proxyUnpackedCargo.id = "SK_BB_2010070" then
write proxyUnpackedCargo.id &amp; " " &amp; proxyUnpackedCargo.amountString &amp; " B";
endif;		
		response.allUnpackedCargo.add(proxyUnpackedCargo);
		allPackedCargo.add(child);
	endforeach;
	
	//epr TFS 37510 14/3/18 
	//check the repack
	//objectArray.clear;
	allTrx.clear();			//27 Aug 2020	NDL	TFS 47356

//	parentContainer.getTITxnsByTypeDate(TRANS_TYPE_PACK, fromTs, null, null, null, objectArray);
	parentContainer.allTransactions.getAllTransactionsOfClass( CM_Pack, allTrx, false );		//27 Aug 2020	NDL	TFS 47356
//	foreach childTrans in objectArray do
	foreach childTrans in allTrx do	//27 Aug 2020	NDL	TFS 47356
		child := childTrans.CM_Pack.getOtherTrackedItem;
		if child = null then
			continue;
		endif;
		
		if not child.myCargoType.allowDuplicates then
			continue;
		endif;
		
		if child.id = "SK_BB_2010070" then
write child.String &amp; " Pack";
endif;
	
	//	proxyUnpackedCargo:=response.allUnpackedCargo.findUnpackedProxyWithId(child.id);
		proxyUnpackedCargo := response.allUnpackedCargo.findUnpackedProxyIdTypeLoc( child.id, child.myCargoType, childTrans.CM_Pack.priorLocation );	//27 Aug 2020	NDL	TFS 47356
if child.id = "SK_BB_2010070" then
write childTrans.CM_Pack.priorLocation &amp; "  " &amp; (proxyUnpackedCargo &lt;&gt; null).String;
endif;
		if proxyUnpackedCargo &lt;&gt; null then
			proxyUnpackedCargo.totalAmount := proxyUnpackedCargo.totalAmount - childTrans.CM_Pack.totalQuantity;
			proxyUnpackedCargo.totalWeight := proxyUnpackedCargo.totalWeight - childTrans.CM_Pack.totalWeight;
			if child.myCargoType.isBreakBulkMulti then
				proxyUnpackedCargo.amountString := proxyUnpackedCargo.totalAmount.asStringJMT;
				//packed more than unpacked in session then don't return at all
				//epr TFS 37906 18/4/18
				if proxyUnpackedCargo.totalAmount &lt;= 0 then
					response.allUnpackedCargo.remove(proxyUnpackedCargo);
					delete proxyUnpackedCargo;
				endif;
			elseif child.myCargoType.isBulkMulti then
				//packed more than unpacked in session then don't return at all
				//epr TFS 37906 18/4/18
				if proxyUnpackedCargo.totalWeight &lt;= 0 then
					response.allUnpackedCargo.remove(proxyUnpackedCargo);
					delete proxyUnpackedCargo;
				else
					proxyUnpackedCargo.amountString := child.myCargoType.getBulkTrackByDisplayForWeight( proxyUnpackedCargo.totalWeight,child.getDensity,true) ;
				endif;			
			endif;
		endif;
	
	endforeach;
	

epilog

//	response.inspectModal();
	delete response;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlTFS49598_2" id="72f35c08-fe65-4071-85a7-549489352950">
        <source>ndlTFS49598_2();

vars

	parentContainer : CM_Container; 
	child : CM_TrackedItem;
	
	response : WS_UnpackedCargoResponse;
	completedOK : Boolean;
	proxyUnpackedCargo : WS_UnpackedCargo;
	allPackedCargo : ObjectSet;
	
	allTrx : CM_TITransactionByTypeDateDict;
	childTrans : CM_TITransaction;

begin

	parentContainer := "2367.45540071".asOid.CM_Container;
	
	app.initialize();
	
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(parentContainer.myTerminal); 
	
	create response transient;
	
	create allTrx transient;	//27 Aug 2020	NDL	TFS 47356
	parentContainer.allTransactions.getAllTransactionsOfClass( CM_Unpack, allTrx, false );		//27 Aug 2020	NDL	TFS 47356

	foreach childTrans in allTrx do
		child := childTrans.CM_Unpack.getOtherTrackedItem;
		if child = null then	//14 Sep 2020	NDL	TFS 48662
			continue;
		endif;
		child := child.getMergedIntoCargo; // this is th e current ti at that location that this was merged into.
		if child = null then
			continue;
		endif;
			
		proxyUnpackedCargo := response.allUnpackedCargo.findUnpackedProxyIdTypeLoc( child.id, child.myCargoType, child.locationId );
		if proxyUnpackedCargo &lt;&gt; null then
			//we've already got one representing this guy
			continue;
		endif;
		
		//create the proxy unpacked object
		create proxyUnpackedCargo transient;
		proxyUnpackedCargo.setProxyFromObject(childTrans.CM_Unpack);
		proxyUnpackedCargo.setDetailsFromChild(child);
		
		//now set the old "unpacked" values to the totals of the current object at the location.
		proxyUnpackedCargo.totalAmount := child.totalQuantity;
		proxyUnpackedCargo.totalWeight := child.totalWeight;
		if child.getDensity &gt; 0 then
			proxyUnpackedCargo.totalVolume := proxyUnpackedCargo.totalWeight / child.getDensity;
		endif;
		if child.myCargoType.isBreakBulkMulti then
			proxyUnpackedCargo.amountString := proxyUnpackedCargo.totalAmount.asStringJMT;
		elseif child.myCargoType.isBulkMulti then
			proxyUnpackedCargo.amountString := child.myCargoType.getBulkTrackByDisplayForWeight( proxyUnpackedCargo.totalWeight,child.getDensity,true) ;	
		endif;
		
		response.allUnpackedCargo.add(proxyUnpackedCargo);
		
	endforeach;
	
	
	
	
	
	
	
	
	
	
	
/*	
	
	
	
//	create allPackedCargo transient;
//	foreach childTrans in objectArray do
	foreach childTrans in allTrx do	//27 Aug 2020	NDL	TFS 47356
		child := childTrans.CM_Unpack.getOtherTrackedItem;
		if child = null then	//14 Sep 2020	NDL	TFS 48662
			continue;
		endif;
		child := child.getMergedIntoCargo;
		if child = null then
			continue;
		endif;
if child.id = "SK_BB_2010070" then
//write child.String &amp; " Unpack";	
endif;		
		//epr TFS 37510 14/3/18 
		
	//	proxyUnpackedCargo:=response.allUnpackedCargo.findUnpackedProxyWithId( child.id );
		proxyUnpackedCargo := response.allUnpackedCargo.findUnpackedProxyIdTypeLoc( child.id, child.myCargoType, child.locationId );	//27 Aug 2020	NDL	TFS 47356
	
		if proxyUnpackedCargo &lt;&gt; null then
			proxyUnpackedCargo.totalAmount := proxyUnpackedCargo.totalAmount + childTrans.CM_Unpack.totalQuantity;
if proxyUnpackedCargo.id = "SK_BB_2010070" then
write proxyUnpackedCargo.id &amp; " " &amp; proxyUnpackedCargo.amountString &amp; " A";
endif;
			proxyUnpackedCargo.totalWeight := proxyUnpackedCargo.totalWeight + childTrans.CM_Unpack.totalWeight;
			if child.myCargoType.isBreakBulkMulti then
				proxyUnpackedCargo.amountString := proxyUnpackedCargo.totalAmount.asStringJMT;

			elseif child.myCargoType.isBulkMulti then
				proxyUnpackedCargo.amountString := child.myCargoType.getBulkTrackByDisplayForWeight( proxyUnpackedCargo.totalWeight,child.getDensity,true) ;	
			endif;
			continue;
		endif;
		
		create proxyUnpackedCargo transient;
		proxyUnpackedCargo.setProxyFromObject(childTrans.CM_Unpack);
		proxyUnpackedCargo.setDetailsFromChild(child);
		if child.getDensity &gt; 0 then
			proxyUnpackedCargo.totalVolume := proxyUnpackedCargo.totalWeight / child.getDensity;
		endif;
if proxyUnpackedCargo.id = "SK_BB_2010070" then
write proxyUnpackedCargo.id &amp; " " &amp; proxyUnpackedCargo.amountString &amp; " B";
endif;		
		response.allUnpackedCargo.add(proxyUnpackedCargo);
		allPackedCargo.add(child);
	endforeach;
	
	//epr TFS 37510 14/3/18 
	//check the repack
	//objectArray.clear;
	allTrx.clear();			//27 Aug 2020	NDL	TFS 47356

//	parentContainer.getTITxnsByTypeDate(TRANS_TYPE_PACK, fromTs, null, null, null, objectArray);
	parentContainer.allTransactions.getAllTransactionsOfClass( CM_Pack, allTrx, false );		//27 Aug 2020	NDL	TFS 47356
//	foreach childTrans in objectArray do
	foreach childTrans in allTrx do	//27 Aug 2020	NDL	TFS 47356
		child := childTrans.CM_Pack.getOtherTrackedItem;
		if child = null then
			continue;
		endif;
		
		if not child.myCargoType.allowDuplicates then
			continue;
		endif;
		
		if child.id = "SK_BB_2010070" then
write child.String &amp; " Pack";
endif;
	
	//	proxyUnpackedCargo:=response.allUnpackedCargo.findUnpackedProxyWithId(child.id);
		proxyUnpackedCargo := response.allUnpackedCargo.findUnpackedProxyIdTypeLoc( child.id, child.myCargoType, childTrans.CM_Pack.priorLocation );	//27 Aug 2020	NDL	TFS 47356
if child.id = "SK_BB_2010070" then
write childTrans.CM_Pack.priorLocation &amp; "  " &amp; (proxyUnpackedCargo &lt;&gt; null).String;
endif;
		if proxyUnpackedCargo &lt;&gt; null then
			proxyUnpackedCargo.totalAmount := proxyUnpackedCargo.totalAmount - childTrans.CM_Pack.totalQuantity;
			proxyUnpackedCargo.totalWeight := proxyUnpackedCargo.totalWeight - childTrans.CM_Pack.totalWeight;
			if child.myCargoType.isBreakBulkMulti then
				proxyUnpackedCargo.amountString := proxyUnpackedCargo.totalAmount.asStringJMT;
				//packed more than unpacked in session then don't return at all
				//epr TFS 37906 18/4/18
				if proxyUnpackedCargo.totalAmount &lt;= 0 then
					response.allUnpackedCargo.remove(proxyUnpackedCargo);
					delete proxyUnpackedCargo;
				endif;
			elseif child.myCargoType.isBulkMulti then
				//packed more than unpacked in session then don't return at all
				//epr TFS 37906 18/4/18
				if proxyUnpackedCargo.totalWeight &lt;= 0 then
					response.allUnpackedCargo.remove(proxyUnpackedCargo);
					delete proxyUnpackedCargo;
				else
					proxyUnpackedCargo.amountString := child.myCargoType.getBulkTrackByDisplayForWeight( proxyUnpackedCargo.totalWeight,child.getDensity,true) ;
				endif;			
			endif;
		endif;
	
	endforeach;
*/	

epilog

	response.inspectModal();
	delete response;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndsTestRestService" id="faf52f74-e40f-48d4-a9c9-bf43f56d3a92">
        <source>ndsTestRestService();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
