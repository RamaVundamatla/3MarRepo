    <JadeMethod name="createProperties" id="46e9d8ce-342e-4fa1-a424-1a92144145b6">
        <source>createProperties();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	tmpProp : CM_QueryProperty;

begin

	create tmpProp as CM_QRefTerminalProperty persistent;
	tmpProp.set('Terminal', CMEVT_LocationActivity::myTerminal.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Location Activity Date', CMEVT_LocationActivity::dateTime.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefLocActTypeProperty persistent;
	tmpProp.set('Location Activity Type', CMEVT_LocationActivity::myEventType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QCargoTypeLookupProperty persistent;
	tmpProp.set('Cargo Type', CMEVT_LocationActivity::cargoType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Cargo Id', CMEVT_LocationActivity::getCargoId.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;	// par 27460 cnwcs5
	tmpProp.set('Carrier', CMEVT_LocationActivity::carrierCode.name, self.className);	// par 27460 cnwcs5
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrCommodityProperty persistent;
	tmpProp.set('Commodity', CMEVT_LocationActivity::commodity.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrConsignProperty persistent;
	tmpProp.CM_QStrConsignProperty.type := CONSIGNEE;
	tmpProp.set('Consignee', CMEVT_LocationActivity::consignee.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QStrConsignProperty persistent;
	tmpProp.CM_QStrConsignProperty.type := CONSIGNOR;
	tmpProp.set('Consignor', CMEVT_LocationActivity::consignor.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Has Been Edited', CMEVT_LocationActivity::hasBeenEdited.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Needs Recalculation', CMEVT_LocationActivity::needsRecalculation.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrOperatorProperty persistent;
	tmpProp.set('Operator', CMEVT_LocationActivity::operatorCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrStevedoreMethod persistent;							
	tmpProp.set('Stevedore', CMEVT_LocationActivity::getStevedoreCode.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	self.createMeasurementProperties(CM_QDecimalProperty, Type_Weight, 'Weight', CMEVT_LocationActivity::weight.name, self.className, null);
	
	self.createMeasurementProperties(CM_QDecimalProperty, Type_Volume, 'Volume', CMEVT_LocationActivity::volume.name, self.className, null);

	create tmpProp as CM_QIntegerProperty persistent;
	tmpProp.set('Quantity', CMEVT_LocationActivity::quantity.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Remarks', CMEVT_LocationActivity::remarks.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Source Location Name', CMEVT_LocationActivity::sourceLocationStr.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Target Location name', CMEVT_LocationActivity::targetLocationStr.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefTrainProperty persistent;
	tmpProp.set('Source Train', CMEVT_LocationActivity::mySourceTrain.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefTrainProperty persistent;
	tmpProp.set('Target Train', CMEVT_LocationActivity::myTargetTrain.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefVoyageProperty persistent;
	tmpProp.set ('Source Voyage', CMEVT_LocationActivity::mySourceVoyage.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (tmpProp);
	
	create tmpProp as CM_QRefVoyageProperty persistent;
	tmpProp.set ('Target Voyage', CMEVT_LocationActivity::myTargetVoyage.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (tmpProp);
	
	create tmpProp as CM_QRefTerminalAreaProperty persistent;
	tmpProp.set('Source Terminal Area', CMEVT_LocationActivity::mySourceTA.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefTerminalAreaProperty persistent;
	tmpProp.set('Target Terminal Area', CMEVT_LocationActivity::myTargetTA.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefVehicleVisitProperty persistent;
	tmpProp.set('Source Vehicle Visit Record', CMEVT_LocationActivity::mySourceVVR.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefVehicleVisitProperty persistent;
	tmpProp.set('Target Vehicle Visit Record', CMEVT_LocationActivity::myTargetVVR.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	
	create tmpProp as CM_QStrVoyageMethod persistent;
	tmpProp.removeOperator( CM_QStringLookupNotEqual );
	tmpProp.set('Voyage', CMEVT_LocationActivity::getVoyageCodes.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrReceiveTrainMethod persistent;
	tmpProp.removeOperator( CM_QStringLookupNotEqual );
	tmpProp.set('Train', CMEVT_LocationActivity::getTrainCodes.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrVehicleVisitMethod persistent;
	tmpProp.removeOperator( CM_QStringLookupNotEqual );
	tmpProp.set('Vehicle Visit Record', CMEVT_LocationActivity::getVvrVisitNumbers.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrTerminalAreasMethod persistent;
	tmpProp.removeOperator( CM_QStringLookupNotEqual );
	tmpProp.set('Terminal Area', CMEVT_LocationActivity::getTerminalAreaIds.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrYardLocationsMethod persistent;
	tmpProp.removeOperator( CM_QStringLookupNotEqual );
	tmpProp.set('Yard Location', CMEVT_LocationActivity::getYardLocationIds.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//04 Jun 2021	NDL	TFS 51245
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Reporting Count', CMEVT_LocationActivity::getReportingCount.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateMethod persistent;
	tmpProp.set('Reporting Service Date', CMEVT_LocationActivity::getReportingServiceDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//13 Jul 2021	NDL	TFS 51528
	create tmpProp as CM_QStrLocActDirectionMode persistent;
	tmpProp.set('Direction Mode', CMEVT_LocationActivity::directionMode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//13 Jul 2021	NDL	TFS 51528
	create tmpProp as CM_QStrLocActDirectionType persistent;
	tmpProp.set('Direction Type', CMEVT_LocationActivity::directionType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="06739b8b-e457-43aa-bc40-7e6110863836">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	qProp := self.allQueryProperties[CMEVT_LocationActivity::dateTime.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CMEVT_LocationActivity::myEventType.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CMEVT_LocationActivity::getCargoId.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CMEVT_LocationActivity::sourceLocationStr.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CMEVT_LocationActivity::targetLocationStr.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CMEVT_LocationActivity::hasBeenEdited.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CMEVT_LocationActivity::needsRecalculation.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
end;
</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
