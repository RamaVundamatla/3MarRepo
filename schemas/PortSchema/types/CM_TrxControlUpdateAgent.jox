    <JadeMethod name="trxUpdateMultipleEDITrans" id="2b2f16d5-5e75-4c36-b173-c818e629a428">
        <updating/>
        <source>trxUpdateMultipleEDITrans(_voyage : CM_Voyage input;_translations : CM_XlationSet; _customsManifest: String; _passport : CM_Passport input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 March 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description
15/07/2022		jlizm1		53964		Include inland voyages in voyage bulk translation screen
****************************************************/
vars
	xlation			: CM_Xlation;
	voyage 			: CM_Voyage;
	terminal 		: CM_Terminal;
	operator		: CM_Operator;
	terminalColl 	: CM_TerminalByCodeDict;
	type			: Integer;
	opTerm			: CM_OperatorTerminal;
	xlationTable	: CM_XlationTable;
	xlationIn		: CM_Xlation_In;
	selectedXlation	: CM_Xlation;
	foreignCode		: String;
	coll			: ObjectArray;
	result 			: Integer;
	errorStore		: CM_ErrorSet;
	err				: CM_Error;
	iter			: Iterator;
	currentDate		: Date;
	departureDate	: Date;
	arriveDate		: Date;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	//validate for create
	foreach xlation in _translations do
		xlation.validateForCreate();		
	endforeach;
	
	if _passport.hasErrors then
		return;
	endif;
	
	beginTransaction;			
	
	//deletion process and update of manifest code--&gt;	
	type := XLATION_TYPE_VOYAGETERMINAL;
	create terminalColl transient;
	create coll transient;
	app.getMyUser.getTerminals(terminalColl);	
	
	foreach terminal in terminalColl discreteLock do			
		iter := terminal.allVoyagesByCode.createIterator();
		terminal.allVoyagesByCode.startKeyGeq(_voyage.code,null,iter);		
		
		while iter.next(voyage) do
			if voyage.code &lt;&gt; _voyage.code then
				break;
			endif;
			currentDate	:=	app.actualTimeServer().date();	
			arriveDate	:=	voyage.arrivedDT.date();
			departureDate :=  voyage.departedDT.date();
			
			if voyage.isNullVoyage then
				continue;
			endif;
			
			if voyage.archived then
				continue;
			endif;
			
			if arriveDate &gt;= currentDate or currentDate &lt;= departureDate then
				voyage.setCustomsManifest(_customsManifest);	
				foreach operator in voyage.allOperators discreteLock do
					opTerm := terminal.allOperatorTerminals[operator];
					foreignCode := "";
					if opTerm &lt;&gt; null then
						selectedXlation := null;
						xlationTable := opTerm.allXlationTables[type, null];
						if xlationTable &lt;&gt; null then						
							foreach xlationIn in xlationTable.allInwardTranslations discreteLock do
								if xlationIn.systemCode &lt;&gt; _voyage.code then
									continue;
								endif;
								coll.add(xlationIn);
								break;
							endforeach;
						endif;														
					endif;
				endforeach;						
			endif;
		endwhile;
		delete iter;
	endforeach;
	
	app.myUtilityDA.utlDeleteXlations (coll, app.myPassport);
	
	if _passport.hasErrors then
		return;
	endif;
	//deletion process &lt;--	
	app.myUtilityUA.utlUpdateMultipleEDITrans(_voyage, _translations, _customsManifest, _passport);

epilog
	delete iter;
	delete coll;
	delete terminalColl;	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_translations" type="CM_XlationSet"/>
        <Parameter name="_customsManifest" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateNonCargoSelectorCols" id="1c509c0b-3a06-46c0-b7a1-fe69c8b95106">
        <updating/>
        <source>trxUpdateNonCargoSelectorCols(	_queryType : Integer;
								_queryMode : Integer;
								_allVisibleColumns : StringArray; 
								_passport : CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Mar 2019	jlgndl1	Initial creation	TFS 44100
03 Mar 2023 navhl20 ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
16 Feb 2023	navmv20	TFS 55649 Task 56228: UI - Selector Dialog for Contracts
10 May 2023 navlw1 ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
29 May 2024	jlier1	TFS 64054
*/

vars
	qDef : CM_QueryDefinition;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	qDef := app.myRoot.allQueryDefinitionObjects[ _queryType, _queryMode ];
	
	if _queryType = CM_QueryDefinition.Transaction_Query_Type
	or _queryType = CM_QueryDefinition.Invoicing_Query_Type
	or _queryType = CM_QueryDefinition.Cash_Query_Type
	or _queryType = CM_QueryDefinition.Audit_Query_Type
	or _queryType = CM_QueryDefinition.VehicleBookingSlot_Query_Type 		//10.05.2023 navlw1 #53902
	then
		//All good, we know what to do with these ones
		if _queryMode = CM_QueryDefinition.Audit_Query_Mode
		or _queryMode = CM_QueryDefinition.CargoTransaction_Query_Mode
		or _queryMode = CM_QueryDefinition.WorkOrderTrans_Query_Mode			//9.3.2023 navhl20 #54350[54269]
		or _queryMode = CM_QueryDefinition.CashPayment_Query_Mode
		or _queryMode = CM_QueryDefinition.CashReceipt_Query_Mode
		or _queryMode = CM_QueryDefinition.EventTransaction_Query_Mode
		or _queryMode = CM_QueryDefinition.HMSTransaction_Query_Mode
		or _queryMode = CM_QueryDefinition.InvoiceLine_Query_Mode
		or _queryMode = CM_QueryDefinition.Invoice_Query_Mode
		or _queryMode = CM_QueryDefinition.Location_Activity_Query_Mode
		or _queryMode = CM_QueryDefinition.Contract_Query_Mode 				//09/03/2023 navmv20	TFS 55649 Task 56228
		or _queryType = CM_QueryDefinition.VehicleBookingSlot_Query_Mode 	//10.05.2023 navlw1 #53902
		then
			//And, we know what to do with these modes
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unrecognised Query Definition Mode to get columns for "' &amp; _queryMode.String &amp; '"');
			return;
		endif;	
	elseif qDef &lt;&gt; null and (qDef.isKindOf(CM_QDefTILC) or qDef.isKindOf(CM_QDefCar)) then
		//do nothing  jlier1 TFS 64054 30/5/24
	else
		//What ever this one is hasn't been coded for yet....
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unrecognised Query Definition Type to save columns for "' &amp; _queryType.String &amp; '"');
	endif;
	
	if _allVisibleColumns = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'allColumnsVisible array is null');
	endif;
	
	if _allVisibleColumns.isEmpty then
		app.raiseCMException(Input_required_field_Required, 'at least one visible column must be selected', null);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	beginTransaction;	
	
	app.myRoot.myQueryMenuRoot.setNonCargoSelectorColumns( _queryType, _queryMode, _allVisibleColumns );	
	
	

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_queryType" type="Integer"/>
        <Parameter name="_queryMode" type="Integer"/>
        <Parameter name="_allVisibleColumns" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateObjMatchCrit" id="5d7065c3-05e4-4e9e-b323-c6e50f4b2444">
        <updating/>
        <source>trxUpdateObjMatchCrit(_pxyObjMatch : CM_ObjectMatchCriteria input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2013	cnwndl1	Initial creation

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
