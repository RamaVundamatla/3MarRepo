/*

Purpose:			


Return Value:		


Date		Who		Reason
24 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.allErrorMsgs.purge;
	self.txtWrongData.text:=null;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
