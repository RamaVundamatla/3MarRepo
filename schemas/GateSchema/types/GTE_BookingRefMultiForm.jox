    <JadeMethod name="doThumbnailContextMenu" id="6f9e4976-1884-4cb6-8aa4-e1fe01529e4b">
        <updating/>
        <source>doThumbnailContextMenu(x: Integer; y: Integer; mouse: Boolean): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	conwin: Window;
	
	x1, y1		: Real;
	
begin
//	return inheritMethod(x, y, mouse);
	conwin := self.tblThumb;
	// clone menus in sub-classes
	self.setupContextMenuItemsThumb();

	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuMain, x1.Integer, y1.Integer);
	return false;



end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="mouse" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doThumbnailDClick" id="8ab84df6-fbc6-43e3-9d7d-101855c37bfb">
        <source>doThumbnailDClick();
// ---------------------------------------------------------------------------
// Created:		Jan 2006 By Hamish Gardiner cnwhjg1
//
// Purpose:		
// 05 MAR 2015 cnwma1 PAR #35800 Break Bulk Items Received 
// ---------------------------------------------------------------------------

vars
	found : Boolean;
	table : Table;
	cellValue,tiID : String;
	theTI : CM_TrackedItem;
	strPos : Integer;
	tiSet : CM_TISet;
	noTis : String;
	tiArray : CM_TIArray;
	bookRef  : CM_BookingRef;
	bookRefItem  : CM_BookingRefItem;		//cnwmc5 - PAR 31168
begin
	table := self.tblThumb;
	if table.row &lt; 1 then // PAR 10308
		return;
	endif;
	
	if self.myCurrentObject = null then 
		return;
	endif;

	cellValue := table.accessCell(table.row,CM_EntryTable.ColumnHeading).text;

	// ### GET THE TI AND SHOW ENQUIRY
	//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-cellValue = ' &amp; cellValue);
	//th2 PAR 12839 - cell value changed
//	if cellValue = "Item Received"   // 19/12/2007 cnwar2 #15595 - changed "Items Received" to "Item Received"
//	or cellValue = "Pre-Notified" 		// 16/4/2008 par 16456 - dh

	if cellValue = app.getErrorString(ItemsReceived)	//27 Sep 2013	NDL	Par 32582
	or cellValue = app.getErrorString(PreNotified)		//27 Sep 2013	NDL	Par 32582
	or cellValue = null then
//	or cellValue = "Items Delivered"
//	or cellValue = "Allocated Items" then

		//cnwmc5 - PAR 31168
		if self.myCurrentObject.isKindOf(CM_BookingRef) then
			bookRef  := self.myCurrentObject.CM_BookingRef;
		else 
			bookRefItem  := self.myCurrentObject.CM_BookingRefItem;
			bookRef := bookRefItem.myBookingReference;
		endif;

		if table.accessRow(table.row).itemObject.isKindOf(CM_TrackedItem) then // TFS 4052
			theTI := table.accessRow(table.row).itemObject.CM_TrackedItem; // TFS 4052
			if theTI &lt;&gt; null then // TFS 4052
				self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);		 // TFS 4052
			endif; // TFS 4052
		endif; // TFS 4052

		/* TFS 4052
		tiID := table.accessCell(table.row,CM_EntryTable.ColumnValue).text[1:20];
		if tiID &lt;&gt; null then
		
			
			// ### ONSITE
			foreach theTI in bookRef.allTIs do 
				//if theTI.id = tiID then  			// 05/03/2015 cnwma1 PAR #35800
				if tiID.endsWith(theTI.id) then		// 05/03/2015 cnwma1 PAR #35800
					self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);		
					break;
				endif;	
			endforeach;			
		endif;
		*/
	elseif cellValue = "Number of TI's Received"   then 
		bookRef  := self.myCurrentObject.CM_BookingRef;
		noTis := table.accessCell(table.row,CM_EntryTable.ColumnValue).text;
		if noTis.Integer &gt; 0 then 
			create tiArray transient;
			self.myCurrentObject.CM_BookingRef.allTIs.copy(tiArray);
			self.myAssistant.showCargoEnquiryForTIs(self.myCurrentObject.CM_BookingRef.allTIs.first, tiArray,self.myMasterMenuAction, false);
		endif;
	endif;
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="fileExceptionHandler" id="ce0d7f82-e7d0-46c9-9c5d-3977b113f0bc">
        <source>fileExceptionHandler(_exObj : Exception; _invalidFileName : Boolean output) : Integer;
// TFS 1937 
vars
	
begin
	if _exObj.errorCode = 5029 then
		_invalidFileName := true;
	endif;
	return Ex_Abort_Action;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_invalidFileName" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findBookingRefItems" id="ea2c7fc2-21c6-4be5-90fd-2f30413bc636">
        <source>findBookingRefItems():Collection;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 July 2009	cnwml2	Initial creation
06 June 2011	cnwcs5	Handle invalid object in collection - there should be none
18 Aug  2011	cnwjre1	par 27881 no longer called - addObjectsToTable now handles booking ref items
*/

vars	
	booking 		: CM_BookingRef;
	bookingRefItem 	: CM_BookingRefItem;
	oa				: ObjectArray;
	gotException	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, booking, gotException);
	
	create oa transient;
	foreach booking in self.myTerminal.allBookingRefsByOperatorRef do
		foreach bookingRefItem in booking.allBookingRefItems do
			oa.add(bookingRefItem);
		endforeach;
	endforeach;
	return oa;
			
epilog

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
