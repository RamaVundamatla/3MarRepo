    <JadeMethod name="getChildTypeName" id="60ff11ef-a13a-4e47-bd30-2d292014b129">
        <source>getChildTypeName(): String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.myParent.isKindOf(CM_VesselStructuralElements) then
		return app.getErrorString(Vessel_external_ramp);
	else
		return app.getErrorString(Voyage_external_ramp);
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
