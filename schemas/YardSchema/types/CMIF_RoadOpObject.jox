epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataTable" id="cf9eda09-4464-4d16-ad29-b6d8d49b6687">
        <source>loadDataTable();

// 23/10/2012	cnwcs5	par 29653 - hide completed jobs

vars
	controller		: CMIF_RoadOpController;	// par 29653 Oct 2012
	coll 			: Collection;
	obj 			: CM_Object;
	iter 			: Iterator;
	invalidObject	: Boolean;
	table			: CM_DataTable;				// par 29653 Oct 2012
begin 
	controller	:= self.myRoadOpController;		// par 29653 Oct 2012
	
	on Exception do app.handleDeletedObject (exception, obj, invalidObject);
	
	self.myDataTable.CM_GroupingTable.clearGroups;

	coll := self.getTableCollection;
	iter := coll.createIterator;
	
	while iter.next(obj) do	
		invalidObject := false;					
		
		if not self.includeObject (obj, controller) then
			continue;
		endif;
		
		if invalidObject then
			continue;
		endif;
	
		self.addDataTableObject(obj);
	endwhile;
	
	//epr par  16494 14/5/08
	self.setStageFrameCaption();
	
	table := self.myDataTable;
	
	if table.isKindOf (CM_GroupingTable) and 
		table.CM_GroupingTable.hasGroups then
		table.resort;
	endif;
epilog
    delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataTable_AddMissingLanes" id="5f902e5b-fbd1-41b2-8123-af992198afb8">
        <source>loadDataTable_AddMissingLanes(_in :Boolean)protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj 			: Object;
	iter 			: Iterator;
	gateLaneColl	: CM_ObjectArray;
	lc				: CM_LocationsController;
	glc				: CM_GateAreaLaneController;
	index 			: Integer;
	vehicle 		: CM_Vehicle;
	str 			: String;
begin
	create gateLaneColl transient;
	
	self.getAllGateLanes (gateLaneColl);
		
	// collection contains all lanes
	foreach obj in gateLaneColl do
		glc	:= obj.CM_GateAreaLaneController;
		
		if glc.isUnavailable then
			continue;
		endif;
		
		if _in and glc.vehicleDirection = CM_GateAreaLaneController.Is_Out_Lane then
			continue;
		endif;
		
		if not _in and glc.vehicleDirection = CM_GateAreaLaneController.Is_In_Lane then
			continue;
		endif;
		
		if glc.hasVehicles then
			// if there are vehicles at the lane location the itemObject will be a vehicle and
			// be added elsewhere
			continue;
		endif;
		
		index := 0;
		
		if self.myDataTable.findObjectInRow (glc, index) then
			// it is already there
			continue;
		endif;
		
		str 	:= glc.getLaneNumber.asStringJMT;
		
		index	:= self.myDataTable.addItemObject(glc, str);
		
		// now add grouping property
		self.myDataTable.CM_GroupingTable.updateGroupingValue (index, glc);
		
		self.setTableRowColour(glc,index);
	endforeach;

	self.setStageFrameCaption();
	
	self.myDataTable.resort;
epilog
    delete iter;
	delete gateLaneColl;
end;</source>
        <access>protected</access>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataTable_GateLanes" id="c6e12ab4-1029-4a85-99f2-b950ea01dea3">
        <source>loadDataTable_GateLanes(_in :Boolean)protected;
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll 			: Collection;
	obj 			: Object;
	iter 			: Iterator;
	gateLaneColl	: CM_ObjectArray;
	lc				: CM_LocationsController;
	glc				: CM_GateAreaLaneController;
	index 			: Integer;
	vehicle 		: CM_Vehicle;
	str 			: String;

begin
	create gateLaneColl transient;
	
	self.getAllGateLanes (gateLaneColl);
		
	coll	:= self.getTableCollection;
	iter	:= coll.createIterator;
	
	while iter.next(obj)	do
		vehicle	:= obj.CM_Vehicle;
		
		// we have changed the reg no of a vehicle , the old one isnt tidied up at that point so we drop it here
		// it will have no road job and be at  no location controller
		//cnwrd1 par 23853 20.4.2010
		if vehicle.myPrimaryActualLocation = null and vehicle.allRoadJobs.size = 0 then
			coll.remove(vehicle);
			continue;
		endif;
		
		if self.addDataTableObject(vehicle) then
			//if anything has been added remove the GlC dummy row
			lc := vehicle.myPrimaryActualLocation;
			
			if lc &lt;&gt; null and gateLaneColl.includes (lc) then
				gateLaneColl.remove (lc); // so we don't add it in next step
			endif;
		endif;
	endwhile;
	
	// collection contains lanes that have not been loaded yet
	foreach obj in gateLaneColl do
		glc	:= obj.CM_GateAreaLaneController;
		
		if glc.isUnavailable then
			continue;
		endif;
		
		if _in and glc.vehicleDirection = CM_GateAreaLaneController.Is_Out_Lane then
			continue;
		endif;
		
		if not _in and glc.vehicleDirection = CM_GateAreaLaneController.Is_In_Lane then
			continue;
		endif;
		
		str 	:= glc.getLaneNumber.asStringJMT;
		index	:= self.myDataTable.addItemObject(glc, str);
		
		// now add grouping property - since all we have added to the table so far is the lane number
		self.myDataTable.CM_GroupingTable.updateGroupingValue (index, glc);
		
		self.setTableRowColour(glc,index);
	endforeach;

	self.setStageFrameCaption();
	self.myDataTable.resort;
epilog
    delete iter;
	delete gateLaneColl;
end;</source>
        <access>protected</access>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="refreshCaptions" id="c6fc3e90-52e1-4d7c-9db8-7ef0e3c2941b">
