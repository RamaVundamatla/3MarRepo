// ---------------------------------------------------------------------------
// Created:     08 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.setIncludesDepartedVoyages(not self.includeSailedVoyages);
	
	//epr TFS 47132 5/2/19 - noticed this never did anything I have changed that 
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage, 
											self.cmbVoyage.listObject.CM_Voyage, 
											true, 
											self.includeArchivedVoyages, //cnwrs1 par15258 nov 2007
											self.includeSailedVoyages,   //cnwrs1 par15258 nov 2007
											true,
											true,
											true,
											true,
											false,
											false);
		
	// PAR #24516 Load tranship export voyage combo as well
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbExpTshipVoy, 
											self.cmbExpTshipVoy.listObject.CM_Voyage, 
											true, 
											self.includeArchivedVoyages, //cnwrs1 par15258 nov 2007
											self.includeSailedVoyages,   //cnwrs1 par15258 nov 2007
											true,
											true,
											true,
											true,
											false,
											false);
	
end;</source>
