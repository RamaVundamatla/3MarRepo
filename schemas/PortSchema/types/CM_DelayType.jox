    <JadeMethod name="validateMe" id="8c3c54cf-e98b-41ca-8529-165008761c67">
        <source>validateMe() protected;
/*
----------   ----------  --------------------------------------------------
Created:	01 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	/*if self.code = null then
		app.raiseCMException1( REQUIRED_FIELD, 'Code', ETRow_Code, null );
	endif;*/
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Description), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Description), null, null); // cnwdb2	PAR 35364


	// remove to allow gaps in description Par14892
	//elseif self.description.hasInvalidChars()then 
	//		app.raiseCMException1(ERR_INVALID_CHARACTERS, 'Description ('&amp; self.description &amp; ') ', null, null);
	endif;
	
	if self.myRoot = null then
	//. need to add to translations
		app.raiseCMException1(Error, app.getErrorString(ERROR_Root), null, null);
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
</Class>
