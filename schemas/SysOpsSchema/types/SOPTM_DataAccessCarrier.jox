<Class name="SOPTM_DataAccessCarrier" id="75c04c1a-fb43-49bf-8202-0f74686fb41b">
    <superclass name="SOPTM_DataAccess"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="2f6af23e-aa03-4d9d-8b88-131c0e90e8da">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_DataAccessCarriers;
	self.permissionView	 := PmCmpDACarrierTableView;
	self.permissionMaint := PmCmpDACarrierTableMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="getMultiGroupHeading" id="bf43cdc4-bbf2-4181-9538-d90692d3dbc4">
        <source>getMultiGroupHeading(): String;

// Created by cnwdvb1 on 26 July 2007

vars

begin
	return 'Carriers';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="849b6543-aa54-45c8-aa94-bb5d63fbee80">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	
	theForm.setupForDataAccessController('Carriers',SOP_TableMaintForm::displayEntryCarrier.name, CM_Carrier);

	theForm.mulSelect1.setAvailable(app.myRoot.allCarriers, true);

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="82d25f4e-f6c5-42d9-94a0-80cf39a40b05">
        <updating/>
        <source>showThumbnail(pDataAccess : CM_DataAccessController) updating;

vars

	theForm : SOP_TableMaintForm;

begin


    theForm := self.myForm;
  	theForm.chkIncludeNotSet.visible := true; // AKB2004SEP
    theForm.myDataAccessClass := CM_Carrier;
	theForm.shtMultiSelect1.caption := "Carriers";
	theForm.chkIncludeNotSet.value := pDataAccess.includeIfNull;
	theForm.txtName.text := pDataAccess.name;
	theForm.optAllow.value	:= (not pDataAccess.mustNotBeIncluded);
	theForm.optDisallow.value := pDataAccess.mustNotBeIncluded;
	theForm.setMSHeadingsForDataAccess();
    theForm.mulSelect1.setSelected(pDataAccess.allObjects);
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pDataAccess" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="91838a5a-3e2e-4381-b870-ff3a755aec06">
        <source>tblDataDisplayRow(table: Table input; pObj: Object): String;

vars

begin
	if pObj.CM_DataAccessController.classContainedName = CM_Carrier.name then //7.3.09 cnwgb1 PAR 19041
		return inheritMethod(table, pObj);
	else
		return null;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="pObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
