						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),Storage,,(Default),CCT109 Days Since Last Load ›,(Default),UT_LineTypeLastLoad' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge ›,(Default),UT_LineTypeFirstDischarge' &amp; CrLf;

	
