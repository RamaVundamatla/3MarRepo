    <JadeMethod name="getEntDefForMode" id="78aed42f-a696-4354-ad5f-8a32104dd100">
        <source>getEntDefForMode(_qDefMode : Integer; _qDefType : Integer) : EntTableDef;
// JIRA 14794 - NAVAB1 30OCT2024
vars
	tbl : CM_DataTable;
	entTableDef 	: EntTableDef;
begin
	tbl := self.tblResults;
	
	if _qDefType = CM_QueryDefinition.Invoicing_Query_Type then
		if _qDefMode = CM_QueryDefinition.Invoice_Query_Mode then
			if app.isSpecial then
				if app.msgBox("Do you want to run with Euroports Columns?", "Question",MsgBox_Yes_No) = MsgBox_Return_Yes then
					entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTableEUP);
				else
					entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTable);
				endif;
				
			else
				if app.myRoot.isClientEuroPorts() then
					entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTableEUP);
				else
					entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTable);
				endif;
			endif;
		elseif _qDefMode = CM_QueryDefinition.InvoiceLine_Query_Mode then
			entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTableLines);
		elseif _qDefMode = CM_QueryDefinition.Contract_Query_Mode then
			entTableDef := app.myController.getEntTableDef(ETDef_InvContractEnq);
		endif;
	elseif _qDefType = CM_QueryDefinition.Cash_Query_Type then
		if _qDefMode = CM_QueryDefinition.CashPayment_Query_Mode then
			//entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTableLines); 
			entTableDef := app.myController.getEntTableDef(ETDef_InvCashPayment);  //04/09/2025	navkc1 JIRA 35574
		elseif _qDefMode = CM_QueryDefinition.CashReceipt_Query_Mode then
			entTableDef := app.myController.getEntTableDef(ETDef_CashReceiptEnquiry); 
		endif;
	elseif _qDefType = CM_QueryDefinition.Audit_Query_Type then
		if _qDefMode = CM_QueryDefinition.Audit_Query_Mode then
			entTableDef := app.myController.getEntTableDef(ETDef_AuditTblData); 
		endif;
	elseif _qDefMode = null then
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = CM_QueryDefinition.CargoTransaction_Query_Mode then
		entTableDef := app.myController.getEntTableDef(ETDef_TransactionCargoEnquiry); 
	elseif _qDefMode = CM_QueryDefinition.EventTransaction_Query_Mode then
		entTableDef := app.myController.getEntTableDef(ETDef_TransactionEventEnquiry); 
	elseif _qDefMode = CM_QueryDefinition.HMSTransaction_Query_Mode then
		entTableDef := app.myController.getEntTableDef(ETDef_TransactionHMSEnquiry); 
	elseif _qDefMode = CM_QueryDefinition.BOLTransaction_Query_Mode then
		entTableDef := app.myController.getEntTableDef(ETDef_TransactionBOLEnquiry); 
	elseif _qDefMode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then
		entTableDef := app.myController.getEntTableDef(ETDef_TransactionWOEnquiry); 
	elseif _qDefMode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then
		entTableDef := app.myController.getEntTableDef(ETDef_VBSEnquiryTbl); 
	elseif _qDefMode = CM_QueryDefinition.Location_Activity_Query_Mode then
		entTableDef := app.myController.getEntTableDef(ETDef_LocationActivityEnquiry); 
	elseif (_qDefMode &gt; BOLType_Min) and (_qDefMode &lt; BOLType_Max) then
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = TI_CargoType_BreakBulk then 
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = TI_CargoType_Car then 
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = TI_CargoType_COU then 
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = TI_CargoType_Container then  
		entTableDef := app.myController.getEntTableDef(ETDef_ContainerData); 
	elseif _qDefMode = TI_CargoType_Generator then  
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = TI_CargoType_LCL then  
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = TI_CargoType_Log then  
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = TI_CargoType_Timber then  
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = TI_CargoType_Tower then  
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = TI_CargoType_Chassis then
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode &gt; BOLType_Max then 
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	elseif _qDefMode = CM_QueryDefinition.UserDefined_Query_Mode then
		entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable); 
	endif;
	
	
	return entTableDef;
end;
</source>
        <Parameter name="_qDefMode" type="Integer"/>
        <Parameter name="_qDefType" type="Integer"/>
        <ReturnType type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="getExportFileName" id="fcf6cbc8-1ddd-4354-ba24-e4fadf685b79">
        <source>getExportFileName(_startDT :TimeStamp; _extension : String) : String;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	JIRA 33575
*/
vars
	
begin
	return self.cmbJRWReport.text &amp; "-" &amp; 
			_startDT.date.userFormat($CM_YearFormat) &amp; 
			_startDT.time.formatAsHHMMSS &amp; 
			_extension ;
epilog

end;</source>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_extension" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportFileNameBase" id="068fed9e-296a-4ba3-a5ac-7995b4e71cb9">
        <source>getExportFileNameBase(_exportPath : String): String;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	JIRA 33575
*/
vars
	fdir:         FileFolder;
	target:       String;
	pos:          Integer;
	hadFileException : Boolean;
begin
	if _exportPath = null then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(Proforma) &amp; "\";
	else
		target := _exportPath.normaliseDirectory().substituteDirectory();
	endif;
		
	create fdir transient;
	fdir.fileName := target;
	
	on FileException do self.fileSilentExceptionHandler(exception,hadFileException);
	
	if not fdir.isAvailable then
		fdir.make;
	endif;
	
	if hadFileException then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(Proforma) &amp; "\";
		fdir.fileName := target;
		if not fdir.isAvailable then
			fdir.make;
		endif;
	endif;
	

	return target;
epilog
	delete fdir;
end;</source>
        <Parameter name="_exportPath" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileExtension" id="64d12140-bb8c-4fba-aca3-096bb5cd86f4">
        <source>getFileExtension() : String;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	JIRA 33575
*/
vars

begin

	return "." &amp; self.cmbFormats.text.toLower();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileForExtract" id="772c41ca-be51-498e-b1e4-af99fc91d240">
        <updating/>
        <source>getFileForExtract(_defaultFileName, _extension : String): File updating;
/*
Purpose:	

Date		Who		Reason
6 December 2024	navab1	JIRA 33575
*/
vars
	filePath,
	exportPath	: String;
	file		: File; 
	fs 			: CMDFileSave;

begin
	create fs transient;
	fs.dialogTitle := "Specify the Report Output";
	fs.resetCurrentPath := true;
	exportPath := MiscDir &amp; "\"&amp; app.getErrorString(Proforma) &amp; "\";
	fs.initDir := self.getExportFileNameBase(exportPath);
	fs.fileName := self.getExportFileName(app.actualTimeAppServer,_extension);
	
	if fs.open = 0 then
		create file transient;
		file.fileName := fs.fileName;
		file.mode := File.Mode_Output;

		if (not file.tryOpen) then
			app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
			return null;
		endif;
	endif;

	return file;
epilog

end;</source>
        <Parameter name="_defaultFileName" type="String"/>
        <Parameter name="_extension" type="String"/>
        <ReturnType type="File"/>
    </JadeMethod>
    <JadeMethod name="getMenu" id="ea46cb0f-77aa-4004-b0f3-24cc7c6c042c">
        <source>getMenu(_menuType: String input): MenuItem;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2011	cnwdap1	Initial creation PAR #26830 CCMS 2013 allow queued move from selector
*/
vars

begin
