    <JadeMethod name="setControlsForAddEdit" id="979294d7-4e37-474c-b437-9f84d7eb01c4">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm 		: 	SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.shtMultiSelect1.visible := true;
	theForm.mulSelect1.userInputEnabled := true;
		
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_ReeferAlerts);
		theForm.tblInput1.enableRowByName(ETRow_TimeAlert);
		theForm.tblInput1.enableRowByName(ETRow_TimeMax);
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);
		//form now hides the row by default in the setupThumbnailDetails method.  Commodities are shown on the Commodities sheet 28082003
		//theForm.tblInput1.hideRowByName(ETRow_CommodityList,false);
		theForm.mulSelect1.setSelected(null);
		theForm.tblInput1.cnEcResizeContents();
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		theForm.fldInput.initSheetBackColors();
	else
/*		if self.myForm.myCurrentObject &lt;&gt; null and self.myForm.myCurrentObject.isKindOf(CM_CommodityGroup) then
			theCommodGrp := self.myForm.myCurrentObject.CM_CommodityGroup;
			theForm.mulSelect1.setSelected(theCommodGrp.allCommodities);
		endif; 
*/		
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_CommodityGroup);

		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_ReeferAlerts);
		theForm.tblInput1.enableRowByName(ETRow_TimeAlert);
		theForm.tblInput1.enableRowByName(ETRow_TimeMax);
		//form now hides the row by default in the setupThumbnailDetails method.  Commodities are shown on the Commodities sheet 28082003		
		//theForm.tblInput1.hideRowByName(ETRow_CommodityList,false);
	endif;
	self.enableMulSelect1Contents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="4ee73442-861d-481c-aac2-1befad9e3dde">
        <updating/>
        <source>setCtrlsForView() updating;

vars
	theForm : SOP_TableMaintForm;
	theCommodGrp	:	CM_CommodityGroup;
begin
	inheritMethod();  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.cnEcResizeContents();
	theForm.shtMultiSelect1.visible := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="e6cb7687-4779-4ea2-a5ae-70d64313c5c9">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm : SOP_TableMaintForm;
	theCommodityGroup	:	CM_CommodityGroup;
begin
  
    theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CommodityGroupTbl);
	//theForm.zAddColumn('Commodity Group Id', 'code', Table.InputType_None, 30);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CommodityGroupMaint);
	theForm.shtTblInput1.visible := true;
	
	//No longer want to see the CommodityList Row as the view of the commodities has been change to be shown in the Commodity Tab. 28082003
	theForm.tblInput1.hideRowByName(ETRow_CommodityList,false);
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="d078df41-4fe9-486d-a306-f46bb7d719c1">
        <updating/>
        <source>showThumbnail(pCommodityGroup : CM_CommodityGroup) updating;

vars

	theForm : SOP_TableMaintForm;
	commodity:CM_Commodity;
	list:String;	
	first:Boolean;
	row : Integer;
	
	commodityCollection	:	CM_CommodityByCodeDict;
	commodity2			:	CM_Commodity;
	code				:	String;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pCommodityGroup.code);
	theForm.tblInput1.setValueByName(ETRow_Description, pCommodityGroup.description);
	theForm.tblInput1.setValueByName(ETRow_Colour, pCommodityGroup.colour.String);
	theForm.tblInput1.setValueByName(ETRow_ReeferAlerts, pCommodityGroup.reeferAlerts);
	theForm.tblInput1.setValueByName(ETRow_TimeAlert, pCommodityGroup.timeAlert);
	theForm.tblInput1.setValueByName(ETRow_TimeMax, pCommodityGroup.timeMax);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pCommodityGroup.isAvailableForEntry); // PAR 10008
	theForm.tblInput1.setValueByName(ETRow_IsSpecialStow, pCommodityGroup.isSpecialStow);
	

//Moved to the set selected method on mulsheet1 01092003
/*	first := false;
	foreach commodity in pCommodityGroup.allCommodities do
		if (not first) then
			first := true;
			list := commodity.code.trimBlanks;
		else
			list := list &amp; ", " &amp; commodity.code.trimBlanks;
		endif;
	endforeach;
	theForm.tblInput1.setValueByName(ETRow_CommodityList, list);
*/
		
	theForm.mulSelect1.setSelected(pCommodityGroup.allCommodities);
	self.disableMulSelect1Contents();

end;</source>
        <Parameter name="pCommodityGroup" type="CM_CommodityGroup"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="f5fbfc07-88ae-4266-90b5-697c38c1fc21">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	commodityGroup:CM_CommodityGroup;
	cell : JadeTableCell;
begin
	commodityGroup := _obj.CM_CommodityGroup;
	if(_idxRow &lt;&gt; 1) then
		if self.colourColumn &gt; 0 then
			cell := myForm.tblData.accessCell(_idxRow, self.colourColumn);
			cell.text := null;			
			cell.backColor := commodityGroup.colour;
		endif;
	endif;

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
