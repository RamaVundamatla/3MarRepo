    <JadeMethod name="getWeightAsST" id="5783e818-73be-427c-8332-6b7c8dc1e9fe">
        <source>getWeightAsST():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	measure : CM_MeasurementType;
	retVal : String;


begin

	measure := CM_Root.firstInstance.allMeasurementTypesByShortName["ST"];
	if measure &lt;&gt; null then
		retVal := measure.convertMeasurementForDisplay( self.weight );
	endif;
	
	return retVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isFromBarge" id="6c82c802-3648-4a87-87e0-73a6bf8e5495">
        <source>isFromBarge(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin
	return self.modeInt.isOneOf( LocnActMoveDir_BargeToYard, LocnActMoveDir_BargeToVessel );

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
