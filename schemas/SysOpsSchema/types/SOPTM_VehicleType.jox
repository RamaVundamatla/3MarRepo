    <JadeMethod name="setControlsForAddEdit" id="8603a756-6c82-42c2-810f-77b894d05e59">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Type);
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_VehicleType);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Type);
	endif;

epilog

end;</source>
    </JadeMethod>
