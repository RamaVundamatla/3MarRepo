    <JadeMethod name="setTime" id="2a2fb6fb-dab2-4ca2-8187-ec8f2c1e3623">
        <updating/>
        <source>setTime(time: Time) updating;

vars

begin

	setHour(time.hour);
	setMinute(time.minute);
	setSecond(time.second);

end;</source>
        <Parameter name="time" type="Time"/>
    </JadeMethod>
    <JadeMethod name="setTimeStamp" id="54c9b86d-84dd-41b1-9121-988fc500b834">
        <updating/>
        <source>setTimeStamp(timestamp: TimeStamp) updating;

vars
	date:   Date;
	time:   Time;
begin
	date := timestamp.date;
	time := timestamp.time;

	// Set the day to a value that is valid for all months.
	// Otherwise if the current day happens to be invalid for
	// the new month, you get an exception.
	setDay(1);

	setYear(date.year);
	setMonth(date.month);
	setDay(date.day);

	setHour(time.hour);
	setMinute(time.minute);
	setSecond(time.second);

end;</source>
        <Parameter name="timestamp" type="TimeStamp"/>
    </JadeMethod>
