    <JadeMethod name="create" id="a348e8d7-48f8-45ed-b963-d0afc4c71f75">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_TidalClass;
	self.permissionView	 := PmHMSTidalClassView;
	self.permissionMaint := PmHMSTidalClassMaint;
	self.myDataClass := HMS_TidalClass;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="9f74f00c-4cc2-4fee-8ec5-070977e045a6">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	maxCurrent : Decimal[6,3];
	pxyTidalClass	: HMS_TidalClass;
	theForm : SOP_HMS_TableMaintForm;
	conflictManager	 : CMIF_HMS_ConflictsManager;
begin

  	theForm := self.myForm.SOP_HMS_TableMaintForm; 
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_TidalClass transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyTidalClass := theForm.myProxyObject.HMS_TidalClass;
	theForm.tblInput1.setObjectFromTable(pxyTidalClass, null, false);
	pxyTidalClass.setProxy(app.myRoot);

	pxyTidalClass.allMaximumCurrents.clear();
	//MaxCurrents must be added to the array in this order
	//Jury out on this one, may change to separate attributes on class??
	maxCurrent := theForm.tblInput1.getValueByName(ETRow_MaxFloodTideArrival).Decimal;
	pxyTidalClass.allMaximumCurrents.add(maxCurrent);
	maxCurrent := theForm.tblInput1.getValueByName(ETRow_MaxEbbTideArrival).Decimal;
	pxyTidalClass.allMaximumCurrents.add(maxCurrent);
	maxCurrent := theForm.tblInput1.getValueByName(ETRow_MaxFloodTideDept).Decimal;
	pxyTidalClass.allMaximumCurrents.add(maxCurrent);
	maxCurrent := theForm.tblInput1.getValueByName(ETRow_MaxEbbTideDept).Decimal;
	pxyTidalClass.allMaximumCurrents.add(maxCurrent);			

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateTidalClass(pxyTidalClass, theForm.myCurrentObject, conflictManager, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateTidalClass(pxyTidalClass, conflictManager, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	if conflictManager &lt;&gt; null then
		if (not conflictManager.allCMIFConflicts.isEmpty) then
			if app.msgBox('There are Voyages with conflicts in the system. Do you want to view the "Conflict Report" now?', 'View Conflict Report', MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_Yes then
				theForm.myAssistant.showConflictsReport(conflictManager, null, theForm.myHarbour);
			else
				delete conflictManager;			
			endif;
		else
			delete conflictManager;
		endif;
	endif;
	
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="ee6b6d39-17ee-4dc2-bf60-908f3d25ae9b">
