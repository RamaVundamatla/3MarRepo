    <JadeMethod name="setForUpdate" id="70a2b693-9e22-4cca-ac63-fc46cb55e0dd">
        <updating/>
        <source>setForUpdate(_pxyLot : CM_LogLot)updating;
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	sol : CM_LogStockOrderLine;

begin
	self.raiseExceptionIfTransient(method);
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.lotNo &lt;&gt; _pxyLot.lotNo then
			foreach sol in self.allLogStockOrderLines do
				self.updateObjectEdition(sol);
			endforeach;
		endif;
	endif;
	
	self.lotNo 			:= _pxyLot.lotNo;
//	self.myLogVoyage 	:= _pxyLot.myLogVoyage;
	self.myLogVoyageStructure := _pxyLot.myLogVoyageStructure;
	
end;</source>
        <Parameter name="_pxyLot" type="CM_LogLot"/>
    </JadeMethod>
