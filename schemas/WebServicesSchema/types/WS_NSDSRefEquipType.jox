    <JadeMethod name="setProxyObject" id="f08d47ed-fcad-4055-8b06-733711be5e36">
        <updating/>
        <source>setProxyObject(_any : Any) updating;
/*

Purpose:			
	Mapping 
	MTN : CM_ISOType
	N4  : ref_equip_type
Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	helper  : CMIF_RefEquipType;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName      	:= helper.tableName;
	self.gkey           	:= helper.gkey;
	self.basic_length   	:= helper.basic_length;
	self.classStr       	:= helper.classStr;
	self.description    	:= helper.description;
	self.height_mm      	:= helper.height_mm;
	self.id	      			:= helper.id;
	self.iso_group			:= helper.iso_group;
	self.length_mm			:= helper.length_mm;
	self.life_cycle_state	:= helper.life_cycle_state;
	self.nominal_height		:= helper.nominal_height;	
	self.nominal_length		:= helper.nominal_length;	
	self.safe_weight_kg		:= helper.safe_weight_kg;	
	self.tare_weight_kg		:= helper.tare_weight_kg;	
	self.width_mm			:= helper.width_mm;	

epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
