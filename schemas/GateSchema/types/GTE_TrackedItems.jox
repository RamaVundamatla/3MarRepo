    <JadeMethod name="getXMLSettingsForSave" id="ff459108-0e09-49f1-925a-46b5773a1631">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theXML : String;

begin

	theXML := inheritMethod();


	if self.myIMEXStatus &lt;&gt; null and self.isReleaseByType then
		theXML := theXML &amp; global.formatAsXML(XML_TAG_IMEX,self.myIMEXStatus.code.String) ;
	endif;
	
	//14 Jun 2021	TFS 51338
	theXML := theXML &amp; global.formatAsXML("UseColumnOrganiser",self.useColumnOrganiser.String) ;
	if self.useColumnOrganiser then
		theXML := theXML &amp; self.tblListAll.getXmlStrForColumns(true);
	endif;
	
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="a0882e96-6399-415c-9349-43a76b5007c8">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;

 	// #### HIDE LEGEND
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TAG_IMEX);
 	if theXMLValue &lt;&gt; null then
 		if self.isReleaseByType then
	 		self.myIMEXStatus := app.myRoot.allImexStatuses[theXMLValue.Integer];
	 	endif;
 	endif;
	
	//14 Jun 2021	TFS 51338
	theXMLValue := theXML.cnEcGetTagValueOfName("UseColumnOrganiser");
	if theXMLValue &lt;&gt; null then
		self.useColumnOrganiser := ( theXMLValue = "true" );
		self.chkUseColOrg.value := self.useColumnOrganiser;
	endif;

end;</source>
    </JadeMethod>
