    <JadeMethod name="translateForm" id="6f43223c-ffdd-40d9-9f38-25bcff0ad2bd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006134, locale);
	btnQualAll.translateBubbleHelp(Xlat_0002043, locale);
	btnQualAll.translateCaption(Xlat_0002047, locale);
	btnQualCancel.translateBubbleHelp(Xlat_0002041, locale);
	btnQualCancel.translateCaption(Xlat_0002042, locale);
	btnQualSave.translateBubbleHelp(Xlat_0002044, locale);
	btnQualSave.translateCaption(Xlat_0002048, locale);
	btnQualify.translateBubbleHelp(Xlat_0002045, locale);
	btnQualify.translateCaption(Xlat_0002049, locale);
	btnQueryQual.translateBubbleHelp(Xlat_0002046, locale);
	btnQueryQual.translateCaption(Xlat_0002050, locale);
	btnQueryUnQual.translateBubbleHelp(Xlat_0002039, locale);
	btnQueryUnQual.translateCaption(Xlat_0002040, locale);
	frame6.translateCaption(Xlat_0002051, locale);
end;</source>
    </JadeMethod>
</GUIClass>
