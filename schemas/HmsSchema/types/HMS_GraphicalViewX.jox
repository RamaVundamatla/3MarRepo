        <source>reserveLockExceptionHandler(_exObj : LockException; _object : CM_Object; _gotException : Boolean output; _userCode : String output) : Integer;
//--------------------------------------------------
// Created:	30 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	_gotException := true;
