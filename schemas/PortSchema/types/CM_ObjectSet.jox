<CollClass name="CM_ObjectSet" id="5d70c311-e7eb-470e-abaa-22271177a777">
    <memberType name="Object"/>
    <superclass name="ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>If possible do not use CM_ObjectSet - use CM_ObjectSetActual as it has
membership of CM_Object.</text>
    <DbClassMap file="misc"/>
    <JadeMethod name="copyNoDupsToCol" id="69d43045-8a4e-456c-8812-2231a0638061">
        <source>copyNoDupsToCol(_col : Btree input; _raiseException: Boolean);
/*
 ------------------------------------------------------------------------
Created:			17 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	ob : MemberType;
begin
	foreach ob in self do
		_col.addNoDuplicates(ob, _raiseException);
	endforeach;
end;</source>
        <Parameter name="_col" type="Btree" usage="input"/>
        <Parameter name="_raiseException" type="Boolean"/>
    </JadeMethod>
</CollClass>
