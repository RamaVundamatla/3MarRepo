    <JadeMethod name="create" id="f6b2f62b-a470-49dc-90e6-f10071f70d25">
        <updating/>
        <source>create() updating;

begin
	// these are required for booking refs
	createInputFile(operatorFile, "Operators.txt");
	createInputFile(isoTypeFile, "ISOTypes.txt");

	createInputFile(userFile, "UserIds.txt");
	createInputFile(userListFile, "UserIdList.txt");
	createInputFile(bookingRefFile, "BookingRefs.txt");
	createInputFile(bookingRefListFile, "BookingRefList.txt");
	createInputFile(rfidTagFile, "rfidTags.txt");
	createInputFile(rfidTagListFile, "rfidTagList.txt");
	
	createInputFile(baplieTemplateFile, "BaplieTemplate.txt");
	createInputFile(baplieFile, "Baplie_"&amp;app.sequenceId.String&amp;".txt");
	
	//carrierIterator:=app.myRoot.allCarriers.createIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="createInputFile" id="b612afd6-e592-4d92-be1d-179ee2ddf52a">
        <source>createInputFile(_file:File io; fileName:String);

begin
	create _file;
	_file.mode := File.Mode_Input;
	_file.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	if fileName[1:7] = "Baplie_" then  // new baplie file is kept on thin client machine
		_file.usePresentationFileSystem:=true;
		_file.fileName:=app.getJadeInstallDir&amp;"\"&amp;fileName;
	else
		_file.usePresentationFileSystem:=false;
		_file.fileName:=app.dbPath.toLower.atcgReplace("c_system","c_misc\jtd\")&amp;fileName;
	endif;
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="9f243c50-c56f-4f95-a922-729582dd8f56">
        <updating/>
        <source>delete() updating;

begin
	delete userFile;
	delete userListFile;
	delete operatorFile;
	delete isoTypeFile;
	delete bookingRefFile;
	delete bookingRefListFile;
	delete rfidTagFile;
	delete rfidTagListFile;

	delete baplieTemplateFile;
/*	if baplieFile &lt;&gt; null and baplieFile.isAvailable then
		baplieFile.purge();  // only one file per planner, so leave them in place in case debugging is required
	endif; /* */
	
	delete baplieFile;
	
	delete carrierIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectForm" id="fb16bbb1-1390-464e-83a5-999ded66acff">
        <source>selectForm(class:Class):Form;

vars
	i:Integer;
	form:Form;
begin
	if app.formsCount &gt; 1 then
		foreach i in 1 to app.formsCount do
			form := app.forms(i);
			if form.isKindOf(class) then
				return form;
			endif;
		endforeach;
	endif;
    return null;
end;</source>
        <Parameter name="class" type="Class"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="selectRandom" id="cf37b66b-1deb-4a66-9aea-acde49d91843">
        <source>selectRandom(f:File):String;
//	grab a random token from the specified file
vars
	i,j,offset:Integer;
	s,t:String;
begin
	offset:=app.random(f.fileLength-99);
	f.seek(offset);
	s:=f.readString(100);
	j:=1;
	// probably in the middle of a token, so look for next full one
	t:=s.scanUntil(',',j);
	j:=j+1;
	t:=s.scanUntil(',',j);
	return t;
end;</source>
        <Parameter name="f" type="File"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="selectRandomBookingRef" id="fff1e52c-e779-44bf-96e4-261814b89e09">
        <source>selectRandomBookingRef():String;

vars
	i,j:Integer; s,t:String;
begin
	if repeatable then
		if bookingRefListFile.endOfFile then
			app.logMessage("---------------------------------------");
			app.logMessage("restarting at top of bookingRefListFile");
			app.logMessage("---------------------------------------");
			bookingRefListFile.seek(0);
		endif;
		return bookingRefListFile.readLine;  // for repeatable random results

	else	
		while s = null do  // for full random
			s:=selectRandom(bookingRefFile);
			i:=i+1;
			if i &gt; 1 then i:=14 div 0; endif;  // ask for help
		endwhile;
		return s;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="selectRandomISOType" id="3629621c-b267-47be-9854-94c5f0d6dbbf">
        <source>selectRandomISOType():String;
//	not used during benchmark - only during file generation
vars
	i,j:Integer; s,t:String;
begin
	while s = null do  // for full random
		s:=selectRandom(isoTypeFile);
		i:=i+1;
		if i &gt; 1 then i:=14 div 0; endif;  // ask for help
	endwhile;
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="selectRandomOperator" id="bd46df15-4873-4258-81c5-8bb76bfe5edf">
        <source>selectRandomOperator():String;
//	not used during benchmark - only during file generation
vars
	i,j:Integer; s,t:String;
begin
	while s = null do  // for full random
		s:=selectRandom(operatorFile);
		i:=i+1;
		if i &gt; 1 then i:=14 div 0; endif;  // ask for help
	endwhile;
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
