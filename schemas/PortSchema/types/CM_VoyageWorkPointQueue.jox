    <JadeMethod name="myVoyage" id="897869b0-5dfc-4db1-ab9e-4c59882c8869">
        <methodInvocation>mapping</methodInvocation>
        <source>myVoyage(set : Boolean; _value : CM_Voyage io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin

	if set then
		return;
	endif;
	
	if self.myParentQueue &lt;&gt; null and 
	   self.myParentQueue.isKindOf(CM_VoyageQueue) then
		_value := self.myParentQueue.CM_VoyageQueue.myVoyage;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Voyage" usage="io"/>
    </JadeMethod>
