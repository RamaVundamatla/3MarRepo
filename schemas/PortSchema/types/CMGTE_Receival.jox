    <JadeMethod name="isReefer" id="4ca411c1-1143-4082-8ba8-d8917e9342bd">
        <source>isReefer(): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/12/2009	cnwdap1	CCMS MES 1007 Initial creation - any tracked item can be a reefer
29/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
*/
vars
	ti	: CM_TrackedItem;
	comm : CM_Commodity;					// PAR #36094

begin
	ti	:= self.myTrackedItem;
	
	if ti &lt;&gt; null then
		return ti.isReefer;
	endif;
	
	// PAR #36094 if no TI, check commodity						// PAR #36094
	if self.commodity &lt;&gt; null then								// PAR #36094
		comm := app.myRoot.allCommodities[self.commodity];		// PAR #36094
		if comm &lt;&gt; null then									// PAR #36094
			return comm.hasTemp;								// PAR #36094
		endif;													// PAR #36094
	endif;														// PAR #36094
	
	return null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="356e5a51-65c4-43ac-a11b-e5d3103e350e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/05/2009	cnwjk3	Initial creation
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
15/05/2014	cnwdap1	PAR #34157 move booking item setting up to CMGTE_Entity level as this is where the reference lives
*/
vars
	pxyGTE : CMGTE_Receival;
	completedOK		: Boolean;
	ti : CM_TrackedItem;
	edition : Integer;
	invalidTi : Boolean;
begin
	pxyGTE := inheritMethod();
	pxyGTE.myTranshipToPort := self.myTranshipToPort;		// cnwjk3 PAR 23390 24/03/2010
	//pxyGTE.myBookingRefItem := self.myBookingRefItem;		// PAR #34157
	pxyGTE.myBusinessUnit := self.myBusinessUnit;
	pxyGTE.myProduct := self.myProduct;
	
	//16 Mar 2012	NDL	Par 28495
	//pxyGTE.myTrackedItem := self.myTrackedItem;
	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, ti, invalidTi);
		edition := ti.edition;
		if invalidTi then
			ti := null;
		endif;
	endif;
	pxyGTE.myTrackedItem := ti;
	
	
	pxyGTE.setPxyHazards(self.allTIHazards);
	pxyGTE.setPxySpecialLifts(self.allSpecialLifts); //+ cnwmd1 Par 22167
	pxyGTE.setPxyToDoTasks(self.allToDoTasks);				//+cnwml2 PAR23851
	// pxyGTE.myGenerator will be updated by  CMGTE_Generator::pxyCreateUpdateProxy()
	pxyGTE.setMoveToTruckOnly(self.moveToTruckOnly);	//08 Jun 2010	NDL	Par 23903
	
	pxyGTE.createProxySeals( self.allSeals );
	
	//jlier1 TFS 53515 25/5/22
	pxyGTE.myCargoGroup:=self.myCargoGroup;
	
	pxyGTE.mySortingMethod := self.mySortingMethod;	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	pxyGTE.myCustomerPriority := self.myCustomerPriority;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyGTE;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyGTE;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="rebuildChildLinks" id="bab342b8-cbb5-45d3-98e3-3c6b5185799a">
        <updating/>
        <source>rebuildChildLinks() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2010	cnwdap1	Initial creation PAR #23355
30/04/2018	jlgmd1	TFS #38259 C3 - Error on Road Gate
*/
vars
	pxyVVR		: CM_VehicleVisitRecord;
	//children	: CM_TISet;
	subItem		: CMGTE_Entity;
	ti			: CM_TrackedItem;
	entity		: CMGTE_Entity;
	tiSet		: CM_TISet;

begin
	//create children transient;
	//self.myTrackedItem.getAllChildren(children);//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
	foreach subItem in self.allChildren discreteLock where CMGTE_Receival.hasInstance(subItem) do
		foreach ti in self.myTrackedItem.allChildren discreteLock do
			if ti.id = subItem.id and ti.cargoType = subItem.CMGTE_Receival.cargoType then
				subItem.CMGTE_Receival.setMyTrackedItem(ti);
			endif;
		endforeach;
	endforeach;
	
	// and the links on the proxy vehicle visit record as well
	if not self.myVehicleVisitRecord.isTransient then
		pxyVVR := self.myVehicleVisitRecord.pxyGetProxyObject;
		if pxyVVR &lt;&gt; null then
			foreach entity in pxyVVR.allGateEntities where CMGTE_Receival.hasInstance(entity) do
				if entity.CMGTE_Receival.isFromPrenote then		// TFS 38259 jlgmd1 30/04/2018
					entity.CMGTE_Receival.rebuildChildLinks;
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="receiptTransportMode" id="60c7809b-9b04-46b5-b1c8-d52dea587ee1">
