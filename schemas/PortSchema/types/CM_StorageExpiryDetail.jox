    <JadeMethod name="getDisplayStringForAttribute" id="c0a310ad-1c64-4b6b-b2dc-c71b2b033c01">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2023 CR 58250 Task 58253: UI - Cargo Enquiry New Sheet
20 May 2024 navrv30 Bug 64162: MTN - COO (The Ownership Change Date Time is BLANK in the Storage Expiry Details tab)
*/

vars
	anniversaryDate : TimeStamp;
	expires, now : Date;
	days : Integer;
begin
	if _attrName = ETRow_DateTime then
		return self.dateTime.asStringJMT();
	elseif _attrName = ETRow_FreeStorageDaysAssigned then
		return self.freeStorageDays.asStringJMT();
	elseif _attrName = ETRow_FreeStorageExpDTSort then
		return self.freeStorageExpiry.asStringJMT();
	elseif _attrName = ETRow_AdditionalStorageDays then
		return self.additionalStorageDays.asStringJMT();
	elseif _attrName = ETRow_FreeStorageDaysRemaining then
		expires := self.freeStorageExpiry.date;
		if expires &gt; now then
			days := expires - now;
		endif;
		return days.asStringJMT();
	elseif _attrName = ETRow_StorageChangeReason then
		return self.storageChangeReason;
	elseif _attrName = ETRow_FutureStorageDate then
		anniversaryDate := self.futureStorageAnniversary;
		if anniversaryDate.isValid then
			return anniversaryDate.date().asStringJMT();
		endif;
	elseif _attrName = ETRow_COOINCODesc then
		return self.getINCOTermDesc();
	elseif _attrName = ETRow_COOINCOCode then
		return self.getINCOTermCode();
	elseif _attrName = ETRow_OperatorPreviousDesc then
		return self.getOperatorPrevDesc();
	elseif _attrName = ETRow_OperatorPreviousCode then
		return self.getOperatorPrevCode();
	elseif _attrName = ETRow_OperatorStorageDesc then
		return self.getOperatorStorageDesc();
	elseif _attrName = ETRow_OperatorStorageCode then
		return self.getOperatorStorageCode();
	elseif _attrName = ETRow_OperatorNewDesc then
		return self.getOperatorNewDesc();
	elseif _attrName = ETRow_OperatorNewCode then
		return self.getOperatorNewCode();
	elseif _attrName = ETRow_FreeDaysOperatorOld then
		return self.getFreeDaysOperatorOld();
	elseif _attrName = ETRow_FreeDaysOperatorNew then
		return self.getFreeDaysOperatorNew();
	elseif _attrName = ETRow_COONumber then
		return self.getCOONumber;
	elseif _attrName = ETRow_COODateTime then   //20 May 2024 navrv30 Bug 64162
		return self.getCOODate();
	elseif _attrName = ETRow_ChargedDaysType then
//		return self.chargedDaysType.asStringJMT();		
		 // ### TFS 58252 25OCT2023 NAVAB1
		if self.chargedDaysType = CM_StorageDetail.Working_Days then
			return app.getErrorString(Working_days); // Show charge days
		elseif self.chargedDaysType = CM_StorageDetail.Calendar_Days then
			return app.getErrorString(All_Days); // Show charge days
		elseif self.chargedDaysType = CM_StorageDetail.Calendar_Months then
			return app.getErrorString(Calendar_months); // Show charge days
		elseif self.chargedDaysType = CM_StorageDetail.Working_Compulsory_Days then
			return app.getErrorString(Working_compulsory_days);
		endif;

	elseif _attrName = ETRow_FreeDaysType then
		//return self.freeDaysType.asStringJMT();
		 // ### TFS 58252 25OCT2023 NAVAB1
		if self.freeDaysType = CM_StorageDetail.Working_Days then
			return app.getErrorString(Working_days);
		elseif self.freeDaysType = CM_StorageDetail.Calendar_Days then
			return  app.getErrorString(All_Days);
		elseif self.freeDaysType = CM_StorageDetail.Calendar_Months then
			return app.getErrorString(Calendar_months);
		elseif self.freeDaysType = CM_StorageDetail.Working_Compulsory_Days then
			return app.getErrorString(Working_compulsory_days);
		endif;

	elseif _attrName = ETRow_IncoTermCode then
		return self.incoTermsCode;
	elseif _attrName = ETRow_OperatorCode then
		return self.operatorCode;
	elseif _attrName = ETRow_OperatorBillingCode then
		return self.operatorForBillingCode;
	elseif _attrName = ETRow_TotalQuantity then
		return self.totalQuantity.asStringJMT();
	elseif _attrName = ETRow_TotalWeight then
		return self.totalWeight.asStringJMT();
	elseif _attrName = ETRow_TotalVolume then
		return self.totalVolume.asStringJMT();
		
	// CR 58373 Task 58381 - NAVAB1 25OCT2023
	elseif _attrName = ETRow_FutureStorageAddReason then
		return self.futureStorageChangeReason;
	elseif _attrName = ETRow_FutureStorageAdditional then
		return self.futureStorageAdditionalDays.asStringJMT();
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
