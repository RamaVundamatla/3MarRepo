    <JadeMethod name="doResize" id="d9383c17-4c74-437f-b359-7c91ee4a5a8e">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
