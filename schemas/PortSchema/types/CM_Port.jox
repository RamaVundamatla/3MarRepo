    <JadeMethod name="pxyCreateUpdateProxy" id="ec273d4b-5097-4707-a16d-0f8d3b91ebc8">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpPort : CM_Port;
	completedOK		: Boolean;
begin
	tmpPort := inheritMethod();
	tmpPort.myPortGroup := self.myPortGroup;
	tmpPort.myCountry := self.myCountry;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpPort;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpPort;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="resetNullDisplayCode" id="97bade5a-c8a7-4a59-9058-24e67c0e8250">
        <updating/>
        <source>resetNullDisplayCode():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2012	cnwndl1	Initial creation	Par 30772

*/
vars

	fullCodeStr : String;
	strC : String;
	strShortCode : String;

begin

	if self.portCode.trimBlanks = null then
		fullCodeStr := self.code.trimBlanks.toUpper;
		if fullCodeStr &lt;&gt; null and fullCodeStr.length = 5 then
			if self.myCountry &lt;&gt; null then
				strC := self.myCountry.code.trimBlanks.toUpper;
			endif;
			if strC &lt;&gt; null and strC.length = 2 then
				if fullCodeStr[1:2] = strC then
					strShortCode := fullCodeStr[3:3];
					if strShortCode &lt;&gt; null then
						self.portCode := strShortCode;
						return true;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f0894c0d-922d-4629-9571-258ed1978998">
        <updating/>
        <source>setForCreate(pProxyPort:CM_Port) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	//always do in set for create
	if not self.isActive then
		self.isActive := true;
	endif;
	setForUpdate(pProxyPort);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyPort" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="aafd0083-f429-4c84-86e7-af37b6f1b446">
        <updating/>
        <source>setForUpdate(_proxy :CM_Port) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete
// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259
// ---------------------------------------------------------------------------
vars

begin
	// par 31259 - make sure xlations updated with new code
	if self.code &lt;&gt; _proxy.code then
		self.updateXlations_Code (_proxy.code.String, self.code.String, self.allXlations);
	endif;
	
	self.code 					:= _proxy.code.trimBlanks;
	self.portCode 				:= _proxy.portCode;
	self.description 			:= _proxy.description.trimBlanks;
	self.ccodePrint 			:= _proxy.ccodePrint;
	self.colour 				:= _proxy.colour;
	self.isNotAvailableForEntry := _proxy.isNotAvailableForEntry;
	self.myCountry 				:= _proxy.myCountry;
	self.myPortGroup 			:= _proxy.myPortGroup;
	self.bIsPort 				:= _proxy.bIsPort;
	self.bIsRail 				:= _proxy.bIsRail;
	self.bIsRoad 				:= _proxy.bIsRoad;
	self.bIsAirport 			:= _proxy.bIsAirport;
	self.bIsMultiModal 			:= _proxy.bIsMultiModal;
	self.bIsPostalExchange 		:= _proxy.bIsPostalExchange;
	self.bIsFixedTransport 		:= _proxy.bIsFixedTransport;
	self.bIsBorderCrossing 		:= _proxy.bIsBorderCrossing;
	self.usLocationID			:= _proxy.usLocationID;
end;</source>
        <Parameter name="_proxy" type="CM_Port"/>
    </JadeMethod>
