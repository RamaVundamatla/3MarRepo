    <JadeMethod name="doBtnLock" id="0fa8661e-e066-4588-8980-5e11d4363e8f">
        <updating/>
        <source>doBtnLock() updating, protected;

vars

begin
	if (not self.btnLock.value) then
		if self.btnNSEWChanges.value then
			self.doBtnWharfAndTimeChanges(true);
		elseif self.btnTimeChanges.value then
			self.doBtnTimeChangesOnly(true);
		else
			self.doBtnWharfChangesOnly(true);
		endif;
	else
		self.controlMoveStyle := Move_None;
	endif;

	if self.myCurrentWorkingMovement &lt;&gt; null then
		if self.btnLock.value then
			self.myCurrentWorkingMovement.myWorkingVoyage.voyageStatus := HMS_VoyageIsLocked;
		else
			self.myCurrentWorkingMovement.myWorkingVoyage.voyageStatus := HMS_VoyageStateNormal;
		endif;
		self.myCurrentWorkingMovement.myWorkingVoyage.voyageStatusHasChanged := true;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
