    <JadeMethod name="btnSlotAdd_click" id="dc276fea-cd59-46dd-ac25-ad58fd24c7d6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSlotAdd_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
16 Oct 2023     navlc30 ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)
31 Jul 2024 	navbs1 	Bug 64332: FR | 53729 - Delivery Dispatch screen - 1239 error
*/


vars
	slotMaintForm : CMUI_VehicleBookingItemMaint;
begin

	self.setPxyVehicleBookTimeSlot(self.myProxyVehicleBookingTimeSlot, true);
	slotMaintForm := app.loadForm(CMUI_VehicleBookingItemMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingItemMaint;
	if slotMaintForm &lt;&gt; null then
		if self.txtCopySlots.text.Integer &gt; 1 then
			slotMaintForm.setMode(slotMaintForm.MODE_BULK_ADD);
		else
			if self.vehicleBookingMode = MODE_ADD or self.vehicleBookingMode = MODE_UPDATE then
				slotMaintForm.setMode(slotMaintForm.MODE_ADD);
			else
				slotMaintForm.setMode(slotMaintForm.MODE_BULK_ADD);
			endif;
		endif;
		slotMaintForm.setParentForm(self);
		//slotMaintForm.show;																			//16.10.2023 navlc30 #58996
		slotMaintForm.showModal;																		//16.10.2023 navlc30 #58996
	endif;
	self.adjustTxtCopySlotsControl();																	//31.07.2024 navbs1 #64332
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSlotDelete_click" id="31705d5c-67ff-49a9-97a6-41f6c93408fd">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSlotDelete_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22/07/2022 		navcs2  ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
31 Jul 2024 	navbs1 	Bug 64332: FR | 53729 - Delivery Dispatch screen - 1239 error
*/

vars
	vbsItemToDelete : CM_VehicleBookingTSItemSet;
	vbsSlotItem		: CM_VehicleBookingTimeSlotItem;
	
begin
	
	create vbsItemToDelete transient;
	
	self.tblSlotItems.allSelectedObjects.copy(vbsItemToDelete);
	
	foreach vbsSlotItem in vbsItemToDelete do 
		self.myProxyVehicleBookingTimeSlot.allVehicleBookingItems.remove(vbsSlotItem);
		delete vbsSlotItem;
	endforeach;
	
	self.populateTableBookingItems();
	self.adjustTxtCopySlotsControl();				//31.07.2024 navbs1 #64332
	
epilog
	vbsItemToDelete.purge();
	delete vbsItemToDelete;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSlotEdit_click" id="e052c84e-63b6-44d5-9909-30acc0d749ed">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSlotEdit_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/07/2022  navcs2  ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
16 Jan 2023 navhl20 Bug 62053: FR | 53429 - VBS prompts error when adding multiple Release Request lines.
31 Jul 2024 navbs1 	Bug 64332: FR | 53729 - Delivery Dispatch screen - 1239 error
24 Sep 2024 navbs1	Bug 66259: FR | 53729 - Delivery Dispatch screen - wrong Job Type &amp; 1239 error - Part 2
*/

vars
	slotMaintForm : CMUI_VehicleBookingItemMaint;
	prxyVBSItem	  : CM_VehicleBookingTimeSlotItem;
begin
	prxyVBSItem := self.tblSlotItems.allSelectedObjects.first.CM_VehicleBookingTimeSlotItem;			
	if prxyVBSItem &lt;&gt; null  then																		//24.09.2023 navbs1	#66259
		
		slotMaintForm := app.loadForm(CMUI_VehicleBookingItemMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingItemMaint;
		/*
		//16.01.2023 navhl20 #62053
		if self.vehicleBookingMode = self.MODE_UPDATE then
			slotMaintForm.setMode(slotMaintForm.MODE_UPDATE);
		else
			slotMaintForm.setMode(slotMaintForm.MODE_BULK_UPDATE);
		endif;*/
		//slotMaintForm.setMode(slotMaintForm.MODE_UPDATE);			//16.01.2023 navhl20 #62053 		//24.04.2023 navbs1	#66259
		if slotMaintForm &lt;&gt; null then
		
			if self.txtCopySlots.text.Integer &gt; 1 then													//24.09.2023 navbs1	#66259
				slotMaintForm.setMode(slotMaintForm.MODE_BULK_UPDATE);
			else
				if self.vehicleBookingMode = MODE_ADD or self.vehicleBookingMode = MODE_UPDATE then
					slotMaintForm.setMode(slotMaintForm.MODE_UPDATE);
				else
					slotMaintForm.setMode(slotMaintForm.MODE_BULK_UPDATE);
				endif;
			endif;
			
			if prxyVBSItem &lt;&gt; null then
				slotMaintForm.setProxyVBSItem(prxyVBSItem);
			endif;
			slotMaintForm.setParentForm(self);
			slotMaintForm.showModal;								//31.07.2024 navbs1 #64332						
		endif;
		self.adjustTxtCopySlotsControl();							//31.07.2024 navbs1 #64332
	endif;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
