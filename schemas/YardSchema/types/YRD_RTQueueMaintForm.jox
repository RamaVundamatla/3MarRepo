    <JadeMethod name="doCancel" id="784303ec-1c30-445f-b885-d4b2ad3092d1">
        <updating/>
        <source>doCancel(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
	if self.tblMain.hasChanged then
		theReturn := app.msgBox("You have changed data, do you want to abandon your changes?","Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		return (theReturn = MsgBox_Return_Yes);
	endif;
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCmbDirectionClick" id="c7e838c8-dfca-42bb-8730-afa0d07495ef">
        <updating/>
        <source>doCmbDirectionClick() protected, updating;
// -------------------------------------------
// Created 19 January 2005 by cnwdvb1
// -------------------------------------------
vars

	isUni : Boolean;

begin

	isUni := self.cmbDirectional.listIndex &lt;&gt; 1 ;
	
	if isUni and (self.cmbType.getCurrentItemData = QTYPE_SUBQUEUE or self.cmbType.getCurrentItemData = QTYPE_VOYAGEYARD ) then
		self.tblMain.hideRowByName(ETRow_Area1Opts,false);
		self.tblMain.hideRowByName(ETRow_Area2Opts,false);
	else
		self.tblMain.showRowByName(ETRow_Area1Opts,false);
		self.tblMain.showRowByName(ETRow_Area2Opts,false);
	endif;
	
	self.tblMain.adjustHeight(100);
	self.resize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doComboAreaClick" id="03334b31-3ae2-40e1-98f6-fcc7e77c3e7e">
        <updating/>
        <source>doComboAreaClick(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	area, theArea1, theArea2 : CM_TerminalAreaMaster;
	theQueue : CM_SubQueue;
begin
	self.tblMain.setValueByControlName(combobox.name,combobox.text);

	if combobox.listIndex &gt; 0 then
		if combobox.itemObject[combobox.listIndex] &lt;&gt; null then
			area := combobox.itemObject[combobox.listIndex].CM_TerminalAreaMaster;
		endif;
	endif;

	if combobox = self.cmbArea1 then
		theArea1 := area;
	else
		theArea2 := area;
	endif;
	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CM_SubQueue) then	
			theQueue := self.myCurrentObject.CM_SubQueue;
			self.doDisplayGroupLocations(theQueue);
		endif;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doComboCranesClick" id="62394d2e-c223-4a9f-bcc5-797bc25f3e01">
        <updating/>
        <source>doComboCranesClick() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theCrane	: CM_Crane;
	theID		: String;
	
begin

	theCrane := self.cmbCranes.myObject.CM_Crane;
	if theCrane = null then
		return;
	endif;
	
	if self.cmbType.getCurrentItemData =  QTYPE_CRANE then
		theID := self.tblMain.getValueByName(ETRow_Parent).String;
		theID := theID &amp; " " &amp; theCrane.id;
		self.tblMain.setValueByName(ETRow_Id,theID);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboTypeClick" id="d694c4d1-8669-4728-8013-17fa5cf507cc">
        <updating/>
        <source>doComboTypeClick() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08 Oct 2009	cnwkpd1		PAR #21238 - Fix up entry for Voyage Crane Queues
// ---------------------------------------------------------------------------

vars
	isSubQueue : Boolean;
	idx: Integer;
begin

	self.tblMain.setValueByControlName(self.cmbType.name,self.cmbType.text);
	
	self.doBuildComboParent(self.cmbType.getCurrentItemData );
	isSubQueue:=self.cmbType.getCurrentItemData = QTYPE_SUBQUEUE or self.cmbType.getCurrentItemData = QTYPE_VOYAGEYARD ; 
	
	self.shtFromAreas.visible :=isSubQueue or self.cmbType.getCurrentItemData = QTYPE_RTG or self.cmbType.getCurrentItemData = QTYPE_RMG;
	self.shtToAreas.visible := isSubQueue;
	self.grpFrmLocations.visible := isSubQueue;
	self.grpToLocations.visible := isSubQueue;
	self.lblFrom.visible := isSubQueue;
	self.lblTo.visible := isSubQueue;
	
	self.shtMachineTypes.visible := isSubQueue;
	self.shtRTGBays.visible:=self.cmbType.getCurrentItemData = QTYPE_RTGSUBQUEUE;
	
	self.tblMain.enableRowByName(ETRow_Id);
	
	if self.cmbType.getCurrentItemData = QTYPE_SUBQUEUE  then
		self.tblMain.showHideRowsByViewName("SubQView",CM_EntryTable.ShowHideRows, false);
		self.doDisplayGroupLocations(null);
	elseif self.cmbType.getCurrentItemData = QTYPE_VOYAGEYARD  then
		self.tblMain.showHideRowsByViewName("VoyageYardQView",CM_EntryTable.ShowHideRows, false);
		self.doDisplayGroupLocations(null);
	elseif  self.cmbType.getCurrentItemData = QTYPE_VOYAGE then
		self.tblMain.showHideRowsByViewName("VoyageQView",CM_EntryTable.ShowHideRows, false);
		
	elseif  self.cmbType.getCurrentItemData = QTYPE_CRANE then
		self.tblMain.disableRowByName(ETRow_Id);
		self.tblMain.showHideRowsByViewName("CraneQView",CM_EntryTable.ShowHideRows, false);
		self.doComboCranesClick();
		self.cmbDiscMachMode.setIndexForItemData(self.myTerminal.getConfig(DefVoyCraneQDischMode).Integer);
		self.tblMain.setValueByName(ETRow_DischargeMachineHandover,self.cmbDiscMachMode.text);
		self.cmbLoadMachMode.setIndexForItemData(self.myTerminal.getConfig(DefVoyCraneQLoadMode).Integer);
		self.tblMain.setValueByName(ETRow_LoadMachineHandover,self.cmbLoadMachMode.text);
		
	elseif self.cmbType.getCurrentItemData = QTYPE_RTGSUBQUEUE then
		self.tblMain.showHideRowsByViewName("RTGSubQView",CM_EntryTable.ShowHideRows, false);
		
	elseif self.cmbType.getCurrentItemData = QTYPE_RTG or
		self.cmbType.getCurrentItemData = QTYPE_RMG then
		self.tblMain.showHideRowsByViewName("RTGQView",CM_EntryTable.ShowHideRows, false);
		idx := self.cmbParent.findObject(self.myTerminal.radioTelemetry.masterQueue);
		if idx &gt; 0 then
			self.cmbParent.listIndex := idx;
			self.cmbParent.click(self.cmbParent);
		endif;
		self.doDisplayGroupLocations(null);
	elseif self.cmbType.getCurrentItemData = QTYPE_WORKPOINT then
		self.tblMain.showHideRowsByViewName("WorkPointQView",CM_EntryTable.ShowHideRows, false);
	endif;
	
	self.tblMain.optimiseTableHeight;
	self.resize();
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboWorkPointsClick" id="13f4db96-345d-4fde-924a-f9d4489983f9">
        <source>doComboWorkPointsClick() protected;
/*

