    <JadeMethod name="pxyCreateUpdateProxy" id="a21dcf96-eeec-4724-aa58-68cab7a2b418">
        <source>pxyCreateUpdateProxy(): SelfType;

// cnwdvb1 10 June 2003 
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	autoTask : CM_AutoTask;
	completedOK		: Boolean;
	
begin

	autoTask := inheritMethod();
	autoTask.myTerminal := self.myTerminal;
	autoTask.myUser		:= self.myUser;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return autoTask;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete autoTask;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3feaf949-37ee-4be1-84f4-579853500fbd">
