    <JadeMethod name="setMeasurementValue" id="dc2bc2d7-d3d9-4840-b3f5-c42795423582">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10 May 2013	cnwdap1		Initial creation PAR #
//
vars

begin
	if _entRowName.isOneOf(ETRow_TotalWeight, ETRow_MyWeight, ETRow_WeightTotal) then
		self.weight := _value;
	elseif _entRowName = ETRow_MyHeight then
		self.height := _value;
	elseif _entRowName = ETRow_MyLength then
		self.length := _value;
	elseif _entRowName = ETRow_MyWidth then
		self.width := _value;
	elseif _entRowName = ETRow_MyVolume then
		self.volume := _value;
	elseif _entRowName = ETRow_MyDensity then
		self.density := _value.Integer;
	else
		inheritMethod(_entRowName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setMyProxyTrackedItem" id="0c9ebb37-09c6-420e-9caf-5bdb60ac3832">
        <updating/>
        <source>setMyProxyTrackedItem(pTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
