    <JadeMethod name="getInvoicesForReport" id="535c23b4-d105-4c86-ac36-761a2da76a82">
        <source>getInvoicesForReport(_objArray : ObjectArray input; _selectedOnly : Boolean);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars

begin
	
	//Being used for invoices so copy directly from the data table based on whether our menu selection.
	if _selectedOnly then
		self.tblData.allSelectedObjects.copy(_objArray);
	else
		self.tblData.getAllRowObjects(_objArray);
	endif;
	
epilog

end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMyTrackedItem" id="4a7b66c8-5dd9-4d30-9253-223ff930a302">
        <source>getMyTrackedItem(	_id			: String;
					_cargoType	: CM_CargoType;
					_operator	: CM_Operator;				//12 Dec 2019	NDL	TFS 47954
					_location	: CM_LocationsController	//12 Dec 2019	NDL	TFS 47954
				) : CM_TrackedItem protected;
/* ---------------------------------------------------------------------------
Created:	11 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// 16 Oct 2019	jlgzm1	TFS 46054 INV_ListLines now allowing searching for cargo without a cargotype
// 14 Feb 2020  cnwma1	Bug 48578: ADP - RE: changes on adding Manual Invoice lines
------------------------------------------------------------------------------*/
vars
	tiSet	    : CM_TISet;
	ti		    : CM_TrackedItem;
	cargoTypeId : Integer;
	iter        : Iterator;
begin

	if _id = null then
		return null;
	endif;
	 
	if _cargoType &lt;&gt; null then 			// TFS 46054
		cargoTypeId := _cargoType.id;	// TFS 46054
	endif;
	
	create tiSet transient;
	
	self.myTerminal.lookupAllOnsiteTrackedItems(cargoTypeId, _id, tiSet, false, null);
	
	//cnwmc5 - 22 Feb 2016 - PAR 37550 - check onship if not onsite..
	if tiSet.isEmpty then
		self.myTerminal.lookupAllOnShipTrackedItems(_id, cargoTypeId, false, false, false, tiSet, null);
	endif;
	
	if tiSet &lt;&gt; null then
		foreach ti in tiSet do
			if ti.id &lt;&gt; _id then
				break;
			endif;
			if _cargoType &lt;&gt; null and ti.myCargoType &lt;&gt; _cargoType then
				break;
			endif;
			if _operator &lt;&gt; null and ti.myOperator &lt;&gt; _operator then
				continue;
			endif;
			if _location &lt;&gt; null and ti.myPrimaryActualLocation &lt;&gt; _location then
				continue;
			endif;
			
			return ti;
			
		endforeach;
	endif;
	
	// when tiSet is null - to check offsite
	//return self.myTerminal.lookupOffsiteTrackedItem(cargoTypeId, _id, true);
	if _location = null then
		iter := self.myTerminal.allOffsiteTIsByIdCargoType.createIterator;
	    self.myTerminal.allOffsiteTIsByIdCargoType.startKeyGeq(_id,cargoTypeId,null, iter);  //14.02.2020 cnwma1 #48578
		while iter.next( ti ) do
			if ti.id &lt;&gt; _id then
				break;
			endif;
			if _cargoType &lt;&gt; null and ti.myCargoType &lt;&gt; _cargoType then
				break;
			endif;
			if _operator &lt;&gt; null and ti.myOperator &lt;&gt; _operator then
				continue;
			endif;	
			return ti;
		endwhile;
	endif;
	
	return null;
	
epilog
	delete tiSet;
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTableColumFilters" id="753b2685-45c4-4aa1-9670-3a58f60f0a99">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2013	cnwjre1	Initial creation

*/

vars

begin
	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );
	
epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="567527b5-eb44-42f9-a4f3-63e2f289a8bf">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 11 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
// ---------------------------------------------------------------------------

vars
	theXML : String;
	hideMacro : Boolean;
begin
	hideMacro :=  (self.mnuContextHide.caption = self.MNU_MACRO_SHOW);
	

	theXML := inheritMethod();
	theXML := theXML &amp; global.formatAsXML("HM",hideMacro.Integer.String);
	theXML := theXML &amp; self.tblData.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblRatesOR.getXmlStrForColumns(true);
	theXML := theXML &amp; global.formatAsXML(self.btnIncludeArchive.name, self.btnIncludeArchive.value.String);		//11.9.2023 navhl20 #59376
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="66e9f961-d94d-439c-9783-9371196a64bb">
        <source>getXMLSettingsForSetup();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 11 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
// ---------------------------------------------------------------------------

vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	hideM : Boolean;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	// #### HIDE MACRO
 	theXMLValue := theXML.cnEcGetTagValueOfName("HM");
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
 	
 	if hideM then
 		self.splMain.hideRightControl(true);
 		self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
 	endif;
	 
	theXMLValue := theXML.cnEcGetTagValueOfName(self.btnIncludeArchive.name);		//11.9.2023 navhl20 #59376
	self.btnIncludeArchive.value := theXMLValue &lt;&gt; null and theXMLValue.Boolean;	//11.9.2023 navhl20 #59376
end;</source>
    </JadeMethod>
    <JadeMethod name="haltProgress" id="4913e6b3-937c-4fce-9887-ce488de73824">
        <source>haltProgress(pe : CM_ProgressException) : Integer;

vars

begin

	if app.msgBox(self.myCurrentBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		return Ex_Abort_Action;
	else
		return Ex_Continue;
	endif;

end;</source>
        <Parameter name="pe" type="CM_ProgressException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleCargoWeighedWarning" id="27c7847a-84c2-487a-bdd1-5e4ceb421ffb">
        <source>handleCargoWeighedWarning( exObj: Exception ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2019	jlgndl1	Initial creation

*/

constants
	
vars

begin

	if exObj.isKindOf(CM_Exception)
	and exObj.CM_Exception.isWarning
	and exObj.errorCode = Cargo_weighed_invoiced
	then
		app.myPassport.addWarningFull(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, exObj.CM_Exception.mySubject);

		return Ex_Continue;
	endif;

	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="cb957bb8-f839-41c1-aeb1-0ebde680fc15">
        <source>includeObject(_invoice : CM_Invoice) : Boolean;

vars
	rt, invalidINV : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _invoice, invalidINV); // PAR 17226

	// PAR 13231. Do not remove from list if the update was done by the current user.
	if _invoice = self.myCurrentInvoice then 
		return true;
	endif;
	
	rt := true;
	
	if self.filterBussinessUnits &lt;&gt; null then
		if _invoice.bank &lt;&gt; self.filterBussinessUnits then
			return false;
		endif;
	endif;
	
	if self.filterDebtor &lt;&gt; null then
		if _invoice.debtor &lt;&gt; self.filterDebtor then
			return false;
		endif;
	endif;

	if self.filterStatus &lt;&gt; -1 then
		if _invoice.status &lt;&gt; self.filterStatus then
			return false;
		endif;
	endif;
	
	if self.filterType &lt;&gt; -1 then
		if _invoice.invoiceType.number &lt;&gt; self.filterType then
			return false;
		endif;
	endif;
	
	if self.filterVoyage &lt;&gt; null then
		if _invoice.myVoyage &lt;&gt; self.filterVoyage then
			return false;
		endif;
	endif;
	
	if self.filterTI &lt;&gt; null then	//Par17895. September 2008
		if _invoice.myTrackedItem &lt;&gt; self.filterTI then
			return false;
		endif;
	endif;
	
	return rt;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initInvPropTable" id="beadefff-be4a-453d-9bf5-b17a1cf6765c">
        <source>initInvPropTable(_enTableDef : String);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin
	//epr par 36958 28/9/15
	self.frmInvProperties.width := self.frmInvProperties.clientWidth - 10;
	self.frmInvProperties.left := 5;	
	self.frmInvProperties.top := self.frmInvToolbar.clientHeight + 5;
	
	self.frmInvPropParent.move(1,self.frmInvToolbar.clientHeight + 4,self.frmInvProperties.clientWidth - 2,
								self.frmInvProperties.height - self.frmInvToolbar.clientHeight - 2);

	theTable := self.tblInvProperties;
	theTable.warningMethod := 'entTableWarning';
	
	theTable.left:=0;
	theTable.top:=0;
	theTable.width:=self.frmInvPropParent.clientWidth;
	theTable.accessColumn(1).width := 100;
	theTable.accessColumn(2).width := (theTable.width - 100).Integer;
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	
	self.frmInvToolbar.width:=self.frmInvProperties.clientWidth;
	self.frmInvToolbar.positionToolbarControls();
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	
	entTableDef := app.myController.getEntTableDef(	_enTableDef);

	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	// ### TFS BUG 64249 23MAY2024 NAVAB1
	if app.doNotFIlterCombos then
		self.cmbVoyage.style := ComboBox.Style_DropDownList;
		self.cmbVoyageInvProp.style := ComboBox.Style_DropDownList;
		self.cmbCargoVoyage_.style := ComboBox.Style_DropDownList;
	endif;
end;</source>
        <Parameter name="_enTableDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="733a6b55-59b4-41b6-8d86-b569e23c829e">
        <updating/>
        <source>initQueryFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 03 Jun 2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
// 24 Feb 2023	navmv20 TFS 56403 Task 56460: Jade - Selector Category collection
// 29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
// 11 Sep 2023  navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
