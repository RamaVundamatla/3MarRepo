    <JadeMethod name="performInstantAction" id="14ffabeb-b736-4f00-8c77-2f696d900b24">
        <updating/>
        <source>performInstantAction(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]

*/

vars
	woActionIF : CMIF_WorkOrderAction;
	result 	   : Integer;
begin


	if not self.canPerformInstantAction() then
		return false;
	endif;

	create woActionIF transient;
	woActionIF.myWorkOrderDtl 		 := self;
	//woActionIF.numberFromKnownCargo  := self.totalUnactioned;				//08.02.2023 navma1 #56457 Task#56458
	woActionIF.numberFromKnownCargo  := self.allSelectedTIs.size;			//08.02.2023 navma1 #56457 Task#56458
	woActionIF.populateFromAvailable := true;
	
	while true do
		
		app.myTrxCA.trxCreateWorkOrderAction(woActionIF, app.myPassport); 
		if app.myPassport.trxCompletedOK then
			return true;
		else
			result := app.showErrorWarningDialog("Work Order Action", app.myPassport, 20);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	return false;
	
epilog

	delete woActionIF;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="prepareAuditDetail" id="7e8e8c54-d893-4bab-ab72-2ca638c840ee">
        <source>prepareAuditDetail(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
20 Apr 2023 Defect  57661: MTN - WO - On the Audit details myPinNo is not showing the actual pin number
04 Jul 2023	jlirs1	TFS 58884 (57807) the allSelectedTIs may already be deleted
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	tmpStr 		: String;
	wodTodo 	: CM_WodToDo;
	todoTask	: CM_ToDoTaskDesc;
	ti			: CM_TrackedItem;
	pinNo		: String;
	invalidTI   : Boolean;
	transport	: Integer;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);      // 04 Jul 2023	jlirs1	TFS 58444 (57807)
	
	tmpStr := app.workOrderStatusEnumToString(self.status) &amp;" "&amp; tmpStr;
	_str   := _str &amp; app.getErrorString(Status) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	foreach wodTodo in self.allToDoRequests discreteLock do
		foreach todoTask in wodTodo.allToDoTasksDescs discreteLock do
			if tmpStr = null then
				tmpStr := todoTask.description;
			else
				tmpStr := tmpStr &amp; Comma &amp; todoTask.description;
			endif;
		endforeach;
	endforeach;
	_str := _str &amp; app.getErrorString(Tasks) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	/*
	31.03.2025 navma1 #MTN-34387
	tmpStr := null;
	foreach ti in self.allSelectedTIs do
		if tmpStr = null then
			tmpStr := ti.id;
		else
			tmpStr := tmpStr &amp; Comma &amp; ti.id;
		endif;
	endforeach;
	_str := _str &amp; "Selected Cargo's" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	*/
	
	tmpStr    := null;
	transport := self.getTransport();
	if transport &lt;&gt; null then
		tmpStr := app.transportModeENumToString(transport) &amp;" "&amp; tmpStr ;
		_str := _str &amp; "Transport" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	
	//20.04.2023 navma1 #57661
	tmpStr := null;
	pinNo  := self.getPINNumber();
	if pinNo &lt;&gt; null then
		tmpStr := pinNo;
		_str := _str &amp; "Pin No" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f839586d-d798-43b2-860e-fff6d23afc12">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 Aug 2009	cnwmd1	Initial creation
20 Apr 2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when trying to create the proxy
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	pxy 			: SelfType;
	completedOK		: Boolean;
	wodToDo		    : CM_WodToDo;
	pxyWodToDo 		: CM_WodToDo;
begin
	
	pxy := inheritMethod();

	self.allActionedTIs.copy(pxy.allActionedTIs);
	self.allAvailableTIs.copy(pxy.allAvailableTIs);
	self.allCompleteTIs.copy(pxy.allCompleteTIs);
	self.allJobs.copy(pxy.allJobs);
	self.allSchedules.copy(pxy.allSchedules);
	self.allTxnsCompleted.copy(pxy.allTxnsCompleted);
	self.allSelectedTIs.copy(pxy.allSelectedTIs);			//08.02.2023 navma1 #56457 Task#56458
	
	//11 Jul 2018	NDL	TFS 39638
	foreach wodToDo in self.allToDoRequests do
		pxyWodToDo := wodToDo.pxyCreateUpdateProxy();
		pxyWodToDo.setMyWorkOrderDetail( pxy );
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeTIAvailable" id="e6b85f14-dac1-4a50-af72-fa29f2d28db3">
        <source>removeTIAvailable( _theTI : CM_TrackedItem );

/*

Purpose: remove an available ti from my available list.		

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2009	cnwrd1	Initial creation

*/

vars

begin

	
	if _theTI = null then
		return;
	endif;

	if self.allAvailableTIs.includes(_theTI) then		
		self.allAvailableTIs.remove( _theTI);
	endif;
	

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="deb0e2a8-8d3c-4463-818b-15cb4788fe93">
        <updating/>
        <source>setForCreate(_pxyWoDDtl: CM_WorkOrderDtl io; realWorkOrder : CM_WorkOrder) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
12 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
*/

vars

begin
	inheritMethod(_pxyWoDDtl, realWorkOrder);
	if _pxyWoDDtl.status &gt; 0 then
		self.setStatus(_pxyWoDDtl.status);				//12.5.2023 navhl20 #56631[56185]
	else
		self.setStatus(WO_STATUS_USERENTRY);			//08.02.2023 navma1 #56457 Task#56458
	endif;
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl" usage="io"/>
        <Parameter name="realWorkOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ced6a6fd-07b2-4771-8114-ed52190a2b6b">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WorkOrderDtl) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
19 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
19 Apr 2023 navhl20 Defect 57648: MTN - Issues when actioning the multiple Receive Cargo Work Order tasks
12 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
21 Dec 2023 navhl20 Bug 61861: EUP | Work Order Transport Mode change - issues
11 Apr 2025 navsaa30 12349-EUP - Transport Manifest load after locking does not add all cargo to work order
*/

vars
	proxy 		: CM_WorkOrderTIDtl;
	ti 			: CM_TrackedItem;
	wodToDo 	: CM_WodToDo;
	deletes 	: CM_WorkOrderToDoSet;
	pxyWodToDo  : CM_WodToDo;
	toDoTask	: CM_ToDoTaskDesc;
begin
	inheritMethod(_pxyWoDDtl);
	
	proxy := _pxyWoDDtl.CM_WorkOrderTIDtl;

	self.totalActioned 		:= proxy.totalActioned;
	self.totalComplete 		:= proxy.totalComplete;
	self.totalUnactioned	:= proxy.totalUnactioned;
	
	//collections
	self.allActionedTIs.clear();
	proxy.allActionedTIs.copy(self.allActionedTIs);
	exclusiveLock(self.allSelectedTIs);							//11/4/2024 navsaa30 #12349
	self.allSelectedTIs.clear();								//08.02.2023 navma1 #56457 Task#56458
	proxy.allSelectedTIs.copy(self.allSelectedTIs);				//08.02.2023 navma1 #56457 Task#56458
	
	self.allAvailableTIs.clear();
	proxy.allAvailableTIs.copy(self.allAvailableTIs);			//08.02.2023 navma1 #56457 Task#56458
	
	
	self.allJobs.clear();
	proxy.allJobs.copy(self.allJobs);		
	
	self.allTxnsCompleted.clear();
	proxy.allTxnsCompleted.copy(self.allTxnsCompleted);		
	
	//11 Jul 2018	NDL	TFS 39638
	create deletes transient;
	foreach wodToDo in self.allToDoRequests do
		foreach toDoTask in wodToDo.allToDoTasksDescs do									//15.3.2023 navhl20	#56614[56615]
			//if not proxy.allToDoRequests.includesToDo( wodToDo.myToDoTaskDesc ) then		//15.3.2023 navhl20	#56614[56615]
			if not proxy.allToDoRequests.includesToDo( toDoTask ) then						//15.3.2023 navhl20	#56614[56615]
				deletes.addNoDuplicates( wodToDo, false );									//15.3.2023 navhl20	#56614[56615]
			endif;
		endforeach;																			//15.3.2023 navhl20	#56614[56615]
	endforeach; 
	
	if not deletes.isEmpty then
		deletes.purge();
	endif; 
	
	/*
	//30.3.2023 navhl20	#56614[56615]
	foreach pxyWodToDo in proxy.allToDoRequests do
		foreach toDoTask in pxyWodToDo.allToDoTasksDescs do									
			//if not proxy.allToDoRequests.includesToDo( pxyWodToDo.myToDoTaskDesc ) then	
			if not self.allToDoRequests.includesToDo( toDoTask ) then						
				create wodToDo persistent;
				wodToDo.setForUpdate( pxyWodToDo );
				wodToDo.setMyWorkOrderDetail( self );
			endif;
		endforeach;																			
	endforeach;*/
	
	if proxy.allToDoRequests.isNotEmpty then												//30.3.2023 navhl20	#56614[56615]
		if not self.allToDoRequests.isNotEmpty then								
			create wodToDo persistent;
			wodToDo.setForUpdate( proxy.allToDoRequests.first );
			if proxy.status &gt; 0 then
				wodToDo.setStatus(proxy.status);											//12.5.2023 navhl20 #56631[56185]
			else
				wodToDo.setStatus(WO_STATUS_USERENTRY);										//19.4.2023 navhl20	#57648		
			endif;
			wodToDo.setMyWorkOrderDetail( self );
		else
			foreach pxyWodToDo in proxy.allToDoRequests do	
				self.allToDoRequests.first.setForUpdate( proxy.allToDoRequests.first );		//21.11.2023 navhl20 #61861
				foreach toDoTask in pxyWodToDo.allToDoTasksDescs do
					if not self.allToDoRequests.includesToDo(toDoTask) then
						foreach wodToDo in self.allToDoRequests do
							wodToDo.allToDoTasksDescs.addNoDuplicates(toDoTask,false);
						endforeach;
					endif;
				endforeach;
			endforeach;
		endif; 
	endif;
	
epilog
	delete deletes;
end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyAllToDoRequests" id="6c26a1e5-b155-4bc1-b223-b3576b8aa046">
        <updating/>
        <source>setProxyAllToDoRequests( _todoSet : CM_ToDoTaskDescSet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2018	jlgndl1	Initial creation	TFS 39638
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
17 Jan 2023 navhl20 ChangeRequest 58760:[61583] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order
*/

vars

	wodToDo : CM_WodToDo;
	deletes : CM_WorkOrderToDoSet;
	toDo 	: CM_ToDoTaskDesc;

begin
	// this one is to set values on the proxy.
	self.raiseExceptionIfNotTransient(method);
	
	create deletes transient;
	foreach wodToDo in self.allToDoRequests do
		foreach toDo in wodToDo.allToDoTasksDescs do						//15.3.2023 navhl20	#56614[56615]
			//if not _todoSet.includes( wodToDo.myToDoTaskDesc ) then		//15.3.2023 navhl20	#56614[56615]
			if not _todoSet.includes( toDo ) then							//15.3.2023 navhl20	#56614[56615]
				deletes.addNoDuplicates( wodToDo, false );					//15.3.2023 navhl20	#56614[56615]
			endif;
		endforeach;															//15.3.2023 navhl20	#56614[56615]
	endforeach;
	
	if not deletes.isEmpty then
		deletes.purge();
	endif; 
	
	if self.allToDoRequests.isEmpty and _todoSet.isNotEmpty then			//30.3.2023 navhl20	#56614[56615]
		create wodToDo transient;
		wodToDo.allToDoTasksDescs.clear();									//27.3.2023 navhl20	#56614[56615]
		foreach toDo in _todoSet do
			wodToDo.allToDoTasksDescs.addNoDuplicates(toDo,true);			//27.3.2023 navhl20	#56614[56615]
		endforeach;
		wodToDo.setMyWorkOrderDetail( self );
		wodToDo.setRequiredByDT(self.requiredByDT);							//02.06.2023 navma1 #58296
	else
		foreach wodToDo in self.allToDoRequests do							//30.3.2023 navhl20	#56614[56615]
			foreach toDo in _todoSet do
				if not wodToDo.allToDoTasksDescs.includes(toDo) then
					wodToDo.allToDoTasksDescs.addNoDuplicates(toDo,false);
				endif;
			endforeach;
			wodToDo.setRequiredByDT(self.requiredByDT);						//17.01.2023 navhl20 #58760[61583]
		endforeach;
	endif; 

epilog
	delete deletes;
end;</source>
        <Parameter name="_todoSet" type="CM_ToDoTaskDescSet"/>
    </JadeMethod>
    <JadeMethod name="setTIActioned" id="fff77e5e-91c4-4f5d-a40d-29b53f3a40e8">
        <updating/>
        <source>setTIActioned(_theTI : CM_TrackedItem; _updateCounts : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
19 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	unActionedCount : Integer;
begin
	
	if _theTI = null then
		return;
	endif;

	/*
	08.02.2023 navma1 #56457 Task#56458
	if self.allAvailableTIs.includes( _theTI) then
		self.allAvailableTIs.remove( _theTI);
	endif;
	
	if not self.allActionedTIs.includes( _theTI) then
		self.allActionedTIs.add( _theTI);
		 
		if _updateCounts then
			//self.totalActioned    := self.totalActioned +1;
			//self.totalUnactioned  := self.totalUnactioned -1;
			self.totalActioned      := self.allActionedTIs.size;									//19.01.2023 navma1 #56141 Task#56147
			unActionedCount         := self.allAvailableTIs.size - self.allActionedTIs.size;		//19.01.2023 navma1 #56141 Task#56147
			
			if unActionedCount &lt; 0 then
				unActionedCount := 0;
			endif;
			self.totalUnactioned   := unActionedCount;
		endif;
	endif;
	*/
	
	self.allAvailableTIs.tryRemoveIfNotNull( _theTI);				//08.02.2023 navma1 #56457 Task#56458	
	self.allActionedTIs.addNoDuplicates(_theTI,false);				//08.02.2023 navma1 #56457 Task#56458
	self.setStatus(WO_STATUS_ACTIONED);								//08.02.2023 navma1 #56457 Task#56458
epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_updateCounts" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTIComplete" id="eb822c5f-d8e0-4ba9-a867-754efc6dd41b">
        <updating/>
        <source>setTIComplete( _theTI : CM_TrackedItem;_toDoTaskDesc : CM_ToDoTaskDesc) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
13 Dec 2018	NDL		TFS 41379
19 Aug 2022 navma1	Bug 54324: MTN - The Work List entries are not complete for the Unpack Work Order
23 Aug 2022 navma1	Bug 54297: MTN - Pack Work Order issues
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
01 Sep 2023 navhl20 ChangeRequest 59121: EUP | Handle Work orders Packing  By Type
05 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
22 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
19 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
29 May 2024 navhl20 Bug 64345: EUP - Retrospective Partial Discharge not wokring.
*/

vars
	parent	 	: CM_WorkOrderTI;
	doComplete  : Boolean;
	todoTaskDesc: CM_ToDoTaskDesc;
	release		: CM_BulkRelease;
	reserve		: CM_ReserveDetail;
begin
	
	if _theTI = null then
		return;
	endif;
	
	if self.allCompleteTIs.includes(_theTI) then															//05.12.2023 navhl20 #58400[61617]
		if self.getTransport() = TI_TRANSMODE_SHIP then
			self.changeStatusWoWLE(JOB_COMPLETE,_theTI,_toDoTaskDesc);
			self.setTiUpdated(_theTI);																		//19.01.2024 navhl20 #62066
			if self.isDetailCompleted() then																//29.05.2024 navhl20 #64345
				self.completeMe();
				return;
			endif;
		endif;
	endif;
	
	if self.allCompleteTIs.includes(_theTI) then		//08.02.2023 navma1 #56457:[56458]
		return;
	endif;
	
	parent := self.getMyParent.CM_WorkOrderTI;			//19.8.2022 navma1 #54324
	
	// remove from available
	self.allAvailableTIs.tryRemove( _theTI);

	//remove from actioned
	self.allActionedTIs.tryRemove( _theTI);
	
	// move to complete collection
	if not self.allCompleteTIs.includes( _theTI) then
		//because of RBT we may not have this TI on the Work order main collection
		if not parent.allTIs.includes(_theTI) then
			
			//30.08.2022 navma1 #54297
			if self.isKindOf(CM_WodPack)then
				if self.CM_WodPack.myReleaseRequest.releaseByType then
					if _theTI.myParent = null then							//08.9.2023 navhl20 #59121
						
						self.CM_WodPack.allSelectedTIs.tryAdd(_theTI);
						parent.allTIs.tryAdd(_theTI);
					else
						self.CM_WodPack.allPackingTIs.tryAdd(_theTI);	
					endif;
				
				else
					if not self.CM_WodPack.allPackingTIs.includes(_theTI) then
						if _theTI.myParent &lt;&gt; null and  parent.allTIs.includes(_theTI.myParent) then
							self.CM_WodPack.allPackingTIs.addNoDuplicates(_theTI,false);
						else
							parent.allTIs.add(_theTI);
						
						endif;
					endif;
				endif;
			else
				parent.allTIs.add(_theTI);
			endif;
		endif;
	
		//23.08.2022 navma1 #54297
		if self.isKindOf(CM_WodPack) then
			if  self.CM_WodPack.allPackingTIs.includes(_theTI) then
				doComplete := false;
			else
				doComplete := true;
			endif;
		elseif self.isKindOf(CM_WodToDo) then								//27.03.2023 navma1 #56614:[56615]
			if _theTI.allToDoTasksToDo.isEmpty then
				doComplete := true;
			else
				doComplete := true;
				foreach todoTaskDesc in self.CM_WodToDo.allToDoTasksDescs do
					if _theTI.allToDoTasksToDo.includesToDoDesc(todoTaskDesc.code) then
						doComplete := false;
					endif;
				endforeach;
			endif;
		else
			doComplete := true;
		endif;
		
		//23.08.2022 navma1 #54297
		if doComplete then
			self.allCompleteTIs.add( _theTI);
			
			//self.totalComplete := self.totalComplete + 1;				//08.02.2023 navma1 #56457:[56458]
			self.totalComplete   := self.allCompleteTIs.size;			//08.02.2023 navma1 #56457:[56458]
		endif;
		//self.createWOTransaction(TRANS_TYPE_WO_COMPLETE );			//08.02.2023 navma1 #56457:[56458]
		self.changeStatusWoWLE(JOB_COMPLETE,_theTI,_toDoTaskDesc);	//19.8.2022 navma1 #54324	//27.03.2023 navma1 #56614:[56615]  //11.09.2023 navma1 #59121
	
		if self.getTransport() = TI_TRANSMODE_SHIP then					//19.01.2024 navhl20 #62066
			self.setTiUpdated(_theTI);
		endif;
	endif;
	
	//if self.isFirstTask and parent.taskStatus = WO_STATUS_APPROVED then											//08.02.2023 navma1 #56457:[56458]
	if parent.allWoDtls.includes(self) then																			//06.03.2023 navma1 #56457:[56458]
		if not parent.isAllTasksWithStatus(WO_STATUS_COMPLETE) and parent.taskStatus = WO_STATUS_APPROVED then		//08.02.2023 navma1 #56457:[56458]
			parent.setTaskStatus(WO_STATUS_PARTCOMPLETE);
			
		endif;
	endif;
	self.setStatus(WO_STATUS_PARTCOMPLETE);																			//08.02.2023 navma1 #56457:[56458]
		
	if self.isKindOf(CM_WodPack) then																				//08.9.2023 navhl20 #59121
		release := self.CM_WodPack.myReleaseRequest;
	endif;
	
	if release &lt;&gt; null and release.allReserveDetails.isNotEmpty() then												//08.9.2023 navhl20 #59121
		reserve := release.allReserveDetails.first;
	endif;
	if release &lt;&gt; null and  release.releaseByType then																//08.9.2023 navhl20 #59121
		if reserve.totalRequested = self.allCompleteTIs.size then
			self.completeMe();
		endif;
	elseif self.getTransport() = TI_TRANSMODE_SHIP then																//05.12.2023 navhl20 #58400[61617]
		if self.isDetailCompleted() then
			self.completeMe();
		endif;
	else
		//if parent.totalRequired = self.totalComplete then					//08.02.2023 navma1 #56457:[56458]
		if self.allSelectedTIs.size = self.allCompleteTIs.size then			//08.02.2023 navma1 #56457:[56458]
			self.completeMe();
		endif;
	endif;
	
	//jlier1 29/5/25 MTN-34591 
	parent.causeTerminalEvent(Event_WorkOrder_Update);
epilog

end;
</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="setTIUnactioned" id="b2094846-406c-46d9-a9cc-fc004fef0bd6">
        <updating/>
        <source>setTIUnactioned(_theTI : CM_TrackedItem; _updateCounts : Boolean) updating;

/*

Purpose:	when deleting jobs we need to unaction TI if we have actioned one.		

Parameters:			

Return Value:		


Date		Who		Reason
15 Jan 2010	cnwrd1	Initial creation
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/


vars

begin
	
	if _theTI = null then
		return;
	endif;
	
	
	if self.allActionedTIs.includes( _theTI) then
		self.allActionedTIs.remove( _theTI);
	endif;

	if not self.allAvailableTIs.includes( _theTI) then
		 self.allAvailableTIs.add( _theTI);
		 
		 if _updateCounts then
			 self.totalActioned 	:= self.totalActioned -1;
			 self.totalUnactioned   := self.totalUnactioned +1;
		endif;
	endif;
	self.setStatus(WO_STATUS_APPROVED);								//08.02.2023 navma1 #56457 Task#56458
epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_updateCounts" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTiUpdated" id="06f27208-6992-41e7-94df-e9b0fa844c7f">
        <source>setTiUpdated(_ti : CM_TrackedItem);
/*

Purpose: To remove splitted cargo and to update selected ti and to update progress string		

Parameters:			

Return Value:		

Date		Who		Reason
10 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
03 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
*/

vars
	tiSelected		: CM_TrackedItem;
	tiOid			: String;
begin
	tiOid := _ti.getOidAsString();
	
	if _ti.hasSplitOrMergeTrans() then							//05.04.2024 navhl20 #63302
		foreach tiSelected in self.allSelectedTIs do
			if tiSelected.id = _ti.id and tiSelected.totalQuantity = 0 then
				self.allSelectedTIs.remove(tiSelected);
				self.allSelectedTIs.addNoDuplicates(_ti,false);
				self.allActionedTIs.remove(tiSelected);
			elseif tiSelected.id = _ti.id and tiSelected.getOidAsString &lt;&gt; tiOid then
				self.allSelectedTIs.tryAdd(_ti);
			endif;
		endforeach;
		self.updateObjectEdition(self.myParent);
		
		//jlier1 29/5/25 MTN-34591 
		self.myParent.causeTerminalEvent(Event_WorkOrder_Update);
	endif;
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTotalActioned" id="7edc3a3b-fa9d-40a2-9479-bc4b87d0b542">
        <updating/>
        <source>setTotalActioned( _value : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwrd1	Initial creation

*/

vars

begin
	self.totalActioned := _value;
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WODtl_Update);
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTotalUnactioned" id="0c0fe504-250e-481b-8e84-bb116a242c9f">
        <updating/>
        <source>setTotalUnactioned( _value : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwrd1	Initial creation

*/

vars

begin
	self.totalUnactioned := _value;
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WODtl_Update);
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="b0d2653b-8c02-427b-89cf-35ac0ce6c752">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2023 navma1	ChangeRequest 57301: EUP - [Framework] - Improve Audits on Work orders

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName  = CM_WorkOrderTIDtl::totalUnactioned.name 
	or propName  = CM_WorkOrderTIDtl::allActionedItemTransactions.name
	or propName  = CM_WorkOrderTIDtl::allTxnsCompleted.name
	then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="skipTiValidation" id="5bdea7d0-18b9-4b06-85cc-268da6bdec37">
        <source>skipTiValidation(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/03/2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement


*/

vars

begin
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateWObyJobGrp" id="998c059f-d768-4b39-9b8f-404fd4594817">
        <source>updateWObyJobGrp( _grpMethod : CM_WorkOrderJobGroupMethod input; _wo : CM_WorkOrder io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Sep 2023 navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
06 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	wodSet			: CM_WorkOrderDtlSet;
	dynaDict		: DynaDictionary;
	obj				: Object;
	ti				: CM_TrackedItem;
	wo				: CM_WorkOrder;
	tiSet			: CM_TISet;
	grpIdx			: Integer;
	lastTi			: CM_TrackedItem;
	lastGroup		: Integer;
	myVoyage		: CM_Voyage;
begin
	
	if not self.isKindOf(CM_WorkOrderTIDtl)  then
		return;
	endif;
	
	_wo := self.myParent.CM_WorkOrderTI;
	create wodSet transient;
	create dynaDict transient;
	create tiSet transient;
	if self.isKindOf(CM_WodReceive) then
		myVoyage := self.CM_WodReceive.myVoyage;
	elseif  self.isKindOf(CM_WodRelease) then
		myVoyage := self.CM_WodRelease.myVoyage;
	endif;
	if myVoyage &lt;&gt; null then
		_grpMethod.actionWOGrouping(myVoyage,wodSet,dynaDict,self);			//06.05.2024 navhl20 #63971
		dynaDict.clear();
		self.CM_WorkOrderTIDtl.allSelectedTIs.tryCopy(dynaDict);
		_wo.allWoDtls.remove(self);
		
		foreach obj in dynaDict do
			ti	:= obj.CM_TrackedItem;
			_grpMethod.doGroupCompare(ti,lastTi,grpIdx);
			if lastGroup = grpIdx then
				tiSet.addNoDuplicates(ti,false);
			endif;
			if lastGroup &lt;&gt; grpIdx then
				_wo.CM_WorkOrderTI.createWoDtl(self,tiSet);
			endif;
			lastTi 		:= ti;
			lastGroup	:= grpIdx;
			if lastGroup = grpIdx then
				tiSet.addNoDuplicates(ti,false);
			endif;
		endforeach;
		if lastGroup = grpIdx then
			_wo.CM_WorkOrderTI.createWoDtl(self,tiSet);
		endif;
	endif;

epilog
	delete wodSet;
	delete dynaDict;
	delete tiSet;
end;</source>
        <Parameter name="_grpMethod" type="CM_WorkOrderJobGroupMethod" usage="input"/>
        <Parameter name="_wo" type="CM_WorkOrder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validate" id="57929e2f-0981-49c0-8644-6d745a6f36d3">
        <source>validate()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Aug 2009	cnwmd1	Initial creation
04 Nov 2021 navma1  ChangeRequest 52249: MTN - Web Portal Cargo Work Orders - Cargo Type Checking when Adding a To Do Task
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
31/03/2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement

*/

vars
	ti : CM_TrackedItem;
begin
	
	if self.CM_WorkOrderTIDtl.allSelectedTIs.isEmpty and self.skipTiValidation = false then					//08.02.2023 navma1 #56457 Task#56458 //31.03.2023	navcs2  #55440:[54990]
		app.raiseCMException(Work_order_must_have_least_ti, null, null);
	endif;
	
	/*
	//08.02.2023 navma1 #56457 Task#56458
	foreach ti in self.allSelectedTIs do									//08.02.2023 navma1 #56457 Task#56458
		if ti.site = TI_SITE_OFFSITE or ti.site = TI_SITE_ONSHIP then
			app.raiseCMException(Work_order_must_have_onsit_pre, null , null);
		endif;
	endforeach;
	*/
	self.validateToDoTasks(); //04.11.2021 navma1 #52249
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateToDoTasks" id="831cb699-f1d5-439d-a510-8789041d763a">
        <source>validateToDoTasks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Oct 2021 navma1  ChangeRequest 52249: MTN - Web Portal Cargo Work Orders - Cargo Type Checking when Adding a To Do Task
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	woToDo		: CM_WodToDo;
	workOrder	: CM_WorkOrderTI;
	woSource	: CM_WorkOrderTISource;
	ti			: CM_TrackedItem;
	cargoType	: CM_CargoType;
	toDoDesc	: CM_ToDoTaskDesc;
begin
	
	if self.allToDoRequests.isEmpty then
		return;
	endif;
	
	if self.myParent = null then
		return;
	endif;
	
	workOrder := self.myParent.CM_WorkOrderTI;
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	woSource := workOrder.mySource;
	if woSource &lt;&gt; null and woSource.getMyCargoType &lt;&gt; null then
		
		foreach woToDo in self.allToDoRequests  do
			if  woToDo.myToDoTaskDesc &lt;&gt; null and not woToDo.myToDoTaskDesc.allCargoTypes.includes( woSource.getMyCargoType ) then
				app.raiseCMException2(TaskCargoTypeMismatch, woToDo.myToDoTaskDesc.shortDescription, woSource.getMyCargoType.abbreviation, null, null);
			endif;
		endforeach;
	endif;
	*/
	
	//12.01.2023 navma1 #56141 Task#56147
	foreach ti in self.allSelectedTIs do 					//08.02.2023 navma1 #56457 Task#56458
		cargoType := ti.myCargoType;
		foreach woToDo in self.allToDoRequests  do
			//toDoDesc := woToDo.myToDoTaskDesc;																					//15.3.2023 navhl20	#56614[56615]		
			foreach toDoDesc in woToDo.allToDoTasksDescs do																			//15.3.2023 navhl20	#56614[56615]
				if  toDoDesc &lt;&gt; null and not toDoDesc.isAvailableForCargoType( ti.cargoType ) then
					app.raiseCMException2(TaskCargoTypeMismatch, toDoDesc.shortDescription, cargoType.abbreviation, null, null);
				endif;
			endforeach;																												//15.3.2023 navhl20	#56614[56615]
		endforeach;
	endforeach;
	
epilog	
	
end;</source>
    </JadeMethod>
</Class>
