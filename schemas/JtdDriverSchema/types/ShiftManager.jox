    <JadeMethod name="runTest" id="85c5ea7d-4c8b-447b-a318-901b0dad0636">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('sm002_CN_lstTest_click');
	sa.add('sm004_CN_lstTest_dblClick');
	sa.add('sm006_CN_lstTest_click');
	sa.add('sm008_CN_lstTest_dblClick');
	sa.add('sm010_CN_lstTest_click');
	sa.add('sm012_CN_lstTest_dblClick');
	sa.add('sm014_SOOWF_cmbVoyage_click');
	sa.add('sm016_SOOWF_picture_click');
	sa.add('sm018_CN_lstTest_click');
	sa.add('sm020_CN_lstTest_dblClick');
	sa.add('sm022_YQF_lstQueues_click');
	sa.add('sm024_CN_lstTest_click');
	sa.add('sm026_CN_lstTest_dblClick');
	sa.add('sm028_SPAF_cmbArea_click');
	sa.add('sm030_CN_lstTest_click');
	sa.add('sm032_CN_lstTest_dblClick');
	sa.add('sm034_SJCF_picture_click');
	sa.add('sm036_SJCF_picture_click');
	sa.add('sm038_SJCF_picture_click');
	sa.add('sm999_tidyUp');

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
