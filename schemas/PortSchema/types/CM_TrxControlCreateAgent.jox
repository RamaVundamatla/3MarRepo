    <JadeMethod name="trxCreateAS400Docket" id="c2aa7133-4d79-440f-b84b-90f94ce11b54">
        <updating/>
        <source>trxCreateAS400Docket(_docketFile : File io;  _fileLoad : CM_AS400FileLoad;
					_passport : CM_Passport input) updating;

vars
	line 	: String;
	lineNo,
	count	: Integer;
	
begin

// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	while not _docketFile.endOfFile do
		line := _docketFile.readLine();
		count := count + 1;
		lineNo := lineNo + 1;
		app.myUtilityCA.utlCreateAS400Docket(line, lineNo, _fileLoad, _passport);
		if _passport.noErrors then
			if count = 1000 then
				count := 0;
				app.cmsCommitTransaction(_passport);
				beginTransaction;
			endif;
		else
			return;
		endif;
	endwhile;
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_docketFile" type="File" usage="io"/>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
