    <JadeMethod name="getTiDesc" id="6aeb8727-19d0-467a-99e4-61b28b94d812">
        <updating/>
        <source>getTiDesc(_ti : CM_TrackedItem) : String protected, updating;
// -------------------------------------------
// Created 04 May 2005 by cnwdvb1
// -------------------------------------------
vars

	def : EntTableDef;
	row	: EntTableRow;
	str,
	str2	: String;
begin

	def := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_YardAllocation];

	if def &lt;&gt; null then
		foreach row in def.allEntTableRows do
			str2 := row.name.toUpper() &amp; ' - ' &amp; _ti.getDisplayStringForAttribute(row.name, false);
			self.addLogEntry(AP_Log_YA_Default,str2, false);
			str := str &amp; str2 &amp; CrLf;
		endforeach;
	endif;

	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUsePriorityLookup" id="64ecc6a2-3ecb-4282-8636-790bc3b63ec6">
        <source>getUsePriorityLookup() : Boolean;
//29 July 2010	cnwdw1	
// Return true if priorities should be used to optimize the autoplan by skipping ya 
// that have to high a priority
vars

begin
	return self.myCurrentTerminal.isAutoPlanUsePriorityLookup();
end;</source>
        <ReturnType type="Boolean"/>
