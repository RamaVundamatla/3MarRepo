15 October 2012	cnwndl1	Initial creation	Par 30521

*/

vars

begin

	if myForm = null then
		write _msg;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeLineOutputToMyForm" id="1092151c-e048-4614-8578-ccbe55e7fffc">
        <source>writeLineOutputToMyForm( _str : String ) protected;
/*
Purpose: Write the string with a CrLf
