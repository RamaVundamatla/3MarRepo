	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ISOGroup]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Product]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_IsOverDimension]);
	if app.isSubTerminalsLicensed then
		_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_SubTerminal]);
	endif;
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_IsHazardous]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_RequiresPower]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_IsHazAllLimited]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_IsHazNotLimited]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_IsHazOrLimited]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Damaged]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_IsEmpty]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_IsReefer]);
	// CCMS DPH 2278 add operator, consignor, consignee and freight forwarder
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Consignee]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Consignor]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_FreightForward]);
	
	
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_TotalWeight]); 	// TFS 4271
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoLength]); 	// TFS 4271
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoHeight]);	 // TFS 4271
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoWidth]); 	// TFS 4271
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_FreightTons]); 	// TFS 4271
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Hazardous]); 		// TFS 4271

	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_RecStevedore]);   //02.10.2020 cnwma1 TFS #50112
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_RelStevedore]);   //02.10.2020 cnwma1 TFS #50112
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_InvContractId]);  // ### TFS CR 55625 TASK 56131 20JAN2023 NAVAB1
	//03/03/2023	navmv20 TFS 56216 Task 56217 - START
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CountryOfOrigin]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_TAStorageGroup]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_VoyageVessel]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Density]);
	//03/03/2023	navmv20 TFS 56216 Task 56217 - END
	// START - 22.5.2023 navmk20 TFS 58016 
