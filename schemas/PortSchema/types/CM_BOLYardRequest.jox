<Class name="CM_BOLYardRequest" id="ca9568fd-6cec-47ad-b3cd-dc431d8e8db6">
    <superclass name="CM_YardRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="operatn"/>
    <ImplicitInverseRef name="myBOL" id="e776d0ed-6958-4f0a-af12-c03990d6d992">
        <embedded/>
        <type name="CM_BOL"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createWLE" id="6f336763-7807-4907-b3d4-eb2b517e1ba5">
        <source>createWLE();
// ---------------------------------------------------------------------------
// Created:     18 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	wle		: CM_YardWLE;
	tmpTI	: CM_TrackedItem;
	coll	: Collection;
begin

	create wle persistent;
	wle.setForCreate(self.myJob, self);
	
	coll := self.myBOL.getTICollectionForTerminal(self.myTerminal);
	tmpTI := coll.first.CM_TrackedItem;
	wle.assignTIandBOL(tmpTI, self.myBOL);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="f1fe9c15-a095-4e1f-8ca3-30fb81fa4c78">
        <source>createWLEs();
// ---------------------------------------------------------------------------
// Created:     18 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (self.allWorkListEntries.isEmpty = false) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_HAS_WL_ENTRIES, null, null);
		return;
	endif;
	if self.myBOL &lt;&gt; null and (self.myBOL.bolType = BOLType_GeneralDocket  or self.myBOL.bolType = BOLType_GeneralBillOfLading) then
		self.myBOL.createWLEs(self);
	else
		self.createWLE();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="da7be89a-5963-4950-a3e1-838ebce145bc">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

vars

begin
	exclusiveLock(self);
	self.myBOL := null;
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="4b5d7800-e448-4faf-ae95-b329f69d8d88">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

	str : String;
	ticket : CM_TicketSequence;
	logExt	: CM_BOLExtLogIn;
begin

	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_BOL_GC), DC_Label, 1, null);
	block.addNewItem(self.myBOL.number, DC_Data, 1, null);


	if self.myBOL.bolType = BOLType_Log and not self.myBOL.isReleaseDocket then
		logExt := self.myBOL.myExtension.CM_BOLExtLogIn;
		if not logExt.allTicketSequences.isEmpty then
			foreach ticket in logExt.allTicketSequences do
				str := app.getErrorString(CM_From) &amp; ticket.fromId &amp; app.getErrorString(CM_To) &amp; ticket.toId &amp; '; ';
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(CM_Ticket_Sequence), DC_Label, 1, null);
				block.addNewItem(str, DC_Data, 1, null);

			endforeach;
		endif;
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Number_Of_Piece), DC_Label, 1, null);
	block.addNewItem(self.myBOL.numItems.String, DC_Data, 1, null);

	if self.myBOL.myPlannedLocation &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Target_Location) , DC_Label, 1, null);
		block.addNewItem(self.myBOL.myPlannedLocation.getID, DC_Data, 1, null);
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7591a19a-83ea-43c8-95ec-065b074fd2f7">
        <updating/>
        <source>setForCreate(pProxyRequest: CM_BOLYardRequest) updating;
// ---------------------------------------------------------------------------
// Created:     18 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myBOL := pProxyRequest.myBOL;
	
	inheritMethod(pProxyRequest);
	
	
end;</source>
        <Parameter name="pProxyRequest" type="CM_BOLYardRequest"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="adb58b84-0b43-4a94-9529-3a1a65ee632a">
        <updating/>
        <source>setProxy(_consigneeCode, _consignorVoyageCode, _deliveryNumber : String;
		_eirNumber, _freightForwarderCode, _freightPayerCode : String;
		_isReceipt : Boolean;
		_reasonCode : Integer; 
		_reasonCodeDescr, _remarks : String;
		_removeStops : Boolean; 
		_userCode, _voyageCode : String;
		_job : CM_Job;
		_bol : CM_BOL) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if not self.isTransient then
		return;
	endif;

	self.setProxyForYardRequest(_consigneeCode, _consignorVoyageCode, _deliveryNumber,
						TI_DOORSDIRN_NULL,
						_eirNumber, _freightForwarderCode, _freightPayerCode,
						_isReceipt, false /* needCOU */, 
						false /* needGenerator */,
						_reasonCode, 
						_reasonCodeDescr, _remarks,
						_removeStops,
						_userCode, _voyageCode,
						_job, null, null);

	self.myBOL := _bol;
	
end;</source>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_consignorVoyageCode" type="String"/>
        <Parameter name="_deliveryNumber" type="String"/>
        <Parameter name="_eirNumber" type="String"/>
        <Parameter name="_freightForwarderCode" type="String"/>
        <Parameter name="_freightPayerCode" type="String"/>
        <Parameter name="_isReceipt" type="Boolean"/>
        <Parameter name="_reasonCode" type="Integer"/>
        <Parameter name="_reasonCodeDescr" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_removeStops" type="Boolean"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
</Class>
