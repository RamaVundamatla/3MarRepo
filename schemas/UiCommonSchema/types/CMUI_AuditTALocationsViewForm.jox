    <JadeMethod name="setupForm" id="1ae314c9-adb7-49bd-9426-72dab7ca05d1">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	date	:Date;
begin
	self.staStatusBar.visible	:= true;
	self.usesQueryFrame 		:= false;
	self.useTableInfo			:= true;
	self.toolbarStyle 			:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar 			:= true;
	self.useTableSorting 		:= true;
	
	self.getXMLSettingsForSetup();
	
	inheritMethod();
	
	self.initTableData (self.getEntTableDef);
	self.initCommentsFrame;
		
	self.frmSearch.top 		:= self.frmToolbar.height;
	self.frmSearch.width	:= self.clientWidth;
	self.frmSearch.left		:= 0;
	
	date := self.systemToLocalTime(app.actualTimeServer).Date;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.cmbTerminalArea.listIndex := -1;
	
	self.txtQDateStart.setDate (date - self.daysToGoBack);
	self.txtQDateEnd.setDate (date);
	
	self.loadTerminalAreas;

	if self.myTerminalArea &lt;&gt; null then	
		self.doQuery;
	endif;
	
	// we have our own context menu - set captions from super class menu :-(
	self.mnuContextHide2.caption	:= self.mnuContextHide.caption;
		
	self.setNavigatorHeading (self.caption);	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnComment.enabled:= false;
		self.mnuAddComments.enabled:= false;
	endif;

epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="showExtraInformation" id="01fd5bbf-7a7d-4595-b6dd-783fd9258207">
        <source>showExtraInformation(_dataContainer: CM_DataContainer; _theTable: CM_DataTable input; _reset: Boolean; _useBigFont: Boolean; _maxColumns: Integer; _colsForData: Integer; _colsForHeader: Integer; _colsForIcon: Integer; _colsforLabel: Integer);
// ---------------------------------------------------------------------------
// Created:     08 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	inheritMethod(_dataContainer, _theTable, _reset, _useBigFont, 2, _colsForData, _colsForHeader, _colsForIcon, _colsforLabel);

	if _theTable.rows &lt;= _theTable.fixedRows then
		return;
	endif;
	
	_theTable.accessColumn (1).width	:= 150;
	_theTable.accessColumn (2).width	:= (_theTable.width - 150).Integer;
	_theTable.autoSize					:= _theTable.AutoSize_Row;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_useBigFont" type="Boolean"/>
        <Parameter name="_maxColumns" type="Integer"/>
        <Parameter name="_colsForData" type="Integer"/>
        <Parameter name="_colsForHeader" type="Integer"/>
        <Parameter name="_colsForIcon" type="Integer"/>
        <Parameter name="_colsforLabel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e25aa8ba-a24d-463c-a05b-10d67a0627b4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015118, locale);
	btnCancelComment.translateCaption(Xlat_0015119, locale);
	btnComment.translateBubbleHelp(Xlat_0015120, locale);
	btnComment.translateCaption(Xlat_0015121, locale);
	btnOkComment.translateCaption(Xlat_0015122, locale);
	btnRefresh.translateCaption(Xlat_0015123, locale);
	lblQDateEnd.translateCaption(Xlat_0015124, locale);
	lblQDateStart.translateCaption(Xlat_0015125, locale);
	lblTerminalArea.translateCaption(Xlat_0015126, locale);
	mnuAddComments.translateCaption(Xlat_0015127, locale);
	mnuColumnOrganiser2.translateCaption(Xlat_0015128, locale);
	mnuContextHide2.translateCaption(Xlat_0015129, locale);
	mnuTablePopup.translateCaption(Xlat_0015130, locale);
end;</source>
    </JadeMethod>
</GUIClass>
