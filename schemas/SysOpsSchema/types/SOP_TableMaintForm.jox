    <JadeMethod name="btnTimeAdd_click" id="4ae2a606-8aae-4693-bd55-ffed217fd5be">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTimeAdd_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Apr 2012	cnwrs1	par 29516
// ---------------------------------------------------------------------------
vars
	tString : String;
	found : Boolean;
	i     : Integer;
	interval : Time;
	startInt : Time;
	endInt : Time;
begin
	app.mousePointer := Busy;
	found := false;
	if self.txtTimeInterval.getTime() = null then
	if self.txtTimeBox1.getTime().isValid() then
		tString := self.txtTimeBox1.getTime().String;
		i := 1;
		
		while i &lt;= self.timelistBox1.listCount do
			if tString =  self.timelistBox1.itemText[i] then
				found := true;
				break;
			else
				i := i+1;
			endif;
		endwhile;
		
		if found = false then
			self.timelistBox1.addItem(tString);
			self.txtTimeBox1.setFocus();
		endif;
	endif;
	else
		interval :=  self.txtTimeInterval.getTime();
		startInt := self.txtTimeIntStart.getTime();
		endInt := self.txtTimeIntEnd.getTime();
		if interval &lt;&gt; null and
		   interval.isValid() and
		   startInt.isValid() and
		   endInt.isValid() then
			self.addScheduleTimes(interval, startInt, endInt);
		endif;
	endif;
epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
