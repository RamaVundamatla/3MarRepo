    <JadeMethod name="logReasonForExclusion" id="433050e8-e1b7-43eb-b2de-4f4227e2fff0">
        <source>logReasonForExclusion(_trx :CM_Transaction; _reason :String) protected;
/*
Date		Who		Reason
17 July 2012	cnwcs5	Initial creation - par 29601
*/
vars

begin
	// does nothing - should never be called.  Only subclass method should be called
epilog

end;</source>
