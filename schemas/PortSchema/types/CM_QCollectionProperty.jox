	return 60;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="13e0cf88-07de-4a1b-b61c-3c63b0de965f">
        <source>getQueryOperatorForYADataConv(): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation

*/

vars

begin
	return CM_QCollIncludesOneOf;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
</Class>
