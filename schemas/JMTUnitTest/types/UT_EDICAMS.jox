    <JadeMethod name="zCoarri_SMDG213TRANSHIP" id="f4283ba3-b5ba-4015-988b-570f2ff88247">
        <source>zCoarri_SMDG213TRANSHIP() : String protected;

//27 Sep 2019	jlgsl4	TFS 46608 SNO - tranship details -&gt; segment group 12, with NAD
//18 Nov 2019 	jlgsl4	TFS 47450 SNO - Missing unknown seal in CoarriSMDG213
//07 May 2020	NDL	TFS 49211 - Add in Hazards and dangerous goods data
//11 Jun 2020	NDL	TFS 49558 - Add in FTX per DGS not per IMD+n (Hazard type)
//13 Oct 2020   cnwma1 Bug 50021: GPHA -- Extract of segment RFF+BM into a COARRI message
vars

begin
