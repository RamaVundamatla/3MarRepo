<Class name="CMIF_EventPublisherHelper" id="9d8d7ff7-cadd-4aef-8393-46ddaae9e242">
    <superclass name="CMIF_DotNetWrap"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myEventPublisher" id="5c13e5dc-aab9-4508-afbd-4484c32cb542">
        <embedded/>
        <type name="JMTEventPublisher"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="connect" id="da2df359-0822-42d4-8bbd-423120490ea1">
        <source>connect(_eventStreamURI : String) : Boolean;
/*

Purpose:			Initiate a connection to the Event Streaming application

Parameters:			Connection IP and Port (e.g. "127.0.0.1:5050")

Return Value:		True if a connection is established, false otherwise

Date		Who		Reason
29 Mar 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
	returnVal,
	excOccurred		: Boolean;
	
begin
	app.writeLog(method.qualifiedName &amp; ' _eventStreamURI=' &amp; _eventStreamURI, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	on Exception do self.handleExceptions(exception, excOccurred);
	returnVal := self.myEventPublisher.connect(_eventStreamURI.StringUtf8);
	
	if not returnVal or excOccurred then
		app.writeLog(method.qualifiedName &amp; ' returnVal=' &amp; returnVal.String &amp; ', excOccurred=' &amp; excOccurred.String, LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_eventStreamURI" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="c82936ce-b128-49c6-bdbd-efd817b0fba2">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
	hadException	: Boolean;
	usePresentation	: Boolean;
	
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	create self.myEventPublisher transient;
	if self.myEventPublisher &lt;&gt; null then
		self.myEventPublisher.usePresentationClient := self.usePresentationClient;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="5a2de30f-4743-41b5-b2df-f60c6c0fb988">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
	delete self.myEventPublisher;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisabledSubscriptions" id="321fba80-c77b-4b14-99da-9b6e32e42746">
        <source>getDisabledSubscriptions(_message : String output) : Boolean;
/*

Purpose:			

Parameters:			List of disabled subscriptions, each with a related error message

Return Value:		True if request was processed succesfully

Date				Who		Reason
28 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	success,
	excOccurred		: Boolean;
	message			: StringUtf8;
	
begin
	app.writeLog(method.qualifiedName, LogTRACE);
	
	on Exception do self.handleExceptions(exception, excOccurred);
	success := self.myEventPublisher.getDisabledSubscriptions(message);
	
	if not success or excOccurred then
		app.writeLog(method.qualifiedName &amp; ' returnVal=' &amp; success.String &amp; 
					   ', message=' &amp; message.String &amp;
					   ', excOccurred=' &amp; excOccurred.String, LogERROR);
	endif;
	
	if success and message.length &gt; 4 then
		// successful message will look like this: "OK[name1::message1||name2::message2||]"
		// we don't need the 'OK' or the brackets
		_message := message.String[4:message.length-4];
	endif;
	
	return success;
	
epilog

end;</source>
        <Parameter name="_message" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="publishEvent" id="0dc2fe78-f6c3-4ece-b6f0-0d486bf4d1f9">
        <source>publishEvent(_dateTime,
			 _source,
			 _environment,
			 _terminal,
			 _terminalCode,
			 _type,
			 _subType,
			 _replayIdentifier,
			 _body : String) : Boolean;
/*

Purpose:			Push the passed in Event details out to the connected Events Stream application.

Parameters:			TimeStamp the event occurred
					Source of the Event
					Environment the Event occurred in
					Terminal OID the Event occurred in (will be null for System Events)
					Terminal Code the Event occurred in (will be null for System Events)
					Type of Event ("Audit", "Event" or "Transaction")
					SubType of the Event
					Optional replay identifier
					JSON object representing the Event

Return Value:		True if the publish event succeeded, false otherwise

Date		Who		Reason
29 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
19 Jun 2017	cnwkpd1	Signature change for JMTEventPublisher::publishEvent
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism

*/

vars
	returnVal,
	excOccurred		: Boolean;
	message			: StringUtf8;
	
begin
	self.cnStartTransaction(method.qualifiedName);
	
	on Exception do self.handleExceptions(exception, excOccurred);
	returnVal := self.myEventPublisher.publishEvent(_dateTime.StringUtf8,
													_source.StringUtf8,
													_environment.StringUtf8,
													_terminal.StringUtf8,
													_terminalCode.StringUtf8,
													_type.StringUtf8,
													_subType.StringUtf8,
													_replayIdentifier.StringUtf8,
													_body.StringUtf8,
													message);

	if not returnVal or excOccurred then
		app.writeLog(method.qualifiedName &amp; ' returnVal=' &amp; returnVal.String &amp; 
					   ', message=' &amp; message.String &amp;
					   ', excOccurred=' &amp; excOccurred.String, LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return false;
	endif;
	
	return true;
	
epilog
	self.cnEndTransaction();
	
end;</source>
        <Parameter name="_dateTime" type="String"/>
        <Parameter name="_source" type="String"/>
        <Parameter name="_environment" type="String"/>
        <Parameter name="_terminal" type="String"/>
        <Parameter name="_terminalCode" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_subType" type="String"/>
        <Parameter name="_replayIdentifier" type="String"/>
        <Parameter name="_body" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="startDispatching" id="368ae183-2daf-4342-bd68-dbaf4ed90ca9">
        <source>startDispatching(_definitionsJSON : String) : Boolean;
/*

Purpose:			Tell the connected Events Streaming application to start, which means reading the
					stored configuration via the passed in Web Service.  Can be called at startup of the 
					Push Events application, or following a stopDispatching call to force the Events Stream to
					reread the config via the Web Service if it has been changed.

Parameters:			AllEventStreamDefinitions formatted as JSON

Return Value:		True if the startDispatching succeeded, false otherwise

Date		Who		Reason
29 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
19 Jun 2017	cnwkpd1	Signature change for JMTEventPublisher::startDispatching
22 Jan 2019	jlgzm1	TFS 47920 Event Stream Admin JMT UI

*/

vars
	returnVal,
	excOccurred		: Boolean;
	message			: StringUtf8;
	
begin
	app.writeLog(method.qualifiedName, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	on Exception do self.handleExceptions(exception, excOccurred);
	returnVal := self.myEventPublisher.startDispatching(_definitionsJSON.StringUtf8, message);
														
	if not returnVal or excOccurred then
		app.writeLog(method.qualifiedName &amp; ' returnVal=' &amp; returnVal.String &amp; 
					   ', message=' &amp; message.String &amp;
					   ', excOccurred=' &amp; excOccurred.String, LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_definitionsJSON" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="stopDispatching" id="e28261fa-c29f-4dc1-8b39-8540741a9b65">
        <source>stopDispatching() : Boolean;
/*

Purpose:			Tell the connected Events Streaming application to stop.  Will be called by the JMTPushEvents 
					at shutdown, and prior to a startDispatching call to force the Events Stream to
					reread the config via the Web Service if it has been changed.

Parameters:			None

Return Value:		True if the startDispatching succeeded, false otherwise

Date		Who		Reason
29 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
19 Jun 2017	cnwkpd1	Signature change for JMTEventPublisher::stopDispatching

*/

vars
	returnVal,
	excOccurred		: Boolean;
	message			: StringUtf8;
	
begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	
	on Exception do self.handleExceptions(exception, excOccurred);
	returnVal := self.myEventPublisher.stopDispatching(message); // TFS 47920 jlgzm1 27/01/2020

	if not returnVal or excOccurred then
		app.writeLog(method.qualifiedName &amp; ' returnVal=' &amp; returnVal.String &amp; 
					   ', message=' &amp; message.String &amp;
					   ', excOccurred=' &amp; excOccurred.String, LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
