    <JadeMethod name="myTerminalArea" id="fcd9bfd1-37a7-45c8-b0b0-b9d3c0a84162">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myTerminalArea(set: Boolean; _value: CM_TerminalArea io) updating, mapping;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars

begin
	if not set then
	//	if not self.isTransient and not app.isJMTUnitTest then // removed for TFS 49912
		if not self.isTransient and self.myGroup &lt;&gt; null then	//07 Apr 2021	NDL	TFS 49912
			_value := self.myGroup.myTerminalArea;
		endif;
		return;
	endif;
	
	inheritMethod(set, _value);

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_TerminalArea" usage="io"/>
    </JadeMethod>
