    <JadeMethod name="isOnGlobalVoyage" id="73e3a341-4d6f-4294-b4de-1d240fe6d9f4">
        <source>isOnGlobalVoyage(_realVoyageObj:CM_VoyageGlobal; _proxyVoyageObj:CM_VoyageGlobal; _voyageObj:CM_VoyageGlobal output):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 March 2008 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is engaged
//				by a Global Voyage at any time between the specified timestamps.
//
// Parameters:	_realVoyageObj - A reference to the real Global Voyage we want to use
//					the Vessel for.
//				_proxyVoyageObj - A reference to the proxy of the real Global Voyage.
//				_voyageObj - A reference to the Voyage which the Vessel conflicts with.
//
// Returns:		True if the receiver is in use, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31 Mar 2008	cnwkpd1		PAR #16365 - Change to ignore any voyages linked to the 
//							existing real voyage as well as the real voyage
// --------------------------------------------------------------------------------

vars
	iteratorObj			: Iterator;
	voyageObj			: CM_VoyageGlobal;
	voyageStart			: TimeStamp;
	voyageEnd			: TimeStamp;
	startTS				: TimeStamp;
	endTS				: TimeStamp;
	allGlobalVoyages	: CM_VoyageGlobalByArrivalDict;
	
begin
	startTS				:=	_proxyVoyageObj.arrivalDT;
	endTS				:=	_proxyVoyageObj.getLastMovementArrivesAtB();
	allGlobalVoyages 	:= 	self.getAllVoyageGlobals();
	iteratorObj			:=	allGlobalVoyages.createIterator();
	allGlobalVoyages.startKeyLeq(startTS, iteratorObj);
	
	while iteratorObj.next(voyageObj) do
		if voyageObj = _realVoyageObj then
			continue;
		endif;
		
		// PAR #16365 - ignore any voyages linked to the real voyage, as they will be moved
		// to accomodate any changes being applied
		if _realVoyageObj &lt;&gt; null and _realVoyageObj.isLinkedToVoyage(voyageObj) then
			continue;
		endif;
		
		voyageStart	:=	voyageObj.arrivalDT;
		voyageEnd	:=	voyageObj.getLastMovementArrivesAtB();
		
		// PAR #16365 - Changed break condition - can break only when the next voyage starts
		// of or after the end of the new/updated one
//		if startTS &gt; voyageEnd then
		if voyageStart &gt;= endTS then												
			break;
		endif;
		
		if voyageStart &gt; startTS and voyageStart &lt; endTS then
			_voyageObj	:=	voyageObj;
			return true;
			
		elseif voyageEnd &gt; startTS and voyageEnd &lt; endTS then
			_voyageObj	:=	voyageObj;
			return true;
			
		elseif voyageStart &lt;= startTS and voyageEnd &gt;= endTS then								// PAR #16365 changed from &lt; and &gt;
			_voyageObj	:=	voyageObj;
			return true;
			
		endif;
	endwhile;
	
	return false;
	
	
epilog
	delete iteratorObj;
	
end;</source>
        <Parameter name="_realVoyageObj" type="CM_VoyageGlobal"/>
        <Parameter name="_proxyVoyageObj" type="CM_VoyageGlobal"/>
        <Parameter name="_voyageObj" type="CM_VoyageGlobal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOpsViewData" id="d50ff54c-b20f-419e-990a-711236dc9082">
