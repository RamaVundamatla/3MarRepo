    <JadeMethod name="addIncompleteWLE" id="7837e033-0521-4052-81df-53f759662776">
        <updating/>
        <source>addIncompleteWLE(wle : CM_WorkListEntry) updating;
/*
 ------------------------------------------------------------------------
Created:			17 July 2001 by cnwdwq1
Purpose:			Adds a WLE to the list of WLES that have not been fully completed     
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if self.allIncompleteWLEs.includes(wle) then
		return;	//Already here, ignore for now.
	endif;
	self.allIncompleteWLEs.add(wle);

end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="addWagon" id="2824e068-68eb-44e3-bee9-cf1dcf1b51fa">
        <source>addWagon( _moveController : CMIF_WagonMoveController; _wagon : CM_Wagon input; _atPos : Integer; _movement : Boolean);
/*
 ------------------------------------------------------------------------
Created:			18 December 2001 by cnwdwq1
Purpose:			Manual end of array manipulation, we can now set a pos for a wagon
							to be included at.
							We have to set the "many" end because we can insert/add to end/add to start
							and this is the only way to control it. DQ
Parameters:		None
Returns:			Nothing

Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
29/05/2009		consw1			PAR 19710 - SFW1067 Rail Simplifications
12/08/2009		consw1			PAR 19913 - SFW1067 Rail Simplifications
---------------------------------------------------------------------------
*/
vars
	auditAdd : Boolean;
	tmpWagon,movedWagon : CM_Wagon;
	currPos : Integer;
	pos ,startPos , endPos : Integer;
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837
	wagMoveController : CMIF_WagonMoveController;

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	else
		create wagMoveController transient;
		wagMoveController.autoSetEffectiveTimeStamp();
		effectiveDate := wagMoveController.effectiveTimeStamp;
	endif;

	if _wagon.confirmed and not _movement then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_WAGON_CONFIRMED, _wagon.id, null, null);
		return;
	endif;

	if _wagon = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Wagon), null, null);
		return;
	endif;
	if _atPos &gt; self.maximumWagons then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Rake_position), app.getErrorString(Maximum_wagons_allowed) &amp; ' ' &amp; self.maximumWagons.String, null, null);		
		return;
	elseif self.allWagonsById.size &gt;= self.maximumWagons then
//		app.setContinueCMExceptions(false);
//		app.raiseCMException2(ERR_NO_SPACE, 'wagon ' &amp; _wagon.id.String, 'rail line ' &amp; self.id, null, null);		
//		return;
	endif;

	//  Audit change
	if _wagon.myRailLine = null then
		auditAdd := true;
	elseif _wagon.myRailLine.myRailArea = self.myRailArea then
		if _atPos = 0 then
			_wagon.createTransaction( effectiveDate, EVT_WagonMoved, self, self.allWagons.size + 1, null, true, null, null, null);
		else
			_wagon.createTransaction( effectiveDate, EVT_WagonMoved, self, _atPos, null, true, null, null, null);
		endif;
		
	else
		_wagon.createTransaction( effectiveDate, EVT_WagonRemove, _wagon.myRailLine, null, null, true, null, null, null);
		auditAdd := true;
	endif;

	//  Change position
	if _atPos = 0 then
		if self.allWagons.includes(_wagon) then
			self.allWagons.remove(_wagon);
		endif;
		
		if _wagon.myRailLine &lt;&gt; null then
			// _wagon already exists on another rail line
			// so remove it from there first
			_wagon.myRailLine.removeWagon(_wagon);
		endif;
		
		if self.allWagons.last = null and not self.allWagons.isEmpty() then
			self.allWagons.atPut(self.allWagons.size, _wagon);
		else
			if (self.allWagons.size + 1 &gt; self.maximumWagons) then
				app.setContinueCMExceptions(false);
				app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Rake_position), app.getErrorString(Maximum_wagons_allowed) &amp; ' ' &amp; self.maximumWagons.String, null, null);		
				return;
			endif;
			self.allWagons.add(_wagon);
		endif;

	else
		//specific location.
		currPos := self.allWagons.indexOf(_wagon);
		if currPos = 0 then // NEW
			if _wagon.myRailLine &lt;&gt; null then
				// _wagon already exists on another rail line
				// so remove it from there first
				_wagon.myRailLine.removeWagon(_wagon);
			endif;
		elseif _atPos &lt;&gt; currPos then // MOVE
			self.allWagons.atPut(currPos, null);
		else // ALREADY THERE
			return;
		endif;
		
		if _atPos &gt; self.allWagons.size then
			self.allWagons.atPut(_atPos, _wagon);
		elseif _movement then
			foreach pos in _atPos to self.allWagons.size do
				tmpWagon := self.allWagons[pos];
				if tmpWagon = null or not tmpWagon.confirmed then
					// There is a gap, will shunt wagons up one position into the gap
					self.allWagons.removeAt(pos);
					if tmpWagon &lt;&gt; null then
						self.removeWagon(tmpWagon);
					endif;
					break;
				endif;
			endforeach;
			if (self.allWagons.size + 1 &gt; self.maximumWagons) then
				app.setContinueCMExceptions(false);
				app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Last_rake_position), app.getErrorString(Maximum_wagons_allowed) &amp; ' ' &amp; self.maximumWagons.String, null, null);		
				return;
			endif;			
			self.allWagons.insert(_atPos, _wagon);
			
			//jlier1 TFS 65100 9/7/24 need to update all the wagons cargo locationId that has been shunted
			if currPos = 0 then
				currPos:=pos; //the position we removed the wagon at
			endif;
			 if currPos &lt; _atPos then
				startPos:=currPos;
				endPos:=_atPos;	
			 elseif currPos &gt; _atPos then
				startPos:=_atPos;
				endPos:=currPos;	
			 endif;
			 if endPos &lt; self.allWagons.size then
				endPos:=endPos+1;
			endif;
			if startPos &gt; 0 then
				foreach pos in startPos to endPos do
					tmpWagon := self.allWagons[pos];
					if tmpWagon &lt;&gt; null and tmpWagon &lt;&gt; _wagon then
						tmpWagon.resetActualCargoLocations();
					endif;
				endforeach;
			endif;
		else
			tmpWagon := self.allWagons[_atPos];
			if tmpWagon = null then //or not tmpWagon.confirmed then
				// There a gap, fill it with this wagon
				self.allWagons.atPut(_atPos, _wagon);
				if tmpWagon &lt;&gt; null then
					self.removeWagon(tmpWagon);
				endif;
			else// another wagon is already there, must be switching positions, shunt along
				// DVB I don't think it is a good idea to shunt wagons around at this stage without checking max size
				// as there have been problems with rakes growing bigger than max size.
				// Par 9099
				app.setContinueCMExceptions(false);
				app.raiseCMException2(Been_confirmed_position, tmpWagon.id, _atPos.String, null, null);
				return;

			endif;

		endif;

	endif;
	
	//  Audit add
	if auditAdd then
		_wagon.createTransaction( effectiveDate, EVT_WagonAdd, self, null, null, true, null, null, null);
	endif;

//	if self.allWagonsById.includes(_wagon) then
//		return;
//	endif;
	
	if not self.allWagonsById.includes(_wagon) then
		self.allWagonsById.add(_wagon);
		_wagon.updateControllersTerminalArea();
	endif;
	
	//05 Mar 2013	NDL	Par 31171
	//The Wagon has moved, any cargo actually on the wagon needs its ground position updated.... 
	_wagon.resetActualCargoLocations();

epilog
	delete wagMoveController;
end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_wagon" type="CM_Wagon" usage="input"/>
        <Parameter name="_atPos" type="Integer"/>
        <Parameter name="_movement" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="calculateNextWagonPosition" id="d3d98ea2-482a-4a5e-8629-cdc1a45a6e11">
        <source>calculateNextWagonPosition(currentRakePos : Integer) : String;
/*
 ------------------------------------------------------------------------
Created:			18 July 2002 by cnwdwq1
Purpose:			Attempts to calculate the next available position on this rake
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.maximumWagons &lt;= currentRakePos then
		return null;
	endif;
	if self.myRailArea.confirmFromFarEnd then
		if currentRakePos &gt; 1 then
			return (currentRakePos -1).String;
		endif;
		return null;
	else
		if currentRakePos &lt; self.maximumWagons then
			if currentRakePos = 0 then
				return "1";
			else
				return (currentRakePos +1).String;
			endif;
		endif;
	endif;	
	return null;
end;</source>
        <Parameter name="currentRakePos" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearRake" id="158eca41-c863-46c0-803c-e2d32eeb7f78">
        <updating/>
        <source>clearRake(startIndex : Integer; endIndex : Integer; _passport :CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 04 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	term	: CM_Terminal;
	iter	: Iterator;
	wagon 	: CM_Wagon;
	event,
	idx		: Integer;
	delWagon: CM_WagonArray;
begin


	exclusiveLock(self);
	
	term := self.myRailArea.myTerminal;
	event := term.getTerminalEvent(Wagon_Delete_Event);
	create delWagon transient;
	
	iter := self.allWagons.createIterator;
	
	while iter.next(wagon) do
		idx := idx + 1;
		if wagon &lt;&gt; null then
			if idx &gt;= startIndex and idx &lt;= endIndex then
				if wagon.confirmed then
					wagon.cleanupAllJobsForRelease(_passport);
					if _passport.noErrors() then
						delWagon.add(wagon);
						wagon.causeEvent(event, false, wagon);
					endif;
				endif;						
			endif;
		endif;
	endwhile; 

	if _passport.noErrors() then
		delWagon.purge();	
	endif;

	self.tidyWagons();
	
	
epilog
	delete delWagon;
	delete iter;
end;</source>
        <Parameter name="startIndex" type="Integer"/>
        <Parameter name="endIndex" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="confirmRake" id="20c43493-69b8-4cbd-82d3-a007f1cddb1c">
        <updating/>
        <source>confirmRake( _moveController : CMIF_WagonMoveController; _autoPlan : Boolean; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	iter 	: Iterator;
	wagon 	: CM_Wagon;
begin
	iter := self.allWagons.createIterator();
	
	while iter.next(wagon) do
		if wagon = null then 
			continue;
		endif;
		if (not wagon.confirmed) then
			wagon.confirmWagonInwards( _moveController, _autoPlan, _passport);
		endif;
		if _passport.hasErrors then
			return;
		endif;
	endwhile;

	self.updateObjectEdition (self);	// par 30292

epilog
	delete iter;
end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_autoPlan" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="containsIncompleteRailRelease" id="1f899ee1-dc0f-4fc8-b6ef-9c411951ccbc">
        <source>containsIncompleteRailRelease() : Boolean;
/*
 ------------------------------------------------------------------------
Created:			17 July 2001 by cnwdwq1
Purpose:			Caled from CM_Rail object.
Parameters:		None
Returns:			Nothing

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	wle : CM_WorkListEntry;
	cleanedUp : Boolean;
	alert : CM_SystemAlert;
	invalid 		: Boolean;
	ed				: Integer;
	
begin
	if self.allIncompleteWLEs.size = 0 then
		return false;
	endif;
	//--------------
	//There are some WLE's here! Check em..
	//--------------	
	
	on Exception do app.handleDeletedObject(exception, wle, invalid);
	
	while true do
		if self.allIncompleteWLEs.size = 0 then
			return false;
		endif;
		wle := self.allIncompleteWLEs.first;
//		if not global.isValidObject(wle) then
		invalid := false;
		// Dereference wle to check it is valid
		ed := wle.edition();
		if invalid then
			//----------------
			//This is a CRAP WLE, remove it!
			//----------------
			self.allIncompleteWLEs.remove(wle);
			continue;
		endif;
		//----------------
		//TEST to see if the TI is on a wagon now!
		//----------------
		if wle.myTrackedItem = null then
			//------------------------
			//Still a WLE here.
			//------------------------
			return true;
		endif;
		if wle.myTrackedItem.getPrimaryLocation(REAL_MODE).isKindOf(CM_WagonController) then
			//----------------
			//TI is on a wagon, its been moved somehow.. Cleanup
			//----------------
			self.allIncompleteWLEs.remove(wle);
			continue;
		endif;
		return true;
	endwhile;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="969a61c8-f2b2-49dd-853e-25c22f1db94e">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
/*
 ------------------------------------------------------------------------
Created:			26 July 2001 by cnwdwq1
Purpose:			'Attempt to find the wagon position (and therefore the wagon)
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	wagonPosStr : String;
	wagonPos : Integer;
	wagon : CM_Wagon;
	remainingStrs : StringArray;
begin
	//-----------------
	//Init
	//-----------------
	_foundLC := null;
	_foundHeight := NULLINDEX;
	if _strs.size = 0 then
		return;
	endif;
	sharedLock(self);
	//-----------------
	//I'm expecting the individual position along this line here. A number that we use to get to
	//the allWagons array.
	//-----------------
	wagonPosStr := _strs[1][1:2];
	if not wagonPosStr.isInteger then
		return;
	endif;
	wagonPos := wagonPosStr.Integer;
	if wagonPos &gt; allWagons.size then
		//No wagon at that pos
		return;
	endif;
	wagon := allWagons[wagonPos];
	if wagon = null then
		return;	//Gap?
	endif;
	create remainingStrs transient;
	_strs.copy(remainingStrs);
	//Chop off the railLine position before we pass to the wagon to find the individual spot on the wagon
	//remainingStrs[1] := remainingStrs[1][wagonPosStr.length : end];
	remainingStrs.removeAt(1);
	wagon.findLocation(remainingStrs, _noException, _foundLC, _foundHeight);
epilog
	unlock(self);
	delete remainingStrs;
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItems" id="2a715be0-1a7b-45c9-8afd-0c1c6a35ea01">
        <source>getAllTrackedItems(_tiArray: CM_TIArray input);
//----------------------------------------------------------------
//	Created:	17 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	wagon	: CM_Wagon;
begin
	foreach wagon in self.allWagons do
		if wagon &lt;&gt; null and wagon.confirmed then
			wagon.getAllTrackedItems(true, _tiArray, false);
		endif;
	endforeach;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="f6cb20bb-cbc7-40cc-941d-279a9d1c4772">
        <source>getAllWLEs(_wleArray : CM_WLEArray input);
//--------------------------------------------------------------
//Created: 17 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	wagon	: CM_Wagon;
begin
	foreach wagon in self.allWagons do
		if wagon = null then
			continue;
		endif;
		wagon.getAllWLEs(_wleArray);
	endforeach;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="47dff970-4e71-4082-a3a7-7681cffd80a2">
        <source>getDisplayDetails(_short: Boolean): String;
//--------------------------------------------------
// Created:	05 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _short then
		return self.id;
	endif;
	
	return self.myRailArea.id &amp; ' ' &amp; self.id;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="197e4ed8-1274-46d8-8431-7e88d48c37dd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 17 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _attrName = ETRow_RailRake or _attrName = ETRow_SourceLocationId then
		return self.getDisplayDetails(_short);
	elseif _attrName = ETRow_WleCount then
		return self.allIncompleteWLEs.size.String;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="d422f7e6-8ae1-4239-a9d6-f0ed9c8784f3">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;

/*
 ------------------------------------------------------------------------
Date		Who		Reason
09 May 2023	navmk20 	Task 57853: Jade - Wagon Planning - Rail Line List Planned Wagons
17 May 2023 navmk20		Defect 58045: Showing 1090 Error
*/

vars
	str 			: String;
	block 			: CM_DataContainerBlock;
	wagon			: CM_Wagon;
	futureMove 		: CM_FutureMoveWagonPlanned;
	isWagonsTitle	: Boolean; 
	wagonCount		: Integer;
	train 			: CM_Train;
	trainArray 		: CM_ObjectArray;
begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Rail_Area), DC_Label, 1, self.myRailArea);
	block.addNewItem(self.myRailArea.id, DC_Data, 1, self.myRailArea);

	// Start - 4.5.2023 navmk20 TFS 57853
	/*foreach wagon in self.allWagonsById reversed do
		str := wagon.id &amp; ' ' &amp; str;
	endforeach;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Wagon_Ids), DC_Label, 1, self);
	block.addNewItem(str, DC_Data, 1, self);*/ 
	isWagonsTitle := false; 

	
	// #### ACTUAL WAGONS by TRAIN
	create trainArray transient;
	foreach wagon in self.allWagons do
		//if wagon.myTrainInwards &lt;&gt; null then						//17.5.2023 navmk20 TFS 58045
		if wagon &lt;&gt; null and wagon.myTrainInwards &lt;&gt; null then		//17.5.2023 navmk20 TFS 58045
			if not trainArray.includes(wagon.myTrainInwards) then
				trainArray.add(wagon.myTrainInwards);
			endif;
		endif;

	endforeach;
	
	foreach train in trainArray as CM_Train do
		if not isWagonsTitle then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Actual_wagons), DC_MoreInfo, 1, null);
			isWagonsTitle := true;
		endif;
		
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Train), DC_LabelHeader, 1, train);
		block.addNewItem(train.code, DC_Data, 1, train);
		block := _dataContainer.addNewBlock;
		block.addNewItem("", DC_Label, 1, null);
		
		wagonCount := 0; // Reset the wagon count
		
		foreach wagon in self.allWagons do
			//if wagon.myTrainInwards = train then						//17.5.2023 navmk20 TFS 58045
			if wagon &lt;&gt; null and wagon.myTrainInwards = train then		//17.5.2023 navmk20 TFS 58045
				wagonCount	:= wagonCount + 1;
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Wagon), DC_Label, 1, wagon);
				block.addNewItem(wagon.id, DC_Data, 1, wagon);
			endif;
		endforeach;
		
		if wagonCount mod 2 = 1 then
			block := _dataContainer.addNewBlock;
			block.addNewItem("", DC_Label, 1, null);
		endif;
	endforeach; 
	
	// #### PLANNED WAGONS by TRAIN
	trainArray.clear(); 
	isWagonsTitle := false;
	
	foreach futureMove in self.allPlannedFutureMoves as CM_FutureMoveWagonPlanned do
		wagon := futureMove.myWagon;
		if wagon &lt;&gt; null then										//17.5.2023 navmk20 TFS 58045
			if not trainArray.includes(wagon.myTrainInwards) then
				trainArray.add(wagon.myTrainInwards);
			endif;
		endif;														//17.5.2023 navmk20 TFS 58045
	endforeach;
	
	foreach train in trainArray as CM_Train do
		if not isWagonsTitle then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Planned_wagons), DC_MoreInfo, 1, wagon);
			isWagonsTitle := true;
		endif;
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Train), DC_LabelHeader, 1, train);
		block.addNewItem(train.code, DC_Data, 1, train);
		block := _dataContainer.addNewBlock;
		block.addNewItem("", DC_Label, 1, null);
		
		wagonCount := 0; // Reset the wagon count
		
		foreach futureMove in self.allPlannedFutureMoves as CM_FutureMoveWagonPlanned do
			wagon := futureMove.myWagon;
			//if wagon.myTrainInwards = train then					//17.5.2023 navmk20 TFS 58045
			if wagon &lt;&gt; null and wagon.myTrainInwards = train then	//17.5.2023 navmk20 TFS 58045
				wagonCount	:= wagonCount + 1;
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Wagon), DC_Label, 1, wagon);
				block.addNewItem(wagon.id, DC_Data, 1, wagon);
			endif;
		endforeach;
		
		if wagonCount mod 2 = 1 then
			block := _dataContainer.addNewBlock;
			block.addNewItem("", DC_Label, 1, null);
		endif;
	endforeach;
	//End 4.5.2023 navmk20 TFS 57853
epilog
	delete trainArray;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="b2cfc14a-5b55-407d-9684-366db33d0c8a">
        <source>getFullId():String;
//--------------------------------------------------
// Created:	05 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.myRailArea.id &amp; ' ' &amp; self.id;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIdString" id="2a96d491-a59b-455c-a36c-0361f7eba526">
        <source>getIdString() : String;

//----------------------------------------------------------
//	Created by:		cnwsgp1 on 12 August 2003
//
//  This method returns only the last 2 characters of the id.
//  Rail line ids were being created with the rail rake name
//  prepended.  This was incorrect so if any of these rail lines
//  still exist we don't want to display the rail rake name
//  as part of the rail line name.  Future rail lines will
//  not have the rail rake name prepended and so will only
//  be 2 characters.  This method will therefore be returning
//  the actual full id.
//----------------------------------------------------------

begin
	return self.id[self.id.length - 1:end];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxStackHeight" id="1cb519f4-3e8e-4ffe-84d1-078678ba6ea1">
        <source>getMaxStackHeight(_maxStackHeight : Integer output);
//-----------------------------------------
//Created: 29 September 2003 By: cnwgd1
//-----------------------------------------
vars
	wagon 	: CM_Wagon;
begin
	
	foreach wagon in self.allWagons do
		if wagon = null then
			continue;
		endif;
		_maxStackHeight := _maxStackHeight.max(wagon.myWagonClass.maxNumInStack);
	endforeach;

end;</source>
        <Parameter name="_maxStackHeight" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getMyPosition" id="d207184a-9e98-4d32-8586-61f7d2bbbcb7">
        <source>getMyPosition() : Integer;
// ---------------------------------------------------------------------------
// Created:		July  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	return self.myRailArea.allRailLines.indexOf(self);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextFreePosition" id="59efe895-9978-42fc-ade7-8d321e8aa922">
        <source>getNextFreePosition() : Integer;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwab1
// Purpose:		if the users have entered wagons on 1,2,3 the next free space is 4 HOWEVER, if they have entered 10, 9, 8 the next will be 7
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	next, size, max, idx : Integer;
	wagon : CM_Wagon;
begin
	max := self.maximumWagons;
	size := self.allWagons.size;

	foreach idx in 1 to max do
		if size &gt;= idx and self.allWagons[idx] &lt;&gt; null then
			if next &gt;= 0 then
				next := next + 1;
			endif;
		else
			if next &lt;= 0 then
				next := next - 1;
			endif;
		endif;
	endforeach;

	if next &gt; 0 then
		next := next + 1;
	else
		next := (next * -1).Integer;
	endif;

	if next &lt; 0 or next &gt; max then
		next :=  0;
	endif;
	return next;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumOfActualWagonForTrain" id="4d6edaa3-fdf0-43f0-b3da-8d3aad0e4d2c">
        <source>getNumOfActualWagonForTrain(_train : CM_Train; _inward : Boolean) : Integer;
/*

Purpose:			
		This method calculates how many actual wagon is at the rail line for the train
Parameters:			

Return Value:		

Date		Who		Reason
// 01/05/2023	navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train
// 21/07/2023	navkc1	Defect 59243: MTN - 1090 exception when planning the wagon using Move Wagons form
*/

vars
	numOfWagon		: Integer;
	wagon			: CM_Wagon;
	actualTrain		: CM_Train;
	
begin
	
	//foreach wagon in self.allWagons discreteLock do
	foreach wagon in self.allWagonsById discreteLock do	// 21/07/2023	navkc1	Defect 59243
		
		if _inward then
			actualTrain := wagon.myTrainInwards;
		else
			actualTrain := wagon.myTrainOutwards;
		endif;
		
		if actualTrain = _train then
			numOfWagon += 1;
		endif;
		
	endforeach;
	
	return numOfWagon;
	
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_inward" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumOfPlannedWagonForTrain" id="dcf1a55d-7da5-4311-8d0f-8c330dc29fb7">
        <source>getNumOfPlannedWagonForTrain(_train : CM_Train; _inward : Boolean) : Integer;
/*

Purpose:			
		This method calculates how many planned wagon is in the rail line for the train
Parameters:			

Return Value:		

Date		Who		Reason
01/05/2023	navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train

*/

vars
	numOfWagon 		: Integer;
	futureMove 		: CM_FutureMoveWagonPlanned;
	plannedTrain 	: CM_Train;
	wagon			: CM_Wagon;
begin
	
	foreach futureMove in self.allPlannedFutureMoves as CM_FutureMoveWagonPlanned discreteLock where futureMove.isInward = _inward do
		
		wagon := futureMove.myWagon;
		
		if wagon = null then 
			continue;
		endif;
		
		if _inward then
			plannedTrain := wagon.myTrainInwards;
		else
			plannedTrain := wagon.myTrainOutwards;
		endif;
		
		if plannedTrain = _train then
			numOfWagon += 1;
		endif;
	endforeach;
	
	return numOfWagon;
	
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_inward" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRakeTIs" id="a130552e-2e61-4fa7-8599-ec4a81356d9d">
        <updating/>
        <source>getRakeTIs(_tiArray: CM_TIArray input; _startIndex: Integer; _endIndex: Integer)updating;
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	iter	: Iterator;
	wagon 	: CM_Wagon;
	idx		: Integer;
begin
	
	iter := self.allWagons.createIterator;
	
	while iter.next(wagon) do
		idx := idx + 1;
		if wagon &lt;&gt; null then
			if idx &gt;= _startIndex and idx &lt;= _endIndex then
				if wagon.confirmed then
					wagon.getAllTrackedItems(true, _tiArray, false);	
				endif;						
			endif;
		endif;
	endwhile; 
	
epilog
	delete iter;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_startIndex" type="Integer"/>
        <Parameter name="_endIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWagonAtPosition" id="8e23b92d-08bf-4001-b1df-1033c4c7df3c">
        <source>getWagonAtPosition(posInRake : Integer) : CM_Wagon;
/*
 ------------------------------------------------------------------------
Created:			27 June 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if self.allWagons.size &lt; posInRake then
		return null;
	endif;
	return self.allWagons[posInRake];
end;</source>
        <Parameter name="posInRake" type="Integer"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getWagonSummary" id="55c2d4e5-3b0f-411e-b5b0-9f2bf4485313">
        <source>getWagonSummary( inward : Boolean; currentTrain : CM_Train;  allConfirmedTIs : CM_TIArray input; mtmConfirmedCargo : StringArray):JadeDynamicObjectArray;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation
11 August 2022	jlika1	TFS 53741 - EUP- Max Wagon Payload
11/07/2025		naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
*/

vars
	jdoArray : JadeDynamicObjectArray;
	jdo		 : JadeDynamicObject;

	pos : Integer;
	wagon : CM_Wagon;
	wagonTis : CM_TIArray;
	wagonConfirmedTis : CM_TIArray;
	tiIter : Iterator;
	ti : CM_TrackedItem;
	baseStr : String;
	dynaDict : DynaDictionary;
	verifiedTi : Boolean;
	str : String;
	colour : Integer;
	obj : Object;
	lastTi : CM_TrackedItem;
	tiCount : Integer;
	cargoTypeDesc : String;
	lastVerifiedTi : Boolean;
	lastCargoTypeDesc : String;
	doAddWagonCargoLine : Boolean;
	wagonConfirmed : Boolean;
	
begin
	create jdoArray transient;
	
	create wagonTis transient;
	create wagonConfirmedTis transient;
	create dynaDict transient;
	
	dynaDict.setMembership( CM_TrackedItem );
	dynaDict.addExternalKey(Boolean, 1, false, false);
	dynaDict.addExternalKey(String, 30, false, false);
	dynaDict.endKeys(true);

	// list every position on the Rail line
	foreach pos in 1 to self.maximumWagons do
		wagon := self.getWagonAtPosition(pos);
		wagonTis.clear;
		wagonConfirmedTis.clear;
		dynaDict.clear;
			
		if wagon = null then
			// empty position
			baseStr := pos.padLeadingWith("0",2) &amp; " - ";
			jdo := makeWagonSummaryJdo(baseStr, 1, 0, null);
			jdoArray.add(jdo);
		else
			// OK we got a wagon.
			baseStr := pos.padLeadingWith("0",2) &amp; " - " &amp; wagon.id;	// base string for wagon
			
			jdo := makeWagonSummaryJdo(baseStr, 1, 0, wagon);
			jdoArray.add(jdo);			
			
			//decide colour
			wagonConfirmed := false;
			if inward then
				if wagon.myTrainInwards &lt;&gt; null and wagon.myTrainInwards &lt;&gt; currentTrain and not wagon.myTrainInwards.isNullTrain then
					// not our train.
					jdo.setPropertyValue("color",Black);
					continue;
				elseif wagon.confirmed then
					jdo.setPropertyValue("color",Green);
					wagonConfirmed := true;
				else
					jdo.setPropertyValue("color",Red);				
					wagonConfirmed := false;
				endif;
			else
				if wagon.myTrainOutwards &lt;&gt; currentTrain then
					// not our train.
					jdo.setPropertyValue("color",Black);
					continue;
				elseif wagon.confirmedOutwards then
					jdo.setPropertyValue("color",Green);
					wagonConfirmed := true;
				else
					jdo.setPropertyValue("color",Red);
					wagonConfirmed := false;
				endif;
			endif;
					
			//find the cargo on the wagon.
			wagon.getAllTrackedItems(inward, wagonTis, false);
			
			if wagonTis.isEmpty then
				continue;
				
			else
				// add detail line(s) for wagon with cargo
				// put our cargo into a sorted dyna dict by cargo by type and whether it has been verified.
				tiIter := wagonTis.createIterator;
				while tiIter.next(ti) do
					if wagonConfirmed or(allConfirmedTIs &lt;&gt; null and allConfirmedTIs.includes(ti)) or (mtmConfirmedCargo &lt;&gt; null and mtmConfirmedCargo.includes(ti.getOidAsString()) ) then				
						verifiedTi := true;
					else
						verifiedTi := false;
					endif;
					if ti.isContainer then
						cargoTypeDesc := ti.getISOType;
					else
						cargoTypeDesc := ti.cargoTypeDescr;
					endif;
					dynaDict.putAtKey(verifiedTi, cargoTypeDesc, ti);
				endwhile;
				delete tiIter;
				
				//clear the local variables we rely on.
				lastTi := null;

				// read thru the dyna dict building lines in teh listbox  for 'unique' sets of cargo by type
				// and whether or not they are verified per wagon
				tiIter := dynaDict.createIterator;
				while tiIter.next( obj ) do
					ti := obj.CM_TrackedItem;
					tiIter.getCurrentKeys(verifiedTi,cargoTypeDesc);  //MTN-35226
									
					if lastTi = null then
						tiCount := 1;
						lastTi := ti;
						lastVerifiedTi := verifiedTi;
						lastCargoTypeDesc := cargoTypeDesc;
						continue;
					else
						if lastVerifiedTi &lt;&gt; verifiedTi or lastCargoTypeDesc &lt;&gt; cargoTypeDesc then
							// add a line
							doAddWagonCargoLine := true;
						else
							tiCount := tiCount + 1;
							continue;
						endif;
					endif;
					
					if doAddWagonCargoLine then
					
						str := Tab &amp; "- " &amp; tiCount.String &amp; " x " &amp; lastCargoTypeDesc;
						colour := Red;	// work to do
						if lastVerifiedTi then
							colour := Green; // my train and alreday confirmed.
						endif;
						jdo := makeWagonSummaryJdo(str, 2, colour, wagon);
						jdoArray.add(jdo);
						tiCount := 1;
						lastVerifiedTi := verifiedTi;
						lastCargoTypeDesc := cargoTypeDesc;
					
					endif;
				
				endwhile;
				
				// when we get to here, we wont have processed the last line yet,
				// so, unconditionally add the last one.
				str := Tab &amp; "- " &amp; tiCount.String &amp; " x " &amp; lastCargoTypeDesc;
				colour := Red;	// work to do
				if lastVerifiedTi then
					colour := Green; // my train and alreday confirmed.
				endif;
				jdo := makeWagonSummaryJdo(str, 2, colour, wagon);
				jdoArray.add(jdo);
				tiCount := 1;
				lastVerifiedTi := verifiedTi;
				lastCargoTypeDesc := cargoTypeDesc;
				
			endif;
			
		endif;
		
	endforeach;
	
	
	return jdoArray;
epilog

	delete wagonTis;
	delete tiIter;
	delete wagonConfirmedTis;
	delete dynaDict;
	
end;

</source>
        <Parameter name="inward" type="Boolean"/>
        <Parameter name="currentTrain" type="CM_Train"/>
        <Parameter name="allConfirmedTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="mtmConfirmedCargo" type="StringArray"/>
        <ReturnType type="JadeDynamicObjectArray"/>
    </JadeMethod>
    <JadeMethod name="makeWagonSummaryJdo" id="81898528-3a48-4a84-94d7-89115c6cf25a">
        <source>makeWagonSummaryJdo(text : String; level : Integer; color : Integer; object : Object):JadeDynamicObject protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2017	cnwsc8	Initial creation

*/

vars
	jdo : JadeDynamicObject;
begin
	create jdo transient;

	jdo.addProperty("text", String);
	jdo.setPropertyValue("text", text);
	jdo.addProperty("level", Integer);
	jdo.setPropertyValue("level", level);
	jdo.addProperty("color", Integer);
	jdo.setPropertyValue("color", color);
	jdo.addProperty("object", Object);
	jdo.setPropertyValue("object", object);
	
	return jdo;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="text" type="String"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="color" type="Integer"/>
        <Parameter name="object" type="Object"/>
        <ReturnType type="JadeDynamicObject"/>
    </JadeMethod>
    <JadeMethod name="removeIncompleteWLE" id="fa3bd225-af59-4239-bd2f-be41be91596c">
        <updating/>
        <source>removeIncompleteWLE(wle : CM_WorkListEntry) updating;
/*
 ------------------------------------------------------------------------
Created:			17 July 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if wle = null then
		return;
	endif;
	if not self.allIncompleteWLEs.includes(wle) then
		return;
	endif;
	self.allIncompleteWLEs.remove(wle);
end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="removeWagon" id="233c5962-29ca-40ff-84c6-0355e4f30770">
        <source>removeWagon(wagon : CM_Wagon input);
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwsgp1
// Purpose:		Manual end of array manipulation.  Use this method to remove
//				a wagon from a railline to make sure it is removed from
//				both collections.
// ---------------------------------------------------------------------------

vars
	currPos : Integer;
begin
	if wagon = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Wagon), null, null);
		return;
	endif;
	
	currPos := self.allWagons.indexOf(wagon);
	if currPos &gt; 0 then
		self.allWagons[currPos] := null;
	endif;
	if self.allWagonsById.includes (wagon) then
		self.allWagonsById.remove(wagon);
	endif;
end;</source>
        <Parameter name="wagon" type="CM_Wagon" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ab01c560-27ad-4509-aeab-e2f5f0d6f3dc">
        <updating/>
        <source>setForCreate(_id : String; _maximumWagons : Integer) updating;
/*
 ------------------------------------------------------------------------
Created:			16 July 2001 by cnwdwq1
Purpose:			Creates a RailLine. At this point it will have NO wagons
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
//	if _myRailArea = null then
//		app.setContinueCMExceptions(false);
//		app.raiseCMException1(ERR_NO_OBJECT, "CM_Rail reference", null, null);
//		return;
//	endif;
	//---------------------
	//All we want is the id and myRailArea reference
	//---------------------
	self.id := _id.trimBlanks;
	self.maximumWagons := _maximumWagons;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_maximumWagons" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRakeRegionDataToClear" id="1dfcbf20-ed7e-40a2-b143-6c552e4a2d55">
        <source>setRakeRegionDataToClear(_cmifRakeRegion : CMIF_RakeRegion input);
//--------------------------------------------------
// Created:	19 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	startPos,
	endPos,
	idx : Integer;
	wagon : CM_Wagon;
	job : CM_Job;
	msgStr : String;
begin
	
	startPos := _cmifRakeRegion.startPosition;
	endPos := _cmifRakeRegion.endPosition;
	
	foreach wagon in self.allWagons do
		idx := idx + 1;
		if wagon = null then
			continue;
		endif;
		sharedLock(wagon);
		if (not wagon.confirmed) or
		   (_cmifRakeRegion.myTrain &lt;&gt; null and wagon.myTrainInwards &lt;&gt; null and _cmifRakeRegion.myTrain &lt;&gt; wagon.myTrainInwards) then
			continue;
		endif;
		
		if idx &gt;= startPos and idx &lt;= endPos then
			if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean and (not wagon.confirmedOutwards) then
				app.raiseCMException1(Wagon_must_be_confirmed, wagon.id, null, null);//'Wagon %1 must be confirmed outwards before this section of the rail line can be cleared'
				continue;
			endif;
			_cmifRakeRegion.allWagons.add(wagon);
			foreach job in wagon.allRailJobs do
				exclusiveLock(job);
				if job.status &lt;&gt; JOB_COMPLETE then
		  			msgStr := msgStr &amp; job.jobId &amp; '; ';					
				endif;
				if (not job.isRelease) and (not job.isTransitJob()) then
					if job.status &lt;&gt; JOB_COMPLETE then
						app.setContinueCMExceptions(false);
						app.raiseCMException1(VB_UNACTIONED_RECEIPT, job.jobId, null, null);
						return;
					endif;
				endif;				
			endforeach; 	
		endif;
		if idx &gt; endPos then
			break;
		endif;
	endforeach;
	
	_cmifRakeRegion.warningMessage := msgStr;
end;</source>
        <Parameter name="_cmifRakeRegion" type="CMIF_RakeRegion" usage="input"/>
    </JadeMethod>
    <JadeMethod name="switchPositions" id="a02124ea-6ae8-4ed6-9d32-754579c57745">
        <updating/>
        <source>switchPositions(sourceWagon: CM_Wagon input; pPosition : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lFrom, lTo : Integer;	
begin
	
	if sourceWagon = null then
		return false;
	endif;

	if pPosition &lt; 1 then
		return false;
	endif;
	
	app.myTrxUA.trxUpdateWagonPosition(self,sourceWagon, pPosition, app.myPassport);

	return true;
end;</source>
        <Parameter name="sourceWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tidyWagons" id="856e0aa2-bdfc-474e-96fd-b9eff9ad718c">
        <source>tidyWagons();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		Get rid of any empty (null) wagon positions after the last non null position
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lWagon : CM_Wagon;
	lLast	: Integer;
begin
	
	while lWagon = null do
		lLast := self.allWagons.size;
		lWagon := self.allWagons.last;
		if lWagon &lt;&gt; null or lLast &lt; 1 then
			break;
		endif;
		self.allWagons.removeAt(lLast);
	endwhile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMoveLabourRestriction" id="996cce56-39c9-44b1-9511-c67815035f68">
        <source>validateMoveLabourRestriction(control : CMIF_MoveController );
/*
 ------------------------------------------------------------------------
Created:			30 July 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.myRailArea.validateMoveLabourRestriction(control);
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateTIsForConfirm" id="527bc4ef-b8d7-4b7a-b302-9c9f5370c97c">
        <source>validateTIsForConfirm(_passport : CM_Passport input) : Boolean;
//-----------------------------------------
//Created: June 2004 By: cnwgd1
//-----------------------------------------
vars
	wagon 	: CM_Wagon;
begin
	
	foreach wagon in self.allWagons discreteLock do
		if wagon = null then
			continue;
		endif;	
		wagon.validateTIsForConfirm(_passport);
	endforeach;

	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
