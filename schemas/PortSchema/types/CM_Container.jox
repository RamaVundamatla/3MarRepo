    <JadeMethod name="getPlannerReportDischGroupDesc" id="f14ffdf3-2893-40f1-930e-7e4383592906">
        <source>getPlannerReportDischGroupDesc() : String;
/*
Purpose:			
Date		Who		Reason
16 June 2011	cnwab1	Initial creation
*/

vars
	isoGroup : CM_ISOTypeGroup;
	iso : CM_ISOType;
	desc, port : String;
begin
	port := self.getShortDPortCode();
	return self.getActualLength.String &amp; port;
	
	isoGroup := self.getISOTypeGroup();
	
	if isoGroup = null then
		iso := self.getISOTypeObject();	
		if iso = null or iso.myISOTypeGroup = null then
			desc := "???";
		else
			desc := iso.myISOTypeGroup.code;
		endif;
	else
		desc := isoGroup.code;
	endif;	
	return desc &amp; " " &amp; port;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
