    <JadeMethod name="jobId" id="cee6469a-6bb2-468e-87af-a5e5ef1a5180">
        <methodInvocation>mapping</methodInvocation>
        <source>jobId(set: Boolean; value: String io) mapping;
vars
	str	:	String;
	//maxLen	:	Integer;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.myVoyage = null then
		value := null;
		return;
	endif;
	
	str := self.myVoyage.code.trimBlanks &amp; " - " &amp; jobNum.trimBlanks;
	//maxLen := CM_Job.getProperty("jobId").getLength;
	if str.length &gt; JOBID_LEN -1 then
		str := str[1:JOBID_LEN -1];
	endif;
	value := str;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
