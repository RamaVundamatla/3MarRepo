    <JadeMethod name="tblAttributes_click" id="becaebe8-faa9-4379-be55-fa17e9b0e522">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAttributes_click(table: Table input) updating;
// JLGAB1 30MAY18
// TFS 38982
vars
	col : Integer;
	row : Integer;
	value : Boolean;
	attrib : CM_ProductAttr;
begin

	if self.mode &lt;&gt; Mode_Update then
		return;
	endif;
	
	col := table.column;
	row := table.row;
	
	if col = 1 then
		table.accessCell(row,col);
		table.accessRow(row);
		value := table.accessedCell.text.Integer.Boolean;
		
		if table.accessedRow.itemObject.isKindOf(CM_ProductAttr) then
			attrib := table.accessedRow.itemObject.CM_ProductAttr;
			attrib.setIsViewable(not value);
			table.accessedCell.text := (not value).Integer.String;
		endif;
	endif;
	
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblAttributes_contextMenu" id="9b94f7b3-ce78-45a7-b266-c35f236ff837">
