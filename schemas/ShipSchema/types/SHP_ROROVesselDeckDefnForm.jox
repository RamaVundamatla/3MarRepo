        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getROROStructure" id="c8fa8dbe-d272-4d98-a959-217540966dd4">
        <source>getROROStructure(): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myROROStructure;

epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getSectionFromPixelX" id="52e7b6a7-c8f4-406d-bfce-a70347f32139">
        <source>getSectionFromPixelX(x : Real; _posM : Decimal io) : CM_VesselSection;
/*
Purpose:			
Date		Who		Reason
28 April 2011	cnwab1	Initial creation
*/

vars

	tmpSect : CM_VesselSection;
	posM : Decimal[12,2];

begin

	posM := (ROROStructureRearLine * self.scaleFactor);
	posM := x - posM;
	posM := posM / (ROROStructurePixelsPerMetre* self.scaleFactor);
	
	tmpSect := self.myROROStructure.getSectionByPosition(posM, 0.2);
	_posM := posM;
	return  tmpSect;


epilog

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="_posM" type="Decimal" usage="io"/>
        <ReturnType type="CM_VesselSection"/>
    </JadeMethod>
    <JadeMethod name="initDetails" id="d86cafd7-8682-43b3-a3b1-c0600a6a789a">
        <updating/>
        <source>initDetails(_parent: CM_Object; _deck: CM_DeckVessel; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	roroVessel	: CM_ROROVesselStructure;
	deck 		: CM_DeckVessel;
begin	

	self.mode:=_mode;

	self.setupDeckItemTable();
	
	deck:=_deck;
	if _parent.isKindOf(CM_ROROVesselStructure) then
		roroVessel:=_parent.CM_ROROVesselStructure;
	elseif _parent.isKindOf(CM_DeckVessel) then
		roroVessel:=_parent.CM_DeckVessel.myROROStructure;
		self.isSubDeck:=true;
		
		deck:=_parent.CM_DeckVessel;
	endif;
	
	self.doChangeROROStructure(roroVessel,_deck);

	if _mode = self.Mode_Copy and _deck &lt;&gt;  null and _deck.isTransient then
		self.myCurrentProxyDeck:=_deck;
	endif;	
	if self.isSubDeck and _deck &lt;&gt; deck then
		self.cmbDeck.listObject:=deck;
	endif;
	self.doChangeMode(self.mode);

epilog

end;</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_deck" type="CM_DeckVessel"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadROROStructureCombo" id="876128d6-8776-4ace-9a6c-e47d7960f873">
        <updating/>
        <source>loadROROStructureCombo(_deck : CM_DeckVessel) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars

begin
	self.myAssistant.comboBoxROROVessel(self.cmbVessel,self.myROROStructure);
	
//	if self.myROROStructure &lt;&gt; null then
//		self.myAssistant.comboBoxROROVesselDecks(self.cmbDeck,self.myROROStructure,_deck);
//	endif;
	
	
	inheritMethod(_deck);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_DeckVessel"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="c69ef631-1021-4e93-8727-1d7f53eeb941">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	tmpCaption : String;
	deck 		:  CM_Deck;
begin
	if self.mode = self.Mode_View then
		tmpCaption  := "(" &amp; app.getErrorString(View).toUpper() &amp; ") ";
	elseif self.mode = self.Mode_Edit then
		tmpCaption  := "(" &amp; app.getErrorString(Edit).toUpper() &amp; ") ";
	elseif self.mode = self.Mode_New then
		tmpCaption  := "(" &amp; app.getErrorString(New).toUpper() &amp; ") ";
	elseif self.mode = self.Mode_Copy then
		tmpCaption  := "(" &amp; app.getErrorString(Copy).toUpper() &amp; ") ";
	endif;

	tmpCaption  := tmpCaption &amp; app.getErrorString(Roro_vessel_deck_definit);
	
	
	if self.myCurrentProxyDeck &lt;&gt; null then
		deck:=self.myCurrentProxyDeck;
	elseif self.myCurrentDeck &lt;&gt; null then
		deck:=self.myCurrentDeck;
	endif;
	
	if deck  = null then
		return;
	endif;
	
	tmpCaption  := tmpCaption &amp; " - " &amp; deck.getVessel.code;
	if self.mode = self.Mode_New then
		if deck.isKindOf(CM_DeckVesselSub) then
		
			tmpCaption  := tmpCaption &amp;", " &amp; app.getErrorString(Parent_deck)  &amp; ": " &amp; deck.CM_DeckVesselSub.myParentDeck.code;		
		endif;
	else
		tmpCaption  := tmpCaption &amp;", " &amp; app.getErrorString(Deck) &amp; ": " &amp; deck.code;
	endif;

	if self.myCurrentProxyLayerLayout &lt;&gt; null then
		tmpCaption  := tmpCaption &amp; ", " &amp; app.getErrorString(Layer) &amp; ": " &amp; self.myCurrentProxyLayerLayout.code;
	endif;

	self.caption := tmpCaption;
epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="startROROStructureNotes" id="9d132640-3171-4080-b375-9da1c11f18c2">
        <source>startROROStructureNotes()  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation

*/

vars

begin
	self.beginNotification(self.myROROStructure,EVENT_VESSEL_DECK_CREATE,Response_Continuous,null);
	self.beginNotification(self.myROROStructure,EVENT_VESSEL_DECK_UPDATE,Response_Continuous,null);
	self.beginNotification(self.myROROStructure,EVENT_VESSEL_DECK_DELETE,Response_Continuous,null);
	
	//got this error in dmast in reality shouldn't be able to have a roro vessel with no container structure
	if self.myROROStructure.myVessel.myCellularVesselStructure &lt;&gt; null then
	
		self.beginNotification(self.myROROStructure.myVessel.myCellularVesselStructure,EVENT_SECTION_CREATE,Response_Continuous,null);
		self.beginNotification(self.myROROStructure.myVessel.myCellularVesselStructure,EVENT_SECTION_UPDATE,Response_Continuous,null);
		self.beginNotification(self.myROROStructure.myVessel.myCellularVesselStructure,EVENT_SECTION_DELETE,Response_Continuous,null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7429b1d1-5d98-4f9c-b003-6ec82039cdcc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 15:43:28.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022917, locale);
end;</source>
    </JadeMethod>
</GUIClass>
