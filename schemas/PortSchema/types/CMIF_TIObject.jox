    <JadeMethod name="getInOutJob" id="de56cad6-99dc-439e-9945-588bdb991b91">
        <source>getInOutJob() : CM_RoadJob;
// ---------------------------------------------------------------------------
// Created:     05 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	job	: CM_RoadJob;
	
begin

	if self.myIntFaceInOutCommon = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIntFaceInOutCommon not set (call setMyInOutCommon(..) to set)');
		return null;
	endif;

	job := self.myIntFaceInOutCommon.myRoadJob;
	
	if job = null then
		//Must have a road job to handle this receival
		app.raiseCMException(ErrorOnStore_JobIsNull, null, null);
		return null;
	endif;
	
	return job;
	
end;</source>
        <ReturnType type="CM_RoadJob"/>
    </JadeMethod>
