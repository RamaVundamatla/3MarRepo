    <JadeMethod name="getDamageDetailsDescr" id="9e91cb2c-f283-44b2-8b2d-57f981e6142f">
        <source>getDamageDetailsDescr() : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 09 May 2019
TFS#		: 44287
Function	:

*** Changes ***
Date			Name		TFS#		Description
24 June 2022 	navhl20	 	53862 		EUP - WMS - Damage Recording Extra Details
****************************************************/
vars
	damageInstance			: CM_DamageInstance;
	str						: String;
	idx						: Integer;
	dsLevel					: String;		//28 June 2022 navhl20 TFS 53862
begin
	foreach damageInstance in self.allDamageInstancesByPos do
		if damageInstance.myDamagePosition = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Damage entry unconverted.');
		else	
			//Start 28 June 2022 navhl20 TFS 53862
			if damageInstance.myDamageSeverity &lt;&gt; null then
				dsLevel	:= damageInstance.myDamageSeverity.level.String;
			endif;
			//End 28 June 2022 navhl20 TFS 53862
			if str = null then
				//str := damageInstance.myDamagePosition.description &amp;' '&amp;'has '&amp;damageInstance.myDamageDefinition.description &amp;' (' &amp; damageInstance.severity.String &amp;')';		//24 June 2022 navhl20 TFS 53862
				str := damageInstance.myDamagePosition.description &amp;' '&amp;'has '&amp;damageInstance.myDamageDefinition.description &amp;' (' &amp; dsLevel &amp;')'; 		//24 June 2022 navhl20 TFS 53862
			else
				//str := str &amp; ", " &amp; damageInstance.myDamagePosition.description &amp;' '&amp;'has '&amp;damageInstance.myDamageDefinition.description &amp;' (' &amp; damageInstance.severity.String &amp;')';		//24 June 2022 navhl20 TFS 53862
				str := str &amp; ", " &amp; damageInstance.myDamagePosition.description &amp;' '&amp;'has '&amp;damageInstance.myDamageDefinition.description &amp;' (' &amp; dsLevel &amp;')';		//24 June 2022 navhl20 TFS 53862
				
			endif;
		endif;
	endforeach;

	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
