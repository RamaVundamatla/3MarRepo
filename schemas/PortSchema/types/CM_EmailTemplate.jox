    <JadeMethod name="attachFile" id="a086b797-9028-42b7-8d00-642e05555f3e">
        <source>attachFile(_fileName	: String);
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allAttachedFilePaths.add(_fileName);


end;</source>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="canBeDeletedForVoyageStatus" id="9582f2d7-7f15-487e-b98e-26420e500d49">
        <source>canBeDeletedForVoyageStatus() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/03/2018	jlgdap1		Initial creation TFS 37540 PEL1 Voyge Statuses Pelindo 1
//
vars

begin
	if self.bccAddresses = null and self.ccAddresses = null and self.toAddresses = null 
	and self.subject = null and self.body = null then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="81c49ad3-3fad-4d41-a19b-e9e56e724b41">
        <updating/>
        <source>cloneReferences(_proxyTemplate : SelfType; _isTransient : Boolean) updating;
// -------------------------------------------
// Created 05 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	_proxyTemplate.allToAddresses.copy(self.allToAddresses);
	_proxyTemplate.allCCAddresses.copy(self.allCCAddresses);
	_proxyTemplate.allBCCAddresses.copy(self.allBCCAddresses);
	
	self.myFromAddress := _proxyTemplate.myFromAddress;

end;</source>
        <Parameter name="_proxyTemplate" type="SelfType"/>
        <Parameter name="_isTransient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllBCCAddressesOrNames" id="c84af7d0-11ed-4ca0-8bd3-6573a230ad25">
        <source>getAllBCCAddressesOrNames(_names : Boolean) : String;
// -------------------------------------------
// Created 05 November 2003 by cnwdvb1
// -------------------------------------------
vars

	str : String;

begin

	if _names then
		str := self.allBCCAddresses.getNames();
	else
		str := self.allBCCAddresses.getAddresses();
	endif;

	if self.bccAddresses.length &gt; 0 then
		if str &lt;&gt; null then
			return self.bccAddresses &amp; ';' &amp; str;	
		else
			return self.bccAddresses;
		endif;
	else
		return str;	
	endif;


end;</source>
        <Parameter name="_names" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllCCAddressesOrNames" id="34665ff9-959a-4645-998f-62589db1d599">
        <source>getAllCCAddressesOrNames(_names : Boolean) : String;
// -------------------------------------------
// Created 05 November 2003 by cnwdvb1
// -------------------------------------------
vars

	str	: String;
	
begin


	if _names then
		str := self.allCCAddresses.getNames();
	else
		str := self.allCCAddresses.getAddresses();
	endif;
	
	if self.ccAddresses.length &gt; 0 then
		if str &lt;&gt; null then
			 return self.ccAddresses &amp; ';' &amp; str;	
		else
			return self.ccAddresses;
		endif;
	else
		return str;	
	endif;


end;</source>
        <Parameter name="_names" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllToAddressesOrNames" id="ed8900b2-357f-4ab1-861d-dc7105b6ecba">
        <source>getAllToAddressesOrNames(_names : Boolean) : String;
// -------------------------------------------
// Created 05 November 2003 by cnwdvb1
// -------------------------------------------
vars

	str : String;

begin

	if _names then
		str := self.allToAddresses.getNames();
	else
		str := self.allToAddresses.getAddresses();
	endif;
	
	if self.toAddresses.length &gt; 0 then
		if str &lt;&gt; null then
			 return self.toAddresses &amp; ';' &amp; str;	
		else
			return self.toAddresses;
		endif;
	else
		return str;
	endif;
end;</source>
        <Parameter name="_names" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFromAddress" id="81f9ecc6-ebc2-4250-9160-4bfe9414fca7">
        <source>getFromAddress() : String;
// -------------------------------------------
// Created 22 November 2005 by cnwgd1
// -------------------------------------------
vars
	sender : String;
begin
	if self.myFromAddress &lt;&gt; null then
		sender := self.myFromAddress.getEmailAddress();
	endif;
	if sender = null then
		sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	endif;
	return sender;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="710359e7-f7a2-414f-a01c-c6ac701cccf4">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 05 November 2003 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxyTemplate : CM_EmailTemplate;
	completedOK		: Boolean;
	
begin
	
	pxyTemplate := inheritMethod();
	
	self.allToAddresses.copy(pxyTemplate.allToAddresses);
	self.allCCAddresses.copy(pxyTemplate.allCCAddresses);
	self.allBCCAddresses.copy(pxyTemplate.allBCCAddresses);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyTemplate;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyTemplate;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
