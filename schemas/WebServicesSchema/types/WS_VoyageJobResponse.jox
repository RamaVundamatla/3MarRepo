    <JadeMethod name="setFromRequest" id="5760ae7a-aa22-4ea1-8503-62bd99726236">
        <updating/>
        <source>setFromRequest(_request : WS_VoyageJobRequest) updating;
/*
Purpose:			
Date		Who		Reason
28 July 2015	cnwab1	Initial creation
*/

vars

begin
	self.alternativeIdTouched := _request.alternativeIdTouched;
	self.damageTouched := _request.damageTouched;
	self.dimensionsTouched := _request.dimensionsTouched;
	self.hazardsTouched := _request.hazardsTouched;
	self.overDimensionsTouched := _request.overDimensionsTouched;
	self.photoTouched := _request.photoTouched;
	self.sealsTouched := _request.sealsTouched;
	self.temperatureTouched := _request.temperatureTouched;
	self.weightTouched := _request.weightTouched;
	
	self.targetLocation := _request.targetLocation;
	self.moveMode := _request.moveMode;
	self.cargoIdSearch := _request.cargoIdSearch;
	self.cargoId := _request.cargoId;
	self.cargoUid := _request.cargoUid;
	self.jobMode := _request.jobMode;
	self.voyageCode := _request.voyageCode;
	self.laneId := _request.laneId;
	self.craneId := _request.craneId;
	self.areaCode := _request.areaCode;
	self.areaDescription := _request.areaDescription;
	
epilog

end;</source>
        <Parameter name="_request" type="WS_VoyageJobRequest"/>
    </JadeMethod>
