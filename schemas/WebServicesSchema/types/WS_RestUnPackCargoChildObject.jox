        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateRequest" id="810a4bf5-d703-4ea5-9a9e-4c8ed8274604">
        <updating/>
        <source>validateRequest(_parent : CM_TrackedItem):CMIF_UnPackingCargoChild updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2024	navsp1	Initial creation TFS ChangeRequest 65967: CUX | MasterTerminalAPI - Pack and Unpack APIs
08 October	 2024   navsp1  JIRA Bug CUX | Pack and Unpack APIs Issue
*/

vars
	childCMIF 				: CMIF_UnPackingCargoChild;
	cargoTypeChild 			: CM_CargoType;
	childCargoFound 		: CM_TrackedItem;
	terminal 				: CM_Terminal;
	weight 					: Decimal [14,4];	
	volume 					: Decimal [14,4];	
	quantity				: Integer;
	unit					: CM_MeasurementType;
	locationId  			: String;
	unpackTime 				: TimeStampOffset;
begin
	terminal := app.myPassport.myTerminal;
	if self.id = null then
		app.myPassport.addErrorFull(Field_tracke_item_requir_reque, app.getErrorString2(Field_tracke_item_requir_reque, app.getErrorString(CargoId), self.id), null, null, null);
	endif;
	
	if self.cargoTypeId = null then
		app.myPassport.addErrorFull(Field_tracke_item_requir_reque, app.getErrorString2(Field_tracke_item_requir_reque, app.getErrorString(CargoType), self.id), null, null, null);
	endif;
	
	cargoTypeChild := app.myRoot.getCargoTypeFromAbbrev(self.cargoTypeId);
	
	if cargoTypeChild = null then
		app.myPassport.addErrorFull(Cargo_speci_track_item_not_val, app.getErrorString2(Cargo_speci_track_item_not_val, self.cargoTypeId, self.id), null, null, null);
	endif;
	
	childCargoFound := terminal.lookupTrackedItem(self.id, cargoTypeChild.id, TI_STATE_NORMAL, null, false);
	
	if childCargoFound = null then
		app.myPassport.addErrorFull(Edi_CargoMove_Cargo_not_found, app.getErrorString1(Edi_CargoMove_Cargo_not_found, self.id), null, null, null);
		return null;
	endif;
	
	if not childCargoFound.isChild then																															//JIRA 33031
		app.myPassport.addErrorFull(Not_unpack_cargo_not_packed, app.getErrorString1(Not_unpack_cargo_not_packed, self.id), null, null, null);					//JIRA 33031
		return null;																																			//JIRA 33031
	endif;																																						//JIRA 33031
	
	if childCargoFound.myParent &lt;&gt; _parent then																													//JIRA 33031
		app.myPassport.addErrorFull(Cargo_not_found_unpack, app.getErrorString2(Cargo_not_found_unpack, self.id, _parent.id), null, null, null);				//JIRA 33031
		return null;																																			//JIRA 33031
	endif;																																						//JIRA 33031
	
	// Check weights and quantities to pack
	quantity 	:= self.quantity;
	
	if self.weight &lt;&gt; null then
		weight 		:= self.weight.amount;
		unit		:= app.myRoot.allMeasurementTypesByShortName[self.weight.unit];
		
		// If the unit is invalid raise an error
		if unit = null then
			app.myPassport.addErrorFull(Field_tracked_item_invalid, app.getErrorString2(Field_tracked_item_invalid, app.getErrorString(Measurement_type), self.id), null, null, null);
		endif;
		
		// Convert if necessary
		if not unit.isDefault then
			weight 	:= unit.convertValueAsValue(weight);
		endif;
	endif;
	
	if self.volume &lt;&gt; null then
		volume 		:= self.volume.amount;
		unit		:= app.myRoot.allMeasurementTypesByShortName[self.volume.unit];
		
		// If the unit is invalid raise an error
		if unit = null then
			app.myPassport.addErrorFull(Field_tracked_item_invalid, app.getErrorString2(Field_tracked_item_invalid, app.getErrorString(Measurement_type), self.id), null, null, null);
		endif;
		
		// Convert if necessary
		if not unit.isDefault then
			volume 	:= unit.convertValueAsValue(volume);
		endif;
	endif;
	
	if childCargoFound.myCargoType.isTrackByVolume then
		weight 	:= volume * childCargoFound.getDensity;
	endif;
	
	// Needs a quantity, volume or weight
	if quantity = null and weight = null and volume = null then
		app.myPassport.addErrorFull(Must_provi_eith_qty_wt_vol, app.getErrorString1(Must_provi_eith_qty_wt_vol, childCargoFound.id), null, null, null);
	endif;
	
	//Check the target location
	locationId := self.targetLocationId;
	if locationId = null then
		app.myPassport.addErrorFull(Location_NotFound, app.getErrorString1(Location_NotFound, locationId), null, null, null);
	endif;
	
	unpackTime := self.unpackTime;
	
	if app.myPassport.hasErrors() then
		self.isValid := false;
	else	
		self.isValid := true;
		create childCMIF transient;	// Transient deletion here should be handled in the postPack Method
		childCMIF.initialise(childCargoFound, quantity, weight, volume, locationId, unpackTime);		
	endif;	
	return childCMIF;
epilog

end;</source>
        <Parameter name="_parent" type="CM_TrackedItem"/>
        <ReturnType type="CMIF_UnPackingCargoChild"/>
    </JadeMethod>
</Class>
