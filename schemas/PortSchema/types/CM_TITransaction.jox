    <JadeMethod name="getCountryOfOriginRegion" id="1c9dd12b-6086-46ed-b0cd-9e4c07bc1c53">
        <source>getCountryOfOriginRegion() : CM_CountryRegion;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria

*/

vars
	port	: CM_Port;
	country : CM_Country;
	region	: CM_CountryRegion;
	
begin
	country := self.myCountryOfOrigin;
	
	if country &lt;&gt; null then
		region := country.myCountryRegion;
	else
		port := self.getLoadPortObject();
		
		if port &lt;&gt; null then
			country := port.myCountry;
			if country &lt;&gt; null then
				region := country.myCountryRegion;
			endif;
		endif;
	endif;
	
	return region;
epilog

end;</source>
        <ReturnType type="CM_CountryRegion"/>
    </JadeMethod>
