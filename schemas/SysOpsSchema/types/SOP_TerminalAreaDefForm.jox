    <JadeMethod name="doSave" id="46a2a043-c3cd-4a37-b9e4-007879282935">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/09/2009	cnwcs5		par 20582 - stop validation for yard interchange area
//							going into grid area validation
// 22/08/2011	cnwdap1		PAR #28047 CCMS POL 2095 - update machines for this terminal area
// 24 Apr 2012	cnwkpd1		PAR #29471 - Fix leak of CM_Machine proxies
// 15 Jul 2013  cnwer1 		PAR #31985 removed trailer area types
// 04 Jun 2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 10 Dec 2020	jlgdap1		TFS 50110 ASPA General Cargo Allocation Row - Label
// 08 Sep 2022	jlika1		TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
// ---------------------------------------------------------------------------

vars
 	pxyTermArea								: CM_TerminalAreaMaster;
	result									: Integer;
	deckingLevelToUpdateTo					: Integer;
	deckingOptions							: CM_YADeckingOptions;
	taTypeObj								: CM_TerminalAreaType;

	interfaceObjects						: ObjectArray;
	anInterfaceObject						: CMIF_GridTARegion;
	int										: Integer;
	intArray								: IntegerArray;
	row										: CM_GridRow;
	lc										: CM_LocationsController;
	heightOfStack							: Integer;
	stagHeight								: Integer;
	stagHeightChanged						: Boolean;
	currentString							: String;
	proxyString								: String;
	
	machines								: CM_MachineSet;			// PAR #28047
	reStartObj : CM_Object; 	//21 Dec 2015	NDL	Par 37270
begin


	if self.myProxyObject = null then
		app.msgBox(app.getErrorString(YouMustSelectATerminalAreaType), self.caption, 0); 
		return false;
	endif;
		
	// 30458 check lane grouping/prev/next lane are setup OK
	if terminalAreaType = TA_TYPE_RTG  or terminalAreaType = TA_TYPE_RMG  then
		if not self.validateRTGAreaLaneGrouping() then
			return false;
		endif;
	endif;
	
	self.frmStrictGrid.visible := false;
	deckingLevelToUpdateTo:=-1;
	taTypeObj:=app.myRoot.allTerminalAreaTypes[terminalAreaType];
	if self.myCMIFTerminalArea = null or self.myCMIFTerminalArea.taType &lt;&gt; terminalAreaType then
		self.createCMIFTerminalArea(taTypeObj);
	endif;
	self.setCMIFFromTable();
	
	if taTypeObj.isGridAreaType then
		self.buildOrAdjustAreaSize(false);
	endif;
	
	if terminalAreaType = TA_TYPE_STRADDLE_STACK then
		self.setTAStraddle();
	elseif terminalAreaType = TA_TYPE_LOGAREA then
		self.setTALog();
	elseif terminalAreaType = TA_TYPE_FORK_LIFT_STACK then
		self.setTAFork();
	elseif terminalAreaType = TA_TYPE_RTG  or terminalAreaType = TA_TYPE_RMG  then
		self.setTARTG(terminalAreaType);
	elseif terminalAreaType = TA_TYPE_IRREGULAR_BLOCK_AREA then
		self.setTABlockArea(false);
	elseif terminalAreaType = TA_TYPE_RAILWAY_TRACK then
		self.setTARail();
	elseif  terminalAreaType = TA_TYPE_BLOCK_STACK
	or terminalAreaType = TA_TYPE_REPAIR
	or terminalAreaType = TA_TYPE_PTI
	or terminalAreaType = TA_TYPE_COU_STORE_AREA
	or terminalAreaType = TA_TYPE_GENERATOR_STORE_AREA
	or terminalAreaType = TA_TYPE_WASH_AREA
	or terminalAreaType = TA_TYPE_FUMIGATION_AREA
	or terminalAreaType = TA_TYPE_CONT_PACK_REPACK
	or terminalAreaType = TA_TYPE_COU_CRIB_PACK_UNPACK
	or terminalAreaType = TA_TYPE_DELETE
	or terminalAreaType = TA_TYPE_HIDE
	or terminalAreaType = TA_TYPE_GATE_ROAD
	or terminalAreaType = TA_TYPE_RELTRANS		//NFS 3833 AA 5/0/01
	or terminalAreaType = TA_TYPE_RECTRANS
	or terminalAreaType = TA_TYPE_RAIL_TRANS//PAR 14704 - Unable to create rail transfer areas
	or terminalAreaType = TA_TYPE_DAIRY	
	or terminalAreaType = TA_TYPE_MAFI
	then
		self.setTABlock();
	elseif terminalAreaType = TA_TYPE_DEPOT_LCL then
		self.setTADepot();
	elseif terminalAreaType = TA_TYPE_BUILDING then
		self.setTABuilding();
	elseif terminalAreaType = TA_TYPE_CRANE_TRANS then
		self.setTACrane();
	elseif terminalAreaType = TA_TYPE_INTERTERM_TRANS_AREA then
		self.setTATerminalTransfer();
	elseif terminalAreaType = TA_TYPE_BULK then	// R Barr 3/11/2006 Comalco
		self.setTABulk();
	elseif terminalAreaType = TA_TYPE_YARD_INTERCHANGE then	// cnwcs5 23/06/2009 ccms 1061
		self.setTAYardInterchangeArea;						// cnwcs5 23/06/2009 ccms 1061
	elseif terminalAreaType = TA_TYPE_RTG_LANE or terminalAreaType =  TA_TYPE_RMG_LANE then //epr 19/8/09 ccms 1076
		self.setTARTGLane(terminalAreaType);
	elseif terminalAreaType = TA_TYPE_RORO_LANE_AREA then	// cnwjk3 20/11/2009 ccms 1018
		if not self.setTARoRoLaneArea() then				// cnwjk3 20/11/2009 ccms 1018
			return false;
		endif;
	elseif terminalAreaType = TA_TYPE_WORKPOINT_INTERCHANGE then //epr CCMS 1033 9/8/11
		if not self.setTAWorkPointInterchange() then
			return false;
		endif;
		
	elseif terminalAreaType = TA_TYPE_GEN_CARGO_ALLOC_ROW then		// TFS 49453
		if not self.setTAGeneralAllocRow() then						// TFS 49453
			return false;											// TFS 49453
		endif;														// TFS 49453
		
	else
		// rs oct 2005 par 10926 tell them that it is not supported
//		app.msgBox("The selection you have chosen is not supported", self.caption, MsgBox_OK_Only);
		app.msgBox(app.getErrorString(Select_have_chosen_not_suppor), self.caption, MsgBox_OK_Only);
		return false;
	endif;

	// Check to see if TA is in use, i.e has TIs, wagons.
	pxyTermArea := self.myProxyObject.CM_TerminalAreaMaster;
	if taTypeObj.isGridAreaType  then	// 21/09/2009 par 20582
		if not self.myCurrentSOPGridArea.validateColumnLabels() then
			app.msgBox(app.getErrorString(LabelsMustBeUnique),app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		self.myCurrentSOPGridArea.relabelColumns(pxyTermArea.CM_GridArea);
		self.myCurrentSOPGridArea.relabelRows(pxyTermArea.CM_GridArea);
		self.myCurrentSOPGridArea.relabelGridControllers(pxyTermArea.CM_GridArea); //epr par 21526
		
		if  not self.validateGridInterchangeAreas() then
			app.msgBox(app.getErrorString(Assoc_Grid_LC_More_One_IC),app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
	endif;	
	
	// Set stock controller if it is available for this terminal area type.
	if pxyTermArea.canBeStockControlled then
		pxyTermArea.CM_TerminalArea.setIsStockControlled(self.tblMain.getValueByName(ETRow_StockControlled).Boolean);
	endif;
	
	// PAR #28047 update selected machines
	create machines transient;
	self.listsMachines.getSelected(machines);
	pxyTermArea.updateMachines(machines);
	// PAR #28047 end

	//+cnwml2 PAR26097
	//see if staggering heights have changed
	stagHeightChanged := false;
	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CM_ForkLiftStack) then
			foreach int in self.myCurrentObject.CM_ForkLiftStack.staggerHeights do
				if currentString = null then
					currentString := int.String;
				else
					currentString := currentString &amp; ", " &amp; int.String;
				endif;
			endforeach;
			
			foreach int in pxyTermArea.CM_ForkLiftStack.staggerHeights do
				if proxyString = null then
					proxyString := int.String;
				else
					proxyString := proxyString &amp; ", " &amp; int.String;
				endif;
			endforeach;
			
			if currentString &lt;&gt; proxyString then
				stagHeightChanged := true;
			endif;
		endif;
	else
		stagHeightChanged := true;
	endif;
	
	// cnwjk3 CCMS 1032 15/12/2008
	if self.mode = Mode_Add then	
		while true do
			app.myTrxCA.trxCreateTerminalArea(self.myProxyObject.CM_TerminalAreaMaster, self.myCurrentObject,app.myPassport);
			if app.myPassport.trxCompletedOK then
				//self.myCurrentObject := self.myCMIFTerminalArea.myTerminalAreaMaster;
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Terminal_area_definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				//elseif (not app.myPassport.noErrors) then
				else
					return false;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
		endwhile;	
	else
	
		//21 Dec 2015	NDL	Par 37270
		if self.myCurrentObject &lt;&gt; null then
			//disarmm so we don't process the updates multiple times.
			reStartObj := self.myCurrentObject.CM_Object;
			self.disarmNotesForObject(reStartObj);
		endif;
	
		if not pxyTermArea.isGridArea() then // PAR 17049
			while true do
				if self.myProxyObject.isKindOf(CM_GeneralCargoAllocRowArea) then												// TFS 50110
					app.myTrxUA.trxUpdateTerminalAreaGCAlloc(self.myProxyObject.CM_GeneralCargoAllocRowArea, app.myPassport);	// TFS 50110
				else																											// TFS 50110
					app.myTrxUA.trxUpdateTerminalArea(self.myProxyObject.CM_TerminalAreaMaster, app.myPassport);
				endif;																											// TFS 50110
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					break;
				else
					result := app.showErrorWarningDialog(app.getErrorString(Terminal_area_definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					elseif (not app.myPassport.noErrors) then
						return false;
					endif;
					self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				endif;
				break;
			endwhile;
		else
			//this is not required for the other types of updates above
			//th2 21/08/06 - this was commented out because originally we could not know
			//if the user had added a column and then deleted it, but now we have the 
			//self.areaChanged boolean which we are keeping track of - this is used below
			
			if pxyTermArea.isKindOf(CM_TerminalArea) then
				deckingLevelToUpdateTo := self.testForDeckingUpdates(pxyTermArea.CM_TerminalArea);
			endif;
			while true do
				app.myTrxUA.trxUpdateTerminalAreaInUse(self.myCMIFTerminalArea, deckingLevelToUpdateTo, app.myPassport);//new
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					break;
				else
					result := app.showErrorWarningDialog(app.getErrorString(Terminal_area_definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					elseif (not app.myPassport.noErrors) then
						return false;
					endif;
					self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				endif;
				break;
			endwhile;
		endif;
	endif;

	self.doClearClipBoard(false);	//21 Aug 2013	NDL	Par 32308
	self.oldRows := 0;		// 34353 change detection
	
	//otherwise well still be in update mode when the update note comes through
	if self.mode = Mode_Update then
		self.mode := Mode_View;
	endif;
	
	if terminalAreaType &lt;&gt; TA_TYPE_INTERTERM_TRANS_AREA and
		(not taTypeObj.isGantryLaneAreaType) then
		self.doSaveAutoPlan();
	endif;

	if deckingLevelToUpdateTo &gt;= DeckingLevel_TA then
		deckingOptions := self.myCurrentObject.CM_TerminalArea.myYADeckingOptions;
		if deckingOptions &lt;&gt; null
		and (deckingOptions.inOptionType = DeckingRule_Custom or deckingOptions.outOptionType = DeckingRule_Custom) then
			//better check to see if the user wants to set decking options
			result := app.msgBox(app.getErrorString(SetCustomDeckingOptions), self.caption, MsgBox_Yes_No+MsgBox_Question_Mark_Icon);
			if result = MsgBox_Return_Yes then
				self.showDeckingOptionsForArea(self.myCurrentObject.CM_TerminalArea);
			endif;
		endif;
	endif;
	
	//+cnwml2 PAR26097
	if stagHeightChanged then
		if terminalAreaType = TA_TYPE_FORK_LIFT_STACK then
			create interfaceObjects transient;
			create intArray transient;
			self.myCurrentObject.CM_ForkLiftStack.staggerHeights.copy(intArray);
				
			foreach int in 1 to intArray.size do
				create anInterfaceObject transient;
				interfaceObjects.add(anInterfaceObject);
				anInterfaceObject.updateMode := CMIF_GridTARegion.UpdateMode_HeightRestriction;
				anInterfaceObject.myGridArea := self.myCurrentObject.CM_GridArea;
				
				//find the location controllers and populate the anInterfaceObject.myLocationControllers collection
				row := self.myCurrentObject.CM_GridArea.allGridRows[int];
				foreach lc in row.allControllersByColumn do
					anInterfaceObject.allLocationControllers.add(lc);
				endforeach;
				heightOfStack := self.myCurrentObject.CM_GridArea.heightOfStack;
				stagHeight := intArray[int];
				if stagHeight = heightOfStack then
					anInterfaceObject.availability := PAD_AVAILABLE;
					anInterfaceObject.updateMode := anInterfaceObject.UpdateMode_LocationAvailable;
				elseif stagHeight = 0 or stagHeight = null then
					anInterfaceObject.availability := PAD_HEIGHT_1_UNAVAIL;
				elseif stagHeight = 1 then 
					anInterfaceObject.availability := PAD_HEIGHT_2_UNAVAIL;
				elseif stagHeight = 2 then
					anInterfaceObject.availability := PAD_HEIGHT_3_UNAVAIL;
				elseif stagHeight = 3 then	
					anInterfaceObject.availability := PAD_HEIGHT_4_UNAVAIL;
				elseif stagHeight = 4 then
					anInterfaceObject.availability := PAD_HEIGHT_5_UNAVAIL;
				elseif stagHeight = 5 then
					anInterfaceObject.availability := PAD_HEIGHT_6_UNAVAIL;
				elseif stagHeight = 6 then
					anInterfaceObject.availability := PAD_HEIGHT_7_UNAVAIL;
				elseif stagHeight = 7 then
					anInterfaceObject.availability := PAD_HEIGHT_8_UNAVAIL;
				endif;
			endforeach;
			
			while true do
				app.myTrxUA.trxUpdateGridControllers(interfaceObjects, self.myCurrentObject.CM_TerminalArea, app.myPassport);
				if app.myPassport.trxCompletedOK then
					// Clear errors/warnings from form and err/warnings window
					self.clearErrorWarnings();
					break;
				else
				
// PAR 32308					result := app.showErrorWarningDialog(self.myCurrentObject.CM_TerminalArea.id &amp; ' Pad Edit', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					result := app.showErrorWarningDialog(app.getErrorString1(EditPad,self.myCurrentObject.CM_TerminalArea.id), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
					return false;
				endif;
				break;
			endwhile;
		endif;
	endif;

	return true;
	
epilog
	delete interfaceObjects;
	delete anInterfaceObject;
	delete intArray;
	
	delete machines;								// PAR #28047
	
	//21 Dec 2015	NDL	Par 37270
	if reStartObj &lt;&gt; null then
		//disarmm so we don't process the updates multiple times.
		self.armNotesForObject(reStartObj);
	endif;
	
	if global.isValidObject(self.myPxyDeckingOptions) then
		delete self.myPxyDeckingOptions;
	endif;
/*	removed 10  May 2021 NDL	TFS 51156
	if pxyTermArea &lt;&gt; null then
		pxyTermArea.allProductMinMax.purge();
//		pxyTermArea.allowedMachines.purge();		// PAR #28047, removed for #29471
	endif; */
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveAutoPlan" id="2710c06d-6692-4759-b7c3-f8802c3876e9">
        <updating/>
        <source>doSaveAutoPlan() updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars

	aProxyTest : CM_AutoPlanTests;
	idx : Integer;
	theInterfaceTA : CMIF_ConfigTerminalArea;
	theTerminalArea : CM_TerminalArea;
	loadStateSet : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	theTerminalArea := self.myCurrentObject.CM_TerminalArea;
	if theTerminalArea &lt;&gt; null then
		app.cmsBeginLoad(loadStateSet);
		aProxyTest := theTerminalArea.autoPlanTest.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadStateSet);
		
		self.tblAPYardStack.setObjectFromTable(aProxyTest, null, false);

		create theInterfaceTA transient;
		if self.cmbStackDirIn.listIndex &lt; 1 then
			self.cmbStackDirIn.listIndex := 1;
		endif;
		theInterfaceTA.autoPlanApStackDirection := self.cmbStackDirIn.itemData[self.cmbStackDirIn.listIndex];
		theInterfaceTA.autoPlanApStackDirectionOut := self.cmbStackDirOut.listIndex -1;
		theInterfaceTA.autoPlanNumRowsMachineSep := self.tblAPYardStack.getValueByName(ETRow_NumRowsMachineSep).Integer;

		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateConfigTA( theTerminalArea,aProxyTest,theInterfaceTA, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Auto-Plan Config', app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endif;

epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	if theInterfaceTA &lt;&gt; null then
		delete theInterfaceTA;
	endif;
	if aProxyTest &lt;&gt; null then
		delete aProxyTest;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveGCICA" id="730f5caf-a279-4f8e-91d5-31254613151a">
        <updating/>
        <source>doSaveGCICA() updating;
/*
Purpose:			
Date		Who		Reason
19 September 2013	cnwab1	Initial creation
*/

vars
	ica : CM_InterchangeArea;
	obj : Object;
	theReturn, numItems : Integer;
	shelves: CM_RackShelfControllerSet;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	obj := self.cmbTBICAreasGC.listObject;
	
	if obj = null then
		return;
	endif;
	
	ica := obj.CM_InterchangeArea;
	create shelves transient;
	foreach obj in self.frmBlkArea.myDrawingController.allSelectedObjects discreteLock do
		if obj.isKindOf(CM_IrregularBlockController) then
			obj.CM_IrregularBlockController.allSubLocations.copyNoDuplicates(shelves, false);
		endif;
	endforeach;
	
	
	while true do
		app.myTrxUA.trxUpdateRackShelfInterchange(shelves,ica);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Interchange Area", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;	

epilog
	delete shelves;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectGridInterchangeArea" id="1dbc129e-c82a-427d-90fe-26b1388df7d7">
        <source>doSelectGridInterchangeArea(interchangeArea : CM_InterchangeArea) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwer1	Initial creation

*/

vars
	cmifObj : Object;
	cmifGridLCsAssocICArea : CMIF_GridLCsAssocICArea;
	minRow,
	maxRow  	: Integer;
	minCol,	
	maxCol		: Integer;
	theGridArea	: CMUI_GridArea;
	topLeftPoint,
	bottomRightPoint : CMUI_GridPoint;
begin

	if interchangeArea = null then
		return;
	endif;
	
	self.frmAssocICArea.parent:=self.frmMain.myDrawingFrame;// self.frmGrdArea;//self.frmMain;
	foreach cmifObj in self.allCMIFGridLCsAssocICArea do
		if cmifObj.CMIF_GridLCsAssocICArea.myInterchangeArea = interchangeArea then
			cmifGridLCsAssocICArea:= cmifObj.CMIF_GridLCsAssocICArea;
			break;
		endif;
	endforeach;
	
	
	theGridArea:=self.frmGrdArea.myGridArea;
	if cmifGridLCsAssocICArea.allGridControllers.size &gt; 0 then
		minRow:=cmifGridLCsAssocICArea.allGridControllers.first.row;
		minCol:=cmifGridLCsAssocICArea.allGridControllers.first.column;
		maxRow:=cmifGridLCsAssocICArea.allGridControllers.last.row;
		maxCol:=cmifGridLCsAssocICArea.allGridControllers.last.column;
		
		topLeftPoint:=theGridArea.allGridRows[minRow].allGridPointsByColumn[minCol];
		bottomRightPoint:=theGridArea.allGridRows[maxRow].allGridPointsByColumn[maxCol];
		
	
	else
		//new one just give it a default grids 
		topLeftPoint:=theGridArea.allGridRows.first.allGridPointsByColumn.first;
		maxRow:=theGridArea.allGridRows.size.min(5);
		maxCol:=theGridArea.allGridColumns.size.min(5);
		bottomRightPoint:=theGridArea.allGridRows[maxRow].allGridPointsByColumn[maxCol];
		
		
		
	endif;
	self.frmAssocICArea.left:=topLeftPoint.x1;
	self.frmAssocICArea.top:=topLeftPoint.y1;
	self.frmAssocICArea.width:=bottomRightPoint.x2-topLeftPoint.x1; 
	self.frmAssocICArea.height:=bottomRightPoint.y2-topLeftPoint.y1;
	
	
	self.frmAssocICArea.visible:=true;
	self.frmAssocICArea.autoRedraw:=false;
	self.frmAssocICArea.userObject:=cmifGridLCsAssocICArea;
	self.frmAssocICArea.zOrder(1);

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="interchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="doSelectNextArea" id="42bd8012-50fc-4678-8f57-49f65036326c">
        <source>doSelectNextArea();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars
	nextRTGArea : CM_RTGArea;
	rtgLane : CM_RTGLane;
	idx , prevIdx, idxOfSelf: Integer;
begin

	nextRTGArea:=self.cmbNextArea.listObject.CM_RTGArea;
	if 	nextRTGArea = null then
		return;
	endif;
	
	rtgLane:=self.cmbLaneGroup.listObject.CM_RTGLane;
	idxOfSelf:=rtgLane.allTAsByTypeId.indexOf(self.myCurrentObject.CM_RTGArea);
	idx:=rtgLane.allTAsByTypeId.indexOf(nextRTGArea);
	
	prevIdx:=idx-1;
	if idxOfSelf &lt;= prevIdx then
		prevIdx:=prevIdx-1;
	endif;
	
	if prevIdx &gt; 0 then
		self.cmbPrevArea.listIndex:=prevIdx;
	
	else
		self.cmbPrevArea.listIndex:=-1;
	endif;
	
	self.tblMain.setValueByControlName(self.cmbPrevArea.name,self.cmbPrevArea.text);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectPrevArea" id="306e9c4c-dafa-4d85-8d06-d8e370d3394a">
        <source>doSelectPrevArea();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwer1	Initial creation

*/

vars
	prevRTGArea : CM_RTGArea;
	rtgLane : CM_RTGLane;
	idx , nextIdx,idxOfSelf: Integer;
begin

	prevRTGArea:=self.cmbPrevArea.listObject.CM_RTGArea;
	if 	prevRTGArea = null then
		return;
	endif;
	
	rtgLane:=self.cmbLaneGroup.listObject.CM_RTGLane;
	idxOfSelf:=rtgLane.allTAsByTypeId.indexOf(self.myCurrentObject.CM_RTGArea);
	idx:=rtgLane.allTAsByTypeId.indexOf(prevRTGArea);

	nextIdx:=idx+1;
	
	
	if nextIdx &gt; 0 and nextIdx &lt;= self.cmbNextArea.listCount then
		self.cmbNextArea.listIndex:=nextIdx;
	
	else
		self.cmbNextArea.listIndex:=-1;
	endif;
	
	self.tblMain.setValueByControlName(self.cmbNextArea.name,self.cmbNextArea.text);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetBlockLabels" id="2c0308c1-f84e-4e42-b812-5b0e162beefb">
        <updating/>
        <source>doSetBlockLabels(isRow : Boolean) updating, protected;
// Let the user chanae the labels used on the grid
vars
	form	: CMUI_GridArea_Labels;
	blockArea : CMUI_BlockArea;
begin
	create blockArea transient;
	if isRow then
		if self.myProxyObject.CM_IrregularBlockArea.hasRowLabels() then
			self.myProxyObject.CM_IrregularBlockArea.allRowLabels.copy(blockArea.rowLabels);
		endif;
		self.myProxyObject.CM_IrregularBlockArea.getDefaultRowLabels(blockArea.rowLabels);
	else
		if self.myProxyObject.CM_IrregularBlockArea.hasColumnLabels() then
			self.myProxyObject.CM_IrregularBlockArea.allColumnLabels.copy(blockArea.columnLabels);
		endif;
		self.myProxyObject.CM_IrregularBlockArea.getDefaultColumnLabels(blockArea.columnLabels);
	endif;
	form := app.loadForm(CMUI_BlockArea_Labels, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_BlockArea_Labels;
	form.set(isRow, blockArea, tblMain.getValueByName(ETRow_Id).String,false,null);
	if form.showModal = IDOK then
		if isRow then
			self.myProxyObject.CM_IrregularBlockArea.allRowLabels.clear();
			blockArea.rowLabels.copy(self.myProxyObject.CM_IrregularBlockArea.allRowLabels);
		else
			self.myProxyObject.CM_IrregularBlockArea.allColumnLabels.clear();
			blockArea.columnLabels.copy(self.myProxyObject.CM_IrregularBlockArea.allColumnLabels);
		endif;
		self.areaChanged := true;
		self.frmBlkArea.drawSelf();
	endif;
epilog
	delete blockArea;
end;</source>
        <access>protected</access>
        <Parameter name="isRow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetGPS" id="9820d340-d950-4842-bab5-f89617bab992">
        <updating/>
        <source>doSetGPS() updating, protected;

vars

	form	: CMUI_GridArea_GPS;
	isRow	: Boolean;

begin

	if not self.myCurrentObject.CM_TerminalArea.isRTGArea() then
		return;
	endif;
	
	form := app.loadForm(CMUI_GridArea_GPS, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_GridArea_GPS;
	form.set(self.myCurrentObject.CM_GridArea);
	form.showModal;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetLabels" id="d5add5e3-4823-46ff-9ef1-629dc144f915">
        <updating/>
        <source>doSetLabels(_is40ftColumn : Boolean) updating, protected;

vars

	form	: CMUI_GridArea_Labels;
	isRow	: Boolean;
	otherColumnLabels : StringArray;
begin

	if self.myCurrentSOPGridArea.selectedColumn &lt;&gt; 0 then
		// Keep going.
	elseif self.myCurrentSOPGridArea.selectedRow &lt;&gt; 0 then
		isRow := true;
	else
		return;
	endif;
	
	
	if not isRow then
		create otherColumnLabels transient;
		if _is40ftColumn then
			self.myCurrentSOPGridArea.getColumnLabels(otherColumnLabels);
		else
			self.myCurrentSOPGridArea.get40ftColumnLabels(otherColumnLabels);
		endif;
	endif;
	
	form := app.loadForm(CMUI_GridArea_Labels, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_GridArea_Labels;
	form.set(isRow, self.myCurrentSOPGridArea, tblMain.getValueByName(ETRow_Id).String,_is40ftColumn,otherColumnLabels);
	form.showModal;
	self.areaChanged := true;
	self.frmMain.drawSelf();

epilog
	delete otherColumnLabels;
end;</source>
        <access>protected</access>
        <Parameter name="_is40ftColumn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblExtraListClick" id="9d276b78-a620-42cf-ac6b-d538b235aff1">
        <updating/>
        <source>doTblExtraListClick() updating;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	obj : Object;
	prodMinMax : CM_TerminalAreaProductMinMax;
	table : CM_DataTable;
	proxyTA : CM_TerminalArea;
begin
	table := self.tblExtraList;
	
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	//08 Sep 2020	NDL	TFS 49984
	obj := table.accessRow(table.row).itemObject;
	if obj &lt;&gt; null and obj.isKindOf( CM_TerminalAreaProductMinMax ) then
		prodMinMax :=obj.CM_TerminalAreaProductMinMax;
		self.displayProductMinMax(prodMinMax);
	elseif obj &lt;&gt; null and obj.isKindOf( CM_GriddedTAStackHeight ) then
		proxyTA := self.myProxyObject.CM_TerminalArea;
		self.btnExtraDelete.enabled := proxyTA &lt;&gt; null;
		self.btnStackEdit.enabled := proxyTA &lt;&gt; null;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateAllPoints" id="e73d4eb8-032e-4b6c-8730-17b8489119b3">
        <updating/>
        <source>doUpdateAllPoints(_type : Integer) : SOP_GridPoint updating, protected;

vars

	gridPoint	 	: CMUI_GridPoint;
	returnGP : SOP_GridPoint;
	cmuiTransient	: CMUI_Transient;

begin
	self.areaChanged := true;

		if self.myCurrentSOPGridArea.allSelectedPoints.size &gt; 0 then
			// cnwjk3 CCMS 1032 15/12/2008
			if _type = LOC_Display_TwinLift then
				doUpdatePointsForTwinLift();
			else
				foreach cmuiTransient in self.myCurrentSOPGridArea.allSelectedPoints do
					if self.validateStateOfController(cmuiTransient.SOP_GridPoint) = Return_Continue then
						self.doUpdatePoints(_type, cmuiTransient.SOP_GridPoint);
						returnGP := cmuiTransient.SOP_GridPoint;
					endif;
				endforeach;
			endif;
			//self.myCurrentSOPGridArea.allSelectedPoints.clear;
		else
			gridPoint := self.myCurrentSOPGridArea.convertPositionToGridPoint(self.x, self.y).SOP_GridPoint;
			if gridPoint &lt;&gt; null then
				if self.validateStateOfController(gridPoint.SOP_GridPoint) = Return_Continue then		
					self.doUpdatePoints(_type, gridPoint.SOP_GridPoint);
					returnGP := gridPoint.SOP_GridPoint;
				endif;
			endif;
		endif;

	
epilog
	self.doRedrawGrid;
	self.myCurrentSOPGridArea.setSelected(0,0);

	return returnGP;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="SOP_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="doUpdateNumLanes" id="d01c09fc-f812-4c56-bb49-5e984205ee3b">
        <source>doUpdateNumLanes() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Feb 2010	cnwjk3	Initial creation
33 Oct 2012 cnwer1	PAR 30461
*/

vars
	oldLaneCnt, 
	laneNum : Integer;
	maxLaneLen : Real;	// cnwjk3 PAR 23760 19/04/2010
	pxyLane : CM_RoRoController;
	iter : Iterator;
	msg : String;
begin
	if terminalAreaType &lt;&gt; TA_TYPE_RORO_LANE_AREA then
		return false;
	endif;
	
	if self.myProxyObject = null then
		return false;
	endif;

	if not self.doCheckNumLaneChange() then
		return false;
	endif;

	maxLaneLen := self.tblMain.getValueByName(ETRow_MaxLaneLen).String.asDecimalJMT();	// cnwjk3 PAR 23760 19/04/2010
	if maxLaneLen = 0 then																// cnwjk3 PAR 23760 19/04/2010
		maxLaneLen := CM_RoRoController.DEFAULT_LENGTH;									// cnwjk3 PAR 23760 19/04/2010
	endif;																				// cnwjk3 PAR 23760 19/04/2010
	
	laneNum := tblMain.getValueByName(ETRow_LaneCount).Integer;
	
	//08 Dec 2015	NDL	Par 37272 - increase limit from 99 to 150 
	if laneNum &gt; 150 then
		msg := app.getErrorString3(MustBeInRange,"Number of Lanes","1","150");	// Display issue on the form after 158  @ max Zoom level
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	//self.myProxyObject.CM_RoRoLaneArea.pxyUpdateLaneCount (laneNum); 
	oldLaneCnt:=self.myProxyObject.CM_RoRoLaneArea.allLanesByLaneNumber.size;
	self.myProxyObject.CM_RoRoLaneArea.pxyUpdateLaneCount (laneNum, maxLaneLen);		// cnwjk3 PAR 23760 19/04/2010 
	
	//epr par 30461 try not to override the old pxy values
	if oldLaneCnt &lt; laneNum then
			self.tblGateLanes.rows:=self.tblGateLanes.fixedRows + oldLaneCnt;
		iter:=self.myProxyObject.CM_RoRoLaneArea.allLanesByLaneNumber.createIterator;
		self.myProxyObject.CM_RoRoLaneArea.allLanesByLaneNumber.startKeyGeq(oldLaneCnt+1,iter);
		while iter.next(pxyLane) do
			self.tblGateLanes.updateItemObject(pxyLane, White, White, app.myPassport);
		endwhile;
	else
		self.tblGateLanes.rows:=self.tblGateLanes.fixedRows + laneNum;
	endif;
	
	
	return true;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdatePoints" id="e7fcdde0-7690-433a-bbf1-b79d0933c729">
        <source>doUpdatePoints(_type : Integer; _gridPoint : SOP_GridPoint input) protected;

vars

	picture			: Picture;

begin

	if _gridPoint &lt;&gt; null then
		if _type = LOC_Display_Unavailable then
			picture := tAUnavailPic;
		elseif _type = LOC_Display_HasPower or _type = LOC_Display_PowerTower then
			picture := tAPowerPic;
		elseif _type = LOC_Display_ReeferGantry then
			picture := tAReeferPic;
		elseif _type = LOC_Display_LightTower then
			picture := tALightPic;
		elseif _type = LOC_Display_Building then
			picture := tABuildingPic;
		endif;
		_gridPoint.setUsage(_type, self.terminalAreaType, picture);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_gridPoint" type="SOP_GridPoint" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdatePointsForTwinLift" id="187197b7-85fa-42cb-966b-79e333d97c14">
        <updating/>
        <source>doUpdatePointsForTwinLift() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2008	cnwjk3	CCMS 1032

*/

vars
	gridRow 		: CMUI_GridRow;
	gridPoint,	
	prevGridPoint	: CMUI_GridPoint;
begin	
	foreach gridRow in self.myCurrentSOPGridArea.allGridRows do
		prevGridPoint := null;
		foreach gridPoint in gridRow.allGridPointsByColumn do
			if self.myCurrentSOPGridArea.allSelectedPoints.includes(gridPoint) then
				if prevGridPoint &lt;&gt; null then
					prevGridPoint.SOP_GridPoint.myGridController.setCanTwinLiftWithNext(true);
					gridPoint.SOP_GridPoint.myGridController.setCanTwinLiftWithPrev(true);		
				endif;
				prevGridPoint := gridPoint;
			else
				prevGridPoint := null;
			endif;
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="editBlockLocation" id="e704f5b5-eb42-445e-bebf-e21ece03f8f3">
        <source>editBlockLocation();
// Edit a location in the block area
vars
	blockArea : CM_IrregularBlockArea;
	locationProxy : CM_IrregularBlockController;
	region : PointArray;
	form : SOP_BlockLocationDetailForm;
	result	: Integer;
begin
	locationProxy := self.frmBlkArea.myDrawingController.getSelectedLocation();
	if locationProxy &lt;&gt; null then
		create form transient;
		form.setLocationProxy(locationProxy, self.myTerminal, self );	//21 Aug 2013	NDL	Par 32308
	//	form.txtName.text := locationProxy.getID();
	//	form.txtName.setFocus();
		if form.showModal = IDOK then
			blockArea := self.myProxyObject.CM_IrregularBlockArea;
			locationProxy.setProxy(	blockArea,
									form.txtName.text,
									locationProxy.region,
									form.clrColour.getColor,	//_colour : Integer;
									form.txtDefCapacity.text.Integer,	//_defaultCapacity : Integer;
									locationProxy.locationType,	//_locationType : Integer;
									form.txtMaxWeight.getConvertedValue,	//_maximumWeight : Real;
									form.cmbICArea.listObject.CM_InterchangeArea	//_myICArea : CM_InterchangeArea
									);
			self.frmBlkArea.myDrawingController.editLocation(locationProxy);
		endif;
	endif;		
end;</source>
    </JadeMethod>
