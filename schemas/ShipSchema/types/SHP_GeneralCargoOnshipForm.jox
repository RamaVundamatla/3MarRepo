    <JadeMethod name="doBOLSelect" id="5485f840-2f6b-4860-92fe-033c38eb277f">
        <updating/>
        <source>doBOLSelect() updating, protected;
//28 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
vars
	obj	: Object;
begin
	self.myCurrentTable := self.tblBOL;

	obj := self.tblBOL.accessRow(self.tblBOL.row).itemObject.CM_Object;

	if not global.isValidObject(obj) then
		return;
	endif;
	if obj.isKindOf(CM_BOLDtl) then
		self.myCurrentBOLDetail := obj.CM_BOLDtl;
		self.myCurrentBOL := self.myCurrentBOLDetail.myBOL;
		// refresh the BOL Detail table entry as well, to get the TI total and qty differences current
		self.refreshBOLDetailEntry(null);
		self.showBOLDetailCargo();
		self.btnBOLEdit.enabled := true;
		self.btnInstruction.enabled := true;	//20.10.2022 navtnr20 TFS 54967
		self.btnBOLDelete.enabled := false;		//cnwmc5 - 1 May 2014 - PAR 34074
// 23144 handle cargo linked to BOL but not BOL detail
	elseif obj.isKindOf(CM_BOL) then
		self.myCurrentBOLDetail := null;
		self.myCurrentBOL := obj.CM_BOL;
		// refresh the BOL table entry as well, to get the TI total and qty differences current
		self.refreshBOLEntry(null);
		self.showBOLCargo();
		self.btnBOLEdit.enabled := true;
		self.btnBOLDelete.enabled := true;		//cnwmc5 - 1 May 2014 - PAR 34074
		// start //01.11.2022 navtnr20 TFS 54967
		if obj.CM_BOL.status = BOL_STATUS_ARCHIVED then
			self.btnInstruction.enabled := false;
		else
			self.btnInstruction.enabled := true;
		endif;
		// End //01.11.2022 navtnr20 TFS 54967
	endif;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
