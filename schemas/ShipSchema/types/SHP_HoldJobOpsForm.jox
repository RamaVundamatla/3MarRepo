// TFS 3549 handle closing and reopening with caption set
vars

begin
	self.frmTop.top := self.frmToolbar.height + 1;
	self.fldData.top := self.frmTop.top + self.frmTop.height + 2;

	inheritMethod();
end;
</source>
    </JadeMethod>
    <JadeMethod name="doShowEventCheckList" id="969e7f49-01dd-463b-af87-ed74bd6e4e9b">
        <source>doShowEventCheckList();
/*
Purpose:			
Date		Who		Reason
03/02/2017	cnwab1	Initial creation
29/05/2017	cnwdap1	TFS 4248 LNX Voyage Event Allocation
*/

vars

	form 		: SHP_VoyageEventCheckList;
	effectiveTS : TimeStamp;

begin
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage),app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only);
		return;
	endif;
	form := app.loadForm(SHP_VoyageEventCheckList, SHP_Assistant, false, false, true, self.myTerminal, null).SHP_VoyageEventCheckList;	
	
	if form = null then
		return;
	endif;	
	
	if self.txtEffectiveDate.getDate &lt;&gt; null then
		effectiveTS.setDate(self.txtEffectiveDate.getDate);
		effectiveTS.setTime(self.txtEffectiveTime.getTime);
	endif;
	
	form.setParentForm(self);
	form.myCurrentVoyage := self.myCurrentVoyage;
	form.myCurrentJob := self.myCurrentJob;
	if self.myCurrentJob &lt;&gt; null then												// TFS 4248
		form.myCurrentJobSheet := self.myCurrentJob.myJobSheet.CM_VoyageJobSheet;	// TFS 4248
	endif;																			// TFS 4248
	form.effectiveTS := effectiveTS;

	form.show;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUnassignDirectRelease" id="efd2a3a5-2f36-45fe-9576-172ac83a7bd0">
        <updating/>
        <source>doUnassignDirectRelease() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
06 September 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail

*/
vars
	wle				: CM_WorkListEntry;
	result			: Integer;
	wlesWithWarnings,
	wleArray,		
	tmpWleArray: CM_WLEArray;
	
begin
	create tmpWleArray transient;
	create wleArray transient;
	create wlesWithWarnings transient;
	self.tblJobDetails.allSelectedObjects.copy(tmpWleArray);
	
	//only want to unplan wles already set as direct release
	foreach wle in tmpWleArray do
		if wle.isDRLinkedByFM then
			wleArray.add(wle);
		endif;
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateWLEsUnplan(wleArray, wlesWithWarnings, NO_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete tmpWleArray;
	delete wleArray;
	delete wlesWithWarnings;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="dragTrackedItem" id="8f840a7e-29ce-49c0-98b9-3e943bf257d2">
        <updating/>
        <source>dragTrackedItem(_ti : CM_TrackedItem; _wle : CM_WorkListEntry; _control : Control input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 July 2019		jlgzm1	Initial creation TFS 42872 JMT - Direct Delivery Between HOLD Voyages and Rail - All Cargo Types

*/

vars
	picture : Picture;
	wle : CM_WorkListEntry;
	obj : Object;
	tmpTi : CM_TrackedItem;
	moveController	: CMIF_MoveController;

begin
	delete app.myMoveController;

	if _wle &lt;&gt; null then
		if _wle.status &lt;&gt; WLE_UNACTIONED then
			app.raiseCMException2(VB_JOB_NOT_UNACTIONED, _wle.job.jobId, _wle.statusString, null, null);
			return;
		endif;
	endif;	
		
	create moveController transient;
	
	app.myMoveController := moveController;	
	moveController.setMyTrackedItem(_ti);

	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		if _wle.myRequest.isKindOf(CM_SlotRequest) then
			moveController.mySlotRequest := _wle.myRequest.CM_SlotRequest;
		elseif _wle.myRequest.isKindOf(CM_VoyageRequest) then
			moveController.myVoyageRequest := _wle.myRequest.CM_VoyageRequest;
		endif;
		_wle.setMoveControllerAllOtherTIs(moveController);
	endif;
		
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isDirectReleaseMove := true;

	if _wle.myFutureMove &lt;&gt; null then
		moveController.setMoveIndex(_ti.allPlannedFutureMoves.indexOf(_wle.myFutureMove));
		moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(PLANNING_MODE));
	endif;	
		
	foreach obj in self.tblJobDetails.allSelectedObjects do
		if obj = _wle then
			continue;
		endif;
		if (not CM_WorkListEntry.hasInstance(obj)) then
			continue;
		endif;
		wle := obj.CM_WorkListEntry;
		if wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		if self.moveModeForm = QUEUE_MODE and wle.queue &lt;&gt; null then
			// Already queued			
			continue;
		elseif self.moveModeForm = PLANNING_MODE and wle.myFutureMove &lt;&gt; null then
			// Already planned or queued
			continue;				
		endif;
		tmpTi := wle.myTrackedItem;
		if tmpTi &lt;&gt; null then
			moveController.allOtherTrackedItems.add(tmpTi);
			moveController.allOtherWLEs.add(wle);
		endif;
	endforeach;	

	_control.dragMode := DragMode_Drag;
	
	create picture transient;
	picture.picture := self.picMvPlanCur.picture;
	if picture &lt;&gt; null then
		_control.dragCursor := picture.picture;
	endif;

epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraPermissions" id="47bb0bd5-a017-4e0f-ace3-eaa2c8dc876f">
        <source>getExtraPermissions(permArray: IntegerArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars

begin
