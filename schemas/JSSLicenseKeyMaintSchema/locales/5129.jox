    <TranslatableString name="COMPONENT_ID_IS_ZERO" id="d2d15f7e-f0b2-48f3-856a-72d444c68406">
        <source>COMPONENT_ID_IS_ZERO = "The Product Component ID cannot be zero."</source>
    </TranslatableString>
    <TranslatableString name="CUSTOMER_EXISTS" id="b9170ce2-0622-405f-b69b-965f7cb76af0">
        <source>CUSTOMER_EXISTS(pName) = "A Customer already exists with the requested name: " &amp; pName</source>
    </TranslatableString>
    <TranslatableString name="CUSTOMER_NAME_BLANK" id="54fe9ac0-ab93-4142-89ae-cedeab03edf3">
        <source>CUSTOMER_NAME_BLANK = "The Customer name cannot be blank."</source>
    </TranslatableString>
    <TranslatableString name="EDITION_OUTOFDATE" id="8837d2e1-47b1-4553-9698-bc713228cddd">
        <source>EDITION_OUTOFDATE(pTitle, pName) = "The entry which you are updating (" &amp; pTitle &amp; ": " &amp; pName &amp; ") has been changed by another user - please close the form, re-select it, and try again."</source>
    </TranslatableString>
    <TranslatableString name="INVALID_CHECKSUM" id="a0caea36-49ea-4093-9445-376f256d6f06">
        <source>INVALID_CHECKSUM = "Invalid license key checksum."</source>
    </TranslatableString>
    <TranslatableString name="INVALID_CUSTOMER_NAME" id="afa05b44-f1db-4666-97f2-8e91e0dbce76">
        <source>INVALID_CUSTOMER_NAME(pName) = "The Customer name (" &amp; pName &amp; ") is not valid for this license."</source>
    </TranslatableString>
    <TranslatableString name="LICENSE_EXPIRED_ON" id="dbf24d4a-0380-4df9-bdde-9e4868b76c44">
        <source>LICENSE_EXPIRED_ON(pDate) = "The license key supplied expired on " &amp; pDate</source>
    </TranslatableString>
    <TranslatableString name="NULL_ROOT" id="3f6e1a62-266a-4171-b1bf-b7fdfd153ec4">
        <source>NULL_ROOT = "The Root object cannot be null."</source>
