    <JadeMethod name="doesCargoGroupExist" id="00e9e1be-d052-448d-9b60-8e4d761aec54">
        <source>doesCargoGroupExist(_cargoGroupId: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2024	navsaa30	Initial creation
7/12/2024 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
*/

vars
	ediTi: CM_EDITrackedItem;
begin
	if self.myRequestMultiLine &lt;&gt; null then
		foreach ediTi in self.myRequestMultiLine.allEDITrackedItems do
		if ediTi.getCargoGroupId().compareEql(_cargoGroupId, true, false, null) then
			return true;
		endif;
	endforeach;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_cargoGroupId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesCargoOperatorExist" id="7e752f53-9aef-4011-9c5d-2a9f4c973c25">
        <source>doesCargoOperatorExist(_cargoOperator: String): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 02 October 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description
07 May 2024		navlw1		63312		EUP | FR 54871 - EDI Administration Usability Operator Search Filter Returns Incorrect Results
****************************************************/

vars
	ediTi: CM_EDITrackedItem;
begin
	if self.myRequestMultiLine &lt;&gt; null and self.myRequestMultiLine.allEDITrackedItems &lt;&gt; null then
		foreach ediTi in self.myRequestMultiLine.allEDITrackedItems do
			if ediTi.getOperatorCode().toUpper().compareEql(_cargoOperator.toUpper(), true, false, null) then
				return true;
			endif;
		endforeach;
	endif;
	if self.sender.toUpper().compareEql(_cargoOperator.toUpper(), true, false, null) or self.operatorCode.toUpper().compareEql(_cargoOperator.toUpper(), true, false, null) then
		return true;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_cargoOperator" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesEDIActionExist" id="a1d38ef5-80b2-4c50-b314-3b2959948aa7">
