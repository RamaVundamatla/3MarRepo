    <JadeMethod name="isValidForCargoType" id="793d57cf-1a5b-448c-9d01-fb3a0f501f1a">
        <source>isValidForCargoType(_theCargoType : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:
//	20 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
//  22 Aug 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//  15 Dec 2022 navma1	Defect 55852: MTN - 1090 exception while loading a Ship Manifest and BOL via EDI
//	18/07/2023	navkc1	Bug 58168: PEN- Child Cargo Stops not being cleared by EDI
// ---------------------------------------------------------------------------
vars
	cargoType 		: Object;
	criteria  		: CM_YACriteria;
	stopCriteria	: CM_StopCriteria;
begin
	// START 20 Jul 2022	navsj20	TFS 53862
	//return self.allCargoTypesNew.includesKey(_theCargoType); 
	
	stopCriteria := self.myStopCriteria;          						   // 15.12.2022 navma1 #55852
	if stopCriteria &lt;&gt; null and not stopCriteria.allCriteria.isEmpty then  // ### TFS 53862 15SEP2022 NAVAB1
		foreach criteria in stopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do
			foreach cargoType in criteria.myYAData.CM_YADataObjects.allObjects where cargoType.isKindOf(CM_CargoBOLType) and cargoType.CM_CargoBOLType.id = _theCargoType do
				return true;
			endforeach;
		endforeach;
	else				
		//return true;	// 22.08.2022 navak20 TFS 53862		
		return false; //18/07/2023	navkc1	Bug 58168
	endif;
	// END 20 Jul 2022	navsj20	TFS 53862
epilog
end;</source>
        <Parameter name="_theCargoType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForChildSetting" id="a10e7124-0090-449c-84da-a2f2a17cf38e">
        <source>isValidForChildSetting(_isChild : Boolean; _terminal : CM_Terminal) : Boolean;
//
///	cnwrs1 may 2007 PAR13378 Stops	
// check to see whether to apply the stop or not
// returns true if the stop satisfies the isChild settings 
//
vars
	result : Boolean;
	stopTableTemplate : CM_StopTableTemplate;
begin
	stopTableTemplate := self.allStopTableTemplates[_terminal, self]; //cnwrs1 par 17129 June 2008
	if stopTableTemplate = null then
		//epr par 37446 2/2/16
		//would of fallen into not stopTableTemplate.isChildOnly and not stopTableTemplate.isChildIgnore and returned true do it without overhead of create and delete 
		// TFS 1626 return true;
		return false; // TFS 1626
	endif;
	if not stopTableTemplate.isChildOnly and not stopTableTemplate.isChildIgnore then
		result := true;
	else
		if _isChild then 
			if (stopTableTemplate.isChildOnly or not stopTableTemplate.isChildIgnore) then
				result := true;
			else
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; self.heading &amp; " is not relevant -Child Template", LogDEBUG);
				result := false;
			endif;
		else
			if (stopTableTemplate.isChildOnly or not stopTableTemplate.isChildIgnore) then
				result := false;
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; self.heading &amp; " is not relevant -Child Template", LogDEBUG);
			else
				result := true;
			endif;
		endif;
	endif;
	return result;
epilog
	
end;
</source>
        <Parameter name="_isChild" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForCoastalSetting" id="97310816-73fa-4d05-b97e-a2df251ea356">
        <source>isValidForCoastalSetting(_isCoastalInBound, _isCoastalOutBound : Boolean; _terminal : CM_Terminal) : Boolean;
//
//	cnwrs1 may 2007 PAR13378 Stops	
// check to see whether to apply the stop or not
// returns true if the stop satisfies the isCoastal settings 
// 01 Oct 2010  cnwrs1      par25912 allow for tranship coastals
vars
	result : Boolean;
	stopTableTemplate : CM_StopTableTemplate;
	coastal : Boolean; //cnwrs1 par 25912 1 Oct 2010
begin
	stopTableTemplate := self.allStopTableTemplates[_terminal, self]; //cnwrs1 par 17129 June 2008
	if stopTableTemplate = null then
		//epr par 37446 2/2/16
		//would of fallen into not stopTableTemplate.isCoastalOnly and not stopTableTemplate.isCoastalIgnore and returned true do it without overhead of create and delete 
		// TFS 1626 return true;
		return false; // TFS 1626
	endif;
	if not stopTableTemplate.isCoastalOnly and not stopTableTemplate.isCoastalIgnore then
		result := true;
	else
		coastal := (_isCoastalInBound and self.isImportStop(_terminal)) or 
		           (_isCoastalOutBound and self.isExportStop(_terminal));
//	coastal := _isCoastalInBound;
		if coastal then  //cnwrs1 par25912 1 Oct 2010
			if (stopTableTemplate.isCoastalOnly or not stopTableTemplate.isCoastalIgnore) then
				result := true;
			else
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; self.heading &amp; " is not relevant - TI is Coastal Stop not coastal", LogDEBUG);
				result := false;
			endif;
		else
			if (stopTableTemplate.isCoastalOnly or not stopTableTemplate.isCoastalIgnore) then
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; self.heading &amp; " is not relevant - TI is not Coastal Stop is coastal", LogDEBUG);
				result := false;
			else
				result := true;
			endif;
		endif;
	endif;
	return result;
epilog
	
end;

</source>
        <Parameter name="_isCoastalInBound" type="Boolean"/>
        <Parameter name="_isCoastalOutBound" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForFulls" id="acf226ac-0431-417f-b928-b636d3aa1752">
        <source>isValidForFulls(_isMT : Boolean; _terminal : CM_Terminal) : Boolean;
//
//	cnwrs1 may 2007 PAR13378 Stops	
// check to see whether to apply the stop or not
// returns true if the stop satisfies the isFull settings 
//
vars
	stopTableTemplate : CM_StopTableTemplate;
	
begin
	stopTableTemplate := self.allStopTableTemplates[_terminal, self]; //cnwrs1 par 17129 June 2008
	if stopTableTemplate = null then
		//epr par 37446 2/2/16
		//would of fallen into not stopTableTemplate.isMT and not stopTableTemplate.isFull and returned true do it without overhead of create and delete 
		// TFS 1626 return true;
		return false; // TFS 1626
	endif;
	if stopTableTemplate.isMT and //ccms 1092 cnwrs1 Mar 2008
	   stopTableTemplate.isFull then
		return true;
	endif;
	if not stopTableTemplate.isMT and 
	   not stopTableTemplate.isFull then
		return true;
	endif;
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; self.heading &amp; " is not relevant -IS FULL", LogDEBUG);
	return stopTableTemplate.isFull = (not _isMT);
epilog
	
end;
</source>
        <Parameter name="_isMT" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForMTs" id="6b61bca0-1510-46d8-8b04-f08f407ce272">
        <source>isValidForMTs(_isMT : Boolean; _terminal : CM_Terminal) : Boolean;
//
//	cnwrs1 may 2007 PAR13378 Stops	
// check to see whether to apply the stop or not
// returns true if the stop satisfies the isMT settings 
//
vars
	stopTableTemplate : CM_StopTableTemplate;
	
begin
	stopTableTemplate := self.allStopTableTemplates[_terminal, self]; //cnwrs1 par 17129 June 2008
	if stopTableTemplate = null then
		//epr 2/2/16 par 37446 performance
		//would of fallen into not stopTableTemplate.isMT and not stopTableTemplate.isFull and returned true do it without overhead of create and delete 
		// TFS 1626 return true;
		return false; // TFS 1626
	endif;
	if stopTableTemplate.isMT and //ccms 1092 cnwrs1 Mar 2008
	   stopTableTemplate.isFull then
		return true;
	endif;
	if not stopTableTemplate.isMT and 
	   not stopTableTemplate.isFull then
		return true;
	endif;
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; self.heading &amp; " is not relevant -MTs", LogDEBUG);
	return stopTableTemplate.isMT = _isMT;
epilog
	
end;
</source>
        <Parameter name="_isMT" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForStopCriteria" id="2fd61782-eb57-4ab9-98eb-2b2e699b08cd">
        <source>isValidForStopCriteria(_ti : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2022	navsj20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	cargoType : Object;
	criteria : CM_YACriteria;
begin
	if self.myStopCriteria &lt;&gt; null then
		if self.myStopCriteria.matches(_ti) then 
			return true;
		else
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; self.heading &amp; " is not relevant - Criteria Does not Match", LogDEBUG);
			return false;
		endif;
	else				
		return true;			
	endif;
epilog
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForTerminal" id="4a4d4df0-67f1-4eb9-b055-6ae50d4cdc81">
        <source>isValidForTerminal(_terminal : CM_Terminal) : Boolean;
//
// par 15536 cnwrs1 dec 2007
vars
	stopTableTemplate : CM_StopTableTemplate;
	
begin
	//epr par 37446 2/2/16
	stopTableTemplate := self.allStopTableTemplates[_terminal, self]; //cnwrs1 par 17129 June 2008
	if  stopTableTemplate = null then
		return false;
	endif;
	
	return  not stopTableTemplate.isNotSet();
	

end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForTranshipSetting" id="814c7f51-7e33-452a-ab36-3e8e1313dcd9">
        <source>isValidForTranshipSetting(_isTranship : Boolean; _terminal : CM_Terminal) : Boolean;
//
//	cnwrs1Jan 2010	
// check to see whether to apply the stop or not
// returns true if the stop satisfies the isTranship settings 
//
vars
	result : Boolean;
	stopTableTemplate : CM_StopTableTemplate;

begin
	stopTableTemplate := self.allStopTableTemplates[_terminal, self]; //cnwrs1 par 17129 June 2008
	if stopTableTemplate = null then
		//epr par 37446 2/2/16
		//would of fallen into not stopTableTemplate.isTranshipOnly and not stopTableTemplate.isTranshipIgnore and returned true do it without overhead of create and delete 
		// TFS 1626 return true;
		return false; // TFS 1626
	endif;
	if not stopTableTemplate.isTranshipOnly and not stopTableTemplate.isTranshipIgnore then
		result := true;
	else
		if _isTranship then 
			if (stopTableTemplate.isTranshipOnly or not stopTableTemplate.isTranshipIgnore) then
				result := true;
			else
				result := false;
			endif;
		else
			if (stopTableTemplate.isTranshipOnly or not stopTableTemplate.isTranshipIgnore) then
				result := false;
			else
				result := true;
			endif;
		endif;
	endif;
	return result;
epilog

end;

</source>
        <Parameter name="_isTranship" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="7c1c0f4b-13f8-4551-a8bb-67d8b25a3bcf">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		March 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
//12 July 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
//03 Aug 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------

vars
	stopTableProxy	: CM_StopsTable;
	stopTableTemplateReal : CM_StopTableTemplate;
	stopTableTemplateProxy : CM_StopTableTemplate;
	completedOK		: Boolean;
	pxyStopCrit		: CM_StopCriteria;
	criteria : CM_YACriteria;
begin
	stopTableProxy := inheritMethod();

	stopTableProxy.myRoot := self.myRoot;
	//self.allCargoTypesNew.copy(stopTableProxy.allCargoTypesNew);	//03 Aug 2022	navsj20	TFS 53862
	self.allSecurityRolesMaint.copy(stopTableProxy.allSecurityRolesMaint);
	self.allSecurityRolesCancel.copy(stopTableProxy.allSecurityRolesCancel);		// cnwdad1 03/06/2010 - CCMS 1129.
	self.allSecurityRolesView.copy(stopTableProxy.allSecurityRolesView);
	foreach stopTableTemplateReal in self.allStopTableTemplates do
		stopTableTemplateProxy := stopTableTemplateReal.pxyCreateUpdateProxy();
		stopTableTemplateProxy.setKeys(stopTableTemplateReal.myTerminal, stopTableProxy);
	endforeach;
	if self.myHookCode &lt;&gt; null then //ccms 1093 cnwrs1 Feb 2008
		stopTableProxy.myHookCode := self.myHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	if self.myStopCriteria &lt;&gt; null then		//12 July 2022 navhl20 TFS 53862
		pxyStopCrit := self.myStopCriteria.pxyCreateUpdateProxy();
		pxyStopCrit.setProxyBaseData( stopTableProxy );
	endif;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return stopTableProxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete stopTableProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresInfoForCustoms" id="ff7e49e0-ea96-4133-80bb-eba6f4057bc9">
        <source>requiresInfoForCustoms() : Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 07SEP2023
ADO - CR 59942 TASK 59943 
*/

vars

begin
	if self.requiresInfo 
		and (self.requiresInfoType = CEDO 
			or self.requiresInfoType =  CustomsEntryNumber
			or self.requiresInfoType =  CustomsReference) then
		return true;
	endif;

	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="requiresInfoString" id="f3428825-5498-49b4-9765-e969cb730353">
        <source>requiresInfoString() :String;

vars
	baseScm 			: Schema;
	category 			: ConstantCategory;
	constDict			: ConstantNDict;
	const 				: Constant;
begin
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(StopRequiredFields);
	constDict := category.getConstants();
	foreach const in constDict do
		if const.getSource().Integer = self.requiresInfoType then
			return const.text;
		endif;
	endforeach;
	return null;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="59714260-aa79-4493-859a-fe2568bc9063">
        <updating/>
        <source>setForCreate(_proxyStopTable : CM_StopsTable) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	user 			: CM_User;
	userTerminal	: CM_UserTerminal;
	termSecRole 	: CM_SecurityRole;
	
begin

	self.id := _proxyStopTable.id; //par 20925 cnwrs1 Oct 2009 do this first so the dicts are correct
	self.setForUpdate(_proxyStopTable);
	
	/* 22/01/2016 cnwar2 #37414 - previously added stop to system/terminal roots only
	if (not self.allSecurityRolesMaint.includes(app.myRoot.mySecurityRoleSystem)) then
		self.allSecurityRolesMaint.add(app.myRoot.mySecurityRoleSystem);
	endif;
	if (not self.allSecurityRolesMaint.includes(app.myRoot.mySecurityRoleTerminal)) then
		self.allSecurityRolesMaint.add(app.myRoot.mySecurityRoleTerminal);
	endif;
// cnwdad1 03/06/2010 - CCMS 1129.
	if (not self.allSecurityRolesCancel.includes(app.myRoot.mySecurityRoleSystem)) then
		self.allSecurityRolesCancel.add(app.myRoot.mySecurityRoleSystem);
	endif;
	if (not self.allSecurityRolesCancel.includes(app.myRoot.mySecurityRoleTerminal)) then
		self.allSecurityRolesCancel.add(app.myRoot.mySecurityRoleTerminal);
	endif;
// cnwdad1 03/06/2010 - End of CCMS 1129.
	if (not self.allSecurityRolesView.includes(app.myRoot.mySecurityRoleSystem)) then
		self.allSecurityRolesView.add(app.myRoot.mySecurityRoleSystem);
	endif;
	if (not self.allSecurityRolesView.includes(app.myRoot.mySecurityRoleTerminal)) then
		self.allSecurityRolesView.add(app.myRoot.mySecurityRoleTerminal);
	endif;*/
	
	// 22/01/2016 cnwar2 #37414 - now add to user's role and all roles above this
	user := app.myPassport.myUser;
	foreach userTerminal in user.allUserTerminals do
	
		termSecRole := userTerminal.mySecurityRole;
		while termSecRole &lt;&gt; null do
			if (not self.allSecurityRolesMaint.includes(termSecRole)) then
				self.allSecurityRolesMaint.add(termSecRole);
			endif;
			if (not self.allSecurityRolesCancel.includes(termSecRole)) then
				self.allSecurityRolesCancel.add(termSecRole);
			endif;
			if (not self.allSecurityRolesView.includes(termSecRole)) then
				self.allSecurityRolesView.add(termSecRole);
			endif;
			
			termSecRole := termSecRole.myParentRole;
		endwhile;
		
	endforeach;
	
end;</source>
        <Parameter name="_proxyStopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="86cbd916-3b1a-4703-a596-b01587b5deb5">
        <updating/>
        <source>setForUpdate(_proxyStopTable : CM_StopsTable) updating;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//11 July 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
//03 Aug 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------
vars
	stopTableTemplateProxy : CM_StopTableTemplate;
	stopTableTemplateReal : CM_StopTableTemplate;
	pxyHookLink	: CM_HookLink;
	criteria : CM_StopCriteria;
begin

	_proxyStopTable.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	// START 03 Aug 2022	navsj20	TFS 53862
	//_proxyStopTable.allCargoTypesNew.copy( self.allCargoTypesNew);
	//self.allCargoTypesNew.clear;
	// END 03 Aug 2022	navsj20	TFS 53862
	self.allSecurityRolesMaint.clear;
	_proxyStopTable.allSecurityRolesMaint.copy(self.allSecurityRolesMaint);
	
// cnwdad1 03/06/2010 - CCMS 1129.
	self.allSecurityRolesCancel.clear();
	_proxyStopTable.allSecurityRolesCancel.copy(self.allSecurityRolesCancel);
	
	self.allSecurityRolesView.clear;
	_proxyStopTable.allSecurityRolesView.copy(self.allSecurityRolesView);
	
	self.requiresInfo := _proxyStopTable.requiresInfo;
	if self.requiresInfo then
		self.requiresInfoType := _proxyStopTable.requiresInfoType;
	else
		self.requiresInfoType := null;
	endif;

	self.code 						:= _proxyStopTable.code.trimBlanks;
	self.heading 					:= _proxyStopTable.heading.trimBlanks;
	self.shortHeading 				:= _proxyStopTable.shortHeading.trimBlanks;
	self.isNotAvailableForEntry		:= _proxyStopTable.isNotAvailableForEntry;
	self.allowClearanceExpiryDate	:= _proxyStopTable.allowClearanceExpiryDate;	// cnwrl1 08/12/2009 PAR 21889
	self.myRoot 					:= _proxyStopTable.myRoot;
	self.excludedForPinGeneration	:= _proxyStopTable.excludedForPinGeneration;	// ### TFS 61382 (61534) 01Dec2023 NAVPW1
	
	if _proxyStopTable.myHookCode &lt;&gt; null then //ccmw 1093 cnwrs1 Feb 2008
		pxyHookLink := _proxyStopTable.myHookLink;
		if pxyHookLink &lt;&gt; null then
			// need to set to the new persistent object
			pxyHookLink.setLinkObject(self);
		endif;
		if self.myHookCode = null then
			create self.myHookCode persistent;
			self.myHookCode.setForCreate(_proxyStopTable.myHookCode);
		else
			self.myHookCode.setForUpdate(_proxyStopTable.myHookCode);
		endif;
	else
		if self.myHookCode &lt;&gt; null then
			delete self.myHookCode;
		endif;
	endif;
	
	//Start 11 July 2022 navhl20 TFS 53862
	if _proxyStopTable.myStopCriteria &lt;&gt; null and _proxyStopTable.myStopCriteria.allCriteria.isNotEmpty then
		if self.myStopCriteria = null then
			create criteria persistent;
			criteria.setMyStopTable(self);
			criteria.setForCreate(_proxyStopTable.myStopCriteria);
		else
			self.myStopCriteria.setForUpdate(_proxyStopTable.myStopCriteria);
		endif;
	else
		criteria := self.myStopCriteria;
		delete criteria;
	endif;
	//End 11 July 2022 navhl20 TFS 53862
	
	foreach stopTableTemplateProxy in _proxyStopTable.allStopTableTemplates do
		stopTableTemplateReal := self.allStopTableTemplates[stopTableTemplateProxy.myTerminal, self];
		if stopTableTemplateReal = null then
			create stopTableTemplateReal persistent;
			stopTableTemplateReal.setKeys(stopTableTemplateProxy.myTerminal, self);
		endif;
		stopTableTemplateReal.setForUpdate(stopTableTemplateProxy);
	endforeach;
end;</source>
        <Parameter name="_proxyStopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="setNotAvailableForEntry" id="db31bf8d-f943-45c8-a3da-a43be8ef9bd7">
        <updating/>
        <source>setNotAvailableForEntry(_isNotAvailable : Boolean) updating;
/*

Purpose:		*Not in wmast* b/c BOL stop that prevents the UT that references
				this method from working, doesn't exist there...
Parameters:			

Return Value:		

Date		Who		Reason
24 Sep 2019	jlgsl4	861.080 cut - add more TSW UTs
*/

vars

begin
	self.isNotAvailableForEntry := _isNotAvailable;
epilog

end;</source>
        <Parameter name="_isNotAvailable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9ca2e759-c0e3-4d94-b6db-8d437d784d7d">
        <updating/>
        <source>setProxy(
	_requiresInfo				: Boolean;
	_code						: String;
	_heading					: String;
	_shortHeading				: String;
	_requiresInfoType			: Integer;
	_id							: Integer;
	_selectedTypes				: CM_CargoBOLTypeSet;
	_isNotAvailableForEntry		: Boolean;
	_allowClearanceExpiryDate	: Boolean;				// cnwrl1 08/12/2009 PAR 21889
	_myRoot						: CM_Root;
	_jadeCode					: String;
	_userCode					: String;
	_excludedForPinGeneration	: Boolean				// ### TFS 61382 (61534) 01Dec2023 NAVPW1
	) updating;

/* cnwrl1 08/12/2009 PAR 21889 - what it was
setProxy(_requiresInfo : Boolean;_code, _heading, _shortHeading : String; _requiresInfoType : Integer; _id : Integer;
		_selectedTypes : CM_CargoBOLTypeSet; _isNotAvailableForEntry : Boolean; _myRoot : CM_Root; _jadeCode, _userCode : String) updating;
*/

// ---------------------------------------------------------------------------
// Created:		March 2002 By Andrew Bishop cnwab1
// Purpose:		
// Parameters:	None
// Returns:		Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/12/2009	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Clearance Expiry Date
// 03/08/2022	navsj20		TFS 53862	EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------
vars
	hookLink : CM_HookLink;
begin
	// START 03 Aug 2022	navsj20	TFS 53862
	//self.allCargoTypesNew.clear;
	//_selectedTypes.copy(self.allCargoTypesNew);
	// END 03 Aug 2022	navsj20	TFS 53862
	self.code := _code;
	self.requiresInfo := _requiresInfo;		//JC Feb2003
	self.requiresInfoType := _requiresInfoType; //RS1 Jan 2007
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.allowClearanceExpiryDate	:= _allowClearanceExpiryDate;	// cnwrl1 08/12/2009 PAR 21889
	self.heading := _heading;
	self.shortHeading := _shortHeading;
	self.id := _id;
	self.myRoot := _myRoot;
	if _jadeCode &lt;&gt; null then //par17724 cnwrs1 Aug 2008
		if self.myHookCode &lt;&gt; null then //ccms1093 cnwrs1 Feb 2008
			self.myHookCode.setForProxy(self.code, app.myRoot.allHookTypes[HookType_IsStopRelevant]);
			self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
		else
			create self.myHookCode transient;
			self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode); //par 16779 may 2008 cnwrs1
			self.myHookCode.setForProxy(self.code, app.myRoot.allHookTypes[HookType_IsStopRelevant]);
			self.myHookCode.createProxyHookLinkForParent(HookType_IsStopRelevant, self);
		endif;
	else
		if self.myHookCode &lt;&gt; null then
			delete self.myHookCode;
		endif;
		if self.myHookLink &lt;&gt; null then
			hookLink := self.myHookLink;
			delete hookLink;
		endif;
	endif;
	
	self.excludedForPinGeneration := _excludedForPinGeneration;	// ### TFS 61382 (61534) 01Dec2023 NAVPW1
end;</source>
        <Parameter name="_requiresInfo" type="Boolean"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_shortHeading" type="String"/>
        <Parameter name="_requiresInfoType" type="Integer"/>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_selectedTypes" type="CM_CargoBOLTypeSet"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_allowClearanceExpiryDate" type="Boolean"/>
        <Parameter name="_myRoot" type="CM_Root"/>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_excludedForPinGeneration" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="d65f558f-f4c9-4548-a7ab-aff46e16918a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property = null or
	   _property.name = CM_StopTableTemplate::allProcessAreas.name or
	   _property.name = CM_StopTableTemplate::allPreventAreas.name or
	   _property.name = CM_StopTableTemplate::allApplyAreas.name or
	   _property.name = CM_StopTableTemplate::isChildIgnore.name or
	   _property.name = CM_StopTableTemplate::isChildOnly.name or
	   _property.name = CM_StopTableTemplate::isCoastalIgnore.name or
	   _property.name = CM_StopTableTemplate::isCoastalOnly.name or
	   _property.name = CM_StopTableTemplate::isTranshipIgnore.name or
	   _property.name = CM_StopTableTemplate::isTranshipOnly.name or
	   _property.name = CM_StopTableTemplate::isFull.name or
	   _property.name = CM_StopTableTemplate::isMT.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
