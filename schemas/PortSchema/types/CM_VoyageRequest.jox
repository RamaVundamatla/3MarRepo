    <JadeMethod name="setForUpdate" id="bfa5bac8-129c-4505-9c2c-7ce94b391b23">
        <updating/>
        <source>setForUpdate(_pxyRequest: CM_VoyageRequest) updating;
/*
Purpose:			
Date		Who		Reason
24 June 2011	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(_pxyRequest);

	self.code := _pxyRequest.code;
	self.doorsDirection := _pxyRequest.doorsDirection;
	self.isDischarge := _pxyRequest.isDischarge;
	self.isLoad := _pxyRequest.isLoad;
	self.isRehandle := _pxyRequest.isRehandle;
	self.isSoB := _pxyRequest.isSoB;
	self.motorDirection := _pxyRequest.motorDirection;
	self.weight := _pxyRequest.weight;
	self.moveType := _pxyRequest.moveType;
	
	if _pxyRequest.allAllocations.size() &gt; 0 then		
		self.allAllocations.clear(); // do not purge
		_pxyRequest.allAllocations.copyNoDupsToCol(self.allAllocations,false);		
	endif;

	app.writeVoyageLog(self, "Colour Code Update");  // PAR 31878 - logging

epilog

end;</source>
        <Parameter name="_pxyRequest" type="CM_VoyageRequest"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateDirection" id="c96c3559-3ff7-45ca-aa8c-642fa2de9268">
        <updating/>
        <source>setForUpdateDirection(_proxyVoyagetRequest: CM_VoyageRequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.doorsDirection:=_proxyVoyagetRequest.doorsDirection;
	//epr TFS 7006 29/9/17
	if self.doorsDirection = TI_DOORSDIRN_FWD then	
		self.motorDirection := Motor_Aft;
	elseif self.doorsDirection =  TI_DOORSDIRN_AFT then
		self.motorDirection := Motor_Forward;
	else 
		self.motorDirection := Motor_Null;
	endif;

epilog

end;</source>
        <Parameter name="_proxyVoyagetRequest" type="CM_VoyageRequest"/>
    </JadeMethod>
