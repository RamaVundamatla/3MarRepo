    <JadeMethod name="mnuGridPlanLoad_click" id="1e9f2e6c-8ddb-40c2-bfe0-687a451450d6">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGridPlanLoad_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
begin
	// PAR7631 AKB2004FEB from here
	if app.myMoveController &lt;&gt; null then
		theTI := app.myMoveController.myTrackedItem;
		if theTI &lt;&gt; null then
			if theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRLoad) &lt;&gt; null  
			or  theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMovePlanned) &lt;&gt; null  then
//				app.msgBox(theTI.id &amp; " is already planned to load, cannot plan again. Unplan and re-plan.","Planning Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				
				app.raiseCMException1(Alread_planne_unplan_replan_ne , theTI.id, null, null);
				return;
			endif;
		endif;
	endif;
	// PAR7631 AKB2004FEB to here

	// NOTE the TI and the source location have already been set on the build of the context menu

	if menuItem.userObject.isKindOf(CM_LocationsController) then
		self.moveTrackedItemSource();
	else
		// BULK LOAD PLAN
		self.moveTrackedItemsSource(menuItem.userObject.YRD_GCRackDrawingController);
	
	endif;



end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuGridSelectAreas_click" id="f82ce7f9-2458-4fb5-921f-8286d9a18999">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGridSelectAreas_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
	theLC : CM_LocationsController;
	theTI : CM_TrackedItem;
begin
	menuAction := app.myController.createMenuAction(PmYardAreaView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	aForm := menuAction.goToObject(null, null, false, null); 
	if aForm = null then
		return;
	endif;
	
	if menuItem.userObject.isKindOf(CM_LocationsController) then
		theLC := menuItem.userObject.CM_LocationsController;
	else
		theTI := menuItem.userObject.CM_TrackedItem;
		if self.myCurrentDrawingController.displayMode = DISPLAY_MODE_ACTUAL then
			theLC := theTI.myPrimaryActualLocation;
		elseif self.myCurrentDrawingController.displayMode = DISPLAY_MODE_QUEUE then
			theLC := theTI.myPrimaryQueuedLocation;
		elseif self.myCurrentDrawingController.displayMode = DISPLAY_MODE_PLAN then
			theLC := theTI.myPrimaryPlannedLocation;
		endif;
	endif;

	
	aForm.sendMsgWithParams("doInitializeWithTI",theLC.myTerminalArea,theLC,theTI);
	aForm.show;	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuGridSelectorClear_click" id="f294e42a-c07d-4640-a06b-4850a9b03dc5">
