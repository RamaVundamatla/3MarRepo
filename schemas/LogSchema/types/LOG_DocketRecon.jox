end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblTicketEntry_cellInputReady" id="b1983826-9a05-4592-9f02-8d821e0344d4">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTicketEntry_cellInputReady(table: Table; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cmb	: ComboBox;
begin

	if inputControl.isKindOf(ComboBox) then
		cmb := inputControl.ComboBox;
		if cmb.isKindOf(CMUI_ComboBox) then
			cmb.CMUI_ComboBox.selectAllText();
		else
			self.myAssistant.selectAllComboText(cmb);
		endif;
	endif;

	if inputControl = cmbOperators2 then
//		cmb := inputControl.ComboBox;
		cmb := inputControl.CMUI_ComboOperator;
//		cmb.listObject := app.myRoot.allOperators[table.text];
		cmb.CMUI_ComboOperator.setObject(app.myRoot.allOperators[table.text]);
	endif;
end;</source>
        <Parameter name="table" type="Table"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c3f02a23-9e50-4388-99c2-f20ae10dc40c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 May 2017 08:47:18.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006310, locale);
	btnAddReceipt.translateCaption(Xlat_0002351, locale);
	btnAddRelease.translateCaption(Xlat_0002352, locale);
	btnClose.translateCaption(Xlat_0002353, locale);
	btnDeleteDocket.translateCaption(Xlat_0002354, locale);
	btnDeleteTicket.translateCaption(Xlat_0002355, locale);
	btnEditDocket.translateCaption(Xlat_0002356, locale);
	btnEditTicket.translateCaption(Xlat_0002357, locale);
	btnMatch.translateCaption(Xlat_0002358, locale);
	btnMerge.translateCaption(Xlat_0002359, locale);
	btnSaveDocket.translateCaption(Xlat_0002360, locale);
	btnSaveTicket.translateCaption(Xlat_0002361, locale);
	btnSplit.translateCaption(Xlat_0002362, locale);
	lblDockets.translateCaption(Xlat_0002363, locale);
	lblTickets.translateCaption(Xlat_0002364, locale);
	mnuContextMenu.translateCaption(Xlat_0022000, locale);
	mnuHideRailTransfers.translateCaption(Xlat_0022001, locale);
	mnuInspect.translateCaption(Xlat_0022002, locale);
end;</source>
    </JadeMethod>
