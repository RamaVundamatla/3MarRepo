    <JadeMethod name="initShtMultiSelect" id="15a291bb-9786-44db-9ab1-c655260c48d2">
        <source>initShtMultiSelect();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwmd1	Initial creation

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	inheritMethod();

	theForm := self.myForm;	
	theForm.mulSelect1.visible		:= true;
	theForm.shtMultiSelect1.visible := true;
	theForm.txtName.visible			:= true;	//email address
	theForm.txtEmailName.visible	:= true;
	theForm.lblEmailAddress.visible	:= true;
	theForm.lblEmailName.visible	:= true;
	
	theForm.lblEmailName.move(50, 20,100, 18);
	theForm.txtEmailName.move(150, 20,205, 18);

	theForm.lblEmailAddress.move(50, 42,100, 18);
	theForm.txtName.move(150, 42,205, 18);

	theForm.txtEmailName.text		:= "";
	theForm.txtName.text			:= "";
	
	theForm.txtName.case			:= TextBox.Case_Lower;
				
	theForm.btnAddNew.visible		:= true;
	theForm.btnAddNew.bubbleHelp	:= "Enter a new email address and click here to add";
	theForm.btnAddNew.move(theForm.txtName.left + theForm.txtName.width + 5, theForm.txtName.top, 20, 20);
	
	theForm.lblName.visible			:= true;
	theForm.lblName.caption			:= "Add New:";
	theForm.lblName.width			:= 60;
	theForm.lblName.height			:= theForm.txtName.height;
	theForm.lblName.left			:= theForm.lblEmailName.left;
	theForm.lblName.top				:= -1;
			
	self.setupMultiSelect1('Addresses',app.myRoot.allEmailEntities,SOP_TableMaintForm::displayEntryEmailAddress.name);
epilog

end;</source>
    </JadeMethod>
