    <JadeMethod name="btnStart_click" id="cd4ac702-72d5-41ad-aa7e-c9cb94ebbe29">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStart_click(btn: Button input) updating;
// Vytenis	11/2006
vars

