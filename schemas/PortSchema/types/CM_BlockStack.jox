    <JadeMethod name="getRailAreaId" id="ab7864a3-a651-4db1-a1c9-9a3ceeda66f8">
        <source>getRailAreaId()	:	String;
//If this is a RTA, we return the ID of our Parent area.
vars
	ta	:	CM_TerminalArea;
	term	:	CM_Terminal;
begin
	if self.type &lt;&gt; TA_TYPE_RAIL_TRANS then
		return null;
  endif;
  term := self.myTerminal;
  foreach ta in term.allTerminalAreas do
  	if ta.isKindOf(CM_Rail) then
  		if ta.CM_Rail.myTransferArea = self then
  			return ta.id.trimRight;
  		endif;
  	endif;
  endforeach;
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRows" id="3fd93b19-0346-4bda-a09b-21f9895c2e14">
        <source>getRows( _forDrawing : Boolean ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 August 2011	cnwndl1	Initial creation	Par 28076

*/

vars

begin
	
	if self.rows &gt; 0 then
		return self.rows;
	elseif _forDrawing then
		return 5;	//YRD_ContainerDrawingController.BlockStackSize;
	endif;
	
	return self.rows;

epilog

end;</source>
