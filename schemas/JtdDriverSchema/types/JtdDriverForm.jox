    <JadeMethod name="resize" id="a1ff21b6-d74f-491c-af5f-d1cd5dfa48a7">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

vars
	jtd : JtdContext;
	
begin
	jtd := app.jtdMyContext;
	
	if jtd.jtdHasInitialFormPosition then
		if self.width &gt; jtd.jtdInitialFormWidth then
			self.width := jtd.jtdInitialFormWidth;
		endif;
		if self.height &gt; jtd.jtdInitialFormHeight then
			self.height := jtd.jtdInitialFormHeight;
		endif;	
	endif;
end;</source>
