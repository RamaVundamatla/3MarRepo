  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pHours" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="jssAddMinutes" id="9e10381a-17a1-4e8e-851b-152530057ec3">
        <source>jssAddMinutes(pMinutes:Integer):Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of minutes to the
//				receiver time.
//
// Parameters:	pMinutes (Integer) - The number of minutes to add (or subtract).
//
// Returns:		The resulting time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + ((pMinutes * 60) * 1000);
end;</source>
