<Class name="CMIF_KPIShipMove" id="935dd7a9-487a-4f3e-8330-df34e6e4def0">
    <superclass name="CMIF_KPIController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myJobSheet" id="416b8a50-d14c-4eaa-b97c-f0696dc1274d">
        <embedded/>
        <type name="CM_VoyageJobSheet"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myUpdateKPICrane" id="e5d1e6c3-2d47-4859-9e48-4c7796d28887">
        <embedded/>
        <type name="CM_KPIVoyageCraneShift"/>
    </ImplicitInverseRef>
    <JadeMethod name="processKPI" id="9b9f872f-7cfa-4eb5-b7f9-c9722a8bdc77">
        <updating/>
        <source>processKPI() updating;
// ---------------------------------------------------------------------------
// Created:		28 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/****Changes

Date		Name	TFS#			Description
============================================================================
22 Jun 2010	cnwkpd1	PAR #24609 - 	Fix 1086 exceptions and performance in 
									Voyage KPI processing.
10/08/2010	cnwcs5	CCMS MES 1033  	RORO KPI.  This method used to call two 
									trx methods but all the code has now been 
									combined so only one method need be called.
18/12/2018	jlgka1	41870			SNO - Add more logging for the Lock Keeper.	
============================================================================*/

vars
	jobSheet	: CM_VoyageJobSheet;
	voyage 		: CM_Voyage;
	terminal	: CM_Terminal;
begin
	if self.myJobSheet = null then
		return;
	endif;

	if self.myTiTransaction = null then
		return;
	endif;
	
	jobSheet	:= self.myJobSheet;
	voyage 		:= jobSheet.myVoyage;
	
	if voyage = null then
		return;
	endif;
	
	terminal 	:= voyage.myTerminal;	
	
	app.writeLog("KPI Agent - Voyage " &amp; voyage.code &amp; " " &amp; self.myTiTransaction.id &amp; " " &amp; self.myTiTransaction.String, LogDEBUG);
	
	if terminal.allShiftsStandard.isEmpty then
		return;
	endif;

	// add trans and TI etc and accumulate stats
	app.myTrxUA.trxUpdateVoyageKPIMoveForTRAN(self, app.myPassport);
end;</source>
    </JadeMethod>
</Class>
