			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2012	cnwndl1	Initial creation		Par 28896

*/

vars

begin

	self.entTableRowName := _entTableRowName;
	self.myCollectedObject := _myCollectedObject;
	self.myCCVoyRowAllocRow := _myCCVoyRowAllocRow;
	
	if _myCCVoyRowAllocRow &lt;&gt; null then
		self.myCCVoyAllocTableRoot := _myCCVoyRowAllocRow.myCCVoyAllocTableRoot;
	endif;

epilog

end;</source>
