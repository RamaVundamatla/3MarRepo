    <JadeMethod name="tCoarri_ECNMOT" id="564692de-6bfd-43cb-862f-3718781e60d9">
        <updating/>
        <source>tCoarri_ECNMOT()updating;
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     22 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10 Sep 2019	cnwrs1	TFS 46030
// ---------------------------------------------------------------------------
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'UT_VOYAGE';				
	BoatName		= 'UT_VESSEL';
	PortName		= "NZAKL";
	ContainerName1	= 'UTXT000001';
	ContainerName2	= 'UTXT000002';
	ContainerName3	= 'UTXT000003';
	ContainerName4	= 'UTXT000004';
	ContainerName5	= 'UTXT000005';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT-ECN1";
	CamProtocol 	= "UT_ECN_COARRI";
	CamProtocol2 	= "UT_ECN_COARRI2";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
vars
	runDateTime : TimeStamp;
	tempStr		: String;
	idx 		: Integer;
	container1, container2, container3, container4, container5 : CM_Container;
	operator, defaultOperator 	: CM_Operator;
	voyage, defaultVoyage 		: CM_Voyage;
	passport 	: CM_Passport;
	bs 			: CM_BlockStack;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol 	: CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
//	time 			: Time;
	port 			: CM_Port;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	crane			: CM_Machine;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	voyage := self.createVesselVoyage (VoyageName,BoatName,  operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings ();
	
	self.createVoyageDischargeJobs (voyage, crane.id);
	self.createVoyageLoadJobs (voyage, PortName, crane.id);
	self.planLoadItems (voyage, crane.id);
	self.loadAllJobsToOps(voyage, true);
	self.planDischargeItems(voyage, bs, crane.id);
	self.moveAllCargo (voyage);
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocol		:= self.createCamProtocolCoarri (CamProtocol, camGroup,"MOT-ECN COARRI", "NZCHC",operator.code);
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_ECNMOT);	// par 29517
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
end;
</source>
