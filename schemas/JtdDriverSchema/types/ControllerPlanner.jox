	sa.add('cp176_CN_lstTest_dblClick');
	sa.add('cp178_CEF_cmbFiltVoyageclick');
	sa.add('cp180_CEF_picture_click');
	sa.add('cp182_CSAF_picture_click');
	sa.add('cp184_CSAF_picture_click');
	sa.add('cp186_CN_lstTest_click');
	sa.add('cp188_CN_lstTest_dblClick');
	//Road Operations
	sa.add('cp190_CN_lstTest_click');/**/
	if app.profileName = "YardShipController" then
	//Job Operations
		sa.add('cp192_CN_lstTest_dblClick');
		sa.add('cp194_SVOF_lstJobs_pictureClic');
		/*sa.add('cp196_SVOF_lstJobs_pictureClic');
		sa.add('cp198_SVOF_lstJobs_pictureClic');
		sa.add('cp200_SVOF_lstJobs_pictureClic');
		sa.add('cp202_SVOF_lstJobs_pictureClic');
		sa.add('cp204_SVOF_lstJobs_pictureClic');
		sa.add('cp206_SVOF_lstJobs_pictureClic');
		sa.add('cp208_SVOF_lstJobs_click');
		sa.add('cp210_SVOF_lstJobs_pictureClic');
		sa.add('cp212_SVOF_lstJobs_pictureClic');
		sa.add('cp214_SVOF_lstJobs_pictureClic');
		sa.add('cp216_SVOF_lstJobs_pictureClic');
		sa.add('cp218_SVOF_lstJobs_pictureClic');/**/
		sa.add('cp220_SVOF_lstJobs_click');
		sa.add('cp222_SVOF_lstJobs_click');
		sa.add('cp224_SVOF_lstJobs_click');
		sa.add('cp226_SVOF_lstJobs_click');
		sa.add('cp228_SVOF_lstJobs_click');
		sa.add('cp230_SVOF_picture_click');
		sa.add('cp232_CN_lstTest_click');
		// SEQUENCE SHEET 812 remove now just a print option on OOW
	/*	sa.add('cp234_CN_lstTest_dblClick');
		sa.add('cp236_SSSF_cmbVoyage_click');
		sa.add('cp238_SSSF_cmbCrane_click');
		sa.add('cp240_SSSF_picture_click');
		sa.add('cp242_SSSF_picture_click');*/
		
		//back to OOW form
		sa.add('cp244_CN_lstTest_click');
		sa.add('cp246_CN_lstTest_pictureClick');
		sa.add('cp248_CN_lstTest_pictureClick');
		sa.add('cp250_CN_lstTest_pictureClick');
	endif;
	sa.add('cp252_CSAF_picture_click');
	sa.add('cp999_tidyUp');

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
