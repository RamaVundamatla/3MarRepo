    <JadeMethod name="jssTime" id="1d915e6f-e246-4c15-8564-eb6f4e7f6bce">
        <source>jssTime(): Time;
// -----------------------------------------------------------------------------
// Created:		03 January 2002 by cnwdad1
//
// Purpose:		Returns the receiver's number as a time, assuming that the value
//				is the number of milliseconds since midnight.
//
// Parameters:	None
//
// Returns:		The current time setting.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	timeValue	: Time;
	
begin
	timeValue	:=	self.getValue().Time;
	
	if timeValue.isValid() then
		return timeValue;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Time"/>
