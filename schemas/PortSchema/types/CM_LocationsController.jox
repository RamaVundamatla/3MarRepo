    <JadeMethod name="isActivityTrackingLocation" id="98abfbfc-44ce-4d16-8dd1-e7cf29a7bad1">
        <source>isActivityTrackingLocation():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if self.isVehicle then
		//vehicles are consider yard laocations byt we don't want these
		return false;
	elseif self.isTILCController then
		//trailers are consider yard laocations byt we don't want these
		return false;
	elseif self.isYardLocation then
		//Only real yard locations thanks.
		return true;
	endif;
	
	return false;
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
