    <JadeMethod name="getAllYAIdentifiers" id="2cd54232-b42a-4c75-ac4a-24972d4bd9ff">
        <source>getAllYAIdentifiers(_yaIdentifiers: StringArray input): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2009	cnwmd1	Initial creation

*/

vars

begin
	_yaIdentifiers.clear;
	_yaIdentifiers.add(app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_RAIL));
	_yaIdentifiers.add(app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_ROAD));
	_yaIdentifiers.add(app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_SHIP));
	//_yaIdentifiers.add(app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_NULL));
	
	return true;

epilog

end;</source>
        <Parameter name="_yaIdentifiers" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="4e50ba8f-b3c0-4a3c-ba09-a7089529aa57">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/11/2010	cnwdap1	Initial creation PAR #26184
*/
vars
	modes : IntegerArray;

begin
	create modes transient;
	modes.add(_ti.intendedReleaseMode);
	_criteriaValue := modes;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="18ac100c-b61b-4a9b-8ae4-add1872f5cdf">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
vars
	i				: Integer;
	displayString	: String;
	
begin
	if pDataObj.isKindOf(CM_YADataPattern) then
		return pDataObj.CM_YADataPattern.getDataDisplay(self);
	endif;

	foreach i in pDataObj.CM_YADataInteger.allValues do
		if displayString = null then
			displayString	:=	app.intendedReleaseModeEnum2String(i);
		else
			displayString	:=	displayString &amp; ", " &amp; app.intendedReleaseModeEnum2String(i);
		endif;
	endforeach;
	
	return displayString;
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIntegerDisplay" id="a2173b3c-f6fe-4629-bdc5-a170f59b3b3a">
        <source>getIntegerDisplay(_value : Integer) : String;
//01 August 2008	cnwdw1
begin
	return app.intendedReleaseModeEnum2String(_value);
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
