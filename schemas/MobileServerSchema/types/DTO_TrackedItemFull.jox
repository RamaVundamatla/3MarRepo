    <JadeMethod name="setFromPersistent" id="5e84e914-68e0-4d5b-a1bb-b23e3b9ea795">
        <updating/>
        <source>setFromPersistent(_ti : CM_TrackedItem) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _ti = null then
		return;
	endif;
	
	self.cargoType		:= _ti.cargoType;
	self.carrier		:= _ti.carrier;
	self.commodity		:= _ti.commodity;
	self.consignee		:= _ti.consignee;
	self.consignor		:= _ti.consignor;
	self.id				:= _ti.id;
	self.isCoastal		:= _ti.isCoastal;
	self.isHazardous	:= _ti.isHazardous;
	self.locationId		:= _ti.locationId;
	self.receivedDT		:= _ti.receivedDT;
	self.remarks		:= _ti.remarks;

	inheritMethod(_ti);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
