    <JadeMethod name="getProspectWagonResDets" id="fe592544-4054-4a74-ad65-f77c686ac29a">
        <source>getProspectWagonResDets( _wagon : CM_Wagon; _resDets : CM_ReserveDetailArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2020	jlgndl1	Initial creation TFS 50164 - NON stwr version

*/

vars

	train : CM_Train;
	startObject : CM_BulkRelease;
	iter : Iterator;
	release : CM_BulkRelease;
	relIter : Iterator;
	reserveDetail : CM_ReserveDetail;
	cargoType : CM_CargoType;
	isByWeightOrVolume : Boolean;
	
	totReq : Integer;
	totAct : Integer;
	totDel : Integer;
	osValue : Integer;
	wtReq : Decimal [16,4];
	wtAct : Decimal [16,4];	
	wtDel : Decimal [16,4];
	osWeight : Decimal [16,4];

begin

	if _resDets = null then
		return;
	endif;
	
	_resDets.clear();
	
	if _wagon = null or _wagon.getTerminal = null then
		return;
	endif;
	
	train := _wagon.myTrainOutwards;
	
	if train = null or train = self.myTerminal.getNullTrain then
		return;
	endif;
	
	startObject := self.myTerminal.allBulkReleaseByTypeByStByCd.getAtKeyGeq(BR_TYPE_RAIL,BR_ACTIVE,null,null);
	if startObject = null then
		return;
		
	else
		relIter := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator;
		relIter.startAtObject( startObject );
		while relIter.next( release ) do
			if release.type &lt;&gt; BR_TYPE_RAIL then
				break;
			endif;
			
			if release.status &lt;&gt; BR_ACTIVE then
				break;
			endif;
			
			if release.myAssignedTrain &lt;&gt; null and release.myAssignedTrain &lt;&gt; train then
				continue;
			endif;
			
			iter := release.allReserveDetails.createIterator;
			while iter.next( reserveDetail ) do
				cargoType := reserveDetail.getCargoType;
				if cargoType = null then
					continue;
				endif;
				
				if _wagon.isWellcarVisit and not cargoType.isContainer then
					//Wellcars can only carry containers
					continue;
				elseif cargoType.isContainer and ( not _wagon.isFlatcar and not _wagon.isWellcarVisit ) then
					//Containers only allowed on flat cars and well cars.
					continue;
				elseif cargoType.isLog and not _wagon.isSkeletonCar then
					// Logs only allowed on well cars
					continue;
				endif;
				
				isByWeightOrVolume := false;
				if cargoType.isBulkByVolume or cargoType.isBulkByWeight then
					isByWeightOrVolume := true;
				endif;
				if isByWeightOrVolume then	
					wtReq := reserveDetail.weightRequested;
					reserveDetail.quantityOnSiteWithJobRail( wtAct );	
					wtDel := reserveDetail.getWeightReleased();
					osWeight := wtReq - wtAct - wtDel;
					if osWeight &lt;= 0 then
						continue;
					endif;
				else	
					totReq := reserveDetail.totalRequested;
					totAct := reserveDetail.quantityOnSiteWithJobRail( wtAct );
					totDel := reserveDetail.getTotalReleased; //jlier1 TFS 54150 26/7/22
					osValue := totReq - totAct - totDel;
					if osValue &lt;= 0 then
						continue;
					endif;
				endif;
				if _wagon.hasResDetAlreadyAssigned( reserveDetail ) then
					continue;
				endif;
				
				_resDets.add( reserveDetail );
			endwhile;
			delete iter;
			
		endwhile;
		
	endif;
	

epilog

	delete relIter;
	delete iter;

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_resDets" type="CM_ReserveDetailArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProspectWagonResDetsOrig" id="54dbe2b7-c124-4950-9946-6efa5274d1ee">
        <source>getProspectWagonResDetsOrig( _wagon : CM_Wagon; _resDets : CM_ReserveDetailArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2017	cnwndl1	Initial creation	TFS 3514
01 Dec 2020	NDL	  TFS 50164 - This is the original 'STWR' version unchanged except for the name so we don't break STWR existing behaviour

*/

vars

	train : CM_Train;
	startObject : CM_BulkRelease;
	iter : Iterator;
	release : CM_BulkRelease;
	relIter : Iterator;
	reserveDetail : CM_ReserveDetail;
	cargoType : CM_CargoType;
	isByWeightOrVolume : Boolean;
	
	totReq : Integer;
	totAct : Integer;
	totDel : Integer;
	osValue : Integer;
	wtReq : Decimal [16,4];
	wtAct : Decimal [16,4];	
	wtDel : Decimal [16,4];
	osWeight : Decimal [16,4];

begin

	if _resDets = null then
		return;
	endif;
	
	_resDets.clear();
	
	if _wagon = null or _wagon.getTerminal = null then
		return;
	endif;
	
	if not _wagon.isBoxcar then
		return;
	endif;
	
	train := _wagon.myTrainOutwards;
	
	if train = null or train = self.myTerminal.getNullTrain then
		return;
	endif;
	
	startObject := self.myTerminal.allBulkReleaseByTypeByStByCd.getAtKeyGeq(BR_TYPE_RAIL,BR_ACTIVE,null,null);
	if startObject = null then
		return;
		
	else
		relIter := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator;
		relIter.startAtObject( startObject );
		while relIter.next( release ) do
			if release.type &lt;&gt; BR_TYPE_RAIL then
				break;
			endif;
			
			if release.status &lt;&gt; BR_ACTIVE then
				break;
			endif;
			
			if release.myAssignedTrain &lt;&gt; null and release.myAssignedTrain &lt;&gt; train then
				continue;
			endif;
			
			iter := release.allReserveDetails.createIterator;
			while iter.next( reserveDetail ) do
				cargoType := reserveDetail.getCargoType;
				if cargoType = null then
					continue;
				endif;
				if not cargoType.isBulkMulti and not cargoType.isBreakBulkMulti then
					continue;
				endif;
				isByWeightOrVolume := false;
				if cargoType.isBulkByVolume or cargoType.isBulkByWeight then
					isByWeightOrVolume := true;
				endif;
				if isByWeightOrVolume then	
					wtReq := reserveDetail.weightRequested;
					reserveDetail.quantityOnSiteWithJobRail( wtAct );	
					wtDel := reserveDetail.getWeightReleased();
					osWeight := wtReq - wtAct - wtDel;
					if osWeight &lt;= 0 then
						continue;
					endif;
				else	
					totReq := reserveDetail.totalRequested;
					totAct := reserveDetail.quantityOnSiteWithJobRail( wtAct );
					totDel := reserveDetail.getTotalReleased; //jlier1 TFS 54150 26/7/22
					osValue := totReq - totAct - totDel;
					if osValue &lt;= 0 then
						continue;
					endif;
				endif;
				if _wagon.hasResDetAlreadyAssigned( reserveDetail ) then
					continue;
				endif;
				
				_resDets.add( reserveDetail );
			endwhile;
			delete iter;
			
		endwhile;
		
	endif;
	

epilog

	delete relIter;
	delete iter;

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_resDets" type="CM_ReserveDetailArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRetrospectiveTS" id="13539b81-ef31-474d-8488-7fa13cb958d4">
        <source>getRetrospectiveTS( _ts : TimeStamp io );
/*

Purpose:			

Parameters:			Called from CMIF_WagonUpdateController::autoSetEffectiveTimeStamp

Return Value:		

Date		Who		Reason
26 February 2021	navndl1	Initial creation	TFS 50837

*/

vars

	cmif : CMIF_WagonUpdateController;  // here to provide a reference of sorts that might be found by a lost dev...
	cmif2 : CMIF_WagonMoveController;  // here to provide a reference of sorts that might be found by a lost dev...

begin

	_ts := null;

	if not validateRetrospectiveTS(null) then
		return;
	elseif self.chkRetrospect.value and self.retrospectiveDate.date.isValid then
		_ts := self.retrospectiveDate;
	endif;

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSelectedWagons" id="4291e4db-3bbb-4ac6-9f19-9b92f03b7f8c">
        <source>getSelectedWagons( wagonColl : Collection input; _defaultWagon : CM_Wagon );

/*

Purpose:			Returns selected wagons.

Parameters:			

Return Value:		


Date		Who		Reason
09 Jun 2009	consw1	Initial creation

*/

vars
	gridArea		: CMUI_GridArea;

begin
	wagonColl.clear();

	foreach gridArea in self.mySDF.allGridAreasByRowColumn where gridArea.YRD_WagonArea.isWagonSelected() do
		wagonColl.add(gridArea.YRD_WagonArea.myWagon);
	endforeach;
	
	if wagonColl.size &lt; 2 and _defaultWagon &lt;&gt; null then
		wagonColl.clear();
		wagonColl.add(_defaultWagon);
	endif;

epilog

end;</source>
        <Parameter name="wagonColl" type="Collection" usage="input"/>
        <Parameter name="_defaultWagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getTblDataXML" id="a1e7e688-3052-446b-a328-28d6a126da82">
        <updating/>
        <source>getTblDataXML(_userWindow: CM_UserWindow) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/03/2011	cnwdap1	Initial creation PAR #27166 CCMS POL 2001 Separate table columns for incoming/outgoing
*/
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	tmpTypeStr	: String;
	
begin
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(app.getFormCaptionsString(Xlat_0011024));
	self.xmlStrTblDataArray[1] := tmpTypeStr.trimCharacters(CrLf);
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(app.getFormCaptionsString(Xlat_0011026));
	self.xmlStrTblDataArray[2] := tmpTypeStr.trimCharacters(CrLf);
	
	self.xmlStrTblData := self.xmlStrTblDataArray[1];
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="getWagonAreaFromWagonObject" id="981beccb-4024-40e5-935c-90e603472391">
        <source>getWagonAreaFromWagonObject(_theWagon : CM_Wagon) : YRD_WagonArea;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		Looks for the wagon in its expected position in the grid area.
//				Returns the displayed Wagon Area if there otherwise null.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	lastWagonArea : YRD_WagonArea;
	theWagonArea : YRD_WagonArea;
	theRow, theCol : Integer;
	theRailLine : CM_RailLine;
begin

	if _theWagon = null then
		return null;
	endif;
	
	if self.myCurrentTrain &lt;&gt; null then
		theRow := 1;
		if self.optDirOutTB.value then
			if _theWagon.myTrainOutwards &lt;&gt; self.myCurrentTrain then
				return null;
			endif;
			theCol := _theWagon.getMyPositionTrainOutwards();
		else
			if _theWagon.myTrainInwards &lt;&gt; self.myCurrentTrain then
				return null;
			endif;
			theCol := _theWagon.getMyPositionTrainInwards();
		endif;
	else
		theRailLine := _theWagon.myRailLine;
		if theRailLine = null or theRailLine.myRailArea &lt;&gt; self.myCurrentRailArea then
			return null;
		endif;
		theRow := theRailLine.getMyPosition();
		theCol := _theWagon.getMyPosition();
	endif;

	if theRow = 0 or theCol = 0 then
		return null;
	endif;
	
	if self.flipHorizontal then
		theCol := self.getMaximumColumn() + 1 - theCol;
	endif;

	lastWagonArea := self.mySDF.allGridAreasByRowColumn.last.YRD_WagonArea;

	if lastWagonArea = null or lastWagonArea.row &lt; theRow or lastWagonArea.column &lt; theCol then
		return null;
	endif;

	theWagonArea := self.mySDF.allGridAreasByRowColumn[theRow,theCol].YRD_WagonArea;

	if theWagonArea &lt;&gt; null then
		if theWagonArea.myWagon = _theWagon then
			return theWagonArea;
		endif;
	endif;
		
	return null;
end;</source>
        <Parameter name="_theWagon" type="CM_Wagon"/>
        <ReturnType type="YRD_WagonArea"/>
    </JadeMethod>
    <JadeMethod name="getWagonAreaFromWagonObjectWas" id="cabf77fa-b7e0-4193-a2b5-e81bf1463796">
        <source>getWagonAreaFromWagonObjectWas(_theWagon : CM_Wagon) : YRD_WagonArea;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		If a wagon is moved this will work out where it was on the screen
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theWagonArea : YRD_WagonArea;
	aGridArea : CMUI_GridArea;
	theRow, theCol : Integer;
	theRailLine : CM_RailLine;
begin

	if _theWagon = null then
		return null;
	endif;
	

	foreach aGridArea in self.mySDF.allGridAreasByRowColumn do
		theWagonArea := aGridArea.YRD_WagonArea;
		if theWagonArea.myWagon.String = _theWagon.String then
			return theWagonArea;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_theWagon" type="CM_Wagon"/>
        <ReturnType type="YRD_WagonArea"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="cee1db00-a58b-4f98-b135-9bba0dde7007">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/05/2009	consw1		SFW1067 - Rail Simplifications
// 08/02/2011	cnwdap1		PAR #27166 CCMS POL 2001 Save off separate columns for Inward and Outward
// ---------------------------------------------------------------------------

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out

vars
	theXML 		: String;
	theGridArea : CMUI_GridArea;
	tableXML	: String;			// PAR #27166
begin

	theXML := inheritMethod() &amp; global.formatAsXML("ZM",self.mySDF.scaleFactor.String) &amp;
//					global.formatAsXML("showExtraInfoInTab",self.mnuToggleExtraInfo.caption) &amp;
//					global.formatAsXML(XML_TV,self.mnuToggleTransportView.caption);
					global.formatAsXML(XML_TV,self.xmlShowGraphic.Integer.String) &amp; 
					global.formatAsXML("showExtraInfoInTab",self.xmlShowMacroInfo.Integer.String); // DO NOT TRANSLATE

//		global.formatAsXML("XMLTag_HideColorLegend", (not self.splGridArea.visible).String) &amp;
//		global.formatAsXML("XMLTag_HideToolBar", (not self.frmRakeToolbar.visible).String) &amp;		
//		global.formatAsXML(XMLTag_HideExtraInfo, (not self.splExtraInfo.visible).String);
	theXML := theXML &amp; self.tblTrains.getXmlStrForColumns(true);
	
	// PAR #27166 Save off work list entry table settings for inward table and outward table
	if self.xmlStrTblDataArray.size &gt;= 1 then
		theXML := theXML &amp; app.formatAsXMLPrefix(app.getFormCaptionsString(Xlat_0011024)) &amp; self.xmlStrTblDataArray[1] &amp; app.formatAsXMLSuffix(app.getFormCaptionsString(Xlat_0011024));
	endif;
	if self.xmlStrTblDataArray.size &gt;= 2 then
		theXML := theXML &amp; app.formatAsXMLPrefix(app.getFormCaptionsString(Xlat_0011026)) &amp; self.xmlStrTblDataArray[2] &amp; app.formatAsXMLSuffix(app.getFormCaptionsString(Xlat_0011026));
	endif;
	// PAR #27166 end
	
	theXML := theXML &amp; global.formatAsXML( self.chkRetrospect.name, self.chkRetrospect.value.String );	//23 Feb 2021	NDL	TFS 50837
	
	
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="a4ddfce9-d730-40e1-aea7-b6a0b37bd708">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/05/2009	consw1		SFW1067 - Rail Simplifications
// 08/02/2011	cnwdap1		PAR #27166 CCM SPOL 2001 separate column organisers for Inward and Outward
// 07/06/24		jlier1 		TFS 64530 - performance improvements
// ---------------------------------------------------------------------------

vars
	zoomScale : Real;
	userWindow		: CM_UserWindow;
	theXML, theCaption : String;
	colXml : String;		// PAR #27166
	idx : Integer;			// PAR #27166
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		self.splGridArea.setLeftToRightRatio(20);
		self.xmlShowMacroInfo := true;
		self.xmlShowGraphic :=true;
		self.doShowHideExtraInfo();
		self.doToggleTransportView();
		return;
	endif;
	theXML := userWindow.xmlInfo;

	zoomScale := theXML.cnEcGetTagValueOfName("ZM").Real;
	theCaption := theXML.cnEcGetTagValueOfName("showExtraInfoInTab").String; // DO NOT TRANSLATE

	if theCaption = null then
		self.xmlShowMacroInfo := true;
	else
		self.xmlShowMacroInfo := theCaption.Integer.Boolean;
		
		
		//self.mnuToggleExtraInfo.caption := theCaption;
	endif;
	self.doShowHideExtraInfo();
	
 	if zoomScale = null then
	 	zoomScale := 1;
	endif;

 	theCaption := theXML.cnEcGetTagValueOfName(XML_TV).String;
	if theCaption = null then
		self.xmlShowGraphic :=true;
		//theCaption := self.MNU_TRANSPORTVIEW_HIDE;
	else
		self.xmlShowGraphic := theCaption.Integer.Boolean;
	endif;

	self.doToggleTransportView();
	 
 	// ### SET CONTROLS
 	self.mySDF.scaleFactor := zoomScale;
	
	// PAR #27166 if xml string array for wle table is empty, put in the ent def for both in and out
	getTblDataXML(userWindow);
	colXml := self.tblWorkEntries.getXmlStrForColumns(true);
	if self.xmlStrTblDataArray.size = 0 then
		self.xmlStrTblDataArray[1] := colXml;
		self.xmlStrTblDataArray[2] := colXml;
	endif;
	foreach idx in 1 to self.xmlStrTblDataArray.size do
		if self.xmlStrTblDataArray[idx] = null then
			self.xmlStrTblDataArray[idx] := colXml;
		endif;
	endforeach;
	// PAR #27166 end
	
	self.chkRetrospect.value := userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkRetrospect.name).Boolean;	//23 Feb 2021	NDL	TFS 50837
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="gridAreaMouseMoveEvent" id="9645c476-dcfb-4d4a-8bb1-15e9d6905e4a">
        <updating/>
        <source>gridAreaMouseMoveEvent(_button : Integer; _x, _y : Real)updating;
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	theTI		: CM_TrackedItem;
	wle			: CM_WorkListEntry;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if self.frmGridArea = null or
			self.frmGridArea.myGridArea = null then
		return;
	endif;

	if _button &lt;&gt; 1 or (not app.dragDetected(_x, _y, self.origXPos, self.origYPos)) then
		return;
	endif;

	// initiate a drag/drop
	gridPoint := self.frmGridArea.myGridArea.convertPositionToGridPoint(self.origXPos, self.origYPos);
	if gridPoint = null then
		return;
	endif;

	if gridPoint.isKindOf(YRD_WagonBody) or gridPoint.isKindOf(YRD_WagonWheels) then
		self.dragWagon(gridPoint.myGridArea.YRD_WagonArea.myWagon, self.frmGridArea);
		return;
	endif;
	
	theTI := gridPoint.getTI(self.origXPos, self.origYPos);
	if theTI = null then
		return;
	endif;

	app.myDraggedTrackedItem := theTI;
	if theTI.jobRailReceive &lt;&gt; null then
		wle := theTI.jobRailReceive.getWLEForTI(theTI);
		//01 Dec 2015	NDL	Par 36788
		if wle.status = WLE_COMPLETED then
			wle := null;
		endif;
	endif;
//	if wle &lt;&gt; null then
//		if wle.status = WLE_COMPLETED then
//			app.raiseCMException2(VB_JOB_NOT_UNACTIONED, wle.job.jobId, wle.statusString, null, null);
//			return;
//		endif;
//	endif;		
	self.dragTrackedItem(theTI, wle, self.frmGridArea);
	
end;</source>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="gridPointChange" id="24d4a375-9ad6-44d7-92a3-3ec41707d935">
        <updating/>
        <source>gridPointChange(_gridPoint: CMUI_GridPoint input; _x, _y : Real) updating;
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	wgnController : CM_WagonController;

begin
	inheritMethod(_gridPoint, _x, _y);
	
	if _gridPoint = null then
		return;
	endif;
	
	// sgp 31 July 2003 : now done via the right click menu
//	if _gridPoint.isKindOf(YRD_WagonBody) then
//		_gridPoint.YRD_WagonBody.setController();
//		_gridPoint.YRD_WagonBody.drawSelf(self.frmGridArea);
//	endif;
	showInfoForWagonGridPoint(_gridPoint, _x, _y);
end;</source>
        <Parameter name="_gridPoint" type="CMUI_GridPoint" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="gridPointRecieveDrop" id="80340684-c955-4860-aad4-928e077e2368">
        <updating/>
        <source>gridPointRecieveDrop(_frame: Frame input; _win: Window input; _gridPoint: CMUI_GridPoint input; _x: Real; _y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

begin

	if _gridPoint = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	self.gridPointChange(_gridPoint, _x, _y);
	
	if self.isMultiCargoDrop(_win, _gridPoint, _x, _y ) then
		return;
	endif;
		
	self.assignTIToTransport(_gridPoint.myLocationsController);
	
		
epilog

	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_win" type="Window" usage="input"/>
        <Parameter name="_gridPoint" type="CMUI_GridPoint" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleSysNotification" id="c2d4d180-3bcd-4d4c-b0b6-2c5d7da10f3d">
        <updating/>
        <source>handleSysNotification(_obj : CM_Object; _event : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Apr 2025	navnk30	JIRA 34157: MTN | Rail Operations - Handle Notifications

*/

vars
	idx			: Integer;
	train 		: CM_Train;
	theDataLine	: String;
	invalid		: Boolean;
	str			: String;
begin
	/**
	 * This method has been created from CMUI_OpsForm::sysNotify() and YRD_RailOperationsForm::sysNotify()
	 * system notification handling part can be handled using Notifications framework.
	 */
	 
	on Exception do app.handleDeletedObject(exception, train, invalid);
	
	if _event = Object_Update_Event then
		if CM_TrackedItem.hasInstance(_obj) then
			self.updateTIWle(_obj.CM_TrackedItem);
		endif;
	endif;
	if CM_Train.hasInstance(_obj) then
		train := _obj.CM_Train;
		str := train.asStringJMT;
		if invalid then
			return;
		endif;
		if _event = Object_Delete_Event then
			if self.myCurrentTrain = train then
				self.setMyTrain( null );
				self.cmbTrain.listObject := null;
				self.doRefreshGraphicView();
			endif;
		else
			if not self.tblTrains.findObjectInRow(train,idx) then
				theDataLine := train.getAttributeStringForDefArray(self.tblTrains.allTblDataEntRows);
				idx := self.tblTrains.addItem(theDataLine);
				self.tblTrains.accessRow(idx).itemObject := train;
			endif;
		endif;
		self.myAssistant.comboBoxTrain(self.cmbTrain, self.cmbTrain.listObject.CM_Train, false, true, false);
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUserNotification" id="577f9dc8-7976-4bc9-9987-be811d74c96f">
        <updating/>
        <source>handleUserNotification(_obj : CM_Object; _event : Integer)updating;
//--------------------------------------------------------------
//Created: 31 January 2003 By: cnwgd1
//14 Apr 2025 navnk30	JIRA 34157: MTN | Rail Operations - Handle Notifications
//--------------------------------------------------------------
vars

	str			: String;
	topRow,
	idx,
	level		: Integer;
	wagon 		: CM_Wagon;
	railJob 	: CM_RailJob;
	expanded 	: Boolean;
	
begin

	self.tblWLESaveSelected();			//15.04.2025 navnk30 JIRA 34157 START
	if _event = WLE_Update_Event then
		self.tblWLEUpdateWle(_obj.CM_WorkListEntry, self.Mode_Update);
		return;
	elseif _event = WLE_Create_Event then
		self.tblWLEUpdateWle(_obj.CM_WorkListEntry, self.Mode_Add);
		return;
	elseif _event = WLE_Delete_Event then
		if self.selectedTableObject.String = _obj.String then
			self.selectedTableObject := null;
		endif;
		self.tblWLEUpdateWle(_obj.CM_WorkListEntry, self.Mode_Delete);
		return;
	endif;								//15.04.2025 navnk30 JIRA 34157 END

	inheritMethod(_obj, _event);
	
	if _event = Rail_Clear_Rake_Event then
		self.updateRailRakeArea(_obj.CM_Rail);
		return;
	endif;

	if _event = RailJob_Delete_Event or _event = Wagon_Delete_Event then
		if _event = Wagon_Delete_Event then
			self.updateWagonArea(_obj.CM_Wagon, _event);
		endif;
	endif;

	if _obj = null or (not global.isValidObject(_obj)) then
		return;
	endif;
	
	if _obj.isKindOf(CM_Wagon) then
		wagon := _obj.CM_Wagon;
		self.updateWagonArea(wagon, _event);
		if self.viewMode &lt;&gt; ViewMode_Transport then
			return;
		endif;
	elseif _obj.isKindOf(CM_RailJob) then
		railJob := _obj.CM_RailJob;
	endif;

	if _event = RailJob_Create_Event then
		if railJob &lt;&gt; null then
			if not self.includeRailJob(railJob) then
				return;
			endif;
			self.displayAllWLEsForObj(railJob);
		endif;
	elseif _event = Wagon_Create_Event then
		if wagon &lt;&gt; null then
			self.updateWagonArea(wagon, _event);						
		endif;
		return;	
	endif;
	
	topRow := self.tblWorkEntries.topRow;
	
	if _event = RailJob_Update_Event then
		if railJob &lt;&gt; null then
			//29 Jul 2009	NDL  check for any that were in the table that should now be removed.
			if self.removedUnrelatedJobWLE( railJob ) then
			else
				self.displayAllWLEsForObj(railJob);
			endif;
		endif;
		
	elseif _event = Wagon_Update_Event then
		if wagon &lt;&gt; null then
			self.updateWagonArea(wagon, _event);
		endif;	
	endif;

	if topRow &gt; 0 and topRow &lt;= self.tblWorkEntries.rows then
		self.tblWorkEntries.topRow := topRow;
	endif;
epilog
	endLoad;
	
	if _event &lt;&gt; WLE_Create_Event and _event &lt;&gt; WLE_Update_Event and _event &lt;&gt; WLE_Delete_Event then	//15.04.2025 navnk30 JIRA 34157
		self.tblWLESetSelected();
	endif;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUserNotificationOLD" id="4c896e76-2d87-43e8-a622-4f2c276c389d">
        <updating/>
        <source>handleUserNotificationOLD(_obj : CM_Object; _event : Integer)updating;
//--------------------------------------------------------------
//Created: 31 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str			: String;
	topRow,
	idx,
	level		: Integer;
	wagon 		: CM_Wagon;
	railJob 	: CM_RailJob;
	expanded 	: Boolean;
	
begin



//	inheritMethod(_obj, _event);

	if _event = Rail_Clear_Rake_Event then
		self.updateRailRakeArea(_obj.CM_Rail);
		return;
	endif;

	if _event = RailJob_Delete_Event or _event = Wagon_Delete_Event then
	/*
		idx := self.lstJobs.findObject(_obj);
		if idx &gt; 0 then
			self.lstJobs.clearBelowLevel(idx);
			self.lstJobs.removeItem(idx);
		else
			self.tblWorkEntries.removeItemObject(_obj);
		endif;
		*/
		if _event = Wagon_Delete_Event then
			self.updateWagonArea(_obj.CM_Wagon, _event);
		endif;
		if _obj.String = self.selectedListObject.String then
			self.selectedListObject := null;
			self.lstJobsSetSelectedObject();	
		endif;		
		return;
	endif;

	if _obj = null or (not global.isValidObject(_obj)) then
		return;
	endif;
	
	if _obj.isKindOf(CM_Wagon) then
		wagon := _obj.CM_Wagon;
//		self.lstJobsUpdateWagon(wagon, _event);		
		self.updateWagonArea(wagon, _event);
		if self.viewMode &lt;&gt; ViewMode_Transport then
			return;
		endif;
	elseif _obj.isKindOf(CM_RailJob) then
		railJob := _obj.CM_RailJob;
	endif;

	if _event = RailJob_Create_Event then
		if railJob &lt;&gt; null then
	//		idx := self.lstJobs.findObject(railJob);
			if idx &gt; 1 then
				return;
			endif;
//			idx := self.lstJobs.findObject(railJob.inOutRakeSheet);	
//			level := lstJobs.itemLevel[idx];
			level := level+1;
			self.lstJobsUpdateJob(railJob, Mode_Add, idx+1, level, false);
			self.lstJobsSetSelectedObject;			
		endif;
	elseif _event = Wagon_Create_Event then
		if wagon &lt;&gt; null then
//			self.lstJobsUpdateWagon(wagon, _event);
			self.updateWagonArea(wagon, _event);						
		endif;
		return;	
	endif;
	
	topRow := self.tblWorkEntries.topRow;
	
	/*
	//Should be an update then					
	idx := self.lstJobs.findObject(_obj);

	if idx &gt; 0 then 
		if _event = RailJob_Update_Event then
			if railJob &lt;&gt; null then
				self.lstJobsRemoveJob(idx, railJob);
				self.setLstJobsBelowSheet(railJob.inOutRakeSheet);
			endif;
		elseif _event = Wagon_Update_Event then
			if wagon &lt;&gt; null then
				self.lstJobsUpdateWagon(wagon, _event);
				self.updateWagonArea(wagon, _event);
			endif;	
		endif;
	endif;
*/
	self.lstJobsSetSelectedObject();
	//th2 14/05/2007 - PAR 14020
	if topRow &gt; 0 and topRow &lt;= self.tblWorkEntries.rows then
		self.tblWorkEntries.topRow := topRow;
	endif;
	
epilog
	endLoad;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeRailJob" id="34a34cc3-b987-41d2-9baa-107958765858">
        <source>includeRailJob(_job : CM_RailJob) : Boolean;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 03/09/2015		cnwdap1			PAR #36210 Correct filtering of rail jobs
// ---------------------------------------------------------------------------

vars
	train : CM_Train;
	railArea : CM_Rail;
	railLine : CM_RailLine;
	railJS : CM_RailJSInOutRake;
begin
	if _job.isRelease() &lt;&gt; self.optDirOutTB.value then
		return false;
	endif;

	if self.myCurrentTrain &lt;&gt; null then
		train := _job.getMyTrain();
		if train &lt;&gt; null then
			if self.myCurrentTrain &lt;&gt; train then
				return false;
			endif;
		endif;
	elseif self.myCurrentRailArea &lt;&gt; null then
		//if _job.isRelease() then															// PAR #36210
		//	railJS := _job.getRakeSheet(Rail_JSIO_Type_Out, self.myCurrentRailArea.id);		// PAR #36210
		//else																				// PAR #36210
		//	railJS := _job.getRakeSheet(Rail_JSIO_Type_In, self.myCurrentRailArea.id);		// PAR #36210
		//endif;																			// PAR #36210
		railJS := _job.inOutRakeSheet;														// PAR #36210
		
		if railJS &lt;&gt; null then
			if railJS &lt;&gt; self.myCurrentJSIORake then
				return false;
			endif;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_job" type="CM_RailJob"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeWLE" id="99d28e1f-3275-4388-9c0f-6926a0c2e63d">
        <source>includeWLE(_wle: CM_WorkListEntry): Boolean;
// ---------------------------------------------------------------------------
// Created:     04 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	relNo, tiRelNo : String;
	dest : CM_Port;
	forward, con : CM_ConsigneeConsignor;
	train : CM_Train;
begin

	// 23 July 2009	NDL	Par 20341
	if self.myCurrentRailArea &lt;&gt; null then
		train := self.cmbSelectedTrain.listObject.CM_Train;	
		if train &lt;&gt; null then
			if _wle.getTrainObject &lt;&gt; train then
				return false;
			endif;
		endif;
	endif;
	
	relNo := self.cmbReleaseNo.text;
	if relNo &lt;&gt; null then
		tiRelNo :=  _wle.getReleaseReference();
		if tiRelNo &lt;&gt; null then
//			if tiRelNo[1: relNo.length()] &lt;&gt; relNo then // Begins with
			if tiRelNo &lt;&gt; relNo then
				return false;
			endif;
		endif;
	endif;

	dest := self.cmbDestination.listObject.CM_Port;
	if dest &lt;&gt; null then
		if not _wle.isMatchedDestination(dest) then
			return false;
		endif;
	endif;

	
	forward := self.cmbFreightFoward.listObject.CM_ConsigneeConsignor;
	if forward &lt;&gt; null then
		if not _wle.isMatchedForwarder(forward) then
			return false;
		endif;
	endif;
	
	con := self.cmbConsignee.listObject.CM_ConsigneeConsignor;
	if con &lt;&gt; null then
		if not _wle.isMatchedConsignee(con) then
			return false;
		endif;
	endif;
	
	
	return inheritMethod(_wle);

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTblTrainQuery" id="599a5ff3-b885-4cc0-a232-96833222980a">
        <source>initTblTrainQuery();
// ---------------------------------------------------------------------------
