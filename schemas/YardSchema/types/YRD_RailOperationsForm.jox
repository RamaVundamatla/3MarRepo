        <source>doTblInfoContextMnu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lLeft 	: Real;
	tTop 	: Real;
begin
	lLeft := x;
