    <JadeMethod name="getGridXMLdefn" id="0ce93dc9-3665-4602-a6f9-169877ce9f7a">
        <source>getGridXMLdefn(_gridView: Integer): String;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	s1, theXML : String;

begin
	theXML :=  inheritMethod(_gridView);
	s1 := getOidStringForObject(self.mySlotController);
	theXML	:= theXML &amp; "&lt;LC&gt;" &amp; s1 &amp; "&lt;/LC&gt;";

	return theXML;

end;</source>
