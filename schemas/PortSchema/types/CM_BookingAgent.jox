<Class name="CM_BookingAgent" id="e890aeae-59c3-418f-85f3-b979338cdb45">
    <superclass name="CM_Agent"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="radioTelemetry"/>
    <JadeMethod name="moveTIsToBookingItem" id="aabda095-c89c-4a3d-ad14-2e169dde46c6">
        <source>moveTIsToBookingItem(_tis: CM_TISet input; _booking: CM_BookingRef input; _bookingItem: CM_BookingRefItem input);
//06 August 2009	cnwdw1	
//
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
// 26/06/2012	cnwdap1	PAR #29735 new parameter for CM_TrackedItem::setBookingRefAndItem - set to true hereas we have
//						just drag-dropped a TI to a specific booking item on the booking reconciliation screen
vars
	pxyTIs: CM_TISet;
	ti: CM_TrackedItem;
	loadState: Boolean;
	result: Integer;
begin
	create pxyTIs transient;
	app.cmsBeginLoad(loadState);
	foreach ti in _tis do
		pxyTIs.add(ti.pxyCreateUpdateProxy());
	endforeach;
	app.cmsEndLoad(loadState);
	//app.myTrxUA.trxUpdateTIBooking(pxyTIs, _booking, _bookingItem, app.myPassport);		// PAR #29735
	app.myTrxUA.trxUpdateTIBooking(pxyTIs, _booking, _bookingItem, true, app.myPassport);	// PAR #29735

epilog
	app.cmsEndLoad(loadState);			// 08/04/2011 cnwmh5 #27347
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
	endif;
	delete pxyTIs;
end;</source>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_booking" type="CM_BookingRef" usage="input"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem" usage="input"/>
    </JadeMethod>
</Class>
