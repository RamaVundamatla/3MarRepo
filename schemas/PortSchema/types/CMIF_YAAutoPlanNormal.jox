    <JadeMethod name="isTranshipDischargePort_Match" id="041296e9-594e-45b8-ba7f-02aad220061a">
        <source>isTranshipDischargePort_Match(_yaData: CM_YADataObjects): Boolean;
// PAR 25934
vars
	dischargePort	: Object;
	port			: String;
begin
	if not self.myTrackedItem.isTranshipItem then
		return false;
	endif;
	
	port := self.myTrackedItem.getTranshipDischargePort;
	
	if port = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
