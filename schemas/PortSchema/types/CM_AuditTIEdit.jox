    <JadeMethod name="getDateTime" id="1a4e2d0c-941e-4cd8-8e9c-f1edc78ed10c">
        <source>getDateTime() : TimeStamp;

vars

begin
	if transaction = null then
		return null;
	endif;
	return transaction.dateTime;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDateTimeLocalTZ" id="63f98973-e703-466d-bc4a-0208d395e974">
        <source>getDateTimeLocalTZ():TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars

begin
	if self.transaction = null then
		return null;
	endif;

	return self.systemToLocalTime(self.transaction.dateTime);

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDetails" id="89c68fbf-1687-467d-bb04-d669b93d6f84">
        <source>getDetails(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
Bug 48219: JMT - Audits for Edit transactions not working properly
20 Feb 2020	NDL	TFS 48650 1300 error Array Index out of bounds
*/

vars
	size : Integer;
	i : Integer;
	str : String;
	array : HugeStringArray;
begin
	create array transient;
	if transaction = null then
		return null;
	endif;

	str := transaction.typeString &amp; ": ";
	transaction.fieldsValues.getStrings(array);
	
	i := 1;

/*	while i &lt;= array.size do
		if array.size = 1  then
			str := str &amp; array[i] ;
			break;
		else
			str := str &amp; array[i] &amp; ": " &amp; array[i + 1] &amp; Lf;
			i := i + 2;
		
		endif; 
	endwhile; 	*/
	
	//20 Feb 2020	NDL TFS 48650
	size := array.size;
	while i &lt;= size do
		if i mod 2 = 0 then
			str := str &amp; ": " &amp; array[i] &amp; Lf; //2 to a line
		else
			str := str &amp; array[i];
		endif;
		if i = size then
			break;
		endif;	
		i := i + 1;
	endwhile;
	
	return str;
epilog
	delete array;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e4f8300a-041f-4b28-8628-b8c7d1b50f02">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/* ---------------------------------------------------------------------------
Created:		March 2004 By Andrew Bishop cnwab1

Purpose:		

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
07/01/2020  cnwma1  Bug 48219: JMT - Audits for Edit transactions not working properly
*/

vars
	invalid			: Boolean;
	returnVal		: String;
	ti				: CM_TrackedItem;
	editTxn			: CM_Edit;
	editTxnTS		: TimeStamp;
	
begin
	editTxn := self.transaction;
	on Exception do app.handleDeletedObject(exception, editTxn, invalid);
	
	if _attrName = ETRow_SequenceNum  then
		return self.sequenceNum.String;	
	elseif _attrName = ETRow_Description  then
		return self.getDetails();	
	elseif _attrName = ETRow_User  then
		if editTxn = null or invalid then
			return null;
		else
			return editTxn.userId;
		endif;
	elseif _attrName = ETRow_EndDate  then
	
		if editTxn = null or invalid then						
			return null;
		else
			return self.systemToLocalTime(editTxn.dateTime).String;	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support  //07.01.2020 cnwma1 #48219
		endif;
	elseif _attrName = ETRow_Ti  then
		ti := self.getTrackedItem();
		if ti &lt;&gt; null then 
			return ti.id;
		else
			return self.trackedItemId;	
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="601289d4-d9fe-4828-8c5a-850adf035f0e">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// changes		
//				PAR 16898 - RJS June 2008 - add FF
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
06 JUl 2015	cnwkpd1	PAR #36578 - Speed up use of CM_Strings
// 24 June 2016	cnwns1	TFS 488 - Multi Timezone Support	
*/

vars
	theString : String;
	idx, size : Integer;
	block : CM_DataContainerBlock;
	theTransaction : CM_Edit;
	strings : HugeStringArray;
	theTransactionDateTime : TimeStamp;
begin

	inheritMethod(_dataContainer);

	theTransaction := self.transaction;
	
	if theTransaction = null then
		return;
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Transaction_Time), DC_Label, 1, self);
	theTransactionDateTime := self.systemToLocalTime(theTransaction.dateTime);		// 24 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	block.addNewItem(theTransactionDateTime.date.shortFormatJMT() &amp; " " &amp; theTransactionDateTime.time.currentLocaleFormatJMT().String, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Operator_Code), DC_Label, 1, self);
	block.addNewItem(theTransaction.operatorCode, DC_Data, 1, self);

	// PAR 16898 - RJS June 2008
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(FreightForwarder), DC_Label, 1, self);
	block.addNewItem(theTransaction.freightForwarderCode, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_User_Request_Number), DC_Label, 1, self);
	block.addNewItem(theTransaction.urNumber, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_User_ID), DC_Label, 1, self);
	block.addNewItem(theTransaction.userId, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_User_Generated), DC_Label, 1, self);
	block.addNewItem(theTransaction.userGenerated.getYesNo, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_No_Charge), DC_Label, 1, self);
	block.addNewItem(theTransaction.noCharge.getYesNo, DC_Data, 1, self);


	block.addNewItem(self.trackedItemId &amp; app.getErrorString(CM_Edit_Details), DC_MoreInfo, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Details), DC_Label, 1, self);

	// PAR #36578 - rework for performance
	create strings transient;
	theTransaction.fieldsValues.getStrings(strings);
	idx := 0;
	foreach theString in strings do

		idx := idx + 1;
		block.addNewItem(theString, DC_Data, 1, self);
		if idx mod 3 = 0 then
			block.addNewItem(app.getErrorString(CM_Details), DC_Label, 1, self);
		endif;

	endforeach;	
	
epilog
	delete strings;
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getPropertyCol" id="9868091d-a1ad-42f3-a249-543fe5ad60e2">
        <source>getPropertyCol(): String;

vars
	str : String;
begin
	str := sequenceNum.String &amp; Tab;
	str := str &amp; getDetails &amp; Tab;
	if transaction = null then
		str := str &amp; Tab &amp; Tab;
	else
		str := str &amp; transaction.userId &amp; Tab;
		str := str &amp; transaction.dateTime.date.shortFormatJMT() &amp; " " &amp; transaction.dateTime.time.currentLocaleFormatJMT() &amp; Tab;
	endif;
	str := str &amp; trackedItemId;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItem" id="5f296962-2f82-43ff-9d2e-cb91527241e2">
        <source>getTrackedItem() : CM_TrackedItem;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidTI		: Boolean;
	id				: String;
	ti				: CM_TrackedItem;
begin
	ti := self.trackedItem;				// 07/03/2011 cnwmh5 #27142
	if ti &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, ti, invalidTI);
		// Dereference TI to check it is valid
		id := ti.id;
	endif;
	
	if invalidTI then
		return null;
	else
		return ti;
	endif;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
