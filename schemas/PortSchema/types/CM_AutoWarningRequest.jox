    <JadeMethod name="pxyCreateUpdateProxy" id="6be487bc-86c8-4016-882e-4920c28f0b7a">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Standard method for creating a proxy data object.
//
// Parameters:	None
//
// Returns:		A refeence to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();
	
	proxyObj.minutesBeforeAlert	:=	self.minutesBeforeAlert;
	proxyObj.alertFrequency		:=	self.alertFrequency;
	proxyObj.className			:=	self.className;
	proxyObj.myController		:=	self.myController;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="663281c4-a1b6-4b38-a46e-23792ba9c6eb">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Standard method used to update the receiver from a proxy object.
//
// Parameters:	_proxyObj - A reference to the proxy data object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.minutesBeforeAlert		:=	_proxyObj.minutesBeforeAlert;
	self.alertFrequency			:=	_proxyObj.alertFrequency;
	self.className				:=	_proxyObj.className;
	self.webSiteConfigName		:= 	_proxyObj.webSiteConfigName;
	self.myController			:=	_proxyObj.myController;
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="af02d22d-321c-44ea-af44-9c87408a929c">
        <updating/>
        <source>setProxy(	_minutesBeforeAlert	:Integer;
			_alertFrequency		:Integer;
			_className			:String;
			_webSiteConfigName	: String;
			_controllerObj		:BGP_AutoWarningController) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Standard method for setting the receiver proxy's property values.
//
// Parameters:	_minutesBeforeAlert - The number of minutes until an alert is sent.
//				_alertFrequency - The number of minutes between alerts.
//				_className - The name of the request class for the alert.
//				_controllerObj - A reference to the BGP controller object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.minutesBeforeAlert		:=	_minutesBeforeAlert;
	self.alertFrequency			:=	_alertFrequency;
	self.className				:=	_className;
	self.webSiteConfigName		:=  _webSiteConfigName;
	self.myController			:=	_controllerObj;
end;</source>
        <Parameter name="_minutesBeforeAlert" type="Integer"/>
        <Parameter name="_alertFrequency" type="Integer"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_webSiteConfigName" type="String"/>
        <Parameter name="_controllerObj" type="BGP_AutoWarningController"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="7abbeaa2-e25f-4000-9498-f5e47e2f8e63">
        <source>validateMe();
// -------------------------------------------
// Created 27 March 2006 by cnwdvb1
// -------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364

vars

	tmpClass	: Class;
	niceName	: String;

begin

	tmpClass := self.getClass(self.className);
	if tmpClass = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Class', null, null);
		app.raiseCMException(Input_required_field_class, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	niceName := tmpClass.text.cnEcGetTagValueOfName('display');
	
	if not self.alertFrequency &gt; 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, niceName &amp; ' Alert Frequency', null, null);
		app.raiseCMException1(Input_required_field_alrtFreq, niceName, null, null); // cnwdb2	PAR 35364
	endif;
	
	if not self.minutesBeforeAlert &gt; 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, niceName &amp; ' Minutes Before Alert', null, null);
		app.raiseCMException1(Input_required_field_mnsBfrAlr, niceName, null, null);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
