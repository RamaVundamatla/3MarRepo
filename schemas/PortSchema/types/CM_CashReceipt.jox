    <JadeMethod name="createCashPayment" id="6da4ae4f-f583-473a-bdc0-9f4d6d81427f">
        <source>createCashPayment(_value ,
				_taxValue 				: Decimal; 
				_includeTaxPayment 		: Boolean; 
				_debtorTerminal 		: CM_DebtorTerminal; 
				_ti 					: CM_TrackedItem;
				_invoiceLine 			: CM_InvoiceLine;
				_profDetail 			: CM_ProformaDetails;
				_invoice 				: CM_Invoice) : CM_CashPayment;
/*

Purpose:			TFS 44275

Parameters:			

Return Value:		

Date		Who		Reason
					TFS 1990 create a new cash payment from split/merge 
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars
	now			: TimeStamp;
	cashPayment, 
	taxPayment	: CM_CashPayment;
	user		: CM_User;
begin
	now := app.actualTimeServer;

	user := app.myPassport.myUser;

	create cashPayment persistent;
	cashPayment.setProxy(_value,			//_cashValue : Decimal;
							0,				//_taxAmount : Decimal;
							now,			//_dateTime : TimeStamp;
							null,			//_proformaDesc : String;
							false,			//_manual : Boolean;
							0,				//_status : Integer;
							false,			//_voided : Boolean;	
							_debtorTerminal,//_myDebtorTerminal : CM_DebtorTerminal;
							_ti,			//_myTrackedItem : CM_TrackedItem;
							_invoice,		//_myInvoice : CM_Invoice;	
							null,			//_vvr : CM_VehicleVisitRecord;
							user			//_myUser : CM_User;
							);
	cashPayment.setCashReceipt(self);
	// only one of _invoiceLine or _profDetail will be set
	cashPayment.setInvoiceLine(_invoiceLine);
	
	// ### JIRA 35593 30JUL2025 NAVAB1
	if cashPayment.myInvoice = null 
	and _invoiceLine &lt;&gt; null then
		cashPayment.pxySetInvoice(_invoiceLine.invoice);  
	endif;
	cashPayment.setProformaDetail(_profDetail);
	
	// TFS 8275
	if _includeTaxPayment then
		create taxPayment persistent;
		taxPayment.setProxy(_taxValue,			//_cashValue : Decimal;
								0,				//_taxAmount : Decimal;
								now,			//_dateTime : TimeStamp;
								null,			//_proformaDesc : String;
								false,			//_manual : Boolean;
								0,				//_status : Integer;
								false,			//_voided : Boolean;	
								_debtorTerminal,//_myDebtorTerminal : CM_DebtorTerminal;
								_ti,			//_myTrackedItem : CM_TrackedItem;
								null,			//_myInvoice : CM_Invoice;	
								null,			//__vvr : CM_VehicleVisitRecord;
								user			//_myUser : CM_User;
								);
		cashPayment.setMyCashPaymentForTax(taxPayment);
	endif;
	
	
	return cashPayment;
epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <Parameter name="_taxValue" type="Decimal"/>
        <Parameter name="_includeTaxPayment" type="Boolean"/>
        <Parameter name="_debtorTerminal" type="CM_DebtorTerminal"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_profDetail" type="CM_ProformaDetails"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="createCashReceiptHeader" id="7b838521-1b5f-4f6a-9f1d-6ecbe4a90e6e">
        <source>createCashReceiptHeader(_title : String) : CMIF_CashReceiptHeader;
/*

Purpose:			TFS 47847 this is the refactored version that only looks at cash payment	

Parameters:			

Return Value:		

Date		Who		Reason
03 Feb 2020 cnwma1  Bug 48450: ADP 
29 May 2020 cnwma1	Bug 49404: MTN - POS receipt no not updated on Cash receipt
22 Sep 2020	jlgma1	Bug 50011: SSL - Cash Module -&gt; Proforma Invoice Issue
*/


vars

	tiLength 	 : Real;
	tiVolume	 : Real;
	tiWeight	 : Decimal[14, 4];
	cmif_header	 : CMIF_CashReceiptHeader;
	cmif_detail	 : CMIF_CashReceiptDetail;
	proDetail 	 : CM_ProformaDetails;
	invoiceLine	 : CM_InvoiceLine;
	voyage		 : CM_Voyage;
	ti			 : CM_TrackedItem;
	theInvoice   : CM_Invoice;
	finIOClass   : CM_ExtFinanceIO;
	title 		 : String;
	cashPay      : CM_CashPayment;
	calcType	 : CM_CalculationType; //02/10/2025	navkc1 JIRA 36149
begin

	title := _title;
	if title = "" then
		title := "CASH RECEIPT";
	endif;

	create cmif_header transient;
	cmif_header.invoiceTitle          := title;
	cmif_header.billOfLading          := self.getBOLNumber();
	cmif_header.myDebtor              := self.getDebtor();
	cmif_header.myTerminal            := self.myTerminal;
	cmif_header.effectiveDate         := self.effectiveDate;
	cmif_header.invoiceDate           := self.dateTime.date;		
	cmif_header.userName 	          := self.getUserName;
	cmif_header.chequeBank 	          := self.chequeBank;
	cmif_header.chequeNumber          := self.chequeNumber;
	cmif_header.posNUmber             := self.externalReceiptNumber;  //29.05.2020 cnwma1 #49404
	cmif_header.chequeBranch          := self.chequeBranch;
	cmif_header.myCashInvoice         := self.myCashInvoice;
	cmif_header.myCashReceipt         := self;
	cmif_header.tax1Description       := self.taxCode1; 
	cmif_header.tax1Value 		      := self.taxValue1;
	cmif_header.tax2Description       := self.taxCode2; 
	cmif_header.tax2Value 			  := self.taxValue2;
	cmif_header.tax3Description 	  := self.taxCode3;
	cmif_header.tax3Value 		      := self.taxValue3;
	cmif_header.externalInvoiceNumber := self.externalInvoiceNumber;
	
	voyage := self.myVoyage;
	if voyage &lt;&gt; null then
		cmif_header.voyageArrivalDate   := voyage.arrivedDT.date;
		cmif_header.voyageDepartureDate := voyage.departedDT.date;
		cmif_header.vesselName          := voyage.vesselName;
		cmif_header.voyageCode          := voyage.code;
		cmif_header.myVoyage 			:= voyage; 
	endif;

	
	if self.roundingDifference &gt; 0 then                                              //03.02.2020 cnwma1 #48450
		cmif_header.total   := self.totalCargoCharges + self.roundingDifference ;
	else
		cmif_header.total := self.totalCargoCharges;
	endif;
	
	
	if cmif_header.myCashInvoice &lt;&gt; null then
		cmif_header.cashComments := cmif_header.myCashInvoice.narration;
	endif;

	if self.myAgent &lt;&gt; null and self.myAgent.isKindOf(CM_CustomsAgent) then
		cmif_header.customsAgentName := self.myAgent.CM_CustomsAgent.name;
	endif;

	
	// 36386 set the invoice unconditionally to handle payment which is just for pro forma items
	theInvoice := self.myCashInvoice;
			
	foreach cashPay in self.allCashPayments discreteLock do
		
		if cashPay.isTaxPayment() then
			continue;
		endif;
		
		create cmif_detail transient;
		
		cmif_detail.setTaxDetailsFromPayment(cashPay);    //03.02.2020 cnwma1 #48450
		cmif_detail.isPaid := cashPay.isPaid();           //22.09.2020 cnwma1 #50011
		
		if cashPay.myInvoiceLine &lt;&gt; null then
		
			invoiceLine   := cashPay.myInvoiceLine;
			if theInvoice = null then
				theInvoice := invoiceLine.invoice;			
			endif;
		
			ti := invoiceLine.trackedItem; //02/10/2025	navkc1 JIRA 36149
		
			cmif_detail.lineDescription 	  		  := invoiceLine.invoiceLineDesc.narration;
			cmif_detail.lineUnit 			  		  := invoiceLine.invoiceLineDesc.unitNarration; 
			cmif_detail.lineValue 		 	  		  := invoiceLine.lineTotal;
			cmif_detail.lineQuantity	      		  := invoiceLine.quantity;
			cmif_detail.lineRate 			  		  := invoiceLine.getRate; 
			cmif_detail.lineRemarks           		  := invoiceLine.remarks;
			cmif_detail.lineDateTime		  		  := invoiceLine.chargeTime; 
			cmif_detail.myTrackedItem	      		  := ti;
			cmif_detail.storagePaidTS	      		  := self.getStoragePaidTS(ti);
			cmif_detail.isStorage 			  		  := invoiceLine.isTransactionOfType(TRANS_TYPE_STORAGE);		 //08 May 2017	NDL	TFS 4168
			cmif_detail.externalInvoiceNumber 		  := self.externalInvoiceNumber; 								 //29 May 2017	NDL	TFS 4355
			
			/* 03.02.2020 cnwma1 #48450
			cmif_detail.lineTaxAmount 		  		  := invoiceLine.getTaxAmountForLine(); 						 // TFS 8307
			cmif_detail.lineTaxRate 		  		  := invoiceLine.getTaxRateForLine();							 // TFS 8307
			cmif_detail.lineTaxCode 		          := invoiceLine.getTaxCode(false); 							 // TFS 8307
			cmif_detail.currencyConversionNotRequired := invoiceLine.invoiceLineDesc.currencyConversionNotRequired;  //01.11.2018 cnwma1 TFS #41739
			*/
			cmif_detail.storageDays 		 := 1; 		
			// 36544 storage days to print as Units
			
			calcType := invoiceLine.invoiceLineDesc.myCalculationType; //02/10/2025	navkc1 JIRA 36149
			
			if invoiceLine.myTransactionTI &lt;&gt; null and
			invoiceLine.myTransactionTI.type = TRANS_TYPE_STORAGE then
				invoiceLine.getTrackedItemValues(tiLength, tiVolume, tiWeight);
				
				//02/10/2025	navkc1 JIRA 36149
				if calcType &lt;&gt; null and calcType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT then
					if calcType.isUseCargoWeight() and ti &lt;&gt; null then
						tiWeight := ti.weightCargo;
					endif;
				endif;
				
				if invoiceLine.quantity.Integer = 0 or calcType = null then
					cmif_detail.storageDays := 0;
				else
					cmif_detail.storageDays := invoiceLine.invoiceLineDesc.myCalculationType.convertQuantityToDays(invoiceLine.quantity,tiWeight, tiVolume, tiLength, invoiceLine.myTransactionTI);
				endif;
			endif;
			
		elseif cashPay.myProformaDetail &lt;&gt; null then
			
			proDetail := cashPay.myProformaDetail;
			ti        := proDetail.myTrackedItem;
			
			cmif_detail.isEstimated 	:= true;
			cmif_detail.lineDescription := proDetail.myInvoiceLineType.narration;
			cmif_detail.lineUnit 		:= proDetail.myInvoiceLineType.unitNarration; 
			cmif_detail.lineValue 	    := proDetail.quantity * proDetail.rate;           
			cmif_detail.lineQuantity 	:= proDetail.quantity;
			cmif_detail.lineRate 		:= proDetail.rate;
			cmif_detail.lineRemarks 	:= proDetail.remarks; 
			cmif_detail.storageDays 	:= 1;						// 36544 storage days to print as Units
			if proDetail.transactionType = TRANS_TYPE_STORAGE then
				
				calcType := proDetail.myInvoiceLineType.myCalculationType; //02/10/2025	navkc1 JIRA 36149
				
				if ti &lt;&gt; null then
					tiVolume 	:= ti.getChargeVolume();
					tiWeight 	:= ti.getChargeWeight();
					tiLength 	:= ti.length;
				endif;
				
				//02/10/2025	navkc1 JIRA 36149
				if calcType &lt;&gt; null and calcType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT then
					if calcType.isUseCargoWeight() and ti &lt;&gt; null then
						tiWeight := ti.weightCargo;
					endif;
				endif;
				
				if proDetail.quantity.Integer = 0 or proDetail.myInvoiceLineType.myCalculationType = null then
					cmif_detail.storageDays := 0;
				else
					cmif_detail.storageDays := proDetail.myInvoiceLineType.myCalculationType.convertQuantityToDays(proDetail.quantity,tiWeight, tiVolume, tiLength, null);
				endif;
			endif;
			
			/*03.02.2020 cnwma1 #48450
			cmif_detail.lineTaxAmount		  		  := proDetail.getTaxAmountForPayment(); 	// TFS 8307
			cmif_detail.lineTaxRate 		  		  := proDetail.getTaxRateForPayment(); 		// TFS 8307
			cmif_detail.lineTaxCode 		 		  := proDetail.getTaxCodeForPayment(false); // TFS 8307		// 20.09.2019.cnwma1 #46586
			*/
			cmif_detail.isStorage 			  		  := proDetail.isStorage;					//11 May 2017	NDL	TFS 4168
			cmif_detail.externalInvoiceNumber 		  := self.externalInvoiceNumber; 			//29 May 2017	NDL	TFS 4355
			cmif_detail.lineDateTime 		 		  := proDetail.chargeTime; 
			cmif_detail.myTrackedItem 		  		  := proDetail.myTrackedItem;
			cmif_detail.storagePaidTS 		          := self.getStoragePaidTS(proDetail.myTrackedItem);
			cmif_detail.currencyConversionNotRequired := proDetail.myInvoiceLineType.currencyConversionNotRequired; //01.11.2018 cnwma1 TFS #41739
		endif;
		
		cmif_header.allDetails.add(cmif_detail);
	endforeach;

	if theInvoice &lt;&gt; null then
		finIOClass := theInvoice.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;

		if theInvoice.getExternalInvoiceNumberRaw() = "" then	//15 Apr 2016	NDL	TFS 1849
			beginTransaction;
				theInvoice.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(theInvoice));
			commitTransaction;
		endif;

		cmif_header.invoiceNumber := theInvoice.getExternalInvoiceNumberRaw();	//15 Apr 2016	NDL	TFS 1849

	endif;

	return cmif_header;
		
epilog
end;</source>
        <Parameter name="_title" type="String"/>
        <ReturnType type="CMIF_CashReceiptHeader"/>
    </JadeMethod>
    <JadeMethod name="createCashReceiptHeaderQTS" id="5fc84d12-f6c8-4bf3-bd77-d88bb4ec885b">
        <source>createCashReceiptHeaderQTS() : CMIF_CashReceiptHeader;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/2024	navkc1 JIRA Bug MTN-33566: QTS | The QTS Cash Report Blank When Run from Report Runner
08/05/2025	navkc1 JIRA BUG MTN-34834: QTS | UAT - Report issue for new CR after a CR is cancelled
*/

vars
	companyDetails		: String;
	businessUnit 		: CM_Bank;
	debtor				: CM_Debtor;
	cmif_header			: CMIF_CashReceiptHeader;
	cmif_detail			: CMIF_CashReceiptDetail;
	amt					: Decimal[16,6];
	totalCharges		: Decimal[16,6];
	invLine				: CM_InvoiceLine;
	ti					: CM_TrackedItem;
	payment				: CM_CashPayment;
	proformaDetail		: CM_ProformaDetails;
	skipLine,
	found				: Boolean;
	index				: Integer;
	max					: Integer;
	invoicedDetails,
	estimatedDetails	: StringArray;
	invoicedValues,
	estimatedValues		: DecimalArray;
	invalidMethod		: Boolean;
	ed					: Integer;
	paymentMethod		: CM_PaymentMethod;
	str					: String;
	voyInvalid			: Boolean;
	voyage				: CM_Voyage;
	oa					: ObjectArray;
	obj					: Object;
	localTiArray 		: CM_TIArray;
	
begin
	// exit if an empty cash receipt
	create localTiArray transient;
	self.getAllGoodTrackedItems( localTiArray );
	
	if self.allInvoiceLines.isEmpty    and
	   self.allProformaDetails.isEmpty and
	   localTiArray.isEmpty		               then
	   
		return null;
	endif;

	businessUnit := self.myBank;
	if businessUnit = null then
		businessUnit := self.myTerminal.getDefaultCompanyBank;
	endif;
	debtor := self.getDebtorTerminal().myDebtor;

	create oa transient;

	foreach ti in localTiArray do
		foreach payment in ti.allCashPayments do
			if payment.myCashPaymentForInvoice &lt;&gt; null then
				continue;
			endif;
			oa.add(payment);
		endforeach;
	endforeach;

	app.mousePointer := MP_HOURGLASS;

	create cmif_header transient;

	on Exception do app.handleDeletedObject(exception, paymentMethod, invalidMethod);
	on Exception do app.handleDeletedObject(exception, voyage, voyInvalid);
	
	cmif_header.qns_myCashReceipt  := self;
	cmif_header.qns_myDebtor 	   := debtor;
	cmif_header.qns_receiptDate    := self.dateTime.date;
	cmif_header.qns_myBank         := businessUnit;
	
	foreach str in businessUnit.allBankDetails do
		companyDetails := companyDetails &amp; str &amp; CrLf;
	endforeach;
	cmif_header.qns_companyDetails := companyDetails;
	
	paymentMethod := self.myPaymentMethod;
	// no inverse, guard against deleted payment method
	ed := paymentMethod.edition;
	if invalidMethod then
		paymentMethod := null;
	endif;
	cmif_header.qns_myPaymentMethod := paymentMethod;
	voyage := self.myVoyage;
	// get voyage from cargo if not already set
	if voyage = null then
		foreach ti in localTiArray do
			voyage := ti.myVoyage;
			if voyage &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;
	// no inverse, guard against deleted voyage
	if voyage &lt;&gt; null then
		ed := voyage.edition;
		if voyInvalid then
			voyage := null;
		endif;
	endif;

	cmif_header.qns_myVoyage := voyage;

	create invoicedDetails transient;
	create estimatedDetails transient;
	create invoicedValues transient;
	create estimatedValues transient;
	
	foreach ti in localTiArray do
		invoicedDetails.clear();
		estimatedDetails.clear();
		invoicedValues.clear();
		estimatedValues.clear();
		amt := 0;
		
		foreach invLine in self.allInvoiceLines where invLine.trackedItem = ti do
			//skipLine := false;
			skipLine := true; //08/05/2025	navkc1 JIRA BUG MTN-34834
			// don't print invoice lines paid for in any other receipt
			foreach payment in invLine.allCashPayments do
				//if payment.myCashReceipt &lt;&gt; self then
				if payment.myCashReceipt = self then //08/05/2025	navkc1 JIRA BUG MTN-34834
					//skipLine := true;
					skipLine := false; //08/05/2025	navkc1 JIRA BUG MTN-34834
					break;
				endif;
			endforeach;
			// skip lines covered by prior pro forma
			found := false;
			foreach obj in oa do
				payment := obj.CM_CashPayment;
				
				if payment.myCashReceipt &lt;&gt; self then
					continue;
				endif;
				
				if payment.myTrackedItem = invLine.trackedItem and
				   payment.myProformaDetail &lt;&gt; null and
				   payment.dateTime &lt; invLine.createdTime then
					if payment.myProformaDetail.myInvoiceLineType = invLine.invoiceLineDesc and
					   payment.cashValue &gt;= invLine.lineTotal.roundedTo(2) then
						skipLine := true;
						found := true;
						break;
					endif;
				endif;
			endforeach;
			if found then
				oa.remove(obj);
			endif;
			if skipLine or
			   invLine.lineTotal = 0 then
				continue;
			endif;
			invoicedDetails.add(invLine.invoiceLineDesc.narration);
			invoicedValues.add(invLine.lineTotal);
			amt := amt + invLine.lineTotal;
			totalCharges := totalCharges + invLine.lineTotal;
		endforeach;
		foreach proformaDetail in self.allProformaDetails where proformaDetail.myTrackedItem = ti do
			skipLine := false;
			// don't print paid-for pro formas (the value is already present in an invoice line and printed from that)
			foreach invLine in self.allInvoiceLines do
				if invLine.trackedItem = proformaDetail.myTrackedItem and
				   invLine.invoiceLineDesc = proformaDetail.myInvoiceLineType then
					if invLine.lineTotal = proformaDetail.lineTotal then
						if proformaDetail.allCashPayments.size = 1 and proformaDetail.allCashPayments.first.myInvoiceLine &lt;&gt; invLine then
							skipLine := false;
							break;
						endif;
						skipLine := true;
						break;
					// do we have an earlier proforma for the same invoice line type and the amount is greater on the proforma
					elseif proformaDetail.creationTime &lt; invLine.createdTime and proformaDetail.lineTotal &gt; invLine.lineTotal then
						// include this proformaDetail, but remove the invLine from invoicedDetails
						if invoicedDetails.includes(invLine.invoiceLineDesc.narration) then
							invoicedDetails.remove(invLine.invoiceLineDesc.narration);
							// and the invoicedValus and runnning totals - so that these reflect the cash values only
							invoicedValues.remove(invLine.lineTotal);
							amt := amt - invLine.lineTotal;
							totalCharges := totalCharges - invLine.lineTotal;
						endif;
					endif;
				endif;
			endforeach;
			if skipLine or
			   proformaDetail.lineTotal = 0 then
				continue;
			endif;
			estimatedDetails.add(proformaDetail.getStrippedRemarks[1:60]);
			estimatedValues.add(proformaDetail.lineTotal);
			amt := amt + proformaDetail.lineTotal;
			totalCharges := totalCharges + proformaDetail.lineTotal;
		endforeach;
		max := invoicedDetails.size.max(estimatedDetails.size);
		
		foreach index in 1 to max do
		
			create cmif_detail transient;
			if index =  1 then
				cmif_detail.qns_cargoId := ti.id;
				cmif_detail.qns_lineTotal := amt.roundedTo(2);
			endif;
			
			if index &lt;= invoicedDetails.size then
				cmif_detail.qns_invoiceLineDescription := invoicedDetails[index];
				cmif_detail.qns_invoiceLineValue := invoicedValues[index].roundedTo(2);
			endif;
			if index &lt;= estimatedDetails.size then
				cmif_detail.qns_estimateDescription := estimatedDetails[index];
				cmif_detail.qns_estimateValue := estimatedValues[index].roundedTo(2);
				cmif_detail.isEstimated := true;
			endif;
			cmif_header.qns_allDetails.add(cmif_detail);
		endforeach;
	endforeach;

	amt := self.cashValue;
	cmif_header.qns_totalAmount := amt.roundedTo(2);
	cmif_header.qns_totalInWords := amt.roundedTo(2).asCurrencyJMTWords();
	
	return cmif_header;
	
epilog
	
	delete oa;
	delete invoicedDetails;
	delete estimatedDetails;
	delete invoicedValues;
	delete estimatedValues;
	delete localTiArray;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <ReturnType type="CMIF_CashReceiptHeader"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceFromReceipt" id="fb80e78a-4776-477d-8f28-d9864863b576">
        <updating/>
        <source>createInvoiceFromReceipt() updating;
/*

Purpose:	// TFS 37964 	this will be called for PELINDO1 SAP integration for PREPAY debtors	

Parameters:			

Return Value:		

Date		Who		Reason
10/06/2018	jlgab1	Initial creation
23/01/2019	jlgdap1	TFS 42925 PEL1 Container Services - Estimation Approval Countdown 
17/10/2019	jlgdap1	TFS 46973 PEL Cash Receipt/Estimate Not Created Automatically
*/

vars
	retInvoice, pxyInvoice : CM_Invoice;
	invoiceType : CM_InvoiceDesc;
	debtor : CM_Debtor;
	cashPayment1 : CM_CashPayment;
	cmifStatus : CMIF_InvoiceStatus;			// TFS 42925
begin

	retInvoice := self.myCashInvoice;
	
	if retInvoice = null then
		create retInvoice;
		
		if self.myWorkOrder = null then
			return;
		endif;
		
		self.reserveLock(self.myBank.allInvoices);			// TFS 46973
		invoiceType := self.getCashInvoiceType(true);
		debtor      := self.getDebtor;                //11.01.2019 cnwma1 TFS #40202
		retInvoice.initialiseWorkOrder(self.myBank, invoiceType, debtor, self.myWorkOrder, self.paymentType);
		self.myCashInvoice := retInvoice;
	endif;
	
	foreach cashPayment1 in self.allCashPayments	discreteLock do
		cashPayment1.createInvoiceLineFromProforma(retInvoice, false);
	endforeach;
	
	// TFS 42925 If cash receipt is prepay, and invoice is at OPEN status, move it to PREPEND
	if self.paymentType = PaymentType_PrePay and retInvoice &lt;&gt; null and retInvoice.status = CM_Invoice.INVOICE_OPEN then
		pxyInvoice := app.createUpdateProxy(retInvoice).CM_Invoice;
		create cmifStatus transient;
		cmifStatus.myInvoice := pxyInvoice;
		cmifStatus.newStatus := CM_Invoice.INVOICE_PREPEND;
		app.myValUA.valInvoiceStatus(retInvoice, cmifStatus);
		if not app.myPassport.noErrors then
			return;
		endif;
		app.myUtilityUA.utlUpdateInvoiceStatus(cmifStatus, app.myPassport);
	endif;
	// TFS 42925 end
	
epilog
	delete cmifStatus;
	delete pxyInvoice;	//24 May 2019	NDL	TFS 44774
end;</source>
    </JadeMethod>
    <JadeMethod name="createProformaDetail" id="c6238b1b-3920-450b-b853-84aeed7e684d">
        <source>createProformaDetail(_value			 : Decimal; 
					_quantity 		 : Real;
					_rate 		     : Real;
					_remarks         : String; 
					_invoiceLineType : CM_InvoiceLineDesc; 
					_trackedItem     : CM_TrackedItem;
					_transactionType : Integer;
					_overridden      : Boolean) : CM_ProformaDetails;				
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
   May 2016	cnwndl1	TFS 1990 May 2016 create proforma detail from split/merge
11 Feb 2020 cnwma1	Bug 48511: JMT - Duplicate Narration for Manual Cash Payment on Cash Collection Screen
*/
vars
	now		 : TimeStamp;
	remarks	 :String;
	detail	 : CM_ProformaDetails;
begin
	now := app.serverTimestampAtTrxStart;
	
	if _invoiceLineType.unitNarration &lt;&gt; null then  //11.02.2020 cnwma1 #48511
	
		remarks := _invoiceLineType.narration &amp; " (" &amp; _quantity.String &amp; " " &amp; _invoiceLineType.unitNarration &amp; ") " &amp; _value.asCurrencyJMT;
	else
		remarks := _invoiceLineType.narration &amp; " (" &amp; _quantity.String &amp; ") " &amp; _value.asCurrencyJMT;
	endif;
	
	if self.isTransient then 	 // TFS 44275
		create detail transient; // TFS 44275
	else
		create detail persistent;
	endif;
	
	detail.setup(now, _value, _quantity, _rate, remarks, self, _invoiceLineType, _trackedItem, _transactionType, null, _overridden);
	
	return detail;
	
end;</source>
        <Parameter name="_value" type="Decimal"/>
        <Parameter name="_quantity" type="Real"/>
        <Parameter name="_rate" type="Real"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_invoiceLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transactionType" type="Integer"/>
        <Parameter name="_overridden" type="Boolean"/>
        <ReturnType type="CM_ProformaDetails"/>
    </JadeMethod>
    <JadeMethod name="createProxyManualPayment" id="9eba689e-1b9c-4090-8c7d-7a7524389913">
        <source>createProxyManualPayment(_invLineDesc : CM_InvoiceLineDesc input;
						_qty 		  : Real;
						_newTotal     : Decimal; 
						_remarks      : String;
						_ti 		  : CM_TrackedItem; 
						_overridden   : Boolean;
						_isMinCharge  : Boolean) : CM_CashPayment;
/*

Purpose:		TFS 44275	

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2019	jlgab1	Initial creation
25 Sep 2019 cnwma1	Bug 46645: New cash form - subsequent payments going to default business unit
15 Jan 2020 cnwma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT - ##336278##
*/
constants
	MAXNEWSEQ = 2000000000; 	// TFS 47980 was using Max_Integer however when 1 is added to Max_Integer it becomes negative Max_Integer
								//	This number is not actually used, it is only for the create proxy items, when persisted the actual seq num is generated.							
vars
	pxyCashPayment, 
	pxyCashPaymentTax    	: CM_CashPayment;
	pxyInvoiceLine, 
	invLine				    : CM_InvoiceLine;
	profDetail 			    : CM_ProformaDetails;
	service 			    : CM_Service;
	charge 				    : CM_Charge;
	count 				    : Integer;
	terminal 			    : CM_Terminal;
	rateTotal, 
	newRate 			    : Real;
	cashvalue, 
	cashtaxvalue 		    : Decimal [23,6];
	bank				    : CM_Bank;
	currentseq, 
	seq 					: Integer;
begin
	terminal := _invLineDesc.getMyTerminal();
	bank     := _invLineDesc.bank;         		    // 25.09.2019 cnwma1 # 46645
	
	// TFS 47847 unique sequence number required
	foreach invLine in self.allInvoiceLines	discreteLock do
		currentseq:= invLine.sequenceNum.max(MAXNEWSEQ); // TFS 47980
		
		seq := seq.max(currentseq);
	endforeach;
	
	if seq = 0 then
		seq := MAXNEWSEQ; // TFS 47980
	else
		seq := seq + 1;
	endif;
	
	create pxyInvoiceLine transient;
	pxyInvoiceLine.setForCreate( seq, // TFS 47847
								true,
								_remarks,
								_invLineDesc,
								null,
								self.getDebtor(),	
								bank,				// 25.09.2019 cnwma1 # 46645
								_qty,
								app.actualTimeAppServer	
							);
	
	if _newTotal = 0 then
		foreach service in _invLineDesc.services do
			create charge transient;
			charge.setForCreate(	null,
									pxyInvoiceLine, 
									seq - count, // TFS 47847
									service);
			newRate := charge.getRateFromTable(rateTotal);
			charge.setRateForMinMax (newRate.roundedTo(6));
			count := count + 1;
		endforeach;
	else
		 service := _invLineDesc.services.first;
		create charge transient;
		charge.setForCreate(	null,
								pxyInvoiceLine, 
								seq, // TFS 47847
								service);
		charge.total := _newTotal;
		
		// 01/12/2025	navkc1	JIRA MTN 36766/36767
		if _overridden then
			charge.setOverriden();
			charge.setRateForMinMax(_newTotal);
		endif;
		
	endif;
	
	// 01/12/2025	navkc1	JIRA MTN 36766/36767
	pxyInvoiceLine.setTaxDetails();
	pxyInvoiceLine.setTotalAmount();
	
	cashvalue := pxyInvoiceLine.lineTotal;
	
	// TFS 47847 proforma print not working with manual payment
	pxyInvoiceLine.setTrackedItemOnly(_ti); //	TFS 47847
	self.allInvoiceLines.add(pxyInvoiceLine); //	TFS 47847

	if self.isKindOf(CM_CashReceiptProformaPrint) then // TFS 47889
		create pxyCashPayment as CM_CashPaymentProformaPrint transient; // TFS 47889
	else
		create pxyCashPayment transient; // TFS 47889
	endif;
	
	
	pxyCashPayment.setProxy(cashvalue,
							0,	
							app.actualTimeAppServer,
							_remarks,	
							true,	
							0,	
							false,	
							self.getDebtorTerminal(),
							_ti,	
							null,						//_myInvoice : CM_Invoice;
							null,						//_vvr : CM_VehicleVisitRecord;
							app.getMyUser				//_myUser : CM_User;
						);
						
	
	profDetail := self.createProformaDetail(pxyCashPayment.cashValue,
											pxyInvoiceLine.quantity,
											pxyInvoiceLine.getRate(),
											_remarks,pxyInvoiceLine.invoiceLineDesc,
											pxyCashPayment.myTrackedItem,
											0,
											_overridden);
	self.allProformaDetails.addNoDuplicates(profDetail, false);  // ### JIRA 36550 07NOV2025 NAVAB1 proformDeail.myCashReceipt is not inversed!!
											
	pxyCashPayment.setProformaDetail(profDetail);
	pxyCashPayment.setCashReceipt(self);
	pxyCashPayment.setInvoiceLine(pxyInvoiceLine);
	pxyCashPayment.setIsMinimumCharge(_isMinCharge);     //16.01.2020 cnwma1 #48298

	
	if terminal.getConfig(CashAllCashTax).String = null and terminal.getConfig(InvoiceMultiTaxRates).Boolean then
	
		cashtaxvalue := pxyInvoiceLine.getTaxAmountForLine();
		
		/*MA 20.09.2019 Stop Creating zero cash payments */
		if cashtaxvalue &gt; 0 then                                    // 25.09.2019 cnwma1 # 46645
		
		
			if self.isKindOf(CM_CashReceiptProformaPrint) then // TFS 47889
				create pxyCashPaymentTax as CM_CashPaymentProformaPrint transient; // TFS 47889
			else
				create pxyCashPaymentTax transient; // TFS 47889
			endif;
		
			pxyCashPaymentTax.setProxy(cashtaxvalue,				//_cashValue : Decimal;
										0,							//_taxAmount : Decimal;
										app.actualTimeAppServer,
										_remarks,	
										true,						//_manual : Boolean;
										0,							//_status : Integer;
										false,						//_voided : Boolean;	
										self.getDebtorTerminal(),	//_myDebtorTerminal : CM_DebtorTerminal;
										_ti,						//_myTrackedItem : CM_TrackedItem;
										null,						//_myInvoice : CM_Invoice;
										null,						//_vvr : CM_VehicleVisitRecord;
										app.getMyUser				//_myUser : CM_User;
								);
			pxyCashPayment.setMyCashPaymentForTax(pxyCashPaymentTax);
		endif;
	endif;

	
	return pxyCashPayment;
epilog

end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc" usage="input"/>
        <Parameter name="_qty" type="Real"/>
        <Parameter name="_newTotal" type="Decimal"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_overridden" type="Boolean"/>
        <Parameter name="_isMinCharge" type="Boolean"/>
        <ReturnType type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="createProxyMinCharge" id="bfe8caff-91cf-421c-afed-0a1a63b27831">
        <source>createProxyMinCharge(_invLineDesc 	 : CM_InvoiceLineDesc input ; 
					_invLine 		 : CM_InvoiceLine;
					_ti              : CM_TrackedItem;
					_newTotal		 : Decimal;
					_isInvoiceProforma : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Oct 2019	cnwma1	Bug 46674: JMT - Form - Minimum charges does not calculate minimum charges when grouping invoice lines

*/

vars
	remarks    		   : String;
	pxyCashPayment,
	pxyCashPaymentTax  : CM_CashPayment;
	pxyProforma        : CM_ProformaDetails;
	taxCashValue	   : Real;
	configCashTax	   : String;
	configInvMultiTax  : Boolean;
	terminal           : CM_Terminal;
begin
	
	terminal          := self.getTerminal();
	configCashTax     := terminal.getConfig(CashAllCashTax).String ;
	configInvMultiTax := terminal.getConfig(InvoiceMultiTaxRates).Boolean ;	
	
	remarks 		  := _invLineDesc.narration &amp; " (1 " &amp; _invLineDesc.unitNarration &amp; ") " &amp;  _newTotal.asCurrencyJMT;
	
	
	if _isInvoiceProforma then
		create pxyCashPayment as CM_CashPaymentProformaPrint transient;
	
	else
		create pxyCashPayment transient;
	endif;
	
	
	// TFS 47852 need to attach the payment to a TI (any TI on the receipt) so that if re calc in cash collection it will be shown. 
	//					Re-calc means calcuate, save and re calculate
	//					These min charge by Invoice are other wise only linked to a cash receipt.
	//					Cash Collection always starts with cargo, so must link this to a TI on the receipt
	pxyCashPayment.setProxy(_newTotal,
							0,	
							app.actualTimeAppServer,
							remarks,	
							false,	
							0,	
							false,	
							self.getDebtorTerminal(),
							_ti,	// TFS 47852
							null,						//_myInvoice : CM_Invoice;
							null,						//_vvr : CM_VehicleVisitRecord;
							app.getMyUser				//_myUser : CM_User;
						);
	
	//Create Proforma
	pxyProforma := self.createProformaDetail(pxyCashPayment.cashValue,
					1,
					_newTotal,
					remarks,
					_invLineDesc,
					null,
					0, 
					false);
	
	pxyCashPayment.setProformaDetail(pxyProforma);
	self.allProformaDetails.addNoDuplicates(pxyProforma,false);
			
	pxyCashPayment.setCashReceipt(self);
	pxyCashPayment.setIsMinimumCharge(true);
	
	
	//Calculate Tax
	taxCashValue := pxyCashPayment.getTaxAmountForPayment();
	if taxCashValue &gt; 0 then
	
		create pxyCashPaymentTax transient;
		if configCashTax = null and configInvMultiTax then
			if _isInvoiceProforma then
				create pxyCashPaymentTax as CM_CashPaymentProformaPrint transient ;
			else
				create pxyCashPaymentTax transient;
			endif;
			
			pxyCashPaymentTax.setProxy(taxCashValue,
								0,
								self.createdTime,	
								null,	
								false,
								0,
								false,
								self.getDebtorTerminal(),
								_ti,		// TFS 47852
								null,
								null,
								app.getMyUser
								);
			pxyCashPaymentTax.setIsMinimumCharge(true);					
			pxyCashPayment.setMyCashPaymentForTax(pxyCashPaymentTax);
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc" usage="input"/>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_newTotal" type="Decimal"/>
        <Parameter name="_isInvoiceProforma" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRoundingDifferenceLine" id="7e3d3cb6-cdc4-43b3-87a1-3c8cc26dc888">
        <updating/>
        <source>createRoundingDifferenceLine(_paymentProxies : ObjectArray input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2015	cnwmc5	Initial creation		PAR 36985

*/

vars
	now		: TimeStamp;
	invoice	: CM_Invoice;
	ild		: CM_InvoiceLineDesc;
	invLine	: CM_InvoiceLine;
	ti		: CM_TrackedItem;
	pxyCashPay	: CM_CashPayment;
	localTiArray : CM_TIArray;		//30 Mar 2016	NDL	TFS 1726
begin
	if not self.shouldRound then
		return;
	endif;

	// configured tax invoice line type... this may need to be chnaged later
//	ild := self.myTerminal.getConfig(CashRoundInvLineType).CM_InvoiceLineDesc;
	ild := self.myTerminal.getCashRoundInvLineType( self.getBank );	//08 Jan 2019	NDl	TFS 40010
	if ild = null then
		return;
	endif;
	
	invoice := self.myCashInvoice;
	if invoice = null then
		create localTiArray transient;	//30 Mar 2016	NDL	TFS 1726
		self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
	//	foreach ti in self.allTrackedItems do
		foreach ti in localTiArray do		//30 Mar 2016	NDL	TFS 1726
			invoice := ti.getCashInvoice();
			if invoice &lt;&gt; null then
				break;
			endif;
		endforeach;
		delete localTiArray;	//30 Mar 2016	NDL	TFS 1726
	endif;
	if invoice = null then
		return;
	endif;
	
	now := app.serverTimestampAtTrxStart;
	if self.roundingDifference &lt;&gt; 0 then
		invLine := ild.createManualInvoiceLineValue(invoice, self.roundingDifference, "roundingDifference", now);
		create pxyCashPay transient;
		pxyCashPay.setProxy(self.roundingDifference,//_cashValue : Decimal;
							0,						//_taxAmount : Decimal;
							self.dateTime,			//_dateTime : TimeStamp;
							null,					//_proformaDesc : String;
							false,					//_manual : Boolean;
							0,						//_status : Integer;
							false,					//_voided : Boolean;	
							self.myDebtorTerminal,	//_myDebtorTerminal : CM_DebtorTerminal;
							null,					//_myTrackedItem : CM_TrackedItem;
							invoice,				//_myInvoice : CM_Invoice;
							null,					//_vvr : CM_VehicleVisitRecord;
							app.getMyUser			//_myUser : CM_User;
							);
		pxyCashPay.setInvoiceLine(invLine);
		_paymentProxies.add( pxyCashPay );
// ### JIRA 33421 18NOV2024 NAVAB1		self.totalCargoCharges += self.roundingDifference; //07/10/2024	navkc1	JIRA 33025 - Include invoice line items to the total
	endif;
	
epilog

	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726

end;</source>
        <Parameter name="_paymentProxies" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createTaxLinesAndPaymentProxy" id="37ffb5e9-01e3-4faa-a0aa-78a2f37ac19f">
        <updating/>
        <source>createTaxLinesAndPaymentProxy(_paymentProxies : ObjectArray input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
					GPHA 2368 34917 create manual invoice lines for each tax value and proxy CM_CashPayments for each, if ILD is configured
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars
	now				: TimeStamp;
	invoice			: CM_Invoice;
	ild				: CM_InvoiceLineDesc;
	invLine			: CM_InvoiceLine;
	ti				: CM_TrackedItem;
	pxyCashPay		: CM_CashPayment;
	localTiArray 	: CM_TIArray;		//30 Mar 2016	NDL	TFS 1726
	taxColumnsMode	: Boolean;
	term 			: CM_Terminal;
	proformaDetail	: CM_ProformaDetails;
begin

	term := self.myTerminal;

	// configured tax invoice line type
	//ild := self.myTerminal.getConfig(CashTaxInvLineType).CM_InvoiceLineDesc;
	ild := self.myTerminal.getCashTaxInvLineType( self.getBank );	//08 Jan 2019	NDL	TFS 40010
	if ild = null then
		return;
	endif;
// TFS 38732	taxColumnsMode := self.getMyTerminal().getConfig(CashAllCashTax).String = null and self.getMyTerminal().getConfig(InvoiceMultiTaxRates).Boolean;	// 20/11/17 MAP TFS7357
	taxColumnsMode := term.getConfig(CashAllCashTax).String = null 
								and term.getConfig(InvoiceMultiTaxRates).Boolean;	// 20/11/17 MAP TFS7357
	if taxColumnsMode then
		return;
	endif;
	// 35992 receipt may not have a cashInvoice if it has payments from a prior receipt
	invoice := self.myCashInvoice;
	if invoice = null then
		create localTiArray transient;	//30 Mar 2016	NDL	TFS 1726
		self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
		//foreach ti in self.allTrackedItems do
		foreach ti in localTiArray do		//30 Mar 2016	NDL	TFS 1726
			invoice := ti.getCashInvoice();
			if invoice &lt;&gt; null then
				break;
			endif;
		endforeach;
		delete localTiArray;	//30 Mar 2016	NDL	TFS 1726
	endif;
	if invoice = null then
		return;
	endif;
	now := app.serverTimestampAtTrxStart;
	if self.taxValue1 &lt;&gt; 0 then
		invLine := ild.createManualInvoiceLineValue(invoice, self.taxValue1, "tax1", now);
		create pxyCashPay transient;
		pxyCashPay.setProxy(self.taxValue1,			//_cashValue : Decimal;
							0,						//_taxAmount : Decimal;
							self.dateTime,			//_dateTime : TimeStamp;
							null,					//_proformaDesc : String;
							false,					//_manual : Boolean;
							0,						//_status : Integer;
							false,					//_voided : Boolean;	
							self.myDebtorTerminal,	//_myDebtorTerminal : CM_DebtorTerminal;
							null,					//_myTrackedItem : CM_TrackedItem;
							invoice,				//_myInvoice : CM_Invoice;
							null,					//_vvr : CM_VehicleVisitRecord;
							app.getMyUser			//_myUser : CM_User;
							);
		pxyCashPay.setInvoiceLine(invLine);
		
		pxyCashPay. setTaxForReceiptDetail(); // ### JIRA 33421 18NOV2024 NAVAB1
		
		_paymentProxies.add( pxyCashPay );
	endif;
	if self.taxValue2 &lt;&gt; 0 then
		invLine := ild.createManualInvoiceLineValue(invoice, self.taxValue2, "tax2", now);
		create pxyCashPay transient;
		pxyCashPay.setProxy(self.taxValue2,			//_cashValue : Decimal;
							0,						//_taxAmount : Decimal;
							self.dateTime,			//_dateTime : TimeStamp;
							null,					//_proformaDesc : String;
							false,					//_manual : Boolean;
							0,						//_status : Integer;
							false,					//_voided : Boolean;	
							self.myDebtorTerminal,	//_myDebtorTerminal : CM_DebtorTerminal;
							null,					//_myTrackedItem : CM_TrackedItem;
							invoice,				//_myInvoice : CM_Invoice;
							null,					//_vvr : CM_VehicleVisitRecord;
							app.getMyUser			//_myUser : CM_User;
							);
		pxyCashPay.setInvoiceLine(invLine);
		
		pxyCashPay. setTaxForReceiptDetail(); // ### JIRA 33421 18NOV2024 NAVAB1
		
		_paymentProxies.add( pxyCashPay );
	endif;
	if self.taxValue3 &lt;&gt; 0 then
		invLine := ild.createManualInvoiceLineValue(invoice, self.taxValue3, "tax3", now);
		create pxyCashPay transient;
		pxyCashPay.setProxy(self.taxValue3,				//_cashValue : Decimal;
							0,							//_taxAmount : Decimal;
							self.dateTime,				//_dateTime : TimeStamp;
							null,						//_proformaDesc : String;
							false,						//_manual : Boolean;
							0,							//_status : Integer;
							false,						//_voided : Boolean;	
							self.myDebtorTerminal,		//_myDebtorTerminal : CM_DebtorTerminal;
							null,						//_myTrackedItem : CM_TrackedItem;
							invoice,					//_myInvoice : CM_Invoice;
							null,						//_vvr : CM_VehicleVisitRecord;
							app.getMyUser				//_myUser : CM_User;
							);
		pxyCashPay.setInvoiceLine(invLine);
		
		pxyCashPay. setTaxForReceiptDetail(); // ### JIRA 33421 18NOV2024 NAVAB1
		
		_paymentProxies.add( pxyCashPay );
	endif;
	
epilog

	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726
	
end;
</source>
        <Parameter name="_paymentProxies" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="631b999e-5693-4f3b-9652-43e2a45e2bc8">
        <updating/>
        <source>delete() updating;
// delete the pro forma invoice line copies - they should only exist if this cash receipt exists

/*
Changed On  By		TFS		Reason
----------------------------------------------------------------------
12 Jul 2019	jlgdi1	45301	Added code for audit purposes
16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
----------------------------------------------------------------------
*/

vars
	sapActivity : CM_ActivityHistoryExtInterface;
	
begin
	// 34227 only for the persistent copy
	if not self.isTransient then
		self.allProformaInvoiceLines.purge();
		self.allProformaDetails.purge();
		
		//11 Feb 2019	NDL	TFS 43318
		app.myRoot.deleteFutureActor(self, CM_CashStatusAdvanceProcess);
		
		foreach sapActivity in self.allSAPActivity discreteLock do
			sapActivity.setMyCashReceipt(null);
		endforeach;
	endif;
	
	if self.isTransient then   //16.10.2019 cnwma1 #46974
		return;
	endif;
	
	if not app.isGarbageCollectionProcess then	// found during testing.
		// TFS 45301
		app.myUtilityDA.myDeleteAuditAgent.audDeleteGeneric(self);
	endif;
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBGPAdvanceRequest" id="164b119b-f081-4711-b8d8-6bb238ad1d9d">
        <source>doBGPAdvanceRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64837 Task 64851: Jade - New API putProformaForExternal

*/

vars
	futureActor		: CM_CashStatusAdvanceProcess;
	
begin
	create futureActor;
	futureActor.setMyCashReceipt(self);
	futureActor.setActionTimeStamp(app.actualTimeServer().addMinutes(30));
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintGLT" id="1ce1daf2-dc1c-4c18-8dba-5c37170b6173">
        <source>doPrintGLT(_isProformaPrint : Boolean) : Boolean;
/*

Purpose:			
		Number of days is total of the storage lines quantity so needs to be divided by the number of containers to get the per-container days
Parameters:			

Return Value:		


Date		Who		Reason
06 Jun 2013	cnwjre1 31602 Gulftainer Umm Qasr cash receipt printing
06 Jan 2015 cnwma1  35461 String too long-I can not print CR ICT 1519
07 Jun 2016	cnwrs1  TFS2107 change rate/cost per unit from 16,4 to 16,6
06 Mar 2019 cnwma1  Bug 42198: GUQ - Proforma Invoice not Printing
17 Apr 2019	jlgdi1	TFS 44259 Exclude previous paid payments both for non-proforma and proforma printing
08 May 2019	NDL		TFS 44350
25 Nov 2019 cnwma1	Bug 47640: GUQ - New Cash Report Proforma / Cash Receipt are not working correctly
28 Oct 2021 cnwma1	ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
*/

vars
	sequence			 : Integer;
	createHeader		 : Boolean;
	first				 : Boolean;
	quantity			 : Real;
	numberOfDays		 : Integer;
	numberOfContainers	 : Integer;
	deliveryRelease ,
	lastDeliveryRelease,
	ids					 : String;
	terminal			 : CM_Terminal;
	dict				 : DynaDictionary;
	obj					 : Object;
	jdo					 : JadeDynamicObject;
	tiArray,		 
	releaseTIs,			 
	localTiArray		 : CM_TIArray;
	trackedItem		     : CM_TrackedItem;
	cashHeader		     : CMIF_CashReceiptHeader;			// 28/8/19 MAP TFS44266
	cashDetail			 : CMIF_CashReceiptDetail;			// 28/8/19 MAP TFS44266
	cashPaymentAmount1, 	 
	cashPaymentAmount2, 	 
	lineAmount,			 
	lineTotal,			 
	rate				 : Decimal [23,6];				   //10 May 201  NDL TFS 38523
	secondCurrencyType	 : CM_CurrencyType;			   	   //08 May 2019 NDL TFS 44350
	secondCurrencyRate	 : CM_CurrencyRate;				   //08 May 2019 NDL TFS 44350
begin
	
	create localTiArray transient;					     //30 Mar 2016	NDL	TFS 1726
	self.getAllGoodTrackedItems( localTiArray );		 //30 Mar 2016	NDL	TFS 1726
	if self.allInvoiceLines.isEmpty    and
	   self.allProformaDetails.isEmpty and
	   localTiArray.isEmpty            then
		return false;
	endif;

	terminal := self.getDebtorTerminal().myTerminal;
	
	//08 May 2019 NDL TFS 44350
	secondCurrencyType := terminal.getCashSecondCurrencyType();
	if secondCurrencyType &lt;&gt; null then
		secondCurrencyRate := secondCurrencyType.getRate( self.dateTime );
	endif;

	// dyna dictionary to group invoice line details by delivery release, invoice line type and container size
	create dict transient;
	dict.setMembership(JadeDynamicObject); 
	dict.addExternalKey(String,  30, true, true);	// CM_cashReceipt.ExternalInvoiceNumber          // 25.11.2019 cnwma1 #47640
	dict.addExternalKey(String,  25, false, true);	// CM_TrackedItem.deliveryRelease
	dict.addExternalKey(String, 200, false, true);	// CM_InvoiceLineDesc.narration  				 // 28.10.2021 navma1 #52163
	dict.addExternalKey(Decimal,  0, false, true);	// TFS 47847 Line Rate
	dict.addExternalKey(Integer,  4, false, true);	// container size (20, 40 etc)
	dict.addExternalKey(Boolean,  1, false, true);	// is payment
	dict.addExternalKey(Integer,  4, false, true);	// number of days (storage or reefer daily)
	dict.endKeys(false);							// no duplicates
	

	self.getInvoiceStatsForQUC(dict); 

	first := true;
	create releaseTIs transient;
	if not dict.isEmpty() then
		foreach obj in dict do
			jdo := obj.JadeDynamicObject;
			deliveryRelease := jdo.getPropertyValue("deliveryRelease").String;
			createHeader := false;
			// print previous delivery release
			if deliveryRelease &lt;&gt; lastDeliveryRelease and not first then
				cashHeader.glt_containerIds 	   := ids;
				cashHeader.glt_totalCharges 	   := lineTotal;
				cashHeader.glt_totalChargesInWords := lineTotal.roundedTo(2).asCurrencyJMTWords();	// 32198
				cashHeader.glt_print(terminal,_isProformaPrint);
				sequence  	 := 0;
				lineTotal 	 := 0;
				ids			 := null;
				createHeader := true;
				releaseTIs.clear();
			endif;
			if first then
				createHeader := true;
				first 		 := false;
			endif;
			lastDeliveryRelease := deliveryRelease;
			tiArray 		    := jdo.getPropertyValue("trackedItems").CM_TIArray;
			trackedItem 		:= tiArray.first();
			// take header details from the first tracked item for this release
			if createHeader and trackedItem &lt;&gt; null then
				create cashHeader transient;
				cashHeader.glt_billOfLading := trackedItem.billOfLading;
				cashPaymentAmount1          := self.cashPayment1;
				cashPaymentAmount2          := self.cashPayment2;
				cashHeader.glt_cashAmount1  := cashPaymentAmount1;
				cashHeader.glt_cashAmount2  := cashPaymentAmount2;
				
				if secondCurrencyRate &lt;&gt; null then
					cashHeader.glt_cashAmount2Base := (secondCurrencyRate.rate * cashPaymentAmount2).roundedTo(2);
				endif;
				
				cashHeader.glt_cashTotal 		 := cashHeader.glt_cashAmount1 + cashHeader.glt_cashAmount2Base;
				cashHeader.glt_cashTotalInWords  := cashHeader.glt_cashTotal.roundedTo(2).asCurrencyJMTWords();	// 32198
				cashHeader.glt_consigneeName 	 := trackedItem.getConsigneeDesc();
				cashHeader.glt_deliveryNumber 	 := trackedItem.deliveryRelease;
				cashHeader.glt_effectiveDate 	 := self.effectiveDate;
				cashHeader.glt_receiptDate 		 := self.dateTime.date;
				cashHeader.glt_userName          := self.myUser.userName;		// from 33523 testing
				cashHeader.glt_vesselName 	     := trackedItem.vesselName;
				cashHeader.glt_voyageArrivalDate := trackedItem.voyageArrivalDate;
				cashHeader.glt_receiptNumber     := self.externalInvoiceNumber;
				if trackedItem.myVoyage &lt;&gt; null then
					cashHeader.glt_voyageNumber := trackedItem.myVoyage.code;
				endif;
				
			endif;
			
			foreach trackedItem in tiArray do
				if not releaseTIs.includes(trackedItem) then
					if ids = null then
						ids := trackedItem.id;
					else
						ids := ids &amp; ", " &amp; trackedItem.id;
					endif;
					releaseTIs.add(trackedItem);
				endif;
			endforeach;

			create cashDetail transient;
			sequence				     := sequence + 1;
			cashDetail.glt_sequence		 := sequence;
			cashDetail.glt_containerSize := jdo.getPropertyValue("containerSize").Integer;
			lineAmount 					 := jdo.getPropertyValue("lineAmount").Decimal;
			cashDetail.glt_lineAmount 	 := lineAmount;
			
			lineTotal := lineTotal + lineAmount;
			
			cashDetail.glt_lineDescription := jdo.getPropertyValue("lineDescription").String ;//[1:60];	//28.10.2021 navma1 #52163
			quantity 					   := jdo.getPropertyValue("quantity").Real;
			rate     					   := jdo.getPropertyValue("lineRate").Decimal;
			if rate &lt; 0 then
				rate := -rate;
			endif;
			cashDetail.glt_lineRate			  := rate;
			numberOfContainers  			  := tiArray.size;
			cashDetail.glt_numberOfContainers := numberOfContainers;
			numberOfDays 					  := jdo.getPropertyValue("numberOfDays").Integer;
			cashDetail.glt_numberOfDays 	  := numberOfDays;
			cashHeader.glt_allDetails.add(cashDetail);
		endforeach;
		
		cashHeader.glt_containerIds 	   := ids;
		cashHeader.glt_totalCharges        := lineTotal;
		cashHeader.glt_totalChargesInWords := lineTotal.roundedTo(2).asCurrencyJMTWords();	// 32198

		cashHeader.glt_print(terminal,_isProformaPrint);
	endif;
	
	return true;

epilog
	if cashHeader &lt;&gt; null then
		cashHeader.glt_allDetails.purge();
		delete cashHeader;
	endif;
	delete releaseTIs;
	delete localTiArray;
	if dict &lt;&gt; null then
		foreach obj in dict do
			jdo      := obj.JadeDynamicObject;
			tiArray := jdo.getPropertyValue("trackedItems").CM_TIArray;
			delete tiArray;
		endforeach;
		dict.purge();	
		delete dict;
	endif;
end;</source>
        <Parameter name="_isProformaPrint" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSAPRequestWOTimer" id="68b6ea65-2bef-4713-a9ba-d5d8ea910628">
        <source>doSAPRequestWOTimer();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/01/2019	jlgdap1		Initial creation TFS 42925 PEL1 Container Services Estimation Approval Countdown
//
vars
	futureActor : CM_CashStatusAdvanceProcess;

begin
	// For cargo work order cash receipts, where SAP approval is needed, create a future actor 
	// for automatically approving the cash receipt and set task status on the work order
	if self.myWorkOrder = null
	or self.myWorkOrder.isVoyageWorkOrder	//11 Feb 2019	NDL	TFS 43219
	then
		return;
	endif;
	if not self.needSAPRequest then
		return;
	endif;
	
	if self.myWorkOrder.taskStatus &lt;&gt; WO_STATUS_PENDING then
		self.myWorkOrder.setTaskStatus(WO_STATUS_PENDING);
	endif;
	create futureActor;
	futureActor.setMyCashReceipt(self);
	futureActor.setActionTimeStamp(app.actualTimeServer.addHours(1));
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findProformaMatching" id="df658be5-13d5-4e5d-baad-92804ea31772">
        <source>findProformaMatching(	_invoiceLineDesc : CM_InvoiceLineDesc;
						_quantity : Real;
						_lineTotal : Decimal
						):CM_ProformaDetails;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	proforma : CM_ProformaDetails;

begin

	foreach proforma in self.allProformaDetails do
		if proforma.myInvoiceLineType &lt;&gt; _invoiceLineDesc then
			continue;
		endif;	
		if proforma.quantity &lt;&gt; _quantity then
			continue;
		endif;
		if proforma.lineTotal &lt;&gt; _lineTotal then
			continue;
		endif;
		return proforma;
		
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_invoiceLineDesc" type="CM_InvoiceLineDesc"/>
        <Parameter name="_quantity" type="Real"/>
        <Parameter name="_lineTotal" type="Decimal"/>
        <ReturnType type="CM_ProformaDetails"/>
    </JadeMethod>
    <JadeMethod name="genExternalReceiptNum" id="2ba4b792-6d4e-46ee-84bb-28bae6d604fc">
        <updating/>
        <source>genExternalReceiptNum() updating;

/*

Purpose:	the Pelindo1 external receipt requires configuration on an INVOICE TYPE
				the invoice type is on the cash payment's proforma details.
				cash payments are created way after the seperate creation of the cash receipt
				so we need to call this method from the web service web portal TRX after all the cash payments are created.

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2018	jlgab1	Initial creation
08 Oct 2021 jlier1	TFS 51963
*/

vars
	finIO : CM_ExtFinanceIO;
begin
		//11/07/2024	navkc1 CR 64839 Task 64856 - do not generate number when it's draft as it may gets deleted and we don't want a gap between them
		if self.paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT then
			return;
		endif;
		
		if not self.allCashPayments.isEmpty() 
		and self.myTerminal&lt;&gt; null then
			finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
			if finIO &lt;&gt; null then
				self.externalInvoiceNumber := finIO.getExternalReciptNumber(self);
			endif;
		
		endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getActionDT" id="6a3e1ff5-0e91-4391-a21c-9e4317d2661d">
        <source>getActionDT() : TimeStamp;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/01/2019	jlgdap1		Initial creation TFS 42925 PEL1 Container Services - Estimation Approval Countdown
//
vars
	fa : CM_OfflineFutureActor;

begin
	if self.paymentType &lt;&gt; PaymentType_PrePay then
		return null;
	endif;
	
	fa := app.myRoot.allOfflineFutureActorParents[self];
	if fa &lt;&gt; null then
		return fa.actionTimeStamp;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getAllCashPayments" id="c85bf19c-9013-43c2-9a25-9203a44d9691">
        <source>getAllCashPayments() : CM_CashPaymentDict;

/*

Purpose:			Get the cash payments collection - for conversion only after 8.2.2

Parameters:			

Return Value:		


Date		Who		Reason
24 April 2014	cnwjre1	Initial creation

*/

vars
	any		: Any;
begin
	global.getExtraData( self.allExtraData, "allCashPayments", any);
	if any &lt;&gt; null then
