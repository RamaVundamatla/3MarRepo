    <JadeMethod name="initializeMe" id="e3b7bb17-2cab-4cba-ad78-fa3421dc8d5d">
        <updating/>
        <source>initializeMe(pKeyName:String; pIsDescending:Boolean; pIsCaseSensitive:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		Initialize the receiver's property values.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.keyName			:=	pKeyName;
	self.isDescending		:=	pIsDescending;
	self.isCaseSensitive	:=	pIsCaseSensitive;
end;</source>
