    <JadeMethod name="isDeleteAllowed" id="d654139e-27cb-4a82-877f-b4d2c0342ccc">
        <updating/>
        <source>isDeleteAllowed(_errorMsg:String output):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		15 September 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether or not the receiver can
//				be deleted.
//
// Parameters:	_errorMsg - Returns an error message if the receiver cannot be deleted.
//
// Returns:		True if the receiver can be deleted, otherwise false (and an error
//				message if appropriate).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	voyageObj	: CM_Voyage;
	
begin
	foreach voyageObj in self.allVoyages do
		if (voyageObj.myVoyageGlobalArrival &lt;&gt; null and voyageObj.myVoyageGlobalArrival &lt;&gt; self)
		or (voyageObj.myVoyageGlobalDeparture &lt;&gt; null and voyageObj.myVoyageGlobalDeparture &lt;&gt; self)
		then
			_errorMsg	:=	app.getString(	Voyage_Cannot_Delete,
											voyageObj.myTerminal.name,
											voyageObj.arrivedDT.date().shortFormatJMT());
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="_errorMsg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLinkedToVoyage" id="c1928e8d-bc96-4cc9-bb70-12d420d6939c">
        <source>isLinkedToVoyage(_voyage : CM_VoyageGlobal) : Boolean;

/*

Purpose:			Determine whether or not the receiver is linked to the passed in voyage


Return Value:		True if it is, false otherwise


Date		Who		Reason
31 Mar 2008	cnwkpd1	PAR #16365 - Correct validation of changes to an existing linked global voyage

*/

vars
	voyages			: CM_VoyageGlobalSet;
	
begin
	create voyages transient;
	
	if self.isLinkedToVoyagePrior(_voyage, voyages) then
		return true;
	endif;
	
	voyages.clear;
	
	if self.isLinkedToVoyageSubsequent(_voyage, voyages) then
		return true;
	endif;
	
	return false;
	

epilog
	delete voyages;
	
end;
</source>
        <Parameter name="_voyage" type="CM_VoyageGlobal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLinkedToVoyagePrior" id="7a8d4c9d-3116-4e2e-b326-269be9530505">
        <source>isLinkedToVoyagePrior(_voyage : CM_VoyageGlobal;
					  _voyagesTraversed : CM_VoyageGlobalSet input) : Boolean protected;

/*

Purpose:			Determine whether the receiver has the passed in voyage in its prior voyages linked list


Return Value:		True if it has, false otherwise


Date		Who		Reason
31 Mar 2008	cnwkpd1	PAR #16365 - Initial creation

*/

vars

begin
	if self.myPriorVoyageGlobal &lt;&gt; null then
		if self.myPriorVoyageGlobal = _voyage then
			return true;
		endif;
		
		// Protect against circular references which would cause a stack overflow
		if _voyagesTraversed.includes(self) then
			return false;
		endif;
		
		_voyagesTraversed.add(self);
		
		if self.myPriorVoyageGlobal.isLinkedToVoyagePrior(_voyage, _voyagesTraversed) then
			return true;
		endif;
	endif;
	
	return false;
		

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_VoyageGlobal"/>
        <Parameter name="_voyagesTraversed" type="CM_VoyageGlobalSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLinkedToVoyageSubsequent" id="80463345-1821-427c-aae3-9c4852a4098d">
        <source>isLinkedToVoyageSubsequent(_voyage : CM_VoyageGlobal;
						   _voyagesTraversed : CM_VoyageGlobalSet input) : Boolean protected;

/*

Purpose:			Determine whether the receiver has the passed in voyage in its subsequent voyages linked list


Return Value:		True if it has, false otherwise


Date		Who		Reason
31 Mar 2008	cnwkpd1	PAR #16365 - Initial creation

*/

vars

begin
	if self.mySubsVoyageGlobal &lt;&gt; null then
		if self.mySubsVoyageGlobal = _voyage then
			return true;
		endif;
		
		// Protect against circular references which would cause a stack overflow
		if _voyagesTraversed.includes(self) then
			return false;
		endif;
		
		_voyagesTraversed.add(self);
		
		if self.mySubsVoyageGlobal.isLinkedToVoyageSubsequent(_voyage, _voyagesTraversed) then
			return true;
		endif;
	endif;
	
	return false;
		

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_VoyageGlobal"/>
        <Parameter name="_voyagesTraversed" type="CM_VoyageGlobalSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="maintainMovementLinkedList" id="2c9076db-0b49-4a29-b506-9dfafe08ca60">
        <source>maintainMovementLinkedList();
// ---------------------------------------------------------------------------
// Created:     19 February 2008 by cnwrs2
//
// Purpose:     The HMS_Movement object have a linked list of myPrevMovement,
//				myNextMovement.  These are currently set by looking at next/prev
//				movement on HMS_VoyageData.allVoyageMovements and self.allHMSMovements
//				dict.  This does
//				not work as movements are updated and the date is changed which
//				affects the order in the dict, so the next/prev references get
//				set incorrectly.
//
//				At some stage this should be reviewed further to store movements
//				as an array.	
// ---------------------------------------------------------------------------
vars
	tmpMovement	: HMS_Movement;
	
begin

	// IMPORTANT: Any changes here may also need to be made on 
	// method CM_Voyage::maintainMovementLinkedList

	// This method should be called whenever a movement dates are updated BUT
	// only ONCE all the movement updates have been completed
	
	foreach tmpMovement in self.allHMSMovements do
		tmpMovement.maintainLinkedList();
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="noOfVoyageForThisTerminal" id="c8575d67-fb4c-4389-b039-96162104c555">
        <source>noOfVoyageForThisTerminal(_terminal : CM_Terminal) : Integer;
//-----------------------------------------------------------------------
//	Created:	01 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
/*

Date		Who		Reason
10 Apr 2008	cnwkpd1	PAR #16378 - Fixed bug found checking references to allVoyages

*/

vars
	voy : CM_Voyage;
	num	: Integer;
	
begin
	foreach voy in self.allVoyages do
		if voy.myTerminal = _terminal then
			num := num + 1;
		endif;
	endforeach;
	
	return num;
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9549b2f5-9ad3-4634-a7a2-a299de9883ca">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyVoyageGlobal : CM_VoyageGlobal;
	pxyVoyage,
	realVoy			: CM_Voyage;
	passport		: CM_Passport;
	movement,
	pxyMovement		: HMS_Movement;
	failedDAC  		: CM_DataAccessController;
	completedOK		: Boolean;
begin
	passport := app.myPassport;
	pxyVoyageGlobal := inheritMethod();
	
	pxyVoyageGlobal.myPriorVoyageGlobal	:= self.myPriorVoyageGlobal;
	pxyVoyageGlobal.mySubsVoyageGlobal	:= self.mySubsVoyageGlobal;
		
	pxyVoyageGlobal.setMyRoot();
	
	foreach realVoy in self.allVoyages do
		if realVoy.canUserAccessSelf(null, failedDAC, passport) then
			pxyVoyage := app.createUpdateProxy(realVoy).CM_Voyage;
			pxyVoyage.setMyVoyageGlobalArrival(pxyVoyageGlobal);
			if pxyVoyage.myHMSVoyageData &lt;&gt; null then
				foreach pxyMovement in  pxyVoyage.myHMSVoyageData.allVoyageMovements do
					pxyMovement.setMyVoyageGlobal (pxyVoyageGlobal);
				endforeach;
			endif;
		endif;
	endforeach;
	
	foreach movement in self.allHMSMovements do
		if movement.isMovementTypePassage then
			pxyMovement := app.createUpdateProxy(movement).HMS_Movement;
			pxyMovement.setMyVoyageGlobal(pxyVoyageGlobal);
		endif;
	endforeach;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401	
	return pxyVoyageGlobal;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyVoyageGlobal;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setArrivalDT" id="3fdee0ee-9b49-48d2-b072-14c6ff07984d">
