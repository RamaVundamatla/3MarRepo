<GUIClass name="CMUI_ToolbarPicture" id="d2eebfd3-3cb8-4321-adcb-8b04e67c9476">
    <superclass name="Picture"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myToolbarControl" id="f7c36f8f-1f45-4813-bbe1-ee7102038a21">
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CMUI_ToolbarControl"/>
        <access>protected</access>
        <Inverse name="CMUI_ToolbarSeperator::myToolbarPicture"/>
        <Inverse name="CMUI_ToolbarButton::myToolbarPicture"/>
    </ExplicitInverseRef>
    <JadeMethod name="windowCreated" id="66556fd1-a249-4e69-8e73-01a6761c7359">
        <updating/>
        <source>windowCreated(cntrl: Picture input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);

	cntrl.autoRedraw	:= true;
	cntrl.height 		:= CMUI_ToolbarButton.HeightPicture;
	cntrl.width 		:= CMUI_ToolbarButton.WidthPicture;
	cntrl.top 			:= 2;
	cntrl.left 			:= 1;
	cntrl.borderStyle	:= BorderStyle_None;
	cntrl.transparent	:= true;
	cntrl.stretch := Picture.Stretch_Proportional;
	cntrl.parentAspect := Picture.ParentAspect_StretchBoth;
	
end;</source>
        <Parameter name="cntrl" type="Picture" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <DevControlTypes name="CMUI_ToolbarPicture">
        <bitmap></bitmap>
        <windowClass>AlPicture</windowClass>
        <DevControlProperties name="backBrush">
            <cntrlType>picture</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrushStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - tile</value>
                <value>1 - stretch</value>
                <value>2 - center</value>
                <value>3 - stretch proportional</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="backColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderColorSingle">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Fixed single</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="bubbleHelp">
            <cntrlType>multilined-string</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="clipControls">
