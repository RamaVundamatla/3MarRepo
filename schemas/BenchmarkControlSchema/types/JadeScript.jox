    <JadeMethod name="jhpJommonV2ToCsvQueuedLocks" id="cbade91e-cb56-43c1-8c82-30b0d0e955b8">
        <source>jhpJommonV2ToCsvQueuedLocks();
vars
	s,t,folderName,folderMask,include,exclude,userDesc:String;
	i,j,k,l,hits,hitsmax,userNum:Integer;
	presentationFileSystem,firstOnly,showFileName:Boolean;
	ts:TimeStamp; userNums:IntegerArray; userDescs:StringArray256;
	f,g:File; fn:FileNode; ff:FileFolder;
begin
	folderName:="G:\BenchMarkResults\tui\20100505_s54\R37a";
	folderName:="G:\BenchMarkResults\tui\20100505_s54\R37CSFa";
	folderMask:="*_jommon_*1.log";
	
	create userNums transient;
	create userDescs transient;
	create f;
	f.mode:=File.Mode_Input;
	f.maxRecordSize:=32000;
	create g;
	g.mode:=File.Mode_Output;
	f.kind:=File.Kind_Unknown_Text;
	create ff;
	ff.fileName:=folderName;
	ff.mask:=folderMask;
	ff.usePresentationFileSystem:=presentationFileSystem;
	foreach fn in ff.files where fn.isKindOf(File) and fn.fileName&lt;&gt;g.fileName
	and fn.name[1:5]&lt;&gt;"grep_"
	do
		f.fileName:=fn.fileName;
		//f.maxRecordSize:=64*1024;  // kills static file optimisation
		f.usePresentationFileSystem:=presentationFileSystem;
		g.fileName:=f.fileName.replace(".log", "_QueuedLocks.csv");
		g.usePresentationFileSystem:=true;
		if not f.isAvailable then continue; endif;
		g.writeLine("Time,Target,Class,User,Request Time,Lock Type,Lock Duration,Lock Kind,Locked By,Elapsed Time,");
		while not f.endOfFile do
			s:=f.readLine&amp;" ";
			if s.contains("key=10;level=3;") then  // update user arrays
				i:=s.pos("process=Process/187.", 1);
				if i &gt; 0 then
					j:=i+20;
					userNum:=s.scanUntil(";", j).Integer;
					//write userNum.String&amp;" "&amp;s[j:10];
					k:=userNums.indexOf(userNum);
					if k = 0 then
						userNums.add(userNum);
						userDescs.add("");
						k:=userDescs.size;
						//write userNum.String&amp;" "&amp;userDesc;
					endif;
					i:=s.pos("userInfo=", 1);
					if i &gt; 0 then
						j:=i+9;
						t:=s.scanUntil(";", j)&amp;"/"&amp;userNum.String;
						if t[1:3].toLower &lt;&gt; "cnw" then  // don't overwite if it's just computer name
							userDescs[k]:=t[1:256];
						endif;
					endif;
				endif;
			endif;
			if s.pos("key=51;level=2", 1) &lt;&gt; 0  // queued locks
			then
				// replace user info
				i:=s.pos("{", 1);
				if i &gt; 0 then
					j:=i+1;
					userNum:=s.scanUntil("}", j).Integer;
					k:=userNums.indexOf(userNum);
					if k &gt; 0 then
						s:=s.replace("{"&amp;userNum.String&amp;"}", userDescs[k]);
					endif;
				endif;
				// replace locked by info
				i:=s.pos("Process/187.", 1);
				if i &gt; 0 then
					j:=i+12;
					userNum:=s.scanUntil(";", j).Integer;
					k:=userNums.indexOf(userNum);
					if k &gt; 0 then
						s:=s.replace("Process/187."&amp;userNum.String, userDescs[k]);
					endif;
				endif;
				// tidy up, convert to csv format
				s:=s.replace(" key=51;level=2;jdoname=;target=", ",").replace(";", ",").zap("Process/187.")
						.zap("cnwjhp1_").zap("cnwchc").zap(" (TWHTUI)")
						.zap("className=").zap("user=").zap("requestTime[TS]=").zap("lockType=").zap("lockDuration=").zap("lockKind=").zap("lockedBy=").zap("elapsedTime[T]=");
				g.writeLine(s);
//				write fn.name&amp;": "&amp;s;
			endif;
		endwhile;
		/*foreach i in 1 to userDescs.size do 
			write userNums[i].String&amp;" "&amp;userDescs[i];
		endforeach;/**/
		f.close;
	endforeach;
	g.close;
epilog
	delete f;
	delete g;
	delete ff;
	delete userNums;
	delete userDescs;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpJommonV2ToCsvSysStats" id="e79ea1f2-3faf-4b50-950e-fae1e87beeb7">
        <source>jhpJommonV2ToCsvSysStats();
//	creates a csv file with all stats counters
vars
	s,t,u,v,counter,folderName,folderMask,include,exclude:String;
	i,j,k,dateLength,counterlength,starttime,tottime,subcount,totcount:Integer;
	l:Integer64;
	ia:Integer64Array;
	presentationFileSystem,firstTime:Boolean;
	ts,prevts,tsStart,tsEnd:TimeStamp;
	tt,tt2,tt3:Time;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
	readCount : Integer;
begin
	create ia transient;
	firstTime:=true;
	create f;
	create g;
	f.fileName:="C:\a\ski\20081124_pfm\20090108\jommon\jommon_queued_locks.log";
	f.fileName:="C:\a\ski\20081124_pfm\20090116\jommon_20090115_7437.log";
	f.fileName:="C:\a\ski\20081124_pfm\20090116\jommon_20090116_13836.log";
	f.fileName:="C:\a\ski\pfm_20081124\20090123\jommon\jommon_20090122.log";
	f.fileName:="C:\a\jsms\Enrol test 2009 11\logs\20091119 combined run 60 mins\s3\jommon_20091119_cnwjre1.log";
	f.fileName:="C:\a\jmt\scalability 2009\work\09\6217_09a_jommon_20091221_cnwjhp1.log";
	f.fileName:="C:\a\jmt\scalability 2009\work\11\6217_11a_jommon_20091221_cnwjhp1.log";
	f.fileName:="C:\a\jmt\scalability 2009\work\63\6305_11a_jommon_20100111_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\tui\20100308_s54\6217a\6217a_jommon_20100308_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\tui\20100307_s54\6305_70_420a\6305_70_420a_jommon_20100307_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\mtl\20100309_s54\6217_772a\6217_772a_jommon_20100309_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\mtl\20100312_s54\6305a\6305a_jommon_20100312_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\mtl\20100322_s54\6305a\6305a_jommon_20100322_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\mtl\20100408_s55\32Va\32Va_jommon_20100408_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\mtl\20100412_s55\64Salla\64Salla_jommon_20100412_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\mtl\20100420_s55\64Sjpa\64Sjpa_jommon_20100420_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\tui\20100423_s54\R37_280a\R37_280a_jommon_20100423_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\tui\20100428_s54\R35a\R35a_jommon_20100428_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\tui\20100503_s54\R37a\R37a_jommon_20100503_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\tui\20100503_s54\R37CSFa\R37CSFa_jommon_20100504_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\tui\20100505_s54\R35a\R35a_jommon_20100505_cnwjhp1.log";
	f.fileName:="C:\CMIS\cnwchcs4\Add Case note to One Case 500 users 4 delay 120 cycle 5 app servers no Notes all background tasks 20130531\jommon_20130531_cnwvu1_released_125900Ansi.log";
	f.fileName:="T:\transfer\TaylorL\jommon_20140210_wyntl1_released_162905.log";
	g.fileName:=f.fileName.replace(".log", "_SysStats.csv");
	g.mode:=File.Mode_Output;
	f.shareMode := File.Share_Exclusive;
	f.kind:=File.Kind_Unknown_Text;

	// find starting timestamp, build header line
	while not f.endOfFile do
		s:=f.readLine;
		readCount := readCount + 1;
//		if readCount mod 1000 = 0 then
//			write readCount;
//		endif;
//		continue;
		if s.contains("key=8") then
			i:=1;
			ts:=s.scanUntil(" ", i).TimeStamp;
			foreach k in 1 to 3 do  // skip to first stats field
				s.scanUntil(";", i); i:=i+1;
			endforeach;
			if firstTime then  // build header line
				t:="Date,Time,";
			else
				t:=ts.logFormat.replace(" ", ",")[1:19]&amp;",";  // build detail line
			endif;
			foreach k in 1 to 15 do  // 15 stats fields
				u:=s.scanUntil(";", i); i:=i+1;
				j:=1;
				if firstTime then  // build header line
					t:=t&amp;u.scanUntil("[", j)&amp;",";
					u.scanUntil("=", j); j:=j+1;
					ia[k]:=u[j:end].Integer64;
				else  // build detail line
					u.scanUntil("=", j); j:=j+1;
					l:=u[j:end].Integer64;
					t:=t&amp;((l - ia[k])/((ts - prevts).getMilliseconds/1000)).rounded.String&amp;",";
					ia[k]:=l;
				endif;
			endforeach;
			if firstTime then  // build header line
				t:=t[1:t.length-1];
				firstTime:=false;
			endif;
			//write ia.display;
			g.writeLine(t);
			//write ((ts - prevts).getMilliseconds/1000).rounded;
			prevts:=ts;
			//break;
		endif;
	endwhile;

epilog
	delete f;
	delete g;
	delete ff;
	delete ia;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpNextBranch" id="801cf520-71f8-4e0e-b5b8-0f3e6d6626aa">
        <source>jhpNextBranch(baseBuildVersion:String):String;

vars
	ff : FileFolder;
	fn : FileNode;
	current: Integer;
begin
	create ff transient;
	ff.usePresentationFileSystem:=false;
	ff.fileName:= DailyBuildParentFolder &amp; "DailyResults";
	
	if baseBuildVersion[3:2] &lt;&gt; "00" then
		return baseBuildVersion;

	elseif baseBuildVersion = "9900" then
		ff.mask := "jade*";
		foreach fn in ff.files do
			if fn.name[5:2].Integer &gt; current and fn.name[5:2] &lt;&gt; "99" then
				current := fn.name[5:2].Integer;
			endif;
		endforeach;
		return (current + 1).String &amp; "01";

	else
		ff.mask := "jade" &amp; baseBuildVersion[1:2] &amp; "*";
		current := baseBuildVersion.Integer;
		foreach fn in ff.files do
			if fn.name[5:4].Integer &gt; current and fn.name[5:3] &lt;&gt; "705" then
				current := fn.name[5:4].Integer;
			endif;
		endforeach;
		return (current + 1).String;
	endif;
epilog
	delete ff;
end;
</source>
        <Parameter name="baseBuildVersion" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
