    <JadeMethod name="setMyTrackedItem" id="073172e4-1aae-4268-8061-3e4476e5e03e">
        <updating/>
        <source>setMyTrackedItem(_value : CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2010	cnwdap1	Initial creation
*/
vars

begin
	_value.raiseExceptionIfTransient(method);
	if _value = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "Persistent TrackedItem", null, null);	
	endif;
	if self.myTrackedItem = _value then 
		return;
	endif;
	self.myTrackedItem := _value;
epilog

end;</source>
        <Parameter name="_value" type="CM_TrackedItem"/>
    </JadeMethod>
