    <JadeMethod name="validateForCreate" id="d2cd746a-6ffa-4104-a712-2848f8e474c6">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars
	
	now : TimeStamp;

begin

	now := app.actualTimeAppServer;

	if self.actionTime &gt; now then
		app.raiseCMException(Reefe_alert_actio_time_not_fut, null, null);
	endif;

	inheritMethod();

epilog

end;</source>
