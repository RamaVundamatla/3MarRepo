    <JadeMethod name="setForCreate" id="1b5a1ac5-b20d-4639-be3f-6242c59c083f">
        <updating/>
        <source>setForCreate(_label : String; _row, _maxHeight : Integer; _yrdPadArea : YRD_PadArea; _gridRow : CM_GridRow) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin


	self.label := _label;
	self.row := _row;
	self.maxHeight := _maxHeight;
	self.myGridRow := _gridRow;
	self.myGridArea	:= _yrdPadArea;

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <Parameter name="_yrdPadArea" type="YRD_PadArea"/>
        <Parameter name="_gridRow" type="CM_GridRow"/>
    </JadeMethod>
