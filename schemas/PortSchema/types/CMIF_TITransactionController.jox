    <JadeMethod name="typeString" id="5a356567-9e81-4c48-9e30-4f29c56f5f1b">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 27/04/2009	cnwdad1		CCMS 1735.  Change from using Translatable Strings,
//							to using translated Global Constants.
// ---------------------------------------------------------------------------
vars
	str			: String;
	constantObj	: Constant;
	
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	str := 'TransType_' &amp; self.type.String;
	constantObj	:=	currentSchema.getConstant(str);

//	_value := app.currentLocale.getStringValue(str);
	if constantObj = null then
		_value	:=	null;
	else
		_value	:=	app.getString(constantObj.getSource().Integer);
	endif;
	
	if _value = null then
		_value	:=	'Unknown Type';
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTransaction" id="b676dc37-2f81-445f-a99c-6c96c4f45ee7">
        <updating/>
        <source>updateTransaction(_passport : CM_Passport input; _origTrans : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	_origTrans.savePreviousVersion();
	_origTrans.generateEditAudit(_passport);
	
	// TFS 47361 jlgzm1 13/11/2019
	if _origTrans.dateTime &lt;&gt; self.dateTime and self.myTrackedItem &lt;&gt; null then
		// if changing the timestamp then there is a chance to have duplicate keys on ti.allTransactions, 
		// because of orderNo, remove from collection for now, then we can guarantee there
		// will be no duplicates, it will be added back in during setFromCMIF_TITransactionCntrl
		_origTrans.setTypeAndTI(_origTrans.type, null);
	endif;
	
	_origTrans.setFromCMIF_TITransactionCntrl(self, _passport);	
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_origTrans" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate" id="9e7a2250-2ebb-4330-9b1d-93cf19979426">
        <source>validate() : Boolean;
// ---------------------------------------------------------------------------
// Created:     18 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//Transactions can be applied to BOLs with no ti's
	if self.myTrackedItem = null and self.myBOL = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'tracked item', null, null);
		app.raiseCMException(Input_required_field_trkdItem, null, null); 
		return false;
	endif;
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
		return false;
	endif;
	
	if (not self.dateTime.isValid) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'date/time', null, null);
		app.raiseCMException(Input_required_field_dateTime, null, null); // cnwdb2	PAR 35364


		return false;
	elseif self.myTrackedItem &lt;&gt; null then
		if (not self.myTrackedItem.validateTransactionDT(self.dateTime)) then
			return false;
		endif;		
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
