    <JadeMethod name="runTest" id="5b9b6e4b-191a-4fb0-be15-79667082cc4d">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('rp002_CN_lstTest_click');
	sa.add('rp004_CN_lstTest_dblClick');
	sa.add('rp006_CN_lstTest_click');
	sa.add('rp008_CN_lstTest_dblClick');
	sa.add('rp010_CN_lstTest_click');
	sa.add('rp012_CN_lstTest_dblClick');
	sa.add('rp014_YTPF_btnSelectAreclick');
	sa.add('rp016_CN_lstTest_click');
	sa.add('rp018_CN_lstTest_click');
	sa.add('rp020_CN_lstTest_dblClick');
	sa.add('rp999_tidyUp');

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
