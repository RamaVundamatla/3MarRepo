    <JadeMethod name="initSearchForLC" id="71bc4937-d411-46f2-97f9-c6317a1ddd58">
        <source>initSearchForLC(_yaAgent : CM_YAAutoplanAgent input) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwer1	Initial creation

*/

vars
	lc  : CM_LocationsController;
	
	noOfLCsThatShouldBeFree : Integer;
	gridRow : CM_GridRow;
	yc : CM_YardController;
	useSARules : Boolean;
begin
	if _yaAgent.myCurrentSpecificTA &lt;&gt; null and _yaAgent.myCurrentSpecificTA &lt;&gt; self.myTerminalArea then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Skipping block as not in specified terminal area ' &amp; _yaAgent.myCurrentSpecificTA.id, true);
		return false;
	endif;
	
	//epr par 19116 18/3/09 if range is closed then skip
	if not self.isOpen then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Skipping range ' &amp; self.getDisplayDetails(false) &amp; ' status is closed', true);
		return false;
	endif;
	
	
	// Clear working sets.
	_yaAgent.myCurrentCMIFYAAutoPlan.allPassedLocations.clear();
	_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.clear();
	//23 Jan 2015	NDL	Par 35547 - don't clear here, otherwise we potentially lose the first restricted position.
	//_yaAgent.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.clear(); //cnwrd1 par 29269 14.3.2012
	_yaAgent.allLCsToIgnore.copy(_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations);
	
	// Don't process locations that ti is sitting on.
	if _yaAgent.myCurrentCMIFYAAutoPlan.allLocations &lt;&gt; null then
		foreach lc in _yaAgent.myCurrentCMIFYAAutoPlan.allLocations do
			if not _yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.includes(lc) then
				_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.add(lc);
			endif;
		endforeach;
	endif;
	
	//cnwjo3, par 22472.  Don't process locations that have not enough free space, which is defined
	//in the overstow rule 'Number of Free 20ft Spaces'.
	noOfLCsThatShouldBeFree := _yaAgent.numberOfFreeSpacesRequired;
	if noOfLCsThatShouldBeFree &gt; 0 then  //only enter loop if freespace is an issue.  Ie, need at least 1 space
		if self.myTerminalArea &lt;&gt; null then
			if self.myTerminalArea.isKindOf(CM_GridArea) then
				if not self.myTerminalArea.CM_GridArea.useSideAccessRules then
					useSARules := true;
				endif;
			endif;
		endif;
		
		if self.isKindOf(CM_YABlockGridArea) and useSARules then
			foreach gridRow in self.CM_YABlockGridArea.allGridRows discreteLock do
				if not gridRow.testForFreeSpaceYA(_yaAgent) then   //test free space.  false = not enough free space, true = enough space.  If there is not enough free space we want to remove all the cells (ie: set to FailedLocation) that are in the Row
					foreach yc in self.allYardControllers discreteLock do  //go through all the YardControllers and add them to the allFailedLocations.  THIS IS SLOW!  ie: multiple YardControllers for a single row!
						if yc.isKindOf(CM_GridController) then
							if yc.CM_GridController.myGridRow = gridRow then
								_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.add(yc);   //using allFailedLocations since allLCsToIgnore does not appear to work..
								//_yaAgent.allLCsToIgnore.add(yc);
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endif;
	
	_yaAgent.resetTempLastResort();
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
