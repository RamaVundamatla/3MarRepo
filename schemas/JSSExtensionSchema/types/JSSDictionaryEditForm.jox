    <JadeMethod name="btnAdd_click" id="9674065f-4ec1-46f5-af7b-c590dbd6e911">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		09 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	self.aIsNew	:=	true;
	
	if self.doFormUpdate(false) then
		txtName.text	:=	null;
		self.enableButtons();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="f464ea80-624e-4de1-ab19-1f0e84f721a5">
