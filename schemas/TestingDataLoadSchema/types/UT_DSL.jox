    <JadeMethod name="addDebtor" id="9b02e32f-08e0-44b7-b182-47a9c101415a">
        <source>addDebtor(_name : String) : CM_DebtorNode;
// 09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
vars
	count	: Integer;
	root	: CM_Root;
	bank : CM_Bank;
	rdg	 : CM_RootDebtorGroup;
	agent		: CM_CustomsAgent;
	carrier		: CM_Carrier;
	consign		: CM_ConsigneeConsignor;
	debtorType	: CM_DebtorType;
	operator	: CM_Operator;

	debtorNode	: CM_DebtorNode;
	proxyDebtor	: CM_Debtor;
	debtorNodeController	: CMIF_DebtorNode;

begin
	create debtorNodeController transient;
	create proxyDebtor transient;
	root := app.myRoot;
	bank := root.myRootCompany;
	rdg := bank.getRootDebtorGroup();
	
	count := 0;
	foreach carrier in root.allCarriers do
		count := count + 1;
		if count &gt; 3 then
			break;
		endif;
		debtorNodeController.allCarriers.add(carrier);
	endforeach;
	count := 0;
	foreach consign in root.allConsigneeConsignors do
		count := count + 1;
		if count &gt; 3 then
			break;
		endif;
		debtorNodeController.allConsignors.add(consign);
	endforeach;
	count := 0;
	foreach agent in root.allCustomsAgents do
		if agent.myDebtor = null then
			count := count + 1;
			if count &gt; 3 then
				break;
			endif;
			debtorNodeController.allCustomsAgents.add(agent);
		endif;
	endforeach;
	count := 0;
	foreach debtorType in root.allDebtorTypes do
		if not debtorType.isSystemGenerated() then
			count := count + 1;
			if count &gt; 3 then
				break;
			endif;
			debtorNodeController.allDebtorTypes.add(debtorType);
		endif;
	endforeach;
	count := 0;
	foreach operator in root.myRootCompany.rootDebtor.operators do
		count := count + 1;
		if count &gt; 3 then
			break;
		endif;
		debtorNodeController.allOperators.add(operator);
	endforeach;
	
	debtorNodeController.allSpecialReleaseTxnTypes.add(TRANS_TYPE_ReeferDaily);
	debtorNodeController.allSpecialReleaseTxnTypes.add(TRANS_TYPE_ReeferFlatRate);
	debtorNodeController.isPurchaseOrderMandatory := true;
	debtorNodeController.billingAddress := "123 Anywhere St" &amp; CrLf &amp; "Some town" &amp; CrLf &amp; "4321 Nowhere";
	debtorNodeController.decfinName := "Test 123456";
	debtorNodeController.isSuspended := false;
	debtorNodeController.isZeroRated := false;
	debtorNodeController.badDebtor := false;
	debtorNodeController.myBank := bank;
	debtorNodeController.myTermsOfTrade := null ; // CM_InvoiceTermsOfTrade.instances.first;
	
	debtorNodeController.myParentDebtorNode := null;
	debtorNodeController.myParentDebtorNode := rdg;

	debtorNodeController.myPxyDebtorNode := proxyDebtor;
	proxyDebtor.setProxySuspend(debtorNodeController.isSuspended);
	debtorNodeController.name := _name;
	debtorNodeController.purchaseOrderCode := "P/O 321";
	debtorNodeController.remarks := "Some random remarks";
	debtorNodeController.doDebtorInvoiceTypes := true;
	debtorNodeController.doDebtorInvoiceLineTypes := true;
	
	//proxyDebtor.setProxy(debtorNodeController.name);								// TFS 40092
	proxyDebtor.setProxy(debtorNodeController.name, debtorNodeController.code);		// TFS 40092
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);

	return debtorNode;
epilog
	delete debtorNodeController;
	delete proxyDebtor;
end;

</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="addDebtorType" id="d50da3f4-8e1f-4509-96d6-ec65903bef51">
        <source>addDebtorType(_debtorTypeCode, _debtorTypeDesc : String) : CM_DebtorType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 January 2012	cnwmh5	Initial creation

*/

vars

