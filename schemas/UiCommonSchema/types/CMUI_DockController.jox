    <JadeMethod name="buildDockBars" id="2f36bf35-d54f-4c84-a86a-1eeb6a5a9afe">
        <source>buildDockBars();

vars
	controlIdx,
	i : Integer;
	dockBar : JadeDockBar;
	control , clonedControl : Control;
	controlArray : CnEcControlArray;
begin
	create controlArray transient;
	myBaseDockBar.cnEcGetAllChildControls(controlArray, true);
	i:=1;
	while i &lt;= self.numberOfDockBars do	
		dockBar:=null;
		if i &lt;= self.allDockBars.size then
			dockBar:=self.allDockBars[i].JadeDockBar;
		endif;
		if dockBar = null then
			dockBar:=myBaseDockBar.loadControl(i).JadeDockBar;	
			dockBar.ignoreSkin:=true;
			self.allDockBars.add(dockBar);
			dockBar.parent:=self.myBaseDockContainer;
			foreach control in controlArray where control.parent = myBaseDockBar do
					clonedControl:=null;
					controlIdx:= (((self.numberOfDockBars - i)+1).String &amp; control.tabIndex.String).Integer;
					
					// index equals index of allDockBars which points to an object and the control.tabIndex
					clonedControl:=control.loadControl(controlIdx);
					
					//write clonedControl.String &amp; " " &amp;  controlIdx.String;
					clonedControl.parent:=dockBar;
					clonedControl.parentBottomOffset:=0;
					clonedControl.parentRightOffset:=0;
					clonedControl.visible:=true;
			endforeach;
		
		endif;
		i:=i+1;
	endwhile;
	
	self.getTilePlan();
	
epilog
	delete controlArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="1c8e77c7-3af3-4646-a00f-d47b24ba74b4">
        <updating/>
        <source>delete() updating;
/*

Date		Who		Reason
17 March 2017	cnwer1	Initial creation TFS

*/

vars

begin
	self.allDockBars.purge;
	
	self.allDockContainers.remove(self.myBaseDockContainer);
	
	self.allDockContainers.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowAllAreas" id="83d10f48-3fa6-4fe0-b920-58908d403264">
        <updating/>
        <source>doShowAllAreas() updating;
/*
Date		Who		Reason
26 September 2006	cnwer1	Initial creation - PAR#xxxx
*/
vars
	area,i : Integer;

begin
	i:=1;
	while i &lt;= self.numberOfDockBars do
		self.showHideArea(i,true);
		i:=i+1;
	endwhile;
	
	self.resizeWidths();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTiled" id="197d2c93-1e26-41bb-97a5-cdb592d58d7d">
        <source>doTiled();

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 July 2006	cnwer1	Initial creation - PAR#xxxx

*/


vars
	i, j, k,
	dcHeight, row : Integer;
	dockBar 	: JadeDockBar;
	parentContainer : JadeDockContainer;
begin
	parentContainer:=self.myBaseDockContainer;
	dcHeight:= ((areaHeight * self.dockAreaHeightPCent)/100).Integer;
	//dcHeight:=(areaHeight/tilePlan.size).truncated;
	
	k:=1;
	row:=1;
	foreach i in tilePlan do
		j:=0;
		while j &lt; i do	
			if row &gt; allDockContainers.size then
				parentContainer:=self.myBaseDockContainer.loadControl(row).JadeDockContainer;	
				parentContainer.ignoreSkin:=true;
				self.allDockContainers.add(parentContainer);
			else
				parentContainer:=allDockContainers[row].JadeDockContainer;
			endif;
			parentContainer.visible:=true;
			parentContainer.refreshNow();
			dockBar:=allDockBars[k].JadeDockBar;
			dockBar.parent:=parentContainer;
			if tiled then
				dockBar.alignContainer:=JadeDockBase.AlignContainer_AllVertical;
			else
				dockBar.alignContainer:=JadeDockBase.AlignContainer_AllHorizontal;
			endif;
			k:=k+1;
			j:=j+1;
		endwhile;
		row:=row + 1;
	endforeach;
	
	//resize tile widths don't know why but if i did it in the above loop it doesn't work
	//self. resizeWidths();

epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="getTilePlan" id="e91f7d06-40b2-4630-81e6-3b74e058ee5b">
        <source>getTilePlan();

/*

Purpose:	Creates a tile plan which is simple an integer array each integer is a row and the integer value is the number of columns

			if tiled it will try to create a nice tile plan ...
				e.g. 3 x 3  4 x 4 etc if remaining dock bars to add will add from the bottom up so would be 3,3,4 
				
			if not just 1 column per row		


Return Value:		


Date		Who		Reason
28 July 2006	cnwer1	Initial creation - PAR#xxxx

*/

vars
	num,
	i,  k, h,v : Integer;
	x,y , rem 	: Real;
begin
	num:=self.allDockBars.size;
	if num = 0 then
		return;
	endif;
	
	if tiled then
		x:= num.Real.sqrt;
		if x.Integer = x then
			y:=x.Integer;
		else
			y:=num div x;
			rem:= num - (x.Integer * y);
		endif;
	
		h:=x.Integer.max(y.Integer).Integer;
		v:=x.Integer.min(y.Integer).Integer;
	
		tilePlan[v]:=null;
		
		k:=1;
		
		i:= v;
		while i &gt; 0 do
			if rem &gt; 0 then
				rem:= rem - 1;
			else
				k:= 0;
			endif;
			tilePlan[i]:=h  +  k;
			i:=i -1;
		endwhile;
	else
		i:=1;
		while i &lt; num do			
			tilePlan[i]:=1;
			i:=i+1;
		endwhile;
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initController" id="8fc3dcc4-236f-42ec-9735-c8c394e81ee2">
        <updating/>
        <source>initController(	_baseDockBar	: JadeDockBar input;
				_baseDockContainer : JadeDockContainer input;
				_numberOfDockBars		: Integer ;
				_dockAreaHeightPCent : Real;
				_tiled			: Boolean) updating;

/*

Purpose:	myBaseDockContainer is added as the base client area
			if more are needed this is the container that is cloned
			
			myBaseDockBar is the base dockbar that is cloned its properties should be added before this is initialised.


Return Value:		


Date		Who		Reason
28 July 2006	cnwer1	Initial creation - PAR#xxxx

*/

vars

begin
	self.tiled := _tiled;
	self.myBaseDockBar:=_baseDockBar;
	self.myBaseDockContainer:=_baseDockContainer;
	self.areaHeight:=_baseDockContainer.clientHeight;
	self.dockAreaHeightPCent := _dockAreaHeightPCent;
	self.allDockContainers.add(_baseDockContainer);
	self.numberOfDockBars := _numberOfDockBars;
	
	
end;</source>
        <Parameter name="_baseDockBar" type="JadeDockBar" usage="input"/>
        <Parameter name="_baseDockContainer" type="JadeDockContainer" usage="input"/>
        <Parameter name="_numberOfDockBars" type="Integer"/>
        <Parameter name="_dockAreaHeightPCent" type="Real"/>
        <Parameter name="_tiled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resizeWidths" id="e7890a62-7f54-4a49-a48b-d6c5c35657b0">
        <source>resizeWidths();
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 August 2006	cnwer1	Initial creation - PAR#xxxx

*/

vars
	numDBs,
	row,i,j,col,
	numColumns,numVisible,
	numColVisible: Integer;
	parentContainer : JadeDockContainer;
	dockBar: JadeDockBar;
	areaHeight: Integer;
begin
			
	i:=1;
	j:=1;
	row:=1;
	numDBs:= self.allDockBars.size;
	foreach row in 1 to self.tilePlan.size reversed do
		numColumns:=numColumns + self.tilePlan[row];
		numVisible:=0;
		
		foreach col in i to numColumns do
			dockBar:= self.allDockBars[(numDBs - i)+1].JadeDockBar;
			
			numVisible:=numVisible + dockBar.visible.Integer;
			parentContainer:=dockBar.parent.JadeDockContainer;
				
			i:=i+1;
		endforeach;	
		parentContainer.visible:=numVisible &lt;&gt; 0;
		numColVisible:=numColVisible + parentContainer.visible.Integer;
		if parentContainer.visible  then
			foreach col in j to numColumns do
				dockBar:= self.allDockBars[(numDBs - j)+1].JadeDockBar;
							
				dockBar.width:=(parentContainer.clientWidth/numVisible).truncated;
				j:=j+1;
			endforeach;	
		endif;
		j:=i;
	endforeach;
	
	
	parentContainer:=self.allDockContainers[1].JadeDockContainer;
	areaHeight:= ((parentContainer.parent.height * self.dockAreaHeightPCent)/100).Integer;
	if numColVisible &lt;&gt; 0 then
		areaHeight:=(areaHeight/numColVisible).Integer;
	endif;
	foreach row in 1  to self.tilePlan.size reversed do
		parentContainer:=self.allDockContainers[row].JadeDockContainer;
		if parentContainer.visible then
			parentContainer.height:=areaHeight;	
		endif;
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="setDockAreaHeightPCent" id="2fbc0ca4-080e-4dc3-83bc-1db9f4d37560">
        <updating/>
        <source>setDockAreaHeightPCent(_value : Integer) updating;
/*

Date		Who		Reason
17 March 2017	cnwer1	Initial creation TFS

*/

vars

begin
	self.dockAreaHeightPCent := _value;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTiled" id="63c60bc1-3f88-4ac5-b05c-bc84f5c7d99e">
        <updating/>
        <source>setTiled(_value : Boolean) updating;

vars

begin
	self.tiled := _value;
	
	self.doTiled();
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideArea" id="de0b1150-6701-4bc7-846c-7b76065e2ecd">
        <updating/>
        <source>showHideArea(_area : Integer;_value : Boolean)  updating;
/*

Date		Who		Reason
17 March 2017	cnwer1	Initial creation TFS

*/

vars
	db					: JadeDockBar;
begin
	if self.allDockBars.size &lt; _area then
		return;
	endif;
	db := self.allDockBars[(self.allDockBars.size - _area) + 1].JadeDockBar;
	if db &lt;&gt; null then
		db.visible:=_value;
	endif;
epilog

end;</source>
        <Parameter name="_area" type="Integer"/>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
</Class>
