    <JadeMethod name="btnShowInvoice_click" id="373d6a00-a3b4-47cb-8a6c-05b11f6d34fb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnShowInvoice_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		28 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theInv : CM_Invoice;
begin
	theInv := self.myCurrentInvoice;
	if theInv = null 
	and self.myCurrentInvoiceLine &lt;&gt; null then
		theInv := self.myCurrentInvoiceLine.invoice;
	endif;
	
	if theInv = null then
		app.msgBox("Please select an invoice line.","Invoice Warning",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.myAssistant.INV_Assistant.showInvoiceListForm(theInv, self.myMasterMenuAction, false);		

////	self.doShowInvoice();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canBeConverted" id="e33adeac-f3a0-4199-850b-70ab0b7dc80c">
        <source>canBeConverted() : Boolean;
/*

Date		Who		Reason
25 September 2015	cnwer1	Initial creation PAR 36958

*/

vars
	obj : Object;
	invLine : CM_InvoiceLine;
	canBeConverted : Boolean;
begin
	canBeConverted:=true;
	foreach obj in self.tblData.allSelectedObjects do        //22/09/2015 cnwma1 PAR #36506
		if  obj.isKindOf(CM_InvoiceLine) then
			invLine:=obj.CM_InvoiceLine;
			if invLine.invoice.isPosted
				or invLine.invoice.isVoided
				or invLine.status  = CM_InvoiceLine.STATUS_VOIDED then	
				canBeConverted:=false;
			endif;
		else
			canBeConverted:=false;
		endif;
	endforeach;	
	
	return canBeConverted;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDropInvoiceLine" id="6c97a1ae-789e-407e-8a60-91640ea15464">
        <source>canDropInvoiceLine(win : Window input; table : Window input) : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	form : INV_ListLines;
	anInvoiceLine, canInvoiceLine : CM_InvoiceLine;
	theInvoice : CM_Invoice;
	currentInvoiceSeqNum : Integer;
begin
	if table = self.tblData then
		if win.isKindOf(Form) and win.Form.isKindOf(INV_ListLines) and win.Form &lt;&gt; self then
			form := win.INV_ListLines;
			//check that we a viewing invoices only.
//			if mode = MODE_INVOICE and form.mode = MODE_INVOICE then
				anInvoiceLine := form.myCurrentInvoiceLine;
				theInvoice := self.myCurrentInvoice; //bank.allInvoices[currentInvoiceSeqNum];
				currentInvoiceSeqNum := theInvoice.sequenceNum;
				if anInvoiceLine &lt;&gt; null and theInvoice &lt;&gt; null then
					if anInvoiceLine.invoice.sequenceNum &lt;&gt; currentInvoiceSeqNum 
					and not anInvoiceLine.invoice.isPosted 
				//	and theInvoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED
					and not theInvoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759
					then
						return true;
					else
						return false;
					endif;
				else
					return false;
				endif;
//			else
//				return false;
//			endif;
		else
			return false;
		endif;
	else
		return false;
	endif;

end;</source>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="table" type="Window" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
