    <JadeMethod name="add" id="b69cda04-c722-4fad-aa51-7dbee2bffebb">
        <source>add(pValue:Any; pDimension:Integer);
// --------------------------------------------------------------------------------
// Created:		17 December 2005 by cnwdad1
//
// Purpose:		Adds an entry to the end of the array.
//
// Parameters:	pValue - The value to added to the array.
//				pDimension - The dimension to add the value to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return;
	endif;
	
	self.getArray(pDimension).add(pValue);
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pDimension" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="at" id="15680d80-5a58-475d-aad4-1ec386694806">
        <source>at(pIndex:Integer; pDimension:Integer):Any;
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Returns the entry at a specified index in the array.
//
// Parameters:	pIndex - The element index of the value to return.
//				pDimension - The dimension to fetch the value from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return null;
	endif;
	
	return self.getArray(pDimension).at(pIndex);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pDimension" type="Integer"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="atPut" id="0b072510-51f2-45db-9799-b488f1741efc">
        <source>atPut(pIndex:Integer; pValue:Any; pDimension:Integer);
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Places an entry at a specified index in the array.
//
// Parameters:	pIndex - The element index to put the value.
//				pValue - The value to put in the element.
//				pDimension - The dimension to put the value into.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return;
	endif;
	
	self.getArray(pDimension).atPut(pIndex, pValue);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pDimension" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="countOf" id="51e91711-e564-4df1-85f4-1c69c0b7dc27">
        <source>countOf(pValue:Any; pDimension:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Returns the number of times the specified entry occurs in the array.
//
// Parameters:	pValue - The value who's count to return.
//				pDimension - The dimension to get the value count from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return 0;
	endif;
	
	return self.getArray(pDimension).Array.countOf(pValue);
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pDimension" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="29db7f30-33e6-47d3-9ec7-37aa3ac4b245">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		17 December 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayObj	: Object;
	
begin
	foreach arrayObj in self.allArrays do
		arrayObj.Array.purge();
	endforeach;
	
	self.allArrays.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="first" id="830e23ca-5c17-41e0-859a-e268f9002f30">
        <source>first(pDimension:Integer):Any;
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Returns the first entry in the array.
//
// Parameters:	pDimension - The dimension to fetch the first element from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return null;
	endif;
	
	return self.getArray(pDimension).Array.first();
end;</source>
        <Parameter name="pDimension" type="Integer"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getArray" id="013bd1a5-d11c-48a8-9f95-47cd132774bf">
        <source>getArray(pDimension:Integer):Array;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		Returns the array for the specified dimension.
//
// Parameters:	pDimension - The dimension of the array to return.
//
// Returns:		An array for the specified dimension, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.allArrays.at(pDimension).Array;
end;</source>
        <Parameter name="pDimension" type="Integer"/>
        <ReturnType type="Array"/>
    </JadeMethod>
    <JadeMethod name="getDimensionAsString" id="86b5cd5f-52e1-469b-b420-cc4a036a7d25">
        <source>getDimensionAsString(pDimension:Integer; pIndex:Integer; pDelimiter:String):String;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		Returns one array dimension as a delimited string.
//
// Parameters:	pDimension - The dimension who's element to string together.
//				pIndex - The index of the elements to fetch.
//				pDelimiter - Separates each of the element values.
//
// Returns:		The delimited string of elements.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayObj	: Array;
	element		: Any;
	returnValue	: String;
	
begin
	arrayObj	:=	self.getArray(pDimension);
	
	foreach element in arrayObj do
		if returnValue = null then
			returnValue	:=	element.String;
		else
			returnValue	:=	returnValue &amp; pDelimiter &amp; element.String;
		endif;
	endforeach;
	
	return returnValue;
end;</source>
        <Parameter name="pDimension" type="Integer"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pDelimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getElementAsString" id="dee68658-d6b1-4421-b437-f1cd001a7f97">
        <source>getElementAsString(pIndex:Integer; pDelimiter:String):String;
// --------------------------------------------------------------------------------
// Created:		06 February 2006 by cnwdad1
//
// Purpose:		Returns one multi-dimension element as a delimited string.
//
// Parameters:	pIndex - The index of the element to fetch.
//				pDelimiter - Separates each of the element values.
//
// Returns:		The delimited string of elements.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayObj		: Array;
	dimension		: Integer;
	dimensionCount	: Integer;
	returnValue		: String;
	
begin
	dimensionCount	:=	self.dimensions;
	arrayObj		:=	self.getArray(1);
	
	foreach dimension in 1 to dimensionCount do
		if returnValue = null then
			returnValue	:=	self.at(pIndex, dimension).String;
		else
			returnValue	:=	returnValue &amp; pDelimiter &amp; self.at(pIndex, dimension).String;
		endif;
	endforeach;
	
	return returnValue;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pDelimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includes" id="ca66ef0a-b553-43ac-aa04-d9939f5ecbcd">
        <source>includes(pValue:Any; pDimension:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Returns true if the array contains a specified object.
//
// Parameters:	pValue - The value to check for.
//				pDimension - The dimension to check for the value in.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return false;
	endif;
	
	return self.getArray(pDimension).includes(pValue);
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pDimension" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="indexOf" id="4212e252-cacf-443a-89fc-3aa750d9aaff">
        <source>indexOf(pValue:Any; pDimension:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Returns the index of a specified entry if it exists in the array.
//
// Parameters:	pValue - The value who's element index to return.
//				pDimension - The dimension to fetch the index from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return 0;
	endif;
	
	return self.getArray(pDimension).indexOf(pValue);
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pDimension" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="6c951d1b-5ba2-43e4-8d5c-ba09c0e0f5f9">
        <updating/>
        <source>initializeMe(pType:Type; pDimensions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		17 December 2005 by cnwdad1
//
// Purpose:		Initializes the receiver by instantiating each array dimension.
//
// Parameters:	pType - A reference to the Type of the Array.
//				pDimensions - The number of dimensions to create of the specified type.
//
// Returns:		True if the receiver was successfully initialized, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isTransient		: Boolean;
	arrayPointer	: Integer;
	arrayObj		: Array;
	
begin
	if pDimensions &lt; 1 then
		CnEcBaseSchemaException.raise_(CNEC_X_86000, "There must be at least one (1) dimension.");
		return false;
	endif;
	
	if not pType.inheritsFrom(Array) then
		CnEcBaseSchemaException.raise_(CNEC_X_86001, "Invalid array Type.");
	endif;
	
	self.dimensions	:=	pDimensions;
	self.myType		:=	pType;
	isTransient		:=	self.isTransient();
	
	foreach arrayPointer in 1 to pDimensions do
		if isTransient then
			create arrayObj as pType.Class transient;
		else
			create arrayObj as pType.Class persistent;
		endif;
		
		self.allArrays.add(arrayObj);
	endforeach;
end;</source>
        <Parameter name="pType" type="Type"/>
        <Parameter name="pDimensions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="insert" id="98e90511-9267-447b-812a-3e19563e9d17">
        <source>insert(pIndex:Integer; pValue:Any; pDimension:Integer);
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Inserts an entry at a specified index in the array and moves up all higher entries.
//
// Parameters:	pIndex - The element index to insert the value at.
//				pValue - The value to insert at the specified index.
//				pDimension - The dimension to insert the value into.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return;
	endif;
	
	self.getArray(pDimension).insert(pIndex, pValue);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pDimension" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="last" id="02db845a-0f23-47a6-8f4c-d76f1a6b5973">
        <source>last(pDimension:Integer):Any;
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Returns the last entry in the array.
//
// Parameters:	pDimension - The dimension to return the last element of.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return null;
	endif;
	
	return self.getArray(pDimension).last();
end;</source>
        <Parameter name="pDimension" type="Integer"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="remove" id="28cf9fa2-587b-4a92-ae7f-38a08fcfc818">
        <source>remove(pValue:Any; pDimension:Integer);
// --------------------------------------------------------------------------------
// Created:		17 December 2005 by cnwdad1
//
// Purpose:		Removes a specified entry from an array, and moves all higher entries
//				down.
//
// Parameters:	pValue - The value to remove from the array.
//				pDimension - The dimension to remove the value from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return;
	endif;
	
	self.getArray(pDimension).remove(pValue);
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pDimension" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeAt" id="0375879a-3eaf-40a3-af7e-db7bb63a8d3c">
        <source>removeAt(pIndex:Integer; pDimension:Integer):Any;
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Removes an entry at a specified index from an array, and moves all
//				higher entries down.
//
// Parameters:	pIndex - The index of the element to remove.
//				pDimension - The dimension to remove the element from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return null;
	endif;
	
	return self.getArray(pDimension).Array.removeAt(pIndex);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pDimension" type="Integer"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="replace" id="3b83242b-0e90-4b64-9b0d-8fb9b46ab9bd">
        <source>replace(pIndex:Integer; pValue:Any; pDimension:Integer);
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		Replaces an existing entry in an array with another entry.
//
// Parameters:	pIndex - The element index of the value to replace.
//				pValue - The value to replace in the element.
//				pDimension - The dimension to replace the element in.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.validateDimension(pDimension) then
		return;
	endif;
	
	self.getArray(pDimension).replace(pIndex, pValue);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pDimension" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateDimension" id="87bc6c4c-30e0-410a-8b59-3dc3652b80c6">
        <source>validateDimension(pDimension:Integer):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		Checks whether the specified dimension is valid, and raises an exception
//				if not.
//
// Parameters:	pDimension - The dimension to validate.
//
// Returns:		True if the dimension is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pDimension &lt; 1 then
		CnEcBaseSchemaException.raise_(	CNEC_X_86000,
										"The array dimension must be greater than zero.");
		
		return false;
	elseif pDimension &gt; self.dimensions then
		CnEcBaseSchemaException.raise_(	CNEC_X_86000,
										"This array only has " &amp; self.dimensions.cnEcNumberFormat() &amp; " dimensions.");
		
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pDimension" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xxx" id="b87be614-6328-4299-ae6f-e5fc55ccd6a4">
        <source>xxx(pDimension:Integer; pElements:ParamListType) protected;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementCount	: Integer;
	elementIndex	: Integer;
	elementValue	: Any;
	
begin
	elementCount	:=	app.getParamListTypeLength(pElements);
	
	foreach elementIndex in 1 to elementCount do
		app.getParamListTypeEntry(elementIndex, pElements);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pDimension" type="Integer"/>
        <Parameter name="pElements" type="ParamListType"/>
    </JadeMethod>
</Class>
