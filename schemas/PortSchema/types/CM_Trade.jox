    <JadeMethod name="getAuditText" id="f8e70e4f-d45c-45d1-a3b0-9c9cf683b67f">
        <source>getAuditText(): String;

vars
	txt		: String;
	tmpStr	: String;
	oper	: CM_Operator;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach oper in self.operators do
		if tmpStr = null then
			tmpStr := oper.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; oper.code;
		endif;
	endforeach;
	txt := txt &amp; 'Selected Operators' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="e9167327-2b84-4c03-84a5-9e44a3e342ee">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.description;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2c90afb9-fbd0-491c-b9cb-da6decdf81f7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2014	cnwdb2	Initial creation

*/

vars

begin

	if _attrName = ETRow_OrderNo then
		return self.order.String ; 
	elseif _attrName = ETRow_NotAvailableForEntry then
		return self.isNotAvailableForEntry.String ; 
	endif;



	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
