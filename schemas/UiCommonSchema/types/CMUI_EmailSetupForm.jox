    <JadeMethod name="setFreeText" id="202af8ca-f97e-4465-bdfc-56579fc1a45e">
        <updating/>
        <source>setFreeText(_row : Integer; _freeText : String) protected, updating;
// -------------------------------------------
// Created 05 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if _row = 1 then
		self.allFreeTextToAddresses := _freeText;
	elseif _row = 2 then
		self.allFreeTextCCAddresses := _freeText;
	elseif _row = 3 then
		self.allFreeTextBCCAddresses := _freeText;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_freeText" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="14325b39-1695-4ef3-aa30-ff27637a09bc">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

	entTableDef : EntTableDef;
	str			: String;

begin
	inheritMethod();
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	entTableDef := app.myController.getEntTableDef(ETDef_EmailSetupMaint);
	self.tblEmail.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.tblEmail.resetSize();
	self.resize();
	self.frSelector.centreHorizontallyInParent();
	self.frSelector.centreVerticallyInParent();
//	self.setupListTable();
	self.frSelector.visible := false;
	self.tblEmail.setFocus();
	self.tblEmail.moveFirst();
	
	self.myEmail.allToAddresses.copy(self.allToAddresses);
	self.myEmail.allCCAddresses.copy(self.allCCAddresses);
	self.myEmail.allBCCAddresses.copy(self.allBCCAddresses);

	str := self.myEmail.getAllToAddressesOrNames(true);
	self.tblEmail.setValueByName(ETRow_EmailToAddresses, str);
	
	str := self.myEmail.getAllCCAddressesOrNames(true);
	self.tblEmail.setValueByName(ETRow_EmailCarbonCopy, str);
	
	str := self.myEmail.getAllBCCAddressesOrNames(true);
	self.tblEmail.setValueByName(ETRow_EmailBlindCarbonCopy, str);
	
	self.txtSubject.text := self.myEmail.subject;
	self.txtBody.text := self.myEmail.body;
	
	self.tblEmail.setValueByName(ETRow_UseExtraInfo, self.myEmail.useExtraInfoInSubjectLine);
	
	if not self.showExtraInfo then
		self.tblEmail.hideRowByName(ETRow_UseExtraInfo, false);
	endif;
		
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupListTable" id="aba46724-31d4-4333-a014-9b0fd0481894">
        <source>setupListTable() protected;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

	obj			: Object;
	entity		: CM_EmailEntity;
	type		: String;

begin

	self.allEmailEntities.setMembership(CM_EmailEntity);
	self.allEmailEntities.addMemberKey("name", false, true);
	self.allEmailEntities.endKeys(true);
	
	app.myRoot.allEmailEntities.copy(self.allEmailEntities);
	
	// Need this so all objects are loaded at once.
	foreach obj in self.allEmailEntities do
		entity := obj.CM_EmailEntity;
		if entity.type = Email_Group then
			type := ' (Email Group)';
		else
			type := ' (' &amp; entity.getEmailAddress() &amp; ')';
		endif;
		self.lstAddresses.addItemObject(entity.name &amp; type, entity);
	endforeach;
	
//	self.lstAddresses.displayCollection(self.allEmailEntities, false, 0, null);

end;</source>
        <access>protected</access>
    </JadeMethod>
