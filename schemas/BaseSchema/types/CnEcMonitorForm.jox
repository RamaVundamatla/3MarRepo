    <JadeMethod name="btnClearExclude_click" id="b9cbbd3f-e72a-4a81-b195-5f405bbfe11e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClearExclude_click(btn: Button input) updating;

begin
	cmbExclude.listIndex	:=	CNEC_NULL_INDEX;
	tblExclude.rows			:=	2;
	tblExclude.column		:=	1;
	tblExclude.row			:=	2;
	tblExclude.text			:=	null;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
