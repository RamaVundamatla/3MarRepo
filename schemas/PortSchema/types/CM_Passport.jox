    <JadeMethod name="isOkToCommit" id="bc6f8810-eed8-4ea9-9dc2-0a5dae1ab78e">
        <updating/>
        <source>isOkToCommit(_ignoreErrors : Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// // PAR 17703 AKB2008SEP
// ---------------------------------------------------------------------------
vars
	warningsOK	: Boolean;
	isOk2IgnoreAllErrors : Boolean;
begin
	if _ignoreErrors then
		isOk2IgnoreAllErrors := self.isOkToIgnoreAllErrors(); // PAR 17703 AKB2008SEP
	endif;
	
	if self.noErrors
	and process.isInTransactionState then
	

		/*
		Not done here as this is called from the epilog which
		could cause a problem
		
		if self.noErrors then
			self.updateTIsForDeferUpd();
		endif;
		if self.noErrors then
			self.updateTITransForDeferUpd();
		endif;
		*/

		if self.raiseExIfDeferredUpdNotDone() then
			return false;
		endif;
	endif;

	if (self.allWarnings.size = self.numWarningsAtValidationStage) or self.warningsIgnored then
		warningsOK := true;
	else
		// More warnings have been created in the update process
		
		if self.debug then
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  savedWarnings = ' &amp; self.allSavedWarnings.size.String);
		endif;

		if (not self.warningsAcknowledged) then
			if self.debug then
				app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  update warnings found and warnings not acknowledged');
			endif;
			return false;
		endif;

		// need to check if these are the same as the previous and check
		if self.areWarningsSame() then
			warningsOK := true;
		else
			if self.debug then
				app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  update warnings found and are different');
			endif;
			return false;
		endif;
	endif;

	if (self.noErrors or isOk2IgnoreAllErrors)  // PAR 17703 AKB2008SEP
//	if self.noErrors 
	and
	   warningsOK and
	   self.status = TRXStatus_InComplete then
		return true;
	else
		if self.debug then
			self.dumpDetails('Trx Failed');
		endif;
		return false;
	endif;
	   
end;</source>
        <Parameter name="_ignoreErrors" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOkToIgnoreAllErrors" id="5645a4e1-416d-4c19-92aa-62efb80d139b">
        <source>isOkToIgnoreAllErrors() : Boolean;
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	anE : CM_Error;
begin
	// in the call to the TRX we can state which errors  are to be ignored so that the transaction does complete
	// if ALL of our errors are in the list then the transaction can complete
	

	if self.errorsToIgnore.isEmpty() then 
		return false;
	endif;
	
	foreach anE in self.allErrors discreteLock do
		if not self.errorsToIgnore.includes(anE.errorCode) then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOpsViewEnabled" id="2babfb6f-8c57-4649-bd6d-1ddaec53356a">
        <source>isOpsViewEnabled(_term : CM_Terminal) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1  ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
14/12/2021	navmh5	CR - 51855 - So testing's OpsView test can run correctly
*/

vars
	bgpRequest 		: BGP_OpsViewWSRequest;
	wsDef			: CM_OpsViewServiceDef;
	root			: CM_Root;
begin
	
	if app.isJMTUnitTest and not app.isNAVOpsviewTest() then
		return false;
	endif;
	
	if self.hasErrors then
		return false;
	endif;
	
	// Handle StarterDB re-initialise root
	root := app.myRoot;
	
	if root = null then
		return false;
	endif;	

	if not root.canDo(Sub_OpsView) then	
		return false;
	endif;
	
	wsDef := root.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;
	
	if wsDef = null then
		return false;
	endif;
	
	if _term &lt;&gt; null then
		if not _term.isOpsViewEnabled(wsDef) then
			return false;
		endif;
	endif;
	
	
	return true;
epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRetrospectiveWoEnabled" id="ccfd91b4-c429-48dc-a5cd-8b4d0f589c79">
        <source>isRetrospectiveWoEnabled():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Feb 2024 navma1	ChangeRequest 62084:[62375] EUP | Retrospective Operations - [54177.010] - Road Entry
08 Feb 2024 navhl20 ChangeRequest 62084:[62375] EUP | Retrospective Operations - [54177.010] - Road Entry
*/

vars
	
begin
	if  app.myRoot.canDo(Sub_RetroWorkOrder) then 				//08.02.2023 navhl20 #62084[62375]
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVASEnabled" id="7cebe3eb-d420-46db-9bcf-5bf7d229baf4">
        <source>isVASEnabled():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Dec 2022	navma1  ChangeRequest 56006: EUP - New VAS Workorder Subscription

*/

vars
	term : CM_Terminal;
begin
	if  app.myRoot.canDo(Sub_VASWorkOrder) then
		
		executeWhen JMTDevelopmentEnvironment;
			/*Temp solution for testing when VAS is NOT enabled */
			if process.isPW then
				return true;
			endif;
			
			term := self.myTerminal;
			if term &lt;&gt; null and (term.code = "MA"/* or term.code = "DAVE"*/) then
				return false;
			endif;
		endExecuteWhen;
		
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="logChangeState" id="3a498870-f2e3-457f-be3e-245470198cac">
        <source>logChangeState(_realTI	: CM_TrackedItem) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2025		navma1	Initial creation

*/
constants
	LOGLEVEL = LogINFO;
	LOGSTATE = 'logNoChangeState';
vars
	newState	: Integer;
	newSite		: Integer;
	oldSite		: Integer;
	oldState	: Integer;
	pxyTI       : CM_TrackedItem;
	isChanged	: Boolean;
	oIdString : String;
	old, new 	: String;
	
	
begin
	
	if not app.isJMTUnitTest then
		return;
	endif;
	
	if _realTI = null then
		return;
	endif;

	
	pxyTI := _realTI.pxyGetProxyObject();
	
	if pxyTI = null then
		return;
	endif;
	
	/*foreach prop in CM_TrackedItem.allProperties where prop.key do
		old := _realTI.getPropertyValue(prop.name).String;
		new := pxyTI.getPropertyValue(prop.name).String;
		if old &lt;&gt; new then
			isChanged := true;
			self.createLogForStateChange(isChanged,oIdString,prop.name,old,new,LOGLEVEL);
		endif;
	endforeach;*/
	
	
	newState    := pxyTI.state;
	newSite 	:= app.stateToSite(newState);
	oldSite		:= _realTI.site;		
	oldState 	:= _realTI.state;	
	
	oIdString		:= _realTI.getOidAsString();
	
	if newSite &lt;&gt; oldSite then
		isChanged := true;
		old := app.siteEnumToString(oldSite);
		new := app.siteEnumToString(newSite);
		self.createLogForStateChange(LOGSTATE,oIdString,'Site',old,new,LOGLEVEL);
	endif;
	
	if newState &lt;&gt; oldState then
		isChanged := true;
		old := app.stateEnumToString(oldState);
		new := app.stateEnumToString(newState);
		self.createLogForStateChange(LOGSTATE,oIdString,'State',old,new,LOGLEVEL);
	endif;
	
	if pxyTI.id &lt;&gt; _realTI.id then
		isChanged := true;
		old := _realTI.id;
		new := pxyTI.id;
		self.createLogForStateChange(LOGSTATE,oIdString,'Id',old,new,LOGLEVEL);
	endif;
	
	if pxyTI.alternativeId &lt;&gt; _realTI.alternativeId then
		isChanged := true;
		old := _realTI.alternativeId;
		new := pxyTI.alternativeId;
		self.createLogForStateChange(LOGSTATE,oIdString,'Alternative Id',old,new,LOGLEVEL);
	endif;
	
	if pxyTI.cargoType &lt;&gt; _realTI.cargoType then
		isChanged := true;
		old := _realTI.cargoTypeCode;
		new := pxyTI.cargoTypeCode;
		self.createLogForStateChange(LOGSTATE,oIdString,'CargoType Code',old,new,LOGLEVEL);
	endif;
	
	if pxyTI.getImExStatus() &lt;&gt; _realTI.getImExStatus() then
		isChanged := true;
		old := _realTI.getImExStatusString();
		new := pxyTI.getImExStatusString();
		self.createLogForStateChange(LOGSTATE,oIdString,'Imex',old,new,LOGLEVEL);
	endif;
	
	if pxyTI.myOperator &lt;&gt;_realTI.myOperator then
		isChanged := true;
		if _realTI.myOperator &lt;&gt; null then
			old := _realTI.myOperator.code;
		endif;
		
		if pxyTI.myOperator &lt;&gt; null then
			new := pxyTI.myOperator.code;
		endif;
		self.createLogForStateChange(LOGSTATE,oIdString,'Operator code',old,new,LOGLEVEL);
	endif;
	
	if pxyTI.myVoyage &lt;&gt;_realTI.myVoyage then
		isChanged := true;
		if _realTI.myVoyage &lt;&gt; null then
			old := _realTI.myVoyage.code;
		endif;
		
		if pxyTI.myVoyage &lt;&gt; null then
			new := pxyTI.myVoyage.code;
		endif;
		self.createLogForStateChange(LOGSTATE,oIdString,'Voyage code',old,new,LOGLEVEL);
	endif;
	
	if pxyTI.myProduct &lt;&gt; _realTI.myProduct then
		isChanged := true;
		if _realTI.myProduct &lt;&gt; null then
			old := _realTI.myProduct.code;
		endif;
		
		if pxyTI.myProduct &lt;&gt; null then
			new := pxyTI.myProduct.code;
		endif;
		self.createLogForStateChange(LOGSTATE,oIdString,'Product code',old,new,LOGLEVEL);
	endif;
	
	if pxyTI.myBookingRef &lt;&gt; _realTI.myBookingRef then
