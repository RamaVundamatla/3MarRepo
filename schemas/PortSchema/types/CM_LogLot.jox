    <JadeMethod name="validateAmount" id="6e98e91b-d209-4f62-bb66-55a14aa9fe12">
        <source>validateAmount(_bolExtLogOut : CM_BOLExtLogOut);
//--------------------------------------------------------------
//Created: 19 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	order : CM_LogStockOrderLine;
	totAssigned,
	totMaxAmount,
	totMinAmount,
	totReq : Real;
begin

return;	//Not required on the load out side as per Alan

	foreach order in self.allLogStockOrderLines do
		totReq := totReq + order.reqdQuantity;
		totMaxAmount := totMaxAmount + order.maxContractQuantity;
		totMinAmount := totMinAmount + order.minContractQuantity;		
	endforeach;
	
	if _bolExtLogOut.unitOfMeasure = BOL_UOM_VOLUME then
		totAssigned := self.calAssignedAmount(BOL_UOM_VOLUME) + _bolExtLogOut.reqdVolume;		
	elseif _bolExtLogOut.unitOfMeasure = BOL_UOM_WEIGHT then
		totAssigned := self.calAssignedAmount(BOL_UOM_WEIGHT) + _bolExtLogOut.myBOL.weightNet;
	else
		totAssigned := self.calAssignedAmount(BOL_UOM_PIECE_COUNT) + _bolExtLogOut.myBOL.numItems;
	endif;	

	if totMaxAmount &gt; 0 and totAssigned &gt; totMaxAmount then
		app.raiseCMWarning2(StockOrderAllocMaxQty, totAssigned.String, totMaxAmount.String,
							ETRow_AllocQuantity, null, self);			
	endif;
	if totMinAmount &gt; 0 and totAssigned &lt; totMinAmount then
		app.raiseCMWarning2(StockOrderAllocMinQty, totAssigned.String, totMinAmount.String,
							ETRow_AllocQuantity, null, self);			
	endif;
	if totAssigned &gt; totReq then
		app.raiseCMWarning2(AllocateQtyWarning, totAssigned.String, totReq.String,
							ETRow_AllocQuantity, null, self);		
	endif;			
end;</source>
        <Parameter name="_bolExtLogOut" type="CM_BOLExtLogOut"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b0139686-ed4e-4d33-a571-9e5e6ef3dbd6">
        <source>validateForCreate();
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.validateForUpdate();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="ab49cf25-f618-42ca-bfb1-b22f3249e2cf">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if (not self.allLogStockOrderLines.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Log Lot ' &amp; self.lotNo, 'Stock Order', null, null);	
	endif;
	if (not self.allBOLExtLogOuts.isEmpty) then
//		app.raiseCMException2(StockOrderLoadedToShip, 'Log Lot ' &amp; self.lotNo, 'vessel ' &amp; self.myLogVoyage.vesselName, null, null);
		app.raiseCMException2(StockOrderLoadedToShip, 'Log Lot ' &amp; self.lotNo, 'vessel ' &amp; self.myLogVoyageStructure.myVoyage.vesselName, null, null);
	endif;
	if (not self.allLocationsByHatchPlace.isEmpty) then
//		app.raiseCMException2(StockOrderLoadedToShip, 'Log Lot ' &amp; self.lotNo, 'vessel ' &amp; self.myLogVoyage.vesselName, null, null);
		app.raiseCMException2(StockOrderLoadedToShip, 'Log Lot ' &amp; self.lotNo, 'vessel ' &amp; myLogVoyageStructure.myVoyage.vesselName, null, null);
	endif;		
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="dfaca25c-c3eb-4c8e-a3d0-3e2fbf3c8ca6">
        <source>validateForUpdate();
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 08/12/2014   cnwdb2	PAR #35364

vars

begin
	
//	if self.myLogVoyage = null then
	if self.myLogVoyageStructure  = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', ETRow_Voyage, null);
		app.raiseCMException(Input_required_field_voyage, ETRow_Voyage, null); // cnwdb2	PAR 35364
	endif;
	if self.lotNo = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Lot No.', ETRow_Lot, null);
		app.raiseCMException(Input_required_field_lotNo, ETRow_Lot, null); // cnwdb2	PAR 35364


	endif;
	
//	if self.myLogVoyage &lt;&gt; null and self.lotNo &lt;&gt; null then
	if self.myLogVoyageStructure &lt;&gt; null and self.lotNo &lt;&gt; null then
		if self.myLogVoyageStructure.allLogLots.includesKey(self.lotNo) then
		//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Lot No.", self.lotNo, null,null, null);
			app.raiseCMException1(Already_exists_lot_number, self.lotNo,null, null); //cnwdb2 PAR 35364
		endif;
	endif;

end;</source>
    </JadeMethod>
</Class>
