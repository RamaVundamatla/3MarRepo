    <JadeMethod name="getEDIBundle" id="b0b36811-c006-4b24-9630-99c2daf1260f">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

