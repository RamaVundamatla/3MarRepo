        <updating/>
        <source>mnuFileRunProfEditor_click(menuItem: MenuItem input) updating;

vars
	errNo : Integer;
	errTxt : String;
	
begin
	errNo := 0;

	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	app.startApplication(currentSchema.name, "JtdDriverProfileEditApp");
	
	if errNo &lt;&gt; 0 then
		app.msgBox("Failed to initiate the Profile Editor." &amp; CrLf &amp; CrLf &amp;
			"Error Number: " &amp; errNo.String &amp; CrLf &amp; "Error Text: " &amp; errTxt,
			"Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;
end;</source>
