    <JadeMethod name="hasTaskThatAllowsResources" id="02a6a7e0-658d-4f9a-81fa-7a24ae22dc76">
        <source>hasTaskThatAllowsResources():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2009	cnwndl1	Initial creation	MES CCMS 1006


*/

vars

	taskDesc : CM_ToDoTaskDesc;
	
begin

	if self.deleted then
		return false;
	endif;
	
	if self.myTrackedItem = null then
		return false;
	endif;
	
	if self.myToDoTask = null then
		return false;
	endif;
	
	taskDesc := self.myToDoTask.getMyToDoTaskDesc;
	
	if taskDesc = null then
		return false;
	endif;

	return not taskDesc.allResourceTypes.isEmpty;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTaskThatIsComplete" id="0db489ae-ae63-4114-b316-6fde3dae835f">
        <source>hasTaskThatIsComplete() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2009	cnwndl1	Initial creation

*/

vars

begin

	if self.myTrackedItem = null then
		return false;
	endif;
	
	if self.myToDoTask = null then
		return false;
	endif;
	
	return self.myTrackedItem.allToDoTasksCompleted.includes(self.myToDoTask);
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
