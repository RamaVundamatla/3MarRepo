<GUIClass name="ScrollBar">
    <JadeMethod name="jssSet" id="413180fd-e632-4007-8a4e-1f462c418148">
        <updating/>
        <source>jssSet(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Updates the receiver's current position with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.value &lt;&gt; pValue then
		self.value	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
</GUIClass>
