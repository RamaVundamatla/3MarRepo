    <JadeMethod name="getValueForObject" id="cf955ee2-7a74-4bc6-9c39-75dc59b23ca9">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
// 10 Sep 2013	NDL	Par 32172
// 11/10/2013	cnwdap1		PAR #32763 Include cargo weight, tare weight, declared weight, length, width and height in here as well
// 18/02/2014	cnwdap1		PAR #33329 Correct handling when we have a mersurement type
//
vars
	value 	: Decimal [23,10];
	measure	: CM_MeasurementType;
	prod : CM_Product;
	type : String;

begin
	if self.propertyName.isOneOf(ETRow_OverHeight, ETRow_OverLengthFront, CM_Container::overLengthRear.name, ETRow_OverWidthRight, ETRow_OverWidthLeft,
									ETRow_Height, ETRow_Length, ETRow_Width,																			// PAR #32763
									ETRow_WeightCargo, ETRow_WeightDeclared, ETRow_WeightTare) then														// PAR #32763
		if self.myMeasurementType = null then
			if _obj &lt;&gt; null then
				if _obj.isKindOf(CM_TrackedItem) then
					prod := _obj.CM_TrackedItem.getProductForMeasurementConv();
				elseif _obj.isKindOf(CM_CargoType) then
					prod := _obj.CM_CargoType.mySystemProductType;
				elseif _obj.isKindOf(CM_Product) then
					prod := _obj.CM_Product;
				endif;
			endif;
			if prod &lt;&gt; null then
				//if self.propertyName = ETRow_OverHeight then																							// PAR #32763
				if self.propertyName = ETRow_OverHeight or self.propertyName = ETRow_Height then														// PAR #32763
					type := Type_Height;
					//elseif ( self.propertyName = ETRow_OverLengthFront or self.propertyName = CM_Container::overLengthRear.name ) then					// PAR #32763
					elseif ( self.propertyName = ETRow_OverLengthFront or self.propertyName = CM_Container::overLengthRear.name or self.propertyName = ETRow_Length) then	// PAR #32763
					type := Type_Length;
				//elseif ( self.propertyName = ETRow_OverWidthRight or self.propertyName = ETRow_OverWidthLeft) then									// PAR #32763
				elseif ( self.propertyName = ETRow_OverWidthRight or self.propertyName = ETRow_OverWidthLeft or self.propertyName = ETRow_Width) then	// PAR #32763
					type := Type_Width;
				elseif self.propertyName.isOneOf(ETRow_WeightCargo, ETRow_WeightDeclared, ETRow_WeightTare) then										// PAR #32763
					type := Type_Weight;																			// PAR #32763
				endif;
				measure := app.getDefaultMeasurementForType( type );
			else
				if self.propertyName.isOneOf(ETRow_WeightCargo, ETRow_WeightDeclared, ETRow_WeightTare) then											// PAR #32763
					measure := app.getDefaultMeasurementForType(Type_Weight);																			// PAR #32763
				else																																	// PAR #32763
					measure := app.getDefaultMeasurementForType(Type_Length);
				endif;																																	// PAR #32763
			endif;
			value := _obj.getPropertyValue(self.propertyName).Decimal;
			return app.convertMeasurementForDisplay(measure.shortName, value);
		else																																// PAR #33329
			return app.convertMeasurementForDisplay(self.myMeasurementType.shortName, _obj.getPropertyValue(self.propertyName).Decimal);	// PAR #33329
		endif;
	endif;
	
	return inheritMethod(_obj, _op);
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
