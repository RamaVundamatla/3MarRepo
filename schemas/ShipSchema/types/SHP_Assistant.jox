    <JadeMethod name="showVoyageJobForm" id="e585322c-594f-40c8-b4d3-78fce9b7a3cb">
        <source>showVoyageJobForm(	_voyage	: CM_Voyage;
						_job	: CM_Job );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2012	cnwpjs1	Initial creation  PAR# 30631

*/

vars
	form 			: SHP_VoyageJobForm;
	invalidObject	: Boolean;
	edition 		: Integer;
begin
	if _voyage = null and _job = null then
		return;
	endif;
	
	//06 Apr 2011	NDL	Par 27244
	if _job &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, _job, invalidObject );
		edition := _job.edition;
	elseif _voyage &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, _voyage, invalidObject );
		edition := _voyage.edition;
	endif;
	if invalidObject then
		return;
	endif;
	// end of 27244
	
	
	form := app.loadForm(SHP_VoyageJobForm, SHP_Assistant, false, false, false, self.myTerminal, null).SHP_VoyageJobForm;	
	
	if form = null then
		return;
	endif;
	
		
	if _job &lt;&gt; null then			
		form.showWithObject(_job, true, true);	
	else
		form.showWithObject(_voyage, false, false);	
	endif;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="showVoyageJobFormDefaultTS" id="44b53b67-c591-43a4-be32-d5a9e2567b14">
        <source>showVoyageJobFormDefaultTS(	_voyage		: CM_Voyage;
							_job		: CM_Job;
							_isStart 	: Boolean;
							_isEnd 		: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2012	cnwpjs1	Initial creation  PAR# 30631

*/

vars
	form 			: SHP_VoyageJobForm;
	invalidObject	: Boolean;
	edition 		: Integer;
begin
	if _voyage = null and _job = null then
		return;
	endif;
	
	//06 Apr 2011	NDL	Par 27244
	if _job &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, _job, invalidObject );
		edition := _job.edition;
	elseif _voyage &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, _voyage, invalidObject );
		edition := _voyage.edition;
	endif;
	if invalidObject then
		return;
	endif;
	// end of 27244
	
	
	form := app.loadForm(SHP_VoyageJobForm, SHP_Assistant, false, false, false, self.myTerminal, null).SHP_VoyageJobForm;	
	
	if form = null then
		return;
	endif;
	
	form.setIsStart(_isStart);
	form.setIsEnd(_isEnd);
		
	if _job &lt;&gt; null then			
		form.showWithObject(_job, true, true);	
	else
		form.showWithObject(_voyage, false, false);	
	endif;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_isStart" type="Boolean"/>
        <Parameter name="_isEnd" type="Boolean"/>
    </JadeMethod>
