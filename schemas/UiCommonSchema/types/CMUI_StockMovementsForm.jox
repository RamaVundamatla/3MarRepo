    <JadeMethod name="displayEntryLocation" id="c05d9845-e940-4ad8-b569-32147319e403">
        <source>displayEntryLocation(_obj : Object) : String;
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpLC	: CM_LocationsController;

begin
	if _obj.isKindOf(CM_LocationsController) then
		tmpLC := _obj.CM_LocationsController;
		if tmpLC.myTerminalArea &lt;&gt; null then
			return tmpLC.getID &amp; ' / ' &amp; tmpLC.myTerminalArea.id;
		else
			return tmpLC.getID;
		endif;
	elseif _obj.isKindOf(CM_TerminalArea) then
		return _obj.CM_TerminalArea.id;
	elseif _obj.isKindOf(CM_Terminal) then
		return _obj.CM_Terminal.name;
	elseif _obj.isKindOf(CM_Voyage) then
		return _obj.CM_Voyage.code &amp; Tab &amp; _obj.CM_Voyage.description;		
	else
		return null.String;
	endif;
	
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doCargoTypeClick" id="ccef4ba5-7268-4113-868b-34b18adac358">
        <updating/>
        <source>doCargoTypeClick() updating;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
