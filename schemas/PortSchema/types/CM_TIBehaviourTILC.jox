<Class name="CM_TIBehaviourTILC" id="65979d0d-5b4d-487e-837e-3fd4c1fb0725">
    <superclass name="CM_TIBehaviourType"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="CM_TILC"/>
    <JadeMethod name="getMyMasterTiClass" id="30d4764b-1f1c-4f63-b6ea-2a69d98f85c7">
        <source>getMyMasterTiClass(): Class;
// -------------------------------------------
// Created 21 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	return CM_TIMasterTILC;


end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getTableViews" id="22877c94-249c-4fbd-9af5-ac121d794011">
        <source>getTableViews(_cargoTypeAttributeName : String): String;
// -------------------------------------------
// Created 05 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _cargoTypeAttributeName = CM_CargoBOLType::mainFormFilterView.name then
		return 'TILC';
	elseif _cargoTypeAttributeName = CM_CargoBOLType::maintFormTblDataDef.name then
		return ETDef_TILCTable;
	else
		return inheritMethod(_cargoTypeAttributeName);
	endif;


end;</source>
        <Parameter name="_cargoTypeAttributeName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setThumbAndEditDefs" id="5057bf28-4c5b-4176-a0ea-deb8bc2cb1e0">
        <source>setThumbAndEditDefs(_allThumbDefs: StringArray input; _allEditDefs: StringArray input);
// -------------------------------------------
// Created 05 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	_allThumbDefs.clear();
	_allEditDefs.clear();
	
	_allThumbDefs.add(ETDef_TILCGeneralData);
	_allEditDefs.add(ETDef_TILCGeneralData);

end;</source>
        <Parameter name="_allThumbDefs" type="StringArray" usage="input"/>
        <Parameter name="_allEditDefs" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
