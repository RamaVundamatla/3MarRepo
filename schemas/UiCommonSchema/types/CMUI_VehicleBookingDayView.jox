	mnuExport.translateCaption(Xlat_0027063, locale);
	mnuInspectObj.translateCaption(Xlat_0019040, locale);
	mnuMaint.translateCaption(Xlat_0018930, locale);
	mnuUnbookSlot.translateCaption(Xlat_0019133, locale);
end;</source>
