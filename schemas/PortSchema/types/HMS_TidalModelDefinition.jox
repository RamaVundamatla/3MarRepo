    <JadeMethod name="checkHeightForDraft" id="8ab0deb4-9722-46cb-bf03-f7ae7fcfbfe3">
        <source>checkHeightForDraft(_tidalData : HMS_TidalData; _draftLimit : Decimal) : Boolean;
// ---------------------------------------------------------------------------
// Created:     28 December 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 May 2008	cnwkpd1	PAR #16642 - signature change to use a Decimal, to correct issues with
					Real imprecision

*/

vars

begin
	return self.getAvailableDraft(_tidalData) &gt;= _draftLimit;
	
end;</source>
        <Parameter name="_tidalData" type="HMS_TidalData"/>
        <Parameter name="_draftLimit" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAvailableDraft" id="47d63f2b-1bab-4245-bc1a-6e031e33dd3c">
        <source>getAvailableDraft(_tidalData : HMS_TidalData) : Decimal;
// ---------------------------------------------------------------------------
// Created:     10 January 2008 by cnwrs2
//
// Purpose:     
/*

Date		Who		Reason
11 Apr 2008	cnwrs2	PAR  16520 - round to 2 decimal places
02 May 2008	cnwkpd1	PAR #16642 - signature change to return a Decimal, to correct issues with
					Real imprecision

*/

vars
//	rtnValue	: Real;

begin
	return (self.declaredDepth + _tidalData.getValue() - self.underKeelClearance).roundedTo(2);
	
end;</source>
        <Parameter name="_tidalData" type="HMS_TidalData"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getChartDatum" id="88e19e80-ad77-4af7-b9e7-c3364ee21d95">
        <source>getChartDatum() : Real;
/*
----------   ----------  --------------------------------------------------
Created:	13 December 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	return self.declaredDepth - self.underKeelClearance;

end;
</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCheckpointsDescr" id="10a7ffcf-7ddd-46c5-a72e-695e42f2c63b">
        <source>getCheckpointsDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	checkpoint			: HMS_CheckPoint;
	str					: String;
	
begin

	foreach checkpoint in self.allHMSCheckpoints do
		str := str &amp; checkpoint.description &amp; ',';
	endforeach;
	
	
	if str &lt;&gt; null then
		str := str[1:str.length -1];
	endif;
	
	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDataForDefSpecial" id="8a632176-731c-427d-a0c6-a3009b851fd0">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;

vars

begin
	//these values are only relevant to a Data File loaded.
	if _attrName = ETRow_HighestValue 		// 26/03/2008 cnwar2 #16272 //
	or _attrName = ETRow_LowestValue then 	
		if dataSource &lt;&gt; HMS_TidalDataSource_File and
		   dataSource &lt;&gt; HMS_TidalDataSourceGetTideFile then //ccms1640 cnwrs1 jan 2009 //par19108 cnwrs1 mar 2008
			// Don't display row
			return true;
		endif;
	endif;
	
	return inheritMethod(_attrName, _heading, _headings, _data);
end;
</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
