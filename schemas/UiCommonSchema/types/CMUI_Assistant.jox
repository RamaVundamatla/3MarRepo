    <JadeMethod name="comboBoxHMSPathSegment" id="ebabaa10-aa7c-45f7-9e1f-d4edd89e0f88">
        <source>comboBoxHMSPathSegment(_comboboxObj:ComboBox input; _regionFromObj:HMS_HarbourRegion);
// --------------------------------------------------------------------------------
// Created:		04 September 2006 by cnwdad1
//
// Purpose:		Populates the specified combobox control with Path Segments.  If a
//				Harbour Region "from" is specified, then only Segments that have a
//				matching Region "from" will be loaded, otherwise all Segments will
//				be loaded.
//
// Parameters:	_comboboxObj - A reference to the control to populate.
//				_regionFromObj - A reference to a Harbour Region which the Segment
//					departs from, or null.
//
// Returns:		The populated combobox control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	segmentObj	: HMS_PathSegment;
	rowPointer	: Integer;
	
begin
	_comboboxObj.clear();
	
	foreach segmentObj in app.myRoot.allPathSegments do
		if _regionFromObj &lt;&gt; null and segmentObj.myRegionFrom &lt;&gt; _regionFromObj then
			continue;
		endif;
		
		rowPointer	:=	_comboboxObj.addItem(self.displayEntryHMSPathSegment(segmentObj));
		_comboboxObj.itemObject[rowPointer]	:=	segmentObj;
	endforeach;
end;</source>
        <Parameter name="_comboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_regionFromObj" type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSPaymentType" id="0ce2c78c-d335-45a0-9242-fc84a084b091">
        <source>comboBoxHMSPaymentType(_cmb: CMUI_ComboBox input; _paymentType: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlgmp6	Initial creation	TFS39250

*/

vars

begin
	_cmb.clear();
	_cmb.sorted := false;
	
	_cmb.itemData[_cmb.addItem(app.paymentTypeEnumToString(PaymentType_None))] := PaymentType_None;
	_cmb.itemData[_cmb.addItem(app.paymentTypeEnumToString(PaymentType_AutoCollection))] := PaymentType_AutoCollection;
	_cmb.itemData[_cmb.addItem(app.paymentTypeEnumToString(PaymentType_PrePay))] := PaymentType_PrePay;
	_cmb.itemData[_cmb.addItem(app.paymentTypeEnumToString(PaymentType_PostPay))] := PaymentType_PostPay;
	_cmb.itemData[_cmb.addItem(app.paymentTypeEnumToString(PaymentType_NoCharge))] := PaymentType_NoCharge;

	_cmb.text := app.paymentTypeEnumToString(_paymentType);
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_paymentType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSPilot" id="5f16ebe1-2a3f-4e5d-9ff1-6295132e46f5">
        <source>comboBoxHMSPilot(pCmb : ComboBox input; _pilot : HMS_Pilot; _harbour : HMS_Harbour);
//--------------------------------------------------------------
//Created: April 2004 By: cnwgd1
// 03/07/2014   cnwma1		CCMS SFW1328  HMS Not Available For Entry  
// 17/07/2018	jlgdap1		TFS 39685 PEL1 Pilots vs Harbours
//--------------------------------------------------------------
vars
	pilot	: HMS_Pilot;	// cnwma1  3/7/2014   CCMS SFW 1328
	idx		: Integer;		// cnwma1  3/7/2014   CCMS SFW 1328
begin

	pCmb.clear();
	//pCmb.listCollection(app.myRoot.allPilots, true, 0);											// cnwma1  3/7/2014   CCMS SFW 1328
	foreach pilot in app.myRoot.allPilots discreteLock where not pilot.isNotAvailableForEntry do	// cnwma1  3/7/2014   CCMS SFW 1328
		if _harbour &lt;&gt; null and pilot.myCurrentHarbour &lt;&gt; _harbour then			// TFS 39685
			continue;															// TFS 39685
		endif;																	// TFS 39685
		if pCmb.isKindOf(CMUI_ComboBox) then
			pCmb.CMUI_ComboBox.addItemObject(pilot.description, pilot);
		else	
			idx := pCmb.addItem(pilot.description);
			pCmb.itemObject[idx] := pilot;
		endif;
	endforeach;
	
	if _pilot &lt;&gt; null then
		pCmb.text := self.displayEntryHMSPilot(_pilot);
		if pCmb.text &lt;&gt; null then
			pCmb.listObject := _pilot;
		endif;
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_pilot" type="HMS_Pilot"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSPilotLaunch" id="11b461f2-b95e-4953-8ce2-514c26c16bab">
        <source>comboBoxHMSPilotLaunch(pCmb : ComboBox input; _pilotLaunch : HMS_PilotLaunch; _harbour : HMS_Harbour);
//--------------------------------------------------------------
//Created: April 2004 By: cnwgd1
// 03/07/2014   cnwma1		CCMS SFW1328  HMS Not Available For Entry  
// 17/07/2018	jlgdap1		TFS 39685 PEL1 Pilots vs Harbours
//--------------------------------------------------------------
vars
	pilotLunch	: HMS_PilotLaunch;									// cnwma1  3/7/2014   CCMS SFW 1328
begin			

	pCmb.clear();
	//pCmb.listCollection(app.myRoot.allPilotLaunches, true, 0);														// cnwma1  3/7/2014   CCMS SFW 1328
	foreach pilotLunch in app.myRoot.allPilotLaunches discreteLock where not pilotLunch.isNotAvailableForEntry do		// cnwma1  3/7/2014   CCMS SFW 1328
		if _harbour &lt;&gt; null and _harbour &lt;&gt; pilotLunch.myCurrentHarbour then		// TFS 39685
			continue;																// TFS 39685
		endif;																		// TFS 39685
		pCmb.CMUI_ComboBox.addItemObject(pilotLunch.description,pilotLunch);		
	endforeach;
	
	if _pilotLaunch &lt;&gt; null then
		pCmb.text := self.displayEntryHMSPilotLaunch(_pilotLaunch);
		if pCmb.text &lt;&gt; null then
			pCmb.listObject := _pilotLaunch;
		endif;
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_pilotLaunch" type="HMS_PilotLaunch"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSPilotTugLocation" id="b8dcf97b-116c-4e0d-ac2d-5c3f7529c3de">
        <source>comboBoxHMSPilotTugLocation(pTbl : CM_EntryTable input; pAttrName : String; _location : String);
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	row : Integer;
	str	: String;
begin
	
	row := pTbl.getRow(pAttrName);

	if (not pTbl.isValidRow(row)) then
		return;
	endif;
			
	str := app.getErrorString(HMS_Along_Side) &amp; Tab &amp; 
			app.getErrorString(On_Station);	

	pTbl.setComboValues(row, str);
	
	if _location = app.getErrorString(On_Station) or
	_location = app.getErrorString(HMS_Along_Side) then	
		pTbl.setValue(row, _location);			
	else
		pTbl.setValue(row, app.getErrorString(HMS_Along_Side));		
	endif;
		  
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_location" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSPropellerType" id="df07e9d4-4caf-4fc9-a5c9-804dc2922bbf">
        <source>comboBoxHMSPropellerType(pTbl : CM_EntryTable input; pAttrName : String; _fixed : Boolean);
//--------------------------------------------------
// Created:	15 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	row : Integer;
	str	: String;
begin
	
	row := pTbl.getRow(pAttrName);

	if (not pTbl.isValidRow(row)) then
		return;
	endif;
			
	str := app.getErrorString(HMS_Fixed) &amp; Tab &amp; 
			app.getErrorString(HMS_VariablePitch);	

	pTbl.setComboValues(row, str); 

	if _fixed then
		pTbl.setValue(row, app.getErrorString(HMS_Fixed));
	else
		pTbl.setValue(row, app.getErrorString(HMS_VariablePitch));	
	endif;
	
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_fixed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSRegion" id="b043fc0a-ebfc-4785-afc0-06ed51788746">
        <source>comboBoxHMSRegion(pCmb : ComboBox input; _harbour : HMS_Harbour; _region : HMS_HarbourRegion);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	realHarbour : HMS_Harbour;
	
begin

	pCmb.clear();
/*	
	if (not HMS_Harbour.hasInstance(_harbour)) then
		return;
	endif;
	
	
	if _harbour.isTransient then
		realHarbour := _harbour.pxyGetRealObject;
	else
		realHarbour := _harbour;
	endif;
*/	
	pCmb.listCollection(app.myRoot.allHMSHarbourRegions, false, 0);
	
	if _region &lt;&gt; null then
		pCmb.text := self.displayEntryHMSRegion(_region);
		if pCmb.text &lt;&gt; null then
			pCmb.listObject := _region;
