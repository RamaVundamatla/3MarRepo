    <JadeMethod name="setForCreate" id="bb33d433-2e9c-4095-b706-c1ceb58dc139">
        <updating/>
        <source>setForCreate(_pxyGTEEntity: CMGTE_Receival; _realVVR : CM_VehicleVisitRecord input) updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxyGTEEntity, _realVVR);
	self.setForUpdate(_pxyGTEEntity, _realVVR);	
