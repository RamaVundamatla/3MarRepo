    <JadeMethod name="getObjects" id="52822708-2aa6-42b2-a640-94e9c25ae041">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	iso: CM_ISOType;
begin
	foreach iso in app.myRoot.allISOTypes do
		objects[iso.getYAIdentifier] := iso;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
