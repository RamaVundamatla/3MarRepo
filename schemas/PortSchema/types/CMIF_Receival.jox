    <JadeMethod name="setMyOriginalProxyTI" id="dc515c1d-a523-47d4-a337-c97910fba688">
        <updating/>
        <source>setMyOriginalProxyTI(pTi : CM_TrackedItem) updating;
//Simply sets the persistent TI pproperty to the passed in value after checks
vars

begin

	pTi.raiseExceptionIfNotTransient(method);

	if pTi = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "Proxy TrackedItem", null, null);	
	endif;
	
	if self.myOriginalProxyTI &lt;&gt; pTi then 
		self.myOriginalProxyTI := pTi;
	endif;
	
end;</source>
        <Parameter name="pTi" type="CM_TrackedItem"/>
    </JadeMethod>
