    <JadeMethod name="addToUserMenuFromMenu" id="44914ab1-27dc-4ea4-bc01-bc0b4f2d50d9">
        <source>addToUserMenuFromMenu(_menuRoot: CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	child	: CM_MenuEntity;

begin

	foreach child in self.allChildren do
		child.addToUserMenuFromMenu(_menuRoot);
	endforeach;

end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cloneFromSource" id="dbdb0b42-3f69-47f9-94ce-9784b2888bc4">
        <updating/>
        <source>cloneFromSource(_parent : CM_MenuEntity; 
				_source : SelfType; 
				_terminal : CM_Terminal;
				_targetMenuRoot : CM_MenuRoot input;
				_user : CM_User;
				_clearFirst : Boolean;
				_deleteSet : CM_MenuEntitySet input) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin	
	self.heading 	:= _source.heading;
	self.level 		:= _source.level;
	self.myMenuItem := _source.myMenuItem;
	self.myTerminal := _terminal;
	self.toolTip 	:= _source.toolTip;
	self.myMenuRoot	:= _targetMenuRoot;

	inheritMethod(_parent, _source, _terminal, _targetMenuRoot, _user, _clearFirst, _deleteSet);

end;</source>
        <Parameter name="_parent" type="CM_MenuEntity"/>
        <Parameter name="_source" type="SelfType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_targetMenuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_clearFirst" type="Boolean"/>
        <Parameter name="_deleteSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getHeading" id="942908bf-6217-4a51-a07e-2b8921f9186a">
        <source>getHeading(): String;
// ---------------------------------------------------------------------------
// Created:     23 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.myMenuItem &lt;&gt; null then
		return self.myMenuItem.getHeading();
	endif;

	return self.heading;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
