    <JadeMethod name="validateForDelete" id="850861ed-ead0-46e5-bb19-31c594370e07">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridCntrl	: CM_GridController;
	firstPathFound : CM_ReeferBlock;
begin
	if self.isInUse then
		app.raiseCMException1(CM_GridColumnInUse, self.getLabel, null, null);
	endif;
	
	//08 Apr 2021	NDL	TFS 51042
	if self.hasReeferWalkPaths( firstPathFound ) then
		app.raiseCMException2(Colum_not_remov_still_decla_re, self.getLabel, firstPathFound.name, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForInsert" id="42e38ff5-34fe-4b0a-a924-aeb689ca5076">
        <source>validateForInsert() : String;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aGridController : CM_GridController;
	nextDoor : CM_GridColumn;
	tmpStr : String;
begin
	nextDoor := self.myGridArea.allGridColumns[self.column + 1];

	if nextDoor = null then
		return null;
	endif;
	
	// ### check the column next to us to see if there are any Yard Allocations etc that we may need to be inserted into.
	foreach aGridController in nextDoor.allControllersByRow do
		if aGridController.hasRestrictions(LOCATION_RESTRICTION) then
			if tmpStr = null then
				tmpStr := "Location Restriction";
			else
				tmpStr := tmpStr &amp; ", " &amp; "Location Restriction";
			endif;
		elseif aGridController.hasRestrictions(LABOUR_RESTRICTION) then
			if tmpStr = null then
				tmpStr := "Labour Restriction";
			else
				tmpStr := tmpStr &amp; ", " &amp; "Labour Restriction";
			endif;
		elseif aGridController.mySubBlockStack &lt;&gt; null then
			if tmpStr = null then
				tmpStr := "Sub-block Stack";
			else
				tmpStr := tmpStr &amp; ", " &amp; "Sub-block Stack";
			endif;
		elseif not aGridController.allYardAllocations.isEmpty then
			if tmpStr = null then
				tmpStr := "Yard Allocation";
			else
				tmpStr := tmpStr &amp; ", " &amp; "Yard Allocation";
			endif;
		endif;
	endforeach;
	
	if tmpStr &lt;&gt; null then
		app.raiseCMWarning2(Exist_setup_that_need_colum_ad, self.myGridArea.id, tmpStr,null, null, self.myGridArea);
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="30b5c4f7-8693-4044-ad5d-cd95c5582a91">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.column &lt;= 0 then
		app.raiseCMException1(GridArea_RowColumnInvalidNum, 'column', null, null);
	endif;
	
	self.validateLabel();

end;</source>
    </JadeMethod>
