    <JadeMethod name="doFrameDragDrop" id="7f244ff4-51a4-4553-828c-6b3ea0b6219e">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doFrameDragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
/*
Purpose:			
Date		Who		Reason
16 September 2011	cnwab1	Initial creation
*/

vars
	obj : Object;

begin
	obj := self.mySideViewFrame.getObjectForPosition(x.Integer,y.Integer);
	if obj.isKindOf(CM_VoyageROROController) then
		self.myCargoSideViewForm.myROROPlanningForm.doMoveFromGridAreaForm(obj.CM_VoyageROROController, true); // PAR 32149 pass in context of drag drop move
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawCurrentObject" id="94c88984-b05f-4d27-be52-34db07dad322">
        <updating/>
        <source>drawCurrentObject(_frame: SHP_ROROLocnDrawingFrame input) updating;
/*
Date		    Who			Reason
14 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	hadDuplicates	: Boolean;
	theFrame: SHP_ROROScrollingFrame;
	slotDefn : CM_ROROSlotDefnVoyage;
	roroReq : CM_RORORequest;
	theDrawTextAlign : Integer;
	backEndPadding, 
	theColour 	: Integer;
	outerColourUpper, outerColourLower : Integer;
	myX2, myX1, myY1, myY2	: Real;
	theTI : CM_TrackedItem;
	theLC : CM_ROROSlotController;
	theDrawingAttribute : CM_DrawingAttribute;
begin

	theFrame := _frame.myScrollingFrame;
	
	theDrawTextAlign := theFrame.drawTextAlign;
	
	theColour := self.getCurrentObjectColour(self.myCurrentObject);
	
	self.setDrawStyleAndColors(self.myCurrentObject, theFrame, theColour, outerColourUpper, outerColourLower);

	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;


	self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, outerColourUpper, outerColourLower);

	// PAR 29050
	if self.myCurrentObject.isKindOf(CM_ROROSlotController) then
		theLC := self.myCurrentObject.CM_ROROSlotController;
		self.drawRoBNoCC(theFrame, theColour, theLC, myX1, myY1, myX2, myY2);
	endif;
	
	
	
	if self.myCurrentObject.isA(CM_ROROLocnDefnVoyage) then		
		_frame.drawLocnDefnLabel(self.myCurrentObject.CM_ROROLocnDefnVoyage,myX1,myY1,theColour.getInverseColour(),self.locnDefnWidth,self.locnDefnHeight);
	elseif self.myCurrentObject.isA(CM_ROROSlotController) then		
		//_frame.drawSlotDefnLabel(self.myCurrentROROSlotDefn,myX1,myY1,theColour.getInverseColour(),(myX2 - myX1).Integer,self.locnDefnHeight);	
		self.drawSlotDefnLabel(theFrame, self.myCurrentROROSlotDefn,myX1,myY1,theColour.getInverseColour(),(myX2 - myX1).Integer,self.locnDefnHeight);	
	endif;
	
	// 28747 Dec 2011 added dup exception handler as this code is also called from notifications and the collections already hold the items from the initial form build
	if self.myCurrentObject.isKindOf(CM_ROROLocnDefn) then		
		on Exception do self.allLocnDefnsByX1Y1X2Y2.noDuplicatesExceptionhandler(exception, hadDuplicates);
		self.allLocnDefnsByX1Y1X2Y2.putAtKey(myX1.Integer, myY1.Integer, myX2.Integer, myY2.Integer, self.myCurrentROROLocnDefn);
	else
		on Exception do self.allSlotDefnsByX1Y1X2Y2.noDuplicatesExceptionhandler(exception, hadDuplicates);
		self.allSlotDefnsByX1Y1X2Y2.putAtKey(myX1.Integer, myY1.Integer, myX2.Integer, myY2.Integer, self.myCurrentROROSlotDefn);
	endif;
	
	// PAR 28939 just incase a 40 foot is removed we need to draw grey between the 2 20 foot slots
	if theColour = White then // PAR 28939 empty slot
		theFrame.drawWidth := 1;
		theFrame.drawFillColor := theFrame.backColor;
		self.drawRectangle(theFrame, myX1 - (self.interLocnSlotsWidth), myY1, myX1 - 1, myY2, theFrame.backColor, theFrame.backColor);
	
	endif;
	
epilog
	
	theFrame.drawTextAlign := theDrawTextAlign;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

end;</source>
        <Parameter name="_frame" type="SHP_ROROLocnDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawIconsTIREQ" id="b130ebe4-c746-4ce9-b09e-ebbf63f28216">
        <updating/>
        <source>drawIconsTIREQ(_ti : CM_TrackedItem; _req : CM_RORORequest; _frame : CMUI_Frame input; _x1,_y1 : Real; _inverseColor : Integer) protected, updating;
/*
Purpose:			
Date				Who			Reason
JANUARY 2012		CNWAB1		Initial creation
11/03/2015			cnwmh5		Transient Leaks
11/11/2019			jlgdap1		TFS 46405 AAT Falt Rack and OOG in LOLO Planning Screen
11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	tmpIcons	: StringArray;
	theAtt		: Integer;
	tmpStr		: String;
	idx : Integer;
	tmpX, tmpY : Real;
	is40 : Boolean;
	maxIcons : Integer; // 11/10/2022	navkc1	#54935
begin


	create tmpIcons transient;
	
	maxIcons := 1; // 11/10/2022	navkc1	#54935
	
	if _ti &lt;&gt; null then
		if self.modeView = ShpDisplayMode_ColCodeLoad and _ti.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then // PAR 29050
			return;
		endif;
		//_ti.getAllDrawingIconsByPriority(tmpIcons, self.attrMaxNum);		// 8/12/17 MAP TFS7493	// TFS 46405
		is40 := (_ti.isForty() or _ti.isThirty or _ti.is45 or _ti.is53); // PAR 30022 
		
		if is40 then
			maxIcons := 2;  // 11/10/2022	navkc1	#54935
		endif;
		
		//_ti.getAllDrawingIconsByPriority(tmpIcons, self.attrMaxNum, false);							// TFS 46405
		_ti.getAllDrawingIconsByPriority(tmpIcons, maxIcons, false);	// 11/10/2022	navkc1	#54935
		
	else
		if _req &lt;&gt; null then
			is40 := _req.getAttrIsNOT20(); // PAR 30253
			
			if is40 then
				maxIcons := 2; // 11/10/2022	navkc1	#54935
			endif;
			
			_req.getAllDrawingIcons(tmpIcons, maxIcons);
			// PAR 30022 is20 := not _req.getAttrIs40();
			// PAR 30253 is40 := (_req.getAttrIs40() or _req.getAttrIs30() or _req.getAttrIs45() or _req.getAttrIs53()); // PAR 30022 
			
		else
			return;
		endif;		
	endif;
	
	tmpX := _x1;
	tmpY := _y1;
	
	if tmpIcons.size &gt; 0 then
		_frame.drawFontSize := 8;
		theAtt := 0;
		foreach tmpStr in tmpIcons do
			self.drawAttribute(_ti,_frame,tmpX,tmpY, _inverseColor, tmpStr, theAtt);
			
			tmpX := tmpX + 1;
				
			idx := idx + 1;
			if is40 then
				//if idx &gt;= 3 or self.scaleFactor &lt; 0.8 then
				if idx &gt;= maxIcons or self.scaleFactor &lt; 0.8 then // 11/10/2022	navkc1	#54935
					break;
				endif;
			else
				//if idx &gt;= 2 or self.scaleFactor &lt; 0.8 then
				if idx &gt;= maxIcons or self.scaleFactor &lt; 0.8 then  // 11/10/2022	navkc1	#54935
					break;
				endif;
			endif;
			
		endforeach;
	endif;
	self.setDefaultFont(_frame);	
	
epilog
	delete tmpIcons;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_req" type="CM_RORORequest"/>
        <Parameter name="_frame" type="CMUI_Frame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_inverseColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLocationsPos" id="4748354e-7545-4d51-8a1b-dd7b7b30a339">
        <updating/>
        <source>drawLocationsPos(_locnX, _locnY : Integer; _colour : Integer) updating, protected;
/*
Date		    Who			Reason
13 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/
vars
	
	tmpForm			: SHP_CargoSideViewForm;
	posFrame		: SHP_ROROLocnDrawingFrame;	
	
begin
	tmpForm := self.myCargoSideViewForm.SHP_CargoSideViewForm;	
	
	self.scaleDimensions(1);
	
	beginLoad;		
		
	posFrame := tmpForm.frmLocationPos;
		
	posFrame.init(_locnX, _locnY, 300, 300, _colour, self);
	
	posFrame.clearGraphics();
	 
	posFrame.drawSelf();	

	posFrame.visible := true;	

epilog	
	
	endLoad;
	
end;</source>
        <access>protected</access>
        <Parameter name="_locnX" type="Integer"/>
        <Parameter name="_locnY" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawObject" id="fae1a70b-0502-4452-9c37-31a9f98c7906">
        <updating/>
        <source>drawObject(_frame: SHP_ROROLocnDrawingFrame input; _obj: Object) updating;
/*
Date		    Who			Reason
13 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/


vars
	frame: SHP_ROROLocnDrawingFrame ;
begin
	frame := _frame;
	if  frame = null then
		frame := self.mySideViewFrame;
	endif;
	
	if _obj = null or frame = null then
		return;
	endif;
	
	frame.drawObject(_obj, self);			

epilog
	
end;</source>
        <Parameter name="_frame" type="SHP_ROROLocnDrawingFrame" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="drawObjectAt" id="8453c148-4c8a-460d-9d1e-bfb6dd9ac0d7">
        <updating/>
        <source>drawObjectAt(_frame: SHP_ROROLocnDrawingFrame input;_objectToDraw: Object; _x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer; _drawingController: CMUI_GridDrawingController input) updating;

vars
	theFrame: SHP_ROROScrollingFrame;
	theDrawTextAlign : Integer;
	backEndPadding, 
	theColour 	: Integer;
	outerColourUpper, outerColourLower : Integer;
	myX2, myX1, myY1, myY2	: Real;
	theLC : CM_ROROSlotController;
	theTI : CM_TrackedItem;
begin
	theFrame := _frame.myScrollingFrame;
	
	theDrawTextAlign := theFrame.drawTextAlign;
	
	theColour := self.getCurrentObjectColour(_objectToDraw);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; _objectToDraw.String &amp; " " &amp; _x1.String &amp; " " &amp; _y1.String);	
	self.setDrawStyleAndColors(_objectToDraw, theFrame, theColour, outerColourUpper, outerColourLower);

	self.x1 := _x1;
	self.y1 := _y1;
	self.x2 := _x2;
	self.y2 := _y2;
	myX1 := _x1;
	myX2 := _x2;
	myY1 := _y1;
	myY2 := _y2;
	
	self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, outerColourUpper, outerColourLower);


	// PAR 29050
	if _objectToDraw.isKindOf(CM_ROROSlotController) then
		theLC := _objectToDraw.CM_ROROSlotController;
		self.drawRoBNoCC(theFrame, theColour, theLC, myX1, myY1, myX2, myY2);
	endif;
	

	if _objectToDraw.isA(CM_ROROLocnDefnVoyage) then		
		_frame.drawLocnDefnLabel(_objectToDraw.CM_ROROLocnDefnVoyage,myX1,myY1,theColour.getInverseColour(),self.locnDefnWidth,self.locnDefnHeight);
	elseif _objectToDraw.isA(CM_ROROSlotController) then		
//		_frame.drawSlotDefnLabel(_objectToDraw.CM_ROROSlotController.mySlotDefn,myX1,myY1,theColour.getInverseColour(),(myX2 - myX1).Integer,self.locnDefnHeight);
		self.drawSlotDefnLabel(theFrame, _objectToDraw.CM_ROROSlotController.mySlotDefn,myX1,myY1,theColour.getInverseColour(),(myX2 - myX1).Integer,self.locnDefnHeight);	
	
	endif;
	
epilog
	
	theFrame.drawTextAlign := theDrawTextAlign;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

end;</source>
        <Parameter name="_frame" type="SHP_ROROLocnDrawingFrame" usage="input"/>
        <Parameter name="_objectToDraw" type="Object"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_drawingController" type="CMUI_GridDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawRectangle" id="9efb6300-0e5d-4128-a41b-3a5c0013859e">
        <source>drawRectangle(_frame : Frame input; x1, y1, x2, y2 : Real; _outerColourUpper, _outerColourLower : Integer) protected;
/*
Date		    Who			Reason
13 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	tmpColor	: Integer;
begin

	
	_frame.drawFilledRectangle(x1, y1, x2, y2, Black); 
	
	_frame.drawLine(x1, y1, x2, y1, _outerColourUpper);
	_frame.drawLine(x1, y1, x1, y2 - 1, _outerColourUpper);
	_frame.drawLine(x2 - 1, y1 + 1, x2 - 1, y2, _outerColourLower);
	_frame.drawLine(x1, y2 - 1, x2 - 1, y2 - 1, _outerColourLower);	

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
        <Parameter name="_outerColourUpper" type="Integer"/>
        <Parameter name="_outerColourLower" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawRoBNoCC" id="933b2ca7-4bda-406a-8b33-5b6e3ecc0214">
        <source>drawRoBNoCC(theFrame: SHP_ROROScrollingFrame input; theColour : Integer; theLC : CM_ROROSlotController;	_myX1, _myY1, _myX2, _myY2	: Real);
/*
Purpose:			
Date		Who		Reason
07 February 2012	cnwab1	Initial creation
*/
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	theTI : CM_TrackedItem;
	myX2, myX1, myY1, myY2	: Real;
	theDrawingAttribute : CM_DrawingAttribute;
begin
	myX1 := _myX1;
	myY1 := _myY1;
	myX2 := _myX2;
	myY2 := _myY2;
	
	// PAR 31073 if Text view then do not draw the RoB stripe
	if self.modeViewSub = ShpDisplayModeSub_Text then
		return;
	endif;

	if self.modeView = ShpDisplayMode_ColCodeDisch 
	or self.modeView = ShpDisplayMode_ColCodeLoad then
		if theLC.hasROB(false) then
			theLC.getROB(self.allTempTIs, true, false);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
			theTI := self.allTempTIs.first();
			if theTI &lt;&gt; null then
				if self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31073 
					if theTI.isExport or theTI.isRehandle or theTI.isSOB then
						return;
					endif;
				endif;
			
				if (self.modeView = ShpDisplayMode_ColCodeLoad and theLC.myRORORequestLoad = null) 
				or self.modeView = ShpDisplayMode_ColCodeDisch then
						myY1 := myY1 + 8;
						myY2 := myY2 - 9;
						theFrame.drawFillColor := theColour;
						self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, theColour, theColour);
						if theLC &lt;&gt; theTI.myPrimaryActualLocation then // Back END 
							theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
							theFrame.drawFontBold := true;
							theFrame.drawFontSize := 20;
							theDrawingAttribute := theTI.getIconBackEnd();
							
							
							if theDrawingAttribute &lt;&gt; null then
								theFrame.drawFontName := theDrawingAttribute.fontName;
								// #######################
								// DRAW THE CHARACTER
								theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
								theFrame.drawFontSize := 20; // (self.scaleFactor * 7);
								theFrame.drawTextAt(theDrawingAttribute.fontCharacter.Character,  (myX1 + ((myX2 - myX1)/2)), (myY1 + ((myY2 - myY1)/2)) - 15, theDrawingAttribute.colour);
							else
								theFrame.drawTextAt("X", (myX1 + ((myX2 - myX1)/2)), (myY1 + ((myY2 - myY1)/2)) - 15 , Red );					
							endif;
							
							self.setDefaultFont(theFrame);
							theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
						endif;
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="theFrame" type="SHP_ROROScrollingFrame" usage="input"/>
        <Parameter name="theColour" type="Integer"/>
        <Parameter name="theLC" type="CM_ROROSlotController"/>
        <Parameter name="_myX1" type="Real"/>
        <Parameter name="_myY1" type="Real"/>
        <Parameter name="_myX2" type="Real"/>
        <Parameter name="_myY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="f7f83770-dfcb-4909-b01f-d91ca3546de7">
        <updating/>
        <source>drawSelf(_clearSelected: Boolean) updating;
/*
Date		    Who			Reason
12 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	tmpForm 				: SHP_CargoSideViewForm;
	tmpDrawingController	: SHP_ROROLocnDrawingController;
	locnX,
	locnY,
	maxX,
	maxY,
	holdWidth,
	holdHeight,
	numColumns,
	st, et,
	aColour,
	numBays,numBayVisible,
	firstColour			: Integer;
begin	
	
	if self.myVessel = null then		
	//	return;
	endif;
	
	self.setupDimensions();
	
	inheritMethod(_clearSelected);

	//self.setScale(1);
	self.setAttrPositions(self.modeView);
	
	tmpForm := self.myCargoSideViewForm;
	tmpDrawingController := self;
	
	self.myOverViewFrame.visible := true;
	self.mySideViewFrame.visible := true;
	
	
	locnX := 0;
	locnY := 0;

	self.allLocnDefns.clear();
	//self.allLocnDefnsByRowCol.clear();
	self.allLocnDefnsByX1Y1X2Y2.clear();
	self.allSlotDefnsByX1Y1X2Y2.clear();
	self.allTempTIs.clear();
	
		
	self.drawLocationsPos(locnX,locnY,self.mySideViewFrame.backColor);
	self.drawSideViewLocns(locnX,locnY,self.mySideViewFrame.backColor);
		
		

epilog

end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSideViewLocns" id="5362a4d2-37d1-4ec4-ae30-75fdab358ed1">
        <updating/>
        <source>drawSideViewLocns(_locnX, _locnY : Integer; _colour : Integer) updating, protected;
/*
Date		    Who			Reason
13 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/
vars
	
	tmpForm			: SHP_CargoSideViewForm;
	slotsFrame		: SHP_ROROLocnDrawingFrame;	
	
begin
	tmpForm := self.myCargoSideViewForm.SHP_CargoSideViewForm;	
	
	self.scaleDimensions(self.scaleFactor);
	
	beginLoad;		
		
	slotsFrame := self.mySideViewFrame;
		
	slotsFrame.init(_locnX, _locnY, 300, 300, _colour, self);
	
	slotsFrame.drawSelf();	

	slotsFrame.visible := true;	

epilog	
	
	endLoad;
	
end;</source>
        <access>protected</access>
        <Parameter name="_locnX" type="Integer"/>
        <Parameter name="_locnY" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSlotDefnLabel" id="bdde9cc5-396a-4640-8a25-d9dc7b56ff8a">
        <updating/>
        <source>drawSlotDefnLabel(_frame : SHP_ROROScrollingFrame; _slotDefn : CM_ROROSlotDefnVoyage; _x,_y : Real ; _colour : Integer; _width,_height : Integer) updating;
/*
Date		    Who			Reason
18 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/
constants
	TopLabelOffset = 17;
vars
	label, label2 : String;
	textX,textY : Real;
	labelWidth, labelHeight : Real;
	scrollingFrame : SHP_ROROScrollingFrame;
	colr, midX, slotHeightY, labelOffset : Integer;
	tmpTI : CM_TrackedItem;
	req : CM_RORORequest;
	job : CM_VoyageJob;
	is40 : Boolean;
begin
	scrollingFrame := _frame; 

	if _slotDefn = null or _width = null then
		return;
	endif;

	
	// ### FILL COLOUR
	if _slotDefn.isAvailable then
		colr := _colour;
	else
		colr := Red;
	endif;
	
	// ### DLR SOB
	midX := (((self.x2 - self.x1) / 2) + self.x1).Integer;
	slotHeightY := ((self.y2 - self.y1).Integer/ 2).Integer - 6;
	
	// PAR 30245 SHow MARK if more than 1 item in a slot
	if _slotDefn.mySlotController.allTrackedItems.size &gt; 1 then
		scrollingFrame.drawWidth := 1;
		scrollingFrame.drawFillColor := Red;
		scrollingFrame.drawFilledRectangle(self.x2 - 2, self.y2 - 3, self.x2 -7, self.y2 - 9, White);
	endif;
	
	//cnwmc5 - 1 August 2013 - PAR 31651 - added the 'if' statement around this block
	if self.modeViewSubSub = ShpDisplayModeSub_ExportsHide
	or not self.modeView = ShpDisplayMode_ColCodeDisch then
		if self.modeView = ShpDisplayMode_ColCodeLoad then
			req := _slotDefn.mySlotController.myRORORequestLoad;
		elseif	 self.modeView = ShpDisplayMode_ColCodeDisch then
			req := _slotDefn.mySlotController.myRORORequestDischarge;
		endif;
	
		if req &lt;&gt; null then
			// PAR 30022 is40 := req.getAttrIs40();
			// PAR 30253 is40 := (req.getAttrIs40() or req.getAttrIs30() or req.getAttrIs45() or req.getAttrIs53());
			is40 := req.getAttrIsNOT20(); // PAR 30253
				
			if req.isRehandle  or req.isSoB then
				scrollingFrame.drawWidth := 1;
				if req.isRehandle then
					scrollingFrame.drawFillColor := COLOUR_DLR;
				else
					scrollingFrame.drawFillColor := COLOUR_SOB;
				endif;
				scrollingFrame.drawFilledRectangle(midX - slotHeightY, self.y1 + 5, midX + slotHeightY, self.y2 - 5, Black);
				scrollingFrame.drawLine(midX + slotHeightY - 1, self.y1 + 5, midX + slotHeightY - 1, self.y2 - 5, White);
				scrollingFrame.drawLine(midX - slotHeightY - 1, self.y2 - 6, midX + slotHeightY - 1, self.y2 - 6, White);
	
				if req.isComplete then // MARK
					scrollingFrame.drawFillColor := Black;
					scrollingFrame.drawFilledRectangle(self.x1 + 2, self.y2 - 2, self.x1 + 8, self.y2 - 8, Black);
				endif;
				// REQUEST IS LINKED MARK
				if req.isLinked() then
					scrollingFrame.drawFillColor := LightGreen;
					scrollingFrame.drawFilledRectangle(self.x1 + 9, self.y2 - 2, self.x1 + 15, self.y2 - 8, LightGreen);
				
				endif;
				
			endif;
		endif;
	endif;
	
	
	// ### GET LABELS
	label := self.getCurrentObjectLabel(_slotDefn).trimBlanks;
	
//	if self.modeViewSub = ShpDisplayModeSub_Colour then // allow space for icons
//		label := label;
//	endif;
	label2 := self.getCurrentObjectLabelLower(_slotDefn).trimBlanks;
	textX := _x + 2;
	textY := _y;
	
	// ### LABEL UPPER
	if is40 then// PAR 29467
		scrollingFrame.drawFontSize := 18;// PAR 29467
	else
		scrollingFrame.drawFontSize := 13;
	
	endif;
	scrollingFrame.drawFontBold := false;
	scrollingFrame.drawTextAlign := Frame.DrawTextAlign_Left;	
	
	labelOffset := 0;
	if self.modeViewSub = ShpDisplayModeSub_Colour then
		labelOffset := TopLabelOffset + 5; // PAR 28887
	else // text
		if is40 then
			labelOffset := 0; // PAR 29467
		else
			labelOffset := TopLabelOffset + 5; // PAR 28939
		endif;
	endif;
	
	while scrollingFrame.drawTextWidth(label) + 6 &gt; (_width - labelOffset) do
		scrollingFrame.drawFontSize := scrollingFrame.drawFontSize - 1;
		if scrollingFrame.drawFontSize &lt; 7 then
			break;
		endif;
	endwhile;

	labelWidth := scrollingFrame.drawTextWidth(label);
	labelHeight := scrollingFrame.drawTextHeight(label);
				
	scrollingFrame.drawTextRotation := 0;
	scrollingFrame.drawTextCharRotation := 0;

	
	if label &lt;&gt; "    X" and self.modeViewSub = ShpDisplayModeSub_Colour then
		//if (self.modeWork = SHP_ROROPlanningForm.WorkMode_Plan or self.modeWork = SHP_ROROPlanningForm.WorkMode_Job)	and 
		if self.modeView = ShpDisplayMode_ColCodeLoad  then
		
			//scrollingFrame.drawFontSize := 8;
//			textY := textY - 2;
//		elseif self.modeView = ShpDisplayMode_ColCodeLoad  then
			textY := textY - 1; // PAR 28939
		endif;
		
		if self.modeView  = ShpDisplayMode_ColCodeLoad  then
			tmpTI := null;
		else
			//epr par 29647 31/5/12
			if req &lt;&gt; null then
				tmpTI := req.getTrackedItem();
			endif;
			if tmpTI = null then
				tmpTI := self.allTempTIs.first(); // allTempTIs is built in method getLabelTILower called from above via getCurrentObjectLabelLower
			endif;
		endif;
		
		if tmpTI &lt;&gt; null then
	//	PAR 28887 self.drawIcons(tmpTI, scrollingFrame, textX,textY,colr);
// PAR 29050			self.drawIconsTIREQ(tmpTI, null, scrollingFrame, textX,textY,colr);
			if tmpTI.isTranshipItem then
				scrollingFrame.drawFillColor := Yellow;
				scrollingFrame.drawFilledRectangle(self.x1 + 12, self.y2 - 2, self.x1 + 15, self.y2 - 5, Yellow);
			endif;
		endif;
		
		scrollingFrame.drawTextAt(label,textX+ (TopLabelOffset * self.scaleFactor) ,textY,colr);
		
		// PAR 28887
	
		self.drawIconsTIREQ(tmpTI, req, scrollingFrame, textX,textY,colr);

	else
		scrollingFrame.drawTextAt(label,textX,textY,colr);
	endif;
	
	
	// ### LABEL LOWER
	if label2 &lt;&gt; null then
		scrollingFrame.drawFontSize := 13;
		scrollingFrame.drawFontBold := false;
		// PAR 28887
		labelOffset := TopLabelOffset;
		if self.modeViewSub = ShpDisplayModeSub_Colour then
			labelOffset := TopLabelOffset + 7;
			textX := textX + TopLabelOffset;
		else // PAR 28939
			labelOffset := TopLabelOffset + 12;
			textY := textY - 1;
			// PAR 29467
			if self.modeView = ShpDisplayMode_ColCodeLoad then
				labelOffset := TopLabelOffset; 
				scrollingFrame.drawFontSize := 11;
			endif;
		endif;
		
		while scrollingFrame.drawTextWidth(label2) + 6 &gt; _width  - labelOffset do
			scrollingFrame.drawFontSize := scrollingFrame.drawFontSize - 1;
			if scrollingFrame.drawFontSize &lt; 7 then			//cnwas3 par 28382
				break;
			endif;
		endwhile;
//		if self.myROROLocnDrawingController.modeView = ShpDisplayMode_Actual then
			textY := textY + (_height /2).Integer;		
//		else
//			textX := textX + (_width - labelWidth)/2;		
//			textY := textY + (_height - labelHeight)/2;		
	//	endif;
		scrollingFrame.drawTextAt(label2,textX,textY,colr);
	endif;
	
		
	// JOB and Sequence Details
	if self.modeWork = SHP_ROROPlanningForm.WorkMode_Plan 
	or self.modeWork = SHP_ROROPlanningForm.WorkMode_Job then
		if self.modeViewSub = ShpDisplayModeSub_Colour then //self.modeView = ShpDisplayMode_ColCodeLoad and 
			if req &lt;&gt; null then
				job := req.myJob.CM_VoyageJob;
				if job &lt;&gt; null then
					scrollingFrame.drawFontSize := 8;
					scrollingFrame.drawTextAt(job.jobNum &amp; "/" &amp; req.numSeqAft.String,self.x1 + 2,self.y2 - 14,colr);
				endif;
			endif;
		endif;
	endif;
	// WLE Complete
	if self.modeView = ShpDisplayMode_ColCodeLoad then
		if req &lt;&gt; null  then
			if req.isComplete  then
				scrollingFrame.drawFilledRectangle(self.x2 - 6, self.y2 - 6, self.x2-3, self.y2-3, Black);
			endif;
		endif;
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
		if req &lt;&gt; null then
			if req.isComplete  then 
				// PAR 29897 - this req may be a completed load, in which case we are drawing the actual export, so do not need the black dot
				if req.myROROController.myRORORequestLoad = null
				or (req.myROROController.myRORORequestLoad &lt;&gt; null and not req.myROROController.myRORORequestLoad.isComplete) then
					scrollingFrame.drawFilledRectangle(self.x2 - 6, self.y2 - 6, self.x2-3, self.y2-3, Black);
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_frame" type="SHP_ROROScrollingFrame"/>
        <Parameter name="_slotDefn" type="CM_ROROSlotDefnVoyage"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSlotFromNote" id="8eb1a069-c59b-4d20-a63f-fca8b3b10ea2">
        <source>drawSlotFromNote(_slotController : CM_ROROSlotController);
/*
Purpose:			
Date		Who		Reason
27 September 2011	cnwab1	Initial creation
*/

vars
	x1, y1 : Integer;
begin
	// 28747 Dec 2011 de-select so the slot is re-drawn coloured
	if self.allSelectedObjects.includes(_slotController) then
		self.allSelectedObjects.remove(_slotController);
	endif;
	
	self.mySideViewFrame.drawSlotFromNote(_slotController);	// 28747
	//self.mySideViewFrame.drawObject(_slotController, self.mySideViewFrame.myROROLocnDrawingController); // was
epilog

end;</source>
        <Parameter name="_slotController" type="CM_ROROSlotController"/>
    </JadeMethod>
    <JadeMethod name="getCurrentObjectColour" id="dc218959-01f1-4a7a-b876-fa3b02d6435f">
        <source>getCurrentObjectColour(_objectToDraw : Object) : Integer;
/*
Date		    Who			Reason
15 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	slotDefn : CM_ROROSlotDefnVoyage;
	slotLC : CM_ROROSlotController;
	theTI : CM_TrackedItem;
	theTIs : CM_TIArray;
begin
	if _objectToDraw.isKindOf(CM_ROROLocnDefn) then
		return self.LocnDefnColour;
	elseif _objectToDraw.isKindOf(CM_ROROSlotController) then
		slotLC := _objectToDraw.CM_ROROSlotController;
		slotDefn := slotLC.mySlotDefn;	
		
		if slotDefn.isAvailable then	

			if self.allSelectedObjects.includes(_objectToDraw) then
				return Gray;
			elseif self.allSelectedObjectsAlt.includes(_objectToDraw) then
				return DarkGray;
			else
				if self.modeView = ShpDisplayMode_Actual then
					slotLC.getTIs(self.allTempTIs, REAL_MODE, true);
					theTI := self.allTempTIs.first();
					if theTI &lt;&gt; null then
						return theTI.getDrawingColour(TI_ColourMode_DischargePort);
					endif;
				elseif self.modeView = ShpDisplayMode_ColCodeLoad then
					if slotDefn.mySlotController.myRORORequestLoad &lt;&gt; null then
						return slotDefn.mySlotController.myRORORequestLoad.getAllocationColour();
					else
						slotDefn.mySlotController.getTIs(self.allTempTIs, REAL_MODE, true);
						theTI := self.allTempTIs.first();
						if theTI &lt;&gt; null then
							if slotDefn.mySlotController.myRORORequestDischarge &lt;&gt; null then
								return White; // PAR 29050 slotDefn.mySlotController.myRORORequestDischarge.getAllocationColour();
							else
								// PAR 29050 return Grey; // Remain on Board
								return theTI.getDrawingColour(TI_ColourMode_DischargePort); // PAR 29050 un comment this
							endif;
						else
							return self.SlotDefnAvailableColour;
						endif;
					endif;
				elseif self.modeView = ShpDisplayMode_Proposed then			//cnwas3 par 28401
					create theTIs transient;
					slotDefn.mySlotController.getProposedTIs(theTIs);					
					theTI := theTIs.first();
					if theTI &lt;&gt; null then
						return theTI.getDrawingColour(TI_ColourMode_DischargePort);
					else
						return self.SlotDefnAvailableColour;
					endif;					
				elseif self.modeView = ShpDisplayMode_ColCodeDisch then
					// PAR 29897
					if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow // PAR 31366 added to SHOW
					and slotDefn.mySlotController.myRORORequestLoad &lt;&gt; null 
					and slotDefn.mySlotController.myRORORequestLoad.isComplete then
/* PAR 31366
					// PAR 31073  hide the export / rehandle loaded TI?
						theTI := slotDefn.mySlotController.myRORORequestLoad.getTrackedItem();
						if theTI &lt;&gt; null then
							if theTI.isExport or theTI.isRehandle or theTI.isSOB then
								return White;
							endif;
						endif;
						*/
						return slotDefn.mySlotController.myRORORequestLoad.getAllocationColour();
						
					//cnwmc5 - 1 August 2013- PAR 31651
					elseif self.modeViewSubSub = ShpDisplayModeSub_ExportsHide
					and slotDefn.mySlotController.myRORORequestDischarge &lt;&gt; null then
						return slotDefn.mySlotController.myRORORequestDischarge.getAllocationColour();
					else
						slotDefn.mySlotController.getTIs(self.allTempTIs, REAL_MODE, true);
						theTI := self.allTempTIs.first();
						if theTI &lt;&gt; null then
							if self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31073 
								if theTI.isExport or theTI.isRehandle or theTI.isSOB then
									return White;
								endif;
							endif;
						
						
							return theTI.getDrawingColour(TI_ColourMode_DischargePort);// PAR 29052 Grey; // Remain on Board
						else
							return self.SlotDefnAvailableColour;
						endif;
					endif;
				else
					return self.SlotDefnAvailableColour;
				endif;
			endif;
		else
			return self.SlotDefnNotAvailableColour;
		endif;
	else
		return White;
	endif;		
	return White;
epilog
	if theTIs &lt;&gt; null then
		delete theTIs;
	endif;
end;</source>
        <Parameter name="_objectToDraw" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentObjectLabel" id="3a1aa650-72f5-4576-9a31-a04626bb20f0">
        <source>getCurrentObjectLabel(_objectToDraw : Object) : String;
/*
Purpose:			
Date		Who		Reason
01 August 2011	cnwab1	Initial creation
*/

vars
	slotLC : CM_ROROSlotController;
	tmpStr : String;
	slotDefn : CM_ROROSlotDefnVoyage;
	theTI : CM_TrackedItem;
	is40, wleComplete : Boolean;
	req : CM_RORORequest;
	slotReq : CM_ROROSlotRequest;
begin
	self.allTempTIs.clear();
	
	if _objectToDraw.isKindOf(CM_ROROLocnDefn) then
		return _objectToDraw.CM_ROROLocnDefn.code;
		
	elseif _objectToDraw.isKindOf(CM_ROROSlotController) 
	or _objectToDraw.isKindOf(CM_ROROSlotDefn) then
		if _objectToDraw.isKindOf(CM_ROROSlotController)  then
			slotLC := _objectToDraw.CM_ROROSlotController;
			slotDefn := slotLC.mySlotDefn;	
		else
			slotDefn := _objectToDraw.CM_ROROSlotDefnVoyage;		
			slotLC := slotDefn.mySlotController;
		endif;
		if slotDefn.isAvailable then			
			if self.modeView = ShpDisplayMode_ColCodeLoad then
				if self.modeViewSub = ShpDisplayModeSub_Colour then
						return self.getLabelTIUpper(slotLC);
				elseif self.modeViewSub = ShpDisplayModeSub_Text then
					return self.getLabelTIUpper(slotLC);
				endif;
			elseif self.modeView = ShpDisplayMode_ColCodeDisch then
				if self.modeViewSub = ShpDisplayModeSub_Colour then
					// PAR 29897
					if slotLC.myRORORequestLoad &lt;&gt; null and slotLC.myRORORequestLoad.isComplete then
					/* PAR 31366
						// PAR 31073 - 'hide' exports / rehandles ?
						if self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then 
							theTI := slotLC.myRORORequestLoad.getTrackedItem();
							if theTI &lt;&gt; null and (theTI.isExport or theTI.isRehandle or theTI.isSOB) then
								return null;
							endif;
						endif;
					*/
					
						return self.getLabelTIUpper(slotLC);
					
					elseif slotLC.myRORORequestDischarge &lt;&gt; null then						
						// PAR 28939
						tmpStr := slotLC.myRORORequestDischarge.getAllocationISOGroup();
						req := slotLC.myRORORequestDischarge; // PAR 30022
						
						//cnwmc5 - 2 August 2013 - PAR 31651
						if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow then
							if req.isComplete then 
								return null;
							elseif req.getAttrIsBackend() then
								if req.getFwdSlotReq.isComplete then
									return null;
								endif;
							endif;
						endif;
						
						//is40 := (req.getAttrIs30() or req.getAttrIs40() or req.getAttrIs45() or req.getAttrIs53()); // PAR 30022
						is40 := req.getAttrIsNOT20(); // PAR 30253
						if is40 then  // PAR 30022
						// PAR 30022if slotLC.myRORORequestDischarge.getAttrIs40() then
							return tmpStr;
						else
							if tmpStr.length() &gt; 6 then
								return tmpStr[1 : tmpStr.pos(" ",1)];
							else
								return tmpStr;
							endif;
						endif;
					else
						return "";
					endif;
				elseif self.modeViewSub = ShpDisplayModeSub_Text then
					// PAR 31073
					slotReq := slotLC.myRORORequestLoad.CM_ROROSlotRequest;
					if slotReq &lt;&gt; null then						
						wleComplete := slotReq.isComplete;
						if slotReq.getAttrIsNOT20() and slotReq.getAttrIsBackend() then // 40 foot backend
							wleComplete := slotReq.mySlotRequestForward.isComplete;
							if wleComplete then
								slotReq := slotReq.mySlotRequestForward;
							endif;
						endif;
						
						//cnwmc5 - 2 August 2013 - PAR 31651
						if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow then
							if not slotReq.isComplete then
								req := slotLC.myRORORequestDischarge;
								if req &lt;&gt; null then
									if req.isComplete then 
										return null;
									elseif req.getAttrIsBackend() then
										if req.getFwdSlotReq.isComplete then
											return null;
										endif;
									endif;
								endif;
							endif;
						endif;
					endif;
					
					
					/* PAR 31366
					if wleComplete then
						// PAR 31073 - hide exports / rehandles ?
						if self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then 
							theTI := slotReq.getTrackedItem();
							if theTI &lt;&gt; null and (theTI.isExport or theTI.isRehandle or theTI.isSOB) then
								return null;
							endif;
						endif;
					endif;
					*/
					return self.getLabelTIUpper(slotLC);
				endif;
			elseif self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_Proposed then //cnwas3 par 28401
				return self.getLabelTIUpper(slotLC);
			else
				return null;
			endif;
		else
			return "    X";
		endif;
	else
		return null;
	endif;	
epilog

end;</source>
        <Parameter name="_objectToDraw" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentObjectLabelLower" id="6b6a74b5-5c7c-44db-86f3-059b3437e1bf">
        <source>getCurrentObjectLabelLower(_objectToDraw : Object) : String;
/*
Purpose:			
Date		Who		Reason
01 August 2011	cnwab1	Initial creation
*/

vars
	slotLC : CM_ROROSlotController;
	slotReq : CM_ROROSlotRequest;
	slotDefn : CM_ROROSlotDefnVoyage;
	theTI : CM_TrackedItem;
begin
	if _objectToDraw.isKindOf(CM_ROROLocnDefn) then
		return _objectToDraw.CM_ROROLocnDefn.code;
		
	elseif _objectToDraw.isKindOf(CM_ROROSlotController) 
	or _objectToDraw.isKindOf(CM_ROROSlotDefn) then
		if _objectToDraw.isKindOf(CM_ROROSlotController)  then
			slotLC := _objectToDraw.CM_ROROSlotController;
			slotDefn := slotLC.mySlotDefn;	
		else
			slotDefn := _objectToDraw.CM_ROROSlotDefnVoyage;		
			slotLC := slotDefn.mySlotController;
		endif;
		if slotDefn.isAvailable then			
			if self.modeView = ShpDisplayMode_ColCodeLoad then
				if self.modeViewSub = ShpDisplayModeSub_Colour then
					return null; 
				elseif self.modeViewSub = ShpDisplayModeSub_Text then
					return self.getLabelTILower(slotLC);
				endif;
			elseif self.modeView = ShpDisplayMode_ColCodeDisch then
				if self.modeViewSub = ShpDisplayModeSub_Colour then
					return null;
				elseif self.modeViewSub = ShpDisplayModeSub_Text then
					return self.getLabelTILower(slotLC);
				endif;
			elseif self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_Proposed then //cnwas3 par 28401
				return self.getLabelTILower(slotLC);

			else
				return null;
			endif;
		else
			return null;
		endif;
	else
		return null;
	endif;	
epilog

end;</source>
        <Parameter name="_objectToDraw" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHazardClass" id="0703ba2b-424b-471d-814c-671aa5953489">
        <source>getHazardClass(_ti : CM_TrackedItem) : CM_HazardClass;
/*
Purpose:	 // PAR 37527		
Date				Who			Reason
MARCH 2016	CNWAB1		Initial creation
*/

vars
	ti : CM_TrackedItem;
	request : CM_ROROSlotRequest;
	allocation : CM_YardAllocation;
	criteria : CM_YACriteria;
	hazardClass : CM_HazardClass;
	dataValue : String;						
	hazCode : String;						
	pos : Integer;							

begin
	// do we have a TI? - get the hazard class from there
	if _ti &lt;&gt; null then
		ti := _ti;
	else
		ti := self.allTrackedItems.first;
	endif;
	if ti &lt;&gt; null and not ti.allTIHazards.isEmpty then
		hazardClass := app.myRoot.allHazardClasses[ti.allTIHazards.first.code];
		return hazardClass;
	endif;
		
	// if no TI, do we have a slot request with a voyage allocation for hazard class
	if self.myCurrentROROSlotDefn &lt;&gt; null then
		request := self.myCurrentROROSlotDefn.mySlotController.allRequestsLoad.first.CM_ROROSlotRequest;
		if request &lt;&gt; null then
			criteria := request.getAttrByType(YACriteriaType_Hazardous);
			if criteria &lt;&gt; null then
				dataValue := criteria.myYAData.getDataValue.String;	
				if dataValue.pos(",", 1) &lt;&gt; null then	
					pos := 1;
					hazCode := dataValue.cnGetToken(pos, ",");	
				else		
					hazCode := dataValue;	
				endif;
				
				hazardClass := app.myRoot.allHazardClasses[hazCode];	
				return hazardClass;
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_HazardClass"/>
    </JadeMethod>
    <JadeMethod name="getLabelTILower" id="02780ac7-6595-4961-9f63-5067b192f1ff">
        <source>getLabelTILower(slotLC : CM_VoyageROROController) : String;
/*
Purpose:			
Date		Who		Reason
09 August 2011	cnwab1	Initial creation
*/

vars
	theTI : CM_TrackedItem;
	req : CM_RORORequest;
	job : CM_VoyageJob;
	tmpStr : String;
	is40 : Boolean;
begin
	if self.modeView = ShpDisplayMode_ColCodeLoad then
		req := slotLC.myRORORequestLoad;
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
		req := slotLC.myRORORequestDischarge;
	endif;


	if self.modeWork = SHP_ROROPlanningForm.WorkMode_Plan then
		if self.modeView = ShpDisplayMode_ColCodeLoad then
			slotLC.getTIs(self.allTempTIs, PLANNING_MODE, true);
		elseif self.modeView = ShpDisplayMode_Proposed then
			slotLC.CM_ROROSlotController.getProposedTIs(self.allTempTIs);
		else													//cnwmc5 - 13 Jan 2013 - PAR 32711
			slotLC.getTIs(self.allTempTIs, REAL_MODE, true);	//cnwmc5 - 13 Jan 2013 - PAR 32711
		endif;
		if self.allTempTIs.isEmpty() 
		and self.mySideViewFrame = null then					//cnwmc5 - 13 Jan 2013 - PAR 32711
			slotLC.getTIs(self.allTempTIs, REAL_MODE, true);
		endif;
	else
		if self.modeView = ShpDisplayMode_Actual then		// PAR 28991
			slotLC.getTIs(self.allTempTIs, REAL_MODE, true);			
// 28990			if self.allTempTIs.isEmpty() and req = null then
//				slotLC.getTIs(self.allTempTIs, PLANNING_MODE, true); 
//			endif;
		elseif self.modeView = ShpDisplayMode_Proposed then		// PAR 28991
			slotLC.getProposedTIs(self.allTempTIs); // PAR 29050
			/*
			slotLC.getTIs(self.allTempTIs, PLANNING_MODE, true); // PAR 28585
			if req = null and self.allTempTIs.isEmpty then
				slotLC.getTIs(self.allTempTIs, REAL_MODE, true); // PAR 28585
			
			endif;
			*/
		endif;
	endif;
	
	
	theTI := self.allTempTIs.first();
	if theTI &lt;&gt; null then
		if self.modeViewSub = ShpDisplayModeSub_Colour then
			return null;
		elseif self.modeViewSub = ShpDisplayModeSub_Text then
			if theTI.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD 
			or (theTI.getImExStatus = TI_IMEX_STATUS_IMPORT and theTI.isOnShip())		//cnwmc5 - 5 March 2014 - PAR 32711
			and self.modeView = ShpDisplayMode_ColCodeLoad then // PAR 29050 no labels for Remain on Board
				return null;
			endif;
			if theTI.isTwenty() then
				if theTI.id.length = 11 then
					return "  " &amp; theTI.id[5:end];
				elseif theTI.id.length &lt; 11 then
					return "          " &amp; (theTI.totalWeight / 1000).asStringWeightJMT() &amp; "t";
				else
					return theTI.id[(theTI.id.length/2).Integer : end];
				endif;
			else
				return null;
			endif;
		else
			return theTI.id;
		endif;
		
	// PAR 28887
	elseif req &lt;&gt; null then
	//	is40 := (req.getAttrIs40() or req.getAttrIs30() or req.getAttrIs45() or req.getAttrIs53()); // PAR 30022 
		is40 := req.getAttrIsNOT20(); // PAR 30253
	
		// PAR 29467
		if self.modeView = ShpDisplayMode_ColCodeLoad then
			if self.modeViewSub = ShpDisplayModeSub_Colour then
				tmpStr := req.getAllocationISOGroup();
			else
				if is40 then // PAR 30022 
				// PAR 30022 if req.getAttrIs40 then
					return null;
				endif;
				tmpStr := req.getAllocationHazGroup();
			endif;
			return tmpStr;
		else
	
	
			tmpStr := req.getAllocationISOGroup();
			
			if is40 then // PAR 30022 
			// PAR 30022 if req.getAttrIs40 then
				return null;
			else
				if tmpStr.length() &gt; 6 then
					return tmpStr[tmpStr.pos(" ",1) : end];
				else
					return null;
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="slotLC" type="CM_VoyageROROController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLabelTIUpper" id="130274f9-daca-49e8-abbd-a3a8bd05a327">
        <source>getLabelTIUpper(slotLC : CM_ROROSlotController) : String;
/*
Purpose:			
Date		Who		Reason
09 August 2011	cnwab1	Initial creation
12 May 2021	navma1	Bug 51149: SNO - Planning containers with mismatching weight
*/

vars
	theTI			  : CM_TrackedItem;
	req				  : CM_RORORequest;
	job 			  : CM_VoyageJob;
	tmpStr 			  : String;
	havePlannedExport : Boolean;
	is40 			  : Boolean;
	tiWT              : Decimal[14,4];
begin
	if self.modeView = ShpDisplayMode_ColCodeLoad then
		req := slotLC.myRORORequestLoad;
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
			// PAR 31366
		if self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then
			req := slotLC.myRORORequestDischarge;
			if req = null then
				return "";// PAR 31366
			endif;
		else
			// PAR 29897
			if slotLC.myRORORequestLoad &lt;&gt; null and slotLC.myRORORequestLoad.isComplete then
				req := null;
			else
				req := slotLC.myRORORequestDischarge;
			endif;
		endif;
	endif;

	if self.modeView = ShpDisplayMode_ColCodeLoad 
	or self.modeView = ShpDisplayMode_ColCodeDisch then	
		if self.modeWork = SHP_ROROPlanningForm.WorkMode_Plan then
			if self.modeView = ShpDisplayMode_ColCodeLoad then
				slotLC.getTIs(self.allTempTIs, PLANNING_MODE, true);
				if self.allTempTIs.isEmpty() and req = null then // PAR 28990
					slotLC.getTIs(self.allTempTIs, REAL_MODE, true);	
				else
					havePlannedExport := true;
				endif;
			else														//cnwmc5 - 13 Jan 2013 - PAR 32711
				slotLC.getTIs(self.allTempTIs, REAL_MODE, true);		//cnwmc5 - 13 Jan 2013 - PAR 32711
			endif;
		else
			if self.modeView = ShpDisplayMode_ColCodeDisch then
				if req &lt;&gt; null then
					req.getAllTrackedItems(self.allTempTIs);
				else
					slotLC.getTIs(self.allTempTIs, REAL_MODE, true);
				endif;
			elseif self.modeView = ShpDisplayMode_ColCodeLoad then // PAR 29050
				slotLC.getTIs(self.allTempTIs, PLANNING_MODE, true); // PAR 28585
				if self.allTempTIs.isEmpty() and req = null then
					slotLC.getTIs(self.allTempTIs, REAL_MODE, true);	
				else
					havePlannedExport := true;
				endif;
			endif;
		endif;
	elseif self.modeView = ShpDisplayMode_Proposed 
	or self.modeView = ShpDisplayMode_Actual then
		if self.modeWork = SHP_ROROPlanningForm.WorkMode_Plan then
			if self.modeView = ShpDisplayMode_Proposed then		//cnwas3 par 28401
				slotLC.getProposedTIs(self.allTempTIs);
				if self.allTempTIs.isEmpty()
				and self.mySideViewFrame = null then					//cnwmc5 - 13 Jan 2013 - PAR 32711
					slotLC.getTIs(self.allTempTIs, REAL_MODE, true);
				endif;
			else														//cnwmc5 - 13 Jan 2013 - PAR 32711
				slotLC.getTIs(self.allTempTIs, REAL_MODE, true);		//cnwmc5 - 13 Jan 2013 - PAR 32711
			endif;
		else
			if self.modeView = ShpDisplayMode_Proposed then		//cnwas3 par 28401
				slotLC.getProposedTIs(self.allTempTIs);
			elseif self.modeView = ShpDisplayMode_Actual then		// PAR 28991
				slotLC.getTIs(self.allTempTIs, REAL_MODE, true);			
			endif;
		endif;
	
	endif;

	theTI := self.allTempTIs.first();

	if theTI &lt;&gt; null then
		
		if self.modeView = ShpDisplayMode_ColCodeLoad  then// PAR 29050 no labels for Remain on Board
			if self.modeViewSub = ShpDisplayModeSub_Colour 
			or self.modeViewSub = ShpDisplayModeSub_Text then
				if not havePlannedExport then
					return null;
				endif;
			endif;
		endif;
		
		tiWT := (theTI.totalWeight / 1000).rounded();  								//12.05.2021 navma1 #51149
		
		if self.modeViewSub = ShpDisplayModeSub_Colour then		
			return theTI.getShortDPortCode() &amp; " " &amp; tiWT.asStringWeightJMT();  	//12.05.2021 navma1 #51149
		elseif self.modeViewSub = ShpDisplayModeSub_Text then
			if theTI.isTwenty() then
				if theTI.id.length = 11 then
					return theTI.id[1:4] &amp; "  " &amp; tiWT.asStringWeightJMT() &amp; "t"; 	//12.05.2021 navma1 #51149
				elseif theTI.id.length &lt; 11 then
					return theTI.id;
				else
					return theTI.id[1:(theTI.id.length/2).Integer];
				endif;
			else // FORTY
				return theTI.id &amp; "  " &amp; tiWT.asStringWeightJMT() &amp; "t";           //12.05.2021 navma1 #51149
			endif;
		else
			return theTI.id;
		endif;
	else
	// PAR 28887
		if self.modeView = ShpDisplayMode_ColCodeLoad then
			if req &lt;&gt; null then
				is40 := req.getAttrIsNOT20(); // PAR 30253
				if self.modeViewSub = ShpDisplayModeSub_Colour then
					tmpStr := req.getAllocationISOGroup();
				else
					if is40 then // PAR 30022 
					// PAR 30022  if req.getAttrIs40 then
						tmpStr := req.getAllocationWeightGroup(); // PAR 29467
						tmpStr := tmpStr &amp; "  " &amp; req.getAllocationHazGroup(); // PAR 29467
					else
						tmpStr := req.getAllocationWeightGroup(); // PAR 29467
					endif;
					if tmpStr.trimBlanks = null then
						tmpStr := req.getAllocationISOGroup();
					endif;
				endif;
				
				if is40 then // PAR 30022 
				// PAR 30022 if req.getAttrIs40 then
					return tmpStr;
				else
					if tmpStr.length() &gt; 6 then
						return tmpStr[1 : tmpStr.pos(" ",1)];
					else
						return tmpStr;
					endif;
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="slotLC" type="CM_ROROSlotController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumSelected" id="516009f5-821a-4096-9124-d9c5e1ed2a4f">
        <source>getNumSelected() : Integer;
/*
Purpose:			
Date		Who		Reason
08 August 2011	cnwab1	Initial creation
*/

vars

	obj : Object;
	idx : Integer;
begin
	foreach obj in self.allSelectedObjects do
		if obj.isKindOf(CM_ROROLocnDefn) then
			continue;
		endif;
		idx := idx + 1;
	endforeach;

	return idx;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDLRItems" id="7fa1be4a-aeca-48c0-81b3-3b6b5aed4d80">
        <source>getSelectedDLRItems(_theLeftRequests: CM_RequestArray input);
/*
Purpose:			
Date		Who		Reason
10 October 2011	cnwab1	Initial creation
*/

vars

	theForm : Form;
	tmpSlotController	: CM_VoyageROROController;
	aRequest : CM_RORORequest;
	tmpObj		: Object;
begin
	app.mousePointer := Window.MousePointer_HourGlass;


	foreach tmpObj in self.allSelectedObjects do
		// ### ONLY DO THIS FOR CONTAINER SLOTS
		if (not tmpObj.isKindOf(CM_VoyageROROController)) then
			continue;
		endif;
		tmpSlotController := tmpObj.CM_VoyageROROController;		

		aRequest := null;
		if self.modeView = ShpDisplayMode_ColCodeDisch then
			aRequest := tmpSlotController.myRORORequestDischarge;
		else
			aRequest := tmpSlotController.myRORORequestLoad;
		endif;
		//13/07/2010 cnwdz2 24599
		if aRequest = null then
			continue;
		endif;
		
		if aRequest.moveType &lt;&gt; DLR_MOVETYPE and aRequest.moveType &lt;&gt; SOB_MOVETYPE then
			aRequest := null;
		endif;
		if aRequest &lt;&gt; null then
			if not _theLeftRequests.includes(aRequest) then
				_theLeftRequests.add(aRequest);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_theLeftRequests" type="CM_RequestArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDLRSOBSlots" id="f6c77220-ba47-4060-a0f6-2ae8ada6185f">
        <source>getSelectedDLRSOBSlots(theSlots,	theSlotsAlt : CM_LCArray input; _isLoad : Boolean) : Boolean;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	obj : Object;
	lc : CM_LocationsController;
	vlc, other : CM_VoyageROROController;
	defn, loadDefn : CM_DeckItem;
begin
		foreach obj in self.allSelectedObjects do
			if obj.isKindOf(CM_RORORequest) then
				vlc := obj.CM_RORORequest.myROROController.CM_VoyageROROController;
				if vlc.myRORORequestDischarge &lt;&gt; null and not vlc.myRORORequestDischarge.isBackEndRequest() then
					if not theSlots.includes(vlc) then
						theSlots.add(vlc);
					endif;
				endif;
			elseif obj.isKindOf(CM_ROROSlotController) then
				vlc := obj.CM_VoyageROROController;
// PAR 31348				if vlc.myRORORequestDischarge = null then // Allow individual items in the side view to turn on and off DLR and SoB
					if not theSlots.includes(vlc) then
						theSlots.add(vlc);
					endif;
//				endif;
			endif;
	
		endforeach;
		
		if not _isLoad then // PAR 31144
		
			// #### Get all the ALT key selected points
			foreach obj in self.allSelectedObjectsAlt do : altLoop
				if obj.isKindOf(CM_RORORequest) then
					// Ignore
				elseif obj.isKindOf(CM_ROROSlotController) then
					vlc := obj.CM_VoyageROROController;
					
					// PAR 32021 if the user is doing an ALT SoB in the sideview then the ALT parts are rotated, need to get the ALT LCs. 
					//					This is because is discharge view we do not show the rotated load locns we show the unrotated actual locns
					defn := vlc.getDefn(); 
					if defn.CM_ROROLocnDefnVoyage.isRotatedLinked(true) then
						loadDefn := defn.CM_ROROLocnDefnVoyage.getRotatedLinked();
						other := loadDefn.CM_ROROLocnDefnVoyage.getLCForRotation(vlc.CM_ROROSlotController);
						if other &lt;&gt; null then
							vlc := other;
							self.allObjectEditions.add(vlc);
						endif;
					endif;

					if vlc.myRORORequestLoad = null  then
						if not theSlotsAlt.includes(vlc) then
							theSlotsAlt.add(vlc);
						endif;
					endif;
				endif;
				if theSlotsAlt.size = theSlots.size then
					break altLoop;
				endif;
			endforeach;
		endif;
		return true;

epilog

end;</source>
        <Parameter name="theSlots" type="CM_LCArray" usage="input"/>
        <Parameter name="theSlotsAlt" type="CM_LCArray" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObjectsAndALT" id="9647510c-a319-4cda-a09f-a523c6002cb1">
        <source>getSelectedObjectsAndALT(theSlots,	theSlotsAlt : CM_LCArray input) : Boolean;
/*
Purpose:			
Date		Who		Reason
02 August 2011	cnwab1	Initial creation
*/

vars
	obj : Object;
		theLCs : CM_LCSet;
begin
	create theLCs transient;
	if not self.allSelectedObjects.isEmpty() then
		foreach obj in self.allSelectedObjects do
			//if obj.isKindOf(CM_DeckItem) then
				//obj.CM_DeckItem.getLCs(theLCs, true);
				//theLCs.copy(theSlots);
			if obj.isKindOf(CM_RORORequest) then
				theSlots.add(obj.CM_RORORequest.myROROController);
			elseif obj.isKindOf(CM_ROROSlotController) then
				theSlots.add(obj.CM_ROROSlotController);
			endif;
		endforeach;
		// #### Get all the ALT key selected points
		foreach obj in self.allSelectedObjectsAlt do
			//if obj.isKindOf(CM_DeckItem) then
			//	obj.CM_DeckItem.getLCs(theLCs, true);
			//	theLCs.copy(theSlotsAlt);
			//else
			if obj.isKindOf(CM_ROROSlotController) then
				theSlotsAlt.add(obj.CM_ROROSlotController);
			endif;
		endforeach;
		
		return true;
	else
		return false;
	endif;

epilog
	delete theLCs;
end;</source>
        <Parameter name="theSlots" type="CM_LCArray" usage="input"/>
        <Parameter name="theSlotsAlt" type="CM_LCArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTIsForMode" id="6b970e5a-fda2-4006-8d35-386803778e70">
        <source>getSelectedTIsForMode(_allTIs : CM_TIArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	iter : Iterator;
	obj  : Object;
	req : CM_RORORequest;
	slotLC : CM_ROROSlotController;
	allTIs : CM_TIArray;
begin
	create allTIs transient;
	iter:= self.allSelectedObjects.createIterator;
	while iter.next(obj) do
		allTIs.clear;
		if obj.isKindOf(CM_ROROSlotController) then
			slotLC:= obj.CM_ROROSlotController;
			if self.modeView = ShpDisplayMode_ColCodeLoad then
				req := slotLC.myRORORequestLoad;
			elseif self.modeView = ShpDisplayMode_ColCodeDisch then
				req := slotLC.myRORORequestDischarge;
			endif;
			
			if self.modeWork = SHP_ROROPlanningForm.WorkMode_Plan then
				if self.modeView = ShpDisplayMode_ColCodeLoad then
					slotLC.getTIs(allTIs, PLANNING_MODE, true);
					if allTIs.isEmpty() then 
						slotLC.getTIs(allTIs, REAL_MODE, true);	
					endif;
				elseif self.modeView = ShpDisplayMode_Proposed then		//cnwas3 par 28401
					slotLC.getProposedTIs(allTIs);
					if allTIs.isEmpty() then
						slotLC.getTIs(allTIs, REAL_MODE, true);
					endif;
				endif;
			else
				if self.modeView = ShpDisplayMode_ColCodeDisch then
					if req &lt;&gt; null then
						req.getAllTrackedItems(allTIs);
					else
						slotLC.getTIs(allTIs, REAL_MODE, true);
					endif;
				elseif self.modeView = ShpDisplayMode_Proposed then		//cnwas3 par 28401
					slotLC.getProposedTIs(allTIs);
				elseif self.modeView = ShpDisplayMode_Actual then		// PAR 28991
					slotLC.getTIs(allTIs, REAL_MODE, true);			
		
				elseif self.modeView = ShpDisplayMode_ColCodeLoad then // PAR 29050
					slotLC.getTIs(allTIs, PLANNING_MODE, true); // PAR 28585
					if allTIs.isEmpty() then
						slotLC.getTIs(allTIs, REAL_MODE, true);	
					endif;
				endif;
			endif;			
		endif;
		
		allTIs.copy(_allTIs);
	endwhile;
	

	
epilog
	delete iter;
	delete allTIs;
end;</source>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSpecialStow" id="7e5119a1-cd6a-4508-9ecf-5ad05f1f5eb3">
        <source>getSpecialStow(_ti : CM_TrackedItem) : CM_SpecialStow;
/*
Purpose:	 // PAR 37527		
Date				Who			Reason
MARCH 2016	CNWAB1		Initial creation
*/

vars
	ti : CM_TrackedItem;
	request : CM_RORORequest;
	allocation : CM_YardAllocation;
	criteria : CM_YACriteria;
	specialStows : CM_ObjectSet;
	specialStow : CM_SpecialStow;

begin
	// do we have a TI? - get the hazard class from there
	if _ti &lt;&gt; null then
		ti := _ti;
	endif;
	if ti &lt;&gt; null then
		specialStow := app.myRoot.allSpecialStows[ti.specialStow];
		return specialStow;
	endif;
		
	// if no TI, do we have a slot request with a voyage allocation for hazard class
	if self.myCurrentROROSlotDefn &lt;&gt; null then
		request := self.myCurrentROROSlotDefn.mySlotController.allRequestsLoad.first.CM_ROROSlotRequest;
		if request &lt;&gt; null then
			criteria := request.getAttrByType(YACriteriaType_SpecialStow);
			if criteria &lt;&gt; null then
				specialStows := criteria.myYAData.getDataValue.CM_ObjectSet;
				if not specialStows.isEmpty then
					return specialStows.first.CM_SpecialStow;
				endif;
			endif;
		endif;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_SpecialStow"/>
    </JadeMethod>
    <JadeMethod name="init" id="c179834b-c608-42b2-913a-22aed2996a3f">
        <updating/>
        <source>init(_vessel : CM_Vessel) updating;
/*
Date		    Who			Reason
14 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	locnDefn 			: CM_DeckItem;
	slotDefn 			: CM_ROROSlotDefnVoyage;
	alreadyInitialised	: Boolean;
begin
	self.myVessel := _vessel;
	self.sideDrawingMargin := 10;
	if self.myOverViewFrame &lt;&gt; null then
		alreadyInitialised := true;
	else
		self.myOverViewFrame := self.myCargoSideViewForm.frmLocationPos;
		self.mySideViewFrame := self.myCargoSideViewForm.frmLocationSlots;	
		self.initModes();
	endif;	
	
	self.allLocnDefns.clear();
	self.allLocnDefnsByRowCol.clear();
	self.allLocnDefnsByX1Y1X2Y2.clear();
	self.allSlotDefnsByX1Y1X2Y2.clear();

	if not alreadyInitialised then
		self.setupDimensions();
	endif;
epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
