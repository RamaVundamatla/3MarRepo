end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setValidOperatorCodes" id="ed3081a4-ed25-4dff-8d49-c66797937134">
        <updating/>
        <source>setValidOperatorCodes(_validOperators : StringArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2018	jlgrh7	Initial creation TFS39472 Internal EDI Format for Voyage doesn't allow the entry of Valid Operators

*/

vars

begin
	self.allValidOperatorCodes.clear();
	_validOperators.copy(self.allValidOperatorCodes);
epilog

end;</source>
        <Parameter name="_validOperators" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setValidOperatorsFromString" id="ac64cf8b-e41e-47b0-884f-0b2c33dfd7f6">
        <updating/>
        <source>setValidOperatorsFromString(_str : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2018	jlgrh7	Initial creation  TFS39472 Internal EDI Format for Voyage doesn't allow the entry of Valid Operators

*/




vars

	strArray : StringArray;

begin

	self.allValidOperatorCodes.clear();

	strArray := _str.getTokens();
	if strArray &lt;&gt; null and not strArray.isEmpty then
		strArray.copy( self.allValidOperatorCodes );
	endif;

epilog

	delete strArray;

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setVisitType" id="1d4e35ed-c5d3-4ce1-9348-d26d0fec83a0">
