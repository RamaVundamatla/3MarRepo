        <source>makeUNZSegment(_protocol :CM_CamProtocol; _count, _seqNumber :Integer):String protected;
/*
Purpose:	Make a UNZ segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
constants
