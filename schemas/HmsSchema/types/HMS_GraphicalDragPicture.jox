    <JadeMethod name="calculateMovementRange" id="4e95c617-a4bf-40a9-8440-179e837d8275">
        <updating/>
        <source>calculateMovementRange() updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	workingMove,
	prevMove,
	nextMove  : CMIF_HMS_WorkingMovement;	 
	tmpDragPict  : HMS_GraphicalDragPicture;
	tmpDict : HMS_DragPictureByWorkVoyDict;
	y	: Real;
	r	: Real;
	int : Integer;
	size: Integer;
begin
	// This method sets the minimum and maximum values that a particular sprite can move (eg stopping the gui from
	// allowing the user to move the arrival date to later than the departure date). 
	workingMove	:= self.myWorkingMovement;
	if workingMove = null then
		return;
	endif;
	nextMove := self.myNextWorkingMovement;
	prevMove := workingMove.getMovementPrevious();

	if self.origEdge = HMS_Edge_Bottom then
		if prevMove = null then
			self.edgeBottomMax := self.parent.height - HMS_WharfDrawControl.Wharf_Label_Height + self.height;// - Movement_View_Threshold;
		else
			// calculate the bottom position that the sprite can be moved to - based on the immediately prior movement
			r := prevMove.occursOnDT.minutesDiff(self.myGraphicalViewForm.myViewController.viewFinishDT);
			y := (r / self.myGraphicalViewForm.minutesPerPixel).rounded;
			self.edgeBottomMax := y;// - Movement_View_Threshold;
		endif;
		self.edgeBottomMin := self.top;// + Movement_View_Threshold;
	elseif self.origEdge = HMS_Edge_Top then
		if nextMove.getMovementNext = null then
			self.edgeTopMin := 0;
		else
			// calculate the bottom position that the sprite can be moved to - based on the immediately prior movement
			r := nextMove.getMovementNext.occursOnDT.minutesDiff(self.myGraphicalViewForm.myViewController.viewFinishDT);
			y := (r / self.myGraphicalViewForm.minutesPerPixel).rounded;
			self.edgeTopMin := y;// + Movement_View_Threshold;
		endif;
		self.edgeTopMax := self.top + self.height;// - Movement_View_Threshold;
	else
		if prevMove = null then
			self.edgeBottomMax := self.parent.height - HMS_WharfDrawControl.Wharf_Label_Height + self.height;// - Movement_View_Threshold;
		else			
			// calculate the bottom position that the sprite can be moved to - based on the immediately prior movement
			r := prevMove.occursOnDT.minutesDiff(self.myGraphicalViewForm.myViewController.viewFinishDT);
			y := (r / self.myGraphicalViewForm.minutesPerPixel).rounded;
			self.edgeBottomMax := y;// - Movement_View_Threshold;
		endif;
		if nextMove &lt;&gt; null then
			if nextMove.getMovementNext = null then
				self.edgeBottomMin := 0 - self.height;// + Movement_View_Threshold;
			else
				// calculate the bottom position that the sprite can be moved to - based on the immediately prior movement
				r := nextMove.getMovementNext.occursOnDT.minutesDiff(self.myGraphicalViewForm.myViewController.viewFinishDT);
				y := (r / self.myGraphicalViewForm.minutesPerPixel).rounded;
				self.edgeBottomMin := y + self.height;// + Movement_View_Threshold;
			endif;
		endif;
	endif;	

	self.myDragPicturePrevious 	:= null;
	self.myDragPictureNext		:= null;
	
	tmpDict := self.myGraphicalViewForm.allDragPictures;

	foreach tmpDragPict in tmpDict do
		// find the control that immediately follows the selected control
		if tmpDragPict.myWorkingMovement = nextMove then
			self.myDragPictureNext := tmpDragPict;
			tmpDragPict.savePosition();
		endif;
		// find the control that immediately precedes the selected control
		if tmpDragPict.myNextWorkingMovement = workingMove then
			self.myDragPicturePrevious := tmpDragPict;
			tmpDragPict.savePosition();
		endif;				
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="colourSelectedMovement3" id="999873fa-3ef1-419f-8588-83819815b1e7">
        <updating/>
        <source>colourSelectedMovement3(	_selectedMovement : CMIF_HMS_WorkingMovement;
							_scrollToSelected : Boolean;
							_allRestrictedObj:CMIF_HMS_WorkingVoyageSet) updating, protected;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//
// This method controls the eventual colors of the
// sprite.  There is a default selected or unselected
// color.  For Comalco, the default unselected color
// comes from the color defined on the applicable
// CM_Voyage object.
//
// Once the default color is set, then "voyage state"
// colors are applied to indicate the current state
// of the Voyage - generally the Voyage won't have a
// state, so the Voyage will retain its default color.
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 20/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 Allow colour from voyage to be shown in graphical view
//03 Oct 2017	cnwma1  	TFS #7257 JMT - Refactoring - Commodity Planning
// 01/10/2021	jlizm1		TFS 51963 SAL Voyage Request Changes
// 30/08/2022	jlizm1		TFS 54298 EUP - Simplified Voyage Work Order Process
vars
	workingVoyageObj	: CMIF_HMS_WorkingVoyage;
	voyageObj			: CM_Voyage;
	points				: RealArray;		//cnwmc5 - 28 May 2014 - PAR 34231
	voyageStatus		: Integer;			// TFS 51963
	
begin
	// Draw the indicator bar across the top or bottom of the sprite to indicate the selected
	// movement (selected either by mousedown or selection from a text view).
	if _selectedMovement &lt;&gt; null then
		if self.myWorkingMovement = _selectedMovement
		or self.myNextWorkingMovement = _selectedMovement
		then
			if _selectedMovement.moveType = HMSMovementTypeArrival then
				self.drawLine(0, self.height - self.drawWidth, self.width, self.height - self.drawWidth, Red);
				
			elseif _selectedMovement.moveType = HMSMovementTypeShift then
				if self.myNextWorkingMovement = _selectedMovement then
					self.drawLine(0, 1, self.width, 1, Red);
				else
					self.drawLine(0, self.height - self.drawWidth, self.width, self.height - self.drawWidth, Red);
				endif;
				
			elseif _selectedMovement.moveType = HMSMovementTypeDeparture then
				self.drawLine(0, 1, self.width, 1, Red);
			endif;

		endif;
	endif;

	workingVoyageObj	:=	self.myWorkingMovement.myWorkingVoyage;
	
	if self.myWorkingMovement.myHMSVoyageData &lt;&gt; null then
		voyageObj	:=	self.myWorkingMovement.myHMSVoyageData.myVoyage;		// cnwdad1 02/02/2007.
	endif;
	
	if workingVoyageObj &lt;&gt; null then
		if self.myWorkingMovement = _selectedMovement
		or self.myNextWorkingMovement = _selectedMovement
		or (_selectedMovement &lt;&gt; null and workingVoyageObj.allWorkingMovements.includes(_selectedMovement))
		then
			// Set the default color for a selected Voyage, then apply any applicable "voyage state" color.
			
			self.backColor	:=	MovementIsSelected;

			
			if self.myWorkingMovement.myPersistentMovement = null then
				self.backColor	:=	Yellow;

			endif;
			
			if self.myWorkingMovement = _selectedMovement
			or self.myNextWorkingMovement = _selectedMovement
			then
				self.myGraphicalViewForm.setCurrentSelectedDragPicture(self, null, self.left, self.top);
			endif;

			if _scrollToSelected then
				self.myGraphicalViewForm.scrollToSelectedSprite(self);
			endif;
		else
			// Set the color for an unselected Voyage.  For Comalco, the default color will come from that
			// defined on the CM_Voyge object, then any "voyage state" colors will be applied if required.
			
			if voyageObj &lt;&gt; null then
				if process.isJLGAB1() then // Draw like BWM
					self.backColor	:=	White; // Draw like BWM
				else // Draw like BWM
				self.backColor	:=	voyageObj.colour;		// cnwdad1 02/02/2007.
				endif;
				// 33482 Feb 2014 if black (was the default for new voyages), show as the new default, Grey
				if self.backColor = 0 then
					self.backColor := MovementIsSaved;
				endif;
			endif;
			
			if self.myWorkingMovement.notYetSaved then
				self.backColor	:=	MovementNotYetSaved;

				
				if self.myWorkingMovement.myPersistentMovement = null then
					self.backColor	:=	Mauve;

				endif;
			
			elseif self.myNextWorkingMovement &lt;&gt; null // PAR11586
			and global.isValidObject(self.myNextWorkingMovement)
			and self.myNextWorkingMovement.notYetSaved
			then
				self.backColor	:=	MovementNotYetSaved;

				
				if self.myWorkingMovement.myPersistentMovement = null then
					self.backColor	:=	Mauve;

				endif;
				
			elseif workingVoyageObj.voyageStatus = HMS_VoyageIsLocked then
				self.backColor	:=	White;

				
			elseif workingVoyageObj.myHMSVoyageData.excludeReport then
				self.backColor	:=	VoyageConfidential;

				
			elseif workingVoyageObj.myHMSVoyageData.getStatusForVoyage = Voyage_Status_Closed then
				self.drawFillColor	:=	DarkGray;
				self.drawFillStyle	:=	self.DrawFillStyle_DownDiagonal;
				self.backColor		:=	MovementIsSaved;

				//self.drawFilledRectangle(-2, -2, self.width, self.height, DarkGray);
				
				//cnwmc5 - 28 May 2014 - PAR 34231 - changed to use 'drawFilledPolygon' because 'drawFilledRectangle' drew overtop of things in Jade 7.0.9 release..
				create points transient;
				points.add(-2);
				points.add(-2);
				
				points.add(self.width);
				points.add(-2);
				
				points.add(self.width);
				points.add(self.height);
				
				points.add(-2);
				points.add(self.height);
				
				self.drawFilledPolygon(points, DarkGray);

			endif;
			
			// TFS 51963
			voyageStatus := workingVoyageObj.myHMSVoyageData.getStatusForVoyage;
			if voyageStatus = Voyage_Status_VoyRequested or
				 voyageStatus = Voyage_Status_VoyReqRejected or
				 voyageStatus = Voyage_Status_VoyReqSubmitted or
				 voyageStatus = Voyage_Status_EUP_VoyReq or			// TFS 54298
				 voyageStatus = Voyage_Status_EUP_VoyReqRej or		// TFS 54298
				 voyageStatus = Voyage_Status_EUP_VoyReqSubm then	// TFS 54298
				 
				// voyage requested but not yet approved
				// draw with hash pattern to differentiate with onsite voyages
				self.drawFillColor	:=	#808080;
				self.drawFillStyle	:=	self.DrawFillStyle_DiagonalCross;

				create points transient;
				points.add(-2);
				points.add(-2);
				
				points.add(self.width);
				points.add(-2);
				
				points.add(self.width);
				points.add(self.height);
				
				points.add(-2);
				points.add(self.height);
				
				self.drawFilledPolygon(points, DarkGray);
			endif;

			if _allRestrictedObj.includes(workingVoyageObj) then										// PAR #33337
				self.backColor	:= DarkGray;
			endif;
		endif;
	else
		self.backColor	:=	Red;

		self.drawTextAt(method.name &amp; ' Voyage missing', 0, self.height / 2, White);
	endif;
	// if there is a user requirement to keep working with a particular movement, set up the selectedShip indicator
	/*if _selectedMovement &lt;&gt; null then
		if self.myWorkingMovement = _selectedMovement
		or self.myWorkingVoyage.code = _selectedMovement.myWorkingVoyage.code
		or self.myNextWorkingMovement = _selectedMovement
		then
			self.myGraphicalViewForm.setCurrentSelectedDragPicture(self, null, self.left, self.top);
		endif;
	endif;*/
epilog
	delete points;		//cnwmc5 - 28 May 2014 - PAR 34231
end;</source>
        <access>protected</access>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_scrollToSelected" type="Boolean"/>
        <Parameter name="_allRestrictedObj" type="CMIF_HMS_WorkingVoyageSet"/>
    </JadeMethod>
    <JadeMethod name="colourSelectedSprite3" id="5ed106d3-1d36-4124-afa3-5789b045d0b3">
        <updating/>
        <source>colourSelectedSprite3(	_selectedMovement : CMIF_HMS_WorkingMovement;
						_scrollToSelected : Boolean;
						_allRestrictedObj:CMIF_HMS_WorkingVoyageSet)updating;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 01/10/2021	jlizm1		TFS 51963 SAL Voyage Request Changes
vars
	yPos			: Real;
	textHeight		: Real;
	workingMoveObj	: CMIF_HMS_WorkingMovement;
	nextWorkingMove	: CMIF_HMS_WorkingMovement;
	harbourObj		: HMS_Harbour;
	shipNamePartA	: String;
	vesselName		: String;
	shipNamePartB	: String;
	etArrival		: String;
	isDrawETA		: Boolean;
	bowColour		: Integer;
	voycolour : Integer;
	voyage : CM_Voyage;
begin
	// Use this method to dynamically label controls and draw the coloured bar onto
	// the sprite that shows which movement has been selected.
	self.visible		:=	false;
	self.clearGraphics();
	self.autoRedraw		:=	true;
	self.drawTextAlign 	:=	Window.DrawTextAlign_Left;
	self.drawFontName	:=	'Arial';
	self.drawFontSize	:=	8;
	self.drawFillColor	:=	Red;
	self.drawWidth		:=	4;

	workingMoveObj	:=	self.myWorkingMovement;
	
	if workingMoveObj = null then
		return;
	endif;
	
	// Apply fill colors to the sprite
	self.colourSelectedMovement3(_selectedMovement, _scrollToSelected, _allRestrictedObj);
	
	// rename the sprite with the ships name - top and bottom.
	
	harbourObj	:=	workingMoveObj.myHarbour;
	vesselName	:=	workingMoveObj.myWorkingVoyage.myHMSVoyageData.vesselName;
	etArrival	:=	workingMoveObj.myWorkingVoyage.arrivedDT.Date.format("dd/MM");
	textHeight	:=	self.drawTextHeight(vesselName);
	
	if workingMoveObj.moveType = HMSMovementTypeShift then
		// Ship's first movement was before this, so draw in date of ETA.
		isDrawETA	:=	true;
	else
		isDrawETA	:=	false;
	endif;

	if self.height &gt; ((2 * textHeight) + (1)) then // NB 1 pixel offsets at top.
		// Enough room for two labels if required.
		
		if harbourObj.isSplitVesselNames then		// cnwdad1 27/02/2007.
		
			if process.isJLGAB1() then // Draw like BWM
				voyage := self.myWorkingMovement.getMyPersistantVoyage();
				if voyage &lt;&gt; null then
				voycolour := voyage.colour;
				endif;
				if voycolour = 0 then
					voycolour := Blue;
				endif;
				
				self.drawFontName	:=	'Verdana';
				self.drawFontSize	:=	7;
				self.drawFillColor	:=	voycolour;
				self.drawWidth		:=	1;
				self.drawFilledRectangle(1,4,self.width, 20,voycolour);
				self.drawTextAt(vesselName, 3, 6, voycolour.getInverseColour());
			
				// put back default
				self.drawFillColor	:=	Red; 
				self.drawWidth		:=	4;
				self.drawFontName	:=	'Arial';
				self.drawFontSize	:=	8;
			
			else
			// Get ship name as two parts.
			self.splitShipNameToTwoStrings(vesselName, shipNamePartA, shipNamePartB);
			
			if shipNamePartB &lt;&gt; "" or shipNamePartB &lt;&gt; null then
				// We have two name labels.
				self.drawTextAt(shipNamePartA, 3, 1, Black);
				self.drawTextAt(shipNamePartB, 3, (self.height - (3 + textHeight)), Black);
				
				if isDrawETA then
					yPos	:=	(self.height - (3 + textHeight) - (textHeight));
					
					if yPos &gt; 2 then
						self.drawTextAt(etArrival, 3, yPos, Black);
					endif;
				endif;
			else
				// Only one name
				self.drawTextAt(vesselName, 3, 1, Black);
				
				if isDrawETA then
					self.drawTextAt(etArrival, 3, (self.height - (3 + textHeight)), Black);
				endif;
			endif;
			endif;
		else
			// Show only one name label.
			self.drawTextAt(vesselName, 3, 1, Black);
			
			if isDrawETA then
				self.drawTextAt(etArrival, 3, (self.height - (3 + textHeight)), Black);
			endif;
		endif;
	else
		// Enough room for only ONE label.
		self.drawTextAt(vesselName, 3, 1, Black);
	endif;

	// Set actual time indication for movement at bottom of sprite.
	self.drawWidth	:=	3;
	
	if workingMoveObj &lt;&gt; _selectedMovement
	and workingMoveObj.moveStatus = MovementStatus_Actual
	then
		self.drawLine(0, self.height - self.drawWidth, self.width, self.height - self.drawWidth, Blue);
	endif;

	// Set actual time indication for movement at top of sprite.
	nextWorkingMove	:=	self.myNextWorkingMovement;
	
	if nextWorkingMove &lt;&gt; null and global.isValidObject(nextWorkingMove) then
		if nextWorkingMove &lt;&gt; _selectedMovement
		and nextWorkingMove.moveStatus = MovementStatus_Actual
		then
			self.drawLine(0, 0, self.width, 0, Blue);
		endif;
	endif;
	
	// Set the bow indicator rectangle.
	if workingMoveObj.sideTo = OrientPortSideTo then
		bowColour	:=	Red;
	else
		bowColour	:=	Green;
	endif;
	
	if self.bowOnLeft then
		self.drawRectangle(0, (self.height / 2) - 2, 2, (self.height / 2) + 2, bowColour);
	else
		self.drawRectangle(self.width - 3, (self.height / 2) - 2, self.width,(self.height / 2) + 2, bowColour);
	endif;
	
	self.doLaycanTime(workingMoveObj);
epilog
	self.visible	:=	true;
end;</source>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_scrollToSelected" type="Boolean"/>
        <Parameter name="_allRestrictedObj" type="CMIF_HMS_WorkingVoyageSet"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="42885e45-8b6b-4e44-8b2c-88615081e349">
        <controlMethod name="Picture::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(pict: Picture input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theMovement : CMIF_HMS_WorkingMovement;
begin
	//Get the movement we are looking at from the GraphicalView form
	theMovement := self.myCurrentWharfDrawControl.myGraphicalViewForm.myCurrentWorkingMovement;
	
	if theMovement = null then
		return; // cnwrd1 par 29860 25.6.2012
		//app.raiseUnexpectedProgramError(self.name, method.name, 'Please contact your administrator');
	endif;
	
	//Setup the Scenario Movement form with the details.
	if self.myCurrentWharfDrawControl.myGraphicalViewForm &lt;&gt; null then
		/*Change as the working movement was defaulting to a shift movement set up.
		//self.myCurrentWharfDrawControl.myGraphicalViewForm.showWorkingMovementForm(self.myWorkingMovement, false);
		*/
		self.myCurrentWharfDrawControl.myGraphicalViewForm.showWorkingMovementForm(theMovement, true);
	endif;
end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="2550801b-5ce2-4f7e-a7c1-392036c04792">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		02 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10/07/2019	jlgdap1		TFS 45455 MSL Error 4 when deleting HMS_GraphicalDragPicture
// --------------------------------------------------------------------------------
begin
	// Looking at the logs for these error 4s, they only happen when there's a network
	// error that causes the thin client to disconnect. One end of the relationship
	// has already been deleted, and given the thin client process has gone, it's safe 
	// to assume the other end will get deleted as well. So just don't do anything
	// here if self isn't valid or myLaycanPic isn't valid
	if not app.isValidObject(self) or not app.isValidObject(self.myLaycanPic) then
		return;
	endif;
	
	delete self.myLaycanPic;
end;</source>
    </JadeMethod>
    <JadeMethod name="doLaycanTime" id="e021e4aa-4eea-4068-a376-4c05ddc7a50c">
        <updating/>
        <source>doLaycanTime(_workingMoveObj:CMIF_HMS_WorkingMovement) updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 March 2007 by cnwdad1
//
// Purpose:		Sets up and positions the Movement's laycan picture (if applicable),
//				and draws the laycan lines on the picture.
//
//				Refer to this method's text for a description of the scenarios that
//				are anticipated.
//
// Parameters:	_workingMoveObj - A reference to the Working Movement object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// --------------------------------------------------------------------------------
vars
	voyageObj		: CM_VoyageGlobal;
	nextMoveObj		: CMIF_HMS_WorkingMovement;
	laycanPicObj	: HMS_LaycanPicture;
	arrivalTS		: TimeStamp;
	nextArrivalTS	: TimeStamp;
	laycanFrom		: TimeStamp;
	laycanTo		: TimeStamp;
	laycanPos		: Real;
	minsPerPixel	: Real;
	verticalPos		: Real;
	centerLine		: Real;
	quarterWidth	: Real;
	
begin
	// Check if we should be doing anything here at all.
	
	if  _workingMoveObj = null  then //03.10.2017	cnwma1  TFS #7257
		self.myLaycanPic.visible	:=	false;
		return;
	endif;
	
	// Gather some vital bits of info and references.
	
	voyageObj		:=	_workingMoveObj.getVoyageGlobal();
	
	if voyageObj = null then					// No Voyage, no can do.
		self.myLaycanPic.visible	:=	false;
		return;
	endif;
	
	nextMoveObj		:=	self.myNextWorkingMovement;
	arrivalTS		:=	_workingMoveObj.occursOnDT;
	nextArrivalTS	:=	nextMoveObj.occursOnDT;
	laycanPicObj	:=	self.myLaycanPic;
	laycanFrom		:=	voyageObj.laycanDateFrom;
	laycanTo		:=	voyageObj.laycanDateTo;
	minsPerPixel	:=	self.myGraphicalViewForm.minutesPerPixel;
	laycanPicObj.isBeforeMove	:=	laycanFrom.cnEcIsLessThan(arrivalTS);
	
	// Check whether we should still continue.
	
	if _workingMoveObj.moveType &lt;&gt; HMSMovementTypeArrival	// We only show the laycan for the Arrival movement.
// cnwdad1 29/06/2007 - We always want to show the Laycan times for an arrival.
//	or laycanFrom &gt; nextArrivalTS							// If the laycan starts after the following movement, don't show anything.
//	or laycanTo &lt;= arrivalTS								// If the laycan ends before this movement, don't show anything.
	then
		self.myLaycanPic.visible	:=	false;
		return;
	endif;
	
	if laycanPicObj.isBeforeMove then
		self.laycanHeight	:=	(laycanFrom.minutesDiff(arrivalTS) / minsPerPixel).rounded();
	else
		self.laycanHeight	:=	(laycanFrom.minutesDiff(laycanTo) / minsPerPixel).rounded();
	endif;
	
	if self.laycanHeight = 0 then							// There's no point continuing with this.
		self.myLaycanPic.visible	:=	false;
		return;
	endif;
	
	if not self.getTimeSlotPos(laycanFrom, laycanPos) then
		// The laycan must be outside the current TS range of the Graphical View.
		self.myLaycanPic.visible	:=	false;
		return;
	endif;
	
	// Get some more drawing information.
	
	self.drawWidth	:=	2;
	quarterWidth	:=	self.width div 4;
	centerLine		:=	(self.width div 2) - self.drawWidth;
	
	// Position the laycan picture control.
	
	laycanPicObj.move(self.left, laycanPos - self.laycanHeight, self.width, self.laycanHeight);
	
	// If any part of the laycan overlaps this movement, we may need to draw part of it onto
	// the movement sprite.
	
	if laycanPicObj.isBeforeMove then
		// The laycan starts before this Movement's arrival date.
		
		if laycanTo.cnEcIsGreaterThanOrEqual(nextArrivalTS) then
			// The "Laycan To" date spans into the next movement, so the vertical line needs
			// to span the whole height of this sprite.
			verticalPos	:=	0;
		elseif laycanTo.cnEcIsGreaterThan(arrivalTS) then
			// The "Laycan To" date falls within this movement, so we need to calculate how much
			// of this sprite the vertical line needs to span.
			verticalPos	:=	laycanTo.minutesDiff(nextArrivalTS) / minsPerPixel;
		elseif laycanTo.cnEcIsLessThan(nextArrivalTS) then
			// The laycan ends within the time of this movement, set the vertical position accordingly.
			verticalPos	:=	self.height - (laycanTo.minutesDiff(nextArrivalTS) / minsPerPixel).rounded();
		endif;
		
		self.drawLine(centerLine, verticalPos, centerLine, self.height - self.drawWidth, Green);
		
		if verticalPos &gt; 0 then
			// The "Laycan To" date must fall within this movement, so we need to draw the terminating
			// horizontal bit of the laycan line on this sprite.
			self.drawLine(quarterWidth, verticalPos, quarterWidth * 3, verticalPos, Green);
		endif;
	else
		// The laycan starts after this Movement's arrival date.
		
		if laycanFrom.cnEcIsGreaterThan(arrivalTS)
		and laycanFrom.cnEcIsLessThanOrEqual(nextArrivalTS)
		then
			// The "Laycan From" date is after this Movement's arrival date, but before the next
			// Movement's arrival date, so the starting point needs to be drawn on this sprite,
			// with a vertical continuation line to the end of this Movement.
			
			// Get the starting vertical position.
			verticalPos	:=	(laycanFrom.minutesDiff(nextArrivalTS) / minsPerPixel).rounded();
			
			// Now draw the vertical line from the horizontal line to the start of the laycan.
			self.drawLine(centerLine, 0, centerLine, verticalPos, Green);
			
			// Draw the starting horizontal line.
			self.drawLine(quarterWidth, verticalPos, quarterWidth * 3, verticalPos, Green);
		endif;
	endif;
	
	// Finally, draw the laycan lines onto the laycan picture control, and position it beneath any
	// movement sprites.
	
	laycanPicObj.drawLaycanLine();
	laycanPicObj.zOrder(0);
	laycanPicObj.visible	:=	true;
end;</source>
        <access>protected</access>
        <text>There are five scenarios of where a laycan range of dates can fit around a Voyage Movement sprite:

1. The "laycan from" is before the arrival date/time, and the "laycan to" is after the arrival date/time
of the next movement.

						 +-------+
						 |       |
						 |       |
						 |       |
	  -----				 |       |
		|			     |       |
		|				 +-------+
		|		+---+---+
		|		|   |   |
		|		|   |   |
	    |		|   |   |
		|		|   |   |
		|		|   |   |
		|		+---+---+
		|           |
		|           |
	  -----       -----

2. The "laycan from" is before the arrival date/time, and the "laycan to" is before the arrival date/time
of the next movement.

						 +-------+
                         |       |
						 |       |
						 |       |
						 |       |
						 |       |
						 +-------+
				+-------+
				|       |
				|       |
	  -----		| ----- |
		|		|   |   |
		|		|   |   |
		|		+---+---+
		|           |
		|           |
	  -----       -----

3. The "laycan from" is after the arrival date/time, and the "laycan to" isafter the arrival date/time of
the next movement.

						 +-------+
						 |       |
						 |       |
						 |       |
	  -----		    	 |       |
		|			     |       |
		|				 +-------+
		|		+---+---+
		|		|   |   |
		|		|   |   |
	  -----		| ----- |
				|       |
				|       |
				+---+---+

4. The "laycan from" and "laycan to are both before the arrival date/time.

						 +-------+
                         |       |
						 |       |
						 |       |
						 |       |
						 |       |
						 +-------+
				+-------+
				|       |
				|       |
				| ----- |
				|   |   |
				|   |   |
				+---+---+

	  -----
		|
		|
		|
		|
		|
	  -----

5. The "laycan from" is after the arrival date/time of the next movement.

	  -----
	    |
		|
		|
		|				 +-------+
		|				 |       |
		|				 |       |
		|				 |       |
	  -----		  -----	 |       |
					|    |       |
					|	 +-------+
				+---+---+
				|       |
				|       |
	    		|       |
				|       |
				|       |
				+---+---+
</text>
        <Parameter name="_workingMoveObj" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="drawShipMetrics" id="d5a7eaa7-533d-4b4b-9a9e-5a351547223a">
        <source>drawShipMetrics(_wharfPointer: CMUI_Label input; _mpp : Real);

vars
	leftToRight : Boolean;
	voyageData	: HMS_VoyageData;
	movement	: CMIF_HMS_WorkingMovement;
	tmpWidth,
	bridge,
	aftContainer,
	fwdContainer,
	b,a,f,
	h1,h2		: Decimal[12,2];	
	loa			: Decimal[6,2];
	cntrl		: HMS_GraphicalDragPicture;
	
begin
	movement	:= self.myWorkingMovement;
	
	if movement = null then
		return;
	endif;
	
	cntrl 		:= self;
	tmpWidth	:= cntrl.width;
	h1			:= ((cntrl.height / 2) - 8);
	h2			:= h1 + 16;

	leftToRight := movement.myBerth.myWharf.displayLeftToRight;
	voyageData	:= movement.myWorkingVoyage.myHMSVoyageData;
	loa			:= voyageData.dim_LengthOverall;
	
	// get required dimensions relative to the bow
	bridge 		:= (voyageData.dist_BridgeToBow / _mpp);
	aftContainer:= ((loa - voyageData.dist_SternToAftContainer) / _mpp);
	fwdContainer:= (voyageData.dist_BowToFwdContainer / _mpp);
	
	if (not cntrl.bowOnLeft) then
		bridge 		:= (tmpWidth - bridge);
		aftContainer:= (tmpWidth - aftContainer);
		fwdContainer:= (tmpWidth - fwdContainer);
	endif;
	
	// make sure that all lines on the sprite are visible
	cntrl.drawWidth := 3;
	b := bridge;
	a := aftContainer;
	f := fwdContainer;

	if b + cntrl.drawWidth &gt; tmpWidth then
		b := (tmpWidth - cntrl.drawWidth);
	endif;
	
	if a + cntrl.drawWidth &gt; tmpWidth then
		a := (tmpWidth - cntrl.drawWidth);
	endif;
	
	if f + cntrl.drawWidth &gt; tmpWidth then
		f := (tmpWidth - cntrl.drawWidth);
	endif;
	
	//Draw bridge to bow marks on drag picture
	cntrl.drawLine(b,h1,b,h2,Red);
	
	//Draw stern to aft container bay marks on drag picture
	if voyageData.dist_SternToAftContainer &lt;&gt; 0 then
		cntrl.drawLine(a, h1, a, h2, Black);
		cntrl.drawLine(f, h1, f, h2, Green);
	endif;
	
	// set the offset attributes on the control - used when displaying positional information
	//cntrl.bridgeOffset 			:= (bridge * _mpp);
	//cntrl.aftContainerOffset 	:= (aftContainer * _mpp);
	//cntrl.fwdContainerOffset	:= (fwdContainer * _mpp);
	
	_wharfPointer.clearGraphics();
	_wharfPointer.left := cntrl.left;
	_wharfPointer.width := tmpWidth;
	
	//Draw bridge to bow marks on wharf scale pointer
	_wharfPointer.drawLine(b, 0, b, 5, Red);

	//Draw stern to aft container bay marks on wharf scale pointer
	if voyageData.dist_SternToAftContainer&lt;&gt;0 then
		_wharfPointer.drawLine(a, 0, a, 5, Black);
		_wharfPointer.drawLine(f, 0, f, 5, Green);
	endif;
	
	_wharfPointer.visible := true;
	
	//self.myCurrentWharfDrawControl.endTimer(20);
	if (not movement.allWorkingResUsed.isEmpty) then
		_wharfPointer.backColor := LightGreen;
		_wharfPointer.transparent := false;
		//self.myCurrentWharfDrawControl.beginTimer(500, Timer_OneShot, 20);
	else
		_wharfPointer.transparent := true;
	endif;
end;</source>
        <Parameter name="_wharfPointer" type="CMUI_Label" usage="input"/>
        <Parameter name="_mpp" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getBubbleHelpCaption" id="ecc85deb-5360-4083-a783-5f6f4ea333ad">
        <updating/>
        <source>getBubbleHelpCaption()updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 15 November 2004
//
//********************************************************************
vars
	vesselRemarks	: 	Boolean;
//	theWorkMove,
	workingMove,
	nextWorkingMove	:	CMIF_HMS_WorkingMovement;
	viewForm : HMS_GraphicalViewX;
	strBubble	: String;
	
begin
//	theWorkMove	:=	self.myGraphicalViewForm.myCurrentWorkingMovement;
	
	if (not global.isValidObject(self.myWorkingMovement)) then
		self.myWorkingMovement	:=	null;
		viewForm				:=	self.myGraphicalViewForm;
//		app.msgBox(class.name &amp; ' ' &amp; method.name &amp; ' ' &amp; app.getErrorString(HMS_Voyage_Updated), app.getErrorString(Voyage_Updated), MsgBox_OK_Only+MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString(HMS_Voyage_Updated), app.getErrorString(Voyage_Updated), MsgBox_OK_Only + MsgBox_Stop_Icon);
		viewForm.myViewController.doRefreshView(false);
		
		return;
	endif;
	
	workingMove		:=	self.myWorkingMovement;
	nextWorkingMove	:=	self.myNextWorkingMovement;
	
	if workingMove = null then
		app.raiseUnexpectedProgramError(self.name, method.name, 'Working movement is null for Drag Picture - Contact Developer');
	endif;
	
	if nextWorkingMove = null then
		app.raiseUnexpectedProgramError(self.name, method.name, 'Next Working movement is null for Drag Picture - Contact Developer');
	endif;

	if not self.myGraphicalViewForm.allToolTipsEntArray.isEmpty then 
		// display bubble help from user settings 
		self.getBubbleHelpUserString();
		
		return;
	endif;

	// if no user set bubble help then display default info
	
	if workingMove &lt;&gt; null then 
		strBubble	:=	workingMove.moveType &amp; ' ' &amp; app.getErrorString(Resources) &amp; ':' &amp; workingMove.getResourceUsedString();
	endif;
	
	if nextWorkingMove &lt;&gt; null then 
		strBubble	:=	strBubble &amp; nextWorkingMove.moveType &amp; ' ' &amp; app.getErrorString(Resources) &amp; ':' &amp; nextWorkingMove.getResourceUsedString();
	endif;
	
	self.bubbleHelp	:=	strBubble;

	//We only care if a remarks exists at this point so we can use the same boolean
	vesselRemarks	:=	workingMove.hasRemarks(true, true, true, true);
	
	if not vesselRemarks then
		vesselRemarks := nextWorkingMove.hasRemarks(true, true, true, true);	
	endif;
		
	if vesselRemarks  then
		if self.bubbleHelp &lt;&gt; null then
			self.bubbleHelp	:=	self.bubbleHelp &amp; CrLf &amp; app.getErrorString(Remarks_Exist);
		else 
			self.bubbleHelp	:=	app.getErrorString(Remarks_Exist);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getBubbleHelpUserString" id="333e9073-0d91-4998-b011-913268c89404">
        <updating/>
        <source>getBubbleHelpUserString()updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	graphicalViewForm 	: HMS_GraphicalViewX;
	entRow				: EntTableRow;
	strBubble			: String;
begin
	graphicalViewForm := self.myGraphicalViewForm;


//	theHiglightedWorkMove := self.myGraphicalViewForm.myCurrentWorkingMovement;
		
	foreach entRow in graphicalViewForm.allToolTipsEntArray do 
		strBubble := strBubble &amp; self.getStrToolTipFromEnt(entRow);	
	endforeach;
		
	self.bubbleHelp := strBubble;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getEdge" id="d3bc70e7-823e-4108-bc3b-6bcb3a1c720a">
        <source>getEdge(_x, _y : Real) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     Returns the edge, if any, for the x,y passed in
// ---------------------------------------------------------------------------
vars
	moveStyle,
	tmpEdge : Integer;

begin

	moveStyle := self.myGraphicalViewForm.controlMoveStyle;
	if moveStyle = HMS_GraphicalViewX.Move_NS then
		if _y &lt; Edge_Threshold then
			tmpEdge := HMS_Edge_Top;
		elseif _y &gt; self.height - Edge_Threshold then
			tmpEdge := HMS_Edge_Bottom;
		endif;		
	elseif moveStyle = HMS_GraphicalViewX.Move_NESW then
		if _y &lt; Edge_Threshold then
			tmpEdge := HMS_Edge_Top;
		elseif _y &gt; self.height - Edge_Threshold then
			tmpEdge := HMS_Edge_Bottom;
		endif;
	else
		tmpEdge := HMS_Edge_None;				
	endif;
	
	return tmpEdge;

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStrToolTipFromEnt" id="ec36766d-5ffa-42d5-9ee9-fcc2ae854d4e">
        <source>getStrToolTipFromEnt(_entRow : EntTableRow) : String;
// ---------------------------------------------------------------------------
// Created:     07 September 2005	cnwhjg1
//
// Purpose:     CCMS 1350
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 13/09/2012	cnwdap1		PAR #30147 New Pilot Relative Time and Tug Relative Time options,
//								display full Remarks if configured to do so
// 21/01/2014	cnwap1		PAR #33337 CCMS PTR 2214 HMS Enhancements - show commodity description
//03 Oct 2017	cnwma1  	TFS #7257 JMT - Refactoring - Commodity Planning
//02 Oct 2020 	cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
//23 Sep 2022 	navsj20		ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

vars
	entRowObj			: EntTableRow;
	strBubble,
	entRowName, 
	srtCommod,
	strSteveDisc,
	strSteveLoad,
	str					: String;
	vesselRemarks		: Boolean;
	workingMoveObj,
	nextWorkingMove		: CMIF_HMS_WorkingMovement;
	voyageObj			: CM_Voyage;
	globVoyageObj		: CM_VoyageGlobal;
	commodityObj		: CM_Commodity;
	tug					: HMS_Tug;
	time				: TimeStamp;
	remarks				: String;			// PAR #30147
	hmsData				: HMS_VoyageData;	// PAR #30147
begin
	entRowObj		:=	_entRow;
	entRowName		:=	entRowObj.name;
	workingMoveObj	:=	self.myWorkingMovement;
	nextWorkingMove	:=	self.myNextWorkingMovement;
	voyageObj		:=	workingMoveObj.getVoyage();

	if voyageObj &lt;&gt; null then
		globVoyageObj	:=	voyageObj.getGlobalVoyage();
		hmsData 		:= voyageObj.myHMSVoyageData;     //02.10.2020 cnwma1 TFS #50112
	endif;

	if entRowName = ETRow_ResourcesUsed then 
		strBubble := workingMoveObj.moveType &amp; ' ' &amp; app.getErrorString(Resources) &amp; ':' &amp; workingMoveObj.getResourceUsedString();
		strBubble := strBubble &amp; nextWorkingMove.moveType &amp; ' ' &amp; app.getErrorString(Resources) &amp; ':' &amp; nextWorkingMove.getResourceUsedString();
		return strBubble;
		
	elseif entRowName = ETRow_RemarksExist then 	
		//We only care if a remarks exists at this point so we can use the same boolean
//		strBubble := entRow.getHeadingUnaltered() &amp; ': ';
		
		vesselRemarks := workingMoveObj.hasRemarks(true, true, true, true);
		if not vesselRemarks then
			vesselRemarks := nextWorkingMove.hasRemarks(true, true, true, true);	
		endif;	
		if vesselRemarks  then
			// PAR #30147 if configured to do so, display voyage remarks rather than "Remarks Exist" message
			if self.myCurrentWharfDrawControl.myGraphicalViewForm.myTerminal.getConfig(ShowFullRemarksInToolTip).Boolean then
				if voyageObj &lt;&gt; null then
					if voyageObj.remarks &lt;&gt; null then
						remarks := remarks &amp; voyageObj.remarks &amp; CrLf;
					endif;
					hmsData := voyageObj.myHMSVoyageData;
					if hmsData &lt;&gt; null then
						if hmsData.remarksGeneral &lt;&gt; null then
							remarks := remarks &amp; hmsData.remarksGeneral &amp; CrLf;
						endif;
						if hmsData.remarksPilotOnly &lt;&gt; null then
							remarks := remarks &amp; hmsData.remarksPilotOnly &amp; CrLf;
						endif;
						if hmsData.remarksPreviousNames &lt;&gt; null then
							remarks := remarks &amp; hmsData.remarksPreviousNames &amp; CrLf;
						endif;
						if hmsData.shortComment &lt;&gt; null then
							remarks := remarks &amp; hmsData.shortComment &amp; CrLf;
						endif;
					endif;
				endif;
				strBubble := strBubble &amp; entRowObj.getHeadingUnaltered() &amp; ': ' &amp; remarks;
				return strBubble;
			endif;
			// PAR #30147 end of remarks changes
			
			strBubble := strBubble &amp; app.getErrorString(Remarks_Exist);
			
		else
			strBubble := strBubble &amp; 'No Remarks';
		endif;
		return strBubble &amp; CrLf;
		
	elseif entRowName = ETRow_ArrivalTime then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': ';
	
		if self.myWorkingVoyage.arrivedDT.isValid then 
			strBubble := strBubble &amp; self.myWorkingVoyage.arrivedDT.TimeStamp.shortCurrentLocaleFormat();			
		endif;
		return strBubble &amp; CrLf; 
		
	elseif entRowName = ETRow_ArrivesPort then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': ';		
		
		if 	self.myWorkingVoyage.ofPortFrom &lt;&gt; null then 
			strBubble  := strBubble &amp; self.myWorkingVoyage.ofPortFrom.description;
		endif;
		return strBubble &amp; CrLf; 
			
	elseif entRowName = ETRow_BridgeMarks then 	
		// START 23 Sep 2022	navsj20	TFS 54739
		//strBubble  := app.getErrorString(BridgeMarks) &amp; ': ' &amp; self.myWorkingMovement.getBridgeMarkTo().String &amp; CrLf;
		if self.myWorkingMovement.myBridgeBollard &lt;&gt; null then
			strBubble := app.getErrorString(Bollard) &amp; ': ' &amp; self.myWorkingMovement.myBridgeBollard.code;
			if self.myWorkingMovement.bridgeToBollard &lt;&gt; null then
				strBubble := strBubble &amp; ' + ' &amp; self.myWorkingMovement.bridgeToBollard.String &amp; ' m';
			endif;
			strBubble := entRowObj.getHeadingUnaltered() &amp; ': ' &amp; strBubble &amp; CrLf;	//04 Oct 2022	navsj20	TFS 54739
		else
			strBubble  := app.getErrorString(BridgeMarks) &amp; ': ' &amp; self.myWorkingMovement.getBridgeMarkTo().String &amp; CrLf;
		endif;
		return strBubble;
		// END 23 Sep 2022	navsj20	TFS 54739
	elseif entRowName = ETRow_BowMark then 
		// START 23 Sep 2022	navsj20	TFS 54739
		//strBubble  := entRowObj.getHeadingUnaltered() &amp; ': ' &amp; self.myWorkingMovement.bowMarkTo.String &amp; CrLf;
		if self.myWorkingMovement.myBowBollard &lt;&gt; null then
			strBubble := app.getErrorString(Bollard) &amp; ': ' &amp; self.myWorkingMovement.myBowBollard.code;
			if self.myWorkingMovement.bowToBollard &lt;&gt; null then
				strBubble := strBubble &amp; ' + ' &amp; self.myWorkingMovement.bowToBollard.String &amp; ' m';
			endif;
			strBubble := entRowObj.getHeadingUnaltered() &amp; ': ' &amp; strBubble &amp; CrLf;	//04 Oct 2022	navsj20	TFS 54739
		else
			strBubble  := entRowObj.getHeadingUnaltered() &amp; ': ' &amp; self.myWorkingMovement.bowMarkTo.String &amp; CrLf;
		endif;
		return strBubble;
		// END 23 Sep 2022	navsj20	TFS 54739
	elseif entRowName = ETRow_SternMark then 	
		// START 23 Sep 2022	navsj20	TFS 54739
		//strBubble  := entRowObj.getHeadingUnaltered() &amp; ': ' &amp; self.myWorkingMovement.sternMarkTo.String &amp; CrLf;
		if self.myWorkingMovement.mySternBollard &lt;&gt; null then
			strBubble := app.getErrorString(Bollard) &amp; ': ' &amp; self.myWorkingMovement.mySternBollard.code;
			if self.myWorkingMovement.sternToBollard &lt;&gt; null then
				strBubble := strBubble &amp; ' + ' &amp; self.myWorkingMovement.sternToBollard.String &amp; ' m';
			endif;
			strBubble := entRowObj.getHeadingUnaltered() &amp; ': ' &amp; strBubble &amp; CrLf;	//04 Oct 2022	navsj20	TFS 54739
		else
			strBubble  := entRowObj.getHeadingUnaltered() &amp; ': ' &amp; self.myWorkingMovement.sternMarkTo.String &amp; CrLf;
		endif;
		return strBubble;
		// END 23 Sep 2022	navsj20	TFS 54739
	elseif entRowName = ETRow_Commodities then 

		/*foreach commodityObj in self.myWorkingVoyage.allCargoLoad do 
			//srtCommod := srtCommod &amp; CrLf &amp; Tab &amp; commodityObj.code;				//PAR #33337
			srtCommod := srtCommod &amp; CrLf &amp; Tab &amp; commodityObj.description;			//PAR #33337
		endforeach;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
		//strBubble  := 'Load ' &amp; app.getErrorString(Commodities) &amp; ': ' &amp; srtCommod  &amp; CrLf; // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
		
		strBubble  &amp;= 'Load ' &amp; app.getErrorString(Commodities) &amp; ': ' &amp; self.myWorkingVoyage.allCargoForecasts.getAllLoadCargoStr() &amp; CrLf; // ### TFS 52132 27APR2022 NAVPW1
		
		//srtCommod := null; // clear this in case one left over from above and not changed below. // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
		
		/*foreach commodityObj in self.myWorkingVoyage.allCargoDischarge do 
			//srtCommod := srtCommod &amp; CrLf &amp; Tab &amp; commodityObj.code;				//PAR #33337
			srtCommod := srtCommod &amp; CrLf &amp; Tab &amp; commodityObj.description;			//PAR #33337
		endforeach;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
		//strBubble  := strBubble &amp; 'Discharge ' &amp; app.getErrorString(Commodities) &amp; ': ' &amp; srtCommod  &amp; CrLf; // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
		
		strBubble  &amp;= 'Discharge ' &amp; app.getErrorString(Commodities) &amp; ': ' &amp; self.myWorkingVoyage.allCargoForecasts.getAllDischargeCargoStr() &amp; CrLf; // ### TFS 52132 27APR2022 NAVPW1
		
		return strBubble;
		
	// ### TFS 53132 27APR2022 NAVPW1
	elseif entRowName = ETRow_CargoForecast then 
		//strBubble  := app.getErrorString(Cargo_Forecast) &amp; ': ' &amp; self.myWorkingVoyage.allCargoForecasts.getCargoForecastStr() &amp; CrLf; // ### TFS 52132 27APR2022 NAVPW1		10.06.2022 navsrk20 52132
		strBubble  := app.getErrorString(Cargo_Forecast) &amp; ': ' &amp; self.myWorkingVoyage.allCargoForecasts.getCargoForecastStr(false) &amp; CrLf; // 10.06.2022 navsrk20 52132
		return strBubble;
	// ### TFS 53132 27APR2022 NAVPW1
	
	elseif entRowName = ETRow_DebtorCode then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': ';
		
		if self.myWorkingVoyage.ofPermanentVoyage &lt;&gt; null and self.myWorkingVoyage.ofPermanentVoyage.myDebtor &lt;&gt; null then 
			strBubble  := strBubble &amp; self.myWorkingVoyage.ofPermanentVoyage.myDebtor.name;
		endif;
		return strBubble &amp; CrLf;
		
	elseif entRowName = ETRow_DepartsPort then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': ';
		
		//5 Nov 2008 cnwdz2 par18429
		//if self.myWorkingVoyage.ofPortFrom &lt;&gt; null then
		//	strBubble  := strBubble &amp; self.myWorkingVoyage.ofPortFrom.description;				
		//endif;
		if self.myWorkingVoyage.ofPortTo &lt;&gt; null then
			strBubble  := strBubble &amp; self.myWorkingVoyage.ofPortTo.description;				
		endif;
		return strBubble &amp; CrLf;
		
	elseif entRowName = ETRow_DepartureTime then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': ';

		if self.myWorkingVoyage.departedDT.isValid then 
			strBubble := strBubble &amp; self.myWorkingVoyage.departedDT.TimeStamp.shortCurrentLocaleFormat;			
		endif;	
		return strBubble &amp; CrLf;		
		
	elseif entRowName = ETRow_Grt then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': ';

		if self.myWorkingVoyage.myHMSVoyageData &lt;&gt; null then 
			strBubble := strBubble &amp; self.myWorkingVoyage.myHMSVoyageData.dim_GrossRegTonnes.String &amp; ' T'; 
		endif;
		return strBubble &amp; CrLf;
		
	elseif entRowName = ETRow_Length then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': ';

		if self.myWorkingVoyage.myHMSVoyageData &lt;&gt; null then 
			strBubble := strBubble &amp; self.myWorkingVoyage.myHMSVoyageData.dim_LengthOverall.String &amp; ' m';
		endif;
		return strBubble &amp; CrLf;
		
	elseif entRowName = ETRow_LinesCompany then 	
		strBubble := workingMoveObj.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ';

		if workingMoveObj.myLineCompany &lt;&gt; null then
			strBubble := strBubble &amp; workingMoveObj.myLineCompany.description;	
		endif;

		strBubble := strBubble &amp; CrLf &amp; nextWorkingMove.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ';
				
		if nextWorkingMove.myLineCompany&lt;&gt;null then
			strBubble := strBubble &amp; nextWorkingMove.myLineCompany.description;	
		endif;
		
		return strBubble &amp; CrLf;
		
	elseif entRowName = ETRow_Pilot then 
		strBubble := workingMoveObj.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ';

		if workingMoveObj.getPilotsString() &lt;&gt; null and not workingMoveObj.pilotExempt then
			strBubble := strBubble &amp; workingMoveObj.getPilotsString() &amp; CrLf;
	 	else
	 		strBubble := strBubble &amp; app.getErrorString(NotRequired) &amp; CrLf;
	 	endif;	

		strBubble := strBubble &amp; nextWorkingMove.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ';

		if nextWorkingMove.getPilotsString() &lt;&gt; null and not nextWorkingMove.pilotExempt then
			strBubble := strBubble &amp; nextWorkingMove.getPilotsString() &amp; CrLf;
	 	else
	 		strBubble := strBubble &amp; app.getErrorString(NotRequired) &amp; CrLf;
	 	endif;	

		return strBubble;
		
	elseif entRowName = ETRow_PilotLaunch then 	
		
		strBubble := workingMoveObj.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ' &amp; workingMoveObj.getPilotLaunchToolTipStr() &amp; CrLf; 
		strBubble := strBubble &amp; nextWorkingMove.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ' &amp; nextWorkingMove.getPilotLaunchToolTipStr() &amp; CrLf;

		return strBubble ;

	elseif entRowName = ETRow_PilotOnBoard then 
		
		if workingMoveObj.moveType = HMSMovementTypeArrival then // workingMove always either arrive or shift movement. never departure move. 
//			strBubble := workingMove.moveType &amp; ' ' &amp; entRow.getHeadingUnaltered() &amp; ':';  // entRow headding string as bit long
			strBubble := workingMoveObj.moveType &amp; ' Pilot on Board' &amp; ':';
			
			if workingMoveObj.pilotExempt then 
				strBubble := strBubble &amp; app.getErrorString(NotRequired);
			elseif workingMoveObj.occursOnDT.isValid then 
				time := workingMoveObj.occursOnDT.changeByXXMinutes(workingMoveObj.myHarbour.defaultOrderTimesArrive[4]);
				strBubble := strBubble &amp; time.shortCurrentLocaleFormat();			
			endif;
		endif;
												
		if nextWorkingMove.moveType = HMSMovementTypeDeparture then 		// nextWorkingMove always either departure or shift movement. never arrive move  		
//			strBubble := strBubble &amp; nextWorkingMove.moveType &amp; ' ' &amp; entRow.getHeadingUnaltered() &amp; ':'; // entRow headding string as bit long
			if strBubble &lt;&gt; null then 
				strBubble := strBubble &amp; CrLf;
			endif;
			strBubble := strBubble &amp; nextWorkingMove.moveType &amp; ' Pilot on Board' &amp; ':';	

			if nextWorkingMove.pilotExempt then 
				strBubble := strBubble &amp; app.getErrorString(NotRequired);	
			elseif nextWorkingMove.occursOnDT.isValid() then 
				time := nextWorkingMove.occursOnDT.changeByXXMinutes(nextWorkingMove.myHarbour.defaultOrderTimesDepart[4]);
				strBubble := strBubble &amp; time.shortCurrentLocaleFormat();			
			endif;
		endif;
																												
		return strBubble &amp; CrLf;
	elseif entRowName = ETRow_ShippingAgent then 	
		
		if workingMoveObj.myShippingAgent &lt;&gt; null then 
			str := workingMoveObj.myShippingAgent.description; 
		endif;
		strBubble := workingMoveObj.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ' &amp; str &amp; CrLf; 
		
		str := null;
		if nextWorkingMove.myShippingAgent &lt;&gt; null then 
			str := nextWorkingMove.myShippingAgent.description; 
		endif;
		strBubble := strBubble  &amp; nextWorkingMove.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ' &amp; str &amp; CrLf; 
		
		return strBubble;
		
	elseif entRowName = ETRow_Tugs then 	
		foreach tug in workingMoveObj.allTugsUsed do
			str := str &amp; tug.description &amp; "; ";
		endforeach;
		
		strBubble := workingMoveObj.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ' &amp; str &amp; CrLf; 
		str :=  null;
		
		foreach tug in nextWorkingMove.allTugsUsed do
			str := str &amp; tug.description &amp; "; ";
		endforeach;
		
		strBubble := strBubble &amp; nextWorkingMove.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered() &amp; ': ' &amp; str &amp; CrLf;

		return strBubble;
	
	elseif entRowName = ETRow_VesselCode then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': '&amp; self.myWorkingVoyage.myHMSVoyageData.vesselCode &amp; CrLf;
		return strBubble;		
	
	elseif entRowName = ETRow_VesselName then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': ' &amp; self.myWorkingVoyage.myHMSVoyageData.vesselName &amp; CrLf; 		
		return strBubble;
	
	elseif entRowName = ETRow_VoyageCode then 	
		strBubble := entRowObj.getHeadingUnaltered() &amp; ': ' &amp; self.myWorkingVoyage.code &amp; CrLf; 		
		return strBubble;
	
	elseif entRowName = ETRow_CargoType then
		return null ; //03.10.2017	cnwma1  TFS #7257
	elseif entRowName = ETRow_TotalWeight then						//+cnwml2 MSL CCMS 1017
		return null ; //03.10.2017	cnwma1  TFS #7257
	// PAR #30147 Pilot and Tug relative times
	elseif entRowName = ETRow_PilotRelativeTime then
		strBubble := self.myWorkingMovement.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered &amp; ': ' &amp;  self.myWorkingMovement.relativeOrderTimePlaunch.asStringJMT &amp; CrLf;
		return strBubble;
		
	elseif entRowName = ETRow_TugRelativeTime then
		strBubble := self.myWorkingMovement.moveType &amp; ' ' &amp; entRowObj.getHeadingUnaltered &amp; ': ' &amp;  self.myWorkingMovement.relativeOrderTimeTugs.asStringJMT &amp; CrLf;
		return strBubble;
			
	elseif entRowName = ETRow_StevedoreDischarge then   //02.10.2020 cnwma1 TFS #50112
		if hmsData &lt;&gt; null then
			strSteveDisc := hmsData.getStevedoresDischarge();
		endif;
		strBubble :=   entRowObj.getHeadingUnaltered &amp; ': ' &amp;  strSteveDisc &amp; CrLf;
		return strBubble;
	elseif entRowName = ETRow_StevedoreLoad then	 //02.10.2020 cnwma1 TFS #50112
		if hmsData &lt;&gt; null then
			strSteveLoad := hmsData.getStevedoresLoad();
		endif;
		strBubble :=   entRowObj.getHeadingUnaltered &amp; ': ' &amp;  strSteveLoad &amp; CrLf;
		return strBubble;
	endif;
	
	return null; 
end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeSlotPos" id="c6178a88-1f1f-4bc5-8567-9c8f88e37f58">
        <source>getTimeSlotPos(_timeslot:TimeStamp; _position:Real output):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		07 March 2007 by cnwdad1
//
// Purpose:		Taking the timestamp parameter, calculate the vertical coordinate
//				on the Graphical View of where that timeslot is.  It the timestamp
//				is not within the current range of the Graphical View, zero is
//				returned.
//
// Parameters:	_timestamp - The TimeStamp who's position we want.
//				_position - The vertical coordinate of the timeslot.
//
// Returns:		True if the coordinate was determined, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startTS			: TimeStamp;
	finishTS		: TimeStamp;
	minsPerPixel	: Real;
	minsFromStart	: Real;
	coordinate		: Real;
	
begin
	self.myGraphicalViewForm.getCurrentDateRange(startTS, finishTS);
	
	if _timeslot.cnEcIsLessThan(startTS)
	or _timeslot.cnEcIsGreaterThan(finishTS)
	then
		return false;
	endif;
	
	minsPerPixel	:=	self.myGraphicalViewForm.minutesPerPixel;
	minsFromStart	:=	startTS.minutesDiff(_timeslot);
	coordinate		:=	self.parent.height - (minsFromStart / minsPerPixel).rounded();
	
	_position		:=	coordinate;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_timeslot" type="TimeStamp"/>
        <Parameter name="_position" type="Real" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasChangedPosition" id="dc3641b8-da46-4929-b6da-b4d93de80e2f">
        <source>hasChangedPosition(_moveStyle : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (_moveStyle = HMS_GraphicalViewX.Move_WE or _moveStyle = HMS_GraphicalViewX.Move_NESW)
	and (self.left &lt;&gt; self.saveLeft or self.width &lt;&gt; self.saveWidth)
	then
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_moveStyle" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasChangedTime" id="e54c3b55-ed92-4d54-9631-5e3e4e505264">
        <source>hasChangedTime(_moveStyle : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (_moveStyle = HMS_GraphicalViewX.Move_NS or _moveStyle = HMS_GraphicalViewX.Move_NESW)
	and (self.top &lt;&gt; self.saveTop or self.height &lt;&gt; self.saveHeight)
	then
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_moveStyle" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="8e7858e4-f80c-4bd6-bd13-6d9788ffaaae">
        <updating/>
        <source>init(	_form : HMS_GraphicalViewX input;
		_wharfDrawControl : HMS_WharfDrawControl;
		_workingMovement: CMIF_HMS_WorkingMovement;
		_nextWorkingMovement : CMIF_HMS_WorkingMovement;
		_bowOnLeft : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	if _workingMovement = null then
		app.raiseUnexpectedProgramError(class.name, method.name, '_workingMovement is null');
		return;
	endif;
	self.myCurrentWharfDrawControl	:=	_wharfDrawControl;
	self.myWorkingMovement			:=	_workingMovement;
	self.myWorkingVoyage			:=	_workingMovement.myWorkingVoyage;
	self.vesselLengthOverall		:=	_workingMovement.myWorkingVoyage.myHMSVoyageData.dim_LengthOverall;
	self.myNextWorkingMovement		:=	_nextWorkingMovement;

	self.bowOnLeft			:=	_bowOnLeft;
	self.parent				:=	_wharfDrawControl.myScrollingFrame;
	self.myLaycanPic.parent	:=	self.parent;			// cnwdad1 05/02/2007.
	_form.addControl(self.myLaycanPic);					// cnwdad1 05/02/2007.

	// do this last as it adds to dict on form
	self.myGraphicalViewForm := _form;
epilog
	self.visible := true;
end;</source>
        <Parameter name="_form" type="HMS_GraphicalViewX" usage="input"/>
        <Parameter name="_wharfDrawControl" type="HMS_WharfDrawControl"/>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_nextWorkingMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_bowOnLeft" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPicHeightUnderZero" id="076ce861-4b2e-4c9b-820a-cef7133522c4">
        <source>isPicHeightUnderZero() : Boolean;

vars

begin
	if self.height &lt;= 0 then
		return true;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="d8a924e4-d14d-44de-92a2-d2a93bcb93df">
        <controlMethod name="Picture::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(pict: HMS_GraphicalDragPicture input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 16/05/2012	cnwdap1		PAR #29427 New parameter for buildEntireForegroundForXViews method to prevent tidal summary form from being updated twice
vars
	tmpSelectedMove : CMIF_HMS_WorkingMovement;
	graphicalView : HMS_GraphicalViewX;
	
begin
	pict.savePosition();
	pict.setOffset(x,y);
	pict.zOrder(1);

	// adjust the pointers that are shown on the wharf control
	pict.myCurrentWharfDrawControl.movePointers(true, pict.left, pict.left + pict.width);

	// don't allow sprite to move unless the mouse has shifted at least 3 pixels - debounces the mouse
	pict.isDragging	:= false;
	
	// show the ship details rule
	pict.myCurrentWharfDrawControl.drawShipMetrics(pict);

	// setup the viewController with the details of the currently selected movement
	graphicalView := self.myGraphicalViewForm;
	graphicalView.setCurrentSelectedDragPicture(pict, button, x, y);

	if y &lt; pict.height / 2 then
		tmpSelectedMove := pict.myNextWorkingMovement;
//		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '::' &amp; self.getOidString &amp; " -  next");
	else
		tmpSelectedMove := pict.myWorkingMovement;
	endif;
	
	if (not global.isValidObject(tmpSelectedMove)) then
		app.msgBox(class.name &amp; ' ' &amp; method.name &amp; ' ' &amp; app.getErrorString(HMS_Voyage_Updated), app.getErrorString(Voyage_Updated), MsgBox_OK_Only+MsgBox_Stop_Icon);
		graphicalView.myViewController.doRefreshView(false);
		return;
	endif;
	
	if graphicalView.myCurrentWorkingMovement &lt;&gt; tmpSelectedMove then
		graphicalView.setSelectedMovement(tmpSelectedMove, false);
		//graphicalView.buildEntireForegroundForXViews();						// PAR #29427
		graphicalView.buildEntireForegroundForXViews(tmpSelectedMove = null);	// PAR #29427
	endif;
	
	if graphicalView.isReadOnly then
		// read only user cannot move sprite
	elseif graphicalView.myCurrentWorkingMovement = null then
		// nothing selected
	elseif graphicalView.myCurrentWorkingMovement.myWorkingVoyage.voyageStatus = HMS_VoyageIsLocked then
		// this voyage is locked and cannot be moved
	else
		// set movement range ready for move
		pict.calculateMovementRange();
	endif;

	// popup menu
	if button = Window.MouseButton_Right then
		graphicalView.dragPictureContextMenu(pict, x, y);
	endif;
	
	graphicalView.refreshNow();
end;</source>
        <Parameter name="pict" type="HMS_GraphicalDragPicture" usage="input"/>
