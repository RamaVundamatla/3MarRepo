<CollClass name="CM_DeckVesselByOrdinalDIct" id="7369da9d-9099-4b9b-b1d9-287c6c809ed0">
    <loadFactor>66</loadFactor>
    <memberType name="CM_DeckVessel"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <MemberKey>
        <property name="CM_Deck::ordinal"/>
    </MemberKey>
    <JadeMethod name="moveElement" id="ca1ad9d3-6c09-4831-bd84-dd467f5a9b5f">
        <lockReceiver/>
        <updating/>
        <source>moveElement(ordinal1, ordinal2 : Integer; _deck : CM_DeckVessel input; _isMoveUp : Boolean) lockReceiver, updating;
/*
Date		    Who			Reason
Dec 2011		cnwjre1	 	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	
	moveDeck1, moveDeck2			: CM_DeckVessel;

begin
	
	moveDeck1 := self.getAtKey(ordinal1);
	moveDeck2 := self.getAtKey(ordinal2);
	self.remove(moveDeck1);
	self.remove(moveDeck2);
	moveDeck1.setOrdinal(ordinal2);
	moveDeck2.setOrdinal(ordinal1);
	self.add(moveDeck1);
	self.add(moveDeck2);
	
	
epilog

end;</source>
        <Parameter name="ordinal1" type="Integer"/>
        <Parameter name="ordinal2" type="Integer"/>
        <Parameter name="_deck" type="CM_DeckVessel" usage="input"/>
        <Parameter name="_isMoveUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rearrangeOrdinals" id="59cccff3-618f-473d-8473-a9927300c1ff">
        <source>rearrangeOrdinals(_pxyDecks : CM_DeckVesselByOrdinalDIct input);
/*
Date		    Who			Reason
Dec 2011		cnwjre1	    Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	pxyDeck,deck : CM_DeckVessel;
	idx, size : Integer;
begin
	size := self.size();
	idx := 1;
	foreach deck in self do
		if idx &gt; size then
			break;
		endif;
		deck.setOrdinal(deck.ordinal + 10000);
		idx := idx + 1;		
	endforeach;
	foreach pxyDeck in _pxyDecks do
		foreach deck in self where deck.code = pxyDeck.code do
			deck.setOrdinal(pxyDeck.ordinal);
			break;
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_pxyDecks" type="CM_DeckVesselByOrdinalDIct" usage="input"/>
    </JadeMethod>
</CollClass>
