    <JadeMethod name="setComboValues" id="a97c423d-7c5d-4a24-9bd2-92587abeefde">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     12/05/2009	cnwdz2 par19585
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	voyCrit,
	termCrit			: CM_SelectorCriteriaLine;
	
	tempCrit 		: CM_SelectorCriteriaLine;
	
	idx				: Integer;
	obj				: Object;
	os				: ObjectSet;
	voyage			: CM_Voyage;
	terminal		: CM_Terminal;
	bay				: CM_Bay;
begin
	_combo.clear();
	
	if _params = null then
		return;
	endif;

	voyCrit := _params.allCriteriaByPropertyName.getAtKeyGeq(CM_TrackedItem::voyageCode.name, null);
	if voyCrit = null or voyCrit.propName &lt;&gt; CM_TrackedItem::voyageCode.name then
		_combo.addItem(app.getErrorString(Must_select_voyage));
		return;
	endif;
	
	if CM_QReferenceIsOneOf.hasInstance(voyCrit.myQueryOperator) then
		_combo.addItem(app.getErrorString(BayId_search_unavailable));
		return;
	endif;
	
	termCrit := _params.allCriteriaByPropertyName.getAtKeyGeq(CM_TrackedItem::myTerminal.name, null);
	create os transient;
	if termCrit &lt;&gt; null and termCrit.propName = CM_TrackedItem::myTerminal.name then
		termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		app.myRoot.allTerminals.copy(os);
	endif;
	
	foreach obj in os do
		voyage := obj.CM_Terminal.lookupVoyage(voyCrit.myQueryOperator.getSearchValue.String, null, false);
		if voyage &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	if voyage = null then
		//epr TFS 47132 17/12/19
		
		return;
	elseif voyage.myCellularVoyageStructure = null then
		_combo.addItem('must be cellular voyage');
		return;
	endif;
	
	foreach bay in voyage.myCellularVoyageStructure.allBayVoyagesById do
		if bay.idBay40 &lt;&gt; null then
			_combo.itemObject[_combo.addItem(bay.idBay40)] := bay;
		endif;
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.text := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
epilog
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="6ddd0b23-5f8b-4f95-a3c4-1ffcb243fe98">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QStringIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     12/05/2009 cnwdz2 par19585
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	voyCrit,
	termCrit			: CM_SelectorCriteriaLine;
	tempCrit 		: CM_SelectorCriteriaLine;
	idx					: Integer;
	obj					: Object;
	os					: ObjectSet;
	voyage				: CM_Voyage;
	terminal			: CM_Terminal;
	bay					: CM_Bay;
	selectionValue		: Integer;
begin

	_tbl.rows := _tbl.fixedRows;
	
	if _params = null then
		return;
	endif;

	foreach tempCrit in _params.allCriteriaByPropertyName do
		if tempCrit.propName = "myTerminal" then
			termCrit := tempCrit;
		endif;
		if tempCrit.propName = "voyageCode" then
			voyCrit := tempCrit;
		endif;
		
	endforeach;

	
	if voyCrit = null then
		_tbl.addItem('You must select a voyage');
		return;
	endif;
	
	create os transient;
	if termCrit &lt;&gt; null then
		termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		app.myRoot.allTerminals.copy(os);	
	endif;
	
	foreach obj in os do
		voyage := obj.CM_Terminal.lookupVoyage (voyCrit.myQueryOperator.getSearchValue.String, null, false);
		if voyage &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	if voyage = null then
		//epr TFS 47132 17/12/19
		
		return;
	elseif voyage.myCellularVoyageStructure = null then
		_tbl.addItem('must be cellular voyage');
		return;
	endif;
	
	foreach bay in voyage.myCellularVoyageStructure.allBayVoyagesById do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(bay.idBay40)then
			selectionValue := 1;
		endif;	
		if bay.idBay40 &lt;&gt; null then
			idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; bay.idBay40);
		endif;
		
		_tbl.accessRow(idx).itemObject := bay;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
epilog
	delete os;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QStringIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="85fd0eee-507c-405a-b11f-2ab59bc3a208">
        <source>setValuesFromList(_tbl : Table input; _op : CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     12/05/2009		cnwdz2 par19585	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	str				: String;
	numRows,
	idx				: Integer;
	bayIdArray		: StringArray;
	bayId			: String;
begin

	create bayIdArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			bayId := _tbl.accessCell(idx, 2).text;
			bayIdArray.add(bayId);
		endif;
	endforeach;
	
	_op.setSearchValue(bayIdArray);

epilog
	delete bayIdArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="46bbe1e3-3156-4a33-85d4-34f9e4b5fed7">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     12/05/2009	cnwdz2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return _value.String;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="fd489102-836e-491c-8aff-9be05f5d892b">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     12/05/2009	cnwdz2 par19585	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	invalidObj 		: Boolean;
	object			: CM_Bay;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_Bay) then
			object := _value.CM_Bay;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);		
		
		returnVal := object.idBay40;		
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="b359699d-b3c5-48aa-96bb-e6093cc4dd80">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Poral selector query parameters
//
vars
	str, result, collStr : String;
	strArray : StringArray;
	bay : CM_Bay;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			result := result &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		result := result[1:result.length-2];
		return result;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			collStr.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
