    <JadeMethod name="tblResources_dblClick" id="ae5275b8-eca5-422b-8bce-5b708e498bba">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResources_dblClick(table: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpRow,
	tmpCol	: Integer;
begin
	tmpRow := table.row;
	tmpCol := table.column;
	if tmpRow = table.fixedRows then
		self.tblResources.resortTableByColumn(tmpCol);
		self.tblResources.colourRows(self.colorRow1, self.colorRow2);		
	endif;
	// need to validate that this is date column
	if tmpRow &gt; table.fixedRows and
	   (tmpCol = 5 or tmpCol = 7) then
		table.showCalenderForm(tmpRow, tmpCol);
	endif;
end;</source>
