//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	// Perform the operation.
	pMasterObj.createMultipleDetails(pAllTransientDetails);

	// If the "create" raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pMasterObj" type="CnEcReleaseHistoryMaster"/>
        <Parameter name="pAllTransientDetails" type="CnEcRelHistoryDetailByTimeDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxHistoryMasterCompleted" id="9a244e3e-fcd5-46b8-abc1-89f9ebd47e39">
        <updating/>
        <source>trxHistoryMasterCompleted(	pHistoryMasterObj:CnEcReleaseHistoryMaster input;
							pRequiredEdition:Integer;
							pTimeCompleted:TimeStamp;
							pIsCompletedOK:Boolean):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Update a Release History Master with a completed timestamp and flag.
//
// Parameters:	The first parameter is the object to be updated.
//              If pRequiredEdition is greater than zero, the method will check that
//              the latest edition of the object is equal to pRequiredEdition. If not
//              then an ObjectOutOfDate error will be returned.
//
//              The remaining parameters are the object properties to update.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pHistoryMasterObj, "The Release History Master being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pHistoryMasterObj);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pHistoryMasterObj.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Release History Master has been changed by another process.  Please refresh the Category and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pHistoryMasterObj.setCompleted(pTimeCompleted, pIsCompletedOK);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pHistoryMasterObj" type="CnEcReleaseHistoryMaster" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pTimeCompleted" type="TimeStamp"/>
        <Parameter name="pIsCompletedOK" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxHistoryMasterCreate" id="029c0443-c614-423d-96b1-b99e095cd665">
        <updating/>
        <source>trxHistoryMasterCreate(	pBaseRootObj:CnEcBaseRoot input;
						pHistoryMasterObj:CnEcReleaseHistoryMaster output):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Transaction method to create a Release History Master.
//
// Parameters:	The properties of the object to be created.
//              The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Start the transaction.
	beginTransaction;

	// Perform the operation.
	pHistoryMasterObj	:=	pBaseRootObj.createReleaseHistoryMaster();

	// If the "create" raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pBaseRootObj" type="CnEcBaseRoot" usage="input"/>
        <Parameter name="pHistoryMasterObj" type="CnEcReleaseHistoryMaster" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxHistoryMasterUpdateUpgrader" id="fcee3f5e-bcee-4c7e-a664-12a4419a95de">
        <updating/>
        <source>trxHistoryMasterUpdateUpgrader(	pHistoryMasterObj:CnEcReleaseHistoryMaster input;
								pRequiredEdition:Integer;
								pUpgraderObj:CnEcReleaseUpgrader):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Update a Release History Master with its Release Upgrader.
//
// Parameters:	The first parameter is the object to be updated.
//              If pRequiredEdition is greater than zero, the method will check that
//              the latest edition of the object is equal to pRequiredEdition. If not
//              then an ObjectOutOfDate error will be returned.
//
//              The remaining parameters are the object properties to update.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pHistoryMasterObj, "The Release History Master being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pHistoryMasterObj);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pHistoryMasterObj.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Release History Master has been changed by another process.  Please refresh the Category and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pHistoryMasterObj.setUpgrader(pUpgraderObj);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pHistoryMasterObj" type="CnEcReleaseHistoryMaster" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pUpgraderObj" type="CnEcReleaseUpgrader"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxHistoryMasterUpdateVersion" id="a2a4d732-d56d-46f8-9c81-e15dcf8a6ab1">
        <updating/>
        <source>trxHistoryMasterUpdateVersion(	pBaseRootObj:CnEcBaseRoot input;
								pHistoryMasterObj:CnEcReleaseHistoryMaster input;
								pRequiredEdition:Integer;
								pReleaseVersion:String):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Update a Release History Master with the Release Version.
//
// Parameters:	The first parameter is the object to be updated.
//              If pRequiredEdition is greater than zero, the method will check that
//              the latest edition of the object is equal to pRequiredEdition. If not
//              then an ObjectOutOfDate error will be returned.
//
//              The remaining parameters are the object properties to update.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pHistoryMasterObj, "The Release History Master being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pHistoryMasterObj);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pHistoryMasterObj.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Release History Master has been changed by another process.  Please refresh the Category and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pBaseRootObj.setCurrentBaseSchemaRelease(pReleaseVersion);
		pHistoryMasterObj.setReleaseNumber(pReleaseVersion);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pBaseRootObj" type="CnEcBaseRoot" usage="input"/>
        <Parameter name="pHistoryMasterObj" type="CnEcReleaseHistoryMaster" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pReleaseVersion" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxReleaseUpgraderCreate" id="902f141e-fb07-41c4-984b-a6f9784fb095">
        <updating/>
        <source>trxReleaseUpgraderCreate(	pUpgraderClassObj:Class;
							pUpgraderObj:CnEcReleaseUpgrader output):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Transaction method to create a Release History Upgrader.
//
// Parameters:	The properties of the object to be created.
//              The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Start the transaction.
	beginTransaction;

	// Perform the operation.
	create pUpgraderObj as pUpgraderClassObj;

	// If the "create" raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pUpgraderClassObj" type="Class"/>
        <Parameter name="pUpgraderObj" type="CnEcReleaseUpgrader" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valHistoryDetailCreate" id="006f61b9-85ed-401c-8b38-956ef6b951a5">
        <updating/>
        <source>valHistoryDetailCreate(	pTimestamp:TimeStamp;
						pText:String):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for creating a Release History Detail.
//
// Parameters:	The object's properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pTimestamp = null then
		return self.agentSetError("The History Detail's timestamp cannot be null.");
	endif;

	return null;
end;</source>
        <Parameter name="pTimestamp" type="TimeStamp"/>
        <Parameter name="pText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
