    <JadeMethod name="getDisplayStringForAttribute" id="22c35fe2-5554-4968-aa49-cfa18fb45c9e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Feb 2012	cnwndl1	Initial creation
06 Nov 2024	navdap1	MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
*/

vars

	invalidObject : Boolean;
	plannedLocId : String;
	groundLC : CM_LocationsController;
begin

	if self.myTrackedItem = null then
		return null;
	endif;
	
	if _attrName = ETRow_AllocationUsed then
		on Exception do app.handleDeletedObject( exception, self.myAllocationUsed, invalidObject);
		if self.splitLocations &lt;&gt; null then
			return app.getErrorString(Multi_range_speci_alloc_not_kn);
		elseif self.myAllocationUsed &lt;&gt; null then
			return self.myAllocationUsed.code;
		else
			return null;
		endif;
		
		if invalidObject then
			return null;
		endif;
	
	elseif _attrName = ETRow_PlanLocation then
		on Exception do app.handleDeletedObject( exception, self.myPlannedLocation, invalidObject);
		if self.splitLocations &lt;&gt; null then
			return self.splitLocations;
		elseif self.myPlannedLocation &lt;&gt; null then
			plannedLocId:= self.myPlannedLocation.getFullId;
			//jlier1 TFS 54675 20/10/22
			if self.myPlannedLocation.isKindOf(CM_TILCController) then
				groundLC:=self.myPlannedLocation.getGroundLC(REAL_MODE);
				if groundLC &lt;&gt; null then
					plannedLocId:=plannedLocId &amp; " in " &amp; groundLC.getFullId;
				endif;
			// MTN-18897 start
			elseif self.myPlannedLocation.isKindOf(CM_IrregularBlockController) then
				if self.myAllocationUsed.myTerminal.getAutoPlanAllowFullGCArea() then
					if self.myAllocationUsed.allYardControllers.size = self.myPlannedLocation.myTerminalArea.allLocationsControllers.size then
						plannedLocId := self.myPlannedLocation.myTerminalArea.id;
					endif;
				endif;
			// MTN-18897 end
			endif;
			return plannedLocId;
		else
			return null;
		endif;
		
		if invalidObject then
			return null;
		endif;
	
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
