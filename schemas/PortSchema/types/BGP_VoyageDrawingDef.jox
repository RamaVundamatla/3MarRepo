<Class name="BGP_VoyageDrawingDef" id="04191091-a5dd-4ce9-96fe-fecd47a8e6cb">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Voyage Drawing Definition&lt;/display&gt;
&lt;displayShort&gt;Voyage Drawing Def&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myVoyage" id="d3925853-bf6b-49e8-88bd-82a557a25868">
        <embedded/>
        <type name="CM_Voyage"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="191294c8-157b-4bda-a526-d4964b83526e">
        <updating/>
        <source>action(): Boolean updating;
// -------------------------------------------
// Created 02 December 2003 by cnwdvb1
// -------------------------------------------

vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	// Andrew. This returns true so the request gets deleted regardless of
	// whether the process was successful.
	// You can return false but then the request will hang around and for an
	// automatic request like yours you probably don't need that.
	self.setUser();
	self.setVoyageDrawingDefinition();

epilog	
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initRequestForVoyageDrawingDef" id="8b8d7c64-7cc3-437e-90bb-0aab33fcae81">
        <updating/>
        <source>initRequestForVoyageDrawingDef(_controller: BGP_Controller) updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		To be run from a trx
//
// ---------------------------------------------------------------------------

vars

begin

	self.initRequestEvent(true,false, null);
end;</source>
        <Parameter name="_controller" type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="setVoyageDrawingDefinition" id="bca5796d-d91e-46ff-916f-385e9037109c">
        <source>setVoyageDrawingDefinition() protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
vars
	pxyVoyage : CM_Voyage;
	ls : Boolean;
begin

	if self.myTerminal = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'Unable to locate terminal', null, null);
	endif;

			
	app.myPassport.setMyTerminal(self.myTerminal);
	
	app.cmsBeginLoad(ls);
	pxyVoyage := app.createUpdateProxy(self.myVoyage).CM_Voyage;
	app.cmsEndLoad(ls);
	
//	app.myTrxUA.trxUpdateVoyageDrawingDefn(pxyVoyage, app.myPassport);
			
	if (not app.myPassport.trxCompletedOK) then
		app.remoteErrorWarningToAlert('Unable to set voyage drawing definition - ' &amp; self.myVoyage.code,null, app.myPassport.allErrors, null, false, true);
	endif;

epilog
	app.cmsEndLoad(ls);			// 08/04/2011 cnwmh5 #27347
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
