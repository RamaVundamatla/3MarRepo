    <JadeMethod name="getSenderCode_NAD_MS" id="60082627-7d25-4d6f-b2a5-5acd897d2606">
        <source>getSenderCode_NAD_MS():String ;
// ---------------------------------------------------------------------------
// Created:     25 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Code to use for Sender in a CAMs NAD+MS message
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	value	:String;
begin
	// protocol
	value := self.camISOPortDesc;
		
	// terminal config
	if value = null then
		value := self.terminal.getConfig(PortDestCode).String;
		
		if value &lt;&gt; null then
			self.protocolDesc.getXlatedForeignCode(self.operatorXlationCode.trimBlanks, value, XLATION_TYPE_PORT_BYOP, self.terminal);
		endif;
	endif;
	
	return value.trimBlanks;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSenderCode_UNB" id="ab6e1f96-6861-478a-84f9-98b4abdbdaea">
