    <JadeMethod name="cmbDelay_displayEntry" id="0659e3a1-4303-45bf-a953-212faa963e2e">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDelay_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

vars

begin
 	return obj.HMS_Delay.description;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
