    <JadeMethod name="getOriginalTaskSourceLoc" id="48a164b2-b951-4335-bd74-717db2ea3a48">
        <source>getOriginalTaskSourceLoc(): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2011	cnwer1	Initial creation

*/

vars
	firstRTEntry : CM_RTQueueEntry;
	pickupTask : CM_RTQueueTask;
	sourceLocation : CM_LocationsController;
	foundHeight 	: Integer;
begin
	if self.allRTQueueEntries.isEmpty then
		return null;
	endif;
	
	firstRTEntry:=self.allRTQueueEntries.first;
		
	pickupTask:=firstRTEntry.findTaskOfType(TASK_PICKUP,NULL_INTEGER);
	if pickupTask = null then
		pickupTask:=firstRTEntry.findTaskOfType(TASK_MOVE,NULL_INTEGER);
	endif;
	
	if pickupTask = null then
		return null;
	endif;
	
	
	
	sourceLocation:= pickupTask.sourceLocation;
	
	if sourceLocation &lt;&gt; null then
		return sourceLocation;
	endif;
	
	self.getMyTerminal.findLocationFromString(self.locationSource,true,sourceLocation,foundHeight);
	return sourceLocation;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
