    </JadeMethod>
    <JadeMethod name="loadNewData" id="87b27b0d-e724-4488-be9d-e2a7093752bd">
        <updating/>
        <source>loadNewData() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/11/2008	cnwrd1	Initial creation
11/01/2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
31/03/2016	cnwdap1	PAR #35843 Make monitor time-based rather than object count based
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars
	passport		: CM_Passport;
	cmifMonitor		: CMIF_Monitor;
	master			: CM_TIMaster;
	cnt,
	partsInJob,
	partsDone		: Integer;
	records 		: Integer;
	dict			: Dictionary;
	iter 			: Iterator;
	idLength		: Integer;
	tmpId,
	idKey			: String;
	tmpCargoType,
	cargoTypeKey	: Integer;
	tiSet			: CM_ObjectSet;
	lastUpdated		: Decimal [20];							// PAR #35843
begin
	passport := app.myPassport;

	cmifMonitor := passport.myCMIFMonitor;
	
	create tiSet transient;
	
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Master Items',  'Please Wait....');
	self.pbProgressBar.visible := true;

	self.setFilterValues();

	partsInJob :=  app.myRoot.allTiMasters.size;
	
	if self.filterID &lt;&gt; null and  self.getCargoType() &lt;&gt; CargoType_Trailer then
	// have ID so we can use dict
	
		//check start
		dict := app.myRoot.allTiMasters;
	
		tmpId	 := self.filterID;
		idLength := tmpId.length;
		iter := dict.createIterator;
		tmpCargoType := self.getCargoTypeIDKey(); //broke for trailers
		
		endLoad;
		beginLoad;
		dict.startKeyGeq(tmpCargoType, tmpId,  iter);
		
		while iter.next(master) do
			iter.getCurrentKeys(cargoTypeKey, idKey); //MTN-35226
							
			if idKey[1 : idLength] &lt;&gt; tmpId then
				break;
			endif;
			if cnt =  self.MAX_SEARCH_RETURN then
				break;
			endif;
		
			if self.includeObject(master) then
				self.tblDataDisplayRow(master);
				tiSet.add(master);
				cnt := cnt +1;
			endif;
		//	if breakOut then
			//	break;
		//	endif;
		endwhile;
			
		delete iter;
			
	//check reverse
	//also check tiSet if is already included.
	
		tmpId := tmpId.reverse;
	
		dict := app.myRoot.allTiMastersRev;

		iter := dict.createIterator;

		dict.startKeyGeq(tmpCargoType, tmpId,  iter);
		
		while iter.next(master) do
			iter.getCurrentKeys(cargoTypeKey, idKey);  //MTN-35226
							
			if idKey[1 : idLength] &lt;&gt; tmpId then
				break;
			endif;
			if tiSet.includes(master) then
						// check to see we have not already added this ti
				continue;
			endif;				
			if cnt =  self.MAX_SEARCH_RETURN then
				break;
			endif;
			
			if self.includeObject(master) then
				cnt := cnt +1;
				self.tblDataDisplayRow(master);
			endif;
		//	if breakOut then
			//	break;
		//	endif;
		endwhile;
			
		delete iter;
			
		cnt := 0;
		endLoad;
	else
	// no ID - or trailer with dodgy cargo id
		foreach master in app.myRoot.allTiMasters where self.isMyTypeItem( master ) do
			if (not self.includeObject(master)) then
				continue;
			endif;
		//	if not self.lstType.allSelectedObjects.includes(master.getCurrentTi().CM_TILC.myTILCType) then
		//		continue;
		//	endif;
			cnt := cnt + 1;
			records := records +1;
			partsDone := partsDone + 1;
			self.tblDataDisplayRow(master);
			//if cnt = 100 then																				// PAR #35843
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
				if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
					break;
				endif;
				cnt := 0;
				lastUpdated := app.relativeMachineTime;														// PAR #35843
			endif;
			
			if records = self.MAX_SEARCH_RETURN then
				break;
			endif;
		endforeach;
	endif;
		

epilog
	endLoad;
	delete cmifMonitor;
	delete tiSet;
	delete iter;		// PAR #26678
	app.myPassport.setMyCMIFMonitor(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="loadNewWagonMasterData" id="145b4903-aff0-462f-b781-eace28a53281">
        <updating/>
        <source>loadNewWagonMasterData() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/07/2009	cnwndl1	Initial creation
31/03/2016	cnwdap1	PAR #35843 Make monitor time bases rather than object count based
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars

	passport : CM_Passport;
	cmifMonitor : CMIF_Monitor;
	master : CM_WagonMaster;
	cnt : Integer;
	partsInJob : Integer;
	partsDone : Integer;
	records : Integer;
	tiSet : CM_ObjectSet;
	iter : Iterator;
	useKey : Boolean;
	dict : CM_WagonMasterById;
	idKey : String;
	tmpId : String;
	idLength : Integer;
	lastUpdated : Decimal [20];									// PAR #35843
	
begin
	passport := app.myPassport;

	cmifMonitor := passport.myCMIFMonitor;
	
	create tiSet transient;
	
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, app.getErrorString(Cancel) , null, null, app.getErrorString(Loading_wagon_master_items),  app.getErrorString(PleaseWait) );
	self.pbProgressBar.visible := true;

	self.setFilterValues();

	dict := app.myRoot.allWagonMasters;

	partsInJob :=  dict.size;
	iter := dict.createIterator;
	if self.filterID &lt;&gt; null then
		useKey := true;
		tmpId := self.filterID.toUpper;
		idLength := tmpId.length;
		dict.startKeyGeq(tmpId,  iter);
	endif;
	
	while iter.next( master ) do
	
		if useKey then
			iter.getCurrentKeys(idKey); //MTN-35226
			if idKey[1 : idLength] &lt;&gt; tmpId then
				break;
			endif;
		endif;
		
	//	if not some futurefilterCheck then
	//		continue;
	//	endif;
	
		cnt := cnt + 1;
		records := records +1;
		partsDone := partsDone + 1;
		self.tblDataDisplayRow(master);
		//if cnt = 100 then																				// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
			if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
				break;
			endif;
			cnt := 0;
			lastUpdated := app.relativeMachineTime;														// PAR #35843
		endif;
		
		if records = self.MAX_SEARCH_RETURN then
			break;
		endif;
		
	endwhile;
		
epilog

	endLoad;
	delete cmifMonitor;
	delete tiSet;
	app.myPassport.setMyCMIFMonitor(null);
	delete iter;
	
end;</source>
    </JadeMethod>
