    <JadeMethod name="getChildTypeName" id="a43b3ffe-6864-4f99-988a-30dc8bb58f1a">
        <source>getChildTypeName(): String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.myParent.isKindOf(CM_VesselStructuralElements) then	
		return app.getErrorString(Vessel_tank);
	else
		return app.getErrorString(Voyage_tank);
	endif;


end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstChildObject" id="a944dbb3-51f8-4f95-a506-2bbb659390ec">
        <source>getFirstChildObject(_parent: CM_Object): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

//cnwrd1 par 31974
	if self.myParent.isKindOf(CM_VesselStructuralElements) then	
		return _parent.CM_VesselStructuralElements.allTanks.first.CM_VesselTankVessel;
	else
		return _parent.CM_VoyageStructuralElements.allTanks.first.CM_VesselTankVoyage;
	endif;
		

epilog

end;</source>
        <Parameter name="_parent" type="CM_Object"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
