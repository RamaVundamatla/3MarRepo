    <JadeMethod name="create" id="5e2e5cf3-27f1-4077-801d-841e6feb2e87">
        <updating/>
        <source>create() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	description := 'Days passed ' &amp; self.Operator_Between;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="efb06d35-2a88-4463-a077-0dada90c40b6">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Aug 2006	cnwer1	Initial creation - PAR#xxxx
16 Jan 2025	navah1	Bug 19289: CUX - Case # 00572807 - Report Runner shows "No Data to Display"
23 Jun 2025 navma1  MTN-35065 Selector Query - Days Passed
*/
vars
	dt : Date;
begin
	if not _value.Date.isValid then  //cnwrd1 15.7.2008 par 17512
		return false;
	endif;

	//return (fromNumDays &lt; (app.actualTimeServer.date - _value.Date)  and toNumDays &gt;= (app.actualTimeServer.date - _value.Date)); //16.01.2025 navah1 #19289
	dt := app.actualTimeServer.date;												  								//23.06.2025 navma1 MTN-35065
	return (fromNumDays &lt;= (dt - _value.Date)  and toNumDays &gt;= (dt - _value.Date));  //16.01.2025 navah1 #19289   //23.06.2025 navma1 MTN-35065
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="2b01ea8c-2543-4e10-8a9b-bde1b152b201">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
// -------------------------------------------
// Created 03 may 2008 by cnwvu1
// -------------------------------------------

vars

begin
	
	_searchValueA			:= self.fromNumDays.asStringJMT();
	_searchValueB			:= self.toNumDays.asStringJMT();
	_searchValueBoolean		:= null;
	_isStringProperty		:= false;
	_isStringBetweenProperty:= true;
	_isBooleanProperty		:= false;
	
end;
</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
