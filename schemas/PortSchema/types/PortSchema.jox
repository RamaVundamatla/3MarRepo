    <JadeMethod name="formatForEditTransaction" id="ae4b8bdf-c310-4bef-bfac-b61ee1cb06e4">
        <source>formatForEditTransaction(_fieldName, _oldValue, _newValue : String) : String;
/* ---------------------------------------------------------------------------
Created:     15 September 2009 by cnwrs2

Purpose:     Centralise formatting of CM_Edit into 1 place
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return _fieldName &amp; " " &amp; _oldValue &amp; " " &amp;
			CM_Edit.S_EDIT_THING &amp; " " &amp; _newValue;
epilog

end;</source>
