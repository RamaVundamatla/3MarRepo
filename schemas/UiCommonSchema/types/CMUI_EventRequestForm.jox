    <JadeMethod name="doBuildMnuTblObj" id="a53b6d9b-d5db-45fc-a8dd-47df1ed9899b">
        <source>doBuildMnuTblObj();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	//set appropriate mnu options as required
	if self.myCurrentEventRequest &lt;&gt; null then
		self.mnuCargoEnquiry.visible := true;	
	else
		self.mnuCargoEnquiry.visible := false;
	endif;
	
	self.mnuAudits.visible:=self.myCurrentEventRequest &lt;&gt; null and self.myCurrentEventRequest.hasAudits; //14 Jan 2021	NDL	TFS 50152
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeUpdateType" id="25044693-e507-4d27-89ca-2461acee1219">
        <source>doChangeUpdateType();
/*

Date		Who		Reason
07 May 2014	cnwer1	Initial creation PAR

*/

vars
	updateType : Integer;
begin
	updateType:=self.cmbUpdateType.listData;
	
	if updateType = null or updateType = EventRequestTypeRemarks or updateType = EventRequestTypeWeight then
		self.tblSearch.hideRowByName(ETRow_Event,false);
		return;
	endif;
	
	if updateType = EventRequestTypeStops then
		if self.tblSearch.getHeadingByName(ETRow_Event) =  app.getErrorString(Stop) then
			return;
		endif;
		
		self.tblSearch.showRowByName(ETRow_Event,false);
		self.tblSearch.setHeadingByName(ETRow_Event,app.getErrorString(Stop));
		self.lstTable.allSelectedObjects.clear;
		self.myAssistant.listTableStopsTableSys(self.lstTable);
		self.tblSearch.setValueByControlName(self.lstTable.name, self.lstTable.getSelectedFromDisplay());
	endif;
	
	if updateType = EventRequestTypeToDo then
			if self.tblSearch.getHeadingByName(ETRow_Event) =  app.getErrorString(To_Do_Tasks) then
			return;
		endif;
		
		self.tblSearch.showRowByName(ETRow_Event,false);
		self.tblSearch.setHeadingByName(ETRow_Event,app.getErrorString(To_Do_Tasks));
		self.lstTable.allSelectedObjects.clear;
		self.myAssistant.listTableToDoTasksSys(self.lstTable);
	
		self.tblSearch.setValueByControlName(self.lstTable.name, self.lstTable.getSelectedFromDisplay());

	endif;
	
	if updateType = EventRequestTypeGrade then
			if self.tblSearch.getHeadingByName(ETRow_Event) =  app.getErrorString(Grade) then
			return;
		endif;
		
		self.tblSearch.showRowByName(ETRow_Event,false);
		self.tblSearch.setHeadingByName(ETRow_Event,app.getErrorString(Grade));
		self.lstTable.clear;
		self.lstTable.allSelectedObjects.clear;
		self.lstTable.displayCollection(app.myRoot.allAvailableAvailabilityGrades, false, Table.DisplayCollection_Forward, null);
		self.tblSearch.setValueByControlName(self.lstTable.name, self.lstTable.getSelectedFromDisplay());

	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="d317b22e-4eac-44fb-ad3f-f81e9b07c3ea">
        <updating/>
        <source>doDelete()updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	msgStr			: String;
	selectedObj 	: CM_Object;
	objectArray		: CM_ObjectArrayActual;
	result 			: Integer;
begin

	if self.tblData.allSelectedObjects.size &gt; 1 then
	   	msgStr := app.getErrorString2(ConfirmDelete, 'selected', self.eventRequestType);
	elseif self.myCurrentEventRequest &lt;&gt; null then
		selectedObj := self.myCurrentEventRequest;
		msgStr := app.getErrorString2(ConfirmDelete, 'the selected', self.eventRequestType);
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.eventRequestType, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;

	if app.msgBox(msgStr, self.eventRequestType, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
		if selectedObj &lt;&gt; null then
			app.myTrxDA.trxDeleteCMObject(selectedObj, app.myPassport);
		else
			create objectArray transient;
			self.tblData.allSelectedObjects.copy(objectArray);
			app.myTrxDA.trxDeleteCMObjects(objectArray, app.myPassport);	
		endif;		  	  

		if  not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Cargo Update Request', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	delete objectArray;
end;</source>
    </JadeMethod>
