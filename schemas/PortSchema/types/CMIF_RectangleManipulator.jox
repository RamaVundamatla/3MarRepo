    <JadeMethod name="calcCentrePoint" id="b7a21e90-d072-49df-8369-cd609cb6943d">
        <updating/>
        <source>calcCentrePoint() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aPoint,newPoint : Point;
	pntX, pntY : Integer;
	maxX, maxY, minX,minY : Integer;
begin

	maxX := -999999999;
	maxY := maxX;
	minX := 999999999;
	minY := minX;
	foreach aPoint in self.originalPoints do
		maxX := maxX.max(aPoint.x);
		minX := minX.min(aPoint.x);
		maxY := maxY.max(aPoint.y);
		minY := minY.min(aPoint.y);
		
	endforeach;
	
	self.centrePoint.set( (((maxX - minX) / 2).Integer + minX), (((maxY - minY) / 2).Integer + minY) );
	
	// now calc the points in relation to our centre point
	self.centredPoints.clear;
	
	foreach aPoint in self.originalPoints do
		newPoint.set( (aPoint.x - self.centrePoint.x), (aPoint.y - self.centrePoint.y) );
		self.centredPoints.add(newPoint);
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDragDetected" id="736423aa-fcc8-4576-8781-733b85bf8f82">
        <source>doDragDetected(x,y : Real) : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	minX,maxX,minY,maxY : Real;
begin
	minX := self.originalX - 5;
	maxX := self.originalX + 5;
	minY := self.originalY - 5;
	maxY := self.originalY + 5;
	
	if x &lt; minX or x &gt; maxX then
		return true;
	elseif y &lt; minY or y &gt;maxY then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExtendLine" id="e2003e5c-eec3-4bc0-b0fb-762ae261be35">
        <updating/>
        <source>doExtendLine(_firstPoint, _secondPoint : Point;_currentX,_currentY : Real) : Point updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		Take 2 points, and extend the line between them by the mouse movement ( this is the diff between the orig X and the passed in X)
// ---------------------------------------------------------------------------
vars
	xDiff, yDiff,xMseDiff, yMseDiff,theSlope : Real;
	pntX1,pntY1,pntX2,pntY2,currentX,currentY,newX,newY : Integer;
	newPoint : Point;
begin
	xMseDiff := (_currentX - self.originalX);
	yMseDiff := (_currentY - self.originalY);
	
	pntX1 := _firstPoint.x;
	pntY1 := _firstPoint.y;
	pntX2 := _secondPoint.x;
	pntY2 := _secondPoint.y;
	
	if pntY2 = pntY1 then
		return _secondPoint;
	endif;
	
	theSlope := (pntX2 - pntX1) / (pntY2 - pntY1);
	if theSlope = 0 then
		return _secondPoint;
	endif;
	
	newX := (pntX2 + xMseDiff).Integer;
	newY := ((newX - pntX1) / theSlope).Integer + pntY1;
	
	newPoint.set(newX,newY);
	return newPoint;
end;</source>
        <Parameter name="_firstPoint" type="Point"/>
        <Parameter name="_secondPoint" type="Point"/>
        <Parameter name="_currentX" type="Real"/>
        <Parameter name="_currentY" type="Real"/>
        <ReturnType type="Point"/>
    </JadeMethod>
    <JadeMethod name="doGetRatio" id="5a6250a8-07bc-4796-8545-78f7773f6453">
        <source>doGetRatio(x0,y0,x1,y1,x2,y2: Real) : Real;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theRatio 	: Real;
	lineLength1 : Real;
	lineLength2	: Real;
	
begin
	if (x0 = x1 and y0 = y1) or (x0 = x2 and y0 = y2) then
		//can't be done
		return null;
	endif;

	lineLength1 := ((x1-x0).squared + (y1-y0).squared).sqrt;
	
	lineLength2 := ((x2-x0).squared + (y2-y0).squared).sqrt;
	
	theRatio := lineLength2/lineLength1;
	return theRatio;
end;</source>
        <Parameter name="x0" type="Real"/>
        <Parameter name="y0" type="Real"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setup" id="720c84cf-5def-4e92-85da-34f8f44ef183">
        <updating/>
        <source>setup(_originalX,_originalY : Real; _originalPoints : PointArray input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if _originalPoints.isEmpty then
		return;
	endif;
	
	self.originalX := _originalX;
	self.originalY := _originalY;
	
	self.originalMousePoint.set(self.originalX.Integer,self.originalY.Integer);
	_originalPoints.copy(self.originalPoints);
	_originalPoints.copy(self.newPoints);
	
	self.calcCentrePoint();
end;</source>
        <Parameter name="_originalX" type="Real"/>
        <Parameter name="_originalY" type="Real"/>
        <Parameter name="_originalPoints" type="PointArray" usage="input"/>
    </JadeMethod>
</Class>
