    <JadeMethod name="displayModeActual" id="33304d84-7436-4718-9b9a-a7126547d13a">
        <updating/>
        <source>displayModeActual(_doClick : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
//	mnuChild : MenuItem;
begin
	self.btnActual.value := true;
	self.frmToolbar.visible:= not self.xmlToolbar; //epr par 36003 29/4/15
	self.frmToolbar2.visible := (not self.xmlToolbar);
	
	self.hideShowPens(false, false);
	self.hideShowViewModes(true);
	self.enableDisableImexBtns(true, true);
	self.enableDisableAttributePens(false);
	self.enableDisableDrawingPens(false);
	self.enableDisableWorkModes(false, false);

	self.btnColorCodeDish.enabled	:= true;
	self.btnColorCodeLoad.enabled	:= true;
	self.btnSaveBase.visible		:= false;
	self.btnDelete.visible			:= false;	
	self.btnEdit.visible			:= false;	
	self.btnMakeActual.enabled		:= false;
	self.btnAutoDischCC.enabled		:= true;
	self.btnImportTasks.enabled		:= true;
	self.btnCustomsEDI.enabled		:= true;
	self.btnSummariseAll.enabled	:= true;	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	self.btnSummariseAll.bubbleHelp := app.getErrorString(Summar_onship_cargo_enquir_pur);
	
	self.mnuWorkCCMain.visible := false;
	self.mnuWorkViewMain.visible := true;
	self.mnuWorkDisplayMain.visible := true;
	
	self.cmbCargoType.visible := false;
	self.cmbCommodity.visible := false;
	self.cmbPortDis.visible := false;
	self.txtWeight.visible	:=	false;		// cnwdad1 30/07/2010 - PAR #24045.
	self.chkIgnoreWeightV.visible :=	false;	// cnwdad1 30/07/2010 - PAR #24045.

	self.cmbCrane.visible := false;
	self.cmbJob.visible := false;
	self.txtJobLinkLoad.visible := false;

	self.frmStatusLine.myFrameDisplayMode.enabled := true;
	self.frmStatusLine.myFrameMoveMode.enabled := true;
	self.frmStatusLine.enabled := true;

	if self.displayMode = ShpDisplayMode_Actual and _doClick then // not EDI
		self.frmStatusLine.setDisplayMode(DISPLAY_MODE_ACTUAL);
	endif;
	
	self.frmStatusLine.doMenuMoveClick(CMUI_GridAreaStatusLine.MENU_MOVE_INSTANT);
	self.frmStatusLine.myFrameDisplayMode.enabled := true; 
	self.frmStatusLine.myFrameMoveMode.enabled := true;
	self.frmStatusLine.displayMode := DISPLAY_MODE_ACTUAL;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnMakeActual.enabled		:= false;
		self.btnAutoDischCC.enabled		:= false;
		self.btnImportTasks.enabled		:= false;
		self.btnCustomsEDI.enabled		:= false;
		self.btnTranship.enabled:= false;
	endif;

end;</source>
        <Parameter name="_doClick" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayModeColourDischarge" id="98b0f2f3-5195-4044-b3d8-7f2811ebbc1e">
        <updating/>
        <source>displayModeColourDischarge() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance
			cnwer1

*/

vars
	useAlloc 		: Boolean;
	yaIMEXConfig 	: CM_VoyageAllocationConfig;
	
begin
	self.frmScrollBackgrd.enabled:= true; // TFS 2198
	useAlloc := false;
	if self.myCurrentVoyage &lt;&gt; null then
		useAlloc := self.myCurrentVoyage.useVoyageAllocations;
	endif;

	self.hideShowViewModes(false);
	self.hideShowPens(false, true);

	self.frmToolbar2.visible := true;
	
	self.enableDisableWorkModes(true, true);
	self.enableDisableImexBtns(false, false);
	
	if self.workingMode = self.WorkMode_CustomSeq then
		self.enableDisableDrawingPens(false);
		self.enableDisableAttributePens(false);
	else
		self.enableDisableDrawingPens(true);
		self.enableDisableAttributePens(false);
		self.btnCCScreen.visible := useAlloc;
		self.btnCCScreen.enabled := useAlloc;

	endif;

	self.cmbCargoType.visible 	:=	false;
	self.cmbCommodity.visible 	:=	false;
	self.cmbPortDis.visible 	:=	false;
	self.txtWeight.visible		:=	false;		// cnwdad1 30/07/2010 - PAR #24045.
	self.chkIgnoreWeightV.visible :=	false;	// cnwdad1 30/07/2010 - PAR #24045.

	self.cmbCrane.visible := false;
	self.cmbJob.visible := false;
	self.txtJobLinkLoad.visible := false;

	if self.workingMode = self.WorkMode_CustomSeq then
		self.btnSaveBase.visible 	:= true;
	else
		self.btnSaveBase.visible 	:= false;
	endif;
	self.btnDelete.visible		:= false;
	self.btnEdit.visible		:= false;	

	self.frmStatusLine.myFrameDisplayMode.clearGraphics;
	self.frmStatusLine.myFrameDisplayMode.enabled := false;
	self.frmStatusLine.myFrameMoveMode.clearGraphics;
	self.frmStatusLine.myFrameMoveMode.enabled := false;

	if self.workingMode = self.WorkMode_Plan then
	//	self.workModePlanning();
	endif;
	if useAlloc then
		// PAR 23412
		if self.workingMode = self.WorkMode_CustomSeq then
			self.btnSaveBase.visible 	:= true;
		else
			self.btnSaveBase.visible 	:= false;
		endif;
		// PAR 23450
		if useAlloc then
			if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.allVoyageAllocationConfigs.size &gt; 0 then
				yaIMEXConfig := self.myCurrentVoyage.allVoyageAllocationConfigs[TI_IMEX_STATUS_EXPORT].CM_VoyageAllocationConfig;
				if yaIMEXConfig &lt;&gt; null then
					if yaIMEXConfig.allOpCriteria.isEmpty then
						app.msgBox(app.getErrorString(Please_voyage_config_color_cod), app.getErrorString(Problem), MsgBox_OK_Only);
						return;
					endif;
				endif;
			endif;
		endif;
		
		if (not  self.myConfig.CMIF_ConfigUserVoyagePlanning.shipCCHidePalette )
		or (self.myCCPalette &lt;&gt; null) then // PAR 26322
			if self.workingMode = self.WorkMode_None then // PAR 23216
				self.showVoyAllocScreens(); // PAR 22925 this has been moved up, was after this if statement
			endif;
			// PAR 27032 - Only call change IMEX if necessary
			if self.myCCPalette &lt;&gt; null and self.myCCPalette.isExport &lt;&gt; false then
				self.myCCPalette.doChangeIMEX(false);
			endif;
			if self.myCCScreen &lt;&gt; null and self.myCCScreen.isExport &lt;&gt; false then
				self.myCCScreen.doChangeIMEX(false);
			endif;
		endif;
		
	endif;
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnJobsMode.enabled:= false;
		self.btnSequenceMode.enabled:= false;
		self.btnPlanningMode.enabled:= false;
		self.btnPenEraser.enabled:= false;
		self.btnPenDischarge.enabled:= false;
		self.btnPenRehandle.enabled:= false;
		self.btnPenSOB.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayModeColourLoad" id="7c17ea87-fbe7-4777-8938-ee756cd56774">
        <updating/>
        <source>displayModeColourLoad() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance
			cnwer1

*/

vars
	yaIMEXConfig 	: CM_VoyageAllocationConfig;
	useAlloc 		: Boolean;
	
begin
	self.frmScrollBackgrd.enabled:= true; // TFS 2198
	useAlloc := false;
	if self.myCurrentVoyage &lt;&gt; null then
		useAlloc := self.myCurrentVoyage.useVoyageAllocations;
	endif;
	
	// PAR 23450
	if useAlloc then
		if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.allVoyageAllocationConfigs.size &gt; 0 then
			yaIMEXConfig := self.myCurrentVoyage.allVoyageAllocationConfigs[TI_IMEX_STATUS_EXPORT].CM_VoyageAllocationConfig;
			if yaIMEXConfig &lt;&gt; null then
				if yaIMEXConfig.allOpCriteria.isEmpty then
					app.msgBox(app.getErrorString(Please_voyage_config_color_cod), app.getErrorString(Problem), MsgBox_OK_Only);
					return;
				endif;
			endif;
		endif;
	endif;
	
	self.chkShipTLHeight.visible := false;
	self.chkShipTLWeight.visible := false;
	
	self.hideShowViewModes(false);
	self.hideShowPens(not useAlloc, true);
	self.frmToolbar2.visible := true;
	
	self.enableDisableWorkModes(true, true);
	self.enableDisableImexBtns(false, false);

	if self.workingMode &lt;&gt; self.WorkMode_CustomSeq then
		self.enableDisableDrawingPens(true);
		self.enableDisableAttributePens(true);
		self.setToolbarCombosWidth();
		self.cmbCargoType.visible := not useAlloc;
		self.cmbCommodity.visible := not useAlloc;
		self.cmbPortDis.visible := not useAlloc;
		self.txtWeight.visible := not useAlloc;		// cnwdad1 30/07/2010 - PAR #24045.
		self.chkIgnoreWeightV.visible :=	false;	// cnwdad1 30/07/2010 - PAR #25353.
		self.frmToolbarCombos.visible := true;
		self.frmToolbarChk.visible := true;
		self.btnCCScreen.visible := useAlloc;
		self.btnCCScreen.enabled := useAlloc;
	else
		self.enableDisableDrawingPens(false);
		self.enableDisableAttributePens(false);
		self.frmToolbarCombos.visible := false;
		self.btnCCScreen.visible := false;
		self.btnCCScreen.enabled := false;
	endif;

	self.cmbCrane.visible := false;
	self.cmbJob.visible := false;
	self.txtJobLinkLoad.visible := false;

	self.btnSaveBase.visible 	:= true;
	self.btnDelete.visible		:= false;
	self.btnEdit.visible		:= false;	

	self.frmStatusLine.myFrameDisplayMode.clearGraphics;
	self.frmStatusLine.myFrameDisplayMode.enabled := false;
	self.frmStatusLine.myFrameMoveMode.clearGraphics;
	self.frmStatusLine.myFrameMoveMode.enabled := false;

	if self.workingMode = self.WorkMode_Plan then
		//self.workModePlanning();
	endif;
	if useAlloc then
		// PAR 23412
		if self.workingMode = self.WorkMode_CustomSeq then
			self.btnSaveBase.visible 	:= true;
		else
			self.btnSaveBase.visible 	:= false;
		endif;
		
		// PAR 23450
		if useAlloc then
			if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.allVoyageAllocationConfigs.size &gt; 0 then
				yaIMEXConfig := self.myCurrentVoyage.allVoyageAllocationConfigs[TI_IMEX_STATUS_EXPORT].CM_VoyageAllocationConfig;
				if yaIMEXConfig &lt;&gt; null then
					if yaIMEXConfig.allOpCriteria.isEmpty then
						app.msgBox(app.getErrorString(Please_voyage_config_color_cod), app.getErrorString(Problem), MsgBox_OK_Only);
						return;
					endif;
				endif;
			endif;
		endif;
		
		self.btnSummariseAll.enabled	:= true;	
		self.btnSummariseAll.bubbleHelp := app.getErrorString(Summa_onsit_cargo_load_colou_c);
		
		//24 Jan 2012	NDL	Par 28896
		if (not  self.myConfig.CMIF_ConfigUserVoyagePlanning.shipCCHidePalette )
		or (self.myCCPaletteLoad &lt;&gt; null) then 
			if self.workingMode = self.WorkMode_None then 
				self.showVoyAllocScreens();
			endif;	
			if self.myCCScreen &lt;&gt; null and self.myCCScreen.isExport &lt;&gt; true  then
				self.myCCScreen.doChangeIMEX(true);
			endif;
		endif;
		/*
		if (not  self.myConfig.CMIF_ConfigUserVoyagePlanning.shipCCHidePalette )
		or (self.myCCPalette &lt;&gt; null) then // PAR 26322
			if self.workingMode = self.WorkMode_None then // PAR 23216
				self.showVoyAllocScreens();
			endif;
			// PAR 27032 - Only call change IMEX if necessary
			if self.myCCPalette &lt;&gt; null and self.myCCPalette.isExport &lt;&gt; true then
				self.myCCPalette.doChangeIMEX(true);
			endif;
				
			if self.myCCScreen &lt;&gt; null and self.myCCScreen.isExport &lt;&gt; true  then //15/02/2011 cnwdz2 par 26993
				self.myCCScreen.doChangeIMEX(true);
			endif;
		endif;
		*/
		
	endif;

	self.doResize();
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnJobsMode.enabled:= false;
		self.btnSequenceMode.enabled:= false;
		self.btnPlanningMode.enabled:= false;
		self.btnPenEraser.enabled:= false;
		self.btnPenLoad.enabled:= false;
		self.btnPenRehandle.enabled:= false;
		self.btnPenSOB.enabled:= false;
		self.enableDisableDrawingPens(false);
		self.enableDisableAttributePens(false);
		self.btnSaveBase.enabled:= false;
		self.cmbPortDis.enabled:= false; // TFS 2734
		self.cmbCommodity.enabled:= false; // TFS 2734
		self.cmbCargoType.enabled:= false; // TFS 2734
		self.txtWeight.enabled:= false; // TFS 2734
		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayModeDefn" id="99efa2d9-f942-452e-96fc-1ba12d952c80">
        <updating/>
        <source>displayModeDefn() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.frmScrollBackgrd.enabled:= true; // TFS 2198

	self.hideShowPens(true, false);

	self.btnPenHiCube.visible		:= false;
	self.btnPenHazard.visible		:= false;
