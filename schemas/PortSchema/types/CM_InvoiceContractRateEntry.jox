    <JadeMethod name="cloneForCopy" id="e92e7335-9c85-417d-8846-a5e4787f723d">
        <source>cloneForCopy(_transient : Boolean) : SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2023	navkc1	Initial creation CR #55652 Task 55681: Jade - Contracts Copy TRX

*/

vars
	clonedRateEntry		: CM_InvoiceContractRateEntry;
	
begin
	
	clonedRateEntry := self.cloneSelf(_transient);
	clonedRateEntry.myBusinessUnit := self.myBusinessUnit;
	
	return clonedRateEntry;
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="delete" id="f1c4f8c3-8af3-4b28-8286-be9b87cf33b4">
        <updating/>
        <source>delete() updating;
/*
Purpose:		used for auditing 	

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	iter : Iterator;
	cmqf : CMQF_InvoiceContract;
begin
	iter := CMQF_InvoiceContract.instances.createIterator;
	while iter.next(cmqf) do
		if cmqf.allContractRateEntries.includes(self) then
			cmqf.allContractRateEntries.remove(self);
		endif;
	endwhile;
	
	self.resetAuditsDuringDelete();

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doIConflictWithDateRanges" id="62056432-9f8c-4a51-85bf-0e6174459fa1">
        <source>doIConflictWithDateRanges(_contractRate :CM_InvoiceContractRate; _mess : String io) : Boolean;
/*
Purpose:	Make sure my From and To date (range) do not overlap with any other ranges

Date		Who		Reason
### TFS BUG 56868 02MAR2023 NAVAB1
*/
vars
	aRateEntry, realMe: CM_InvoiceContractRateEntry;
	fromDate, toDate : TimeStamp;
begin
	realMe := self.pxyGetRealObject();
	
	// Start navtnr20 10-03-2023 bug 56908 
	if realMe &lt;&gt; null then // during an update use the 'original' dates, not the proxy 'new' dates when comparing to other entries for my group of rate entries.
		fromDate := realMe.fromTS;
		toDate := realMe.toTS;
	else
		fromDate := self.fromTS;
		toDate := self.toTS;
	endif;
	
	_mess := null;
	
	foreach aRateEntry in _contractRate.allInvoiceContractRateEntries discreteLock do
		if realMe &lt;&gt; null 
		and realMe = aRateEntry then
			continue;
		endif;
		
		if aRateEntry.fromTS = fromDate // Start navtnr20 10-03-2023 bug 56908 
		and aRateEntry.toTS =  toDate then// Start navtnr20 10-03-2023 bug 56908
			continue;
		endif;
		
		// ### TFS DEFECT 61482 27NOV2023 NAVAB1 - add '=' to each of the following 4 &gt; and &lt;
		if self.fromTS &gt;= aRateEntry.fromTS and self.fromTS &lt;= aRateEntry.toTS  then
			_mess := " From date " &amp; self.fromTS.asStringJMT() &amp; " conflicts with existing range " &amp; aRateEntry.fromTS.asStringJMT() &amp; " - " &amp; aRateEntry.toTS.asStringJMT();
		endif;
		if self.toTS &gt;= aRateEntry.fromTS and self.toTS &lt;= aRateEntry.toTS  then
			_mess := " To date " &amp; self.toTS.asStringJMT() &amp; " conflicts with existing range " &amp; aRateEntry.fromTS.asStringJMT() &amp; " - " &amp; aRateEntry.toTS.asStringJMT();
		endif;
	
	endforeach;

	return (_mess = null);
	
epilog
end;</source>
        <Parameter name="_contractRate" type="CM_InvoiceContractRate"/>
        <Parameter name="_mess" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doIConflictWithRangesForCreate" id="e5337770-6ea0-4c5c-aad9-b39f50e03d19">
        <source>doIConflictWithRangesForCreate(_contractRate :CM_InvoiceContractRate; _mess : String io) : Boolean;
/*
Purpose:	Make sure my From and To amounts (range) do not overlap with any other range that has the same from and to time stamp.		

Date		Who		Reason
09DEC2022	NAVAB1	TFS CR 55623 TASK 55677
*/
vars
	aRateEntry: CM_InvoiceContractRateEntry;
	myst, myen,st, en : Decimal[23,4];
	rateEntries : CM_InvContractRateEntryByAmnt;
begin
	
	myst := self.fromAmount;
	myen := self.toAmount;
	
	 // ### TFS CR 55644 TASK 55684 12JAN2023 NAVAB1 get the rate entries with the same date range as me
	create rateEntries transient;
	foreach aRateEntry in _contractRate.allInvoiceContractRateEntries discreteLock do
		if aRateEntry.fromTS = self.fromTS 
		and aRateEntry.toTS = self.toTS then
			rateEntries.add(aRateEntry);
		endif;
	
	endforeach;
	
	foreach aRateEntry in rateEntries discreteLock do
		st := aRateEntry.fromAmount;
		en := aRateEntry.toAmount;
		
		if myst = st then
			_mess := _mess &amp; ", " &amp;  myst.String &amp; " is the same as " &amp; st.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
		endif;
		if myst = en then
			_mess := _mess &amp; ", " &amp;  myst.String &amp; " is the same as " &amp; en.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
		endif;
		if myen = st then
			_mess := _mess &amp; ", " &amp;  myen.String &amp; " is the same as " &amp; st.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
		endif;
		if myen = en then
			_mess := _mess &amp; ", " &amp;  myen.String &amp; " is the same as " &amp; en.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
		endif;

		if myst &gt; en then
			continue;
		endif;
		
		if myen &lt; st then
			continue;
		else
			if myst &gt; st then
				if myen &gt; en then
					_mess := _mess &amp; ", " &amp;  myen.String &amp; " is greater than " &amp; en.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
				elseif myen &lt; en then
					_mess := _mess &amp; ", " &amp;  myen.String &amp; " is less than " &amp; en.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
				endif;
			else
				_mess := _mess &amp; ", " &amp;  myen.String &amp; " is greater than " &amp; st.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
			endif;
		endif;
		
	endforeach;
	
	if _mess &lt;&gt; null then
		_mess := "'" &amp; self.fromAmount.asStringJMT() &amp; "-" &amp; self.toAmount.asStringJMT() &amp;"' : " &amp; _mess;
	endif;
	
	return (_mess = null);
	
epilog

	delete rateEntries;
end;</source>
        <Parameter name="_contractRate" type="CM_InvoiceContractRate"/>
        <Parameter name="_mess" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doIConflictWithRangesForUpdate" id="5fc4f2bd-2574-42e2-aeb0-22498e95e3a0">
        <source>doIConflictWithRangesForUpdate(_contractRate :CM_InvoiceContractRate; _mess : String io) : Boolean;
/*
Purpose:	Make sure my From and To amounts (range) do not overlap with any other range that has the same from and to time stamp.					

Date		Who		Reason
09DEC2022	NAVAB1	TFS CR 55623 TASK 55677
*/
vars
	aRateEntry, realME, prevEntry, beforeME, afterME: CM_InvoiceContractRateEntry;
	myst, myen,st, en : Decimal[23,4];
	getAfter : Boolean;
	rateEntries : CM_InvContractRateEntryByAmnt;
begin
	realME := self.pxyGetRealObject();
	
	myst := self.fromAmount;
	myen := self.toAmount;
	
	 // ### TFS CR 55644 TASK 55684 12JAN2023 NAVAB1 get the rate entries with the same date range as me
	create rateEntries transient;
	foreach aRateEntry in _contractRate.allInvoiceContractRateEntries discreteLock do
		if aRateEntry.fromTS = self.fromTS 
		and aRateEntry.toTS = self.toTS then
			rateEntries.add(aRateEntry);
		endif;
	
	endforeach;
	
	foreach aRateEntry in rateEntries discreteLock do
		
		if realME = aRateEntry then
			getAfter:= true;
			beforeME := prevEntry;
			continue;
		endif;

		prevEntry := aRateEntry;
		
		if getAfter then
			getAfter := false;
			afterME := aRateEntry;
		endif;
		
	endforeach;
	
	foreach aRateEntry in _contractRate.allInvoiceContractRateEntries discreteLock do
		// ignore me, as I am about to be updated
		if realME = aRateEntry then
			continue;
		endif;
		st := aRateEntry.fromAmount;
		en := aRateEntry.toAmount;
		
		
		if aRateEntry = beforeME then // one before me
			if myst &lt;= en then
				_mess := _mess &amp; ", " &amp;  myst.String &amp; " is the same or less than " &amp; en.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
			
			endif;
		endif;
		if aRateEntry = afterME then // one after me
			if myen &gt;= st then
				_mess := _mess &amp; ", " &amp;  myen.String &amp; " is the same or greater than " &amp; st.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
			
			endif;
		endif;

	endforeach;

	if _mess &lt;&gt; null then
		_mess := "'" &amp; self.fromAmount.asStringJMT() &amp; "-" &amp; self.toAmount.asStringJMT() &amp;"' : " &amp; _mess;
	endif;

	return (_mess = null);
epilog

	delete rateEntries;
end;</source>
        <Parameter name="_contractRate" type="CM_InvoiceContractRate"/>
        <Parameter name="_mess" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
