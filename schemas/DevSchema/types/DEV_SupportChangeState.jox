    <JadeMethod name="doOK" id="363c65a2-d062-40af-a404-1997edfa398e">
        <updating/>
        <source>doOK() updating;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars
	oldState,
	newState		: DEV_SupportState;
	newStateStr 	: String;
	kpi1Remaining,
	kpi2Remaining,
	kpi3Remaining	: String;
	tfs				: String;
	
begin
	newStateStr := self.cmbState.text;
	oldState	:= self.myContact.allStates.last;
	tfs			:= self.txtTFS.text;
	
	if checkBox1.value = false and tfs = "" then
		if newStateStr = "" then
			app.msgBox('No state selected', 'Error', 48);
			return;
		endif;	
	endif;
	
	if newStateStr &lt;&gt; "" then
		if newStateStr = oldState.type then
			app.msgBox('Contact already in this state', 'Error', 48);
			return;
		endif;
	
		if not txtStartTS.text.TimeStamp.isValid then
			app.msgBox('Invalid timestamp (' &amp; txtStartTS.text &amp; '), ', 'Error', 48);
			return;
		endif;
		
		if oldState.startTS &gt;= txtStartTS.text.TimeStamp then
			app.msgBox('New state must be after last state', 'Error', 48);
			return;
		endif;
	endif;
	
	if tfs &lt;&gt; "" then
		if not (tfs.isInteger and tfs.Integer &gt; 1000 and tfs.Integer &lt; 10000) then
			app.msgBox('bad TFS number (' &amp; tfs &amp; ')', 'Error', 48);
			return;
		endif;
	endif;
	
	if self.myContact.getRemainingTimeKPI1().Integer &lt; 0 
	and checkBox1.value = true 
	and not self.txtKPI1Time.text.TimeStamp.isValid then
		app.msgBox('KPI1 has failed - a date/time for KPI completion must be entered so failure amount can be recorded.', 'Error', 48);
		return;
	endif;
	
	beginTransaction;
	// create the new state and set the end time on the old one
	if newStateStr &lt;&gt; "" then
		create newState persistent;
		newState.type 	 	:= newStateStr;
		newState.startTS 	:= txtStartTS.text.TimeStamp;
		newState.myContact	:= self.myContact;
		oldState.endTS	 	:= txtStartTS.text.TimeStamp;
	endif;
	commitTransaction;
	
	beginTransaction;
	if tfs &lt;&gt; "" then
		self.myContact.tfsNumber := tfs.Integer;
	endif;
	
	// update the kpiDone flags and record any kpi failures
	if checkBox1.value = true then
		if self.txtKPI1Time.text.TimeStamp.isValid then
			kpi1Remaining := self.getKPIFailedBy(self.myContact, self.txtKPI1Time.text.TimeStamp, 1);
			if kpi1Remaining.Real &lt;= 0 then
				self.myContact.kpi1FailedBy := kpi1Remaining;
			endif;
		endif;
		self.myContact.kpi1Done := true;
	endif;
	if (newStateStr = 'Active Development' or newStateStr = 'Closed') and not self.myContact.kpi2Done then
		kpi2Remaining := self.myContact.getRemainingTimeKPI2();
		if kpi2Remaining.Real &lt;= 0 then
			self.myContact.kpi2FailedBy := kpi2Remaining;
		endif;
		self.myContact.kpi2Done := true;
	endif;
	
	if newStateStr = 'Closed' then
		kpi3Remaining := self.myContact.getRemainingTimeKPI3();
		if kpi3Remaining.Real &lt;= 0 then
			self.myContact.kpi3FailedBy := kpi3Remaining;
		endif;
	endif;
	commitTransaction;
	
	self.unloadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="getKPIFailedBy" id="f743e01e-c1f6-4e68-b1be-db3aa54734df">
        <source>getKPIFailedBy(_contact : DEV_SupportContact; _endTS : TimeStamp; _kpi : Integer): String;

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	state 			: DEV_SupportState;
	duration		: Integer;
	timeRemaining	: Decimal[10,1];
	
begin
	// need to work out the business-hours active support time between opened and _endTS
	// if this exceeds the first KPI limit, return the amount the KPI failed by (in "1.1h" format)

	foreach state in _contact.allStates do
		if state.type = 'Active Support' or state.type = 'Architect/Dev Support' then
			duration := duration + state.getDurationInMinutes(_endTS);
		endif;
	endforeach;

	if _kpi = 1 then
		timeRemaining := (4*60) - duration;
	else
		timeRemaining := (48*60) - duration;
	endif;
	timeRemaining := timeRemaining/60;
	
	if timeRemaining &lt; 0 then
		return timeRemaining.String &amp; "h";
	else
		return "";
	endif;
end;</source>
        <Parameter name="_contact" type="DEV_SupportContact"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_kpi" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="16674156-f56b-47fa-bb23-0e0fdb3c884c">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars

begin
	self.centreWindow();
	
	self.cmbState.addItem('Active Support');
	self.cmbState.addItem('Pending Response');
	self.cmbState.addItem('Active Development');
	self.cmbState.addItem('Architect/Dev Support');
	self.cmbState.addItem('Closed');
	
	self.lblContact.caption := "Contact " &amp; self.myContact.number.String;
	
	if self.myContact.kpi1Done then
		checkBox1.enabled := false;
		label4.enabled := false;
		txtKPI1Time.enabled := false;
	endif;
end;</source>
    </JadeMethod>
</GUIClass>
