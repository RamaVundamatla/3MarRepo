    <JadeMethod name="setMyTrackedItem" id="5ce5ed4a-f0d6-4206-8fa4-aea3b79fd29c">
        <updating/>
        <source>setMyTrackedItem(pTI : CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2001 by cnwrs2
//
// Changes: 
//				PAR 16898 - RJS June 2008    - add FF code
//				TFS 44554 - jlgdap1 05/06/2019 - AAT Stevedore Data Access
//
// Date				Who		Reason
// 20 Sep 2019		jlgdi1	46043 Update the value of the new attribute billOfLading
//	13 may 2022		navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
// 24 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
// 28 May 2025		jlizm1	MTN 34966 Error 1081 when reading ti.allTransactions
// 20/06/2025		navcs2		MTN-34987
// ---------------------------------------------------------------------------
vars
	tmpDT			: TimeStamp;
	tmpOrderNo		: Integer;
	transDict		: CM_TITransactionByDateOrdDict;
begin
	if pTI = null then
		return;
	endif;
	
	exclusiveLock(pTI);
	
	transDict := pTI.allTransactions;
	
	tmpDT	:= self.dateTime;
	tmpOrderNo	:= self.orderNo;
	
	while transDict.includesKey(tmpDT, tmpOrderNo) do
		// need to update orderNo
		tmpOrderNo := tmpOrderNo + 1;
	endwhile;
	
	self.orderNo := tmpOrderNo;

	// Add into the dict.
	self.myTrackedItem 		:= pTI;
	self.createAndSetSnapShot(pTI);
	//jlier1 TFS 55140 18/10/22 - refactored into method to set values from ti
	self.setFromTrackedItem(pTI,_tiTransCntrl);
	
	//self.sendSAP();	//09 Apr 2019	NDL	TFS 44248 		20/06/2025		navcs2		MTN-34987
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageRelivant" id="3bbea01c-bb04-4983-9bc9-e3ae23537078">
        <updating/>
        <source>setMyVoyageRelivant(_voyage : CM_Voyage) updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2004	cnwth2
// ----------   ----------  --------------------------------------------------
// 10/06/2013	cnwcs5		par 31752 - Handle invalid voyage (probably only happens in DMAST)
vars
	gotException	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, _voyage, gotException);
	
	if _voyage &lt;&gt; null and _voyage.code = NULL_VOYAGE_CODE then
		return;
	endif;
	
	if gotException then
		return;
	endif;
	
	if not self.isVoyageRelivant then 
		return;
	endif;
	
	self.myVoyageRelivant := _voyage;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setNewProperties" id="13b99fbd-84df-4a02-bd25-20e3189d915d">
        <updating/>
        <source>setNewProperties(previousTrans: CM_TITransaction input) updating;
// works backward to set new properties
// Used when editting a transaction (not when being created)
// Changes
//			PAR 16898 - RJS June 2008 - add FF
// 			TFS 44554 - jlgdap1 05/06/2019 AAT Stevedore Data Access
begin
	if previousTrans = null then
		return;
	endif;
	previousTrans.commodity			:= self.commodity;
	previousTrans.companyCode		:= self.companyCode;
	previousTrans.customsAgentCode			:= self.customsAgentCode;
	previousTrans.consignee			:= self.consignee;
	previousTrans.consignor			:= self.consignor;
	previousTrans.contentsStatus	:= self.contentsStatus;
	previousTrans.freightForwarderCode	:= self.freightForwarderCode;	// PAR 16898 - RJS June 2008
	previousTrans.loadPort			:= self.loadPort;
	previousTrans.dischargePort		:= self.dischargePort;
	previousTrans.destinationPort	:= self.destinationPort;
	previousTrans.imExStatus		:= self.imExStatus;
	previousTrans.operatorCode		:= self.operatorCode;
	previousTrans.transitStatus := self.transitStatus;
	previousTrans.totalQuantity		:= self.totalQuantity;
	previousTrans.totalVolume		:= self.totalVolume;
	previousTrans.totalWeight		:= self.totalWeight;
	previousTrans.totalLength		:= self.totalLength; // PAR 31615
	previousTrans.voyage			:= self.voyage;
	previousTrans.voyageCode		:= self.voyageCode;		// PAR 24432
	previousTrans.stevedoreCode		:= self.stevedoreCode;			// TFS 44554
	
end;</source>
        <Parameter name="previousTrans" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
