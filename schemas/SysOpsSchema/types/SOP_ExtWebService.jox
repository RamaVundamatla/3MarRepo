    <JadeMethod name="doDelete" id="ecc40979-80a2-4281-ab3f-050abbf19b86">
        <source>doDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 July 2019	jlgmp6	Initial creation

*/

vars
	ccem: CM_CargoChainEventMapping;

begin
	ccem := self.tblEventMappings.accessCell(self.tblEventMappings.row, 1).itemObject.CM_CargoChainEventMapping;

	if ccem &lt;&gt; null then
		app.myTrxDA.trxDeleteWebServiceAdvSet(self.myExtWebService, ccem, app.myPassport);
	endif;

	self.populateTable();
epilog

end;</source>
