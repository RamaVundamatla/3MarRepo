        <source>btnCargo1_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 November 2013	cnwrd1	Initial creation

*/

vars

begin
	self.btnCargo2.value := not self.btnCargo1.value;
	self.setMySwapWle();
epilog

end;</source>
