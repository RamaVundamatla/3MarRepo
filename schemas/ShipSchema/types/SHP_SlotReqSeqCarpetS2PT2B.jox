<CollClass name="SHP_SlotReqSeqCarpetS2PT2B" id="cbaef419-8b90-4a83-a505-16019f9dfcdd">
    <duplicatesAllowed/>
    <memberType name="CM_SlotRequest"/>
    <superclass name="MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Sort Slot Request by Deck Cell and Tier. Duplicates are allowed in case across several bays.

In this order:

321
654
987</text>
    <DbClassMap file="clrcodes"/>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="CM_SlotRequest::myBay"/>
        </keyPath>
        <property name="CM_Bay::ordinalBay"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_SlotRequest::ordinalDeck"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_SlotRequest::ordinalTier"/>
        <descending/>
    </MemberKey>
    <MemberKey>
        <property name="CM_SlotRequest::ordinalCell"/>
    </MemberKey>
</CollClass>
