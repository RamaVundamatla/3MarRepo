		self.tblEvents.selectMode := Table.SelectMode_CurrentRow;
		
	endif;*/													//cnwas3 commented out to replace editing functionality with showing an invoice line
	
	if (event &lt;&gt; null and not event.allInvoiceLines.isEmpty()) then
		
		self.myAssistant.showInvoiceLineForm(event.allInvoiceLines.first(), self.myMasterMenuAction);
		self.tblEvents.selectMode := Table.SelectMode_CurrentRow;
		
	endif;
epilog

