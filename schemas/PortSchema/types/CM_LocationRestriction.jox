    <JadeMethod name="setForCreateAuto" id="17db0d4b-3e96-4485-beb1-19957d81b6b4">
        <updating/>
        <source>setForCreateAuto(_ta : CM_TerminalArea; _tmpTI : CM_TrackedItem; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     01 July 2004	cnwth2
//
// Purpose:     Called when automatically creating a restiction for the first TI moved into
//				a location that has AutoRestrictions turned on.
//				Sets self's restrictions from the TI passed in.
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpOp				: CM_Operator;
	lc					: CM_LocationsController;
begin
	self.myTerminalArea := _ta;
	self.allLocationControllers.clear();
	foreach lc in _ta.allLocationsControllers do
		if (not CM_YardController.hasInstance(lc)) then
			continue;
		endif;
		
		self.allLocationControllers.add(lc);
	endforeach;
	//_ta.allLocationsControllers.copy(self.allLocationControllers);
	
	self.id := DESCRIPTION_AUTO;
	self.comment := DESCRIPTION_AUTO &amp; ' restriction based on the state of ' &amp; _tmpTI.cargoTypeDescr &amp; ' ' &amp; _tmpTI.id;
	
	tmpOp := _tmpTI.myOperator;
	
	if tmpOp &lt;&gt; null then
		self.allOperators.add(tmpOp);
		
		self.updateObjectEdition( tmpOp); //cnwrd1 par 34536 update for sqlnative
	endif;
	/*
	if _tmpTI.getImExStatus() = TI_IMEX_STATUS_IMPORT then
		self.importsOnly := true;
	elseif _tmpTI.getImExStatus() = TI_IMEX_STATUS_EXPORT then
		self.exportsOnly := true;
	endif;
	*/
	//_tmpTI.allStops.copy(self.allStopsToCheck);
	
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_tmpTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForProxyLocationRestriction" id="4628d595-30a1-4e19-a2e6-21ee2d9f7a4f">
        <updating/>
        <source>setForProxyLocationRestriction(	_user,
								_comment		: String;
							 	_terminalArea	: CM_TerminalArea;
							 	_colour 		: Integer;
							 	_allOperators,
							 	_allCommodityGroups,
							 	_allConsignees,
							 	_allDischargePorts,
							 	_allVoyages		: ObjectArray;
							 	_allStopTablesToCheck: CM_StopsTableSet) updating, protected;

begin

	self.raiseExceptionIfNotTransient(method);
	self.setForProxyRestriction(_colour, _user, _comment);
	self.myTerminalArea := _terminalArea;
	self.allOperators.clear;
	self.allCommodityGroups.clear;
	self.allConsignees.clear;
	self.allDischargePorts.clear;
	self.allVoyages.clear;
	self.allStopsToCheck.clear;

	_allOperators.copy(self.allOperators);
	_allCommodityGroups.copy(self.allCommodityGroups);
	_allConsignees.copy(self.allConsignees);
	_allDischargePorts.copy(self.allDischargePorts);
	_allVoyages.copy(self.allVoyages);
	_allStopTablesToCheck.copy(self.allStopsToCheck);

end;</source>
        <access>protected</access>
        <Parameter name="_user" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_allOperators" type="ObjectArray"/>
        <Parameter name="_allCommodityGroups" type="ObjectArray"/>
        <Parameter name="_allConsignees" type="ObjectArray"/>
        <Parameter name="_allDischargePorts" type="ObjectArray"/>
        <Parameter name="_allVoyages" type="ObjectArray"/>
        <Parameter name="_allStopTablesToCheck" type="CM_StopsTableSet"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ecf9cc53-cc8b-48d3-8c09-7726643d7bb4">
        <updating/>
        <source>setForUpdate(prxyRestriction : CM_LocationRestriction) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	oper : CM_Operator;

begin

	inheritMethod(prxyRestriction);

	prxyRestriction.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	// other restrictions get auto IDs, Container restrictions let the user enter an ID. 
	// However the ID will have been already set on the superclass. That aauto ID will be used if the user does not enter an ID
	if prxyRestriction.id &lt;&gt; null then
		self.id := prxyRestriction.id;
	endif;
	self.exportsOnly 	:= prxyRestriction.exportsOnly;
	self.importsOnly 	:= prxyRestriction.importsOnly;

	// do the references

	self.allLocationControllers.clear();
	prxyRestriction.allLocationControllers.copy(self.allLocationControllers);

	self.allCargoTypes.clear;
	prxyRestriction.allCargoTypes.copy(self.allCargoTypes);

	self.allCommodityGroups.clear;
	prxyRestriction.allCommodityGroups.copy(self.allCommodityGroups);

	self.allConsignees.clear;
	prxyRestriction.allConsignees.copy(self.allConsignees);

	self.allDischargePorts.clear;
	prxyRestriction.allDischargePorts.copy(self.allDischargePorts);
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264 - clearing them
		foreach oper in self.allOperators do
			self.updateObjectEdition(oper);
		endforeach;
	endif;
	self.allOperators.clear;
	prxyRestriction.allOperators.copy(self.allOperators);
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264 - adding them
		foreach oper in self.allOperators do
			self.updateObjectEdition(oper);
		endforeach;
	endif;

	self.allStopsToCheck.clear;
	prxyRestriction.allStopsToCheck.copy(self.allStopsToCheck);

	self.allVoyages.clear;
	prxyRestriction.allVoyages.copy(self.allVoyages);
	
end;</source>
        <Parameter name="prxyRestriction" type="CM_LocationRestriction"/>
    </JadeMethod>
