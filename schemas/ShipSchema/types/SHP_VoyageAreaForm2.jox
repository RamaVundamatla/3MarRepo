    <JadeMethod name="doMnuGridLocateClick" id="e3e6ef07-081c-4634-a57c-8ba86760a119">
        <updating/>
        <source>doMnuGridLocateClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		08 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theObj : Object;
	objs : CM_TIArray;
	objset : ObjectSet;
	theENQ : CM_EnquiryController;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	create objs transient;
	create objset transient;
	self.myBayDrawingController.getOnsiteCargoFromColourCoding(objs);

	// PAR 15598
	foreach theObj in objs do
		if theObj.CM_TrackedItem.planningState = PLANNED_LOAD_STATE then
			continue;
		endif;
		objset.add(theObj);
	endforeach;

	if objset.isEmpty then //jlgzm1 20/12/2018 tfs41984 YardRowEnquiry reutrns a misleading error msg if objset is null
		app.msgBox(app.getErrorString(No_Cargo_Match_colour_coding),app.getErrorString(NO_Cargo_found),MsgBox_Exclamation_Mark_Icon);
	else
		theENQ := self.myAssistant.SHP_Assistant.doGetSelectorTIsLoadList(objset, self.myCurrentVoyage);
	
		self.myAssistant.showYardRowEnquiryForm(objset,  self.myMasterMenuAction,  theENQ,true, VIEW_DISPORT, null, null); // PAR 21148
	endif;
	
epilog
	delete objs;
	// do not delete 	objset they are cleared up by the enquiry form
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
