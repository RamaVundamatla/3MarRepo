    <JadeMethod name="doQueryTaskDirectorPlanning" id="c8317c09-24e0-4ae0-87e6-e5b94a17964d">
        <source>doQueryTaskDirectorPlanning();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2025	jlier1	Initial creation MTN-35633

*/

vars
	messageLogForm :	CMUI_MessageLogForm;
	request : CM_Request;
	wle : CM_WorkListEntry;
	bestPickOnlySource : Boolean;
	ti : CM_TrackedItem;
	sourceTa : CM_TerminalArea;
	sourceLocn : CM_LocationsController;
	allLogging : StringArray;
	log, log2 : String;
begin

	if self.myCurrentTask = null then
		return;
	endif;
	
	request:=self.myCurrentTask.myEntry.getMyRequest ;
	if request = null then
		return;
	endif;
	wle:=self.myCurrentTask.myEntry.myWorkListEntry;
	if wle = null then
		return;
	endif;

	create allLogging transient;
	bestPickOnlySource:=self.myTerminal.getConfig(GateBestPickForSource).Boolean;
	
	if wle.isBestPick or bestPickOnlySource then		// 23098
		ti := app.sourceTisForRequestBestPick(wle.getMyTerminal, wle, sourceTa, true,allLogging);		
	else
		// If we are best pick we should have a source location or have exited		
		sourceLocn	:= app.sourceTisForRequestYA(wle.getMyTerminal, request);
		if app.myYAAgent.myCurrentCMIFYAAutoPlan &lt;&gt; null then
			 app.myYAAgent.myCurrentCMIFYAAutoPlan.allVerboseLogging.copy( allLogging);
		endif;
	endif;
	
	create messageLogForm transient;
	messageLogForm.caption:=app.getErrorString(Queryin_directo_task_plannin); 
	
	foreach log in allLogging do
		log2:=log.replace("99,",Tab);//AP_Log_YA_Default
		log2:=log2.replace("0,",""); //AP_Log_YA_Global
		messageLogForm.allMessages.add(log2);
	endforeach;
	
	messageLogForm.show;
epilog
	
	delete allLogging;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryTaskMachineCoverage" id="bded2465-668e-4fe9-8adb-18decf2a663f">
        <source>doQueryTaskMachineCoverage();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwer1	Initial creation

*/

vars

	sa : StringArray512;
	messageLogForm :	CMUI_MessageLogForm;
begin
	if self.myCurrentTask = null then
		return;
	endif;
	
	
	create sa transient;
	self.myCurrentTask.queryMachineCoverage(sa);
	
	create messageLogForm transient;
	messageLogForm.caption:= app.getErrorString(Queryin_task_machine_assignm);  // ### JIRA 35862 09SEP2025 NAVAB1
	sa.copy(messageLogForm.allMessages);
	messageLogForm.show;
	
	
epilog
	
	delete sa;


end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryTaskQueueAssign" id="fb4703f2-c6f9-40bd-b676-955b004db49e">
        <source>doQueryTaskQueueAssign();
/*
Purpose - 	
Who - NAVAB1
Date - 08SEP2025
ADO - JIRA 35862
*/


vars
	arbiter 	: CM_RTQueueArbiter;
	str : String;
	sa : StringArray512;
	messageLogForm :	CMUI_MessageLogForm;
begin
	if self.myCurrentTask = null then
		return;
	endif;
	
	
	create sa transient;
	
	create arbiter transient;
	arbiter.setForQueueAssignmentQuery(self.myCurrentTask.myEntry);
	arbiter.getQueue();
	
	arbiter.captureLoggingText.removeCrLfs();
	arbiter.captureLoggingText.getTokensForDelimiter("@#",sa);
	
	create messageLogForm transient;
	messageLogForm.caption := app.getErrorString(Querying_queue_assignment);  // ### JIRA 35862 09SEP2025 NAVAB1 
	foreach str in sa do
		if str = null then
			continue;
		endif;
		messageLogForm.allMessages.add(str);
	endforeach;

	messageLogForm.show;
	
	
epilog
	
	delete sa;
	delete arbiter;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueueCleanup" id="b40ac597-7d78-4bb4-94e2-aeb7c757ba09">
        <updating/>
        <source>doQueueCleanup(_showMessage : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     12 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numCleaned,
	recurseLevel	: Integer;
	ok		: Boolean;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	app.mousePointer := MousePointer_HourGlass;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateQueueCleanup(self.myMasterQueue, numCleaned, recurseLevel,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.loadQueues(true);
			if _showMessage then
				app.msgBox(app.getErrorString1(QueueCleanupComplete, numCleaned.String), 'Cleanup Jobs', MsgBox_OK_Only + MsgBox_Information_Icon	);
			endif;
			break;
		else
			theResult := app.showErrorWarningDialog('Queue Cleanup', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;	

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_showMessage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueueDelete" id="7adfd8df-ae62-4927-8d1b-c304fce9c7cd">
        <updating/>
        <source>doQueueDelete() updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  The status - either QSTATUS_HELD or QSTATUS_RUNNING
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	currentObj		: CM_Object;
	ok				: Boolean;
	lReturn			: Integer;
	entry			: CM_RTQueueEntry;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin


	app.mousePointer := MousePointer_HourGlass;
	
	currentObj := lstQueues.listObject.CM_Object;
	
	if currentObj = null then
		return;
	endif;
	
	if currentObj.isKindOf(CM_RadioTelemetryQueue) then
		lReturn := app.msgBox('Do you wish to delete this queue?','Delete Queue' ,MsgBox_Yes_No + MsgBox_Question_Mark_Icon	);
		if lReturn = MsgBox_Return_No then
			return;
		endif;
	elseif currentObj.isKindOf(CM_RTQueueEntry) then
		lReturn := app.msgBox('Do you wish to delete this queue entry?','Delete Queue Entry' ,MsgBox_Yes_No + MsgBox_Question_Mark_Icon	);
		if lReturn = MsgBox_Return_No then
			return;
		endif;
		entry := currentObj.CM_RTQueueEntry;
		self.deselectRTQueueEntry( entry );	//17 July 2014	NDL	Par 25646
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if currentObj.isKindOf(CM_RadioTelemetryQueue) then
			app.myTrxDA.trxDeleteQueue(currentObj.CM_RadioTelemetryQueue,app.myPassport);
		elseif currentObj.isKindOf(CM_RTQueueEntry) then
			self.deleteQueueEntry(entry);
		endif;
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Delete Queue/Queue Entry', app.myPassport, ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueueSuspendResume" id="e6049874-7081-4942-94a1-426417bba47b">
        <updating/>
        <source>doQueueSuspendResume() updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  The status - either QSTATUS_HELD or QSTATUS_RUNNING
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	currentObj	: CM_Object;
	ok			: Boolean;
	status		: Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	app.mousePointer := MousePointer_HourGlass;
	
	currentObj := lstQueues.listObject.CM_Object;
	
	if currentObj = null then
		return;
	endif;
	
	if currentObj.isKindOf(CM_RadioTelemetryQueue) then
		status := currentObj.CM_RadioTelemetryQueue.status;
		if status = QSTATUS_HELD then
			status := QSTATUS_RUNNING;
		elseif status =	QSTATUS_RUNNING then
			status := QSTATUS_HELD;
		endif;
		
	elseif currentObj.isKindOf(CM_RTQueueEntry) then
		status := currentObj.CM_RTQueueEntry.status;
		if status = QSTATUS_HELD then
			status := QSTATUS_RUNNING;
		elseif status =	QSTATUS_RUNNING then
			status := QSTATUS_HELD;
		endif;
		
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if currentObj.isKindOf(CM_RadioTelemetryQueue) then
			app.myTrxUA.trxUpdateQueueStatus(currentObj.CM_RadioTelemetryQueue, status,app.myPassport);
		elseif currentObj.isKindOf(CM_RTQueueEntry) then
			app.myTrxUA.trxUpdateQueueEntryStatus(currentObj.CM_RTQueueEntry, status, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.loadQueues(true);
			break;
		else
			theResult := app.showErrorWarningDialog('Override Halt', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueueTblRowColChange" id="051378c2-c023-4066-96e5-7890115de107">
        <updating/>
        <source>doQueueTblRowColChange(table: CM_DataTable input) updating, protected;
// -------------------------------------------
// Created 17 September 2003 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
29 May 2008	cnwkpd1	PAR #16738 - Handle invalid task entries
05 Nov 2009	cnwphb1	PAR 21532 CCMS SFW 1025 - Add "Show in Yard Grid Display" menu-item
08 Mar 2010	cnwer1 PAR 22950 moved enabling task menu code to doShowContextMenu called from tblQEntries contextMenu event
15 Mar 2010 cnwer1 PAR 23089 the setting of the 2 fixed columns is now handled from IF_CM_DataTable methods it now does it on the row select and deselect
*/

vars

	lTask		: Object;
	lEntry		: CM_RTQueueEntry;
	invalidTask,
	invalidEntry : Boolean;

begin

	lTask	:= self.tblQEntries.accessRow(self.tblQEntries.row).itemObject;
	if lTask = null then
		return;
	endif;
	
	//epr par  23089 15/3/10
	
	on Exception do app.handleDeletedObject(exception, lTask, invalidTask);		// PAR #16738
	on Exception do app.handleDeletedObject(exception, self.myCurrentEntry, invalidEntry);
	
	if lTask.isKindOf(CM_RTQueueTask) then
		lEntry := lTask.CM_RTQueueTask.myEntry;
		if invalidTask then
			return;
		endif;
				
		self.myCurrentEntry := lEntry;
		self.myCurrentTask := lTask.CM_RTQueueTask;
		//epr par 8/3/10 22950 now setting task menu visibility on context menu event
	else
		self.myCurrentEntry := null;
		self.myCurrentTask := null;
	endif;


	
epilog
	if invalidTask or invalidEntry then		// PAR #16738
		self.myCurrentEntry := null;
		self.myCurrentTask := null;
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="92cf946d-183e-4068-b7d5-08b87ccd2e8f">
        <updating/>
        <source>doRefresh() updating, protected;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 11 August 2003
//
//-----------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.loadQueues(true);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveMachineFromTask" id="7e633bc6-0e13-4209-a0ef-7c6c8c08339a">
        <updating/>
        <source>doRemoveMachineFromTask() updating;

// cnwdvb1 14 April 2003 
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	loadStateSet			: Boolean;
	lReturn					: Integer;
	lRealTask, lProxyTask	: CM_RTQueueTask;
	lResult					: Boolean;
	lIgnoreWarnings			: Boolean;
	obj 					: Object;
	entry : CM_RTQueueEntry;
	allErrors : CM_ErrorSet;
	error : CM_Error;
	allSelectedEntries : CM_RTQueueEntryArray;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	
	//epr 3/3/2011 could get a 1090 exception
	if not checkCurrentObjects() then
		return;
	endif;
	
	create allSelectedEntries transient;
	foreach obj in self.tblQEntries.allSelectedObjects do
		if obj.isKindOf(CM_RTQueueTask) then
			allSelectedEntries.add(obj.CM_RTQueueTask.myEntry);
		endif;
	endforeach;
	
	create allErrors transient;
	foreach entry in allSelectedEntries   do 
		lRealTask:=entry.getFirstUncompletedTask();	
		if lRealTask = null then
			continue;
		endif;
		delete lProxyTask;
	
		//lRealTask := self.myCurrentTask; // self.tblQEntries.accessRow(self.tblQEntries.row).itemObject.CM_RTQueueTask;
		app.cmsBeginLoad(loadStateSet);
		lProxyTask := lRealTask.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadStateSet);

		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateTaskRemoveMachine(lProxyTask,app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Remove Machine', app.myPassport, ErrWarnMode_Add);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	endforeach;
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	delete lProxyTask;
	delete allErrors;
	delete allSelectedEntries;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveQueuedMachine" id="cd94b2b9-5f14-457e-82e4-a27cd89a92d3">
        <source>doRemoveQueuedMachine();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2009	cnwer1	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	machine,
	proxy : CM_Machine;
begin
	
	self.getCurrentMachine(machine);
	beginLoad;
	proxy:=machine.pxyCreateUpdateProxy;
	endLoad;
	app.myTrxUA.trxUpdateMachineNextQueue(proxy,null,app.myPassport);
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete proxy;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSession" id="44d43714-278c-4fe1-ac38-595d6876aa20">
        <updating/>
        <source>doResetSession() updating;

// cnwdvb1 27 March 2003 

vars

	pxyM, machine : CM_Machine;
	theReturn : Integer;
begin

	self.getCurrentMachine(machine);
	if machine = null then
		app.msgBox('Please select a machine', 'Reset Session', MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	pxyM := app.createUpdateProxy(machine).CM_Machine;
	while true do
		app.myTrxUA.trxUpdateRTResetMediator(pxyM, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog("Reset Mediator", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
epilog
	
	delete pxyM;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="535231ec-32a5-48c7-b93e-46de45f4e998">
