    <JadeMethod name="updateHazardsFromDetailForm" id="cd5c1561-6f63-4ae8-8af7-149e94e2867d">
        <updating/>
        <source>updateHazardsFromDetailForm(_hazDict: CM_HazardByCodeDict): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
// 30/11/2016	cnwdap1		TFS 3058 Correct hazard updating
//
vars
	str : String;

begin	
	if self.myProxyBookingRef &lt;&gt; null then									// TFS 3058
		self.myProxyBookingRef.allTIHazards.clear;							// TFS 3058
		_hazDict.copy(self.myProxyBookingRef.allTIHazards);					// TFS 3058
	endif;																	// TFS 3058
	//self.lstHazards.setSelected(_hazDict);								// TFS 3058
	self.lstHazards.setSelectedFromObject(self.myProxyBookingRef);			// TFS 3058
	str := self.lstHazards.getSelectedString();
	if str.length &gt; 37 then
		self.txtHazards.text := str[1:36] &amp; '...';
	else
		self.txtHazards.text := str;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_hazDict" type="CM_HazardByCodeDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSpecialLift" id="aaf80498-88af-44a8-b7f2-ab7894d0ce1b">
        <source>updateSpecialLift();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2009	cnwml2	Initial creation

*/

vars
	strArray : StringArray;
	spLift : CM_SpecialLift;
	str : String;
	bookItem : CM_BookingRefItem;
begin
	myAssistant.listTableSpecialLift(self.lstSpecialLift);
	create strArray transient;
	//foreach spLift in myProxyBookingRef.allSpecialLifts do
	//	strArray.add(spLift.code);
	//endforeach;
	
	foreach bookItem in myProxyBookingRef.allBookingRefItems do
		foreach spLift in bookItem.allSpecialLifts do
			strArray.add(spLift.code);
		endforeach;
	endforeach;
	
		
	myAssistant.setListTableSpecialLift(self.lstSpecialLift, strArray);
	str := self.lstSpecialLift.getSelectedString('code');
	if str.length &gt; 30 then
		self.txtSpecialLift.text := str[1:29]&amp; '...';
	else
		self.txtSpecialLift.text := str;
	endif;
epilog
	delete strArray;
end;</source>
    </JadeMethod>
