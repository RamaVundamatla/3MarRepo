    <JadeMethod name="cmbOperator_displayEntry" id="b3fbe01f-9de0-4178-8a6f-38c956d3cd8f">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
// ---------------------------------------------------------------------------

vars

begin
	if app.myRoot.getConfig(ComboByNameOperator).Boolean then				// TFS 53362
		return obj.CM_Operator.description &amp; " " &amp; obj.CM_Operator.code;	// TFS 53362
	else																	// TFS 53362
		return obj.CM_Operator.code &amp; " " &amp; obj.CM_Operator.description;
	endif;																	// TFS 53362
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
