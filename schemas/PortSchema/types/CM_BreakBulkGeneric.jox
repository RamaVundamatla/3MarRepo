    <JadeMethod name="getPalletType" id="4d7b094a-17fa-4708-85ab-ddd0d71dea4f">
        <source>getPalletType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	handlingType : CM_HandlingType;
	palletType : CM_PalletType;

begin

	if self.myPalletDetailsTI &lt;&gt; null then
		palletType := self.myPalletDetailsTI.getPalletTypeObj;
	endif;
	
	if palletType = null then
		handlingType := self.getHandlingType();
		if handlingType &lt;&gt; null and handlingType.isPallet then
			palletType := handlingType.getDefaultSubHandlingType.CM_PalletType;
		endif;
	endif;
	
	if palletType &lt;&gt; null then
		return palletType.getHandlingTypeDisplay( false );
	endif;
	
	return inheritMethod();

epilog

end;</source>
