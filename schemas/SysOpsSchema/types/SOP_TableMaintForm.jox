        <source>reeferLablePrinter(_tbl: CM_EntryTable; theRow: Integer; entTableRo, value: String);
//----------------------------------------------------------------
//	Created:	16 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin


epilog
