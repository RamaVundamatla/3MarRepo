/*

Purpose:			


Return Value:		


Date		Who		Reason
20 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.endDT.isValid and self.endDT &lt;&gt; null then
		return self.endDT;
	elseif self.estEndDT.isValid and self.estEndDT &lt;&gt; null then
		return self.estEndDT;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
