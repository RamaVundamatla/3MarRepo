    <JadeMethod name="displayTblSeals" id="1e476a1a-9078-4706-9153-f13d34579114">
        <updating/>
        <source>displayTblSeals() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 May 2014			cnwndl1	Initial creation	Par 34076
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks

*/

vars
	ti : CM_TrackedItem;
	gte : CMGTE_Receival;
	cargoType : CM_CargoType;
	mess : String;
	sealType : CM_SealType;
	allSealTypes : CM_SealTypeSet;
	operator : CM_Operator;
	gate : CM_Gate;
begin

	tblSeals.clear();
	
	ti := self.myTrackedItem;
	gte := self.myGTEReceival;
	
	if ti = null and gte = null then
		mess := app.getErrorString(There_nothi_selec_perfo_seal_c);
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		return;
	endif;
	
	if ti &lt;&gt; null then
		cargoType := ti.myCargoType;
	elseif gte &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[gte.cargoType];
	endif;
	if cargoType = null then
		mess := app.getErrorString(CouldNotFindCargoType);
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		return;
	endif;
	
	create allSealTypes transient;
	if self.myVehicleVisit &lt;&gt; null then
		foreach sealType in app.myRoot.allTruckSealTypes do
			if sealType.notAvailableForEntry then
				continue;
			endif;
			allSealTypes.add(sealType);
		endforeach;
	else
		foreach sealType in cargoType.allSealTypes do
			if sealType.notAvailableForEntry then
				continue;
			endif;
			allSealTypes.add(sealType);
		endforeach;
	endif;
	
	if allSealTypes.isEmpty then
		mess := app.getErrorString(No_Seal_types_for_cargo_type);//"No Seal types declared for cargo type that are available for entry.";
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		return;
	endif;

	if ti &lt;&gt; null then
		self.sealCheckType := ti.getSealCheckTypeForContext( self.myCargoChecks.context );
	elseif gte &lt;&gt; null then
		operator := app.myRoot.allOperators[gte.operatorCode];
		if operator &lt;&gt; null then
			self.sealCheckType := operator.getSealCheckTypeForContext( self.myCargoChecks.context );
		endif;
		if self.sealCheckType = SEAL_CHECK_DEFAULT.Integer then
			if gte.myVehicleVisitRecord &lt;&gt; null then
				gate := gte.myVehicleVisitRecord.myGateIn;
			endif;
			if gate &lt;&gt; null then
				self.sealCheckType := gate.getSealCheckTypeForContext( self.myCargoChecks.context );
			endif;
		endif;
		if self.sealCheckType = SEAL_CHECK_DEFAULT.Integer then
			self.sealCheckType := self.myTerminal.getSealCheckTypeForContext( self.myCargoChecks.context );
		endif;
	endif;
	if self.sealCheckType = SEAL_CHECK_DEFAULT.Integer then
		self.sealCheckType := SEAL_CHECK_NONE;
	endif;
	
	if self.sealCheckType = SEAL_CHECK_NONE  then // 1
		self.setSealsTableForNoneMode();

	elseif self.sealCheckType = SEAL_CHECK_VIEW then	// 2
		self.setSealsTableForViewMode( allSealTypes, ti );	// sealName column and Yes / No  columns only
	
	elseif self.sealCheckType = SEAL_CHECK_FULL then	// 3
		self.setSealsTableForFullMode( allSealTypes, ti );	// type and value columns only
	
	elseif self.sealCheckType = SEAL_CHECK_STRICT then	//4
		self.setSealsTableForStrictMode( allSealTypes, ti );	// type and value columns only
	
	else
		mess := app.getErrorString(Invalid_seal_check_type) &amp; " [" &amp; self.sealCheckType.String &amp; "]" &amp; CrLf &amp; app.getErrorString(Pleas_ensur_that_seals_check_v);
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		
	endif;
	

epilog

	delete allSealTypes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTemperature" id="2a598cbf-2e12-412b-b72d-57dad513ee0a">
        <source>displayTemperature();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars
	tempReading : CM_TempReading;
	temperature : Real;
	operator : CM_Operator;

begin
	temperature := NULL_TEMPERATURE;
	
	if self.myTrackedItem &lt;&gt; null then
		operator := self.myTrackedItem.myOperator;
		tempReading := self.myTrackedItem.getLastTempReading();
		if tempReading &lt;&gt; null then
			temperature := tempReading.getTemperatureValue;
		endif;		
	elseif self.myGTEReceival &lt;&gt; null then
		operator := app.myRoot.allOperators[myGTEReceival.operatorCode];
		temperature := self.myGTEReceival.carriageTempC;
	endif;
	
	if operator.displayTempFahrenheit then
		self.optCelcius.visible := false;
		self.optFahrenheit.enabled := true;
		self.optFahrenheit.value := true;
		self.optFahrenheit.left := self.optCelcius.left;
		if temperature &lt;&gt; NULL_TEMPERATURE then
			self.txtTemperature.text := app.temperatureConversion(true, temperature).String;
		endif;
	else
		if temperature &lt;&gt; NULL_TEMPERATURE then
			self.txtTemperature.text := temperature.roundedTo(1).String;
		endif;
		self.optCelcius.enabled := true;
		self.optCelcius.value := true;
		self.optFahrenheit.visible := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayWeight" id="04c9054a-3d5b-4e76-8635-fbfe6bb3206b">
        <source>displayWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation	Par 33268

*/

vars

