    <JadeMethod name="addToolbarControls" id="3a240ece-0934-4f72-b339-3d04a64c7be7">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnRun, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addFrame(self.frmInspect, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnRun_click" id="d3f729f3-4b2f-4715-adbd-92bcc4d3407f">
