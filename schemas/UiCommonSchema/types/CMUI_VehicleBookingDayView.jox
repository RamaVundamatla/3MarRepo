        <source>doChangeMonth()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation

*/

vars

begin

	if self.month &lt;&gt; self.mthPicker.getMonth then
		self.month := self.mthPicker.getMonth;
		self.doRefreshBookings();
	endif;

epilog

end;</source>
