    <JadeMethod name="getWPOpHrsGrossMins" id="5188e6d7-107e-462c-8d77-6f334ff4a492">
        <source>getWPOpHrsGrossMins():Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	iter : Iterator;
	opHr : CM_WorkPointOperatingHours;
	earliestExchangeStart : TimeStamp;
	latestExchangeEnd : TimeStamp;
	timeStampInt : TimeStampInterval;
	localExchangeEnd : TimeStamp;
	
begin

	iter := self.myVoyage.allWorkPointOperatingHours.createIterator;
	earliestExchangeStart := null;
	latestExchangeEnd := null;
	while iter.next( opHr ) do
		if opHr.craneWorkPointId &lt;&gt; crane then
			continue;
		endif;
		if opHr.exchangeStart.Date.isValid then
			if earliestExchangeStart = null or opHr.exchangeStart &lt; earliestExchangeStart then
				earliestExchangeStart := opHr.exchangeStart;
			endif;
		endif;
		localExchangeEnd := opHr.getExchangeEnd;
		if latestExchangeEnd = null or localExchangeEnd &gt; latestExchangeEnd then
			latestExchangeEnd := localExchangeEnd;
		endif;
	endwhile;
	
	if earliestExchangeStart.Date.isValid and latestExchangeEnd.Date.isValid then
		timeStampInt := latestExchangeEnd - earliestExchangeStart;
		return timeStampInt.asMinutes;
	else
		return 0;
	endif;

epilog

	delete iter;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
