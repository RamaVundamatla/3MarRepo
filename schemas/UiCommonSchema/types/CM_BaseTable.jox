		tmpControl.JadeEditMask.insertMode := false;
	endif;

/*
	tmpControl := _cell.cellControl;
	if JadeEditMask.hasInstance(tmpControl) then
write class.name &amp; '::' &amp; method.name;
		//tmpControl.JadeEditMask.text := null; //rs aug 2005 to try and stop crashes
		tmpControl.JadeEditMask.mask := EditMask_Date;	// the default
		tmpControl.JadeEditMask.selectionStyle := JadeEditMask.SelectionStyle_Select;	
	
		// set mode to overwrite
		tmpControl.JadeEditMask.insertMode := false;
	endif;
*/
end;</source>
