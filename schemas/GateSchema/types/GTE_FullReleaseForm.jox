    </JadeMethod>
    <JadeMethod name="tblCustEntry_lostFocus" id="fc3a5d2b-b577-4c6c-a2c8-ffd212ae6fff">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCustEntry_lostFocus(table: Table input) updating;

/*

Date		Who		Reason
26 Jun 2008	cnwkpd1	PAR #17183 - rework again to better handle lostFocus in all situations

*/

vars
	parentTable		: CM_EntryTable;
	rowHeight 		: Real; 

begin
	if table.parent &lt;&gt; null and table.parent.isKindOf(CM_EntryTable) then
		parentTable := table.parent.CM_EntryTable;
		rowHeight := self.saveRowHeight;
		self.myAssistant.stringsTableLostFocus(parentTable, rowHeight, table.CM_Table);
		self.saveRowHeight := rowHeight.Integer;
		
		// For bulk edit need to fire this for row changed
		parentTable.doChangedComparismForControl(table.name);
	endif;

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="081c33a9-d631-42d1-aaff-b947cace56aa">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
// ---------------------------------------------------------------------------
// Created:     26 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_idxRow, _obj);

	if _obj.CM_TrackedItem.isHazardous then
		self.tblData.accessRow(_idxRow).foreColor := Red; // AKB2004NOV
	endif;

	if self.userPermissionMode = PmGteFullReleaseCarrierMaint 
	or self.userPermissionMode = PmGteFullReleaseForward
	or self.userPermissionMode = PmGteFullReleaseMaint then
		//Show the pin number - carry on.
	else
		//Hide the pin number
		if self.columnPinNo &lt;&gt; null then
			self.tblData.accessCell(_idxRow, self.columnPinNo).text := '****';		
		endif;
	endif;
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblExtra_cellInputReady" id="268b09c9-2fb2-4165-8854-68e783eab407">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtra_cellInputReady(table: Table; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTable	: Table;
	tmpOperator	: CM_Operator;
	tmpVoyage	: CM_Voyage;
	tmpPort		: CM_Port;
	
begin

	tmpTable := table;
	
	if inputControl.name = 'cmbISOType' then
		if table.text &lt;&gt; null then
			cmbISOType.text := table.text;
		endif;

	else
		
	endif;

end;</source>
        <Parameter name="table" type="Table"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
