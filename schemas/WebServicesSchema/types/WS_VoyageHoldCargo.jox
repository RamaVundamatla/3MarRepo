    <JadeMethod name="getProduct" id="ed2b2fb9-457d-4153-9bc3-28230189e6d5">
        <source>getProduct() : CM_Product;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation

*/

vars
	cargoTypeObj : CM_CargoType;
	product : CM_Product;
begin
	cargoTypeObj :=self.getCargoType();
	
	if cargoTypeObj &lt;&gt; null and cargoTypeObj.isSubCargoTypeRequired and self.cargoSubType &lt;&gt; null then
		product:=cargoTypeObj.getProductFromCode(self.cargoSubType); 	//18/03/2010 cnwdz2 23232
		if product = null then
			product:=app.myPassport.getObjectOfTypeFromOid(self.cargoSubType,CM_Product).CM_Product;
		endif;
	endif;
	return product;
epilog

end;</source>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
