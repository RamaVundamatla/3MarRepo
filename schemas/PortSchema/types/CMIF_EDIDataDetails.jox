    <JadeMethod name="setOperator" id="9ec7f82d-ac56-4c8e-ae50-2696cc8a97ee">
        <updating/>
        <source>setOperator(_opCode: String) updating;
//----------------------------------------------------------------
//	Created:	25 November 2003	by Jason Chapman  (cnwjc2)
//  17 Apr 2023	navmp20		Bug 56230: MTN - String Too Long Error When Verifying Load/Discharge List EDI
//	24 Apr 2023	navdap1		TFS 57702 1090 error processing EDI file when "Display Operator Combo By Name" Ticked
//----------------------------------------------------------------
vars
	op : CM_Operator;

begin
	//self.operatorCode := _opCode.trimBlanks;
	//Start 17.04.2023 navmp20 TFS 56230
	if app.myRoot.getConfig(ComboByNameOperator).Boolean then
		op := app.myRoot.getOperatorByDesc(_opCode);
		// TFS 57702 start
		if op = null then
			op := app.myRoot.allOperators[_opCode];
		endif;
		if op &lt;&gt; null then
			self.operatorCode := op.code;
		else
			self.operatorCode := _opCode.trimBlanks;
		endif;
		// TFS 57702 end
	else
		self.operatorCode := _opCode.trimBlanks;
	endif;
	//End 17.04.2023 navmp20 TFS 56230
	self.operator := app.myRoot.allOperators[self.operatorCode];

end;</source>
        <Parameter name="_opCode" type="String"/>
    </JadeMethod>
</Class>
