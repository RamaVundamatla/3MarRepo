<Class name="CM_SnapshotField_CountAbstract" id="d00b248f-54d9-4d51-bff1-e9839557c476">
    <superclass name="CM_SnapshotField"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="snapshots"/>
    <PrimAttribute name="count" id="7ed155c4-8400-4fb9-a6b8-dce1b139618a">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="d0e329f5-5ba6-473b-92d3-8db7c2fd66b4">
        <source>getValue(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation

*/

vars
	value	:Integer;
begin
	value := self.count;	
	
	if value = 0 then		
		return null;		
	endif;					
	
	return value.asStringJMTWithOptionalCommas( self.useSeperator, false );	// cnwcs5 07/12/2009
	
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCmifAndXtabFields" id="a3de4ac0-1ff0-418a-ae99-657912070733">
        <updating/>
        <source>setFromCmifAndXtabFields(_cmifField: CMIF_OutputField; _xtabField: CM_XTABField) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	inheritMethod(_cmifField, _xtabField);
	
	self.count := _cmifField.CMIF_OutputField_CountAbstract.count;

epilog

end;</source>
        <Parameter name="_cmifField" type="CMIF_OutputField"/>
        <Parameter name="_xtabField" type="CM_XTABField"/>
    </JadeMethod>
</Class>
