<Class name="CMQF_WarehouseInwards" id="8ed7de28-8fb1-4636-be43-7a8248ae464b">
    <superclass name="CMQF_BreakBulk"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Gets breakbulks with recieval date within the self.start/endDate for operator
For the purpose of an inwards goods charges report</text>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="549f73cd-e875-41b0-8bab-367c78d02f4f">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwth2
//
// Purpose:     
// 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
// ----------   ----------  --------------------------------------------------
vars
	bolIter				: Iterator;
	bolDict				: CM_BOLByTypeDateTimeDict;
	bol					: CM_BOLIn;
	ti					: CM_TrackedItem;
	terminal			: CM_Terminal;
	breakOut			: Boolean;
	typeKey				: Integer;
	tsKey,
	startTS				: TimeStamp;
begin
	if self.startDate.isValid() then
		startTS.setDate(self.startDate);
	endif;

	foreach terminal in self.allTerminals do : terminalLoop
		bolDict := terminal.allBOLsReceivedByDTType;
		
		delete bolIter;
		bolIter := bolDict.createIterator;
		bolDict.startKeyGeq(BOLType_GeneralDocket, startTS, bolIter);
		
		while bolIter.next(bol) do
			bolIter.getCurrentKeys(typeKey, tsKey); //MTN-35226
			
			if tsKey.date &gt; self.endDate then
				break;
			endif;
			
			// Par 9465 Use bol operator rather that ti operator.
			if self.myOperator &lt;&gt; null and self.myOperator &lt;&gt; bol.myOperator then
				continue;
			endif;
			
			foreach ti in bol.allTrackedItems discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					_collection.add(ti);
				endif;
//				if breakOut then
//					return;
//				endif;
			endforeach;
		endwhile;
	endforeach;
		
epilog
	delete bolIter;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="b1a202cc-1466-4686-aad5-cfce611183af">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	receiveDate			: Date;
	querySelf			: CMQF_WarehouseInwards;
	failedDAC  :CM_DataAccessController;
	
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
//	receiveDate := _ti.receivedDT.Date;
	
	// Par 9465 Use bol operator rather that ti operator.
//	if (self.myOperator = null or self.myOperator = _ti.myOperator) and
		
//	 if   (receiveDate &gt;= querySelf.startDate) and
//	   (receiveDate &lt;= querySelf.endDate) then
		
		if _ti.canUserAccessSelf(null, failedDAC, _passport)
		   and _ti.state &lt;&gt; TI_STATE_DELETED then
			querySelf.numFound := querySelf.numFound +1;
			return true;
		endif;
//	endif;


	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
