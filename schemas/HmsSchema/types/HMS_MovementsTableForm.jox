    <JadeMethod name="setSelectedMovement" id="77404836-498c-4dc3-b6ca-6904bc5a8f62">
        <updating/>
        <source>setSelectedMovement(movement : CMIF_HMS_WorkingMovement) updating;

vars

begin
	// clear all current selections
	
	self.tblMovements.setSelectedMovement(movement);
	if movement &lt;&gt; null then
		self.setCurrentVoyage(movement.myWorkingVoyage);
	else		
		self.setCurrentVoyage(null);				
	endif;
	// Set new selected movement on controller
	if self.myViewController &lt;&gt; null 
	and movement &lt;&gt; null then
		if movement &lt;&gt; self.myViewController.myCurrentWorkingMovement then
    		self.myViewController.view_NewSelectedMovement(movement, false);
   		endif;
   	endif;

end;</source>
        <Parameter name="movement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
