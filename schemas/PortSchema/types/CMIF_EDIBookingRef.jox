<Class name="CMIF_EDIBookingRef" id="9a313fc4-ac1f-4c0b-a349-b56ca045f0e9">
    <superclass name="CMIF_EDI"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <ImplicitInverseRef name="allCMIFBookingRefs" id="d244cdd7-ad02-49f8-a35d-891b22539b4e">
        <memberTypeInverse/>
        <type name="CMIF_BookingRefSet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="d2a2f018-396d-47f7-82f1-ff736b51f6f8">
        <updating/>
        <source>delete() updating;
/*
	Created on 04 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmifBR : CMIF_BookingRef;
	cmifObject : CMIF_Object;
	
begin
	foreach cmifObject in self.allCMIFBookingRefs do
		cmifBR := cmifObject.CMIF_BookingRef;
		delete cmifBR.myProxyBookingRef;
	endforeach;
	
	self.allCMIFBookingRefs.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="findAndLoadCMIFBookingRef" id="1e073310-a215-4ce2-9f2b-69c2f116da4d">
        <source>findAndLoadCMIFBookingRef(	_ediBR : CM_EDIBookingRefTI;
							_realBookingRef : CM_BookingRef;
							_terminal : CM_Terminal):CMIF_BookingRef;
/*
	Created on 04 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	cmifObject 				: CMIF_Object;
	cmifBookingRef			: CMIF_BookingRef;
	foundCmifBookingRef		: CMIF_BookingRef;
	pxyBookingRef 			: CM_BookingRef;
	ediVoyageCode			: String;
	ediOperatorCode			: String;
	misVersionBookingRef : Boolean; //ccms 1855 cnwrs1 sept 2009
begin
	misVersionBookingRef := _terminal.getConfig(ProcessMISVersionBkRef).Boolean; //cnwrs1 ccms 1855 Sept 2009
	if _realBookingRef &lt;&gt; null then
	
		foreach cmifObject in self.allCMIFBookingRefs do
		
			cmifBookingRef := cmifObject.CMIF_BookingRef;
			
			if cmifBookingRef.myRealBookingRef = _realBookingRef then
			
				if _ediBR.messageMode = null then	// behaviour as previous, no EDI action mode
					foundCmifBookingRef := cmifBookingRef;
					
				else	//EDI action mode (ADD, UPDATE, DELETE). Par 18495, Jan 2009
					// for each _ediBR we create separate CMIF_BookingRef, because sequence of EDI actions is important 
					// (DELETE, ADD, later can be UPDATE etc.)
					// Note. For multi booking ref, we have CMIF_BookingRef for whole group (but for each EDI action - it's corresponding CMIF_BookingRef)
					if _ediBR.groupCodeForEDIMultiItem = cmifBookingRef.myProxyBookingRef.myEDIBookingRefTI.groupCodeForEDIMultiItem and //cmifBookingRef.groupCodeForEDIMultiItem 
					   _ediBR.messageMode = cmifBookingRef.myProxyBookingRef.myEDIBookingRefTI.messageMode then //cmifBookingRef.messageMode
						if _ediBR.groupCodeForEDIMultiItem &lt;&gt; null then	//When EDI action, grouping in CMIF_BookingRef only for multi booking ref items
							foundCmifBookingRef := cmifBookingRef;
						endif;
					endif;
					
				endif;
			endif;
			
		endforeach;
	else
//		ediVoyageCode	:=	_ediBR.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
		ediVoyageCode	:=	_ediBR.getVoyageCode();
		ediOperatorCode	:=	_ediBR.operatorCode;
		
		if ediVoyageCode &lt;&gt; null and
		   _terminal.lookupVoyage(ediVoyageCode.String, null, false) = null then
			ediVoyageCode	:=	null;
		endif;
		
		if ediOperatorCode &lt;&gt; null and
		   app.myRoot.allOperators[ediOperatorCode] = null then
			ediOperatorCode	:=	null;
		endif;
		
		foreach cmifObject in self.allCMIFBookingRefs do
			cmifBookingRef	:=	cmifObject.CMIF_BookingRef;
			
			if cmifBookingRef.myRealBookingRef = null and
			   cmifBookingRef.myProxyBookingRef.bookingReference = _ediBR.getId(misVersionBookingRef) and //ccms 1855 Sept 2009 cnwrs1
			   cmifBookingRef.myProxyBookingRef.voyageCode = ediVoyageCode and
			   cmifBookingRef.myProxyBookingRef.operatorCode = ediOperatorCode then
				if _ediBR.messageMode = null then // behaviour as previous - no EDI action mode
					foundCmifBookingRef	:=	cmifBookingRef;
					
				else	//EDI action mode (ADD, UPDATE, DELETE). Par 18495, Jan 2009
						// for each _ediBR we create separate CMIF_BookingRef, because sequence of EDI actions is important 
						// (DELETE, ADD, later can be UPDATE etc.). Each CMIF_BookingRef will be proceeded by separate trx method later.
						// Note. For multi booking ref, we have CMIF_BookingRef for whole group (but for each EDI action - corresponding CMIF_BookingRef)
					if _ediBR.groupCodeForEDIMultiItem = cmifBookingRef.myProxyBookingRef.myEDIBookingRefTI.groupCodeForEDIMultiItem //cmifBookingRef.groupCodeForEDIMultiItem
					and _ediBR.messageMode = cmifBookingRef.myProxyBookingRef.myEDIBookingRefTI.messageMode	//cmifBookingRef.messageMode
					then
						if _ediBR.groupCodeForEDIMultiItem &lt;&gt; null then	//grouping in CMIF_BookingRef only for multi booking ref items
							foundCmifBookingRef	:=	cmifBookingRef;
						endif;
					endif;
					
				endif;
				
			endif;
		endforeach;
	endif;

	if foundCmifBookingRef = null then
		create foundCmifBookingRef transient;
		
		if _realBookingRef = null then
			// the booking ref doesn't exist in the database
			create pxyBookingRef transient;
		else
			pxyBookingRef := _realBookingRef.pxyCreateUpdateProxy();
		endif;
		
		foundCmifBookingRef.setMyProxyBookingRef(pxyBookingRef);
		foundCmifBookingRef.setMyRealBookingRef(_realBookingRef);
		self.allCMIFBookingRefs.add(foundCmifBookingRef);
	endif;
	
	// now load or update it to the latest line in the bookingref
	foundCmifBookingRef.setProxyFromEDI(_ediBR, _terminal); 
	foundCmifBookingRef.allEDIBookingRefTIs.add(_ediBR);
	
	return foundCmifBookingRef;
end;</source>
        <Parameter name="_ediBR" type="CM_EDIBookingRefTI"/>
        <Parameter name="_realBookingRef" type="CM_BookingRef"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="findAndLoadCMIFBookingRefEDI" id="a6936caa-46e0-4e97-a128-20c1365e64f4">
        <source>findAndLoadCMIFBookingRefEDI(_ediBookingHeader : CM_EDIBookingHeaderTI; _realBookingRef : CM_BookingRef; _terminal : CM_Terminal) : CMIF_BookingRef;
//
// par21718 cnwrs1 Dec 2009
//
vars
	cmifObject 				: CMIF_Object;
	cmifBookingRef			: CMIF_BookingRef;
	foundCmifBookingRef		: CMIF_BookingRef;
	pxyBookingRef 			: CM_BookingRef;
	ediVoyageCode			: String;
	ediOperatorCode			: String;
	misVersionBookingRef : Boolean; //ccms 1855 cnwrs1 sept 2009
//	ediBookingItemTI : CM_EDIBookingItemTI;
begin
	misVersionBookingRef := _terminal.getConfig(ProcessMISVersionBkRef).Boolean; //cnwrs1 ccms 1855 Sept 2009
	if _realBookingRef &lt;&gt; null then
	
		foreach cmifObject in self.allCMIFBookingRefs do
		
			cmifBookingRef := cmifObject.CMIF_BookingRef;
			
			if cmifBookingRef.myRealBookingRef = _realBookingRef then
			
				if _ediBookingHeader.messageMode = null then	// behaviour as previous, no EDI action mode
					foundCmifBookingRef := cmifBookingRef;
					
				else	//EDI action mode (ADD, UPDATE, DELETE). Par 18495, Jan 2009
					// for each _ediBR we create separate CMIF_BookingRef, because sequence of EDI actions is important 
					// (DELETE, ADD, later can be UPDATE etc.)
					// Note. For multi booking ref, we have CMIF_BookingRef for whole group (but for each EDI action - it's corresponding CMIF_BookingRef)
//					if _ediBookingHeader.groupCodeForEDIMultiItem = cmifBookingRef.myProxyBookingRef.myEDIBookingRefTI.groupCodeForEDIMultiItem and //cmifBookingRef.groupCodeForEDIMultiItem 
//					if _ediBookingHeader.messageMode = cmifBookingRef.myProxyBookingRef.myEDIBookingRefTI.messageMode then //cmifBookingRef.messageMode
//						if _ediBookingHeader.groupCodeForEDIMultiItem &lt;&gt; null then	//When EDI action, grouping in CMIF_BookingRef only for multi booking ref items
							foundCmifBookingRef := cmifBookingRef;
//						endif;
//					endif;
				endif;
			endif;
		endforeach;
	else
//		ediVoyageCode	:=	_ediBookingHeader.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
		ediVoyageCode	:=	_ediBookingHeader.getVoyageCode();
		ediOperatorCode	:=	_ediBookingHeader.operatorCode;
		
		if ediVoyageCode &lt;&gt; null
		and _terminal.lookupVoyage(ediVoyageCode.String, null, false) = null
		then
			ediVoyageCode	:=	null;
		endif;
		
		if ediOperatorCode &lt;&gt; null
		and app.myRoot.allOperators[ediOperatorCode] = null
		then
			ediOperatorCode	:=	null;
		endif;
		
		foreach cmifObject in self.allCMIFBookingRefs do
			cmifBookingRef	:=	cmifObject.CMIF_BookingRef;
			
			if cmifBookingRef.myRealBookingRef = null and
			   cmifBookingRef.myProxyBookingRef.bookingReference = _ediBookingHeader.getId(misVersionBookingRef) and //ccms 1855 Sept 2009 cnwrs1
			   cmifBookingRef.myProxyBookingRef.voyageCode = ediVoyageCode and
			   cmifBookingRef.myProxyBookingRef.operatorCode = ediOperatorCode then
				if _ediBookingHeader.messageMode = null then // behaviour as previous - no EDI action mode
					foundCmifBookingRef	:=	cmifBookingRef;
				else	//EDI action mode (ADD, UPDATE, DELETE). Par 18495, Jan 2009
						// for each _ediBR we create separate CMIF_BookingRef, because sequence of EDI actions is important 
						// (DELETE, ADD, later can be UPDATE etc.). Each CMIF_BookingRef will be proceeded by separate trx method later.
						// Note. For multi booking ref, we have CMIF_BookingRef for whole group (but for each EDI action - corresponding CMIF_BookingRef)
//					if _ediBookingHeader.groupCodeForEDIMultiItem = cmifBookingRef.myProxyBookingRef.myEDIBookingRefTI.groupCodeForEDIMultiItem and //cmifBookingRef.groupCodeForEDIMultiItem
//					if _ediBookingHeader.messageMode = cmifBookingRef.myProxyBookingRef.myEDIBookingRefTI.messageMode	then //cmifBookingRef.messageMode
//						if _ediBookingHeader.groupCodeForEDIMultiItem &lt;&gt; null then	//grouping in CMIF_BookingRef only for multi booking ref items
							foundCmifBookingRef	:=	cmifBookingRef;
//						endif;
//					endif;
					
				endif;
				
			endif;
		endforeach;
	endif;

	if foundCmifBookingRef = null then
		create foundCmifBookingRef transient;
		
		if _realBookingRef = null then
			// the booking ref doesn't exist in the database
			create pxyBookingRef transient;
		else
			pxyBookingRef := _realBookingRef.pxyCreateUpdateProxy();
		endif;
		
		foundCmifBookingRef.setMyProxyBookingRef(pxyBookingRef);
		foundCmifBookingRef.setMyRealBookingRef(_realBookingRef);
		self.allCMIFBookingRefs.add(foundCmifBookingRef);
	endif;
	
	// now load or update it to the latest line in the bookingref
	foundCmifBookingRef.setProxyFromEDIBooking(_ediBookingHeader, _terminal); 
	foundCmifBookingRef.allEDIBookingRefTIs.add(_ediBookingHeader);	//par 26044 cnwrs1 19 oct 2010

	return foundCmifBookingRef;
end;</source>
        <Parameter name="_ediBookingHeader" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_realBookingRef" type="CM_BookingRef"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CMIF_BookingRef"/>
    </JadeMethod>
</Class>
