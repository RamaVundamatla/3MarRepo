    <JadeMethod name="exportObjects" id="0f758aa7-3f8e-4797-bec3-0a9804cba5f1">
        <source>exportObjects(_class : Class; _dirName : String;
			_exportReferences, _exportCollections : Boolean; _maxNumber : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     18 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	obj: Object;
	passInArray: ObjectArray;
	file: File;
	cnt, numberToProcess: Integer;
	fileName: String;
begin
	
	if _class = null or _dirName = null then
		return;
	endif;
	numberToProcess := _class.instances.size;
	if numberToProcess = 0 then 
		return;
	endif;
	fileName := _dirName &amp; _class.name &amp; '.xml';
	create file transient;
	file.openOutput(fileName);
	
	create passInArray transient;
	app.writeLog('Started outputing instances of ' &amp; _class.name &amp; ' at ' &amp; app.actualTimeServer.String, LogINFO);
	cnt := 0;	
	foreach obj in _class.instances do
		obj.CM_Object.exportMeXML(file, passInArray, _exportReferences, _exportCollections);
		cnt := cnt + 1;
		if _maxNumber &gt; 0 then
			if cnt &gt; _maxNumber then
				break;
				app.writeLog('Processed ' &amp; cnt.String &amp; ' instances of ' &amp; _class.name &amp; ' at ' &amp; app.actualTimeServer.String, LogINFO);
			endif;
		endif;
	endforeach;
	file.close;
	
	app.writeLog('Finished outputing instances of ' &amp; _class.name &amp; ' at ' &amp; app.actualTimeServer.String, LogINFO);
	app.writeLog('Total instances of class ' &amp; _class.name &amp; ' ouput to file : ' &amp; numberToProcess.String, LogINFO);
	app.writeLog('Total objects output to file : ' &amp; cnt.String, LogINFO);
	
epilog
	delete file;
	delete passInArray;

end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_dirName" type="String"/>
        <Parameter name="_exportReferences" type="Boolean"/>
        <Parameter name="_exportCollections" type="Boolean"/>
        <Parameter name="_maxNumber" type="Integer"/>
    </JadeMethod>
