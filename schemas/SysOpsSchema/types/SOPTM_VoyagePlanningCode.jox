    <JadeMethod name="isObjectRelevant" id="8d0b0ecb-4c87-4ccf-89db-87796ce5db8c">
        <source>isObjectRelevant(_obj: Object): Boolean;
//-----------------------------------------------------------------------
//	Created:	30 March 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
vars

begin

	if inheritMethod(_obj) then
		if _obj.CM_VoyagePlanningCode.myTerminal = self.myForm.myTerminal then
			return true;
		endif;	
	endif;

	return false;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
