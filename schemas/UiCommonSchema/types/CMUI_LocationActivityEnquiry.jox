    <JadeMethod name="mnuInvoiceLineShow_click" id="412527de-7694-485e-ab2c-88e6a188c205">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInvoiceLineShow_click(menuItem: MenuItem input) updating;
/*
Purpose:			

Date		Who		Reason
28MAY2021	NAVAB1	TFS 51219
*/

vars
	table : Table;
	anObject : Object;
	invoice	: CM_Invoice;
	event : CMEVT_LocationActivity;
	lines : CM_InvoiceLineBySeqNumDict;
begin

	table := self.tblLocActivity;
	if table.row &gt; table.fixedRows then
		anObject := table.accessRow(table.row).itemObject;
		if anObject.isKindOf(CMEVT_LocationActivity) then
			event := anObject.CMEVT_LocationActivity;
			
			if event.allInvoiceLines.isEmpty() then
				return;
			endif;
			
			create lines transient;
			event.allInvoiceLines.copy(lines);
			self.myAssistant.showInvoiceLineCollection(lines, self.myTerminal, self.myMasterMenuAction);
		endif;
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
