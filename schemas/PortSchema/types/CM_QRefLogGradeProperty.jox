<Class name="CM_QRefLogGradeProperty" id="c3e4f469-8042-4c94-8769-13da6ef3c647">
    <superclass name="CM_QReferenceLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="b2485e98-025e-4f0d-ab77-1765d01715f3">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 16 September 2004 by cnwdvb1
// -------------------------------------------
vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getSpeciesList" id="b49208ff-e530-48bc-a059-d123945006fd">
        <source>getSpeciesList(_crit : CM_SelectorCriteriaLine) : CM_CodeSet;
/*

Purpose:			TFS 7821

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2017	jlgab1	Initial creation

*/

vars
	opset : CM_CodeSet;
	ls : CM_LogSpecies;
	anything : Any;
	array : ObjectSet;
	type : CM_CodeGroupType;
	group : CM_CodeGroup;
	codels : CM_Code;
begin
	create array transient;
	create opset transient;
	
	anything := _crit.myQueryOperator.getSearchValue();
	if anything &lt;&gt; null then
		if anything.isKindOf(ObjectSet) then
			anything.ObjectSet.copy(array);		
		elseif anything.isKindOf(Object) then
			array.add(anything.Object);
		
		endif;
	endif;
	
	type := app.myRoot.allCodeGroupTypes[CodeGroup_LogSpecs];
	
	foreach group in type.allCodeGroups do
		foreach codels in group.allCodes do
			ls := codels.CM_LogSpecies;
			
			if array.includes(ls) then
				opset.addNoDuplicates(ls, false);
			endif;
		endforeach;
	
	endforeach;
	
	
	return opset;
epilog

end;</source>
        <Parameter name="_crit" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="CM_CodeSet"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="e86a3ebd-202f-4162-9749-c4ea026d1c68">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	crit				: CM_SelectorCriteriaLine;
	gradeCode, lsCode			: CM_Code;
	ls : CM_CodeSet;
begin

	_combo.clear;
	
	if _params = null then
		return;
	endif;

	crit := _params.allCriteriaByPropertyName['myLogSpecies', CM_BOL.name/*CM_Log.name*/];	// Par16731. cnwvu1 15 May 2008
	if crit = null then		
		crit := _params.allCriteriaByPropertyName['myLogSpecies', CM_Log.name];	// Par16731. cnwvu1 15 May 2008
		if crit = null then		
			_combo.addItem('Must select an appropriate Log Species');// TFS 7821
			return;
		endif;
	endif;

	ls := self.getSpeciesList(crit); // TFS 7821
	
	foreach lsCode in ls do // TFS 7821
		foreach gradeCode in lsCode.CM_LogSpecies.allLogGrades do // TFS 7821
			_combo.itemObject[_combo.addItem(gradeCode.code &amp; '   ' &amp; gradeCode.description)] := gradeCode;
		endforeach;
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		gradeCode := _queryOperator.CM_QReferenceLookup.mySelectionValue.CM_LogGrade;
		if gradeCode &lt;&gt; null  then
			if _combo.findObject(gradeCode) &gt; 0 then // TFS 7821
				_combo.listObject := gradeCode;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="a616eaed-df6e-4ac8-97d9-a7ec2179cb17">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QReferenceIsOneOf; _passport : CM_Passport);
/*
Purpose:		TFS 7821	
Date				Who			Reason
NOVEMBER 2017		CNWAB1		Initial creation
*/

vars
	crit				: CM_SelectorCriteriaLine;
	gradeCode, lsCode			: CM_Code;
	selectionValue, idx		: Integer;
	nameDict		: CM_ObjectByStringDict;
	ls : CM_CodeSet;
begin
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2;
	
	if _params = null then
		return;
	endif;

	crit := _params.allCriteriaByPropertyName['myLogSpecies', CM_BOL.name/*CM_Log.name*/];	// Par16731. cnwvu1 15 May 2008
	if crit = null then		
		crit := _params.allCriteriaByPropertyName['myLogSpecies', CM_Log.name];	// Par16731. cnwvu1 15 May 2008
		if crit = null then		
			_tbl.addItem('Must select an appropriate Log Species');// TFS 7821
			return;
		endif;
	endif;

	ls := self.getSpeciesList(crit); // TFS 7821
	
	foreach lsCode in ls do
		foreach gradeCode in lsCode.CM_LogSpecies.allLogGrades do // TFS 7821
			selectionValue := 0;
			if _operator &lt;&gt; null and _operator.allSelectionValues.includes(gradeCode) then
				selectionValue := 1;
			endif;
			idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; gradeCode.code &amp; '   ' &amp; gradeCode.description);
			_tbl.accessRow(idx).itemObject := gradeCode;
			_tbl.row := idx;
			_tbl.change(_tbl);
		endforeach;
	endforeach;


epilog
	delete nameDict;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="b8565f2b-a082-4962-b20f-5b9fb5fed8a1">
        <source>translateStringToSearchValue( _value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 13 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	gradeCode	: CM_Code;
	speciesCode	: CM_LogSpecies;
	critHolder	: CM_QueryCriteriaLineHolder;
	critLine	: CM_SelectorCriteriaLine;
	dict		: CM_CodesByCodeDict;
	tmpValue	: String;
	
begin

	if _value.isKindOf( CM_Code ) then
		return _value;
	endif;

	tmpValue := _value.String.toUpper();
	
	critHolder	:= _criteriaLine.myCriteriaLineHolder;
	critLine	:= critHolder.allCriteriaByPropertyName['myLogSpecies', CM_BOL.name];

	speciesCode := critLine.myQueryOperator.getSearchValue().CM_LogSpecies;
	dict		:= speciesCode.allLogGrades;
	
	foreach gradeCode in dict discreteLock do
		if gradeCode.code.toUpper() = tmpValue then
			return gradeCode;
		endif;
	endforeach;

		// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="f842087c-a408-4bdf-bd9b-8f80e61448e5">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - Handle null objects in selector queries

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_LogGrade.code;
	endif;
	
	return null;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="d1dd6b9a-b609-4301-8b56-8f07ab09e3f0">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	returnVal		: CM_LogGrade;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;
		
		if _value.isKindOf(CM_LogGrade) then
			returnVal := _value.CM_LogGrade;
		endif;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
