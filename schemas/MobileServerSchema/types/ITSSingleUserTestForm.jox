    <JadeMethod name="sysNotify" id="871230ec-a88c-4893-93d8-443a6f07ed6b">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
15 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	if CM_ITSInterfaceResponseIdDict.hasInstance(theObject) then
		self.tblMachines.refreshEntries(null);
	endif;
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblMachines_dblClick" id="2074720d-e6c7-4fb9-b17c-cc77182542e3">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMachines_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
08 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	if self.tblMachines.row &gt; self.tblMachines.fixedRows then
		self.tblMachines.accessRow(self.tblMachines.row).itemObject.inspect();
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMachines_displayRow" id="d17993f3-270b-4498-a6bb-44444b7997d4">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMachines_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	activeResponse	: CM_ITSInterfaceResponse;
	col				: Integer;
	currentQEId		: String;
	currentTask		: CM_RTQueueTask;
	machine			: CM_Machine;
	str				: String;
	
begin
	machine := obj.CM_Machine;
		
	currentTask := machine.currentQueueTask;
	if currentTask &lt;&gt; null then
		currentQEId := "  (" &amp; self.getInstanceIdForObject(currentTask.myEntry).Integer.String &amp; " - " &amp; currentTask.taskTypeId &amp; ")";
	endif;

	str		:= machine.id &amp; currentQEId;
	col		:= 1;
	
	foreach activeResponse in machine.allITSInterfaceResponsesActive do
		col := col + 1;
		str := str &amp; Tab &amp; activeResponse.queueEntryID.String;
		if activeResponse.despatchNow then
			str := str &amp; "  Now";
		endif;
	endforeach;

	while col &lt; table.columns do
		col := col + 1;
		str := str &amp; Tab &amp; " ";
	endwhile;
	
	if table.columns &lt; col then
		table.columns := col;
	endif;
	
	return str;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblMessages_dblClick" id="618283ed-0c75-4efb-b28d-c9152f38e14c">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
