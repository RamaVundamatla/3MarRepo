<Class name="AtcgCellMate" id="9cc7f98e-1639-4928-88a1-81f319d4248b">
    <superclass name="AtcgCommonEntity"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="JtdCommon"/>
    <PrimAttribute name="column" id="d3121b14-36a3-4395-88da-c32f6d49e887">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="control" id="febe5a47-d99a-4c6c-94e3-41a5ab6ed50d">
        <embedded/>
        <type name="Control"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="form" id="090a4ce4-3b75-4d66-8541-a2c6159609e0">
        <embedded/>
        <type name="Form"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="meth" id="089e376d-a2d6-45a5-8d22-84e45d027c8a">
        <embedded/>
        <type name="Method"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="receiver" id="e5dc8746-cb5a-4a9c-a25f-14752dd3c729">
        <embedded/>
        <type name="Object"/>
    </ImplicitInverseRef>
    <PrimAttribute name="row" id="1385288f-8445-4e2b-93c5-d72540bf95c2">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="table" id="a03958e5-d4c1-45f1-9611-1f608a83f2ea">
        <embedded/>
        <type name="Table"/>
    </ImplicitInverseRef>
    <PrimAttribute name="text" id="77ed0036-b3fd-4b6c-befd-6f7544601418">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getName" id="4222006c-d14c-45ac-b2bc-71919a62aacd">
        <source>getName():String;

vars
	s,t:String;
begin
	if app.isValidObject(form) then
		s:=s&amp;"form="&amp;form.name;
	else
		s:=s&amp;"form="&amp;form.String;
	endif;
	
	if app.isValidObject(table) then
		s:=s&amp;" table="&amp;table.name&amp;"("&amp;table.String&amp;")";
	else
		s:=s&amp;" table="&amp;table.String;
	endif;
	
	if app.isValidObject(control) then
		s:=s&amp;" control="&amp;control.name&amp;"("&amp;control.String&amp;")";
	else
		s:=s&amp;" control="&amp;control.String;
	endif;
	
	if app.isValidObject(meth) then
		s:=s&amp;" meth="&amp;meth.name;
	else
		s:=s&amp;" meth="&amp;meth.String;
	endif;
	
	s:=s&amp;" receiver="&amp;receiver.String&amp;" row="&amp;row.String&amp;" column="&amp;column.String&amp;" text="&amp;text;
	return s;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
