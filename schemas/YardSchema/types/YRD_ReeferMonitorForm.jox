    <JadeMethod name="doPrint" id="51fa8e7a-6602-4f21-9a47-2cc21fdaa31f">
        <updating/>
        <source>doPrint() updating ;

vars
	form			: YRD_ConnAndLabelReport;
begin

//	self.runReport('Reefer Monitoring');
	
	create form;
	form.init(true, self.tblData.allSelectedObjects);
	form.centreWindow;
	form.setAssistantAndTerminalRefs(self.myAssistant, self.myTerminal);
	
	form.showModal();

epilog
	delete form;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintConnectionRpt" id="1fb77e2f-f843-4b1e-8b7a-a0c0860653c9">
