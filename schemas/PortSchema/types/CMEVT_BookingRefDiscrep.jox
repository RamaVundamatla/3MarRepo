    <JadeMethod name="getValueFromBookingRef" id="83cf6473-5c91-41a2-aae0-65935e3e26df">
        <source>getValueFromBookingRef( _bookingRef : CM_BookingRef; _heading : String; _attrName : String ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
8 Nov 2022 navhl20 ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?
*/

vars

	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	name : String;
	tmpStr	: String;
	brItem 	: CM_BookingRefItem;
	
begin
	if _bookingRef = null then
		return null;
	endif;
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	if _attrName &lt;&gt; null then
		name := _attrName;
	else
		entTableRow := entTableDef.getEntTableRowByHeading(_heading);
		if entTableRow &lt;&gt; null then
			name := entTableRow.name;
		endif;
	endif;
	

	if name = ETRow_BookingRef or name = ETRow_BookingReference then
		return _bookingRef.getDisplayStringForAttribute(ETRow_BookingRef, false);
	
	
	//26 Mar 2010	NDL	Par 23433 ( as a result of 23316 ).  If we are associated with a booking ref item,
	//'getValueFromBookingRefItem' would have been called, and we would have returned teh booked iso type,
	// but as we are not associated with an 'item' and the parent booking has no facility to record an
	// iso type, curtains value and/or hazardous value , we should not return anything. (When the link is made from the TI to a specific ref item,
	// the real value will be sought and compared...)
	elseif ( name = ETRow_ISOType
	or name = ETRow_ISOGroup	// 20/02/2014 cnwar2 #33139
	or name = ETRow_ContAtmosAndCurtainsIn
	or name = ETRow_CO2		//8.11.2022	navhl20 TFS 55087
	or name = ETRow_O2		//8.11.2022	navhl20 TFS 55087
	or name = ETRow_Hazardous
	or name = ETRow_Humidity
	or name = ETRow_Ventilation
	or name = ETRow_Commodity
	) then
		return null;
		
	elseif ( name = ETRow_Consignee
	or name = ETRow_Consignor
	or name = ETRow_Destination
	or name = ETRow_DischargePort
	or name = ETRow_Voyage
	) then
		return _bookingRef.getDisplayStringForAttribute(name, false);
	
	elseif name = ETRow_CargoType then
		if not _bookingRef.allBookingRefItems.isEmpty then	//14 Oct 2009	NDL	Par 20880
			return _bookingRef.allBookingRefItems.first.getDisplayStringForAttribute(ETRow_CargoTypeDesc, false);
		else
			return _bookingRef.getDisplayStringForAttribute(name, false);
		endif;
		
	elseif name = ETRow_CarriageTemperature then
		return _bookingRef.getDisplayStringForAttribute(ETRow_Temperature, false);
			
	elseif name = ETRow_IsStock or name = ETRow_IsStockBookingReference then
		return _bookingRef.getDisplayStringForAttribute(ETRow_IsStockBookingRef, false);
	
	elseif name = ETRow_Operator then
		return _bookingRef.getDisplayStringForAttribute(ETRow_OperatorCode, false);

	else
		return null;
	
	endif;
	
epilog

end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueFromBookingRefItem" id="2e07deb4-ac69-4a26-baa2-d0a6df02aa5b">
        <source>getValueFromBookingRefItem( _bookingRefItem : CM_BookingRefItem; _heading : String):String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/09/2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
31/10/2011	cnwdap1	PAR #28524 CCMS POL 2096 Correct Hazard and Curtains In discrepancy checking
8 Nov 2022 navhl20 ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?
05 May 2023 navmv20 Bug 56858: PNL - Booking Discrepancies - CO2 &amp; O2 showing '-1.000' instead of being blank
*/
vars

	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	bookingRef : CM_BookingRef;
	name : String;
	
begin
	if _bookingRefItem = null then
		return null;
	endif;
	
	bookingRef := _bookingRefItem.myBookingReference;
	
	if bookingRef = null then
		return null;
	endif;
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	entTableRow := entTableDef.getEntTableRowByHeading(_heading);
	if entTableRow &lt;&gt; null then
		name := entTableRow.name;
	endif;
	
	
	// Values determined from the parent Booking reference
	
	if name = ETRow_BookingRef or name = ETRow_BookingReference then
		return bookingRef.getDisplayStringForAttribute(ETRow_BookingRef, false);
		
	elseif ( name = ETRow_Consignee
	or name = ETRow_Consignor
	or name = ETRow_Destination
	or name = ETRow_DischargePort
	or name = ETRow_Voyage
	) then
		return bookingRef.getDisplayStringForAttribute(name, false);
	
	elseif name = ETRow_IsStock or name = ETRow_IsStockBookingReference then
		return bookingRef.getDisplayStringForAttribute(ETRow_IsStockBookingRef, false);
	
	elseif name = ETRow_Operator then
		return bookingRef.getDisplayStringForAttribute(ETRow_OperatorCode, false);
	
	// Values determined from the individual booking reference item.
		
	elseif ( name = ETRow_Commodity 
	or name = ETRow_Humidity
	or name = ETRow_Ventilation
	or name = ETRow_CargoType
	) then
		return _bookingRefItem.cargoIF_GetStringForETRow( name );
			
	elseif name = ETRow_CarriageTemperature then
		return _bookingRefItem.cargoIF_GetStringForETRow( ETRow_CarriageTempC );
		
	elseif name = ETRow_ISOType then
		return _bookingRefItem.cargoIF_GetStringForETRow( ETRow_IsoTypeCode );
		
	// 20/02/2014 cnwar2 #33139
	elseif name = ETRow_ISOGroup then
		return _bookingRefItem.cargoIF_GetStringForETRow( ETRow_IsoTypeGroup );
		
	//elseif name = ETRow_CurtainsIn then	//14 Oct 2009	NDL	Par 20880						// PAR #28524
	//	if _bookingRefItem.getIsControlledAtmosphere() and _bookingRefItem.getCurtainsIn then	// PAR #28524
	elseif name = ETRow_ContAtmosAndCurtainsIn then												// PAR #28524
		if _bookingRefItem.getCurtainsIn then													// PAR #28524
			return true.cnEcGetYesNo;
		else
			return null;			
		endif;
		
	//Start 8.11.2022	navhl20 TFS 55087
	elseif name = ETRow_CO2 then
		//return _bookingRefItem.getCarbonDioxide().asStringJMT; //05/05/2023 navmv20 Bug 56858
		return _bookingRefItem.getCarbonDioxide().asNullCarbonDioxide(); ///05/05/2023 navmv20 Bug 56858
	elseif name = ETRow_O2 then												
		//return _bookingRefItem.getOxygen().asStringJMT; //05/05/2023 navmv20 Bug 56858
		return _bookingRefItem.getOxygen().asNullOxygen();	//05/05/2023 navmv20 Bug 56858
	//End 8.11.2022	navhl20 TFS 55087
		
	elseif name = ETRow_Hazardous then	//14 Oct 2009	NDL	Par 20880
		if not _bookingRefItem.allTIHazards.isEmpty then
			//return true.cnEcGetYesNo;					// PAR #28524
			return _bookingRefItem.getHazardsAsString();		// PAR #28524
		else
			return null;			
		endif;

	// unknown value
	else
		return null;
	
	endif;
	
epilog

end;</source>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem"/>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueFromTI" id="7791449e-2288-446c-a58e-b46e4d0668a2">
        <source>getValueFromTI( _ti : CM_TrackedItem; _heading : String ): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/08/2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
17/12/2009	cnwmh5	PAR 22050 _ check ti's booking ref item is container before checking has curtains
31/01/2100	cnwdap1	PAR #28524 CCMS POL 2096 Correct TI Hazards and Curtains In checking
8 Nov 2022 navhl20 ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?
05 May 2023 navmv20 Bug 56858: PNL - Booking Discrepancies - CO2 &amp; O2 showing '-1.000' instead of being blank
*/
vars

	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	name : String;
	
begin

	if _ti = null then
		return null;
	endif;
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	entTableRow := entTableDef.getEntTableRowByHeading(_heading);
	if entTableRow &lt;&gt; null then	//26 Mar 2010	NDL Par 23433
		name := entTableRow.name;
	endif;

	if name = ETRow_BookingRef or name = ETRow_BookingReference then
		return _ti.getDisplayStringForAttribute(ETRow_BookingRef, false);
		
	elseif ( name = ETRow_CargoType
	or name = ETRow_Commodity
	or name = ETRow_Consignee
	or name = ETRow_Consignor
	or name = ETRow_Destination
	or name = ETRow_DischargePort
	or name = ETRow_Humidity
	or name = ETRow_Voyage
	) then
		return _ti.getDisplayStringForAttribute(name, false);
		
	elseif name = ETRow_Ventilation then	//26 Mar 2010	NDL Par 23433	
		return _ti.getVentilation.asStringJMT;
			
	elseif name = ETRow_CarriageTemperature then
		return _ti.getDisplayStringForAttribute(ETRow_Temperature, false);
			
	elseif name = ETRow_ContAtmosAndCurtainsIn then	//14 Oct 2009	NDL Par 20880
		//if _ti.myBookingRefItem &lt;&gt; null and _ti.myBookingRefItem.isKindOf(CM_BRefItemContainer) and 	// 17/12/2009 cnwmh5 #22050	// PAR #28524
		//		_ti.myBookingRefItem.CM_BRefItemContainer.getCurtainsIn then														// PAR #28524
		if _ti.getCurtainsIn then																									// PAR #28524
			return true.getYesNo;
		else
			return null;
		endif;
	
	//Start 8.11.2022	navhl20 TFS 55087
	elseif name = ETRow_CO2 then
		//return _ti.getCarbonDioxide.asStringJMT; //05/05/2023 navmv20 Bug 56858
		return _ti.getCarbonDioxide.asNullCarbonDioxide(); //05/05/2023 navmv20 Bug 56858
	elseif name = ETRow_O2 then
		//return _ti.getOxygen.asStringJMT; //05/05/2023 navmv20 Bug 56858
		return _ti.getOxygen.asNullOxygen(); //05/05/2023 navmv20 Bug 56858
	//End 8.11.2022	navhl20 TFS 55087
	elseif name = ETRow_ISOType then
		return _ti.getDisplayStringForAttribute(ETRow_IsoType, false);

	// 20/02/2014 cnwar2 #33139
	elseif name = ETRow_ISOGroup then
		return _ti.getDisplayStringForAttribute(ETRow_IsoGroup, false);
	
	elseif name = ETRow_IsStockBookingReference then
		return _ti.myBookingRef.getDisplayStringForAttribute(ETRow_IsStockBookingRef, false);
	
	elseif name = ETRow_Operator then
		return _ti.getDisplayStringForAttribute(ETRow_OperatorCode, false);
		
	elseif name = ETRow_Hazardous then	//14 Oct 2009	NDL Par 20880
		if _ti.isHazardous then
			//return true.getYesNo;				// PAR #28524
			return _ti.getHazardsAsString();	// PAR #28524
		endif;
		return null;

	else
		return null;
	
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasBookingRef" id="0c228383-bdf7-47b1-b36a-e800b700fbf4">
        <source>hasBookingRef(_str: String): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

begin
	if self.myBookingRef &lt;&gt; null then
		return _str = self.myBookingRef.bookingReference;
