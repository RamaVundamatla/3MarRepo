    <JadeMethod name="doSaveToGlobalConstants" id="ec25405e-0ee9-4f77-ae02-82e98c9c1cb3">
        <source>doSaveToGlobalConstants(_permObj :CM_PermissionObject);
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.mousePointer := MousePointer_HourGlass;
	
	self.myPermissionAgent.trxSaveDataToGlobalConstants(_permObj);
	

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_permObj" type="CM_PermissionObject"/>
    </JadeMethod>
    <JadeMethod name="editException" id="5a8df00e-3b6f-4135-828e-5d5567563658">
        <updating/>
        <source>editException() updating;
// ---------------------------------------------------------------------------
// Created:     17 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	currentEx	: Constant;
	addErrForm	: DEV_AddErrorForm;

begin

	self.savedRow		:= tblData.row;
	self.savedTopRow	:= tblData.topRow;

	currentEx := tblData.accessRow(self.savedRow).itemObject.Constant;
	
	if currentEx &lt;&gt; null then
		create addErrForm transient;
		addErrForm.myConstant := currentEx;
		if addErrForm.showModal() = MsgBox_Return_OK then
			tblData.accessCell(self.savedRow, 1).text := self.getDisplayStringForEx(currentEx, StandardTextLocaleStr, null);
		endif;
	else
		app.msgBox("Please select an exception to edit first", "Select first", 0);
	endif;
	
epilog
	delete addErrForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="editPermission" id="e3f18175-9078-4a62-9e4c-99771be2b511">
        <updating/>
        <source>editPermission()updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	currentPerm  :CM_PermissionObject;
	permName		:String;

begin

	self.savedRow		:= tblData.row;
	self.savedTopRow	:= tblData.topRow;

	permName := tblData.accessCell(self.savedRow, 1).text;
	currentPerm := self.myPermissionAgent.allPermissionsByName.getAtKey(permName);	
	
	if currentPerm &lt;&gt; null then
		self.myCurrentPermissionObject := currentPerm;
		self.addEditPermission();
	else
		app.msgBox("Please select a permission to edit first","Select first",0);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="findText" id="b6716a90-c881-4bcd-8159-9793d744a72c">
        <source>findText() : Boolean;

vars
	currentRow, 
	idx,
	col,
	numCols		: Integer;
	tmpStr		: String;

begin

	if findTxt = null then
		return false;
	endif;

	currentRow := tblData.row;
	
	numCols := tblData.columns;
	
	//search from current row to end
	foreach idx in currentRow to tblData.rows do
	
		tmpStr := null;
		foreach col in 1 to numCols do
			tmpStr := tmpStr &amp; ' ' &amp; tblData.accessCell(idx, col).text;
		endforeach;

		if self.textFound(tmpStr) then
			tblData.clearAllSelected;
			tblData.row 		:= idx;
			if tblData.topRow + 5 &lt; idx then
				tblData.topRow := idx;
			endif;
			tblData.accessRow(idx).selected := true;
			return true;
		endif;
	endforeach;
	
	global.beep;
	
	tblData.topRow := 1;

	//search from end to current row
	foreach idx in 1 to currentRow do

		tmpStr := null;
		foreach col in 1 to numCols do
			tmpStr := tmpStr &amp; ' ' &amp; tblData.accessCell(idx, col).text;
		endforeach;

		if self.textFound(tmpStr) then
			tblData.clearAllSelected;
			tblData.row 		:= idx;
			if tblData.topRow + 5 &lt; idx then
				tblData.topRow := idx;
			endif;
			tblData.accessRow(idx).selected := true;
			return true;
		endif;
	endforeach;

	tblData.row :=	currentRow;
	app.msgBox("'" &amp; findTxt &amp; "'" &amp; " text not found", "Find", MsgBox_OK_Only);
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getConstantMessagesForLocale" id="cf194a67-e79a-47df-b739-bbbc6ffaef43">
        <source>getConstantMessagesForLocale(constant : Constant; locale : Integer; msg, shortMsg : String output);

// Return "Exception" error message and short message for the given locale
// NOTE Moved from PortSchema::Constant class because Jade reports 1010 (perhaps par 40429)

vars
	xmlDoc		: CM_XMLDocument;
	xmlElement	: JadeXMLElement;
	xmlArray	: JadeXMLElementArray;
	xmlElem		: JadeXMLElement;
begin
	if constant.text = null then
		return;
	endif;
	
	create xmlDoc transient;
	create xmlArray transient;

	xmlDoc.parseString(constant.text);
	xmlDoc.getElementsByTagName(XMLTag_LocaleMsg, xmlArray);

	foreach xmlElem in xmlArray where xmlElem.attributes.size &gt; 0 and xmlElem.attributes[1].value = locale.String do
		msg := xmlElem.getTagValueOfName(XMLTag_Msg);
		shortMsg := xmlElem.getTagValueOfName(XMLTag_ShortMsg);
	endforeach;


epilog
	delete xmlDoc;
	delete xmlArray;
end;</source>
        <Parameter name="constant" type="Constant"/>
        <Parameter name="locale" type="Integer"/>
        <Parameter name="msg" type="String" usage="output"/>
        <Parameter name="shortMsg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForEx" id="80f79919-b79a-49bf-9823-655e68c2dce9">
        <source>getDisplayStringForEx(_constant : Constant; locale1, locale2 : String) : String;
// ---------------------------------------------------------------------------
// Created:     17 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// RBarr May 06 Default message replaced with (current) locale specific message
// ---------------------------------------------------------------------------
vars
	msg1, shortMsg1 : String;
	msg2, shortMsg2 : String;
begin

	getConstantMessagesForLocale(_constant, locale1.Integer, msg1, shortMsg1);
	if locale2 &lt;&gt; null then
		getConstantMessagesForLocale(_constant, locale2.Integer, msg2, shortMsg2);
	endif;

	return  _constant.name &amp; Tab &amp; _constant.valueAsInteger.String &amp; Tab &amp;
			msg1 &amp; Tab &amp; shortMsg1&amp; Tab &amp; msg2 &amp; Tab &amp; shortMsg2;

end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="locale1" type="String"/>
        <Parameter name="locale2" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hideCurrentColumn" id="98ed6a3c-2c99-49a6-935f-d5fa24911e73">
        <updating/>
        <source>hideCurrentColumn() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	row,
	col	: Integer;
	permObj	: CM_PermissionObject;
begin
	col := tblData.column;
	if col &gt; 0 then
		tblData.accessColumn(col).visible := false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialise" id="af86c57e-9d90-404c-aaa7-5ffe6666252b">
        <updating/>
        <source>initialise()updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 2
// ---------------------------------------------------------------------------
vars
//	mutex        : BGP_Mutex;
	message      : String;
	lockType     : Integer;
	lockDuration : Integer;
	lockedBy     : Process;
	error        : Integer;
	descr : String;
	mutex : CM_Mutex;	//15 Sep 2021	NDL	TFS 51142
	root : CM_Root;	//15 Sep 2021	NDL	TFS 51142
begin

	if CM_Root.firstInstance.systemMode &lt;&gt; CM_Root.SystemMode_Dev then
		// Terminate if not a development system to prevent clients
		// running at their sites.
		terminate;
	endif;

	on Exception do doHandleInitializeException(exception, error);
	on LockException do doHandleInitializeLocException(exception, lockedBy);
	app.myCnCntrl.setCheckTransientsOnShutDown(true);
	
/*	foreach mutex in BGP_Mutex.instances do
		if mutex.primaryKey = Mutex_Permissions then
			break;
		endif;
	endforeach;
	
	if mutex = null then
		beginTransaction;
		create mutex;
		descr := "Permissions";
		mutex.update(Mutex_Permissions, descr, 0, null, null, null); 
		commitTransaction;
	endif; */
	
	root := CM_Root.firstInstance;	//15 Sep 2021	NDL	TFS 51142
	mutex := root.allMutexes.getAtKey( Mutex_Permissions_String, Mutex_Permissions );	//15 Sep 2021	NDL	TFS 51142

	lock(mutex, Reserve_Lock, Session_Duration, LockTimeout_Immediate);
	if lockedBy &lt;&gt; null then
		message := 'Application is in use by ' &amp; lockedBy.userCode &amp; CrLf &amp; 'Please retry later.';
		app.msgBox(message, 'PermissionsApp', 0);
		terminate;
	endif;

	create self.myPermissionAgent transient;
	create self.myMenuAgent transient;
	

	txtNextNumber.readOnly := true;

	tblData.sortColumn[1] := 1;
	tblData.sortType[1] := Table.SortType_Alpha;
	tblData.sortAsc[1] := true;
	
	// ### JIRA 33490 03DEC2024 NAVAB1
	// have used so comment out was using with script
	//self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	self.optPermissions.value := true;
	self.doPutInPermissionMode();
	
	beginClassNotification(GlobalConstant, false, Any_System_Event, Response_Continuous, 0);
	
epilog
	if error &lt;&gt; 0 then 
		if error &lt;&gt; 1225 then
			message := 'Error ' &amp; error.String &amp; ' occurred';
			app.msgBox(message, 'PermissionsApp', 0);
			terminate;
		else
			terminate;
		endif;
	endif;
end;</source>
    </JadeMethod>
