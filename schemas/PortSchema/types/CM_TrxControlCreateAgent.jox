        <source>trxCreateWagon(pProxyWagon		: CM_Wagon input; 
			   pNewWagon		: CM_Wagon output; 
			   pRailLine 		: CM_RailLine input; 
			   pIndex 			: Integer; 
			   lWagonContainers : CMIF_TIWagonPositionArray input;
			   _passport 		: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 Oct 2024 navma1 MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useEventDeferUpdate := true;							//25.10.2024 navma1 #MTN-33231
	
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateWagon(pProxyWagon, pNewWagon, pRailLine, pIndex,lWagonContainers, _passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();								//25.10.2024 navma1 #MTN-33231
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
