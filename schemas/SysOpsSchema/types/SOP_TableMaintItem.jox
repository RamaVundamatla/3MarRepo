    <JadeMethod name="getImportFile" id="5bde4775-23ef-4b3f-bec6-758a033e8612">
        <source>getImportFile(_file: File io);

vars
	fileGet		 		: CMDFileOpen;
	fileName			: String;
begin
	if _file = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " file is null - create file before calling ");
	endif;
	
	create fileGet;
	fileGet.filter := getImportFilter;	//MES 1010 jmn
	fileGet.fileName := '';
	fileGet.initDir := "C:\";
	if fileGet.open = 0 then	//user clicked OK
		_file.fileName := fileGet.fileName;
	endif;
	
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
    </JadeMethod>
