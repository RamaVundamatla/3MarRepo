        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

begin

	if not self.splitBreakBulk() then
		return;
	endif;
	
	inheritMethod();

epilog

end;</source>
