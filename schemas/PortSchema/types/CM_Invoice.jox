    <JadeMethod name="getAmountForCurrencyCode" id="7df8a364-dc43-4b93-8885-9f1843bb8a3d">
        <source>getAmountForCurrencyCode( _typeCode : String ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlgndl1	Initial creation	TFS 37550
29 Nov   2018   cnwma1  Bug 42218: PEL1 - International Tariff - Currency Conversion.
*/

vars

	currencyType : CM_CurrencyType;
	curRate      : CM_CurrencyRate;
	effectiveDT  : TimeStamp;

begin

	if _typeCode.trimBlanks = null then
		return 0.0;
	endif;
	
	currencyType := app.myRoot.allCurrencyTypes.getAtKey(_typeCode).CM_CurrencyType;
	
	if currencyType = null then
		return 0.0;
	endif;

	effectiveDT := self.getRateDateForCurrencyCode(); 			//	18 Sep 2018	NDL	TFS 40908
	
	curRate := currencyType.getRate( effectiveDT );
	if curRate = null then
		return 0.0;
	endif;
	
	//return rate.rate * self.getTotalAmount; 	   //29.11.2018 cnwma1 Bug #42218
	return self.getTotalAmountConverted(curRate, null);  //29.11.2018 cnwma1 Bug #42218
epilog

end;</source>
        <Parameter name="_typeCode" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAmountForInvCurrencyCode" id="04ab1f18-0505-409b-89a4-b7261c618a00">
        <source>getAmountForInvCurrencyCode() : Decimal;
/*

Purpose:			Gets the amount for the invoice line based on currency code

Parameters:			NONE

Return Value:		Decimal	Representing the converted amount based on the currency code

Date		Who		Reason
30 August 2022	navpw1	Initial creation TFS: 54564 (54376)

*/

begin
	if self.myCurrencyType = null then
		return null;
		
	endif;
	
	return self.getAmountForCurrencyCode(self.myCurrencyType.code);
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAuditOfClass" id="f62bd87a-2ed2-46a6-bae2-9811cff1d840">
        <source>getAuditOfClass(cls: Class): CM_Audit protected;
//----------------------------------------------
//Created: 27 September 2001 By: cnwgd1
//----------------------------------------------
vars
	audit:   CM_Audit;
begin
	foreach audit in qualifiedAudits do
		if audit.isKindOf(cls) then
			break;
		endif;
		audit := null;
	endforeach;

	if audit = null then
		foreach audit in unqualifiedAudits do
			if audit.isKindOf(cls) then
				break;
			endif;
			audit := null;
		endforeach;
	endif;

	return audit;
end;</source>
        <access>protected</access>
        <Parameter name="cls" type="Class"/>
        <ReturnType type="CM_Audit"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="13843e50-7b22-467b-b25e-7ece67c11a72">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2018	jlgmp6	Initial creation	TFS37718
24/01/2023	navkc1	TFS CR 55305 Task 55535: Jade - Invoice Credit Note Audits
07 November 2023	navrv30	Bug 58391: EUP - Audits for Invoice Copy
*/

vars
	txt,
	tmpStr: String;
	invoice : CM_Invoice;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	//11/07/2023 navrv30 #58391
	tmpStr := null ;
	if app.isCallingFromForm("INV_InvoiceCopy") then
		tmpStr := "Copied";
		txt := 'Invoice' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator &amp; txt;
	endif;

	tmpStr := app.getInvoiceStatusString(self.getMyInvoiceProcess, self.status); // TFS 39618
	txt := txt &amp; app.getErrorString(Status) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	//22.07.2019 cnwma1 TFS #45577
	tmpStr := null ;
	if self.myBillingAddress &lt;&gt; null then
		tmpStr := self.myBillingAddress.code;
		txt := txt &amp; 'Debtor Address' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null ;
	if self.myAlternativeAddress &lt;&gt; null then
		tmpStr := self.myAlternativeAddress.code;
		txt := txt &amp; 'Alternative Address' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null ;
	if self.myLocale &lt;&gt; null then
		tmpStr := self.myLocale.vLocaleIdAndDescription;
		txt := txt &amp; 'Locale' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	// 24/01/2023	navkc1	TFS CR 55305 TASK 55535
	tmpStr := null;
	if self.allOtherInvoices.size() &gt; 0 then
		txt := txt &amp; 'My Other Invoice' &amp; AuditStringSeparator;
		
		foreach invoice in self.allOtherInvoices do
			tmpStr := invoice.sequenceNum.String &amp; Cr &amp; tmpStr;
		endforeach;
		
		txt := txt &amp; CM_Invoice::allOtherInvoices.name &amp; AuditStringSeparator &amp; tmpStr.length().String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	
	
	// ### TFS CR 58085 TASK 61342 08JAN2024 NAVAB1
	tmpStr := null ;
	if app.isCallingFromForm("INV_InvoiceMerge") then
		tmpStr := "Merged";
		txt := 'Invoice' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator &amp; txt;
	endif;
	 
	tmpStr := null;
	if self.allMergedInvoices.size() &gt; 0 then
		txt := txt &amp; 'My Merges Invoice' &amp; AuditStringSeparator;
		 
		foreach invoice in self.allMergedInvoices do
			tmpStr := invoice.sequenceNum.String &amp; Cr &amp; tmpStr;
		endforeach;
		 
		txt := txt &amp; CM_Invoice::allOtherInvoices.name &amp; AuditStringSeparator &amp; tmpStr.length().String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	 
	tmpStr := null ;
	if self.myMergeInvoice &lt;&gt; null then
		tmpStr := self.myMergeInvoice.sequenceNum.String;
		txt := txt &amp; 'Merged Into' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	
	
	return txt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="0cdda66e-fc5f-42f9-b582-aceaa0732471">
        <source>getAuditTextForProperty(_property: Property): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2023	navkc1	Initial creation TFS CR 55305 Task 55535: Jade - Invoice Credit Note Audits
06 June 2023 navmv20 Bug 58390: EUP - Copied Invoice Other Invoice
*/

vars
	str,
	propName	: String;
	
	invoice		: CM_Invoice;
begin
	
	
	propName := _property.name;
	
	if propName = CM_Invoice::category.name then
		return self.formatAuditText(propName, self.getCategory());
	elseif propName = CM_Invoice::myOtherInvoice.name then
		if self.myOtherInvoice &lt;&gt; null then
			//06/06/2023 navmv20 Bug 58390 - start
			if self.myOtherInvoice.category = InvoiceCategory_Invoice then
				return self.formatAuditText(propName, app.getErrorString(Invoice) &amp; " - " &amp; self.myOtherInvoice.sequenceNum.String);
			elseif self.myOtherInvoice.category = InvoiceCategory_CreditNote then
			//06/06/2023 navmv20 Bug 58390 - end
				return self.formatAuditText(propName, app.getErrorString(Credit_note) &amp; " - " &amp; self.myOtherInvoice.sequenceNum.String);
			endif; //06/06/2023 navmv20 Bug 58390
		endif;
	elseif propName = CM_Invoice::allCreditCredits.name then //16/10/2024	navkc1	JIRA Bug MTN-12541
		foreach invoice in self.allCreditCredits discreteLock do
			if str = null then
				str := invoice.sequenceNum.asStringJMT();
			else
				str &amp;= CrLf &amp; invoice.sequenceNum.asStringJMT();
			endif;
		endforeach;
		return self.formatAuditText(propName, str);
	elseif propName = CM_Invoice::allCreditInvoices.name then //16/10/2024	navkc1	JIRA Bug MTN-12541
		foreach invoice in self.allCreditInvoices discreteLock do
			if str = null then
				str := invoice.sequenceNum.asStringJMT();
			else
				str &amp;= CrLf &amp; invoice.sequenceNum.asStringJMT();
			endif;
		endforeach;
		return self.formatAuditText(propName, str);
	else
		return inheritMethod(_property);
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
