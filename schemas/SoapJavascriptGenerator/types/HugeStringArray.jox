<CollClass name="HugeStringArray">
    <JadeMethod name="stringify" id="dd6db16e-3c86-488b-80f2-8610be89b59a">
        <source>stringify():String;

vars
	s,t : String;
begin
	foreach t in self do
		s := s &amp; t &amp; CrLf;
	endforeach;
	return s;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
