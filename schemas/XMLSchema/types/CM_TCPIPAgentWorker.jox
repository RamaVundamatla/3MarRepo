    <JadeMethod name="doConnectionClose" id="515bbe40-8c46-4f40-97a6-f7c8054ecff5">
        <updating/>
        <source>doConnectionClose(_tcp : TcpIpConnection) updating, protected;
// -----------------------------------------------------------------------------
// Created:		14 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(_tcp);
	endTimer(0);
	self.freeWorker();
end;</source>
