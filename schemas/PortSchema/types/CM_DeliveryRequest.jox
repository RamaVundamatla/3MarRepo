    <JadeMethod name="setMTCommodity" id="1ac1d7b2-ad50-438b-b1a2-e4ed0e7d280b">
        <updating/>
        <source>setMTCommodity() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2009	cnwer1	Initial creation

