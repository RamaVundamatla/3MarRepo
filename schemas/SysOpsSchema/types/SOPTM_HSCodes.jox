	self.showDetailsForHSType(hsType);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="6d3a2dbc-8953-4347-a842-cc97a37aefdd">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 January 2023		jlizm1	Initial creation TFS 56029 HS Codes

*/

vars

begin
