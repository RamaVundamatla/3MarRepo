        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="num40Empty" id="5731cefe-924e-4c33-909a-d26003b67647">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="num40General" id="b64d17ca-9ad3-4fbb-87ef-6fc45836dc9b">
