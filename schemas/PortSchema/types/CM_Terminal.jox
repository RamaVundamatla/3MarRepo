    <JadeMethod name="doObjectVolatilityConversion" id="78f32f0a-0631-4fc5-af20-05c581d98997">
        <updating/>
        <source>doObjectVolatilityConversion(_converter : CM_ObjectVolatilityConverter input; 
							 _logIndent : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
23 April 2010		cnwkpd1	PAR #23525 - System performance enhancements
20 September 2019	jlgzm1	TFS 7286 Additional stable collections required to improve performance

*/

vars
	indent			: Integer;
	terminalAreaView : CM_TerminalAreaView;
	taMaster		: CM_TerminalAreaMaster;
	voyage			: CM_Voyage;
	bank			: CM_Bank;
	
begin
	_converter.logMessage("Processing collections for " &amp; self.String, _logIndent);
	indent := _logIndent + 1;
	
	inheritMethod(_converter, indent);

	_converter.doChangeVolatilityOfObject(self.allCargoBOLTypes, indent);
	_converter.doChangeVolatilityOfObject(self.allShiftsStandard, indent);
	_converter.doChangeVolatilityOfObject(self.allSubTerminals, indent);
	_converter.doChangeVolatilityOfObject(self.allTerminalAreaGroups, indent);
	_converter.doChangeVolatilityOfObject(self.allTerminalAreaMastersById, indent);
	_converter.doChangeVolatilityOfObject(self.allTerminalAreaViews, indent);
	_converter.doChangeVolatilityOfObject(self.allTerminalAreas, indent);
	_converter.doChangeVolatilityOfObject(self.allTerminalAreasByTypeId, indent);
	_converter.doChangeVolatilityOfObject(self.camProtocols, indent);
	_converter.doChangeVolatilityOfObject(self.companies, indent); // TFS 7286
	
	foreach terminalAreaView in self.allTerminalAreaViews discreteLock do
		_converter.doChangeVolatilityOfObject(terminalAreaView.allTerminalAreaViewPositions, indent);
	endforeach;
	
	foreach bank in self.companies discreteLock do												// TFS 7286
		_converter.logMessage("Processing collections for " &amp; bank.String, indent);				// TFS 7286
		bank.doObjectVolatilityConversion(_converter, indent + 1);								// TFS 7286
		_converter.logMessage("Finished processing collections for " &amp; bank.String, indent);	// TFS 7286
	endforeach;
	
	_converter.doChangeStateObjectArrayVol(self.allStateObjects, indent);

	// Do all the voyage collections
	_converter.doChangeVolatilityOfObject(self.allVoyagesArchived, indent);
	_converter.doChangeVolatilityOfObject(self.allVoyagesByArrivalDTCode, indent);
	_converter.doChangeVolatilityOfObject(self.allVoyagesByCode, indent);
	_converter.doChangeVolatilityOfObject(self.allVoyagesByDepartDTCode, indent);
	_converter.doChangeVolatilityOfObject(self.allVoyagesByInwardCode, indent);
	_converter.doChangeVolatilityOfObject(self.allVoyagesByVesselCodeArrivDT, indent);
	_converter.doChangeVolatilityOfObject(self.allVoyagesNew, indent);
	_converter.doChangeVolatilityOfObject(self.allVoyagesSet, indent);
	
	foreach taMaster in self.allTerminalAreas discreteLock do
		_converter.logMessage("Processing collections for " &amp; taMaster.String, indent);
		taMaster.doObjectVolatilityConversion(_converter, indent + 1);
		_converter.logMessage("Finished processing collections for " &amp; taMaster.String, indent);
	endforeach;
	
	foreach voyage in self.allVoyagesByCode discreteLock do
		_converter.logMessage("Processing collections for " &amp; voyage.String, indent);
		voyage.doObjectVolatilityConversion(_converter, indent + 1);
		_converter.logMessage("Finished processing collections for " &amp; voyage.String, indent);
	endforeach;

	foreach voyage in self.allVoyagesArchived discreteLock do
		_converter.logMessage("Processing collections for " &amp; voyage.String, indent);
		voyage.doObjectVolatilityConversion(_converter, indent + 1);
		_converter.logMessage("Finished processing collections for " &amp; voyage.String, indent);
	endforeach;

	_converter.logMessage("Finished processing collections for " &amp; self.String, _logIndent);


epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doOrderLayoutGraphics" id="cdaaadc3-1528-4543-aac6-47ae5184f0d0">
        <updating/>
        <source>doOrderLayoutGraphics(_newOrder : CM_GraphicArray) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		take a collection of the same objects as our terminal graphic object, but in a different order.
//				dettach th eobject and re attachin the new order
// ---------------------------------------------------------------------------
vars
	aGraphic : CM_Graphic;
begin
	if _newOrder.size &lt;&gt; self.allLayoutGraphics.size then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. Graphic arrays different sizes.");
		return;
	endif;
	
	// detach
	foreach aGraphic in _newOrder do
		aGraphic.CM_LayoutGraphic.setTerminal(null,aGraphic.label);
	endforeach;

	if not self.allLayoutGraphics.isEmpty then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. Graphic array is not EMPTY!");
		return;
	endif;
	
	//attach
	foreach aGraphic in _newOrder do
		aGraphic.CM_LayoutGraphic.setTerminal(self,aGraphic.label);
	endforeach;
	
end;</source>
        <Parameter name="_newOrder" type="CM_GraphicArray"/>
    </JadeMethod>
    <JadeMethod name="doOrderLayoutGraphicsSet" id="9d35231a-fc7d-4387-b2fd-e20b2d1d0c1f">
        <updating/>
        <source>doOrderLayoutGraphicsSet(_pxyOrder : CM_GraphicArray) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		take a pxy collection of graphics in the new order
//				dettach the graphics on this real terminal
//				reattach the graphic to this real termianl by going through the graphic in the new 
//				AND linking from the proxy object to the real object
// ---------------------------------------------------------------------------
vars
	aGraphic,pxyGraphic : CM_Graphic;
begin
	if _pxyOrder.size &lt;&gt; self.allLayoutGraphics.size then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. Graphic arrays different sizes.");
		return;
	endif;
	
	// detach
	while not self.allLayoutGraphics.isEmpty do
		aGraphic := self.allLayoutGraphics.first;
		
		// if we have just created a new polygon it will not be linked so do not dettach
		pxyGraphic := aGraphic.pxyGetProxyObject();
		if pxyGraphic = null then
			return;
		endif;
		aGraphic.CM_LayoutGraphic.setTerminal(null,aGraphic.label);
	endwhile;
	
	if not self.allLayoutGraphics.isEmpty then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. Graphic array is not EMPTY!");
		return;
	endif;
	
	//attach in the new order
	foreach pxyGraphic in _pxyOrder do
		aGraphic := pxyGraphic.pxyGetRealObject();
		if aGraphic = null then
			continue;
		endif;
		
		aGraphic.CM_LayoutGraphic.setTerminal(self,aGraphic.label);
	endforeach;
	
end;</source>
        <Parameter name="_pxyOrder" type="CM_GraphicArray"/>
    </JadeMethod>
    <JadeMethod name="doPurgeKPIByType" id="1ae22a28-1305-4f17-8511-6ce871db2459">
        <source>doPurgeKPIByType(_type : Integer);
// ---------------------------------------------------------------------------
// Created:		18 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	iter : Iterator;
	objs : ObjectArray;
	kpi : CM_KPI;
	
	ls : Boolean;
	lclTrans : Boolean;
begin

	if not process.isInTransactionState then
		lclTrans := true;
		beginTransaction;
	endif;
	
	create objs transient;
	
	iter := self.allKPIbyTypeCodeTS.createIterator();
	kpi := self.allKPIbyTypeCodeTS.getAtKeyGeq(_type,null,null);

	if kpi = null then
		return;
	endif;

	
	if kpi.type &lt;&gt; _type then
		return;
	endif;
	
	iter.startAtObject(kpi);
	
	while iter.next(kpi) do
		if kpi.type &lt;&gt; _type then
			break;
		endif;
		if not objs.includes(kpi) then
			objs.add(kpi);
		endif;
	endwhile;
	
	objs.purge;
	
epilog
	if lclTrans then
		app.cmsCommitTransaction(app.myPassport);
	endif;
	delete objs;
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="erase" id="ad3c7af8-5c47-4158-a297-f5c33b4d6a95">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Date		Who		Reason
17 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
11 May 2018	jlgrs1	make delete Terminal work
*/
vars

begin
	self.exclusiveLock(self);

	self.eraseXlations (self.allXlations, NORMAL_ERASE);
	if process.isInTransactionState and
	   app.isGarbageCollectionProcess then
		self.allStateObjects.purge();
	endif;
	self.allWeighAuthTerminals.purge();
	
	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findAllCargoStartsWithId" id="959590eb-50b1-4f5d-8a38-9e2293cb48ff">
        <source>findAllCargoStartsWithId(	_id : String; 
					_cargoType : Integer; 
					_state : Integer;
					_voyage : CM_Voyage;
					_searchReversed, _containerEnqSearch : Boolean;
					_foundTis : Collection input);
//
//Date		Who		Reason
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
//
vars
	myEnqController : CM_EnqControllerTI;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	qDef : CM_QueryDefinition;
	criteriaLine : CM_SelectorCriteriaLine;
	cargoType : CM_CargoType;
begin
	if _state = null then
//		return;
	endif;
	
	if _id = null then
		return;
	endif;
	
	create myEnqController;
	myEnqController.allObjects := _foundTis;
	create criteriaHolder transient;
	myEnqController.myTerminal := self;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	myEnqController.searchReversed := _searchReversed;
	myEnqController.containerEnqSearch := _containerEnqSearch;
	
	cargoType := self.myRoot.allCargoTypesById[_cargoType];
	if _cargoType = TI_CargoType_Container then
		qDef := self.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container];
	else
		qDef := self.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	endif;
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, self);
	criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	
	if cargoType &lt;&gt; null then // already derived from self.cmbFiltTiType / filterCargoTypeId
		criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	if _state &gt; 0 then
		criteriaLine := qDef.createCriteriaLine( CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, _state);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith, _id);
	criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	
	if _voyage &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, _voyage);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	myEnqController.doQuery(qDef);
epilog
	// Tidy up local transients
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
		myEnqController.allObjects:=null;
	endif;
	delete myEnqController;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_searchReversed" type="Boolean"/>
        <Parameter name="_containerEnqSearch" type="Boolean"/>
        <Parameter name="_foundTis" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findAllCargoWithId" id="5642b9c4-c344-4dff-b290-24797bb42989">
        <source>findAllCargoWithId(	_id : String; 
					_idSearchOperator : String;
					_cargoType : Integer; 
					_state : Integer;
					_voyage : CM_Voyage;
					_booking : CM_BookingRef;
					_bol : CM_BOL;
					_searchAltIds : Boolean;
					_foundTis : Collection input);
/*

Date		Who		Reason
20 Apr 2016	cnwer1	Initial creation PAR
10 Jan 2019 jlger1	TFS 42829 
17 Aug 2023	jlier1 	TFS  59748
*/

vars
	myEnqController : CM_EnqControllerTI;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	qDef : CM_QueryDefinition;
	criteriaLine : CM_SelectorCriteriaLine;
	cargoType : CM_CargoType;
begin
	//jlier1 TFS 59948 11/10/23
	if _id = null and _voyage = null and _booking = null and _bol = null then
		return;
	endif;
	
	create myEnqController;
	myEnqController.allObjects := _foundTis;
	create criteriaHolder transient;
	myEnqController.myTerminal := self;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	cargoType:=self.myRoot.allCargoTypesById[_cargoType];
	if _cargoType = TI_CargoType_Container then
		qDef := self.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container];
	else
		qDef := self.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	endif;
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, self);
	criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	
	if cargoType &lt;&gt; null then // already derived from self.cmbFiltTiType / filterCargoTypeId
		criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	if _state &gt; TI_STATE_UNDEFINED then
		criteriaLine := qDef.createCriteriaLine( CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, _state);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	//jlier1 TFS 59948 11/10/23
	if _id &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::id.name, _idSearchOperator, _id);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	if _voyage &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, _voyage);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	//jlier1 TFS 59748 16/8/23
	if _booking &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_Equal, _booking.bookingReference.toUpper);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	
	if _bol &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::billOfLading.name, CM_QueryOperator.Operator_Equal, _bol.number.toUpper);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	
	
	myEnqController.doQuery( qDef );
	
	if _foundTis.first = null and _searchAltIds  and _id &lt;&gt; null then
		criteriaLine := myEnqController.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);	
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(null);
			delete criteriaLine;
		endif;
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::alternativeId.name, CM_QueryOperator.Operator_Equal,  _id);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(myEnqController.myCriteriaLineHolder);
		endif;
		myEnqController.doQuery( qDef );	
	endif;
	
	
epilog
	// Tidy up local transients
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
		myEnqController.allObjects:=null;
	endif;
	delete myEnqController;
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_idSearchOperator" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_searchAltIds" type="Boolean"/>
        <Parameter name="_foundTis" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findCargoByIdOrAltId" id="fbb8923b-e361-4eb0-8366-1debec2032cb">
        <source>findCargoByIdOrAltId( _id : String; 
					_filterClass : Class;
					_allCargoFound : CM_TIArray input);
/*

Purpose:			

Parameters:			filter class for type of cargo to return

Return Value:		

Date		Who		Reason
28 July 2017	jlger1	Initial creation TFS 5597 

*/

vars
	iter : Iterator;
	ti,
	tiToAdd : CM_TrackedItem;
	startTi : CM_TrackedItem;
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	firstTi : CM_TrackedItem;
begin
	
	
	cargoIdLength := _id.length;
	cargoIdReversed := _id.reverse;
		
	//Exact match only for whole id
	firstTi := self.allOnsiteTIsByIdCargoType.getAtKey(_id,null);
	if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = _id then
		iter := self.allOnsiteTIsByIdCargoType.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
			if ti.id[1:cargoIdLength] &lt;&gt; _id then
				break;
			endif;
			if ti.id &lt;&gt; _id then
				//to select, must be an exact match
				continue;
			endif;
			
			if _filterClass &lt;&gt; null and ti.class &lt;&gt; _filterClass then
				continue;
			endif;
			
			_allCargoFound.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
	
	//Allow for partial searches matching on the last 'n' chars
	//Try reverse 'cargoId' as any piece of the id
	if _allCargoFound.isEmpty then
		firstTi := self.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := self.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				
				if _filterClass &lt;&gt; null and ti.class &lt;&gt; _filterClass then
					continue;
				endif;
				
				_allCargoFound.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
	
	//Still nothing try an exact match on the alternate id
	if _allCargoFound.isEmpty then
		firstTi := self.allOnsiteTIsByAlternativeId.getAtKey(_id);
		if firstTi &lt;&gt; null and firstTi.alternativeId = _id then	
			iter := self.allOnsiteTIsByAlternativeId.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.alternativeId &lt;&gt; _id then
					break;
				endif;
				
				if _filterClass &lt;&gt; null and ti.class &lt;&gt; _filterClass then
					continue;
				endif;
				_allCargoFound.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_filterClass" type="Class"/>
        <Parameter name="_allCargoFound" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findCargoGroupAssignment" id="2f7e22a4-29c9-444b-ad0d-fce63224b7d9">
        <source>findCargoGroupAssignment( _id : String ):CM_CargoGroupAssignment;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cgAssign : CM_CargoGroupAssignment;

begin
	
	cgAssign := self.allWorkTasksDict.getAtKey( CM_WorkTask.Type_CargoGroupAssignment, _id ).CM_CargoGroupAssignment;
	
	return cgAssign;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_CargoGroupAssignment"/>
    </JadeMethod>
    <JadeMethod name="findCargoUpdateRequest" id="d26230a2-87d6-4011-ad57-13ccf7b8905c">
        <source>findCargoUpdateRequest(	_id : String;
						_type : Integer;
						_status : Integer) : CM_EventRequestStops;
/*

Date		Who		Reason
07 April 2016	cnwer1	Initial creation tfs 1787

*/

vars
	iter : Iterator;
	eventRequest : CM_EventRequestStops;
begin

	iter:= self.allEventRequestStopsByCargoID.createIterator;
	
	while iter.next(eventRequest) do
		if eventRequest.cargoId &lt;&gt; _id then
			break;
		endif;
		
		if eventRequest.type &lt;&gt; _type then
			continue;
		endif;
		
		if eventRequest.status &lt;&gt; _status then
			continue;
		endif;
		
		return eventRequest;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="CM_EventRequestStops"/>
    </JadeMethod>
    <JadeMethod name="findDriver" id="74c8c810-54e9-49b2-8732-7dff92e6b280">
        <source>findDriver(_id : String) : CM_DriverDetails;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpDR, aDR : CM_DriverDetails;
begin
	if _id = null then
		return null;
	endif;
	
	// cnwjk3 PAR 21510 16/02/10
	aDR := self.allDriversByCode[_id];
	if aDR = null then
		aDR := self.allDriversBySecondaryCode[_id];
	endif;
	if aDR = null then
		aDR := self.allDriversbyName[_id];
	endif;
	
	return aDR;

epilog


end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="findDriversWithName" id="7928f2b4-da0a-4f90-8333-c0665d89fe63">
        <source>findDriversWithName(_name : String; _foundDrivers : CM_DriverDetailsSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 June 2024		jlizm1	Initial creation TFS 63908 Allow duplicate driver names

*/

vars
	driver 	: CM_DriverDetails;
	iter 	: Iterator;
	
begin
	if _name = null then
		return;
	endif;
	
	if _foundDrivers = null then
		return;
	endif;
	
	iter := self.allDriversbyName.createIterator();
	self.allDriversbyName.startKeyGeq(_name, iter);
	
	while iter.next(driver) do
		if driver.name.toUpper() &lt;&gt; _name.toUpper() then
			break;
		endif;
		
		_foundDrivers.add(driver);	
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_foundDrivers" type="CM_DriverDetailsSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="caaf5b83-f71a-4386-be76-8d3ab9c14b82">
        <source>findLocation(_strs : StringArray; _noException : Boolean; _foundLC : CM_LocationsController io; _foundHeight : Integer io) protected;
// ---------------------------------------------------------------------------
// Created:			05 July 2001 by cnwdwq1
// Purpose:			Guess what this does!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 15 Mar 2010	consw1		PAR #23020 - Allow for vehicle that is defined with a state
// 25 Mar 2010 	cnwer1		PAR #22943  - Find RTG areas with overlapping names
// 22 Nov 2010	cnwmh5		PAR #26383 - Add additional test for finding vehicle
// ---------------------------------------------------------------------------
vars
	str,
	str1,
	str2,
	state,
	tmpLbl 	: String;
	len : Integer;
	pos	: Integer;
	remainingStrs : StringArray;
	ta : CM_TerminalArea;
	voy : CM_Voyage;
	wagon : CM_Wagon;
	machine : CM_Machine;
	vehicle : CM_Vehicle;
	allTAs  : CM_TerminalAreaSet;
	ti: CM_TrackedItem;
	trailer: CM_TILC;
	isUnknowTrailer : Boolean;
begin
	_foundLC := null;
	_foundHeight := NULLINDEX;
	if _strs.size &lt; 1 then
		return;
	endif;

	create remainingStrs transient;

	// Try finding terminal Area epr par 22943 25/3/10 - rtg areas situation where areas are named A &amp; AA that if they are looking for AA it will always return A
	create allTAs transient;
	self.findTAFromString(_strs,remainingStrs,_noException,allTAs);
	foreach ta in allTAs do
		ta.findLocation(remainingStrs, _noException, _foundLC, _foundHeight);
		if _foundLC &lt;&gt; null then
			return;	//Found!
		endif;
	endforeach;
	
	str := _strs[1].toUpper; 
	//Try finding a voyage
	voy := self.lookupVoyage(str, null, false);
	if voy &lt;&gt; null then
		remainingStrs.clear; // If the first string happens to match a terminal area ID , but actually is a voyage ID clear this out.
		_strs.copy(remainingStrs);
		remainingStrs.removeAt(1);
		voy.findLocation(remainingStrs, _noException, _foundLC, _foundHeight);
	endif;
	if _foundLC &lt;&gt; null then
		return;	//Found!
	endif;

	// Look for Wagon PAR 19710 wagon := self.allWagons[str, null];
	wagon := self.getLatestWagonByCode(str);
	if wagon &lt;&gt; null then
		remainingStrs.clear;	//Par 35346 / CCMS 1408
		_strs.copy(remainingStrs);
		remainingStrs.removeAt(1);
		wagon.findLocation(remainingStrs, _noException, _foundLC, _foundHeight);
	endif;
	if _foundLC &lt;&gt; null then
		return;	//Found!
	endif;

	//Try finding a Machine
	machine := self.machines[str];
	if machine &lt;&gt; null then
		_strs.copy(remainingStrs);
		remainingStrs.removeAt(1);
		machine.findLocation(remainingStrs, _noException, _foundLC, _foundHeight);
	endif;
	if _foundLC &lt;&gt; null then
		return;	//Found!
	endif;

	//Try finding a Vehicle
	if _strs.size &gt; 1 then
		str2 := _strs[2].toUpper;
		if str2 &lt;&gt; app.getErrorString(Road).toUpper() then
			state := str2;
		endif;
		len := str2.length();
		if len &gt; 2 and
		   str2[1:1] = "(" and
		   str2[len:1] = ")" then
			state := str2[2:len-2].trimBlanks();
		endif;
		// 22/11/2010 cnwmh5 #26383 - Start
		str1 := _strs[1].toUpper;
		len := str1.length;
		if str1[len:1] = ")" then
			pos := str1.pos("(", 1);
			if pos &gt; 0 then
				str := str1[1:pos-1];
			endif;
		endif;
		// 22/11/2010 cnwmh5 #26383 - End
	endif;
	//epr par 33302 15/1/14
	if state = CM_TILCRow.UnknownTrailer.toUpper then
		isUnknowTrailer:=true;
		state:=null;
	endif;
	
	vehicle := self.vehicles[str, state];
	if vehicle &lt;&gt; null then
		if isUnknowTrailer then
			_foundLC:= vehicle.myUnknownChassis;
			return;
		endif;
		
		_strs.copy(remainingStrs);
		remainingStrs.removeAt(1);
		vehicle.findLocation(remainingStrs, _noException, _foundLC, _foundHeight);
	endif;
	if _foundLC &lt;&gt; null then
		
		return;	//Found!
	endif;
	
	// Check for a trailer - PAR 31260
	ti := self.lookupTrailerOnsite(str, null);
	if ti &lt;&gt; null then
		trailer := ti.CM_TILC;
		//jlier1 TFS 54700 30/8/2022
		if _strs.size = 1 then
			_foundLC:=trailer.allLCs.first;
		elseif  _strs.size &gt; 1 then
			pos := _strs[2].Integer;
			if trailer.allLCs.size &gt;= pos then
				_foundLC := trailer.allLCs[pos];
			endif;
		endif;
		
	endif;
	if _foundLC &lt;&gt; null then
		return;	//Found!
	endif;
	
epilog
	delete remainingStrs;
	delete allTAs;
end;</source>
        <access>protected</access>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findLocationFromString" id="6d6eee90-2877-4cd2-ab2c-678bce80f007">
        <source>findLocationFromString(_locStr : String; _noException : Boolean; _foundLC : CM_LocationsController io; _foundHeight : Integer io);
// ---------------------------------------------------------------------------
// Created:			05 July 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------	----------		--------------------------------------------------
// 08 Oct 2008	cnwkpd1			PAR #18009 - Prevent transient leaks
// ---------------------------------------------------------------------------

constants
	DoubleSpace : String = "  ";
	SingleSpace : String = " ";
vars
	tStr : String;
	strs : StringArray;
	ta	 : CM_TerminalArea;
	pos : Integer;
	got1035 : Boolean;
begin
	_foundLC := null;
	tStr := _locStr.trimBlanks;	//Tidy up both ends of the string
	if tStr = null then
		return;
	endif;
	
	// remove any double spaces... 08 Mar 2010	NDL	Par 22728
	pos := tStr.pos(DoubleSpace, 1);
	while pos &gt; 1 do
		tStr := tStr.replaceString(DoubleSpace,SingleSpace);
		pos := tStr.pos(DoubleSpace, 1);
	endwhile;
	
	// check may be a block stack with tokens in the id e.g. B10/4
	ta := self.allTerminalAreas[tStr];

	if ta &lt;&gt; null then
		// will return a single controller if ta is a blockstack or depot
		_foundLC := ta.getLocationsController();
	endif;

	if _foundLC &lt;&gt; null then
		return;
	endif;
	
	on Exception do doHandle1035ForLocation(exception, got1035);	// 21 Apr 2016	NDL	TFS 1885
	
	//epr par 21526  - only delimeter is space
	create strs transient;
	tStr.getTokensForDelimiter(Space,strs);
	
	if got1035 then		// 21 Apr 2016	NDL	TFS 1885
		return;
	endif;

	//---------------------
	//Call the method that does all the work
	//---------------------
	self.findLocation(strs, _noException, _foundLC, _foundHeight);

epilog
	delete strs;
end;</source>
        <Parameter name="_locStr" type="String"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findLocationWhenOffsite" id="9f17e4f9-3201-4cb4-b517-5c16655bd622">
        <source>findLocationWhenOffsite(_locStr : String) : Integer;
// 36460 findLocationFromString does not find rail locations for ofsite cargo as the wagon is no longer in the given position -
//		rail location strings are XXXX 0101 02 where XXXX is the rail
//   only called when findLocationFromString has failed so doesn't repeat the code from there
constants
	DoubleSpace : String = "  ";
	SingleSpace : String = " ";
vars
	tStr : String;
	strs : StringArray;
	ta	 : CM_TerminalArea;
	pos : Integer;
begin
	tStr := _locStr.trimBlanks;
	if tStr = null then
		return 0;
	endif;
	
	pos := tStr.pos(DoubleSpace, 1);
	while pos &gt; 1 do
		tStr := tStr.replaceString(DoubleSpace, SingleSpace);
		pos := tStr.pos(DoubleSpace, 1);
	endwhile;
	
	create strs transient;
	tStr.getTokensForDelimiter(Space, strs);

	return self.findOffsiteLocation(strs);

epilog
	delete strs;
end;</source>
        <Parameter name="_locStr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findOffsiteLocation" id="393cdbed-51fd-4190-8ceb-65cd2fb37143">
        <source>findOffsiteLocation(_strs : StringArray) : Integer protected;
// 36460
vars
	result	: Integer;
	remainingStrs : StringArray;
	ta : CM_TerminalArea;
	allTAs  : CM_TerminalAreaSet;
begin
	if _strs.size &lt; 1 then
		return 0;
	endif;

	create remainingStrs transient;
	create allTAs transient;
	self.findTAFromString(_strs, remainingStrs, true, allTAs);
	foreach ta in allTAs do
		result := ta.findOffsiteLocation(remainingStrs);
		if result &gt; 0 then
			return result;
		endif;
	endforeach;
	
	return 0;
epilog
	delete remainingStrs;
	delete allTAs;
end;</source>
        <access>protected</access>
        <Parameter name="_strs" type="StringArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findPrenoteCargo" id="9b21daec-1bcc-44dc-ad03-9915c75060e9">
        <source>findPrenoteCargo(	_id : String; 
					_cargoType : Integer;
					_parentCargo : CM_TrackedItem input;
					_cargoGroupID : String) : CM_TrackedItem;
/*

Date		Who		Reason
04 April 2017	cnwer1	Initial creation TFS 3880
10 Oct 2023		navra1	TFS 60776 - EUP | FR 53824 - Transport Manifest - Duplicate Item IDs for different Cargo Group IDs

*/

vars
	cargoType  : CM_CargoType;
	ti 	: CM_TrackedItem;
	iter : Iterator;
begin
	cargoType:= self.myRoot.allCargoTypesById[_cargoType];
	
	if cargoType &lt;&gt; null and cargoType.allowDuplicates then
		//find duplicate that is not a child i
		iter:= self.allNotifiedTIsByIdCargoType.createIterator;
		self.allNotifiedTIsByIdCargoType.startKeyGeq(_id,_cargoType,iter);
		while iter.next(ti) do
			if ti.id &lt;&gt; _id then
				break;
			endif;
			if ti.cargoType &lt;&gt; _cargoType then
				continue;
			endif;
			
			//prenoted cargo with same id are allowed in differnt containers
			if ti.isChild then
				if ti.myParent = _parentCargo then
					return ti;
				endif;
				continue;
			endif;
			
			//navra1 - TFS 60776 - 10th Oct 2023 - start
			//if you wanted an item from a specific cargogroup
			if _cargoGroupID &lt;&gt; null then
				if ti.myCargoGroup &lt;&gt; null then 				
					if ti.myCargoGroup.id = _cargoGroupID then
						return ti;
					else
						continue;
					endif;
				else
					continue;
				endif;				
			endif;
			//navra1 - TFS 60776 - 10th Oct 2023 - end
			
			return ti;
			
		endwhile;
			
	
	else
		return self.lookupTrackedItem(_id, _cargoType, TI_STATE_NOTIFIED, null, false);

	endif;
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_parentCargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_cargoGroupID" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findQueue" id="775cf9a2-3158-4f52-b7df-f15c23a71704">
        <source>findQueue(_id : String) : CM_RadioTelemetryQueue;
/*

Date		Who		Reason
07 June 2017	cnwer1	Initial creation TFS 4624

*/

vars
	queues : CM_RadioTelemQueueByIdDict;
begin
	
	create queues transient;
	self.getAllQueues(queues);
	
	return queues[_id];
epilog
	delete queues;
end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="findTAFromString" id="008eceb2-42e7-45e3-8a0b-57ec7778375c">
        <source>findTAFromString(_strs : StringArray ;_remainingStrs : StringArray io; _noException : Boolean; _allFoundTerminalAreas : CM_TerminalAreaSet input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Feb 2010	cnwer1	Initial creation
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  

*/

vars
	str,
 	tmpLbl		:String;
	ta 			: CM_TerminalArea;
	startIdx 	 : Integer;
	lc 			: CM_LocationsController;
	strArray 	: StringArray;
begin

	// 34392 exit on empty input
	if _strs.isEmpty then					//05.06.2025 navma1 #MTN-34114
		return;
	endif;
	
	strArray := _strs; //16Feb2023 navsp1 TFS 56512
	
	//---------------------
	//Try finding a terminal Area
	//---------------------
	str := strArray[1].toUpper; 
	ta := self.allTerminalAreas[str];

	if ta &lt;&gt; null then
		
		//16Feb2023 navsp1 TFS 56512
		//Add available locations to the strArray, if the parameter pass only the terminal area name
		if  ta.isIrregularBlockArea and strArray.size = 1 and  self.getAutoPlanAllowFullGCArea then		//05.06.2025 navma1 #MTN-34114
			foreach lc in ta.allLocationsControllers do
				strArray.add(lc.ident);
			endforeach;
		endif;
		
		strArray.copy(_remainingStrs);
		_remainingStrs.removeAt(1);
		_allFoundTerminalAreas.add(ta);
		return;
	endif;
	
	startIdx:=1;
	ta := self.getTAFromClassString(str,startIdx,CM_RTGArea);
	if ta &lt;&gt; null then
		_allFoundTerminalAreas.add(ta);
	endif;
	//epr par 21526 
	strArray.copy(_remainingStrs);
	if ta = null then
		//rtg areas have a special case when sent from rtg telegram where the area is not zero filled 
		// e.g. instead of B02 as the termainal area id it is B2 
		//RTG names also have not 
		if str.length = 6 and strArray.size = 1 then // 2 digit lane label so zero fill
			tmpLbl := str[1:1] &amp; str[2:1].padLeadingZeros(2);
			str:=tmpLbl &amp; str[3:end];
			_remainingStrs.removeAt(1);
			_remainingStrs.insert(1,str);
		endif;
		startIdx:=1;
		ta := self.getTAFromClassString(str,startIdx,CM_RTGArea);
		if ta &lt;&gt; null then
			_allFoundTerminalAreas.add(ta);
			return;
		endif;
	endif;
	
	//epr par 22943 there is an issue if RTG areas are named CP CPX etc we need to get more than one area
	while startIdx &lt; str.length do
		startIdx:=startIdx+1;
		ta := self.getTAFromClassString(str,startIdx,CM_RTGArea);
		if ta &lt;&gt; null then
			if not _allFoundTerminalAreas.includes(ta) then
				_allFoundTerminalAreas.add(ta);
			endif;
		endif;
	endwhile;
	
	
	
	if ta = null then
		startIdx:=1;
		ta := self.getTAFromClassString(str,startIdx,CM_GantryInterchangeArea);
	endif;
	
	if ta &lt;&gt; null then
		_allFoundTerminalAreas.add(ta);
	endif;
	
epilog

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_remainingStrs" type="StringArray" usage="io"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_allFoundTerminalAreas" type="CM_TerminalAreaSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findTruck" id="fddd3123-5864-4a01-88fe-38d459dea37c">
        <source>findTruck(_regNumber, _state, _batNum : String ) : CM_Vehicle;
/*

Date		Who		Reason
10 November 2015	cnwer1	Initial creation PAR 37162

 */


vars
	truck : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	
begin
	if _regNumber &lt;&gt; null then		
		truck := self.vehicles[_regNumber.toUpper, _state.trimBlanks];		
	endif;
	
	if truck = null and _batNum &lt;&gt; null then
		vvr := self.getVehicleVisitForBatNumber( _batNum );
		if vvr &lt;&gt; null then
			truck:= vvr.vehicle;
		endif;
	endif;
	
	if truck &lt;&gt; null and truck.isNotAvailableForEntry  then
		return null;
	endif;
	
	return truck;
epilog
	
end;</source>
        <Parameter name="_regNumber" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_batNum" type="String"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="findTrucksWithRegInYard" id="a00c1a38-c392-4cab-9410-070238864101">
        <source>findTrucksWithRegInYard(	_regNumber : String;
							_foundTrucks : ObjectArray input);
/*	

Date		Who		Reason
03 August 2016	cnwer1	Initial creation TFS 2252

*/

vars
	iter : Iterator;
	truck : CM_Vehicle;
begin
	if _foundTrucks = null then
		return;
	endif;
	
	iter :=self.vehicles.createIterator;
	self.vehicles.startKeyGeq(_regNumber.toUpper,null,iter);
	while iter.next(truck) do
		if truck.regNumber.toUpper &lt;&gt; _regNumber.toUpper then
			break;
		endif;
		if truck.isNotAvailableForEntry then
			continue;
		endif;
	
		if  not truck.isOnsite or not truck.myPrimaryActualLocation.CM_YardController.isInsideYard then
			continue;
		endif;
		_foundTrucks.add(truck);			
	endwhile;
		
epilog
	delete iter;
end;</source>
        <Parameter name="_regNumber" type="String"/>
        <Parameter name="_foundTrucks" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findYABlock" id="fb13d9b3-545a-4e24-a892-ef4fee9c5ba2">
        <source>findYABlock(_locationText : String; _topLeftLC, _bottomRightLC : CM_LocationsController output; _taView  : CM_TerminalAreaView) : Boolean;

/*

Purpose:			
	&lt;Terminal Area&gt; [&lt;Lane Name&gt;] [&lt;RR-RR&gt; [&lt;CC-CC&gt;]]
Parameters:			

Return Value:		


Date		Who		Reason
21 January 2009	cnwjk3	SFW1030

*/

vars
	textLength		: Integer;
	pos 			: Integer;
	areaId			: String;
	colFrom, colTo	: String;
	rowFrom, rowTo	: String;
	ta				: CM_TerminalArea;
	taViewPosition  : CM_TerminalAreaViewPosition;
	maxRowCol		: String;
	locText			: String;
begin
	
	if _locationText = null then
		return false;
	endif;

	locText := _locationText.trimBlanks();
	
	textLength := locText.length;
	if textLength = 0 then
		return false;
	endif;
	
	pos := 1;
	
	areaId := locText.scanUntil(" ",pos);

	ta := allTerminalAreas[areaId];
	
	if ta = null then
		return false;
	endif;
	
	if _taView &lt;&gt; null then
		taViewPosition := _taView.findViewPositionForTA(ta);
	endif;
	if pos = 0 then
		// PAR 19308
		//return ta.findYABlock(null, _topLeftLC, _bottomRightLC);
		return ta.findYABlock(null, _topLeftLC, _bottomRightLC, taViewPosition);
	else	
		// PAR 19308
		//return ta.findYABlock(locText[pos:end], _topLeftLC, _bottomRightLC);
		return ta.findYABlock(locText[pos:end], _topLeftLC, _bottomRightLC, taViewPosition);
	endif;		
epilog

end;</source>
        <Parameter name="_locationText" type="String"/>
        <Parameter name="_topLeftLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_bottomRightLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_taView" type="CM_TerminalAreaView"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findYABlock_OLD" id="02f798c3-c609-4e35-b33c-f01d52caccf4">
        <source>findYABlock_OLD(_locationText : String; _topLeftLC, _bottomRightLC : CM_LocationsController output) : Boolean;

/*

Purpose:			
	&lt;Terminal Area&gt; [&lt;Lane Name&gt;] [&lt;RR-RR&gt; [&lt;CC-CC&gt;]]
Parameters:			

Return Value:		


Date		Who		Reason
21 January 2009	cnwjk3	SFW1030

*/

vars
	textLength		: Integer;
	pos 			: Integer;
	areaId			: String;
	colFrom, colTo	: String;
	rowFrom, rowTo	: String;
	ta				: CM_TerminalArea;
begin
	if _locationText = null then
		return false;
	endif;

	textLength := _locationText.length;
	pos := 1;
	
	areaId := _locationText.scanUntil(" ",pos);
	
	if pos &lt;&gt; 0 and pos &lt; textLength then
		pos := pos + 1;
		rowFrom := _locationText.scanUntil("-",pos);
	endif;
	if pos &lt;&gt; 0 and pos &lt; textLength then
		pos := pos + 1;
		rowTo := _locationText.scanUntil(" ",pos);
	endif;
	
	if pos &lt;&gt; 0 and pos &lt; textLength then
		pos := pos + 1;
		colFrom := _locationText.scanUntil("-",pos);
	endif;
	if pos &lt;&gt; 0 and pos &lt; textLength then
		pos := pos + 1;
		colTo := _locationText.scanUntil(" ",pos);
	endif;

	ta := allTerminalAreas[areaId];
	
	if ta = null or not ta.isKindOf(CM_GridArea) then
		return false;
	endif;

	_topLeftLC := ta.CM_GridArea.allGridControllersByName[ rowFrom &amp; colFrom ];
	
	if _topLeftLC = null  then
		return false;
	endif;

	_bottomRightLC := ta.CM_GridArea.allGridControllersByName[ rowTo &amp; colTo ];
	
	if _bottomRightLC = null  then
		return false;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_locationText" type="String"/>
        <Parameter name="_topLeftLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_bottomRightLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findYALocation" id="e40f9d55-d3af-427b-ad33-5c7af6bd939d">
        <source>findYALocation(_area:String; _column:String; _row:String):CM_LocationsController;
// --------------------------------------------------------------------------------
// Created:		07 April 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controllerObj	: CM_LocationsController;
	locationHeight	: Integer;
	allLocationIds	: StringArray;
	
begin
	create allLocationIds transient;
	allLocationIds.add(_area);
	allLocationIds.add(_column &amp; _row);
	
	self.findLocation(allLocationIds, false, controllerObj, locationHeight);
	
	return controllerObj;
epilog
	delete allLocationIds;
end;</source>
        <Parameter name="_area" type="String"/>
        <Parameter name="_column" type="String"/>
        <Parameter name="_row" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="fixCollection" id="2e5eecf4-1c98-4553-8183-c2f67cb93249">
        <source>fixCollection(pClass : Class; pTermCol : Collection; pController : CnEcReleaseController) protected;
// ---------------------------------------------------------------------------
// Created:     06 July 2001 by cnwrs2
//
// Purpose:     Deletes any orphan objects from the instances collection
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------
vars
	oa,
	da	: ObjectArray;
	o	: Object;

begin

	pController.logEntry('CM_Terminal::fixCollection - fixing (' &amp; pClass.getName &amp; '), collection (' &amp; pTermCol.getName &amp; ')');

	create oa transient;
	pClass.allInstances(oa, 0, true);
	
	create da transient;
	
	beginLoad;

	foreach o in oa do
		if (not pTermCol.includes(o.CM_Object)) then
			da.add(o);
		endif;
	endforeach;
	
	endLoad;
	
	if (not da.isEmpty) then
		pController.logEntry('CM_Terminal::fixCollection - Deleting ' &amp; da.size.String &amp; ' instances of ' &amp; pClass.name);
		beginTransaction;
		da.purge;
		commitTransaction;
	endif;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete oa;
	delete da;
	
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pTermCol" type="Collection"/>
        <Parameter name="pController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixupPINs" id="70d09bb8-c685-4ba4-8ff9-eb37b1974ee5">
        <source>fixupPINs();
// ---------------------------------------------------------------------------
// Created:     27 August 2004 by cnwrs2
//
// Purpose:     Clears out any PINs that should not be on TIs
// ---------------------------------------------------------------------------
vars
	tmpPIN		: CM_PinNo;
	deleteSet	: ObjectSet;
	tmpTIs		: CM_TISet;
begin

	create deleteSet transient;
	create tmpTIs transient;
	
	beginTransaction;
	
	foreach tmpPIN in self.allPinNos do
		if tmpPIN.canDelete(tmpTIs) then
			deleteSet.add(tmpPIN);
		endif;
	endforeach;
	
	deleteSet.purge;
	
	commitTransaction;
	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	delete deleteSet;
	delete tmpTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="fixupStockOnHand" id="f649caba-6750-42f9-8c60-15d5f5cbe594">
        <updating/>
        <source>fixupStockOnHand(_passport : CM_Passport input; _comment : String; _parent : Object; 
				_cmifMonitor : CMIF_Monitor input; _localTransactions : Boolean) updating;
//--------------------------------------------------------------
//Created: 25 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	area	: CM_TerminalArea;
//	sohTerm : CM_SOHTerminal;
	tmpMsg	: String;
	tmpPartsDone, tmpPartsInJob : Integer;
begin

	tmpPartsInJob := self.allTerminalAreas.size;
	
	if _cmifMonitor &lt;&gt; null then
		tmpMsg := _cmifMonitor.message;
	endif;
	
	//Fixup terminal areas and locations first
	foreach area in self.allTerminalAreas do
		app.writeLog('Fixup Stock on Hand :: Checking Terminal Area ' &amp; area.id, LogINFO);
		tmpMsg := 'Area ' &amp; area.id;				
		area.fixupStockOnHand(_passport, _comment, _parent, _cmifMonitor, _localTransactions);
		if (not _passport.noErrors) then
			return;
		endif;
		tmpPartsDone := tmpPartsDone + 1;
		if _cmifMonitor &lt;&gt; null and (not _cmifMonitor.updateProgress(tmpMsg, tmpPartsInJob, tmpPartsDone)) then
			return;
		endif;
	endforeach;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_parent" type="Object"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <Parameter name="_localTransactions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="gatePassNextSeqNumber" id="e3853988-3f38-4e47-a553-69052d293412">
        <methodInvocation>mapping</methodInvocation>
        <source>gatePassNextSeqNumber(set: Boolean; _value: String io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	08 December 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	KeyDesc = 'Gate Pass Sequence Number';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix 			: String;
	root 			: Integer;
	keyLocked		: Boolean;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);	
		return;
	endif;
	
	//17 May 2012	NDL	Par 28193 - Being a mapping method this is
	// called from CardSchema when a system dump is being performed... 
	// If we are not in trans state, the crash caused by the 1048,
	// means we don't get the rest of the details for terminal in the dump
	if not self.isTransient then
		if not process.isInTransactionState then
			return;
		endif;
	endif;
	
	theKeySeries := self.allKeySeriesByCode[SN_GatePassSeqNumber];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_GatePassSeqNumber, KeyDesc, self);
		create seriesKey persistent;
		//everitt - seed 1000
		seriesKey.set(prefix, self.bolInNextSeqNumber.Integer);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; prefix then
			seriesKey.set(prefix, 1);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);
	keyLocked := true;	//17 May 2012	NDL	Par 28193

	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);

	_value := prefix &amp; root.String;	// &amp; suffix; not used at present.

epilog
	if keyLocked then	//17 May 2012	NDL	Par 28193
		unlock(theKeySeries);
	endif;		
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="generateNextCargoId" id="1f50b066-5813-4bb6-bda8-63bab9f37db3">
        <source>generateNextCargoId( _raiseError : Boolean; _doMsgBox : Boolean;
					 _cargoTypeAbbreviation : String) :String; //1 Sept 2022 navmv20 TFS 54610

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options

*/

vars

	cargoId : String;
	cargoIdGenerator : CM_AutoCargoIdGen;
	
begin

	cargoIdGenerator := self.getMyAutoIdGenerator( CM_AutoCargoIdGen ).CM_AutoCargoIdGen;
	
	if cargoIdGenerator = null then	//18 May 2017	NDL	TFS 4483
		if _raiseError then
			app.raiseCMException(Must_config_style,null,null);
		endif;
		if _doMsgBox then
			app.msgBox(app.getErrorString(Must_config_style), app.getErrorString(Error), MsgBox_OK_Only);
		endif;
	else
		lock(cargoIdGenerator, Reserve_Lock, Transaction_Duration, 5000);
		//cargoId := cargoIdGenerator.getNextId; // 1 Sept 2022 navmv20 TFS 54610
		// Start 1 Sept 2022 navmv20 TFS 54610
		if cargoIdGenerator.useCargoTypeAbbrv then
			 cargoId := cargoIdGenerator.getNextId(_cargoTypeAbbreviation, null);
		else
			cargoId := cargoIdGenerator.getNextId(null, null); 
		endif;
		// End 1 Sept 2022 navmv20 TFS 54610
	endif;

epilog

	if cargoIdGenerator &lt;&gt; null then
		unlock(cargoIdGenerator);
	endif;
	return cargoId;
	
end;</source>
        <Parameter name="_raiseError" type="Boolean"/>
        <Parameter name="_doMsgBox" type="Boolean"/>
        <Parameter name="_cargoTypeAbbreviation" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateNextCargoWorkOrderId" id="60a48581-7ce8-48cf-bd17-94aab975b7f6">
        <source>generateNextCargoWorkOrderId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2018	jlgndl1	Initial creation	TFS 39142
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars

	woNumber : String;
	woNumberGenerator : CM_AutoIdGenerator;
	proxyWOIdGen : CM_AutoIdWOIdGen;
	msg : String;
	
	lastUsedSeriesKeyDate : Date;
	
begin

	woNumberGenerator := self.getMyAutoIdGenerator( CM_AutoIdWOIdGen ).CM_AutoIdWOIdGen;
	
	if woNumberGenerator = null then
	
		create proxyWOIdGen transient;
		proxyWOIdGen.setProxy(	null,	//_cargoIdPrefix : String ;
								4,	//_cargoIdSeqNumLength : Integer;
								AutoIdStyle_SSS,	//_cargoIdStyle : Integer; 
								self,	//_myTerminal : CM_Terminal; 
								0,	//_nextSequenceNum : Real
								CM_AutoIdWOIdGen.Reset_On_Overflow_Int
								);	
								
		app.myUtilityCA.utlCreateAutoIdGenerator( proxyWOIdGen, woNumberGenerator, app.myPassport );
		
		
		if app.myPassport.hasErrorsOrWarnings then
			msg := "Cargo Work Orders - NO 'Id format' configured. Please go to 'Auto Id Maint' in 'Terminal Config' and create it.";
		else
			msg := "Cargo Work Orders - 'Id format' was not configured.  Has been set automatically to the system defaults. Please go to 'Auto Id Maint' in 'Terminal Config' and check it.";
		endif;
		app.createAlert(msg, false);
		
	endif;
		
	if woNumberGenerator &lt;&gt; null then
		//woNumber := woNumberGenerator.getNextId;     //1 Sept 2022 navmv20 TFS 54610
		woNumber := woNumberGenerator.getNextId(null, null); //1 Sept 2022 navmv20 TFS 54610
		return woNumber;
	
	else
	
		// the old way refactored
		lastUsedSeriesKeyDate := app.actualTimeAppServer.date;
		woNumber := self.getNextSeriesNumber(	lastUsedSeriesKeyDate,	//_lastUsedSeriesKeyDate : Date input;
												SN_WorkOrder,	//_keySeriesCode : String;
												"Work Order Number",	//_keyDesc : String;
												false,	//_resetByDate : Boolean;
												false,	//_resetByYear : Boolean;
												false,	//_resetByMax : Boolean;
												1,	//_startNumber : Integer;
												null,	//_prefix : String;
												9999	//_maxNumber : Integer
												).padLeadingZeros( 4 );

		return woNumber;
	
	endif;
	
	return null;

epilog

	delete proxyWOIdGen;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateNextCustDocNumber" id="6ff00171-aef1-420b-876e-0341337d6443">
        <source>generateNextCustDocNumber(_date : Date; _dontUpdate : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars
	numGenerator		: CM_AutoIdCustomDocs;
	nextNumber			: String;
	
begin
	
	numGenerator := self.getMyAutoIdGenerator(CM_AutoIdCustomDocs).CM_AutoIdCustomDocs;
	
	if numGenerator = null then
		return null;
	endif;
	
	nextNumber := numGenerator.getNextIdForYear(_date);
	
	return nextNumber;
	
epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_dontUpdate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
