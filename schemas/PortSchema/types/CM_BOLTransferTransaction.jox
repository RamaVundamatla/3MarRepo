    <JadeMethod name="isUnassignTrn" id="20339c75-5d56-4cc2-9be3-d450ee91f3a0">
        <source>isUnassignTrn():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwndl1	Initial creation	TFS 1903

*/

