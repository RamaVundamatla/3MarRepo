    <JadeMethod name="doSave" id="18747116-cc38-4040-92ed-6dd8f497521f">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation

*/

vars

	table : CM_EntryTable;

	proxy : CM_InvoiceSignoffUser;
	
	effectiveDate : Date;
	effectiveTime : Time;
	effectiveTS : TimeStamp;
	businessUnit : CM_Bank;
	user : CM_User;
	jobTitle : String;
	
	theReturn : Integer;

begin
	
	table := self.tblEntDetail;

	if self.mode = Mode_Add then
		create proxy transient;
	elseif self.mode = Mode_Update then
		proxy := self.myProxyObject.CM_InvoiceSignoffUser;
	else
		return false;
	endif;
	
	effectiveDate := self.tblEntDetail.getValueByName(ETRow_EffectiveDate).Date;
	effectiveTime := self.tblEntDetail.getValueByName(ETRow_EffectiveTime).Time;
	
	if not effectiveDate.isValid then
		app.msgBox( app.getErrorString(Must_enter_valid_effec_date_ti), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	effectiveTS.setDate( effectiveDate );
	effectiveTS.setTime( effectiveTime );
	
	jobTitle := self.tblEntDetail.getValueByName(ETRow_UserJobTitle).String;
	user := self.cmbUser.listObject.CM_User;
	businessUnit := self.cmbBankMaint.listObject.CM_Bank;
	
	proxy.setProxy(	effectiveTS,	//_effectiveDT : TimeStamp;
					businessUnit,	//_businessUnit : CM_Bank;
					user,	//_user : CM_User;
					jobTitle	//_userJobTitle : String
					);
					
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateInvSignoff( proxy, self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvSignoff( proxy, app.myPassport );
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return true;
		else
			theReturn := app.showErrorWarningDialog( app.getErrorString(Invoice_signoff_user), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

epilog

	if self.mode = Mode_Add then
		delete proxy;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
