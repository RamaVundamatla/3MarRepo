    <JadeMethod name="getReleaseTypeString" id="04ada3ea-8814-406a-889f-ab06e6e0accc">
        <source>getReleaseTypeString(): String;
//----------------------------------------------------------------
//	Created:	30 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 22/11/2011	cnwcs5	CCMS POL 2122 / par 28696 - use method on app
vars

begin
	return app.releaseRequestTypeEnumToString (self.releaseType);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="40f192cc-ce6b-4428-b2ee-59885f602dbf">
        <source>noOutputReturned(): Boolean;
//----------------------------------------------------------------
//	Created:	01 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.allBulkReleases.isEmpty then
		return true;
	endif;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectionCriteria" id="887c5af4-563c-464c-a5d0-525bc52eb4ac">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteria(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	04 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
begin
	inheritMethod(set, _value);
	
	if set then
		return;
	endif;
	
	str :=_value;
	
	if self.fromDate.isValid
	or self.toDate.isValid then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Requested Dates:";
		else
			str :=              "Requested Dates:";
		endif;
	endif;

	if self.myOperatorGroup &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Operator Group:";
		else
			str :=              "Operator Group:";
		endif;
	endif;

	if self.myISOGroup &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "ISO Group:";
		else
			str :=              "ISO Group:";
		endif;
	endif;
	
	if self.availabilityGrade &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Grade:";
		else
			str :=              "Grade:";
		endif;
	endif;

	if not self.allAvaGrades.isEmpty  then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Grades:";
		else
			str :=              "Grades:";
		endif;
	endif;
	
	if self.requiredDateTime.isValid then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Required By:";
		else
			str :=              "Required By:";
		endif;
	endif;

	if self.searchText &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Search Text:";
		else
			str :=              "Search Text:";
		endif;
	endif;
	
	if self.releaseType &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Release Type:";
		else
			str :=              "Release Type:";
		endif;
	endif;
	
	
epilog
	_value := str;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="selectionCriteriaValues" id="9342af2a-7846-4023-9d09-0e3b7adf1a1b">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteriaValues(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	04 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
begin
	inheritMethod(set, _value);

	if set then
		return;
	endif;
	
	str :=_value;
	
	if self.fromDate.isValid
	or self.toDate.isValid then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.fromDate.shortFormatJMT &amp; " -&gt; ";
		else
			str :=              self.fromDate.shortFormatJMT &amp; " -&gt; ";
		endif;
		
		if self.toDate.isValid then
			str := str &amp;        self.toDate.shortFormatJMT;
		endif;
	endif;
	
	if self.myOperatorGroup &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.myOperatorGroup.code;
		else
			str :=              self.myOperatorGroup.code;
		endif;
	endif;
	
	if self.myISOGroup &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.myISOGroup.code;
		else
			str :=              self.myISOGroup.code;
		endif;
	endif;	
	
	if self.availabilityGrade &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.availabilityGrade.description;
		else
			str :=              self.availabilityGrade.description;
		endif;
	endif;

	if not self.allAvaGrades.isEmpty  then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.allAvaGrades.asCSV(false);
		else
			str :=              self.allAvaGrades.asCSV(false);
		endif;
	endif;

	if self.requiredDateTime.isValid then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.requiredDateTime.shortCurrentLocaleFormat;
		else
			str :=              self.requiredDateTime.shortCurrentLocaleFormat;
		endif;
	endif;

	if self.searchText &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.searchText;
		else
			str :=              self.searchText;
		endif;
	endif;	
	
	if self.releaseType &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.getReleaseTypeString();
		else
			str :=              self.getReleaseTypeString();
		endif;
	endif;
	
	
epilog
	_value := str;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
