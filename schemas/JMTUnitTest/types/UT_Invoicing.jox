    <JadeMethod name="tranMapLoadLineGrouping" id="13a48a71-8bc8-4423-bd40-b5eb9d1422ff">
        <source>tranMapLoadLineGrouping(_mapName : String);
/*
Purpose:			

Date		Who		Reason
16FEB2023	NAVAB1	CR 56446 TASK 56447  
*/

vars
	fileContent : String;
	fileName : String;
	bank : CM_Bank;
	tranMap : CM_TranMap;

begin
	fileName := "QuantityRanges";
	
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,VOID' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,All,ALL - 01' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,All,ALL - 02' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 1,Highest 1 - 01' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 1,Highest 1 - 02' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 2,Highest 2 - 01' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 2,Highest 2 - 02' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 3,Highest 3 - 01' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 3,Highest 3 - 02' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,All,ALL - 03,X,,,,,,,,,' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,All,ALL - 02,X,,,,,,,,,' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 1,OD Highest 1 - 01,X,,,,,,,,,' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 1,OD Highest 1 - 02,X,,,,,,,,,' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 2,OD Highest 2 - 01,X,,,,,,,,,' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 2,OD Highest 2 - 02,X,,,,,,,,,' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 3,OD Highest 3 - 01,X,,,,,,,,,' &amp; CrLf &amp;
'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,Highest 3,OD Highest 3 - 02,X,,,,,,,,,' &amp; CrLf;
			
					//#######################
					
	// DELETE TRAN MAP
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	tranMap := bank.myCurrentTranMapCargo[_mapName];
 	if tranMap &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tranMap, app.myPassport);
	endif;
	
	// CREATE TRAN MAP
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	tranMap := bank.myCurrentTranMapCargo[_mapName];
	self.assertNotNullMsg(tranMap, "Transaction map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(tranMap, app.myPassport);
end;
</source>
        <Parameter name="_mapName" type="String"/>
    </JadeMethod>
    <JadeMethod name="tranMapLoadMove" id="d68dd1c9-7be7-442a-aa57-afcd1a02578c">
        <source>tranMapLoadMove();

/*

Purpose:		

Date			Who		Reason
25 March 2015	cnwmh5	Initial creation

*/
constants

	FileName					: String = "MoveMDH";
	MapName						: String = "UT_MoveMDH";

vars

	bank						: CM_Bank;
	cargoMap					: CM_TranMap;
		
	fileContent					: String;
	fileName					: String;


begin

	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
		'Cargo,'&amp;MapName&amp;',CANNONBALL| Cannon Balls,(Default),12POUNDER-12,Import,(Default),(Default),(Move),Road -&gt; Yard,(Default),(Default) ›,(Default),All,UT_MDHInvLineType1' &amp; CrLf;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[MapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

epilog

end;</source>
    </JadeMethod>
