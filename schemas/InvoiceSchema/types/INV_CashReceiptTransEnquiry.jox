        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2019	jlgndl1	Initial creation	TFS 47284

*/

vars
	xmlStr	: String;
begin

