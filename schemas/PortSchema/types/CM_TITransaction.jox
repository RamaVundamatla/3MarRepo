    <JadeMethod name="getOperator" id="a28b8e29-4818-4195-a312-80be5b017235">
        <source>getOperator(): CM_Operator;
//----------------------------------------------------------------
//	Created:	17 June 2005	by Jason Chapman  (cnwjc2)
//
//	Provides access to more operator info in transaction reports
//	
//----------------------------------------------------------------
vars
	op : CM_Operator;
begin
	// ### TFS CR 58263 TASK 58264 16JAN2024 NAVAB1
	op := app.myRoot.allOperators[self.operatorCode];
	
	if op &lt;&gt; null then
		return op;
	endif;
	
	if self.myTerminal = null then
		return null;
	endif;

	return self.myTerminal.myRoot.allOperators[self.operatorCode];

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
