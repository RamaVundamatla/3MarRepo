    <JadeMethod name="getColours" id="468fd399-c43d-4cdd-9965-8786a6a174c5">
        <source>getColours(_colBackGen, _colBackTable, _colForeGen, _colForeTable : Integer output);
/*
	Created on 16 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if userColourBackGeneral = -1 then
		_colBackGen := sysColourBackGeneral;
	else
		_colBackGen := userColourBackGeneral;
	endif;
	if userColourBackTable = -1 then
		_colBackTable := sysColourBackTable;
	else
		_colBackTable := userColourBackTable;
	endif;
	if userColourForeGeneral = -1 then
		_colForeGen := sysColourForeGeneral;
	else
		_colForeGen := userColourForeGeneral;
	endif;
	if userColourForeTable = -1 then
		_colForeTable := sysColourForeTable;
	else
		_colForeTable := userColourForeTable;
	endif;
end;</source>
        <Parameter name="_colBackGen" type="Integer" usage="output"/>
        <Parameter name="_colBackTable" type="Integer" usage="output"/>
        <Parameter name="_colForeGen" type="Integer" usage="output"/>
        <Parameter name="_colForeTable" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setPortLogo" id="2b7ad25f-fac3-477a-8546-b9530f966890">
        <updating/>
        <source>setPortLogo(_logo : Binary) updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	portLogo := _logo;
end;</source>
        <Parameter name="_logo" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setSysColours" id="c7600cca-1531-4b0a-b4a3-e27e78eff457">
        <updating/>
        <source>setSysColours(colBG, colBT, colFG, colFT : Integer) updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	sysColourBackGeneral := colBG;
	sysColourForeGeneral := colFG;
	sysColourBackTable := colBT;
	sysColourForeTable := colFT;
end;</source>
        <Parameter name="colBG" type="Integer"/>
        <Parameter name="colBT" type="Integer"/>
        <Parameter name="colFG" type="Integer"/>
        <Parameter name="colFT" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setUserColours" id="4b5d7a34-2c3e-454d-a8e5-8a0e780e2238">
        <updating/>
        <source>setUserColours(colBG, colBT, colFG, colFT : Integer) updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	userColourBackGeneral := colBG;
	userColourForeGeneral := colFG;
	userColourBackTable := colBT;
	userColourForeTable := colFT;
end;</source>
        <Parameter name="colBG" type="Integer"/>
        <Parameter name="colBT" type="Integer"/>
        <Parameter name="colFG" type="Integer"/>
        <Parameter name="colFT" type="Integer"/>
    </JadeMethod>
