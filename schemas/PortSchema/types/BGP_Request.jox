    <JadeMethod name="sendAlert" id="23e57566-1f0d-47b8-aecc-cb7948266543">
        <updating/>
        <source>sendAlert() protected, updating;
//
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//
vars

	alert 	: CM_SystemAlert;
	emailTo,
	emailFrom	: String;
	msg : String;
begin

	// SHOULD ALREADY BE IN TRANSACTION STATE FROM TRX.
	if not process.isInTransactionState then
		beginTransaction;
	endif;
	msg := '(' &amp; self.class.text.cnEcGetTagValueOfName('display') &amp; ') -' &amp; app.getErrorString(Request_Has_Been_Created);
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	self.isAlerted := true;
	create alert transient;
	alert.details := msg;
	alert.setSeverity(SEVERE_WARNING);
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
	
//	app.sendMessageToUsers(detail, null); 
	emailTo	:= app.myRoot.getConfig(AutoSupportEmailAddress).String;
	emailFrom := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	if emailTo = null or emailFrom = null then
		// This will stuff system up so just jump out. An alert will have to do
		return;
	endif;
	app.myUtilityCA.utlCreateEmailSendRequest(false, app.getErrorString(BGP_Processing), emailTo, emailFrom, null, null, msg,
												null, null, null, null, null, EmailSource_System,  null, app.myPassport);

end;</source>
        <access>protected</access>
    </JadeMethod>
