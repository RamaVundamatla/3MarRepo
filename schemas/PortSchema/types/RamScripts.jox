    <JadeMethod name="processField" id="c3acff79-4427-42ba-9b4d-af12d5bb08d9">
        <updating/>
        <source>processField( _fieldArray : StringArray ) : String updating;

//--------------------------------------------------------------------------------------------------
// Returns total weight on the container that has already been loaded (by BAPLIE)
// The numbers in square brackets represent the field number in the field mapping table.
// If the order of the fields changes, then these numbers may also need changing
//--------------------------------------------------------------------------------------------------

vars
	operator : CM_Operator;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	voyCode : String;
	cargoId : String;
	cargoTypeDescr : String;
	cargoTypeId : Integer;
	weight : Real;
	foundMatch : Boolean;
begin
	operator := app.myRoot.allOperators["MSL"];
	if _fieldArray[1] = "CARGO" then
		cargoTypeDescr := _fieldArray[7];
		cargoId := _fieldArray[21];
		voyCode := _fieldArray[48];		
		weight := _fieldArray[49].Real;		
		voyCode := operator.getXlationSystemCode_Voyage(voyCode, null, null, null, foundMatch);
		voyage := app.myPassport.myTerminal.lookupVoyage(voyCode, null, false);
		cargoTypeId := operator.getXlationSystemCode(cargoTypeDescr, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch).Integer;
		if cargoTypeId = 0 then
			cargoTypeId := 1;
		endif;
		ti := voyage.allOnshipTIsByCargoTypeId[cargoTypeId, cargoId];
		if ti &lt;&gt; null and 
		   ti.weight &lt;&gt; 0 then
				return ti.weight.asStringJMT();
			else
				return _fieldArray[49];
			endif;
		endif;
end;
	
	</source>
        <Parameter name="_fieldArray" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="releaseScript" id="6384fbb4-5527-4fbc-864c-bd04416e1570">
        <source>releaseScript();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2023	navra1	Initial creation for 54078 - MTN - Compress msgWebReq and msgWebRes on CM_EdiFile

*/

vars
	terminal : CM_Terminal;	
	terminalList : CM_TerminalByCodeDict;	
	ediConfig : CM_EDIConfig;
	allEDIFilesForTerm : CM_EDIFileByCreatedTSDict;
	ediFile : CM_EDIFile;	
	numCompleted : Integer;
	totalNumber : Integer;
	startTs : TimeStamp;
begin
	startTs := app.actualTimeServer;
	write "start"&amp;startTs.asStringJMT();

	//if self.hasScriptBeenRunAtAll(method.name, _controller) then
		//return;
	//endif;
	
	//app.writeLog(method.qualifiedName &amp; " Compressing Web Req and Res", LogINFO);	
	
	create terminalList transient;
	terminalList := app.myRoot.allTerminals;
	
	foreach terminal in  terminalList do
		ediConfig := terminal.myEdiConfig;
		if ediConfig &lt;&gt; null then
			allEDIFilesForTerm := ediConfig.ediFiles;
			totalNumber := totalNumber + allEDIFilesForTerm.size();
		endif;
	endforeach;
	
	beginTransaction;
	
		foreach terminal in  terminalList do
			ediConfig := terminal.myEdiConfig;		
			allEDIFilesForTerm := ediConfig.ediFiles;
			
			if allEDIFilesForTerm &lt;&gt; null then
				foreach ediFile in allEDIFilesForTerm  do
					if ediFile.msgWebReq &lt;&gt; null then
						ediFile.setWebReqString(ediFile.msgWebReq);
						//ediFile.msgWebRes := null;
					endif;
					
					if ediFile.msgWebRes &lt;&gt; null then
						ediFile.setWebResString(ediFile.msgWebRes);
						//ediFile.msgWebRes := null;
					endif;					
				
					numCompleted := numCompleted  + 1;
				
					//see if its time to end
					if startTs.addSeconds(10) &lt;= app.actualTimeAppServer() then
						//write "end"&amp;app.actualTimeAppServer() ;
						break;
					endif;
					
				endforeach;					
			endif;
		
		endforeach;
	
	commitTransaction;	
	
	if numCompleted = totalNumber then
		//self.addScriptRun(method.name);
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="robScript" id="2ee05894-fa67-4ee8-a41a-adf223054709">
        <source>robScript();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2024	navra1	Initial creation

*/

vars
	term : CM_Terminal;
	voyage : CM_Voyage;
	robtobedeleted : CM_TISet;
	
begin
	app.initialize();
	
	term := app.myRoot.allTerminals['IMT'];
	foreach voyage in term.allVoyagesByCode do
		if voyage.code = '011S' then
			break;
		endif;
	endforeach;
	
	create robtobedeleted transient;
	if voyage &lt;&gt; null then
		voyage.getNonWorkedROB(robtobedeleted);
	endif;
	
	write 'hi';
epilog
	delete robtobedeleted;

end;</source>
    </JadeMethod>
    <JadeMethod name="runReport" id="45eb5c9d-5077-4080-b6fd-8bdeb1c4bade">
        <source>runReport();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2024	navra1	Initial creation

*/

vars
	_invoice : CM_Invoice;
	_directory : String;
	
	
	bgpUser : CM_User;
	internalUser : CM_User;
	reportTemplate : CM_ReportTemplate;
	pdfPrinter : CM_PrinterDef;
	outputDestination : String;
	filter : CMQF_Invoice;
	chosenReportTemplate : CM_ReportTemplate;
	terms : CM_TerminalByCodeDict;
	ramt : CM_Terminal;
	invp : CM_InvoiceProcess;
	directoryObj:FileFolder;
begin
	app.initialize();
	
	terms := app.myRoot.allTerminals;
	ramt := terms["RAM"];
	
	foreach invp in ramt.myRoot.allInvoiceProcesses where invp.isKindOf(CM_InvoiceProcessInvoiceAPI) do
		break;
	endforeach;
	
	foreach _invoice in invp.allInvoices where _invoice.sequenceNum = 525 do
		break;
	endforeach;
	
	_directory := "D:\navDmast\server\c_misc\Ram\BEDFBUIN2400379-1";
	
	foreach bgpUser in CM_UserInternal.instances do
		if bgpUser.userName = "BGPUSER" then			
			break;
		endif;
	endforeach;
	
	if bgpUser.userName &lt;&gt; "BGPUSER" then
		app.writeLog("BGP User does not exist, so no reports can be generated", LogERROR);
		return;
	endif;

	foreach reportTemplate in bgpUser.allReportsToRunForUser where reportTemplate.myQryReport &lt;&gt; null and reportTemplate.myQryReport.reportType = CM_QryReportUser.ReportType_Invoice do
		chosenReportTemplate := reportTemplate;
		if chosenReportTemplate.name = "DEFAULT" then
			break;			
		endif;
	endforeach;
	
	if chosenReportTemplate = null then
		app.writeLog("BGP has no suitable reports, will not be able to generate a report", LogERROR);
		return;
	endif;
	
	if chosenReportTemplate.name &lt;&gt; "DEFAULT" then
		app.writeLog("BGP has no invoice report named DEFAULT, so generating with a different template - " &amp; chosenReportTemplate.name &amp; 
					" type is " &amp; chosenReportTemplate.myQryReport.getDescriptionFromType(chosenReportTemplate.myQryReport.reportType), 
					LogERROR);		
	endif;
	
	foreach pdfPrinter in CM_PrinterDef.instances do
		if pdfPrinter.printerIsPDF then
			break;
		endif;
	endforeach;
	
	if pdfPrinter = null or pdfPrinter.printerIsPDF &lt;&gt; true then
		app.writeLog("Could not find a PDF printer, exiting!", LogERROR);		
		return;
	endif;	
	
	outputDestination := _directory &amp; "\" &amp; _invoice.externalNumber;
	
	create directoryObj transient;	
	directoryObj.usePresentationFileSystem := false;
	directoryObj.fileName := outputDestination;	

	//this directory should have been created in the previous utl that copys over the invoice attachments, if it does not exist, return
	if not directoryObj.isAvailable() then	
		app.writeLog("The directory to put the invoice report does not exist, so returning!", LogERROR);
		return;
	endif;
	
	outputDestination := outputDestination &amp; "\" &amp; chosenReportTemplate.name;
	
	create filter transient;
	filter.initialize();
	filter.invoiceNumber := _invoice.sequenceNum;
	filter.allCompaniesByCode.add(_invoice.bank);	
	
	app.myUtilityCA.utlCreateAndRunBackgroundRpt(false,
											chosenReportTemplate.name,
											chosenReportTemplate.description,
											null,
											pdfPrinter.getName(),
											outputDestination,											
											CM_QryReport.PDF_Format,
											BGP_ReportRequest.SaveAndPrint,
											true,
											//null,
											filter,
											chosenReportTemplate.myQryReport,
											null,
											chosenReportTemplate.myEmailTemplate,
											chosenReportTemplate.myUserToRunAs.code,
											chosenReportTemplate.allUsersToGetOutput,
                                            null, //MTN-36668
											app.myPassport
											);											
	
										
	
	
epilog
	delete filter;
	delete directoryObj;
end;
	
</source>
    </JadeMethod>
    <JadeMethod name="split" id="33414aba-45b5-48e5-a9fe-aaa0cf39f8df">
        <source>split();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2025	navra1	Initial creation

*/
constants
	PatternStr ="\\";
	Text ="...parison via Voyage Progress Screen\DISCHARGE_LIST_ANL.txt";
vars
	compiledPattern : JadeRegexPattern;
    splits : JadeRegexResult;
    numOfSplits, i : Integer;
	strArray : StringArray;
	str : String;
	
begin
	str := "...parison via Voyage Progress Screen\DISCHARGE_LIST_ANL.txt";
	strArray := str.cnGetTokens("\\");
	create compiledPattern;
    compiledPattern.compile(PatternStr);
    numOfSplits := compiledPattern.splitSubstring(Text, 1, Text.length(), 
                                  splits);
								  
	write "answer - " &amp;splits.at(numOfSplits).value;
	foreach i in 1 to numOfSplits do
		write i.String&amp;") "&amp;splits.at(i).value;
    endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="test11" id="d726f1dc-9275-4344-b617-8cd591b2003c">
        <source>test11();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2025	navra1	Initial creation

*/


vars
	extDef			: CM_ExternalWebServiceDef;
	objArray : ObjectArray;
	now : TimeStamp;
	date : Date;
	time : Time;
	
begin
	now.setDateTime(2025,1,1,0,0,0,0);
	
	foreach extDef in app.myRoot.allExternalWebServices discreteLock do		
		
		
		if extDef.name = 'CNWCHCS11 SimpleWebServer1' and extDef.isKindOf(CM_APIEndpointServiceDef) then
			beginTransaction;
				extDef.CM_APIEndpointServiceDef.setLastSuccessfulTS(now);
			commitTransaction;
			write 'changed';
			
			break;			
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
