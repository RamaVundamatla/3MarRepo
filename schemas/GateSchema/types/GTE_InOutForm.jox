    <JadeMethod name="goToErrorItem" id="925554a8-29b0-4944-877a-b580518d0856">
        <source>goToErrorItem(pError: CM_Error);
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	theWindow	: Window;
	theField	: String;
	fieldFound	: Boolean;
	tbl			: CM_EntryTable;
	idx			: Integer;
	cntrl		: Control;
	sheetType	: String;
	
begin
	if pError.myUserObject = null then
		//If we have no object to jump to, just can out here
		return;
	endif;

	if not app.isValidObject(pError.myUserObject) then
		//User may have deleted the relevant sheet already
		return;
	endif;
	if (not pError.myUserObject.isKindOf(Window)) then
		return;
	endif;
	theWindow := pError.myUserObject.Window;
	theField  := pError.fieldName;

	if theWindow.name = 'shtInOut' then
		// If from entry table (tblMain or tblExtra) then may need to translate
		
		if theWindow.isKindOf(GTE_Sheet) then
			sheetType := theWindow.GTE_Sheet.myMenuAction.code;
		endif;
		
		if sheetType = NavObj_GTE_In then
			if theField = 'id' then
				theField := 'idTextBox';
			elseif theField = 'operator' then
				theField := 'operatorCode';
			elseif theField = 'status' then
				theField := 'statusString';
			elseif theField = 'temperature' then
				// As tempC field is shown even if tempF being used this should get user back to correct area.
				theField := 'carriageTempC';
			elseif theField = 'weight' then
			  theField := 'weightTotal';	
			elseif theField = 'voyage' then
				theField := 'voyageCode';
			endif;
		elseif sheetType = NavObj_GTE_OutById then
			if theField = 'id' then
				theField := 'idCombo';
			endif;
		endif;
		
		theField := app.myController.getEntTableErrorReturnString(ETGrp_GateReceivals, theField);

	elseif theWindow.name = 'tblCommon' then
		theField := app.myController.getEntTableErrorReturnString('InOutCommon', theField);
	endif;

	if theWindow.name = 'tblCommon' then
		if theWindow.CM_EntryTable.goToRowByName(theField) then
			theWindow.setFocus();
		endif;
		
	elseif theWindow.isKindOf(GTE_Sheet) then
		tbl := theWindow.GTE_Sheet.myTblMain;
		if tbl.goToRowByName(theField) then
			tbl.setFocus;
			fieldFound := true;
		else
			tbl := theWindow.GTE_Sheet.myTblExtra;
			if tbl.goToRowByName(theField) then
				tbl.setFocus;
				fieldFound := true;
			endif;
		endif;
		
	else
		if theField &lt;&gt; null then
			fieldFound := false;
		
			if theWindow.isKindOf(CM_EntryTable) then
				tbl := theWindow.CM_EntryTable;
				if tbl.goToRowByName(theField) then
					tbl.setFocus();
					fieldFound := true;
				endif;
			endif;
		
			if not fieldFound then
				// search controls which have pWindow as a parent
				foreach idx in 1 to self.controlCount do
					cntrl := self.controls(idx);
					if cntrl.parent = theWindow then
						if cntrl.name = theField then
							cntrl.setFocus;
							fieldFound := true;
							break;
						endif;
						if cntrl.isKindOf(CM_EntryTable) then
							tbl := cntrl.CM_EntryTable;
							if tbl.goToRowByName(theField) then
								tbl.setFocus;
								fieldFound := true;
								break;
							endif;
						endif;
					endif;
				endforeach;
			endif;

		endif;
	endif;

end;</source>
        <Parameter name="pError" type="CM_Error"/>
    </JadeMethod>
