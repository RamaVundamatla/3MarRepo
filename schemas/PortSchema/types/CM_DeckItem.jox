    <JadeMethod name="validateCreate" id="ed88eca5-dfcf-41d5-97fc-62385174107d">
        <source>validateCreate(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	
begin
	self.raiseExceptionIfNotTransient(method);

	if self.code = null then
	 //	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Item) &amp; " " &amp; app.getErrorString(Code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Item) &amp; " " &amp; app.getErrorString(Code), null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	self.validateUpdate(_passport);
	
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
