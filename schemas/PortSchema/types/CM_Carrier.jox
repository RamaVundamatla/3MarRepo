    <JadeMethod name="cnEcGetDuplicate" id="1e66ef9e-83f4-457e-a462-5fdbb99230ba">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	carrier : CM_Carrier;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		carrier := app.myRoot.allCarriers.getAtKey( code );
	endif;

epilog

	return carrier;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="delete" id="ff6c886e-fe1e-41c0-9b59-a929946893f1">
        <updating/>
        <source>delete() updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 18 February 2004
//
//********************************************************************
vars

begin

	//04 Apr 2019	NDL	TFS 44194
	if app.myAlternateDict &lt;&gt; null then
		app.myAlternateDict.setCarrierDictNeedsRefresh();
	endif;

	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
end;</source>
    </JadeMethod>
    <JadeMethod name="displayForXlation" id="9e328124-8c52-48fd-8150-21c9f9a44f2c">
        <source>displayForXlation(_codeFirst : Boolean) : String;

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="erase" id="3f7a585e-e326-4e00-a854-564b681a5ba3">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Date		Who		Reason
25 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.exclusiveLock(self);

	self.eraseXlations (self.allXlations, NORMAL_ERASE);
	
	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="b5dae94d-f766-4207-a4a4-a71835a1f8ff">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	email   : CM_EmailEntity;
	car    : CM_Vehicle;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach email in self.allPINNotifyEmailAddresses do
		if tmpStr = null then
			tmpStr := email.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; email.name;
		endif;
	endforeach;

	txt := txt &amp; 'Addresses Selected' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	tmpStr := null;
	foreach car in self.vehicles do
		if tmpStr = null then
			tmpStr := car.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; car.code;
		endif;
	endforeach;

	txt := txt &amp; 'Vehicles' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
