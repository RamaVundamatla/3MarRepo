        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssAddMonths" id="cb8e9ac3-e1d1-4ca0-9295-781f1bf0664a">
        <source>jssAddMonths(pMonths:Integer) : Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of months to the
//				receiver date.
//
// Parameters:	pMonths (Integer) - The number of months to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dayNum		: Integer;
	monthNum	: Integer;
	yearNum		: Integer;
	daysInMonth : Integer;
	dateResult	: Date;
    
begin
	// Copy year, month and day attributes from self to local variables for computation.
	
	yearNum		:=	self.year;
	monthNum	:=	self.month;
	dayNum		:=	self.day;

	// Handle negative months parameters by going backwards in time.
	
	if monthNum + pMonths &lt; 1 then
		yearNum	:=	yearNum + (monthNum + pMonths - 12) div 12;
	else
		yearNum	:=	yearNum + (monthNum + pMonths - 1) div 12;
	endif;

	monthNum	:=	(monthNum + pMonths - 1) mod 12 + 1;
    
	if monthNum &lt; 1 then
		monthNum	:=	monthNum + 12;
	endif;

    // If end day exceeds last day of month, set day equal to the last day of the month.
    
	daysInMonth	:=	monthNum.jssDaysInMonth(yearNum.jssIsLeapYear);
    
	if dayNum &gt; daysInMonth then
		dayNum	:=	daysInMonth;
	endif;

	dateResult.setDate(dayNum, monthNum, yearNum);

	return dateResult;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pMonths" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssAddYears" id="7f0bb0e1-567f-4eef-b706-8d56e58e92dd">
        <source>jssAddYears(pYears:Integer):Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of years to the
//				receiver date.
//
// Parameters:	pYears (Integer) - The number of years to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
    dayNum		: Integer;
    monthNum	: Integer;
    yearNum		: Integer;
    dateResult	: Date;

begin
	// Copy year, month and day attributes from self to local variables for computation.

	yearNum		:=	year + pYears;
	monthNum	:=	month;
	dayNum		:=	day;

	// Handle special case where we end up with 29 Feb on non leap year, round down to 28th.
    
	if monthNum = 2 and dayNum = 29 and not yearNum.jssIsLeapYear then
		dayNum	:=	28;
	endif;

	dateResult.setDate(dayNum, monthNum, yearNum);

	return dateResult;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pYears" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssCurrentAge" id="ab0797ed-7b9a-43e5-9e70-c452366d60d0">
        <source>jssCurrentAge():String;
// If a valid date supplied, return current age in the format years:months:days 
// If invalid date format or a date in the future return null.
//
// Requires cnEcIsInFuture method to exist against Date.
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	birthday	: String;			// Birth date
	today		: String;			// Today
	workArea	: String;			// Work area to carry this years birthday date
	age			: String;          	// Return Value  years:months:days
	ageYears	: Integer;			// Work area for years portion of the result
	ageMonths	: Integer;			// Work area for months portion of the result
	ageDays		: Integer;			// Work area for days portion of the result		

begin
	// Invalid date or date format, return null and stop.
	
	if self.Date = null or not self.Date.isValid then
		return null;
	endif;

	birthday	:= self.format("dd-MM-yyyy");   
	today		:= app.actualTimeServer.Date.format("dd-MM-yyyy");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	// If the date is in the future, return null and stop.
	
	if birthday.Date.jssIsInFuture then
		return null;
	endif;

	// We have a valid date to work with.

   	workArea		:= birthday;
   	workArea[7:4]	:= today[7:4];						// Modify the year to become the actual date of this year's Birthday.

	if workArea.Date.jssIsInFuture then
		ageYears	:= today[7:4].Integer - birthday[7:4].Integer - 1;	
	else
		ageYears	:= today[7:4].Integer - birthday[7:4].Integer;
	endif;

	age[1:3]	:= ageYears.String;						// Set the years value.
	age[4:1]	:= ":";

	if birthday[1:2] &lt;= today[1:2] then      			// Birthday 'day of the month' has occurred 
		if birthday[4:2] &gt; today[4:2] then   			// Birthday 'month' hasn't occurred yet.      
			ageMonths	:= 12 + today[4:2].Integer - birthday[4:2].Integer;
		else											// Birthday 'month' has occurred.
			ageMonths	:= today[4:2].Integer - birthday[4:2].Integer;
		endif;

		ageDays	:= today[1:2].Integer - birthday[1:2].Integer;       	
	endif;

	if birthday[1:2] &gt; today[1:2] then     				// Birthday 'day of the month' hasn't occurred yet.
		if birthday[4:2] &gt;= today[4:2] then   			// Birthday 'month' or before.
			ageMonths := 12  + today[4:2].Integer - birthday[4:2].Integer -1 ;
		else  	
			ageMonths := today[4:2].Integer - birthday[4:2].Integer - 1;
		endif;

		ageDays	:= 31;									// How many days between the relevant day last month and this month. Initially assume 31.

		// If last month was Apr, Jun, Sep or Nov change it to 30.
		
		if today[4:2].Integer - 1 = 4 or today[4:2].Integer - 1 = 6 or today[4:2].Integer - 1 = 9 or today[4:2].Integer - 1 = 11 then
			ageDays	:= 30;
		endif;

		if today[4:2].Integer - 1 = 2 then				// Last month was February.
			ageDays	:= 28;

			if today.Date.isLeapYear then
				ageDays	:= 29;
			endif;
		endif;

		ageDays	:= ageDays - birthday[1:2].Integer + today[1:2].Integer;
	endif;

	age[5:2]	:= ageMonths.String;					// Set the months value.
	age[7:1]	:= ":";
	age[8:2]	:= ageDays.String;						// Set the days value.

	// Correct any alignment problems caused by going from Integer to String during calculations.
	
	if age[3:1] = " " then
		age[2:2]	:= age[1:2];
		age[1:1]	:= " ";
	endif;

	if age[3:1] = " " then
		age[2:2]	:= age[1:2];
		age[1:1]	:= " ";
	endif;

	if age[6:1] = " " then
		age[6:1]	:= age[5:1];
		age[5:1]	:= " ";
	endif;

	if age[9:1] = " " then
		age[9:1]	:= age[8:1];
		age[8:1]	:= " ";
	endif;

	return age;									//  Return value and stop.
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssDaysInMonth" id="27891a9e-3abf-4730-a1bf-6be8e42a5f11">
        <source>jssDaysInMonth():Integer;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the number of days in the month of the receiver.
//
// Parameters:	None
//
// Returns:		The number of the days.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.month.jssDaysInMonth(self.year.jssIsLeapYear);
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssDaysInYear" id="469d6800-f8cd-40ad-85cf-069f071cf07c">
        <source>jssDaysInYear():Integer;
// --------------------------------------------------------------------------------
// Created:		09 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMonth	: Integer;
	daysInYear	: Integer;

begin
	foreach theMonth in 1 to 12 do
		daysInYear	:=	daysInYear + theMonth.jssDaysInMonth(self.year.jssIsLeapYear());
	endforeach;

	return daysInYear;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetCentury" id="dbcf1fe9-03ab-498e-be7c-316f53dde636">
        <source>jssGetCentury():Integer;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver's century.  If the receiver is not valid, then
//				a value of zero will be returned.
//
// Parameters:	None
//
// Returns:		The two-digit century as an integer.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &lt;&gt; null and self.isValid then
		return (self.year - self.format("yy").Integer) div 100;
	else
		return 0;
	endif;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
