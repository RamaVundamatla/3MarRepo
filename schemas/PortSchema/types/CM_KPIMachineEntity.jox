    <JadeMethod name="updateForReject" id="3d6401e2-bf7a-47a5-b03c-26781e75e7ad">
        <updating/>
        <source>updateForReject(_history :CM_MachineMoveHistory)updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.numRejectedMoves := self.numRejectedMoves + 1;
	
	self.allMachineHistory.addNoDuplicates (_history, false);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
