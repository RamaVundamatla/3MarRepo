    <JadeMethod name="getDefaultCharacters" id="dfbb6a7e-1ed8-4de3-a381-5f330d3c843c">
        <source>getDefaultCharacters(_decimal, _element, _escape, _segment, _subElement :Character output);
/*
Purpose:	Get values for default characters to use in CAMS messages

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
vars

begin
	_decimal	:= self.decimalCharacter;
	_element	:= self.elementSeparator;
	_escape		:= self.escapeCharacter;
	_segment	:= self.segmentTerminator;
	_subElement	:= self.subElementSeparator;
epilog

end;</source>
