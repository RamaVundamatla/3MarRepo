    <JadeMethod name="getMeasurementStringForAttrib" id="4423ee26-0e4e-4d4a-bcc7-1a9d7eec6ee1">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2013	cnwdap1	Initial creation
18 March 2016   cnwma1  PAR #37528 - MSL - load list - oversize not showed
30 Oct	   2018	jlgrh7 	TFS #41372 MSL - MGW on Cargo Enquiry
*/
vars
	maxWeight		: Decimal [16,4];
	containerRange 	: CM_ContRange;
	maxTotalWeight : Decimal[16,4];			//+TFS41372
	isoType : CM_ISOType;								//+TFS41372
begin

	if _attrName=ETRow_Length then 																		//18/03/2016 cnwma1 PAR #37528
		return app.convertMeasurementForDisplay(_measureType, self.overLengthFront+self.overLengthRear);
		
	elseif _attrName=ETRow_Width then																	//18/03/2016 cnwma1 PAR #37528		
		return app.convertMeasurementForDisplay(_measureType, self.overWidthLeft+self.overWidthRight);
	
	elseif _attrName=ETRow_Height then																	//18/03/2016 cnwma1 PAR #37528
		return app.convertMeasurementForDisplay(_measureType, self.overHeight);
				
	elseif _attrName = ETRow_OverLengthBack then
		return app.convertMeasurementForDisplay(_measureType, self.overLengthRear);
	elseif _attrName = ETRow_OverLengthFront then
		return app.convertMeasurementForDisplay(_measureType, self.overLengthFront);
	elseif _attrName = ETRow_OverWidthLeft then
		return app.convertMeasurementForDisplay(_measureType, self.overWidthLeft);
	elseif _attrName = ETRow_OverWidthRight then
		return app.convertMeasurementForDisplay(_measureType, self.overWidthRight);
	elseif _attrName = ETRow_OverHeight then
		return app.convertMeasurementForDisplay(_measureType, self.overHeight);
	elseif _attrName.isOneOf(ETRow_ContainerVolume, ETRow_VolumeMax) then
		return app.convertMeasurementForDisplay(_measureType, self.getMaxVolume);
	elseif _attrName = ETRow_WeightMax then
		maxWeight := self.getMaxWeightFromTIMaster();
		if maxWeight = 0 then
			containerRange := app.myRoot.lookupContainerRange(self.id);
			if containerRange &lt;&gt; null then
				maxWeight := containerRange.maxKilos + containerRange.tareKilos;
			endif;
		endif;
		return app.convertMeasurementForDisplay(_measureType, maxWeight);
	elseif _attrName = ETRow_MaxTotalWeight then																			//+TFS41372
		isoType := self.getISOTypeObject;
		if  isoType &lt;&gt; null then
			maxTotalWeight := isoType.maxTotalWeight;
		endif;
		if maxTotalWeight &lt;&gt; null then
			return  app.convertMeasurementForDisplay(_measureType, maxTotalWeight);
		else
			return null;
		endif;
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveLengthForLCs" id="121d6f21-811b-40a0-b0b7-2d868d709cc7">
        <source>getMoveLengthForLCs(): Real;
// ---------------------------------------------------------------------------
// Created:		28 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		Get length in 20 foot lengths
//
// ---------------------------------------------------------------------------

vars

begin
	if self.is40 then
		return 40;
	elseif self.is45() then // PAR 16415 CCMS 1029
		return 40;
	elseif self.is30() then // PAR 16415 CCMS 1029
		return 20;
	elseif self.is53() then // PAR 16415 CCMS 1029
		return 40;
	else
		return 20;
	endif;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getMultiplierForDrawing" id="2adf33b8-66ae-4916-8e43-5f8250d8dc2e">
        <source>getMultiplierForDrawing() : Real;
// ---------------------------------------------------------------------------
// Created:		08 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.is45() then // PAR 16415 CCMS 1029
		return 2.25;
	elseif self.is40 then
		return 2;
	elseif self.is30() then // PAR 16415 CCMS 1029
		return 1.49;
	elseif self.is53() then // PAR 16415 CCMS 1029
		return 2.65;
	else
		return 1;
	endif;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getMyTotalVolume" id="656ca039-36f5-4e1e-a3a3-efd6aa73d690">
        <source>getMyTotalVolume(): Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2011	cnwndl1	Initial creation	Par 27868

*/

vars

	vol : Decimal [16,4];

begin

	vol := inheritMethod();
	
	if vol &gt; NULL_VOLUME then
		// we have a stored value, return it.
		return vol;
	endif;
	
	//OK, nothing stored, see if we can get it from the fleet file.
	vol := self.getMyContainerVolume;
	
	return vol;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
