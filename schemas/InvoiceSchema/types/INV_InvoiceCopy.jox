	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="c4c8e2da-bf4d-4d27-83ff-c8cf5425c5eb">
        <source>loadData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2023 navtnr20	TFS CR 55303	Task 55531: UI - Invoice NEW UI Changes Invoice Copy

*/

vars
	comm : CM_Commodity;
	ti : CM_TrackedItem;

begin
	// sheet general
	self.tblInvProperties.setValueByName( ETRow_Debtor, self.myCurrentInvoice.debtor.name );
	self.tblInvProperties.setValueByName( ETRow_InvoiceTypeCode, self.myCurrentInvoice.invoiceType.description);
	//sheet voyage
	if self.myCurrentInvoice.myVoyage &lt;&gt; null then
		self.tblVoyage.setValueByName(ETRow_Voyage,self.myCurrentInvoice.myVoyage.code);
		self.tblVoyage.setValueByName(ETRow_VoyageDesc,self.myCurrentInvoice.myVoyage.description);
		self.tblVoyage.setValueByName(ETRow_ArrivalTS,self.myCurrentInvoice.myVoyage.arrivedDT);
		self.tblVoyage.setValueByName(ETRow_DepartureTS,self.myCurrentInvoice.myVoyage.departedDT);
		
	endif;
	// sheet cargo specific

	// ### JIRA 33006 15OCT2024 NAVAB1
	if self.myCurrentInvoice.myTrackedItem	&lt;&gt; null then 
	
		ti := self.myCurrentInvoice.myTrackedItem;
		
		self.tblCargo.setValueByName(ETRow_CargoType,ti.cargoTypeDescr);
		self.tblCargo.setValueByName(ETRow_CargoOperator,ti.operatorCode);
		self.tblCargo.setValueByName(ETRow_CargoTA,ti.terminalAreaId);
		self.tblCargo.setValueByName(ETRow_CargoLocation,ti.locationId);
		self.tblCargo.setValueByName(ETRow_CargoId,ti.id);
		self.tblCargo.setValueByName( ETRow_ReceivedDT, ti.receivedDT.asStringJMT());
		self.tblCargo.setValueByName( ETRow_ReleaseDT, ti.releasedDT.asStringJMT());

		// ### JIRA 33006 15OCT2024 NAVAB1
		self.populateCargoCommodities(ti.myCargoType);
		self.populateCargoSubTypes(ti.myCargoType);
		
		comm := ti.getCommodityObject();
		if comm &lt;&gt; null then
			self.cmbCargoCommodity.listObject := comm;
			self.tblCargo.setValueByControlName(self.cmbCargoCommodity.name,self.cmbCargoCommodity.text);
		endif;
		
		self.cmbCargoSubType.listObject := ti.myProduct;
		self.tblCargo.setValueByControlName(self.cmbCargoSubType.name,self.cmbCargoSubType.text);
	endif;	
	/* ### JIRA 33006 15OCT2024 NAVAB1
	if self.myCurrentCargoType	&lt;&gt; null then 
		self.tblCargo.setValueByName(ETRow_CargoType,self.myCurrentCargoType.id);
	elseif self.myCurrentTIOperator &lt;&gt; null then
		self.tblCargo.setValueByName(ETRow_CargoOperator,self.myCurrentTIOperator.code);
	elseif	self.myCurrentTI &lt;&gt; null then
		self.tblCargo.setValueByName(ETRow_CargoTA,self.myCurrentTI.terminalAreaId);
	elseif self.myCurrentTILocation &lt;&gt; null then
		self.tblCargo.setValueByName(ETRow_CargoLocation,self.myCurrentTILocation.ident);
	endif;
	
	if self.myCurrentInvoice.myTrackedItem &lt;&gt; null and self.myCurrentInvoice.myTrackedItem.receivedDT &lt;&gt; null then
		self.tblCargo.setValueByName( ETRow_ReceivedDT, self.myCurrentInvoice.myTrackedItem.receivedDT.asStringJMT());
	endif;
	if self.myCurrentInvoice.myTrackedItem &lt;&gt; null and  self.myCurrentInvoice.myTrackedItem.releasedDT &lt;&gt; null then
		self.tblCargo.setValueByName( ETRow_ReleaseDT, self.myCurrentInvoice.myTrackedItem.releasedDT.asStringJMT());
	endif;
	*/
	
	
	
	
	//sheet bol
	if self.myCurrentInvoice.myBOL &lt;&gt; null then
		self.tblBOL.setValueByName(ETRow_BolSelect, self.myCurrentInvoice.myBOL.number);
	endif;
	
	// sheet release specific
	if self.myCurrentInvoice.myReleaseRequest &lt;&gt; null then
		self.tblRelease.setValueByName(ETRow_ReleaseRequest, self.myCurrentInvoice.myReleaseRequest.code);
	endif;
	// sheet cargo group specific
	if self.myCurrentCargoGroup &lt;&gt; null then
		self.tblCargoGroup.setValueByName(ETRow_CargoGroupType, self.myCurrentCargoGroup.cargoTypeDescr);
		self.tblCargoGroup.setValueByName(ETRow_CargoGroupId, self.myCurrentCargoGroup.id);
	endif;
	
	//sheet booking specific
	if self.myCurrentInvoice.myBookingRef &lt;&gt; null then
		self.tblBooking.setValueByName(ETRow_BookingSelect, self.myCurrentInvoice.myBookingRef.bookingReference);
	endif;
	//sheet purchase order
	if self.myCurrentInvoice.purchaseOrderNumber &lt;&gt; null then
		self.txtPONumber.text := self.myCurrentInvoice.purchaseOrderNumber;
	endif;
		
epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="ed596d09-f588-4ab5-aa7d-51aa413ccb85">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2023	navmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
09 Aug 2024		navnk30 Bug 65367: FR - 54086 - Copy Invoice Cargo Group selection

*/

begin
	self.doCmbDebtorBuild(self.cmbDebtorInvProp); 
	self.doCmbStatusInvPropBuild(self.myCurrentInvoice.myInvoiceProcess, self.myCurrentInvoice.status);	
	self.doCmbCategoryBuild();
	self.doCmbInvoiceTypeBuild(self.cmbInvTypeInv, false);
	self.doCmbCargoGroupIdBuild(self.myCurrentInvoice.myCargoGroup);	// 09.08.2024 navnk30 #65367
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCargoOperLocns" id="06fa3ef1-8679-4a82-8a5d-aa31760ff07b">
        <source>populateCargoOperLocns() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2023 navtnr20	TFS CR 55303	Task 55531: UI - Invoice NEW UI Changes Invoice Copy

*/

vars

begin
	inheritMethod();
	self.cmbCargoOper.listIndex	:= self.cmbCargoOper.findObject(self.myCurrentTIOperator);
	self.cmbCargoLoc.listIndex	:= self.cmbCargoLoc.findObject(self.myCurrentTILocation);
	self.cmbCargoTA.listIndex	:= self.cmbCargoTA.findObject(self.myCurrentTI);
	self.cmbCargoTypeInvP.listIndex	:= self.cmbCargoTypeInvP.findObject(self.myCurrentCargoType);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCurrentInvoice" id="77886ab4-cedc-45f0-b64a-647288f88e03">
        <updating/>
        <source>setCurrentInvoice(_invoice : CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Apr 2023 navtnr20	TFS CR 55303	Task 55531: UI - Invoice NEW UI Changes Invoice Copy

*/

vars

begin
	self.myCurrentInvoice := _invoice;
	
	if self.myCurrentInvoice &lt;&gt; null then // navmk20	Bug 57663
		self.myCurrentCargoGroup := self.myCurrentInvoice.myCargoGroup; // navmk20	Bug 57663
	endif;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d98615fa-aa62-41f6-a8bb-07fc8ff02bc9">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Apr 2023 navtnr20	TFS CR 55303	Task 55531: UI - Invoice NEW UI Changes Invoice Copy

*/

vars
	now		: TimeStamp;
	dateStr,
	timeStr	: String;
	sheet : CMUI_Sheet;
begin
	inheritMethod();
	
	dateStr := now.date().format("dd/MM/yyy");
	timeStr := now.time().format("HH:mm");
	//self.mskStartDate.text := dateStr;
	//self.mskStartTime.text := timeStr;
	self.tblCargoGroup.maxLength := 20;
	self.btnSearch.parent := self.btnSaveBase.parent;
	self.btnSearch.visible	:= false;
	self.btnSearch.top	:= self.btnSaveBase.top;
	self.btnSearch.left	:= self.btnSaveBase.left+60;
	self.loadData();
	self.tblInvProperties.setValueByName( ETRow_StartDate, dateStr );
	self.tblInvProperties.setValueByName( ETRow_StartTime, timeStr );
	self.caption := self.caption &amp; self.myCurrentInvoice.debtor.name; // ### TFS BUG 58106 23MAY2023 NAVAB
	self.tblInvProperties.showRowByName(ETRow_StartDate, false); //navtnr20 13-04-2023 55531
	self.tblInvProperties.showRowByName(ETRow_StartTime, false);  //navtnr20 13-04-2023 55531
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4eec0630-cbf2-4e34-b375-91dd2c01be4c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 April 2023 09:54:46.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025939, locale);
	btnSearch.translateCaption(Xlat_0025940, locale);
end;</source>
    </JadeMethod>
</GUIClass>
