    <JadeMethod name="getDataForBRItem" id="ebf67190-1f89-410e-a3c9-d9307d2c0306">
        <source>getDataForBRItem(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean;
/*
	Created on 22 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return getDataForDefSpecial(_attrName, _heading, _headings, _data);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataForDefSpecial" id="73683e89-b840-4d19-ae03-62505404dcbf">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
/*
Created:     10 May 2002 by cnwth2

Purpose:		to handle the output of the bookingRef thumbnail Def for attributes needing special treatment  

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
17 Jun 2013	cnwcs5	par 31670
04 Apr 2019 jlgzm1	TFS43864 Booking screen performance
16 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
24 Jul 2023	navma1	ChangeRequest 59275: MTN - Transport Mode should be used to filter prenotes
*/

vars
	str				: String;
	firstTime, 
	invalid,
	showChildren	: Boolean;
	hazard			: CM_Hazard;
	hazDict			: CM_HazardByCodeDict;
	ti, child		: CM_TrackedItem;
	brItem 			: CM_BookingRefItem;
	prod			: CM_Product;
	coll			: CM_TIArray;
	voyage			: CM_Voyage;
	oper            : CM_Operator;
begin
	
	if _attrName = ETRow_MyOperator then
		oper := self.myOperator;
		if oper &lt;&gt; null then
			_headings.add(_heading);
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then					// TFS 53362
				_data.add(oper.description &amp; '  ' &amp; oper.code);							// TFS 53362
			else																		// TFS 53362
				_data.add(oper.code &amp; '  ' &amp; oper.description);
			endif;																		// TFS 53362
			return true;
		else
			return true;
		endif;
		
	elseif _attrName = ETRow_IsoType then
		brItem := self.allBookingRefItems.first;
		
		_headings.add(_heading);
		
		if brItem &lt;&gt; null and brItem.myISOType &lt;&gt; null then
			_data.add(brItem.myISOType.getTableDisplay);
		else
			_data.add(null);
		endif;
		
		return true;

	elseif _attrName = ETRow_IsStock or _attrName = ETRow_IsStockBookingRef then
		_headings.add(_heading);
		_data.add(self.isStockBookingRef.cnEcGetYesNo);
		
		return true;
	
	elseif _attrName = ETRow_Voyage then
		_headings.add(_heading);
		
		voyage := self.myVoyage;
		
		if voyage &lt;&gt; null then
			_data.add(voyage.code &amp; '  ' &amp; voyage.description);
		else
			_data.add(null);
		endif;
		
		return true;
		
	elseif _attrName = ETRow_ConsignorCode then
		_headings.add(_heading);
		
		if self.myConsignor &lt;&gt; null then
			_data.add(self.myConsignor.code &amp; '   ' &amp; self.myConsignor.description);
		else
			_data.add(null);
		endif;
		
		return true;
		
	elseif _attrName = ETRow_ConsigneeCode then		
		_headings.add(_heading);
		
		if self.myConsignee &lt;&gt; null then			
			_data.add(self.myConsignee.code &amp; '   ' &amp; self.myConsignee.description);
		else
			_data.add(null);
		endif;
		
		return true;
		
	elseif _attrName = ETRow_Vessel then
		_headings.add(_heading);
		_data.add(self.vesselCode &amp; '  ' &amp; self.vesselName);
		return true;
					
	elseif _attrName = ETRow_DischargePorts then
		firstTime := true;
		
		foreach str in self.allDischargePorts do
			if firstTime then
				firstTime := false;
				_headings.add(_heading);
			else
				_headings.add(' ' );
			endif;
			
			_data.add(str);		
		endforeach;
		
		return true;

	elseif _attrName = ETRow_AllTIHazards then 
		firstTime := true;
		
		create hazDict transient;
		self.getAllItemTIIHazards(hazDict);
		
		foreach hazard in hazDict do
			if firstTime then
				firstTime := false;
				str := _heading;
			else
				str := ' ';
			endif;
			
			_headings.add(str);
			_data.add(hazard.getTableDisplay(false, true)&amp; " " &amp; hazard.description);		
		endforeach;
		
		return true;
	elseif _attrName = ETRow_WeightTotal then
		_headings.add(_heading);
		_data.add(self.getTotalWeight.asStringWeightJMT()); // dh 29/2/2008 ccms 1618
		return true;

	elseif _attrName = ETRow_MyVessel then
		_headings.add(_heading);
		_data.add(self.vesselName);
		
		return true;
		
	elseif _attrName = ETRow_CargoType then
		brItem := self.allBookingRefItems.first;
		
		_headings.add(_heading);
		
		if brItem &lt;&gt; null then
			_data.add(brItem.cargoTypeDescr);
		else
			_data.add(null);
		endif;
		
		return true;
	  
	elseif _attrName = ETRow_Temperature then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			str := brItem.getTempString(false);
		endif;
		
		_headings.add(_heading);
		_data.add(str);
		
		return true;
		
	elseif _attrName = ETRow_TiRecieved then//cnwyl1 changed it for par15152
		create coll transient;
		
		firstTime := true;
		
		// blank row before we show items received so far
		_headings.add(''); _data.add('');
		
		//tfs43864
		if self.allTIs.size &gt; 1000 then
			return true;
		endif;
		
		self.getPrenotedTrackedItems (coll,null);					//24.07.2023 navma1 #59275

		foreach ti in coll do
			if firstTime then
				firstTime 	:= false;
				_headings.add( app.getErrorString(PreNotified) );	//27 Sep 2013	NDL	Par 32582
			else		
				_headings.add(null); 
			endif;
			_data.add(ti.getOidAsString); // TFS 4052
		endforeach;
		
		firstTime 		:= true;
		showChildren	:= self.myTerminal.getConfig(ShowChildOnBookThumb).Boolean;
		
		coll.clear;
		self.getReceivedTrackedItems (coll);
		
		foreach ti in coll do
			if firstTime then
				firstTime 	:= false;
				_headings.add( app.getErrorString(ItemsReceived) );	//27 Sep 2013	NDL	Par 32582
			else		
				_headings.add(null); 
			endif;
			
			_data.add(ti.getOidAsString); // TFS 4052
			
			if showChildren then
				foreach child in ti.allChildren do
					_headings.add("");
					_data.add(child.getOidAsString);	//15 Dec 2017	NDL	TFS 8228
				endforeach;
			endif;
		endforeach;
		
		return true;
		
	elseif _attrName = ETRow_MyProduct then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			prod := brItem.myProduct;

			if prod &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, prod, invalid);
				
				str := prod.description;

				if not invalid then
					_headings.add(_heading);
					_data.add(str);
				endif;
			endif;
		endif;
		
		return true;
		
	elseif _attrName = ETRow_MyQuantity then
		if self.myProduct &lt;&gt; null then
			_headings.add(_heading);
			_data.add(self.productQuantity.String);
		endif;
		
		return true;
		
	elseif 	_attrName = ETRow_MyLength or
			_attrName = ETRow_MyHeight or
			_attrName = ETRow_MyWidth or
			_attrName = ETRow_MyVolume or
			_attrName = ETRow_MyWeight or
			_attrName = ETRow_MyDensity then
		
		brItem := self.allBookingRefItems.first;
		
		if brItem = null or brItem.myProduct = null then
			return true;
		endif;
		
	elseif _attrName = ETRow_MyLengthString then
		brItem := self.allBookingRefItems.first;
		
		if brItem = null or brItem.lengthString = null then
			return true;
		endif;
		
	elseif _attrName = ETRow_MyHeightString then
		brItem := self.allBookingRefItems.first;
		
		if brItem = null or brItem.heightString = null then
			return true;
		endif;
		
	elseif _attrName = ETRow_MyWidthString then
		brItem := self.allBookingRefItems.first;
		
		if brItem = null or brItem.widthString = null then
			return true;
		endif;

		if brItem = null or brItem.myProduct = null then
			return true;
		endif;
	
	elseif _attrName = ETRow_IsControlledAtmosphere then				// CCMS 1654 - slw 11/09/2008
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null and brItem.getIsControlledAtmosphere then
			_headings.add(_heading);
			_data.add(brItem.getIsControlledAtmosphere.getYesNo);
		endif;
		
		return true;
		
	elseif _attrName = ETRow_CarbonDioxide then							// CCMS 1654 - slw 11/09/2008
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null and brItem.getIsControlledAtmosphere then
			_headings.add(_heading);
			_data.add(brItem.getCarbonDioxide.asNullCarbonDioxide);
		endif;
		
		return true;
		
	elseif _attrName = ETRow_Oxygen then								// CCMS 1654 - slw 11/09/2008
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null and brItem.getIsControlledAtmosphere then
			_headings.add(_heading);
			_data.add(brItem.getOxygen.asNullOxygen);
		endif;
		
		return true;
		
	elseif _attrName = ETRow_CurtainsIn then							// CCMS 1654 - slw 11/09/2008
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null and brItem.getIsControlledAtmosphere then
			_headings.add(_heading);
			_data.add(brItem.getCurtainsIn.getYesNo);
		endif;
		
		return true;
	endif;
	
	return inheritMethod(_attrName, _heading, _headings, _data);
epilog
	delete hazDict;
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
