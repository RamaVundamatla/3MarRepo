    <DbClassMap file="Jtd"/>
    <JadeMethod name="create" id="441c0258-8983-49e5-84fb-47215d8a81ea">
        <updating/>
        <source>create() updating;

vars
	md : JtdTrxGenMethodDesc;
	mp : JtdMethodProfile;
	
begin
	self.jtdName := "Default";
	
	if app.jtdMyContext = null then
		return;
	endif;
	
	foreach md in app.jtdMyContext.jtdAllTrxGenMethodDescs do
		if md.jtdClassAndMethodExist then
			create mp transient;
			
			mp.jtdSetClassAndMethodNames(md.jtdClassName, md.jtdMethodName);
			mp.jtdSetNumCalls(1);
			mp.jtdSetTrxGenMethodDesc(md);
			
			self.jtdAllMethodProfiles.add(mp);
		endif;
	endforeach;
	
	self.jtdRandomSelection := true;
	self.jtdDefaultThinkSecs := 0;
end;</source>
    </JadeMethod>
</Class>
