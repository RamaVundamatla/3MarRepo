    <JadeMethod name="compareTo" id="37691145-1796-4bc6-bd95-7c30f8997289">
        <updating/>
        <source>compareTo(_ediTI: CM_EDILoadListTI; _ignoreFields: StringArray) updating; 
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
// 26 Jun 2012	cnwrs1	Par 31625 DPH Load list changes
// 02 May 2016	cnwdap1	TFS #1699 VGM Comparison changes
// 28 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
// 22/03/2018 	JLGNS1	Bug 37745: SPT - Seal Numbers not loading as Vent Seals from Load List
// 06 June 2018	jlgrh7 TFS #38887 SNO - Re: 38076 Cargo Comparison and seal issue
vars
	selfISOGroup, ediISOGroup : CM_ISOTypeGroup;
	selfISOType, ediISOType : CM_ISOType;
	selfContentStatus, ediTiContentStatus : String;									//navra1 - CR 64620/Task 64658 - 8th July 2024
	cs : CM_ContentsStatus;															//navra1 - CR 64620/Task 64658 - 8th July 2024	
begin	
	self.allDiscrepancyAttributes.clear;
	
	if (not _ignoreFields.includes(ETRow_Bol)) and self.bol &lt;&gt; _ediTI.bol then
		self.allDiscrepancyAttributes.add(ETRow_Bol);
	endif;
	if (not _ignoreFields.includes(ETRow_BookingRef)) and self.bookingRef &lt;&gt; _ediTI.bookingRef then
		self.allDiscrepancyAttributes.add(ETRow_BookingRef);
	endif;
	if (not _ignoreFields.includes(ETRow_CarbonDioxide)) and self.getCarbonDioxide &lt;&gt; _ediTI.getCarbonDioxide then
		self.allDiscrepancyAttributes.add(ETRow_CarbonDioxide);
	endif;
	if (not _ignoreFields.includes(ETRow_Commodity)) and self.commodity &lt;&gt; _ediTI.commodity then
		self.allDiscrepancyAttributes.add(ETRow_Commodity);
	endif;
	if (not _ignoreFields.includes(ETRow_Consignee)) and self.consignee &lt;&gt; _ediTI.consignee then		//ccms 1915 - PAR 22271
		self.allDiscrepancyAttributes.add(ETRow_Consignee);
	endif;
	if (not _ignoreFields.includes(ETRow_SpecialStowage)) and self.specialStowage &lt;&gt; _ediTI.specialStowage then		//ccms 1915 - PAR 22271
		self.allDiscrepancyAttributes.add(ETRow_SpecialStowage);
	endif;
	if (not _ignoreFields.includes(ETRow_Consignor)) and self.consignor &lt;&gt; _ediTI.consignor then
		self.allDiscrepancyAttributes.add(ETRow_Consignor);
	endif;
	// PAR 12246 Compare destinations
	if (not _ignoreFields.includes(ETRow_DestinationPort)) and self.destinationPort &lt;&gt; _ediTI.destinationPort then
		self.allDiscrepancyAttributes.add(ETRow_DestinationPort);
	endif;
	if (not _ignoreFields.includes(ETRow_DischargePort)) then //PAR25362 cnwsh3 Tranship cargo onboard the inbound voyage compare the tranship discharge port, 
		if self.exportTshipOnboardInboundVoyge() then		  //not the current discharge port
			if self.transhipDischargePort &lt;&gt; _ediTI.dischargePort then
				self.allDiscrepancyAttributes.add(ETRow_DischargePort);
			endif;
		else
			if self.dischargePort &lt;&gt; _ediTI.dischargePort then
				self.allDiscrepancyAttributes.add(ETRow_DischargePort);
			endif;
		endif;
	endif;
	if (not _ignoreFields.includes(ETRow_FreightForwarder)) and self.freightForwarder &lt;&gt; _ediTI.freightForwarder then
		self.allDiscrepancyAttributes.add(ETRow_FreightForwarder);
	endif;
	if (not _ignoreFields.includes(ETRow_Hazardous)) and self.hazardous &lt;&gt; _ediTI.hazardous then
		self.allDiscrepancyAttributes.add(ETRow_Hazardous);
	endif;
	if (not _ignoreFields.includes(ETRow_Humidity)) and self.getHumidity &lt;&gt; _ediTI.getHumidity then	//ccms 1550
		self.allDiscrepancyAttributes.add(ETRow_Humidity);
	endif;
	if (not _ignoreFields.includes(ETRow_IsoGroup)) then	//19  Aug 2015	NDL	Par 36779
		
		if self.isoGroup &lt;&gt; null then
			selfISOGroup := app.myRoot.allISOTypeGroups[self.isoGroup.trimBlanks];
		else
			selfISOType := app.myRoot.allISOTypes[self.isoType.trimBlanks];
			if selfISOType &lt;&gt; null then
				selfISOGroup := selfISOType.myISOTypeGroup;
			endif;
		endif;
		
		if _ediTI.isoGroup &lt;&gt; null then
			ediISOGroup := app.myRoot.allISOTypeGroups[_ediTI.isoGroup.trimBlanks];
		else
			ediISOType := app.myRoot.allISOTypes[_ediTI.isoType.trimBlanks];
			if ediISOType &lt;&gt; null then
				ediISOGroup := ediISOType.myISOTypeGroup;
			endif;
		endif;
		
		if selfISOGroup &lt;&gt; ediISOGroup then
			self.allDiscrepancyAttributes.add(ETRow_IsoTypeGroup);  // Yes it is different to the ignore fields row!!
		endif;
		
	endif;
	if (not _ignoreFields.includes(ETRow_IsoType)) and self.isoType &lt;&gt; _ediTI.isoType then
		// ### CCMS 1221 from here
	/*	if (not _ignoreFields.includes(ETRow_IsoGroup)) then	//cnwrs1 CCMS 1137 15 June 2010
			selfISOType := app.myRoot.allISOTypes[self.isoType.trimBlanks];
			if selfISOType &lt;&gt; null then
				selfISOGroup := selfISOType.myISOTypeGroup;
			endif;
			ediISOType := app.myRoot.allISOTypes[_ediTI.isoType.trimBlanks];
			if ediISOType &lt;&gt; null then
				ediISOGroup := ediISOType.myISOTypeGroup;
			endif;
			if selfISOGroup = null then
				self.allDiscrepancyAttributes.add(ETRow_IsoType);
			elseif selfISOGroup &lt;&gt; ediISOGroup then
				self.allDiscrepancyAttributes.add(ETRow_IsoType);
			endif;  
		else
		// ### CCMS 1221 to here  */
			self.allDiscrepancyAttributes.add(ETRow_IsoType);
		//endif;
	endif;
	if (not _ignoreFields.includes(ETRow_OutOfGauge)) and self.outOfGauge &lt;&gt; _ediTI.outOfGauge then
		self.allDiscrepancyAttributes.add(ETRow_OutOfGauge);
	endif;
	if (not _ignoreFields.includes(ETRow_OperatorCode)) and self.operatorCode &lt;&gt; _ediTI.operatorCode then
		self.allDiscrepancyAttributes.add(ETRow_OperatorCode);
	endif;
	if (not _ignoreFields.includes(ETRow_Oxygen)) and self.getOxygen &lt;&gt; _ediTI.getOxygen then
		self.allDiscrepancyAttributes.add(ETRow_Oxygen);
	endif;
	if (not _ignoreFields.includes(ETRow_MyTranshipToPort)) and 
	    self.myTranshipToPort &lt;&gt; _ediTI.myTranshipToPort then
		self.allDiscrepancyAttributes.add(ETRow_MyTranshipToPort);
	endif;
	//19 May 2010	NDL	Par 24243
	if (not _ignoreFields.includes(ETRow_SealCustoms)) and self.sealCustoms &lt;&gt; _ediTI.sealCustoms then
		self.allDiscrepancyAttributes.add(ETRow_SealCustoms);
	endif;
	if (not _ignoreFields.includes(ETRow_SealNum)) and self.sealNum &lt;&gt; _ediTI.sealNum then
		self.allDiscrepancyAttributes.add(ETRow_SealNum);
	endif;
	if (not _ignoreFields.includes(ETRow_SealNumberVent)) and self.sealNumberVent &lt;&gt; _ediTI.sealNumberVent then
		self.allDiscrepancyAttributes.add(ETRow_SealNumberVent);
	endif;
	if (not _ignoreFields.includes(ETRow_SealShipper)) and self.sealShipper &lt;&gt; _ediTI.sealShipper then
		self.allDiscrepancyAttributes.add(ETRow_SealShipper);
	endif;
	//if (not _ignoreFields.includes(ETRow_SealTerminalOperator)) and self.sealTerminalOperator &lt;&gt; _ediTI.sealTerminalOperator then						//-TFS38887 
	if (not _ignoreFields.includes(ETRow_SealNumTerminalOperator)) and self.sealTerminalOperator &lt;&gt; _ediTI.sealTerminalOperator then				//+TFS38887
		self.allDiscrepancyAttributes.add(ETRow_SealTerminalOperator);
	endif;
	if (not _ignoreFields.includes(ETRow_SealNumUnknown)) and self.sealUnknown &lt;&gt; _ediTI.sealUnknown then	//Bug 37745
		//self.allDiscrepancyAttributes.add(ETRow_SealNumUnknown);											//Bug 37745  //-TFS38887
		self.allDiscrepancyAttributes.add(ETRow_SealUnknown);											//+TFS38887
	endif;
	if (not _ignoreFields.includes(ETRow_Temperature)) and self.temperature &lt;&gt; _ediTI.temperature then
		if self.temperature &lt;= NULL_TEMPERATURE
		and _ediTI.temperature &lt;= NULL_TEMPERATURE then
			//actually ok if they don't match
		else
			self.allDiscrepancyAttributes.add(ETRow_Temperature);
		endif;
	endif;

	if (not _ignoreFields.includes(ETRow_Vent)) and self.vent &lt;&gt; _ediTI.vent then
		self.allDiscrepancyAttributes.add(ETRow_Vent);
	endif;
	if (not _ignoreFields.includes(ETRow_IsWaterCooled)) and self.isWaterCooled &lt;&gt; _ediTI.isWaterCooled then
		self.allDiscrepancyAttributes.add(ETRow_IsWaterCooled);
	endif;
	//if (not _ignoreFields.includes(ETRow_Weight)) and self.weight &lt;&gt; _ediTI.weight  then				//-cnwml2 MSL CCMS 1017
	if (not _ignoreFields.includes(ETRow_TotalWeight)) and self.weight &lt;&gt; _ediTI.weight then				//+cnwml2 MSL CCMS 1017
		//self.allDiscrepancyAttributes.add(ETRow_Weight);							//-cnwml2 MSL CCMS 1017
		self.allDiscrepancyAttributes.add(ETRow_TotalWeight);						//+cnwml2 MSL CCMS 1017
	endif;
	//cnwrs1 CCMS 1137 08 June 2010
	if (not _ignoreFields.includes(ETRow_TranshipVoyageCode)) then
//	    self.transhipVoyageCode &lt;&gt; _ediTI.transhipVoyageCode then	// cnwrl1 09/06/2010 PAR 24299 - what it was
		if self.exportTshipOnboardInboundVoyge and
		   self.myTrackedItem.myVoyageTranshipExport.code = _ediTI.getTranshipVoyageCode() then
			return;
		endif;
	    if self.getTranshipVoyageCode() &lt;&gt; _ediTI.getTranshipVoyageCode() then
			self.allDiscrepancyAttributes.add(ETRow_TranshipVoyageCode);
		endif;
	endif;
	//cnwrs1 CCMS 1137 28 June 2010
	if (not _ignoreFields.includes(ETRow_TranshipBOLId)) and 
	    self.transhipBOLId &lt;&gt; _ediTI.transhipBOLId then
		self.allDiscrepancyAttributes.add(ETRow_TranshipBOLId);
	endif;
	//cnwrs1 CCMS 1137 28 June 2010
	if (not _ignoreFields.includes(ETRow_TranshipBookingRef)) and 
	    self.transhipBOLId &lt;&gt; _ediTI.transhipBookingRef then
		self.allDiscrepancyAttributes.add(ETRow_TranshipBookingRef);
	endif;
	
	if (not _ignoreFields.includes(ETRow_IsCertifiedWeight)) 						// TFS #1699
	and self.isWeightCertified &lt;&gt; _ediTI.isWeightCertified then						// TFS #1699
		self.allDiscrepancyAttributes.add(ETRow_IsCertifiedWeight);					// TFS #1699
	endif;																			// TFS #1699
	if (not _ignoreFields.includes(ETRow_WeightCertifiedName)) 						// TFS #1699
	and self.weightCertifiedName &lt;&gt; _ediTI.weightCertifiedName then					// TFS #1699
		self.allDiscrepancyAttributes.add(ETRow_WeightCertifiedName);				// TFS #1699
	endif;																			// TFS #1699
	if (not _ignoreFields.includes(ETRow_WeightCertifiedReference)) 				// TFS #1699
	and self.weightCertifiedReference &lt;&gt; _ediTI.weightCertifiedReference then		// TFS #1699
		self.allDiscrepancyAttributes.add(ETRow_WeightCertifiedReference);			// TFS #1699
	endif;																			// TFS #1699

//	if (not _ignoreFields.includes(ETRow_CurtainsIn)) and self.curtainsIn &lt;&gt; _ediTI.curtainsIn then
//		self.allDiscrepancyAttributes.add(ETRow_CurtainsIn);
//	endif;

	//navra1 - CR 64620/Task 64658 - 8th July 2024 - start	
	if (not _ignoreFields.includes(ETRow_ContentsStatus)) then		
		if self.contentsStatus &lt;&gt; _ediTI.contentsStatus then
			self.allDiscrepancyAttributes.add(ETRow_ContentsStatus);
		endif;	
	endif;
	
	if (not _ignoreFields.includes(ETRow_ContainerLength)) then
		if self.containerLength &lt;&gt; _ediTI.containerLength then
			self.allDiscrepancyAttributes.add(ETRow_ContainerLength);
		endif;
	endif;
	//navra1 - CR 64620/Task 64658 - 8th July 2024 - end
end;</source>
        <Parameter name="_ediTI" type="CM_EDILoadListTI"/>
        <Parameter name="_ignoreFields" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="compareToUserDefinedTI" id="5d719ade-3508-4ceb-933a-9d8960551332">
        <updating/>
        <source>compareToUserDefinedTI(_ediTI: CM_EDICargoTI; _ignoreFields: StringArray) updating; //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
// 26 Jun 2012	cnwrs1	Par 31625 DPH Load list changes
// 28 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
// 22/03/2018 	JLGNS1	Bug 37745: SPT - Seal Numbers not loading as Vent Seals from Load List
// 06 June 2018	jlgrh7 TFS #38887 : SNO - Re: 38076 Cargo Comparison and seal issue
vars
	selfISOGroup, ediISOGroup : CM_ISOTypeGroup;
	selfISOType, ediISOType : CM_ISOType;
	selfContentStatus, ediTiContentStatus : String;									//navra1 - CR 64658/Task 64658 - 8th July 2024
	cs : CM_ContentsStatus;															//navra1 - CR 64658/Task 64658 - 8th July 2024
	selfContainerLength, ediTiContainerLength : CMIF_ContainerLength;				//navra1 - CR 64658/Task 64658 - 8th July 2024
begin
	self.allDiscrepancyAttributes.clear;
	
	if (not _ignoreFields.includes(ETRow_Bol)) and self.bol &lt;&gt; _ediTI.bol then
		self.allDiscrepancyAttributes.add(ETRow_Bol);
	endif;
	if (not _ignoreFields.includes(ETRow_BookingRef)) and self.bookingRef &lt;&gt; _ediTI.bookingRef then
		self.allDiscrepancyAttributes.add(ETRow_BookingRef);
	endif;
// not carbonDioxide
	if (not _ignoreFields.includes(ETRow_Commodity)) and self.commodity &lt;&gt; _ediTI.commodity then
		self.allDiscrepancyAttributes.add(ETRow_Commodity);
	endif;
	if (not _ignoreFields.includes(ETRow_Consignee)) and self.consignee &lt;&gt; _ediTI.consignee then	//ccms 1915 - PAR 22271
		self.allDiscrepancyAttributes.add(ETRow_Consignee);
	endif;
	if (not _ignoreFields.includes(ETRow_Consignor)) and self.consignor &lt;&gt; _ediTI.consignor then
		self.allDiscrepancyAttributes.add(ETRow_Consignor);
	endif;
// not cooledType curtainsIn
	// PAR 12246 Compare destinations
	if (not _ignoreFields.includes(ETRow_DestinationPort)) and self.destinationPort &lt;&gt; _ediTI.destinationPort then
		self.allDiscrepancyAttributes.add(ETRow_DestinationPort);
	endif;
	if (not _ignoreFields.includes(ETRow_DischargePort)) and self.dischargePort &lt;&gt; _ediTI.dischargePort then
		self.allDiscrepancyAttributes.add(ETRow_DischargePort);
	endif;	
	if (not _ignoreFields.includes(ETRow_FreightForwarder)) and self.freightForwarder &lt;&gt; _ediTI.freightForwarder then
		self.allDiscrepancyAttributes.add(ETRow_FreightForwarder);
	endif;
	if (not _ignoreFields.includes(ETRow_Hazardous)) and self.hazardous &lt;&gt; _ediTI.isHazardous() then	//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
		self.allDiscrepancyAttributes.add(ETRow_Hazardous);
	endif;
// not height humidity imCodes
	if (not _ignoreFields.includes(ETRow_IsoGroup)) then	//19  Aug 2015	NDL	Par 36779
		
		if self.isoGroup &lt;&gt; null then
			selfISOGroup := app.myRoot.allISOTypeGroups[self.isoGroup.trimBlanks];
		else
			selfISOType := app.myRoot.allISOTypes[self.isoType.trimBlanks];
			if selfISOType &lt;&gt; null then
				selfISOGroup := selfISOType.myISOTypeGroup;
			endif;
		endif;
		
		if _ediTI.isoTypeGroup &lt;&gt; null then
			ediISOGroup := app.myRoot.allISOTypeGroups[_ediTI.isoTypeGroup.trimBlanks];
		else
			ediISOType := app.myRoot.allISOTypes[_ediTI.isoType.trimBlanks];
			if ediISOType &lt;&gt; null then
				ediISOGroup := ediISOType.myISOTypeGroup;
			endif;
		endif;
		
		if selfISOGroup &lt;&gt; ediISOGroup then
			self.allDiscrepancyAttributes.add(ETRow_IsoTypeGroup); // Yes it is different to the ignore fields row!!
		endif;
		
	endif;
	if (not _ignoreFields.includes(ETRow_IsoType)) and self.isoType &lt;&gt; _ediTI.isoType then
		// ### CCMS 1221 from here
	/*	if (not _ignoreFields.includes(ETRow_IsoGroup)) then //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
			selfISOType := app.myRoot.allISOTypes[self.isoType.trimBlanks];
			if selfISOType &lt;&gt; null then
				selfISOGroup := selfISOType.myISOTypeGroup;
			endif;
			ediISOType := app.myRoot.allISOTypes[_ediTI.isoType.trimBlanks];
			if ediISOType &lt;&gt; null then
				ediISOGroup := ediISOType.myISOTypeGroup;
			endif;
			if selfISOGroup = null then
				self.allDiscrepancyAttributes.add(ETRow_IsoType);
			elseif selfISOGroup &lt;&gt; ediISOGroup then
				self.allDiscrepancyAttributes.add(ETRow_IsoType);
			endif;
		else
		// ### CCMS 1221 to here */
			self.allDiscrepancyAttributes.add(ETRow_IsoType);
	//	endif;
	endif;
// not isWaterCooled length loadPort locationId myTranshipToPort
	if (not _ignoreFields.includes(ETRow_OperatorCode)) and self.operatorCode &lt;&gt; _ediTI.operatorCode then
		self.allDiscrepancyAttributes.add(ETRow_OperatorCode);
	endif;
// not opStatus outOfGuage overHeight overWidth overLength oxygen 
	if (not _ignoreFields.includes(ETRow_SealCustoms)) and self.sealCustoms &lt;&gt; _ediTI.sealCustoms then
		self.allDiscrepancyAttributes.add(ETRow_SealCustoms);
	endif;
	if (not _ignoreFields.includes(ETRow_SealNum)) and self.sealNum &lt;&gt; _ediTI.sealNum then
		self.allDiscrepancyAttributes.add(ETRow_SealNum);
	endif;
	if (not _ignoreFields.includes(ETRow_SealNumberVent)) and self.sealNumberVent &lt;&gt; _ediTI.sealNumberVent then
		self.allDiscrepancyAttributes.add(ETRow_SealNumberVent);
	endif;
	if (not _ignoreFields.includes(ETRow_SealShipper)) and self.sealShipper &lt;&gt; _ediTI.sealShipper then
		self.allDiscrepancyAttributes.add(ETRow_SealShipper);
	endif;
	if (not _ignoreFields.includes(ETRow_SealTerminalOperator)) and self.sealTerminalOperator &lt;&gt; _ediTI.sealTerminalOperator then
		self.allDiscrepancyAttributes.add(ETRow_SealTerminalOperator);
	endif;
	if (not _ignoreFields.includes(ETRow_SealNumUnknown)) and self.sealUnknown &lt;&gt; _ediTI.sealUnknown then	//Bug 37745
		//self.allDiscrepancyAttributes.add(ETRow_SealNumUnknown);																							//Bug 37745	//-TFS38887
		self.allDiscrepancyAttributes.add(ETRow_SealUnknown);																										//+TFS38887
	endif;
// not shipperDesc state 
	if (not _ignoreFields.includes(ETRow_Temperature)) and self.temperature &lt;&gt; _ediTI.temperature then
		if self.temperature &lt;= NULL_TEMPERATURE
		and _ediTI.temperature &lt;= NULL_TEMPERATURE then
			//actually ok if they don't match
		else
			self.allDiscrepancyAttributes.add(ETRow_Temperature);
		endif;
	endif;
// not tranship
	if (not _ignoreFields.includes(ETRow_Vent)) and self.vent &lt;&gt; _ediTI.vent then
		self.allDiscrepancyAttributes.add(ETRow_Vent);
	endif;
	if (not _ignoreFields.includes(ETRow_TotalWeight)) and self.weight &lt;&gt; _ediTI.weight then	//+cnwml2 MSL CCMS 1017
		self.allDiscrepancyAttributes.add(ETRow_TotalWeight);									//+cnwml2 MSL CCMS 1017
	endif;
	if (not _ignoreFields.includes(ETRow_SpecialStowage)) and self.specialStowage &lt;&gt; _ediTI.specialStowage then	//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
		self.allDiscrepancyAttributes.add(ETRow_SpecialStowage);
	endif;
// not width
	//navra1 - CR 64620/Task 64658 - 8th July 2024 - start	
	if (not _ignoreFields.includes(ETRow_ContentsStatus)) then
		selfContentStatus := self.contentsStatus;		
		
		cs := app.myRoot.allContentsStatuses[_ediTI.contentsStatus];
		
		if cs = null then
			ediTiContentStatus := "N/A";
		else
			ediTiContentStatus := cs.abbreviation;
		endif;
		
		if ediTiContentStatus &lt;&gt; selfContentStatus then
			self.allDiscrepancyAttributes.add(ETRow_ContentsStatus);
		endif;		
	endif;
	
	if (not _ignoreFields.includes(ETRow_ContainerLength)) then
		if self.containerLength &lt;&gt; _ediTI.containerLength then
			self.allDiscrepancyAttributes.add(ETRow_ContainerLength);
		endif;
	endif;
	//navra1 - CR 64620/Task 64658 - 8th July 2024 - end
end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI"/>
        <Parameter name="_ignoreFields" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="exportTshipOnboardInboundVoyge" id="d8681ee5-d239-4e3f-9d19-181ee4ed45ba">
        <source>exportTshipOnboardInboundVoyge() : Boolean;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 01 September 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 01/09/2010 	cnwsh3		Check to determine whether the object is reporting on 
//							a tranship item on the export voyage (outbound leg) but the item is still
//							physically onboard the import voyage (inbound leg). PAR25362
//----------------------------------------------------------------------
vars

begin
	return self.comparisonMode = TI_IMEX_STATUS_EXPORT and self.isTranshipInbound();
		   
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDiscrepTI" id="9c3294bd-7fdd-448b-9b69-72eeb5298ac9">
