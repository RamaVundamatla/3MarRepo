    <JadeMethod name="getAmountForCurrencyCode" id="346c7b3c-d4fe-49db-9f28-6385db4f9f66">
        <updating/>
        <source>getAmountForCurrencyCode( _typeCode : String; _asAtDateTime : TimeStamp ):Decimal updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

	currencyType : CM_CurrencyType;
	rate 		 : CM_CurrencyRate;

begin

	if _typeCode.trimBlanks = null then
		return 0.0;
	endif;
	
	currencyType := app.myRoot.allCurrencyTypes.getAtKey(_typeCode).CM_CurrencyType;
	
	if currencyType = null then
		return 0.0;
	endif;
	
	rate := currencyType.getRate( self.createdTime );
	if rate = null then
		return 0.0;
	endif;
	
	return rate.rate * self.cashValue;

epilog

end;</source>
        <Parameter name="_typeCode" type="String"/>
        <Parameter name="_asAtDateTime" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
