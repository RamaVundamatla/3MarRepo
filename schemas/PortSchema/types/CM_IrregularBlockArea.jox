    <JadeMethod name="setForUpdate" id="3102f1bb-62fd-4365-a802-3d43604387fb">
        <updating/>
        <source>setForUpdate(_proxy : CM_IrregularBlockArea) updating;

// 23/06/2009	concms1		ccms 1061 - Changed method signature to use proxy rather than controller

vars

begin
		
	inheritMethod(_proxy);
	
	self.columns	:= _proxy.columns;
	self.rows 		:= _proxy.rows;
	self.unit 		:= _proxy.unit;
	
	self.allRowLabels.clear();
	_proxy.allRowLabels.copy(self.allRowLabels);
	self.allColumnLabels.clear();
	_proxy.allColumnLabels.copy(self.allColumnLabels);
	
	self.setForUpdateLocations(_proxy);
end;</source>
        <Parameter name="_proxy" type="CM_IrregularBlockArea"/>
    </JadeMethod>
