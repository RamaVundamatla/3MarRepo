        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_containers" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCargoForCash" id="de29967d-43a9-4846-bd24-47fdbdcfa1b4">
        <updating/>
        <source>createCargoForCash() protected, updating;
// cnwjre1
/*	
	Create cargo for cash module demos, in nominated terminal for nominated voyage and cargo operator
	with known transactions and existing charges.
*/
vars
	terminalId	: String;
	terminal	: CM_Terminal;
	passTerm	: CM_Terminal;
	tm			: CM_TranMap;
	bs : CM_TerminalArea;
	location	: CM_LocationsController;
	operator	: CM_Operator;
	ti			: CM_TrackedItem;
	voyage : CM_Voyage;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
	now : Date;
begin

	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	passTerm := app.myPassport.myTerminal;

	terminalId := "JT1";		// John's Terminal, change as required
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminalId);
	terminal := self.getTerminal();
	app.myPassport.setPropertyValue("myTerminal", terminal);
	operator := self.getOperator("PON");

	// use a specific transaction map, if present (unit test class start method sets the active one to 'default')
	tm := self.getTransactionMap("Cash");
	if tm &lt;&gt; null then
		app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	endif;
	
	voyage := self.createTargetVesselVoyage(terminal, "JMT CASH", "JCASH001", operator);
	
	self.opts.addAssoc("Operator", operator);
	self.createCashCargoOnShip(voyage, false);
	self.createCashCargoOnSite(voyage, 0);
	
	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("BS2");
	location := bs.allLocationsControllers.first;
	self.moveAllCargo(voyage, location);
	
	// move all cargo around to get an extra charge
	self.opts.addAssoc("Terminal", terminalId);
	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("BS3");

	foreach ti in voyage.allImportTIs do
		self.move(ti, bs);
		// connect the reefers for later reefer daily charges
		if ti.isReefer then
			self.updateTIConnection(ti, false, true, tranTS, null);
		endif;
	endforeach;

	// back-date transactions 10 days to get storage charges
	tranDate := now - 10;
	tranTS.setDate(tranDate);
	foreach ti in voyage.allImportTIs do
		foreach tran in ti.allTransactions do
			tranTS.setDate(tranDate);
			tranTS.setTime(tran.dateTime.time);
		
			beginTransaction;
			tran.setPropertyValue("dateTime", tranTS);
			commitTransaction;
		endforeach;
	endforeach;

epilog
	app.myPassport.setPropertyValue("myTerminal", passTerm);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createCashCargo" id="9c3a4697-d3f1-4b37-bcc5-82771804b661">
