    <JadeMethod name="qlbClassData_click" id="62dff1af-d192-497c-a4b1-2228f10e9993">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>qlbClassData_click(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2023	navpw1	Initial creation

*/

vars
	schemaObjectEntity : DEV_SchemaObjectEntity;
	
begin
	if listbox.text = null then
		return;
	endif;
	
	schemaObjectEntity := listbox.itemObject[listbox.listIndex].DEV_SchemaObjectEntity;
	
	if schemaObjectEntity = null then
		return;
		
	endif;
	
	if schemaObjectEntity.resolvedBy &lt;&gt; null then
		self.slStatus.caption := "Source Comparison: Item - Resolved by: " &amp; schemaObjectEntity.resolvedBy &amp; "@" &amp; schemaObjectEntity.resolvedAt.String;
		listbox.setFocus();
	endif;
	
	self.compareClassDetail(listbox, schemaObjectEntity);
	listbox.setFocus();
	
	self.btnOpenInWinMerge.visible := false;
	self.btnOpenInNPP.visible := false;
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="qlbClassData_contextMenu" id="d8b2998b-6f78-4532-a2a0-a97a1b4578be">
        <controlMethod name="ListBox::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>qlbClassData_contextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2022	navmd1	Initial creation

*/

vars
    x1 : Real;
    y1 : Real;
begin
    x1 := x;
    y1 := y;
	
    listbox.windowToScreen(x1, y1);
    self.screenToWindow(x1, y1);   // convert x, y relative to form
    
	self.mnuUnresolve.visible := false;
	self.mnuTableViewDiff.visible := false;  // ### JIRA 36455 23OCT2026 NAVAB1
	
	self.mnuLBContext.userObject := listbox;
	self.popupMenu(self.mnuLBContext, x1.Integer, y1.Integer);
    
	return false;                  // cancel further processing
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="qlbClassData_dblClick" id="f8e282a8-a14f-49ae-8365-201e564a6202">
        <controlMethod name="CMUI_ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>qlbClassData_dblClick(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devEnt,
	schemaObjectEntity	: DEV_SchemaObjectEntity;
	classConstant		: DEV_ClassConstant;
	schema 				: Schema;
	currentClass 		: Class;
	currentConstant 	: Constant;
	checked				: Boolean;
	
	selIndex,
	selLevel,
	index,
	level				: Integer;
	
begin
	if listbox.text &lt;&gt; null then
		schemaObjectEntity := listbox.itemObject[listbox.listIndex].DEV_SchemaObjectEntity;
	endif;
	
	if schemaObjectEntity &lt;&gt; null and schemaObjectEntity.isClassConstant then
		classConstant := schemaObjectEntity.DEV_ClassConstant;
		
		schema := rootSchema.getSchema(classConstant.myClass.mySchema.name);
		currentClass := schema.getClass(classConstant.myClass.name);
		currentConstant := currentClass.getConstant(classConstant.name);
		
		if currentConstant &lt;&gt; null and 
			classConstant.type = currentConstant.type.name and 
			classConstant.documentationTextData = currentConstant.text and 
			classConstant.value = currentConstant.getSource()
		then
			self.qlbClassData.enabled := false;
			
			if self.mnuLBContext.userObject = null then
				write method.qualifiedName &amp; " No userObject set on mnuLBContext";
				return;
			endif;
			
			selIndex := listbox.listIndex;
			if selIndex &lt; 1 then
				return;
			endif;
			
			devEnt := listbox.itemObject[selIndex].DEV_SchemaObjectEntity;
			
			// Mark the difference object as 'resolved'
			if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
				if app.msgBox("Mark as Resolved ?", "Clear and Resolve", MsgBox_Yes_No) = MsgBox_Return_Yes then
					devEnt.setResolved(process.getComputerName);
				endif;
			endif;
			
			if selIndex &lt; 1 or selIndex &gt; listbox.listCount then
				app.raiseUnexpectedProgramError(class.name, method.name, "Invalid Item Index");
				return;
			endif;
			
			selLevel := listbox.itemLevel[selIndex];

			// Remove the selected item
			listbox.removeItem(selIndex);
			
			// Also remove the 'Header' items if this was the only subitem
			index := selIndex;
			level := selLevel;
			while index &gt; 1 do
				// If the one above us is at a lower level,
				// and the one below us (if it exists) is also at a lower level
				if listbox.itemLevel[index-1] &lt; level and (listbox.listCount &lt; index or listbox.itemLevel[index] &lt; level) then
					listbox.removeItem(index-1);
					index -= 1;
					level -= 1;
					continue;
				endif;
				break;
			endwhile;
			
			checked := true;
		endif;
		
	endif;
	
	if not checked then
		self.showDetails(listbox);
		
	endif;
	
epilog
	self.qlbClassData.enabled := true;
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
