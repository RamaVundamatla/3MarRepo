		self.weight := _weight;
	endif;
end;</source>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="verifyBookingRef" id="816bd28d-9542-4caf-bff7-282802b2bdc8">
        <source>verifyBookingRef();
//
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	terminal	  	: CM_Terminal;
	myBookingRef	:CM_BookingRef;
begin
	// no longer used can be deleted?
	terminal := self.getMyTerminal();
	myBookingRef := terminal.allBookingRefsByRef[bookingRef];
	if myBookingRef = null then
		app.raiseCMWarning2(ERR_FIELD_BOOKING_REF,self.bookingRef, 'Booking Ref', 'Booking Ref', self, self);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="verifyCommodity" id="eb37d5c0-5d62-4ea2-b721-0840b42f199a">
        <source>verifyCommodity();

vars

begin

	if app.myRoot.allCommodities[self.commodity] = null then
		app.raiseCMWarning2(ERR_FIELD_COMMODITY,self.commodity, 'Commodity', 'Commodity', self, self);
	else	//02 Mar 2021	NDL	TFS 50740
		self.validateCommodityPlus( app.myRoot.allCommodities[self.commodity] );
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="verifyDestinationPort" id="ae8b63a5-9500-4431-8d62-0d2232a911c9">
        <source>verifyDestinationPort();

vars
	destPort : CM_Port;
	
begin
	/* cnwrl1 13/08/2010 PAR 25355 - what it was
	destPort := app.myRoot.allPorts[destinationPort];
	if destPort = null then
		app.raiseCMWarning1(ERR_INVALID_DEST_PORT,destinationPort,"Destination",self, self);
	endif;
	cnwrl1 13/08/2010 PAR 25355 - end of what it was */
	
	// cnwrl1 13/08/2010 PAR 25355 - start of replacement coding
	if self.destinationPort &lt;&gt; null then
		destPort := app.myRoot.allPorts[ self.destinationPort.toUpper ];
		if destPort = null then
			app.raiseCMWarning1( ERR_INVALID_DEST_PORT, self.destinationPort, ETRow_DestinationPort, self, self );
		endif;
	endif;
	// cnwrl1 13/08/2010 PAR 25355 - end of coding
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="verifyDischargePort" id="1d1f7591-49c7-491f-9c6b-6b2edbe34caa">
        <source>verifyDischargePort(_terminal: CM_Terminal);

vars
	voyage: CM_Voyage;
	discharge: CM_Port;

begin
	if _terminal &lt;&gt; null then
		voyage := _terminal.lookupVoyage(self.getExportVoyageCode(), null, false);
	endif;

	discharge := self.getRealDischargePort();

	if voyage &lt;&gt; null and not voyage.isNullVoyage then								// 25/05/2022 jlizm1 TFS 53083
		if discharge &lt;&gt; null and not voyage.allPorts.includes(discharge) then		// 27/6/19 MAP TFS45340
			app.raiseCMException1(ERR_INVALID_DIS_PORT, self.dischargePort, "Discharge", self);			//cnwjo3 par 22940
		endif;
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifyExportVoyageCode" id="63219f22-10fb-44d5-b0e8-2df0df215b30">
        <source>verifyExportVoyageCode();

/*
Date		Who		Reason
02 December 2009	cnwphb1	Initial creation (Par 21809)
11/06/2010	cnwrl1	PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	voyageCodeStr	: String;
	
begin
	/* cnwrl1 11/06/2010 PAR 24299 - what it was
	if self.exportVoyageCode = null or
	   self.myEDIData.CM_EDIDataTranship.getVoyage(self.exportVoyageCode) = null then
		app.raiseCMException2(ERR_EXP_VOY_CODE, self.exportVoyageCode, 'export voyage code', self.exportVoyageCode, self);
	endif;
	cnwrl1 11/06/2010 PAR 24299 - end of what it was */
	
	// cnwrl1 11/06/2010 PAR 24299 - start of coding
	voyageCodeStr	:= self.getExportVoyageCode();
	if voyageCodeStr = null or
	   self.myEDIData.CM_EDIDataTranship.getVoyage( voyageCodeStr ) = null then
//		app.raiseCMException2( ERR_EXP_VOY_CODE, voyageCodeStr, 'export voyage code', voyageCodeStr, self );	// cnwrl1 14/07/2010 PAR 23499 - what it was
		app.raiseCMException2( ERR_EXP_VOY_CODE, voyageCodeStr, 'Outgoing voyage code', voyageCodeStr, self );
	endif;
	// cnwrl1 11/06/2010 PAR 24299 - end of coding
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="verifyIdAndIsoType" id="3df2e06d-1af8-4c86-aa82-41ec225cf928">
        <source>verifyIdAndIsoType( _terminal : CM_Terminal );

vars
	isoTypeCode,
	tiISOTypeCode	: CM_ISOType;
//	trackedItem 	: CM_Container;				// cnwrl1 12/08/2010 PAR 25318 - what it was
	trackedItem 	: CM_TrackedItem;
	tiIsoCode		: String;

begin
	/* cnwrl1 12/08/2010 PAR 25318 - what it was
	isoTypeCode := app.myRoot.allISOTypes[self.isoType];
	if isoTypeCode = null then
		app.raiseCMWarning3(ERR_INVALID_ISOTYPE, self.isoType, 'ID', self.id , 'ISO', self, self);
	endif;
	
	if id.trimBlanks = null then
		app.raiseCMWarning2(ERR_FIELD_CONT_ID,id, 'container id', 'ID', self, self);
	endif;
	
	trackedItem := self.getRealTI( _terminal );
	
	if trackedItem = null  then
		app.raiseCMWarning2(ERR_VOY_CARGO_ONSHIP, self.getVoyageCode(), self.id, 'ID', self, self);
	else
		if isoTypeCode &lt;&gt; null then
			tiISOTypeCode := app.myRoot.allISOTypes[trackedItem.isoType];
			if tiISOTypeCode.myISOTypeGroup &lt;&gt; isoTypeCode.myISOTypeGroup then
				if tiISOTypeCode.myISOTypeGroup &lt;&gt; null then
					tiIsoCode := tiISOTypeCode.myISOTypeGroup.code;
				endif;
				app.raiseCMWarning3(ERR_INVALID_ISOTYPE, self.isoType, self.id, tiIsoCode, 'ISO', self, self);
			endif;
		endif;
	endif;
	cnwrl1 12/08/2010 PAR 25318 - end of what it was */
	
	// cnwrl1 12/08/2010 PAR 25318 - start of replacement coding
	// Changed to handle all CM_Cargo classes not just CM_Containers.
	if id.trimBlanks = null then
		app.raiseCMWarning2( ERR_FIELD_CONT_ID,id, 'container id', 'ID', self, self );
	else
		trackedItem	:= self.getRealTI( _terminal );
	endif;
	
	if trackedItem = null  then
		app.raiseCMWarning2( ERR_VOY_CARGO_ONSHIP, self.getVoyageCode(), self.id, 'ID', self, self );
	else
		if trackedItem.usesISOType then
			isoTypeCode	:= app.myRoot.allISOTypes[ self.isoType ];
			if isoTypeCode = null then
				app.raiseCMWarning3( ERR_INVALID_ISOTYPE, self.isoType, 'ID', self.id , 'ISO', self, self );
			else
				tiISOTypeCode	:= trackedItem.getISOTypeObject();
				if tiISOTypeCode.myISOTypeGroup &lt;&gt; isoTypeCode.myISOTypeGroup then
					if tiISOTypeCode.myISOTypeGroup &lt;&gt; null then
						tiIsoCode := tiISOTypeCode.myISOTypeGroup.code;
					endif;
					app.raiseCMWarning3( ERR_INVALID_ISOTYPE, self.isoType, self.id, tiIsoCode, 'ISO', self, self );
				endif;
			endif;
		endif;
	endif;
	// cnwrl1 12/08/2010 PAR 25318 - end of coding
	
epilog
	
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
