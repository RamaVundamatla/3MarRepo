    <JadeMethod name="getDisplayStringForAttribute" id="577b3939-18e8-4229-9419-f1c6944bceb9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     02 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	display:String;
begin

	if _attrName = ETRow_TerminalAreas then
		return self.allTerminalAreas.getDisplay();
	elseif _attrName = ETRow_Projected20 then
		if self.projected20 &gt; 0 then
			return self.projected20.String;
		else
			return "";
		endif;
	elseif _attrName = ETRow_Projected40 then
		if self.projected40 &gt; 0 then
			return self.projected40.String;
		else
			return "";
		endif;
	// PAR 19760
	elseif _attrName = ETRow_Projected30 then
		if self.projected30 &gt; 0 then
			return self.projected30.String;
		else
			return "";
		endif;
	// PAR 19760
	elseif _attrName = ETRow_Projected45 then
		if self.projected45 &gt; 0 then
			return self.projected45.String;
		else
			return "";
		endif;
	// PAR 19760
	elseif _attrName = ETRow_Projected53 then
		if self.projected53 &gt; 0 then
			return self.projected53.String;
		else
			return "";
		endif;
	elseif _attrName = ETRow_ProjectedGC then	//31 Mar 2021	NDL	TFS 49912
		if self.projectedGC &gt; 0 then
			return self.projectedGC.String;
		else
			return "";
		endif;
	elseif _attrName = ETRow_Code then
		return self.code;
	elseif _attrName = ETRow_PriorityValue then
		return self.priorityValue.String;
	elseif _attrName = ETRow_DeckingSequence then
		display := app.yaFillOptionToString(self.fillOptionIn);
		display := display[1:4];
		display := display.toUpper();
		if display[1] = "A" then
			display := display[1:3];
		endif;
		return display;
	elseif _attrName = ETRow_OverstowRule then
		if self.myYAOverstowRule &lt;&gt; null then
			return self.myYAOverstowRule.code;
		endif;
		return null;
	elseif _attrName = ETRow_HideShow or
		   _attrName = ETRow_Total20 or
		   _attrName = ETRow_Total30 or
		   _attrName = ETRow_Total40 or
		   _attrName = ETRow_Total45 or
		   _attrName = ETRow_Total53 or
		   _attrName = ETRow_Used20 or
		   _attrName = ETRow_Used30 or
		   _attrName = ETRow_Used40 or
		   _attrName = ETRow_Used45 or
		   _attrName = ETRow_Used53 or
		   _attrName = ETRow_Free20 or
		   _attrName = ETRow_Free30 or
		   _attrName = ETRow_Free40 or
		   _attrName = ETRow_Free45 or
		   _attrName = ETRow_Free53 or
		   _attrName = ETRow_QueuedIn20 or
		   _attrName = ETRow_QueuedIn30 or
		   _attrName = ETRow_QueuedIn40 or
		   _attrName = ETRow_QueuedIn45 or
		   _attrName = ETRow_QueuedIn53 or
		   _attrName = ETRow_QueuedOut20 or
		   _attrName = ETRow_QueuedOut30 or
		   _attrName = ETRow_QueuedOut40 or
		   _attrName = ETRow_QueuedOut45 or
		   _attrName = ETRow_QueuedOut53 or
		   _attrName = ETRow_PlannedIn20 or
		   _attrName = ETRow_PlannedIn30 or
		   _attrName = ETRow_PlannedIn40 or
		   _attrName = ETRow_PlannedIn45 or
		   _attrName = ETRow_PlannedIn53 or
		   _attrName = ETRow_PlannedOut20 or
		   _attrName = ETRow_PlannedOut30 or
		   _attrName = ETRow_PlannedOut40 or
		   _attrName = ETRow_PlannedOut45 or
		   _attrName = ETRow_PlannedOut53 or		   
		   //cnwjo3 par 21189 start
		   _attrName = ETRow_ColTotalFree or
		   _attrName = ETRow_ColTotalPlanIn or
		   _attrName = ETRow_ColTotalPlanOut or
		   _attrName = ETRow_ColTotalProjected or
		   _attrName = ETRow_ColTotalQIn or
		   _attrName = ETRow_ColTotalQOut or
		   _attrName = ETRow_ColTotalTotal or
		   _attrName = ETRow_ColTotalUsed or
		   //cnwjo3 par 21189 finish
		   _attrName = ETRow_Stacking then
		return null;
	elseif _attrName = ETRow_AllowOthers then //cnwjo3 par 20135
		if allowOthersOption = YAOverlap_Always then
			return YAOverlap_AlwaysStr;
		elseif allowOthersOption = YAOverlap_LastResort then
			return YAOverlap_LastResortStr;
		elseif allowOthersOption = YAOverlap_Never then
			return YAOverlap_NeverStr;
		elseif allowOthersOption = YAOverlap_Sometimes then
			return YAOverlap_SometimesStr;
		else
			return null;  //something I am unfamiliar with
		endif;
	elseif _attrName = ETRow_IfNoLocationFound then //cnwjo3 par 20135
		if self.noLocationOption = YANoLocation_Continue then
			return YANoLocation_ContinueStr;
		elseif self.noLocationOption = YANoLocation_Stop then
			return YANoLocation_StopStr;
		else
			return null;  //unknow NoLocation value
		endif;
	elseif _attrName = ETRow_HasRemarks then	//04 Jan 2012	NDL	Par 28889
		if self.remarks.trimBlanks = null then
			return null;
		else
			return true.getYesNo;
		endif;
	elseif _attrName = ETRow_Remarks then	//04 Jan 2012	NDL	Par 28889
		if self.remarks.trimBlanks.length &gt; 200 then	//25 Nov 2013	NDL	Par 32071
			return self.remarks.trimBlanks[1:197] &amp; "...";
		else
			return self.remarks.trimBlanks;
		endif;
		
	//05 Jan 2012	NDL	Par 28889
	elseif _attrName = ETRow_AvailabilityGrade
		or _attrName = ETRow_BOL
		or _attrName = ETRow_Booking
		or _attrName = ETRow_CargoHeight
		or _attrName = ETRow_CargoLength
		or _attrName = ETRow_CargoSubtype
		or _attrName = ETRow_CargoType
		or _attrName = ETRow_CargoWidth
		or _attrName = ETRow_Carrier
		or _attrName = ETRow_Clean
		or _attrName = ETRow_Commodity
		or _attrName = ETRow_CommodityGroup
		or _attrName = ETRow_Communicating
		or _attrName = ETRow_Consignee
		or _attrName = ETRow_Consignor
		or _attrName = ETRow_ContainerLength
		or _attrName = ETRow_ContentsStatus
		or _attrName = ETRow_CurtainsIn
		or _attrName = ETRow_DestinationPort
		or _attrName = ETRow_DestinationTerminal
		or _attrName = ETRow_DischargePort
		or _attrName = ETRow_FreightForwarder
		or _attrName = ETRow_Hazardous
		or _attrName = ETRow_HeavyDuty
		or _attrName = ETRow_Id
		or _attrName = ETRow_ImexStatus
		or _attrName = ETRow_IntendedReleaseMode
		or _attrName = ETRow_IsAvailable
		or _attrName = ETRow_IsCoastal
		or _attrName = ETRow_IsControlled
		or _attrName = ETRow_IsFiftyThree
		or _attrName = ETRow_IsForty
		or _attrName = ETRow_IsFortyFive
		or _attrName = ETRow_IsHazardLtdQty
		or _attrName = ETRow_IsHazardOrLtdQty
		or _attrName = ETRow_IsHazardous
		or _attrName = ETRow_IsHazardousNotLtd
		or _attrName = ETRow_IsOverDimensional
		or _attrName = ETRow_IsThirty
		or _attrName = ETRow_IsTransShip
		or _attrName = ETRow_IsTwenty
		or _attrName = ETRow_ISO
		or _attrName = ETRow_ISOGroup
		or _attrName = ETRow_LoadPort
		or _attrName = ETRow_OperatorItem
		or _attrName = ETRow_OperatorVoyage
		or _attrName = ETRow_ReceiveTransMode
		or _attrName = ETRow_Rehandles
		or _attrName = ETRow_ReleaseRequest
		or _attrName = ETRow_ReleaseTransMode
		or _attrName = ETRow_RequiresPower
		or _attrName = ETRow_SourceTermArea
		or _attrName = ETRow_SourceTermAreaType
		or _attrName = ETRow_SpecialLift
		or _attrName = ETRow_SpecialStow
		or _attrName = ETRow_Stops
		or _attrName = ETRow_SubTerminal
		or _attrName = ETRow_TodoTasks
		or _attrName = ETRow_TrailerType
		or _attrName = ETRow_Train
		or _attrName = ETRow_TranshipDischPort
		or _attrName = ETRow_TranshiptoPort
		or _attrName = ETRow_Voyage
		or _attrName = ETRow_VoyageBerth
		or _attrName = ETRow_VoyageInbound
		or _attrName = ETRow_VoyageOutbound
		or _attrName = ETRow_VoyagePlanningCode
		or _attrName = ETRow_VoyageTrade
		or _attrName = ETRow_WaterCooled
		or _attrName = ETRow_Weight
		or _attrName = ETRow_WeightFlexi
		or _attrName = ETRow_Mark
		or _attrName = ETRow_Colour
		then
			return self.getDisplayForYAMTableColumn( _attrName );
			
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="796f1e3b-9e04-499b-b128-b15f52f3fb24">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	terminal : CM_Terminal;
begin
//	block := _dataContainer.addNewBlock;
//	block.addNewItem("Yard Allocation", DC_MoreInfo, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Code", DC_Label, 1, self);
	block.addNewItem(self.code, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Description", DC_Label, 1, self);
	block.addNewItem(self.description, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Disabled", DC_Label, 1, self);
	block.addNewItem(self.isDisabled.getYesNo(), DC_Data, 1, self);

	
	// cnwjk3 SFW1030
	/*
	block := _dataContainer.addNewBlock;
	block.addNewItem("Criteria", DC_Label, 1, self);
	block.addNewItem(self.getCriteriaString(), DC_Data, 1, self);
    */


	block := _dataContainer.addNewBlock;
	block.addNewItem("Fill In Option", DC_Label, 1, self);
	block.addNewItem(app.yaFillOptionToString(self.fillOptionIn), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Fill Out Option", DC_Label, 1, self);
	block.addNewItem(app.yaFillOptionToString(self.fillOptionOut), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Allow Others", DC_Label, 1, self);
	block.addNewItem(app.yaOverlapFlagToString(self.allowOthersOption), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("No Location", DC_Label, 1, self);
	block.addNewItem(app.yaNoLocationFlagToString(self.noLocationOption), DC_Data, 1, self);

	// CCMS 1357	
	//if app.getMyTerminal().getConfig(AutoPlanUseOverstowRules).Boolean then
	//Par13157 Need to check for Terminal.  Users have this form open while in System Items meaning no terminal exists.
	//Don't use CM_YardAllocation::myTerminal as CM_YardAllocationTemplate does not have a terminal.
	terminal := app.getMyTerminalDO_NOT_USE;
	if terminal &lt;&gt; null and terminal.isAutoPlanUseOverstowRules() then   //SFW1030 04/08/2008
		block := _dataContainer.addNewBlock;
		block.addNewItem("Overstow Rule", DC_Label, 1, self);
		if self.myYAOverstowRule &lt;&gt; null then
			block.addNewItem(self.myYAOverstowRule.code, DC_Data, 1, self);
		else
			block.addNewItem('None', DC_Data, 1, self);
		endif;
	endif;
	
	// 19/03/2009 cnwar2 #19085
	block := _dataContainer.addNewBlock;
	block.addNewItem("Projected 20s", DC_Label, 1, self);
	block.addNewItem(self.projected20.asStringJMT, DC_Data, 1, self);
	block := _dataContainer.addNewBlock;
	block.addNewItem("Projected 30s", DC_Label, 1, self);
	block.addNewItem(self.projected30.asStringJMT, DC_Data, 1, self);
	block := _dataContainer.addNewBlock;
	block.addNewItem("Projected 40s", DC_Label, 1, self);
	block.addNewItem(self.projected40.asStringJMT, DC_Data, 1, self);
	block := _dataContainer.addNewBlock;
	block.addNewItem("Projected 45s", DC_Label, 1, self);
	block.addNewItem(self.projected45.asStringJMT, DC_Data, 1, self);
	block := _dataContainer.addNewBlock;
	block.addNewItem("Projected 53s", DC_Label, 1, self);
	block.addNewItem(self.projected53.asStringJMT, DC_Data, 1, self);
	block.addNewItem("Projected GC", DC_Label, 1, self);	//31 Mar 2021	NDL	TFS 49912
	block.addNewItem(self.getProjectedGCString, DC_Data, 1, self);

	// cnwjk3 SFW1030
	/*
	block := _dataContainer.addNewBlock;
	block.addNewItem("Priority Adjustment", DC_Label, 1, self);
	block.addNewItem(self.priorityAdjustment.String, DC_Data, 1, self);
	*/
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Expiry", DC_Label, 1, self);
	block.addNewItem(app.yaExpiryFlagToString(self.expiryType), DC_Data, 1, self);
	
	if self.expiryType = YAExpiryType_SpecifiedDate then
	
		block := _dataContainer.addNewBlock;
		block.addNewItem("Expiry Date", DC_Label, 1, self);
		block.addNewItem(self.expiryDate.String, DC_Data, 1, self);
	
	endif;
 

	block := _dataContainer.addNewBlock;
	block.addNewItem("Remarks", DC_Label, 1, self);
	block.addNewItem(self.remarks.String, DC_Data, 1, self);
	
	if app.isSpecial() then
		block := _dataContainer.addNewBlock;
		block.addNewItem("OID", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);

	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
