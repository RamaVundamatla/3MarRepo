    <PrimAttribute name="isFromEDI" id="8d2a90a6-1453-42fb-9084-b0693be6160d">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myTerminal" id="d257daeb-204d-4966-85e5-537aa118bef3">
