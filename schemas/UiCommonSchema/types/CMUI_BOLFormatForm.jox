    <JadeMethod name="click" id="2f1c4552-d472-4a5a-ab92-633b08c0a4f4">
        <controlMethod name="Form::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>click() updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.useTblThumb		:= false;
	self.frmDetailsBottom.visible := true;
	self.frmDetailsTop.visible := true;
	self.sptThumbEdit.setLeftToRightRatioAndResize(20);
	self.sptThumbEdit.visible := true;
	
	self.sptThumbEdit.setupChildControls();
	
	self.initForDemo();
	// this is just a demo form so ok here for now
	self.allowAdd := true;
	self.allowDelete := true;
	self.allowUpdate := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbSpecies_mouseDown" id="11cab8ef-8796-45ad-935c-8b5db16ff7eb">
        <controlMethod name="CMUI_ComboBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSpecies_mouseDown(comboBox: ComboBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if button = Window.MouseButton_Left then
		self.myDraggedControl := comboBox;
		self.dragMode := DragMode_Drag;
	endif;

end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="create" id="cde6f431-357f-4064-972a-58d4c338b2fe">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cntrl	: CMUI_Controller;

begin

app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  need to update here');
app.initialize;
app.myPassport.setMyUserFromCode('CNWRS2');
create cntrl transient;
app.setPropertyValue('myController', cntrl);

	self.permissionView := PmAdmCargoEnquiryView;
	self.permissionMaint := PmAdmCargoEnquiryMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="frmDetailsBottom_dragDrop" id="97b8d9fd-4f4e-4779-a394-6d3c7390edcf">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmDetailsBottom_dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.writeStatement( class.name &amp; '::' &amp; method.name);
	
	if self.myDraggedControl &lt;&gt; null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  moving to ' &amp; x.String &amp; ', ' &amp; y.String);
		self.myDraggedControl.left := x;
		self.myDraggedControl.top := y;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="8fdc7b07-4517-47c4-86ca-0cea0250ca8b">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.allowMultiSelectEdit := false;	
	self.setTblDataEntRows(ETDef_OperatorTbl);
	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_Code, false);	
end;</source>
    </JadeMethod>
    <JadeMethod name="initForDemo" id="cd815ebc-28dc-4995-aeb4-b359dd3a0d0e">
        <updating/>
        <source>initForDemo() updating;
// ---------------------------------------------------------------------------
// Created:     16 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
	
begin

	self.caption := 'BOL Formats';

	self.tblFormat.rows := 0;
	
	idx := self.tblFormat.addAttribute('code', 'Code', Table.InputType_TextBox , 0, true);
	self.tblFormat.setValue(idx, 'CHH01');
	
	idx := self.tblFormat.addAttribute('descr', 'Description', Table.InputType_TextBox , 0, true);
	self.tblFormat.setValue(idx, 'Carter Holt Standard Docket');

	idx := self.tblFormat.addAttribute('isAvailable', 'Available for Entry', Table.InputType_CheckBox , 0, true);
	self.tblFormat.setValue(idx, '0');

	idx := self.tblFormat.addAttribute('formatType', 'Format Type', Table.InputType_ComboBox, 0, true);
	self.tblFormat.setComboValues(idx, 'Field' &amp; Tab &amp; 'Table');

	idx := self.tblFormat.addAttribute('height', 'Height', Table.InputType_TextBox , 0, true);
	self.tblFormat.setValue(idx, '506');

	idx := self.tblFormat.addAttribute('width', 'Width', Table.InputType_TextBox , 0, true);
	self.tblFormat.setValue(idx, '245');

	tblControls.columns := 6;
	tblControls.rows := 0;
	tblControls.addItem('Used' &amp; Tab &amp; 'Control' &amp; Tab &amp; 'Caption' &amp; Tab &amp; 'Top' &amp; Tab &amp; 'Left' &amp; Tab &amp; 'Width');
	tblControls.fixedRows := 1;
	tblControls.accessColumn(1).inputType := Table.InputType_CheckBox;
	tblControls.accessCell(1,1).inputType := Table.InputType_TextBox;
	tblControls.accessCell(1,1).text := 'Used' &amp; Tab &amp; 'Control' &amp; Tab &amp; 'Caption' &amp; Tab &amp; 'Top' &amp; Tab &amp; 'Left' &amp; Tab &amp; 'Width';

	idx := tblControls.addItem('1' &amp; Tab &amp; 'Operator Label' &amp; Tab &amp; 'Exporter' &amp; Tab &amp; '23' &amp; Tab &amp; '15' &amp; Tab &amp; '30');
	tblControls.accessRow(idx).backColor := LightRed;
	idx := tblControls.addItem('1' &amp; Tab &amp; 'Operator Combo' &amp; Tab &amp; '' &amp; Tab &amp; '23' &amp; Tab &amp; '50' &amp; Tab &amp; '30');
	tblControls.accessRow(idx).backColor := LightRed;

	idx := tblControls.addItem('1' &amp; Tab &amp; 'Remarks Label' &amp; Tab &amp; 'Remarks' &amp; Tab &amp; '23' &amp; Tab &amp; '15' &amp; Tab &amp; '30');
	tblControls.accessRow(idx).backColor := LightBlue;
	idx := tblControls.addItem('1' &amp; Tab &amp; 'Remarks Text' &amp; Tab &amp; '' &amp; Tab &amp; '23' &amp; Tab &amp; '50' &amp; Tab &amp; '30');
	tblControls.accessRow(idx).backColor := LightBlue;
	
	tblData.rows := tblData.fixedRows;
	tblData.addItem('CHH01' &amp; Tab &amp; 'Carter Holt Standard Docket');
	tblData.addItem('CHH02' &amp; Tab &amp; 'Carter Holt Weekend Docket');
	tblData.addItem('FCF01' &amp; Tab &amp; 'FCF Standard Docket');

	self.initTblRowsForDemo();

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="2c9a13f0-eb59-433f-8721-ea192d185bbb">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.allowAdd	 		:= true;
	self.allowDelete 		:= true;
	self.allowUpdate 		:= true;
	self.showFilterOnStartup := false; 	// Show the filter frame
	self.showDataOnStartup 	:= true; 	// Do not populate the data table with data
	self.allowPrint 		:= false;
	self.allowExportCSV		:= false;
	self.useNumRowsShown	:= true;
	self.useTblThumb		:= false;

//	self.tblData.autoSize := Table.AutoSize_Column;
	
//	if self.initialSptMainRatio = 0 then
//		self.initialSptMainRatio := 50;
//	endif;
	
//	self.initTblThumb();
//	self.initTblEntDetail();
//	self.initTblDefaultValues();
	self.setMyDataClass();
	
	self.allowTblDataSearch := true;
	
	self.frmDetailsBottom.visible := true;
	self.frmDetailsTop.visible := true;
	self.sptThumbEdit.setLeftToRightRatioAndResize(50);
	

	self.fldDetails.stretchToParent := true;
	self.tblFormat.stretchToParent := true;
	self.tblControls.stretchToParent := true;
	
	self.fldDetails.useSheetBackColors := true;
	self.fldDetails.setDefaultSheetBackColors();
	self.fldDetails.initSheetBackColors();

	self.tblThumb.visible := false;

	self.initForDemo();

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblRowsForDemo" id="40b3141a-841b-4c79-b240-fa6b4ef4daca">
        <source>initTblRowsForDemo();
// ---------------------------------------------------------------------------
// Created:     05 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entDef	: EntTableDef;
	entRow	: EntTableRow;
	
begin

	tblRowsToView.columns := 2;
	tblRowsToView.accessColumn(2).inputType := Table.InputType_CheckBox;
	tblRowsToView.stretchToParent := true;

	entDef := CM_EntTableDataRoot.firstInstance.allEntTableDefs['InExtra'];

	foreach entRow in entDef.allEntTableRows do
		tblRowsToView.addItem(entRow.getHeading(null, null, app.myCurrentLocale) &amp; Tab &amp; '0');
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="48020009-a723-4aae-944e-2720a07f74c1">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myDataClass := CM_Operator;

end;</source>
    </JadeMethod>
    <JadeMethod name="tblFormat_click" id="2beae03f-977e-4dc0-a2d7-b33d5821b401">
        <controlMethod name="CM_EntryTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFormat_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     05 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpType	: String;
	
begin

	if table.row = 4 then
		tmpType := tblFormat.getValueByName('formatType').String;
		if tmpType = 'Field' then
			self.tblRowsToView.visible := false;
			self.lblOperator.visible := true;
			self.cmbSpecies.visible := true;
			self.shtControls.enabled := true;
			self.tblFormat.showRowByName('height', false);
			self.tblFormat.showRowByName('width', false);
		else
			self.lblOperator.visible := false;
			self.cmbSpecies.visible := false;
			self.tblRowsToView.visible := true;
			self.shtControls.enabled := false;
			self.tblFormat.hideRowByName('height', false);
			self.tblFormat.hideRowByName('width', false);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="113174cb-0942-4b9c-8e5c-d2b0fbc6e08b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017254, locale);
	lblOperator.translateCaption(Xlat_0000128, locale);
	shtControls.translateCaption(Xlat_0000129, locale);
	shtHeader.translateCaption(Xlat_0000130, locale);
end;</source>
    </JadeMethod>
</GUIClass>
