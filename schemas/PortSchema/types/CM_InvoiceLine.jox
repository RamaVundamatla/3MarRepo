    </JadeMethod>
    <JadeMethod name="quantityEventCalcType" id="16e734fa-c66e-49d9-9200-dd1f28d75029">
        <updating/>
        <source>quantityEventCalcType(_theCalcType : CM_CalculationType) : Real updating;
// ---------------------------------------------------------------------------
// Created:		17 October 2007 By Andrew Bishop cnwab1
// PAR 25720
// Purpose:		ANY CHANGES HERE NEED TO BE DONE IN CM_QuantityMap::getQuantityForTransactionEvent
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
22 Aug 2022	jlika1	TFS 54420 - PRP - Enstructure - Financial Requirements
23 Sep 2022	jlika1	TFS 54897 MTN - Days being charged is incorrect
TFS BUG 61892 29DEC2023 NAVAB1 changed to pass in the calc type

*/
vars
	theVoyage 		: CM_Voyage;
	theVessel 		: CM_Vessel;
	theHMSData 		: HMS_VesselData;
	theHMSVoyageData: HMS_VoyageData;
	
	theUnits 		: Integer;
	stTS, 
	endTS 			: TimeStamp;
	value, 
	diffTS 			: Real;
	tran 			: CM_EventTransaction;
	cmifHook		: CMIF_CalcTypeQuantityHook;
	valueOut 		: Real;
	blockAmount 	: Real;
	blockUnit		: Integer;		
	diffDays		: Integer;
begin
	tran := self.myTransactionEvent;
	
	if tran &lt;&gt; null then

		theVoyage := tran.getVoyage();
		
		theUnits := _theCalcType.calculationType;
		if self.myResourceTypeUsage &lt;&gt; null then
			stTS := self.myResourceTypeUsage.fromDateTime;
			endTS := self.myResourceTypeUsage.toDateTime;
		else
			stTS := tran.getStartTS();
			endTS := tran.getEndTS();
		endif;
		
		diffTS := stTS.differenceInHoursReal(endTS);
		
		if isEventBlockUnit(theUnits) then
			blockUnit := _theCalcType.theCalcTypeUnit;		
			if theVoyage &lt;&gt; null then
				theHMSVoyageData := theVoyage.myHMSVoyageData;				
			endif;
			
			if theHMSVoyageData &lt;&gt; null then
				blockAmount := self.quantityVoyageBlockUnits(blockUnit, theHMSVoyageData, theVoyage, null);
				if blockAmount = 0 then
					blockAmount := 1;
				endif;
			else 
				blockAmount := 1;
			endif;
		endif;
		
		if theUnits = INV_CALC_TYPE_EVENT_UNIT then
			value := tran.getAmount(); // PAR 25719
			if value = 0 then
				if self.myResourceTypeUsage &lt;&gt; null then // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
					value := self.myResourceTypeUsage.quantity; // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
				else
					value := 1;
				endif;
			endif;
		elseif theUnits = INV_CALC_TYPE_EVENT_TIME_DAYS then
			value :=  (diffTS / 24) * blockAmount;
		elseif theUnits = INV_CALC_TYPE_EVENT_DAYS_FULL then
			diffDays := stTS.differenceInHoursFullDay(endTS);
			value :=  diffDays * blockAmount;
		elseif theUnits = INV_CALC_TYPE_EVENT_TIME_HOURS then 
			value := diffTS * blockAmount;
		elseif theUnits = INV_CALC_TYPE_EVENT_TIME_MINUT then
			value := (diffTS * 60) * blockAmount;
		elseif (theUnits = INV_CALC_TYPE_EVENT_LENGTH or theUnits = INV_CALC_TYPE_EVENT_GRT) then
			value := 1;
			if theVoyage &lt;&gt; null then
				theVessel := theVoyage.getMyVessel();
				if theVessel &lt;&gt; null then
					theHMSData := theVessel.myHMSVesselData;
					if theHMSData &lt;&gt; null then
						if theUnits = INV_CALC_TYPE_EVENT_LENGTH then
							value := theHMSData.dim_LengthOverall;
						elseif theUnits = INV_CALC_TYPE_EVENT_GRT then
							value := theHMSData.dim_GrossRegTonnes;
						endif;
					endif;
				endif;
			endif;
		endif;
		
		if _theCalcType &lt;&gt; null and _theCalcType.myHookCodeQuantity &lt;&gt; null then
			create cmifHook transient;
			cmifHook.myTransaction := tran;
			cmifHook.origQty := value;
			
			valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, _theCalcType, _theCalcType, cmifHook).Real;
	
			value := valueOut;
		endif;
	endif;
	
	
	return value;

end;</source>
        <Parameter name="_theCalcType" type="CM_CalculationType"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityInventory" id="ba1b21a5-1091-4dc0-adb0-f5cc6cd5f953">
        <updating/>
