    <JadeMethod name="keyDown" id="0f692243-ae6d-4395-9a08-781dee4666f9">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2008	cnwrd1	Initial creation

*/

vars

begin
	if keyCode = CMUI_Key_F3 then		
		self.showHideSearcher();
		return;
	endif;
	
	if keyCode = CMUI_Key_Enter then
		if self.frmSearcher.visible then 
			self.btnDoSearch.click(self.btnDoSearch);
			return;
		endif;
	endif;
	
	if keyCode = CMUI_Key_F11 then
		if self.myCurrentTiMaster &lt;&gt; null then
			self.myCurrentTiMaster.inspect;
		elseif self.myCurrentWagonMaster &lt;&gt; null then
			self.myCurrentWagonMaster.inspect;
		endif;
	endif;
	inheritMethod(keyCode, shift );
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
