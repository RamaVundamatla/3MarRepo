    <JadeMethod name="buildList" id="35f71a63-e4c1-469d-8e11-9e5f80730ed6">
        <updating/>
        <source>buildList() updating;
/*
Purpose:			
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars

begin
	myVoyageCheckList.myTerminal := self.myTerminal;
	myVoyageCheckList.myVoyage := self.myVoyage;
	
	self.myVoyageCheckList.buildList();
epilog

end;</source>
