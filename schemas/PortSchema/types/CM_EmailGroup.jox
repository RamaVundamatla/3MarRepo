    <JadeMethod name="getAuditText" id="3f7e41f8-1edf-4a2e-b8b2-c561879eda87">
        <source>getAuditText(): String;

vars
	txt		: String;
	tmpStr	: String;
	email		: CM_EmailAddress2;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach email in self.allEmailAddresses do
		if tmpStr = null then
			tmpStr := email.emailAddress;
		else
			tmpStr := tmpStr &amp; ', ' &amp; email.emailAddress;
		endif;
	endforeach;
	txt := txt &amp; 'EmailAddresses' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEmailAddress" id="205cac54-5598-4ec9-a36b-c4f01b450b98">
        <source>getEmailAddress(): String;
// -------------------------------------------
// Created 17 September 2003 by cnwdvb1
// -------------------------------------------
vars

	selectedAddresses	: String;
	emailAddress		: CM_EmailAddress2;

begin

	foreach emailAddress in self.allEmailAddresses do
		if emailAddress.emailAddress &lt;&gt; null then	//&lt;&lt;-- PAR9841 Can be null	
			selectedAddresses := selectedAddresses &amp; ';' &amp; emailAddress.emailAddress.trimBlanks();
		endif;
	endforeach;
	if selectedAddresses.length &gt; 1 then
		selectedAddresses := selectedAddresses[2:end];	
	endif;
	return selectedAddresses;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
