    <JadeMethod name="getUniqueOrdCodeLocnDefn" id="0c8b73d3-716e-4282-9af4-638ca0b28dce">
        <source>getUniqueOrdCodeLocnDefn(_code : String; _offsetOrd : Integer; _newCode : String output; _newOrd : Integer output);
/*
Purpose:			
Date		Who		Reason
11 July 2011	cnwab1	Initial creation
*/

vars
	lastLocnDefn : CM_ROROLocnDefn;
begin
	lastLocnDefn := self.allROROLocnDefnByOrdinal.last;
	if lastLocnDefn &lt;&gt; null then
		_newOrd := lastLocnDefn.ordinal + 1;
	else
		_newOrd := _offsetOrd + 1;
	endif;
	// PAR 27595
	while true do : codeLoop
		_newCode := _code &amp; _newOrd.String;
		if self.allDeckItems[_newCode] &lt;&gt; null then
			_newOrd := _newOrd + 1;
		else
			break codeLoop;
		endif;
	endwhile;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_offsetOrd" type="Integer"/>
        <Parameter name="_newCode" type="String" usage="output"/>
        <Parameter name="_newOrd" type="Integer" usage="output"/>
    </JadeMethod>
