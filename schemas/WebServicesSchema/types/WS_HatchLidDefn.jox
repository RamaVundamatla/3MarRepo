    <JadeMethod name="createProxy" id="a783aea0-f535-493a-b5a1-a774e2c30f86">
        <source>createProxy(_pxyBay : CM_BayDefn);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	pxyHatch 		: CM_HatchLidVessel;
	ordinalODStartCell,
	ordinalODEndCell,
	ordinalUDStartCell,
	ordinalUDEndCell	: Integer;
	allBays : 		CM_BaySet;
	cell 		: CM_CellDefn;
	completedOK	 : Boolean;
	wsLayout 		: WS_Layout;
begin
	create allBays transient;
	allBays.add(_pxyBay);
	
	// ordinal end and start cell are the ondeck cells
	// can work out the under deck from this
	cell:=_pxyBay.allCellsOnDeckByOrdinal[self.ordinalCellStart];
	if cell &lt;&gt; null then
		ordinalUDStartCell:=cell.getUnderDeckAlignedCell();
	else // no ondeck
		ordinalUDStartCell := self.ordinalCellStart;
	endif;
	app.writeLog(_pxyBay.allCellsOnDeckByOrdinal.size.String, LogINFO);	//26 Nov 2019	NDL	TFS 47053
	
	cell:=_pxyBay.allCellsOnDeckByOrdinal[self.ordinalCellEnd];
	if cell &lt;&gt; null then
		ordinalUDEndCell:=cell.getUnderDeckAlignedCell();
	else // no ondeck
		ordinalUDEndCell:=self.ordinalCellEnd;
	endif;
	
	// PAR 29610
	// ### UNDERDECK START
	if ordinalUDStartCell = 0 then
		cell:=_pxyBay.allCellsUnderDeckByOrdinal.first;
		if cell &lt;&gt; null then
			ordinalUDStartCell:=cell.ordinal;
		endif;
		if ordinalUDStartCell = 0 then
			cell:=_pxyBay.allCellsOnDeckByOrdinal.first;
			if cell &lt;&gt; null then
				ordinalUDStartCell:=cell.ordinal;
			endif;
		endif;
	endif;
	// ### UNDERDECK END
	if ordinalUDEndCell = 0 then
		cell:=_pxyBay.allCellsUnderDeckByOrdinal.last;
		if cell &lt;&gt; null then
			ordinalUDEndCell:=cell.ordinal;
		endif;
		if ordinalUDEndCell = 0 then
			cell:=_pxyBay.allCellsOnDeckByOrdinal.last;
			if cell &lt;&gt; null then
				ordinalUDEndCell:=cell.ordinal;
			endif;
		endif;
	endif;
	
	create pxyHatch transient;
	pxyHatch.setProxy(	self.ordinalBay,  //ordinalStartBay
						self.ordinalBay, //ordinalEndBay
						self.ordinalCellStart,
						self.ordinalCellEnd,
						ordinalUDStartCell,
						ordinalUDEndCell,	
						self.startsMidCell,
						self.endsMidCell,
						null, //allHolds
						allBays); //bayset
						
	pxyHatch.setMyVessel(_pxyBay.myVesselCellular);		
	
	foreach wsLayout in self.allLayouts discreteLock do
		wsLayout.createProxy(pxyHatch);
	endforeach;
	
	completedOK:=true;
epilog
	delete allBays;
	if not completedOK then
		delete pxyHatch;
	endif;
end;</source>
        <Parameter name="_pxyBay" type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="delete" id="cf9fee74-d9a7-49de-9daf-68e9e1fc09b4">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	allLayouts.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="17259e66-23f9-43d8-9a66-6802687d542c">
        <updating/>
        <source>setProxyFromObject(_hatch : CM_HatchLid) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwer1	Initial creation HAT 2189

*/

vars

begin
	inheritMethod(_hatch);
	
	//always using just the underdeck ordinal cell positions
	self.ordinalCellStart:=_hatch.ordinalUDStartCell;
	self.ordinalCellEnd:=_hatch.ordinalUDEndCell;
	self.endsMidCell:=_hatch.endsMidCell;
	self.startsMidCell:=_hatch.startsMidCell;
	self.ordinalDeck:=DeckUnderDeck; //at this stage always underdeck
	
	self.setProxyLayouts(_hatch);
epilog

end;</source>
        <Parameter name="_hatch" type="CM_HatchLid"/>
    </JadeMethod>
    <JadeMethod name="setProxyLayouts" id="19acb49a-cced-427a-a06f-2a07509953b0">
        <source>setProxyLayouts(_hatchLid : CM_HatchLid) protected;
/*

Date		Who		Reason
16 August 2013	cnwer1	Initial creation PAR

*/

vars
	wsLayout	: WS_Layout;
	layout 		: CM_BayItemLayout;
begin
	foreach layout in _hatchLid.allBayItemLayouts discreteLock do
		create wsLayout transient;
		wsLayout.setProxyFromObject(layout);
		self.allLayouts.add(wsLayout);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_hatchLid" type="CM_HatchLid"/>
    </JadeMethod>
</Class>
