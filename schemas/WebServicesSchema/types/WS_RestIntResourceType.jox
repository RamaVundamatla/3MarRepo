<Class name="WS_RestIntResourceType" id="812b949d-4045-4994-b912-94b7f22a319a">
    <superclass name="WS_RestInternalProxyObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="code" id="74bfd798-109a-4425-b59f-9317132ccc83">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="decimalPlaces" id="192d331e-38e7-4ebe-bacc-4ea7362559e4">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="8fba6d18-f0f7-4612-aea2-3d032dce364f">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="groupCode" id="8b7f537d-45ea-4a25-b79a-6e8aa771a8a4">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="groupDesc" id="720ac828-8234-4649-b393-a129921ed16a">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="isFromToDateTimeRequired" id="96df132b-745e-49b7-8022-25a59ad36239">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="unitDescription" id="1f714b0a-7aeb-4549-98eb-f42b5ca58b8d">
