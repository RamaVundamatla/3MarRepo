begin

	trackedItemId := "id";
	read trackedItemId;
	
	ti := self.getTrackedItem(trackedItemId);
	self.xFixUpTrackedItem(ti);
	

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="uGenerateBigTransMap" id="89e18cd9-0598-485f-8f3b-6e413e53deeb">
        <source>uGenerateBigTransMap();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2017	jlgndl1	Initial creation		TFS 7055

*/

vars

	hugeStringArray : HugeStringArray;
	firstLine : String;
	lineString : String;
	term : CM_Terminal;
	mapName : String;
	cargoType : CM_CargoBOLType;
	cargoTypeStr : String;
	product : CM_Product;
	productStr : String;
	imexString : String;
	imexStringArray : StringArray;
	commodity : CM_Commodity;
	commodityStr : String;
	allTransTypes : CM_TransactionTypeByType;
	transType : CM_TransactionType;
	transTypeStr : String;
	maxSize : Integer;
	
	fileName : String;
	file : File;

begin

	maxSize := 45000;

	create allTransTypes transient;
	
	foreach transType in app.myRoot.allTransactionTypes do
		if transType.trxGroup = TRANS_TYPE_GROUP_HMS
		or transType.trxType = TRANS_TYPE_FUTURE_STORAGE
		then
			continue;
		endif;
		
		allTransTypes.add( transType );
		if allTransTypes.size &gt; 4 then  // fibe trxs will do
			break;
		endif;
		
	endforeach;
	
	create imexStringArray transient;
	imexStringArray.add("Double Lift Restow");
	imexStringArray.add("Export");
	imexStringArray.add("Import");
	imexStringArray.add("Remain On Board");
	imexStringArray.add("Shift On Board");
	imexStringArray.add("Storage");
	imexStringArray.add("Tranship");

	create hugeStringArray transient;

	firstLine :=  "TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?";
	hugeStringArray.add( firstLine );
	
	term := app.myRoot.allTerminals.getAtKey("NDL");
	mapName := "Cargo,BigMap,";
	
	// Default cargoType line
	lineString := mapName &amp; "(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,Void";
	hugeStringArray.add( lineString );
	
	foreach cargoType in term.allCargoBOLTypes do
		if not cargoType.isCargoType then
			continue;
		endif;
		cargoTypeStr := cargoType.abbreviation &amp; "| " &amp; cargoType.description &amp; ",";		//BEER| Beer
		lineString := mapName &amp; cargoTypeStr &amp; "(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,Void";	// Default line for cargo type
		hugeStringArray.add( lineString );
		
		if hugeStringArray.size &gt; maxSize then
			break;
		endif;
		
		foreach product in cargoType.CM_CargoType.allProducts do
		
			if hugeStringArray.size &gt; maxSize then
				break;
			endif;
		
			productStr := "(Default)," &amp; product.code &amp;",";		//"(Default),SPEIGHTS-24,"
			lineString := mapName &amp; cargoTypeStr &amp; productStr &amp; "(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,Void";	// Default line for product
			hugeStringArray.add( lineString );
			
			foreach imexString in imexStringArray do
				lineString := mapName &amp; cargoTypeStr &amp; productStr &amp; imexString &amp; ",(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,Void";
				hugeStringArray.add( lineString );
				
				foreach commodity in cargoType.CM_CargoType.allCommodities do
				
					if hugeStringArray.size &gt; maxSize then
						break;
					endif;
					
					commodityStr := ",(Default)," &amp; commodity.code &amp; ",";	//,(Default),BEER,
					lineString := mapName &amp; cargoTypeStr &amp; productStr &amp; imexString &amp; commodityStr &amp; "(Default),,(Default),(Default) ›,(Default),,,All,Void";
					hugeStringArray.add( lineString );
					
					foreach transType in allTransTypes do
						transTypeStr := transType.description &amp; ",";
						lineString := mapName &amp; cargoTypeStr &amp; productStr &amp; imexString &amp; commodityStr &amp; transTypeStr &amp; ",(Default),(Default) ›,(Default),,,All,Void";
						hugeStringArray.add( lineString );
						
					endforeach; 
					
				endforeach; 
				
			endforeach;
			
		endforeach;
		
	endforeach;

	fileName := "c:/temp\BigMapTMExport.csv";
	create file;
	file.fileName := fileName;
	file.kind := File.Kind_Unknown_Text;
	file.openOutput(fileName);
	
	foreach lineString in hugeStringArray do
		file.writeLine(lineString);
	endforeach;
	
	file.close;

epilog

	delete hugeStringArray;
	delete imexStringArray;
	delete allTransTypes;
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="uGetEntGroup" id="d7cbe726-71a8-464c-9e41-05d3064373ce">
        <source>uGetEntGroup();
/*

Purpose:			

	Get the ent table group name which belongs to the ent table data

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2015	cnwdb2	Initial creation

*/


constants
	EntTabGroupToFind = "WeighBridge" ; 

vars

	schema						: Schema;
	klass						: Class;
	entTableDef					: EntTableDef;
	entTableRow 				: EntTableRow; 
	entTabText 					: XLAT_EntityTableText; 
	xlation 					: XLAT_Translation;
	
	seperatedLines 				: StringArray; 
	goodNamesArray				: HugeStringArray;
	subClasses					: ClassColl;
	errorStrArray				: HugeStringArray;
	
	tempStr						: String;
	includeDutyDoc				: Boolean;
	nameEntDef 					: String;
	errorStr					: String;
	xlationResult 				: String; 
	line : String ; 
	index  :Integer ; 
	
	found, found2 : Boolean ; 
	
	entTableGroup  : EntTableGroup ;

begin
	found := false ; 
	found2 := false ; 

	// initialisations
	includeDutyDoc := app.isDutyDocEnabled;
	
	// Get the required subclasses
	create subClasses transient;
	
	schema := rootSchema.getSchema("SysOpsSchema");
	
	klass := schema.getClass("SOP_TableMaintItem");
	if klass = null then
		write "Class is null" ; 
		return ; 
	endif ; 
	
	klass.allLocalSubclasses(subClasses);

	
	foreach klass in subClasses do
	
		if klass.abstract then
			continue;
		endif;
		
		if klass.name = "SOPTM_EDIActions" then 
			continue;							  
		endif;
		
		if not includeDutyDoc then
			if klass.name = "SOPTM_DutyDocHSCodes" or 
					klass.name = "SOPTM_DutyDocType" or 
					klass.name = "SOPTM_DutyDocExchangeRate" then
				continue;
			endif;
		endif;
		
		if klass.name = "SOPTM_DataAccessSubTerminal" or klass.name = "SOPTM_SubTerminal" then
			if not app.isSubTerminalsLicensed then
			   continue;
			endif;
		endif;		
		
		nameEntDef := self.sysOpsGetEntTableDef(CM_UnitTestAgent::sopGetEntTableDef.name, klass).String;
		entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[nameEntDef];
		
		if entTableDef	&lt;&gt; null	 then
			foreach	entTableRow	in entTableDef.allEntTableRows do
				
				if found = true then
					found2 := true  ;
					break ; 
				endif  ;
				foreach entTableDef in entTableRow.myGroup.allEntTableDefsByName do
					if entTableDef.name = EntTabGroupToFind then
						write entTableRow.myGroup.name ; 
						found := true ; 
					endif ; 
				endforeach ; 
			endforeach ; 
		endif  ;
		
		if found2 = true then
			break ; 
		
		endif ; 
		
	endforeach ;
	
epilog
		delete subClasses  ; 
end ; </source>
    </JadeMethod>
