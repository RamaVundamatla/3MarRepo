    <JadeMethod name="initShtMultiSelect" id="563f2127-926d-4b87-a6db-097a31030d09">
        <source>initShtMultiSelect();

vars
	theForm	: SOP_TableMaintForm;
	terminology : String;
begin

	theForm := self.myForm;	

	//07 Dec 2012	NDL	Par 24669
	theForm.optTypes.visible := true;
	theForm.optGroups.visible := true;

	inheritMethod;
	
	self.setupMultiSelect1("Grades",app.myRoot.allAvailabilityGrades,SOP_TableMaintForm::displayEntryMTGrades.name);	
	   
	//	Par 10009
	terminology := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionPlural, 'Operators');
	self.setupMultiSelect2(terminology,app.myRoot.allOperators,SOP_TableMaintForm::displayEntryOperator.name);
	 
	self.setupMultiSelect3("Tasks",app.myRoot.allToDoTaskDescriptions,SOP_TableMaintForm::displayEntryToDoTaskDesc.name);
	
	self.setupMultiSelect4("ISO","ISO Type","ISO Group",app.myRoot.allISOTypes,app.myRoot.allISOTypeGroups,SOP_TableMaintForm::displayEntryIsoType.name,SOP_TableMaintForm::displayEntryIsoGroup.name);
	//hard code this - we need to be able to set this to half the size of the sheet for todo templates and CAM protocols
	theForm.mulSelect41.stretchHeight := false;

	//Par7355 cnwsh3 Tab order set here so ISOType sheet with two multiselect group boxes is shown
	//before the 'Tasks Applied' sheet with only one multiselect group box. 
	//The code to set up and realign the sheets in the order they are currently is far greater than just
	//changing the tab index.  
	theForm.shtTblInput1.tabIndex := 1;
	theForm.shtMultiSelect1.tabIndex := 2;
	theForm.shtMultiSelect2.tabIndex := 3;
	theForm.shtMultiSelect3.tabIndex := 5;
	theForm.shtMultiSelect4.tabIndex := 4;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="95e32df6-b3d6-4142-8409-9161424f7db7">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;
	time    : Time;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;		
	theForm.mulSelect3.userInputEnabled := true;
	theForm.mulSelect41.userInputEnabled := true;
	theForm.mulSelect42.userInputEnabled := true;		
	theForm.mulSelect1.setSelected(null);
	theForm.mulSelect2.setSelected(null);
	theForm.mulSelect3.setSelected(null);
	theForm.mulSelect41.setSelected(null);
	theForm.mulSelect42.setSelected(null);
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.fldInput.initSheetBackColors();	
	else
		self.showThumbnail(theForm.myProxyObject.CM_ToDoTemplate);
	endif;
	
end;</source>
    </JadeMethod>
