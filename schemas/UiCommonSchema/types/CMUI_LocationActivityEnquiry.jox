    <JadeMethod name="populateLocActivityTable" id="03a04246-05de-4ee5-960f-1d4922576354">
        <updating/>
        <source>populateLocActivityTable() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	invalidObj	: Boolean;
	ed,
	idx		: Integer;
	fixedRows	: Integer;
	partsInJob,
	partsDone	: Integer;
	enqRow	: String;
	table	: CM_DataTable;
	locActivity : CMEVT_LocationActivity;
	ableToBeEdited : Boolean;
	movedirstr : String;
begin
	table := self.tblLocActivity;
	table.rows := table.fixedRows;
	
	partsInJob := self.allLocActivityByDate.size;

	self.modalDialogReturnValue := null;
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, app.getErrorString(CMUI_Displaying_Data), null);
	
	on Exception do app.handleDeletedObject(exception, locActivity, invalidObj);

	if partsInJob &gt; 2000 and (not self.frmModalDialog.visible) then
		self.frmModalDialog.visible := true;
		self.pbProgressBar.partsInJob := partsInJob;
	endif;
	


	foreach locActivity in self.allLocActivityByDate do
		invalidObj := false;
		ed := locActivity.edition;
		if invalidObj then
			continue;
		endif;
		
		if (partsDone mod 2000) = 0 then
			self.modalDialogUpdateInfo(app.getErrorString2(Displaying_items, partsDone.String, partsInJob.String));
			self.pbProgressBar.partsDone := partsDone;
			self.btnModalOpt2.doWindowEvents(0);
			self.frmModalDialog.refreshNow();
			if self.modalDialogReturnValue = self.ModalDialogReturn_Option2 then
				self.searchCancelled := true;
				break;
			endif;
		endif;
	
		// ### TFS 51515 13JUL2021 NAVAB1
//		if filterTranTypes.pos(locActivity.myEventType.name.toUpper(),1) = 0 then
//			continue;
//		endif;
		
		if locActivity.isLocationMove then
			movedirstr := locActivity.directionMode.toUpper();
			if movedirstr &lt;&gt; null
			and filterMoveDirections &lt;&gt; null	//16 Sep 2021	NDL	TFS 51976
			and filterMoveDirections.pos(movedirstr,1) = 0 then
				continue;
			endif;
		endif;
		
		
		enqRow := locActivity.getAttributeStringForDefArray(table.allTblDataEntRows);
		idx := table.addItem(enqRow);
		partsDone := partsDone + 1;
		table.accessRow(idx).itemObject := locActivity;
	
		table.accessRow(idx).backColor := locActivity.getDisplayColour( self.colorRow1 );

		if locActivity.isLocationBalance
		and locActivity.needsRecalculation then  // ### TFS 51515 13JUL2021 NAVAB1
			// ### TFS 51515 13JUL2021 NAVAB1 table.accessCell(idx,10).foreColor := Red;
			table.accessRow(idx).foreColor := Red;// ### TFS 51515 13JUL2021 NAVAB1
		endif;
	
		// 'table limit exceeded' message has already been shown in the query, just stop here, don't get the second message from the table as well
		if partsDone + fixedRows &gt;= JadeTableRowLimit then
			break;
		endif;
	endforeach;
	
	self.enableButtons();
	
epilog
	self.frmModalDialog.visible := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
