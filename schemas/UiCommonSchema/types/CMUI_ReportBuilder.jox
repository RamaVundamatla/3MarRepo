/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/

vars
	baseTbl 	: CM_BaseTable;
	theRow		: Integer;
	str			: String;
	status		: CM_Association;
begin
	baseTbl := self.tblCriteria;
	theRow := self.myReportAgent.getRowByControlName(table.name);

	if theRow &lt;&gt; 0 then
		baseTbl.accessRow(theRow).height := self.saveRowHeight.Integer;
		self.saveRowHeight := 0;		// set to 0 so that can use in pTable.cellInputReady;
		baseTbl.scrollBars := Table.ScrollBars_Both;
		
		foreach status in table.allSelectedObjects as CM_Association do
			if str = null then
				str := str &amp; app.vbsStatusNumToString(status.CM_Association.getValue().Integer);
			else
				str := str &amp; Comma &amp; app.vbsStatusNumToString(status.CM_Association.getValue().Integer);
			endif;
		endforeach;
		baseTbl.setCellText(theRow, self.Column_DefaultValue, str);
	endif;
epilog

end;</source>
