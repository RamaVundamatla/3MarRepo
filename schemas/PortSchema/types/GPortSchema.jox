    <JadeMethod name="loadBinaryFile" id="6c5dff8c-dad5-4723-acf4-b293b1f4f694">
        <source>loadBinaryFile(_fileName : String; 
				_usePresentationFileSystem : Boolean;
				_cmifMonitor : CMIF_Monitor input) : Binary;
// ---------------------------------------------------------------------------
// Created:     18 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  CNWTH2 - pass in a monitor to chunk it up
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	f				: File;
	binChunk,
	bin				: Binary;
	fileDisplayName	: String;
	idx,
	offset,
	fileLength,
	chunkSize,
	byteCount		: Integer;
begin
	
	create f transient;
	f.usePresentationFileSystem := _usePresentationFileSystem;
	f.shareMode 	:= File.Share_Read;
	f.kind 			:= File.Kind_Binary;
	f.readOnly 		:= true;
	f.allowCreate 	:= false;
	f.allowReplace 	:= false;
	f.mode 			:= File.Mode_Input;
	f.fileName 		:= _fileName;
	
	if not f.isAvailable then
		return null;
	endif;
	
	f.open;
	
	if _cmifMonitor &lt;&gt; null then
		chunkSize	:=	File_DownloadChunkSize;
		fileLength 		:= f.fileLength();
		idx := _fileName.reversePos('\');
		fileDisplayName := _fileName[idx + 1 : end];
		
		while offset &lt;= fileLength do
			if (fileLength - offset) &lt; chunkSize then
				chunkSize	:=	fileLength - offset;
			endif;
			
			if offset &lt;&gt; 0 then
				f.seek(offset);
			endif;
			
			binChunk :=	f.readBinary(chunkSize);
			bin := bin &amp; binChunk;

			_cmifMonitor.updateProgress('Reading file : ' &amp; fileDisplayName,
									  (fileLength / 1024).Integer, (offset / 1024).Integer);
			
			if _cmifMonitor.monitorReturnValue = _cmifMonitor.MonitorReturnValue_Cancel then
				return null;
			endif;
			
			if offset &gt;= fileLength then
				break;
			endif;
			
			offset := offset + binChunk.length;
			
		endwhile;
		
		_cmifMonitor.updateProgress('Reading file : ' &amp; fileDisplayName, 
									(fileLength / 1024).Integer, (offset / 1024).Integer);
		if _cmifMonitor.monitorReturnValue = _cmifMonitor.MonitorReturnValue_Cancel then
			return null;
		endif;
	else
		bin := f.readBinary(f.fileLength);
	endif;
	
	return bin;

epilog
	f.close;
	delete f;
	
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_usePresentationFileSystem" type="Boolean"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="loadBinaryFileServer" id="931874ff-bfd8-40e0-ba6d-fe05131d7820">
        <executionLocation>server</executionLocation>
        <source>loadBinaryFileServer(_fileName : String; _cmifMonitor : CMIF_Monitor input) : Binary serverExecution;
// ---------------------------------------------------------------------------
// Created:     17 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.loadBinaryFile(_fileName, false, _cmifMonitor);

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="odbcValidateUsercodePassword" id="154b1d5e-1ea5-4c34-806f-6711f9e88801">
        <source>odbcValidateUsercodePassword(_usercode, _password : String) : Integer;
/*
Purpose:			Validate usercode and password without going into transaction state
					(so no alerts, no updates to logon attempts, etc)

Parameters:			

Return Value:		

Date		Who		Reason
06/11/2012	cnwdap1	Initial creation CCMS APM 2208 PAR #30668
*/
vars
	userObj			: CM_User;
	errCode			: Integer;
	
begin
	app.writeLog(method.qualifiedName &amp; " usercode to be validated is " &amp; _usercode, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	//====================
	// Does user exist?
	//===================	
 	userObj	:=	app.myRoot.allUsers[_usercode.toUpper];

 	if userObj = null then
		errCode := ERR_PASSWORD;
		app.writeLog('User ' &amp; _usercode &amp; ' not known in system', LogERROR);	//25 Nov 2019	NDL	TFS 47053
		return errCode;
	endif;
	
  	//===================
  	// Password correct?
  	//===================
	errCode := 0;
	app.writeLog(method.qualifiedName &amp; " checking password...", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	if userObj.isValidPassword(_password) = false then
		errCode	:=	ERR_PASSWORD;
		app.writeLog('User ' &amp; _usercode &amp; ' password supplied is invalid', LogERROR);	//25 Nov 2019	NDL	TFS 47053
		return errCode;
	endif;
 
	//==============
	// Not disabled?
	//==============
//	if userObj.isSuspended() then
	if userObj.isSuspendedOrIsDisabled() then	 //23 Nov 2020	NDL TFS 50378
		app.writeLog('User ' &amp; _usercode &amp; ' is suspended or disabled', LogERROR);	//25 Nov 2019	NDL	TFS 47053
		return ERR_USER_SUSPENDED;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " calling setForLogon on app.myPassport", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	app.myPassport.setForLogon(userObj);

 	if userObj.isPasswordOld() then
	   app.writeLog('User ' &amp; userObj.code &amp; ' logged on - requires password change ******', LogERROR);	//25 Nov 2019	NDL	TFS 47053
 		return Err_Password_Expired;		
 	endif;
	
	if not app.isWebApp and not app.myRoot.concurrentAppSignonCheck(userObj, errCode, null,null, app.myPassport) then
	   	app.writeLog('User ' &amp; userObj.code &amp; ' failed concurrent signon test - errCode is ' &amp; errCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053
		return errCode;
	endif;
	
	app.writeLog(method.qualifiedName &amp; ' usercode ' &amp; _usercode &amp; ' successfully validated', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
 	return 0;
epilog

end;</source>
        <Parameter name="_usercode" type="String"/>
        <Parameter name="_password" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="safeAnyToObject" id="bc330625-d284-45d4-8aa6-f6dd7f2ae6d7">
        <source>safeAnyToObject(a : Any; o : Object output) : Boolean;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwsb1
//--------------------------------------------------------------

vars
	gotEx : Boolean;
	
begin
	if a = null then
		o := null;
		return true;
	endif;
	
	gotEx := false;
	
	on Exception do self.safeAnyToObjectExHandler(exception, gotEx);
	
	o := a.Object;
	
	// If the type guard gets a 4, 1072, 1086 or 4029, our handler will resume to here
	if gotEx then
		o := null;
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="a" type="Any"/>
        <Parameter name="o" type="Object" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="safeAnyToObjectExHandler" id="53fde0ad-cb8a-4dd4-82e8-c248e0f04ede">
        <source>safeAnyToObjectExHandler(exObj : Exception; gotEx : Boolean output) : Integer protected;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwsb1
//--------------------------------------------------------------

constants
	ObjectNotFound = 4;
	ObjectDeleted = 1072;
	TypeGuardFailed = 1086;
	IllegalConversion = 4029;
	
begin
	gotEx := true;
	if exObj.errorCode = ObjectNotFound  or exObj.errorCode = ObjectDeleted  or
	   exObj.errorCode = TypeGuardFailed or exObj.errorCode = IllegalConversion
	then
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="gotEx" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="schDoErrorBreak" id="b360fe74-7c8a-40bd-b11c-fb5c4a94bb40">
        <updating/>
        <source>schDoErrorBreak() :Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 29 July 2007
//
//----------------------------------------------------------------------

vars

begin
		app.raiseCMException1(Early_break_message_withParam, method.name, null,null);
		return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setExtraData" id="be509d49-ffeb-4b64-aaae-03ca3abc2bfb">
        <source>setExtraData(_allExtraData : CM_StateDataDict;
			 _parent : Object;
			 _key : String; _value : Any);
//--------------------------------------------------------------
//Created: 23 October 2002 By: cnwgd1
//11-04-2024 navrv30 Task 62541: MTN - [Extra Data][2] Stop Creating Extra Data Object with Null Value
//10 May 2024	navrv30	ChangeRequest 63763: MTN - [Extra Data][2] Stop Creating Extra Data Object with Null Value - Update Mode
//28 May 2024   navrv30 Defect 64330: MTN - Extra Data - Boolean value should not be saved if it is false
//19 Nov 2025 	navhl20 Bug MTN-36492: TPA - Overall System Slowness
//--------------------------------------------------------------
// Assumes that we are in transaction state
vars
	data		: CM_StateData;
	dataClass	: Class;
	theClass	: Class;
	tmpDict		: CM_StateDataDict;
begin

	data := _allExtraData[_key];

	if data &lt;&gt; null then
		// cnwjre1 May 2014 from cash conversion: handle reference value being cleared
		if _value = null then
			dataClass := data.class;
			if dataClass = CM_StateCollection or
			   dataClass = CM_StateObject then
				tmpDict := _allExtraData;
				tmpDict.remove(data);
				delete data;
				return;
			else 							//10 May 2024	navrv30	CR 63763
				data.clearReferences();
				delete data;
				return;
			endif;
		endif;
		//28 May 2024   navrv30 Defect 64330
		if _value.String = "false" then
			data.clearReferences();
			delete data;
			return;
		endif;
					
		theClass := self.getDataClass(_value);
		if data.class &lt;&gt; theClass then
			// need to delete and re-add
			delete data;
			data := null;
		endif;
	endif;

	
	if data = null then
		theClass := self.getDataClass(_value);
		// causes problems trying to set a new value to false
		// if it is a string can have value = null i.e. false if a Boolean
		if _value = null or (_value.isKindOf(String) and _value.String = "false") then			//11-04-2024 navrv30 Task 62541 Even for a string do not have null value	//19.11.2025 navhl20 #36492
			return;
		endif;
		if _parent.isTransient then
			create data as theClass transient;
		else
			create data as theClass persistent;
		endif;
		data.set(_key, _value, _parent);
		if (not _allExtraData.includes(data)) then
			// Done this way as some dicts not inversed
			// as transient so need to add in manually.
			// Need to set to local variable so can update
			tmpDict := _allExtraData;
			tmpDict.add(data);
		endif;
	else
		data.setValue(_value);
	endif;

end;</source>
        <Parameter name="_allExtraData" type="CM_StateDataDict"/>
        <Parameter name="_parent" type="Object"/>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="splitTISetForMove" id="6dd9b0cd-ddda-4204-8f89-1c48c792b7fc">
        <source>splitTISetForMove(_tis : CM_TISet; _type, _maxNum : Integer; _outSet : CM_TISetOfSets input);
// ---------------------------------------------------------------------------
// Created:     29 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpCargoTypeDict	: CM_TIByCargoTypeDict;
	ti				: CM_TrackedItem;
	iter			: Iterator;
	cnt,
	cargoTypeKey,
	oldCargoType	: Integer;
	tmpSet			: CM_TISet;
	commodity,
	productCode		: String;
	
begin

	create tmpCargoTypeDict transient;
	_tis.copy(tmpCargoTypeDict);

	iter := tmpCargoTypeDict.createIterator;

	while iter.next(ti) do
		tmpCargoTypeDict.getIteratorKeys(cargoTypeKey, productCode, commodity, iter);
		if oldCargoType &lt;&gt; cargoTypeKey or
		   (_maxNum &lt;&gt; 0 and cnt &gt;= _maxNum) then
			create tmpSet transient;
			_outSet.add(tmpSet);
			cnt := 0;
		endif;
		tmpSet.add(ti);
		oldCargoType := cargoTypeKey;
		cnt := cnt + 1;
	endwhile;

epilog
	delete tmpCargoTypeDict;
	delete iter;
	//delete tmpSet; Do not delete this here. They are output used in _outSet by the move controller and will be deleted when the move controller is deleted.
end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_maxNum" type="Integer"/>
        <Parameter name="_outSet" type="CM_TISetOfSets" usage="input"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="b16e18dd-5269-49d3-b3a8-8bf96c5834e6">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// -------------------------------------------
// Created 08 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if eventTag = Keep_Alive_Timer then
		app.writeLog('Keeping Alive', LogINFO);
		self.tryLock(self, Share_Lock, Session_Duration, LockTimeout_Immediate); 
	endif;

epilog
	self.unlock(self);
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="writeForUser" id="114b647f-7f61-4a0e-b839-0a2d5d5efe35">
        <source>writeForUser(_userNameToWriteFor : String; _doForSUPERUSER : Boolean; _text: String);
// ---------------------------------------------------------------------------
// Created:		29 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if app.isDevelopmentSystem then
		if (app.userName.toUpper = _userNameToWriteFor.toUpper) 
		or (_doForSUPERUSER and app.isSpecial()) then
			app.writeStatement( _userNameToWriteFor &amp; " " &amp;  _text);
		endif;
	endif;
end;</source>
        <Parameter name="_userNameToWriteFor" type="String"/>
        <Parameter name="_doForSUPERUSER" type="Boolean"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
</Class>
