    <JadeMethod name="getAuditText" id="2aa50f2b-433e-474f-a9f1-6b5c09c38c5f">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     29 October 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt,
	classStr,
	tmpStr	: String;
	obj		: Object;
	
begin
	txt[10000] := '*';
	txt := null;

	txt := inheritMethod();

	classStr := self.getClassName();
	
	foreach obj in self.allObjects do
		tmpStr := self.getCodeForObject(obj);
		if tmpStr &lt;&gt; null then
			txt := txt &amp; classStr &amp; ' ' &amp; tmpStr &amp; AuditStringSeparator &amp; '4' &amp; AuditStringSeparator &amp; 'true' &amp; AuditStringSeparator;
		endif;
	endforeach;
	
	return txt;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getClassName" id="a0b3fbe2-1ced-4211-9a7b-9c3207679907">
        <source>getClassName() : String;
// ---------------------------------------------------------------------------
// Created:     29 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//13 July 2018	jlgrh7 TFS #39277  Cargo Update Requests - inconsistent Reason Action Failed field
// ---------------------------------------------------------------------------
vars

begin

	if self.myClassContained = CM_Carrier then
		return 'Carrier';
	elseif self.myClassContained = CM_ConsigneeConsignor then
		return 'Consignee/Consignor';
	elseif self.myClassContained = CM_Operator then
		return 'Operator';
	elseif self.myClassContained = CM_Organisation then
		return 'Organisation';
	elseif self.classContainedName = CM_Operator.name then							//+TFS39244
		return "Operator";
	elseif self.myClassContained = CM_CustomsAgent then				//+TFS39244
		return "Customs Agent";
	else
		return self.myClassContained.name;
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCodeForObject" id="e91f1a6d-5916-4f01-ba3e-3f30e9c8c4aa">
        <source>getCodeForObject(pObj : Object) : String protected;
// ---------------------------------------------------------------------------
// Created:     29 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	code	: String;
	
begin

   	if self.myClassContained = CM_Carrier then
   		code := pObj.CM_Carrier.code;
   	elseif self.myClassContained = CM_ConsigneeConsignor then
   		code := pObj.CM_ConsigneeConsignor.code;
   	elseif self.myClassContained = CM_Operator then
   		code := pObj.CM_Operator.code;
   	elseif self.myClassContained = CM_Organisation then
   		code := pObj.CM_Organisation.name;
   	else
   		code := null;
   	endif;

	return code;
	
end;</source>
        <access>protected</access>
        <Parameter name="pObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCodeString" id="7196765c-2a58-417b-a086-b353d6d1e474">
        <source>getCodeString() : String;//serverExecution;
// ---------------------------------------------------------------------------
// Created:     27 August 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	i,
	x		: Integer;
	code,
	str		: String;
	obj		: Object;
	col	 	: Collection;
	carrier	: CM_Carrier;
	oper	: CM_Operator;
	consign	: CM_ConsigneeConsignor;	
	dynaDict	: DynaDictionary;
	any		: Any;
begin

    x := 1;
    
    if self.mustNotBeIncluded then
    	if self.myClassContained = CM_Carrier then
    		col := app.myRoot.allCarriers;
    	elseif self.myClassContained = CM_ConsigneeConsignor then
    		col := app.myRoot.allConsigneeConsignors;
    	elseif self.myClassContained = CM_Operator then
    		col := app.myRoot.allOperators;
    	elseif self.myClassContained = CM_Organisation then
    		col := app.myRoot.allOrganisations;
    	endif;
    else
    	// As self.allObjects is not sorted we resort for the list
		create dynaDict transient;
		dynaDict.setMembership(self.myClassContained);
		dynaDict.addMemberKey(self.getKeyName(), false, false);
		dynaDict.endKeys(false);
    	self.allObjects.copy(dynaDict);
    	col := dynaDict;
    endif;
    
    if col = null then
    	return null;
    endif;
    
    foreach any in col do
    	obj := any.Object;
	    if self.mustNotBeIncluded then
	    	if self.allObjects.includes(obj.CM_Object) then
	    		continue;
	    	endif;
	    	
	    		    	//PAR10654
	    	if self.myClassContained = CM_Carrier then
	    		if obj.CM_Carrier.isNotAvailableForEntry then 
	    			continue;
	    		endif;
	    	elseif self.myClassContained = CM_ConsigneeConsignor then
	    		if obj.CM_ConsigneeConsignor.isNotAvailableForEntry then 
	    			continue;
	    		endif;
	    	elseif self.myClassContained = CM_Operator then
	    		if obj.CM_Operator.isNotAvailableForEntry then 
	    			continue;
	    		endif;
	    	elseif self.myClassContained = CM_Organisation then
	    		if obj.CM_Organisation.isNotAvailableForEntry then 
	    			continue;
	    		endif;
	    	endif;
	    		    	
   			str := str &amp; self.getCodeForObject(obj) &amp; ', ';
   			if x mod 12 = 0 then
   				str := str &amp; CrLf;
   			endif;
	    else
	    	if not self.allObjects.includes(obj.CM_Object) then
	    		continue;
	    	endif;
	    	
	    		    	//PAR10654
	    	if self.myClassContained = CM_Carrier then
	    		if obj.CM_Carrier.isNotAvailableForEntry then 
	    			continue;
	    		endif;
	    	elseif self.myClassContained = CM_ConsigneeConsignor then
	    		if obj.CM_ConsigneeConsignor.isNotAvailableForEntry then 
	    			continue;
	    		endif;
	    	elseif self.myClassContained = CM_Operator then
	    		if obj.CM_Operator.isNotAvailableForEntry then 
	    			continue;
	    		endif;
	    	elseif self.myClassContained = CM_Organisation then
	    		if obj.CM_Organisation.isNotAvailableForEntry then 
	    			continue;
	    		endif;
	    	endif;
	    	
   			str := str &amp; self.getCodeForObject(obj) &amp; ', ';
   			if x mod 12 = 0 then
   				str := str &amp; CrLf;
   			endif;
	    endif;
	    x := x + 1;
    endforeach;

    return str;

epilog
	delete dynaDict;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7fdc69ef-73db-478e-ac39-239e91993c3b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 05 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _attrName = ETRow_Code then
		return self.name;
	elseif _attrName = ETRow_Description then
		return self.getClassName();
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyName" id="54046c93-2a0a-4726-9b41-003bfe8567ab">
        <source>getKeyName() : String protected;
// ---------------------------------------------------------------------------
// Created:     29 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

   	if self.myClassContained = CM_Organisation then
   		return 'name';
   	endif;

	return 'code';
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="myClassContained" id="bc2364fa-09f7-4f1a-adc4-ce5f1aad8995">
        <methodInvocation>mapping</methodInvocation>
        <source>myClassContained(set: Boolean; _value: Class io) mapping;
// ---------------------------------------------------------------------------
// Created:     17 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := currentSchema.getClass(self.classContainedName);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Class" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAllObjects" id="484a1135-9ec4-4b8f-bac6-4c110e8d1e34">
        <updating/>
        <source>setAllObjects(_objs : CM_ObjectSetActual) updating, protected;
// ---------------------------------------------------------------------------
// Created:			04 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj : CM_Object;
begin
	allObjects.clear();
 	if self.myClassContained = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "myClassContained", null, null);
		return;
	endif;
	foreach obj in _objs do
		if (not obj.class.inheritsFrom(self.myClassContained)) then
		    
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ObjectNotOfClass, obj.class.name, self.myClassContained.name, null, null);
			return;
		endif;
		self.allObjects.add(obj);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_objs" type="CM_ObjectSetActual"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="201b518b-38da-465e-b475-55f2e075bfcc">
        <updating/>
        <source>setForCreate(_name : String; _class : Class; _allObjects : CM_ObjectSetActual ; _mustNotBeIncluded, _includeNull : Boolean; _root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:			04 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.mustNotBeIncluded := _mustNotBeIncluded;
	self.includeIfNull := _includeNull;
	self.name := _name;
	self.setMyClassContained(_class);
	self.setAllObjects(_allObjects);
	self.myRoot := _root;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_allObjects" type="CM_ObjectSetActual"/>
        <Parameter name="_mustNotBeIncluded" type="Boolean"/>
        <Parameter name="_includeNull" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="75427724-c38f-4c1d-8fcc-111b8f47bac4">
        <updating/>
        <source>setForUpdate(_allObjects : CM_ObjectSetActual; _mustNotBeIncluded, _includeNull : Boolean ) updating;
// ---------------------------------------------------------------------------
// Created:			04 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.mustNotBeIncluded := _mustNotBeIncluded;
	self.includeIfNull := _includeNull;
	self.setAllObjects(_allObjects);
	
end;</source>
        <Parameter name="_allObjects" type="CM_ObjectSetActual"/>
        <Parameter name="_mustNotBeIncluded" type="Boolean"/>
        <Parameter name="_includeNull" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyClassContained" id="8db043c0-a668-4de1-957c-ee84a767f550">
        <updating/>
        <source>setMyClassContained(_myClassContained : Class) updating, protected;
// ---------------------------------------------------------------------------
// Created:			04 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _myClassContained.getSuperclass &lt;&gt; CM_Object then
		//If this is not one of our objects, then forget it!

		app.setContinueCMExceptions(false);
		app.raiseCMException2(ObjectNotOfClass, _myClassContained.name, CM_Object.name, null, null);
		return;
	endif;
	self.classContainedName := _myClassContained.name;
end;</source>
        <access>protected</access>
        <Parameter name="_myClassContained" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="24fcab92-9e20-4433-913e-9c2462e80540">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;
	
end;</source>
    </JadeMethod>
</Class>
