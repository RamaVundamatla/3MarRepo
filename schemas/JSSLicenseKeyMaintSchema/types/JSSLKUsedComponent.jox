        <Inverse name="JSSLKComponent::allUsedComponents"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myUsedProduct" id="ee9ae29e-d2d5-4ee6-9373-3e3cf4cc56ed">
