<Class name="CM_QBooleanMethod" id="4373d5db-73dc-4512-9243-54d630ce9751">
    <superclass name="CM_QueryMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="d74abc8e-a195-4518-811c-548f70af5b02">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwas3	Initial creation

*/

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QueryBooleanOperator persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="8e698c04-1b8e-4722-8044-1906b64d2b00">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwas3	Initial creation

*/

vars

begin
	if _op.isKindOf(CM_QueryBooleanOperator) then
		return QueryControl_ComboBox;
	endif;

	return inheritMethod(_op);

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="e2d4be4c-3748-4e68-b53c-13e54972bed2">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     12 February 2010 by cnwcs5
// Purpose:     par 22140
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.niceName.length + 3 +
			app.getTranslatedStringYes.length.max (app.getTranslatedStringNo.length); // 12/02/2010 cnwcs5 par 22140
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
