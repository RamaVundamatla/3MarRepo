    <JadeMethod name="createView" id="421dba0c-0dd8-45e5-8806-866d55dcf41a">
        <updating/>
        <source>createView() updating;

/*

Purpose:		Create initial view for current terminal.

Parameters:			

Return Value:		


Date				Who		Reason
04 September 2008	consw1	Initial creation

*/

vars
	proxyAreaView	: CM_TerminalAreaView;
	realAreaView	: CM_TerminalAreaView;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	create proxyAreaView transient;
	proxyAreaView.setTerminal(self.myTerminal);
	proxyAreaView.setName("Default");

	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateTerminalAreaView(proxyAreaView, realAreaView, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.unloadForm;
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete proxyAreaView;
end;</source>
    </JadeMethod>
