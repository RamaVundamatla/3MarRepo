<Class name="CarElementPrintVisitor" id="10d8aa71-cf23-41b1-b884-914f45049557">
    <superclass name="CarElementVisitor"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="visit" id="5d6cfc47-6a35-4547-b348-69b51ac9f609">
        <source>visit(element: Any);
//18 August 2009	cnwdw1	
//
vars

begin
	if element.isKindOf(Body) then
		write "Visiting Body";
	elseif element.isKindOf(Engine) then
		write "Visiting Engine";
	elseif element.isKindOf(Wheel) then
		write "Visiting Wheel "&amp;element.Wheel.name;
	endif;
end;</source>
        <Parameter name="element" type="Any"/>
    </JadeMethod>
    <JadeMethod name="visitCar" id="a33d431c-5049-4528-841d-37871121b984">
        <source>visitCar(_car: Car);
//18 August 2009	cnwdw1	
//
vars
	obj: Object;
begin
	write "============";
	write "Visiting Car";
	foreach obj in _car.elements do
		obj.CarElement.accept(self);
	endforeach;
	write "Visited Car";
end;</source>
        <Parameter name="_car" type="Car"/>
    </JadeMethod>
</Class>
