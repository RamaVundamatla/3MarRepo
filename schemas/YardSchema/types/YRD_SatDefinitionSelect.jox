	self.unloadForm();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="c1142d10-3463-4cf4-bf13-0a021aa1439d">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwer1	Initial creation

*/

vars
	selectedView : CM_TerminalAreaView;
begin
	
	selectedView:=self.lstTAViews.listObject.CM_TerminalAreaView;

	inheritMethod();
