    <JadeMethod name="getDescription" id="d1bd4400-7b9e-40d9-bede-6a2022ffc391">
        <source>getDescription() : String;

vars

begin
	return self.getDebtorString() &amp; "/" &amp; self.getLineTypeString() &amp; "/" &amp; self.getInvoiceTypeString();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="53cc009f-0e5f-4401-981f-31abc254a218">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			Gets the display string for an attribute passed in from an Ent Table Def

Parameters:			_attrName	String	The attribute name
					_short		Boolean	Whether it is a short field or not

Return Value:		String	The string to display

Date		Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	if _attrName = ETRow_Bank then
		if self.myBank = null then
			return null;
		endif;
		
		return self.myBank.code;
		
	elseif _attrName = ETRow_Debtor then
		if self.myDebtor = null then
			return null;
		endif;
		
		return self.myDebtor.name;
		
	elseif _attrName = ETRow_InvoiceType then
		if self.myInvoiceType = null then
			return null;
		endif;
		
		return self.myInvoiceType.description;
		
	elseif _attrName = ETRow_InvoiceLineType then
		if self.myInvoiceLineDesc = null then
			return null;
		endif;
		
		return self.myInvoiceLineDesc.narration;
		
	else
		return inheritMethod(_attrName, _short);
		
	endif;
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
