  &lt;AllLayout/&gt;
  &lt;AllCargoOnShip&gt;
    &lt;CargoOnShip&gt;
      &lt;site&gt;3&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
      &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
      &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/001&lt;/id&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;CMA-CGM366&lt;/sealShipper&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
	  &lt;AllToDoTask/&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/002&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;TBE495037&lt;/sealShipper&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/003&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/004&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
  &lt;/AllCargoOnShip&gt;
 &lt;/JMTInternalShipManifest&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;'1'&amp;method.name);
//return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 9, "incorrect number of EDI trackedItems");
	
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTranship xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTranship.xsd"&gt;
  &lt;AllTranship&gt;
    &lt;Tranship&gt;
      &lt;site&gt;3&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
      &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
      &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/001&lt;/id&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;CMA-CGM366&lt;/sealShipper&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;exportVoyageCode&gt;'&amp;ExportVoyageName&amp;'&lt;/exportVoyageCode&gt;
	&lt;/Tranship&gt;
	&lt;Tranship&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/002&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;TBE495037&lt;/sealShipper&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;exportVoyageCode&gt;'&amp;ExportVoyageName&amp;'&lt;/exportVoyageCode&gt;
	&lt;/Tranship&gt;
	&lt;Tranship&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/003&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;exportVoyageCode&gt;'&amp;ExportVoyageName&amp;'&lt;/exportVoyageCode&gt;
	&lt;/Tranship&gt;
	&lt;Tranship&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/004&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;exportVoyageCode&gt;'&amp;ExportVoyageName&amp;'&lt;/exportVoyageCode&gt;
	&lt;/Tranship&gt;
  &lt;/AllTranship&gt;
 &lt;/JMTInternalTranship&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME_TRANSHIP, USER_DEF_NAME_TRANSHIP&amp;'2'&amp;method.name);
//return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");

	// Create the Receives
    
	// create terminal area
    self.deleteTerminalArea(BlockStackName);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
    
    create cargoItems transient;
    voyage.getAllTrackedItems(cargoItems);    
   // Discharge 4 of the items 
    foreach cargoItem in cargoItems do
        count := count + 1;
        self.move(cargoItem, bs);
        if count = 4 then
            break;
        endif;
    endforeach;

//	beginTransaction;
//    et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
//    et.CMEVT_VoyageEvent.setMyVoyage(voyage);
//    commitTransaction;

	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create camTrainEventTypes transient;
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainDepart]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonConfirmed]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonDeparted]);
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Warehouse"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
//	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.zOutput_AST_WareXMLTransEBITrn(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "warehouse_activity");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	delete cargoItems;
	delete camTrainEventTypes;
	app.setIsBackGroundApp (false);
	delete camEditTriggerFields;
	delete voyageNames;
	delete voyageArray;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tAlabamaSteelWareXMLTransEBI" id="0ba842b6-1105-44d3-84cd-c49959a1baea">
        <updating/>
        <source>tAlabamaSteelWareXMLTransEBI() updating;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams Transactions only
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 10 Sep 2019	cnwrs1	TFS 46030
constants
	USER_DEF_NAME : String = "JMTInternalShipManifest";
	Cargo_Type = "COILS";
	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOY4AST';				
	BoatName		= 'UT_VES4AST';
	PortName		= "NZAKL";
	ContainerName1	= 'COIL240501';
	ContainerName2	= 'COIL240502';
	ContainerName3	= 'COIL240503';
	ContainerName4	= 'COIL240504';
	ContainerName5	= 'COIL240505';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT_AST4";
	CamProtocol 	= "UT_ASTWAREHOUSE2";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "UTOP";
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
//	container1, container2, container3, container4, container5 : CM_Container;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	cargo3 : CM_TrackedItem;
	cargo4 : CM_TrackedItem;
	cargo5 : CM_TrackedItem;
	operator : CM_Operator;
	defaultOperator : CM_Operator;
	voyage : CM_Voyage;
	defaultVoyage : CM_Voyage;
	passport : CM_Passport;
	bs 	: CM_BlockStack;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	theSlot : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
	cargoTypeObj : CM_CargoType;
	cargoSubType : CM_Product;
	ediText : String;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	errorMsg : String;
	expectedOutput : String;
	cargoItems : CM_TISet;
	cargoItem : CM_TrackedItem;
	count : Integer;
	et : CM_EventTransaction;
	camTrainEventTypes : CM_EventTypeByNameDict;
	measureType : CM_MeasurementType;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	create camEditTriggerFields transient;
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null and
	   measureType.conversionRate &lt;&gt; 1 then
		beginTransaction;
		measureType.setPropertyValue(CM_MeasurementType::isDefault.name, false);
		commitTransaction;
	endif;
	measureType := app.myRoot.allMeasurementTypesByShortName['kg'];
	if measureType &lt;&gt; null then
		if not measureType.isDefault then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::isDefault.name, true);
			commitTransaction;
		endif;
		if not measureType.format = 14.3 then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::format.name, '14.3'.Decimal);
			commitTransaction;
		endif;
	endif;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoSubType := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];

	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	cargo1 := self.getTrackedItem(ContainerName1);
	self.deleteTrackedItem(cargo1, false);
	cargo1 := self.getTrackedItem(ContainerName1);
	self.assertIsDeleted(cargo1);
	
	cargo2 := self.getTrackedItem(ContainerName2);
	self.deleteTrackedItem(cargo2, false);
	cargo2 := self.getTrackedItem(ContainerName2);
	self.assertIsDeleted(cargo2);
	
	cargo3 := self.getTrackedItem(ContainerName3);
	self.deleteTrackedItem(cargo3, false);
	cargo3 := self.getTrackedItem(ContainerName3);
	self.assertIsDeleted(cargo3);
	
	cargo4 := self.getTrackedItem(ContainerName4);
	self.deleteTrackedItem(cargo4, false);
	cargo4 := self.getTrackedItem(ContainerName4);
	self.assertIsDeleted(cargo4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	voyage := self.createVesselVoyage ( VoyageName, BoatName,operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addCargoAtLocationDetailed(ContainerName3, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_EXPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo3.getImExStatus() =TI_IMEX_STATUS_EXPORT), "ImEx on Exports is wrong" );
	beginTransaction;
	cargo3.setLoadPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addCargoAtLocationDetailed(ContainerName4, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_EXPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo4.getImExStatus() =TI_IMEX_STATUS_EXPORT), "ImEx on Exports is wrong" );
	beginTransaction;
	cargo4.setLoadPort ("NZLYT");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	cargo1 := self.addCargoAtLocationDetailed(ContainerName1, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo1, tempStr);
	beginTransaction;
	cargo1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	cargo2 := self.addCargoAtLocationDetailed(ContainerName2, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo2, tempStr);
	
//	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
//	self.assertNoTrxErrorsOrWarnings ();
	
//	self.createVoyageDischargeJobs(voyage, crane.id);
//	self.createVoyageLoadJobs(voyage, PortName, crane.id);
//	self.planLoadItems(voyage, crane.id);
//	self.loadAllJobsToOps(voyage, true);
//	self.planDischargeItems(voyage, bs, crane.id);
//	self.moveAllCargo(voyage);

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalShipManifest xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalShipManifest.xsd"&gt;
  &lt;AllBOLHeader&gt;
    &lt;BOLHeader&gt;
      &lt;bolType&gt;5003&lt;/bolType&gt;
      &lt;numItems&gt;50&lt;/numItems&gt;
      &lt;id&gt;BOL01&lt;/id&gt;
      &lt;loadPort&gt;GBLIV&lt;/loadPort&gt;
      &lt;messageMode&gt;A&lt;/messageMode&gt;
      &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
      &lt;AllBOLDetails&gt;
        &lt;BOLDetails&gt;
          &lt;weight&gt;8090.0000&lt;/weight&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
          &lt;consignee&gt;UOP Tonawanda / Tonawanda NY&lt;/consignee&gt;
          &lt;consignor&gt;UOP Tonawanda / Tonawanda NY&lt;/consignor&gt;
          &lt;id&gt;BOL01&lt;/id&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
        &lt;/BOLDetails&gt;
        &lt;BOLDetails&gt;
          &lt;weight&gt;16960.0000&lt;/weight&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
          &lt;consignee&gt;UOP Tonawanda / Tonawanda NY&lt;/consignee&gt;
          &lt;consignor&gt;UOP Tonawanda / Tonawanda NY&lt;/consignor&gt;
          &lt;id&gt;BOL01&lt;/id&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
        &lt;/BOLDetails&gt;
      &lt;/AllBOLDetails&gt;
    &lt;/BOLHeader&gt;
  &lt;/AllBOLHeader&gt;
  &lt;AllLayout/&gt;
  &lt;AllCargoOnShip&gt;
    &lt;CargoOnShip&gt;
      &lt;site&gt;3&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
      &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
      &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/001&lt;/id&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;CMA-CGM366&lt;/sealShipper&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
	  &lt;AllToDoTask/&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/002&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;TBE495037&lt;/sealShipper&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/003&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/004&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
  &lt;/AllCargoOnShip&gt;
 &lt;/JMTInternalShipManifest&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
//return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 9, "incorrect number of EDI trackedItems");
	
	// Create the Receives
    
	// create terminal area
    self.deleteTerminalArea(BlockStackName);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
    
    create cargoItems transient;
    voyage.getAllTrackedItems(cargoItems);    
   // Discharge 4 of the items 
    foreach cargoItem in cargoItems do
        count := count + 1;
		beginTransaction;
		cargoItem.setDeliveryRelease("912345678901234567890");
		commitTransaction;
        self.move(cargoItem, bs);
        if count = 4 then
            break;
        endif;
    endforeach;

//	beginTransaction;
//   et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
//    et.CMEVT_VoyageEvent.setMyVoyage(voyage);
//    commitTransaction;

	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create camTrainEventTypes transient;
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainDepart]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonConfirmed]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonDeparted]);
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Warehouse"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
//	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.zOutput_AST_WareXMLTransEBI(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "warehouse_activity");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	delete cargoItems;
	delete camTrainEventTypes;
	app.setIsBackGroundApp (false);
	delete camEditTriggerFields;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tAlabamaSteelWareXMLTransERI" id="f7b205c3-6d62-4d82-b19a-90f0b68d4235">
        <updating/>
        <source>tAlabamaSteelWareXMLTransERI() updating;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams Transactions only
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
// 10 Sep 2019	cnwrs1	TFS 46030
constants
	USER_DEF_NAME : String = "JMTInternalTrainConsist";
	Cargo_Type = "COILS";
	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOY4AST';				
	BoatName		= 'UT_VES4AST';
	PortName		= "NZAKL";
	ContainerName1	= 'COIL240501';
	ContainerName2	= 'COIL240502';
	ContainerName3	= 'COIL240503';
	ContainerName4	= 'COIL240504';
	ContainerName5	= 'COIL240505';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT_AST4";
	CamProtocol 	= "UT_ASTWAREHOUSE2";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "UTOP";
	TrainCode = "UT-TRAIN03";
	WagonCode = "UK35564";
	RAILAREA	= 'RR35564';
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
//	container1, container2, container3, container4, container5 : CM_Container;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	cargo3 : CM_TrackedItem;
	cargo4 : CM_TrackedItem;
	cargo5 : CM_TrackedItem;
	operator : CM_Operator;
	defaultOperator : CM_Operator;
	voyage : CM_Voyage;
	defaultVoyage : CM_Voyage;
	passport : CM_Passport;
	bs 	: CM_BlockStack;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	theSlot : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
	cargoTypeObj : CM_CargoType;
	cargoSubType : CM_Product;
	ediText : String;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	errorMsg : String;
	expectedOutput : String;
	cargoItems : CM_TIArray;
	cargoItem : CM_TrackedItem;
	count : Integer;
	et : CM_EventTransaction;
	camTrainEventTypes : CM_EventTypeByNameDict;
	train : CM_Train;
	wagonMaster : CM_WagonMaster;
	railArea : CM_Rail;
	railIORake : CM_RailJSInOutRake;
	railLine : CM_RailLine;
	obj : Object;
	wagon : CM_Wagon;
	ti : CM_TrackedItem;
	measureType : CM_MeasurementType;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	create camEditTriggerFields transient;
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null and
	   measureType.conversionRate &lt;&gt; 1 then
		beginTransaction;
		measureType.setPropertyValue(CM_MeasurementType::isDefault.name, false);
		commitTransaction;
	endif;
	measureType := app.myRoot.allMeasurementTypesByShortName['kg'];
	if measureType &lt;&gt; null then
		if not measureType.isDefault then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::isDefault.name, true);
			commitTransaction;
		endif;
		if not measureType.format = 14.3 then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::format.name, '14.3'.Decimal);
			commitTransaction;
		endif;
	endif;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoSubType := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];

	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	cargo1 := self.getTrackedItem(ContainerName1);
	self.deleteTrackedItem(cargo1, false);
	cargo1 := self.getTrackedItem(ContainerName1);
	self.assertIsDeleted(cargo1);
	
	cargo2 := self.getTrackedItem(ContainerName2);
	self.deleteTrackedItem(cargo2, false);
	cargo2 := self.getTrackedItem(ContainerName2);
	self.assertIsDeleted(cargo2);
	
	cargo3 := self.getTrackedItem(ContainerName3);
	self.deleteTrackedItem(cargo3, false);
	cargo3 := self.getTrackedItem(ContainerName3);
	self.assertIsDeleted(cargo3);
	
	cargo4 := self.getTrackedItem(ContainerName4);
	self.deleteTrackedItem(cargo4, false);
	cargo4 := self.getTrackedItem(ContainerName4);
	self.assertIsDeleted(cargo4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	wagonMaster := self.getRoot.allWagonMasters[WagonCode];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteTrain(TrainCode, null);
	self.deleteTrain(TrainCode, null);

	self.deleteRailArea(RAILAREA);

	railArea := self.addRailArea(RAILAREA, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
		
	self.assertNotNull(railIORake);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	voyage := self.createVesselVoyage ( VoyageName,BoatName, operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addCargoAtLocationDetailed(ContainerName3, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);

	self.assertTrueMsg((cargo3.getImExStatus() =TI_IMEX_STATUS_EXPORT), "ImEx on Exports is wrong" );
	beginTransaction;
	cargo3.setLoadPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addCargoAtLocationDetailed(ContainerName4, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);

	self.assertTrueMsg((cargo4.getImExStatus() =TI_IMEX_STATUS_EXPORT), "ImEx on Exports is wrong" );
	beginTransaction;
	cargo4.setLoadPort ("NZLYT");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	cargo1 := self.addCargoAtLocationDetailed(ContainerName1, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo1, tempStr);
	beginTransaction;
	cargo1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	cargo2 := self.addCargoAtLocationDetailed(ContainerName2, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo2, tempStr);
	
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTrainConsist xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTrainConsist.xsd"&gt;
&lt;AllTrain&gt;
&lt;Train&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;000000001&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;scheduleCode&gt;DDTEST&lt;/scheduleCode&gt;
&lt;trainCode&gt;'&amp;TrainCode&amp;'&lt;/trainCode&gt;
&lt;trainDestination&gt;NZDUD&lt;/trainDestination&gt;
&lt;trainOrigin&gt;NZCHC&lt;/trainOrigin&gt;
&lt;scheduledArrivalDT&gt;05 April 2010, 15:30:00&lt;/scheduledArrivalDT&gt;
&lt;scheduledDepartureDT&gt;01 May 2010, 00:00:00&lt;/scheduledDepartureDT&gt;
&lt;AllWagon&gt;
&lt;Wagon&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;carrierCode&gt;ABC&lt;/carrierCode&gt;
&lt;id&gt;00000002&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;trainCode&gt;'&amp;TrainCode&amp;'&lt;/trainCode&gt;
&lt;wagonClass&gt;UK&lt;/wagonClass&gt;
&lt;wagonNumber&gt;'&amp;WagonCode&amp;'&lt;/wagonNumber&gt;
&lt;scheduledArrivalDT&gt;05 April 2010, 15:30:00&lt;/scheduledArrivalDT&gt;
  &lt;AllPrenote&gt;
    &lt;Prenote&gt;
      &lt;site&gt;3&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
      &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
      &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/001&lt;/id&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
&lt;transportMode&gt;Rail&lt;/transportMode&gt;
&lt;wagonNumber&gt;'&amp;WagonCode&amp;'&lt;/wagonNumber&gt;
	&lt;/Prenote&gt;
	&lt;Prenote&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/002&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Rail&lt;/transportMode&gt;
&lt;wagonNumber&gt;'&amp;WagonCode&amp;'&lt;/wagonNumber&gt;
	&lt;/Prenote&gt;
	&lt;Prenote&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/003&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Rail&lt;/transportMode&gt;
&lt;wagonNumber&gt;'&amp;WagonCode&amp;'&lt;/wagonNumber&gt;
	&lt;/Prenote&gt;
	&lt;Prenote&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/004&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Rail&lt;/transportMode&gt;
&lt;wagonNumber&gt;'&amp;WagonCode&amp;'&lt;/wagonNumber&gt;
	&lt;/Prenote&gt;
  &lt;/AllPrenote&gt;
&lt;/Wagon&gt;
&lt;/AllWagon&gt;
  &lt;/Train&gt;
  &lt;/AllTrain&gt;
 &lt;/JMTInternalTrainConsist&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.opts.purge();
	self.opts.addAssoc("SetRemarks", false);
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 6, "incorrect number of EDI trackedItems");
	
	// Create the Receives
    
	// create terminal area
    self.deleteTerminalArea(BlockStackName);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
    
	train := self.getTrain(TrainCode, null);
	wagon := self.getWagon(WagonCode, train);
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	create cargoItems transient;
    train.getAllTrackedItems(true, cargoItems);    
   // Discharge 4 of the items 
    foreach cargoItem in cargoItems do
        count := count + 1;
        self.move(cargoItem, bs);
        if count = 4 then
            break;
        endif;
    endforeach;
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create camTrainEventTypes transient;
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);

	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Warehouse"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);

	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.zOutput_AST_WareXMLTransERIa(expectedOutput);	//14 Aug 2020	NDL TFS 49876 - Data the same but order corrected.
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "warehouse_activity");
	
	// 14/09/2015 cnwmh5
	beginTransaction;
	foreach ti in voyage.allOnsiteTIsByCargoTypeId discreteLock do
		ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	endforeach;
	commitTransaction;	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	delete cargoItems;
	delete camTrainEventTypes;
	app.setIsBackGroundApp (false);
	self.updateEDITIRemarks(ediFileObj);
	delete camEditTriggerFields;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tAlabamaSteelWareXMLTransERO" id="67f50b18-0496-4389-af6e-29b9721f4c9f">
        <updating/>
        <source>tAlabamaSteelWareXMLTransERO() updating;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams Transactions only
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 10 Sep 2019	cnwrs1	TFS 46030
constants
	USER_DEF_NAME : String = "JMTInternalTrainConsist";
	Cargo_Type = "COILS";
	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOY4AST';				
	BoatName		= 'UT_VES4AST';
	PortName		= "NZAKL";
	CoilName1	= 'UT_VOY4AST/BOL01/001';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT_AST4";
	CamProtocol 	= "UT_ASTWAREHOUSE2";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "UTOP";
	TrainCode = "UT-TRAIN04";
	WagonCode = "BV35564";
	RAILAREA	= 'RR35564';
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
	cargo1 : CM_TrackedItem;
	operator : CM_Operator;
	defaultOperator : CM_Operator;
	voyage : CM_Voyage;
	defaultVoyage : CM_Voyage;
	passport : CM_Passport;
	bs 	: CM_BlockStack;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	lc : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
	cargoTypeObj : CM_CargoType;
	cargoSubType : CM_Product;
	ediText : String;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	errorMsg : String;
	expectedOutput : String;
	cargoItems : ObjectSet;
	cargoItem : CM_TrackedItem;
	count : Integer;
	ix : Integer;
	et : CM_EventTransaction;
	camTrainEventTypes : CM_EventTypeByNameDict;
	train : CM_Train;
	pxyTrain : CM_Train;
	wagonMaster : CM_WagonMaster;
	railArea : CM_Rail;
	railIORake : CM_RailJSInOutRake;
	railLine : CM_RailLine;
	obj : Object;
	wagon : CM_Wagon;
	wle :CM_WorkListEntry;
	request : CM_Request;
	reserve : CM_ReserveDetail;
	release	: CM_BulkRelease;
	cmifObjects : ObjectArray;
	intFaceBP : CMIF_BuildPriority;
	cmifRequest	: CMIF_Request;
	moveController	: CMIF_MoveController;
	destination : CM_LocationsController;
//	moveController	: CMIF_MoveController;
	trainSet : CM_TrainSet;
	cmifRakeRegion : CMIF_RakeRegion;
	measureType : CM_MeasurementType;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	create camEditTriggerFields transient;
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null and
	   measureType.conversionRate &lt;&gt; 1 then
		beginTransaction;
		measureType.setPropertyValue(CM_MeasurementType::isDefault.name, false);
		commitTransaction;
	endif;
	measureType := app.myRoot.allMeasurementTypesByShortName['kg'];
	if measureType &lt;&gt; null then
		if not measureType.isDefault then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::isDefault.name, true);
			commitTransaction;
		endif;
		if not measureType.format = 14.3 then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::format.name, '14.3'.Decimal);
			commitTransaction;
		endif;
	endif;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoSubType := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];

	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	cargo1 := self.getTrackedItem(CoilName1);
	self.deleteTrackedItem(cargo1, false);
	cargo1 := self.getTrackedItem(CoilName1);
	self.assertIsDeleted(cargo1);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	wagonMaster := self.getRoot.allWagonMasters[WagonCode];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteTrain(TrainCode, null);
	self.deleteRailArea(RAILAREA);

	railArea := self.addRailArea(RAILAREA, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
//return;		
	self.assertNotNull(railIORake);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	voyage := self.createVesselVoyage ( VoyageName,BoatName, operator);
	
	// create terminal area
	bs := self.addBlockStack(BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargoOnSite&gt;
&lt;AllCargoOnSite&gt;
    &lt;CargoOnSite&gt;
      &lt;site&gt;1&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
      &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
      &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/001&lt;/id&gt;
      &lt;locationId&gt;'&amp;BlockStackName&amp;'&lt;/locationId&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/CargoOnSite&gt;
	&lt;/AllCargoOnSite&gt;
 &lt;/JMTInternalCargoOnSite&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;'1'&amp;method.name);
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.opts.purge();
	self.opts.addAssoc("SetRemarks", false);
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTrainConsist xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTrainConsist.xsd"&gt;
&lt;AllTrain&gt;
&lt;Train&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;000000001&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;scheduleCode&gt;DDTEST&lt;/scheduleCode&gt;
&lt;trainCode&gt;'&amp;TrainCode&amp;'&lt;/trainCode&gt;
&lt;trainDestination&gt;NZDUD&lt;/trainDestination&gt;
&lt;trainOrigin&gt;NZCHC&lt;/trainOrigin&gt;
&lt;scheduledArrivalDT&gt;05 April 2014, 15:30:00&lt;/scheduledArrivalDT&gt;
&lt;scheduledDepartureDT&gt;01 May 2014, 00:00:00&lt;/scheduledDepartureDT&gt;
&lt;AllWagon&gt;
&lt;Wagon&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;carrierCode&gt;ABC&lt;/carrierCode&gt;
&lt;id&gt;00000002&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;trainCode&gt;'&amp;TrainCode&amp;'&lt;/trainCode&gt;
&lt;wagonClass&gt;BV&lt;/wagonClass&gt;
&lt;wagonNumber&gt;'&amp;WagonCode&amp;'&lt;/wagonNumber&gt;
&lt;scheduledArrivalDT&gt;05 April 2014, 15:30:00&lt;/scheduledArrivalDT&gt;
&lt;/Wagon&gt;
&lt;/AllWagon&gt;
  &lt;/Train&gt;
  &lt;/AllTrain&gt;
 &lt;/JMTInternalTrainConsist&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;'2'&amp;method.name);
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.opts.purge();
	self.opts.addAssoc("SetRemarks", false);
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 2, "incorrect number of EDI trackedItems");
    
	train := self.getTrain(TrainCode, null);
	wagon := self.getWagon(WagonCode, train);

	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(app.actualTimeServer);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	create moveController transient;
	create cargoItems transient;
    bs.getAllLocationsTrackedItems(cargoItems);    
	cargoItem := cargoItems.first.CM_TrackedItem;
	lc := wagon.allLocationsControllers.first;
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 1);
	release := self.addReleaseById("UTRRail"&amp;idx.String, BR_TYPE_RAIL, cargoItem);

	// assign release to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	release.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	release.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.quantityTxt := release.allReserveDetails.size;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	moveController.setMyOriginatingLocation(bs.allLocationsControllers.first);
	moveController.setMyTrackedItem(cargoItem);
	moveController.setMyWorkListEntry(railIORake.railJobs.first.CM_RailJob.workListEntries.first);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	moveController.setMyToPrimaryLocation(lc);
	moveController.setMoveMode(QUEUE_MODE);
	moveController.isForcedMove := true;
	app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	reserve := release.allReserveDetails.first;
	request := reserve.allRequests.first;
	wle := release.allRequestsBeingActioned.first.allWorkListEntries.first;

 	app.myTrxUA.trxAssignWleToWagonController(wle.CM_YardWLE, 1, lc.CM_WagonController, false, app.myPassport);

	self.moveQueuedCargo (wle);

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);  //iout
	
	// clear the entire train.
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add (wagon);
	cmifRakeRegion.clearAll	:= false;
	
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create camTrainEventTypes transient;
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainDepart]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonConfirmed]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonDeparted]);
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
//return;	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Warehouse"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
//	self.runCamsNow(startDateTime, camProtocol);

	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.zOutput_AST_WareXMLTransERO(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "warehouse_activity");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	delete cargoItems;
	delete camTrainEventTypes;
	app.setIsBackGroundApp (false);
	delete pxyTrain;
	delete cmifObjects;
	if intFaceBP &lt;&gt; null then
		delete intFaceBP.myProxyRailJob;
	endif;
	delete intFaceBP;
	delete moveController;
	delete cmifRequest;
	delete cmifRakeRegion;
	delete trainSet;
	self.updateEDITIRemarks(ediFileObj);
	delete camEditTriggerFields;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAlabamaSteelWareXMLTransETI" id="d981c0b2-7a48-4b1e-8913-f441b14cb28c">
        <updating/>
        <source>tAlabamaSteelWareXMLTransETI() updating;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams Transactions only
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 10 Sep 2019	cnwrs1	TFS 46030
constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	Cargo_Type = "COILS";
	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOY4AST';				
	BoatName		= 'UT_VES4AST';
	PortName		= "NZAKL";
	ContainerName1	= 'COIL240501';
	ContainerName2	= 'COIL240502';
	ContainerName3	= 'COIL240503';
	ContainerName4	= 'COIL240504';
	ContainerName5	= 'COIL240505';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT_AST4";
	CamProtocol 	= "UT_ASTWAREHOUSE2";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "UTOP";
	Bookin = "Book2405";
//	TrainCode = "UT-TRAIN03";
//	WagonCode = "UK35564";
//	RAILAREA	= 'RR35564';
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
//	container1, container2, container3, container4, container5 : CM_Container;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	cargo3 : CM_TrackedItem;
	cargo4 : CM_TrackedItem;
	cargo5 : CM_TrackedItem;
	operator : CM_Operator;
	defaultOperator : CM_Operator;
	voyage : CM_Voyage;
	defaultVoyage : CM_Voyage;
	passport : CM_Passport;
	bs 	: CM_BlockStack;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	theSlot : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
	cargoTypeObj : CM_CargoType;
	cargoSubType : CM_Product;
	ediText : String;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	errorMsg : String;
	expectedOutput : String;
	cargoItems : CM_TIArray;
	cargoItem : CM_TrackedItem;
	count : Integer;
	et : CM_EventTransaction;
	camTrainEventTypes : CM_EventTypeByNameDict;
	gate : CM_Gate;
//	train : CM_Train;
//	wagonMaster : CM_WagonMaster;
//	railArea : CM_Rail;
//	railIORake : CM_RailJSInOutRake;
//	railLine : CM_RailLine;
//	obj : Object;
//	wagon : CM_Wagon;
	measureType : CM_MeasurementType;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	create camEditTriggerFields transient;
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null and
	   measureType.conversionRate &lt;&gt; 1 then
		beginTransaction;
		measureType.setPropertyValue(CM_MeasurementType::isDefault.name, false);
		commitTransaction;
	endif;
	measureType := app.myRoot.allMeasurementTypesByShortName['kg'];
	if measureType &lt;&gt; null then
		if not measureType.isDefault then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::isDefault.name, true);
			commitTransaction;
		endif;
		if not measureType.format = 14.3 then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::format.name, '14.3'.Decimal);
			commitTransaction;
		endif;
	endif;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoSubType := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];

	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	cargo1 := self.getTrackedItem(ContainerName1);
	self.deleteTrackedItem(cargo1, false);
	cargo1 := self.getTrackedItem(ContainerName1);
	self.assertIsDeleted(cargo1);
	
	cargo2 := self.getTrackedItem(ContainerName2);
	self.deleteTrackedItem(cargo2, false);
	cargo2 := self.getTrackedItem(ContainerName2);
	self.assertIsDeleted(cargo2);
	
	cargo3 := self.getTrackedItem(ContainerName3);
	self.deleteTrackedItem(cargo3, false);
	cargo3 := self.getTrackedItem(ContainerName3);
	self.assertIsDeleted(cargo3);
	
	cargo4 := self.getTrackedItem(ContainerName4);
	self.deleteTrackedItem(cargo4, false);
	cargo4 := self.getTrackedItem(ContainerName4);
	self.assertIsDeleted(cargo4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
//	wagonMaster := self.getRoot.allWagonMasters[WagonCode];
//	if wagonMaster &lt;&gt; null then
//		self.deleteWagonMasterAndWagons( wagonMaster );
//	endif;
//	self.deleteTrain(TrainCode, null);
//	self.deleteRailArea(RAILAREA);

//	railArea := self.addRailArea(RAILAREA, 4, 5);
//	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
//	foreach obj in railArea.allRailJSInOut discreteLock do
//		railIORake := obj.CM_RailJSInOutRake;
//		if railIORake.getIoType() = Rail_JSIO_Type_Out then
//			break;
//		endif;
//		railIORake := null;
//	endforeach;
	
//	self.assertNotNull(railIORake);
	
//	railLine := railArea.allRailLinesByIndex.first; 
//	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	voyage := self.createVesselVoyage ( VoyageName,BoatName, operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addCargoAtLocationDetailed(ContainerName3, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_EXPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo3.getImExStatus() =TI_IMEX_STATUS_EXPORT), "ImEx on Exports is wrong" );
	beginTransaction;
	cargo3.setLoadPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addCargoAtLocationDetailed(ContainerName4, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_EXPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo4.getImExStatus() =TI_IMEX_STATUS_EXPORT), "ImEx on Exports is wrong" );
	beginTransaction;
	cargo4.setLoadPort ("NZLYT");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	cargo1 := self.addCargoAtLocationDetailed(ContainerName1, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo1, tempStr);
	beginTransaction;
	cargo1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	cargo2 := self.addCargoAtLocationDetailed(ContainerName2, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo2, tempStr);
	
//	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
//	self.assertNoTrxErrorsOrWarnings ();
	
//	self.createVoyageDischargeJobs(voyage, crane.id);
//	self.createVoyageLoadJobs(voyage, PortName, crane.id);
//	self.planLoadItems(voyage, crane.id);
//	self.loadAllJobsToOps(voyage, true);
//	self.planDischargeItems(voyage, bs, crane.id);
//	self.moveAllCargo(voyage);
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalBooking&gt;
&lt;AllBookingHeader&gt;
&lt;BookingHeader&gt;
&lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
&lt;consignor&gt;UTCOE&lt;/consignor&gt;
&lt;destinationPort&gt;SAJED&lt;/destinationPort&gt;
&lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
&lt;id&gt;'&amp;Bookin&amp;'&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
&lt;vesselName&gt;'&amp;BoatName&amp;'&lt;/vesselName&gt;
&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;AllBookingItem&gt;
&lt;BookingItem&gt;
&lt;weight&gt;18830.0000&lt;/weight&gt;
&lt;number&gt;1&lt;/number&gt;
&lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
&lt;id&gt;'&amp;Bookin&amp;'&lt;/id&gt;
&lt;/BookingItem&gt;
&lt;/AllBookingItem&gt;
&lt;/BookingHeader&gt;
&lt;/AllBookingHeader&gt;
&lt;/JMTInternalBooking&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;'1'&amp;method.name);
//return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.opts.purge();
	self.opts.addAssoc("SetRemarks", false);
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write method.name&amp;" EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 2, "incorrect number of EDI trackedItems");

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalPrenote&gt;
    &lt;AllPrenote&gt;
    &lt;Prenote&gt;
      &lt;site&gt;3&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;bookingRef&gt;'&amp;Bookin&amp;'&lt;/bookingRef&gt;
      &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
      &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/001&lt;/id&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/Prenote&gt;
	&lt;Prenote&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;bookingRef&gt;'&amp;Bookin&amp;'&lt;/bookingRef&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/002&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/Prenote&gt;
	&lt;Prenote&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;bookingRef&gt;'&amp;Bookin&amp;'&lt;/bookingRef&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/003&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/Prenote&gt;
	&lt;Prenote&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;bookingRef&gt;'&amp;Bookin&amp;'&lt;/bookingRef&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/004&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/Prenote&gt;
    &lt;/AllPrenote&gt;
&lt;/JMTInternalPrenote&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;'2'&amp;method.name);
//return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.opts.purge();
	self.opts.addAssoc("SetRemarks", false);
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	
	// Create the Receives
    
	// create terminal area
    self.deleteTerminalArea(BlockStackName);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
    
//	train := self.getTrain(TrainCode, null);
//	wagon := self.getWagon(WagonCode, train);
//	railLine.switchPositions(wagon, 01);	
//	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
//	app.myTrxUA.trxUpdateWagonConfirmTrain(true, train, true, app.myPassport);  //in
//	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
    create cargoItems transient;
//	train.getAllTrackedItems(true, cargoItems);    
   // Discharge 4 of the items 
	deleteVehicle("UTTRUCK");
	self.opts.addAssoc("AutoComplete", true);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/001', gate);
	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/001').isOnSite);
	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/002', gate);
	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/002').isOnSite);
	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/003', gate);
	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/003').isOnSite);
	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/004', gate);
	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/004').isOnSite);
//	vvr :=  self.gateInPrenote(TruckId, "", DriverId, ti7, dualGate);
    foreach cargoItem in cargoItems do
        count := count + 1;
        self.move(cargoItem, bs);
        if count = 4 then
            break;
        endif;
    endforeach;

//	beginTransaction;
//   et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
//    et.CMEVT_VoyageEvent.setMyVoyage(voyage);
//    commitTransaction;

	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create camTrainEventTypes transient;
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainDepart]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonConfirmed]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonDeparted]);
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Warehouse"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
//	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.zOutput_AST_WareXMLTransETI(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "warehouse_activity");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	delete cargoItems;
	delete camTrainEventTypes;
	app.setIsBackGroundApp (false);
	self.updateEDITIRemarks(ediFileObj);
	delete camEditTriggerFields;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tAlabamaSteelWareXMLTransETR" id="4fa53491-88c3-41cc-a9dd-4ee2046d9df8">
        <updating/>
        <source>tAlabamaSteelWareXMLTransETR() updating;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams Transactions only
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 10 Sep 2019	cnwrs1	TFS 46030
constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	Cargo_Type = "COILS";
	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOY4AST';				
	BoatName		= 'UT_VES4AST';
	PortName		= "NZAKL";
	ContainerName1	= 'COIL240501';
	ContainerName2	= 'COIL240502';
	ContainerName3	= 'COIL240503';
	ContainerName4	= 'COIL240504';
	ContainerName5	= 'COIL240505';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT_AST4";
	CamProtocol 	= "UT_ASTWAREHOUSE2";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "UTOP";
//	TrainCode = "UT-TRAIN03";
//	WagonCode = "UK35564";
//	RAILAREA	= 'RR35564';
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
//	container1, container2, container3, container4, container5 : CM_Container;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	cargo3 : CM_TrackedItem;
	cargo4 : CM_TrackedItem;
	cargo5 : CM_TrackedItem;
	operator : CM_Operator;
	defaultOperator : CM_Operator;
	voyage : CM_Voyage;
	defaultVoyage : CM_Voyage;
	passport : CM_Passport;
	bs 	: CM_BlockStack;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	theSlot : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
	cargoTypeObj : CM_CargoType;
	cargoSubType : CM_Product;
	ediText : String;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	errorMsg : String;
	expectedOutput : String;
	cargoItems : CM_TIArray;
	cargoItem : CM_TrackedItem;
	count : Integer;
	et : CM_EventTransaction;
	camTrainEventTypes : CM_EventTypeByNameDict;
	gate : CM_Gate;
	vehicleVisitRecord : CM_VehicleVisitRecord;
//	train : CM_Train;
//	wagonMaster : CM_WagonMaster;
//	railArea : CM_Rail;
//	railIORake : CM_RailJSInOutRake;
//	railLine : CM_RailLine;
//	obj : Object;
//	wagon : CM_Wagon;
	measureType : CM_MeasurementType;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	create camEditTriggerFields transient;
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null and
	   measureType.conversionRate &lt;&gt; 1 then
		beginTransaction;
		measureType.setPropertyValue(CM_MeasurementType::isDefault.name, false);
		commitTransaction;
	endif;
	measureType := app.myRoot.allMeasurementTypesByShortName['kg'];
	if measureType &lt;&gt; null then
		if not measureType.isDefault then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::isDefault.name, true);
			commitTransaction;
		endif;
		if not measureType.format = 14.3 then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::format.name, '14.3'.Decimal);
			commitTransaction;
		endif;
	endif;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoSubType := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];

	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');

	// delete the cargo - this should have already been done if on the voyage, but just in case.
	cargo1 := self.getTrackedItem(ContainerName1);
	self.deleteTrackedItem(cargo1, false);
	cargo1 := self.getTrackedItem(ContainerName1);
	self.assertIsDeleted(cargo1);
	
	cargo2 := self.getTrackedItem(ContainerName2);
	self.deleteTrackedItem(cargo2, false);
	cargo2 := self.getTrackedItem(ContainerName2);
	self.assertIsDeleted(cargo2);
	
	cargo3 := self.getTrackedItem(ContainerName3);
	self.deleteTrackedItem(cargo3, false);
	cargo3 := self.getTrackedItem(ContainerName3);
	self.assertIsDeleted(cargo3);
	
	cargo4 := self.getTrackedItem(ContainerName4);
	self.deleteTrackedItem(cargo4, false);
	cargo4 := self.getTrackedItem(ContainerName4);
	self.assertIsDeleted(cargo4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

//	wagonMaster := self.getRoot.allWagonMasters[WagonCode];
//	if wagonMaster &lt;&gt; null then
//		self.deleteWagonMasterAndWagons( wagonMaster );
//	endif;
//	self.deleteTrain(TrainCode, null);
//	self.deleteRailArea(RAILAREA);

//	railArea := self.addRailArea(RAILAREA, 4, 5);
//	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
//	foreach obj in railArea.allRailJSInOut discreteLock do
//		railIORake := obj.CM_RailJSInOutRake;
//		if railIORake.getIoType() = Rail_JSIO_Type_Out then
//			break;
//		endif;
//		railIORake := null;
//	endforeach;
	
//	self.assertNotNull(railIORake);
	
//	railLine := railArea.allRailLinesByIndex.first; 
//	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	voyage := self.createVesselVoyage (VoyageName,BoatName,  operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addCargoAtLocationDetailed(ContainerName3, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_EXPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo3.getImExStatus() =TI_IMEX_STATUS_EXPORT), "ImEx on Exports is wrong" );
	beginTransaction;
	cargo3.setLoadPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addCargoAtLocationDetailed(ContainerName4, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_EXPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo4.getImExStatus() =TI_IMEX_STATUS_EXPORT), "ImEx on Exports is wrong" );
	beginTransaction;
	cargo4.setLoadPort ("NZLYT");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	cargo1 := self.addCargoAtLocationDetailed(ContainerName1, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo1, tempStr);
	beginTransaction;
	cargo1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	cargo2 := self.addCargoAtLocationDetailed(ContainerName2, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
//	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo2, tempStr);
	
//	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
//	self.assertNoTrxErrorsOrWarnings ();
	
//	self.createVoyageDischargeJobs(voyage, crane.id);
//	self.createVoyageLoadJobs(voyage, PortName, crane.id);
//	self.planLoadItems(voyage, crane.id);
//	self.loadAllJobsToOps(voyage, true);
//	self.planDischargeItems(voyage, bs, crane.id);
//	self.moveAllCargo(voyage);

	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalPrenote&gt;
    &lt;AllPrenote&gt;
    &lt;Prenote&gt;
      &lt;site&gt;3&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
      &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
      &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/001&lt;/id&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/Prenote&gt;
	&lt;Prenote&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/002&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/Prenote&gt;
	&lt;Prenote&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/003&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/Prenote&gt;
	&lt;Prenote&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/004&lt;/id&gt;
	  &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/Prenote&gt;
    &lt;/AllPrenote&gt;
 &lt;/JMTInternalPrenote&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;

	self.opts.purge();
	self.opts.addAssoc("SetRemarks", false);
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");

	// Create the Receives
    
	// create terminal area
    self.deleteTerminalArea(BlockStackName);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
    
//	train := self.getTrain(TrainCode, null);
//	wagon := self.getWagon(WagonCode, train);
//	railLine.switchPositions(wagon, 01);	
//	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
//	app.myTrxUA.trxUpdateWagonConfirmTrain(true, train, true, app.myPassport);  //in
//	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
    create cargoItems transient;
//	train.getAllTrackedItems(true, cargoItems);    
   // Discharge 4 of the items 
	deleteVehicle("UTTRUCK");
	self.opts.addAssoc("AutoComplete", true);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/001', gate);
	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/001').isOnSite);
	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/002', gate);
	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/002').isOnSite);
	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/003', gate);
	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/003').isOnSite);
	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/004', gate);
	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/004').isOnSite);
//	vvr :=  self.gateInPrenote(TruckId, "", DriverId, ti7, dualGate);
	cargo1 := self.getTrackedItem(VoyageName&amp;'/BOL01/001');
	vehicleVisitRecord := cargo1.allVisitRecords.first.CM_VehicleVisitRecord;
	beginTransaction;
	vehicleVisitRecord.setPropertyValue(CM_VehicleVisitRecord::carrierCode.name,"CSA");
	commitTransaction;
	cargo1 := self.getTrackedItem(VoyageName&amp;'/BOL01/002');
	vehicleVisitRecord := cargo1.allVisitRecords.first.CM_VehicleVisitRecord;
	beginTransaction;
	vehicleVisitRecord.setPropertyValue(CM_VehicleVisitRecord::carrierCode.name,"CSA");
	commitTransaction;
	cargo1 := self.getTrackedItem(VoyageName&amp;'/BOL01/003');
	vehicleVisitRecord := cargo1.allVisitRecords.first.CM_VehicleVisitRecord;
	beginTransaction;
	vehicleVisitRecord.setPropertyValue(CM_VehicleVisitRecord::carrierCode.name,"CSA");
	commitTransaction;
	cargo1 := self.getTrackedItem(VoyageName&amp;'/BOL01/004');
	vehicleVisitRecord := cargo1.allVisitRecords.first.CM_VehicleVisitRecord;
	beginTransaction;
	vehicleVisitRecord.setPropertyValue(CM_VehicleVisitRecord::carrierCode.name,"CSA");
	commitTransaction;
//	foreach cargoItem in cargoItems do
//        count := count + 1;
//       self.move(cargoItem, bs);
//        if count = 4 then
//            break;
//        endif;
//    endforeach;

//	beginTransaction;
//   et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
//    et.CMEVT_VoyageEvent.setMyVoyage(voyage);
//    commitTransaction;

	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create camTrainEventTypes transient;
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainDepart]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonConfirmed]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonDeparted]);
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Warehouse"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
//	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.zOutput_AST_WareXMLTransETR(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "warehouse_activity");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	delete cargoItems;
	delete camTrainEventTypes;
	app.setIsBackGroundApp (false);
	self.updateEDITIRemarks(ediFileObj);
	delete camEditTriggerFields;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
