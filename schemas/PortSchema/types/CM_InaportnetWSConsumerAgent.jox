    <JadeMethod name="getPKK" id="de92a65d-e546-43b6-82e2-8474bd22b36d">
        <updating/>
        <source>getPKK(_request : CMIF_IPNGetPKKRequest) : CMIF_IPNGetPKKResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	response		: CMIF_IPNGetPKKResponse;
	authToken,
	errorMessage	: String;
	authResult,
	timeoutOccurred	: Boolean;
	url				: String;
	jsonResponse	: String;
	jsonHelper		: CMIF_JsonHelper;
	xml				: JadeXMLDocument;
	xmlElement,
	pkkElement		: JadeXMLElement;
	xmlHelper		: CM_XmlHelperAgent;
	createdObjects	: ObjectSet;
	resultCode		: Integer;
	
begin
	// Firstly need to authenticate the user and get a token
	authResult := self.doAuthenticateUser(authToken, errorMessage, timeoutOccurred);
	
	// Always return a null result for a timeout
	if timeoutOccurred then
		return null;
	endif;
	
	// If the authentication failed for any reason, then create an error response and return it
	if not authResult then
		create response transient;
		response.status := false;
		response.message := errorMessage;
		return response;
	endif;
	
	// Authenticated OK, so construct the request using the parameter information
	url := self.restAPIBaseEndpoint &amp; 
		   method.name &amp; '/' &amp;
		   _request.nomorPKK &amp;
		   "?token=" &amp; authToken;
		   
	// Send the request
	jsonResponse := self.doSendHTTPRequest(url,
										   "GET",
										   self.getAdditionalHeadersForHTTP(),
										   null,
										   resultCode);

	// Null response means a timeout
	if jsonResponse = null then
		return null;
	endif;
	
	// Interpret the response
	create jsonHelper transient;
	create xmlHelper transient;
	create xml transient;
	xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	
	// Create a response
	create response transient;
	
	// Just check we have a valid XML document
	if xml.rootElement = null then
		response.status := false;
		response.message := "Unable to interpret the response";
		return response;
	endif;
	
	// Check for an error response first
	xmlElement := xml.rootElement.getElementByTagName("error");
	if xmlElement &lt;&gt; null then
		response.status := false;
		response.message := xmlElement.text();
		return response;
	endif;
		
	// Find status in response
	xmlElement := xml.rootElement.getElementByTagName("status");
	if xmlElement &lt;&gt; null then
		response.status := xmlElement.text().Boolean;
	endif;

	// Find message in response
	xmlElement := xml.rootElement.getElementByTagName("message");
	if xmlElement &lt;&gt; null then
		response.message := xmlElement.text();
	endif;

	// Finally unbust the data and create the response objects
	xmlElement := xml.rootElement.getElementByTagName("data");
	if xmlElement &lt;&gt; null then
		pkkElement := xmlElement.getElementByTagName("req");
		if pkkElement &lt;&gt; null then
			create response.myPKKItem transient;
			create createdObjects transient;
			response.myPKKItem.populateFromXMLElement(pkkElement, createdObjects);
		endif;
	endif;
	

	return response;
	
epilog
	delete jsonHelper;
	delete xml;
	delete xmlHelper;
	delete createdObjects;
	
end;</source>
        <Parameter name="_request" type="CMIF_IPNGetPKKRequest"/>
        <ReturnType type="CMIF_IPNGetPKKResponse"/>
    </JadeMethod>
    <JadeMethod name="getRKBM" id="c9ce0c3b-5824-4aae-9f52-ed04be8142b7">
        <updating/>
        <source>getRKBM(_request : CMIF_IPNGetRKBMRequest) : CMIF_IPNGetRKBMResponse  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	response		: CMIF_IPNGetRKBMResponse;
	authToken,
	errorMessage	: String;
	authResult,
	timeoutOccurred	: Boolean;
	url				: String;
	jsonResponse	: String;
	jsonHelper		: CMIF_JsonHelper;
	xml				: JadeXMLDocument;
	xmlElement,
	dataElement,
	rkbmItemElement,
	rkbmDetailElement	: JadeXMLElement;
	allData,
	allRkbmDetail	: JadeXMLElementArray;
	xmlHelper		: CM_XmlHelperAgent;
	createdObjects	: ObjectSet;
	rkbmItem		: CMIF_IPNRKBMItem;
	rkbmDetail 		: CMIF_IPNRKBMDetailItem;
	resultCode		: Integer;
	
begin
	// Firstly need to authenticate the user and get a token
	authResult := self.doAuthenticateUser(authToken, errorMessage, timeoutOccurred);
	
	// Always return a null result for a timeout
	if timeoutOccurred then
		return null;
	endif;
	
	// If the authentication failed for any reason, then create an error response and return it
	if not authResult then
		create response transient;
		response.status := false;
		response.message := errorMessage;
		return response;
	endif;
	
	// Authenticated OK, so construct the request using the parameter information
	url := self.restAPIBaseEndpoint &amp; 
		   method.name &amp; '/' &amp;
		   _request.nomorPKK &amp;
		   "?token=" &amp; authToken;
		   
	// Send the request
	jsonResponse := self.doSendHTTPRequest(url,
										   "GET",
										   self.getAdditionalHeadersForHTTP(),
										   null,
										   resultCode);

	// Null response means a timeout
	if jsonResponse = null then
		return null;
	endif;
	
	// Interpret the response
	create jsonHelper transient;
	create xmlHelper transient;
	create xml transient;
	xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	
	// Create a response
	create response transient;
	
	// Just check we have a valid XML document
	if xml.rootElement = null then
		response.status := false;
		response.message := "Unable to interpret the response";
		return response;
	endif;
	
	// Check for an error response first
	xmlElement := xml.rootElement.getElementByTagName("error");
	if xmlElement &lt;&gt; null then
		response.status := false;
		response.message := xmlElement.text();
		return response;
	endif;
		
	// Find status in response
	xmlElement := xml.rootElement.getElementByTagName("status");
	if xmlElement &lt;&gt; null then
		response.status := xmlElement.text().Boolean;
	endif;

	// Find message in response
	xmlElement := xml.rootElement.getElementByTagName("message");
	if xmlElement &lt;&gt; null then
		response.message := xmlElement.text();
	endif;

	// For RKBM, data is an array
	create allData transient;
	xml.rootElement.getElementsByTagName("data", allData);
	
	foreach dataElement in allData do
		rkbmItemElement := dataElement.getElementByTagName("RequestEntryRKBM");
		
		if rkbmItemElement &lt;&gt; null then
			create rkbmItem transient;
			response.allItems.add(rkbmItem);
			rkbmItem.populateFromXMLElement(rkbmItemElement, createdObjects);
		
			// Each RequestEntryRKBM has an array of DetailRKBM
			delete allRkbmDetail;
			create allRkbmDetail transient;
			rkbmItemElement.getElementsByTagName("DetailRKBM", allRkbmDetail);
			
			foreach rkbmDetailElement in allRkbmDetail do
				create rkbmDetail transient;
				rkbmItem.allDetailItems.add(rkbmDetail);
				rkbmDetail.populateFromXMLElement(rkbmDetailElement, createdObjects);
			endforeach;
		endif;
	
	endforeach;
	
	return response;
	
epilog
	delete jsonHelper;
	delete xml;
	delete xmlHelper;
	delete createdObjects;
	delete allData;
	delete allRkbmDetail;
	
end;</source>
        <Parameter name="_request" type="CMIF_IPNGetRKBMRequest"/>
        <ReturnType type="CMIF_IPNGetRKBMResponse"/>
    </JadeMethod>
    <JadeMethod name="monitorPandu" id="b05d5215-2d89-4baf-8aec-5979c34ce4e7">
