        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="27c97bf0-e2b1-492d-b7cd-db5105aa6f7e">
        <source>validate() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Aug 2009	cnwmd1	Initial creation
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	ti 			  : CM_TrackedItem;
	toDoTaskDesc  : CM_ToDoTaskDesc;
begin
	inheritMethod();
	
	//toDoTaskDesc := self.myToDoTaskDesc;		//08.02.2023 navma1 #56457:[56458]		//15.3.2023 navhl20	#56614[56615]
	
	if self.allToDoTasksDescs.isEmpty() then											//15.3.2023 navhl20	#56614[56615]
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_To_Do_Task), null, null); 
		return;									//08.02.2023 navma1 #56457:[56458]
	endif;
	
	foreach ti in self.allSelectedTIs do
		foreach toDoTaskDesc in self.allToDoTasksDescs do								//15.3.2023 navhl20	#56614[56615]
			if not toDoTaskDesc.isAvailableForCargoType(ti.cargoType) then
				app.raiseCMException1(ERR_TODOTASK_ADD,  app.getErrorString2( ERR_NotAvailableForCargoType, toDoTaskDesc.description,	ti.id), null, self);
			endif;
		endforeach;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
