    <JadeMethod name="getOperatorCode" id="2b6339e7-dcfb-4084-a03d-1f0c0bbeaa68">
        <source>getOperatorCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 
16 December 2021	jlier1	Initial creation 52595

*/

vars
	wle 		: CM_WorkListEntry;
	request  	: CM_Request;
begin

	if self.ti &lt;&gt; null then
		return self.ti.operatorCode;
	else
		wle:=self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null then
			request :=wle.myRequest;
			if request &lt;&gt; null then
				return request.getOperatorCode();
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperatorDesc" id="36844c06-ccc8-465a-a58a-25ad8bb7629f">
        <source>getOperatorDesc() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/06/2022	navdap1		Initial creation TFS 53362 EUP Master Data interface customers between TOS and ERP
//
vars
	wle 		: CM_WorkListEntry;
	request  	: CM_Request;
	opCode 		: String;
	operator 	: CM_Operator;
begin

	if self.ti &lt;&gt; null then
		return self.ti.operatorCode;
	else
		wle:=self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null then
			request :=wle.myRequest;
			if request &lt;&gt; null then
				opCode := request.getOperatorCode();
				if opCode &lt;&gt; null then
					operator := app.myRoot.allOperators[opCode];
					if operator &lt;&gt; null and app.myRoot.getConfig(ComboByNameOperator).Boolean then
						return operator.description;
					endif;
				endif;
				return opCode;
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOverstownTask" id="4be3bad0-36df-4f2b-bc95-518df6523ef7">
        <source>getOverstownTask() : CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2021	jlier1	Initial creation 52595

*/

vars
	overstownTask : CM_RTQueueTask;
begin
	if not self.isOverstowTask then
		return null;
	endif;

	if 	 self.isOverstowTaskAuto then
		overstownTask:=self.myEntry.findNonOverstowTaskOfType(TASK_PICKUP);	
	elseif self.myEntry.myOverstowOfEntry &lt;&gt; null then
		overstownTask:=self.myEntry.myOverstowOfEntry.getTaskOfType(TASK_PICKUP,null);		
	endif;
	
	return overstownTask;

epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getPreviousTask" id="23db383a-03d9-4bba-9e32-fbcbe1cbad3d">
        <source>getPreviousTask(): CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Dec 2010	cnwer1	Initial creation
01 Mar 2011 cnwer1	par 27113  
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming - moved exception
					handling to caller (CM_RTQueueEntry::getDirectorOrPickupTask

*/

vars
	iter : Iterator;
	task : CM_RTQueueTask;
	allRelatedTasks : CM_RTQueueTaskArray;
	
begin
	//epr par 27113 1/3/2011 copying to transient coll to prevent 1308 error
	allRelatedTasks := self.relatedTasks.cloneSelf(true);
	
	iter := allRelatedTasks.createIterator;
	
	iter.startAtObject(self); 
	
	iter.back(task);
	
	iter.back(task);
	
	return task;
	
	
epilog
	delete iter;
	delete allRelatedTasks;
end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForMoveHistory" id="051d2ffa-2526-4512-a553-dfe3662cf8be">
        <source>getQuantityForMoveHistory():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2013	cnwndl1	Initial creation	Par 31799

*/

vars

	quantity : Integer;

begin

	if self.myEntry &lt;&gt; null then
		quantity := self.myEntry.getTotalToMove();
	endif;
	
	if quantity = 0 then
		quantity := 1;
	endif;
	
	return quantity;

epilog

end;</source>
        <ReturnType type="Integer"/>
