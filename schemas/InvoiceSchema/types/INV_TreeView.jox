    <JadeMethod name="doPrintOut" id="bce0395c-475f-4f01-bb19-24bbb3c4c44a">
        <updating/>
        <source>doPrintOut() updating;
// ---------------------------------------------------------------------------
// Created:		23 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTable : Table;
	anObj : Object;
	servObj : CM_ServiceObject;
	totRows, padding, idy, idx , idr: Integer;
	tmpPad, tmpStr : String;
begin

	tmpTable := self.tblPrint;
	tmpTable.rows := 0;
	totRows := self.lstData.listCount();
	
	foreach idx in 1 to totRows do
		tmpStr := self.lstData.itemText[idx];
		anObj := self.lstData.itemObject[idx];
		padding := (self.lstData.itemLevel[idx] - 1) ;
		tmpPad := "";
		foreach idy in 1 to padding do
			tmpPad := tmpPad &amp; "&gt; ";
		endforeach;
		tmpStr := tmpPad &amp; tmpStr;
		idr := tmpTable.addItem(tmpStr);
		if anObj.isKindOf(CM_ServiceGroup) 
		or anObj.isKindOf(CM_DebtorGroup) 
		or (anObj.isKindOf(CM_Bank) and not anObj.CM_Bank.isBusinessUnit) then
			tmpTable.accessRow(idr).fontBold := true;
		endif;
	endforeach;
	
	self.doPrintOutTable(tmpTable, self.caption, true, true, false, true);
end;</source>
    </JadeMethod>
