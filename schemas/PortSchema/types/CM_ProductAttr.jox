    <JadeMethod name="importMyCollectionsXML" id="d37a77bc-5db1-452d-909b-1aa0e1df1b96">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newCode		: CM_ProductAttributeCode;
	codeStr,
	allCodesBlock,
	codeBlock	: String;
	blockLength,
	pos			: Integer;
begin
	allCodesBlock := _collectionsBlock.cnEcGetTagValueOfName('allCodes');

	if allCodesBlock = null then
		return;
	endif;
	
	pos := 1;
	blockLength := allCodesBlock.length;
	
	while pos &lt; blockLength do
		codeBlock := allCodesBlock.cnEcGetNextTagValueOfName(CM_ProductAttributeCode.name, pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if codeBlock = null then
			continue;
		endif;
		codeStr := codeBlock.cnEcGetTagValueOfName('code');
		if self.allCodes.includesKey(codeStr) then
			continue;
		endif;
		
		create newCode persistent;
		newCode.importMeXML(codeBlock);
		self.allCodes.add(newCode);
	endwhile;

end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importMyReferencesXML" id="cabfe989-6b26-4b84-8087-eba98e201155">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	codeStr,
	codeBlock,
	typeStr			: String;
	newCode			: CM_ProductAttributeCode;
begin
	codeBlock := _referencesBlock.cnEcGetTagValueOfName('myCode');
	if codeBlock &lt;&gt; null then
		create newCode persistent;
		newCode.importMeXML(codeBlock);
		self.allCodes.add(newCode);
		self.myCode := newCode;
	endif;

end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="e9686221-51f9-4580-9359-5a7d14cf0e1d">
        <updating/>
        <source>initialize(_name, _displayName : String) updating;
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     reimplement on subclasses to set allValidationTypes etc.
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.isViewable := true;
	self.name := _name;
	self.displayName := _displayName;
	//default to just hold a value
	self.validationType := ValidationType_Value;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_displayName" type="String"/>
    </JadeMethod>
