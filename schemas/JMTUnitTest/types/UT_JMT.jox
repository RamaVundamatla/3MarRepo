    <JadeMethod name="uStringToLong" id="11676fb5-a404-4aec-8ac6-6fb186ddbba9">
        <source>uStringToLong(_hexValue : String;
			  _expectedValue : Integer);
// cnwkpd1
/*

Purpose:			Use both old and new Hex conversion mechanisms to convert the passed in string
					Check the returned value of both is the same, and equal to the expected value

Parameters:			Hex String, and expected result

Return Value:		None


Date		Who		Reason
19 Apr 2010	cnwkpd1	PAR #23610 - Allow for 64-bit deployment

*/

vars
	oldNumEquivalent,
	newNumEquivalent	: Integer;
	osDetails			: JadeDynamicObject;
	
begin
	create osDetails transient;
	process.getOSDetails(osDetails);
	if osDetails.getPropertyValue("buildArchitecture").String.pos("win32", 1) &gt; 0 then
		oldNumEquivalent := call stringToLong(_hexValue, 0, 16);
		self.assertEqual(oldNumEquivalent, _expectedValue);
	endif;
	
	newNumEquivalent := _hexValue.convertHexToInteger();
	self.assertEqual(newNumEquivalent, _expectedValue);
	
	write method.qualifiedName &amp; " _hexValue=" &amp; _hexValue &amp; ", old=" &amp; oldNumEquivalent.String &amp; ", new=" &amp; newNumEquivalent.String;
	
	
epilog
	delete osDetails;
	
end;</source>
        <Parameter name="_hexValue" type="String"/>
        <Parameter name="_expectedValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="uTestProxyCreationPost14042011" id="1fb7dd5c-17b0-4127-847b-b6b8a013df46">
        <source>uTestProxyCreationPost14042011();
/*

Purpose:			Test all CM_Object Proxy creation methods
					This will only check those methods that have been created since this 
					method was created.  Anything before this date will be ignored.  Will
					mean that gong forward it will be correct.

Date		Who		Reason
14 Apr 2011	cnwkpd1	PAR #27401 - Fix up proxy framework
28/04/2011	cnwmh5	Add getting of references coded for in pxyCreateUpdateProxy
*/

vars
	
	cls						: Class;
	object,
	proxy					: CM_Object;
	meth					: Method;
	oldObject				: CM_Object; 
	proxyLink				: CM_ProxyLink;
	
	classes					: ClassColl;
	
	pxyNotClearedProperly	: HugeStringArray;
	badProps				: StringArray;
	failedDetails			: HugeStringArray;
	proxyRefsCodedFor		: StringArray;
	
	msgStr					: String;
	str						: String;
	count 					: Integer;
	
begin

	cls := rootSchema.getSchema("PortSchema").getClass(CM_Object.name);
	create classes transient;
	cls.allSubclasses(classes);
	
	create badProps transient;
	create failedDetails transient;
	create pxyNotClearedProperly transient;
	create proxyRefsCodedFor transient;
	
	foreach cls in classes where not cls.abstract do
	
		meth := cls.getMethodInHTree(CM_Object::pxyCreateUpdateProxy.name);
		if meth = null then
			continue;
		endif;
		
		if meth.schemaType.name = CM_Object.name then
			//write "Class " &amp; cls.name &amp; " does not implement pxyCreateUpdateProxy";
			continue;
		endif;
		
		object := cls.lastInstance().CM_Object;
		if object = null then
			//write "No instances of " &amp; cls.name &amp; " found, skipped";
			continue;
		endif;
		
		// if method was created before 14/04/2011 then don't check it.
		if meth.creationTime.date &lt; "14/04/2011".Date then
			continue;
		endif;
		
		delete proxy;
		
		// need to check to see if delete proxy has cleaned up properly
		// if not then log and clear the collection
		str := null;
		if app.myProxyManager.allReals.size &gt; 0 then
			foreach proxyLink in app.myProxyManager.allReals discreteLock do
				str := str &amp; Tab &amp; Tab &amp; proxyLink.String &amp; Tab &amp; proxyLink.myProxyObject.String &amp; Tab &amp; 
					proxyLink.myRealObject.String &amp; CrLf;
			endforeach;		
			pxyNotClearedProperly.add(oldObject.String &amp; CrLf &amp; str);
			app.myProxyManager.clearAllProxies();
		endif;
				
		beginLoad;
		proxy := object.pxyCreateUpdateProxy();
		endLoad;
		
		oldObject := object;		
		
		// 28/04/2011 cnwmh5 - Get references coded for in the method
		proxyRefsCodedFor.clear();
		self.getProxyRefsCodedFor(meth, proxyRefsCodedFor);
			
		badProps.clear();
		if not object.matchesProxy(proxy, proxyRefsCodedFor, badProps) then
			failedDetails.add("Failed " &amp; cls.name &amp; " properties " &amp; badProps.concatenate(", "));
			//write "Failed " &amp; cls.name &amp; " properties " &amp; badProps.concatenate(",");
		else
			//write "Class " &amp; cls.name &amp; " OK";
			count := count + 1;
		endif;

	endforeach;
	
	// create msgStr with failed details
	if failedDetails.size &gt; 0 then
		msgStr := msgStr &amp; CrLf &amp; CrLf;
		foreach str in failedDetails do
			msgStr := msgStr &amp; str &amp; CrLf;
		endforeach;
	endif;
	
	// create msgStr with proxy's not cleared details
	if pxyNotClearedProperly.size &gt; 0 then
		msgStr := msgStr &amp; CrLf &amp; CrLf;
		foreach str in pxyNotClearedProperly do
			msgStr := msgStr &amp; str;
		endforeach;
	endif;
	
	// write the strings details
	if msgStr &lt;&gt; null then
		app.writeStatement(msgStr);
	endif;
	
	// test failed if something in the string
	self.assertTrue(msgStr = null);
			
epilog
	endLoad;
	delete badProps;
	delete classes;
	delete failedDetails;
	delete pxyNotClearedProperly;
	delete proxyRefsCodedFor;
	delete proxy;
	
end;</source>
        <text>Do Not Run, Saturday1</text>
    </JadeMethod>
