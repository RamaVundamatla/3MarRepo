    <JadeMethod name="getTerminalReportHeading" id="7170f117-46d6-4690-8497-64a862c0fdc8">
        <source>getTerminalReportHeading() : String;

/*

Purpose:			Get the special Report Group header name to use for the 
					ungrouped Terminal reports

Parameters:			None

Return Value:		String to use for the report heading


Date		Who		Reason
26 Mar 2009	cnwkpd1	PAR #19263 - Prevent String too long exception when terminal name
					is very long

*/

constants
	MaxLength		= 25;		// This is the maximum allowable length of the returned heading
	
vars
	terminal		: CM_Terminal;
	heading,
	termString,
	repString		: String;
	
begin
	terminal := app.getMyTerminalDO_NOT_USE();
	repString := app.getErrorString(Reports);
	
	// Default is Terminal name and "Reports"
	heading := terminal.name &amp; " " &amp; repString;
	if heading.length &lt;= MaxLength then
		return heading;
	endif;
	
	// If this is too long, then use "Terminal" and code and "Reports"
	heading := app.getErrorString(Terminal) &amp; " " &amp; terminal.code &amp; " " &amp; repString;

	if heading.length &lt;= MaxLength then
		return heading;
	else
		return heading[1:MaxLength];
	endif;
	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
