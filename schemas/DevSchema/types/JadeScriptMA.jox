    <JadeMethod name="aDPArchiveVoyage" id="82741f66-dae3-4ff9-965c-5f0da2ff39c1">
        <source>aDPArchiveVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2023		navma1	Initial creation

*/

vars
	lFile      		: File;
	term            : CM_Terminal;
	voyage			: CM_Voyage;
	startDT,
	endDT			: TimeStamp;
	iter			: Iterator;
	msg				: String;
	canBeArc		: Boolean;
	wleCount		: Integer;
	job				: CM_Job;
begin
	//app.initialize();
	term := app.myRoot.allTerminals["04"];
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\" &amp; term.code &amp;"VoyageData-1.csv";
    lFile.open;
	
	startDT.setDate("01/01/2020".Date);
	startDT.setTime('00:00:00:000'.Time);
	
	endDT.setDate("31/12/2020".Date);
	endDT.setTime('23:59:59:000'.Time);
	
	iter := term.allVoyagesByArrivalDTCode.createIterator();
	term.allVoyagesByArrivalDTCode.startKeyGeq(startDT,null,iter);
	
	lFile.writeLine(
					"Term code"       			&amp; Comma &amp;   //01
					"Oid"    		 			&amp; Comma &amp;   //02
					"Voyage Code"  	  			&amp; Comma &amp;   //03
					"Voyage Status"  			&amp; Comma &amp;   //04
					"Voyage Can Br Archived" 	&amp; Comma &amp;   //05
					"ATA" 			  			&amp; Comma &amp;   //06
					"ATD"       	 			&amp; Comma &amp;	//07			
					"Number Of jobs"  			&amp; Comma &amp;   //08
					"Number Of Wle"				&amp; Comma &amp;   //09
					"has Resources"			&amp; Comma &amp;   //09
					"Jobs Status"    			&amp; Comma &amp;   //10
					"Message"								//11	 
					);			
		while iter.next(voyage) do
			canBeArc := false;
			msg      := null;
			wleCount := null;	
			
			if voyage.arrivedDT&gt; endDT then
				break;
			endif;
			
			if voyage.status &lt;&gt; Voyage_Status_Departed then
				continue;
			endif;
			
			foreach job in voyage.allVoyageJobs do 
				wleCount := wleCount + job.workListEntries.size;
			endforeach;
			
			canBeArc := voyage.canVoyageBeArchived(msg,true);
			msg      := msg.removeCrLfs();
			lFile.writeLine(term.code  							&amp; Comma &amp;	//01
							voyage.getOidAsString				&amp; Comma &amp;   //02
							voyage.code  						&amp; Comma &amp;   //03
							voyage.statusDescription			&amp; Comma &amp;   //04
							canBeArc.asStringJMT  				&amp; Comma &amp;   //05
							voyage.arrivedDT.asStringJMT		&amp; Comma &amp;   //06
							voyage.departedDT.asStringJMT		&amp; Comma &amp;   //07
							voyage.allVoyageJobs.size.String	&amp; Comma &amp;   //08
							wleCount.String						&amp; Comma &amp;   //09
							voyage.checkAllResourcesAreCharged.String &amp; Comma &amp;
							voyage.allVoyageJobs.listString('|',CM_Job::statusString.name) &amp; Comma &amp;  //10
							msg																		//11
							
						);
		endwhile;
	
epilog
	delete iter;

end;</source>
    </JadeMethod>
