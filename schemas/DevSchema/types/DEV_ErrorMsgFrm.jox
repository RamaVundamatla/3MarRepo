    <JadeMethod name="doImportExceptions" id="a1c2c020-21bd-4155-9128-06ccddbb9626">
        <source>doImportExceptions();

vars
	file 	: File;
	cmdOpen	: CMDFileOpen;
	header	: String;
	locale1	: String;
	locale2	: String;
	headerFields	: HugeStringArray;
	fields	: HugeStringArray;
	obj		: Object;
	records	: ObjectArray;
	line	: String;
	localeMessage : String;
	xml		: String;
begin
	app.msgBox('NOTE. 
Messages are imported for existing Global Constants.
If an existing Global Constant is not found, then this is reported. 
Existing Global Constants that do not have an entry in the import file are NOT deleted.', 'Import Exceptions', MsgBox_Information_Icon);
	 
	create cmdOpen transient;
	cmdOpen.initDir := app.getJadeLogDir;
	cmdOpen.defaultExt := '.csv';
	if cmdOpen.open &lt;&gt; 0 then
		return;
	endif;
	
	create file transient;
	file.usePresentationFileSystem := true;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := cmdOpen.fileName;

	create headerFields transient;
	
	header := file.readLine;
//	header.csvToStringArray(headerFields);
	header.csvConvert(headerFields, ",");		// cnwdad1 25/11/2009 - PAR #21720 Added delimiter parameter.

	if headerFields.size &lt; 2 or headerFields.size &gt; 3 or headerFields[1] &lt;&gt; 'Locales' then
		app.msgBox('Error - header field not found', 'Message Import', MsgBox_Stop_Icon);
		return;
	endif;
	
	// get locale1, and optional translated locale
	locale1 := headerFields[2];

	if headerFields.size = 3 then 
		locale2 := headerFields[3];
	endif;

	file.readLine;	// column headers
		
	create records transient;

	// read the file
	while file.endOfFile = false do
		create fields transient;
		line := file.readLine;
		line.csvConvert(fields, ",");		// cnwdad1 25/11/2009 - PAR #21720 Added delimiter parameter.
		
		// validation
		if (locale2 = null and fields.size &lt;&gt; 4) or
		   (locale2 &lt;&gt; null and fields.size &lt;&gt; 6) then
			app.msgBox('Error - unexpected field count:' &amp; CrLf &amp; line, 'Message Import', MsgBox_Stop_Icon);
			return;
		endif;

		records.add(fields);
	endwhile;
	
	localeMessage := 'locale ' &amp; locale1;
	if locale2 &lt;&gt; null then
		localeMessage := localeMessage &amp; ' and locale ' &amp; locale2;
	endif;
	
	if app.msgBox('The import file contains &amp; ' &amp; records.size.String &amp; ' records for ' &amp; localeMessage &amp; CrLf &amp; 'Confirm overwriting existing messages', 'message Import', MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	
	// now save
//	records.inspectModal;

	foreach obj in records do

		if updateExceptionXml(locale1, locale2, obj.StringArray) = false then
			continue;	// error - can't update
		endif;
	
		app.writeStatement( xml);
break; // testing - first record only
	endforeach;	
	
epilog
	delete file;
	delete cmdOpen;
	delete headerFields;
	delete fields;
	if records &lt;&gt; null then
		records.purge;
	endif;
	delete records;
end;</source>
    </JadeMethod>
    <JadeMethod name="doListPermNoExpl" id="bf3ef1d8-0199-49ae-a048-150f8cc7a16d">
        <updating/>
        <source>doListPermNoExpl() updating;

vars
	permObj	: CM_PermissionObject;
	numRows,
	idx		: Integer;
	str	: String;
	file : File;
begin
	create file transient;
	file.fileName := "c:\perm.txt";
	numRows := tblData.rows;
	foreach idx in 1 to numRows do
		permObj := tblData.accessRow(idx).itemObject.CM_PermissionObject;
		if permObj = null then
			continue;
		endif;
		if permObj.myConstant = null then
			continue;
		endif;
		
		if permObj.explanation = null then
			str := permObj.constName;
			file.writeLine (str);
		endif;
	endforeach;
epilog
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissionsReset" id="e83afcff-3924-4b65-afe9-a31d9390b371">
        <source>doPermissionsReset();
// ---------------------------------------------------------------------------
// Created:     31 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuAgent	: CM_MenuAgent;
	user		: CM_User;
	translationAgent : CM_TranslationAgent;
begin

	staLine.caption := 'Resetting Root Security Roles';
	staLine.doWindowEvents(0);
	beginTransaction;
	app.myRoot.resetRootSecurityRoles(null);
	commitTransaction;

	// RBarr 1/9/2006 Localisation - Rebuild permissions translatable text items from global constants
	//								 only required if GC's and permission objects get out of sync
	create translationAgent transient;
	translationAgent.trxLoadXLATsFromGlbConstants(XLAT_Permissions);
	

	staLine.caption := 'Resetting Menus';
	staLine.doWindowEvents(0);
	create menuAgent transient;
	menuAgent.resetAllMenuDetails();
	
	staLine.caption := 'Reset of permissions and menus complete';
	global.beep;

epilog	
	delete menuAgent;
	delete translationAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissionsResetSingle" id="4a49a2bb-4540-4fa7-9b26-44dad22f7aba">
        <updating/>
        <source>doPermissionsResetSingle() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwmc5	Initial creation

*/

vars
	currentPerm : CM_PermissionObject;
	permName	: String;
	
	termRole	: CM_SecurityRoleTerminalRoot;
	sysRole		: CM_SecurityRoleSystemRoot;
	newPerms	: IntegerArray;
	
begin
	permName := tblData.accessCell(tblData.row, 1).text;
	currentPerm := self.myPermissionAgent.allPermissionsByName.getAtKey(permName);	
	
	if currentPerm = null then
		app.msgBox("Please select a permission to reset.", "Select first",0);
		return;
	endif;
	
	create newPerms transient;
	newPerms.add(currentPerm.constValue);
	
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	
	if currentPerm.permType = PermType_System then
		beginTransaction;
		termRole.setPermissionsFromIntArray(newPerms,false);
		sysRole.setPermissionsFromIntArray(newPerms,true);
		commitTransaction;
	elseif currentPerm.permType = PermType_Terminal then
		beginTransaction;
		termRole.setPermissionsFromIntArray(newPerms,true);
		sysRole.setPermissionsFromIntArray(newPerms,false);
		commitTransaction;
	endif;
	
	app.msgBox("Permission '" &amp; currentPerm.constName &amp; "' was reset sucessfully.", "Reset Sucessful", 0);
	
epilog
	delete newPerms;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissionsSave" id="732a4163-cfa5-40d9-a8e4-5a0befbd4f99">
        <source>doPermissionsSave();
// ---------------------------------------------------------------------------
// Created:     17 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	permObj	: CM_PermissionObject;
	numRows,
	idx		: Integer;
begin

	// Not generally enabled but here in case want to update
	// the text for all permission constants

	beginTransaction;

	numRows := tblData.rows;
	foreach idx in 1 to numRows do
		permObj := tblData.accessRow(idx).itemObject.CM_PermissionObject;
		if permObj = null then
			continue;
		endif;
		if permObj.myConstant = null then
			continue;
		endif;
		
		permObj.myConstant.setText(permObj.outputAsXML);
	endforeach;
	
	commitTransaction;

end;</source>
    </JadeMethod>
