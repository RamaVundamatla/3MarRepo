    <JadeMethod name="uMethodLastChangedDate" id="91422f29-3796-4eed-90c6-829f952abb0f">
        <source>uMethodLastChangedDate();

/*

Purpose:	Get all Unit Test Methods changed after the specified date		

Date		Who		Reason
02 May 2011	cnwmh5	Initial creation

*/
constants
	TextStr			: String = "Get methods changed after date.  e.g. 13/11/2011";
vars

	klass			: Class;
	meth			: Method;
	file			: File;
	
	methodsDict		: MethodNDict;
	classes			: ClassColl;
	
	iter			: Iterator;
	
	lastModified	: TimeStamp;
	author			: String;
	
	dateStr			: String;
	date			: Date;

	
begin

	// get the class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	/*
	create file transient;
	file.fileName := "c:\temp\methodLastChangedDate.txt";
	if file.isAvailable() then
		file.purge;
	endif;
	file.writeLine("class" &amp; Tab &amp; 'method' &amp; Tab &amp; 'key' &amp; Tab &amp; 'author' &amp; Tab &amp; 'date' &amp; Tab &amp; 'time');
	*/
	
	dateStr := TextStr;
	read dateStr;
	if dateStr = null then
		app.writeLog("****** Method Aborted ******", LogINFO);
		return;
	endif;
	date := dateStr.cnAsDate();
	if not date.isValid() then
		date.setDate(01, 01, 1970);
	endif;
	
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	
	foreach klass in classes do
				
		// Get all the references to the named class
		delete iter;
		methodsDict := klass.cnGetMethods();
		iter:= methodsDict.createIterator;
		
		while iter.next(meth) do
			
			lastModified := meth.cnGetModifiedTimeStamp();
			author := meth.cnGetModifierName();
			
			//file.writeLine(klass.name &amp; Tab &amp; meth.name &amp; Tab &amp; klass.name &amp; "::" &amp; meth.name &amp; Tab &amp; author &amp; Tab &amp; 
			//	lastModified.date.String &amp; Tab &amp; lastModified.time.String);
			
			if lastModified.date &gt; date then
				app.writeLog(klass.name &amp; Tab &amp; meth.name &amp; Tab &amp; klass.name &amp; "::" &amp; meth.name &amp; Tab &amp; author &amp; Tab &amp; 
					lastModified.date.String &amp; Tab &amp; lastModified.time.String, LogINFO);
			endif;
			
		endwhile;
		
	endforeach;
	
	//file.close();
	
epilog

	delete classes;
	delete iter;
	delete file;

end;</source>
    </JadeMethod>
