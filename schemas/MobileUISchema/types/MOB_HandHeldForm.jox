    <JadeMethod name="moveVMButtons" id="1d384864-d146-42a8-897c-12aebe65b060">
        <source>moveVMButtons(_backButton : Button input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwer1	Initial creation

*/

vars
	otherButtons : ObjectArray;
	obj 		: Object;
	cancelButton,editButton,
	button ,prevButton		: Button;
	theLeft : Integer;
begin
	
	
	create otherButtons transient;

	otherButtons.add(self.btnOne);
	if self.btnTwo.visible then
		otherButtons.add(self.btnTwo);
		
	endif;
	if self.btnThree.visible then
		otherButtons.add(self.btnThree);
		
	endif;
	if self.btnFour.visible then
		otherButtons.add(self.btnFour);
		
	endif;
	if self.btnFive.visible then
		otherButtons.add(self.btnFive);
	endif;
	
	
	prevButton:=_backButton;
	_backButton.left := self.clientWidth - _backButton.width - 2;
	foreach obj in otherButtons do
		button:=obj.Button;
		if button = _backButton then
			break;
		endif;
		button.left:=prevButton.left - button.width -2;
		//for vm we want the edit cancel buttons to be in order Edit , Cancel rahter than Cancel, Edit
		if button.caption = app.getErrorString(Cancel) 
			and prevButton.caption = app.getErrorString(Edit) then
			//swap positions
			button.left:=prevButton.left;
			prevButton.left:=prevButton.left - button.width -2;
				
		endif;
		
		prevButton:=button;
		
	endforeach;

	
	
	
epilog
	delete otherButtons;
end;</source>
        <access>protected</access>
        <Parameter name="_backButton" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="msgBox" id="bf0dfb0e-6031-452b-8431-35979d67a6d9">
        <source>msgBox(msg, title : String; flags: Integer; alertOption : Boolean ): Integer protected;
//03 June 2008	cnwdw1	
//
vars
	handHeldMsgBox : MOB_HandHeldMsgBox;
	msgBoxOptionalAlert : MOB_HHMsgBoxAndAlert;
	modalResult : Integer;
begin

	if alertOption and flags = MsgBox_OK_Only then	// 09 Feb 2010	NDL	CCMS MES 1005
		create msgBoxOptionalAlert transient;
		msgBoxOptionalAlert.setMessage(msg, title, flags);
		msgBoxOptionalAlert.resizedMargin := self.resizedMargin;
		msgBoxOptionalAlert.drawFontSize := self.drawFontSize;
		modalResult := msgBoxOptionalAlert.showModal();
		// if modalResult = MsgBox_Return_OK, an alert will heve been generated...
		return modalResult;
	else
		create handHeldMsgBox transient;
		handHeldMsgBox.setMessage(msg, title, flags);
		return handHeldMsgBox.showModal();
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <Parameter name="alertOption" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="ca43fe24-defc-4a2a-ac34-0c0747aa621e">
        <source>myTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2017	cnwndl1	Initial creation	TFS 3387 / 3006

*/

vars

	terminal : CM_Terminal;

begin

	if self.myMobileGenericAgent &lt;&gt; null then
		terminal := self.myMobileGenericAgent.myTerminal;
		if terminal = null then
			terminal := self.myMobileGenericAgent.getTerminal;
		endif;
	endif;

	if terminal = null then
		terminal := inheritMethod();
	endif;
	
	return terminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
