    <JadeMethod name="isStorageDetailMatch" id="30e3e0f8-8cbb-42c6-83bb-ef9dae2edbcc">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars

begin
	//epr TFS 37176 21/2/18
	//return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.requiresPower);
	
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch(_tiTrx.myTrackedItem.requiresPower);	// requires power not kept on the generic transaction
	else
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.requiresPower);
	endif;

end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocationCT" id="8b21157c-fcb4-4892-9127-6c80732b5b6f">
