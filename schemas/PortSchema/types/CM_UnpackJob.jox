    <JadeMethod name="setForCreateInternal" id="f2d99a99-1752-4dd0-b52f-1c0f12b4c719">
        <updating/>
        <source>setForCreateInternal(_unpackInternalJobParam : CMIF_WorkOrderJobParams;_terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwrd1	Initial creation

*/



vars
	req : CM_UnpackRequest;
begin

	self.myTerminal := _terminal;
	self.id := _unpackInternalJobParam.jobId;
	//self.type := _todoInternalJobParam.typeToCreate;

	self.allTrackedItems.clear();
	_unpackInternalJobParam.allTIs.copy(self.allTrackedItems);
	
	//self.isPackParentJob := _packInternalJobParam.isPackParentJob;
	self.myWODtl := _unpackInternalJobParam.myWorkOrderDtl.CM_WorkOrderTIDtl;
	
	
	//---------------
	//Build a Request
	//---------------
	create req;	
	req.setForCreateInternal(self, _unpackInternalJobParam);
	//---------------
	//Build the WLEs' from the request.
	//---------------
	self.createWLEs();

	self.addToJobSheet();
	

end;</source>
        <Parameter name="_unpackInternalJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
