    <JadeMethod name="getOutgoingVoyageStatus" id="dc394db2-f0b1-450a-abfb-fb31ab3a535b">
        <source>getOutgoingVoyageStatus(_voyage: CM_Voyage): CM_VoyageStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	return app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_ICancelReqIPN );

epilog

end;</source>
