/*

Date		Who		Reason
18 September 2014	cnwer1	Initial creation PAR

*/

vars
	theRow ,
	theCol : Integer;
begin
	//highlight the dragged over machine
	if table.getCellFromPosition(x,y,theRow,theCol) then
		table.clearAllSelected;
		table.accessRow(theRow).selected:=true;
	endif;
	
epilog

end;</source>
