    <JadeMethod name="utlDeleteUser" id="8b1a6a30-8d4c-4779-9c3c-4b2f325377f8">
        <source>utlDeleteUser(pUser : CM_User; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     13 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toDelete	: CM_User;

begin

	self.initialiseActivity();

	toDelete := pUser;
	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;
	
	app.myValDA.valUser(toDelete);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
	endif;

	if _passport.noErrors then
		toDelete.erase(NORMAL_ERASE);
	endif;

epilog
	return;
	
end;</source>
        <Parameter name="pUser" type="CM_User"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
