    <JadeMethod name="canDoHandHeldGate" id="ec78910a-1c29-4ae7-bac4-d90e599a5d50">
        <source>canDoHandHeldGate() : Boolean;
// ---------------------------------------------------------------------------
// Created:		24 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
//	return (self.user.canDo(self.myTerminal, PmHandHeldGateClient) and self.user.canDo(self.myTerminal, PmAdmHHGate1));
	return (self.user.canDo(self.myTerminal, Mod_WebApps) and self.user.canDo(self.myTerminal, PmAdmHHGate1));	//07 Oct 2019	NDL	TFS 46169
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
