    <JadeMethod name="addFieldCodeMapping" id="da7e0429-b969-4e79-8437-0b689a6c7a27">
        <source>addFieldCodeMapping( _fieldHook	: CM_EDIFieldHookCode; _table :CM_DataTable input ) protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
05 September 2008	cnwrd1	Initial creation

*/

vars
	row			: Integer;
	str			: String;
	strCodeDesc : String;
begin
	strCodeDesc := _fieldHook.userDesc;

	if _fieldHook &lt;&gt; null then
		str :=	'1'	&amp; Tab &amp; _fieldHook.propName &amp; Tab &amp;	strCodeDesc &amp; Tab &amp; '' ;
	endif;
	
	row := _table.addItem(str);
	
	if _fieldHook &lt;&gt; null then
		_table.accessRow(row).itemObject := _fieldHook;
	endif;
		
	_table.accessCell(row, 1).text 		:= (row - _table.fixedRows).String;
	_table.accessCell(row, 2).inputType := Table.InputType_None;
	_table.accessCell(row, 3).inputType := Table.InputType_TextBox;
	_table.accessCell(row, 4).inputType := Table.InputType_None;
end;</source>
        <access>protected</access>
        <Parameter name="_fieldHook" type="CM_EDIFieldHookCode"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addFieldMapping" id="5c4aa95d-8a12-407e-86e1-c05b09c2beae">
        <source>addFieldMapping(_table :CM_DataTable input;_row :Integer;  _fieldMapping : CM_EDIFieldMapping) protected;
/*
----------  ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Changed On  Changed By  Reason
22/09/2009	cnwcs5		par 20320 - changed columns on table
28/05/2013	cnwcs5		par 31618
----------  ----------  --------------------------------------------------
*/
vars
	row, col	: Integer;
begin
	if _row = null then
		row := _table.addItem(null);
	else
		row := _row;
	endif;
	
	self.setValuesForFieldMapping (_fieldMapping, _table, row);
	
	self.setInputTypesForFieldMapping (_table, row);
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_fieldMapping" type="CM_EDIFieldMapping"/>
    </JadeMethod>
    <JadeMethod name="addSamplRowFreeForm" id="f396d2c2-2fce-4c2f-ad1d-54d9e370b259">
        <source>addSamplRowFreeForm(_str : String) protected;
//
// cnwrs1 ccms 2044 28 Apr 2011
//
vars
	tbl	: CM_DataTable;
	row : Integer;
begin
	tbl := self.tblSampleData;
	row := tbl.addItem(_str);
end;
</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="addSampleRowDelimited" id="103a0f83-7fe3-43aa-8487-c60a76c1c1b6">
        <source>addSampleRowDelimited(_str : String; _numFields : Integer) protected; 	//cnwrs1 Par 23424 25 Mar 2010

/*
----------   ----------  --------------------------------------------------
Created:	05 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row,
	idx,
	pos			: Integer;
	tbl			: CM_DataTable;
	rowStr,
	delim		: String;
	colData : String;
	lastPos : Integer;
begin
	tbl := self.tblSampleData;
	
	delim := self.txtDelim.text;
	pos := 1;
	
	foreach idx in 1 to _numFields do
		colData := _str.cnEcNextDelimitedField(delim, pos);
		if pos &lt; lastPos then //cnwrs1 Par 23424 25 Mar 2010 dont re process a line 
			break;
		endif;
		rowStr := rowStr &amp; colData &amp; Tab;
		lastPos := pos;
	endforeach;
	tbl.addItem(rowStr);
end;





</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <Parameter name="_numFields" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSampleRowFixedLength" id="22b10431-5e44-4a54-a7e6-8b8675f3f9b1">
        <source>addSampleRowFixedLength(_str : String) protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row,
	idx,
	len			: Integer;
	tbl			: CM_DataTable;
	
begin
	tbl := self.tblSampleData;
	len := _str.length;
	if tbl.columns &lt; len then
		tbl.columns := len;
	endif;
	row := tbl.addItem(null);
	
	foreach idx in 1 to len do
		tbl.setCellText(row, idx, _str[idx:1]);
	endforeach;

end;


</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="51bc8cb3-0bf1-4576-9ac6-ffc6141a2900">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	20 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
09/04/2014	 cnwah9		 CCMS1380
----------   ----------  --------------------------------------------------
*/
vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	showCaptions := toolbar.showCaptions;
	
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExportDef, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImportDef, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnBrowse_click" id="dd698823-cdd4-45ed-837e-37d823d0a91f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowse_click(btn: Button input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	fileGet		 		: CMDFileOpen;
//	fileName			: String;
begin
	create fileGet transient;
	//fileGet.filter := '*.csv|';
	//fileGet.fileName := '*.csv';
//	fileGet.initDir := self.myTerminal.getConfig(EDIFileDirectory).String;	// cnwrl1 27/05/2009 PAR 19732 - what it was
	fileGet.initDir := self.myTerminal.getConfig_FileDirectory(EDIFileDirectory).String;
	if fileGet.open = 0 then	//user clicked OK
		self.txtFileName.text := fileGet.fileName;
	else
		self.txtFileName.text := null;
	endif;
	
	
epilog
	delete fileGet;	



end;


</source>
