    <JadeMethod name="checkWSDL11UpdateTFS45330" id="6eddfead-a79a-4594-b111-fdfce3c26326">
        <source>checkWSDL11UpdateTFS45330( _voyage : CM_Voyage );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2019	jlgndl1	Initial creation	TFS 45330

*/

vars

	cr : CM_CashReceipt;
	inv : CM_Invoice;
	
	isBackGround : Boolean;
	objArray : ObjectArray;
	
	sapPerfEnabled : Boolean;
	sapFinEnabled : Boolean;
	
	wsdlType : String;
	invLines : CM_InvoiceLineSet;
	
begin

	isBackGround := app.isBackGroundApp;
	sapPerfEnabled := self.getMyTerminal.getConfig( SapPerformanceEnabled ).Boolean;
	sapFinEnabled := self.getMyTerminal.getConfig( SapFinancialEnabled ).Boolean;
	
	app.setIsBackGroundApp( true );	// for lock testing.

	create objArray transient;
	_voyage.allCashReceipts.copy( objArray );
	
	cr := objArray[2].CM_CashReceipt;
	wsdlType := BGP_SAPWSRequest.WSDL11;	//1.1  **************************
	
	self.doWsdlReprocessing( wsdlType, null, cr, null );
		
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.1 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED, "Failed to set payment status to paid for 'cash receipt' after WSDL 1.1" );
	self.assertTrueMsg( cr.myWorkOrder.taskStatus = WO_STATUS_APPROVED, "Failed to set status to approved for 'work order' after WSDL 1.1" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL110;	//1.10  *****************************
	
	self.doWsdlReprocessing( wsdlType, null, cr, null );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.10 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CANCEL_APPROVED, "Failed to set payment status to Credit Cancel Approved for 'cash receipt' after WSDL 1.10" );

	
	
	cr := objArray[3].CM_CashReceipt;
	inv := cr.myCashInvoice;
	wsdlType := BGP_SAPWSRequest.WSDL111;	//1.11 ************************
	
	self.doWsdlReprocessing( wsdlType, inv, cr, null );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.11 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CANCEL_APPROVED, "Failed to set payment status to Credit Cancel Approved for 'cash receipt' after WSDL 1.11" );
	self.assertTrueMsg( inv.paymentStatus = CM_Invoice.INVOICE_PAYMENT_CANCEL, "Failed to set payment status to Payment Cancel for 'Invoice' after WSDL 1.11" );
	
	
	
	if not sapPerfEnabled then
		beginTransaction;
		self.getMyTerminal.setConfig( SapPerformanceEnabled, true );
		commitTransaction;
	endif;
	if not sapFinEnabled then
		beginTransaction;
		self.getMyTerminal.setConfig( SapFinancialEnabled, true );
		commitTransaction;
	endif;
	
	wsdlType := BGP_SAPWSRequest.WSDL17;	//1.7  *****************************
	
	self.doWsdlReprocessing( wsdlType, inv, null, null );
		
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.7 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID, "Failed to set payment status to Payment NOT Paid for 'Invoice' after WSDL 1.7" );
	self.assertTrueMsg( inv.invoiceLines.first.externalTS07.isValid, "Failed to set 'externalTS07' on the invoicelines after WSDL 1.7" );
	self.assertTrueMsg( not inv.allSapRequests.isEmpty, "Failed to find a BGP request for Kinerja after WSDL 1.7" );

	
	inv := objArray[3].CM_CashReceipt.myCashInvoice;
	wsdlType := BGP_SAPWSRequest.WSDL13;	//1.3  *****************************
	
	self.doWsdlReprocessing( wsdlType, inv, null, null );
		
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.3 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.invoiceLines.first.externalTS06.isValid, "Failed to set 'externalTS06' on the invoicelines after WSDL 1.3" );
	self.assertTrueMsg( not inv.allSapRequests.isEmpty, "Failed to find a BGP request for Kinerja after WSDL 1.3" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL19;	//1.9  *****************************
	
	self.doWsdlReprocessing( wsdlType, inv, null, null );
		
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.9 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.kinerjaDT.isValid, "Failed to set 'kinerjaDT' on the invoice after WSDL 1.9" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL112;	//1.12  *****************************
	
	create invLines transient;
	inv.invoiceLines.copy(invLines);
	self.doWsdlReprocessing( wsdlType, inv, null, invLines );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.12 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.invoiceLines.first.externalTS05.isValid, "Failed to set 'externalTS05' on the invoicelines after WSDL 1.12" );
	//self.assertTrueMsg( inv.status = CM_Invoice.INVOICE_POSTED, "Failed to set status to Posted for 'Invoice' after WSDL 1.12" );
	
	
	
	inv := objArray[4].CM_CashReceipt.myCashInvoice;
	// dummy up an associated posted pending invoice so we can trick the code into trying to export the inv lines.
	beginTransaction;
	inv.setPropertyValue( CM_Invoice::myPostedPendingInvoice.name, objArray[3].CM_CashReceipt.myCashInvoice );
	commitTransaction;
	
	wsdlType := BGP_SAPWSRequest.WSDL15;	//1.5  *****************************
	
	self.doWsdlReprocessing( wsdlType, inv, null, null );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.5 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( not inv.allSapRequests.isEmpty, "Failed to find a BGP request for a WSDL 1.12 after processing a WSDL 1.5" );
	
	cr := objArray[5].CM_CashReceipt;
	wsdlType := BGP_SAPWSRequest.WSDL14;	//1.4  *****************************
	
	self.doWsdlReprocessing( wsdlType, null, cr, null );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.4 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED, "Failed to set payment status to paid for 'cash receipt' after WSDL 1.4" );
	self.assertTrueMsg( cr.myWorkOrder.taskStatus = WO_STATUS_APPROVED, "Failed to set status to approved for 'work order' after WSDL 1.4" );


	
	cr := objArray[3].CM_CashReceipt;
	wsdlType := BGP_SAPWSRequest.WSDL16;	//1.6  *****************************
	
	self.doWsdlReprocessing( wsdlType, null, cr, null );
		
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.6 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED, "Failed to set payment status to paid for 'cash receipt' after WSDL 1.6" );
	self.assertTrueMsg( cr.myWorkOrder.taskStatus = WO_STATUS_APPROVED, "Failed to set status to approved for 'work order' after WSDL 1.6" );
			
epilog

	if sapPerfEnabled &lt;&gt; self.getMyTerminal.getConfig( SapPerformanceEnabled ).Boolean then
		beginTransaction;
		self.getMyTerminal.setConfig( SapPerformanceEnabled, sapPerfEnabled );
		commitTransaction;
	endif;
	if sapFinEnabled &lt;&gt; self.getMyTerminal.getConfig( SapFinancialEnabled ).Boolean then
		beginTransaction;
		self.getMyTerminal.setConfig( SapFinancialEnabled, sapFinEnabled );
		commitTransaction;
	endif;

	app.setIsBackGroundApp( isBackGround );

	delete objArray;
	delete invLines;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="checkWSDL12updateTFS45312" id="7e5a37a4-eca6-4ffa-8357-b4113712dddd">
        <source>checkWSDL12updateTFS45312( _voyage : CM_Voyage );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2019	jlgndl1	Initial creation	TFS 45312

*/

vars

	inv : CM_Invoice;
	cr : CM_CashReceipt;
	voyage : CM_Voyage;
	
	pxyInvoice : CM_Invoice;
	cmifStatus : CMIF_InvoiceStatus;
	
	finIOClass : CM_ExtFinanceIO;
	addInfo1 : String;
	isBackGround : Boolean;
	
	wsdlType : String;

begin

	isBackGround := app.isBackGroundApp;
	finIOClass := self.getTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	addInfo1 := self.getTerminal.getConfig(AdditionalInfo1).String;

	cr := _voyage.allCashReceipts.first;
	inv := cr.myCashInvoice;

	beginTransaction;
	
	pxyInvoice := app.createUpdateProxy( inv ).CM_Invoice;
	pxyInvoice.toDT := app.actualTimeServer;
		
	create cmifStatus transient;
	cmifStatus.myInvoice := pxyInvoice;
	cmifStatus.newStatus := CM_Invoice.INVOICE_PENDING;
	
	app.myValUA.valInvoiceStatus( inv, cmifStatus );
	
	if app.myPassport.noErrors then
		app.myUtilityUA.utlUpdateInvoiceStatus( cmifStatus, app.myPassport);
	endif;
	
	cr.setPropertyValue( CM_CashReceipt::paymentStatus.name, CM_CashReceipt.CREDIT_CHECK_APPROVED );
	
	commitTransaction;
	
	delete pxyInvoice;
	delete cmifStatus;
	
	if finIOClass &lt;&gt; null or not finIOClass.isKindOf(CM_Pelindo1Interface) then 
		beginTransaction;
		self.getTerminal.setConfig(FinancialIOClass, CM_Pelindo1Interface.firstInstance);
		self.getTerminal.setConfig(AdditionalInfo1, "222");
		commitTransaction;
	endif;
	
	app.setIsBackGroundApp( true );	// for lock testing.
	
	wsdlType := BGP_SAPWSRequest.WSDL12;	//1.2  **************************
	
	self.doWsdlReprocessing( wsdlType, inv, cr, null );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL1.2 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID, "Failed to set payment status to paid for 'invoice' after WSDL1.2" );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.PAID, "Failed to set payment status to paid for 'cash receipt' after WSDL1.2" );
	self.assertTrueMsg( inv.externalTaxNumber &lt;&gt; null, "Failed to set tax number for 'invoice' after WSDL1.2" ); 
	self.assertTrueMsg( inv.status = CM_Invoice.INVOICE_POSTED, "Failed to set status to posted for 'invoice' after WSDL12" );

epilog

	app.setIsBackGroundApp( isBackGround );

	abortTransaction;
	if self.getTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO &lt;&gt; finIOClass then
		beginTransaction;
		self.getTerminal.setConfig(FinancialIOClass, finIOClass);
		self.getTerminal.setConfig(AdditionalInfo1, addInfo1);
		commitTransaction;
	endif;

	delete pxyInvoice;
	delete cmifStatus;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="checkWSDLHandleResponse" id="cbecf311-751d-4b57-a542-fa0368f30d53">
        <source>checkWSDLHandleResponse( _voyage : CM_Voyage );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	inv : CM_Invoice;
	cr : CM_CashReceipt;
	invLines : CM_InvoiceLineSet;
	voyage : CM_Voyage;
	
	wsDefinition : CM_ExternalWebServiceDef;
	
	finIOClass : CM_ExtFinanceIO;
	addInfo1 : String;
	isBackGround : Boolean;
	sapPerfEnabled : Boolean;
	sapFinEnabled : Boolean;
	objArray : ObjectArray;
	
	wsdlType : String;
	dummyResponse : CMIF_SAPWSResponse;
	
	pxyInvoice : CM_Invoice;
	cmifStatus : CMIF_InvoiceStatus;

begin

	isBackGround := app.isBackGroundApp;
	finIOClass := self.getTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	addInfo1 := self.getTerminal.getConfig(AdditionalInfo1).String;
	
	sapPerfEnabled := self.getMyTerminal.getConfig( SapPerformanceEnabled ).Boolean;
	sapFinEnabled := self.getMyTerminal.getConfig( SapFinancialEnabled ).Boolean;
	
	if finIOClass &lt;&gt; null or not finIOClass.isKindOf(CM_Pelindo1Interface) then 
		beginTransaction;
		self.getTerminal.setConfig(FinancialIOClass, CM_Pelindo1Interface.firstInstance);
		self.getTerminal.setConfig(AdditionalInfo1, "222");
		commitTransaction;
	endif;
	
	if not sapPerfEnabled then
		beginTransaction;
		self.getMyTerminal.setConfig( SapPerformanceEnabled, true );
		commitTransaction;
	endif;
	if not sapFinEnabled then
		beginTransaction;
		self.getMyTerminal.setConfig( SapFinancialEnabled, true );
		commitTransaction;
	endif;
	
	app.setIsBackGroundApp( true );	// for lock testing.
	
	create objArray transient;
	_voyage.allCashReceipts.copy( objArray );
	
	create dummyResponse transient;
	dummyResponse.status := "X";
	
	wsDefinition := CM_SAPWebService.firstInstance;
	
	wsdlType := BGP_SAPWSRequest.WSDL12;	//1.2  **************************
	//Send Release Hold and Debit for Auto-Collection Customer
	//WSDL 1.2: Auto-Collection - Release Hold/Debit
	//PaymentType_AutoCollection
	
	cr := _voyage.allCashReceipts.first;
	inv := cr.myCashInvoice;
	
	beginTransaction;
	
	pxyInvoice := app.createUpdateProxy( inv ).CM_Invoice;
	pxyInvoice.toDT := app.actualTimeServer;
		
	create cmifStatus transient;
	cmifStatus.myInvoice := pxyInvoice;
	cmifStatus.newStatus := CM_Invoice.INVOICE_PENDING;
	
	app.myValUA.valInvoiceStatus( inv, cmifStatus );
	
	if app.myPassport.noErrors then
		app.myUtilityUA.utlUpdateInvoiceStatus( cmifStatus, app.myPassport);
	endif;
	
	cr.setPropertyValue( CM_CashReceipt::paymentStatus.name, CM_CashReceipt.CREDIT_CHECK_APPROVED );
	
	commitTransaction;
	
	delete pxyInvoice;
	delete cmifStatus;
	
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, inv, cr, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.2 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID, "Failed to set payment status to paid for 'invoice' after WSDL 1.2" );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.PAID, "Failed to set payment status to paid for 'cash receipt' after WSDL 1.2" );
	self.assertTrueMsg( inv.externalTaxNumber &lt;&gt; null, "Failed to set tax number for 'invoice' after WSDL 1.2" ); 
	self.assertTrueMsg( inv.status = CM_Invoice.INVOICE_POSTED, "Failed to set status to posted for 'invoice' after WSDL 1.2" );

	
	wsdlType := BGP_SAPWSRequest.WSDL11;		//1.1  **************************
	//Perform Credit Check for Auto-Collection Customer 
	//WSDL 1.1: Auto-Collection - Credit Limit + Hold Amount
	//PaymentType_AutoCollection
	
	cr := objArray[2].CM_CashReceipt;
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, null, cr, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.1 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED, "Failed to set payment status to paid for 'cash receipt' after WSDL 1.1" );
	self.assertTrueMsg( cr.myWorkOrder.taskStatus = WO_STATUS_APPROVED, "Failed to set status to approved for 'work order' after WSDL 1.1" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL110;		//1.10  **************************
	
	cr := objArray[2].CM_CashReceipt;
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, null, cr, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.10 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CANCEL_APPROVED, "Failed to set payment status to Credit Cancel Approved for 'cash receipt' after WSDL 1.10" );

	
	wsdlType := BGP_SAPWSRequest.WSDL111;		//1.11  **************************
	
	inv := objArray[3].CM_CashReceipt.myCashInvoice;
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, inv, null, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.11 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CANCEL_APPROVED, "Failed to set payment status to Credit Cancel Approved for 'cash receipt' after WSDL 1.11" );
	self.assertTrueMsg( inv.paymentStatus = CM_Invoice.INVOICE_PAYMENT_CANCEL, "Failed to set payment status to Payment Cancel for 'Invoice' after WSDL 1.11" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL17;		//1.7  **************************
	
	inv := objArray[3].CM_CashReceipt.myCashInvoice;
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, inv, null, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.7 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID, "Failed to set payment status to Payment NOT Paid for 'Invoice' after WSDL 1.7" );
	self.assertTrueMsg( inv.invoiceLines.first.externalTS07.isValid, "Failed to set 'externalTS07' on the invoicelines after WSDL 1.7" );
	self.assertTrueMsg( not inv.allSapRequests.isEmpty, "Failed to find a BGP request for Kinerja after WSDL 1.7" );

	
	wsdlType := BGP_SAPWSRequest.WSDL13;		//1.3  **************************
	
	inv := objArray[3].CM_CashReceipt.myCashInvoice;
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, inv, null, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.3 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.invoiceLines.first.externalTS06.isValid, "Failed to set 'externalTS06' on the invoicelines after WSDL 1.3" );
	self.assertTrueMsg( not inv.allSapRequests.isEmpty, "Failed to find a BGP request for Kinerja after WSDL 1.3" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL19;		//1.9  **************************
	
	inv := objArray[3].CM_CashReceipt.myCashInvoice;
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, inv, null, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.9 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.kinerjaDT.isValid, "Failed to set 'kinerjaDT' on the invoice after WSDL 1.9" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL112;		//1.12  **************************
	
	inv := objArray[3].CM_CashReceipt.myCashInvoice;
	create invLines transient;
	inv.invoiceLines.copy(invLines);
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, inv, null, invLines, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.12 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( inv.invoiceLines.first.externalTS05.isValid, "Failed to set 'externalTS05' on the invoicelines after WSDL 1.12" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL15;		//1.5  **************************
	
	inv := objArray[4].CM_CashReceipt.myCashInvoice;
	beginTransaction;
	inv.setPropertyValue( CM_Invoice::myPostedPendingInvoice.name, objArray[3].CM_CashReceipt.myCashInvoice );
	commitTransaction;
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, inv, null, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.5 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( not inv.allSapRequests.isEmpty, "Failed to find a BGP request for a WSDL 1.12 after processing a WSDL 1.5" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL14;		//1.4  **************************
	
	cr := objArray[5].CM_CashReceipt;
	inv := cr.myCashInvoice;
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, inv, cr, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.4 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED, "Failed to set payment status to paid for 'cash receipt' after WSDL 1.4" );
	self.assertTrueMsg( cr.myWorkOrder.taskStatus = WO_STATUS_APPROVED, "Failed to set status to approved for 'work order' after WSDL 1.4" );
	
	
	wsdlType := BGP_SAPWSRequest.WSDL16;		//1.6  **************************
	
	cr := objArray[3].CM_CashReceipt;
	self.doWsdlHandleResponse( wsDefinition, dummyResponse, null, cr, null, wsdlType );
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to complete WSDL 1.6 update : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cr.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED, "Failed to set payment status to paid for 'cash receipt' after WSDL 1.6" );
	self.assertTrueMsg( cr.myWorkOrder.taskStatus = WO_STATUS_APPROVED, "Failed to set status to approved for 'work order' after WSDL 1.6" );

	
epilog

	app.setIsBackGroundApp( isBackGround );

	abortTransaction;
	if self.getTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO &lt;&gt; finIOClass then
		beginTransaction;
		self.getTerminal.setConfig(FinancialIOClass, finIOClass);
		self.getTerminal.setConfig(AdditionalInfo1, addInfo1);
		commitTransaction;
	endif;
	
	if sapPerfEnabled &lt;&gt; self.getMyTerminal.getConfig( SapPerformanceEnabled ).Boolean then
		beginTransaction;
		self.getMyTerminal.setConfig( SapPerformanceEnabled, sapPerfEnabled );
		commitTransaction;
	endif;
	if sapFinEnabled &lt;&gt; self.getMyTerminal.getConfig( SapFinancialEnabled ).Boolean then
		beginTransaction;
		self.getMyTerminal.setConfig( SapFinancialEnabled, sapFinEnabled );
		commitTransaction;
	endif;

	delete objArray;
	delete dummyResponse;
	delete invLines;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="doWsdlHandleResponse" id="fd6efdf4-0ab6-4af2-9de5-6182fbd3f45b">
        <source>doWsdlHandleResponse(	_wsDefinition : CM_ExternalWebServiceDef;
						_dummyResponse : CMIF_SAPWSResponse;
						_inv : CM_Invoice input;
						_cr : CM_CashReceipt input;
						_invLines : CM_InvoiceLineSet input;
						_wsdlType : String
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	wo : CM_WorkOrder;
	bgpReq : BGP_SAPWSRequest;
	agent : CM_SAPWSConsumerAgent;
	request : CMIF_SAPWSRequest;
	realResponse : CMIF_SAPWSResponse;
	invLine : CM_InvoiceLine;

begin

	create agent transient;
	agent.setupFromWebServiceDefinition(_wsDefinition);
	app.myPassport.setMyTerminal(self.getTerminal);

	create bgpReq transient;
	bgpReq.myInvoice := _inv;
	bgpReq.myCashReceipt := _cr;
	if _invLines &lt;&gt; null and not _invLines.isEmpty then
	_invLines.copy( bgpReq.allInvoiceLines );
	endif;
	
	if _wsdlType = BGP_SAPWSRequest.WSDL11 then
		bgpReq.isSAPAutoEstReq := true;
		create request as CMIF_SAPAutoEstReq transient;
		request.CMIF_SAPAutoEstReq.copyToSAPAutoEstReq(_cr);
		realResponse := agent.autocollEstimationRequest_SI(request.CMIF_SAPAutoEstReq);
		
	elseif _wsdlType = BGP_SAPWSRequest.WSDL12 then
		bgpReq.isSAPReleaseHoldDebit := true;
		create request as CMIF_SAPAutoPreInvReq transient;
		request.CMIF_SAPAutoPreInvReq.copyToSAPAutoPreInvReq(_inv);
		realResponse := agent.autocollPreInvoiceNewRequest_SI(request.CMIF_SAPAutoPreInvReq);
		
	elseif _wsdlType = BGP_SAPWSRequest.WSDL13 then
		bgpReq.isSAPAutoInvReq := true;
		create request as CMIF_SAPAutoInvReq transient;
		request.CMIF_SAPAutoInvReq.copyToSAPAutoInvReq(_inv);
		realResponse := agent.autocollInvoiceRequest_SI(request.CMIF_SAPAutoInvReq);
	
	elseif _wsdlType = BGP_SAPWSRequest.WSDL14 then
		bgpReq.isSAPPreBillCheckLimitReq := true;
		create request as CMIF_SAPPreBillCheckLimitReq transient;
		request.CMIF_SAPPreBillCheckLimitReq.copyToSAPPreBillCheckLimitReq(_inv);
		realResponse := agent.preBillCheckLimitRequest_SI(request.CMIF_SAPPreBillCheckLimitReq);
	
	elseif _wsdlType = BGP_SAPWSRequest.WSDL15 then
		bgpReq.isSAPPreBillInvoiceReq := true;
		create request as CMIF_SAPPreBillPaidInvReq transient;
		request.CMIF_SAPPreBillPaidInvReq.copyToSAPPreBillPaidInvReq(_inv);
		realResponse := agent.preBillPaidInvoiceRequest_SI(request.CMIF_SAPPreBillPaidInvReq);
		
	elseif _wsdlType = BGP_SAPWSRequest.WSDL16 then
		bgpReq.isSAPPostBillEstReq := true;
		create request as CMIF_SAPPostBillEstReq transient;
		request.CMIF_SAPPostBillEstReq.copyToSAPPostBillEstReq(_cr);
		realResponse := agent.postBillEstimationRequest_SI(request.CMIF_SAPPostBillEstReq);
		
	elseif _wsdlType = BGP_SAPWSRequest.WSDL17 then
		bgpReq.isSAPPostBillInvReq := true;
		create request as CMIF_SAPPostBillInvReq transient;
		request.CMIF_SAPPostBillInvReq.copyToSAPPostBillInvReq(_inv);
		realResponse := agent.postBillInvoiceRequest_SI(request.CMIF_SAPPostBillInvReq);
	
	elseif _wsdlType = BGP_SAPWSRequest.WSDL19 then
		bgpReq.isSAPDataKinerja := true;
		create request as CMIF_SAPDataKinerjaReq transient;
		if _inv &lt;&gt; null then 						
			request.CMIF_SAPDataKinerjaReq.copyToSAPDataKinerjaReq(_inv);
		else
			request.CMIF_SAPDataKinerjaReq.copyToSAPDataKinerjaReq(self.getTerminal);
		endif;
		realResponse := agent.dataKinerja_OB_SI(request.CMIF_SAPDataKinerjaReq);
		
	elseif _wsdlType = BGP_SAPWSRequest.WSDL110 then
		bgpReq.isSAPCancelEstimate := true;
		create request as CMIF_SAPAutoCancelReq transient;
		request.CMIF_SAPAutoCancelReq.copyToSAPAutoCancelReq(_cr);
		realResponse := agent.autocollCancellationRequest_SI(request.CMIF_SAPAutoCancelReq);
		
	elseif _wsdlType = BGP_SAPWSRequest.WSDL111 then
		bgpReq.isSAPCancelPaymentCode := true;
		create request as CMIF_SAPPreBillCancelReq transient;
		request.CMIF_SAPPreBillCancelReq.copyToSAPPreBillCancelReq(_inv);
		realResponse := agent.preBillCancellationRequest_SI(request.CMIF_SAPPreBillCancelReq);
	
	elseif _wsdlType = BGP_SAPWSRequest.WSDL112 then
		bgpReq.isSAPPreBillProdDataReq := true;
		create request as CMIF_SAPPreBillProdDataReq transient;
		request.CMIF_SAPPreBillProdDataReq.copyToSAPPreBillProdDataReq( _inv, _invLines );
		realResponse := agent.preBillProdDataReq_SI(request.CMIF_SAPPreBillProdDataReq);
		
	endif;

	request.handleSAPResponse(	_dummyResponse,	//_response : CMIF_SAPWSResponse;
								_cr,	//_cashReceipt : CM_CashReceipt input;
								_inv,	//_invoice : CM_Invoice input;
								_invLines,	//_invoiceLines : CM_InvoiceLineSet input;
								agent.myLastActivityHistory	//_activityHistory : CM_ActivityHistoryExtInterface input
								);
	
	
epilog

	abortTransaction;
	
	delete agent;
	delete request;
	delete realResponse;
	delete bgpReq;

end;</source>
        <Parameter name="_wsDefinition" type="CM_ExternalWebServiceDef"/>
        <Parameter name="_dummyResponse" type="CMIF_SAPWSResponse"/>
        <Parameter name="_inv" type="CM_Invoice" usage="input"/>
        <Parameter name="_cr" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_invLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_wsdlType" type="String"/>
    </JadeMethod>
    <JadeMethod name="doWsdlReprocessing" id="a92cc957-a97b-4b3c-a583-4d88db8938c4">
        <source>doWsdlReprocessing( _wsdlType : String;
					_invoice : CM_Invoice;
					_cashReceipt : CM_CashReceipt;
					_invLines : CM_InvoiceLineSet
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	activityHistExt : CM_ActivityHistoryExtInterface;
	cmifSapHelper : CMIF_SAPWSHelper;
	errorString : String;
	msg : String;

begin

	//create a dummy record including our cash receipt that has a successfull response from SAP, but errors 
	//for the 'response processing'.
	activityHistExt := self.generateDummyFailActivity( _wsdlType, _invoice, _cashReceipt, _invLines );
	self.assertTrueMsg( activityHistExt &lt;&gt; null, "Activity History Ext Interface object not created. ");

	//Now force re-processing vis the same mechanism used on the right click context menu  for reprocessing in 'CMUI_ActivityHistoryForm' 
	create cmifSapHelper transient;
	cmifSapHelper.setFromActivityHistory( activityHistExt );
	
	if not cmifSapHelper.handleSAPResponseReprocess( activityHistExt, errorString ) then
		if errorString &lt;&gt; null then
			msg := errorString;
		else
			msg := app.getErrorString(Reprocessing_failed) &amp; CrLf &amp; app.getErrorString(Check_activity_history);
		endif;
	endif;
	self.assertTrueMsg( msg = null, "Reprocess of " &amp; _wsdlType &amp; " failed with " &amp; msg);
	
epilog

	delete cmifSapHelper;

end;</source>
        <Parameter name="_wsdlType" type="String"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_invLines" type="CM_InvoiceLineSet"/>
    </JadeMethod>
    <JadeMethod name="generateDummyFailActivity" id="c5c272c4-9a79-4f99-935a-9303023ba129">
        <source>generateDummyFailActivity( 	_type : String;
							_invoice : CM_Invoice;
							_cashReceipt : CM_CashReceipt;
							_invLines : CM_InvoiceLineSet
							):CM_ActivityHistoryExtInterface;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	cmifSapHelper : CMIF_SAPWSHelper;
	proxyActivityHistExt : CM_ActivityHistoryExtInterface;
	activityHistExt : CM_ActivityHistoryExtInterface;

begin
	
	create cmifSapHelper transient;
	create proxyActivityHistExt transient;
	proxyActivityHistExt.setProxy(ActivityHistoryExtInterface, self.getTerminal, false);
	proxyActivityHistExt.setInterfaceName( CM_SAPWebService.firstInstance.name );
	proxyActivityHistExt.setSuccess( true );
	proxyActivityHistExt.setErrors( "Test for : Failed to do JMT Response updating" );

	if _type = BGP_SAPWSRequest.WSDL110 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample110Request, cmifSapHelper.sample110Response );
		proxyActivityHistExt.setMyCashReceipt( _cashReceipt );
		proxyActivityHistExt.setDescription( "AutocollCancellationRequest " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL11 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample11Request, cmifSapHelper.sample11Response );
		proxyActivityHistExt.setMyCashReceipt( _cashReceipt );
		proxyActivityHistExt.setDescription( "AutocollEstimationRequest " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL13 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample13Request, cmifSapHelper.sample13Response );
		proxyActivityHistExt.setMyInvoice( _invoice );
		proxyActivityHistExt.setDescription( "AutocollInvoiceRequest " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL12 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample12Request, cmifSapHelper.sample12Response );
		proxyActivityHistExt.setMyInvoice( _invoice );
		proxyActivityHistExt.setDescription( "AutocollPreInvoiceNewRequest " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL19 or  _type = "sent Performance Kinerja" then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample19Request, cmifSapHelper.sample19Response );
		proxyActivityHistExt.setMyInvoice( _invoice );
		proxyActivityHistExt.setDescription( "DataKinerja_OB_MT " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL16 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample16Request, cmifSapHelper.sample16Response );
		proxyActivityHistExt.setMyCashReceipt( _cashReceipt );
		proxyActivityHistExt.setDescription( "PostBillEstimationRequest " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL17 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample17Request, cmifSapHelper.sample17Response );
		proxyActivityHistExt.setMyInvoice( _invoice );
		proxyActivityHistExt.setDescription( "PostBillInvoiceRequest " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL111 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample111Request, cmifSapHelper.sample111Response );
		proxyActivityHistExt.setMyInvoice( _invoice );
		proxyActivityHistExt.setDescription( "PreBillCancellationRequest " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL14 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample14Request, cmifSapHelper.sample14Response );
		proxyActivityHistExt.setMyCashReceipt( _cashReceipt );
		proxyActivityHistExt.setDescription( "PreBillCheckLimitRequest " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL15 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample15Request, cmifSapHelper.sample15Response );
		proxyActivityHistExt.setMyInvoice( _invoice );
		proxyActivityHistExt.setDescription( "PreBillPaidInvoiceRequest " &amp; _type );
		
	elseif _type = BGP_SAPWSRequest.WSDL112 then
		proxyActivityHistExt.setMessageData( cmifSapHelper.sample112Request, cmifSapHelper.sample112Response );
		proxyActivityHistExt.setMyInvoice( _invoice );
		proxyActivityHistExt.setInvoiceLines( _invLines );
		proxyActivityHistExt.setDescription( "PreBillProdDataRequest " &amp; _type );
			
	endif;
	
		
	activityHistExt := app.myTrxCA.trxCreateActivityHistory(proxyActivityHistExt, app.myPassport).CM_ActivityHistoryExtInterface;
	self.assertTrueMsg( activityHistExt &lt;&gt; null, "Failed to create Dummy Act Hist for " &amp; _type &amp; " - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	return activityHistExt;

epilog

	delete proxyActivityHistExt;
	delete cmifSapHelper;

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_invLines" type="CM_InvoiceLineSet"/>
        <ReturnType type="CM_ActivityHistoryExtInterface"/>
    </JadeMethod>
    <JadeMethod name="setPelindo1HmsTAT_2" id="6054869a-e775-41f7-a4f5-77cd42f00971">
        <source>setPelindo1HmsTAT_2( _restoreDefaultOnly : Boolean; _operatorCode : String; _shipLineCode : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgndl1	Initial creation	TFS 44773

*/

constants
	
vars

	terminal : CM_Terminal;
	harbour : HMS_Harbour;
	wharf1 : HMS_Wharf;
	wharf2 : HMS_Wharf;
	berth : HMS_Berth;
	resourceType : HMS_ResourceType;
	resource : HMS_Resource;
	vessel : CM_Vessel;
	voyageSet : CM_VoyageSet;
	voyage : CM_Voyage;
	
	xmlDocumentParser : JadeXMLDocumentParser;
	xmlDocument : JadeXMLDocument;
	xmlRawString : String;
	rootElement : JadeXMLElement;
	pxyVessel : CM_Vessel;
	conflictManager : CMIF_HMS_ConflictsManager;
	
	transferType : CM_VoyageJobTransferType;
	workPoint : CM_WorkPoint;
	wpRate : CM_WorkPointCargoRates;
	cargoType : CM_CargoType;
	product : CM_Product;
	
	processHarbour : CM_ProcessHarbour;
	allHMSResourcesForShift : HMS_ResourceByTypeDict;		
	allHMSResourceTypeForEquip : HMS_ResourceTypeByCodeDict;	
	allHMSResourcesForExt : HMS_ResourceByTypeDict;
	
begin

	terminal:= self.getTerminal;
	harbour := terminal.myHarbour;
	
	self.deleteProcessHarbour( CM_VoyageProcessPEL1.firstInstance, harbour );
	
	vessel := self.getVessel( Vessel_Name );
	if vessel &lt;&gt; null then
		create voyageSet transient;
		vessel.allVoyagesByTermCodeArrival.copy( voyageSet );
		foreach voyage in voyageSet do
			self.deleteVoyage( voyage.code );
		endforeach;
		self.deleteVessel( Vessel_Name );
	endif;
	
	if harbour &lt;&gt; null then
		self.deleteBerth( Berth1Name, harbour );
		self.deleteBerth( Berth2Name, harbour );
		self.deleteBerth( Berth3Name, harbour );
		self.deleteBerth( Berth4Name, harbour );
		self.deleteWharf( Wharf1Name, harbour );
		self.deleteWharf( Wharf2Name, harbour );
	endif;
	
	self.deleteWorkPoint( WorkPoint1 );
	self.deleteWorkPoint( WorkPoint2 );
	
	self.opts.purge();
	self.opts.addAssoc( "deleteResources", true );
	self.deleteHMSResourceType( ResourceType1 );
	self.deleteHMSResourceType( ResourceType2 );
	self.deleteHMSResourceType( ResourceType3 );
	self.deleteHMSResourceType( ResourceType4 );
	self.deleteHMSResourceType( ResourceType5 );
	self.deleteHMSResourceType( ResourceType6 );
	self.deleteHMSResourceType( ResourceType7 );
	
	self.deleteVoyageJobTransferType( TransferType1 );
	self.deleteVoyageJobTransferType( TransferType2 );
	
	
	
	if _restoreDefaultOnly then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc( "IsLogicalWharf", false );
	wharf1 := self.addWharf(Wharf1Name,"Test wharf for Pelindo tests - DO NOT TOUCH", harbour, 1000, 10);
	self.assertTrueMsg( wharf1 &lt;&gt; null, "Failed to create wharf " &amp; Wharf1Name );
	
	wharf2 := self.addWharf(Wharf2Name,"Test wharf for Pelindo tests - DO NOT TOUCH", harbour, 1000, 10);
	self.assertTrueMsg( wharf2 &lt;&gt; null, "Failed to create wharf " &amp; Wharf2Name );
	
	self.opts.purge();
	self.opts.addAssoc( HMS_Berth::requiresLengthOfTime.name, true);
	berth := self.addBerth(Berth1Name, "Test berth for Pelindo tests - DO NOT TOUCH", harbour, 1, 500, 2.5, false, wharf1);
	self.assertTrueMsg( berth &lt;&gt; null, "Failed to create berth " &amp; Berth1Name );
	
	berth := self.addBerth(Berth2Name, "Test berth for Pelindo tests - DO NOT TOUCH", harbour, 501, 499, 2.5, false, wharf1);
	self.assertTrueMsg( berth &lt;&gt; null, "Failed to create berth " &amp; Berth2Name );
	
	berth := self.addBerth(Berth3Name, "Test berth for Pelindo tests - DO NOT TOUCH", harbour, 1, 500, 2.5, false, wharf2);
	self.assertTrueMsg( berth &lt;&gt; null, "Failed to create berth " &amp; Berth3Name );
	
	berth := self.addBerth(Berth4Name, "Test berth for Pelindo tests - DO NOT TOUCH", harbour, 501, 499, 2.5, false, wharf2);
	self.assertTrueMsg( berth &lt;&gt; null, "Failed to create berth " &amp; Berth4Name );
	
	create allHMSResourcesForShift transient;		
	create allHMSResourceTypeForEquip transient;	
	create allHMSResourcesForExt transient;
	
	self.opts.purge();
	self.opts.addAssoc( HMS_ResourceType::isFromToDateTimeRequired.name, true );
	resourceType := self.addHMSResourceTypeBasic(ResourceType1);
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create HMS resource type " &amp; ResourceType1 );
	allHMSResourceTypeForEquip.add( resourceType );
	
	
	resourceType := self.addHMSResourceTypeBasic(ResourceType2);
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create HMS resource type " &amp; ResourceType2 );
	allHMSResourceTypeForEquip.add( resourceType );
	
	resourceType := self.addHMSResourceTypeBasic(ResourceType3);
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create HMS resource type " &amp; ResourceType3 );
	
	resourceType := self.addHMSResourceTypeBasic(ResourceType4);
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create HMS resource type " &amp; ResourceType4 );
	
	resourceType := self.addHMSResourceTypeBasic(ResourceType5);
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create HMS resource type " &amp; ResourceType5 );
	
	self.opts.purge();
	self.opts.addAssoc( HMS_ResourceType::quantityUnits.name, true );
	resourceType := self.addHMSResourceTypeBasic(ResourceType6);
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create HMS resource type " &amp; ResourceType6 );
	
	resourceType := self.addHMSResourceTypeBasic(ResourceType7);
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create HMS resource type " &amp; ResourceType7 );
	allHMSResourceTypeForEquip.add( resourceType);
	
	self.opts.purge();
	self.opts.addAssoc( HMS_Resource::allVoyageStatuses.name, Voyage_Status_ServicesPending );
	resource := self.addHMSResourceBasic( harbour, ResourceType1, 2 );
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create resource for HMS resource type " &amp; ResourceType1 );
	allHMSResourcesForShift.add( resource );
	allHMSResourcesForExt.add( resource );
	
	resource := self.addHMSResourceBasic( harbour, ResourceType2, 2 );
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create resource for HMS resource type " &amp; ResourceType2 );
	allHMSResourcesForShift.add( resource );
	allHMSResourcesForExt.add( resource );
	
	resource := self.addHMSResourceBasic( harbour, ResourceType3, 2 );
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create resource for HMS resource type " &amp; ResourceType3 );
	allHMSResourcesForExt.add( resource );
	
	resource := self.addHMSResourceBasic( harbour, ResourceType4, 2 );
	allHMSResourcesForExt.add( resource );
	
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create resource for HMS resource type " &amp; ResourceType4 );
	resource := self.addHMSResourceBasic( harbour, ResourceType5, 2 );
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create resource for HMS resource type " &amp; ResourceType5 );
	resource := self.addHMSResourceBasic( harbour, ResourceType6, 2 );
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create resource for HMS resource type " &amp; ResourceType6 );
	resource := self.addHMSResourceBasic( harbour, ResourceType7, 2 );
	self.assertTrueMsg( resourceType &lt;&gt; null, "Failed to create resource for HMS resource type " &amp; ResourceType7 );
	
	self.addWharfResource( wharf1, resource, null );
	self.addWharfResource( wharf2, resource, null );
	
	self.opts.purge();
	self.opts.addAssoc( CM_ProcessHarbour::allHMSResourcesForShift.name, allHMSResourcesForShift );
	self.opts.addAssoc( CM_ProcessHarbour::allHMSResourcesForExt.name, allHMSResourcesForExt );
	self.opts.addAssoc( CM_ProcessHarbour::allHMSResourceTypeForEquip.name, allHMSResourceTypeForEquip );
	processHarbour := self.addProcessHarbour( CM_VoyageProcessPEL1.firstInstance, harbour );
	self.assertTrueMsg( processHarbour &lt;&gt; null, "Failed to create Process Harbour for " &amp; harbour.code );
	
	transferType := self.addVoyageJobTransferType( TransferType1 );
	self.assertTrueMsg( transferType &lt;&gt; null, "Failed to create Voyage Job Transfer Type " &amp; TransferType1 );
	transferType := self.addVoyageJobTransferType( TransferType2 );
	self.assertTrueMsg( transferType &lt;&gt; null, "Failed to create Voyage Job Transfer Type " &amp; TransferType2 );
	
	//add work point
	workPoint := self.addWorkPoint( WorkPoint1, false );
	self.assertTrueMsg( workPoint &lt;&gt; null, "Failed to create Work Point " &amp; WorkPoint1 );
	
	//add work point rates x2
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CargoType1 );
	product := cargoType.allProducts.findProductByCode(CargoSubType1);
	transferType := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( TransferType2 );
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("product", product);
	self.opts.addAssoc("targetRatePHQuantity", 150.Integer);
	self.opts.addAssoc("transferType", transferType.id.Integer);
	self.opts.addAssoc("dailyHoursWorkable", 15.Integer);
	wpRate := self.addWorkPointCargoRate( workPoint );
	
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CargoType2 );
	transferType := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( TransferType1 );
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("targetRatePHQuantity", 15.Integer);
	self.opts.addAssoc("transferType", transferType.id.Integer);
	self.opts.addAssoc("dailyHoursWorkable", 15.Integer);
	wpRate := self.addWorkPointCargoRate( workPoint );
	
	//add work point
	workPoint := self.addWorkPoint( WorkPoint2, false );
	self.assertTrueMsg( workPoint &lt;&gt; null, "Failed to create Work Point " &amp; WorkPoint2 );
	
	//add work point rates x2
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CargoType1 );
	product := cargoType.allProducts.findProductByCode(CargoSubType1);
	transferType := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( TransferType2 );
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("product", product);
	self.opts.addAssoc("targetRatePHQuantity", 150.Integer);
	self.opts.addAssoc("transferType", transferType.id.Integer);
	self.opts.addAssoc("dailyHoursWorkable", 5.Integer);
	wpRate := self.addWorkPointCargoRate( workPoint );
	
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CargoType2 );
	transferType := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( TransferType1 );
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("targetRatePHQuantity", 15.Integer);
	self.opts.addAssoc("transferType", transferType.id.Integer);
	self.opts.addAssoc("dailyHoursWorkable", 5.Integer);
	wpRate := self.addWorkPointCargoRate( workPoint );
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	
	xmlRawString := xmlVesselTAT_2( _operatorCode, _shipLineCode );
	xmlDocumentParser.parseDocumentString( xmlDocument, xmlRawString );
	
	rootElement := xmlDocument.rootElement;

	create pxyVessel as CM_Vessel transient;	
	pxyVessel.importFromXMLDoc(rootElement);
	pxyVessel.setPropertyValue( CM_Vessel::code.name, Vessel_Name );
	pxyVessel.myHMSVesselData.setPxyMyRoot(app.myRoot);

	app.myTrxCA.trxCreateVessel( pxyVessel, vessel, conflictManager, app.myPassport );
	self.assertTrueMsg( vessel &lt;&gt; null and app.myPassport.getErrorsAndWarningsAsString = null, "Failed to create Vessel " &amp; Vessel_Name &amp; " - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
epilog

	delete voyageSet;
	delete pxyVessel;
	delete xmlDocumentParser;
	delete xmlDocument;
	delete allHMSResourcesForShift;		
	delete allHMSResourceTypeForEquip;	
	delete allHMSResourcesForExt;

end;</source>
        <Parameter name="_restoreDefaultOnly" type="Boolean"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_shipLineCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPelindo1MapsTAT_1_2" id="04d5fcfd-3ed9-4d9e-b331-fb54765424d8">
        <source>setPelindo1MapsTAT_1_2( _restoreDefaultOnly : Boolean; _debtor : CM_DebtorNode ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2019	jlgndl1	Initial creation	TFS 44774 - Sets up / Cleans up the transaction map etc for the Base TAT Pelindo unit tests
													I.e. Pelindo1TAT_1  and Pelindo1TAT_2

*/

constants
	
vars

	terminal : CM_Terminal;
	bank : CM_Bank;

begin

	terminal := self.getTerminal;
	bank := terminal.getDefaultCompanyBank(); 
	
	
	if _restoreDefaultOnly then
		beginTransaction;
		bank.setInvoiceProcess( CM_InvoiceProcessDefault.firstInstance );
		commitTransaction;
	else
		beginTransaction;
		bank.setInvoiceProcess( CM_InvoiceProcessPel1.firstInstance );
		commitTransaction;
	endif;

	self.setPelindo1TATCargoMap( _restoreDefaultOnly, bank, _debtor );
	self.setPelindo1TATWorkOrderMap( _restoreDefaultOnly, bank, _debtor );
	self.setPelindo1TATVoyageHMSMap( _restoreDefaultOnly, bank, _debtor );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_restoreDefaultOnly" type="Boolean"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="setPelindo1TATCargoMap" id="aa813652-31c4-477c-9c7b-0796a0859f75">
        <source>setPelindo1TATCargoMap(	_restoreDefaultOnly : Boolean;
						_bank : CM_Bank;
						_debtor : CM_DebtorNode
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2019	jlgndl1	Initial creation	TFS 44773

*/

constants

		
vars

	cargoMap	: CM_TranMap;
	services : CM_ServiceByNameDict;
	invType1 : CM_InvoiceDesc;
	calType1 : CM_CalculationType;
	service : CM_Service;
	
	invLineType : CM_InvoiceLineDesc;
	
	fileContent : String;
	fileName : String;
	mapName : String;
	
	cargoTrxTypes : IntegerArray;	// The Transactions we want to include for invoicing in the Cargo Map
	trxNameArray1 : StringArray;
	trxName : String;
	type : Integer;
	serviceName : String;
	invLineTypeName : String;
	
	index : Integer;

begin

	// make sure we are using the default map before we start deleting the specific test one
	cargoMap := _bank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"Default cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	
	//delete our special transaction maps.
	self.deleteInvoiceTransactionMap( 1, CargoMapName );
		
	// delete our special invoice types.
	self.deleteInvoiceType(PelInvTypeGen);
	
	//get the transactions we care about
	 create cargoTrxTypes transient;  						create trxNameArray1 transient;
	cargoTrxTypes.add( TRANS_TYPE_WORKORDER_RETURNED );		trxNameArray1.add( app.getErrorString(TransType_195) );
	cargoTrxTypes.add( TRANS_TYPE_WORKORDER_MOVE );			trxNameArray1.add( app.getErrorString(TransType_194) );
	cargoTrxTypes.add( TRANS_TYPE_WORKORDER_NULLVOY );		trxNameArray1.add( app.getErrorString(TransType_196) );
	cargoTrxTypes.add( TRANS_TYPE_WORKORDER_RECEIVE );		trxNameArray1.add( app.getErrorString(TransType_197) );
	cargoTrxTypes.add( TRANS_TYPE_WORKORDER_RELEASE );		trxNameArray1.add( app.getErrorString(TransType_198) );
	cargoTrxTypes.add( TRANS_TYPE_WORKORDER_RELEXTEND );	trxNameArray1.add( app.getErrorString(TransType_215) );
	cargoTrxTypes.add( TRANS_TYPE_TASKCOMPLETE );			trxNameArray1.add( app.getErrorString(TransType_97) );

	// delete our services and inoice line types
	index := 0;
	foreach type in cargoTrxTypes do
		index := index + 1;
		serviceName := PelInvServicePrefix &amp; type.String;
		self.deleteInvoiceService( serviceName, FORCED_ERASE );
		invLineTypeName := PelInvLineTypePrefix &amp; type.String &amp; trxNameArray1[index];
		self.deleteInvoiceLineType( invLineTypeName, FORCED_ERASE );
	endforeach;
	
	if _restoreDefaultOnly then
		// we are only doing a delete ... All done
		return;
	endif;
	
	//create out special invoice types.
	invType1 := self.createInvoiceType(PelInvTypeGen, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType1, "General Invoice type '" &amp; PelInvTypeGen &amp; "' not created");
	beginTransaction;
	invType1.setPropertyValue( CM_InvoiceDesc::externalReference.name, "4NL"); // used when generating SAP Kinerja data via WSDL 1.9
	commitTransaction;
	
	self.setDefaultBankCashInvoiceType(invType1);
	
	// get the basic calulation type.  ( These ar all pre-existing )
	calType1 := app.myRoot.allCalculationTypesByCode['CCT00'];	 //INV_CALC_TYPE_QUANTITY;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_QUANTITY not found");
	
	// for each trx type we care about create a service, and an invoice line type and a rate
	create services transient;
	index := 0;
	foreach type in cargoTrxTypes do
		index := index + 1;
		services.clear();
		serviceName := PelInvServicePrefix &amp; type.String;
		service := self.createInvoiceService( serviceName, "Pelindo1 TAT Test", calType1, null);
		self.assertNotNullMsg(service, "Service " &amp; serviceName &amp; " not created");
		beginTransaction;
		delete service.debtorNodeRates.first.rateEntries.first;
		commitTransaction;
		services.add( service );
		self.setServiceRate( service, _debtor, "01/01/2019".Date, type.Decimal );
		invLineTypeName := PelInvLineTypePrefix &amp; type.String &amp; trxNameArray1[index];
		invLineType := self.createInvoiceLineType( invLineTypeName, calType1, invType1, services,"SDT1");  // SDT1 = Cargo Operator
		self.assertNotNullMsg(invLineType, "Invoice Line Type" &amp; invLineTypeName &amp; " not created");
	endforeach;	
	
	// Now create a dummy file to represent the special cargo map with a mapping for each of the above trx types to the invoice line types
	fileName := "CargoPEL1";
	// create the header line
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf;
	// adding the default void line
	fileContent := fileContent &amp; 'Cargo,'&amp;CargoMapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,VOID' &amp; CrLf;
	
	index := 0;
	foreach type in cargoTrxTypes do
		//adding each trx mapping line
		index := index + 1;
		invLineTypeName := PelInvLineTypePrefix &amp; type.String &amp; trxNameArray1[index];
		trxName := trxNameArray1[index];
		fileContent := fileContent &amp; 'Cargo,'&amp;CargoMapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),'&amp;trxName&amp;',,(Default),|CCT00|Value of 1 ›,(Default),,,All,' &amp; invLineTypeName &amp; CrLf;
	endforeach;
	
	//load the file
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	cargoMap := _bank.myCurrentTranMapCargo[CargoMapName];
	self.assertNotNullMsg(cargoMap, CargoMapName &amp; " cargo map should not be null");

	// now make the new map active.
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	
epilog

	delete services;
	delete cargoTrxTypes;
	delete trxNameArray1;

end;</source>
        <access>protected</access>
        <Parameter name="_restoreDefaultOnly" type="Boolean"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="setPelindo1TATVoyageHMSMap" id="42cf633a-9b82-4e66-a766-5848bb1f2e6d">
        <source>setPelindo1TATVoyageHMSMap(	_restoreDefaultOnly : Boolean;
							_bank : CM_Bank;
							_debtor : CM_DebtorNode
							) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2019	jlgndl1	Initial creation	TFS 44773
// ### TFS CR 65336 TASK 65339 09AUG2024 NAVAB1 added new columns to tran map CSV 

*/

constants
	
vars

	services : CM_ServiceByNameDict;
	invType3 : CM_InvoiceDesc;
	calType3 : CM_CalculationType;
	service : CM_Service;	
	invLineType : CM_InvoiceLineDesc;
	
	fileContent : String;
	fileName : String;
	mapName : String;

	trxName : String;
	type : Integer;
	serviceName : String;
	invLineTypeName : String;

	voyageMap	: CM_TranMapVoyage;
	intTypeArray3 : IntegerArray;
	trxNameArray3 : StringArray;
	
	resourceType : HMS_ResourceType;
	resources : HMS_ResourceByTypeDict;
	resource : HMS_Resource;
	resourceCode : String;
	resourceDesc : String;
	
	index : Integer;

begin
	
	//delete our special transaction map.
	self.deleteInvoiceTransactionMap( 3, VoyMapName );
	self.deleteInvoiceType(PelInvTypeVoy);
	

	//get the transactions we care about
	create intTypeArray3 transient;  						create trxNameArray3 transient;
	intTypeArray3.add( Trans_Type_ResourceCharged );		trxNameArray3.add( app.getErrorString(TransType_98) );
	
	// delete our special services and inoice line types
	index := 0;
	foreach type in intTypeArray3 do
		index := index + 1;
		serviceName := PelInvServicePrefix &amp; type.String;
		self.deleteInvoiceService( serviceName, FORCED_ERASE );
		invLineTypeName := PelInvLineTypePrefix &amp; type.String &amp; trxNameArray3[index];
		self.deleteInvoiceLineType( invLineTypeName, FORCED_ERASE );
	endforeach;
	
	if _restoreDefaultOnly then
		// we are only doing a delete ... All done
		return;
	endif;
	
	//If we are creating, then do this stuff.	
	create resources transient;
	resourceType := app.myRoot.allResourceTypes[ResourceType1];
	if resourceType = null then
		//will be null if called from "Pelindo1TAT_1, because it doesn't use resources or this mapping
		return;
	endif;
	resourceType.allResources.copy( resources );
	resourceType := app.myRoot.allResourceTypes[ResourceType2];
	resourceType.allResources.copy( resources );
	resourceType := app.myRoot.allResourceTypes[ResourceType3];
	resourceType.allResources.copy( resources );
	resourceType := app.myRoot.allResourceTypes[ResourceType4];
	resourceType.allResources.copy( resources );
	resourceType := app.myRoot.allResourceTypes[ResourceType5];
	resourceType.allResources.copy( resources );
	resourceType := app.myRoot.allResourceTypes[ResourceType6];
	resourceType.allResources.copy( resources );
	resourceType := app.myRoot.allResourceTypes[ResourceType7];
	resourceType.allResources.copy( resources );
	
	//create out special invoice types.
	self.opts.purge();
	self.opts.addAssoc( CM_InvoiceDesc::invoiceKey.name, CM_InvoiceDesc.Key_Voyage );
	invType3 := self.createInvoiceType(PelInvTypeVoy, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType3, "Voyage HMS Invoice type '" &amp; PelInvTypeVoy &amp; "' not created");
	self.opts.purge();
		
	// get the basic calulation type.  ( pre-existing )
	calType3 := app.myRoot.allCalculationTypesByCode['HMS009'];	 //INV_CALC_TYPE_RESOURCE_QTY;
	self.assertNotNullMsg(calType3, "Calculation type INV_CALC_TYPE_RESOURCE_QTY not found");
	
	// for each trx type we care about create a service, and an invoice line type and a rate
	create services transient;	
	index := 0;
	foreach type in intTypeArray3 do
		index := index + 1;
		services.clear();
		serviceName := PelInvServicePrefix &amp; type.String;
		service := self.createInvoiceService( serviceName, "Pelindo1 TAT Test", calType3, null);
		self.assertNotNullMsg(service, "Service " &amp; serviceName &amp; " not created");
		beginTransaction;
		delete service.debtorNodeRates.first.rateEntries.first;
		commitTransaction;
		services.add( service );
		self.setServiceRate( service, _debtor, "01/01/2019".Date, type.Decimal );
		invLineTypeName := PelInvLineTypePrefix &amp; type.String &amp; trxNameArray3[index];
		invLineType := self.createInvoiceLineType( invLineTypeName, calType3, invType3, services,"SDT4");  // SDT4 = Ship Operator
		self.assertNotNullMsg(invLineType, "Invoice Line Type" &amp; invLineTypeName &amp; " not created");
	endforeach;	
	
	// Now create a dummy file to represent the special Voyage (HMS) map with a mapping for each of the above trx types to the invoice line types
	fileName := "VoyPEL1";
	// create the header line
	fileContent := 'TranMap Type,TranMap Name,Resource,Debtor,Quantity Type,Quantity Range,In Contract,Cargo Type,Sub Type, Commodity,Vessel Category,Transfer Type,Grouping,Invoice Line' &amp; CrLf;
	// adding the default void line
	fileContent := fileContent &amp; 'Voyage,'&amp;VoyMapName&amp;',(Default),(Default),(Default) ›,(Default),X,(Default),(Default),(Default),**Any**,**Any**,All,VOID' &amp; CrLf;
	fileContent := fileContent &amp; 'Voyage,'&amp;VoyMapName&amp;',(Default),(Default),(Default) ›,(Default),(Default),(Default),(Default),,**Any**,**Any**,All,VOID' &amp; CrLf;
	
	index := 1;  // We only have one at the moment
	invLineTypeName := PelInvLineTypePrefix &amp; type.String &amp; trxNameArray3[index];
	trxName := trxNameArray3[index];
	foreach resource in resources do
		resourceCode := resource.code;
		resourceDesc := resource.description;
		fileContent := fileContent &amp; 'Voyage,'&amp;VoyMapName&amp;','&amp;resourceCode&amp;'| '&amp;resourceDesc&amp;',(Default),(Default) ›,(Default),X,(Default),(Default),(Default),**Any**,**Any**,All,VOID' &amp; CrLf;
		fileContent := fileContent &amp; 'Voyage,'&amp;VoyMapName&amp;','&amp;resourceCode&amp;'| '&amp;resourceDesc&amp;',(Default),(Default) ›,(Default),,(Default),(Default),(Default),**Any**,**Any**,All,' &amp; invLineTypeName &amp; CrLf;
	endforeach;

	//load the file
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	voyageMap := _bank.allJMHTMs[VoyMapName];
	self.assertNotNullMsg(voyageMap, VoyMapName &amp; " work order map should not be null");

	// now make the new map active.
	app.myTrxUA.trxUpdateBankTMVActive(voyageMap,app.myPassport);
	
epilog

	delete services;	
	delete intTypeArray3;
	delete trxNameArray3;
	delete resources;

end;</source>
        <access>protected</access>
