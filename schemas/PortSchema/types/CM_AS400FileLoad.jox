    <JadeMethod name="addAudit" id="3064db4a-5ab8-4307-8e96-ab71422a011b">
        <updating/>
        <source>addAudit(_user : String; _startTime, _endTime : TimeStamp; _state : Integer) updating;

vars

	store	: String;

begin

	store := 'Process - ' &amp; self.getLoadStateString(_state);
	store := store &amp; '/ User - ' &amp; _user;
	if _startTime &lt;&gt; null then
		store := store &amp; '/Start Time - ' &amp; _startTime.display();
	elseif _endTime &lt;&gt; null then
		store := store &amp;  '/End Time - ' &amp; _endTime.display();
	endif;
	self.allAudits.add(store);

end;</source>
        <Parameter name="_user" type="String"/>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_endTime" type="TimeStamp"/>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLoadStateString" id="17d40eb4-98f5-4c7a-913f-3f7fb40bdc59">
        <source>getLoadStateString(_loadState : Integer) : String;

vars

begin

	if _loadState = 0 then
		return 'File Load Unsuccessful';
	elseif _loadState = File_Loaded then
		return 'File Load';
	elseif _loadState = File_Preloaded then
		return 'Preload';
	elseif _loadState = File_DocketsLoaded then
		return 'Docket Load';
	elseif _loadState = File_LogsLoaded then
		return 'Log Load';
	elseif _loadState = File_PostLoad then
		return 'Post Load';
	else
		return 'Invalid state';
	endif;

end;</source>
        <Parameter name="_loadState" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="81db7830-a244-462c-9597-aa1ab3b51db2">
        <updating/>
        <source>setForCreate(_id, _docketFile, _logFile, _terminal : String; _root : CM_AS400Root) updating;

vars

begin

	self.id := _id;
	self.docketFileName := _docketFile;
	self.logFileName := _logFile;
	self.terminalName := _terminal;
	self.myAS400Root := _root;
	

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_docketFile" type="String"/>
        <Parameter name="_logFile" type="String"/>
        <Parameter name="_terminal" type="String"/>
        <Parameter name="_root" type="CM_AS400Root"/>
    </JadeMethod>
    <JadeMethod name="setLoadState" id="fd67feda-fb47-4fb1-ae94-0120303c6730">
        <updating/>
        <source>setLoadState(_loadState : Integer) updating;

vars

begin

	self.loadState := _loadState;

end;</source>
        <Parameter name="_loadState" type="Integer"/>
    </JadeMethod>
