    <JadeMethod name="writeToDiskFileDbServer" id="c26dfe0f-565d-47d4-8cba-f44ce6c4f5b6">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>writeToDiskFileDbServer(pDiskFileObj:File; pFileData:Binary; pIsCompressionUsed:Boolean) updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		08 July 2002 by cnwdad2
//
// Purpose:		Database Server node wrapper for the writeToDiskFile method.
// --------------------------------------------------------------------------------
begin
	on Exception do self.xHandlerServer(exception);
	
	self.writeToDiskFile(pDiskFileObj, pFileData, pIsCompressionUsed);
end;</source>
        <access>protected</access>
        <Parameter name="pDiskFileObj" type="File"/>
        <Parameter name="pFileData" type="Binary"/>
        <Parameter name="pIsCompressionUsed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="041bcef6-63b5-450a-8952-333c59f5ed21">
        <updating/>
        <source>xHandler(pTheException:Exception):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2002 by cnwdad1
//
// Purpose:		If the exception is for an aborted method on another node, then
//				ignore the exception, the server execution method will have handled
//				it.  Otherwise, save the error code and message and abort action.
//
// Parameters:	pTheException - The exception object.
//
// Returns:		The exception return code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pTheException.errorCode = 1242 then
		// Do nothing, the server exception handler will already have updated the error code and message.
		return Ex_Resume_Next;
	else
		self.errorCode		:=	pTheException.errorCode;
		
		if FileException.hasInstance(pTheException) then
			self.errorMessage	:=	process.getErrorText(pTheException.errorCode) &amp;
									CrLf &amp; "(" &amp; pTheException.FileException.file().fileName &amp; ")";
		else
			self.errorMessage	:=	process.getErrorText(pTheException.errorCode);
		endif;
		
		return Ex_Resume_Next;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerServer" id="d716af43-ce1e-4dc8-859b-74ce2a36df02">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>xHandlerServer(pExceptionObj:Exception):Integer updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		16 September 2002 by cnwdad1
//
// Purpose:		Save the error code and message and abort action.
//
// Parameters:	pExceptionObj - The exception object.
//
// Returns:		The exception return code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.errorCode		:=	pExceptionObj.errorCode;
	
	if FileException.hasInstance(pExceptionObj) then
		self.errorMessage	:=	process.getErrorText(pExceptionObj.errorCode) &amp;
								CrLf &amp; "(" &amp; pExceptionObj.FileException.file().fileName &amp; ")";
	else
		self.errorMessage	:=	process.getErrorText(pExceptionObj.errorCode);
	endif;
	
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
