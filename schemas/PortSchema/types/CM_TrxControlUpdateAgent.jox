    <JadeMethod name="trxAddVVRWeighing" id="530f7fdc-8b4c-49d1-9cfb-f94df2427c2b">
        <updating/>
        <source>trxAddVVRWeighing(	_vvr : CM_VehicleVisitRecord input;
					_pxyWeighing : CM_VehicleVisitWeighing;
					_rtsContToUpd : CM_Container input;
					_certifiedBy : String;
					_authPerson : String;
					_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars
	pxyVVR	: CM_VehicleVisitRecord;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	beginTransaction;
	
	app.myUtilityUA.utlAddVVRWeighing(_vvr, _pxyWeighing, _passport);
	
	//11 May 2020	NDL	TFS 49296	- SNO want to bypass validation for updating weight
	// on RTS containers via a 'qualified' weigh bridge.
	if _rtsContToUpd &lt;&gt; null then
		app.myUtilityUA.utlUpdateRTSWeight( _pxyWeighing.myWeighBridge,
											_rtsContToUpd,
											_pxyWeighing.weightCargo,
											_certifiedBy,
											_authPerson,
											_passport );
	endif;

epilog
	delete pxyVVR;
	self.finaliseActivityWithPassportEW(_passport, true);
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
