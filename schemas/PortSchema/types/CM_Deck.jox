    <JadeMethod name="buildLocationCode" id="1a6c9ad1-84f7-4095-8e37-05d2b66fcc7a">
        <source>buildLocationCode(roroDeckLabelPrefix, roroSubDeckLabelPrefix, roroRotatedLabel, roroOOTLSuffix: String; roroLocationCodeIsZeroFilled, rotated, ootl : Boolean; roroLocationNumberLength, locnOrd : Integer) : String;
/*
Purpose:			
Date		Who		Reason
21 July 2011	cnwab1	Initial creation
*/

vars
	newCode : String;
	idx : Integer;
begin


	newCode := roroDeckLabelPrefix;  // initialise
	newCode := newCode &amp; self.code;
	if self.isSubDeck() then
		newCode := newCode &amp; roroSubDeckLabelPrefix;
	endif;
	if roroLocationCodeIsZeroFilled then
		newCode := newCode &amp; locnOrd.padLeadingWith("0",roroLocationNumberLength) ;
	else
		newCode := newCode &amp; locnOrd.String;
	endif;
// PAR 28990	if rotated then
//		newCode := newCode &amp; roroRotatedLabel;
//	endif;

	if ootl then
		newCode := newCode &amp; roroOOTLSuffix;
	endif;
		
	return newCode;
epilog

end;</source>
        <Parameter name="roroDeckLabelPrefix" type="String"/>
        <Parameter name="roroSubDeckLabelPrefix" type="String"/>
        <Parameter name="roroRotatedLabel" type="String"/>
        <Parameter name="roroOOTLSuffix" type="String"/>
        <Parameter name="roroLocationCodeIsZeroFilled" type="Boolean"/>
        <Parameter name="rotated" type="Boolean"/>
        <Parameter name="ootl" type="Boolean"/>
        <Parameter name="roroLocationNumberLength" type="Integer"/>
        <Parameter name="locnOrd" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
