    <JadeMethod name="getQueueTasks" id="e7bddf7a-7f25-4c23-a115-f05dfc59b319">
        <source>getQueueTasks(arbiter: CM_RTQueueArbiter input);
//Returns the tasks required to do a unit of work. (move a TI)
//Called from the RTQueueArbiter.
vars
	isSource : Boolean;
	height	: Integer;
	task	: CM_RTQueueTask;
	array : CM_TIArray; 
begin
	//Determine if the ti in the arbiter transient is here.
	/* WAS isSource := trackedItems.includes(arbiter.ti);
	NOW */
	create array transient;
	self.getTIs(array, REAL_MODE);
	isSource := array.includes(arbiter.ti);
	if isSource then
		//This lc is the source of all evil.
		//------------
		//Get the TI to provide its "pickup tasks"
		//------------
		self.getPickupTasks(arbiter);
		//------------
		//Get the TI to provide its "move tasks"
		//------------
		//lf.getMoveTasks(arbiter);	Deimplimented, no longer required.
	else
		//Target.
		//------------
		//Get the target to provide its "set-down tasks"
		//------------
		self.getSetdownTasks(arbiter);
	endif;
epilog

	delete array;
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRailAllocation" id="10295064-23a8-49e9-ae40-47aa2431cb0e">
        <source>getRailAllocation() : CM_RailAllocation;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagonController			: CM_WagonController;
begin
	//wagonController := self.allLocationsControllers.first;
	wagonController := self.allLocationsControllersArray.first;	//04 Dec 2014	NDL	Par 35345
	
	if wagonController = null then
		return null;
	endif;
	
	return wagonController.myRailAllocation;
end;


</source>
        <ReturnType type="CM_RailAllocation"/>
    </JadeMethod>
    <JadeMethod name="getRailAreaDesc" id="0919af2d-1a7c-4687-9e64-62cbefaf2d61">
        <source>getRailAreaDesc() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2018	jlgns1	Initial creation
9/01/2018 JLGNS1 Bug 36407: Wagon Enquiry Issues
*/

vars
	rail : CM_Rail;
begin
	
	if self.myRailLine &lt;&gt; null then
		rail := self.myRailLine.myRailArea;
		if rail &lt;&gt; null then
			return rail.getDisplayDetails(true);
		endif;
	endif;
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRailJSInOutRake" id="929bf5aa-4260-4de9-91c4-7c7670b0bd17">
        <source>getRailJSInOutRake( _in : Boolean ):CM_RailJSInOutRake;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2017	cnwndl1	Initial creation	TFS 3514

*/

vars

	rail : CM_Rail;
	obj : Object;
	railIORake : CM_RailJSInOutRake;

begin
	
	if self.myRailLine &lt;&gt; null then
		rail := self.myRailLine.myRailArea;
		if rail &lt;&gt; null then
			foreach obj in rail.allRailJSInOut discreteLock do
				railIORake := obj.CM_RailJSInOutRake;
				if _in and railIORake.getIoType() = Rail_JSIO_Type_In then
					return railIORake;
				elseif not _in and railIORake.getIoType() = Rail_JSIO_Type_Out then
					return railIORake;
				endif;
			endforeach;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_in" type="Boolean"/>
        <ReturnType type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="getReceiptTimeStamp" id="43c32e7b-cb79-49c6-ac39-c5baf23e7be7">
        <source>getReceiptTimeStamp():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2013	cnwndl1	Initial creation	Par 31278
16 Sep 2016	cnwns1	TFS 488 - Multi Timezone Support
26 Jun 2023 navma1	Defect 58877: MTN - Getting 1090 exception when opening Work Order Operations in AMAST
18 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
*/

vars

	trans : CM_EventTransaction;
	now : TimeStamp;

begin
	now   := app.actualTimeServer();	
	trans := self.allTransactions.getAtKeyGeq( EVT_WagonConfirmed, null );
	
	if trans &lt;&gt; null and trans.type = EVT_WagonConfirmed then				//26.06.2023 navma1 #58877
		//return trans.creationTime();										//18.06.2024 navhl20 #64602
		return trans.dateTime;												//18.06.2024 navhl20 #64602
	endif;
		
	return now;
	
epilog
	
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getReceiveJob" id="6e133348-fe82-4d5c-af5b-763e2307aa29">
        <source>getReceiveJob() : CM_RailJob;
//--------------------------------------------------------------
//Created: 11 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	job		: CM_Job;
	railJob	: CM_RailJob;
begin

	foreach job in self.allRailJobs do
		if job.isRelease then
			continue;
		else
			railJob := job.CM_RailJob;
			break;
		endif;
	endforeach;
	
	return railJob;
	
end;</source>
        <ReturnType type="CM_RailJob"/>
    </JadeMethod>
    <JadeMethod name="getReleaseCargoSubType" id="824f8e99-464b-4833-b8a9-b3ed8a7e7fa5">
        <source>getReleaseCargoSubType() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2023	navmk20	Bug 57779: EUP -FR 53740 | Wagon Track Planning - Release Info

*/

vars
	cont 					: CM_WagonController;
	wle 					: CM_WorkListEntry;
	myRequest				: CM_Request;
	myReserveDetail			: CM_ReserveDetail;
	myProduct				: CM_Product;
	data 					: String;
	myProductDescription	: String;
	
begin
	foreach cont in self.allLocationsControllers do 
		foreach wle in cont.CM_WagonController.allRailWLELoad do
			myRequest := wle.myRequest;
			if myRequest &lt;&gt; null then
				myReserveDetail :=  myRequest.myReserveDetail;
				if myReserveDetail &lt;&gt; null then
					myProduct := myReserveDetail.getMyProduct();
					if myProduct &lt;&gt; null and myProduct.description &lt;&gt; null then
						myProductDescription := myProduct.description;
						/*
						if data.pos(myProductDescription,1) = 0 then
							if data = null then
								data := myProductDescription;
							else
								data := data &amp; ", " &amp; myProductDescription;
							endif;
						endif; 
						*/
						
						data.addStringToList(myProductDescription, ", ");//04/04/2025	navkc1 JIRA Story MTN-33940
					endif;
				endif; 
			endif; 
		endforeach;
	endforeach;
	return data;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
