    <JadeMethod name="getMinimumChargeInvLineType" id="96796983-70da-40f0-adc0-a8c18d9e1248">
        <source>getMinimumChargeInvLineType():CM_InvoiceLineDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38914

*/

vars

	lineType : CM_InvoiceLineDesc;
	edition : Integer;
	invalid : Boolean;

begin

	lineType := self.myMinimumChargeInvoiceLineType;
	if lineType = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, lineType, invalid );
	edition := lineType.edition;
	if invalid then
		return null;
	endif;
	
	return lineType;

epilog

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
