    <JadeMethod name="lostFocus" id="588b8d9b-93a0-451e-9985-dc9253791abe">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2025	navhl20	Bug MTN-36437: SAL - Dropdown not working properly in Harbor Function &gt;&gt; Movement Maintenance &gt;&gt; Add Resource

*/

vars
	dataTable 	: CM_DataTable;
	resource	: HMS_Resource;		
begin
	if self.filterIgnore then
		inheritMethod(combobox);
	else
		self.helpContextId := AllKeys; 
		
		if self.parent.isKindOf(CM_DataTable) then
			dataTable := self.parent.CM_DataTable;
			resource := combobox.listObject.HMS_Resource;
			if resource &lt;&gt; null and resource.description = combobox.text then
				dataTable.setCellText(dataTable.row, dataTable.getColumnByRowName(ETRow_MyResource), combobox.text);
			endif;
		endif;

		self.filterReshowAllItems();
	endif;
	
	if self.parent.isKindOf(CMUI_RowFrame) then
		self.parent.CMUI_RowFrame.handleComboLostFocus(combobox.CMUI_ComboBox);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setObject" id="5ae11047-5b2c-4612-adf4-0c48068a74f4">
        <updating/>
        <source>setObject(_value: HMS_Resource) updating;
// ---------------------------------------------------------------------------
// Created:     28 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if _value &lt;&gt; null then 
		if _value.HMS_Resource.myResourceType &lt;&gt; self.myResourceType then 
			// reset collection 
			self.myResourceType := _value.HMS_Resource.myResourceType;
			self.amInitialised := false; //cause reset
		endif;
	endif;

	inheritMethod(_value);

end;</source>
        <Parameter name="_value" type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="setObjectAndResourceType" id="f0085c2f-1b0c-4a19-9dd3-8a94bf7429fa">
        <updating/>
        <source>setObjectAndResourceType(_resource : HMS_Resource; _resourceType : HMS_ResourceType; _harbour : HMS_Harbour)updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	coll		: Collection;
	idx			: Integer;
	saveText	: String;
begin

	
	if _resourceType &lt;&gt; null then
		self.amInitialised := false;
		self.myResourceType := _resourceType;
		self.myHarbour := _harbour; // PAR  31709
		self.setObject(_resource);
	elseif _resource &lt;&gt; null then
		self.setObject(_resource);
	else	
		// resource and resource type is null
		self.amInitialised := false;
		self.myHarbour := _harbour;
		self.myResourceType  := null;
		self.setObject(null);
	endif;

end;</source>
        <Parameter name="_resource" type="HMS_Resource"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
