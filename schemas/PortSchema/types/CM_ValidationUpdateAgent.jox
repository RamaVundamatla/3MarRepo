    <JadeMethod name="valRegradeLog" id="371901fb-6afb-4e90-a92a-86c600a37815">
        <source>valRegradeLog(_realLog : CM_Log input; _location : CM_LocationsController; 
			_passport : CM_Passport input);

vars

	operator	: CM_Operator;
	species		: CM_LogSpecies;
	grade		: CM_LogGrade;
	location	: CM_LocationsController;
	auto		: CMIF_AutoMovePlan;
	restriction	: CM_LocationRestrictLog;
	updCntrl	: CMIF_TIUpdateController;
		

begin

	updCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	_realLog.validateTrackedItem(updCntrl, _passport);
	if _passport.noErrors() then
		if _location &lt;&gt; null then
			if _location &lt;&gt; _realLog.getPrimaryLocation(REAL_MODE) then
				_location.isTiValidForLocation(_realLog);
			endif;
		else
		//	app.raiseCMException1(REQUIRED_FIELD, 'Location', null, null);
			app.raiseCMException(Input_required_field_location, null, null); // cnwdb2	PAR 35364


		endif;
	endif;
epilog
	delete updCntrl;
end;</source>
        <Parameter name="_realLog" type="CM_Log" usage="input"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valReinstateReject" id="9f637903-6b1e-46b2-8d09-d68f9f9791ae">
        <source>valReinstateReject(_reason : String; _transactionType : Integer);


vars

begin

	if  _transactionType &lt;&gt; TRANS_TYPE_ReinstateReject then
		app.raiseCMException2(ERR_FIELD_TRANSACTION, _transactionType.String, 'Transaction type', 'transactionType', null);
	endif;
	
	if _reason = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'reason code', 'reasonCode', null);
	else
		if app.myRoot.allLogRejectCodes[_reason] = null then
			app.raiseCMException2(ERR_FIELD_REASON, _reason, 'reason code', 'reasonCode', null);
		endif;
	endif;

end;</source>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_transactionType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="valRejectTrackedItems" id="2edcb396-16ac-4a1f-ac9e-d1053cefa65d">
        <source>valRejectTrackedItems(_reason, _recovery : String; _transactionType : Integer; _term : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     23 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if  _transactionType = TRANS_TYPE_REJECT and _term = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _reason = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'reason code', 'reasonCode', null);
		app.raiseCMException(Input_required_field_reasonCde, 'reasonCode', null); // cnwdb2	PAR 35364
	else
		if app.myRoot.allLogRejectCodes[_reason] = null then
			app.raiseCMException2(ERR_FIELD_REASON, _reason, 'reason code', 'reasonCode', null);
		endif;
	endif;

	if _recovery = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'recovery code', 'recoveryCode', null);
		app.raiseCMException(Input_required_field_recvryFld, 'recoveryCode', null); // cnwdb2	PAR 35364
	else
		if (not app.myRoot.allLogRejectRecoveryCodes.includesKey(_recovery)) then
			app.raiseCMException2(ERR_FIELD_RECOVERY, _recovery, 'recovery code', 'recoveryCode', null);
		endif;
	endif;
	
	if _transactionType &lt;&gt; TRANS_TYPE_REJECT and _transactionType &lt;&gt; TRANS_TYPE_DISASSEMBLY then
		app.raiseCMException2(ERR_FIELD_TRANSACTION, _transactionType.String, 'Transaction type', 'transactionType', null);
	endif;

end;</source>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_recovery" type="String"/>
        <Parameter name="_transactionType" type="Integer"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
