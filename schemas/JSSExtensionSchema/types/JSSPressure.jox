    <JadeMethod name="convertBaseToTarget" id="3e11d9aa-ede9-4cd4-9f2f-e5d10c5c151c">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.ATMOSPHERES then
		convertedMeasure	:=	pMeasure / 101325;

	elseif pUnitTo = self.BARS then
		convertedMeasure	:=	pMeasure / 100000;
		
	elseif pUnitTo = self.CENTIMETRES_OF_MERCURY then
		convertedMeasure	:=	pMeasure / 1333.22;
		
	elseif pUnitTo = self.CENTIMETRES_OF_WATER then
		convertedMeasure	:=	pMeasure / 98.0665;
		
	elseif pUnitTo = self.FEET_OF_WATER then
		convertedMeasure	:=	pMeasure / 2989.06692;

	elseif pUnitTo = self.GIGAPASCALS then
		convertedMeasure	:=	pMeasure / 1000000000;
		
	elseif pUnitTo = self.HECTOPASCALS then
		convertedMeasure	:=	pMeasure / 100;
		
	elseif pUnitTo = self.INCHES_OF_MERCURY then
		convertedMeasure	:=	pMeasure / 3386.388;
		
	elseif pUnitTo = self.INCHES_OF_WATER then
		convertedMeasure	:=	pMeasure / 249.08891;
		
	elseif pUnitTo = self.KG_FORCE_PER_SQUARE_CENTIMETRE then
		convertedMeasure	:=	pMeasure / 98066.5;
		
	elseif pUnitTo = self.KG_FORCE_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure / 9.80665;
		
	elseif pUnitTo = self.KILONEWTON_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure / 1000;
		
	elseif pUnitTo = self.KILOPASCALS then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.KIPS_PER_SQUARE_INCH then
		convertedMeasure	:=	pMeasure / 6894760;
		
	elseif pUnitTo = self.MEGANEWTONS_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure / 1000000;

	elseif pUnitTo = self.MEGAPASCALS then
		convertedMeasure	:=	pMeasure / 1000000;
		
	elseif pUnitTo = self.METRES_OF_WATER_4 then
		convertedMeasure	:=	pMeasure / 9806.375413;

	elseif pUnitTo = self.METRES_OF_WATER_15 then
		convertedMeasure	:=	pMeasure / 9797.059096;
		
	elseif pUnitTo = self.MILLIBARS then
		convertedMeasure	:=	pMeasure / 100;
		
	elseif pUnitTo = self.MILLIMETRES_OF_MERCURY then
		convertedMeasure	:=	pMeasure / 133.3223684;
		
	elseif pUnitTo = self.MILLIMETRES_OF_WATER_4 then
		convertedMeasure	:=	pMeasure / 9.806375414;

	elseif pUnitTo = self.MILLIMETRES_OF_WATER_15 then
		convertedMeasure	:=	pMeasure / 9.797059096;
		
	elseif pUnitTo = self.NEWTONS_PER_SQUARE_CENTIMETRE then
		convertedMeasure	:=	pMeasure / 10000;
		
	elseif pUnitTo = self.NEWTONS_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure;
		
	elseif pUnitTo = self.NEWTONS_PER_SQUARE_MM then
		convertedMeasure	:=	pMeasure / 1000000;
		
	elseif pUnitTo = self.PASCALS then
		convertedMeasure	:=	pMeasure;
		
	elseif pUnitTo = self.POUNDALS_PER_SQUARE_FOOT then
		convertedMeasure	:=	pMeasure / 1.44816;
		
	elseif pUnitTo = self.POUNDS_FORCE_PER_SQUARE_FOOT then
		convertedMeasure	:=	pMeasure / 47.880;
		
	elseif pUnitTo = self.POUNDS_FORCE_PER_SQUARE_INCH then
		convertedMeasure	:=	pMeasure / 6894.757;
		
	elseif pUnitTo = self.TONNES_FORCE_PER_SQUARE_CM then
		convertedMeasure	:=	pMeasure / 98066500;
		
	elseif pUnitTo = self.TONNES_FORCE_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure / 9806.65;
		
	elseif pUnitTo = self.TONS_UK_FORCE_PER_SQUARE_FOOT then
		convertedMeasure	:=	pMeasure / 107252;
		
	elseif pUnitTo = self.TONS_UK_FORCE_PER_SQUARE_INCH then
		convertedMeasure	:=	pMeasure / 15444256;
		
	elseif pUnitTo = self.TONS_US_FORCE_PER_SQUARE_FOOT then
		convertedMeasure	:=	pMeasure / 95760;
		
	elseif pUnitTo = self.TONS_US_FORCE_PER_SQUARE_INCH then
		convertedMeasure	:=	pMeasure / 13789500;
		
	else
		JSSException.raise_(JSS_X_03004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of pressure to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="c8b358c6-2e92-4329-b913-34b74057a211">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.ATMOSPHERES then
		convertedMeasure	:=	self.measure * 101325;

	elseif pUnitFrom = self.BARS then
		convertedMeasure	:=	self.measure * 100000;
		
	elseif pUnitFrom = self.CENTIMETRES_OF_MERCURY then
		convertedMeasure	:=	self.measure * 1333.22;
		
	elseif pUnitFrom = self.CENTIMETRES_OF_WATER then
		convertedMeasure	:=	self.measure * 98.0665;
		
	elseif pUnitFrom = self.FEET_OF_WATER then
		convertedMeasure	:=	self.measure * 2989.06692;

	elseif pUnitFrom = self.GIGAPASCALS then
		convertedMeasure	:=	self.measure * 1000000000;
		
	elseif pUnitFrom = self.HECTOPASCALS then
		convertedMeasure	:=	self.measure * 100;
		
	elseif pUnitFrom = self.INCHES_OF_MERCURY then
		convertedMeasure	:=	self.measure * 3386.388;
		
	elseif pUnitFrom = self.INCHES_OF_WATER then
		convertedMeasure	:=	self.measure * 249.08891;
		
	elseif pUnitFrom = self.KG_FORCE_PER_SQUARE_CENTIMETRE then
		convertedMeasure	:=	self.measure * 98066.5;
		
	elseif pUnitFrom = self.KG_FORCE_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure * 9.80665;
		
	elseif pUnitFrom = self.KILONEWTON_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure * 1000;
		
	elseif pUnitFrom = self.KILOPASCALS then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.KIPS_PER_SQUARE_INCH then
		convertedMeasure	:=	self.measure * 6894760;
		
	elseif pUnitFrom = self.MEGANEWTONS_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure * 1000000;

	elseif pUnitFrom = self.MEGAPASCALS then
		convertedMeasure	:=	self.measure * 1000000;
		
	elseif pUnitFrom = self.METRES_OF_WATER_4 then
		convertedMeasure	:=	self.measure * 9806.375413;

	elseif pUnitFrom = self.METRES_OF_WATER_15 then
		convertedMeasure	:=	self.measure * 9797.059096;
		
	elseif pUnitFrom = self.MILLIBARS then
		convertedMeasure	:=	self.measure * 100;
		
	elseif pUnitFrom = self.MILLIMETRES_OF_MERCURY then
		convertedMeasure	:=	self.measure * 133.3223684;
		
	elseif pUnitFrom = self.MILLIMETRES_OF_WATER_4 then
		convertedMeasure	:=	self.measure * 9.806375414;

	elseif pUnitFrom = self.MILLIMETRES_OF_WATER_15 then
		convertedMeasure	:=	self.measure / 9.797059096;
		
	elseif pUnitFrom = self.NEWTONS_PER_SQUARE_CENTIMETRE then
		convertedMeasure	:=	self.measure * 10000;
		
	elseif pUnitFrom = self.NEWTONS_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure;
		
	elseif pUnitFrom = self.NEWTONS_PER_SQUARE_MM then
		convertedMeasure	:=	self.measure * 1000000;
		
	elseif pUnitFrom = self.PASCALS then
		convertedMeasure	:=	self.measure;
		
	elseif pUnitFrom = self.POUNDALS_PER_SQUARE_FOOT then
		convertedMeasure	:=	self.measure * 1.44816;
		
	elseif pUnitFrom = self.POUNDS_FORCE_PER_SQUARE_FOOT then
		convertedMeasure	:=	self.measure * 47.880;
		
	elseif pUnitFrom = self.POUNDS_FORCE_PER_SQUARE_INCH then
		convertedMeasure	:=	self.measure * 6894.757;
		
	elseif pUnitFrom = self.TONNES_FORCE_PER_SQUARE_CM then
		convertedMeasure	:=	self.measure * 98066500;
		
	elseif pUnitFrom = self.TONNES_FORCE_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure * 9806.65;
		
	elseif pUnitFrom = self.TONS_UK_FORCE_PER_SQUARE_FOOT then
		convertedMeasure	:=	self.measure * 107252;
		
	elseif pUnitFrom = self.TONS_UK_FORCE_PER_SQUARE_INCH then
		convertedMeasure	:=	self.measure * 15444256;
		
	elseif pUnitFrom = self.TONS_US_FORCE_PER_SQUARE_FOOT then
		convertedMeasure	:=	self.measure * 95760;
		
	elseif pUnitFrom = self.TONS_US_FORCE_PER_SQUARE_INCH then
		convertedMeasure	:=	self.measure * 13789500;
		
	else
		JSSException.raise_(JSS_X_03003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of pressure to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
