    <JadeMethod name="validateForCreate" id="e7cf20dd-d682-4da9-846a-1e4ec041b8cc">
        <source>validateForCreate();
/*

Purpose:			Validates the Invoice Type Debtor Separation for create. Debtor, AccrualType and one separation required
					Also validates there are no duplicate objects created for a debtor.

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
24 August 2022	navpw1	Initial creation TFS: 54565 (54384)
31 October 2022	navpw1	TFS: 55235 - Added validation for new collection added and for invoice type and debtor to make sure these are not null
*/

begin
	self.validateMe();
	
	if self.mySurchargesAndExemptions = null then //To make sure we exit if this reference is null
		return;
	endif;
	
	if self.mySurchargesAndExemptions.myInvoiceType = null then //This should never happen but just in case
		app.raiseCMException1(Must_be_related, app.getErrorString(Invoice_type), null, null);
		return;
	endif;
	
	if self.myDebtor = null then
		return;
	endif;
	
	//Check we are not adding any duplicate records for debtors. A debtor can only have one separation per invoice type
	//if self.mySurchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.myDebtor] &lt;&gt; null then					// ### TFS 55235 31Oct2022 NAVPW1
	if self.myDebtor.allInvTypeDebtorSeparations[self.mySurchargesAndExemptions.myInvoiceType.number] &lt;&gt; null then	// ### TFS 55235 31Oct2022 NAVPW1
		app.raiseCMException2(ObjectAlreadyInCollection, app.getErrorString(Debtor_GC), app.getErrorString(Surcharges_exemptions), null, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d3727384-54a5-4b74-9e4a-0c95559ba5c9">
        <source>validateForUpdate();
/*

Purpose:			Validates the Invoice Type Debtor Separation for update. Debtor, AccrualType and one separation required

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
25 August 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

begin
	self.validateMe();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="6218ea58-ec67-45bf-9958-fc8ac2dbb8f5">
        <source>validateMe();
/*

Purpose:			Validates the Creation, Updating and Deleting of a Debtor Separation fitting a certain criteria

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
14 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

begin
	if self.myDebtor = null then
		app.raiseCMException(Input_required_field_debtor, null, null);
	endif;
	
	if not self.getHasSeparations() then
		app.raiseCMException(Must_have_separation_def, null, null);
	endif;
	
	if self.mySurchargesAndExemptions = null then
		app.raiseCMException1(Must_be_related, app.getErrorString(Surcharges_exemptions), null, null);
		return;
	endif;
	
end;</source>
    </JadeMethod>
</Class>
