    <JadeMethod name="doLoadCmbDepot" id="bf1444ea-73fe-4dc8-b3a3-ae17763caba5">
        <updating/>
        <source>doLoadCmbDepot(_theComboBox : CMUI_ComboBox) updating, protected;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aTerminalArea : CM_TerminalArea;
	idx : Integer;
begin

	_theComboBox.clear();
	_theComboBox.addItem(null);
	
	foreach aTerminalArea in self.myTerminal.allTerminalAreas do
		if aTerminalArea.type =  TA_TYPE_COU_STORE_AREA 
		or aTerminalArea.type =  TA_TYPE_DEPOT_LCL 
		or aTerminalArea.type =  TA_TYPE_COU_CRIB_PACK_UNPACK then
			idx := _theComboBox.addItem(aTerminalArea.id);
			_theComboBox.itemObject[idx] := aTerminalArea;
		endif;
	endforeach;



end;</source>
        <access>protected</access>
        <Parameter name="_theComboBox" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doLoadCmbDestPort" id="2b91065f-3ffa-4119-b1d9-7457f42c03aa">
        <source>doLoadCmbDestPort() protected;
//+cnwml2 PAR24740

vars
	portDict		: CM_PortByCodeDict;
	port 			: CM_Port;
	idx 			: Integer;
	cmb				: CMUI_ComboBox;
	
	iter			: Iterator;
	voy				: CM_Voyage;
	tmpStr			: String;
	selectedPort	: CM_Port;
	foundMatch		: Boolean;
begin

	selectedPort := self.cmbDestPortRight.listObject.CM_Port;				
	self.cmbDestPortRight.clear();
	
	voy := self.cmbVoyageRight.listObject.CM_Voyage;
	if voy &lt;&gt; null then
		iter := voy.allPorts.createIterator;
	else	
		iter := app.myRoot.allActivePorts.createIterator;
	endif;
	
	while iter.next(port) do
	
		tmpStr := port.code &amp; Tab &amp; port.description;
		idx := self.cmbDestPortRight.addItem(tmpStr);
		self.cmbDestPortRight.itemObject[idx] := port;
		
		if selectedPort = port then  
			foundMatch := true;   
		endif;
		
	endwhile;
			
	if foundMatch then
		self.cmbDestPortRight.listObject := selectedPort;
	else
		self.cmbDestPortRight.listObject := null;
	endif;

epilog
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
