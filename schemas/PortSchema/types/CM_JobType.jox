    <JadeMethod name="setProxy" id="210a6cd8-8036-45f8-98b7-e385ce7da10f">
        <updating/>
        <source>setProxy(pName : String; pIsHatchType: Boolean; _timeToComplete : Integer; _colour : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);

	self.name := pName[1:30].trimBlanks;
	self.isHatchType := pIsHatchType;
	self.estimatedTimeToCompleteMins := _timeToComplete;
	self.colour := _colour;
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pIsHatchType" type="Boolean"/>
        <Parameter name="_timeToComplete" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="71a506cd-fcb0-4c94-9e23-110582481aba">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------

vars
	dynaDict : DynaDictionary;
	dupEntry : CM_JobType;

begin
	//epr par 18276 6/3/09 - checking case sensitive name
	create dynaDict transient;
	
	dynaDict.setMembership(CM_JobType);
	dynaDict.addMemberKey(CM_JobType::name.name,true,true);
	dynaDict.endKeys(true);
	
	app.myRoot.allJobTypes.copy(dynaDict);
	
	dupEntry:=dynaDict[self.name].CM_JobType;
	//if app.myRoot.allJobTypes[self.name] &lt;&gt; null then
	if  dupEntry &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, dupEntry.name, null, null);
	endif;

	self.validateMe;
	
epilog
	delete dynaDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="e532736c-af19-4d48-b47b-38603aa4addd">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 13042
//
// ---------------------------------------------------------------------------
vars
	aTerm : CM_Terminal;
	aMachine : CM_Machine;
	theMachines : CM_MachineSet;
	mess : String;
begin
	create theMachines transient;
	
	foreach aTerm in self.myRoot.allTerminals discreteLock do
		aTerm.getAllMachines(theMachines, true);
		
		foreach aMachine in theMachines do
			if aMachine.CM_Crane.allHatchJobTypes.includes(self) then
				if mess = null then
					mess := aTerm.code &amp; " " &amp; app.getErrorString(CM_Crane_GC) &amp; aMachine.code;
				else
					mess := mess &amp; ", " &amp; aTerm.code &amp;  " " &amp; app.getErrorString(CM_Crane_GC) &amp; aMachine.code; 
				endif;
			endif;
		endforeach;
	endforeach;

	if mess &lt;&gt; null then
		app.raiseCMException2(Job_Type_used, self.name, mess, null, null);
	endif;
epilog
	delete theMachines;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="49f3127c-3ee9-47c5-ace1-b88f4be0a0d4">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="255b587e-a47a-4bae-b5e7-4d1b8823cb7c">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if self.name.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'JobType Name', null, null);
		app.raiseCMException(Input_required_field_jobType, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
