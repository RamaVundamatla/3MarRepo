        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="86543099-49c1-4a81-897d-f37a4d559bd8">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------------------
//Created: 17 April 2003 By: cnwgd1
//--------------------------------------------------------------
// 03 jun 2009	concms1	par 19807 - hide sub-terminal row in extra table
// 17/02/2010	cnwmh5	PAR22235 - add test for voyage when setting discharge port
// 14/04/2010	cnwdap1	PAR #23519 - hide to do tasks row for Gdansk
// 11/08/2011	cnwdap1	PAR #27972 - Bulk release type no longer translatable, replaced with string constants
vars
	theMode	:	String;
	port : String;
	thePort : CM_Port;
	defCarrier : CM_Carrier;
	strCarrier : String;
begin
	
	inheritMethod();
	
	if self.mode = self.Mode_Add then
		self.lstStops.clearSelected();
		self.lstToDo.clearSelected();
	endif;
	
	
	self.tblExtra.hideRowByName(ETRow_EmailOptions, false);	//show in add mode, road only
	self.tblExtra.hideRowByName(ETRow_CustomsAgentCode, false); // PAR 11607
	self.btnResendCarrier.enabled := false;
	self.btnBookingRefDis.enabled := false;//26 Aug 2009	NDL	CCMS 1609 Par 20521
	
	self.tblExtra.showRowByName(ETRow_ExportReleaseNumber,false); //cnwrd1 20.11.08 CCMS JMT 1743/1764 

	//if self.viewTransportMode &lt;&gt; app.getErrorString(BR_TYPE_DESCR_SHIP) then // cnwrd1 par 18519 6.3.09	// PAR #27972
	if self.viewTransportMode &lt;&gt; BR_TYPE_SHIP_STR then // cnwrd1 par 18519 6.3.09							// PAR #27972
		tblMain.hideRowByName(ETRow_YardLocationTxt, false);
		tblExtra.hideRowByName(ETRow_LoadPort, false);
		tblMain.showRowByName(ETRow_ReceiptTransportMode, false);
		tblExtra.hideRowByName(ETRow_BillOfLading, false);
		tblMain.showRowByName(ETRow_StatusString, false);
	
	else
		tblMain.showRowByName(ETRow_YardLocationTxt, false);	
		tblExtra.showRowByName(ETRow_LoadPort, false);	
		tblMain.hideRowByName(ETRow_ReceiptTransportMode, false);
		tblExtra.showRowByName(ETRow_BillOfLading, false);
		tblMain.hideRowByName(ETRow_StatusString, false);
	
		port 	:= self.myTerminal.getConfig(PortDestCode).String;
		thePort := app.myRoot.allPorts[port];	

		if thePort &lt;&gt; null then
		//if thePort &lt;&gt; null or (thePort &lt;&gt; null and cmbVoyage.listObject &lt;&gt; null and self.txtBookingRef.text &lt;&gt; null) then				// 17/02/2010 cnwmh5 #22235
//			self.myAssistant.comboBoxDischarge(cmbDischarge, cmbVoyage.listObject.CM_Voyage, thePort);
			self.cmbDischarge.myAssistant := self.myAssistant;
			self.cmbDischarge.setObjectAndVoyage(thePort,cmbVoyage.listObject.CM_Voyage);
			//cmbDischarge.listObject := thePort;
		endif;	
		
		
		
		self.myAssistant.mainExtraSetValueByControl(tblMain, tblExtra, cmbDischarge.name, cmbDischarge.text);
		
		if self.myCurrentObject &lt;&gt; null then
			if self.myCurrentObject.CM_TrackedItem.isExport then
				tblExtra.showRowByName(ETRow_MyTranshipToPort, false);				
			else
				tblExtra.hideRowByName(ETRow_MyTranshipToPort, false);
			endif;
		endif;		
		
	endif;

	if self.mode = self.Mode_Add then
		//Set up the combo control in tblMain so that only road or rail can be selected as a transport mode.
		//The mode we start out in is the one that is selected from the transport mode combo box while in view mode.
		//if self.cmbTransportMode.text &lt;&gt; ViewRail then
		//if self.cmbTransportMode.text &lt;&gt; app.getErrorString(BR_TYPE_DESCR_RAIL) then	 // cnwrd1 par 18519 6.3.09	// PAR #27972
		if self.cmbTransportMode.text &lt;&gt; BR_TYPE_RAIL_STR then	 // cnwrd1 par 18519 6.3.09							// PAR #27972
			//theMode := app.getErrorString(BR_TYPE_DESCR_ROAD);													// PAR #27972
			theMode := BR_TYPE_ROAD_STR;																			// PAR #27972
			if self.mode = self.Mode_Add
			//and self.viewTransportMode &lt;&gt; app.getErrorString(BR_TYPE_DESCR_SHIP) then // cnwrd1 par 18519 6.3.09	// PAR #27972
			and self.viewTransportMode &lt;&gt; BR_TYPE_SHIP_STR then // cnwrd1 par 18519 6.3.09							// PAR #27972
				self.tblExtra.showRowByName(ETRow_EmailOptions, false);
				self.tblExtra.disableRowByName(ETRow_EmailOptions);
			endif;		 	
		else
			//theMode := ViewRail;
			//theMode := app.getErrorString(BR_TYPE_DESCR_RAIL); // cnwrd1 par 18519 6.3.09							// PAR #27972
			theMode := BR_TYPE_RAIL_STR; // cnwrd1 par 18519 6.3.09													// PAR #27972
			if self.mode = self.Mode_Add then 
				// if adding new rail pre-note then set to default // CCMS 1415
				// if null then will get set anyway to default on then save (CMIF_PreNote::actionForCreate)
				strCarrier := self.myTerminal.getConfig(DefRailCarrier).String;
				defCarrier	:= app.myRoot.allCarriers[strCarrier];
				self.cmbCarrierPN.setObject(defCarrier);
				self.tblExtra.setValueByName(ETRow_Carrier, strCarrier);
			endif;
		endif;
	elseif self.myCurrentObject &lt;&gt; null then
		theMode := self.myCurrentObject.CM_TrackedItem.getReceiptTransportModeStr();	// 22/07/2009 cnwar2 #20334 - for edit, transport mode should come from current object
	endif;
	
	self.cmbExtraTransMod.text := theMode;
	self.tblMain.setValueByName(ETRow_ReceiptTransportMode, theMode);
	self.setTiTypeFields;
	self.myAssistant.GTE_Assistant.showHideCEDOField(self.tblExtra,self.mode);// ### CCMS 1294 AKB2005JAN
	self.doCmbExtraTransModeClick();	//04 Nov 2009	NDL	Par 21519
	
	//th2CCMS 1452 - stops and todo tasks entry from prenote screen
	self.lstStops.userInputEnabled := true;
	self.lstStops.lostFocus(self.lstStops);
	self.lstToDo.userInputEnabled := true;
	self.lstToDo.lostFocus(self.lstToDo);
	// PAR #23519 for Gdansk, hide to do tasks
//	if app.myRoot.isClientGdansk then
	if not app.getMyUser.canDo(null,PmAdmToDoTaskShowPreNote) then	//22 Jul 2010	NDL	Par 24982
		self.tblExtra.hideRowByName(ETRow_ToDoTasks, false);
	endif;
	
	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.CM_TrackedItem.myBookingRef &lt;&gt; null then
			self.loadBookingRefItems(self.myCurrentObject.CM_TrackedItem.myBookingRef);
		endif;
		if self.myCurrentObject.CM_TrackedItem.myBookingRefItem &lt;&gt; null then
			self.cmbBRItem.setObject(self.myCurrentObject.CM_TrackedItem.myBookingRefItem);
		endif;
	endif;
	
	// 28/07/2008 cnwar2 #17617
	self.myAssistant.GTE_Assistant.mainExtraSplitterRatio(tblMain, tblExtra, sptThumbEdit);
	self.sptMain.cnEcResizeContents();	// 06/11/2008 cnwar2 #18443
	
	/*
		Date		Who		Reason
	20 Dec 2008   cnwdz2   Par18224 - show the field "Booking Reference Item" in the thumbnail only if the flag is checked.
	*/
	if not self.myTerminal.getConfig(AllowMultiBookingRef).Boolean then
		self.tblMain.hideRowByName(ETRow_MyBookingRefItem,false);
	endif;
	
	// par 19807 - hide sub-terminal row if these are not used
	if not app.isSubTerminalsOn (self.myTerminal) then
		self.tblExtra.hideRowByName(ETRow_MySubTerminal,false); 
	endif;
	self.doIMEXStatusChanged();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForNext" id="f5f3d335-b02f-4d73-a60f-e6edbf66d7fe">
        <updating/>
        <source>setControlsForNext() updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed on	By			Reason
// ----------	----------	--------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
vars
	assistant	: GTE_Assistant;
	addAttachRow,tmpRow,idx : Integer;		
begin

	assistant := self.myAssistant.GTE_Assistant;

	if self.myIntFacePreNote &lt;&gt; null then
		delete self.myIntFacePreNote;
	endif;
	
	if self.myEmailDefaults &lt;&gt; null then
		delete self.myEmailDefaults;
	endif;
	
	// create an intFaceObject here as this holds the attachment collection
	create self.myIntFacePreNote transient;

	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_BookingReference, txtBookingRef.text);
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_MyBookingRefItem, null);
	
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_IdTextBox, null);
	txtTrackedItemID.text := null;
	
	//th2 for PAR 14865 - type should clear out
	//th2 PAR 14943 - centerport etc. don't want to clear these
	if app.myRoot.client = Client_PortOtago then
		assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_WeightTotal, null);
	endif;

	tmpRow := tblExtra.getRow(ETRow_HasCOU);
	if (tblExtra.getValue(tmpRow).Boolean = true) then
		tmpRow := tblExtra.getRow(ETRow_CouId);
		tblExtra.setValue(tmpRow,null);
	endif;
	tmpRow := tblExtra.getRow(ETRow_HasAttachments);	
	if (tblExtra.getValue(tmpRow).Boolean = true) then
		tblExtra.setValue(tmpRow,false);
		addAttachRow := tblExtra.hideRowByName(ETRow_AddAttachment, true);	
		foreach idx in (addAttachRow + 1) to tblExtra.rows do
			if tblExtra.accessCell(idx, 1).text[1:6] = GTE_Assistant.ATTACH_RowName then
				//tblExtra.hideRow(idx)
				//tblExtra.setValue(idx,null);
				tblExtra.rows := tblExtra.rows - 1;
			endif;
		endforeach;				
		self.allAttachments.purge;
	endif;
	
	//reset hazards
	self.lstHazardList.loadHazardObjects;
	self.lstHazardList.setSelectedFromObject(null);
	tblExtra.setValueByName(ETRow_AllTIHazards, null);	
	
	if cmbExtraTransMod.text = TI_TRANSMODE_ROAD_STR then
		self.tblExtra.showRowByName(ETRow_EmailOptions, false);
		self.tblExtra.disableRowByName(ETRow_EmailOptions);				
	else
		self.tblExtra.hideRowByName(ETRow_EmailOptions, false);
	endif;

	tblMain.clearAllSelected;
	tblExtra.clearAllSelected;

	self.saveRowHeight := 0;
	//if self.viewTransportMode &lt;&gt; app.getErrorString(BR_TYPE_DESCR_SHIP) then // cnwrd1 par 18519 6.3.09	// PAR #27972
	if self.viewTransportMode &lt;&gt; BR_TYPE_SHIP_STR then // cnwrd1 par 18519 6.3.09							// PAR #27972
		tblMain.hideRowByName(ETRow_YardLocationTxt, false);
	else
		tblMain.showRowByName(ETRow_YardLocationTxt, false);	
	endif;

	self.tableIsPrefilled := true;
	
	tblMain.row := tblMain.getRowByName(ETRow_IdTextBox);
	
	tblMain.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="d71aa154-162f-4e45-a65d-cd156be9bf01">
        <updating/>
        <source>setControlsForView() updating;
//----------------------------------------------------------------
//	Created:	21 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	coll : ObjectSet;
	obj : Object;
	
begin
	inheritMethod();
	self.tableIsPrefilled := false;
	self.btnResendCarrier.enabled := true;
	if self.myEmailDefaults &lt;&gt; null then
		delete self.myEmailDefaults;
	endif;
	
	//26 Aug 2009	NDL	CCMS 1609 Par 20521 
	self.btnBookingRefDis.enabled := true;
	
epilog

	delete coll;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultsForAttachments" id="d841f794-d316-4526-a317-d70a9c090cd7">
        <updating/>
        <source>setDefaultsForAttachments(pChildren : CM_TISet) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	child			: CM_TrackedItem;
	intFaceAttach	: CMIF_InOutAttachment;
	tmpRow			: Integer;
	assistant		: GTE_Assistant;
	
begin

	assistant := self.myAssistant.GTE_Assistant;

	if pChildren.isEmpty then
		assistant.mainExtraSetValue(tblMain, tblExtra, 'hasAttachments', false);
		assistant.showHideAttachmentFields(tblExtra, false);
		assistant.clearAttachmentLines(tblExtra);
		return;
	endif;

	// need to add children
	// create intFaceInOutAttachment (with proxy)
	assistant.mainExtraSetValue(tblMain, tblExtra, 'hasAttachments', true);
	foreach child in pChildren do
		create intFaceAttach transient;
		//intFaceAttach.set(self.myTerminal, child.cargoType, child.id, child.getISOType, child.weight);			//-cnwml2 MSL CCMS 1017
		intFaceAttach.set(self.myTerminal, child.cargoType, child.id, child.getISOType, child.totalWeight);			//+cnwml2 MSL CCMS 1017
		intFaceAttach.setMasterItem(self.myIntFacePreNote);
		intFaceAttach.setMyProxyTrackedItem(child);
		self.allAttachments.add(intFaceAttach);
	endforeach;

	tmpRow := tblExtra.getRow('addAttachment');
	if tmpRow &gt; 0 then
		assistant.showAttachments(self.allAttachments, tblExtra, tmpRow);
	endif;
	assistant.showHideAttachmentFields(tblExtra, true);

end;</source>
        <Parameter name="pChildren" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsForCOU" id="629a46d9-17e8-432f-99eb-b5ef18d0fb78">
        <updating/>
        <source>setDefaultsForCOU(pCOU : CM_ClipOnUnit) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	intFaceCOU	: CMIF_InOutCOU;
	assistant	: GTE_Assistant;	
begin

	assistant := self.myAssistant.GTE_Assistant;
	
	if pCOU = null then
		assistant.mainExtraSetValue(tblMain, tblExtra, 'hasCOU', false);
		assistant.showHideCOUFields(tblExtra, false);
		return;
	endif;
		
/*
	create intFaceCOU transient;
	intFaceCOU.setMasterItem(self.myIntFacePreNote);
	intFaceCOU.setMyProxyTrackedItem(pCOU);
	//AA 20/3/01: Set this ref or we create another instance on save !
	self.myIntFaceCOU := intFaceCOU;
*/	
	// other intFaceCOU attributes will be set on save
	
	assistant.mainExtraSetValue(tblMain, tblExtra, 'hasCOU', true);
	assistant.mainExtraSetValue(tblMain, tblExtra, 'couId', pCOU.id);
	assistant.mainExtraSetValue(tblMain, tblExtra, 'couISOType', pCOU.isoType);
	assistant.mainExtraSetValue(tblMain, tblExtra, 'couTypeString', app.couTypeEnumToString(pCOU.couType));

	assistant.showHideCOUFields(tblExtra, true);

end;</source>
        <Parameter name="pCOU" type="CM_ClipOnUnit"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsForDimensions" id="4fa2ef12-3370-42cc-8959-6ae511f4f7e5">
        <updating/>
        <source>setDefaultsForDimensions(theTI : CM_TrackedItem) updating;
//
// 17/02/2010	cnwdap1	PAR #21624 Display dimensions as integer only
vars
	assistant : GTE_Assistant;
begin
	assistant := self.myAssistant.GTE_Assistant;

	assistant.mainExtraSetValue(tblMain, tblExtra, 'length', theTI.length.asStringMeasurementJMT);
	assistant.mainExtraSetValue(tblMain, tblExtra, 'height', theTI.height.asStringMeasurementJMT);
	assistant.mainExtraSetValue(tblMain, tblExtra, 'width', theTI.width.asStringMeasurementJMT);
	if theTI.isContainer then
		assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_OverLengthFront, theTI.CM_Container.overLengthFront.asStringMeasurementJMT);
		assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_OverLengthBack, theTI.CM_Container.overLengthRear.asStringMeasurementJMT);
		assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_OverWidthLeft, theTI.CM_Container.overWidthLeft.asStringMeasurementJMT);
		assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_OverWidthRight, theTI.CM_Container.overWidthRight.asStringMeasurementJMT);
		assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_OverHeight, theTI.CM_Container.overHeight.asStringMeasurementJMT);
	endif;
	assistant.mainExtraSetValue(tblMain, tblExtra, 'isOverDimensions', theTI.isOverDimensions);		

	assistant.showHideDimensionFields(tblExtra, theTI.isOverDimensions, theTI.myCargoType);
end;</source>
        <Parameter name="theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromObject" id="6aab9209-33ab-4c7f-b152-710d4ab0018f">
        <updating/>
        <source>setDefaultsFromObject( pObj : CM_Object ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/11/2009	cnwmh5		PAR 21492 - Change so loads Type combobox and
//							load the details for Height Text/Width Text and 
//							Length Text
// 14/04/2010	cnwdap1		PAR #23519 Hide To Do Tasks for Gdansk
// ---------------------------------------------------------------------------
vars
	assistant	 		: GTE_Assistant;
	theTI				: CM_TrackedItem;
	defTransportMode 	: Integer;
	defConsignee 		: CM_ConsigneeConsignor;
	defCarrier			: CM_Carrier;
	tmpStop				: CM_Stops;
	toDoTask			: CM_ToDoTask;
	trainDesc			: String;
	allStops			: CM_StopsByIdDict;
	
begin
	assistant := self.myAssistant.GTE_Assistant;
	
	if self.myIntFacePreNote &lt;&gt; null then
		delete self.myIntFacePreNote;
	endif;

	// create an intFaceObject here as this holds the attachment collection
	create self.myIntFacePreNote transient;

	inheritMethod(pObj);
	self.tblExtra.setValueByName(ETRow_EmailOptions, DblClickToUpdate);
	self.tblMain.setValueByName(ETRow_StatusString, self.cmbImexStatus.text);	// 27/03/2009 cnwar2 #19219

	if pObj = null then
		return;
	endif;
	
	self.tableIsPrefilled := true;
	
	
	if pObj.isKindOf(CM_TrackedItem) then
		theTI := pObj.CM_TrackedItem;
		defTransportMode:= theTI.receiptTransportMode;
		assistant.comboBoxTransportMode(tblMain, ETRow_ReceiptTransportMode, defTransportMode);	
		defConsignee	:= app.getCargoFieldObject(pObj, ETRow_ConsigneeCode).CM_ConsigneeConsignor;
		self.cmbConsignee.setType(CONSIGNEE);
		self.cmbConsignee.setObject(defConsignee);
		self.tblExtra.setValueByName(ETRow_ConsigneeCode, self.cmbConsignee.text);
		self.tblExtra.disableRowByName(ETRow_EmailOptions);
		
		defCarrier	:= app.getCargoFieldObject(pObj, ETRow_Carrier).CM_Carrier;
		self.cmbCarrierPN.setObject(defCarrier);
		
		self.lstStops.clearSelected();
//		foreach tmpStop in theTI.getAllStops() do		// cnwrl1 15/12/2009 PAR 21889 - what it was
		create allStops transient;
		theTI.getAllActiveStops( allStops );
		foreach tmpStop in allStops do
			self.lstStops.addSelectedObject(tmpStop.myStopsTable);
		endforeach;
		
		self.lstToDo.clearSelected();
		foreach toDoTask in theTI.allToDoTasksToDo do
			self.lstToDo.addSelectedObject(toDoTask.toDoTaskDesc);
		endforeach;
		// PAR #23519 hide To Do Tasks for Gdansk
		//if app.myRoot.isClientGdansk then
		if not app.getMyUser.canDo(null,PmAdmToDoTaskShowPreNote) then	//22 Jul 2010	NDL	Par 24982
			self.tblExtra.hideRowByName(ETRow_ToDoTasks, false);
		endif;
		
		self.tblExtra.setValueByName(ETRow_ExportReleaseNumber, theTI.getOperatorExpReleaseNo() );
		
		if theTI.mySubTerminal &lt;&gt; null then // 16/04/2009 cnwdz2 ccms1735
			self.cmbSubTerminal.text := theTI.mySubTerminal.code;
			self.tblExtra.setValueByName(ETRow_MySubTerminal, self.cmbSubTerminal.text);
		endif;
		
		trainDesc :=  theTI.getMyNotifiedTrainString;		// 17/02/2010 KPD
		self.tblExtra.setValueByName(ETRow_WagonTrain, trainDesc);	//04 Nov 2009	NDL	Par 21519
		
		// 19/11/2009 cnwmh5 PAR21492 - Start
		if theTI.isBulkOrBreakBulkGeneric and not theTI.isBulkCargo then
			//06/08/2010 cwndz2 25326
			self.tblExtra.setValueByName(ETRow_MyQuantity, theTI.CM_BreakBulkGeneric.quantity.asStringJMT());
			self.tblExtra.setValueByName(ETRow_MyHeightString, theTI.CM_BreakBulkGeneric.heightString);
			self.tblExtra.setValueByName(ETRow_MyWidthString, theTI.CM_BreakBulkGeneric.widthString);
			self.tblExtra.setValueByName(ETRow_MyLengthString, theTI.CM_BreakBulkGeneric.lengthString);
		endif;
		self.setSysSubTypeDetails(theTI);
		// 19/11/2009 cnwmh5 PAR21492 - End
	endif;
	
epilog
	delete allStops;
	
end;
</source>
        <access>protected</access>
        <Parameter name="pObj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="d8008d8f-4cea-4c93-b335-e44940b81487">
        <updating/>
        <source>setFilterDefaults() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2001		cnwrs2	Initial creation
23 May 2019 cnwma1	Bug 44836: JMT - Pre-note search does not work with out a created from date
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
25 May 2022 navak20 ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/
vars	
	tmpDate : Date;
begin
	inheritMethod();
	//app.getDatesThisMonth(tmpDate, self.filtEndDate);      //23.05.2019 cnwma1 Bug #44836

	if self.filtStartDate &lt;&gt; null then
		self.tblSearch.setValueByName(ETRow_FilterDateFrom, self.filtStartDate);
	endif;
	if self.filtEndDate &lt;&gt; null then
		self.tblSearch.setValueByName(ETRow_FilterDateTo, self.filtEndDate);
	endif;
	self.filtIMEXStatus := null;
	self.tblSearch.setValueByName(ETRow_FilterIMEXStatus, null);

	self.filtConsigneeCode   := null;
	self.filtConsignorCode   := null;
	self.filterStevedoreCode := null;  //02.10.2020 cnwma1 TFS #50112
	self.filtPIN := null;
	self.filtShippingLine := null; 		// 25.05.2022 navak20 TFS 53204
	self.filtCountryOfOrigin := null;   //16.08.2022 navtnr20 54441 

end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="9ae7f840-92b5-4a69-bb48-0fac415d958c">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/07/2008	cnwdad1		PAR #17532.
// 02 Oct 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
// 23 May 2022	navak20		ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 29 Jun 2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
// 17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
// ---------------------------------------------------------------------------
vars
	consignCode ,
	stevedoreCode 		 : String;  
	shippingLineCode	 : String; 	
	countryCode 		 : String; 
begin
	inheritMethod();

	self.filterId      := self.tblSearch.getValueByName(ETRow_FilterId).String[1:20];
	self.filtStartDate := self.tblSearch.getValueAsDate(ETRow_FilterDateFrom);
	self.filtEndDate   := self.tblSearch.getValueAsDate(ETRow_FilterDateTo);
	self.filtPIN 	   := self.tblSearch.getValueByName(ETRow_FilterPIN).String.trimBlanks;
	self.filtClientRef := self.tblSearch.getValueByName(ETRow_FilterClientRef).String;	//JIRA 20762
	if self.cmbFiltIMEX.listObject &lt;&gt; null then
		self.filtIMEXStatus := self.cmbFiltIMEX.listObject.CM_IMEXStatus.code;
	else
		self.filtIMEXStatus := null;
	endif;
	
	if self.cmbConsignee.listObject &lt;&gt; null and app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean   then	// TFS 53362
		self.filtConsigneeCode := self.cmbConsignee.listObject.CM_ConsigneeConsignor.code;							// TFS 53362
	else																											// TFS 53362
		consignCode := self.tblSearch.getValueByName(ETRow_FilterConsignee).String;
		if consignCode &lt;&gt; Any_String then
			self.filtConsigneeCode := consignCode;
		else
			self.filtConsigneeCode := null;
		endif;
	endif;																											// TFS 53362

	if self.cmbConsignor.listObject &lt;&gt; null and app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean  then	// TFS 53362
		self.filtConsignorCode := self.cmbConsignor.listObject.CM_ConsigneeConsignor.code;							// TFS 53362
	else																											// TFS 53362
		consignCode := self.tblSearch.getValueByName(ETRow_FiltConsignor).String;
		if consignCode &lt;&gt; Any_String then
			self.filtConsignorCode := consignCode;
		else
			self.filtConsignorCode := null;
		endif;
	endif;																											// TFS 53362
	
	if  self.cmbStevedore.listObject &lt;&gt; null and app.myRoot.getConfig(ComboByNameStevedore).Boolean  then			// TFS 53362
		self.filterStevedoreCode := self.cmbStevedore.listObject.CM_Stevedore.code;									// TFS 53362
	else																											// TFS 53362
		stevedoreCode := self.tblSearch.getValueByName(ETRow_Stevedore).String;  //02.10.2020 cnwma1 TFS #50112
		if stevedoreCode &lt;&gt; Any_String then
			self.filterStevedoreCode := stevedoreCode;
		else
			self.filterStevedoreCode := null;
		endif;
	endif;																											// TFS 53362
	
	//TFS 53204 start
	if self.cmbShippingLine.listObject &lt;&gt; null and self.myTerminal.getConfig(ComboByNameLine).Boolean   then		// TFS 53362
		self.filtShippingLine := self.cmbShippingLine.listObject.CM_ShippingLine.code;								// TFS 53362
	else																											// TFS 53362
		shippingLineCode := self.tblSearch.getValueByName(ETRow_ShippingLine).String;  //May 22, 2022 navak20 TFS 53204
		if shippingLineCode &lt;&gt; Any_String then
			self.filtShippingLine := shippingLineCode;
		else
			self.filtShippingLine := null;
		endif;
	endif;																											// TFS 53362
	//TFS 53204 end
	// Start	17.08.2022 navtnr20 54441
	countryCode := self.tblSearch.getValueByName(ETRow_CountryOfOrigin).String;  
	if countryCode &lt;&gt; Any_String then
		self.filtCountryOfOrigin := countryCode;
	else
		self.filtCountryOfOrigin := null;
	endif;
	//End 17.08.2022 navtnr20 54441
end;</source>
    </JadeMethod>
