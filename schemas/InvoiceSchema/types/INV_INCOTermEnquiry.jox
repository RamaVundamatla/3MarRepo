    <JadeMethod name="doNotableAdd" id="425afd40-1d2e-4034-86a6-d260e53d4149">
        <source>doNotableAdd(_shipTerm: CM_InvoiceContractShipTerm);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars
	invalid : Boolean;
	ed : Integer;
begin
	
	self.allNotableObjects.add(_shipTerm);
	beginNotification(_shipTerm, self.myTerminal.getTerminalEvent(Event_InvINCOTermUpdate), Response_Continuous, null);
	beginNotification(_shipTerm, EventFileAdd, Response_Continuous, null);
	beginNotification(_shipTerm, EventFileDelete, Response_Continuous, null);

epilog

end;</source>
        <Parameter name="_shipTerm" type="CM_InvoiceContractShipTerm"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="7a1c084e-d0b9-4a59-9c34-7932d2b18540">
        <source>doNotableClear();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars

	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvINCOTermUpdate));
		endNotification(anObject, EventFileAdd);
		endNotification(anObject, EventFileDelete);
	endforeach;
	
	self.allNotableObjects.clear;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissions" id="01e61ae8-7320-4467-af96-e13d54363a59">
        <source>doPermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnRemove.enabled := false;
		self.btnNew.enabled := false;
		self.btnUpdate.enabled := false;
		self.cmbBusinessUnit.enabled := false;
		self.tblINCOTerm.enabled := false;
		self.btnAudits.enabled := false;
	endif;
		
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="6f97a067-c422-46f1-985a-7086a9826ff6">
        <updating/>
        <source>doRemove(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars
	theReturn : Integer;
	iNCOTerm : CM_InvoiceINCOTerm;
begin
	iNCOTerm := _obj.CM_InvoiceINCOTerm;
	if iNCOTerm = null then
		app.msgBox("No record selected", "Warning",MsgBox_OK_Only);
		return;
	endif;
	if app.msgBox(app.getErrorString2(Sure_want_remov_from_invoi_inc, iNCOTerm.code,null), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	while true do
 	app.myTrxDA.trxDeleteInvINCOTerms(iNCOTerm, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
		else
			theReturn := app.showErrorWarningDialog("Invoice INCO Term", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doTblCFContMenu" id="3114003b-51c8-4b52-b22e-31c4c0e374f9">
        <updating/>
        <source>doTblCFContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblINCOTerm;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doViewAudits" id="d5607103-e17a-4c29-b19a-b4dca392778f">
        <updating/>
        <source>doViewAudits(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars

begin
	if _obj = null then
		return;
	endif;

	if self.myAssistant = null then
		create self.myAssistant as CMUI_Assistant transient;
		self.myAssistant.setMyTerminal(self.myTerminal);		
	endif;
	
	app.viewAuditForm(_obj.CM_InvoiceINCOTerm, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="initTblINCOTerm" id="cf8138ee-5ec8-48c4-be9f-9e6a3eded5bf">
        <source>initTblINCOTerm(_theEntDef :String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblINCOTerm;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_InvoiceINCOTerm);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblINCOTerm);	
		//self.setFieldAlignmentOnTable(theTable);
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
