    <JadeMethod name="getMySchedule" id="ab53d8ea-ae9f-42cf-960d-094c402104ac">
        <source>getMySchedule(): CM_WorkOrderSchedule;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2010	cnwrd1	Initial creation

*/

vars

begin
	return self.myWorkOrderSchedule;

epilog

end;</source>
