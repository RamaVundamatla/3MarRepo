    <JadeMethod name="isSameArrayContents" id="fb598860-bfff-4d01-a727-133b192c7e08">
        <source>isSameArrayContents(toArray : CM_ObjectArray) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			25 July 2001 by cnwdwq1
Purpose:			Returns TRUE if the passed in array is the same as this one.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
25 Mar 2024   	navma1			Bug 62928: EUP - Demo - Pack Load By Request Froze During Cargo Display for User Selection
---------------------------------------------------------------------------
*/
vars
	obj 	: Object;
	arrSize : Integer;
	
begin
	
	
	if toArray = null then
		return false;
	endif;
	
	arrSize := self.size;					//25.03.2024 navma1 #62928
	
	if arrSize &lt;&gt; toArray.size then
		return false;
	endif;
	
	if arrSize = 0 then						//25.03.2024 navma1 #62928
		return true;
	endif;
	
	foreach obj in self do
		if not toArray.includes(obj) then
			return false;
		endif;
	endforeach;
	return true;
end;</source>
        <Parameter name="toArray" type="CM_ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
