    <JadeMethod name="init" id="b7b98fbc-f4d8-4800-9d96-a319e787d05d">
        <updating/>
        <source>init(_mode : Integer; _proxyStopTable : CM_StopsTable; _currentTerminal : CM_Terminal; selectedTypes : CM_CargoBOLTypeArray) updating;		//cnwmc5 - 11 April 2014 - CCMS 2532
 //ccms1824 cnwrs1 may 2009
vars
	dict : CM_VoyageSet;
begin
	selectedTypes.copy(self.allSelectedCargoTypes);		//cnwmc5 - 11 April 2014 - CCMS 2532

	self.myCurrentTerminal 	:= _currentTerminal;
	//self.caption 			:= app.getString( StopTable_Setting_4_Terminal, self.myCurrentTerminal.code );BUG 39408
	self.myProxyStopTable 	:= _proxyStopTable;
	if self.myProxyStopTableTemplate = null then
		self.myProxyStopTableTemplate := myProxyStopTable.allStopTableTemplates[self.myCurrentTerminal, self.myProxyStopTable];
		if self.myProxyStopTableTemplate = null then
			create self.myProxyStopTableTemplate transient;
			self.myProxyStopTableTemplate.setKeys(self.myCurrentTerminal, self.myProxyStopTable);
		endif;
	endif;
	
	self.frmToolbarBtns.visible := true;
	
	self.mulHoldVoyages.formDisplayEntryMethodName := SOP_StopTableTerminalForm::displayEntryVoyage.name;

	self.mulHoldVoyages.availableHeading := app.getString( Voyages_available );
	self.mulHoldVoyages.selectedHeading  := app.getString( Hold_Voyages_selected );
	create dict transient;
	self.myCurrentTerminal.allVoyagesByCode.copy(dict);
	self.mulHoldVoyages.setAvailable(dict, true);
	self.displayStopTableTemplate();
	
	if _mode = self.Mode_View then	// concms1 par 19830 jun 2009
		self.setControlsForView;	// concms1 par 19830 jun 2009
	endif;							// concms1 par 19830 jun 2009
	
epilog
	delete dict;
end;
</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_proxyStopTable" type="CM_StopsTable"/>
        <Parameter name="_currentTerminal" type="CM_Terminal"/>
        <Parameter name="selectedTypes" type="CM_CargoBOLTypeArray"/>
    </JadeMethod>
