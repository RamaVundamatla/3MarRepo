        <updating/>
        <source>doMnuHideClick(_menuItem :MenuItem input) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
10 February 2010	cnwrd1	Initial creation
*/
vars

begin
	if self.mnuShowHideMacro.caption = self.MNU_MACRO_HIDE then
