    <JadeMethod name="doSave" id="2f20a701-911a-46a9-bf65-83a8c694e77a">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	errObj: CM_Error;
	timeToComplete : Real;
	idx: Integer;
	tmpListBox: ListBox;
	ignoreWarnings,rtnValue: Boolean;
	proxyJobType: CM_JobType;
	lName: String;
	lIsHatchType: Boolean;
	theForm : SOP_TableMaintForm;
	lColour : Integer;
	

begin
  	theForm := self.myForm; 
	lName := theForm.tblInput1.getValueByName(ETRow_Name).String;
	lIsHatchType := theForm.tblInput1.getValueByName(ETRow_IsHatchType).Boolean;
	//timeToComplete := theForm.tblInput1.getValueByName(ETRow_TimeToComplete).Integer;
	timeToComplete := theForm.tblInput1.getValueByName(ETRow_TimeToComplete).Real;
	lColour:=theForm.tblInput1.getValueByName(ETRow_Colour).Integer;

	if timeToComplete &gt; Max_Integer then				// 10/10/2011 cnwmh5 #28411
		app.raiseCMException1(Invalid_Number_Mins_Allowed, 'Estimated Time to Complete (Mins)',  null, null);		
		return false;
	endif;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_JobType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyJobType := theForm.myProxyObject.CM_JobType;
	proxyJobType.setProxy(lName, lIsHatchType, timeToComplete.Integer ,lColour);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateJobType(proxyJobType, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateJobType(proxyJobType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
