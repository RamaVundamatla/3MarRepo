    <JadeMethod name="createDefaultBayProxy" id="a8a89444-ebc4-4e5b-a665-09b656f24676">
        <updating/>
        <source>createDefaultBayProxy() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/

vars
	testBay : CM_BayDefn;
	pxyHold : CM_VesselHold;
	newBayDefn: SelfType;
	slotDefnVessel, newSlotDefn, pxySlotDefn: CM_SlotDefnVessel;
	slotDefn: CM_SlotDefn;
	cellDefn, newCellDefn: CM_CellDefn;
	tierDefn, newTierDefn: CM_TierDefn;
	holdIndex : Integer;
	aPxyHold : CM_Hold;
	aLid,pLid : CM_HatchLid;
begin
	//this is just for testing 
	testBay:="2157.944".asOid.CM_BayDefn;
	
	self.myProxyBayDefn := testBay.cloneSelf(true);

	pxyHold:=testBay.myHold.CM_VesselHold.cloneSelf(true);
	pxyHold.setProxy(null,testBay.myHold.ordinalHold);
	self.myProxyBayDefn.setMyHold(pxyHold);

	
	
	foreach cellDefn in testBay.allCellsOnDeckByOrdinal do
		newCellDefn := cellDefn.cloneSelf(true);
		newCellDefn.setMyBay(self.myProxyBayDefn,true);
	endforeach;
	foreach cellDefn in testBay.allCellsUnderDeckByOrdinal do
		newCellDefn := cellDefn.cloneSelf(true);
		newCellDefn.setMyBay(self.myProxyBayDefn,false);
	endforeach;
	foreach tierDefn in testBay.allTiersOnDeck do
		newTierDefn := tierDefn.cloneSelf(true);
		newTierDefn.setMyBay(self.myProxyBayDefn,true);
	endforeach;
	foreach tierDefn in testBay.allTiersUnderDeck do
		newTierDefn := tierDefn.cloneSelf(true);
		newTierDefn.setMyBay(self.myProxyBayDefn,false);
	endforeach;
	
	foreach slotDefn in testBay.allSlotsByOrdinal do
		slotDefnVessel := slotDefn.CM_SlotDefnVessel;
		newSlotDefn := slotDefnVessel.cloneSelf(true);

		newSlotDefn.setMyBay(self.myProxyBayDefn,slotDefn.ordinalDeck = DeckOnDeck);
		newSlotDefn.setFortyFrontBack(slotDefnVessel.fortyFront,slotDefnVessel.fortyBack); // PAR 9716. We are cloning so make exactly the same, (setForCraete tries to work it out)

		if slotDefn.ordinalDeck = DeckOnDeck then // PAR 7843 added
			tierDefn := self.myProxyBayDefn.allTiersOnDeck[slotDefn.ordinalTier];
			cellDefn := self.myProxyBayDefn.allCellsOnDeckByOrdinal[slotDefn.ordinalCell];
		else
			tierDefn := self.myProxyBayDefn.allTiersUnderDeck[slotDefn.ordinalTier]; // PAR 7843 added
			cellDefn := self.myProxyBayDefn.allCellsUnderDeckByOrdinal[slotDefn.ordinalCell]; // PAR 7843 added
		endif;
		newSlotDefn.setCellAndTierDefn(cellDefn,tierDefn);
		
		if slotDefnVessel.ordinalDeck = DeckOnDeck then
			newSlotDefn.setMyBay(self.myProxyBayDefn,true);
		else
			newSlotDefn.setMyBay(self.myProxyBayDefn,false);
		endif;
		
	endforeach;

	self.myProxyBayDefn.updateSlotLinks;
	
	// ############################
	// HATCH LIDS
	foreach aLid in testBay.allHatchLids do
		// hatch lids cover many bays and so may already have been proxied	
		pLid := aLid.cloneSelf(true);
		pLid.allBays.add(self.myProxyBayDefn);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="f8b63145-cdc2-4ab2-a018-6585d08f2c08">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myProxyBayDefn &lt;&gt; null then
		//for testing
		if self.myProxyBayDefn.myHold.isTransient then
			delete  self.myProxyBayDefn.myHold;
		endif;
		self.myProxyBayDefn.allHatchLids.purge;
		delete self.myProxyBayDefn;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBayOrderLostFocus" id="7a4f5cd8-2892-443b-aa34-94d7809f5cf5">
        <source>doBayOrderLostFocus();
// ---------------------------------------------------------------------------
// Created:     18 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 17912
// ---------------------------------------------------------------------------

vars
	hyphen, comma : Integer;
	allBays, bays, tmp : String;
	holdOrd, bayID, bayID1, bayID2 : Integer;
begin
	bays := self.txtBayOrder.text;
	tmp := bays;
	
	tmp.replaceChar("-", " ");
	if not self.validateBayLabelsWizard(tmp, true) then
		app.msgBox("Physical Bay Order can only have numbered bay IDs with space and comma separators", "Physical Bay Order Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon); // PAR 18147
		self.txtBayOrder.setFocus();
		return;
	endif;
	
	hyphen := bays.pos("-", 1);
	comma := bays.pos(CM_CellularVesselStructure.HoldSeperator, 1);

	if hyphen &gt; 0 and comma &lt;= 0 then
		bayID1 := bays[1:hyphen-1].Integer;
		bayID2 := bays[hyphen+1:end].Integer;
		
		foreach bayID in bayID1 to bayID2 do
			if bayID mod(2) &lt;&gt; 0 then
				holdOrd := holdOrd + 1;
				if allBays = null then
					allBays := allBays &amp; bayID.padLeadingWith("0",2);
				else
					if holdOrd mod(2) &lt;&gt; 0 then
						allBays := allBays &amp; CM_CellularVesselStructure.HoldSeperator &amp; bayID.padLeadingWith("0",2);
					else
						allBays := allBays &amp; CM_CellularVesselStructure.BaySeperator &amp; bayID.padLeadingWith("0",2);
					endif;
				endif;
			endif;
		endforeach;
		bays := allBays;
	endif;

	self.txtBayOrder.text := bays;


end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnPenRight" id="ebe13300-3455-4693-ad4f-8c6be6cb4a81">
        <updating/>
        <source>doBtnPenRight() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bayFrame : CMUI_GridAreaFrame;

begin
	bayFrame := self.frmGridArea.getControl(ONDECK);
