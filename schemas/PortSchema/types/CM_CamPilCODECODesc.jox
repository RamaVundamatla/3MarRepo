    <JadeMethod name="imExStatusToString" id="31634b97-e708-4e72-97ae-5f0a3f731829">
        <source>imExStatusToString(_ti:CM_TrackedItem):String;
//
// 9 May 2017	cnwrs1	TFS 3671 POL PIL new work
//
vars
	imexString:String;
begin
	if _ti.isExport then
		imexString := "2";
	elseif _ti.isImport then
		imexString := "3";
	elseif _ti.isTranshipItem then
		imexString := "6";  
	else
		imexString := "";
	endif;
	return imexString;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeBGMSegment" id="77262126-7452-4091-abc6-cc1bdac2e2a0">
        <source>makeBGMSegment(_protocol: CM_CamProtocol; _typeCode: String; _number: Integer; _function: Integer; _response: String): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2014	cnwmc5	Initial creation

*/

constants
	MESSAGE	= "BGM";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_typeCode;
	
	if _response &lt;&gt; null then
		msg := msg &amp; plus &amp; _response;
	endif;
	
	msg := msg &amp; plus &amp; _function.String;

	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_typeCode" type="String"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_function" type="Integer"/>
        <Parameter name="_response" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeDAMSegment" id="c5f4a041-52d6-4b1f-8ae1-4f3b1abd66da">
        <source>makeDAMSegment(_protocol: CM_CamProtocol; _group: HugeStringArray input; _qual: String; _type: String; _typeQual: String; _typeAgency: String; _typeDesc: String): String protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
16 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "DAM";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; _qual &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_qual" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_typeQual" type="String"/>
        <Parameter name="_typeAgency" type="String"/>
        <Parameter name="_typeDesc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeDTMSegment" id="c9f641bf-a58c-4d14-b809-bb1b1d098b62">
        <source>makeDTMSegment(_protocol: CM_CamProtocol; _group: HugeStringArray input; _type: String; _datetime: TimeStamp; _qual: String): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
05 July 2022		jlizm1	Initial creation TFS 53754 LNX Different local and server time zones causing incorrect edi outputs

*/

constants
	MESSAGE	= "DTM";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
	dateTimeStr : String;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	dateTimeStr := _datetime.localToUTCTime.date.longYearEDI() &amp; _datetime.localToUTCTime.time.formatAsHHMMSS();
	
	msg := MESSAGE &amp; plus &amp; _type &amp; colon &amp; dateTimeStr &amp; colon &amp; _qual;
			
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then 
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_datetime" type="TimeStamp"/>
        <Parameter name="_qual" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageDimensionsData" id="184a6ace-048e-4eb2-96f6-b346a1fb998b">
        <source>makeMessageDimensionsData(_protocol: CM_CamProtocol; _group: HugeStringArray input; _ti: CM_TrackedItem) protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
16 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	if _ti.CM_Container.overLengthFront &lt;&gt; 0 then
		_group.add("DIM" &amp; plus &amp; "5" &amp; plus &amp; "CMT" &amp; colon &amp; _ti.CM_Container.overLengthFront.asStringMeasurementJMT() &amp; colon &amp; "0" &amp; colon &amp; "0" &amp; singleQuote);
	endif;
	if _ti.CM_Container.overLengthRear &lt;&gt; 0 then
		_group.add("DIM" &amp; plus &amp; "6" &amp; plus &amp; "CMT" &amp; colon &amp; _ti.CM_Container.overLengthRear.asStringMeasurementJMT() &amp; colon &amp; "0" &amp; colon &amp; "0" &amp; singleQuote);
	endif;
	if _ti.CM_Container.overWidthRight &lt;&gt; 0 then
		_group.add("DIM" &amp; plus &amp; "7" &amp; plus &amp; "CMT" &amp; colon &amp; "0" &amp; colon &amp; _ti.CM_Container.overWidthRight.asStringMeasurementJMT() &amp; colon &amp; "0" &amp; singleQuote); 
	endif;
	if _ti.CM_Container.overWidthLeft &lt;&gt; 0 then
		_group.add("DIM" &amp; plus &amp; "8" &amp; plus &amp; "CMT" &amp; colon &amp; "0" &amp; colon &amp; _ti.CM_Container.overWidthLeft.asStringMeasurementJMT() &amp; colon &amp; "0" &amp; singleQuote);
	endif;
	if _ti.CM_Container.overHeight &lt;&gt; 0 then
		_group.add("DIM" &amp; plus &amp; "13" &amp; plus &amp; "CMT" &amp; colon &amp; "0" &amp; colon &amp; "0" &amp; colon &amp; _ti.CM_Container.overHeight.asStringMeasurementJMT() &amp; singleQuote);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageHeader" id="03551e5e-c091-426f-800c-4136e20ff8a6">
        <updating/>
        <source>makeMessageHeader(_camFile: CM_CamFile input; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _type: String; _fileType: String; _coll: HugeStringArray input) : String updating;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
15 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	protocol	: CM_CamProtocol;
	senderCode	: String;
	portCode, 
	fPortCode	: String;
	terminal	: CM_Terminal;
	strLine : String;
begin
	protocol 	:= _camTaskHistory.camProtocol;
	senderCode 	:= self.getSenderCode_UNB(protocol);
	terminal := _camTaskHistory.camProtocol.terminal;
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "95B", "UN", "ITG14", senderCode, _camTaskHistory.runDateTime), _coll); 	//cnwmc5 - 15 Oct 2014 - CCMS 2380
	
	// Need to pass in port UN Location code as _response...
	portCode := terminal.getConfig(PortDestCode).String;
	fPortCode := self.getXlatedForeignCode(protocol.operatorXlationCode, portCode, XLATION_TYPE_PORT_BYOP, terminal);
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeBGMSegment (protocol, _type, null, 9, fPortCode), _coll);
	
	_camFile.incrementMessageCount();
	return strLine;
epilog

end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC_GATEIN" id="86d59ef5-7326-4a7a-8d3c-d0d550aab724">
        <source>makeMessageLOC_GATEIN(_camProtocol: CM_CamProtocol; _group: HugeStringArray input; _activity: Integer; _ti: CM_TrackedItem; _contentsStatus: String) protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
28 November 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	code, pCode	:String;
begin	
	code 			:= _ti.loadPort.trimRight;
	pCode 			:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _camProtocol.terminal);
	
	if _ti.getImExStatus() = TI_IMEX_STATUS_EXPORT then
		self.makeLOCSegment (_camProtocol, _group, '76', pCode, '139', '6', null, null, null);
	elseif _ti.getImExStatus() = TI_IMEX_STATUS_IMPORT then
		self.makeLOCSegment (_camProtocol, _group, '164', pCode, '139', '6', null, null, null);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC_GATEOUT" id="1238ad46-fb75-4528-9e69-35ceddeba334">
        <source>makeMessageLOC_GATEOUT(_camProtocol: CM_CamProtocol; _group: HugeStringArray input; _activity: Integer; _ti: CM_TrackedItem; _contentsStatus: String) protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
28 November 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	code, pCode, fCode	:String;
	terminal			:CM_Terminal;
begin
	terminal	:= _camProtocol.terminal;
	
	//get the port code
	code 	:= _ti.loadPort;
	pCode 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
	
	if pCode = null then
		pCode := code;
	endif;
	
	pCode := pCode.trimRight;
	
	self.makeLOCSegment (_camProtocol, _group, '8', pCode, '139', '6', null, null, null);			
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_BN" id="6ec97cf9-c407-4a5e-9573-767a4cbe2ab7">
        <source>makeMessageRFF_BN(_camProtocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer;  _ti :CM_TrackedItem; _transaction :CM_TITransaction)protected;
//
//Purpose:	Refactored code	
//
//Date			Who		Reason
// 9 May 2017	cnwrs1	TFS 3671 POL PIL new work
//
vars
	ref	:String;
begin
	if _activity = CODECO_GATEIN  then
		if _camProtocol.isUseCarrierRefForBooking then
			ref := _ti.getCarrierReference;
		else
			ref := _ti.bookingReference.trimRight;						
			
			if ref = null then											
				ref := _ti.deliveryRelease.trimRight;					
			endif;														
		endif;
		
		if ref &lt;&gt; null then											
			if _ti.isEmpty then
				self.makeRFFSegment(_camProtocol, _group, "AEW", ref);
			else
				self.makeRFFSegment(_camProtocol, _group, "BN", ref);
			endif;
		endif;														
	endif;

	if _activity = CODECO_GATEOUT then
		if _camProtocol.isUseCarrierRefForBooking then
			ref := _ti.getCarrierReference;
		else
			ref := _ti.deliveryRelease.trimRight;						
			
			if ref = null then				
				ref := _ti.bookingReference.trimRight;					
			endif;														
		endif;
		
		if ref &lt;&gt; null then
			if _ti.isEmpty then
				self.makeRFFSegment(_camProtocol, _group, "AEW", ref);
			else
				self.makeRFFSegment(_camProtocol, _group, "BN", ref);
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageTDT1Segment" id="8d54e1b4-f694-4773-b917-9e1585e75e1f">
        <source>makeMessageTDT1Segment(_protocol: CM_CamProtocol; _group: HugeStringArray input; _activity: Integer; _transaction: CM_TITransaction; _ti: CM_TrackedItem) protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
17 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	refOther : String;
	ref	:String;
begin
	// RAIL
	if _transaction.isCamsRailReceiveType()	or _transaction.isCamsRailReleaseType() then
		ref := _ti.wagonNumber.trimRight;
		
		if _transaction.isCamsRailReceiveType then
			refOther := _ti.bookingReference.trimRight[1:17];
		else
			refOther := _ti.deliveryRelease.trimRight[1:17];
		endif;
		
		if ref &lt;&gt; null then
			self.makeTDT1Segment (_protocol, _group, refOther, '2', null, null, null, null, null, null, ref, null, null, null); 
		else
			ref := _ti.wagon.trimRight;
			
			if ref &lt;&gt; null then
				self.makeTDT1Segment (_protocol, _group, refOther, '2', null, null, null, null, null, null, ref, null, null, null); 
			endif;
		endif;
	endif;
	// ROAD RECEIVAL
	if _transaction.isCamsRoadReceiveType() then
		ref := _ti.vehicle;
		
		if ref &lt;&gt; null then
			self.makeTDT1Segment (_protocol, _group, _ti.bookingReference.trimRight[1:17], '3', null, _ti.carrier.trimRight[1:17], null, null, null, null, ref, null, null, null); 
		endif;
	endif;
	// ROAD RELEASE
	if _transaction.isCamsRoadReleaseType() then
		ref := _ti.releaseVehicle;
		
		if ref &lt;&gt; null then
			self.makeTDT1Segment (_protocol, _group, _ti.deliveryRelease.trimRight[1:17], '3', null, _ti.releaseCarrier.trimRight[1:17], null, null, null, null, ref, null, null, null); // par 27460 09/05/2011 cnwcs5
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageTDT20Segment" id="fb5f0271-c8c4-4be4-b28b-537c5d86a3d5">
        <updating/>
        <source>makeMessageTDT20Segment(_protocol: CM_CamProtocol; _camVoyage: CM_CamVoyage; _activity: Integer): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2014	cnwmc5	Initial creation
// 9 May 2017	cnwrs1	TFS 3671 POL PIL new work
*/

vars
	vCode, msg	:String;
	voyage		:CM_Voyage;
begin
	vCode 	:= _camVoyage.getSanitisedVoyageCode().trimBlanks;
	voyage	:= _camVoyage.voyageOid;
	
	if voyage &lt;&gt; null then
		if vCode &lt;&gt; null and
		   voyage.vesselName &lt;&gt; null then
			if _protocol.camGroup.useCallSign then
				// Only should ever go through here?
				msg := self.makeTDT20Segment (_protocol, vCode, '1', null, 'PCIU', '172', null, null, null, voyage.callSign.trimRight, '103', null, voyage.vesselName.trimRight.toUpper);
			else
				msg := self.makeTDT20Segment (_protocol, vCode, '1', null, 'PCIU', '172', null, null, null, null, '103', null, voyage.vesselName.trimRight.toUpper);
			endif;
		else
			msg := self.makeTDT20Segment (_protocol, vCode, '1', null, 'PCIU', '172', null, null, null, null, '103', null, null);
		endif;
	else
		msg := self.makeTDT20Segment (_protocol, null, '1', null, 'PCIU', '172', null, null, null, null, '103', null, null);	
	endif;

	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_activity" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="7b768d76-08de-47f4-971d-f6a5df3577b2">
        <source>makeMessages(	_trackedItem: CM_TrackedItem; 
				_transaction: CM_TITransaction; 
				_camProtocol: CM_CamProtocol; 
				_camMessage: CM_CamMessage input; 
				_xlVoyageId: String; 
				_terminal: CM_Terminal; _secondTrx : CM_TITransaction);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16/10/2014		cnwmc5	Initial creation
30/05/2016		cnwdap1	TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 15/07/2016   cnwma1  TFS #2376 POL - CODECO NAD lines in wrong segment and doubling up on information
// 9 May 2017	cnwrs1	TFS 3671 POL PIL new work
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
05/07/2022		jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
*/
vars
	fCode, code, tempStr,
	imExStatus			: String;
	ti 					: CM_TrackedItem;
	contentsStatus 		: String;
	foundMatch			: Boolean;
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
begin
	
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);
	imExStatus := self.imExStatusToString(ti);
	
	// DGS+ segment
	if ti.allTIHazards.isNotEmpty and  not _camProtocol.dgsDetailsInGroup14 then	//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);													
	endif;
	
	 // EQD+ segment
	//self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, ti.CM_Container.isoType, '102', '5', null, imExStatus, contentsStatus); //23/08/2017 cnwma1 TFS #5834	
	isoCode := ti.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, imExStatus, contentsStatus);	//23/08/2017 cnwma1 TFS #5834
	
	_camMessage.eqdCount := _camMessage.eqdCount + 1;		//cnwmc5 - 18 Dec 2014 - PAR 35393
	
	// RFF+BN segment
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);
	
	// RFF+CT segment
	self.makeMessageRFF_CT (_camProtocol, _camMessage.group5, ti);
	
	// RFF+CN segment
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group5, ti);
	
	// TMD+ segment
	self.makeTMDSegment (_camProtocol, _camMessage.group5);
	
	// DTM+ segment
	self.makeDTMSegment (	_camProtocol, 
							_camMessage.group5, 
							'7',  
							self.transDateTime(_transaction, _camMessage.activity, _camProtocol),
							'203');
	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;
	
	/** NEED TO REVIEW LOC **/
	// LOC+ segment
//	if _camMessage.activity = CODECO_GATEIN then
//		self.makeMessageLOC_GATEIN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);
//	elseif _camMessage.activity = CODECO_GATEOUT then
//		self.makeMessageLOC_GATEOUT (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	
//	endif;
	
	code := _terminal.getConfig(PortDestCode).String;
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, code, XLATION_TYPE_PORT_BYOP, _terminal);
	self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '160', '20', null, null, null);
	/****** END ******/
	
	// MEA+ segment
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,null); //epr par 37551 TFS 1429 16/2/16
	
	// DIM+ segment
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group5, ti);
	
	// TMP+ Segment
	if ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE then
		self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");		
	endif;
	
	// SEL+ segment
	self.makeMessageSealsData( ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);
	
	// DAM+ segment
	if ti.damaged then
		self.makeDAMSegment (_camProtocol, _camMessage.group5, '1', null, null, null, null);
	endif;

	if includeVGM then
		self.makeMessageFTX_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;
	
	// TDT+1 segment
	self.makeMessageTDT1Segment (_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti);
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);									// 15/07/2016 cnwma1  TFS #2376
	endif;																								// TFS #2061
	
	// ie Dangerous Goods													//JIRA-20814
	if _camProtocol.dgsDetailsInGroup14  then								//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group5);	//JIRA-20814
	endif;																	//JIRA-20814
epilog
	
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeTDT1Segment" id="ff058050-5213-461f-8fce-633b32153437">
        <source>makeTDT1Segment(_protocol: CM_CamProtocol; 
				_group: HugeStringArray input; 
				_ref: String; 
				_mode: String; 
				_means: String; 
				_carrier: String; 
				_carrierQual: String; 
				_carrierAgency: String; 
				_direction: String; 
				_excess: String; 
				_transportMeansID: String; 
				_transportQual: String; 
				_transportAgency: String; 
				_transportID: String): String protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
16 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "TDT";
	STAGE = "1";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; STAGE;
	if _ref = null and _mode = null and _means = null and _carrier = null and _carrierQual = null and _carrierAgency = null and
		_direction = null and _excess = null and _transportMeansID = null and _transportQual = null and _transportAgency = null and _transportID = null then
	else
		msg := msg &amp; plus &amp; 
				_ref &amp; plus &amp;
				_mode &amp; plus &amp; 
				_means &amp; plus &amp; colon &amp; colon &amp; colon &amp;
				_carrier &amp; plus &amp; 
                _carrierQual &amp; plus &amp;
                _carrierAgency &amp; plus &amp; 
				_transportID;
	endif;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_means" type="String"/>
        <Parameter name="_carrier" type="String"/>
        <Parameter name="_carrierQual" type="String"/>
        <Parameter name="_carrierAgency" type="String"/>
        <Parameter name="_direction" type="String"/>
        <Parameter name="_excess" type="String"/>
        <Parameter name="_transportMeansID" type="String"/>
        <Parameter name="_transportQual" type="String"/>
        <Parameter name="_transportAgency" type="String"/>
        <Parameter name="_transportID" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeUNBSegment" id="82f8dba8-3ea1-4760-ba19-a3eab7ac46d6">
        <source>makeUNBSegment(	_protocol: CM_CamProtocol; 
				_syntaxId: String; 
				_syntaxVersion: Integer; 
				_senderId: String; 
				_senderQual: String; 
				_recipientId: String; 
				_recipientQual: String; 
				_seqNumber: Integer; 
				_080: String; 
				_useLongYear: Boolean; _runDateTime : TimeStamp): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2014	cnwmc5	Initial creation
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "UNB";
	SPACE = ' ';
vars
	msg	:String;
	plus, colon, singleQuote, decimal, escape	:Character;
	timeStamp : TimeStamp;
begin
	timeStamp := _runDateTime.localToUTCTime();
	
	_protocol.getDefaultCharacters (decimal, plus, escape, singleQuote, colon);
	
	msg := MESSAGE &amp; plus &amp;
			_syntaxId &amp; colon &amp; _syntaxVersion.String &amp; plus &amp; 
			_senderId;
	
	msg := msg &amp; plus &amp;	_recipientId;
		
	msg := msg &amp; plus &amp;	timeStamp.date.shortYearEDI() &amp; colon &amp; timeStamp.time.shortFormatEDI();			
	
	msg := msg &amp; plus &amp; _senderId &amp; singleQuote;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_syntaxId" type="String"/>
        <Parameter name="_syntaxVersion" type="Integer"/>
        <Parameter name="_senderId" type="String"/>
        <Parameter name="_senderQual" type="String"/>
        <Parameter name="_recipientId" type="String"/>
        <Parameter name="_recipientQual" type="String"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_080" type="String"/>
        <Parameter name="_useLongYear" type="Boolean"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeUNHSegment" id="affaf1f0-fe04-47e6-bb76-73e98daed1ab">
        <source>makeUNHSegment(_protocol: CM_CamProtocol; _number: Integer; _fileType: String; _msgVersion: String; _msgReleaseNo: String; _agency: String; _association: String; _030: String; _runDateTime: TimeStamp): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2014	cnwmc5	Initial creation

*/

constants
	MESSAGE	= "UNH";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
	timeStamp : TimeStamp;
	msgRef : String;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	timeStamp := _runDateTime.localToUTCTime();
	msgRef := timeStamp.date.longYearEDI() &amp; timeStamp.time.formatAsHHMMSS();
	
	msg := MESSAGE &amp; plus &amp; 
			msgRef &amp; plus &amp; 
			_fileType &amp; colon &amp; _msgVersion &amp; colon &amp; _msgReleaseNo &amp; colon &amp; _agency;
			
	if _association &lt;&gt; null then
		msg := msg &amp; colon &amp; _association;
	endif;
	
	if _030 &lt;&gt; null then
		msg := msg &amp; plus &amp; _030;
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_msgVersion" type="String"/>
        <Parameter name="_msgReleaseNo" type="String"/>
        <Parameter name="_agency" type="String"/>
        <Parameter name="_association" type="String"/>
        <Parameter name="_030" type="String"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeUNTSegment" id="c083a998-b350-4156-9470-0914be13855c">
        <source>makeUNTSegment(_protocol: CM_CamProtocol; _count: Integer; _seqNumber: Integer; _runDateTime: TimeStamp): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2014	cnwmc5	Initial creation

*/

constants
	MESSAGE	= "UNT";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
	timeStamp : TimeStamp;
	msgRef : String;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	timeStamp := _runDateTime.localToUTCTime();
	msgRef := timeStamp.date.longYearEDI() &amp; timeStamp.time.formatAsHHMMSS();
	
	msg := MESSAGE &amp; plus &amp; 
			_count.String &amp; plus &amp; 
			msgRef
			&amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeUNZSegment" id="fbc15969-9c12-49b6-a154-5484d124f259">
        <source>makeUNZSegment(_protocol: CM_CamProtocol; _count: Integer; _seqNumber: Integer): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2014	cnwmc5	Initial creation

*/

constants
	MESSAGE	= "UNZ";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
	senderCode : String;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	senderCode 	:= self.getSenderCode_UNB(_protocol);
	
	msg := MESSAGE &amp; plus &amp; 
			_count.String &amp; plus &amp; 
			senderCode
			&amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_LOC" id="30b8e970-e0ed-4e38-ace6-8348e9640207">
