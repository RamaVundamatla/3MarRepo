    <JadeMethod name="getXMLSettingsForSave" id="e30cb910-f671-4b98-8bc7-0e2e563091e1">
        <updating/>
        <source>getXMLSettingsForSave() : String updating;
// Purpose:     Gets XML settings of window state for saving windows on closing the form.
// ***************************************************************************
// This is similar to method MobileUISchema::MOB_BaseForm::getXMLSettingsForSave.  
// Changes to this method may also need to be done in that method
// ***************************************************************************
vars

	xmlStr : String;
begin

	/* //13/03/2025	navkc1 JIRA Story MTN-34219
	return global.formatAsXML(XML_TagToolbarShowCaptions, self.frmToolbar.showCaptions.String) &amp;
		   global.formatAsXML(self.XMLTag_ShowEnhanced, self.isEnhanced.String);	
	*/
	
	xmlStr := global.formatAsXML(XML_TagToolbarShowCaptions, self.frmToolbar.showCaptions.String) &amp;
		   global.formatAsXML(self.XMLTag_ShowEnhanced, self.isEnhanced.String);
	
	// Notification Level
	xmlStr &amp;= global.formatAsXML(self.XMLTag_NotificationLevel, self.notificationLevel.String);
	
	// Auto refresh value
	xmlStr &amp;= global.formatAsXML(self.XMLTag_AutoRefreshValue, self.autoRefreshValue.String);
	
	return xmlStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
