    <JadeMethod name="doActivateCodes" id="3da8de52-9897-4bc2-9381-2a83e63b9a72">
        <source>doActivateCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
08 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	obj : Object;
	pxyHS : CM_HarmonizedSystem;
	coll : CM_HarmonizedSystemSet;
	selectedObjs : ObjectArray;
	theResult : Integer;
	
begin

	if not app.myCurrentUserCan(null, self.permissionMaint) then
		return;
	endif;
	
	if self.tblCodes.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create coll transient;
	
	beginLoad;
	foreach obj in self.tblCodes.allSelectedObjects where obj.isKindOf(CM_HarmonizedSystem) do
		pxyHS := obj.CM_HarmonizedSystem.pxyCreateUpdateProxy();
		coll.add(pxyHS);
	endforeach;
	endLoad;
	
	while true do
		app.myTrxUA.trxUpdateHarmonizedSysActivate(coll, true, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			create selectedObjs transient;
			self.tblCodes.allSelectedObjects.copy(selectedObjs);
			
			foreach obj in selectedObjs do
				self.tblCodes.removeItemObject(obj);
			endforeach;
			break;
			
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport,ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
	endwhile;
	
	self.loadActiveTable();
	
epilog
	if coll &lt;&gt; null then
		coll.purge();
		delete coll;
	endif;
	delete selectedObjs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeactivateCodes" id="85aebbd3-be6e-49ab-aad7-980ea8591571">
        <source>doDeactivateCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes
31 August   2024        navrv30 CR 65205: EUP - HS Code Purge Validation
*/

vars
	obj : Object;
	pxyHS : CM_HarmonizedSystem;
	coll : CM_HarmonizedSystemSet;
	selectedObjs : ObjectArray;
	theResult : Integer;
	
begin

	if not app.myCurrentUserCan(null, self.permissionMaint) then
		return;
	endif;

	if self.tblCodesActive.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create coll transient;
	
	beginLoad;
	foreach obj in self.tblCodesActive.allSelectedObjects where obj.isKindOf(CM_HarmonizedSystem) do		
		pxyHS := obj.CM_HarmonizedSystem.pxyCreateUpdateProxy();
		coll.add(pxyHS);
	endforeach;
	endLoad;
	
	while true do
		app.myTrxUA.trxUpdateHarmonizedSysActivate(coll, false, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			create selectedObjs transient;
			self.tblCodesActive.allSelectedObjects.copy(selectedObjs);
			
			foreach obj in selectedObjs do
				self.tblCodesActive.removeItemObject(obj);
			endforeach;
			break;
			
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport,ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else	//31.08.2024 navrv30 CR 65205
				break;
			endif;
		endif;
	endwhile;
	
epilog
	if coll &lt;&gt; null then
		coll.purge();
		delete coll;
	endif;
	delete selectedObjs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFileLoad" id="a602809b-a13d-47fe-b92e-56d8179a437a">
        <updating/>
        <source>doFileLoad() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	agent		: CM_HSCodeFileLoadAgent;
	cmifMonitor	: CMIF_Monitor;
	mode 		: Integer;
	
begin
	
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		return;
	endif;
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
		cmifMonitor.myParent := self;
	endif;

	app.doWindowEvents(0);
	
	if app.msgBox(app.getErrorString(Wish_reload_hscodes), app.getErrorString(Update_database), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	self.pbProgressBar.visible := true;   	
	
	create agent transient;
	
	if optPurge.value then
		mode := agent.Purge_Create;
	elseif optCreates.value then
		mode := agent.Create_Only;
	elseif optUpdates.value then
		mode := agent.Update_Only;
	elseif optUpdatesCreates.value then
		mode := agent.Create_Update;	
	endif;

	if not agent.loadFile(mode) and not app.myPassport.allErrors.isEmpty then
		app.showErrorWarningDialog( app.getErrorString(File_import_process) , app.myPassport, ErrWarnMode_Update);
		return;
	endif;
	
	app.msgBox(app.getErrorString(File_load_sucessful), app.getErrorString(Update_database), MsgBox_OK_Only);

	self.doRefresh();
	
epilog
	app.mousePointer := Idle;
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
	delete agent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterCodes" id="938ffd47-9fa5-42fb-a8e3-3bb024df3afd">
        <source>doFilterCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
	
begin
	filterText := self.txtFilter.text.toUpper();
	start := self.tblCodes.fixedRows + 1;
	
	if (filterText = "") then
		foreach rowIdx in start to self.tblCodes.rows do
			self.tblCodes.accessRow(rowIdx);
			self.tblCodes.accessedRow.visible := true;
		endforeach;
		return;
	endif;
	
	foreach rowIdx in start to self.tblCodes.rows do	: rowLoop
		self.tblCodes.accessRow(rowIdx);
		foreach colIdx in 1 to self.tblCodes.columns do
			cell := self.tblCodes.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblCodes.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblCodes.accessedRow.visible := false;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="7fef7b66-059c-4cf6-ad25-c218044ff57e">
        <updating/>
