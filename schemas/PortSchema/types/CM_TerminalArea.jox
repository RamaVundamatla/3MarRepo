    <JadeMethod name="setAutoRetrictionsEnabled" id="b08360ef-3095-40e3-94d0-72bea59f1dab">
        <updating/>
        <source>setAutoRetrictionsEnabled(_enabled : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	realTA			: CM_TerminalArea;
begin
	self.autoRestrictionsEnabled := _enabled;
	
	if self.pxyIsProxy() then
		realTA := self.pxyGetRealObject();
	else
		realTA := self;
	endif;
	
	if _enabled and realTA &lt;&gt; null then //look to see if we are empty and set isEmpty flag
		self.isEmpty := realTA.getIsEmptyValue();	
	endif;	
end;</source>
        <Parameter name="_enabled" type="Boolean"/>
