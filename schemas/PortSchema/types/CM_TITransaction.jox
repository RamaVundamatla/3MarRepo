    <JadeMethod name="getCCEventJSON" id="9840ce5f-f212-4006-9862-56afce16d32c">
        <source>getCCEventJSON() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2019	jlger1	Initial creation

*/

vars
	
	ccEventType : String;
	jsonHelper		: CMIF_JsonHelper;
	ccEvents : CMIF_CCEvents;
	ccEvent : CMIF_CCEvent;
	json : String;

begin
	
	ccEventType:=self.getCCEventType;
	if ccEventType = null then
		return null;
	endif;

	if self.myTrackedItem = null then
		return null;
	endif;
	
	if self.myTrackedItem.externalProfileSecret = null then
		return null;
	endif;
	
	create ccEvents transient;
	ccEvents.profileSecretId:=self.myTrackedItem.externalProfileSecret;
	
	create ccEvent transient;
	ccEvent.eventType:=ccEventType;
	ccEvents.events.add(ccEvent);
	
	self.getCCEventProperties(ccEvent);
	
	ccEvents.deserializeJSON(json);
	
	create jsonHelper transient;

	json:= jsonHelper.formatJsonString(json);
	
	return CN_LEFT_BRACKET &amp; json  &amp;  CN_RIGHT_BRACKET;
	
epilog
	delete jsonHelper;
	delete ccEvents;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
