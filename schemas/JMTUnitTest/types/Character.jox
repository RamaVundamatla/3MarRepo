<PrimType name="Character">
    <JadeMethod name="contIdWeighting" id="e6230b79-f4f7-4306-8e4e-6d9ef9813124">
        <source>contIdWeighting() : Integer;
//
//11 June 2019	jlgrs1	Initial creation
//
vars

begin
	if self &gt;= "0" and self &lt;= "9" then
		return self.Integer - 48;
	endif;
	if self = "A" then
		return 10;
	endif;
	if self &gt;= "B" and self &lt;= "K" then
		return self.Integer - 54;
	endif;
	if self &gt;= "L" and self &lt;= "U" then
		return self.Integer - 53;
	endif;
	if self &gt;= "V" and self &lt;= "Z" then
		return self.Integer - 52;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
