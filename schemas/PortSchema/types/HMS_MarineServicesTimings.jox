    <JadeMethod name="pxyCreateUpdateProxy" id="9ee7f311-55a3-4d41-8952-ad9ed3a09c3f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2018	jlgndl1	Initial creation	TFS 39215

*/

vars

	proxy : HMS_MarineServicesTimings;
	completedOK : Boolean;

begin

	proxy := inheritMethod();
	
	proxy.setMyVoyageMovement( self.myMovement );
	
	completedOK := true;
	return proxy;

epilog

	if not completedOK then
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0b299c10-0b5f-471d-916c-63ccf53d567d">
        <updating/>
        <source>setForUpdate( _pxyMST : HMS_MarineServicesTimings; _passport: CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/06/2018	jlgndl1	Initial creation
25/06/2018	jlgdap1	TFS 39355 PEL1 Pilot Surcharges
24/07/2018	jlgdap1	TFS 39741 PEL1 Marine Service Timings Changes
03/04/2019	jlgdap1	TFS 43694 PLE1 Charginf for Vessels that use a Ramp
19/11/2025	navlw1	JIRA-36116: ATD | Marine Service Audits - jade
*/

vars
	inaportnetWSRequest 	: BGP_InaportnetWSRequest;
begin

	inheritMethod( _pxyMST, _passport );
	
	if (not app.isConverting) then
		self.createTransaction(TRANS_TYPE_EditMarineTimings, _pxyMST, _passport);
	endif;	
	
	// Start navlw1 JIRA-36116 19/11/2025
	if self.linesActualTS &lt;&gt; _pxyMST.linesActualTS then
		self.linesActualTS := _pxyMST.linesActualTS;
	endif;
	
	if self.linesApprovedTS &lt;&gt; _pxyMST.linesApprovedTS then
		self.linesApprovedTS := _pxyMST.linesApprovedTS;
	endif;
	
	if self.linesRemarks &lt;&gt; _pxyMST.linesRemarks then
		self.linesRemarks :=  _pxyMST.linesRemarks;
	endif;
	
	if self.linesRequestedTS &lt;&gt; _pxyMST.linesRequestedTS then
		self.linesRequestedTS :=  _pxyMST.linesRequestedTS;
	endif;
	
	if self.movementActualTS &lt;&gt; _pxyMST.movementActualTS then
		self.movementActualTS :=  _pxyMST.movementActualTS;
	endif;
	
	if self.movementApprovedTS &lt;&gt; _pxyMST.movementApprovedTS then
		self.movementApprovedTS :=  _pxyMST.movementApprovedTS;
	endif;
	
	if self.movementRemarks &lt;&gt; _pxyMST.movementRemarks then
		self.movementRemarks :=  _pxyMST.movementRemarks;
	endif;
	
	if self.movementRequestedTS &lt;&gt; _pxyMST.movementRequestedTS then
		self.movementRequestedTS :=  _pxyMST.movementRequestedTS;
	endif;
	
	if self.movementBerthArrival &lt;&gt; _pxyMST.movementBerthArrival then
		self.movementBerthArrival := _pxyMST.movementBerthArrival;	//26 Oct 2018	NDL	TFS 41413
	endif;
	// End navlw1 JIRA-36116 19/11/2025
	
	if self.pilotActualTS &lt;&gt; _pxyMST.pilotActualTS then
		self.pilotActualTS :=  _pxyMST.pilotActualTS;
		// epr TFS 40847 14/9/18 inaportnet SPOG means its been aproved by inaportnet we can send pilot timings
		if _pxyMST.myMovement &lt;&gt; null and _pxyMST.myMovement.HMS_VoyageMovement.inaportnetSPOG &lt;&gt; null then
			create inaportnetWSRequest persistent;
			inaportnetWSRequest.setMarineTimings(self,BGP_InaportnetWSRequest.PilotTimeOnboard);
			inaportnetWSRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);	
		endif;
	endif;
	
	if self.pilotStartsMoving &lt;&gt; _pxyMST.pilotStartsMoving then
		self.pilotStartsMoving := _pxyMST.pilotStartsMoving;	//14 Sep 2018	NDL	TFS 40876
		// epr TFS 40847 14/9/18 inaportnet SPOG means its been aproved by inaportnet we can send pilot timings
		if _pxyMST.myMovement &lt;&gt; null and _pxyMST.myMovement.HMS_VoyageMovement.inaportnetSPOG &lt;&gt; null then
			create inaportnetWSRequest persistent;
			inaportnetWSRequest.setMarineTimings(self,BGP_InaportnetWSRequest.PilotTimeStartMove);
			inaportnetWSRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);	
		endif;
	endif;
	
	if self.pilotFinishMoving &lt;&gt; _pxyMST.pilotFinishMoving then
		self.pilotFinishMoving := _pxyMST.pilotFinishMoving;	//14 Sep 2018	NDL	TFS 40876
		// epr TFS 40847 14/9/18 inaportnet SPOG means its been aproved by inaportnet we can send pilot timings
		if _pxyMST.myMovement &lt;&gt; null and _pxyMST.myMovement.HMS_VoyageMovement.inaportnetSPOG &lt;&gt; null then
			create inaportnetWSRequest persistent;
			inaportnetWSRequest.setMarineTimings(self,BGP_InaportnetWSRequest.PilotTimeFinishMove);
			inaportnetWSRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);	
		endif;
	endif;
	
	if self.pilotOffboard &lt;&gt; _pxyMST.pilotOffboard then
		self.pilotOffboard := _pxyMST.pilotOffboard;	//14 Sep 2018	NDL	TFS 40876
		// epr TFS 40847 14/9/18 inaportnet SPOG means its been aproved by inaportnet we can send pilot timings
		if _pxyMST.myMovement &lt;&gt; null and _pxyMST.myMovement.HMS_VoyageMovement.inaportnetSPOG &lt;&gt; null then
			create inaportnetWSRequest persistent;
			inaportnetWSRequest.setMarineTimings(self,BGP_InaportnetWSRequest.PilotTimeOffboard);
			inaportnetWSRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);	
		endif;
	endif;
	
	// Start navlw1 JIRA-36116 19/11/2025
	if self.pilotApprovedTS &lt;&gt; _pxyMST.pilotApprovedTS then
		self.pilotApprovedTS :=  _pxyMST.pilotApprovedTS;
	endif;
	
	if self.pilotRemarks &lt;&gt; _pxyMST.pilotRemarks then
		self.pilotRemarks :=  _pxyMST.pilotRemarks;
	endif;
	
	if self.pilotRequestedTS &lt;&gt; _pxyMST.pilotRequestedTS then
		self.pilotRequestedTS :=  _pxyMST.pilotRequestedTS;
	endif;
	
	if self.tugsActualTS &lt;&gt;_pxyMST.tugsActualTS then
		self.tugsActualTS :=  _pxyMST.tugsActualTS;
	endif;
	
	if self.tugsApprovedTS &lt;&gt; _pxyMST.tugsApprovedTS then
		self.tugsApprovedTS :=  _pxyMST.tugsApprovedTS;
	endif;
	
	if self.tugsRemarks &lt;&gt;  _pxyMST.tugsRemarks then
		self.tugsRemarks :=  _pxyMST.tugsRemarks;
	endif;
	
	if self.tugsRequestedTS &lt;&gt; _pxyMST.tugsRequestedTS then
		self.tugsRequestedTS := _pxyMST.tugsRequestedTS;
	endif;
	
	if self.tugsRequestedTSTo &lt;&gt; _pxyMST.tugsRequestedTSTo then
		self.tugsRequestedTSTo := _pxyMST.tugsRequestedTSTo;		// TFS 39741
	endif;
	
	if self.tugsApprovedTSTo &lt;&gt; _pxyMST.tugsApprovedTSTo then
		self.tugsApprovedTSTo := _pxyMST.tugsApprovedTSTo;			// TFS 39741
	endif;
	
	if self.tugsActualTSTo &lt;&gt; _pxyMST.tugsActualTSTo then
		self.tugsActualTSTo := _pxyMST.tugsActualTSTo;				// TFS 39741
	endif;
	
	if self.pilotSurchargeInvLIneTypeVNR &lt;&gt; _pxyMST.pilotSurchargeInvLIneTypeVNR then
		self.pilotSurchargeInvLIneTypeVNR := _pxyMST.pilotSurchargeInvLIneTypeVNR;		// TFS 39355
	endif;
	
	if self.pilotSurchargeInvLIneTypeRTS &lt;&gt; _pxyMST.pilotSurchargeInvLIneTypeRTS then
		self.pilotSurchargeInvLIneTypeRTS := _pxyMST.pilotSurchargeInvLIneTypeRTS;		// TFS 39355
	endif;
	
	if self.hasRamp &lt;&gt; _pxyMST.hasRamp then
		self.hasRamp := _pxyMST.hasRamp;			// TFS 43694
	endif;

	// End navlw1 JIRA-36116 19/11/2025
	
epilog

end;</source>
        <Parameter name="_pxyMST" type="HMS_MarineServicesTimings"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHasRamp" id="21200dd8-5969-4520-97cc-1a370e4fd710">
        <updating/>
        <source>setHasRamp(_hasRamp : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/04/2019	jlgdap1		Initial creation TFS 43694 PEL1 Charging for Vessels that use a Ramp
// 16MAY19 JLGAB1 		Ian says 'don't tick any box automatically and leave it up to the user to confirm on the movement 
//									when the vessel moves away from the berth if the ramp was actually used there.'
//										This means this method is not used

//
vars

begin
	self.hasRamp := _hasRamp;
epilog

end;</source>
        <Parameter name="_hasRamp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMovementDateTimes" id="1bcee765-8b4a-4bac-aa0f-88502ec3c498">
        <updating/>
        <source>setMovementDateTimes(_dateTime : TimeStamp; _requested, _approved, _actual, _berthArrival : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2018	jlgndl1	Initial creation	TFS 41412

*/

vars

begin

	if _requested then
		if _dateTime.isValid and not self.movementRequestedTS.isValid then
			self.movementRequestedTS := _dateTime;
		endif;
	elseif _approved then
		if _dateTime.isValid and self.movementApprovedTS &lt;&gt; _dateTime then
			self.movementApprovedTS := _dateTime;
		endif;
	elseif _actual then
		if _dateTime.isValid and self.movementActualTS &lt;&gt; _dateTime then
			self.movementActualTS := _dateTime;
		endif;
	elseif _berthArrival then	//26 Oct 2018	NDL	TFS 41413
		if _dateTime.isValid and self.movementBerthArrival &lt;&gt; _dateTime then
			self.movementBerthArrival := _dateTime;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_requested" type="Boolean"/>
        <Parameter name="_approved" type="Boolean"/>
        <Parameter name="_actual" type="Boolean"/>
        <Parameter name="_berthArrival" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageMovement" id="58c0371e-3ebb-4414-9cdc-e8948a1628a2">
        <updating/>
        <source>setMyVoyageMovement( _voyageMovement : HMS_Movement ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2018	jlgndl1	Initial creation	TFS 39215

*/

vars

begin

	self.myMovement := _voyageMovement;

epilog

end;</source>
        <Parameter name="_voyageMovement" type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="setPilotDateTimes" id="054121f9-330b-49ae-9175-84228b529ca1">
        <updating/>
        <source>setPilotDateTimes(_dateTime : TimeStamp; _requested, _approved, _actual : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/07/2018	jlgdap1		Initial creation TFS 39741 PEL1 Marine Service Timings Changes
// 20//11/2025	navlw1		JIRA-36116: ATD | Marine Service Audits - jade
//
vars
	createTransaction : Boolean;
	pxyMarineServices : HMS_MarineServicesTimings;
begin
	// create a transient as we do not have a set proxy to set these date/times for the pilots
	// we set the fields on the transeint that have changed and then pass the transient to the createTransaction Method
	create pxyMarineServices transient;
	if _requested then
		if _dateTime.isValid and not self.pilotRequestedTS.isValid then
			self.pilotRequestedTS := _dateTime;
		endif;
	elseif _approved then
		if _dateTime.isValid and self.pilotApprovedTS &lt;&gt; _dateTime then
			self.pilotApprovedTS := _dateTime;
			pxyMarineServices.pilotApprovedTS := self.pilotApprovedTS;
			createTransaction := true;
		endif;
	elseif _actual then
		if _dateTime.isValid and self.pilotActualTS &lt;&gt; _dateTime then
			self.pilotActualTS := _dateTime;
			pxyMarineServices.pilotActualTS := self.pilotActualTS;
			createTransaction := true;
		endif;
	endif;
	if createTransaction then
		self.createTransaction(TRANS_TYPE_EditMarineTimings,pxyMarineServices,app.myPassport);
	endif;
epilog
	delete pxyMarineServices;
end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_requested" type="Boolean"/>
        <Parameter name="_approved" type="Boolean"/>
        <Parameter name="_actual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="d627f747-3d61-48f9-802b-ab417311e000">
        <updating/>
        <source>setProxy(	_linesActualTS : TimeStamp;
			_linesApprovedTS : TimeStamp;
			_linesRemarks : String;
			_linesRequestedTS : TimeStamp;	
			_movementActualTS : TimeStamp;
			_movementApprovedTS : TimeStamp;
			_movementRemarks : String;
			_movementRequestedTS : TimeStamp;	
			_pilotActualTS : TimeStamp;
			_pilotApprovedTS : TimeStamp;
			_pilotRemarks : String;
			_pilotRequestedTS : TimeStamp;	
			_tugsActualTS : TimeStamp;
			_tugsApprovedTS : TimeStamp;
			_tugsRemarks : String;
			_tugsRequestedTS : TimeStamp;
			_pilotSurchargeRTS : Boolean;			// TFS 39355
			_pilotSurchargeVNR : Boolean;			// TFS 39355
			_tugsRequestedTSTo : TimeStamp;		// TFS 39741
			_tugsApprovedTSTo : TimeStamp;		// TFS 39741
			_tugsActualTSTo : TimeStamp;		// TFS 39741
			_movement : HMS_Movement;
			_pilotStartMoveTS : TimeStamp;	//14 Sep 2018	NDL	TFS 40876
			_pilotFinishMoveTS : TimeStamp;	//14 Sep 2018	NDL	TFS 40876
			_pilotOffBoardTS : TimeStamp;	//14 Sep 2018	NDL	TFS 40876
			_movementBerthArrTS : TimeStamp;	//26 Oct 2018	NDL	TFS 41413
			_usedRamp : Boolean					// TFS 43694
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/06/2018	jlgndl1	Initial creation	TFS 39215
25/06/2018	jlgdap1	TFS 39355 PEL1 Pilot Surcharges
20/07/2018	jlgdap1	TFS 39741 PEL1 Marine Service Timings Changes
28/03/2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
*/

vars

begin

	self.linesActualTS := _linesActualTS;
	self.linesApprovedTS := _linesApprovedTS;
	self.linesRemarks := _linesRemarks;
	self.linesRequestedTS := _linesRequestedTS;
	
	self.movementActualTS := _movementActualTS;
	self.movementApprovedTS := _movementApprovedTS;
	self.movementRemarks := _movementRemarks;
	self.movementRequestedTS := _movementRequestedTS;
	self.movementBerthArrival := _movementBerthArrTS;	//26 Oct 2018	NDL	TFS 41413
	
	self.pilotActualTS := _pilotActualTS;
	self.pilotApprovedTS := _pilotApprovedTS;
	self.pilotRemarks := _pilotRemarks;
	self.pilotRequestedTS := _pilotRequestedTS;
	
	self.pilotStartsMoving := _pilotStartMoveTS;	//14 Sep 2018	NDL	TFS 40876
	self.pilotFinishMoving := _pilotFinishMoveTS;	//14 Sep 2018	NDL	TFS 40876
	self.pilotOffboard := _pilotOffBoardTS;	//14 Sep 2018	NDL	TFS 40876
			
	
	self.tugsActualTS := _tugsActualTS;
	self.tugsApprovedTS := _tugsApprovedTS;
	self.tugsRemarks := _tugsRemarks;
	self.tugsRequestedTS := _tugsRequestedTS;
	self.tugsRequestedTSTo := _tugsRequestedTSTo;		// TFS 39741
	self.tugsApprovedTSTo := _tugsApprovedTSTo;			// TFS 39741
	self.tugsActualTSTo := _tugsActualTSTo;				// TFS 39741
	
	self.pilotSurchargeInvLIneTypeRTS := _pilotSurchargeRTS;		// TFS 39355
	self.pilotSurchargeInvLIneTypeVNR := _pilotSurchargeVNR;		// TFS 39355
	
	self.hasRamp := _usedRamp;					// TFS 43694
	
	if _movement &lt;&gt; null then
		self.setMyVoyageMovement( _movement );
	endif;

epilog

end;</source>
        <Parameter name="_linesActualTS" type="TimeStamp"/>
        <Parameter name="_linesApprovedTS" type="TimeStamp"/>
        <Parameter name="_linesRemarks" type="String"/>
        <Parameter name="_linesRequestedTS" type="TimeStamp"/>
        <Parameter name="_movementActualTS" type="TimeStamp"/>
        <Parameter name="_movementApprovedTS" type="TimeStamp"/>
        <Parameter name="_movementRemarks" type="String"/>
        <Parameter name="_movementRequestedTS" type="TimeStamp"/>
        <Parameter name="_pilotActualTS" type="TimeStamp"/>
        <Parameter name="_pilotApprovedTS" type="TimeStamp"/>
        <Parameter name="_pilotRemarks" type="String"/>
        <Parameter name="_pilotRequestedTS" type="TimeStamp"/>
        <Parameter name="_tugsActualTS" type="TimeStamp"/>
        <Parameter name="_tugsApprovedTS" type="TimeStamp"/>
        <Parameter name="_tugsRemarks" type="String"/>
        <Parameter name="_tugsRequestedTS" type="TimeStamp"/>
        <Parameter name="_pilotSurchargeRTS" type="Boolean"/>
        <Parameter name="_pilotSurchargeVNR" type="Boolean"/>
        <Parameter name="_tugsRequestedTSTo" type="TimeStamp"/>
        <Parameter name="_tugsApprovedTSTo" type="TimeStamp"/>
        <Parameter name="_tugsActualTSTo" type="TimeStamp"/>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_pilotStartMoveTS" type="TimeStamp"/>
        <Parameter name="_pilotFinishMoveTS" type="TimeStamp"/>
        <Parameter name="_pilotOffBoardTS" type="TimeStamp"/>
        <Parameter name="_movementBerthArrTS" type="TimeStamp"/>
        <Parameter name="_usedRamp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTugFromToDateTimes" id="10b80105-07fd-45e9-8ba3-31c4a16cdaee">
        <updating/>
        <source>setTugFromToDateTimes(_fromDT, _toDT : TimeStamp; _requested, _approved, _actual : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/07/2018	jlgdap1		Initial creation TFS 39741 PEL1 Marine Service Timings Changes
// 20/11/2025	navlw1		JIRA-36116: ATD | Marine Service Audits - jade
//
vars
	createTransaction : Boolean;
	pxyMarineServices : HMS_MarineServicesTimings;
begin
	// create a transient as we do not have a set proxy to set these date/times for the tugs
	// we set the fields on the transient that have changed and then pass the transient to the createTransaction Method
	create pxyMarineServices transient;
	if _requested then
		if _fromDT.isValid and not self.tugsRequestedTS.isValid then
			self.tugsRequestedTS := _fromDT;
		endif;
		if _toDT.isValid and not self.tugsRequestedTSTo.isValid then
			self.tugsRequestedTSTo := _toDT;
		endif;
	elseif _approved then
		if _fromDT.isValid and self.tugsApprovedTS &lt;&gt; _fromDT then
			self.tugsApprovedTS := _fromDT;
			pxyMarineServices.tugsApprovedTS := self.tugsApprovedTS;
			createTransaction := true;
		endif;
		if _toDT.isValid and self.tugsApprovedTSTo &lt;&gt; _toDT then
			self.tugsApprovedTSTo := _toDT;
			pxyMarineServices.tugsApprovedTSTo := self.tugsApprovedTSTo;
			createTransaction := true;
		endif;
	elseif _actual then
		if _fromDT.isValid and self.tugsActualTS &lt;&gt; _fromDT then
			self.tugsActualTS := _fromDT;
			pxyMarineServices.tugsActualTS := self.tugsActualTS;
			createTransaction := true;
		endif;
		if _toDT.isValid and self.tugsActualTSTo &lt;&gt; _toDT then
			self.tugsActualTSTo := _toDT;
			pxyMarineServices.tugsActualTSTo := self.tugsActualTS;
			createTransaction := true;
		endif;
	endif;
	if createTransaction then
		self.createTransaction(TRANS_TYPE_EditMarineTimings,pxyMarineServices,app.myPassport);
	endif;
epilog
	delete pxyMarineServices;
end;</source>
        <Parameter name="_fromDT" type="TimeStamp"/>
        <Parameter name="_toDT" type="TimeStamp"/>
        <Parameter name="_requested" type="Boolean"/>
        <Parameter name="_approved" type="Boolean"/>
        <Parameter name="_actual" type="Boolean"/>
    </JadeMethod>
</Class>
