<GUIClass name="CMUI_NextPrevButton" id="75bba04c-1c18-44bc-8b46-cef42e2ef116">
    <superclass name="CMUI_Button"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isNext" id="c4d02d96-5700-4f8e-abc0-247bc6dae003">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="click" id="bb3d5b56-3434-463e-9ff0-c08c1d37d103">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(btn: Button input) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2022	navkc1	Initial creation ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables

*/

vars
	form 		: CM_BaseForm;
	table		: CM_FilterTable;
	
begin

	form := self.form.CM_BaseForm;
	table := self.parent.CM_FilterTable;
	
	if self.isNext then
		form.doTableClickNext(self, table);
	else
		form.doTableClickPrev(self, table);
	endif;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
