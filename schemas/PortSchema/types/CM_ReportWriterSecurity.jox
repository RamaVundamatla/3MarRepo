    <JadeMethod name="canAccessConfiguration" id="f7ec0c0c-65a8-482f-976d-f48342bacbdf">
        <source>canAccessConfiguration(userName: String): Integer;

vars

begin

	return self.userCanDo(userName, PmRwDesignRead, PmRwDesignFull);

end;</source>
        <Parameter name="userName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
