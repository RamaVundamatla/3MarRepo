    <JadeMethod name="frmGrdArea_contextMenu" id="73050504-5311-430b-b7c3-e9dbd2a274b0">
        <controlMethod name="Frame::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGrdArea_contextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

vars
	validate		: Integer;
	gridArea		: CM_GridArea;
	taType			: Integer;
begin

	self.x := x;
	self.y := y;
	
	//PAR16950 cnwsh3 check to see if I'm not being 
	if self.myCurrentSOPGridArea &lt;&gt; null then
		self.myCurrentSOPGridArea.setSelected(0,0);
	endif;
		
	validate := validateState();

	if CM_GridArea.hasInstance(self.myCurrentObject) then //PAR17397 cnwsh3 Prevent error occurring for Trailer areas .
		gridArea := self.myCurrentObject.CM_GridArea;
	endif;

	if app.isAllowedToInspect then
		self.mnuInspectGridPoint.visible := true;
	endif;
	// New functionality.
	if validate = Return_Continue or validate = Return_Tracked_Items then
		setContextMenu(Grid_Menu);
		return self.showContextMenu(mnuSetAttribute, cntrl, conwin, mouse, x, y);
	else
		return self.showContextMenu(mnuNoEdit, cntrl, conwin, mouse, x, y);
	endif;
	return false;

end;</source>
