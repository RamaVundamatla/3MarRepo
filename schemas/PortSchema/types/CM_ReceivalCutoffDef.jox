<Class name="CM_ReceivalCutoffDef" id="3defa3c0-4670-4dff-a4b3-3890878269dd">
    <superclass name="CM_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="defaultCutoff" id="f3fb18a9-280c-4e63-9c4a-75a9ac0259f2">
        <precision>7</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
        <text>If 0.0:

- for CARGO don't calculate cutoff TS
- for EDI do calculate cutoff TS</text>
    </PrimAttribute>
    <PrimAttribute name="defaultCutoffPN" id="fdb66f52-6e47-499a-8e8d-8a760b378f05">
        <precision>7</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="defaultEarliestReceival" id="f08e7b9b-0dc5-4f69-9a4b-9cce86f67e9e">
        <precision>7</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
        <text>If 0.0:

- for CARGO don't calculate cutoff TS
- for EDI do calculate cutoff TS</text>
    </PrimAttribute>
    <PrimAttribute name="defaultEarliestReceivalPN" id="79be0d3d-e0af-41fd-b160-c2684d563a52">
        <precision>7</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="defaultRelativeTo" id="acc850c3-40d9-4e7b-a2a0-4d1bd852a382">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getCode" id="9b7ac1f5-16e6-4dbe-92e7-a77da19983b8">
