    <JadeMethod name="getFullIdTI" id="f06ff26d-2e7f-4ab1-8299-e9cd65ee7ccb">
        <source>getFullIdTI(_ti: CM_TrackedItem): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwer1	Initial creation

*/

vars

begin
	if  (_ti.isAttributeTrue(TI_Attrib_IsForty) or _ti.isOverSizedContainer) then
	//if _ti.isAttributeTrue(TI_Attrib_IsForty) or 
	//   _ti.isAttributeTrue(TI_Attrib_IsFortyFive) then
		return self.getFullId40(); 
	else
		return self.getFullId(); 
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullSourceId" id="2e8f2d83-027b-466d-916d-5fdb416d4389">
        <source>getFullSourceId(): String;
// 28771 Dec 2011 restore returning number of items in interchange area
vars
	str	: String;
begin
	str := inheritMethod();
	return str &amp; ' ' &amp; self.numTIs.String;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
