        <source>setCtrlsForView() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2013	cnwrd1	Initial creation

*/

vars

	theForm : SOP_TableMaintForm;
	canAdd	: Boolean;
	
begin
	inheritMethod();    
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.cnEcResizeContents();
	
	theForm.btnSetDefault1.enabled := true;
	theForm.lstSingleSelect1.visible:=true;
	theForm.btnSingle1Edit.enabled:=true;
	theForm.btnSingle1Delete.enabled:=true;
	theForm.btnSingle1New.enabled:=true;
	theForm.btnSingle1Down.enabled:=true;
	theForm.btnSingle1Up.enabled:=true;
epilog

end;</source>
    </JadeMethod>
