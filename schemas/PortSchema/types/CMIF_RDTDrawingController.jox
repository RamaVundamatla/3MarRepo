    <JadeMethod name="gotoLocationByString" id="98345178-c935-4585-bf92-8664e7ee49ac">
        <updating/>
        <source>gotoLocationByString(_location : String; _ti : CM_TrackedItem; _mode : Integer; _calcBestZoom : Boolean) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars
	location 	: String;
	height	 	: Integer;
	lc			: CM_LocationsController;
	glc			: CM_GridController;
begin	

	if _location = null then 
		return false;
	endif;
	location := _location.trimBlanks();
	
	self.myTerminal.findLocationFromString(location, true, lc, height);
	self.targetLocationHeight := height; // Used for side view
	return self.gotoLocationByID(lc, _ti, _mode, _calcBestZoom);
	
epilog

end;</source>
        <Parameter name="_location" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_calcBestZoom" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
