    <JadeMethod name="getExtraInfoLogVoyOps" id="0d8b306e-1b20-4d49-8cd5-6abd209643a2">
        <source>getExtraInfoLogVoyOps(_array : HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//
//	par 10009 - _terminalForTerminology added to method signature. needed
//	for teminology. is taken from form so terminology will be consistent 
//	depending on what terminal the form was started from - HJG 10/05/05
//--------------------------------------------------------------
vars
	terminology :	String;
begin	
	terminology := app.getTerminologyAlternate(app.myRoot.allCargoTypesById[TI_CargoType_Log], _terminalForTerminology, 
												CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');

	_array.add("Comments"  &amp; Tab &amp; self.comments);		
	_array.add(terminology &amp; " Comments" &amp; Tab &amp; self.commentsOperator);
//	_array.add("Operator Comments" &amp; Tab &amp; self.commentsOperator);
	self.myStockOrderHeader.getExtraInfoLogVoyOps(_array,_terminalForTerminology);

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
