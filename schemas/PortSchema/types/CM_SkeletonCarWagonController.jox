    <JadeMethod name="isThereRoomForTI" id="1861e601-3c28-45a7-a3b2-ff896ee418de">
        <source>isThereRoomForTI(_overHangLC: CM_LocationsController; _control: CMIF_MoveController input; _ti: CM_TrackedItem): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2020	jlgndl1	Initial creation

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	tiWeights : Decimal [16,4];

begin

	if _ti = null then
		return null;
	endif;
	
	if (_ti.getLengthInMetres * 100) &gt; self.myWagon.myWagonClass.overallLength then
		app.raiseCMException(Cargo_dimension_too_big, null, null);
		return app.getErrorString(Cargo_dimension_too_big);
	endif;
	
	if _ti.getActualWidthRaw &gt; self.myWagon.myWagonClass.overallLength then
		app.raiseCMException(Cargo_dimension_too_big, null, null);
		return app.getErrorString(Cargo_dimension_too_big);
	endif;
	
	if _ti.getActualHeightRaw &gt; self.myWagon.myWagonClass.overallLength then
		app.raiseCMException(Cargo_dimension_too_big, null, null);
		return app.getErrorString(Cargo_dimension_too_big);
	endif; 
	
	
	if _control &lt;&gt; null and _control.weight &lt;&gt; null then
		tiWeights := _control.weight;
	elseif _control &lt;&gt; null and _control.isDirectReleaseMove and				// tfs42863
	   _control.quantity &gt; 0 and _control.quantity &lt; _ti.totalQuantity then		// tfs42863
		// in direct release moves can plan a move without splitting the TI, want to
		// verify with the split weight
		tiWeights := _ti.totalWeight * (_control.quantity/_ti.totalQuantity);	// tfs42863
	else
		tiWeights := _ti.totalWeight;
	endif;
	
	iter := self.allTrackedItems.createIterator;
	while iter.next( ti ) do
		tiWeights := tiWeights + ti.totalWeight;
	endwhile;
	//jlier1 TFS 58104 23/5/23
	if tiWeights &gt; self.myWagon.maxCargoWeight then
		app.raiseCMException(WARN_MAX_LOAD_WEIGHT, null, null);
		return app.getErrorString(WARN_MAX_LOAD_WEIGHT);
	endif;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_overHangLC" type="CM_LocationsController"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
