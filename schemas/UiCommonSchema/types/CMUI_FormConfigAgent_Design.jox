    <JadeMethod name="buildFormFromJadeDefinition" id="1cc6d37d-8b7f-45dd-834e-44c07f0695b6">
        <updating/>
        <source>buildFormFromJadeDefinition(_form :CM_BaseForm input; _parent :Frame input)updating, protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
29 August 2008	concms1	Builds a version of a form in context of _parent
*/

vars
	form		:CM_BaseForm;	
	scm			:Schema;
	cls			:Class;
	collOrig, 
	collCloned	:CMUI_ControlsByNameDict;
begin
	if self.myFormConfiguration = null then
		return;
	endif;
	
	scm := currentSchema.getSchema(self.myFormConfiguration.getSchemaName);
	cls := scm.getClass (self.myFormConfiguration.formName);
	
	if self.myJadeForm &lt;&gt; null then
		delete self.myJadeForm;
	endif;
	
	create self.myJadeForm as cls;
	
	form := self.myJadeForm;
	
	// set the form dimensions first - this avoids any funny problems with parent aspect
	self.setFormDimensions (_form, _parent, self.myPxyFormConfiguration);
	
	// create all collections we need to add cloned controls to _form
	create collOrig transient;	
	create collCloned transient; 
	
	// create clones of all controls we need to display the form image
	self.buildForm_cloneControls (form, collOrig, collCloned);
	
	// set parent control for all the cloned controls
	self.buildForm_setParent (collOrig, collCloned, _parent);
	
	// add our cloned controls to the customiation form
	self.buildForm_addControls (collCloned, _form, _parent);

	
	_parent.backBrush	:= form.backBrush;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
        <Parameter name="_parent" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildForm_addControls" id="31bb5b88-e816-45aa-8cf7-8055fe2b786b">
        <source>buildForm_addControls(_collCloned :CMUI_ControlsByNameDict; _form :CM_BaseForm input; _parent :Frame)protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll1, coll2	:ObjectSet;
	obj				:Object;
	control			:Control;
begin
	create coll1 transient;
	create coll2 transient;
	
	_collCloned.copy (coll1);
	
	// we have to add parent controls to the form before their children !!!
	while coll1.size &gt; 0 do
		foreach obj in coll1 do
			control := obj.Control;
			
			if control.parent = _parent or 
				coll2.includes (control.parent) then
				
				// add control to the form as its parent has already been added
				self.doAddControl (_form, control); 
				// put it in added collection in case it has children
				coll2.add (control);	
				// take it out of source collection as so we only add it once.
				coll1.remove (control);
			endif;
		endforeach;
	endwhile;
epilog
	delete coll1;
	delete coll2;
end;</source>
        <access>protected</access>
        <Parameter name="_collCloned" type="CMUI_ControlsByNameDict"/>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
        <Parameter name="_parent" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="buildForm_cloneControls" id="5b86262b-9c96-487b-93c9-614ba3b0b385">
        <source>buildForm_cloneControls(_form :CM_BaseForm; _collOrig, _collCloned :CMUI_ControlsByNameDict input) protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	size, int	:Integer;
	control, 
	newControl	:Control;
begin
	size := _form.controlCount;
	
	foreach int in 1 to size do
		control := _form.controls (int);
		
		if not self.buildForm_includeControl (_form, control) then
			continue;
		endif;
		
		_collOrig.putAtKey(control.name, control);
		
		newControl := control.cloneSelf (true);
	
		_collCloned.putAtKey (newControl.name, newControl);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_form" type="CM_BaseForm"/>
        <Parameter name="_collOrig" type="CMUI_ControlsByNameDict" usage="input"/>
        <Parameter name="_collCloned" type="CMUI_ControlsByNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildForm_includeControl" id="8a506b3c-1333-4d5d-b1f6-8885ceae0cc6">
        <source>buildForm_includeControl(_form :CM_BaseForm; _control :Control):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
//				not all controls are to be included eg, toolbars etc
// Parameters:  _form	- original jade form
//				_control - control on original jade form
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// we don't want to clone any of the framework controls - eg toolbar
	if _control = _form.frmToolbarBtns or 
		_control = _form.frmToolbar or 
		_control = _form.frmModalDialog or
		_control = _form.frmProgressCtr then
		return false;
	endif;
	
	if self.isChildControlOf (_control, _form.frmToolbarBtns) then
		return false;
	endif;
	
	if self.isChildControlOf (_control, _form.frmToolbar) then
		return false;
	endif;
	
	if self.isChildControlOf (_control, _form.frmModalDialog) then
		return false;
	endif;
		
	if self.isChildControlOf (_control, _form.frmProgressCtr) then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_form" type="CM_BaseForm"/>
        <Parameter name="_control" type="Control"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildForm_setParent" id="20c836ab-7909-42d8-8e78-d25d2622e8e9">
        <source>buildForm_setParent(_collOrig, _collCloned :CMUI_ControlsByNameDict; _parent :Frame);
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	control,
	clonedControl	:Control;
begin
	foreach control in _collOrig do
		clonedControl := _collCloned [control.name];

		if control.parent &lt;&gt; null and control.parent.isKindOf(Control) then
			clonedControl.parent := _collCloned[control.parent.name];
		else
			clonedControl.parent := _parent;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_collOrig" type="CMUI_ControlsByNameDict"/>
        <Parameter name="_collCloned" type="CMUI_ControlsByNameDict"/>
        <Parameter name="_parent" type="Frame"/>
    </JadeMethod>
