    <JadeMethod name="getButtonIndexByName" id="6553fae3-614b-4040-9572-5c085f6b683a">
        <source>getButtonIndexByName(_btnName : String; _leftControl : Boolean) : Integer;
/* ---------------------------------------------------------------------------
Created:     01 October 2009 by cnwrs2

Purpose:     Finds where the button is and returns the idx in the array
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpControl	: CMUI_ToolbarControl;
	foundPos,
	idx			: Integer;
	
begin

	if _leftControl then
		foreach tmpControl in self.allLeftControls do
			idx := idx + 1;
			if tmpControl.isKindOf(CMUI_ToolbarButton) and
			   tmpControl.CMUI_ToolbarButton.userObjectName  = _btnName then
				foundPos := idx;
			endif;
		endforeach;
	else
		foreach tmpControl in self.allRightControls do
			idx := idx + 1;
			if tmpControl.isKindOf(CMUI_ToolbarButton) and
			   tmpControl.CMUI_ToolbarButton.userObjectName  = _btnName then
				foundPos := idx;
			endif;
		endforeach;
	endif;

	return foundPos;

epilog

end;</source>
        <Parameter name="_btnName" type="String"/>
        <Parameter name="_leftControl" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
