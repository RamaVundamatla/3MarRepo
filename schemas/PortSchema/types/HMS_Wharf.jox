    <JadeMethod name="calTotalLengthOfBerths" id="a5a69ef2-faea-4e91-a3cf-f9773f9e599d">
        <source>calTotalLengthOfBerths():Integer;
//--------------------------------------------------
// Created:	31 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	totLength : Integer;
	berth : HMS_Berth;
	realWharf : HMS_Wharf;
begin
	
	if self.isTransient then
		realWharf := self.pxyGetRealObject();
	else
		realWharf := self;
	endif;
	if realWharf &lt;&gt; null then	
		foreach berth in realWharf.allBerths do
			totLength := totLength + berth.length;
		endforeach;
	endif;
	return totLength;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
