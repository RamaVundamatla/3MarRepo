	//strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+999+1+9'");
	strArray.add("TDT+20+VYPAR27945+1+++++:146::VSPAR27945'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230001+AP01:102:5+++4'");
	endif;
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("FTX+DAR++8'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;

	// cleanout transactions from previous test
	beginTransaction;
	camTaskHistory.erase(NORMAL_ERASE);
	objArray.purge;
	commitTransaction;
    
	// TEST 6 Needs Pretrip and Needs Wash (Reversed case of above) produce ONE Damage entry
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_NeedsPreTrip), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_NeedsWash), null);
	objArray.add(transObj);

	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	idx := 0;
	strArray.clear();
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+999+1+9'");
	strArray.add("TDT+20+VYPAR27945+1+++++:146::VSPAR27945'");
