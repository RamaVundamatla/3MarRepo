    <JadeMethod name="doResize" id="49171e77-240d-4a9b-a3a2-c4d96e5b1049">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.isBaseFormModal and (not self.isFirstActivateComplete) then
		// refer to comment in form activate method for why this is done
		return;
	endif;

	self.sptMain.top := self.frmToolbar.height;

	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="6702ff7a-4100-4f47-992e-201a0716b1e8">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myCurrentView := null;
	self.modalResult := MsgBox_Return_OK;
	unloadForm();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblAllClick" id="3c6be5b1-a677-4fbb-ab20-d313680d5f74">
        <updating/>
        <source>doTblAllClick(table: Table input) updating;
//--------------------------------------------------------------
//Created: 02 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theObject : Object;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	self.selectedRow := table.row;
	table.accessRow(table.row).selected := true;
	self.mySelectedItem := table.accessRow(table.row).itemObject.CMIF_TIObject;
	self.showSelectedItem();

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
