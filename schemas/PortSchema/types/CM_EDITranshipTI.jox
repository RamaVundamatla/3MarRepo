    </JadeMethod>
    <JadeMethod name="getRealBOLIn" id="175598a9-3b06-4f65-8e4b-cde42728d6dc">
        <source>getRealBOLIn( _terminal : CM_Terminal ) : CM_BOLIn;
//getRealBOLIn() : CM_BOLIn;			// cnwrl1 03/08/2010 PAR 24991 - what it was
//
// cnwrs1 22 mar 2010 par 23163
//
// 03/08/2010	cnwrl1		PAR 24991 - Optimise the EDI Tranship processing.

vars
//	terminal : CM_Terminal;				// cnwrl1 03/08/2010 PAR 24991 - what it was
	bolIn : CM_BOLIn;
	foundBOL : CM_BOLIn;
	voyage : CM_Voyage;
begin
	// cnwrl1 14/07/2010 PAR 23499 - start of coding
	// No point doing anything if there is no BOL supplied.
	if self.billOfLading = null then
		return null;
	endif;
	// cnwrl1 14/07/2010 PAR 23499 - end of coding
	
	// Improve the efficiency by passing in the terminal rather than getting it each time around the loops.
//	terminal := self.getTerminal;		// cnwrl1 03/08/2010 PAR 24991 - what it was
	
//	voyage := terminal.lookupVoyage(self.voyageCode, null, false); //cnwrs1 par23247 18 mar 2010 work in progress	// cnwrl1 09/06/2010 PAR 24299 - what it was
//	voyage := terminal.lookupVoyage(self.getVoyageCode(), null, false); //cnwrs1 par23247 18 mar 2010 work in progress	// cnwrl1 03/08/2010 PAR 24991 - what it was
	voyage := _terminal.lookupVoyage(self.getVoyageCode(), null, false); //cnwrs1 par23247 18 mar 2010 work in progress
	if voyage &lt;&gt; null then
		foreach bolIn in voyage.allBOLInByTypeStatusNumDT where bolIn.bolType = 5003 and bolIn.number = self.billOfLading do
			foundBOL := bolIn;
			break;
		endforeach;
	endif;
	return foundBOL;
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
