<Class name="WS_CargoTask" id="3546c877-a8f9-4b58-9e75-7f3d77eb122e">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="c7f108e1-c7f8-4866-97fa-02b52fb95df3">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="completedDate" id="dc5b5bbf-9bfa-485e-8057-e18b5f9aea72">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="completedDateUTC" id="ea1bbab1-9909-457d-a563-2863eac516e9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="64b71887-0c87-4c3c-9d34-082de0cccce1">
        <length>61</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="hasResources" id="ecae9d4d-08c0-4ec2-b8e7-944fd3c47afd">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isComplete" id="72201117-51b2-446a-aa34-7cbf4708ae6e">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isSet" id="e9fdbf65-c7e4-42f9-8c75-5a2d324147b9">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="remarks" id="eb421831-f8fb-4335-94d7-e7ae9cbab6de">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="requiredExtraInfo" id="aee75dac-eedb-40cc-bc03-1eb0f96701ae">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="1dabfbc2-3573-423b-bc88-78bcfcb2caa2">
        <updating/>
        <source>setProxyFromObject(_task: CM_ToDoTask) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2016	cnwmc5	Initial creation
10 Jul  2018    cnwma1	Bug 39560: JMT - "Damaged" flag cannot be reset by completing task using Cargo App
*/

vars
	lineStr	: String;
begin
	inheritMethod(_task);
	
	if _task.toDoTaskDescShort = null then
		lineStr := _task.toDoTaskDescDesc;
	else
		lineStr := _task.toDoTaskDescShort;
	endif;
	
	//self.description := lineStr;
	// change made to reflect full string description rather than code, 9/3/17
	self.description := _task.toDoTaskDesc.description;
	self.code := _task.toDoTaskDescCode;
	self.remarks := _task.remarks;
	if _task.status = STATUS_COMPLETE then	 //10.7.2018 cnwma1 TFS #39560
		self.completedDate := _task.dtLastUpdate.asStringForWebInterface;
	endif;
	self.requiredExtraInfo := _task.toDoTaskDesc.requiredExtraInfo;
	self.hasResources := _task.toDoTaskDesc.allResourceTypes.isNotEmpty();
	self.isComplete := _task.status = STATUS_COMPLETE;
	
epilog

end;</source>
        <Parameter name="_task" type="CM_ToDoTask"/>
    </JadeMethod>
</Class>
