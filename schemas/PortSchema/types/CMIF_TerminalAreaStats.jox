        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="totalNumPlanned" id="7a37e2f9-cb3e-4d3d-98d6-57949ccb23f2">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="totalNumQueued" id="976a5889-c83a-4ca2-b342-92c09084c484">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <JadeMethod name="canConvertToXML" id="5576bcb9-e56f-4d78-9fcb-64ac8ef67006">
