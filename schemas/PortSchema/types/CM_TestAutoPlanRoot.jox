    <JadeMethod name="addPlannedResult" id="d2e4085b-0f62-4cd1-bda5-499b77e9630d">
        <source>addPlannedResult(	_plannedLoc : CM_LocationsController;
					_myAllocationUsed : CM_YardAllocation;
					_myTrackedItem : CM_TrackedItem;
					_cmifYAPlanScenario  : CMIF_YAAutoPlanSenario;
					_myPrimeYardAllocation : CM_YardAllocation;
					_log : StringArray512;
					_splitLocations : String
					) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	planned : CM_TestAutoPlanPlanned;

begin

	create planned transient;
	planned.setBaseDetails(	_myTrackedItem,	//_myTrackedItem : CM_TrackedItem;
							_cmifYAPlanScenario,
							_myPrimeYardAllocation,	//_myPrimeYardAllocation : CM_YardAllocation;
							_log,	//_log : StringArray512;
							self	//_myTestAutoPlanRoot : CM_TestAutoPlanRoot
							);
							
	planned.setSpecific(	_plannedLoc,	//_myPlannedLocation : CM_LocationsController;
							_myAllocationUsed,	//_myAllocationUsed : CM_YardAllocation;
							_splitLocations	//_splitLocations : String
							);

epilog

end;</source>
        <access>protected</access>
