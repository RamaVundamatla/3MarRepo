        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doISOTypeChange" id="bc5c5433-e3e1-4d5f-b9da-501973eda4cf">
        <updating/>
        <source>doISOTypeChange() updating, protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
23 July 2009	cnwdap1	Initial creation
18/05/2010		cnwcs5	par 24178 - use correct default tare weight method
						Also used local variable instead of using self.myProxyTrackedItem and self.cmbCommodity.getObject
27/03/2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
01/10/2025		navdap1	MTN-36141 AAT | Rotabox Creation (EDI/API/Manual)
*/

vars
	isoType 	: CM_ISOType;
	proxy		: CM_TrackedItem;	// par 24178
	id			: String;			// par 24178
	master		: CM_TIMaster;		// par 24178
	commodity	: CM_Commodity;		// par 24178
	tareWeight	: Decimal [14, 4];	// par 24178
	
begin
	// MTN-36141 If ISO Type is Rotatable, show contents cargo type and cargo sub type combos, otherwise hide them
	isoType := self.cmbISOType.getObject.CM_ISOType;
	if isoType &lt;&gt; null and isoType.isRotatable() then
		self.decideEntDefType(true);
	else
		self.decideEntDefType(not self.cmbContentsCargoType.isHidden);
	endif;
	
	if self.isPreNoteForm or  self.isOnshipForm 
	or self.isMakeLCLForm  then // PAR 35740	
		proxy	:= self.myProxyTrackedItem;		// par 24178 cnwcs5 18/05/2010
		if proxy &lt;&gt; null then
			isoType := self.cmbISOType.getObject.CM_ISOType;
			
			// add null isoType test to allow for general cargo
			if isoType &lt;&gt; null and proxy.usesISOType and not proxy.isKindOf(CM_BreakBulk) then
				// set ISO type on the proxy - one of few propertys that actually get set on proxy prior to save
				proxy.setISOType(isoType.code);
			endif;
			// if we have a TI Master then the tare weight on the master overrides the tare weight for the
			// new iso type
			id		:= self.txtCargoID.getString;	// par 24178 cnwcs5 18/05/2010
			master 	:= self.findTIMaster (id) ;		// par 24178 cnwcs5 18/05/2010
			
			if master = null or master.tWeight = null then
				// set id on the proxy - so we can use methods on tracked item to get default tare weight
				proxy.zSetPxyId (id);										// par 24178 cnwcs5 18/05/2010
				// default weight will come from ti master/cargo range/iso type if it has not already been set
				// on the proxy
				tareWeight := proxy.getTareWeight;							// par 24178 cnwcs5 18/05/2010
				
				self.tblTareWeight.setValueDefault(tareWeight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
				
				commodity := self.cmbCommodity.getObject.CM_Commodity;		// par 24178 cnwcs5 18/05/2010
				
				if commodity &lt;&gt; null and commodity.code = "MT" then			// par 24178 cnwcs5 18/05/2010
					// total weight is the same as tare weight for any empty
					self.tblTotalWeight.setValueDefault(tareWeight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
				endif;
			else
				// no change to tare weight as a result of changing iso type
			endif;
		endif;
	//+cnwml2 PAR24904	
	elseif self.isFlexiGateForm then
		isoType := self.cmbISOType.getObject.CM_ISOType;
		if isoType &lt;&gt; null then	
			if isoType.myCargoType.useTareCargoWeight then
				if self.tblTareWeight.getConvertedValue = null then							// PAR #31155
					tareWeight := isoType.tareKilos;
					self.tblTareWeight.setValueDefault(tareWeight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadBOLItems" id="1b73b51a-ab81-445f-962d-6969ce0e9c9b">
        <source>doLoadBOLItems(_bolDetail : CM_BOLDtl) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2009	cnwdap1	Initial creation

*/

vars
	cmb		: CMUI_FieldComboBox;
begin
	cmb := self.cmbBOLItem;
	// don't reload if the booking reference has not changed
	//if cmb.listIndex &lt;&gt; -1 and _brItem &lt;&gt; null and _brItem.myBookingReference = cmb.getObject.CM_BookingRefItem.myBookingReference then  
	//	return;
	//endif;
	cmb.clear;
	if _bolDetail &lt;&gt; null then
		cmb.listCollection(_bolDetail.myBOL.allBOLDtls, true, 0);
		cmb.setForObject(_bolDetail);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bolDetail" type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="doLoadBookingRefItems" id="62d6f32f-c83b-4d55-8e41-1d782c4298a4">
        <source>doLoadBookingRefItems(_brItem : CM_BookingRefItem) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/07/2009	cnwdap1	Initial creation
*/

vars
	cmb		: CMUI_FieldComboBox;
	brItem	: CM_BookingRefItem;
begin
	cmb := self.cmbBRItem;
	// don't reload if the booking reference has not changed
	if cmb.listIndex &lt;&gt; -1 and _brItem &lt;&gt; null and _brItem.myBookingReference = cmb.getObject.CM_BookingRefItem.myBookingReference then  
		return;
	endif;
	cmb.clear;
	if _brItem &lt;&gt; null then
		cmb.listCollection(_brItem.myBookingReference.allBookingRefItems, true, 0);
		cmb.setForObject(_brItem);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="doNext" id="a5142e40-8765-4630-bc09-6e5c3b8b4ecd">
        <updating/>
        <source>doNext() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/09/2009	cnwjk3	Initial creation
29/03/2010	cnwdap1	PAR #22604 Check for duplicate attachment IDs
18/10/2017	jlgma1	Initial creation TFS #7196 PEN - Weight field after Save -Next on Pre-Note
*/
vars
	string 	: String;
	dupId : String;
	control : Control;
	idx 	: Integer;
begin

	//30 Oct 2013	NDL	Par 31829
	if self.isAttachmentForm then
		dupId := self.findAnyDuplicateId();
		if dupId &lt;&gt; null then
			string := app.getErrorString1( Cargo_already_used, dupId);
			app.msgBox(string, app.getErrorString(Error), MsgBox_OK_Only);
			return;
		endif;
	endif;
	
	if self.isFlexiGateForm then
		self.doNextFlexiGateForm();
	elseif self.isPreNoteForm or
	    self.isOnshipForm //epr par 34945 20/10/14
		or self.isOnsiteForm then // TFS 2318
		// JIRA 12384 21OCT2024 NAVAB1 self.doNextPreNoteForm();
		self.doNextPreNoteFormDLRT(); // JIRA 12384 21OCT2024 NAVAB1
	elseif self.isRailPreNoteForm then
		self.doNextRailPreNoteForm();
	elseif self.isMakeLCLForm then
		self.doNextMakeLCL();
	endif;
	
	foreach idx in 1 to self.controlCount do  // 18.10.2017 cnwma1 TFS #7196
		control := self.controls(idx);
		if control.isKindOf(CMUI_MeasurementTable) then
			control.CMUI_MeasurementTable.column :=1;
		endif;
	endforeach;
	self.txtCargoID.setFocus();
	
	//cnwmc5 - 30 Oct 2013 - PAR 32666
	self.resetHazardTable();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNextFlexiGateForm" id="bf9d2bf4-f6eb-43a9-8519-88b9faa728b2">
        <updating/>
        <source>doNextFlexiGateForm() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/09/2009	cnwjk3	Initial creation
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
06/04/2020  navhl20 TFS 52777 EUP - INT - Generic API: record-scan
12/07/2022	navmd1	TFS 52777 Tidy up/review code
*/
vars
	isoType : CM_ISOType;
	
begin
	if self.doSaveFlexiGateForm(true) then
		self.resetForm();
		self.txtCargoID.setValue(null);
		
		//+cnwml2 PAR21795
		isoType := self.cmbISOType.getObject.CM_ISOType;
		//self.txtNettWeight.setValue(null);								// PAR #31155
		//self.txtTotalWeight.setValue(null);								// PAR #31155
		self.tblNettWeight.setValueDefault(null);							// PAR #31155
		self.tblTotalWeight.setValueDefault(null);							// PAR #31155
		if isoType &lt;&gt; null then
			//self.txtTareWeight.setValue(isoType.tareKilos);				// PAR #31155
			self.tblTareWeight.setValueDefault(isoType.tareKilos.String);	// PAR #31155
		else
			//self.txtTareWeight.setValue(null);							// PAR #31155
			self.tblTareWeight.setValueDefault(null);						// PAR #31155
		endif;
		self.myTI := null;
		self.myMainForm.myAssistant.populateScanDataFields4Cargo(self.myCurrentVehicleVisit, self.cmbType.getEmbeddedControl().ComboBox,
			self.txtCargoID.getEmbeddedControl().TextBox, self.txtAlternativeId.getEmbeddedControl().TextBox, self.sealTypes, self.sealValues);		// TFS 52777
		self.restoreSealControlValues();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNextMakeLCL" id="127798b8-1d79-4371-a240-282026b1d9e2">
        <updating/>
        <source>doNextMakeLCL() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2013	cnwndl1	Initial creation	Par 32854

*/

vars
	
begin
	if self.doSaveMakeLCLForm() then
		self.resetForm();
		self.txtCargoID.setValue(null);
		
		self.tblNettWeight.setValueDefault(null);								// PAR #31155
		self.tblTotalWeight.setValueDefault(null);								// PAR #31155
		
		self.myTI := null;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNextPreNoteForm" id="1b40f454-ca8e-4601-a053-28650afe1e03">
        <updating/>
        <source>doNextPreNoteForm() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/09/2009	cnwjk3	Initial creation
24/02/2010	cnwdap1	PAR #21827 Don't delete myIntFacePreNote if we're an attachment form
27/03/2013	cnwdap1	PAR #31155 CCNS SFW 1321 Imperial Measurements
13/11/2019	jlgsl4	TFS 47373 - PEN - Save-Next prevents use of Remarks Additional
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars
	isoType : CM_ISOType;	
    newId : String;
	unit : String;
begin
	if self.doSavePreNoteForm() then
		self.doNextPreNoteResetForm();
		/*
		self.resetForm();
		self.txtCargoID.setValue(null);
		
		// TFS 3218
		if self.myTerminal.getConfig(AutoGenIDsForOnShip).Boolean then
			//newId := self.myTerminal.generateNextCargoId(false,true); // 1 Sept 2022 navmv20 TFS 54610
			newId := self.myTerminal.generateNextCargoId(false,true,null); //1 sept 202 navmv20 TFS 54610
			self.txtCargoID.setValue(newId); 
		endif;
		
		if not self.isAttachmentForm then	// PAR #21827
			delete self.myIntFacePreNote;
		else								// PAR #21827
			self.myIntFacePreNote := null;	// PAR #21827	Clear the reference for the next item
		endif;								// PAR #21827
		
		//+cnwml2 PAR21795
		isoType := self.cmbISOType.getObject.CM_ISOType;
		//24 Jul 2017	NDL	TFS 5509
		unit := self.tblNettWeight.getMeasurementUnit;
		if unit &lt;&gt; null then
			self.tblNettWeight.setValues( Space &amp; unit );
		else
			self.tblNettWeight.setValueDefault(null);								// PAR #31155
		endif;
		
		//24 Jul 2017	NDL	TFS 5509
		unit := self.tblTotalWeight.getMeasurementUnit;
		if unit &lt;&gt; null then
			self.tblTotalWeight.setValues( Space &amp; unit );
		else
			self.tblTotalWeight.setValueDefault(null);								// PAR #31155
		endif;
		
		if isoType &lt;&gt; null then
			self.tblTareWeight.setValueDefault(isoType.tareKilos.String);		// PAR #31155
		else
			self.tblTareWeight.setValueDefault(null);							// PAR #31155
		endif;
		self.myTI := null;
		*/
	endif;
	self.createNewProxy(); // TFS 47373 - set up proxy so next PreNote's details can be entered
	self.lblAdditionalDet.caption := ''; // TFS 47373 - blank out 'Click to View Details'
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNextPreNoteFormDLRT" id="b6f4599d-8fab-4d54-ba57-620f0508b3a9">
        <updating/>
        <source>doNextPreNoteFormDLRT() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
JIRA 12384 21OCT2024 NAVAB1: EUP - DeadLocks When Creating Prenotes
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone
*/

vars
	localCaption : String;
	result : Boolean;
begin
	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(250, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	while true do
	
		if self.doSavePreNoteForm() then
			self.doNextPreNoteResetForm();
			self.createNewProxy(); 
			self.lblAdditionalDet.caption := ''; 

			return;
		endif;
		
		//if we did NOT have a dead lock, just bail out.
		if app.myPassport.noTrxReplayAllowed() then	
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(Gate), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;
		
		self.updateCaptionDeadlockRetry(localCaption);	
	endwhile;

	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818
	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doNextPreNoteResetForm" id="9e050980-c838-459c-a6b1-ad7418d589e3">
        <updating/>
        <source>doNextPreNoteResetForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
JIRA 12384 21OCT2024 NAVAB1: EUP - DeadLocks When Creating Prenotes

*/

vars
	isoType : CM_ISOType;	
    newId : String;
	unit : String;
begin
		self.resetForm();
		self.txtCargoID.setValue(null);
		
		// TFS 3218
		if self.myTerminal.getConfig(AutoGenIDsForOnShip).Boolean then
			//newId := self.myTerminal.generateNextCargoId(false,true); // 1 Sept 2022 navmv20 TFS 54610
			newId := self.myTerminal.generateNextCargoId(false,true,null); //1 sept 202 navmv20 TFS 54610
			self.txtCargoID.setValue(newId); 
		endif;
		
		if not self.isAttachmentForm then	// PAR #21827
			delete self.myIntFacePreNote;
		else								// PAR #21827
			self.myIntFacePreNote := null;	// PAR #21827	Clear the reference for the next item
		endif;								// PAR #21827
		
		//+cnwml2 PAR21795
		isoType := self.cmbISOType.getObject.CM_ISOType;
		//24 Jul 2017	NDL	TFS 5509
		unit := self.tblNettWeight.getMeasurementUnit;
		if unit &lt;&gt; null then
			self.tblNettWeight.setValues( Space &amp; unit );
		else
			self.tblNettWeight.setValueDefault(null);								// PAR #31155
		endif;
		
		//24 Jul 2017	NDL	TFS 5509
		unit := self.tblTotalWeight.getMeasurementUnit;
		if unit &lt;&gt; null then
			self.tblTotalWeight.setValues( Space &amp; unit );
		else
			self.tblTotalWeight.setValueDefault(null);								// PAR #31155
		endif;
		
		if isoType &lt;&gt; null then
			self.tblTareWeight.setValueDefault(isoType.tareKilos.String);		// PAR #31155
		else
			self.tblTareWeight.setValueDefault(null);							// PAR #31155
		endif;
		self.myTI := null;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
