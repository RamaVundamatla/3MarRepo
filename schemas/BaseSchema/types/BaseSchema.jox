//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);

	self.cnEcInitializeBaseSchema();
	create self.myReportAppHandler transient;
	
	if self.applicationType = ApplicationType_Non_GUI then
		self.myReportAppHandler.doStart();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcInitializeSecurity" id="adac8e94-20f4-4a5a-87f0-1a918210fbbc">
        <source>cnEcInitializeSecurity() protected;
// --------------------------------------------------------------------------------
// Created:		19 May 2003 by cnwdad1
//
// Changed On	Changed By	Reason
