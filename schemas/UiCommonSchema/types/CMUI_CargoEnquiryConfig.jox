    <JadeMethod name="doLoad" id="1ced109d-46c2-4aaf-bbef-b9dfac4a048a">
        <updating/>
        <source>doLoad() updating, protected;
// load 
vars
	returnValue	: Integer;
	filePath	: String;
	file		: File;
	loadAgent	: CM_ExtractLoadAgent;
begin
	// from 28323 load problems, prompt for save first if form has changed
	if self.isFormChanged then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;
	// pass null path so that opens where last open at
	filePath := app.getFilePath(null, "*.csv", null, true);
	if filePath = null then
		return;
	endif;
	
	if filePath.toLower.pos(".csv", 1) &lt;= 0 then
		filePath := filePath &amp; ".csv";
	endif;
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := filePath;
	file.mode := File.Mode_Input;
	
	if not file.tryOpen() then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);
		return;
	endif;

	delete self.myProxyUserCargoType;		// 28323 to avoid conflict with load proxy creation Nov 2011
	self.isFormChanged := false;
	
	create loadAgent;
	loadAgent.loadUserCargoConfig(file);
	
	if app.myPassport.trxCompletedOK() then
		self.clearErrorWarnings();
		global.beep();
	else
		returnValue	:= app.showErrorWarningDialog("User Enquiry Configuration Load", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors() and returnValue = IDOK then
			app.myPassport.warningsAcknowledged	:=	true;
		endif;
		
		self.setAllErrorWarnings(app.myPassport);
	endif;

	// 28323 Nov 2011 recreate the current proxy and refresh the form from it
	self.showTabsForCargoType(false);

epilog
	if file &lt;&gt; null then
		file.close();
		delete file;
	endif;
	delete loadAgent;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRenameTab" id="1ed466d3-0b2d-4aae-9495-56e27f4839ad">
        <updating/>
        <source>doRenameTab() updating, protected;

vars
	row		: Integer;
	tabForm : CMUI_CargoEnqConfigEditTab;
begin
	if self.myCargoType = null then
		return;
	endif;
	
	create tabForm transient;
	tabForm.centreWindow;
	tabForm.myUserConfigTab := self.myUserConfigTab;
	tabForm.myUserCargoType := self.myProxyUserCargoType;
	tabForm.myConfigForm := self;
	tabForm.showModal;
	
	if tabForm.cancelled then
		return;
	endif;

	self.myUserConfigTab := tabForm.myUserConfigTab;
	self.setChanged();
	row := self.tblTabs.row;
	if row &gt; self.tblTabs.fixedRows and 
	   row &lt;= self.tblTabs.rows then
		self.tblTabs.setCellText(row, 1, self.myUserConfigTab.description);
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="03bf8f9f-811c-452e-8e8f-6543e586e9f8">
        <updating/>
        <source>doSave() updating;

vars
	theReturn	: Integer;
begin
	if self.myCargoType = null then
		return;
	endif;

	if not self.doValidate() then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateUser_CargoType(self.myProxyUserCargoType, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			delete self.myProxyUserCargoType;
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog("Cargo Enquiry Config", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	self.doCancel();
end;
</source>
    </JadeMethod>
    <JadeMethod name="doTabsDown" id="822414ed-a747-4efd-bfb7-eaff51ec1bd8">
        <updating/>
        <source>doTabsDown() updating, protected;

vars
	row	: Integer;
	uctab	: CM_UserConfigTab;
	table	: CM_DataTable;
begin
	table := self.tblTabs;
	row := table.row;
	if row &lt;= table.fixedRows or 
	   row &gt;= table.rows then
		return;
	endif;

	uctab := table.accessRow(row).itemObject.CM_UserConfigTab;
	self.myProxyUserCargoType.moveTab(uctab, false);
	
	self.moveTabItem(row, false);
	self.recolourTable(self.tblTabs);
	self.enableTabsArrows();
end;
</source>
