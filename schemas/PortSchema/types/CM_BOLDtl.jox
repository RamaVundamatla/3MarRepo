	self.remarks := _ediTI.remarks;
	self.weight := _ediTI.weight;
	self.width := _ediTI.width;
	self.volume := _ediTI.volume;			//cnwmc5 - 14 May 2014 - PAR 34149
	self.hsCode := _ediTI.hsCode;			//jlika1 TFS 55586
end;
</source>
