    <JadeMethod name="doBayPlanMakeActual" id="825e8a61-acff-4ce9-a032-65bf3afcec30">
        <updating/>
        <source>doBayPlanMakeActual() updating;
//----------------------------------------------------------------
//	Created:	10 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 27 Mar 2018	jlgrs1	TFS 37419 - QNS Sundry
//
vars
	ediData		: CM_EDIDataBayPlan;
	theReturn,
	theIndex	: Integer;
	voyage		: CM_Voyage;
	passport	: CM_Passport;
	mergeOptionsForm : CMUI_EDIBayPlanMerge;
	clearDetails : Boolean;
	mergeRetainAllCargo : Boolean; //July 2008 cnwrs1 Par 17595 
	mergeRetainEDICargo : Boolean;
	mergeRetainManCargo : Boolean;
	mergeRetainNoCargo : Boolean;
	mergePlanning : Boolean; 
	completed, unactioned, partCompleted, exportCargo : Integer;
	hasPlanning : Boolean;
	hasCargo : Boolean;
begin
//app.myPassport.myActivityCapture.startCaptureDebugMisc('Voyage make actual');
	passport := app.myPassport;
	
	if self.myCurrentObject = null or (not self.myCurrentObject.isKindOf(CM_EDIDataBayPlan)) then
		return;
	endif;

	ediData := self.myCurrentObject.CM_EDIDataBayPlan; 
	
	voyage := self.myTerminal.lookupVoyage(ediData.voyageCode, null, false);
	
	if voyage = null then
		return;
	endif;
	
	if ediData.myBayPlanController &lt;&gt; null and 
	   voyage.allEDIBayPlans.includes(ediData.myBayPlanController) then
		//continue
	else
		return;
	endif;

// ccms 1022 cnwrs1 june 2006	
	voyage.getJobTotals(completed, unactioned, partCompleted, exportCargo);
	if completed &gt; 0 or partCompleted &gt; 0 and exportCargo &gt; 0 then
		app.msgBox("The current bay plan cannot be made actual because the current voyage" &amp; CrLf &amp; 
				   "has jobs that have been worked.  You will need to either delete any" &amp; CrLf &amp; 
				   "worked jobs or create a new voyage.", "EDI Update", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
//	if not voyage.allVoyageJobs.isEmpty then
//		app.msgBox("The current bay plan cannot be made actual because the current voyage" &amp; CrLf &amp; 
//				   "has jobs that may have been worked.  You will need to either delete all" &amp; CrLf &amp; 
//				   "jobs or create a new voyage.", "EDI Update", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
//		return;	
//	endif;

	hasCargo := not voyage.allOnshipTIsByCargoTypeId.isEmpty;
	hasPlanning := voyage.hasVoyageStartedPlanning();
	if not hasCargo and
	   not hasPlanning then
		theReturn := app.msgBox("Make EDI Bay Plan " &amp; ediData.myBayPlanController.description &amp; " Actual?", "EDI Update", MsgBox_Yes_No);
		if theReturn &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	else
		mergeOptionsForm := app.loadForm(CMUI_EDIBayPlanMerge, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_EDIBayPlanMerge;
		if mergeOptionsForm = null then
			return;
		endif;
		mergeOptionsForm.hasCargo := hasCargo;
		mergeOptionsForm.hasPlanning := hasPlanning;
		if mergeOptionsForm.showModal() &lt;&gt; IDOK then
			return;
		endif;
		// now get input options
		clearDetails := mergeOptionsForm.chkClear.value;
		if not clearDetails then
			mergeRetainAllCargo := mergeOptionsForm.optRetnAllCargo.value;
			mergeRetainEDICargo := mergeOptionsForm.optRetnEDICargo.value;
			mergeRetainManCargo := mergeOptionsForm.optRetnManCargo.value;
			mergeRetainNoCargo := mergeOptionsForm.optRetnNoCargo.value;
			mergePlanning := mergeOptionsForm.optRetainPlannin.value;
		endif;
//		theReturn := app.msgBox("Merge EDI Bay Plan " &amp; ediData.myBayPlanController.description &amp; Cr &amp; " Into Actual?", "EDI Merge", MsgBox_Yes_No);
	endif;
// ccms 1022 cnwrs1 june 2006	
//	if theReturn = MsgBox_Return_Yes then
	app.mousePointer := Window.MousePointer_HourGlass;
	
	//show progress dialog
	
	while true do
		app.myTrxUA.trxSetEDIAsActualBayPlan(voyage, ediData.myBayPlanController, clearDetails, mergeRetainAllCargo, mergeRetainEDICargo, mergeRetainManCargo, mergeRetainNoCargo, mergePlanning, passport);
		
		if passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			app.myTrxUA.trxSetEDIDataStatus(ediData, CM_EDIFile.EDI_STATUS_MADE_ACTUAL);
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog('EDI Set To Actual', passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if passport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
//	endif;
	ediData.causeEvent(EVENT_EDI_EDIDATA_UPDATE, true, ediData);
//	self.updateTblData(ediData);		// cnwdad1 31/08/2010 - PAR #25547.
epilog
	delete mergeOptionsForm;
	app.mousePointer := Window.MousePointer_Default;
//	app.myPassport.myActivityCapture.stopCaptureDebugMisc();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="2fe6de8a-414b-408b-bd41-2829a92fcbe6">
        <updating/>
        <source>doCancel(): Boolean updating;
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	return self.doCancelEDIDataEdit();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCancelEDIData" id="3b086dec-38e9-4cff-9ef9-54e9052fa332">
        <updating/>
        <source>doCancelEDIData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
26 Oct 2022 navvt20 ChangeRequest 55084: EUP - EDI Administration Usability Requirements
20 Mar 2023 navra1 	TFS 57124 - A cancelled EDI should not be editable, disable the edit button as soon as user
								cancels the EDI
*/

vars
	ediData	: CM_EDIData;
	passport: CM_Passport;
	result	: Integer;
begin
	passport := app.myPassport;
	ediData := self.myCurrentObject.CM_EDIData;
	if ediData = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
	endif;
	if not ediData.canBeCancelled then // 26 October 2022 navvt20 TFS 55084
		app.raiseCMException(EDIFile_Incorrct_Status_Cancel, null, null);
		return;
	endif;
	
	//disable the edit button on the form as soon as he cancels the EDI - a cancelled edi should not be editable
	self.btnEditTV.enabled := false;	//navra1 - TFS 57124 - 20th Mar 2023
	
	while true do
		app.myTrxUA.trxSetEDIDataStatus(ediData, CM_EDIFile.EDI_STATUS_CANCELLED);
		
		if passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString (EDI_Set_To_Cancel), passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if passport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	if app.myPassport.trxCompletedOK then	// 25 Oct 2022 navvt20 TFS 55084
		ediData.causeEvent(EVENT_EDI_EDIDATA_UPDATE, true, ediData);
	endif;	// 25 Oct 2022 navvt20 TFS 55084
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCancelEDIDataEdit" id="93653933-901a-4da8-98d5-e1806aa10a3e">
        <updating/>
        <source>doCancelEDIDataEdit(): Boolean updating; 
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 05/09/2012	cnwcs5	par 29842 - performance
vars
	changedCol,
	intRow	: Integer;
	str		: String;
	obj		: Object;
	rtValue : Integer;
	index : Integer;
	tbl : CM_DataTable;
begin
	//go through any
	if self.tiDataHasChanged then
		// cnwrs1 mar 2006 par 9626 can lose changes 
		rtValue := app.msgBox(app.getErrorString1(ConfirmCancel, 'some data'),"Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if rtValue = MsgBox_Return_No then
			return self.tiDataHasChanged;
		endif;
		
		//Check for changed rows on all of the cloned tables MES 1011 cnwgb1 26.9.09
		index := 0;
		while (true) do
			tbl := self.tblEDITI.getControl(index);
			if tbl = null or not tbl.visible then 
				break;
			endif;
			changedCol := tbl.getColumnByRowName(ETRow_HasChanged);
			foreach intRow in 2 to tbl.rows do
				if tbl.accessCell(intRow, changedCol).text = self.HAS_CHANGED then
					obj := tbl.accessRow(intRow).itemObject;
					//str := self.tblEDITIDisplayRow(tbl, obj.CM_EDITrackedItem);
					str := obj.CM_EDITrackedItem.getAttributeStringForDefArray(tbl.allTblDataEntRows);	// par 29842 Sep 2012
					tbl.accessCell(intRow, 1).text 	:= str;
				endif;
			endforeach;
			index := index+1;
		endwhile;
		self.tiDataHasChanged := false;
	endif;
	
	self.mode := Mode_View;
	self.setControls();
	return self.tiDataHasChanged;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCancelLoad" id="5e534e66-5313-477f-ab34-41be2126ad10">
        <updating/>
        <source>doCancelLoad()updating;
//----------------------------------------------------------------
//	Created:	29 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
			
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; "Deleting temporary objects." &amp; Cr &amp; "Please wait...";
	self.frmModalDialog.visible := true;
	
	app.doWindowEvents(0);
	
	self.mode := Mode_View;
	self.setControls();	

	self.setEDIFileInError(null);

epilog
	self.closeModalDialog();
end;</source>
    </JadeMethod>
    <JadeMethod name="doClickAddReplace" id="598d46c9-89ff-4bfd-a81f-121d466644cd">
        <source>doClickAddReplace();
//----------------------------------------------------------------
//	Created:	06 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	colTag		: String;
	find		: String;
	replace		: String;
	selectedLinesOnly,
	fullWord	: Boolean;
	rowPointer	: Integer;
	
begin
	colTag		:=	self.tblFindReplace.getValue(1).String;
	
// cnwdad1 11/04/2006 - If no colTag is found, then don't do anything!
	if colTag = null then
		return;
	endif;
	
	find		:=	self.tblFindReplace.getValueByName(ETRow_Find).String;
	replace		:=	self.tblFindReplace.getValueByName(ETRow_ReplaceWith).String;
	fullWord	:=	self.tblFindReplace.getValueByName(ETRow_FullWordOnly).Boolean;
	selectedLinesOnly := self.tblFindReplace.getValueByName(ETRow_SelectedLines).Boolean;
	rowPointer	:=	self.tblMultiReplace.addItem(colTag &amp; Tab &amp; find &amp; Tab &amp; replace &amp; Tab &amp; fullWord.String &amp; Tab &amp; selectedLinesOnly.String);
	self.tblMultiReplace.accessRow(rowPointer).backColor	:=	LightRed;
	
	//reset the replace field
	self.tblFindReplace.setValueByName(ETRow_ReplaceWith, null);
end;</source>
    </JadeMethod>
    <JadeMethod name="doClickRemoveReplace" id="2c70d5af-4cf8-4577-a0ce-c717e785b44c">
        <source>doClickRemoveReplace(_all: Boolean);
//----------------------------------------------------------------
//	Created:	06 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intRow	: Integer;
begin
	
	if _all then
		foreach intRow in 2 to self.tblMultiReplace.rows do
			self.tblMultiReplace.rows := 1;	
		endforeach;
	else	//just the current row
		intRow := self.tblMultiReplace.row;
		
		if intRow &gt; 1 then
			self.tblMultiReplace.removeItem(intRow);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="17b832af-37c8-4d1f-a3e4-b7c9a0d9e91c">
        <updating/>
        <source>doClonedMenuClickSpecial(_menuItem: MenuItem input) updating, protected;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj	: Object;
begin

	obj := _menuItem.userObject;
	
	if CM_FileFormatEDI.hasInstance(obj) then
		self.doMnuFormatClick(obj.CM_FileFormatEDI, _menuItem);	
		return;
	endif;

	inheritMethod(_menuItem);

	
end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDBExtract" id="f8d72ad8-16a7-4d5c-828f-fdf1d2bc8b1a">
        <updating/>
        <source>doDBExtract( _mode : Integer; _ediData : CM_EDIData ) updating;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	extractForm		: CMUI_EDIDBExtract;
begin
	create extractForm;
	
	extractForm.mode := _mode;
	extractForm.setAssistantAndTerminalRefs(self.myAssistant, self.myTerminal);
	extractForm.setEDIData(_ediData);
	extractForm.setEDIAgent(self.myEDIAgent);
	extractForm.showModal;
	
	if extractForm.modalResult &lt;&gt; IDOK then
		return;
	endif;
epilog
	delete 	extractForm;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="doDBLoadEDIDataMulti" id="01cbd620-b16b-47b8-ae08-37f9267c1dc6">
        <updating/>
        <source>doDBLoadEDIDataMulti()updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		03 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 27/08/2009 	cnwsh3 		CCMS SFW1044 - AMS requirement to load multiple Customs Message Files.
// 02 Aug 2012	cnwcs5		par 30136 - change usage of loadEDIDb _ediData parameter
// 02 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//----------------------------------------------------------------------
vars
	table		: CM_DataTable;		// par 30136 Aug 2012
	passport 	: CM_Passport;

	objArray 	: CM_ObjectArray;
 	valid, mergeCargo	: Boolean;
	object 		: Object;
	ediData 	: CM_EDIData;
	cmifMonitor : CMIF_Monitor;
	status		: Integer;			// par 30136 Aug 2012
begin
	passport 	:= app.myPassport;
	table		:= self.tblData;	// par 30136 Aug 2012
	
	if table.allSelectedObjects.size = 0 then
		return;
	endif;
	
	create objArray transient;
	
	table.allSelectedObjects.copy(objArray);

	foreach object in objArray do 
		valid 	:= true;
		ediData := object.CM_EDIData;
		
		if ediData = null then
			return;
		endif;
		
		app.mousePointer := MP_HOURGLASS;
		
		self.initModalDialog();
		
		self.pbProgressBar.visible 		:= false;
		self.lblModalMessage.height 	:= 40;
		self.lblModalMessage.caption 	:= Cr &amp; "Loading EDI data." &amp; Cr &amp; "Please wait...";
		self.frmModalDialog.visible 	:= true;
		
		app.doWindowEvents(0);
		
		if passport.myCMIFMonitor = null then
			create cmifMonitor transient;
			cmifMonitor.myParent := self;
			passport.setMyCMIFMonitor(cmifMonitor);
		endif;
		
		//Note: Multi load process will ignore already loaded files.
		if self.tryLock(ediData, Share_Lock, Session_Duration, LockTimeout_Immediate) then
			status	:= ediData.status;
			
			if status = CM_EDIFile.EDI_STATUS_VERIFIED or
				status = CM_EDIFile.EDI_STATUS_VERIFYING or 		// cnwrs1 18 mar 2010 so you can still continue
				status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or
				status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS or
				status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then // cnwgb1 PAR 21881 CCMS 1906 21.12.09
				//We're still true so far.......
				valid := true;	
			else
				// We have verified yet.
				valid := self.myEDIAgent.verifyEdiData(ediData);
			endif;
		else
// 02 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
			app.raiseCMException(Objects_locked, null, ediData);
		endif;
		
		if valid then
			passport.warningsAcknowledged 	:= true;
			app.mousePointer 				:= MP_HOURGLASS;
			
			self.myEDIAgent.loadEdiDb(null, ediData, mergeCargo);
		endif;
		
	endforeach;
	
	if self.hasVerifyErrorsToShow (ediData) then		// par 30136 Aug 2012, par 27392 13 Apr 2011
		self.showVerifyErrors(ediData);			// par 27392 13 Apr 2011
	else
		self.mode := self.Mode_View;
		
		self.setControls();
		self.clearErrorWarnings();
		
		self.staMain.caption := app.getErrorString(DBLoadSuccessful);
	endif;
epilog
	self.unlock(ediData);
	self.closeModalDialog();
	
	delete objArray;
	delete cmifMonitor;
	
	passport.setMyCMIFMonitor(null);
	
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDBLoadEDITIs" id="1178094c-d6b6-4322-8283-af7e06f94891">
        <updating/>
        <source>doDBLoadEDITIs()updating;
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 02 Aug 2012	cnwcs5	par 30136 - change usage of loadEDIDb _ediData parameter
//14 Jan 2016	cnwrs1	Par 37289 Out of Seq should be able to be dbloaded and verified
// 02 Mar 2018	jlgrs1	TFS 37418 - QNS Verify locking
// 20 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
// 27 Mar 2018	jlgrs1	TFS 37419 - QNS Sundry
// 02 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// 06 May 2024	naviv1	TFS 63174 - EUP* | FR - 54084 CallOff Work Order Created Despite Error During DBLoad
vars
	valid		: Boolean;
	ediData		: CM_EDIData;
	passport	: CM_Passport;
	strTemp		: String;
	answer,
	flags,
	intCancel	: Integer;
	cmifMonitor	: CMIF_Monitor;
	hasCargo : Boolean;
	voyage : CM_Voyage;
	mergeOptionsForm : CMUI_EDIBayPlanMerge;
	mergeRetainAllCargo : Boolean;  //July 2008 cnwrs1 Par 17595 
	mergeRetainEDICargo : Boolean;
	mergeRetainManCargo : Boolean;
	mergeRetainNoCargo : Boolean;
	mergeCargo : Boolean;
	clearDetails : Boolean;
	warningMessage : Integer;
	prof	 : JadeProfiler;
	starTM   : Decimal[19,0];
begin
	if process.isHari or process.isIshwarya then
		app.myRoot.startJadeProfiler(prof,method.getNiceName,20,false,'MA',starTM);
	endif;
	passport := app.myPassport;
	ediData := self.myCurrentObject.CM_EDIData;
	
	if ediData = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
	endif;
	
	ediData.warnOnDBLoad(strTemp, flags, intCancel);
	
	if strTemp &lt;&gt; null then
		answer := app.msgBox(strTemp, app.getErrorString(Warning), flags);
		if answer = intCancel then
			return;
		endif;
	endif;
		
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	app.myPassport.clearErrorsWarnings();
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; "DB Loading EDI data.";
	self.frmModalDialog.visible := true;
	
	app.mousePointer := MP_HOURGLASS;
	self.doWindowEvents(0);
	
	valid := true;
	if self.tryLock(ediData, Share_Lock, Session_Duration, LockTimeout_Immediate) then
		if ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED 
		or ediData.status = CM_EDIFile.EDI_STATUS_VERIFYING //cnwrs1 18 mar 2010 so you can still continue
		or ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS
		or ediData.status = CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE
		or ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS 
		or ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then //cnwgb1 PAR 21881 CCMS 1906 21.12.09
			valid := true;	//still
			
		elseif ediData.CM_EDIData.status = CM_EDIFile.EDI_STATUS_DBLOADED and ediData.canReDBLoad()	then
			if ediData.isCallOff() then		//06-May-2024 naviv1 #63174
				warningMessage := File_DB_Loaded_Warning;
			else
				warningMessage := File_DB_Loaded;
			endif;
			answer := app.msgBox(app.getErrorString(warningMessage), "DB Load", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);		//06-May-2024 naviv1 #63174
			
			if answer = MsgBox_Return_Yes then
				//restart from verify
				if ediData.isCallOff() then		//06-May-2024 naviv1 #63174  -- Start
					app.myTrxUA.trxSetEDICallOffAction(ediData.CM_EDIDataCallOff, CMIF_JsonHeaderEUP.Status_Replace,passport);
				endif;							//06-May-2024 naviv1 #63174  -- End
				valid := self.myEDIAgent.verifyEdiData(ediData);
			else
				valid := false; 
			endif;
		else
			valid := self.myEDIAgent.verifyEdiData(ediData);
		endif;
		
		if valid then
			if ediData.isKindOf(CM_EDIDataBayPlan) then
				voyage := ediData.CM_EDIDataBayPlan.getVoyageFromCode(ediData.CM_EDIDataBayPlan.voyageCode);//getMyVoyage();
				
				if voyage &lt;&gt; null then
				// ccms 1022 cnwrs1 june 2006
/*					voyage.getJobTotals(completed, unactioned, partCompleted, exportCargo);
					
					if completed &gt; 0 or partCompleted &gt; 0 and exportCargo &gt; 0 then
						app.msgBox("The current bay plan cannot be made actual because the current voyage" &amp; CrLf &amp; 
								   "has jobs that have been worked.  You will need to either delete any" &amp; CrLf &amp; 
								   "worked jobs or create a new voyage.", "EDI Update", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
						return;
					endif;*/
					//ccms 1022 cnwrs1 july 2006
//	PAR 33644				if voyage.isNonPlannedVoyage then
					if voyage.isHOLDSorSHIP() then
						hasCargo := not voyage.allOnshipTIsByCargoTypeId.isEmpty;
						
						if hasCargo then
							app.mousePointer := Window.MousePointer_Default;
							mergeOptionsForm := app.loadForm(CMUI_EDIBayPlanMerge, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_EDIBayPlanMerge;
							
							if mergeOptionsForm = null then
								return;
							endif;
							
							mergeOptionsForm.hasCargo := hasCargo;
							mergeOptionsForm.hasPlanning := false;
							
							if mergeOptionsForm.showModal() &lt;&gt; IDOK then
								return;
							endif;
							
							// now get input options
							app.mousePointer := Window.MousePointer_HourGlass;
							clearDetails := mergeOptionsForm.chkClear.value;
							
							if not clearDetails then
								mergeRetainAllCargo := mergeOptionsForm.optRetnAllCargo.value;  //July 2008 cnwrs1 Par 17595 
								mergeRetainEDICargo := mergeOptionsForm.optRetnEDICargo.value;
								mergeRetainManCargo := mergeOptionsForm.optRetnManCargo.value;
								mergeRetainNoCargo := mergeOptionsForm.optRetnNoCargo.value; //currently no included in next line
								mergeCargo := mergeRetainAllCargo or mergeRetainEDICargo or mergeRetainManCargo;  //July 2008 cnwrs1 Par 17595 
							endif;
						endif;
					endif;
				endif;
			endif;
			
			passport.warningsAcknowledged := true;
			app.mousePointer := MP_HOURGLASS;
			self.myEDIAgent.loadEdiDb(null, ediData, mergeCargo);
		endif;
	else
// 02 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
		app.raiseCMException(Objects_locked, null, ediData);
	endif;
	
	if self.hasVerifyErrorsToShow (ediData) then		// par 30136 Aug 2012, par 27392 13 Apr 2011
		self.showVerifyErrors(ediData);	//par 27392 13 Apr 2011
	else
		self.mode := self.Mode_View;
		self.setControls();
		self.clearErrorWarnings();
		self.staMain.caption := "DB Load successful";
	endif;

// cnwdad1 09/06/2010 - PAR #24302
	ediData.causeEvent(EVENT_EDI_EDIDATA_UPDATE, true, ediData);
//	self.updateTblData(ediData);
epilog
	self.unlock(ediData);
	self.closeModalDialog();
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
	app.mousePointer := MP_DEFAULT;
	app.myRoot.stopJadeProfiler(prof,starTM);
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteEDIData" id="3e931ee6-58bb-4640-8e1e-4dab48c7b5a2">
        <updating/>
        <source>doDeleteEDIData() updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 15/08/2012	cnwcs5	par 29543 - arm exception handler in case edi data deleted
vars
	ediData			: CM_EDIData;
	ediFile			: CM_EDIFile;
	i,j,result		: Integer;
	ediConfig		: CM_EDIConfig;
	object 			: Object;
	objArray 		: ObjectArray;
	isBulkEdit 		: Boolean; //added by cnwyl1 for par12686
	gotException	: Boolean;	// par 29543 Aug 2012
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	if self.tblData.allSelectedObjects.size = 0 then
		return;
	endif;
	
	create objArray transient;
	
	self.tblData.allSelectedObjects.copy(objArray);

	//added by cnwyl1 for par12686
	if objArray.size &gt; 1 then
		isBulkEdit := true;
	else
		isBulkEdit := false;
	endif;
	
	if isBulkEdit then
		i := app.msgBox(app.getErrorString (Delete_EDI_Data_Confirm), app.getErrorString (Delete_EDI_Data), MsgBox_Information_Icon + MsgBox_OK_Cancel); 
		
		if i = MsgBox_Return_Cancel then
			return;
		endif;	
	endif;	
	
	on Exception do app.handleDeletedObject (exception, ediData, gotException);	// par 29543 Aug 2012
	
	foreach object in objArray do
		ediData := object.CM_EDIData;
		
		if ediData = null or ediData.edition &lt; 0 then
			return;
		endif;
		
		if gotException then
			// edi data has already been deleted
			gotException := false;
			
			continue;
		endif;
		
		if not isBulkEdit then
			i := app.msgBox("Deleting " &amp; self.myAssistant.getEDIDisplayStrForType(ediData.ediDataType) &amp; " loaded " &amp; ediData.createdTime.shortCurrentLocaleFormat &amp; ". Do you wish to continue?", "Deleting EDI Data", MsgBox_Information_Icon + MsgBox_OK_Cancel); 

			if i = MsgBox_Return_Cancel then
				return;
			endif;
		endif;
	
		app.mousePointer := MP_HOURGLASS;
		
		self.initModalDialog();
		
		self.pbProgressBar.visible 		:= false;
		self.lblModalMessage.height 	:= 40;
		self.lblModalMessage.caption 	:= Cr &amp; "Deleting EDI data." &amp; Cr &amp; "Please wait...";
		self.frmModalDialog.visible 	:= true;
		
		app.doWindowEvents(0);
		
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteEDIData(ediData, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				self.initTblEDITI(0);  
				self.myCurrentObject := null;
				self.setControls();		
				break;
			else
				theResult := app.showErrorWarningDialog('Delete EDI data', app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
		self.frmModalDialog.visible := false;
	
	endforeach;

epilog
	self.closeModalDialog();
	
	delete objArray;
	
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayTIWarnings" id="6861b67d-161f-4d54-9838-c9cdb988d05e">
        <source>doDisplayTIWarnings(_showWarnings: Boolean);
//----------------------------------------------------------------
//	Created:	05 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//20 Dec 2016	cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
vars
	intRow,
	rowHeight	: Integer;
	table		: CM_DataTable;
	theRow		: JadeTableRow;
	theCel		: JadeTableCell;
begin
	table := self.tblEDITIError;
	
	if _showWarnings then
		if table.rows &gt; 0 then
			rowHeight := table.accessRow(1).height;
		endif;
	else
		rowHeight := 1;
	endif;
	foreach intRow in 2 to table.rows do
		theCel := table.accessCell(intRow, 2);
		if theCel.text = self.WARNING_STR then
			table.accessRow(intRow).visible := _showWarnings;
		endif; 	
	endforeach;


epilog

end;</source>
        <Parameter name="_showWarnings" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEDIDataReplace" id="006b715e-6f64-4370-9eba-e5357eadbce2">
        <updating/>
        <source>doEDIDataReplace(_table: Table; 
				_columnHeading: String; 
				_findStr: String; 
				_replaceStr: String; 
				_fullWord,
				_selectedLinesOnly : Boolean): Integer updating;
//----------------------------------------------------------------
//	Created:	06 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	col,
	intRow,
	intCol,
	foundCol,
	intCount,
	replCount	: Integer;
	theText		: String;
	theTable	: CM_DataTable;
begin
	theTable := _table.CM_DataTable; //21030 cnwgb1 11.10.9
	foundCol := 0;
	
	foreach intCol in 1 to theTable.columns do
		if theTable.accessCell(1, intCol).text = _columnHeading then
			foundCol := intCol;
			break;
		endif;
	endforeach;
	
	if foundCol = 0 then
		//no such column
		return 0;
	endif;
	col := theTable.getColumnByRowName(ETRow_HasChanged); //PAR 21030 cnwgb1 11.10.09 fixup for 20320
	foreach intRow in 2 to theTable.rows do
		if _selectedLinesOnly and (not theTable.accessRow(intRow).selected) then
			continue;
		endif;
		//th2 trim blanks added for PAR13829 - Loading ANL Load list find replace problem
		theText := theTable.accessCell(intRow,foundCol).text.trimBlanks();
		
		if self.replaceSubString(true, theText, _findStr, _replaceStr, intCount, _fullWord) then
			replCount := replCount + intCount; 
			theTable.accessedCell.text := theText;			
			theTable.accessCell(intRow,col).text := self.HAS_CHANGED;
		endif;
	
	endforeach;
	
	return replCount;	
end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_columnHeading" type="String"/>
        <Parameter name="_findStr" type="String"/>
        <Parameter name="_replaceStr" type="String"/>
        <Parameter name="_fullWord" type="Boolean"/>
        <Parameter name="_selectedLinesOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doEDIFileReplace" id="94ec271c-946d-40f6-b012-b34b8e88336e">
        <updating/>
        <source>doEDIFileReplace(_table: Table; _tagHeading: String; _findStr: String; _replaceStr: String; _fullWord: Boolean): Integer updating;
//----------------------------------------------------------------
//	Created:	06 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
//	col,
	intRow,
//	intCol,
	intCount,
	replCount	: Integer;
	theText		: String;
	theTable	: Table;
begin
	theTable := _table;
//	intCol := 1;
//	col := 2;
	foreach intRow in 2 to theTable.rows do
		theText := theTable.accessCell(intRow, self.COLUMN_DATA).text; //par17172 cnwrs1 July 2008
		if theText[1:3] &lt;&gt; _tagHeading then
			continue;
		endif;
		
		if self.replaceSubString(true, theText, _findStr, _replaceStr, intCount, _fullWord) then
			replCount := replCount + intCount; 
			theTable.accessedCell.text := theText;			
			theTable.accessCell(intRow, self.COLUMN_CHANGED).text := self.HAS_CHANGED; //par17172
		endif;
	endforeach;
	
	return replCount;	
end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_tagHeading" type="String"/>
        <Parameter name="_findStr" type="String"/>
        <Parameter name="_replaceStr" type="String"/>
        <Parameter name="_fullWord" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doEditEDIDataDetails" id="7b57c7bd-2c41-411b-88ab-08e96d881e29">
        <updating/>
        <source>doEditEDIDataDetails()updating;
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//10 Sep 2012	cnwrs1	Par30246 remove restriction on editing DBloaded data
//20 Mar 2023 navra1 	TFS 57124 - A cancelled EDI should not be editable, incase he tries to edit, throw error and return
vars
	theStatus	: Integer;
	rtnValue : Integer;
begin
	if self.myCurrentObject = null then
		return;
	endif;

	theStatus := self.myCurrentObject.CM_EDIData.status;	
	
	//A cancelled EDI should not be editable, incase he tries to edit(should not be possible though), throw error and return
	if theStatus = CM_EDIFile.EDI_STATUS_CANCELLED then																											//navra1 - TFS 57124 - 20th Mar 2023
		app.msgBox(app.getErrorString(ERR_CANCELLED_EDI_EDIT), app.getErrorString(ERR_CANCELLED_EDI_EDIT), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon); 		//navra1 - TFS 57124 - 20th Mar 2023
		return;																																					//navra1 - TFS 57124 - 20th Mar 2023
	endif;																																						//navra1 - TFS 57124 - 20th Mar 2023

	if (theStatus = CM_EDIFile.EDI_STATUS_DBLOADED or theStatus = CM_EDIFile.EDI_STATUS_MADE_ACTUAL) then
//	and (not self.myCurrentObject.CM_EDIData.singleDataFile) then // cnwrs1 Par 24207 ccms 1117 11 May 2010
//10 Sep 2012	cnwrs1	Par30246 remove restriction on editing DBloaded data
		rtnValue := app.msgBox(app.getErrorString(InvalidEdit), app.getErrorString(EDI_Data_Edit), MsgBox_Yes_No + MsgBox_Question_Mark_Icon); 
		if rtnValue = MsgBox_Return_No then
			return;
		endif;
	endif;

	//self.fldDetail.topSheet := self.shtEDIDetails;
	self.mode := Mode_Update;
	self.setControls();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditVoyage" id="c45750c9-8821-464c-9381-0e56efa3c2f0">
        <source>doEditVoyage();
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------


vars
	currentEdiData	: CM_EDIData;
	voyageForm		: CMUI_EDIVoyageEdit;
	ediDataClass	: Class;
begin
	
	if self.myCurrentObject = null then
		return;
	endif;
	
	currentEdiData := self.myCurrentObject.CM_EDIData;
	
	if not (currentEdiData.isKindOf(CM_EDIDataBayPlan) or currentEdiData.isKindOf(CM_EDIDataStowAdvice)) then
		return;
	endif;
	
	create voyageForm;
	
	voyageForm.setEDIData(currentEdiData);
	voyageForm.setAssistantAndTerminalRefs(self.myAssistant, self.myTerminal);
	voyageForm.showModal;
	
	if voyageForm.modalResult &lt;&gt; IDOK then
		//there was a problem?/cancelled
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFileEdit" id="8ca0c05e-9a15-49db-a7bc-575e71f1eb73">
        <updating/>
        <source>doFileEdit() updating;
// ---------------------------------------------------------------------------
// Created:		23 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
29/11/2011	cnwcs5	CCMS POL 2122 / par 28696	
15 Dec 2014	cnwkpd1	PAR #34713 - Changes for .NET EDI Integration
12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
31 Mar 2016	cnwkpd1	TFS 1751 - 1090 exception trying to view message
09 Jul 2018  cnwma1	Bug 39483: JMT - EDI Operations View Raw Data and Internal XML
// 25 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 6
24 Aug 2023	navmd1 	TFS 59451 Refactor EDI Ops/EDI Web Service viewer to call one method
*/
vars
	ediData			: CM_EDIData;
	invalidObj		: Boolean;
begin
	//	ccms 1064	Centreport	cnwvu1
	if self.myCurrentObject &lt;&gt; null and CM_EDIData.hasInstance(self.myCurrentObject) then
		ediData := self.myCurrentObject.CM_EDIData;
		
		on Exception do app.handleDeletedObject( exception, ediData, invalidObj );
		ediData.edition;
		
		if invalidObj then
			app.msgBox( app.getErrorString(Selec_item_not_avail_been_dele), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			return;
		endif;
		
		self.myEDIUIAgent.doEDIViewRawData(ediData, self);
	endif;
		
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFindFrom" id="476baa0f-3dfb-4b4d-9510-9a598b14678d">
        <updating/>
        <source>doFindFrom(_startRow: Integer) updating;
//----------------------------------------------------------------
//	Created:	06 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	startAt		: Integer;
	intRow		: Integer;
	intCol		: Integer;
	foundCol	: Integer;
	foundAt		: Integer;
	theText		: String;
	strCol		: String;
	strFind		: String;
	fullWord	: Boolean;
	theTable	: CM_DataTable;
	index : Integer;
	
begin
	if _startRow &lt; 2 then
		startAt	:=	2;
	else
		startAt	:=	_startRow;
	endif;

	strCol		:=	self.tblFindReplace.getValue(1).String;
	strFind		:=	self.tblFindReplace.getValue(2).String;
	fullWord	:=	self.tblFindReplace.getValue(4).Boolean;

	if strFind &lt;&gt; self.findNextString then
		//has changed since last find
		startAt	:=	2;
		self.findNextString	:=	strFind;
	endif;

	if self.isDataSheetDisplayed(index) then //cnwgb1 30.9.09 MES 1011 Par 20320 Handle cloned tables
		theTable	:=	self.tblEDITI.getControl(index);
	else
		theTable	:=	self.tblEDITI; //Shouldn't ever happen
	endif;

	foreach intCol in 1 to theTable.columns do
		if theTable.accessCell(1, intCol).text = strCol then
			foundCol	:=	intCol;
			break;
		endif;
	endforeach;
	
	if foundCol = 0 then
		//no such column
		return;
	endif;
	
	//clear any selected cells in the table
	theTable.clearAllSelected;
	
	foreach intRow in startAt to theTable.rows do
		theText	:=	theTable.accessCell(intRow,foundCol).text;
		foundAt	:=	theText.pos(strFind, 1);
		
		if fullWord then
			if strFind = theText then
				theTable.accessedCell.selected	:=	true;
				self.findNextStartRow	:=	intRow+1;
				theTable.topRow			:=	intRow-1;
				return;
			endif;
		else
			if foundAt &gt; 0 then
				theTable.accessedCell.selected	:=	true;
				self.findNextStartRow	:=	intRow+1;
				theTable.topRow			:=	intRow-1;
				return;
			endif;
		endif;
		
		foundAt	:=	0;
	endforeach;
	
	app.msgBox("Search text not found.", "Find", 0);
	self.findNextStartRow	:=	null;
end;</source>
        <Parameter name="_startRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doHideWarnings" id="20a920bf-f656-4136-aff6-7eff4858fbf0">
        <updating/>
        <source>doHideWarnings(_value :Boolean) updating;
//----------------------------------------------------------------
//	Created:	05 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 25/10/2012	cnwcs5	par 28376 - pass value as parameter
vars

begin
	if _value then
		self.doDisplayTIWarnings(false);	// hide warnings
	else
		self.doDisplayTIWarnings(true);		// show warnings
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadAsFormat" id="a7e73514-1c98-48ae-8c12-e55202c29d3e">
        <updating/>
        <source>doLoadAsFormat(_fileFormat: CM_FileFormatEDI) updating;
//----------------------------------------------------------------
//	Created:	03 September 2003	by Jason Chapman  (cnwjc2)
//
//	the file needs to be already loaded as a plain csv/xml file to be able to start from here
//
//----------------------------------------------------------------
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
vars
	ediData		: CM_EDIData;
	loadFile	: File;
	newEDIFile	: CM_EDIFile;
	cmifMonitor	: CMIF_Monitor;
	passport	: CM_Passport;
	ediFileType	: CM_EDIFileType;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	if _fileFormat = null then
		return;
	endif;
	
	
	passport := app.myPassport;
	app.mousePointer := MP_HOURGLASS;
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	ediFileType := _fileFormat.myEDIFileType;
	
	if ediFileType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'edi file type is null');
	endif;
	
	if self.myCurrentObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current edi object');
	endif;
	
	ediData := self.myCurrentObject.CM_EDIData;
	
	if ediData.fileName = "" then
		app.raiseUnexpectedProgramError(class.name, method.name, 'edi object has no disk file');
	endif;
	
	create loadFile;	
	
	loadFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	loadFile.fileName := ediData.fileName;
	
	if not loadFile.isAvailable then
		loadFile.fileName := ediData.myEDIFile.fileName; // ccms1117 cnwrs1 29 Apr 2010
		if not loadFile.isAvailable then
			app.msgBox('The file ' &amp; loadFile.fileName &amp; ' is no longer available', self.caption, null);
			return;
		endif;
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; "Loading EDI file." &amp; Cr &amp; "Please wait...";
	self.frmModalDialog.visible := true;
	
	app.doWindowEvents(0);
	
	//must set this before loadFileForTerminal so that we know which format to use
	self.myEDIAgent.setCurrentFileFormat(_fileFormat, ediData.myOperator);
	newEDIFile := self.myEDIAgent.loadAndProcessFileForTerminal(loadFile, ediFileType, passport); 
	
	if passport.allErrorWarnings.size &gt; 0 then
		
		self.setEDIFileInError(newEDIFile);
		
		if self.myEDIFileInError = null then
			app.showErrorWarningDialog('Load EDI file', passport, ErrWarnMode_AddUpdate);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window					
		else	
			self.mode := self.Mode_EditEDIFile;
			self.showFileLoadErrors(passport);
		endif;
		self.setControls();	
		
	else
		//get rid of the dummy ediData
		
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteEDIData(ediData, passport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog( "Delete Temporary Data", app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
		self.staMain.caption := "Load successful";

		app.doWindowEvents(0);
		self.selectTblDataObject(newEDIFile.ediData);
		
	endif;
	
epilog
	self.closeModalDialog();
	delete loadFile;
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_fileFormat" type="CM_FileFormatEDI"/>
    </JadeMethod>
    <JadeMethod name="doLoadGeneric" id="4a7c3222-cd7b-4aef-bd27-016b4d3d407a">
        <updating/>
        <source>doLoadGeneric(_fileType: Integer) updating;
//----------------------------------------------------------------
//	Created:	03 September 2003	by Jason Chapman  (cnwjc2)
//
//	the file needs to be already loaded as a plain csv/xml file to be able to start from here
//
//----------------------------------------------------------------
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
vars
	ediData		: CM_EDIData;
	loadFile	: File;
	newEDIFile	: CM_EDIFile;
	cmifMonitor	: CMIF_Monitor;
	passport	: CM_Passport;
	ediFileType	: CM_EDIFileType;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	passport := app.myPassport;
	app.mousePointer := MP_HOURGLASS;
	
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(_fileType, null);
	
	if ediFileType = null  or ediFileType.type &lt;&gt; _fileType then
		app.raiseUnexpectedProgramError(class.name, method.name, 'edi file type is null');
	endif;
	
	if self.myCurrentObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current edi object');
	endif;
	
	ediData := self.myCurrentObject.CM_EDIData;
	
	if ediData.fileName = "" then
		app.raiseUnexpectedProgramError(class.name, method.name, 'edi object has no disk file');
	endif;
	
	create loadFile;	
	
	loadFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	loadFile.fileName := ediData.fileName;
	
	if not loadFile.isAvailable then
		loadFile.fileName := ediData.myEDIFile.fileName; // ccms1117 cnwrs1 29 Apr 2010
		if not loadFile.isAvailable then
			app.raiseUnexpectedProgramError(class.name, method.name, 'the file ' &amp; loadFile.fileName &amp; ' is no longer available');
		endif;
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; "Loading EDI file." &amp; Cr &amp; "Please wait...";
	self.frmModalDialog.visible := true;
	
	app.doWindowEvents(0);
	
	self.myEDIAgent.setCurrentFileFormat(null, null); 
	newEDIFile := self.myEDIAgent.loadAndProcessFileForTerminal(loadFile, ediFileType, passport); 
	
	if passport.allErrorWarnings.size &gt; 0 then
		
		self.setEDIFileInError(newEDIFile);
		
		if self.myEDIFileInError = null then
			app.showErrorWarningDialog('Load EDI file', passport, ErrWarnMode_AddUpdate);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window					
		else	
			self.mode := self.Mode_EditEDIFile;
			self.showFileLoadErrors(passport);
		endif;
		self.setControls();	
		
	else
		//get rid of the dummy ediData
		
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteEDIData(ediData, passport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog( "Delete Temporary Data", app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;

		self.clearErrorWarnings();
		self.staMain.caption := "Load successful";

		app.doWindowEvents(0);
		self.selectTblDataObject(newEDIFile.ediData);
	endif;
	
epilog
	self.closeModalDialog();
	delete loadFile;
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_fileType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLoadNew" id="93ef80fe-3f70-4b66-aa8c-42d50e2497ab">
        <updating/>
        <source>doLoadNew(_copyToServer :Boolean)updating;
/*
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

26/06/2008 concms1	par 17254 - copy file to server before processing
2 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
16/03/2015	cnwmh5	Tranisent Leak
6/07/2018 	JLGNS1	Bug 39173: MSL - Roro baplie not entirely loaded - HIGH PRIORITY
21/11/2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
16/08/2023	navmd1	TFS 59811 Handle JSON parsing errors a bit better
*/
vars
	loadFile		: File;
	ediFile			: CM_EDIFile;
	cmifMonitor		: CMIF_Monitor;
	passport		: CM_Passport;
	ext				: String;
	dotPos			: Integer;
	fileName		: String;
	fileArray		: FileNodeArray;
	fileNode		: FileNode;
	aMsg			: String;
	selectedType	: CM_EDIFileType;
	serverFileName	: String;
	ediErrorWarnings : CM_ErrorSet;
begin
	
	passport := app.myPassport;
	
	if self.txtFileName.text.trimBlanks = null then
		self.getNewEDIFile();
	endif;

	create loadFile transient;
	loadFile.fileName := self.txtFileName.text.trimBlanks();
	
	if loadFile.fileName = "" then
		return;
	endif;

	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	if self.optSpecifyType.value then
		selectedType := self.cmbLoadAsType.listObject.CM_EDIFileType;
		
		if selectedType = null then
			app.msgBox('You must selected an EDI file type first, (or select auto-detect for non-user defined types only)','No file type selected',MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	// TFS 59811 Transform JSON files for specific clients
	if self.cmbTransformAs.visible then
		self.myEDIAgent.transformFor := self.cmbTransformAs.text;
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; "Loading EDI file.";
	self.frmModalDialog.visible := true;
	
	dotPos := loadFile.fileName.reversePos('.'); //cnwgb1 13.2.09
	if dotPos &gt; 0 and dotPos &lt; loadFile.fileName.length then
		ext := loadFile.fileName[dotPos+1:end];
		fileName := loadFile.fileName.getFileName();
	endif;
	
	create fileArray transient;
	
	if ext.toUpper = "XLS" or	//par 27124 2 Mar 2011
	   ext.toUpper = "XLSX" then
		self.convertXLSToCSV(loadFile, fileName, fileArray);
		delete loadFile;
		
		if not self.optSpecifyType.value then //cnwrs1 Mar 2007 dont need to do this for user defined type
			if fileArray.isEmpty then
				aMsg := "The selected Excel file could not be converted to a loadable format." &amp; CrLf &amp; CrLf;
				aMsg := aMsg &amp; "Check the application log for more details.";
			else
				aMsg := "Worksheets from the selected Excel file have been converted into the following CSV files:" &amp; CrLf;
				
				foreach fileNode in fileArray do
					aMsg := aMsg &amp; CrLf &amp; fileNode.File.fileName;
				endforeach;
				
				aMsg := aMsg &amp; CrLf &amp; CrLf &amp; "Select a file format from the 'Load CSV As' menu.";
			endif;
			app.msgBox(aMsg, self.caption, MsgBox_Information_Icon);
		endif;
	else
		fileArray.add(loadFile);
	endif;
	
	app.doWindowEvents(0);
	self.myEDIAgent.setCurrentFileFormat(null, null); //must reset these
	
	foreach fileNode in fileArray do
	// par 17254 - start
		if _copyToServer then
			app.writeLog('  Copying file to AppServer', LogINFO);
			serverFileName := app.copyFileToAppServer(fileNode.fileName);
			app.writeLog('  Copied file to AppServer as (' &amp; serverFileName &amp; ')', LogINFO);
			
			fileNode.File.close;
			
			fileNode.usePresentationFileSystem 	:= false;
			fileNode.fileName					:= serverFileName;
		endif;
	// par 17254 - end
		ediFile := self.myEDIAgent.loadAndProcessFileForTerminal(fileNode.File, selectedType, passport);
		
		if passport.allErrorWarnings.size &gt; 0 then
			break;
		endif;
	endforeach;
	
	if passport.allErrorWarnings.size &gt; 0 then
		create ediErrorWarnings transient;
		passport.moveErrorsToSet(ediErrorWarnings);
		
		self.setEDIFileInError(ediFile);	// calls a trx which cleans the passport
		
		passport.addErrorsFromSet(ediErrorWarnings);
		
		if self.myEDIFileInError = null then																			//Bug 39173
	//		app.showErrorWarningDialog('Load EDI file', passport, ErrWarnMode_AddUpdate);								//Bug 39173
	//		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window	//Bug 39173
		else																											//Bug 39173
			self.mode := self.Mode_EditEDIFile;																			//Bug 39173
	//		self.showFileLoadErrors(passport);																			//Bug 39173
		endif;																											//Bug 39173
																														//Bug 39173
		self.showFileLoadErrors(passport);																				//Bug 39173
		app.showErrorWarningDialog('Load EDI file', passport,  ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);		//Bug 39173
																														//Bug 39173
		if ediFile &lt;&gt; null then																							//Bug 39173
			self.selectTblDataObject(ediFile.ediData);																	//Bug 39173
		endif;																											//Bug 39173
		
		self.setControls();	
		
	else
		self.clearErrorWarnings();
		self.staMain.caption := "Load successful";
		app.doWindowEvents(0);
		if ediFile &lt;&gt; null then
			self.selectTblDataObject(ediFile.ediData);		
		endif;
	endif;
	
	self.showHideLoadNewFile(false);
epilog
	self.closeModalDialog();
	
	delete fileArray;
	delete loadFile;
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
	
	if ediErrorWarnings &lt;&gt; null then
		ediErrorWarnings.purge();
		delete ediErrorWarnings;
	endif;
end;</source>
        <Parameter name="_copyToServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadNewFile" id="8b2aafbc-887d-4ee5-a024-f10da3a54428">
        <updating/>
        <source>doLoadNewFile(_copyToServer :Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2009 by cnwdad1
//
// Purpose:		Wrapper method for loading a new file, with an exception handler to
//				catch any file handling problems.
//
// Parameters:	_copyToServer - True if the file should be copied to the server.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 
// --------------------------------------------------------------------------------
vars
	errorMsg		: String;
	autoDetectFailed : Boolean;
begin
	on FileException do self.xHandlerFileOpen(exception, errorMsg);
	//02 Jul 2020	NDL	TFS 49485
	if self.optAutoType.value then
		on CM_Exception do handle89095(exception, autoDetectFailed);	// Auto detect message
	endif;
	
	errorMsg	:=	null;
	self.doLoadNew(_copyToServer);
	
	if autoDetectFailed then	//02 Jul 2020	NDL	TFS 49485
		app.msgBox(app.getErrorString(Faile_auto_detec_file_type_ple), app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.staMain.caption	:=	app.getErrorString(Load_failed) &amp; ".";
	elseif errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.staMain.caption	:=	app.getErrorString(Load_failed) &amp; ".";
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_copyToServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="6b4113c8-2d51-4aa3-91a9-8e4f48370fbe">
        <source>doMnuColumnOrganiserClick(_menuItem : MenuItem);
//--------------------------------------------------
// Created:	jan 2006 cnwrs1
//--------------------------------------------------
//07 Aug 2019	jlgsl4	TFS 45974 - JMT - non-default measurement fields shouldn't be editable

vars

begin
	if (not self.useTblData) then
		return;
	endif;
	
	if self.myCurrentDataTable = null then
		self.tblData.showColumnOrganiserFrm(self.myTerminal, self.allTblDataTransientRows);
	else
	
		if self.myCurrentObject = null then	//PAR 22402 19/02/2010
			app.msgBox( app.getErrorString(Please_select_EDI_file_first), "", MsgBox_OK_Only);
		else
			self.myCurrentDataTable.showColumnOrganiserFrm(self.myTerminal, self.allTblDataTransientRows);
		endif;
		self.myCurrentDataTable.setReadOnlyEntRows(); // TFS 45974
	endif;
end;</source>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuEDIIgnore" id="1b46cee2-0523-4008-b3c5-2dd9e24dd4f4">
        <source>doMnuEDIIgnore(_table :CM_DataTable) protected;
/*
Date		Who		Reason
20 Aug 2013	cnwcs5		CCMS POL 2221 / par 32094(2)
*/
vars
	obj		:Object;
	coll 	:CM_EDITISet;
	result	:Integer;
begin
	create coll transient;

	foreach obj in _table.allSelectedObjects do
		if not obj.isKindOf (CM_EDITrackedItem) then
			continue;
		endif;
		
		coll.add (obj.CM_EDITrackedItem);
	endforeach;
	
	while true do
		app.myTrxUA.trxEDIIgnoreEDITrackedItem (coll, app.myPassport);
		
		if not app.myPassport.trxCompletedOK() then
			result := app.showErrorWarningDialog( app.getErrorString(Road_exit), app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and
				result = IDOK then
				
				app.myPassport.warningsAcknowledged     := true;
				continue;
			endif;
		endif;

		break;
	endwhile;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doMnuEDIProcess" id="97583b54-8e60-4ba4-8bb6-ded03c676c49">
