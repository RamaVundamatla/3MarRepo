    <JadeMethod name="doBaseFormSave" id="55dfabc5-2258-4d23-a0ca-64179b2866a4">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/
vars
	controller   	: CMIF_InvoiceLineCopy;
	theTable 		: CM_DataTable;
	theReturn 	    : Integer;
	ls 			    : Boolean;
	pxyInvoice      : CM_Invoice;
	dateTime		: TimeStamp;
	date            : Date;
	time            : Time;
	status 			: Integer;
	allWorkOrders	: CM_WorkOrderSet;
begin
	status := self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.listIndex];	// 26.4.2023 navmk20 TFS 57663

 	theTable := self.tblResults;
	create allWorkOrders transient;//navtnr20 23-05-2023 BUG 58089
	self.mulWorkOrder.getSelected(allWorkOrders);
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(self.myCurrentBank,
								self.cmbDebtorInvProp.listObject.CM_Debtor,
								self.cmbDebtorAddressProp.listObject.CM_Address,
								self.cmbVoyageInvProp.listObject.CM_Voyage,
								self.cmbInvTypeInv.listObject.CM_InvoiceDesc,
								//self.cmbStatusInvProp.text = app.getErrorString(Suspense), // 26.4.2023 navmk20 TFS 57663
								status,	// 26.4.2023 navmk20 TFS 57663
								true,
								self.myCurrentTI,
								self.myBillOfLading,
								self.myBookingRef,
								self.myCurrentCargoGroup,
								self.myReleaseRequest,
								self.cmbCategory.itemData[self.cmbCategory.listIndex],
								self.tblInvProperties.getValueByName(ETRow_PurchaseOrderNumber).String,  // ### BUG 56925 07MAR2023 NAVAB1
								self.myCurrentBank.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663
								allWorkOrders, //navtnr20 23-05-2023 BUG 58089
								self.txtNarr.text, //14/08/2023	navkc1	Bug 59803
								self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade, //14/08/2023	navkc1	Bug 59803
								self.tblInvProperties.getValueByName(ETRow_DebtorReference).String,	//14/08/2023	navkc1	Bug 59803
								self.cmbCurrencyType.listObject.CM_CurrencyType,	//14/08/2023	navkc1	Bug 59803
								self.cmbLocale.listObject.CM_Locale,	//14/08/2023	navkc1	Bug 59803,
								self.cmbDebtorAltAddrProp.listObject.CM_Address	//14/08/2023	navkc1	Bug 59803
								);
	
	date := self.tblInvProperties.getValueByName(ETRow_StartDate).Date;
	time := self.tblInvProperties.getValueByName(ETRow_EndDate).Time;
	dateTime := app.actualTimeAppServer;
	if date.isValid then
		dateTime.setDate(date);
		dateTime.setTime(time);
	endif;
	
	create controller transient;
	self.allSelectedInvoiceLines.copy(controller.allSelectedInvoiceLines);
	controller.setValues(true,true,true,pxyInvoice,self.allTIs,dateTime); 
	
	
	if controller.allTrackedItems.size() &gt; 0 then
		if app.msgBox(app.getErrorString2(Pleas_confi_invLines_items,(controller.allSelectedInvoiceLines.size()) .String,
			controller.allTrackedItems.size().String),app.getErrorString(Confirmation),MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
			global.beep;
			return;
		endif;
	endif;
	
	while true do
		app.myTrxCA.trxCopyInvoiceLine(controller,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Copy", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
			
		break;
	endwhile;
	
	self.tblResults.clear();
	self.unloadForm();
	
epilog
	app.cmsEndLoad(ls);
	delete pxyInvoice;
	delete controller;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="a2528cca-d192-4f64-9976-6a893010ab02">
        <source>doMnuColumnOrganiserClick(menuItem : MenuItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	tbl  	: CM_DataTable;
	iter 	: Iterator;
	ti   	: CM_TrackedItem;
	count,
	idx	 	: Integer;
begin
	tbl := menuItem.userObject.CM_DataTable;

	self.tblResults.showColumnOrganiserFrm(self.myTerminal, self.tblResults.allTblDataEntRows);
	
	iter := self.allTIs.createIterator();
	self.tblResults.setMyDataClass(CM_TrackedItem);

	while iter.next(ti) do
		count := count + 1;
		idx := self.tblResults.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblResults.accessRow(idx).itemObject := ti;
	endwhile;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doTblSelectorContMenu" id="ac463901-fd1a-4a84-a4d5-4a34e583e182">
        <updating/>
        <source>doTblSelectorContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganizer.visible := true;
	self.mnuColumnOrganizer.userObject := self.tblResults;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
