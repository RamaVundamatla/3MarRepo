    </JadeMethod>
    <JadeMethod name="setDayListArray" id="c8cdf160-8132-489b-86e3-c39a9779d024">
        <source>setDayListArray( monday : Date );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation

*/

vars

	date : Date;
	pos : Integer;
	
begin

	date := monday;
	self.dayListArray.clear();
	foreach pos in 1 to 7 do
