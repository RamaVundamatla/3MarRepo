<Class name="CMIF_LayoutGraphics" id="0e626723-b545-4a1b-8371-5403924f330d">
    <superclass name="CMIF_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used to update the graphics for many terminal areas</text>
    <DbClassMap file="terminal"/>
    <ImplicitInverseRef name="allObjects" id="38f96bb9-c815-469d-a9d0-292fb4418ede">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allPointPolygons" id="c0964881-5e44-4ad3-b5f0-2656dc0e1efe">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="add" id="d0f0f0a7-5833-423d-9cad-f05f1448002a">
        <updating/>
        <source>add(_theObject : Object; _thePoints : PointArray) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if _theObject = null then
		return;
	endif;
	
	self.allObjects.add(_theObject);
	self.allPointPolygons.add(_thePoints);
end;</source>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_thePoints" type="PointArray"/>
    </JadeMethod>
</Class>
