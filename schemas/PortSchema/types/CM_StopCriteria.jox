    <JadeMethod name="addPxyCriteriaFromEDI" id="962796d1-2054-4778-b00a-57609bb0f4b5">
        <updating/>
        <source>addPxyCriteriaFromEDI(_myStopTable : CM_StopsTable input; _ediReqCrit : CM_EDIRequestCriteriaTI ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

	critName : String;
	rawCriteriaValue : String;
	ct : CM_YACriteriaType;
	criteriaType : CM_YACriteriaType;
	errorItemId : String;
	
	proxyCriteria: CM_YACriteria;
	itemCode : String;
	value : Any;

begin

	self.raiseExceptionIfNotTransient(method);

	critName := _ediReqCrit.criteriaName.toUpper;
	rawCriteriaValue := _ediReqCrit.criteriaValue;
	errorItemId := _ediReqCrit.releaseRequestNumber &amp; "/" &amp; _ediReqCrit.requestDetailID.String;
	
	if _myStopTable = null then
		app.raiseCMException( Reserve_selecti_referen_not, errorItemId, null );
		return;
	//elseif self.myStopTable &lt;&gt; null and self.myStopTable &lt;&gt; _myReserveSelection then
		app.raiseCMException( Incorrr_reserve_selecti_found, errorItemId, null );
		return;
	endif;
	
	if critName.trimBlanks = null then
		app.raiseCMException( Extra_criter_type_not_empty, errorItemId, null );
		return;
	endif;
	if rawCriteriaValue.trimBlanks = null then
		app.raiseCMException( Extra_crite_value_match_empty, errorItemId, null );
		return;
	endif;
	
	foreach ct in app.myRoot.allYACriteriaTypes do
		if ct.description.toUpper = critName then
			criteriaType := ct;
			break;
		endif;
	endforeach;
	
	if criteriaType = null then
		app.raiseCMException1( Extra_criter_type_not_known, _ediReqCrit.criteriaName, errorItemId, null );
		return;
	elseif self.isAnExcludedTypeForMatching(criteriaType.type) then
		app.raiseCMException1( Crite_type_not_valid_type_extr, _ediReqCrit.criteriaName, errorItemId, null );
		return;
	endif;
	
	if criteriaType.isBooleanType then
		if rawCriteriaValue.toUpper.trimBlanks = "TRUE" then
			value := CM_YADataBoolean.VALUE_TRUE;
		elseif rawCriteriaValue.toUpper.trimBlanks = "FALSE" then
			value := CM_YADataBoolean.VALUE_FALSE;
		else
			app.raiseCMException2( Extra_crite_value_not_valid, rawCriteriaValue, critName , errorItemId, null );
		endif;
	else
		value := rawCriteriaValue;
	endif;
	
	itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	
	if self.myStopTable = null then
		self.setProxyBaseData( _myStopTable );
	endif;
	
	create proxyCriteria transient;
	proxyCriteria.setProxy(criteriaType, value, itemCode);
	
	self.allCriteria.add(proxyCriteria);

epilog

end;</source>
        <Parameter name="_myStopTable" type="CM_StopsTable" usage="input"/>
        <Parameter name="_ediReqCrit" type="CM_EDIRequestCriteriaTI"/>
    </JadeMethod>
    <JadeMethod name="createStopCriteria" id="ddfe80a8-13dc-4b9c-bb65-fb7b6b87cef7">
        <source>createStopCriteria(_item: Any; _criteriaType: Integer; stopCriteria: CM_StopCriteria input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	criteria		: CM_YACriteria;
	criteriaType	: CM_YACriteriaType;
begin
	criteriaType := app.myRoot.allYACriteriaTypes[_criteriaType];
	if criteriaType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Stop criteria type (' &amp; _criteriaType.String &amp; ') not present');
		return;
	endif;
	
	create criteria transient;
	criteria.setProxy(criteriaType, _item, null);

	stopCriteria.allCriteria.add(criteria);
epilog

end;</source>
        <Parameter name="_item" type="Any"/>
        <Parameter name="_criteriaType" type="Integer"/>
        <Parameter name="stopCriteria" type="CM_StopCriteria" usage="input"/>
    </JadeMethod>
