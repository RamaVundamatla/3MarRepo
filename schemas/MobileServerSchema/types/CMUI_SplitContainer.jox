    <JadeMethod name="setLeftToRightRatio" id="642f78e5-8615-4789-ab57-8a96ab8749af">
        <updating/>
        <source>setLeftToRightRatio(value : Integer) updating;

// no resize is done here as it is assumed a general resize of the form will be done later.
begin
	
	self.useRatio := true;
	self.leftToRightRatio := value;

end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setLeftToRightRatioAndResize" id="bd466da8-a1a0-4027-ac3f-24cd1d8f0267">
        <updating/>
        <source>setLeftToRightRatioAndResize(value : Integer) updating;
//Purpose:		Update the ratio (in percent) that the left control uses of the parent
//				control width
begin

	if value &lt;&gt; self.leftToRightRatio then
		self.leftToRightRatio	:=	value;
		self.useRatio := true;
		self.resizeChildrenAndSplitter();
	endif;

end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setLeftToRightSize" id="0527b099-c4ac-4724-bc18-610db200d49a">
        <updating/>
        <source>setLeftToRightSize(_leftWidth : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		This attempts to set the size  by pixels instead of ratio
//
// ---------------------------------------------------------------------------

vars
	totSize, leftRatio : Integer;
begin
	totSize := self.clientWidth;
	
	leftRatio := ((_leftWidth / totSize) * 100).Integer;
	
	self.setLeftToRightRatio(leftRatio);
end;</source>
        <Parameter name="_leftWidth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setLeftToRightSizeAndResize" id="3db2de19-a86c-4ae2-8405-d07d6512b776">
        <updating/>
        <source>setLeftToRightSizeAndResize(_leftWidth : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		This attempts to set the size  by pixels instead of ratio
//
// ---------------------------------------------------------------------------

vars
	totSize, leftRatio : Integer;
begin
	if self.isSplitHorizontal then
		totSize := self.clientHeight;
	else
		totSize := self.clientWidth;
	endif;
	
	leftRatio := ((_leftWidth / totSize) * 100).Integer + 1;	// add one to force rounded up
	
	self.setLeftToRightRatioAndResize(leftRatio);
end;</source>
        <Parameter name="_leftWidth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRightControl" id="d02c6355-ce27-4454-904e-315382129e33">
        <updating/>
        <source>setRightControl(_control : Control input) updating;
//-----------------------------------------
// Created: October 2003 By: cnwgd1
//-----------------------------------------
vars

begin

	self.myRightControl := _control;
	if _control &lt;&gt; null then
		_control.parent := self;
	endif;

end;</source>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSplitDirection" id="f40f3873-08a6-426c-bff5-84b4756eb568">
        <updating/>
        <source>setSplitDirection(_isSplitHorizontal : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theVertical		: CnEcVerticalSplitter;
	theHorizontal	: CnEcHorizontalSplitter;

begin

	if self.isSplitHorizontal &lt;&gt; _isSplitHorizontal then
		self.isSplitHorizontal := _isSplitHorizontal;
	endif;
	
	if _isSplitHorizontal then
		if self.myVerticalSplitter &lt;&gt; null then
			delete self.myVerticalSplitter;
		endif;
		if self.myHorizontalSplitter = null then
			create theHorizontal transient;
			theHorizontal.parent	:=	self;
			self.form.addControl(theHorizontal);
			self.myHorizontalSplitter := theHorizontal;
		endif;
	else
		if self.myHorizontalSplitter &lt;&gt; null then
			delete self.myHorizontalSplitter;
		endif;
		if self.myVerticalSplitter = null then
			create theVertical transient;
			theVertical.parent	:=	self;
			self.form.addControl(theVertical);
			self.myVerticalSplitter	:= theVertical;
		endif;
	endif;

end;</source>
        <Parameter name="_isSplitHorizontal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupChildControls" id="fb7bb5fe-9337-48a3-b196-82e243abfbcd">
        <updating/>
        <source>setupChildControls() updating;
// Purpose:	Setup the left and right child controls the children of the receiver, and
//			setup the starting ratio to reflect the painted ratios of the visible child 
//			controls.
//
// Note:	The container control only supports two child controls.
vars
	theControl		: Control;
	controlIndex	: Integer;
	totalSize		: Real;
	errorMessage	: String;

begin
	// First delete any existing splitter bars
	if self.myVerticalSplitter &lt;&gt; null then
		delete self.myVerticalSplitter;
	endif;

	if self.myHorizontalSplitter &lt;&gt; null then
		delete self.myHorizontalSplitter;
	endif;

	// Forget existing controls
	self.myLeftControl	:=	null;
	self.myRightControl	:=	null;

	// Look through the controls of the form for children of self
	foreach controlIndex in 1 to self.form.controlCount do
		theControl := self.form.controls(controlIndex);
		
		if theControl.isKindOf(ScrollBar) or
		   theControl.isKindOf(CnEcVerticalSplitter) or
		   theControl.isKindOf(CnEcHorizontalSplitter) then
		   	continue;
		endif;

		if theControl.parent = self then
			if self.myLeftControl = null then
	    		self.myLeftControl := theControl;
	    	else
	    		if self.myRightControl = null then

					// check the position child controls and set appropriately 
		    		if (not self.isSplitHorizontal) and 
		    		   (theControl.left &gt; self.myLeftControl.left) or 
		    		   self.isSplitHorizontal and (theControl.top &gt; myLeftControl.top)
		    			then
		    			self.myRightControl	:=	theControl;
		    		else
		    			self.myRightControl	:=	self.myLeftControl;
		    			self.myLeftControl	:=	theControl;
		    		endif;
				else
					errorMessage	:=	self.class().name &amp; '::' &amp; method.name &amp;
										"  Error&gt;&gt; you can only have 2 child controls.";
					app.msgBox(errorMessage, app.getErrorString(Error), MsgBox_OK_Only);
				endif;
			endif;
	 	endif;
	endforeach;

	if self.myRightControl = null then
		// write self.class().name &amp; '::' &amp; method.name &amp; '  Error&gt;&gt; you must have 2 child controls';
		// return added to avoid null object ref if cloning at run time (RJS 7Feb01)
		return;
	endif;

	if self.myLeftControl.visible and self.myRightControl.visible then
		// Setup the ratios of the children based on their current widths/heights if not
		//  defined in Painter
	 	if self.leftToRightRatio = 0 then
	 		if self.isSplitHorizontal then
	 			totalSize				:=	self.myLeftControl.height + self.myRightControl.height;
				self.leftToRightRatio	:=	(self.myLeftControl.height / totalSize * 100).Integer;
 			else
				totalSize				:=	self.myLeftControl.width + self.myRightControl.width;
				self.leftToRightRatio	:=	(self.myLeftControl.width / totalSize * 100).Integer;
			endif;
 		endif;
 	else
 		if self.myLeftControl.visible then
 			self.leftToRightRatio	:=	100;
 		else
			self.leftToRightRatio	:=	0;
		endif;
	endif;
	
	// Following was moved from windowCreated to allow for control to be cloned at runtime (RJS 7Feb01).
	if (self.myLeftControl &lt;&gt; null) and
	   self.myLeftControl.visible and
	   (self.myRightControl &lt;&gt; null) and
	   self.myRightControl.visible	then
		self.setSplitDirection(self.isSplitHorizontal);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupChildControlsLeftRight" id="4f7ff98d-03e2-4caf-b273-b78cd80bfb63">
        <updating/>
        <source>setupChildControlsLeftRight(_lControl : Control input;_rControl : Control input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:	Setup the left and right child controls the children of the receiver, and
//			setup the starting ratio to reflect the painted ratios of the visible child 
//			controls.
//
// Note:	The container control only supports two child controls.
vars
	theControl		: Control;
	controlIndex	: Integer;
	totalSize		: Real;
	errorMessage	: String;

begin
	// First delete any existing splitter bars
	if self.myVerticalSplitter &lt;&gt; null then
		delete self.myVerticalSplitter;
	endif;

	if self.myHorizontalSplitter &lt;&gt; null then
		delete self.myHorizontalSplitter;
	endif;

	// Forget existing controls
	self.myLeftControl	:=	_lControl;
	self.myRightControl	:=	_rControl;


	if self.myRightControl = null then
		// write self.class().name &amp; '::' &amp; method.name &amp; '  Error&gt;&gt; you must have 2 child controls';
		// return added to avoid null object ref if cloning at run time (RJS 7Feb01)
		return;
	endif;

	if self.myLeftControl.visible and self.myRightControl.visible then
		// Setup the ratios of the children based on their current widths/heights if not
		//  defined in Painter
	 	if self.leftToRightRatio = 0 then
	 		if self.isSplitHorizontal then
	 			totalSize				:=	self.myLeftControl.height + self.myRightControl.height;
				self.leftToRightRatio	:=	(self.myLeftControl.height / totalSize * 100).Integer;
 			else
				totalSize				:=	self.myLeftControl.width + self.myRightControl.width;
				self.leftToRightRatio	:=	(self.myLeftControl.width / totalSize * 100).Integer;
			endif;
 		endif;
 	else
 		if self.myLeftControl.visible then
 			self.leftToRightRatio	:=	100;
 		else
			self.leftToRightRatio	:=	0;
		endif;
	endif;
	
	// Following was moved from windowCreated to allow for control to be cloned at runtime (RJS 7Feb01).
	if (self.myLeftControl &lt;&gt; null) and
	   self.myLeftControl.visible and
	   (self.myRightControl &lt;&gt; null) and
	   self.myRightControl.visible	then
		self.setSplitDirection(self.isSplitHorizontal);
	endif;
end;</source>
        <Parameter name="_lControl" type="Control" usage="input"/>
        <Parameter name="_rControl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showLeftControl" id="a526f3ee-797c-4683-8809-7824cfe0f6f7">
        <updating/>
        <source>showLeftControl(pRatio : Integer; _doResize : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     14 November 2000 by cnwrs2
//
// Purpose:     Make visible the receiver's left-hand control and spliter bar.
//
// Parameters:  pRatio - The ratio (in percent) that the left control uses of
//					the parent control's width.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	true;
	else
		self.myVerticalSplitter.visible		:=	true;
	endif;

	if self.myLeftControl &lt;&gt; null then
		self.myLeftControl.visible	:=	true;
	endif;

	if _doResize then
		self.setLeftToRightRatioAndResize(pRatio);
	else
		self.setLeftToRightRatio(pRatio);
	endif;

end;</source>
        <Parameter name="pRatio" type="Integer"/>
        <Parameter name="_doResize" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showLeftControlAndSize" id="990865e4-c88a-4948-9787-17bd9d6e0e86">
        <updating/>
        <source>showLeftControlAndSize(_size : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     14 November 2000 by cnwrs2
//
// Purpose:     Make visible the receiver's left-hand control and spliter bar.
//
// Parameters:  _size - The ratio (in percent) that the left control uses of
//					the parent control's width.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	true;
	else
		self.myVerticalSplitter.visible		:=	true;
	endif;

	if self.myLeftControl &lt;&gt; null then
		self.myLeftControl.visible	:=	true;
	endif;

	self.setLeftToRightSizeAndResize(_size);
end;</source>
        <Parameter name="_size" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRightControl" id="9ccdb382-0204-40e6-8131-9700188023eb">
        <updating/>
        <source>showRightControl(pRatio : Integer; _doResize : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     Make visible the receiver's right-hand control and spliter bar.
//
// Parameters:  pRatio - The ratio (in percent) that the right control uses of
//					the parent control's width.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	true;
	else
		self.myVerticalSplitter.visible		:=	true;
	endif;

	if self.myRightControl &lt;&gt; null then
		self.myRightControl.visible	:=	true;
	endif;

	if _doResize then
		self.setLeftToRightRatioAndResize(100 - pRatio);
	else
		self.setLeftToRightRatio(100 - pRatio);
	endif;

end;</source>
        <Parameter name="pRatio" type="Integer"/>
        <Parameter name="_doResize" type="Boolean"/>
    </JadeMethod>
    <ExternalMethod name="splitterMove" id="0b580e20-c741-4034-a877-79128ac992c3">
