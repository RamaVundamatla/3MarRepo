    <JadeMethod name="isReefer" id="a4e0ce4b-67f7-467a-9ffc-1ec8e15a2396">
        <methodInvocation>mapping</methodInvocation>
        <source>isReefer(_set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	16 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.typeAttributes.bitOr(ISO_REEFER) &lt;&gt; 0;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
