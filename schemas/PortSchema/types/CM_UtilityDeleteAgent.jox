    <JadeMethod name="utlDeleteGate" id="b26c0137-4180-42ed-83a0-068d2527138a">
        <source>utlDeleteGate(_gate :CM_Gate io; _passport :CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valCM_Object (_gate, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_gate);
	endif;

	if _passport.noErrors then
		_gate.erase(NORMAL_ERASE);
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_GATE_DELETE), false, _gate);
	endif;

epilog

end;</source>
        <Parameter name="_gate" type="CM_Gate" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteGateScanRecords" id="c97efd9f-3bcb-4aa3-be0f-d36c4ff613e0">
        <source>utlDeleteGateScanRecords(_gateScanRecords : CM_GenericGateScanRecs io; _passport :CM_Passport input);
/*

Purpose:			Utility to delete a collection of GateScan Records from real objects passed in (They must be unassigned from a VVR)

Parameters:			_gateScanRecords	CM_GenericGateScanRecs 	A collection of gate scan records to delete
					_passport			CM_Passport				Passport to use for our Trx that holds errors and other useful data

Return Value:		NONE

Date		Who		Reason
12 April 2022	navpw1	Initial creation TFS: 52773

*/

vars
	gateScanRecord : CM_GenericGateScanRecord;
	
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	foreach gateScanRecord in _gateScanRecords do
		app.myValDA.valGateScanRecord(gateScanRecord, _passport);
	endforeach;
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	foreach gateScanRecord in _gateScanRecords do
		if gateScanRecord.myVVR &lt;&gt; null then
			continue;
		endif;
		
		if _passport.noErrors then
			self.myDeleteAuditAgent.audDeleteGeneric(gateScanRecord);
		endif;
		
		if _passport.noErrors then
			gateScanRecord.erase(NORMAL_ERASE);
		endif;
		
	endforeach;

end;</source>
        <Parameter name="_gateScanRecords" type="CM_GenericGateScanRecs" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteHMSObject" id="d65fde12-7081-4171-9d39-fb654dcb893c">
        <source>utlDeleteHMSObject(_hmsObj: HMS_Object io; _passport : CM_Passport input);
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
//19 Jan 2025 navrv30 JIRA 33641 MTN | Deleting HMS Shift Movement Leaves Arrival and Departure Incorrect
//-----------------------------------------
vars
	yaType : CM_YATypeVoyageBerth;
	previousHMSObject : HMS_Movement;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valHMS_Object(_hmsObj, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_hmsObj);
	endif;

	if _passport.noErrors then
		if _hmsObj.isKindOf(HMS_Berth) then
			yaType := CM_YATypeVoyageBerth.firstInstance;
			if yaType &lt;&gt; null then
				yaType.removeMyDataObject(_hmsObj);
			endif;
		endif;
		//19 Jan 2025 navrv30 JIRA 33641
		if _hmsObj.isKindOf(HMS_Movement) then
			previousHMSObject := _hmsObj.HMS_Movement.myPreviousMovement;
		endif;
		_hmsObj.causeHMSEvent(_hmsObj.EventMode_Delete);
		_hmsObj.setForDelete(_passport);
		//21.09.2020 cnwma1 TFS #49906
		if  _hmsObj.isKindOf(HMS_Berth) then
			if _passport.isOpsViewEnabled(null) then
				_hmsObj.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
												   BGP_OpsViewWSRequest.OPS_TYPE_BERTH,
												   _hmsObj);
			endif;
		endif;
		///21.09.2020 cnwma1 TFS #49906
		_hmsObj.erase(NORMAL_ERASE);
		//19 Jan 2025 navrv30 JIRA 33641
		if previousHMSObject&lt;&gt; null then
			previousHMSObject.HMS_Movement.maintainLinkedList();
		endif;
	endif;
epilog
	return;

end;</source>
        <Parameter name="_hmsObj" type="HMS_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteHandlingType" id="66628e85-b518-4d12-be4e-091aa785be04">
        <source>utlDeleteHandlingType(_handlingType : CM_HandlingType io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
