    <JadeMethod name="loadCompanies" id="caa98792-3b42-4a79-9366-a47bcebce4b5">
        <source>loadCompanies();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	co:      CM_Bank;
	index:   Integer;
	level:   Integer;
	iter	: Iterator;
	theList : CMUI_ListBox;
begin
	app.mousePointer := MousePointer_HourGlass;
	theList := self.lstData;
	
	theList.clear;

	index := 1;
	level := 1;

	iter := app.myRoot.myRootCompany.subCompanies.createIterator;
	app.myRoot.myRootCompany.subCompanies.startKeyGeq(self.myTerminal, null, iter);
	while iter.next(co) do
		if co.terminal &lt;&gt; self.myTerminal then
			break;
		endif;
		self.loadCompany(co, theList, level, index);
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCompany" id="b444b169-97d0-4d81-a6d0-4ad191546ec1">
        <source>loadCompany(co: CM_Bank; listbox: ListBox; level: Integer; index: Integer io);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	com:            CM_Bank;
	originalIndex:  Integer;
begin
	addCompanyAt(co, listbox, level, index, false);
	originalIndex := index;
	index := index + 1;

	foreach com in co.subCompanies do
		// should not need terminal check here as this is only
		// called for sub-companies
		addCompanyAt(com, listbox, level + 1, index, false);
		index := index + 1;
	endforeach;

	listbox.itemExpanded[originalIndex] := true;
end;</source>
        <Parameter name="co" type="CM_Bank"/>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="index" type="Integer" usage="io"/>
    </JadeMethod>
