<Class name="CM_YATypeDwellDays" id="24799e9b-54ef-45f1-b4a3-62086c206380">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="resourceTask"/>
    <JadeMethod name="getAllCriteriaValues" id="9623585a-be27-4739-80d2-3e4d989171cb">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2015	cnwmc5	Initial creation

*/

vars
	dwellDay		: CM_DwellDayRange;
	
begin
	
	foreach dwellDay in app.myRoot.allDwellDayRanges do
		_allCriteriaValues.add(dwellDay);
	endforeach;

epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="05a62031-c934-45b1-a00f-47bf3ed2e9ec">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2015	cnwmc5	Initial creation

*/

vars

begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);

epilog

end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="b3f198c8-6db0-4585-8578-0b0fe0ebc1c4">
        <source>getDisplay(dataObj: Object): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
