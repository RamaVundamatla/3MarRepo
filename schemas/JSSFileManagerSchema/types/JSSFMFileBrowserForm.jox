    <JadeMethod name="tblFilesTop_click" id="660f57a1-a26d-4536-a010-f4e7bf0fc400">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFilesTop_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setState(Busy);
	
	if table.row &lt;= table.fixedRows then
		self.tableSort(table);
	else
		self.statusSetSelectedCount(table);
		self.statusResizeObjectCounts();
	endif;
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblFilesTop_dragDrop" id="120b269f-c83d-4ba1-93d7-38fd568ac208">
