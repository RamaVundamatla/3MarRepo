    <JadeMethod name="getMyTerminal" id="875ae790-1576-4543-9598-152f8d0c9747">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2016	cnwns1	Initial creation
//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	
	return self.myTerminal;

epilog

end;</source>
