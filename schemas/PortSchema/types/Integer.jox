    <JadeMethod name="unsetBit" id="9effc00d-bccf-4b9f-8685-0ab8b0e44d3e">
        <source>unsetBit(bitToUnset : Integer);
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			Method to unset a bit on an integer
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	notF : Integer;
begin
	notF := bitToUnset;
	notF := notF.bitNot();
	self.bitOr(notF);	//Turn OFF the no bit
end;</source>
        <Parameter name="bitToUnset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zeroNotAllowed" id="53aa7aa7-d16f-40d9-bbf1-0cc0f5b860a9">
