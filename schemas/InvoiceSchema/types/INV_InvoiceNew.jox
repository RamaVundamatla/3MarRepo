    <JadeMethod name="cmbCargoTA_change" id="c99a7b8a-301e-4981-84cf-f1ca4aaaef57">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoTA_change(combobox: ComboBox input) updating;
/*

Purpose:			Sets the ent table to the value of the combo box

Parameters:			combobox	ComboBox	The combobox that lost focus

Return Value:		NONE

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	priorLocation			: CM_LocationsController;
	ta						: CM_TerminalArea;
	locationControllerArray	: ObjectArray;

begin
	ta				:= combobox.listObject.CM_TerminalArea;
	priorLocation	:= self.cmbCargoLoc.listObject.CM_LocationsController;

	self.tblCargo.setValueByControlName(combobox.name,combobox.text);
	
	self.cmbCargoLoc.clear();
	
	if ta &lt;&gt; null then
		create locationControllerArray transient;
		ta.getAllMachineVehicleConts(locationControllerArray);
		ta.getAllLocationsControllers(locationControllerArray);
		self.cmbCargoLoc.listCollection(locationControllerArray, false, 0);
		
		if priorLocation &lt;&gt; null then
			self.cmbCargoLoc.listIndex := self.cmbCargoLoc.findObject(priorLocation);
		endif;
		
		if locationControllerArray.size = 1 and self.cmbCargoLoc.listIndex &lt; 1 then
			self.cmbCargoLoc.listIndex := self.cmbCargoLoc.findObject(locationControllerArray.first);
		endif;
		
	endif;

epilog
	delete locationControllerArray;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoTA_displayEntry" id="457abb5b-a762-44a3-8c7b-f5af689aa602">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoTA_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
