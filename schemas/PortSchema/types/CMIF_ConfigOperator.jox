    <JadeMethod name="isObjectCorrectType" id="78c2c071-5303-448d-99a2-00a910bc617e">
        <source>isObjectCorrectType(_obj: CM_Object): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     16 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin	
	
	if _obj.isKindOf(CM_Operator) then
		return true;
	endif;
	
	app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown class (' &amp; _obj.String &amp; ')');
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromPersistentData" id="75be632a-29d0-463a-9403-2010ad1dc8aa">
        <updating/>
        <source>setFromPersistentData(_op: CM_Operator) updating;
// ---------------------------------------------------------------------------
// Created:     16 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	propCol		: PropertyColl;
	prop		: Property;
	keyStr		: String;
	
begin

	inheritMethod(_op);

	propCol := self.class.allPropertiesUpTo(CMIF_Config);
	
	foreach prop in propCol do
		if self.isPropertyToIgnore(prop) then
			continue;
		endif;
		keyStr := self.getKeyStringForProperty(prop.name);
		
		if keyStr &lt;&gt; null then			
			self.setPropertyFromStringValue(prop, _op.getConfig(keyStr));
		else
			// need to handle as a special
			app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '&gt;&gt;&gt;&gt; special ' &amp; prop.name);
		endif;
	endforeach;
epilog
	delete propCol;
end;</source>
        <Parameter name="_op" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setXMLTagForType" id="ccf7c27d-3a71-4fda-b276-7e776dbc7b96">
        <updating/>
        <source>setXMLTagForType() updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.xmlTagForType := self.XMLTag_LvlOperator;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updatePersistentObject" id="28563299-a97b-4044-b86f-9078e2ebe0e8">
        <source>updatePersistentObject(_operator : CM_Operator input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     08 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	propCol	: PropertyColl;
	prop	: Property;
	keyStr	: String;
	
begin

	inheritMethod(_operator, _passport);
	
	propCol := self.class.allPropertiesUpTo(CMIF_Config);
	
	foreach prop in propCol do
		if self.isPropertyToIgnore(prop) then
			continue;
		endif;
		keyStr := self.getKeyStringForProperty(prop.name);

		if keyStr &lt;&gt; null then
			_operator.setConfig(keyStr, self.getPropertyValue(prop.name));
		else
			// need to handle as a special
			app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '&gt;&gt;&gt;&gt; special ' &amp; prop.name);
		endif;
	endforeach;
epilog
	delete propCol;
end;</source>
        <Parameter name="_operator" type="CM_Operator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
