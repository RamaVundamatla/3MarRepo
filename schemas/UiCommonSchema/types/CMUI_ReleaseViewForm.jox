	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnUpgradeJMT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnUpgradeJMTSys, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowInfo, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

end;</source>
