*/

vars
	trainHasArrived, trainHasDeparted, isOnsite : Boolean;
begin
	trainHasArrived  := self.arrivalDT.Date.isValid;
	trainHasDeparted  := self.departureDT.Date.isValid;
	
	isOnsite := trainHasArrived and not trainHasDeparted;

	return isOnsite;
epilog

end;</source>
