    <JadeMethod name="tblReeferJobs_contextMenu" id="57792cd3-f442-4558-b026-525a0844deef">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReeferJobs_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	rowIndex : Integer;
	obj : Object;

begin

	rowIndex := self.tblReeferJobs.row;
	if rowIndex &gt; 1 then
		obj := self.tblReeferJobs.accessRow( rowIndex ).itemObject;
	endif;

	self.mnuInspectObj.visible := obj &lt;&gt; null and ( app.isDevelopmentSystem or app.getMyUser.isSuperUser );
	self.mnuInspectObj.userObject := obj;
	
	return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblReeferJobs_dblClick" id="d8cdfdd6-9280-4b3b-a093-321acaecf689">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReeferJobs_dblClick(table: Table input) updating;
/*
Purpose:			

Date		Who		Reason
09JUL2021	NAVAB1	TFS 51455
*/

vars


	rowIndex : Integer;
	reeferJob : CM_YardActivity;

begin

	rowIndex := self.tblReeferJobs.row;
	if rowIndex &gt; self.tblReeferJobs.fixedRows then
		reeferJob := self.tblReeferJobs.accessRow( rowIndex ).itemObject.CM_YardActivity;
	endif;
	if reeferJob = null then
		return;
	endif;

	if reeferJob.myTrackedItem &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(reeferJob.myTrackedItem, self.myMasterMenuAction, true, false);	 
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
