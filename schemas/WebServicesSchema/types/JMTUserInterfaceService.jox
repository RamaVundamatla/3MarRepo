    <JadeWebServicesMethod name="setUserStateData" id="10010494-1b40-4673-b1b6-bb05961dd4b0">
        <source>setUserStateData(_stateData : WS_StateData) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2015	cnwmc5	Initial creation

*/


vars
	response		: WS_StateDataResponse;
	completedOK		: Boolean;
	
	stateData		: WS_StateData;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(99999);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if _stateData = null then
		//app.raiseCMException(null, null, null);
		completedOK := true;
		return response;
	endif;
	
	if _stateData.key = null or _stateData.value = null then
		//app.raiseCMException(null, null, null);
		completedOK := true;
		return response;
	endif;
	
	app.myTrxUA.trxUpdateUserStateData(app.getMyUser(), ConfigGrp_Web, _stateData.key, _stateData.value, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="_stateData" type="WS_StateData"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="submitVoyageRequest" id="ae7494ef-ce5a-402a-8efb-11d2c84cd26b">
        <source>submitVoyageRequest(request : WS_CreateVoyageRequest)  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 September 2021	jlier1	Initial creation 51963
18 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
26 March 2024		navpw1	TFS: 62849 (62927) - Reverted Code by adding beginLoad/endLoad

*/

vars
	response : WS_Response;
	completedOK : Boolean;
	voyageStatus : CM_VoyageStatus;
	voyage : CM_Voyage;
	pxyDtl,
	woDtl : CM_WodVoyageRequest;
	allDocuments		: ObjectArray;
	pxyWorkOrder : CM_WorkOrder;
	voyageProcess : CM_VoyageProcess;
	
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmVoyageDefEdit);		// Replace with appropriate permission
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.myTerminal = null then
		completedOK:=true;
		return response;
	endif;

	voyage:=app.myPassport.getObjectOfTypeFromOid(request.cmObjectId,CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	
	if voyage = null then
		// create the voyage TFS 52302 8/11/21
		request.createVoyageRequest(true);
		
		completedOK:=true;
		return response;
	endif;	
	
	voyageProcess := app.myPassport.myTerminal.getDefaultVoyageProcess();
	if voyageProcess = null then
		app.raiseCMException(Voyage_process_selected,null,null);
		completedOK := true;
		return response;
	endif;
	
	if voyageProcess.isEUPDefaultProcess then																		// TFS 54298
		if voyage.status &lt;&gt; Voyage_Status_EUP_VoyReq  and voyage.status &lt;&gt; Voyage_Status_EUP_VoyReqRej then			// TFS 54298
			app.raiseCMException2(Voyage_incorr_status_this_acti,voyage.code,voyage.statusDescription,null ,null);	// TFS 54298
			completedOK:=true;																						// TFS 54298
			return response;																						// TFS 54298
		endif;
	elseif voyage.status &lt;&gt; Voyage_Status_VoyRequested  and voyage.status &lt;&gt; Voyage_Status_VoyReqRejected then
		app.raiseCMException2(Voyage_incorr_status_this_acti,voyage.code,voyage.statusDescription,null ,null);
		completedOK:=true;
		return response;
	endif;
	
	if voyageProcess.isEUPDefaultProcess then											// TFS 54298
		voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_EUP_VoyReqSubm];		// TFS 54298
	else
		voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_VoyReqSubmitted];
	endif;
	
	if not voyageStatus.userCanSet(app.myPassport.myTerminal) then
		app.raiseCMException2(Cannot_Set_Voyage_Status, app.myPassport.myTerminal.code, voyageStatus.description, "status", null);
		completedOK:=true;
		return response;
	endif;
	
	woDtl := voyage.getWorkOrderForVoyageRequest();	
	if woDtl = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK := true;
		return response;
	endif;
	beginLoad;
		pxyWorkOrder:=woDtl.getMyParent.pxyCreateUpdateProxy.CM_WorkOrder;
		pxyDtl:=woDtl.pxyGetProxyObject.CM_WodVoyageRequest;
	endLoad;
	pxyWorkOrder.setTaskStatus(WO_STATUS_PENDING);
	request.updatePxyVoyageRequest(pxyDtl);

	create allDocuments transient;
	beginLoad;
	request.allDocuments.setProxyDocuments(allDocuments);
	endLoad;
	
	app.myPassport.setWarningsIgnored( true);
	app.myPassport.setWarningsAcknowledged( true);
	app.myTrxUA.trxUpdateVoyageRequest(pxyWorkOrder,allDocuments,app.myPassport);

		// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	endLoad;
	delete pxyWorkOrder;
	if allDocuments &lt;&gt; null then
		allDocuments.purge;
		delete allDocuments;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_CreateVoyageRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateBooking" id="907d8f4c-c268-456d-90c8-7af5eef87a88">
        <source>updateBooking(bookingRequest : WS_BookingUpdateRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/10/2014	cnwmc5	Initial creation
11/06/2015	cnwdap1	PAR #36421 Changed signature for CM_TIHazard::setProxy
16/11/2016	cnwdap1	TFS 2842 Changed signature for CM_TIHazard::setProxy
05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
30/09/2019	jlgzm1	TFS 46575 GUI, Web, EDI createing Booking ref items differently
15/01/2020	jlgdap1	TFS 47457 Web Portal Bookings
04/11/2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
08/01/2021  cnwma1  Bug 50346: ASPA - Error 80017 while editing a booking with Received Item on Web Portal
26/11/2021  navmj1  TFS 51856 Booking marks not being saved
01 Aug 2024 navah1  Bug 65484: SNO - Unable to update a booking status via the web portal 
14-Jan-2026 navtr3	MTN-36695 SNO - Release Empties - Thin client Webservices changes
*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	bookingRef,
	pxyBookingRef	: CM_BookingRef;
	wsBooking		: WS_Booking;
	destination,
	discharge		: String;
	consignee,
	consignor,
	freightFwder	: CM_ConsigneeConsignor;
	operator		: CM_Operator;
	voyage,
	transhipVoyage	: CM_Voyage;
	customsAgent,
	carrier			: String;
	newBulkRelease	: CM_BulkRelease;
	wsBookingItem	: WS_BookingItem;
	bookingRefItem,
	pxyBookingRefItem,
	tmpBookingRefItem : CM_BookingRefItem;
	newBookingRefItem : CM_BRefItemContainer; // TFS 46575
	cargoType		: CM_CargoType;
	dischargePorts	: StringArray;
	temp			: Real;
	commodity,
	isoType,
	isoGroup		: String;
	load			: Boolean;
	obj				: Object;
	statusCode		: Integer;
	failedDAC		: CM_DataAccessController;
	bookingRefItemOID	: String;
	matchFound		: Boolean;
	hazards			: CM_HazardByCodeDict;
	tiHazard		: CM_TIHazard;
	wsTIHazard		: WS_TIHazard;
	bookHazards		: ObjectArray;
	allBookHazards	: CM_HazardByCodeDict;
	permissionsToCheck : IntegerArray;				// TFS 47457
	product 		: CM_Product;					// TFS 47457
	specialStow 	: CM_SpecialStow;				// TFS 47457
	allSpecialLifts	: CM_SpecialLiftByCodeDict;		// TFS 47457
	wsSpecialLift 	: WS_SpecialLift;				// TFS 47457
	specialLift		: CM_SpecialLift;				// TFS 47457
	stevedore       : CM_Stevedore; 
	// Release Empties variables					MTN-36695
	wsBulkRelease	: WS_BulkRelease;
	_pxyBulkRelease	: CM_BulkRelease;
	noFullsIn,
	noEmptiesOut	: Boolean;
	consigneeCode,
	consignorCode,
	carrierReleaseReqCode,
	freightForwarderCode,
	releaseId,
	deliveryReasonDesc	: String;
	destinationPort,
	dischargePort,
	loadPort		: CM_Port;
	transType		: Integer;
	subTerminal		: CM_SubTerminal;
	deliveryReason	: CM_DeliveryReleaseReason;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	create permissionsToCheck transient;								// TFS 47457
	permissionsToCheck.add(PmGteBookingRefMaint);						// TFS 47457
	permissionsToCheck.add(PmWebBookingMaint);							// TFS 47457
	//app.checkCurrentUserHasAccess(PmGteBookingRefMaint);				// TFS 47457
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);	// TFS 47457
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsBooking := bookingRequest.myBooking;
	
	bookingRef := app.myPassport.myTerminal.allBookingRefsByRef[wsBooking.bookingReference];
	
	if bookingRef = null then
		app.raiseCMException1(Matching_found, app.getErrorString(Booking), null, null);
		completedOK := true;
		return response;
	endif;
	
	if not bookingRef.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException(ERR_dontHaveAccessToThisItem, null, null);
		completedOK := true;
		return response;
	endif;
	
	create dischargePorts transient;
	create bookHazards transient;
	create allBookHazards transient;
	create allSpecialLifts transient;					// TFS 47457
	 
	destinationPort := null;
	if wsBooking.destination &lt;&gt; null then
		destination := wsBooking.destination.code;
		destinationPort := app.myRoot.allPorts[destination];
	endif;
	
	dischargePort := null;
	if wsBooking.dischargePort &lt;&gt; null then
		discharge := wsBooking.dischargePort.code;
		dischargePort := null;
	endif;
	
	if wsBooking.consignee &lt;&gt; null then
		consignee := app.myRoot.allConsigneeConsignors[wsBooking.consignee.code];		
		consigneeCode := consignee.code;
	endif;
	
	if wsBooking.consignor &lt;&gt; null then
		consignor := app.myRoot.allConsigneeConsignors[wsBooking.consignor.code];
		consignorCode := consignor.code;
	endif;
	
	if wsBooking.operator &lt;&gt; null then
		operator := app.myRoot.allOperators[wsBooking.operator.code];
	endif;
	
	if wsBooking.customsAgent &lt;&gt; null then
		customsAgent := wsBooking.customsAgent.code;
	endif;
	
	if wsBooking.freightForwarder &lt;&gt; null then
		freightFwder := app.myRoot.allConsigneeConsignors[wsBooking.freightForwarder.code];
	endif;
	
	if wsBooking.carrier &lt;&gt; null then
		carrier := wsBooking.carrier.code;
	endif;
	
	if wsBooking.stevedoreCode &lt;&gt; null then        								//02.10.2020 cnwma1 TFS #50112
		stevedore := app.myRoot.allStevedores[wsBooking.stevedoreCode];
	endif;
	
	if wsBooking.status &lt;&gt; null then
		statusCode := wsBooking.status.id;
	endif;
	 
	// Check for WS_BulkRelease for Release Empties

	wsBulkRelease := wsBooking.bulkRelease;
	noEmptiesOut := false;
	
	if wsBulkRelease &lt;&gt; null then
		noEmptiesOut := true;
		noFullsIn := wsBulkRelease.noFullsIn;
	endif;
	
	voyage := app.myPassport.myTerminal.lookupVoyage(wsBooking.voyageCode, null, false);
	transhipVoyage := app.myPassport.myTerminal.lookupVoyage(wsBooking.transhipOriginalVoyage, null, false);
	
	app.cmsBeginLoad(load);
	pxyBookingRef := bookingRef.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	bookingRef.allTIHazards.copy(allBookHazards);

	pxyBookingRef.setProxy(wsBooking.bookingReference,
						pxyBookingRef.cargoType,
						pxyBookingRef.clean,
						pxyBookingRef.commodity,
						pxyBookingRef.consignorReference,
						pxyBookingRef.description,
						destination,
						discharge,
						pxyBookingRef.myTranshipToPort,
						dischargePorts,
						bookHazards,		//review - hazards
						pxyBookingRef.getHumidity,
						pxyBookingRef.inspected,
						pxyBookingRef.isoType,
						consignor,
						consignee,
						operator,
						voyage,
						pxyBookingRef.quantity,
						wsBooking.bookingRemarks,
						wsBooking.remarks,
						pxyBookingRef.temperature,
						pxyBookingRef.ventilation,
						pxyBookingRef.height,
						pxyBookingRef.length,
						pxyBookingRef.width,
						pxyBookingRef.heightString,
						pxyBookingRef.lengthString,
						pxyBookingRef.widthString,
						pxyBookingRef.typeString,
						pxyBookingRef.density,
						pxyBookingRef.volume,
						pxyBookingRef.productQuantity,
						pxyBookingRef.weight,
						pxyBookingRef.cubicMetres,
						app.myPassport.myTerminal,
						pxyBookingRef.myProduct,
						true,
						wsBooking.isStockBooking,
						pxyBookingRef.myEDIBookingRefTI,
						pxyBookingRef.rawEDIData,
						wsBooking.shippingReference,
						carrier,
						pxyBookingRef.consignorDesc,
						pxyBookingRef.consigneeDesc,
						pxyBookingRef.myCustomerPriority,
						pxyBookingRef.mySpecialStow,
						pxyBookingRef.holdPartials,
						noFullsIn, //Release empties
						noEmptiesOut, //Release empties
						pxyBookingRef.isMilitary,
						pxyBookingRef.vNumber,
						pxyBookingRef.overrideCutoff,
						pxyBookingRef.overDimension,
						pxyBookingRef.fumigationNeeded,
						pxyBookingRef.isStopped,
						statusCode,				//pxyBookingRef.status,					//01.08.2024 navah1 #65484	
						pxyBookingRef.ediFileIssueDateTime,
						null,								//pxyBookingRef.allSpecialLifts,		//review - specialLift
						pxyBookingRef.allLinkedStockBookingItems,
						wsBooking.receiveAsTranship,
						transhipVoyage,
						app.bookingPackAsStringToEnumb(wsBooking.packAs.toUpper),
						customsAgent,
						pxyBookingRef.ediVoyageCode,
						pxyBookingRef.ediVesselName,
						wsBooking.isDirectDelivery,         //pxyBookingRef.directDelivery,			//02.08.2024 navah1 #65484
						freightFwder,
						null, 	//carrier,
						stevedore                       //02.10.2020 cnwma1 TFS #50112
						);
	
	//Delete booking items that aren't included
	foreach pxyBookingRefItem in pxyBookingRef.allBookingRefItems do
		
		//bookingRefItemOID := pxyBookingRefItem.getOidString();                       //08.01.2021 cnwma1 #50346
		if pxyBookingRefItem.pxyGetRealObject() &lt;&gt; null then
			bookingRefItemOID := pxyBookingRefItem.pxyGetRealObject.getOidString();   //08.01.2021 cnwma1 #50346
		endif;
		matchFound := false;
		
		foreach wsBookingItem in wsBooking.allBookingItems do
			if bookingRefItemOID = wsBookingItem.cmObjectId then
				matchFound := true;
				break;
			endif;
		endforeach;
		
		if not matchFound then
			delete pxyBookingRefItem;
		endif;
	endforeach;
	
	//Create and update booking items
	foreach wsBookingItem in wsBooking.allBookingItems do
		tmpBookingRefItem := null;		//cnwmc5 - 25 Nov 2014 - CCMS 2429
		
		if wsBookingItem.cargoType &lt;&gt; null then
			cargoType := app.myRoot.allCargoTypesById[wsBookingItem.cargoType.id];
			if cargoType = null then
				app.raiseCMException(ERR_INVALID_TI_TYPE, null, null);
				completedOK := true;
				return response;
			endif;
		endif;
		
		temp := wsBookingItem.temperature;
		if temp = 0 then
			temp := NULL_TEMPERATURE;
		endif;
		
		commodity := null;										// TFS 47457
		if wsBookingItem.commodity &lt;&gt; null then
			commodity := wsBookingItem.commodity.code;
		endif;
		
		isoType := null;										// TFS 47457
		if wsBookingItem.isoType &lt;&gt; null then
			isoType := wsBookingItem.isoType.code;
		endif;
		
		isoGroup := null;										// TFS 47457
		if wsBookingItem.isoGroup &lt;&gt; null then
			isoGroup := wsBookingItem.isoGroup.code;
		endif;
		
		//Get the pxy object based off the real one
		if wsBookingItem.cmObjectId &lt;&gt; null then
			//epr TFS 5535 9/8/17
			bookingRefItem := app.myPassport.getObjectOfTypeFromOid(wsBookingItem.cmObjectId,CM_BookingRefItem).CM_BookingRefItem;
			if bookingRefItem &lt;&gt; null  then
				tmpBookingRefItem := bookingRefItem.pxyGetProxyObject();
			else
				app.raiseCMException1(Matching_found, app.getErrorString(Booking_Item), null, null);
				completedOK := true;
				return response;
			endif;
		endif;
		
		if wsBookingItem.allTIHazards &lt;&gt; null and not wsBookingItem.allTIHazards.isEmpty then
			create hazards transient;
			foreach wsTIHazard in wsBookingItem.allTIHazards do
				create tiHazard transient;
				//tiHazard.setProxy(	wsTIHazard.code,							// TFS 2842
				//					wsTIHazard.description,							// TFS 2842
				//					wsTIHazard.undgCodes,							// TFS 2842
				//					null,											// TFS 2842
				//					wsTIHazard.limitedQuantity.asBooleanJMT,		// TFS 2842
				//					null);											// TFS 2842
				tiHazard.setProxy(	wsTIHazard.code,								// TFS 2842
									wsTIHazard.description,							// TFS 2842
									wsTIHazard.undgCodes,							// TFS 2842
									null,											// TFS 2842
									wsTIHazard.limitedQuantity.asBooleanJMT,		// TFS 2842
									wsTIHazard.packingGroup,						// TFS 2842		// TFS 47457
									wsTIHazard.flashpointTemperature,				// TFS 2842		// TFS 47457
									wsTIHazard.marinePollutant,						// TFS 2842		// TFS 47457
									wsTIHazard.acidsBases	);						// TFS 2842		// TFS 47457
				hazards.add(tiHazard);
				allBookHazards.addNoDuplicates(tiHazard, false);
			endforeach;
		endif;
		
		// TFS 47457 product, special stow and special lifts
		product := null;
		if wsBookingItem.product &lt;&gt; null then
			if operator &lt;&gt; null then
				product := cargoType.allProducts[operator.code, wsBookingItem.product.code];
			endif;
			if product = null then
				product := cargoType.allProducts[null, wsBookingItem.product.code];
			endif;
		endif;
		specialStow := null;
		if wsBookingItem.specialStow &lt;&gt; null then
			specialStow := app.myRoot.allSpecialStows[wsBookingItem.specialStow];
		endif;
		allSpecialLifts.clear;
		foreach wsSpecialLift in wsBookingItem.allSpecialLifts do
			specialLift := app.myRoot.allSpecialLifts[wsSpecialLift.code];
			if specialLift &lt;&gt; null then
				allSpecialLifts.addNoDuplicates(specialLift, false);
			endif;
		endforeach;
		// TFS 47457
		
		if tmpBookingRefItem = null or not pxyBookingRef.allBookingRefItems.includes(tmpBookingRefItem) then
			//create pxyBookingRefItem as pxyBookingRef.getBookingRefItemClass(cargoType) transient;
			create newBookingRefItem transient;	// TFS 46575
			// TFS 47457 different setproxy methods for container and non-container
			if cargoType.isContainer then
				newBookingRefItem.setProxy(cargoType.id,
										commodity,
										null,		//review - description
										wsBookingItem.remarks,
										hazards,
										isoType,
										wsBookingItem.quantity,
										wsBookingItem.weight,
										wsBookingItem.maxToRelease,		//review - maxToRelease
										wsBookingItem.grade,		//review - grade
										wsBookingItem.humidity,
										temp,
										wsBookingItem.vent,
										wsBookingItem.ventUnits,
										wsBookingItem.carbonDioxide,
										wsBookingItem.oxygen,
										wsBookingItem.curtainsIn,
										wsBookingItem.clean,		//review - isClean
										wsBookingItem.heavyRated,		//review - heavyRated
										specialStow,							// TFS 47457
										isoGroup,
										wsBookingItem.inspected,		//review - inspected
										allSpecialLifts,						// TFS 47457
										wsBookingItem.purchaseOrder,			// TFS 47457
										wsBookingItem.serviceOrder,				// TFS 47457
										wsBookingItem.matchMode);				//navra1 - CR 63764/Task 64227 - 23rd May 2024
			// TFS 47457 start
			else
				newBookingRefItem.setProxyForCargo(cargoType.id,
										commodity,
										null,
										hazards,
										wsBookingItem.quantity,
										wsBookingItem.remarks,
										wsBookingItem.height,
										wsBookingItem.length,
										wsBookingItem.width,
										null,						// _heightString
										null,						// _lengthString
										null,						// _widthString
										null,						// _type
										wsBookingItem.density.Integer,
										wsBookingItem.volume,
										wsBookingItem.productQuantity,
										wsBookingItem.marks,		// _shippingMarks - TFS 51856
										wsBookingItem.weight,
										product,
										null,						// _ediBookingRefTI
										null,						// _rawEDIData
										wsBookingItem.generatorType,
										specialStow,
										wsBookingItem.cargoID,
										wsBookingItem.colour,
										wsBookingItem.markNumber,
										allSpecialLifts,
										wsBookingItem.productWeight,
										wsBookingItem.productVolume,
										wsBookingItem.trailerTypeCode,
										wsBookingItem.purchaseOrder,
										wsBookingItem.serviceOrder,
										wsBookingItem.matchMode);								//navra1 - CR 63764/Task 64227 - 23rd May 2024
			endif;
			// TFS 47457 end
			
			pxyBookingRef.allBookingRefItems.add(newBookingRefItem); // TFS 46575
			
			if pxyBookingRef.isReleaseEmptiesAllowed and noEmptiesOut then //Only Applicable to ISO Containers //MTN-36695
			 newBookingRefItem.setProxyReserveDetail(wsBookingItem.quantity, wsBookingItem.maxToRelease, wsBookingItem.grade,wsBookingItem.heavyRated);		
			endif;
		
		else
			// TFS 47457 different setproxy methods for container and non-container
			if cargoType.isContainer then
				tmpBookingRefItem.setProxy(cargoType.id,
										commodity,
										tmpBookingRefItem.description,
										wsBookingItem.remarks,
										hazards,
										isoType,
										wsBookingItem.quantity,
										wsBookingItem.weight,
										wsBookingItem.maxToRelease,
										wsBookingItem.grade,		//review - grade
										wsBookingItem.humidity,
										temp,
										wsBookingItem.vent,
										wsBookingItem.ventUnits,
										wsBookingItem.carbonDioxide,
										wsBookingItem.oxygen,
										wsBookingItem.curtainsIn,
										wsBookingItem.clean,
										wsBookingItem.heavyRated,		//review - heavyRated
										specialStow,							// TFS 47457
										isoGroup,
										wsBookingItem.inspected,
										allSpecialLifts,						// TFS 47457
										wsBookingItem.purchaseOrder,			// TFS 47457
										wsBookingItem.serviceOrder,				// TFS 47457
										wsBookingItem.matchMode);				//navra1 - CR 63764/Task 64227 - 23rd May 2024
			// TFS 47457 start
			else
				tmpBookingRefItem.setProxyForCargo(cargoType.id,
										commodity,
										tmpBookingRefItem.description,
										hazards,
										wsBookingItem.quantity,
										wsBookingItem.remarks,
										wsBookingItem.height,
										wsBookingItem.length,
										wsBookingItem.width,
										tmpBookingRefItem.heightString,
										tmpBookingRefItem.lengthString,
										tmpBookingRefItem.widthString,
										tmpBookingRefItem.typeString,
										wsBookingItem.density.Integer,
										wsBookingItem.volume,
										wsBookingItem.productQuantity,
										wsBookingItem.marks,					//_shippingMarks - TFS 51856
										wsBookingItem.weight,
										product,
										tmpBookingRefItem.getEDIBookingRefTI,
										tmpBookingRefItem.rawEDIData,
										wsBookingItem.generatorType,
										specialStow,
										wsBookingItem.cargoID,
										wsBookingItem.colour,
										wsBookingItem.markNumber,
										allSpecialLifts,
										wsBookingItem.productWeight,
										wsBookingItem.productVolume,
										wsBookingItem.trailerTypeCode,
										wsBookingItem.purchaseOrder,
										wsBookingItem.serviceOrder,
										wsBookingItem.matchMode);						//navra1 - CR 63764/Task 64227 - 23rd May 2024
			endif;
			// TFS 47457 end
			
			if pxyBookingRef.isReleaseEmptiesAllowed and noEmptiesOut then //Only Applicable to ISO Containers	//MTN-36695
			 tmpBookingRefItem.setProxyReserveDetail(wsBookingItem.quantity, wsBookingItem.maxToRelease, wsBookingItem.grade,wsBookingItem.heavyRated);		
			endif;
			
		endif;
		
	endforeach;
	
	if not allBookHazards.isEmpty then
		pxyBookingRef.setPxyHazards(allBookHazards);
	endif;
	
	// Release Empties - Process WS_BulkRelease if present and booking allows release empties MTN-36695
	if wsBulkRelease &lt;&gt; null and pxyBookingRef &lt;&gt; null and pxyBookingRef.isReleaseEmptiesAllowed and noEmptiesOut then
		// Get or create bulk release if it doesn't exist
		if pxyBookingRef.allReleaseRequests.isEmpty then
			create _pxyBulkRelease as CM_BulkRelease transient;
			_pxyBulkRelease.setBookingRefStock(pxyBookingRef);
		else
			_pxyBulkRelease := pxyBookingRef.allReleaseRequests.first;
		endif;
		
		if _pxyBulkRelease &lt;&gt; null then
			// Get values from WS_BulkRelease
			if wsBulkRelease.carrier &lt;&gt; null then
				carrierReleaseReqCode := app.myRoot.allCarriers[wsBulkRelease.carrier.code].code;
			endif;
			
			releaseId := wsBooking.bookingReference;
			
			if wsBulkRelease.transType = BR_TYPE_ROAD then
				transType := BR_TYPE_ROAD;
			elseif  wsBulkRelease.transType = BR_TYPE_RAIL then
				transType := BR_TYPE_RAIL;
			elseif  wsBulkRelease.transType = BR_TYPE_SHIP then
				transType := BR_TYPE_SHIP;
			endif;
			
			loadPort := null;
			if wsBulkRelease.myLoadPort &lt;&gt; null then
				loadPort := app.myRoot.allPorts[wsBulkRelease.myLoadPort.code];
			endif;
			
			if pxyBookingRef.myTerminal.isSubTerminalsOn then
				if transType = BR_TYPE_PACKING then
					subTerminal := pxyBookingRef.myTerminal.getConfig(MySubTerminalForSourceBulkPack).CM_SubTerminal;
				elseif transType = BR_TYPE_ROAD then
					subTerminal := pxyBookingRef.myTerminal.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal;
				elseif transType = BR_TYPE_RAIL then
					subTerminal := pxyBookingRef.myTerminal.getConfig(MySubTerminalForSourceBulkRail).CM_SubTerminal;
				endif;
			endif;
			
			foreach deliveryReason in app.myRoot.allDeliveryReasonselReasons do
				if deliveryReason.id = wsBulkRelease.deliveryReasonCode then
					deliveryReasonDesc := deliveryReason.description;
				endif;
			endforeach;			
			
			_pxyBulkRelease.setProxy(releaseId, //code same as this booking reference number
									transType,							//Release Empties
									true,
									BR_ACTIVE,
									null, ///availability grades null set on reserve selections
									null,//booking confirmation 
									carrierReleaseReqCode, //carrierId				//Release Empties
									null, //cargo remarks
									consigneeCode,		//consigneeCode
									null,
									consignorCode,		//consignor Code
									null,
									null,//_consignorVoyageCode 
									null, //date requested
									null,//_dateEstimatedRequired
									wsBulkRelease.deliveryReasonCode,//_deliveryReasonCode			//Release Empties
									deliveryReasonDesc,//_deliveryReasonDescr						//Release Empties
									wsBulkRelease.deliveryReleaseNumber,//_deliveryReleaseNumber	//Release Empties	
									null,//_doorsDirection
									null,//_freightPayerCode
									pxyBookingRef,//CM_BookingRef
									loadPort,//_loadPort				//Release Empties
									destinationPort,//_destinationPort	
									dischargePort,//_dischargePort
									freightForwarderCode,//_freightForwarder
									null,//_transferToTerminal
									pxyBookingRef.myTerminal,
									operator,//_operator
									null,//_operatorGroup
									voyage,//_voyage
									null,		//_businessUnit	
									null,		//_fullRelease	
									null,  //pack locations
									null,
									null,
									subTerminal,
									pxyBookingRef.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal, // subterm target
									null,
									false,
									customsAgent,
									false,
									false,
									_pxyBulkRelease.needsReview,
									_pxyBulkRelease.blockEDIUpdates,
									null,
									null,
									null,
									null
									);
		_pxyBulkRelease.requests.purge();
		endif;
	endif;
		
	self.setIgnoreWarnings(true);			//cnwmc5 - 5 Feb 2015 - PAR 35639
	app.myTrxUA.trxUpdateBookingBulkRel(pxyBookingRef, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	delete dischargePorts;
	if hazards &lt;&gt; null and not hazards.isEmpty then
		hazards.purge();
	endif;
	delete hazards;
	delete pxyBookingRef;
	delete bookHazards;
	delete allBookHazards;
	if allBookHazards &lt;&gt; null and not allBookHazards.isEmpty then
		allBookHazards.purge();
	endif;
	delete permissionsToCheck;				// TFS 47457
	delete allSpecialLifts;					// TFS 47457
	
	app.cmsEndLoad(load);
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="bookingRequest" type="WS_BookingUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateBulkRelease" id="b80895b7-4466-48b2-bf3d-6e72aa7c3de7">
        <source>updateBulkRelease(bulkReleaseRequest : WS_BulkReleaseUpdateRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#	Description
============================================================================
16/10/2014	cnwmc5	Initial creation
01/07/2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
06/09/2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
28/08/2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
24/01/2019	jlgka1	41708	As a result of the changes in the CM_BulkRelease.setProxy
							we also need to add myBOLIn here.
12/09/2019	cnwma1	Bug 46485: JMT - Web Portal - Warnings do not show for updating release requests
14 Jun 2022 jlier1	TFS 53678
19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
05/09/2022	navma1		Bug 54714: MTN - Web Portal - Release Request - Unable to save due to error message about Line number already existing
25/01/2023	navcs2		Bug 55803: PNL - Data cleared from release request when update made in Web Portal	
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request													
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
============================================================================*/
vars
	response				: WS_BulkReleaseUpdateResponse;
	completedOK				: Boolean;
	pxyBulkRelease,
	bulkRelease				: CM_BulkRelease;
	wsBulkRelease			: WS_BulkRelease;
	terminal,
	destTerminal			: CM_Terminal;			//cnwmc5 - 2 March 2015 - PAR 35777
	root					: CM_Root;
	dischargePort			: CM_Port;
	operator				: CM_Operator;
	voyage					: CM_Voyage;
	type					: Integer;
	pxyReserveTI,
	reserveTI				: CM_ReserveTI;
	pxyReserveSelection,
	tmpReserveSelection,
	reserveSelection		: CM_ReserveSelection;
	wsReserveDetail			: WS_ReserveDetail;
	wsReserveTI				: WS_ReserveTI;
	wsReserveSelection		: WS_ReserveSelection;
	ti						: CM_TrackedItem;
	cargoTypeID				: Integer;
	allTis					: CM_TISet;
	wsTI					: WS_TrackedItem;
	cargoType				: CM_CargoType;
	isoType					: CM_ISOType;
	isoTypeGroup			: CM_ISOTypeGroup;
	product					: CM_Product;
	failedDAC				: CM_DataAccessController;
	statusCode				: Integer;
	carrier					: CM_Carrier;
	carrierCode				: String;
	consignee				: CM_ConsigneeConsignor;
	consigneeCode			: String;
	consignor				: CM_ConsigneeConsignor;
	consignorCode			: String;
	freightForwarder		: CM_ConsigneeConsignor;
	freightForwarderCode	: String;
	infoMessage				: WS_InfoMessage;
	load					: Boolean;
	pxyReserveDetail		: CM_ReserveDetail;
	reserveDetailOID		: String;
	matchFound				: Boolean;
	beforePIN				: String;
	requestDate				: TimeStamp;
	
	weightType,
	volumeType				: CM_MeasurementType;
	weight,
	volume					: Decimal [23,10];
	
	booking					: CM_BookingRef;		//cnwmc5 - 1 June 2016 - TFS 2039
	dac						: CM_DataAccessController;
	operatorStr				: String;	
	estimatedDT				: TimeStamp;
	allAvailabilityGrades	: IntegerArray;			// ### TFS 55803 17Feb2022 NAVPW1
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmGteEmptyReleaseMaintAll);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;

	// Perform validation, start populate response
	wsBulkRelease := bulkReleaseRequest.myBulkRelease;
	
	root := app.myRoot;
	terminal := app.myPassport.myTerminal;
	
	bulkRelease := terminal.getBulkReleaseFromCode(wsBulkRelease.releaseNo);
	if bulkRelease = null then
		app.raiseCMException1(Bulk_Release_Not_Found, wsBulkRelease.releaseNo, null, null);
		completedOK := true;
		return response;
	endif;
	
	if not bulkRelease.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException(ERR_dontHaveAccessToThisItem, null, null);
		completedOK := true;
		return response;
	endif;
	
	beforePIN := bulkRelease.getPinNumber();
	
	if wsBulkRelease.dischargePort &lt;&gt; null then
		dischargePort := root.allPorts[wsBulkRelease.dischargePort.code];
	endif;
	
	if wsBulkRelease.operator &lt;&gt; null then
		operator := root.allOperators[wsBulkRelease.operator.code];
	endif;
	
	if wsBulkRelease.carrier &lt;&gt; null then
		carrier := root.allCarriers[wsBulkRelease.carrier.code];
		if carrier &lt;&gt; null then
			carrierCode := carrier.code;
		endif;
	endif;
	
	if wsBulkRelease.consignee &lt;&gt; null then
		consignee := root.allConsigneeConsignors[wsBulkRelease.consignee.code];
		if consignee &lt;&gt; null then
			consigneeCode := consignee.code;
		endif;
	endif;
	
	if wsBulkRelease.consignor &lt;&gt; null then
		consignor := root.allConsigneeConsignors[wsBulkRelease.consignor.code];
		if consignor &lt;&gt; null then
			consignorCode := consignor.code;
		endif;
	endif;
	
	if wsBulkRelease.freightForwarder &lt;&gt; null then
		freightForwarder := root.allConsigneeConsignors[wsBulkRelease.freightForwarder.code];
		if freightForwarder &lt;&gt; null then
			freightForwarderCode := freightForwarder.code;
		endif;
	endif;
	
	if wsBulkRelease.type &lt;&gt; null then
		type := wsBulkRelease.type.id;
	endif;
	
	voyage := terminal.lookupVoyage(wsBulkRelease.voyageCode, null, false);
	
	if wsBulkRelease.status &lt;&gt; null then
		statusCode := wsBulkRelease.status.id;
	endif;
	
	//cnwmc5 - 2 March 2015 - PAR 35777
	if wsBulkRelease.destinationTerminal &lt;&gt; null then
		destTerminal := app.myRoot.allTerminals[wsBulkRelease.destinationTerminal.code];
	endif;
	
	//cnwmc5 - 1 June 2016 - TFS 2039
	if wsBulkRelease.booking &lt;&gt; null then
		//epr TFS 5535 9/8/17
		booking := app.myPassport.getObjectOfTypeFromOid(wsBulkRelease.booking.cmObjectId,CM_BookingRef).CM_BookingRef;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	//6/9/19 epr web portal doesn't show estimated so calling this was wiping the bulk release estimated date/time
	estimatedDT:=bulkRelease.dateEstimatedRequired;
	if wsBulkRelease.estimatedRequiredDate &lt;&gt; null then
		estimatedDT := wsBulkRelease.estimatedRequiredDate.asTimeStampFromWebInterface ;
	endif;
			
	requestDate.setDate(wsBulkRelease.requestDate.asDateFromWebInterface);		//cnwmc5 - 26 Nov 2014 - CCMS 2429
	requestDate.setTime(wsBulkRelease.requestTime.asTimeFromWebInterface);		//cnwmc5 - 26 Nov 2014 - CCMS 2429
	
	app.cmsBeginLoad(load);
	pxyBulkRelease := bulkRelease.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	pxyBulkRelease.setProxy(wsBulkRelease.releaseNo,
							type,
							wsBulkRelease.releaseByType,
							statusCode,
							pxyBulkRelease.allAvailabilityGrades,
							wsBulkRelease.bookingConfirmation,
							carrierCode,
							wsBulkRelease.remarks,			//cnwmc5 - 12 Nov 2014 - CCMS 2429
							consigneeCode,
							pxyBulkRelease.consigneeDesc,
							consignorCode,
							pxyBulkRelease.consignorDesc,
							wsBulkRelease.consignorVoyageCode,
							requestDate,					//cnwmc5 - 26 Nov 2014 - CCMS 2429
							estimatedDT,
							pxyBulkRelease.deliveryReasonCode,
							pxyBulkRelease.deliveryReasonDescr,
							wsBulkRelease.deliveryReleaseNumber,
							pxyBulkRelease.doorsDirection,
							wsBulkRelease.freightPayerCode,
							booking,						//cnwmc5 - 1 June 2016 - TFS 2039
							pxyBulkRelease.myLoadPort,
							pxyBulkRelease.myDestinationPort,
							dischargePort,
							pxyBulkRelease.freightForwarderCode,		//25/01/2023	navcs2	Bug 55803
							destTerminal,					//cnwmc5 - 2 March 2015 - PAR 35777
							terminal,
							operator,
							pxyBulkRelease.myOperatorGroup,
							voyage,
							pxyBulkRelease.myBusinessUnit,
							wsBulkRelease.fullRelease,
							pxyBulkRelease.allPackLocations,						//25/01/2023	navcs2	Bug 55803
							pxyBulkRelease.myPoolPartner,
							pxyBulkRelease.dispatchLocation,
							pxyBulkRelease.mySubTerminal,
							pxyBulkRelease.mySubTerminalTarget,
							pxyBulkRelease.myAssignedTrain,
							pxyBulkRelease.allowCargoOnMultipleReleases,
							pxyBulkRelease.customsAgent,
							pxyBulkRelease.customsAssistance,
							pxyBulkRelease.canBeHiLoCube,
							pxyBulkRelease.needsReview,
							pxyBulkRelease.blockEDIUpdates,
							pxyBulkRelease.allEDIFiles,
							pxyBulkRelease.expiryTimeStamp,		// expiryTimeStamp 13 Feb 2017	NDL	TFS 3368
							pxyBulkRelease.myBOLIn,				// jlgka1 TFS 41708
							pxyBulkRelease.context				// ### TFS 53953 27June2022 NAVPW1
							);

	//Delete bulk release details that aren't included
	foreach pxyReserveDetail in pxyBulkRelease.allReserveDetails do
		reserveDetailOID := pxyReserveDetail.pxyGetRealObject.getOidString();
		matchFound := false;
		
		foreach wsReserveDetail in wsBulkRelease.allReserveDetails do
			if reserveDetailOID = wsReserveDetail.cmObjectId then
				matchFound := true;
				break;
			endif;
		endforeach;
		
		if not matchFound then
			//cnwmc5 - 26 Nov 2104 - CCMS 2429
			if pxyReserveDetail.isKindOf(CM_ReserveTI) then
				ti := pxyReserveDetail.CM_ReserveTI.getTI();
				if ti &lt;&gt; null then
					pxyBulkRelease.removeTIAssigned(ti);
					pxyBulkRelease.removeTIReleased(ti);
				endif;
			else
				pxyReserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
				//foreach ti in pxyReserveDetail.allTrackedItems do
				foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
					if pxyBulkRelease.allTrackedItemsAssigned.includes(ti) then
						pxyBulkRelease.allTrackedItemsAssigned.remove(ti);
						pxyBulkRelease.removeTIFromWorkOrders(ti);
					endif;
				endforeach;
				delete pxyReserveDetail;
			endif;
		endif;
	endforeach;
	
	//cnwmc5 - 13 March 2015 - PAR 35864
	weightType := app.getDefaultMeasurementForType(Type_Weight);
	volumeType := app.getDefaultMeasurementForType(Type_Volume);
	
	//Create and update bulk release details
	foreach wsReserveDetail in wsBulkRelease.allReserveDetails do
		
		// cnwma1 - 04.05.2018 ChangeRequest 37957
		wsTI := null;
		ti := null;
		cargoType:= null;
		product :=null;
		cargoTypeID := null;
		volume := null;
		weight := null;
		isoType := null;
		isoTypeGroup := null;
		if wsReserveDetail.isKindOf(WS_ReserveTI) then
			wsReserveTI := wsReserveDetail.WS_ReserveTI;
			wsTI := wsReserveTI.myTrackedItem;
			ti := null;
			
			//Get the pxy object based off the real one
			if wsReserveDetail.cmObjectId &lt;&gt; null then
				//epr TFS 5535 9/8/17
				reserveTI := app.myPassport.getObjectOfTypeFromOid(wsReserveDetail.cmObjectId,CM_ReserveTI).CM_ReserveTI;
				if reserveTI &lt;&gt; null  then
					pxyReserveTI := reserveTI.pxyGetProxyObject();
					pxyReserveTI.allTrackedItems.clear();
				else
					app.raiseCMException1(Matching_found, app.getErrorString(BulkRelease) &amp; " " &amp; app.getErrorString(Detail), null, null);
					completedOK := true;
					return response;
				endif;
			else
				create pxyReserveTI transient;
				pxyBulkRelease.allReserveDetails.add(pxyReserveTI);			//cnwmc5 - 26 Nov 2014 - CCMS 2429
			endif;
			
			//Attempt to get the cargo item by look at the 'myTrackedItem' and see if they have provided an OID..
			//If not, go looking up cargo items, break-bulk may have more than 1 for that ID..
			if wsTI &lt;&gt; null and wsTI.cmObjectId &lt;&gt; null then
				//epr TFS 5535 9/8/17
				ti := 	app.myPassport.getObjectOfTypeFromOid(wsTI.cmObjectId,CM_TrackedItem).CM_TrackedItem;
				if ti &lt;&gt; null then
					pxyReserveTI.allTrackedItems.add(ti);
				else
					//Couldn't find the tracked item..
					app.raiseCMException1(Cargo_item_not_found, wsTI.idTextBox, null, null);
					completedOK := true;
					return response;
				endif;	
			else
				if wsReserveTI.cargoType &lt;&gt; null then
					cargoTypeID := wsReserveTI.cargoType.id;
				endif;
				
				if wsReserveTI.cargoID &lt;&gt; null and cargoTypeID &lt;&gt; null then
					delete allTis;
					create allTis transient;
					terminal.lookupAllOnShipTrackedItems(wsReserveTI.cargoID, cargoTypeID, true, false, false, allTis, null);
					terminal.lookupAllOnsiteTrackedItems(cargoTypeID, wsReserveTI.cargoID, allTis, false, null);
					terminal.lookupAllNotifiedOnsiteTIs(cargoTypeID, wsReserveTI.cargoID, allTis, false, null);
					
					//Create an error here, contain all onsite TIs and return them for user to choose one then make another request..
					if allTis.size &gt; 1 then
						//Found more than 1 tracked item and them to the responses collection to return for choosing..
						foreach ti in allTis do
							create wsTI transient;
							wsTI.setProxyFromObject(ti);
							response.allTrackedItems.add(wsTI);
						endforeach;
						app.raiseCMException1(Multiple_cargo_items_search, wsReserveTI.cargoID, null, null);
						completedOK := true;
						return response;
					endif;
					
					if allTis.size = 1 then
						ti := allTis.first;												//cnwmc5 - 18 Dec 2014 - PAR 35320
						pxyReserveTI.addTI(ti);
						
						pxyReserveTI.setTotalRequested(wsReserveTI.totalQuantity);	//cnwmc5 - 18 Dec 2014 - PAR 35320
						
						//cnwmc5 - 13 March 2015 - PAR 35864 - begin
						cargoType := ti.myCargoType;
						product := ti.myProduct;
						
						if cargoType &lt;&gt; null
						and cargoType.isBulkByVolume then
							if product = null then
								product := cargoType.mySystemProductType;
							endif;
							
							volume := app.convertMeasurementForStorage(volumeType.shortName, wsReserveTI.totalVolume.asDecimalJMT);
							pxyReserveTI.setWeightRequested(volume * product.myDensityDec.value);	// ### TFS 52193 22Nov2021 NAVPW1
						else
							weight := app.convertMeasurementForStorage(weightType.shortName, wsReserveTI.totalWeight.asDecimalJMT);
							pxyReserveTI.setWeightRequested(weight);
						endif;
						//cnwmc5 - 13 March 2015 - PAR 35864 - end
					else
						//Couldn't find the tracked item..
						app.raiseCMException1(Cargo_item_not_found, wsReserveTI.cargoID, null, null);
						completedOK := true;
						return response;
					endif;
				endif;
			endif;
			
		elseif wsReserveDetail.isKindOf(WS_ReserveSelection) then
			wsReserveSelection := wsReserveDetail.WS_ReserveSelection;
			tmpReserveSelection := null;			//cnwmc5 - 25 Nov 2014 - CCMS 2429
			
			//Get the pxy object based off the real one
			if wsReserveDetail.cmObjectId &lt;&gt; null then
				reserveSelection := app.myPassport.getObjectOfTypeFromOid(wsReserveDetail.cmObjectId,CM_ReserveSelection).CM_ReserveSelection;
				if reserveSelection &lt;&gt; null  then
					tmpReserveSelection := reserveSelection.pxyGetProxyObject();
				else
					app.raiseCMException1(Matching_found, app.getErrorString(BulkRelease) &amp; " " &amp; app.getErrorString(Detail), null, null);
					completedOK := true;
					return response;
				endif;
			endif;
			
			if wsReserveSelection.cargoType &lt;&gt; null then
				cargoType := root.allCargoTypesById[wsReserveSelection.cargoType.id];
				if cargoType = null then
					app.raiseCMException(ERR_INVALID_TI_TYPE, null, null);
					completedOK := true;
					return response;
				endif;
			endif;
			
			if wsReserveSelection.isoType &lt;&gt; null then
				isoType := root.allISOTypes[wsReserveSelection.isoType.code];
			endif;
			
			if wsReserveSelection.isoGroup &lt;&gt; null then
				isoTypeGroup := root.allISOTypeGroups[wsReserveSelection.isoGroup.code];
			endif;
			
			if wsReserveSelection.product &lt;&gt; null and cargoType &lt;&gt; null and cargoType.hasProductTypes then
				product := cargoType.getProductFromCode(wsReserveSelection.product.code);
			endif;
			
			// ### TFS 55803 17Feb2022 NAVPW1
			//if tmpReserveSelection.allAvailabilityGrades &lt;&gt; null and tmpReserveSelection.allAvailabilityGrades.isNotEmpty then
			if tmpReserveSelection &lt;&gt; null and tmpReserveSelection.allAvailabilityGrades &lt;&gt; null and tmpReserveSelection.allAvailabilityGrades.isNotEmpty then	// ### TFS 56761 27Feb2023 NAVPW1
				create allAvailabilityGrades transient;
				tmpReserveSelection.allAvailabilityGrades.copy(allAvailabilityGrades);
			endif;
			// ### TFS 55803 17Feb2022 NAVPW1
			
			//cnwmc5 - 13 March 2015 - PAR 35864 - begin
			if cargoType &lt;&gt; null
			and cargoType.isBulkByVolume then
				if product = null then
					product := cargoType.mySystemProductType;
				endif;
				
				volume := app.convertMeasurementForStorage(volumeType.shortName, wsReserveSelection.totalVolume.asDecimalJMT);	
			else
				weight := app.convertMeasurementForStorage(weightType.shortName, wsReserveSelection.totalWeight.asDecimalJMT);
			endif;
			//cnwmc5 - 13 March 2015 - PAR 35864 - end
			
			if tmpReserveSelection = null and not pxyBulkRelease.allReserveDetails.includes(tmpReserveSelection) then
				create pxyReserveSelection transient;		//cnwmc5 - 25 Nov 2014 - CCMS 2429
				pxyReserveSelection.setProxy(	null,		//review - packType
												cargoType,
												null,		//review - bookRefItemObj
												isoType,
												isoTypeGroup,
												product,
												null,		//review - productStr
												wsReserveSelection.remarks,
												wsReserveSelection.totalRequested,
												null,		//review - allAvailGrades
												wsReserveSelection.clean,
												null,		//review - doISOGroupCheck
												wsReserveSelection.heavyDuty,
												null,		//review - maskIds
												null,		//review - maxToRelease
												null,		//review - color
												null,		//review - descriptionSelection
												null,		//review - heightSelection
												null,		//review - lengthSelection
												null,		//review - markNumber
												null,		//review - quantitySelection
												null,		//review - remarksSelection
												volume,		//review - volumeSelection
												weight,		//review - weightSelection
												null,		//review - widthSelection
												null,		//review - markSelection
												null,		//review - densitySelection
												null,		//review - typeSelection
												null,		//review - terminalArea
												null,		//review - myReceivalBOL
												null,		//review - bestPick
												null,		//review - sequence
												null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
												null,	// ### TFS 53953 11July2022 NAVPW1
												null,null,  //12-07-2022 navtnr20 53974
												null,
												false, //28/06/2023 navmv20 CR 58410 Task 58411	
												terminal.getConfig(LocnByOldestTransArrival).Boolean, //19/02/2023	navkc1 CR 60078 Task 62450
												null, //24/04/2025	navrv30	MTN 34319
												null);
				//cnwmc5 - 13 March 2015 - PAR 35864
				pxyReserveSelection.setWeightRequested(weight);
				
				pxyBulkRelease.allReserveDetails.add(pxyReserveSelection);
				pxyReserveSelection.setLineNumber(pxyBulkRelease.getNextLineNumber(pxyReserveSelection));  //05.09.2022 namva1 #54714
			else
				tmpReserveSelection.setProxy(	tmpReserveSelection.packType,							   //25/01/2023	navcs2	Bug 55803
												cargoType,
												tmpReserveSelection.myBookingRefItem,
												isoType,
												isoTypeGroup,
												product,
												tmpReserveSelection.productStr,
												wsReserveSelection.remarks,
												wsReserveSelection.totalRequested,
												allAvailabilityGrades,										// ### TFS 55803 17Feb2022 NAVPW1
												wsReserveSelection.clean,
												tmpReserveSelection.doISOGroupCheck,
												wsReserveSelection.heavyDuty,
												null,		//tmpReserveSelection.maskIds,
												tmpReserveSelection.maxToRelease,
												tmpReserveSelection.colour,
												tmpReserveSelection.descriptionSelection,
												tmpReserveSelection.heightSelection,
												tmpReserveSelection.lengthSelection,
												tmpReserveSelection.markNumber,
												tmpReserveSelection.quantitySelection,
												tmpReserveSelection.remarksSelection,
												volume,
												weight,
												tmpReserveSelection.widthSelection,
												tmpReserveSelection.markSelection,
												tmpReserveSelection.densitySelection,
												tmpReserveSelection.typeSelection,
												tmpReserveSelection.allTerminalAreas,		  // 01/07/2015 cnwma1 PAR #36555
												tmpReserveSelection.myBOLIn,
												tmpReserveSelection.bestPick,
												tmpReserveSelection.sequence,
												tmpReserveSelection.myDeliveryParty,
												tmpReserveSelection.myDeliveryAddress,
												tmpReserveSelection.deliveryInstructions,
												tmpReserveSelection.deliveryFrom,
												tmpReserveSelection.deliveryTo,
												tmpReserveSelection.defaultAnyAmount,
												tmpReserveSelection.defaultAnyId,
												tmpReserveSelection.cargoMatchClientReference,
												tmpReserveSelection.cargoMatchUNDGcode,
												tmpReserveSelection.cargoMatchOrderNumber,
												tmpReserveSelection.cargoMatchPurchaseOrder,
												tmpReserveSelection.cargoMatchReceiveDate,
												tmpReserveSelection.cargoMatchReleaseDate,
												tmpReserveSelection.cargoMatchRemarks,
												tmpReserveSelection.cargoMatchVesselCode,
												tmpReserveSelection.weightRequested,	// ### TFS 53953 11July2022 NAVPW1
												tmpReserveSelection.lineNumber,	 //12-07-2022 navtnr20 53974
												tmpReserveSelection.customerReference,	//12-07-2022 navtnr20 53974
												null,	//28/06/2023 navmv20 CR 58410 Task 58411
												false,
												tmpReserveSelection.locnByOldestTransportArrival, //19/02/2023	navkc1 CR 60078 Task 62450
												null,	//24/04/2025	navrv30	MTN 34319
												null);
				
				//cnwmc5 - 13 March 2015 - PAR 35864
				tmpReserveSelection.setWeightRequested(weight);	// ### TFS 55803 16Feb2022 NAVPW1
			endif;
		endif;
	endforeach;
	
	if not pxyBulkRelease.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException(ERR_dontHaveAccessToThisItem, null, null);
		completedOK := true;
		return response;
	endif;
	
	if carrier &lt;&gt; null and not carrier.canCarrierAccessForOperator(operator, dac, true) then		// 20/9/17 MAP TFS2749
		if operator &lt;&gt; null then
			operatorStr := operator.description;
		endif;
		app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
		completedOK := true;
		return response;
	endif;
	
	//Do the update trx...
	app.myPassport.setWarningsIgnored(bulkReleaseRequest.warningsAcknowledged); //12/09/2019 cnwma1 #46485
	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, null, app.myPassport);
	
	//Attach PIN number to response..
	if app.myPassport.allErrors.isEmpty() then
		bulkRelease := terminal.getBulkReleaseFromCode(wsBulkRelease.releaseNo);
		if bulkRelease &lt;&gt; null and bulkRelease.getPinNumber() &lt;&gt; null and bulkRelease.getPinNumber() &lt;&gt; beforePIN then
			create infoMessage transient;
			infoMessage.text := bulkRelease.getPinNumber();
			response.allInfo.add(infoMessage);
		endif;	
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	// Tidy up any local transients
	delete pxyBulkRelease;
	delete allTis;
	delete allAvailabilityGrades; // ### TFS 55803 17Feb2022 NAVPW1
	
	app.cmsEndLoad(load);
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="bulkReleaseRequest" type="WS_BulkReleaseUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoAvailabilityGrade" id="a081c893-386c-4886-ac50-3f25def3d5e2">
        <source>updateCargoAvailabilityGrade (cargoGradeUpdateRequest: WS_CargoGradeUpdateRequest) : WS_Response  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2016	cnwma1	Initial creation TFS #1494 :JMT Mobile Apps - Cargo - Grading

*/

vars
	response : WS_Response;
	completedOK : Boolean;
	cargoGradeController 	: 	CMIF_MobileGenericAgent;
	terminal 		: CM_Terminal;
	ti : CM_TrackedItem;
	availabilityGrade : CM_MTGrade;
	failedDAC 		: CM_DataAccessController;
	obj :     Object;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	terminal := app.myPassport.myTerminal;
	
	// Create the response
	create response transient;
	terminal:=app.myPassport.myTerminal;
	
	// Check security access to Cargo Grading
	if not app.myCurrentUserCan(terminal, PmHHGrading) then
		completedOK := true;
		return response;
	endif;
	
	if cargoGradeUpdateRequest.cargoOid = null then
		completedOK := true;
		return response;
	endif;
	
	availabilityGrade  := app.myRoot.allAvailabilityGrades[cargoGradeUpdateRequest.availabilityGradeCode.asIntegerJMT];
	//epr TFS 5535 9/8/17
	ti :=app.myPassport.getObjectOfTypeFromOid(cargoGradeUpdateRequest.cargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	create cargoGradeController transient;

	if not cargoGradeController.updateAvailabilityGrade(ti,availabilityGrade) then
		completedOK := true;
		return response;
	endif;
	
	
	completedOK := true;
	return response;
	
epilog

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	delete cargoGradeController;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="cargoGradeUpdateRequest" type="WS_CargoGradeUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoChecksTI" id="1ef608ea-8557-412f-bfa4-55c32e4cee15">
        <source>updateCargoChecksTI(request : WS_CargoCheckTIRequest) : WS_Response webService;
/*
Purpose:		This updates the data entered during cargo checks - AltId, Weight, Dimensions, temperature readings etc.	
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
06/03/2023		jlika1		TFS 56882 - CUX - Transaction for hazardous symbol check in gate checker app.
22/03/2023		jlika1		TFS 57253 - FR 56564 | CUX - Hazard Symbol Requires To Do Task (Make the Todo Task for Hazards Symbol Optional)
22/01/2023		navhl20		Bug 61949:[61950] STWO - MTN Pack/Unpack container Error-89854
05/02/2023		navhl20		Bug 62344: EUP - 11052 Error when performing the seal checks on the work order operations app
16/01/2026		navdap1		MTN-36569 CPL | Reefer Runner Integration
*/

vars
	tempParams 					: CMIF_TempReading;
	response					: WS_Response;
	completedOK					: Boolean;
	tis 						: CM_TISet;
	cargo, pxyTI 				: CM_TrackedItem;
	term 						: CM_Terminal;
	load						: Boolean;
	cargoCheck 					: CM_CargoCheck;
	cargoCheckItem 				: CM_CargoCheckItem;
	cmifAutoPlan 				: CMIF_YAAutoPlanNormal;
	updatecargo 				: Boolean;
	updatecargotxn 				: Boolean;
	validationMsg 				: String;
	theTransactionController	: CMIF_TITransactionController;
	txnControllerDict 			: CMIF_TITxnContrlrByTypeDTDict;
	checkItem					: WS_CargoCheckItem;
	todoDesc					: String;
	myCargoCheckTI				: WS_CargoCheckTI;
	todoTaskDesc				: String;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	//response.setFromRequest(request);

	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(PmAdmCargocheckMaint);		//	removed 20/4 - permission is for creating cargo checks in jmt, not validating in handheld
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	term := app.myPassport.myTerminal;
	
	app.writeLog(method.name &amp; " checks context=" &amp;  request.context.String,LogDEBUG);
	// ### GET CARGO CHECK FOR CONTEXT
	cargoCheck := term.allCargoChecks[request.context];
	
	if cargoCheck = null then
		app.raiseCMException1(Invalid_cargo_check_context,request.context.String,null,null);
		completedOK := true;
		return response;
	endif;
	
	if request.myCargoCheckTI = null then
		completedOK := true;
		return response;
	endif;
	
	myCargoCheckTI := request.myCargoCheckTI;
	
	// ### GET CARGO ITEM
	if myCargoCheckTI.cargoUid &lt;&gt; null then
		//epr TFS 5535 8/8/17
		cargo :=app.myPassport.getObjectOfTypeFromOid( myCargoCheckTI.cargoUid,CM_TrackedItem).CM_TrackedItem;
	endif;
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 8/8/17
	request.validateCheckPermissions();
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	
	validationMsg:=request.validateCargoChecksForTI(cargo);
	if validationMsg &lt;&gt; null then
		app.raiseCMException2(Cargo_check_required,validationMsg,cargo.id, null,null); // TFS 1490 added ID
		completedOK := true;
		return response;
	endif;
	
	app.cmsBeginLoad(load);
	pxyTI := cargo.pxyCreateUpdateProxy;
	app.cmsEndLoad(load);
	
	updatecargo := false;
	
	if myCargoCheckTI.temperatureCheck.touched = "Y"  then // blank means not touched
		foreach cargoCheckItem in cargoCheck.allCargoCheckItems discreteLock do
			if cargoCheckItem.requiredExtraInfo = EXTRA_INFO_TEMPERATURE then
				create tempParams transient;
				self.myWebServiceAgent.updateRequiredExtraInfo(cargoCheckItem.requiredExtraInfo, request.myRequiredExtraInfo, pxyTI, tempParams);
				
				app.myTrxCA.trxCreateReeferReadings(tempParams, null, null, null, null, null, app.myPassport);		// MTN-36569
				if (not app.myPassport.trxCompletedOK) then
					completedOK := true;
					return response;
				endif;
				
				// ### proxy has been used so addition has changed.
				delete pxyTI;
				
				app.cmsBeginLoad(load);
				pxyTI := cargo.pxyCreateUpdateProxy;
				app.cmsEndLoad(load);
				
				if myCargoCheckTI.temperatureCheck.toDo then
					updatecargo := true;
					pxyTI.addToDoTask(cargoCheckItem.myToDoTaskDesc.description, app.myPassport);
				endif;
			endif;		
		endforeach;
	endif;
	
	//updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI(cargo);
	
	foreach cargoCheckItem in cargoCheck.allCargoCheckItems discreteLock do
		if not cargoCheckItem.doesTIMatchMe(cmifAutoPlan) then
			continue;
		endif;
		
		if cargoCheckItem.myToDoTaskDesc &lt;&gt; null then
			todoTaskDesc := cargoCheckItem.myToDoTaskDesc.description;
		endif;
		
		if cargoCheckItem.requiredExtraInfo = EXTRA_INFO_IS_OD and myCargoCheckTI.overDimensionsCheck.touched = "Y" then // blank means not touched
			self.myWebServiceAgent.updateRequiredExtraInfo(cargoCheckItem.requiredExtraInfo, request.myRequiredExtraInfo, pxyTI, null);
			updatecargo := true;
			
			if myCargoCheckTI.overDimensionsCheck.toDo then
				pxyTI.addToDoTask(todoTaskDesc, app.myPassport);
			endif;
		elseif cargoCheckItem.requiredExtraInfo = EXTRA_INFO_HAZARD_SYMBOLS and myCargoCheckTI.hazardsCheck.touched = "Y" then // blank means not touched
			self.myWebServiceAgent.updateRequiredExtraInfo(cargoCheckItem.requiredExtraInfo, request.myRequiredExtraInfo, pxyTI, null);
			
			if myCargoCheckTI.hazardsCheck.toDo then
				pxyTI.addToDoTask(todoTaskDesc, app.myPassport);				
			endif;			
			updatecargotxn := true;
		elseif cargoCheckItem.requiredExtraInfo = EXTRA_INFO_ALTERNATIVE_ID and myCargoCheckTI.alternativeIdCheck.touched = "Y" then // blank means not touched
			self.myWebServiceAgent.updateRequiredExtraInfo(cargoCheckItem.requiredExtraInfo, request.myRequiredExtraInfo, pxyTI, null);
			updatecargo := true;
			
			if myCargoCheckTI.alternativeIdCheck.toDo then
				pxyTI.addToDoTask(todoTaskDesc, app.myPassport);
			endif;
		elseif cargoCheckItem.requiredExtraInfo = EXTRA_INFO_DIMENSION and myCargoCheckTI.dimensionsCheck.touched = "Y" then // blank means not touched
			self.myWebServiceAgent.updateRequiredExtraInfo(cargoCheckItem.requiredExtraInfo, request.myRequiredExtraInfo, pxyTI, null);
			updatecargo := true;
			
			if myCargoCheckTI.dimensionsCheck.toDo then
				pxyTI.addToDoTask(todoTaskDesc, app.myPassport);
			endif;
		elseif cargoCheckItem.requiredExtraInfo = EXTRA_INFO_SPECIAL_LIFT and myCargoCheckTI.specialLiftCheck.touched = "Y" then // blank means not touched
			self.myWebServiceAgent.updateRequiredExtraInfo(cargoCheckItem.requiredExtraInfo, request.myRequiredExtraInfo, pxyTI, null);
			updatecargo := true;
			
			if myCargoCheckTI.specialLiftCheck.toDo then
				pxyTI.addToDoTask(todoTaskDesc, app.myPassport);
			endif;
		elseif cargoCheckItem.requiredExtraInfo = EXTRA_INFO_WEIGHT and myCargoCheckTI.weightCheck.touched = "Y" then // blank means not touched
			self.myWebServiceAgent.updateRequiredExtraInfo(cargoCheckItem.requiredExtraInfo, request.myRequiredExtraInfo, pxyTI, null);
			updatecargo := true;
			
			if myCargoCheckTI.weightCheck.toDo then
				pxyTI.addToDoTask(todoTaskDesc, app.myPassport);
			endif;
		elseif cargoCheckItem.requiredExtraInfo = EXTRA_INFO_DAMAGE and myCargoCheckTI.damageCheck.touched = "Y" then  //epr TFS 44276 7/5/19
			if myCargoCheckTI.damageCheck.toDo then
				pxyTI.addToDoTask(todoTaskDesc, app.myPassport);
				updatecargo := true;
			endif;
		elseif cargoCheckItem.requiredExtraInfo = EXTRA_INFO_SEALS and myCargoCheckTI.sealsCheck.touched = "Y" then
			if myCargoCheckTI.sealsCheck.toDo then
				pxyTI.addToDoTask(todoTaskDesc, app.myPassport);
				updatecargo := true;
			endif;
		elseif cargoCheckItem.requiredExtraInfo = null and cargoCheckItem.myToDoTaskDesc &lt;&gt; null then							//22.01.2023 navhl20 #61949[61950]
			foreach checkItem in myCargoCheckTI.additionalChecks do
				if checkItem.touched = "Y" and cargoCheckItem.myToDoTaskDesc.code.asStringJMT = checkItem.toDoCode then
					pxyTI.addToDoTask(cargoCheckItem.myToDoTaskDesc.description, app.myPassport);
					updatecargo := true;
				endif;
			endforeach;
		endif;
	endforeach;
	
	if updatecargo then
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	elseif updatecargotxn then
		create txnControllerDict transient;
		create theTransactionController transient;
		
		theTransactionController.type := TRANS_TYPE_HAZ_CHECK;
		theTransactionController.myTrackedItem := cargo;
		
		txnControllerDict.add(theTransactionController);
		
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);		
		app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, txnControllerDict, app.myPassport);
	endif;
	
	if app.myPassport.trxCompletedOK then
		completedOK := true;
		return response;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog	
	delete cmifAutoPlan;
	delete tis;
	delete pxyTI;
	
	app.cmsEndLoad(load);
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoCheckTIRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoDamage" id="c9eb7c3f-c471-4938-bbce-c29dbafc81f2">
        <source>updateCargoDamage(cargoDamageRequest : WS_CargoDamageUpdateRequest) : WS_Response webService;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2015	cnwmc5	Initial creation
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/

vars

	response 		: WS_Response;
	completedOK 	: Boolean;	
	wsDamage	 	: WS_Damage;
	terminal 		: CM_Terminal;
	
	ti,
	pxyTI			: CM_TrackedItem;
	
	//damSev 			: Integer;				// 11.07.2022 navak20 TFS 53862
	damSev 			: CM_DamageSeverity;		// 11.07.2022 navak20 TFS 53862
	damPos 			: CM_DamagePosition;
	damType 		: CM_DamageDefinitionCode;
	damage			: CM_DamageInstance;
	damageToUpdate	: CM_DamageInstance;
	pxyDamage		: CM_DamageInstance;
	isLoadStateSet	: Boolean;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(cargoDamageRequest.warningsAcknowledged);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	terminal := app.myPassport.myTerminal;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHDamageReport);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	wsDamage := cargoDamageRequest.damage;
	
	if wsDamage.cmObjectId &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		damageToUpdate := app.myPassport.getObjectOfTypeFromOid(wsDamage.cmObjectId,CM_DamageInstance).CM_DamageInstance;
		if damageToUpdate = null  then
			completedOK := true;
			return response;
		endif;
	endif;
	//epr TFS 5535 4/8/17
	ti :=  app.myPassport.getObjectOfTypeFromOid(cargoDamageRequest.cmObjectId,CM_TrackedItem).CM_TrackedItem;
	
	damPos := app.myRoot.allDamagePositionsByCode[wsDamage.myDamagePosition.code].CM_DamagePosition;
	damType := app.myRoot.allDamageDefinitionCodes[wsDamage.myDamageCode.code].CM_DamageDefinitionCode;
	//damSev := wsDamage.severity;		// 11.07.2022 navak20 TFS 53862
	damSev := terminal.allDamageSeverities[wsDamage.severity.String];	// 11.07.2022 navak20 TFS 53862
	
	//if ti = null or damPos = null or damType = null or damSev = 0 then			// 11.07.2022 navak20 TFS 53862
	if ti = null or damPos = null or damType = null or damSev = null then			// 11.07.2022 navak20 TFS 53862
		completedOK := true;
		return response;
	endif;	
	
	app.cmsBeginLoad(isLoadStateSet);
	pxyTI		:=	ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoadStateSet);
	
	pxyTI.purgeAllDamageInstance();
	foreach damage in ti.allDamageInstances do
		if damage = damageToUpdate then
			continue;
		endif;
		
		app.cmsBeginLoad(isLoadStateSet);
		pxyDamage := damage.pxyCreateUpdateProxy();
		app.cmsEndLoad(isLoadStateSet);
		pxyDamage.setMyTrackedItem(pxyTI);
	endforeach;
	
	//pxyTI.createPxyDamageInstance(damType, damPos, null, true, wsDamage.quantity, damSev, false, null);		// July 1, 2022 navak20 TFS 53862
	pxyTI.createPxyDamageInstance(damType, damPos, null, true, wsDamage.quantity, damSev, null,
																									damageToUpdate.myDamagePlace,		// July 1, 2022 navak20 TFS 53862
																									damageToUpdate.myDamageParty,		// July 1, 2022 navak20 TFS 53862
																									damageToUpdate.myDamageReason,		// July 1, 2022 navak20 TFS 53862
																									damageToUpdate.myRepairReason,		// July 1, 2022 navak20 TFS 53862
																									damageToUpdate.damageSize,			// July 1, 2022 navak20 TFS 53862
																									damageToUpdate.damageDateTime,		// July 1, 2022 navak20 TFS 53862
																									damageToUpdate.status,				// July 1, 2022 navak20 TFS 53862
																									damageToUpdate.repairRemarks,		// July 1, 2022 navak20 TFS 53862
																									damageToUpdate.repairedDateTime		// July 1, 2022 navak20 TFS 53862
																									);
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	app.cmsEndLoad(isLoadStateSet);
	delete pxyTI;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="cargoDamageRequest" type="WS_CargoDamageUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoItem" id="1fa02176-0575-4769-a3f5-8b974f13d90a">
        <source>updateCargoItem(request : WS_CargoItemUpdateRequest) : WS_TrackedItemUpdateResponse webService;
/*

Purpose:	
ChangeRequest 1503:JMT Mobile Apps - Cargo - Alt Id

Parameters:			

Return Value:		

Date			Who		Reason
09 August 2016	cnwrh7	Initial creation
30 May 2017		cnwdap1	TFS 4449 STWR Mark and Mark Number field length adjustments
26/06/2018 		JLGNS1 	Bug 39058: QNS - Testing WEB Portal Exception 1035 String to long
13/03/2019		jlgzm1	TFS43548 seals not being updated
19/05/2020		JLGAM15	TFS48664 remarks should be set on a cargo via Maintenance App (Mobile Apps)
20/05/2020		JLGAM15	TFS48664 year,width,height were not being set properly for a CAR cargo
25/05/2022		jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
28.06.2022		navsrk20	Task 53923: Implement shipping line in WS_CargoItemUpdateRequest
25 Oct 2022 	navlw1		Bug 55211: MTN - Trailer Type doesn't able to Create or Update correctly from Mobile apps
09/03/2023		jlizm1	TFS 56720 Running weight total for MAFIs
24 Jun 2024 	navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
*/

vars
	
	load,
	completedOK		: Boolean;
	failedDAC		: CM_DataAccessController;
	obj				: Object;
	pxyTI,
	cargo,ti		: CM_TrackedItem;			
	response		: WS_TrackedItemUpdateResponse;
	booking 		: CM_BookingRef;
	bookingItem 	: CM_BookingRefItem;
	commodity 		: CM_Commodity;
	cargoType 		:CM_CargoType;
	product			: CM_Product;
	permissions 	: IntegerArray;
	shippingLine	: CM_ShippingLine;			//28.06.2022 navsrk20 TFS 53923
	trailerType		: CM_TILCType;
	voyageChangedMAFI : Boolean;
	queueParams 	: CMIF_AutoplanParams;
	mafi 			: CM_TILC;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	//Get tracked item
	if request.cmObjectId &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		cargo := app.myPassport.getObjectOfTypeFromOid(request.cmObjectId,CM_TrackedItem).CM_TrackedItem;
	endif;
	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		completedOK := true;
		return response;
	endif;
		
	// Perform validation, start populate response
	app.cmsBeginLoad(load);
	pxyTI := cargo.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	create permissions transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissions.add(PmMobDeliveryDispatchApp);										//24.06.2024 navsck1 #63668
	if request.alternativeIdSupplied = true then
		pxyTI.zSetPxyAlternativeId(request.alternativeId);
		permissions.add(PmHHCargoAltId);
	endif;
		permissions.add(PmHHPackContainer);
		permissions.add(PmHandHeldInterTerminal);
		permissions.add(PmWebUpdateCargo);
	
	
	//epr TFS 5535 17/8/17
	app.myPassport.validateUserHasOnePermission(permissions);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if request.exportBookingItemOid &lt;&gt; null then
		//update the booking and booking item
		bookingItem :=app.myPassport.getObjectOfTypeFromOid( request.exportBookingItemOid,CM_BookingRefItem).CM_BookingRefItem;
		if bookingItem = null then
			app.raiseCMException1(WARN_BOOKING_REF,request.exportBookingItemOid,null,null);
			completedOK := true;
			return response;
		endif;
		
		booking := bookingItem.myBookingReference;
		
		if  not booking.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			app.raiseCMException(ERR_dontHaveAccessToThisItem,null,null);
			completedOK := true;
			return response;
		endif;
		pxyTI.setVoyageCode(booking.voyageCode, app.myPassport );
		pxyTI.setBookingRefAndItem(booking,bookingItem,false,app.myPassport);		
		pxyTI.setDestinationPort(booking.destinationPort);		
		pxyTI.setDischargePort( booking.dischargePort);
		pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
		
		//update the voyage, discharge and destination 
	else
		if request.voyageCode &lt;&gt; null then
			pxyTI.setVoyageCode(request.voyageCode,app.myPassport);
		endif;
		
		if request.dischargePort &lt;&gt; null then
			pxyTI.setDischargePort( request.dischargePort);		
		endif;
		
		if request.destinationPort &lt;&gt; null then
			pxyTI.setDestinationPort(request.destinationPort);	
		endif;
	
		//imex 
		if request.imexStatus &gt; 0 then
			pxyTI.setImExStatus(request.imexStatus);
		endif;
		
		//operator
		if request.operatorCode &lt;&gt; null then                           // 10/11/2016  cnwma1 TFS #2524  
			pxyTI.setOperatorCode(request.operatorCode,app.myPassport);
		endif;	
		// Cargo Type and Product
		if request.cargoType &lt;&gt; null then
			cargoType :=app.myRoot.getCargoTypeFromAbbrev(request.cargoType);
			if cargoType &lt;&gt; null then
				pxyTI.setCargoType(cargoType.id);
				if cargoType.hasProductTypes then
					if request.product &lt;&gt; null then
						product := cargoType.getProductFromCode(request.product);
						if product &lt;&gt; null then
							pxyTI.setMyProduct(product);
						endif;
					endif;
				endif;
			endif;	
		endif;		
		
	endif;
	
	//cargo remarks need to be set. TFS 48664
	pxyTI.setRemarks(request.remarks,false);
	
	// cargo that is track by weight must do a discrepancy 
	if request.weightTotal &lt;&gt; null and not pxyTI.myCargoType.isBulkByWeight  then             // 10/11/2016  cnwma1 TFS #2524  
		pxyTI.setTotalWeightWithoutTrans(request.weightTotal.asDecimalJMT);
	
	endif;
	
	//jlier1 TFS 56680 23/2/23
	if request.weightTare &lt;&gt; null then
		pxyTI.setWeightTare(request.weightTare.asDecimalJMT);
	endif;
	
	// cargo that is track by volume must do a discrepancy 
	if request.volumeTotal &lt;&gt; null and not pxyTI.myCargoType.isBulkByVolume then
		pxyTI.setMyTotalVolume(request.volumeTotal.asDecimalJMT);		
	endif;
	
	// cargo that is track by quantity must do a discrepancy 
	if request.quantity &lt;&gt; null then             //TFS 48664
		pxyTI.setTotalQuantity(request.quantity);		
	endif;
	
	if request.isoType &lt;&gt; null then                // 10/11/2016  cnwma1 TFS #2524  
		pxyTI.setISOType(request.isoType);
	endif;
	
	if request.shippingLine &lt;&gt; null then										//28.06.2022 navsrk20 TFS 53923
		shippingLine := app.myRoot.allShippingLines[request.shippingLine];		//28.06.2022 navsrk20 TFS 53923
		pxyTI.setMyShippingLine(shippingLine);									//28.06.2022 navsrk20 TFS 53923
	endif;																		//28.06.2022 navsrk20 TFS 53923
	
	if request.commodityCode &lt;&gt; null then
		commodity := app.myRoot.allCommodities[request.commodityCode];
		if commodity &lt;&gt; null then
			pxyTI.setCommodity(request.commodityCode);
		
			if commodity.hasTemp and pxyTI.isReefer then
				pxyTI.setTemperature( request.carriageTemp );	
				pxyTI.setOxygen( request.oxygen);	
				pxyTI.setCarbonDioxide( request.carbonDioxide );	
				pxyTI.setHumidity( request.humidity );	
				pxyTI.setVentilation( request.ventilation );	
			endif;
		endif;	
	endif;
	
	//TFS43548 start
	//These are the only seal types supported by the request currently
	if request.sealNum &lt;&gt; null then
		pxyTI.setSealNumOperators(request.sealNum);
	endif;
	
	if request.sealNumCustoms &lt;&gt; null then
		pxyTI.setSealNumCustoms(request.sealNumCustoms);
	endif;
	
	if request.sealNumShippers &lt;&gt; null then
		pxyTI.setSealNumShippers(request.sealNumShippers);
	endif;
	
	if request.sealNumVent &lt;&gt; null then
		pxyTI.setSealNumVent(request.sealNumVent);
	endif;
	//TFS43548 end
	
	if pxyTI.isKindOf(CM_Car) then  			// 10/11/2016  cnwma1 TFS #2524  
		if request.carType &lt;&gt; null then
			pxyTI.CM_Car.setVehicleType(request.carType);
		endif;
		
		if request.model &lt;&gt; null then
			pxyTI.CM_Car.setModel(request.model);
		endif;
		
		if request.make &lt;&gt; null then
			pxyTI.CM_Car.setMake(request.make);									//Bug 39058
			//pxyTI.CM_Car.setMark(request.mark);				// TFS 4449		//Bug 39058
		//	pxyTI.CM_Car.setMark(request.mark[1:150]);			// TFS 4449		//Bug 39058
		endif;
		
		if request.year &lt;&gt; null then			
			pxyTI.CM_Car.setYear(request.year);					// TFS 48664	
		endif;
		
		if request.mark &lt;&gt; null then
			//pxyTI.CM_Car.setMark(request.mark);
			pxyTI.CM_Car.setMark(request.mark[1:150]);			// TFS 4449		//Bug 39058
		endif;
		
		if  request.length &lt;&gt; null then
			pxyTI.setLength(request.length.asDecimalJMT);
		endif;
		
		if  request.width &lt;&gt; null then
			pxyTI.setWidth(request.width.asDecimalJMT);
		endif;
		
		if  request.height &lt;&gt; null then
			pxyTI.setHeight(request.height.asDecimalJMT);
		endif;
		
	endif;
	
	if pxyTI.isKindOf(CM_BreakBulkGeneric) then
		if  request.diameter &lt;&gt; null then
			pxyTI.CM_BreakBulkGeneric.setDiameter(request.diameter.asDecimalJMT);
		endif;
		
		if  request.grade &lt;&gt; null then
			pxyTI.CM_BreakBulkGeneric.setGrade(request.grade);
		endif;
		
		if  request.grammage &lt;&gt; null then
			pxyTI.CM_BreakBulkGeneric.setGrammage(request.grammage.asDecimalJMT);
		endif;
		
		if  request.rollingLength &lt;&gt; null then
			pxyTI.CM_BreakBulkGeneric.setRollingLength(request.rollingLength.asDecimalJMT);
		endif;
	endif;
	
	// 25/10/2022 navlw1 tfs 55211
	if pxyTI.isKindOf(CM_TILC) then 
		if request.trailerType &lt;&gt; null then
			trailerType := pxyTI.myCargoType.allTILCTypes[request.trailerType];
			if trailerType &lt;&gt; null then
				pxyTI.CM_TILC.setMyType(trailerType);
			endif;
		endif;
	endif;
	
	// TFS 56720
	if cargo.isOnMAFI then
		// cargo voyage details changed
		if ((cargo.voyageCode &lt;&gt; pxyTI.voyageCode) or (cargo.dischargePort &lt;&gt; pxyTI.dischargePort)) then
			mafi := cargo.getCurrentTrailer();
			if mafi &lt;&gt; null and mafi.getAllOnboardTIsCount &gt; 1 then
				// loaded cargo different from mafi details
				if (mafi.voyageCode &lt;&gt; pxyTI.voyageCode) or (mafi.dischargePort &lt;&gt; pxyTI.dischargePort) then
					voyageChangedMAFI := true;
				endif;
			endif;
		endif;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	// Call trx to update item
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,
											null,
											TI_UPDMODE_NORMAL, 
											null, 
											app.myPassport);
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// TFS 56720
	if voyageChangedMAFI then
		// queue cargo off mafi
		create queueParams transient;
		queueParams.moveMode := QUEUE_MODE;
		queueParams.allTrackedItems.add(cargo);
		app.myTrxUA.trxUpdateAutoplanTrackedItems(queueParams, app.myPassport);
		if app.myPassport.hasErrors then
			// create alert to notify failure to queue, since can't return errors
			app.myPassport.createAlertsFromErrors(EVENT_AT_FailedAutoPlan, cargo);
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	delete pxyTI;
	delete permissions;
	delete queueParams;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoItemUpdateRequest"/>
        <ReturnType type="WS_TrackedItemUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoNotification" id="90808d12-1ee4-4f9a-b26d-998652bedb6d">
        <usesRPC>default</usesRPC>
        <source>updateCargoNotification(cargoUpdateRequest : WS_CargoNoteUpdateRequest) : WS_CargoNoteUpdateResponse webService;

/*

Purpose:			Update a single Cargo Notification request.

Parameters:			

Return Value:		


Date		Who		Reason
22 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	response		: WS_CargoNoteUpdateResponse;
	completedOK		: Boolean;
	
	eventReq		: CM_EventRequestNotification;
	pxyRequestNotify : CM_EventRequestNotification;
	
	tmpUser 		: CM_User;
	cmifEventReq 	: CMIF_EventRequestController;
	pxyEmail,
	realEmail 		: CM_EventRequestEmail;
	
	addresses 		: CM_StringArray;
	stringAddresses	: StringArray;
	
	requestTypeStr	: String;
	requestTypeObj	: CM_Object;
	cargoId 		: String;
	cargoType 		: CM_CargoType;
	organisation 	: CM_Organisation;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmEventReqNotifyMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	//epr TFS 47319 11/11/19
	if cargoUpdateRequest.cmObjectId &lt;&gt; null then
		eventReq:=app.myPassport.getObjectOfTypeFromOid(cargoUpdateRequest.cmObjectId,CM_EventRequestNotification).CM_EventRequestNotification;
	endif;
	
	if eventReq = null then
		// Perform validation
		eventReq := cargoUpdateRequest.findFirstMatchingCargoEvent().CM_EventRequestNotification;
	endif;
	if eventReq = null then
		app.raiseCMException(Matchin_cargo_notific_found,
							null, 
							null);
		completedOK := true;
		return response;
	endif;
	
	
	// Setup for update - cloned from CMUI_EventRequestModal::doSaveNotify
	beginLoad;
	pxyRequestNotify := eventReq.pxyCreateUpdateProxy().CM_EventRequestNotification;
	endLoad;
	
	tmpUser := eventReq.myUser;
	if tmpUser = null then
		tmpUser := app.getMyUser;
	endif;
	//epr TFS 47319 18/11/19
	cargoType:=pxyRequestNotify.myCargoType.CM_CargoType;
	if cargoUpdateRequest.myCargoType &lt;&gt; null then
		cargoType:=app.myRoot.allCargoTypesById[cargoUpdateRequest.myCargoType];
	endif;
	cargoId:=pxyRequestNotify.cargoId;
	if cargoUpdateRequest.cargoId &lt;&gt; null then
		cargoId:=cargoUpdateRequest.cargoId;
	endif;
	organisation:=pxyRequestNotify.myOrganisation;
	if cargoUpdateRequest.myOrganisation &lt;&gt; null then
		organisation 	:= app.myRoot.allOrganisations[cargoUpdateRequest.myOrganisation];
		if not tmpUser.canUserAccessObj(organisation, CM_Organisation) then
			app.raiseCMException1(User_does_have_access_organi, organisation.name,	null, null);
			completedOK := true;
			return response;
		endif;
	endif;
	// Get email addresses - needs to be refactored later
	create stringAddresses transient;
	cargoUpdateRequest.emailAddresses.getTrimedTokensForDelimiter(";", stringAddresses); //18/03/2009 cnwdz2 par19178
	create addresses transient;
	stringAddresses.copy(addresses);
	
	pxyRequestNotify.setProxyRequestNotify(addresses,						// _addresses		: CM_StringArray; 
										   cargoUpdateRequest.remarks,		// _remarks, 
										   cargoId,		// _cargoId		: String;
										   tmpUser,							// _user			: CM_User;
										   cargoType,	// _cargoType		: CM_CargoType;
										   pxyRequestNotify.myTrackedItem,	// _trackedItem	: CM_TrackedItem;
										   organisation,	// _organisation	: CM_Organisation;
										   pxyRequestNotify.myTerminal,			// _root			: CM_Root;
										   pxyRequestNotify.status,			// _status			: Integer;
										   pxyRequestNotify.eventType,		// _eventType,
										   pxyRequestNotify.eventName,		// _eventName		: String;
										   pxyRequestNotify.eventKey,		// _eventKey,
										   pxyRequestNotify.eventTypeNew,	// _eventTypeNew	: Integer; 
										   cargoUpdateRequest.reference,	// _ref : String; 
										   false,							// _noCleanup : Boolean) updating;
										   false );							// is EDI	// cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages
	
	if not cargoUpdateRequest.allNotifyTimes.isEmpty then
		beginLoad;
		realEmail := tmpUser.allEventRequestEmail[pxyRequestNotify.type];
		if realEmail &lt;&gt; null then
			pxyEmail := realEmail.pxyCreateUpdateProxy();
		else
			create pxyEmail transient;
		endif;
		pxyEmail.setProxy(app.myRoot, tmpUser, pxyRequestNotify.type, cargoUpdateRequest.allNotifyTimes);
		endLoad;
	endif;
	
	
	// Create update request
	create cmifEventReq transient;
	cmifEventReq.myPxyEventRequestEmail := pxyEmail;		
	cmifEventReq.myPxyEventRequestNotify := pxyRequestNotify;
	cmifEventReq.cargoIds := cargoUpdateRequest.cargoId;

	if cargoUpdateRequest.allRequestTypes.size &gt; 0  then
		requestTypeStr := cargoUpdateRequest.allRequestTypes.first.description;
	endif;
	requestTypeObj := app.getObjectForRequestTypeString(requestTypeStr);
	if requestTypeObj &lt;&gt; null then
		cmifEventReq.allEventNames.add(requestTypeStr);
		cmifEventReq.allSelectedObjects.add(requestTypeObj);
	endif;
	

	// Perform update	
	app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);					

	// If result is OK, then set up response return values
	if app.myPassport.trxCompletedOK then
		response.numberActioned := cmifEventReq.numActioned;
		response.numberMatchFailed := cmifEventReq.numMatchFailed;
		response.numberPending := cmifEventReq.numPending;
	endif;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
		

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	// Tidy up local transients
	delete pxyRequestNotify;
	delete pxyEmail;
	delete addresses;
	delete stringAddresses;
	delete cmifEventReq;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Update a single Cargo Notification request.</text>
        <Parameter name="cargoUpdateRequest" type="WS_CargoNoteUpdateRequest"/>
        <ReturnType type="WS_CargoNoteUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoPhotos" id="f83af257-cf9c-4844-b185-92bba20267e9">
        <source>updateCargoPhotos(request : WS_PhotoUpdateRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
18 Apr 2016	cnwmc5				Initial creation
18 Sep 2019 jlgka1 	TFS 46306 	JMT - Add photos to Cargo via web apps
03 Oct 2019 cnwma1	Bug 46731: Cargo App - Add Photos Permission + file types 
08 Sep 2025 navtr3	MTN-35929	Upload Cargo photos thumbnail is empty
21 Nov 2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
============================================================================*/

vars
	response		: WS_Response;
	completedOK		: Boolean;	
	obj				: Object;
	cargo			: CM_TrackedItem;
	failedDAC		: CM_DataAccessController;	
	wsCargoPhoto	: WS_Photo;
	proxyPhoto, 
	photo			: CM_Photo;	
	attachment		: CM_Attachment;
	iter			: Iterator;
	photosToDelete	: ObjectArray;
	permissions 	: IntegerArray;
	picture         : Binary;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	//jlgka1 TFS 46306 --&gt;
	create permissions transient;
	permissions.add(PmMobAddPhoto);
	permissions.add(PmHHDamageReport);		
		
	app.myPassport.validateUserHasOnePermission(permissions);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if request.cargoOid &lt;&gt; null then
		cargo := app.myPassport.getObjectOfTypeFromOid(request.cargoOid,CM_TrackedItem).CM_TrackedItem;
	endif;
	
	if cargo = null then
		completedOK := true;
		return response;
	endif;
	
	// Check and remove any duplicates
	create photosToDelete transient;
	foreach wsCargoPhoto in request.allPhotos do
		iter := cargo.allAttachments.createIterator();
		cargo.allAttachments.startKeyGeq(CM_Attachment.Type_Photo,iter);
		while iter.next(attachment) do
			if attachment.type &lt;&gt; CM_Attachment.Type_Photo then
				break;
			endif;	
			photo := attachment.CM_Photo;	
			if wsCargoPhoto.description = cargo.id then
				continue;
			endif;
			if wsCargoPhoto.description &lt;&gt; null and wsCargoPhoto.description = photo.description then
				photosToDelete.add(photo);
			endif;
		endwhile;
		delete iter;
	endforeach;
	
	foreach obj in photosToDelete do
		app.myTrxDA.trxDeleteCargoPhoto(obj.CM_Photo, app.myPassport);
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
	endforeach;
	
	// Add new photos
	foreach wsCargoPhoto in request.allPhotos do
		create proxyPhoto transient;
		proxyPhoto.setDescription(wsCargoPhoto.description);
		proxyPhoto.setMyParent(cargo);
		proxyPhoto.setPhotoContent(wsCargoPhoto.photoBytes);
		//proxyPhoto.setThumbnailContent(wsCargoPhoto.photoBytes);	//08-sept-2025 navtr3 MTN-35929         //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
	
		picture := proxyPhoto.photoBytes.getContent();    //03.10.2019 cnwma1 #46731
		if not picture.isPictureValid then                //03.10.2019 cnwma1 #46731
			continue;
		endif;
		
		app.myTrxCA.trxCreateCargoPhoto(proxyPhoto, photo, app.myPassport);		
	endforeach;	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	delete photosToDelete;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_PhotoUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoReeferConnection" id="4711af10-c2f0-4c21-a486-0a95b471ea38">
        <source>updateCargoReeferConnection(request : WS_CargoReeferConnectRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2016	cnwmc5	Initial creation

*/

vars
	response			: WS_Response;
	completedOK			: Boolean;
	
	power 				: CM_GapController;
	ti 					: CM_TrackedItem;
	obj					: Object;
	failedDAC			: CM_DataAccessController;
	agent 				: CMIF_MobileGenericAgent;
	connectParams		: CMIF_ConnectParams;
	connectTimeStamp	: TimeStamp;
	action				: Integer;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
//	app.checkCurrentUserHasAccess(PmReeferMonitorMod);		// Replace with appropriate permission
	app.checkCurrentUserHasAccess(Mod_BaseSystem);	//07 Oct 2019	NLD	TFS 46169
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if request.cargoOid &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		ti := app.myPassport.getObjectOfTypeFromOid(request.cargoOid,CM_TrackedItem).CM_TrackedItem;
	endif;
	
	if ti = null then
		completedOK := true;
		return response;
	endif;
	
	// Check to see if this container has been connected/disconnected already elsewhere
	if ti.isConnected = request.connected then
		completedOK := true;
		return response;
	endif;
	
	create agent transient;
	
	// Power cannot be null if the terminal area is a Gridded Block stack
	if ti.myTerminalArea.isKindOf(CM_ForkLiftStack) and not ti.myPrimaryActualLocation.hasPower then
		power := agent.findClosestPowerPoint(ti);
		if power = null then
			app.raiseCMException(No_power_avail, null, null);
			completedOK := true;
			return response;
		endif;
	endif;
	
	if request.connected then
		action := ACTION_CONNECT;
	else
		action := ACTION_DISCONNECT;
	endif;
	
	connectTimeStamp := app.actualTimeServer;

	create connectParams transient;
	connectParams.allTrackedItems.add(ti);
	connectParams.dateTime := connectTimeStamp;
	connectParams.noCharge := request.noCharge;
	connectParams.myTerminal := ti.myTerminal;
	connectParams.myTrackedItem := ti;
	if connectParams.myTrackedItem &lt;&gt; null then
		connectParams.locationsController := connectParams.myTrackedItem.myPrimaryActualLocation;
	endif;
	connectParams.userId := app.getMyUserCode();
	connectParams.action := action;
	connectParams.gapController := power; 
	connectParams.urNumber := null;
	connectParams.radioTelemetryIgnoreWarnings := true;
	connectParams.radioTelemetryUser := false;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	if request.connected then
		app.myTrxUA.trxUpdateConnect(connectParams, app.myPassport);
	else
		app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);
	endif;

	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	delete agent;
	delete connectParams;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoReeferConnectRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoStop" id="9613dc02-7654-4c36-854d-19e9e7f66368">
        <usesRPC>default</usesRPC>
        <source>updateCargoStop(cargoUpdateRequest : WS_CargoStopUpdateRequest) : WS_CargoStopUpdateResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation - following KPD's update cargo notes method
13/03/2009 cnwdz2 par19066 rewrite the method 
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
12/05/2014 	cnwer1	PAR 34113 CCMS 2289 - Cargo Update Requests changes to also update to do tasks, grades and cargo remarks
*/

vars
	response		: WS_CargoStopUpdateResponse;
	completedOK		: Boolean;
	tmpUser 		: CM_User;
	cmifEventReq 	: CMIF_EventRequestController;
	cargoType 		: CM_CargoType;
	organisation 	: CM_Organisation;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmEventReqStopsMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;		
	
	tmpUser 		:= app.getMyUser;
	cargoType 		:= app.myRoot.allCargoTypesById[cargoUpdateRequest.myCargoType];
	organisation 	:= app.myRoot.allOrganisations[cargoUpdateRequest.myOrganisation];
	// Validate User access to organisation here - TBC
	if not tmpUser.canUserAccessObj(organisation, CM_Organisation) then
		app.raiseCMException1(User_does_have_access_organi, organisation.name,	null, null);
		completedOK := true;
		return response;
	endif;
	
	// Create update request
	create cmifEventReq transient;
	cargoUpdateRequest.createAllPxyCargoUpdates(cmifEventReq);
	//epr TFS 5535 4/8/17 
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	// Perform update	
	app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);				

	// If result is OK, then set up response return values
	if app.myPassport.trxCompletedOK then
		response.numberActioned := cmifEventReq.numActioned;
		response.numberMatchFailed := cmifEventReq.numMatchFailed;
		response.numberPending := cmifEventReq.numPending;
	endif;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
		

epilog
	// Tidy up local transients
	if cmifEventReq &lt;&gt; null then
		cmifEventReq.allPxyCargoUpdateRequests.purge;
	endif;
	delete cmifEventReq;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="cargoUpdateRequest" type="WS_CargoStopUpdateRequest"/>
        <ReturnType type="WS_CargoStopUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoTaskExtraInfo" id="c891f970-f948-4597-b9a8-2fad4f9cfe14">
        <source>updateCargoTaskExtraInfo(request : WS_CargoTaskExtraInfoUpdReq) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/07/2016	cnwmc5	Initial creation
16/01/2026	navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

vars
	tempParams 				: CMIF_TempReading;
	response				: WS_Response;
	completedOK				: Boolean;
	cargo, pxyTI 			: CM_TrackedItem;
	load					: Boolean;
	toDoTask				: CM_ToDoTaskDesc;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHMaintainTasks);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if request.cargoOid &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		cargo := app.myPassport.getObjectOfTypeFromOid(request.cargoOid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		completedOK := true;
		return response;
	endif;
		
	toDoTask := app.myRoot.allToDoTaskDescriptions[request.taskCode];
	
	if toDoTask = null then
		app.raiseCMException(ERR_INVALID_TODOTASKDESCR,null,null);
		completedOK := true;
		return response;
	endif;
	
	app.cmsBeginLoad(load);
	pxyTI := cargo.pxyCreateUpdateProxy;
	app.cmsEndLoad(load);
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		
	//if toDoTask.requiredExtraInfo = EXTRA_INFO_TEMPERATURE then
	if toDoTask.requiredExtraInfo = EXTRA_INFO_TEMPERATURE  then
		create tempParams transient;
		self.myWebServiceAgent.updateRequiredExtraInfo(toDoTask.requiredExtraInfo, request.myRequiredExtraInfo, pxyTI, tempParams);
		app.myTrxCA.trxCreateReeferReadings(tempParams, null, null, null, null, null, app.myPassport);		// MTN-36569
	else
		self.myWebServiceAgent.updateRequiredExtraInfo(toDoTask.requiredExtraInfo, request.myRequiredExtraInfo, pxyTI, null);
		app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete tempParams;
	delete pxyTI;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoTaskExtraInfoUpdReq"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoTaskResourceUsage" id="a99a9be9-ce1a-4cea-ac67-6240d12bfe12">
        <source>updateCargoTaskResourceUsage(request : WS_CargoTaskResourceUpdReq) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2016	cnwmc5	Initial creation

*/

vars
	response				: WS_Response;
	completedOK				: Boolean;
	tis 					: CM_TISet;
	cargo, pxyTI 			: CM_TrackedItem;
	load					: Boolean;
	toDoTask				: CM_ToDoTaskDesc;
	wsResourceUsage			: WS_ResourceTypeUsage;
	resourceUsage			: CM_ResourceTypeUsage;
	resource				: CM_ResourceType;
	resourceUsageProxys		: CM_ResourceTypeUsageSet;
	fromDT,
	toDT					: TimeStamp;
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHMaintainTasks);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if request.cargoOid &lt;&gt; null then
		cargo :=app.myPassport.getObjectOfTypeFromOid( request.cargoOid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		completedOK := true;
		return response;
	endif;
		
	toDoTask := app.myRoot.allToDoTaskDescriptions[request.taskCode];
	
	if toDoTask = null then
		app.raiseCMException(ERR_INVALID_TODOTASKDESCR,null,null);
		completedOK := true;
		return response;
	endif;
	
	app.cmsBeginLoad(load);
	pxyTI := cargo.pxyCreateUpdateProxy;
	app.cmsEndLoad(load);
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	create resourceUsageProxys transient;
	foreach wsResourceUsage in request.allResourceTypeUsages do
		resource := app.myRoot.allTaskResourceTypes[wsResourceUsage.myResourceType.code];
		//epr TFS 38523 1/6/18
		fromDT:=null;
		toDT  := null;
		if resource.isFromToDateTimeRequired then
			fromDT :=wsResourceUsage.fromDateTime.asTimeStampFromWebInterface;
			toDT:= wsResourceUsage.toDateTime.asTimeStampFromWebInterface;
		endif;
		
		create resourceUsage transient;
		resourceUsage.setProxy(resource,
								null,							//_transaction : CM_TITransaction;
								wsResourceUsage.noCharge,
								wsResourceUsage.quantity,
								wsResourceUsage.remarks,
								CM_InvoiceLine.STATUS_NORMAL,
								fromDT,							//_fromDateTime : TimeStamp
								toDT,							//_toDateTime : TimeStamp
								null,
								null,
								null
								);
		resourceUsageProxys.add(resourceUsage);
	endforeach;
	
	create tis transient;
	tis.add(cargo);
	
	app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTask, tis, resourceUsageProxys, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog

	delete tis;
	delete resourceUsageProxys;
	delete pxyTI;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoTaskResourceUpdReq"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateCargoTemperatureReading" id="58b6d350-306f-4cab-937f-19dc3fa95cca">
        <source>updateCargoTemperatureReading(request : WS_CargoTempReadingRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2016	cnwmc5	Initial creation
27 Sep 2021	navdap1	TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
16 Jan 2026	navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

vars
	response			: WS_Response;
	completedOK			: Boolean;
	
	pxyTI,
	ti 					: CM_TrackedItem;
	timeStamp			: TimeStamp;
	tempReadingParams	: CMIF_TempReading;
	humidReadingParams	: CMIF_HumidReading;
	ventReadingParams	: CMIF_VentReading;
	measure				: CM_MeasurementType;
	load				: Boolean;	
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
//	app.checkCurrentUserHasAccess(PmReeferMonitorMod);		// Replace with appropriate permission
	app.checkCurrentUserHasAccess(Mod_BaseSystem);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if request.cargoOid &lt;&gt; null then
		ti := app.myPassport.getObjectOfTypeFromOid(request.cargoOid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	if ti = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		completedOK := true;
		return response;
	endif;
	
	app.cmsBeginLoad(load);
	pxyTI := ti.pxyCreateUpdateProxy;
	app.cmsEndLoad(load);	
		
	timeStamp := app.actualTimeServer();
	
	if request.temperature &lt;&gt; NULL_TEMPERATURE then
		create tempReadingParams transient;	
	/*	tempReadingParams.dateTime := timeStamp;
		tempReadingParams.noCharge := request.noCharge;
		tempReadingParams.userId := app.getMyUserCode();
		tempReadingParams.myTerminal := pxyTI.myTerminal;
		tempReadingParams.isRefConReading := false;
		tempReadingParams.isRefConAlarm := false;
		tempReadingParams.refConRawData := null;
		tempReadingParams.myTrackedItem := pxyTI;
		tempReadingParams.noCharge := pxyTI.noChargeForTemperature(request.noCharge, timeStamp);
		tempReadingParams.temperature := request.temperature; */
		
		//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
		tempReadingParams.initialise( 	pxyTI,	//_reefer : CM_TrackedItem;
										request.noCharge,	//_defaultNoChargeValue : Boolean;
										timeStamp,	//_dateTime : TimeStamp;		// TFS 52081
										request.temperature	//_temperature : Real
										);
	endif;
	
	if request.humidity &lt;&gt; NULL_HUMIDITY then
		create humidReadingParams transient;
		humidReadingParams.myTrackedItem := pxyTI;
		humidReadingParams.dateTime := timeStamp;
		humidReadingParams.noCharge := request.noCharge;
		humidReadingParams.userId := app.getMyUserCode();
		humidReadingParams.myTerminal := ti.myTerminal;
		humidReadingParams.setHumidity( request.humidity );
	endif;
	
	if request.ventilation &lt;&gt; NULL_VENTILATION then
		measure := app.getDefaultMeasurementForType(Type_Displacement);
		create ventReadingParams transient;
		ventReadingParams.myTrackedItem := pxyTI;
		ventReadingParams.dateTime := timeStamp;
		ventReadingParams.noCharge := request.noCharge;
		ventReadingParams.userId := app.getMyUserCode();
		ventReadingParams.myTerminal := ti.myTerminal;
		ventReadingParams.ventilation := app.convertMeasurementForStorage(measure.shortName, request.ventilation);
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxCA.trxCreateReeferReadings(tempReadingParams, humidReadingParams, ventReadingParams, null, null, null, app.myPassport);	// MTN-36569
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	delete pxyTI;
	delete tempReadingParams;
	delete humidReadingParams;
	delete ventReadingParams;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoTempReadingRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateDelay" id="954720de-cbd0-4af1-95b0-ec0e7a6204ed">
        <source>updateDelay(request : WS_DelayUpdateRequest) : WS_DelayResponse webService;
/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
*/

vars
	response		: WS_DelayResponse;
	completedOK		: Boolean;
	failedDAC		: CM_DataAccessController;
	
	pxyDelay,realDelay	: CM_Delay;
	
	wsDelay,
	wsDelayUpdate	: WS_Delay;
	ts : TimeStamp;
	load			: Boolean;
	voyage : CM_Voyage;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHandHeldShipDelays);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsDelay := request.myDelay;
	//epr TFS 5535 4/8/17 
	realDelay :=app.myPassport.getObjectOfTypeFromOid(wsDelay.cmObjectId,CM_Delay).CM_Delay;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if realDelay = null then
		app.raiseCMException2(Does_not_exist_cannot_update, app.getErrorString(Delay), wsDelay.myDelayType.description, null, null);
		completedOK := true;
		return response;
	endif;
	
	app.cmsBeginLoad(load);
	pxyDelay := realDelay.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	wsDelay.setProxyDelay(pxyDelay);
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxUpdateDelay(pxyDelay, app.myPassport);
	
	if app.myPassport.noErrors() then
		create wsDelayUpdate transient;
		wsDelayUpdate.setProxyFromObject(pxyDelay);
		response.setDelay(wsDelayUpdate);
	endif;
	
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete pxyDelay;
	
	app.cmsEndLoad(load);
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_DelayUpdateRequest"/>
        <ReturnType type="WS_DelayResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateGateCheckerDetails" id="47893928-30d3-4725-82e4-e3c2997cf5b4">
        <source>updateGateCheckerDetails(_request : WS_GateCheckerUpdateRequest) : WS_GateCheckerResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 March 2016	cnwma1	TFS 1488 JMT Mobile Apps - RecRel -  Gate Checker
16 April 2018 	jlgmd1	TFS 37997 MSL - Gate Checker - web application
16 Jun 2025		navbs1	Story MTN-34429: MTN - DeadLock Retry Required for trxVehicleRoadExit

*/
vars
	response		: WS_GateCheckerResponse;
	gateCheckerController : CMIF_MobileGateChecker;
	terminal 		: CM_Terminal;
	completedOK		: Boolean;
	truck 			: CM_Vehicle;
	gate 			: CM_Gate;
	errmsg 			:String;
	gateArea 		: CM_TerminalArea;
	gateLane		: CM_LocationsController;
	idx				: Integer;

begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	
	terminal := app.myPassport.myTerminal;
	truck := terminal.vehicles[_request.vehicle.toUpper, null];
	
	if truck = null then
		app.raiseCMException1(ERR_Truck_Unknown,_request.vehicle,null,null);
		completedOK:=true;
		return response;
	endif;
	
	gate := terminal.allGates[_request.gate];
	// Create the response
	create response transient;
	
	app.checkCurrentUserHasAccess(PmHandHeldGateChecker);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	create gateCheckerController transient;
	gateCheckerController.setMyTerminal(terminal);
	gateCheckerController.setTruck(truck);
	
	self.setIgnoreWarnings(_request.warningsAcknowledged);
	
	
	if not app.myPassport.hasErrorsOrWarnings then
		response.setDefaultForTouched();
	endif;
	
	idx := _request.lane.pos("Lane",1) - 1;			// TFS 37997 jlgmd1 16/04/2018
	// getTAFromClassString does a lazy match, and returns the first one it finds, so to try and avoid matching the wrong one
	// lets help it out a bit by setting its start index to our lane name.
	gateArea := terminal.getTAFromClassString(_request.lane,idx,CM_GateArea);
	
	foreach  gateLane in gateArea.allLocationsControllers do
		if gateLane.isKindOf(CM_GateAreaLaneController) then
			if gateLane.getNiceName = _request.lane then
				gateCheckerController.setGateAreaLaneController(gateLane.CM_GateAreaLaneController,false);
				break;
			endif;
	 endif;
	endforeach;

	if gateCheckerController.inward then
		// now move truck to yard...
		if not gateCheckerController.moveTruckToYard(errmsg) then
			app.raiseCMException1(Error_Display,errmsg, null, null);  //22/02/2017 cnwma1 TFS 2761
			completedOK := true;
			return response;
		endif;
	
	elseif not gateCheckerController.inward then
		//16.06.2025 navbs1 #34429 START
		/*if not gateCheckerController.doGateCheckerCompleteOutward() then
			completedOK := true;
			return response;
		endif;*/
		app.myPassport.setupForDeadlockReplay(-10, 2000);
		while true do 
			gateCheckerController.doGateCheckerCompleteOutward();
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;
		//16.06.2025 navbs1 #34429 END

	endif;
		
	if errmsg&lt;&gt; null then
		app.raiseCMException1(Error_Display,errmsg, null, null); //22/02/2017 cnwma1 TFS 2761
		completedOK := true;
		return response;
	endif;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	process.setPersistentDeadlockPriority(0);							//16.06.2025 navbs1 #34429
	app.myPassport.replayingDeadlocks := false;							//16.06.2025 navbs1 #34429
	if gateCheckerController &lt;&gt; null then
		gateCheckerController.clearAll();
		gateCheckerController.setGateAreaLaneController(null, true);	// reset lane controller
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	delete gateCheckerController;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="_request" type="WS_GateCheckerUpdateRequest"/>
        <ReturnType type="WS_GateCheckerResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateHMSResourcesUsed" id="03d58e3e-97d6-4451-bf23-a0dd24f4cebb">
        <source>updateHMSResourcesUsed(_request : WS_HMSResourcesUsedRequest input)  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2018	jlger1	Initial creation 37665
24 Aug 2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
01/10/2021	jlier1	TFS 51963 - changes voyage process
*/

vars
	response : WS_Response;
	completedOK : Boolean;
	voyage : CM_Voyage;
	pxyResourceUsed : HMS_ResourceUsed;
	wsHMSResourceUsed : WS_HMSResourceUsed;
	allPxyHMSResourcesUsed : HMS_ResourceUsedSet;
	voyageStatus : CM_VoyageStatus;
	berth : HMS_Berth;
	newOccursOn :TimeStamp;
	towingVoyage : CM_Voyage;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	voyage := app.myPassport.getObjectOfTypeFromOid(_request.voyage, CM_Voyage).CM_Voyage;
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK:=true;
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmWebWorkOrdersVoyMaint);
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	voyageStatus := app.myRoot.allVoyageStatuses[voyage.status];
	if voyageStatus = null then
		app.raiseCMException2(Cannot_Set_Voyage_Status, voyage.myTerminal.code, null, "status", null);
		completedOK:=true;
		return response;
	endif;
	//epr TFS 41539 31/10/18 can now update at request and rejected approval 
	if voyageStatus.isInitialMarineServiceStatus then
		if voyage.myVoyageProcess.isMTNWOProcess then	//jlier1 TFS 51963 1/10/21 			
			voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_ServicesPending];			
		endif;

	else//if voyageStatus.isDepartureMarineService then
		if voyage.myVoyageProcess.isMTNWOProcess then		//jlier1 TFS 51963 1/10/21		
			voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_DepServPending];			
		endif;
	endif;

	if voyageStatus = null or not voyageStatus.userCanSet(voyage.myTerminal) then
		if voyageStatus &lt;&gt; null then
			app.raiseCMException2(Cannot_Set_Voyage_Status, voyage.myTerminal.code, voyageStatus.description, "status", null);
		else
			app.raiseCMException2(Cannot_Set_Voyage_Status, voyage.myTerminal.code, null, "status", null);
		endif;
		completedOK:=true;
		return response;
	endif;
	
	create allPxyHMSResourcesUsed transient;
	
	foreach wsHMSResourceUsed in _request.allHMSResourcesUsed discreteLock do
		create pxyResourceUsed transient;
		wsHMSResourceUsed.setProxyHMSResorceUsed(pxyResourceUsed);
		allPxyHMSResourcesUsed.add(pxyResourceUsed);		
	endforeach;
	
	if _request.berth &lt;&gt; null then
		berth:=app.myPassport.getObjectOfTypeFromOid(_request.berth,HMS_Berth).HMS_Berth;
	endif;
	
	if _request.occursOnDT &lt;&gt; null then
		newOccursOn:=_request.occursOnDT.asTimeStampFromWebInterface;
		newOccursOn := newOccursOn.addSeconds(1); // TFS 41539 during testing the newOccursOn has no milliseconds but voyage.arrivedDT does so the next if statement was being raised
		
		//25 Sep 2018	NDL	TFS 40810
		if newOccursOn &lt; voyage.arrivedDT or newOccursOn &gt; voyage.departedDT then
			app.raiseCMException(Occur_date_must_betwe_arriv_de, "", null);
			completedOK:=true;
			return response;
		endif;
	endif;
	
	
	if voyage &lt;&gt; null and voyage.myHMSVoyageData &lt;&gt; null  and voyage.myHMSVoyageData.requiresTow and  _request.towingVoyage &lt;&gt; null then
		towingVoyage:= app.myPassport.getObjectOfTypeFromOid(_request.towingVoyage,CM_Voyage).CM_Voyage;
	endif;
	
	app.myTrxUA.trxUpdateHMSResourcesUsed(allPxyHMSResourcesUsed,voyage,null,voyageStatus.id,berth,newOccursOn,towingVoyage,null,
																			_request.bowMarkTo, _request.draftAft, _request.draftFwd, _request.hasRamp, // TFS 40236
																			_request.starboardBerthed, app.myPassport); // TFS 40236
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog

	
	if allPxyHMSResourcesUsed &lt;&gt; null then
		allPxyHMSResourcesUsed.purge;
		delete allPxyHMSResourcesUsed;
	endif;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_HMSResourcesUsedRequest" usage="input"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateInterTerminalLoadStatus" id="3be223ee-154c-4975-8ad8-58353e09234e">
        <source>updateInterTerminalLoadStatus(request : WS_InterTerminalStatusRequest): WS_Response webService;
/*

Purpose: checks to see if the cargoId is valid and is of type ISO container
and whether cargo item is NOT already on the vehicle. If the checks pass through
update the status of the move to 'Loading'

Parameters:	

Return Value:		

Date		Who		Reason
09 February 2017	cnwam15	Initial creation

*/

vars
	response : WS_Response;
	targetTerminal : CM_Terminal;
	sourceTerminal : CM_Terminal;
	truck : CM_Vehicle;
	interTerminalJob : CM_InterTermVehicleJob;
	move : CM_InterTerminalMove;
	ti : CM_TrackedItem;
	completedOK	: Boolean;
	pProxyInterTermMove : CM_InterTerminalMove;
	pNewInterTermMove   : CM_InterTerminalMove;
	interTerminalJobProxy : CM_InterTermVehicleJob;
		
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	
	app.checkCurrentUserHasAccess(PmHandHeldInterTerminal);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	sourceTerminal := app.myPassport.myTerminal;		
	ti:= sourceTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(request.cargoId,null);
	if ti = null then
		app.raiseCMException1(Cargo_item_not_found,request.cargoId,null,null);
		completedOK := true;
		return response;
	endif;
	
	if not ti.isContainer then
		app.raiseCMException(Inter_trans_truck_desig_trans,null,null);
		completedOK := true;
		return response;
	endif;
		
	truck := sourceTerminal.vehicles[request.truckId.toUpper, ""];
	if truck = null then
		app.raiseCMException(Truck_not_found,null,null);
		completedOK := true;
		return response;
	endif;
		
	interTerminalJob := truck.getInterTerminalJob();
	if interTerminalJob = null then
		create interTerminalJobProxy transient;
		interTerminalJobProxy.setProxy(truck, app.myPassport.myUser.getName());
		app.myTrxCA.trxCreateInterTermVehicleJob(interTerminalJobProxy, interTerminalJob, app.myPassport);
		
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
	else
		foreach move in interTerminalJob.allInterTerminalMoves do 
			if move.mySourceTI = ti then
				app.raiseCMException(CargoItemAlreadyOnVehicle,app.getErrorString(CargoItemAlreadyOnVehicle),null);
				completedOK := true;
				return response;
			endif;
		endforeach;
	endif;
		
	targetTerminal := app.getMyRoot().getTerminalByName(request.terminalName);
	
	//validate is completed, now update the status
	create pProxyInterTermMove transient;
	pProxyInterTermMove.setProxy(	ti.id,	//_cargoID : String;
									ti.myOperator,	//_operator : CM_Operator;
									ti,	//_sourceTI : CM_TrackedItem;
									sourceTerminal,	//_sourceTerminal : CM_Terminal;
									targetTerminal,	// _targetTerminal : CM_Terminal;
									truck,	//_sourceVehicle : CM_Vehicle;
									truck.regNumber,	//_vehicleId : String;
									ITT_LOADING,	//_status : Integer;
									interTerminalJob	//_myInterTermVehicleJob : CM_InterTermVehicleJob
									);
		
	app.myTrxCA.trxCreateInterTerminalMove(pProxyInterTermMove, pNewInterTermMove, app.myPassport); 
	
	completedOK := true;
	return response;
	
epilog
	
	delete interTerminalJobProxy;
	delete pProxyInterTermMove;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;
	
</source>
        <Parameter name="request" type="WS_InterTerminalStatusRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateInterTerminalMoveStatus" id="16eb07a2-d2d1-4b08-a0b8-c0446e48a111">
        <source>updateInterTerminalMoveStatus(request : WS_InterTerminalStatusRequest): WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2017	cnwhl1	Initial creation

*/

vars
	truck : CM_Vehicle;
	interTerminalJob : CM_InterTermVehicleJob;
	interTerminalMove, move, proxyMove : CM_InterTerminalMove;
	response : WS_Response;
	terminal : CM_Terminal;
	completedOK : Boolean;
	tmpFoundLC : CM_LocationsController;
	foundHeight : Integer;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	self.setIgnoreWarnings(request.warningsAcknowledged);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	app.checkCurrentUserHasAccess(PmHandHeldInterTerminal);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;

	truck := terminal.vehicles[request.truckId.toUpper, ""];	
	
	interTerminalJob := truck.getInterTerminalJob();
	
	foreach move in interTerminalJob.allInterTerminalMoves do 
		if move.cargoID = request.cargoId then
			interTerminalMove := move;
		endif;
	endforeach;
	
	
	terminal.findLocationFromString(request.locationId ,true,tmpFoundLC,foundHeight);
	
	proxyMove := app.createUpdateProxy(interTerminalMove).CM_InterTerminalMove;
	proxyMove.setStatus( ITT_UNLOADING );
	proxyMove.setMyTargetLC( tmpFoundLC );
	
	app.myTrxUA.trxUpdateInterTerminalMove(  proxyMove, app.myPassport ); 
	
	completedOK := true;
	return response;
	
epilog
	
	delete proxyMove;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_InterTerminalStatusRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateInvoiceStatus" id="1f3a6be5-d4dc-482d-ad95-f2dafc8fe4f2">
        <source>updateInvoiceStatus(request : WS_InvoiceApproveRejectRequest): WS_InvoiceUpdateResponse  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Sep 2018	jlgndl1	Initial creation	TFS 40889
03 Oct 2018 jlger1	TFS 41012 - also sending emails here with better details from the invoice/cashreceipt
                              - also now works with cash receipt objects
28 Feb 2019 cnwma1  Bug 43514: PEL1 - SAP Credit check approval option
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars

	response 	: WS_InvoiceUpdateResponse;
	completedOK : Boolean;	
	
	invoice : CM_Invoice;
	doApprove : Boolean;
	doReject : Boolean;
	
	terminal : CM_Terminal;
	status : Integer;
	permission : Integer;
	pxyInvoice : CM_Invoice;
	statuses : CMIF_Array;
	cmifStatus : CMIF_InvoiceStatus;
	cashReceipt : CM_CashReceipt;
	workOrder	: CM_WorkOrder;
	rejectEmailSubject : String;
	voyageCode : String;
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	doApprove := request.doApprove;
	doReject := request.doReject;
	if request.doApprove = request.doReject then
		app.raiseCMException(Invalid_action,null,null);
		completedOK := true;
		return response;
	endif;
	
	invoice := app.myPassport.getObjectOfTypeFromOid( request.invoiceOid, CM_Invoice ).CM_Invoice;
	
	if invoice = null then
		app.myPassport.clearErrorsWarnings;
		cashReceipt:=app.myPassport.getObjectOfTypeFromOid( request.invoiceOid, CM_CashReceipt ).CM_CashReceipt;
	endif;
	
		
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if invoice = null and cashReceipt = null  then
		app.raiseCMException(Invoice_selected,null,null);
		completedOK := true;
		return response;
	endif;
	
	response.setMyInvoice( invoice ); // set to the current version.
	
	if invoice &lt;&gt; null then
		terminal := invoice.myTerminal;
		if doApprove then
			// TFS 39618 PATCH 1 permission := PmAdmInvoiceStatusPost;
			status := CM_Invoice.INVOICE_PENDING;
		elseif doReject then
			// TFS 39618 PATCH 1 permission := PmAdmInvoiceStatusDisputed;
			status := CM_Invoice.INVOICE_DISPUTED;
		endif;
		
		if not invoice.bank.userCanSet(status) then  // TFS 39618 PATCH 1 
		// TFS 39618 PATCH 1 if not app.getMyUser.canDo(terminal, permission) then
			app.raiseCMException(Err_InsufficientPermission, null, null);//79610
			completedOK := true;
			return response;
		endif;	
		
		if invoice.status &lt;&gt; status then
			pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
			
			create statuses transient;
			create cmifStatus transient;
			cmifStatus.myInvoice := pxyInvoice;
			cmifStatus.newStatus := status;
			statuses.add(cmifStatus);
			
			app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
		
			response.setMyInvoice( invoice ); // reset to the latest version.
			
		endif;
		if doReject then
			if invoice.myVoyage &lt;&gt; null then
				voyageCode:=invoice.myVoyage.code;
			endif;
			//rejectEmailSubject:=app.getErrorString3(Reject_invoice_voyage_sent,invoice.externalFinancialId,voyageCode,app.getMyUser.getEmailAddress);
			rejectEmailSubject:=app.getErrorString3(Reject_invoice_voyage_sent,invoice.getExternalFinancialId(),voyageCode,app.getMyUser.getEmailAddress); //08/12/2025	navkc1 JIRA 36262
		endif;
	else
		if doApprove then
			if  cashReceipt.myWorkOrder &lt;&gt; null then
					app.myTrxUA.trxUpdateWOApproved( cashReceipt.myWorkOrder,false,null,null, app.myPassport);		//02.05.2024 navhl20 #63971
			endif;
			
		
		else
			if  cashReceipt.myWorkOrder &lt;&gt; null then
					app.myTrxUA.trxOOWRejection( cashReceipt.myWorkOrder, null,null,app.myPassport);
			endif;
			
			
			rejectEmailSubject:=app.getErrorString3(Reject_estimat_voyage_sent,cashReceipt.externalInvoiceNumber,cashReceipt.myWorkOrder.id,app.getMyUser.getEmailAddress);
		endif;
		response.setMyInvoice( cashReceipt ); // reset to the latest version.
	endif;
	
	if doReject then
		//send an email
		app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(),	// _alertDescription
										  app.myPassport.myTerminal.getConfig(EmailForFinance).String,		// _toAddress
										   app.myRoot.getConfig(AutoSendersEmailAddress).String,					// _fromAddress
										  null,		// _ccAddresses
										  null,		// _bccAddresses
										  rejectEmailSubject,			// _sendSubject
										  request.rejectReason,				// _sendMessage
										  null,						// _allAttachedFilePaths
										  null,						// _allFileData
										  null,						// _blob
										  null,						// _blobFileName
										  EmailSource_System,		// _sourceOfEmail
										  null,						// _updateCallbackObj
										  app.myPassport);			// _passport
	
	endif;
	
	completedOK := true;
	return response;

epilog

	delete cmifStatus;
	delete pxyInvoice;
	delete statuses;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_InvoiceApproveRejectRequest"/>
        <ReturnType type="WS_InvoiceUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateLogDocket" id="46187f2f-6f75-4943-8009-157477f84de9">
        <source>updateLogDocket(request : WS_LogDocketDataRequest) : WS_LogDocketResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation
15 Nov     2017 cnwma1  TFS #7354: C3 - Urgent - createLogDocket and updateLogDocket webservice returning the wrong JadeOID
*/

vars
	response			: WS_LogDocketResponse;
	completedOK			: Boolean;
	
	wsLogDocket 		: WS_LogDocket;
	logDocketData,
	logDocketDataNew 	: CM_LogDocketData;
	bol,
	pxyBOL 				: CM_BOLIn;
	wsBOL				: WS_BOL;
	
	intFaceArray		: CMIF_TIObjectArray;
	intFaceCommon		: CMIF_InOutCommon;
	intFaceBOLIn		: CMIF_BOLIn;
	terminal			: CM_Terminal;
	
	load				: Boolean;
	
	gateDefault			: CM_Gate;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmLogDocketCorrection);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//Method processing here...
	wsLogDocket := request.myLogDocket;
	terminal := app.getMyTerminalDO_NOT_USE();
	
	create logDocketData transient;
	wsLogDocket.setLogDocketProxy(logDocketData);
	
	create intFaceArray transient;
	create intFaceCommon transient;
	
	intFaceCommon.myTerminal := terminal;
	intFaceCommon.regNumber := logDocketData.regNo;
	intFaceCommon.carrierCode := logDocketData.carrierCode;
	intFaceCommon.driverId := logDocketData.driverId;
	intFaceCommon.isReceiptRequired := logDocketData.receiptRequired;
	intFaceCommon.vehicleTareKilos := logDocketData.weightTare;
	
	gateDefault := terminal.getDefaultGate_IN();
	intFaceCommon.myGateEntry := gateDefault;
	if gateDefault &lt;&gt; null and gateDefault.myDefaultInterchangeArea &lt;&gt; null then
		intFaceCommon.roadTransAreaId := gateDefault.myDefaultInterchangeArea.id;
	endif;
	
	//epr TFS 2711 22/9/16
	if wsLogDocket.docketOid &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		bol :=app.myPassport.getObjectOfTypeFromOid( wsLogDocket.docketOid,CM_BOLIn).CM_BOLIn;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	if bol = null then
		//bol := terminal.getBOLInByNumber(logDocketData.docketNumber, BOLType_Log);             					  //16/11/2017 cnwma1 TFS #7354
		bol := terminal.getBOLInByNumberOperator(logDocketData.docketNumber,logDocketData.operatorCode.toUpper, BOLType_Log); //16/11/2017 cnwma1 TFS #7354
		
	endif;
	
	//cnwmc5 - 18 Dec 2014 - PAR 35436
	if bol = null then
		app.raiseCMException1(DocketNotFound, logDocketData.docketNumber, null, null);
		completedOK := true;
		return response;
	endif;
	
	app.cmsBeginLoad(load);
	pxyBOL := bol.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	create intFaceBOLIn transient;
	intFaceBOLIn.setMyInOutCommon(intFaceCommon);
	logDocketData.setIntFaceBOLIn(intFaceBOLIn, pxyBOL);
	intFaceArray.add(intFaceBOLIn);
	
	pxyBOL.setPxyFromCMIF_BOL(intFaceBOLIn, app.myPassport);
	
	app.myTrxUA.trxUpdateBOL(pxyBOL, false, null, app.myPassport);
	
	//Find the newly added Log Docket (BOL)
	if app.myPassport.noErrors() then
		if bol &lt;&gt; null then
			create wsBOL transient;
			wsBOL.setProxyFromObject(bol);
			response.allBOLs.add(wsBOL);
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	app.cmsEndLoad(load);

	// Tidy up any local transients
	delete logDocketData;
	delete intFaceBOLIn;
	delete intFaceArray;
	delete intFaceCommon;
	if pxyBOL &lt;&gt; null and not pxyBOL.allDocketErrors.isEmpty() then		//cnwmc5 - 18 Dec 2014 - PAR 35436
		pxyBOL.allDocketErrors.purge();
	endif;
	delete pxyBOL;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_LogDocketDataRequest"/>
        <ReturnType type="WS_LogDocketResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateLogDocketData" id="06423433-7d4d-4922-b92c-24054508d1aa">
        <source>updateLogDocketData(request : WS_LogDocketDataRequest) : WS_LogDocketDataResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation

*/

vars
	response			: WS_LogDocketDataResponse;
	completedOK			: Boolean;
	
	wsLogDocket,
	wsLogDcoketUpdated	: WS_LogDocket;
	logDocket,
	logDocketUpdated	: CM_LogDocketData;
	
	terminal			: CM_Terminal;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmXmlBolEntryRq);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//Method processing here...
	wsLogDocket := request.myLogDocket;
	terminal := app.getMyTerminalDO_NOT_USE();
	
	create logDocket transient;
	wsLogDocket.setLogDocketUpdateProxy(logDocket);
	
	app.myTrxUA.trxUpdateLogDocketData(logDocket, app.myPassport);
	
	logDocketUpdated := terminal.allLogDocketDataByOidString[logDocket.docketNumberWeigh];
	if logDocketUpdated &lt;&gt; null and app.myPassport.noErrors() then
		create wsLogDcoketUpdated transient;
		wsLogDcoketUpdated.setProxyFromObject(logDocketUpdated);
		response.setMyLogDocketData(wsLogDcoketUpdated);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	//cnwmc5 - 18 Dec 2014 - PAR 35436
	delete logDocket;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_LogDocketDataRequest"/>
        <ReturnType type="WS_LogDocketDataResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateLogRow" id="0557c6ff-9389-43f4-86e7-ad2423d4d7d3">
        <source>updateLogRow(request : WS_LogRowUpdateRequest) : WS_LogRowResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_LogRowResponse;
	completedOK		: Boolean;
	cmifLogRow		: CMIF_LogRowRestriction;
	logRow,
	newLogRow		: CM_LogController;
	wsLogRow,
	wsNewLogRow		: WS_LogController;
	load			: Boolean;
	terminal		: CM_Terminal;
	foundHeight		: Integer;
	logArea			: CM_LogArea;
	terminalArea	: CM_TerminalArea;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmLogRowMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.getMyTerminalDO_NOT_USE();
	wsLogRow := request.myLogController;
	
	terminalArea := terminal.allTerminalAreas[wsLogRow.terminalAreaId];
	if terminalArea &lt;&gt; null and terminalArea.isKindOf(CM_LogArea) then
		logArea := terminalArea.CM_LogArea;
	endif;
	
	logRow := logArea.findLogRow(wsLogRow.id);
	if logRow = null then
		app.raiseCMException2(Does_not_exist_cannot_update, app.getErrorString(LogRow), wsLogRow.id, null, null);
		completedOK := true;
		return response;
	endif;
	
	create cmifLogRow transient;
	wsLogRow.setCMIFLogRowForUpdate(cmifLogRow, logRow);
	
	app.cmsBeginLoad(load);
	cmifLogRow.myProxyLogController := logRow.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	app.myTrxUA.trxUpdateLogRow(cmifLogRow, app.myPassport);
	
	if app.myPassport.noErrors() then
		create wsNewLogRow transient;
		wsNewLogRow.setProxyFromObject(logRow);
		response.setLogController(wsNewLogRow);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	if cmifLogRow &lt;&gt; null then
		delete cmifLogRow.myProxyLogController;
	endif;
	delete cmifLogRow;
	
	app.cmsEndLoad(load);
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_LogRowUpdateRequest"/>
        <ReturnType type="WS_LogRowResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateLogSpec" id="332eea70-b539-460c-885c-2498c4940b69">
        <source>updateLogSpec(request : WS_LogSpecsUpdateRequest) : WS_LogSpecsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_LogSpecsResponse;
	completedOK		: Boolean;
	
	pxyCodeGroup	: CM_CodeGroup;
	realCodeGroup	: CM_CodeGroup;
	
	wsCodeGroup,
	wsCodeGroupNew	: WS_CodeGroupLogSpecs;
	
	load			: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmCodeGroupMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsCodeGroup := request.myCodeGroupLogSpecs;
	
	realCodeGroup := app.myRoot.allCodeGroups[CodeGroup_LogSpecs, wsCodeGroup.name];
	
	if realCodeGroup = null then
		app.raiseCMException2(Does_not_exist_cannot_update, /*app.getErrorString(LogSpecs)*/ "Log Specs", wsCodeGroup.name, null, null);
		completedOK := true;
		return response;
	endif;
	
	app.cmsBeginLoad(load);
	pxyCodeGroup := realCodeGroup.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	wsCodeGroup.setUpdateProxyCodeGroupLogSpec(pxyCodeGroup.CM_CodeGroupLogSpecs, realCodeGroup.CM_CodeGroupLogSpecs);
	
	//cnwmc5 - 6 Jan 2015 - PAR 35446
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	app.myTrxUA.trxUpdateCodeGroupLogSpecsTree(pxyCodeGroup, realCodeGroup, app.myPassport);
	
	if realCodeGroup.isKindOf(CM_CodeGroupLogSpecs) and app.myPassport.noErrors() then
		create wsCodeGroupNew transient;
		wsCodeGroupNew.setProxyFromObject(realCodeGroup.CM_CodeGroupLogSpecs);
		response.setCodeGroupLogSpecs(wsCodeGroupNew);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete pxyCodeGroup;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_LogSpecsUpdateRequest"/>
        <ReturnType type="WS_LogSpecsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateMoveJobVoyage" id="1cf053b4-1058-4590-a5bf-354a1548c4d8">
        <source>updateMoveJobVoyage(request : WS_VoyageJobRequest) : WS_VoyageJobResponse webService;
/*
Purpose:			
Date		Who		Reason
24/06/2015	cnwab1	Initial creation
27/03/2020	jlgdap1	TFS 49002 GPHA Error In Transit
26/10/2022  navmv20 Bug 51643: MTN - Cargo Lander Shift on board gives error about not having a job 
24 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
*/

vars
	response		: WS_VoyageJobResponse;
	completedOK		: Boolean;
	terminal		: CM_Terminal;
	ti : CM_TrackedItem;
	moveMode : String;
	context : Integer;
	mobileAgent : CMIF_MobileGenericAgent;
	allTIs : CM_TIArray;
	targetLocation : String;
	subCargo : CM_TrackedItem;
	checkMsg : String;
	failedDAC		: CM_DataAccessController;
	targetLC : CM_LocationsController;
	groundOption  : Integer;
	permissionsToCheck : IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	response.webserviceCall := method.name;
	
	response.setFromRequest(request);
	
	terminal := app.myPassport.myTerminal;
	
	moveMode := request.moveMode;
	if request.jobMode = WS_VoyageJobRequest.JobModeDischarge and (moveMode = null or moveMode = "null") then // default
		moveMode := WS_VoyageJobRequest.MoveModeMachine;
	endif;
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(terminal.allVoyagesByCode.getAtKeyGeq(request.voyageCode.trimBlanks,null));
	if request.jobMode = WS_VoyageJobRequest.JobModeDischarge then
		mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipDischargeCargo) ;
		
	elseif request.jobMode = WS_VoyageJobRequest.JobModeLoad then
		mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipLoadCargo);
	elseif request.jobMode = WS_VoyageJobRequest.JobModeSOB then
		mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShiftOnBoard);
	endif;
	
	create allTIs transient;
	
	if request.cargoUid &lt;&gt; "" then
		//epr TFS 5535 4/8/17 
		ti:=app.myPassport.getObjectOfTypeFromOid(request.cargoUid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if ti &lt;&gt; null then
			allTIs.add(ti);
		endif;
	endif;
		
	if ti = null and request.cargoId &lt;&gt; null then
		mobileAgent.findLanderCargo(request.cargoId, allTIs);
		if allTIs.size = 1 then
			ti:= allTIs.first;
		endif;
	endif;
	
	targetLocation:= request.targetLocation;
	if ti &lt;&gt; null then
		mobileAgent.validateLanderCargo(ti);
		if targetLocation = null then
			targetLocation :=mobileAgent.getLanderCargoTargetLocation(ti);
		endif;
	endif;
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHandHeldLander);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	//if not app.myCurrentUserCan(ti.myTerminal,PmHandHeldLander) then
	//	app.raiseCMException(Err_InsufficientPermission, null, null);//79610
	//	completedOK := true;
	//	return response;
	//endif;
	
	if  not ti.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then   
		app.raiseCMException(Err_InsufficientPermission, null, null);
		completedOK := true;
		return response;
	endif;
	
	self.setIgnoreWarnings(request.warningsAcknowledged);
	
	if mobileAgent.checksState = CMIF_MobileGenericAgent.ShipDischargeCargo  then
		context := CARGO_CHECK_CONTEXT_SHIP_DISC;
	elseif mobileAgent.checksState = CMIF_MobileGenericAgent.ShipLoadCargo  then
		context := CARGO_CHECK_CONTEXT_SHIP_LOAD;
	endif;
	
	if context &lt;&gt; 0 then
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_ALTERNATIVE_ID,context,ti,request.alternativeIdTouched);
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_IS_OD,context,ti,request.overDimensionsTouched);
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_DIMENSION,context,ti,request.dimensionsTouched);
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_HAZARD_SYMBOLS,context,ti,request.hazardsTouched);
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_PHOTO,context,ti,request.photoTouched);
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_SEALS,context,ti,request.sealsTouched);
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_SPECIAL_LIFT,context,ti,request.specialLiftTouched);
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_TEMPERATURE,context,ti,request.temperatureTouched);
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_WEIGHT,context,ti,request.weightTouched);
		mobileAgent.createCargoCheckForTI(EXTRA_INFO_DAMAGE,context,ti,request.damageTouched);				// TFS 49002
		checkMsg := mobileAgent.isWaitingOnRequiredChecks(context,ti,subCargo); 
		if checkMsg &lt;&gt; null then
			app.raiseCMException2(Cargo_check_required,checkMsg,ti.id, null,null); // TFS 1490 added ID
			completedOK := true;
			return response;
		endif;
	endif;
	
	targetLC:= mobileAgent.findLanderLocation(targetLocation);	
	if targetLC = null then
		app.raiseCMException1(Location_NotFound,targetLocation,null,null);		
		completedOK := true;
		return response;
	endif;
	
	if mobileAgent.checksState = CMIF_MobileGenericAgent.ShipLoadCargo then
		mobileAgent.doLanderLoad(ti,targetLC,null,null,null);
	elseif mobileAgent.checksState = CMIF_MobileGenericAgent.ShiftOnBoard then
		if ti.myPrimaryActualLocation = targetLC then
			app.raiseCMException2(Cargo_already_located,ti.id,targetLocation,null,null);
			completedOK := true;
			return response;
		endif;
		//mobileAgent.doLanderSOB(ti,targetLC,null,null); //26/10/2022 navmv20 TFS 51643
		mobileAgent.doLanderSOB(ti,targetLC,null,null,false); //26/10/2022 navmv20 TFS 51643
	elseif mobileAgent.checksState = CMIF_MobileGenericAgent.ShipDischargeCargo  and request.moveMode = WS_VoyageJobRequest.MoveModeMachine then
		mobileAgent.doLanderDischarge(ti,targetLC,null,null);
	else
		groundOption := GroundComplete;
		if request.moveMode = WS_VoyageJobRequest.MoveModeTransit then
			groundOption :=GroundInTransit;
		endif;
		mobileAgent.doLanderDischargeToGround(ti,targetLC,groundOption,null,null);
	endif;
	
	
	if not app.myPassport.hasErrorsOrWarnings then
		response.setDefaultForTouched();
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

	
	delete mobileAgent;
	delete allTIs;
end;</source>
        <Parameter name="request" type="WS_VoyageJobRequest"/>
        <ReturnType type="WS_VoyageJobResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateOrAddWagon" id="ec8c67f3-6921-4b1e-9483-4be1840fb1a1">
        <updating/>
        <source>updateOrAddWagon(request : WS_WagonAddOrUpdRequest) : WS_WagonAddOrUpdResponse updating, webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2017	cnwsc8	Initial creation

*/

vars
	completedOK 	: Boolean;
	response  		: WS_WagonAddOrUpdResponse;
	train			: CM_Train;
	terminal 		: CM_Terminal;
	railLine		: CM_RailLine;
	wagon,currentWagon,pxyWagon	: CM_Wagon;
	wagonProxy		: WS_Wagon;
	errorMess		: String;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	loadState : Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	
	//epr TFS 5535 4/8/17
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		// Replace with appropriate permission
		
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	
	if request.trainUid = "" then
		completedOK := true;
		return response;
	endif;
	
	if request.rakeUid = "" then
		completedOK := true;
		return response;
	endif;

	if request.newWagonId = "" then
		completedOK := true;
		return response;
	endif;

	if request.rakePosition &lt; 1 then
		completedOK := true;
		return response;
	endif;

	terminal := app.myPassport.myTerminal;
	//epr TFS 5535 4/8/17 
	train := app.myPassport.getObjectOfTypeFromOid(request.trainUid,CM_Train).CM_Train;
	if train = null then
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	railLine :=app.myPassport.getObjectOfTypeFromOid( request.rakeUid,CM_RailLine).CM_RailLine;
	if railLine = null then
		completedOK := true;
		return response;
	endif;
	//epr TFS 44905 10/6/19
	currentWagon:=railLine.getWagonAtPosition(request.rakePosition);
	wagon:=train.allWagonsByIdInward[request.newWagonId];
	if currentWagon &lt;&gt; null and currentWagon &lt;&gt; wagon then
		if currentWagon.myTrainInwards &lt;&gt; null and  currentWagon.myTrainInwards &lt;&gt; train and not currentWagon.myTrainInwards.isNullTrain then
			app.raiseCMException2(INWARD_WAG_ALREADY_EXISTS,currentWagon.id, currentWagon.myTrainInwards.code,null,null);
			completedOK:=true;
			return response;
		endif;
	endif;	
	//epr TFS 44905 10/6/19 already a wagon put it in the position
	if wagon &lt;&gt; null then
		//set Wagon position if currentWagon &lt;&gt; null then swap that
		if wagon.confirmed then
			app.raiseCMException2(Already_confirmed, wagon.id, wagon.getPositionDescr,null,null);
			completedOK:=true;
			return response;
		endif;
		if currentWagon &lt;&gt; null and currentWagon.confirmed then
			app.raiseCMException2(Already_confirmed, currentWagon.id, currentWagon.getPositionDescr,null,null);
			completedOK:=true;
			return response;
		endif;
		
		if currentWagon = null then
			app.cmsBeginLoad(loadState);
			pxyWagon :=	wagon.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
		
			create wagonUpdateCtrl transient;
			wagonUpdateCtrl.setBasicDetails(CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
											railLine,// rake
											train,	//_train : CM_Train;
											request.rakePosition, //_wagonPosition : Integer;
											false	// isTrainMode
											);										
			wagonUpdateCtrl.myProxyWagon := pxyWagon;
			wagonUpdateCtrl.expectedEditionWagon := wagon.edition;
			wagonUpdateCtrl.populateFromExistingWagonAddTi( wagon, null, 0 );
			
			app.myPassport.clearErrorsWarnings();
			app.myPassport.setWarningsIgnored(true);
			app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);
		else
			app.myTrxUA.trxUpdateWagonRakePositionSwap(currentWagon, wagon, app.myPassport);
		endif;
	else
		
		wagon := train.createOrUpdateWagon(request.newWagonId, request.rakePosition, railLine, errorMess);
	endif;

	if wagon &lt;&gt; null then
		create wagonProxy transient;
		wagonProxy.setProxyFromObject(wagon);
		wagonProxy.setOidDetails(wagon);
		response.wagon := wagonProxy;	
	endif;
	
	if errorMess &lt;&gt; "" then
		app.myPassport.addErrorFull(Wagon_null, errorMess, null, null, null);
	endif;
	
	completedOK:=true;
	return response;
epilog
	app.cmsEndLoad(loadState);
	delete pxyWagon;
	delete wagonUpdateCtrl;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_WagonAddOrUpdRequest"/>
        <ReturnType type="WS_WagonAddOrUpdResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updatePreNote" id="0caf9df9-0f36-4733-a324-373e119c5758">
        <usesRPC>default</usesRPC>
        <source>updatePreNote(preNoteUpdateReq : WS_PreNoteUpdateRequest) : WS_TrackedItemUpdateResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2008	cnwkao1	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
13/06/2013	cnwdap1	PAR #31754 CCMS SFW 1321 Imperial Measurements
13/06/2013	cnwdap1	PAR #31700 Added numberOfItems for break-bulk
17/06/2013	cnwdap1	PAR #31800 Added alternative ID, client ref, itemDesc, colour, mark number and remarks 
24/09/2013	cnwdap1	PAR #32215 CCMS DPH 2290 New Car Attributes
05/03/2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
30/05/2017	cnwdap1	TFS 4449 STWR Mark and Mark Number feild length adjustments
30/04/2018	jlgam15	TFS 38345 On update, prenotes should save new photos added. The Oid was missing in the response.
16/09/2019  cnwma1	Bug 46485: JMT - Web Portal - Warnings do not show for updating release requests
11/08/2023  navrv30 Bug 59370: NXL-Creating prenotes in MTN encountered performance issues in Conlinxx
*/

vars
	iFPreNote		: CMIF_PreNote;

	iFArray			: CMIF_TIObjectArray;
	response		: WS_TrackedItemUpdateResponse;
	completedOK		: Boolean;
	trackedItem		: CM_TrackedItem;
	pxyTrackedItem	: CM_TrackedItem;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGtePreNoteMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	

	create iFArray transient;
	create iFPreNote transient;
	
	if preNoteUpdateReq.cmObjectId = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "cmObjectId", preNoteUpdateReq.length, null, null);
		completedOK := true;
		return response;
	endif;
	
	//epr tfs 7744 15/11/17 refactored into method  
	preNoteUpdateReq.validateDimensions();
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	trackedItem := app.myPassport.getObjectOfTypeFromOid(preNoteUpdateReq.cmObjectId,CM_TrackedItem).CM_TrackedItem;
	if trackedItem = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		completedOK := true;
		return response;
	endif;
	// Create the required proxy (must be in load state
	beginLoad;
		pxyTrackedItem := trackedItem.pxyCreateUpdateProxy().CM_TrackedItem;
	endLoad;
	
	iFPreNote.setMyOriginalProxyTI(pxyTrackedItem); //not entirely sure this is the correct thing to call, but GTE_PreNoteForm::doSave utilises it
	
	iFPreNote.setFromTI( trackedItem, trackedItem.myTerminal );	//04 Dec 2012	NDL	Par 30777
	
	//epr tfs 7744 15/11/17 refactored into one method  
	preNoteUpdateReq.setCMIF_Prenote(iFPreNote);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;

	iFArray.add(iFPreNote);
	app.myPassport.setWarningsIgnored(preNoteUpdateReq.warningsAcknowledged); //12/09/2019 cnwma1 #46485
	app.myTrxUA.trxUpdatePreNotes(iFArray, false, app.myPassport);

	if app.myPassport.trxCompletedOK then
		if iFPreNote.myPersistentTrackedItem &lt;&gt; null then
			response.cargoUidUpdated:=iFPreNote.myPersistentTrackedItem.getOidAsString;
		endif;
	endif;
	
	completedOK := true;
	return response;
	
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	// Tidy up local transients
	delete iFArray;
	if iFPreNote &lt;&gt; null then							//11/08/2023   navrv30  Bug 59370
		delete iFPreNote.myEmailDefaults;
		iFPreNote.allDamageInstancesByPos.purge;
		delete iFPreNote;
	endif;

	delete pxyTrackedItem;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;

	cnEndTransaction;
end;
	</source>
        <Parameter name="preNoteUpdateReq" type="WS_PreNoteUpdateRequest"/>
        <ReturnType type="WS_TrackedItemUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updatePreNoteAttachment" id="758a4c37-41cd-46b8-aa16-e628e86ca234">
        <usesRPC>default</usesRPC>
        <source>updatePreNoteAttachment(attachmentCreateReq : WS_AttachmentUpdateRequest) : WS_AttachmentUpdateResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Jan 2009	cnwdz2	Initial creation

*/

vars
	
	response	  : WS_AttachmentUpdateResponse;
	completedOK	  : Boolean;
	terminal	  : CM_Terminal;
	
	intFaceAttach : CMIF_InOutAttachment;
	
	tmp,
	isoType,
	cargoId       : String; 
	weightTotal,   
	cargoType     : Integer;
	
	cargoTypeArray,
	idTextBoxArray,
	isoTypeArray,
	weightTotalArray  : StringArray;
	
	//cnwmc5 - 19 Feb 2015 - PAR 34346
	cargoTypeObj	: CM_CargoType;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGtePreNoteMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	create intFaceAttach transient;

	// apparently we have been instructed to ignore warnings.... aren't they interested in data integrity?
	self.setIgnoreWarnings(true);
	
	terminal := app.myPassport.myTerminal;
	
	cargoTypeArray := attachmentCreateReq.cargoTypeArray;
	tmp := cargoTypeArray.removeAt(1);
	if tmp &lt;&gt; null and tmp.length() &gt; 0 and tmp.isInteger() then
		cargoType := tmp.Integer;
	else
		cargoType := TI_CargoType_Null;
	endif;
	
	idTextBoxArray := attachmentCreateReq.idTextBoxArray;
	tmp := idTextBoxArray.removeAt(1);
	if tmp &lt;&gt; null and tmp.length() &gt; 0 then
		cargoId := tmp;
	endif;
	
	tmp := attachmentCreateReq.isoTypeArray.first();
	if tmp &lt;&gt; null and tmp.length() &gt; 0 then
		isoType := tmp;
	endif;
	
	tmp := attachmentCreateReq.weightTotalArray.first();
	if tmp &lt;&gt; null and tmp.length() &gt; 0 and tmp.isInteger() then
		weightTotal := tmp.Integer;
	endif;
	
	//cnwmc5 - 19 Feb 2015 - PAR 34346
	tmp := attachmentCreateReq.productTypeArray.first();
	if tmp &lt;&gt; null and tmp.length() &gt; 0 then
		cargoTypeObj := app.myRoot.allCargoTypesById[cargoType];
		if cargoTypeObj &lt;&gt; null then
			//app.raiseCMException1(null,null,null,null);
		endif;
	endif;
	
	intFaceAttach.set(terminal,cargoType,cargoId,isoType,weightTotal);
	intFaceAttach.checkFieldsNotNull(cargoType);	
	
	completedOK := true;
	return response;
	
	
epilog
	// Tidy up any local transients
	delete intFaceAttach;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="attachmentCreateReq" type="WS_AttachmentUpdateRequest"/>
        <ReturnType type="WS_AttachmentUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateReleaseImport" id="f093eb9a-3cf4-47b1-b103-cf7abafa6e2b">
        <usesRPC>default</usesRPC>
        <source>updateReleaseImport(relImportUpdateReq : WS_ReleaseImportUpdateRequest) : WS_TrackedItemUpdateResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
12 September 2008	cnwkao1	Initial creation
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	response			: WS_TrackedItemUpdateResponse;
	completedOK			: Boolean;
	trackedItem			: CM_TrackedItem;
	pxyTrackedItem		: CM_TrackedItem;
	pxyItems			: CM_TISet;	
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	realTrackedItems	: CM_TISet;
	originalStops,
	additionalStops,
	removeStops			: IntegerArray;	
	tiStop 				: CM_Stops;
	aStopTable			: CM_StopsTable;
	allStops			: CM_StopsByIdDict;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGteFullReleaseMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;		
	
	//apparently we have been instructed to ignore warnings.... 
	self.setIgnoreWarnings(true);
	
	// Perform search for specific item
	trackedItem := relImportUpdateReq.findReleaseImportTI();
	if trackedItem = null then
		app.raiseCMException(Matchin_tracked_item_found,
							null, 
							null);
		completedOK := true;
		return response;
	endif;
	
	if relImportUpdateReq.generatePinNo and app.myCurrentUserCan(app.myPassport.myTerminal, PmGteGeneratePinNo) then
//		termEmailDefaults	:= app.myPassport.myTerminal.getCarrierEmailDefaultsForType(PINEmail_CargoRelease).cloneSelf(true).CM_PINObjectDefaultEmail;	// cnwrl1 30/07/2009 PAR 20349 - what it was
		termEmailDefaults	:= app.myPassport.myTerminal.getEmailDefaultsSettings( PINEmail_CargoRelease ).cloneSelf(true).CM_PINObjectDefaultEmail;
		if termEmailDefaults = null then
			app.raiseCMException(Email_defaul_proxy_creati_fail, null, null);
			completedOK := true;
			return response;
		endif;
	endif;

	// Create the required proxy (must be in load or trx state
	beginLoad;
	pxyTrackedItem := trackedItem.pxyCreateUpdateProxy();
	endLoad;
	
	pxyTrackedItem.setReleaseCarrier(relImportUpdateReq.releaseCarrier);
	pxyTrackedItem.setFreightForwarder(relImportUpdateReq.freightForwarder);
	pxyTrackedItem.setCarrierRemarks(relImportUpdateReq.carrierRemarks);
	pxyTrackedItem.setDeliveryRelease(relImportUpdateReq.deliveryReleaseNumber);
	pxyTrackedItem.setCustomsAgent(app.myRoot.allCustomsAgents.getAtKey(relImportUpdateReq.myCustomsAgent));
	pxyTrackedItem.setRemarks(relImportUpdateReq.remarks, false);
	if pxyTrackedItem.customsEntryNumber &lt;&gt; relImportUpdateReq.customsEntryNumber then
		pxyTrackedItem.setCustomsEntryNumber(relImportUpdateReq.customsEntryNumber); //not convinced about this - just appends to an array
	endif;
	
	create originalStops transient;
	create additionalStops transient;
	create removeStops transient;
	
//	foreach tiStop in pxyTrackedItem.getAllStops() do	// cnwrl1 15/12/2009 PAR 21889 - what it was
	create allStops transient;
	pxyTrackedItem.getAllActiveStops( allStops );
	foreach tiStop in allStops do
		originalStops.add(tiStop.id);
	endforeach;	
	
	foreach aStopTable in app.myRoot.allStopsTable discreteLock do
		if not originalStops.includes(aStopTable.id) and relImportUpdateReq.allStopTableIds.includes(aStopTable.id) then					
			additionalStops.add(aStopTable.id);
		endif;
				
		if originalStops.includes(aStopTable.id) and not relImportUpdateReq.allStopTableIds.includes(aStopTable.id) then 
			removeStops.add(aStopTable.id);
		endif;		
	endforeach;
	
	pxyTrackedItem.createStopsProxyBulkEdit(additionalStops, removeStops);	
	
	create pxyItems transient;	
	pxyItems.add(pxyTrackedItem);
	
	app.myTrxUA.trxUpdateTrackedItems(pxyItems, TI_UPDMODE_NORMAL, null, app.myPassport);

	//if we get to this point and termEmailDefaults isn't null we are going to attempt to generate a PIN
	if app.myPassport.noErrors() and termEmailDefaults &lt;&gt; null then
		//KO - not convinced this is entirely correct either...
		create realTrackedItems transient;
		foreach pxyTrackedItem in pxyItems do
			realTrackedItems.add(pxyTrackedItem.pxyGetRealObject());
		endforeach;
		
//		termEmailDefaults.setAddresses(app.myPassport.myTerminal, app.myRoot.allCarriers.getAtKey(pxyTrackedItem.carrier), null);	// cnwrl1 30/07/2009 PAR 20349 - what it was
		termEmailDefaults.setAddresses(	app.myPassport.myTerminal,
										app.myRoot.allCarriers.getAtKey(pxyTrackedItem.carrier),
										null,
										PINEmail_CargoRelease );
		app.myTrxUA.trxUpdateGeneratePin(realTrackedItems, termEmailDefaults, app.myPassport);	
	endif;
	
	//endif;
	completedOK := true;
	return response;
	
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	// Tidy up local transients
	delete pxyTrackedItem;
	delete realTrackedItems;
	delete pxyItems;
	delete originalStops;
	delete additionalStops;
	delete removeStops;
	delete allStops;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;
	
end;
</source>
        <Parameter name="relImportUpdateReq" type="WS_ReleaseImportUpdateRequest"/>
        <ReturnType type="WS_TrackedItemUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateSealChecksTI" id="2af9c814-9bd2-4a25-854a-3ad4c152d428">
        <source>updateSealChecksTI(request : WS_SealCheckItemRequest ) : WS_SealCheckItemResponse webService;
/*
Purpose:		This updates the data entered during seal checks 
Date				Who			Reason
MARCH 2016		CNWAB1		Initial creation
07 Jul 2021 cnwma1 Bug 51460: MTN - Cargo Lander - Missing Seal Checks with Type [View ]
19 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps 
*/

vars
	failedDAC			: CM_DataAccessController;
	response			: WS_SealCheckItemResponse;
	completedOK, 
	load				: Boolean;
	tis					: CM_TISet;
	cargo, 
	pxyTI 				: CM_TrackedItem;
	term 				: CM_Terminal;
	sealCheck 			: WS_SealCheckItem;
	cargotypeid 		: Integer;
	sealType 			: CM_SealType;
	beforeValue, 
	afterValue 			: String;
	pxySealCheckTrx 	: CM_SealCheck;
	realSealCheckTrx 	: CM_SealCheck;
	viewed, 
	sealCheckTypeValue  : Integer;
	updateArray 		: CM_ObjectArray;
	sealCheckDetail 	: CM_SealCheckDetail;
	permissionsToCheck : IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	//epr TFS 5535 16/8/17
	//jlier1 TFS 52389 23/11/2021
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHCargoSeals);
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	create updateArray transient;
	
	term := app.myPassport.myTerminal;
	
	// ### Get the first seal check item to get the cargo and seal check mode - full, strict, view
	sealCheck := request.allSealCheckItems.first();
	if sealCheck = null then
		app.raiseCMException(Invalid_seal_check_type,null,null);
		completedOK := true;
		return response;
	endif;
	
	sealCheckTypeValue := sealCheck.sealCheckType;
	//09 May 2019	NDL	TFS 44596
	if not sealCheckTypeValue.isOneOf(2,3,4) then
		app.raiseCMException(Inval_seal_type_check_value_va,null,null);
		completedOK := true;
		return response;
	endif;
	
	if sealCheck.cmObjectId &lt;&gt; "" then
		//epr TFS 5535 4/8/17 
		cargo :=app.myPassport.getObjectOfTypeFromOid( sealCheck.cmObjectId,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	// ### Get the cargo
	if cargo = null then
		cargotypeid := app.myRoot.getCargoTypeIDFromDescription(sealCheck.cargoTypeDesc);
				
		cargo := term.lookupTrackedItem(sealCheck.cargoId, cargotypeid,TI_STATE_NORMAL,null,false);
		if cargo = null then
			app.raiseCMException2(No_Cargo_Id_Match,sealCheck.cargoId, term.code,null,null);
			completedOK := true;
			return response;	
		endif;
	endif;
		
	if cargo = null then
		completedOK := true;
		return response;
	endif;
	
	if  not cargo.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then   
		completedOK := true;
		return response;
	endif;
		
	// ### If VIEW mode then check that all the seals have been touched
	if sealCheckTypeValue = SEAL_CHECK_VIEW then
		foreach sealCheck in request.allSealCheckItems discreteLock do
			if sealCheck.sealTouched = "" then
				app.raiseCMException2(Pleas_indic_wheth_seal_item_be,sealCheck.cargoId, sealCheck.sealType,null,null);
				completedOK := true;
				return response;
			endif;
		endforeach;
	endif;
		
	// ### If STRICT mode then check that all the seal values are the same as recorded
	if sealCheckTypeValue = SEAL_CHECK_STRICT then
		foreach sealCheck in request.allSealCheckItems discreteLock do
		
			sealType	 := app.myRoot.allSealTypes[sealCheck.sealType];
			beforeValue  := cargo.getSealValue(sealType);
			afterValue 	 := sealCheck.value;
			
			if beforeValue &lt;&gt; afterValue then
				app.raiseCMException2(Value_entered_does_not_match,afterValue, sealType.description,null,null);
				completedOK := true;
				return response;
			endif;
		endforeach;
	
	endif;

	app.cmsBeginLoad(load);
	pxyTI := cargo.pxyCreateUpdateProxy;
	app.cmsEndLoad(load);
	
	if pxyTI = null then
		app.raiseCMException2(No_Cargo_Id_Match,sealCheck.cargoId, term.code,null,null);
		completedOK := true;
		return response;	
	endif;
	
	// ### Save a Seal Detail and create the seal transaction
	// ### the seal detail records whether the seal have been viewed or not.
	
	create pxySealCheckTrx transient;
	
	foreach sealCheck in request.allSealCheckItems discreteLock do
		
		viewed := 0;
		if sealCheckTypeValue = SEAL_CHECK_VIEW then   	  //07.07.2021 cnwma1 #51460
			if sealCheck.sealTouched = "Y"	  then          
				viewed := CM_SealCheckDetail.Seal_Viewed;
			elseif sealCheck.sealTouched = "N" 	then  		
				viewed := CM_SealCheckDetail.Seal_Not_Viewed;
			endif;
		endif;

		sealType 	:= app.myRoot.allSealTypes[sealCheck.sealType];
		beforeValue := cargo.getSealValue(sealType);
		afterValue  := sealCheck.value;

		if sealCheckTypeValue = SEAL_CHECK_FULL
		or sealCheckTypeValue = SEAL_CHECK_STRICT then
			updateArray.add(sealType);
		endif;
	
		create sealCheckDetail transient;
		
		sealCheckDetail.setProxy(	pxySealCheckTrx,	//_sealCheck : CM_SealCheck;
									afterValue,			//_sealAfter : String;
									beforeValue,		//_sealBefore : String;
									sealCheckTypeValue,	//_sealCheckType : Integer;
									sealType.sealType,	//_sealType : String;
									viewed				//_viewed : Integer;
									);
	endforeach;
	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	realSealCheckTrx := self.myWebServiceAgent.updateSealChecksTITransaction(cargo, pxySealCheckTrx, updateArray, app.myPassport);

	if app.myPassport.trxCompletedOK then
		completedOK := true;
		return response;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete pxySealCheckTrx;
	delete tis;
	delete pxyTI;
	delete updateArray;
	delete permissionsToCheck;
	
	app.cmsEndLoad(load);
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_SealCheckItemRequest"/>
        <ReturnType type="WS_SealCheckItemResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateSourceLocation" id="76aad876-7d0b-4be5-9b79-4351dd574e4a">
        <source>updateSourceLocation(request : WS_SourceLocationUpdateRequest) : WS_SourceLocationResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_SourceLocationResponse;
	completedOK		: Boolean;
	
	pxyCodeGroup,
	realCodeGroup	: CM_CodeGroup;
	
	wsCodeGroup,
	wsCodeGroupNew	: WS_CodeGroupSourceLocation;
	
	load			: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmCodeGroupMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsCodeGroup := request.myCodeGroupSourceLocation;
	realCodeGroup := app.myRoot.allCodeGroups[CodeGroup_SourceLocation, wsCodeGroup.name];
	
	if realCodeGroup = null then
		app.raiseCMException2(Does_not_exist_cannot_update, app.getErrorString(Source_location), wsCodeGroup.name, null, null);
		completedOK := true;
		return response;
	endif;
	
	app.cmsBeginLoad(load);
	pxyCodeGroup := realCodeGroup.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	wsCodeGroup.setUpdateProxyCodeGroup(pxyCodeGroup, realCodeGroup);
	
	app.myTrxUA.trxUpdateCodeGroupSrcLocTree(pxyCodeGroup, realCodeGroup, app.myPassport);
	
	if app.myPassport.noErrors() then
		create wsCodeGroupNew transient;
		wsCodeGroupNew.setProxyFromObject(realCodeGroup);
		response.setCodeGroupSourceLocation(wsCodeGroupNew);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete pxyCodeGroup;
	
	app.cmsEndLoad(load);
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_SourceLocationUpdateRequest"/>
        <ReturnType type="WS_SourceLocationResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateVehicleBooking" id="d10d9622-fcd1-44ee-b881-f7b55161a3d6">
        <source>updateVehicleBooking( updbookingReq : WS_VehicleBookingUpdateRequest ) : WS_VehicleBookingUpdResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393
26 May 2021 cnwma1  ChangeRequest 51051: PRP - WebPortal VBS - Driver and Vehicle fields rework
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

vars
	response : WS_VehicleBookingUpdResponse;
	vbTimeslot : CM_VehicleBookingTimeSlot;
	pxyVbTimeslot : CM_VehicleBookingTimeSlot;
	invalidItem : Boolean;
	errorProxy : WS_ErrorMessage;
	completedOK : Boolean;
	carrier : CM_Carrier;
	driver : CM_DriverDetails;
	vehicle : CM_Vehicle;
	remarks : String;
	includesDelivery : Boolean;
	includesPickUp : Boolean;
	bookedTiIds : StringArray;
	deliveryTiIds, pickupTiIds : StringArray;		// TFS 51248
	additionalRemarks : String;
	allBookingRefs : CM_BookingRefSet;
	allBulkReleases : CM_BulkReleaseSet;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	
	if not app.myPassport.myTerminal.isVehicleBookingEnabled then
		app.raiseCMException(Vehicl_schedu_module_requir_li,null,null);
		completedOK := true;
		return response;
	endif;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGteVehSchWeb);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	

	//apparently we have been instructed to ignore warnings.... 
	self.setIgnoreWarnings(true);
	
	//handle invalid object reference.
	on Exception do app.handleDeletedObject(exception, vbTimeslot, invalidItem);
	vbTimeslot := updbookingReq.getRealVehicleBookingTimeslot;

	// Create the required proxy (must be in load state
	beginLoad;
		pxyVbTimeslot := vbTimeslot.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
	endLoad;
	
	if invalidItem then
		app.raiseCMException1(ObjectDeletedByOtherUser,app.getErrorString(Vehicle_schedul_booking_slot),null,null);
		completedOK := true;
		return response;
	endif;
	
	if vbTimeslot.isExpired then
		app.raiseCMException(Vehic_sched_booki_not_maint_af,null,null);
		completedOK := true;
		return response;
	endif;
	
	if vbTimeslot.isUsed then
		app.raiseCMException(Vehic_sched_booki_not_added_th,null,null);
		completedOK := true;
		return response;
	endif;
	
	create allBookingRefs transient;	//28 Oct 2014	NDL	Par 35008
	create allBulkReleases transient;	//28 Oct 2014	NDL	Par 35008
	create bookedTiIds transient;
	create deliveryTiIds transient;				// TFS 51248
	create pickupTiIds transient;				// TFS 51248
	
	carrier := updbookingReq.getMyCarrier;
	if carrier = null then
		driver := null;
		vehicle := null;
		remarks := null;
		includesDelivery := false;
		includesPickUp := false;
		
	else
		driver := updbookingReq.getMyDriver;
		vehicle := updbookingReq.getMyVehicle;
		remarks := updbookingReq.remarks;
		//updbookingReq.getBookedTiIds( bookedTiIds, includesDelivery, includesPickUp, additionalRemarks);					// TFS 51248
		updbookingReq.getBookedTiIds( deliveryTiIds, pickupTiIds, includesDelivery, includesPickUp, additionalRemarks);		// TFS 51248
		if additionalRemarks &lt;&gt; null then
			if remarks = null then
				remarks := additionalRemarks;
			else
				remarks := remarks &amp; " [" &amp; additionalRemarks &amp; "]";
			endif;
		endif;
		
		//28 Oct 2014	NDL	Par 35008
		updbookingReq.getBookingRefs(allBookingRefs);
		if not allBookingRefs.isEmpty then
			includesDelivery := true;
		endif;
		updbookingReq.getBulkReleases(allBulkReleases);
		if not allBulkReleases.isEmpty then
			includesPickUp := true;
		endif;
		
		if not includesDelivery and not includesPickUp then
			app.raiseCMException2( Must_select_least_one_of, app.getErrorString(PickingUp), app.getErrorString(Delivering), null, null );
			completedOK := true;
			return response;
		endif;
		
		if vehicle = null and updbookingReq.vehicle &lt;&gt; null then          //26.05.2021 navma1 #51051
			app.raiseCMException1( Err_Gate_VehicleId,null,null,null);
			completedOK := true;
			return response;
		endif;
		
	endif;
	
	deliveryTiIds.copy(bookedTiIds);			// TFS 51248
	pickupTiIds.copy(bookedTiIds);				// TFS 51248
	
	pxyVbTimeslot.setProxy(	vbTimeslot.bookingTSstart,	//_scheduleTSstart : TimeStamp;
							vbTimeslot.bookingTSend,	//_scheduleTSend : TimeStamp;
							vbTimeslot.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
							carrier,	//_myCarrier : CM_Carrier;
							null,		//_mySubCarrier : CM_Carrier;
							driver,	//_myDriver : CM_DriverDetails;
							vehicle,	//_myVehicle : CM_Vehicle;
							remarks,	//_remarks : String;
							includesDelivery,	//_includesDelivery : Boolean;
							includesPickUp,	//_includesPickUp : Boolean;
							bookedTiIds,	//_bookedTiIds : StringArray;	
							null,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
							vbTimeslot.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
							vbTimeslot.id,	//_id : String;
							allBookingRefs,	//_allBookingRefs : CM_BookingRefSet;
							allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
							null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
							null,	//_preGateInCheck : Boolean;
							null,	//_preGateOutChck : Boolean;
							null,	//_kioskCheck : Boolean;
							null,	//_externalReference : String
							null); 	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
						
	//app.myTrxUA.trxUpdateVehicleBooking(pxyVbTimeslot, app.myPassport);								// TFS 51248
	app.myTrxUA.trxUpdateVehicleBooking(pxyVbTimeslot, deliveryTiIds, pickupTiIds, app.myPassport);		// TFS 51248

	
	completedOK := true;
	return response;
	
	
epilog
	endLoad;				
	// Tidy up local transients
	delete bookedTiIds;
	delete deliveryTiIds;				// TFS 51248
	delete pickupTiIds;					// TFS 51248
	delete pxyVbTimeslot;
	delete allBookingRefs;
	delete allBulkReleases;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;

	cnEndTransaction;
end;
	</source>
        <Parameter name="updbookingReq" type="WS_VehicleBookingUpdateRequest"/>
        <ReturnType type="WS_VehicleBookingUpdResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateVesselLOLODefinition" id="cabc3b6f-6374-4a46-add3-018286dc7fe9">
        <source>updateVesselLOLODefinition(request : WS_UpdateVesselLOLODefnRequest ) : WS_Response  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	wsVessel 	: WS_VesselDefn;
	pxyVessel 		: CM_CellularVesselStructure;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmShipBayDefMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsVessel:=request.vesselDefn;

	//create pxyStructure from ws objects
	pxyVessel:=wsVessel.createProxy();

	if pxyVessel = null then
		app.raiseCMException1(Vessel_not_found,wsVessel.code,null,null);
		completedOK:=true;
		return response;
	endif;
	
	
	app.myTrxUA.trxUpdateVesselStructure(pxyVessel, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	delete pxyVessel;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_UpdateVesselLOLODefnRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateVesselLOLOHoldDefn" id="6fd34c96-f3cc-4a2c-84ab-fcab157e962a">
        <source>updateVesselLOLOHoldDefn(request : WS_UpdateVesselHoldRequest) : WS_Response  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	vesselStructure	: CM_CellularVesselStructure;
	pxyHold,
	realHold 		: CM_VesselHold;
	pxyBay : CM_Bay;

begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmShipBayDefMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	vesselStructure:=app.myRoot.allVesselCellularStructures[request.vesselCode];
	
	if vesselStructure = null then
		//raise exception return
		app.raiseCMException1(Vessel_not_found,request.vesselCode,null,null);
		completedOK:=true;
		return response;
	endif;
	
	pxyHold:=request.holdDefn.createProxy(vesselStructure,request.oldOrdinal);
	
	if pxyHold = null then
//		app.raiseCMException1(REQUIRED_FIELD,"proxy hold null",null,null);
		app.raiseCMException(Input_required_field_proxHold,null,null); // cnwdb2	PAR 35364
		completedOK:=true;
		return response;
	endif;
	
	//pxy Hold can not have a  0 ordinal
	if pxyHold.ordinalHold  = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD,"proxy hold oridnal can not be zero",null,null);
		app.raiseCMException(Input_required_field_prxHldOrd,null,null); // cnwdb2	PAR 35364
		completedOK:=true;
		return response;
	endif;
	
	//app.myCnCntrl.cnWriteLog(CnCntrl.CnLogDiag, "proxy hold ordinal =" &amp; pxyHold.ordinalHold.String, null);
	
	// PAR 33443 the WS bay objects have no references to other bays and the WS slot objects do not have refs to other slots.
	// This is all needed to set back end settings for 40s. 
	self.myWebServiceAgent.updateVesselHoldSlotLinks(pxyHold);
	
	app.myTrxUA.trxUpdateHoldVessel(pxyHold,realHold,app.myPassport);
	
	completedOK := true;
	return response;
epilog
	pxyHold.allBays.purge;
	delete pxyHold;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_UpdateVesselHoldRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateVoyageDocuments" id="0f0ff9a3-5863-40bb-a0e2-5862e498317d">
        <source>updateVoyageDocuments(_request : WS_VoyageDocumentsRequest)  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2018	jlger1	Initial creation tfs 37939

*/

vars
	response : WS_Response;
	completedOK : Boolean;
		wsDocument : WS_Document;
	documentHeader : CM_FileData;
	documentContent : CM_FileDataStorageDetail;
	fileData	: Binary;
	allDocuments : ObjectArray;
	voyage : CM_Voyage; 
begin
		// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;

	voyage:=app.myPassport.getObjectOfTypeFromOid(_request.voyage,CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK:=true;
		return response;
	endif;	
	
	create allDocuments transient;
	foreach wsDocument in _request.allDocuments discreteLock do
		create documentHeader transient;
		documentHeader.setDetails(app.actualTimeServer,wsDocument.description,wsDocument.fileName,wsDocument.heading);
		create documentContent transient;
		fileData	:=	wsDocument.documentBytes.compressToBinary(Binary.Compression_ZLib);
		documentContent.set(wsDocument.fileName,fileData,null,documentHeader);
		allDocuments.add(documentHeader);
	endforeach;
	
	
	app.myPassport.setWarningsIgnored(_request.warningsAcknowledged);
	app.myTrxUA.trxUpdateVoyageDocuments(voyage,allDocuments,app.myPassport);
	
		// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	if allDocuments &lt;&gt; null then
		allDocuments.purge;
		delete allDocuments;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_VoyageDocumentsRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateVoyageManualETMAL" id="bfc3066a-44d3-4fe1-8bf8-9d104a509140">
        <source>updateVoyageManualETMAL(_request : WS_VoyageManualETMALRequest)  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2018	jlger1	Initial creation

*/

vars
	response : WS_Response;
	voyage : CM_Voyage;
	completedOK : Boolean;
	nextStatus : CM_VoyageStatus;
begin

// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;

	voyage:=app.myPassport.getObjectOfTypeFromOid(_request.voyage,CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	
	if voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK:=true;
		return response;
	endif;	
	
	nextStatus:=voyage.getNextUpdateStatus(voyage.status);
	if nextStatus = null or not nextStatus.userCanSet(voyage.myTerminal) then
		app.raiseCMException2(Cannot_Set_Voyage_Status, voyage.myTerminal.code, nextStatus.description, "status", null);
		completedOK:=true;
		return response;
	endif;
	
	app.myTrxUA.trxUpdateVoyageManualETMAL(voyage,_request.reason,_request.lengthOfStay.Decimal,app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
		
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_VoyageManualETMALRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateVoyageRequest" id="dbe47929-dbae-4870-860b-9fd7f954e276">
        <source>updateVoyageRequest(request : WS_CreateVoyageRequest)  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 September 2021	jlier1	Initial creation 51963
18 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
26 March 2024		navpw1	TFS: 62849 (62927) - Reverted Code by adding beginLoad/endLoad

*/

vars
	response : WS_Response;
	completedOK : Boolean;
	voyageStatus : CM_VoyageStatus;
	voyage : CM_Voyage;
	pxyDtl,
	woDtl : CM_WodVoyageRequest;
	allDocuments		: ObjectArray;
	pxyWorkOrder : CM_WorkOrder;
	voyageProcess : CM_VoyageProcess;
	
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmVoyageDefEdit);		// Replace with appropriate permission
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.myTerminal = null then
		completedOK:=true;
		return response;
	endif;
	
	voyageProcess := app.myPassport.myTerminal.getDefaultVoyageProcess();

	voyage:=app.myPassport.getObjectOfTypeFromOid(request.cmObjectId,CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	if voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK:=true;
		return response;
	endif;	
	
	if voyageProcess = null then	// TFS 54298
		//raise exception
		app.raiseCMException(Voyage_process_selected,null,null);	// TFS 54298
		completedOK := true;		// TFS 54298
		return response;			// TFS 54298
	endif;
	
	if voyageProcess.isEUPDefaultProcess then																		// TFS 54298
		if voyage.status &lt;&gt; Voyage_Status_EUP_VoyReq and voyage.status &lt;&gt; Voyage_Status_EUP_VoyReqRej then			// TFS 54298
			app.raiseCMException2(Voyage_incorr_status_this_acti,voyage.code,voyage.statusDescription,null ,null);	// TFS 54298
			completedOK:=true;		// TFS 54298
			return response;		// TFS 54298
		endif;
	elseif voyage.status &lt;&gt; Voyage_Status_VoyRequested and voyage.status &lt;&gt; Voyage_Status_VoyReqRejected then
		app.raiseCMException2(Voyage_incorr_status_this_acti,voyage.code,voyage.statusDescription,null ,null);
		completedOK:=true;
		return response;
	endif;
	
	if voyageProcess.isEUPDefaultProcess then										// TFS 54298
		voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_EUP_VoyReq];		// TFS 54298
	else
		voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_VoyRequested];
	endif;
	
	if not voyageStatus.userCanSet(app.myPassport.myTerminal) then
		app.raiseCMException2(Cannot_Set_Voyage_Status, app.myPassport.myTerminal.code, voyageStatus.description, "status", null);
		completedOK:=true;
		return response;
	endif;
	
	woDtl := voyage.getWorkOrderForVoyageRequest();
	if woDtl = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK := true;
		return response;
	endif;
	beginLoad;
		pxyWorkOrder:=woDtl.getMyParent.pxyCreateUpdateProxy.CM_WorkOrder;
		pxyDtl:=woDtl.pxyGetProxyObject.CM_WodVoyageRequest;
	endLoad;
	//should already be at this status - but if the WO was not approved then updating should go back to user entry
	pxyWorkOrder.setTaskStatus(WO_STATUS_USERENTRY);
	request.updatePxyVoyageRequest(pxyDtl);
	
	create allDocuments transient;
	beginLoad;
	request.allDocuments.setProxyDocuments(allDocuments);
	endLoad;
	app.myPassport.setWarningsIgnored( true);
	app.myPassport.setWarningsAcknowledged( true);
	app.myTrxUA.trxUpdateVoyageRequest(pxyWorkOrder,allDocuments,app.myPassport);

		// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	endLoad;
	delete pxyWorkOrder;
	if allDocuments &lt;&gt; null then
		allDocuments.purge;
		delete allDocuments;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_CreateVoyageRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateVoyageStatus" id="c824824b-d453-4ef4-b596-08c67d856e4c">
        <source>updateVoyageStatus(_request : WS_VoyageUpdateStatusRequest)  : WS_Response webService; 
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2018	jlger1	Initial creation tfs 37931

*/

vars
	voyage : CM_Voyage;
	response : WS_Response;
	completedOK : Boolean;
	voyageStatus,
	newVoyageStatus : CM_VoyageStatus;
	nextStatuses : CM_VoyageStatusByPriority;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;

	voyage:=app.myPassport.getObjectOfTypeFromOid(_request.voyage,CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	
	if voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK:=true;
		return response;
	endif;	
	
	
	voyageStatus:= voyage.getVoyageStatusObject;
	if not voyageStatus.userCanSet(voyage.myTerminal) then
		app.raiseCMException2(Cannot_Set_Voyage_Status, voyage.myTerminal.code, voyageStatus.description, "status", null);
		completedOK:=true;
		return response;
	endif;	
		
	newVoyageStatus:=app.myRoot.allVoyageStatuses[_request.status.Integer];
	if newVoyageStatus = null then
		app.raiseCMException1(Not_valid_voyage_status,_request.status,null,null);
		completedOK:=true;
		return response;
	endif;
	
	if not newVoyageStatus.userCanSet(voyage.myTerminal) then
		app.raiseCMException2(Cannot_Set_Voyage_Status, voyage.myTerminal.code, newVoyageStatus.description, "status", null);
		completedOK:=true;
		return response;
	endif;
	
	app.myTrxUA.trxUpdateVoyageVoyageStatus(voyage, _request.status.Integer,false,app.myPassport);
		
		// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_VoyageUpdateStatusRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateWagonPosition" id="63111515-2272-48c5-bfe7-33d1ee17808c">
        <updating/>
        <source>updateWagonPosition(request : WS_WagonPosUpdRequest) : WS_WagonPosUpdResponse updating, webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Apr 2017	cnwsc8	Initial creation
05 Jun 2019 cnwma1	Bug 44905: JMT - Rail Lander Confirm bugs
18 Mar 2020 cnwma1  Bug 48925: Mobile App - POL - Rail Confirm - Change in Walk direction does not update the position
*/

vars
	completedOK 	    : Boolean;
	response  		    : WS_WagonPosUpdResponse;
	terminal 		    : CM_Terminal;
	railLine		    : CM_RailLine;
	wagon			    : CM_Wagon;
	wagonProxy		    : WS_Wagon;
	wagonMoveController : CMIF_WagonMoveController;
	wagonOrginalPos     : Integer;
	wagonAtSamePos      : CM_Wagon;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	
	//epr TFS 5535 4/8/17
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		// Replace with appropriate permission
		
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if request.rakeUid = "" then
		app.raiseCMException(Rake_not_found,null,null);		
		completedOK := true;
		return response;
	endif;

	if request.wagonUid = "" then
		app.raiseCMException(Wagon_null,null,null);	
		completedOK := true;
		return response;
	endif;

	if request.rakePosition &lt; 1 then
		app.raiseCMException(Rake_posi_not_found,null,null);			
		completedOK := true;
		return response;
	endif;

	terminal := app.myPassport.myTerminal;
	//epr TFS 5535 4/8/17 
	railLine := app.myPassport.getObjectOfTypeFromOid(request.rakeUid,CM_RailLine).CM_RailLine;
	
	if railLine = null then
		app.raiseCMException(Rake_posi_not_found,null,null);				
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	wagon :=  app.myPassport.getObjectOfTypeFromOid(request.wagonUid,CM_Wagon).CM_Wagon;
	if wagon = null then
		app.raiseCMException(Wagon_null,null,null);		
		completedOK := true;
		return response;
	endif;
	wagonOrginalPos := wagon.getWagonPosition().asIntegerJMT();         // 05.06.2019 cnwma1 #44905
	
	if request.rakePosition &lt;= railLine.allWagons.size then             // 18.03.2020 cnwma1 #48925
		wagonAtSamePos := railLine.allWagons[request.rakePosition];     // 05.06.2019 cnwma1 #44905
	endif;
	
	create wagonMoveController transient;
	wagonMoveController.myTargetRailLine := railLine;
	wagonMoveController.isInwardTarget   := request.inwards;
	wagonMoveController.targetPosition   := request.rakePosition;
	wagonMoveController.allWagons.add(wagon);
	app.myTrxUA.trxMoveWagons(wagonMoveController, app.myPassport);

	if wagon &lt;&gt; null then
		create wagonProxy transient;
		wagonProxy.setProxyFromObject(wagon);
		wagonProxy.setOidDetails(wagon);
		response.wagon := wagonProxy;	
	endif;
	
	//SWAP if there are a wagon at the current position 
	// 05.06.2019 cnwma1 #44905
	if app.myPassport.noErrors then
		if wagonAtSamePos &lt;&gt; null then
			
			if wagonMoveController &lt;&gt; null then
				delete wagonMoveController;
			endif;
			
			create wagonMoveController transient;
			wagonMoveController.myTargetRailLine := railLine;
			wagonMoveController.isInwardTarget   := request.inwards;
			wagonMoveController.targetPosition   := wagonOrginalPos;
			wagonMoveController.allWagons.add(wagonAtSamePos);
			app.myTrxUA.trxMoveWagons(wagonMoveController, app.myPassport);
		endif;
	endif;
	
	completedOK:=true;
	return response;
epilog
	
	if wagonMoveController &lt;&gt; null then
		delete wagonMoveController;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_WagonPosUpdRequest"/>
        <ReturnType type="WS_WagonPosUpdResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateWorkOrderDetail" id="76239ecf-ae18-403a-ad8c-bd7b35fa9d07">
        <source>updateWorkOrderDetail(request : WS_WorkOrderDetailUpdateReq )  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/05/2018	jlger1	Initial creation
11/12/2018	jlgdap1	TFS 42456 PEL1 More details in security role
28 Aug 2023 navhl20 Bug 60008: MTN - 1223 exception when actioning Pack Work Order
26 Mar 2024	navpw1	TFS: 62849 (62927) - Reverted Code by adding beginLoad/endLoad
26 Mar 2024	navpw1	TFS: 62849 (62927) - Added new trx call for updating files

*/

vars
	response : WS_Response;
	completedOK : Boolean;
	pxyWorkOrder : CM_WorkOrder;
	allDocuments		: ObjectArray;
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	//	app.myProxyManager.clearAllProxies;
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;	
	
	if not request.myWorkOrderDetail.isVoyageWorkOrder and request.myWorkOrderDetail.requiredByDT = null and app.myPassport.myTerminal.isUseYardJobsForCargoWo = true then			//28.8.2023 navhl20 #60008
		app.raiseCMException(Work_order_yard_req_date, null, null);
	endif;
	
	if request.myWorkOrderDetail.isKindOf(WS_WorkOrderPermitRequest) then
		create allDocuments transient;
		beginLoad;
		request.myWorkOrderDetail.WS_WorkOrderPermitRequest.allDocuments.setProxyDocuments(allDocuments);
		endLoad;
	endif;
	
	pxyWorkOrder := request.createProxyWorkOrder(false);
	
	if pxyWorkOrder = null then
		completedOK:=true;
		return response;
	endif;
	
	if pxyWorkOrder.isVoyageWorkOrder then
		if not app.checkCurrentUserHasAccess(PmWebVoyWOCargoMaint) then			// TFS 42456
			app.checkCurrentUserHasAccess(PmWebWorkOrdersVoyMaint);		// Replace with appropriate permission
		endif;																	// TFS 42456
	else
		app.checkCurrentUserHasAccess(PmWebWorkOrderMaint);		// Replace with appropriate permission
	endif;
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored( true);
	app.myPassport.setWarningsAcknowledged( true);
	app.myTrxUA.trxUpdateWorkOrder(pxyWorkOrder,true,app.myPassport);
	
	if app.myPassport.noErrors then
		app.myTrxUA.trxUpdateFiles(pxyWorkOrder.pxyGetRealObject(), allDocuments, app.myPassport);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	delete pxyWorkOrder;	

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	if allDocuments &lt;&gt; null then
		allDocuments.purge;
		delete allDocuments;
	endif;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_WorkOrderDetailUpdateReq"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateWorkOrderStatus" id="c6420949-1676-4e38-a700-963e21d360f8">
        <source>updateWorkOrderStatus(_request : WS_WorkOrderStatusUpdate) : WS_Response webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/09/2018	jlgdap1		Initial creation TFS 40202 PEL1 Estimation SAP Integration
// 26/03/2024	navpw1		TFS: 62849 (62927) - Reverted code back
//
vars
	response : WS_Response;
	workOrderDtl : CM_WorkOrderDtl;
	workOrder, pxyWorkOrder : CM_WorkOrder;
	completedOK : Boolean;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;

	workOrderDtl := app.myPassport.getObjectOfTypeFromOid(_request.workOrder, CM_WorkOrderDtl).CM_WorkOrderDtl;
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	if workOrderDtl = null then
		app.raiseCMException(Please_select_work_order, null, null);
		completedOK := true;
		return response;
	endif;
	
	workOrder := workOrderDtl.getMyParent();
	
	if workOrder.isVoyageWorkOrder then
		app.checkCurrentUserHasAccess(PmWebWorkOrdersVoyMaint);		// Replace with appropriate permission
	else
		app.checkCurrentUserHasAccess(PmWebWorkOrderMaint);		// Replace with appropriate permission
	endif;
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if _request.status = null then
		app.raiseCMException2(Not_updat_work_order_with_stat, workOrder.id, "null", null, null);
		completedOK := true;
		return response;
	endif;
	
	if _request.status.Integer &lt;&gt; WO_STATUS_APPROVED and _request.status.Integer &lt;&gt; WO_STATUS_NOTAPPROVED then
		app.raiseCMException2(Not_updat_work_order_with_stat, workOrder.id, _request.status, null, null);
		completedOK := true;
		return response;
	endif;
	
	pxyWorkOrder := app.createUpdateProxy(workOrder).CM_WorkOrder;
	if pxyWorkOrder = null then
		app.raiseCMException(Proxy_Object_Null_For_Update, null, null);
		completedOK := true;
		return response;
	endif;
	pxyWorkOrder.setTaskStatus(_request.status.Integer);
	
	app.myTrxUA.trxUpdateWorkOrder(pxyWorkOrder, false, app.myPassport);
		
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_WorkOrderStatusUpdate"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
</JadeWebServiceProviderClass>
