    <JadeMethod name="utlUpdateExtWebService" id="5d599d75-5957-4517-9198-c976650b962e">
        <source>utlUpdateExtWebService(_proxyExtWebService : CM_ExternalWebServiceDef input; _passport : CM_Passport input);
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
vars
	realExtWebService : CM_ExternalWebServiceDef;
	expectedEdition	: Integer;
	realMapping : CM_ExtWebServiceEventMapping; // TFS 40360
begin
	self.initialiseActivity();
	_proxyExtWebService.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	_proxyExtWebService.pxyGetRealObjectAndEdition(realExtWebService, expectedEdition);
	if realExtWebService = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ExternalWebServiceDef.name, null, null);
		return;
	endif;
	app.myValUA.valExtWebService(realExtWebService, _proxyExtWebService);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	exclusiveLock(realExtWebService);
	if _passport.noErrors and 
	   realExtWebService.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'External Web Service Def', null, null);
		return;
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realExtWebService, true);
	endif;
	if _passport.noErrors then
		realExtWebService.setForUpdate(_proxyExtWebService);
		if _proxyExtWebService.myEventMapping &lt;&gt; null then // TFS 40360 - if an Event Type's been set
			realMapping := realExtWebService.myEventMapping; // TFS 40360 - create new mapping or delete &amp; replace existing one
			if realMapping = null or _proxyExtWebService.myEventMapping.myEventType &lt;&gt; realMapping.myEventType then // TFS 40360
				delete realMapping; // TFS 40360 - does nothing if mapping's null
				create realMapping persistent; // TFS 40360
				realMapping.setEventType(_proxyExtWebService.myEventMapping.myEventType); // TFS 40360
				realExtWebService.setMyEventMapping(realMapping); // TFS 40360
			endif; // TFS 40360
		endif; // TFS 40360		
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realExtWebService, false);
	endif;
epilog

end;</source>
        <Parameter name="_proxyExtWebService" type="CM_ExternalWebServiceDef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateExtWebServiceAdvSet" id="a88f9b9f-95a7-4714-8c2d-765180baf74a">
        <updating/>
        <source>utlUpdateExtWebServiceAdvSet(_extWebServiceObj: CM_ExternalWebServiceDef input; _eventName: String; _ccFunction: Integer; _parameter: CM_Object; _passportObj: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2018	jlgmp6	Initial creation	TFS42015

*/

vars
	ccem: CM_CargoChainEventMapping;
	allCcem: CM_CargoChainEventMappingSet;
	found: Boolean;
	parameters: JadeDynamicObject;
begin
	allCcem := _extWebServiceObj.CM_CargoChainServiceDef.allCargoChainEventMappings;
	foreach ccem in allCcem do
		if ccem.eventName = _eventName then
			found := true;
			break;
		endif;
	endforeach;

	exclusiveLock(_extWebServiceObj);

	if found then
		ccem.setEventName(_eventName);
		ccem.setCargoChainFunction(_ccFunction);
		if _parameter.isKindOf(CM_InvoiceLineDesc) then
			if ccem.myParameters &lt;&gt; null then
				ccem.myParameters.clear();
			endif;
			ccem.myParameters.addProperty("invoiceLineDesc", CM_InvoiceLineDesc);
			ccem.myParameters.setPropertyValue("invoiceLineDesc", _parameter);
		endif;
	else
		create ccem persistent;
		ccem.setEventName(_eventName);
		ccem.setCargoChainFunction(_ccFunction);
		create parameters persistent;
		if _parameter.isKindOf(CM_InvoiceLineDesc) then
			parameters.setPropertyValue("name", CM_InvoiceLineDesc.name);
			parameters.addProperty("invoiceLineDesc", CM_InvoiceLineDesc);
			parameters.setPropertyValueByIndex(1, _parameter.CM_InvoiceLineDesc);
		endif;
		ccem.setParameters(parameters);
		allCcem.add(ccem);
	endif;
epilog

end;</source>
        <Parameter name="_extWebServiceObj" type="CM_ExternalWebServiceDef" usage="input"/>
        <Parameter name="_eventName" type="String"/>
        <Parameter name="_ccFunction" type="Integer"/>
        <Parameter name="_parameter" type="CM_Object"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
