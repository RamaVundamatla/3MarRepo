    <JadeMethod name="doShowTranshipExportTis" id="491b970d-4fae-4acf-b02e-ca3da3c135b6">
        <source>doShowTranshipExportTis(_tiArray :ObjectArray);
// ---------------------------------------------------------------------------
// Created:     18 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	tiFound : Boolean;
	 tiExports : CM_TIArray;
	 masterTI	: CM_TrackedItem;
	 ti		: Object;
begin
	tiFound:= false;
	if _tiArray.size &gt; 0 then
		
		create tiExports transient;
		tiExports.clear;
		
		foreach ti in _tiArray.ObjectArray do
	
			//if ti.CM_TrackedItem.isTranshipItem and ti.CM_TrackedItem.myTranshipExport &lt;&gt; null then 	// PAR #23645 CCMS 1116
			//	tiExports.add(ti.CM_TrackedItem.myTranshipExport);										// PAR #23645 CCMS 1116
			if ti.CM_TrackedItem.isTranshipItem and ti.CM_TrackedItem.myExportVoyage &lt;&gt; null then 		// PAR #23645 CCMS 1116
				tiExports.add(ti.CM_TrackedItem);														// PAR #23645 CCMS 1116
				tiFound :=true;
			endif;
		endforeach;
		if tiFound then
			masterTI := tiExports.first;
			self.myAssistant.myTerminal := masterTI.CM_TrackedItem.myTerminal;
			self.myAssistant.showCargoEnquiryForTIs(masterTI, tiExports, self.myMasterMenuAction, false);	
		endif;
	endif;
epilog
	delete tiExports;	
end;</source>
        <Parameter name="_tiArray" type="ObjectArray"/>
    </JadeMethod>
