    <JadeMethod name="doReorderLayerFrames" id="277f00a1-011a-421e-86c7-ade1e2b375fa">
        <source>doReorderLayerFrames();
/*
Purpose:			
Date		Who		Reason
23 May 2011	cnwab1	Initial creation
*/

vars
	newOrder : ObjectArray;
	pxyLayer : CM_DeckLayerLayout;
	frame : Frame;
begin
	if self.myCurrentProxyDeck = null then
		return;
	endif;
	
	create newOrder transient;
	foreach pxyLayer in self.myCurrentProxyDeck.myDeckLayout.allDeckLayerLayouts discreteLock do
		frame := self.getFrameForLayer(pxyLayer);
		newOrder.add(frame);
	endforeach;
	
	self.allBackgroundFrames.clear;
	newOrder.copy(self.allBackgroundFrames);
	
epilog
	delete newOrder;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="0bd282f5-8517-44a9-b063-0f6a56f45b1d">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     04 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	
	self.fldDefinition.top := self.frmToolbar.top + self.frmToolbar.height;
	self.fldDefinition.height := self.height - self.fldDefinition.top - 37;
	
	self.frmScrollable.top := self.frmROROTB.top + self.frmROROTB.height;
	self.frmScrollable.height := self.fldDefinition.clientHeight - self.frmROROTB.clientHeight - 20;
	
	
	self.frmScrollable.repositionAfterResize();
	self.frmScrollable.resizeDrawingFrame(self.rulerHPixels,self.rulerVPixels);
	self.repositionAllBackFrames();

	
	// PAR 29373 - noticesd in vessel definition these guys getting under the drawing frame
	self.frmScrollable.myHScroll.zOrder(1);
	self.frmScrollable.myVScroll.zOrder(1);
	self.frmScrollable.myTopLeftFillerFrame.zOrder(1);
	//epr par 33409 8/7/14
	self.frameLabelLineV.height:=self.frmScrollable.height;
	self.frameLabelLineH.width:=self.frmScrollable.width;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveProxy" id="55bebd0f-1059-46ca-89c8-a6f9fc744fa3">
        <source>doSaveProxy() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	code : String;
	description : String;
	remarks : String;
	maxClearHeight,
	totalArea : Decimal[12,2];
	totalVolume : Decimal[12,2];
	totalTEU : Integer;
	totalLM,
	maxLoadStack20,
	maxLoadStack40,
	maxLoadAxel,
	maxLoadM2   : Decimal[12,2];
	numTier : Integer;
	heightFromBL : Decimal[12,2];
	x1, y1, x2, y2   :Integer;
	scale	: Decimal[12,2];
	deckImage	: Binary;
	imageHeight	: Integer;
	roroPrintForm : SHP_ROROPrint;
begin
	code:= self.txtCode.text;
	description:=self.txtDescription.text;
	remarks:=self.txtRemarks.text;
	maxClearHeight:=self.txtClearHeight.text.asDecimalJMT;
	totalArea:=self.txtTotalArea.text.asDecimalJMT;
	totalVolume:=self.txtTotalVol.text.asDecimalJMT;
	totalTEU:=self.txtTotalCont.text.asIntegerJMT; // PAR 27595
	totalLM:=self.txtLinearM.text.asDecimalJMT;
	maxLoadStack20:=self.txtMax20.text.asDecimalJMT;
	maxLoadStack40:=self.txtMax40.text.asDecimalJMT;
	maxLoadAxel:=self.txtMaxAxel.text.asDecimalJMT;
	maxLoadM2:=self.txtMaxLoadM2.text.asDecimalJMT;
	numTier:=self.txtMaxTier.text.asIntegerJMT;
	heightFromBL :=self.txtHeightBL.text.asDecimalJMT;
	

	self.myCurrentProxyDeck.setProxy(	code ,
										description,
										remarks,
										maxClearHeight,
										totalArea,
										totalVolume,
										totalTEU,
										totalLM,
										maxLoadStack20,
										maxLoadStack40,
										maxLoadAxel,
										maxLoadM2 ,
										numTier ,
										heightFromBL );
										
										
		if self.myCurrentProxyDeck.myDeckLayout &lt;&gt; null then
			x2:=0;
			y2:=0;
			x1 := 9999999;
			y1 := 9999999;
			myCurrentProxyDeck.myDeckLayout.getExtremePoints(x1, y1, x2, y2 );
			//scaled to the height of the pic
			scale:=(70)/(y2-y1);
			create roroPrintForm transient;
			roroPrintForm.frmDeckPrint.width:=3000;
			roroPrintForm.chkPrintLabels.value:=false;
			deckImage:=roroPrintForm.getRORODeckImage(myCurrentProxyDeck,scale,imageHeight);
			self.myCurrentProxyDeck.setDeckImage(deckImage);
		endif;
epilog
	delete roroPrintForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveTrx" id="724dffdf-e391-408e-9342-96b2348bf4b6">
        <source>doSaveTrx(realDeck : CM_Deck output) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

