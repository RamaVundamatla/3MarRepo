    <JadeMethod name="getMyRTGBay" id="3503a965-9655-4c13-9535-fc22a4b11e10">
        <source>getMyRTGBay() : CM_RTGBay;
// ---------------------------------------------------------------------------
// Created:		07 March 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// 01/11/2023	navmd1		TFS 61063 - Unit Test - Handle old data a bit better (even though this isn't really used any more)
// ---------------------------------------------------------------------------

vars	
	iter : Iterator;
	gridLC : CM_GridController;
begin
	if self.myGridColumn = null then	// This is always true!
		return null;
	endif;
	
	iter := self.myGridColumn.allControllersByRow.createIterator();
	iter.startAtObject(self);
	
	while iter.next(gridLC) do
		if gridLC.isRTGController() then
			return gridLC.CM_RTGController.myRTGBay;
		endif;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_RTGBay"/>
    </JadeMethod>
