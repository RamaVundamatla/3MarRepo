    <JadeMethod name="delete" id="c590e67f-753f-4921-b1ea-6a106aa3828d">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2017	jlger1	Initial creation 7521

*/

