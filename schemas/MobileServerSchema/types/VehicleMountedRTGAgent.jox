    </JadeMethod>
    <JadeMethod name="userNotification" id="abbfa30f-1e26-475f-abbd-85dfb1273980">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 November 2006	cnwer1	Initial creation - PAR#xxxx

*/

vars
	infoStr : String;
	theEvent	: Integer;
	rfidTag		: CM_RFIDTag;
	telegram    : CM_RTGTelegram;
	info		: DTO_VehicleMountedInfo;
begin

	
	if self.myTerminal.getEventFromTerminalEvent(eventType) = Event_RFIDTagRead then
		if userInfo.isKindOf(CM_RFIDTag) then
			rfidTag:=userInfo.CM_RFIDTag;
			if rtgState &lt;&gt; SETTINGDOWN then		
				self.doOfferTasksOfVM(rfidTag);	
			endif;
		endif;
	elseif eventType = EVENT_TWISTLOCK_RESPONSE then
		telegram:=userInfo.CM_RTGTelegram;
		self.writeLog(method.name &amp; " received telegram");
		if telegram &lt;&gt; null  then
			self.processTelegram(telegram);	
		endif;

		self.doStartTwistLockRead();
	elseif eventType = Event_RFIDInfo then
		create info transient;
		info.event := eventType + Event_Factor;
	//	self.writeLog(method.name &amp; " received rfid info " &amp; userInfo.String);
		info.eventMessage := userInfo.String;
		self.causeEvent(self.Event_Server_Note, true, info);
	else
	
		inheritMethod(eventType, theObject, eventTag, userInfo);
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
