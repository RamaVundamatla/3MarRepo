    <JadeMethod name="setBaseDetails" id="ef1a0a42-a8a7-4883-8c16-bd78792ff2fd">
        <updating/>
        <source>setBaseDetails( _cash : CM_Cash; cmifSumm : CMIF_CashTrxSummary ) updating, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.myCM_CashObject := _cash;
	self.cashValue := _cash.getAmountForBalanceTotal(null);
	self.dateTime := _cash.dateTime;
	self.myDebtorTerminal := _cash.getDebtorTerminal;
	self.myCMIF_CashTrxSummary := cmifSumm;

epilog

end;</source>
        <Parameter name="_cash" type="CM_Cash"/>
        <Parameter name="cmifSumm" type="CMIF_CashTrxSummary"/>
    </JadeMethod>
