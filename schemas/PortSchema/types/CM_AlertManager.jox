<Class name="CM_AlertManager" id="bb3a9a21-a2c1-4c34-a04a-42554886cfde">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>There is one of these per process.
It is charged with managing the commit of alerts
to the database.</text>
    <DbClassMap file="planning"/>
