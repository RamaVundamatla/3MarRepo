begin
	if _treatment &lt;&gt; null then
		_table.setValueByControlName(_treatmentCmb.name, _treatment.code);
	else
		_table.setValueByControlName(_treatmentCmb.name, null);
	endif;
	
	if _grade &lt;&gt; null then
		tmpCodeGroup := _grade.allLogTreatments;
	endif;

	self.comboBoxAddCode(_treatmentCmb, tmpCodeGroup, _treatment, true);

end;</source>
