    <JadeMethod name="getEndTS" id="1566167b-9d54-4334-aab7-59ddb5a19299">
        <source>getEndTS():TimeStamp ;
// ---------------------------------------------------------------------------
// Created:     16 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ts		:TimeStamp;
	time	:Time;
begin
	ts := null;
	ts.setDate (self.date);
	time.setTime (23, 59, 59, 999);
	ts.setTime (time);
	
	return ts;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
