    <JadeMethod name="translateForm" id="a08df8a5-50c9-41d5-8d0a-ef6b02b221cf">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 December 2024 11:22:00.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010884, locale);
	btnAdd.translateCaption(Xlat_0010885, locale);
	btnAddImage.translateCaption(Xlat_0027011, locale);
	btnRemove.translateCaption(Xlat_0010886, locale);
	btnUpdate.translateCaption(Xlat_0010887, locale);
	chkRepaired.translateCaption(Xlat_0013422, locale);
	lblDamage.translateCaption(Xlat_0010889, locale);
	lblNewDamage.translateCaption(Xlat_0011879, locale);
	lblPosition.translateCaption(Xlat_0010890, locale);
	lblQuantity.translateCaption(Xlat_0010891, locale);
	lblRemarks.translateCaption(Xlat_0010892, locale);
	lblSeverity.translateCaption(Xlat_0010893, locale);
	mnuTblInspectObject.translateCaption(Xlat_0023575, locale);
	mnuTblViewContext.translateCaption(Xlat_0023576, locale);
	optNo.translateCaption(Xlat_0010894, locale);
	optYes.translateCaption(Xlat_0010895, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateItem" id="c5c3bd76-7283-4a8f-931c-dfd88150f8cd">
        <source>updateItem();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		06 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 06/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 30/09/2022	navkc1		ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
// 04/04/2023	navlw1		Bug #57383: SNO -- Incorrect error 95674 when attempting to create a damage in basic mode
//----------------------------------------------------------------------
vars
	damageInstance : CM_DamageInstance;
	damagePosition 	: CM_DamagePosition;
	damageCode     	: CM_DamageDefinitionCode;
	damageSeverity : CM_DamageSeverity;
	remarks			: String;
	isNewDamage,
	isRepaired		: Boolean;
	quantity,
	idx, 
	severity, status 	   	: Integer; //Change this when the CM_DamageSeverity class is created.  It will be CM_DamageSeverity object.
	damageDT : TimeStamp;
	
begin
	if self.mySelectedItem = null then
		app.msgBox('Please Select a Damage Entry', 'Select Item', 0);
		return;
	endif;
	
	damageInstance 	:= self.mySelectedItem;
	damagePosition 	:= self.cmbPosition.listObject.CM_DamagePosition;
	damageCode 		:= self.cmbDamage.listObject.CM_DamageDefinitionCode;
	remarks			:= self.txtRemarks.text;
	quantity 		:= self.txtQuantity.text.Integer;
	isNewDamage		:= self.optYes.value;
	//severity 		:= self.cmbSeverity.text.Integer;					// navkc1	30/09/2022	#54463
	damageSeverity	:= self.cmbSeverity.listObject.CM_DamageSeverity; 	// navkc1	30/09/2022	#54463 - fix Severity not updated correctly
	isRepaired 		:= self.chkRepaired.value;
	status := DamageStatusDamaged; // ### TFS 54887 21SEP2022 NAVAB1
	if isRepaired then // ### TFS 54887 21SEP2022 NAVAB1
		status := DamageStatusRepaired; // ### TFS 54887 21SEP2022 NAVAB1
	endif;
	
	// navkc1	30/09/2022	#54463 - To handle a scenario when the user is special and able to access both New and Old UI
	if damageInstance.damageDateTime &lt;&gt; null then
		// If we have the damage date time set in New UI, use that
		damageDT := damageInstance.damageDateTime;
	else
		// Otherwise, just set the current date time.
		damageDT := app.actualTimeServer(); // navlw1 04/04/2023 tfs 57383
	endif;
	
	//create damageSeverity transient;									// navkc1	30/09/2022	#54463
	
	damageInstance.setProxy(self.myProxyMasterItem.CM_TrackedItem, 
							null, 
							damageCode, 
							damagePosition, 
							remarks, 
							isNewDamage, 
							quantity, 
							damageSeverity, // ### TFS 54887 21SEP2022 NAVAB1
							null, // ### TFS 54887 21SEP2022 NAVAB1
							null, // ### TFS 54887 21SEP2022 NAVAB1
							null, // ### TFS 54887 21SEP2022 NAVAB1
							null, // ### TFS 54887 21SEP2022 NAVAB1
							null, // ### TFS 54887 21SEP2022 NAVAB1
							0, // ### TFS 54887 21SEP2022 NAVAB1
							//null, // ### TFS 54887 21SEP2022 NAVAB1
							damageDT, // navkc1	30/09/2022	#54463 - Use current timestamp for normal damage code form.
							 // ### TFS 54887 21SEP2022 NAVAB1 isRepaired,
							 status, // ### TFS 54887 21SEP2022 NAVAB1
							null, // ### TFS 54887 21SEP2022 NAVAB1
							null	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
							);
	
	//Update the entry in the data table.
	self.tblDamage.updateItemObject(damageInstance, self.colorRow1, self.colorRow2, app.myPassport);
epilog
	
end;</source>
    </JadeMethod>
</GUIClass>
