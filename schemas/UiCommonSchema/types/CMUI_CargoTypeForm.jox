/* ---------------------------------------------------------------------------
Created:	27 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

		//self.mnuEditAttrtHdr.userObject := table;
	return self.doShowContextMenuTblAttributes(self.mnuEditAttrtHdr, table, conwin, mouse, x, y);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
