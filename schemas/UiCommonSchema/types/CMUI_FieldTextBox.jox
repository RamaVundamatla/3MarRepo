    <JadeMethod name="setMaxLength" id="b1370acb-bdbb-442e-956b-4c77985bab5d">
        <updating/>
        <source>setMaxLength(_maxLength : Integer) updating;

// Created by cnwdvb1 on 27 October 2006

vars
begin
	self.myTextBox.maxLength := _maxLength;
	if _maxLength = null or 
		(_maxLength &lt;&gt; null and getTextExtent(self.TEXTEXTENT[1:_maxLength]) &gt; self.myTextBox.width) then
		self.myTextBox.scrollHorizontal := true;
	endif;
end;</source>
        <Parameter name="_maxLength" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTabOrder" id="94aba05d-da32-4cde-808f-3ea24c472bb1">
        <source>setTabOrder(_tabOrder: Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tabOrder	: Integer;
	
begin
	tabOrder	:=	inheritMethod(_tabOrder);
	tabOrder	:=	tabOrder + 1;
	self.myTextBox.tabIndex	:=	tabOrder;
	
	return tabOrder;
end;</source>
        <Parameter name="_tabOrder" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
