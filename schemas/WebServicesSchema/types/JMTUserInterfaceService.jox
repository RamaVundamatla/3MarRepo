	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	create reportFormat transient;
	reportFormat.id				:= JadeReportWriterReport.HTML.String;
	reportFormat.description	:= "On Screen";	
	response.allOutputFormats.add(reportFormat);

	create reportFormat transient;
	reportFormat.id				:=  CM_QryReport.PDF_Format.String;
	reportFormat.description	:= "PDF";		
	response.allOutputFormats.add(reportFormat);

	create reportFormat transient;
	reportFormat.id				:= JadeReportWriterReport.CSV.String;
	reportFormat.description	:= "CSV";	
	response.allOutputFormats.add(reportFormat);	
	
	create reportFormat transient;
	reportFormat.id				:= JadeReportWriterReport.RTF.String;
	reportFormat.description	:= "RTF";	
	response.allOutputFormats.add(reportFormat);
	
	create reportFormat transient;
	reportFormat.id				:= JadeReportWriterReport.XML.String;
	reportFormat.description	:= "XML";		
	response.allOutputFormats.add(reportFormat);

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getReportOutputFormats</wsdlName>
        <ReturnType type="WS_ReportOutputFormatsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getReportParameters" id="107b718d-1feb-4453-894e-fda0893d02dd">
        <source>getReportParameters(_reportName : String) : WS_FormDefinitionResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2018	jlger1	Initial creation 37479

*/

vars	
	formDef			: WS_FormDefinition;
	response		: WS_FormDefinitionResponse;
	completedOK		: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	create formDef transient;
	formDef.formName := _reportName;	
	response.myFormDefinition := formDef;	
	
	formDef.buildReportParameters();
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_reportName" type="String"/>
        <ReturnType type="WS_FormDefinitionResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getReportTrains" id="88d0d0c3-4a6d-4619-9478-f8a5e3f94ec8">
        <source>getReportTrains() : WS_TrainsResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
// 28/06/2022	jlika1 TFS 53971 - MTN - Rail Confirm App to React
constants
	Max_Trains = 200;
	
vars
	response : WS_TrainsResponse;
	completedOK : Boolean;
	trainDict : CM_TrainByDepatureDTDict;
	train : CM_Train;
	term : CM_Terminal;
	wsTrain : WS_Train;
	count : Integer;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	term := app.myPassport.myTerminal;
	if term = null then
		completedOK := true;
		return response;
	endif;
	
	// get on-terminal trains, and recently departed trains (up to a maximum of 200)
	create trainDict transient;
	foreach train in term.allTrainsOnTerminal discreteLock do
		if train.isNullTrain then
			continue;
		endif;
		trainDict.add(train);
	endforeach;
	foreach train in term.allTrainsDepartedReversed discreteLock do
		if train.isNullTrain then
			continue;
		endif;
		// don't show older trains past an arbitrary limit
		count := count + 1;
		if count &gt; Max_Trains then
			break;
		endif;
		trainDict.add(train);
	endforeach;
	
	foreach train in trainDict do
		create wsTrain transient;
		wsTrain.setProxyFromObject(train);
		wsTrain.setProxyWagons(train);
		response.allTrains.add(wsTrain);
	endforeach;
	
	completedOK := true;
	return response;
	
epilog
	delete trainDict;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_TrainsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getReportVoyages" id="ecca6297-6bd4-4b2f-9606-12485e4b37c3">
        <source>getReportVoyages() : WS_VoyagesResponse webService; 
/*

Date			Who		Reason
09 June 2017	cnwer1	Initial creation TFS 4644
07 May 2024		jlizm1	TFS 63899 Limit report parameters based on user data access restrictions

*/



vars
	response		: WS_VoyagesResponse;
	completedOK		: Boolean;
	proxyVoyage		: WS_Voyage;	
	iter			: Iterator;
	voy				: CM_Voyage;
	failedDAC		: CM_DataAccessController;
	passport		: CM_Passport;
	restrictData	: Boolean;
		
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	restrictData := passport.myTerminal.getConfig(WpReportRestrictData).Boolean;
	
	// Populate response - cloned from CMUI_ComboForVoyageActive, and CMUI_Assistant::setAllVoyageCodes
	iter := passport.myTerminal.allVoyagesByCode.createIterator();
	
	while iter.next(voy) do
		//epr just do the same as report runner which is display all voyages
		/*if voy.displayOption = VoyageDisplayNever then
			continue;
		endif;

	    if voy.myTerminalArchived &lt;&gt; null then			// exclude archived
	    	continue;
	    endif;*/
		
		if restrictData and not voy.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;

		create proxyVoyage transient;
		proxyVoyage.setProxyFromObject(voy);
		response.allVoyages.add(proxyVoyage);

	endwhile;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up local transients
	delete iter;

	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getReportsForReportHeader" id="aab60d19-ce0a-459e-a4fb-ac9b585ead64">
        <usesRPC>default</usesRPC>
        <source>getReportsForReportHeader(reportHeaderStr : String) : WS_ReportsResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Sep 2008	cnwkao1	Initial creation

*/

vars
	reportsReq : WS_ReportsRequest;
	
begin
	create reportsReq transient;
	reportsReq.headerName := reportHeaderStr;	
	return self.getReportsForReportHeaderReq(reportsReq);
	
	
epilog
	delete reportsReq;
	
end;</source>
        <wsdlName>getReportsForReportHeader</wsdlName>
        <Parameter name="reportHeaderStr" type="String"/>
