    <JadeMethod name="tTrackedItemValContractId" id="3eeffa62-14e9-4c32-a3c8-76866bc99453">
        <updating/>
        <source>tTrackedItemValContractId() updating;
/*

Purpose:			
		This UT tests the Create &amp; Update of TrackedItem's Contract ID
Parameters:			

Return Value:		

Date		Who		Reason
13 January 2023	navkc1	Initial creation TFS CR 55625 Task 55661: Jade - Contract Id EDI Unit Tests
24 Nov 2023 navrv30 #61154: FR | 54089 - EUP - Invoice Contracts - EDI upload for Contract ID

*/

constants
	
	InvalidContractId 	: String = "InvalidContractId";
	InvalidContractId2 	: String = "InvalidContractId2";
	OperatorId 			: String = "ABOS";
	
vars
	terminal						: CM_Terminal;
	pxyTI, ti1, ti2					: CM_TrackedItem;
	updController 					: CMIF_TIUpdateController;
	operator						: CM_Operator;
	tiSet							: CM_TISet;
	index							: Integer;
	tiId							: String;
	noContract						: Boolean;
	debtor							: CM_Debtor;
	today,
	fromTS,
	toTS							: TimeStamp;
	contract						: CM_InvoiceContract;
begin
	
	terminal := self.getTerminal();
	
	noContract := terminal.allInvoiceContractsById.isEmpty();
	//24 Nov 2023 navrv30 #61154
	operator := self.getOperator(OperatorId);
	self.assertNotNull(operator);
	debtor := operator.debtor;
	today := app.actualTimeAppServer();
	fromTS := today.addDays(-365);
	toTS := today.addDays(365);	
	self.deleteAllContractsForDebtor(debtor);
	
	create tiSet transient;

	foreach index in 1 to 2 step 1 do
		tiId := "UTKIAT" &amp; index.padLeadingWith("0", 2);
		self.deleteTrackedItem(self.getTrackedItem(tiId), false);
		
		create pxyTI as CM_Container transient;
		
		pxyTI.setPxyFromDefaultTI(terminal, TI_CargoType_Container, tiId, "EFEC", operator);
		pxyTI.CM_Container.zSetPxyISOType("2200");
		pxyTI.setImExStatus(TI_IMEX_STATUS_STORAGE);
		pxyTI.CM_Container.zSetPxyTotalWeight(5000);
		pxyTI.setContractId(InvalidContractId);
		
		tiSet.add(pxyTI);
	endforeach;
	
	app.myPassport.clearErrorsWarnings();
	
	updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	updController.setMyTransientTIs(tiSet);	
	
	contract := self.createContract(debtor, InvalidContractId, false, false, fromTS, toTS, true);  //24 Nov 2023 navrv30 #61154
	
	while true do
		app.myTrxCA.trxCreateTrackedItems(updController, app.myPassport);
		
		if contract &lt;&gt; null then                //24 Nov 2023 navrv30 #61154
			self.assertNoTrxErrorsOrWarnings();
		else
			self.assertTrxWarning(Contract_not_found_for_debtor);
		endif;
		
		if app.myPassport.trxCompletedOK() then
			app.myPassport.clearErrorsWarnings();
			break;
		endif;
		
		self.ignoreTrxWarnings(true);
	endwhile;
	
	self.ignoreTrxWarnings(false);
	
	ti1 	:= self.getTrackedItem(tiSet.first().CM_TrackedItem.id);	
	ti2 	:= self.getTrackedItem(tiSet.last().CM_TrackedItem.id);
	
	self.assertEqualMsg(ti1.contractId, InvalidContractId, "Contract Id is not set correctly for " &amp; ti1.id);
	self.assertEqualMsg(ti2.contractId, InvalidContractId, "Contract Id is not set correctly for " &amp; ti2.id);
	
	beginLoad;
	pxyTI := ti1.pxyCreateUpdateProxy();
	endLoad;
	
	pxyTI.setContractId(InvalidContractId2);
	contract := self.createContract(debtor, InvalidContractId2, false, false, fromTS, toTS, true);   //24 Nov 2023 navrv30 #61154
	while true do
		app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);
		
		if contract &lt;&gt; null then                             //24 Nov 2023 navrv30 #61154
			self.assertNoTrxErrorsOrWarnings();
		else
			self.assertTrxErrorMsg(Contract_not_found_for_debtor, "Contract is not found for InvalidContractId2");
		endif;
		
		if app.myPassport.trxCompletedOK() then
			app.myPassport.clearErrorsWarnings();
			break;
		endif;
		
		self.ignoreTrxWarnings(true);
	endwhile;
	
	self.assertEqualMsg(ti1.contractId, InvalidContractId2, "Contract Id is not udpated correctly for " &amp; ti1.id);
	
epilog
	self.ignoreTrxWarnings(false);
	delete pxyTI;
	delete tiSet;
	delete updController;	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrxCreateTrackedItem" id="b9c4ec2a-ba12-47e2-b630-56419600d0e9">
        <source>tTrxCreateTrackedItem();
// cnwndl1
//13 September 2010	cnwdw1	
// Test trxCreateTrackedItem which is used by Centre Port  PAR 25659
constants
	CargoId : String = "UTREBAR1234567890";
vars
	pxyTI,realTI	: CM_TrackedItem;
	terminal: CM_Terminal;
	company: CM_Bank;
	cargoId : String;
begin
	self.deleteContainer("UUT12345678");
	terminal := self.getTerminal();
	
	pxyTI := terminal.createTI(self.getCargoType("CONT"), true);
	pxyTI.zSetPxyId("UUT12345678");
	pxyTI.zSetPxyOperator(self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	pxyTI.zSetPxyTerminal(terminal);
	pxyTI.zSetPxyISOType("2200");
	pxyTI.zSetPxyCommodity("GENL");
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_EXPORT);
	pxyTI.setSubTerminalDefaultFromTerm(terminal);	
	pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));						// 10/09/2015 cnwmh5
	foreach company in terminal.companies do
		if company.isBusinessUnit then
			pxyTI.zSetPxyCompany(company);
			break;
		endif;
	endforeach;
	
	// Test Total Weight Volume and Quantity
	
	pxyTI.zSetPxyTotalQVW(1,1, 200, 2400);  			   //18.08.2022 navma1 #54368
	//assertEqual(pxyTI.totalQuantity, 1);
	//assertEqual(pxyTI.getMyCargoVolume, 200.Decimal);   //18.08.2022 navma1 #54368
	assertEqual(pxyTI.totalWeight, 2400.Decimal);

	app.myTrxCA.trxCreateTrackedItem(pxyTI, realTI, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	assertEqual(realTI.totalQuantity, 1);                 //18.08.2022 navma1 #54368
	//assertEqual(realTI.getMyCargoVolume, 200.Decimal);  //18.08.2022 navma1 #54368
	assertEqual(realTI.totalWeight, 2400.Decimal);
	
	pxyTI := app.createUpdateProxy(realTI).CM_TrackedItem;
	pxyTI.zSetPxyTotalQuantity(101);
	pxyTI.setMyCargoVolume(201);
	pxyTI.zSetPxyTotalWeight(2401);
	
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	assertEqual(realTI.totalQuantity, 101);
	assertEqual(realTI.getMyCargoVolume, 201.Decimal);
	assertEqual(realTI.totalWeight, 2401.Decimal);
	delete pxyTI;
	
	// now try a break-bulk item
	cargoId := CargoId;
	self.deleteTrackedItem(cargoId, true);
	
	pxyTI := terminal.createTI(self.getCargoType("REBAR"), true);
	pxyTI.zSetPxyId(cargoId);
	pxyTI.zSetPxyOperator(self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	pxyTI.zSetPxyTerminal(terminal);
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_EXPORT);
	pxyTI.setSubTerminalDefaultFromTerm(terminal);	
	pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));						// 10/09/2015 cnwmh5
	foreach company in terminal.companies do
		if company.isBusinessUnit then
			pxyTI.zSetPxyCompany(company);
			break;
		endif;
	endforeach;
	
	// Test Total Weight Volume and Quantity
	pxyTI.zSetPxyTotalQVW(1,1, 200, 2400);  			   //18.08.2022 navma1 #54368
	assertEqual(pxyTI.totalQuantity, 1);
	assertEqual(pxyTI.getMyCargoVolume, 200.Decimal);   //18.08.2022 navma1 #54368
	assertEqual(pxyTI.totalWeight, 2400.Decimal);

	app.myTrxCA.trxCreateTrackedItem(pxyTI, realTI, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	assertEqual(realTI.totalQuantity, 1);                 //18.08.2022 navma1 #54368
	assertEqual(realTI.getMyCargoVolume, 200.Decimal);  //18.08.2022 navma1 #54368
	assertEqual(realTI.totalWeight, 2400.Decimal);
	
	pxyTI := app.createUpdateProxy(realTI).CM_TrackedItem;
	pxyTI.zSetPxyTotalQuantity(101);
	pxyTI.setMyCargoVolume(201);
	pxyTI.zSetPxyTotalWeight(2401);
	
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	assertEqual(realTI.totalQuantity, 101);
	assertEqual(realTI.getMyCargoVolume, 201.Decimal);
	assertEqual(realTI.totalWeight, 2401.Decimal);
	delete pxyTI;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateNonTranship" id="76f5b5e8-4e3a-41dd-844f-73363be00720">
        <updating/>
        <source>tUpdateNonTranship()updating;
/*

Purpose:	update To non Tranship		

Date		Who		Reason
07/04/2014	cnwma1	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants 

	ContainerID1 = "CRXU304050";
	ContainerID2 = "TRXU666777";
	VoyageIMP = 'CAI4040';
	VoyageEXP = 'AMA5050';
vars

	pxyTi,ti  : CM_TrackedItem;
	pxyTi2,pxyTi3,ti2 : CM_TrackedItem;
	pxyTiArray : CM_TIArray;
	voyageImp		: CM_Voyage;
	voyageExp		: CM_Voyage;
	controller		: CMIF_TranshipTIController;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
		self.deleteVoyage(VoyageIMP);
		self.deleteVoyage(VoyageEXP);
		
	voyageImp := self.addVoyageWithContainerStructur(VoyageIMP,
													"CAI",
													"APL", 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNull(voyageImp);
	
	voyageImp := self.getVoyage(VoyageIMP);
	self.assertNotNull(voyageImp);

	
	voyageExp := self.addVoyageWithContainerStructur(VoyageEXP,
													"AMA",
													"APL", 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNull(voyageExp);
	
	voyageExp := self.getVoyage(VoyageEXP);
	self.assertNotNull(voyageExp);
	
	
	create pxyTiArray transient;
	
		pxyTi := self.createContainer(ContainerID1, "2010", "FOIL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), true);
		pxyTi.setTotalWeight(12000, null, null);
		pxyTi.setWeightTare(2000);
		pxyTi.setDischargePort('NZPOE');
		pxyTi.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
		pxyTi.setMyVoyage(voyageImp, app.myPassport);
		pxyTi.changeState(TI_STATE_ONSHIP, app.myPassport);
		ti:= self.addContainerFromProxyToLC(pxyTi, VoyageIMP&amp;' 010682');
	// Make the Containers tranship
	//
	create controller transient;

	ti := self.getTrackedItemOnVoy(ContainerID1, VoyageIMP);
	self.assertNotNull(ti);
	controller.allTrackedItems.add(ti);

	
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= voyageExp;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	
	beginLoad;	
	pxyTi := ti.pxyCreateUpdateProxy();
	endLoad;
	
	pxyTiArray.clear();
	pxyTiArray.add(pxyTi);

	app.myTrxUA.trxUpdateTINonTranship(pxyTiArray,TI_UPDMODE_NORMAL,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.getImExStatus,TI_IMEX_STATUS_REMAINONBOARD);

	// Update Tranist Status
	pxyTi2 := self.createContainer(ContainerID2, "2010", "FOIL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), true);
	pxyTi2.setDischargePort('NZPOE');
	pxyTi2.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
	pxyTi2.setMyVoyage(voyageExp, app.myPassport);
	pxyTi2.changeState(TI_STATE_ONSHIP, app.myPassport);
	ti2:= self.addContainerFromProxyToLC(pxyTi2, VoyageEXP&amp;' 010682');
	
	beginLoad;	
	pxyTi3 := ti2.pxyCreateUpdateProxy();
	endLoad;
	
	
	app.myTrxUA.trxUpdateTITransitStatus(pxyTi3,TI_TransitStatusDLR,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti2.isRehandle,true);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete pxyTi;
	delete pxyTiArray;
	delete controller;
	delete pxyTi;
	delete pxyTi3;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tUpdateTiBol" id="1ae0681c-a95e-4ffc-81b2-30d4dd008c38">
        <source>tUpdateTiBol();
/*

Purpose:			

Date		Who		Reason
22/4/2014	cnwma1	Initial creation
06/05/2014  cnwma1	remove Bol  Details from Tracked Item
21/05/2014  cnwma1 Move Tracked Item to Planned Location
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	BOLNUM = "BL5566";
	VOYNUM = "CAI7070";
	BS	= "UTBS777";
	BS1	= "UTBS888";
	CNTR= "MSCU999777";
	CNTR2= "GLDU555333";

vars
	realBOL			: CM_BOL;
	boLItem 		: CM_BOLDtl;
	voyage 			: CM_Voyage;
	tiSet			: CM_TISet;
	pxyTi,ti,ti2	: CM_TrackedItem;
	bs,bs1			: CM_BlockStack;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	idx				: Integer;
	tiArray	        : CM_TIArray;
	tmpLoadCC					: CMIF_LoadColorCode;
	slots 						: CM_SlotControllerArray;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.disableAllYA(true);
	
	self.deleteVoyage(VOYNUM);
	
	self.deleteYA("MAYA");
	deleteTerminalArea(BS);
	bs := self.addBlockStack(BS,500,null);
	
	deleteTerminalArea(BS1);
	bs1 := self.addBlockStack(BS1,20,null);
	
	voyage := self.addVoyageWithContainerStructur(VOYNUM,
													"CAI",
													"APL", 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
													
													
	realBOL:= self.addBOL(BOLNUM,voyage,self.getOperator("APL"),"",self.getTerminal());
	self.assertNotNull(realBOL);
	
	boLItem := realBOL.allBOLDtls.first;
	
	ti := addContainerAtLocation(CNTR,self.getOperator("APL"),"2200","GENL",TI_IMEX_STATUS_IMPORT,bs);
	self.assertNotNull(ti);
	beginLoad;	
	pxyTi := ti.pxyCreateUpdateProxy();
	endLoad;
	
	create tiSet transient;
	tiSet.add(pxyTi);
	app.myTrxUA.trxUpdateTIBOL(tiSet,realBOL,boLItem,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(boLItem.allTrackedItems.first,ti);

	tiSet.clear();
	tiSet.add(ti);
	app.myTrxUA.trxDetachTIsFromBOLDtl(tiSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	create strs transient;
	
	create slots transient;
	create tmpLoadCC transient;


	deleteContainer("UTMDHJ00001");
	strs.clear;
	strs.add("010682");
	voyage.findLocation(strs, false, theSlot, idx);
	
	//Move Tracked ITem to planned Location
	deleteContainer(CNTR2);
	ti2 := addContainerAtLocnDisch(CNTR2,"2200","GENL",TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);
	self.assertNotNull(ti2);
	self.getJobSlotControllers(voyage.code, "01", DeckOnDeck, 1, 1, 1, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	create tiArray transient;
	tiArray.add(ti2);
	
	
	self.addYAToBlockStack("MAYA", YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, bs1);
	self.autoplanTIs(tiArray);
	tiSet.clear();
	tiSet.add(ti2);
	
	app.myTrxUA.trxMoveTrackedItemsToPlannedLC(tiSet,REAL_MODE,null,app.myPassport,VESSEL_TYPE_LOLO); // NAVAB1 MAY17 0); TFS 4435
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti2.myPrimaryActualLocation.ident,"UTBS888");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.disableAllYA(false);
	delete tiSet;
	delete pxyTi;
	delete strs;
	delete tiArray;
	delete tmpLoadCC;
	delete slots;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadMDHReeferMon" id="1c23beea-3ffa-4440-842b-339b5f0ddd5c">
        <source>tranMapLoadMDHReeferMon();

/*

Purpose:			

Date			Who		Reason
19/11/2015		cnwmh5	Initial creation

*/

vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "CargoLoaded!";
	mapName := "MDHReefer";

	fileContent := 'TTranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Temperature Read,,(Default),(Default) ›,(Default),All,UTMHLineDesc1' &amp; CrLf;

	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	//bank := app.myPassport.myTerminal.getConfig(DefCompany).CM_Bank;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateDataForKPICargoCount" id="1cf8e009-6c9a-4878-9ee0-57ee36ac6e9f">
        <updating/>
        <source>uCreateDataForKPICargoCount() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/09/2010	cnwdap1	Initial creation CCMS SFW 1108 PAR #25163
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
constants
	KPContainer1	= "UTKR";
	KPContainer2	= "UTKS";
	KPBbulk			= "UTKPBULK";
	KPCar			= "UTKPCAR";
	KPChassis		= "UTKPCHASSIS";
	KPTruck1		= "UTKPTRUCK1";
	KPTruck2		= "UTKPTRUCK2";
	KPTruck3		= "UTKPTRUCK3";
	KPTruck4		= "UTKPTRUCK4";
	KPTruck5		= "UTKPTRUCK5";
	KPDriver		= "UTKPDriver";
	
	KPVoyage		= "UTKPVOY01";
	KPShip			= "UTKPSHIP";
	TestOperator 	= 'MSK';
		
vars
	date, s, e 		: Date;
	remainder, int, row	: Integer;
	container 		: CM_Container;
	log				: CM_Log;
	car				: CM_Car;
	bbulk			: CM_BreakBulkGeneric;
	gate			: CM_Gate;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	pxyTI, ti		: CM_TrackedItem;
	ta				: CM_GridArea;
	ya				: CM_YardAllocation;
	locations		: CM_LCArray;
	location		: CM_LocationsController;
	vvr				: CM_VehicleVisitRecord;
	terminal		: CM_Terminal;
	iter			: Iterator;

begin
	self.deleteVehicle(KPTruck1);
	self.deleteVehicle(KPTruck2);
	self.deleteVehicle(KPTruck3);
	self.deleteVehicle(KPTruck4);
	self.deleteVehicle(KPTruck5);
	self.deleteVoyage(KPVoyage);
	self.deleteVessel(KPShip);
	self.deleteYA("UTKP");
	self.deleteTerminalArea("UTKPSTRD");
	terminal := self.getTerminal();
	iter := terminal.allOnsiteTIsByIdCargoType.createIterator;
	terminal.allOnsiteTIsByIdCargoType.startKeyGeq("UTK", null, iter);
	while iter.next(ti) do
		if ti.id[1:3] &lt;&gt; "UTK" then
			break;
		endif;
		if CM_Container.hasInstance(ti) then
			self.deleteContainer(ti.id);
		elseif ti.myCargoType.abbreviation.toUpper.isOneOf("CANNON", "CAR", "CHAS", "TL") then
			self.deleteCargo(ti.id, ti.myCargoType.abbreviation.toUpper);
		endif;
	endwhile;
	//self.deleteContainer("UTKS1009172");
	//self.deleteCargo("UTKPBULK100907002", "CANNON");
	//self.deleteCargo("UTKPCAR100907002", "CAR");
	//self.deleteCargo("UTKPCHASSIS100907002", "CHAS");
	//return;
	
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	vessel := self.addVesselCellular(KPShip, self.getOperator(TestOperator));
	voyage := self.addVoyageWithContainerStructur(KPVoyage, KPShip, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	voyage := self.getVoyage(KPVoyage);
	ta := addStraddleStack("UTKPSTRD", 10, 10, 2);
	create locations transient;
	foreach row in 1 to 6 do
		locations.add(ta.allGridControllersByRowColumn[row, 1]);
		locations.add(ta.allGridControllersByRowColumn[row, 2]);
	endforeach;
	ya := self.addYA1("UTKP", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	// we're going to create 5 days worth of receival data
	s := app.actualTimeServer.Date - 1;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	e := s - 5;
	
	foreach date in e to s do
		// we create a variable number of receipts depending on the date
		remainder := date.day mod 5;
		if remainder = null then
			remainder := 6;
		endif;
		//remainder := 1;		// testing
		foreach int in 1 to remainder do
			// ISO container road receival 
			vvr := gateInContainer(KPTruck1, KPContainer1 &amp; date.format('yyMMdd') &amp; int.String, "2200", "UTOP", "MT", gate);
			self.moveVehicleToLane(vvr.vehicle, null, 1);
			self.moveVehicleToYard(vvr.vehicle);
			self.workVehicle(vvr);
			self.moveVehicleToLane(vvr.vehicle, null, 1);
			self.roadExit(vvr);
			
			// General cargo road receival
			vvr := gateInGC(KPTruck2, "", KPDriver, KPBbulk &amp; date.format('yyMMdd') &amp; int.padLeadingWith("0", 3), "CANNON", "UTOP", "", gate,1);
			self.moveVehicleToLane(vvr.vehicle, null, 1);
			self.moveVehicleToYard(vvr.vehicle);
			self.workVehicle(vvr);
			self.moveVehicleToLane(vvr.vehicle, null, 1);
			self.roadExit(vvr);
			
			// Car road receival
			vvr := gateInGC(KPTruck3, "", KPDriver, KPCar &amp; date.format('yyMMdd') &amp; int.padLeadingWith("0", 3), "CAR", "UTOP", "", gate,1);
			self.moveVehicleToLane(vvr.vehicle, null, 1);
			self.moveVehicleToYard(vvr.vehicle);
			self.workVehicle(vvr);
			self.moveVehicleToLane(vvr.vehicle, null, 1);
			self.roadExit(vvr);
			
			// Chassis cargo road receival
			vvr := gateInGC(KPTruck4, "", KPDriver, KPChassis &amp; date.format('yyMMdd') &amp; int.padLeadingWith("0", 3), "CHAS", "UTOP", "", gate,1);
			self.moveVehicleToLane(vvr.vehicle, null, 1);
			self.moveVehicleToYard(vvr.vehicle);
			self.workVehicle(vvr);
			self.moveVehicleToLane(vvr.vehicle, null, 1);
			self.roadExit(vvr);
			
			// ISO Container ship receival
			pxyTI := self.createContainer(KPContainer2 &amp; date.format('yyMMdd') &amp; int.String, "2010", "FOIL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), true);
			pxyTI.setTotalWeight(12000, null, null);
			pxyTI.setWeightTare(2000);
			pxyTI.setDischargePort('NZPOE');
			pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
			pxyTI.setMyVoyage(voyage, app.myPassport);
			pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
			ti := self.addContainerFromProxyToLC(pxyTI, KPVoyage&amp;' 010682');
			location := app.autoPlanTiYA(self.getTerminal, ta, ti);
			self.move(ti, location);
		endforeach;
	endforeach;
epilog
	delete locations;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="uTestForIncorrectAllQueues" id="065c5674-f928-46fd-b2a4-f498d2a865d6">
        <source>uTestForIncorrectAllQueues();
//cnwrd1	
/*

Purpose:	test for par #28665

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2011	cnwrd1	Initial creation

*/

vars
	aTerminal : CM_Terminal;
	aTI : CM_TrackedItem;
	iter : Iterator;
	tiSet : CM_TISet;
begin
	
	create tiSet transient;
	
	foreach aTerminal in CM_Terminal.instances do
		iter := aTerminal.allOnsiteTIsByIdCargoType.createIterator;
	
		while iter.next(aTI) do
			if aTI.allQueues.isNotEmpty and aTI.allQueuedFutureMoves.isEmpty then
				//problemchild
				tiSet.add(aTI);
			endif;
		endwhile;
		delete iter;	
	endforeach;
	
	self.assertEqual(tiSet.size,0);
	
epilog
	delete iter;
	delete tiSet;
end;</source>
    </JadeMethod>
</Class>
