    <JadeMethod name="buildSelf" id="05a63bce-5802-4e00-b5dc-fed728adfff7">
        <updating/>
        <source>buildSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Instantiates the appropriate controls, and sets them all up.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlWidth	: Real;
	controlLeft		: Real;
	editMaskObj		: CMUI_FieldTimeMaskControl;
	
begin
	inheritMethod();
	
	create editMaskObj transient;
	
	self.myTimeBox		:=	editMaskObj;
	editMaskObj.parent	:=	self;
	self.form.addControl(editMaskObj);
	controlLeft			:=	self.myLabel.left + self.myLabel.width + CMUI_FieldFrame.HORIZONTAL_SPACING;
	controlWidth		:=	self.clientWidth() - controlLeft;
	editMaskObj.move(controlLeft, 0, controlWidth, editMaskObj.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getEmbeddedControl" id="537dffe6-716c-4abe-8418-788276212a5f">
        <source>getEmbeddedControl(): Control;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwdap1	Initial creation

*/

vars

begin
	return self.myTimeBox;
epilog

end;</source>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="getTime" id="efc8a6dd-a22b-4779-b7d5-485cb3ebc611">
        <source>getTime(): Time;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTimeBox.getTime();
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="invalidOrNoTimeEntered" id="835f0220-c12f-4017-a760-e68887644812">
        <source>invalidOrNoTimeEntered():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2011	cnwndl1	Initial creation	Par 27898

*/

vars

	time : Time;
	
begin

	if self.myTimeBox.textUser.trimBlanks() = null then
		return true;
	endif;

	time	:=	self.myTimeBox.getTextAsTime();
	if time.isValid() then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsEnabled" id="f6f2e7ff-fde6-41f5-8b7c-889672cac7cf">
        <updating/>
        <source>setIsEnabled(_isEnabled: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		01 March 2006 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myTimeBox.enabled	:=	_isEnabled;
end;</source>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTabOrder" id="f74071f6-2f00-412e-9aa4-3b10013f87f5">
        <source>setTabOrder(_tabOrder: Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tabOrder	: Integer;
	
begin
	tabOrder	:=	inheritMethod(_tabOrder);
	tabOrder	:=	tabOrder + 1;
	self.myTimeBox.tabIndex	:=	tabOrder;
	
	return tabOrder;
end;</source>
        <Parameter name="_tabOrder" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="9c1480f1-188e-45b6-af44-cb1ac9e2c488">
        <updating/>
        <source>setValue(_value: Any) updating;
// --------------------------------------------------------------------------------
// Created:		22 February 2006 by cnwdad1
//
// Purpose:		Sets the receiver's field value.
//
// Parameters:	_value - The field value to set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
// cnwdad1 17/06/2009 - PAR #19942.
//	self.myTimeBox.setTime(_value.Time);
	self.myTimeBox.setTime(_value.String.asTimeJMT());
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setWidths" id="90f33e2c-586c-4c2a-a6ff-143929d323c2">
        <updating/>
        <source>setWidths(_controlWidth: Integer; _labelWidth: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2009	cnwdap1	Initial creation

*/

vars

begin
	inheritMethod(_controlWidth, _labelWidth);
	self.myTimeBox.width	:= getTextExtent(self.TEXTEXTENT[1:self.myTimeBox.text.length]);
//	self.myTimeBox.width	:= getTextExtent(self.myTimeBox.text);
	self.myTimeBox.left		:= self.width - _controlWidth;
epilog

end;</source>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_labelWidth" type="Integer"/>
    </JadeMethod>
