    <JadeMethod name="getExtraInfo" id="33693036-b15a-4f7e-b68e-eb984e751730">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	block : CM_DataContainerBlock;
	release : CM_BulkRelease;
	str, reason : String;

    docActions : CM_ReserveDetailActions;

begin
	// TFS 3943
	if self.myReserveDetail &lt;&gt; null then
	
		docActions := self.myReserveDetail .myReserveDetailActions;
		if docActions &lt;&gt; null then
// TFS 4052			if not docActions.areAllActionsComplete(reason ) then
			if not docActions.areAllActionsCompleted(reason) then // TFS 4052
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Document_actions), DC_Warning, 1, self);
				block.addNewItem(reason, DC_Data, 1, null);
			endif;
		endif;
	
	endif;

	inheritMethod(_dataContainer);
	
	if self.isYardDeliveryReq then	//11 Jun 2012	NDL	Par 29665
		release := self.CM_YardDeliveryRequest.myRelease;
		if release = null then
			release := self.myOriginatingBulkRelease;
		endif;
		if release &lt;&gt; null then
			release.getExtraInfo(_dataContainer);
		endif;
	
	else
		if self.myOriginatingBulkRelease &lt;&gt; null then
			self.myOriginatingBulkRelease.getExtraInfo(_dataContainer);
		endif;
	
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
