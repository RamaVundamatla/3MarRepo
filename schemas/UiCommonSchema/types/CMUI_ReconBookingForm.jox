    <JadeMethod name="clearForm" id="82d39571-8e65-4e08-a60a-155301e40852">
        <source>clearForm();
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
19 August 2009	cnwml2	Initial creation
15/03/2010		cnwcs5	par 23159 - replace literals with translated text/rationalising notifications
*/

vars

begin
	self.tblExpected.clearAllData();
	
	self.tblExpectedMacro.rows 		:= 0;
	self.tblExpectedMacro.columns 	:= 0;
	self.tblActual.clearAllData();
	self.tblActualMacro.rows 		:= 0;
	self.tblActualMacro.columns 	:= 0;
	self.tblUnreconciled.clearAllData();
	self.tblUnreconMacro.rows 		:= 0;
	self.tblUnreconMacro.columns 	:= 0;
	self.lblReconDetail.caption 	:= "";
	self.lblActual.caption 			:= app.getErrorString1 (CARGO_RECEIVED, 0.asStringJMT);	// par 23159 
	self.lblUnreconciled.caption 	:= app.getErrorString1 (UNRECONCILED_CARGO, 0.asStringJMT);	// par 23159
	self.chkShowAllCargo.value 		:= false;
	
	self.optBooking.enabled	 		:= false;	// par 23196
	self.optVoyage.enabled	 		:= false;	// par 23196
	self.optAllBookings.enabled	 	:= false;	// par 23196
	self.optBooking.value			:= true;	// par 23196
	self.btnCompleteRecon.enabled	:= false;	// par 23196
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbBooking_click" id="f8a9c9a6-ed46-456e-90f8-d691020ade80">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBooking_click(combobox: ComboBox input) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
18 August 2009	cnwml2	Initial creation
15/03/2010		cnwcs5	par 23159
01/04/2010		cnwcs5	par 23159 - post qual - do not reset notifications
*/

vars
	idx  : Integer;
begin	
	if self.myBooking &lt;&gt; self.cmbBooking.listObject.CM_BookingRef then		//+cnwml2 PAR23796
		//clear macros
		self.tblExpectedMacro.rows 		:= 0;
		self.tblExpectedMacro.columns 	:= 0;
		self.tblActualMacro.rows 		:= 0;
		self.tblActualMacro.columns 	:= 0;
		self.tblUnreconMacro.rows 		:= 0;
		self.tblUnreconMacro.columns 	:= 0;
	endif;
	
	self.myBooking 	:= self.cmbBooking.listObject.CM_BookingRef;
	self.myVoyage 	:= self.myBooking.myVoyage;
	
	self.cmbVoyage.setObject(self.myVoyage);
	

	self.setCmbBooking();
	self.loadData();
	
	if self.myBooking &lt;&gt; null then					// par 23159	
		self.optBooking.enabled	 		:= true;	// par 23196
		self.optVoyage.enabled	 		:= true;	// par 23196
		self.optAllBookings.enabled	 	:= true;	// par 23196
		self.btnCompleteRecon.enabled	:= true;	// par 23196
	endif;											// par 23159

	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbVoyage_click" id="cfbc73e7-3868-4fe4-9c0c-bae530fb5943">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_click(combobox: ComboBox input) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
18 August 2009	cnwml2	Initial creation
15/03/2010		cnwcs5	par 23259 - rationalise notifications
01/04/2010		cnwcs5	par 23159 - post qual - do not reset notifications
*/
vars

begin
	self.myVoyage := combobox.listObject.CM_Voyage;
	self.cmbVoyage.setObject(self.myVoyage);
	self.setCmbBooking();
	self.myBooking := self.cmbBooking.listObject.CM_BookingRef;
	self.clearForm();
	
	if self.myBooking &lt;&gt; null then					// par 23159
	
		self.optBooking.enabled	 		:= true;	// par 23196
		self.optVoyage.enabled	 		:= true;	// par 23196
		self.optAllBookings.enabled	 	:= true;	// par 23196
		self.btnCompleteRecon.enabled	:= true;	// par 23196
	endif;											// par 23159
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="eab83be8-cfe3-4da6-a613-f20a062135ec">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2010 by cnwcs5
// Purpose:     par 22605 - Booking reconciliation permission
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.permissionView	:= PmGteBookingRefRecon;
// TFS 2734	self.permissionMaint	:= PmGteBookingRefRecon;
	self.permissionMaint	:= PmGteBookingRefReconMaint; // TFS 2734
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDragDrop" id="e6c73c54-a5f0-4e21-95c3-336c0d710c2c">
        <updating/>
        <source>doDragDrop(_table: Table input; _win: Window; _x: Real; _y: Real) updating;
// 06 August 2009	cnwdw1	
// 11/03/2010		cnwcs5	par 22892 - if user clicks cancel after warnings don't update the table
vars
	sourceTable: CM_DataTable;
	targetRow: Integer;
	targetBookingItem: CM_BookingRefItem;
	sourceTI, targetTI: CM_TrackedItem;
	tis: CM_TISet;
	result, row : Integer;
	obj : Object;
	ti : CM_TrackedItem;
begin
	inheritMethod(_table, _win, _x, _y);
	
	sourceTable := _win.CM_DataTable;
	
	if _table = self.tblExpected then
		// moving ti to a new booking item
		targetRow := self.tblExpected.dragRow;
		if targetRow &gt; 1 then
			targetBookingItem := self.tblExpected.accessRow(targetRow).itemObject.CM_BookingRefItem;
			self.myCurrentBookingItem := targetBookingItem; //+ cnwmd1 Par 21741
			create tis transient;
			sourceTable.allSelectedObjects.copy(tis);

		endif;
	endif;
	if _table = self.tblUnreconciled then
		targetBookingItem := null;
		create tis transient;
		sourceTable.allSelectedObjects.copy(tis);
		self.allCurrentTrackedItems.clear(); //+ cnwmd1 Par 21741
		tis.copy(self.allCurrentTrackedItems);	//+ cnwmd1 Par 21741

	endif;

	if tis = null then		// PAR 21102
		return;
	endif;
	
	while true do
		if not sourceTable.allSelectedObjects.isEmpty then
			self.myBookingAgent.moveTIsToBookingItem(tis, self.myBooking, targetBookingItem);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.tblUnreconMacro.rows 		:= 0;
			self.tblUnreconMacro.columns 	:= 0;
			// need to do the updating
			break;
		endif;
		
		result := app.showErrorWarningDialog(app.getErrorString (Booking), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors and  result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		// they must have clicked the cancel button
		return;	// 11/03/2010 cnwcs5 par 22892
	endwhile;
	
	self.doMoveBetweenTables (_table, sourceTable, tis);
	
epilog
	delete tis;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_win" type="Window"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doEditRecon" id="7bee03b8-3c12-43ae-9369-b4c969049bed">
        <source>doEditRecon();
//12 August 2009	cnwdw1	
//
vars
begin
	self.myAssistant.showBookingForm(myBooking, self.myMasterMenuAction, self.myTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuBookingDiscrepClick" id="750d0000-8a56-467c-b664-de794784583e">
        <source>doMnuBookingDiscrepClick();
//15 February 2010	cnwml2


vars

	tiArray : CM_TISet;
	obj : Object;
begin
	create tiArray transient;
	if self.tblActual.allSelectedObjects.size &gt; 0 then
		foreach obj in self.tblActual.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) then
				tiArray.add(obj.CM_TrackedItem);
			endif;
		endforeach;
	elseif self.tblUnreconciled.allSelectedObjects.size &gt; 0 then
		foreach obj in self.tblUnreconciled.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) then
				tiArray.add(obj.CM_TrackedItem);
			endif;
		endforeach;
	endif;
		
	if tiArray = null or tiArray.size &lt; 1 then
		return;
	endif;
	
	self.myAssistant.showBookingRefDiscrep(null, tiArray, null, self.myMasterMenuAction, self.myTerminal);

	
epilog

	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveBetweenTables" id="dbe34e1f-2805-441d-a692-7043e3cb637a">
        <updating/>
        <source>doMoveBetweenTables(_table :Table input; _sourceTable :CM_DataTable input; _coll :CM_TISet)updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 March 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti	:CM_TrackedItem;
begin
	if _table = self.tblExpected then
		if _sourceTable = self.tblUnreconciled then
			foreach ti in _coll do
				self.tblActual.CM_DataTable.addItemObject(ti, ti.getAttributeStringForDefArray(self.tblActual.allTblDataEntRows));
				_sourceTable.removeItemObject(ti);
				
				if ti.allBookingRefDiscreps.size &gt; 0 then
					self.tblActual.accessCell(self.tblActual.rows,1).foreColor := Red;
					self.tblActual.accessCell(self.tblActual.rows, 1).fontUnderline := true;
				endif;
			endforeach;
		elseif _sourceTable = self.tblActual then
			foreach ti in _coll do
				if ti.allBookingRefDiscreps.size &gt; 0 then
					self.tblActual.accessCell(self.tblActual.rows,1).foreColor := Red;
					self.tblActual.accessCell(self.tblActual.rows, 1).fontUnderline := true;
				endif;
			endforeach;
		endif;
		self.loadExpectedTable();
	elseif _table = self.tblUnreconciled then
		foreach ti in _coll do
			_table.CM_DataTable.addItemObject(ti, ti.getAttributeStringForDefArray(_table.CM_DataTable.allTblDataEntRows));
			_sourceTable.removeItemObject(ti);
			if ti.allBookingRefDiscreps.size &gt; 0 then
				self.tblUnreconciled.accessCell(self.tblUnreconciled.CM_DataTable.rows,1).foreColor := Red;
				self.tblUnreconciled.accessCell(self.tblUnreconciled.rows, 1).fontUnderline := true;
			endif;
		endforeach;
		self.loadExpectedTable();
	endif;
	
	if _table = self.tblUnreconciled or
		_sourceTable = self.tblUnreconciled then
		self.lblUnreconciled.caption := app.getErrorString1 (UNRECONCILED_CARGO, (self.tblUnreconciled.rows - self.tblUnreconciled.fixedRows).asStringJMT);	// 11/03/2010 - make locale aware
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_sourceTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_coll" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="bab78c2b-95e4-4925-b7b9-72f7d9a3d324">
        <updating/>
        <source>doRefresh() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwml2	Initial creation

*/

vars

begin
	inheritMethod();
	self.refreshForm();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="fe6277b6-6415-49c7-8c34-711f07969ff1">
        <updating/>
        <source>doSave(): Boolean updating;
/*
Date		Who		Reason
14 August 2009	cnwml2	Initial creation
*/

vars
	newBookingRef, pxyBookingRef : CM_BookingRef;
	newBulkRelease : CM_BulkRelease;
	result : Integer;
begin
	
	pxyBookingRef := app.createUpdateProxy(self.myBooking).CM_BookingRef;

	pxyBookingRef.setReconciliation(self.chkReconciled.value, self.txtCompleteReaso.text, self.dateComplete.text.asDateJMT);

	while true do
		if self.myBooking &lt;&gt; null then
			app.myTrxUA.trxUpdateBookingBulkRel(pxyBookingRef,
												app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			//unloadForm;
			return true;
		else
			result := app.showErrorWarningDialog('Booking', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
epilog
	delete pxyBookingRef;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSysNotes" id="24885491-75b4-4bc6-a51b-73b34fb8dfa9">
        <updating/>
        <source>doSysNotes(eventType: Integer; theObject: Object; userInfo: Any) updating;
//12 August 2009	cnwdw1	
//15/03/2010		cnwcs5	par 23159 - rationalise notification handling
vars
	invalidObject	: Boolean;
	ti				: CM_TrackedItem;
	idx				: Integer;
begin 
	if self.myBooking = null then	// par 23159
		// nothing to display
		return;						// par 23159
	endif;							// par 23159
	
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);
	
	if theObject.isKindOf(CM_BookingRef) then
		if eventType = Object_Update_Event then
			// we don't register for these any more - we use a user notification
			//self.refreshForm();
		elseif eventType = Object_Delete_Event then
			if theObject = self.myBooking then		// par 23159
				// display message to user then unload form
				app.msgBox(app.getErrorString1(DeletedByAnotherUser, self.cmbBooking.text),
								app.getErrorString(BookingReconciliation), MsgBox_OK_Only);
				self.unloadForm;
			elseif self.myBooking &lt;&gt; null then		// par 23159
				// a delete of a booking reference could leave previously reconciled 
				// items unreconciled
				if self.optVoyage.value or			// par 23159
					self.optAllBookings.value then	// par 23159
					self.loadUnreconciledTable;		// par 23159
				endif;
			endif;									// par 23159
		endif;
	endif;	
/*	elseif theObject.isKindOf(CM_TrackedItem) then
		if self.myBooking &lt;&gt; null then
			ti := theObject.CM_TrackedItem;
			
			if eventType = Object_Create_Event then			// par 23159
				if ti.myBookingRef = self.myBooking then	// par 23159
					if ti.myBookingRefItem &lt;&gt; null then		// par 23159
						self.refreshForm;					// par 23159
					else
						// unreconciled for the current booking
						self.loadUnreconciledTable;			// par 23159
					endif;
				elseif ti.myBookingRef &lt;&gt; null then			// par 23159
					if ti.myBookingRefItem = null then		// par 23159
						// unreconciled for another booking
						if not self.optBooking.value then
							self.loadUnreconciledTable;
						endif;
					else
						// reconciled item for another booking
					endif;				
				endif;
//			elseif ti.myBookingRefItem = null then
				// No booking item so is unreconciled
//				self.loadUnreconciledTable();
			elseif eventType = Object_Update_Event then
				if self.tblUnreconciled.findObjectInRow(theObject, idx) then
					// A Ti that we had in the unreconciled table has changed
				   self.loadUnreconciledTable();
				endif;
			endif;
		endif;
	endif;
*/

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doTblExpMoveTI" id="8973d6da-c718-4089-89a2-549a009fed5d">
        <updating/>
        <source>doTblExpMoveTI(_table: Table input; _win: Window)updating, protected;
//20 August 2009	cnwml2
/*

Date		Who		Reason
30 Aug 2012	cnwkpd1	PAR #28731 - Transient leaks in JMT
	
*/

vars
	sourceTable: CM_DataTable;
	targetRow: Integer;
	targetBookingItem: CM_BookingRefItem;
	sourceTI: CM_TrackedItem;
	tis: CM_TISet;
	result : Integer;
begin
	inheritMethod(_table, _win);
	sourceTable := _win.CM_DataTable;
//	if sourceTable = null or sourceTable.allSelectedObjects.first.isKindOf(CM_TrackedItem) then
		// source must be tracked items
//		return;
//	endif;
	
	if _table = self.tblExpected then
		// moving ti to a new booking item
		targetRow := self.tblExpected.accessedRow.row;
		if targetRow &gt; 1 then
			targetBookingItem := self.tblExpected.accessRow(targetRow).itemObject.CM_BookingRefItem;
			create tis transient;
			sourceTable.allSelectedObjects.copy(tis);
		endif;
	endif;
	if _table = self.tblUnreconciled then
		targetBookingItem := null;
		create tis transient;
		sourceTable.allSelectedObjects.copy(tis);
	endif;

	while true do
		if not sourceTable.allSelectedObjects.isEmpty then
			self.myBookingAgent.moveTIsToBookingItem(tis, self.myBooking, targetBookingItem);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.tblUnreconMacro.rows 		:= 0;
			self.tblUnreconMacro.columns 	:= 0;
			break;	// 11/03/2010 cnwcs5 par 22892 - need to update tables
		endif;
		result := app.showErrorWarningDialog(app.getErrorString (Booking), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);	// 11/03/2010 cnwcs5 make locale aware
		
		if app.myPassport.noErrors and  result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		return;
	endwhile;

	self.doMoveBetweenTables (_table, sourceTable, tis);	// 11/03/2010 cnwcs5 par 22892

epilog
	delete tis;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_win" type="Window"/>
    </JadeMethod>
    <JadeMethod name="doTblExpectedDblClick" id="60a383c1-0c12-40fc-8a6e-cceb0f7bff66">
        <source>doTblExpectedDblClick(_obj : Object);
//28 September 2009	cnwml2
// 15/03/2010	cnwcs5	Fixed excception if nothing selected in the table
vars
	bRefItem : CM_BookingRefItem;
	modalResult : Integer;
	
	subSys : CMUI_SubSystem;
	formCls,
	assistCls: Class;
	bookingRefForm : CM_BaseForm;
begin
	if _obj = null then		// 15/03/2010 cnwcs5
		return;				// 15/03/2010 cnwcs5
	endif;					// 15/03/2010 cnwcs5
	
	subSys := app.myController.allSubSystems['GateSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('GTE_BookRequestItemForm', formCls, assistCls);
	endif;
	if formCls = null then
		return;
	endif;
	bookingRefForm := app.loadForm(formCls,
									assistCls,
									false,
									false,
									false,
									self.myTerminal, null).CM_BaseForm;
									
	bRefItem := _obj.CM_BookingRefItem;
	
	if bRefItem &lt;&gt; null then
		bookingRefForm.setFormObject(bRefItem);
	endif;

	bookingRefForm.width := 500;
	
	bookingRefForm.setPropertyValue("isReadOnly", true);
	
	modalResult := bookingRefForm.showModal;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doUserNotes" id="6625b286-2766-4693-b6b8-4a5dff31cb33">
        <updating/>
        <source>doUserNotes(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2010 by cnwcs5
// Purpose:     par 23159 - Code moved from userNotify event
//				Gets called in superclass form methods
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	termEvent 	: Integer;
	ti			: CM_TrackedItem;
	row			: Integer;
	oldBooking	: CM_BookingRef;
begin 
	if self.myBooking = null then
		// nothing being displayed so no need to update form
		return;
	endif;
	
	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(_eventType);
	endif;

	if termEvent = Event_BookingRefUpdate then
		// something has been updated for the booking
		if _object = self.myBooking then
			// we need to re-display everything
			self.refreshForm();
		else
			if self.optAllBookings.value then
				// we are displaying ALL unreconciled bookings so need to refresh list
				// we don't know what may have changed
				self.loadUnreconciledTable;
			elseif self.optVoyage.value then
				// we need to re-display unreconciled bookings as we don't know if
				// the change to the booking was to change the voyage from the one we are
				// displaying to another
				self.loadUnreconciledTable;
			else
				// no need to re-load anything as we are displaying unreconciled
				// items for ANOTHER booking
			endif;			
		endif;
	elseif termEvent = Event_BookingRefDelete then
		if _object = self.myBooking then		// par 23159
			// display message to user then unload form
			app.msgBox(app.getErrorString1(DeletedByAnotherUser, self.cmbBooking.text),
							app.getErrorString(BookingReconciliation), MsgBox_OK_Only);
			self.unloadForm;
		elseif self.myBooking &lt;&gt; null then		// par 23159
			// a delete of a booking reference could leave previously reconciled 
			// items unreconciled
			if self.optVoyage.value or			// par 23159
				self.optAllBookings.value then	// par 23159
				self.loadUnreconciledTable;		// par 23159
			endif;
		endif;									// par 23159
	elseif termEvent = EVENT_TI_BOOKING_RECON then

		ti 			:= _object.CM_TrackedItem;
		oldBooking	:= _userInfo.CM_BookingRef;
		
		if ti.myBookingRef = self.myBooking or
			oldBooking = self.myBooking then
			self.refreshForm;
			return;
		endif;
		
		// if we get to here then change relates to a ti on another booking so no need 
		// to refresh anything other than the unreconciled table
		if self.tblUnreconciled.findObjectInRow(ti, row) then
			// A Ti that we had in the unreconciled table has changed
			self.loadUnreconciledTable();
		else
			// the object was not already in the unreconciled table
			if ti.myBookingRef &lt;&gt; null and ti.myBookingRefItem = null then
				// not reconciled
				if optVoyage.value or
					optAllBookings.value then
					self.loadUnreconciledTable;
				else
					// we are only looking at unreconciled items for the current booking
					// this is handled in the refreshForm above
				endif;
			endif;		
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
