    <JadeMethod name="addRowFromGlobalConstant" id="9cb3d3c4-e2c0-49ab-ae9a-398364177333">
        <source>addRowFromGlobalConstant(pConstant : GlobalConstant);
// ---------------------------------------------------------------------------
// Created:     17 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	inStr,
	grpRowStr,
	grpName		: String;
	restartPos	: Integer;
	group		: EntTableGroup;
	
begin

	// parse XML in text - there can be more than one group
	
	inStr := pConstant.text;
	
	while (inStr &lt;&gt; null) do
		grpRowStr := inStr.cnEcGetTagValueOfName(XMLTag_GroupRow);
		if grpRowStr &lt;&gt; null then
			// process the group row here
			
			grpName := grpRowStr.cnEcGetTagValueOfName(XMLTag_GroupName);
			if grpName &lt;&gt; null then
				group := self.allEntTableGroups[grpName];
				if group = null then
					group := self.createEntTableGroup(grpName, null);
				else
					group.addRowFromXML(grpRowStr);
				endif;
			endif;
		endif;
		
		restartPos := grpRowStr.length + (XMLTag_GroupRow.length * 2);
		
		if inStr.length &lt; restartPos then
			break;
		endif;
		
		inStr := inStr[restartPos : end];
		
	endwhile;

end;</source>
        <Parameter name="pConstant" type="GlobalConstant"/>
    </JadeMethod>
    <JadeMethod name="clearAllData" id="3507fb05-130c-4c6d-b2c9-cdf2aa8ff704">
        <source>clearAllData();
// ---------------------------------------------------------------------------
// Created:     17 July 2001 by cnwrs2
