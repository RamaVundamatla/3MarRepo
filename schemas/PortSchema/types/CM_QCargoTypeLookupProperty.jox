    <JadeMethod name="setComboValues" id="6e06c6b2-0939-428c-a284-6d43d8595667">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars
	cargoBOLType		: CM_CargoBOLType;
	cargoTypeDict		: Collection;
		os				: ObjectSet;
	iter : Iterator;
	current : Any;
begin
	_combo.clear();
	cargoTypeDict := app.myRoot.allCargoTypesById;
	
	create os transient;
	_params.getTerminals(os,_passport);
	
	if  os.size = 1 and (_params.context ="CM_ContainerEnqForm" ) then    
		cargoTypeDict:=os.first.CM_Terminal.allCargoBOLTypes;
	endif;
	
	current:=_queryOperator.getSearchValue();

	iter:=cargoTypeDict.createIterator;
	while iter.next(cargoBOLType) do
		
		if cargoBOLType.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort then	// TFS 49252
			continue;																			// TFS 49252
		endif;																					// TFS 49252
		
		if os.size &gt; 0 and cargoBOLType.isKindOf(CM_CargoType) and not os.includesAny(cargoBOLType.allTerminals) then
			continue;
		endif;
		_combo.itemObject[_combo.addItem(cargoBOLType.description)] := cargoBOLType;
		if cargoBOLType.id = current.Integer then
			_combo.listObject:=cargoBOLType;
		endif;
	endwhile;
	
	
/*	foreach cargoBOLType in cargoTypeDict do
		_combo.itemObject[_combo.addItem(cargoBOLType.description)] := cargoBOLType;
	endforeach;
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.listObject := cargoTypeDict[_queryOperator.CM_QIntegerLookupEqual.searchValue];
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := cargoTypeDict[_queryOperator.CM_QIntegerLookupNotEqual.searchValue];
	endif;*/
epilog
	delete iter;
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="af43a2dd-b3d8-4738-b659-7b8c2106f7eb">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cargoBOLType		: CM_CargoBOLType;
	selectionValue		: Integer;
	idx					: Integer;
begin
	
	_tbl.clear();
	_tbl.rows := 0;
	
	foreach cargoBOLType in app.myRoot.allCargoTypesById do
		if not cargoBOLType.isKindOf(CM_CargoType) then
			continue;
		endif;
		
		selectionValue := 0;
		if _operator &lt;&gt; null then
			if _operator.allSelectionValues.includes(cargoBOLType.id) then
				selectionValue := 1;
			endif;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; cargoBOLType.description);
		_tbl.accessRow(idx).itemObject := cargoBOLType.CM_CargoType;
		_tbl.row := idx;
		_tbl.change(_tbl); 
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="a1ad5cd8-d277-4f74-b72e-c981fac915fe">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cargoType	: CM_CargoType;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			cargoType := _tbl.accessRow(idx).itemObject.CM_CargoType;
			//str := _tbl.accessCell(idx, 2).text;
			ia.add(cargoType.id);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="f03ff909-bb8b-4ded-aa23-6b549e627b13">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	cargoBOLTytpe	: CM_CargoBOLType;
	codeDict		: CM_CargoTypesByIdDict;
	tmpValue		: String;
	
begin
	
	if _value.isKindOf( CM_CargoBOLType ) then
		return _value;
	endif;
	
	tmpValue	:= _value.String.toUpper();
	codeDict := app.myRoot.allCargoTypesById;
	
	foreach cargoBOLTytpe in codeDict discreteLock do
		if tmpValue = cargoBOLTytpe.description.toUpper() then
			return cargoBOLTytpe.id;
		endif;
	endforeach;

	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="db6194a9-7b3e-4221-842d-bfe44f05229e">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Modified:	04 April 2014		cnwmc5 - Needed to add exception handler for deleted cargo types..
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	object 		: CM_CargoType;
	invalidObj 	: Boolean;
	returnVal	: String;
	
begin
	if _value.Integer &gt; 0 then
		object := app.myRoot.allCargoTypesById[_value.Integer];
		
		if object &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, object, invalidObj);
			
			returnVal := object.description;
		endif;
		
	endif;
	
	return returnVal;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="15c76099-f6ac-44bb-bde0-74ec989c7aab">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf
26 Aug 2019	jlgdap1	TFS 45769 JMT Web Portal selector query parameters
*/

vars
	invalidObj 		: Boolean;
	object			: CM_CargoBOLType;
	returnVal		: Integer;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;
		
		if _value.isKindOf(CM_CargoBOLType) then //epr TFS 47132 16/12/19
			object := _value.CM_CargoBOLType;
		elseif _value.isKindOf(Integer) then								// TFS 45769
			object:= app.myRoot.allCargoTypesById[_value.Integer];			// TFS 45769
		elseif _value.isKindOf(String) and _value.String.isInteger then		// TFS 45769
			object:= app.myRoot.allCargoTypesById[_value.String.Integer];	// TFS 45769
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.id;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
