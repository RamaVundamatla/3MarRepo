    <JadeMethod name="addUpdateCargoConfirmed" id="0ea50b7f-7fa5-4ffe-b9d3-a615741e3a7a">
        <updating/>
        <source>addUpdateCargoConfirmed( _ti : CM_TrackedItem; _initialLoad : Boolean; _confirmed : Boolean ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	row : Integer;
	index : Integer;

begin

	if _ti = null then
		return;
	endif;
	
	if _initialLoad then
		index := self.tblCargo.addItem( _ti.id &amp; Tab &amp; "1" &amp; Tab &amp; "0" );
		self.tblCargo.accessRow(index).itemObject := _ti;
		return;
	
	else
	
		foreach row in 1 to self.tblCargo.rows do
			if self.tblCargo.accessRow(row).itemObject = _ti then
				index := row;
				break;
			endif;
		endforeach;
		
		if index &gt; 0 then
			//update
			if _confirmed then
				self.tblCargo.accessCell(index,3).text := "1";
				self.tblCargo.accessRow(index).backColor := LightGreen;
				self.tblCargo.topRow := index;
			endif;
		else
			//Extra Add, i.e. not expected
			index := self.tblCargo.addItem( _ti.id &amp; Tab &amp; "0" &amp; Tab &amp; "1" );
			self.tblCargo.accessRow(index).itemObject := _ti;
			self.tblCargo.accessRow(index).backColor := LightRed;
			self.tblCargo.topRow := index;
		endif;
		
	endif;
	
	self.resetProgressCaptions();
	

epilog


end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_initialLoad" type="Boolean"/>
        <Parameter name="_confirmed" type="Boolean"/>
    </JadeMethod>
