    <JadeMethod name="canDo" id="abb97067-da5f-4ac5-be2d-c1d3dde20b88">
        <source>canDo(_value : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	chkIdx	: Integer;
begin

	chkIdx := self.getLicenseIndex(_value);
	if chkIdx &lt;=0 then
		return false;
	endif;
	
	if chkIdx &lt;= self.allDetails.size then
		return self.allDetails[chkIdx];
	endif;

	return false;
		
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearArrays" id="30d6e915-e0a0-43f6-9157-0268fcda51aa">
        <source>clearArrays();
/*
Purpose:	

Date		Who		Reason
13 December 2024	navab1	JIRA 33541
*/

vars

begin
	self.allDetails.clear;
	self.allExpiries.clear;
	
	 // ### JIRA 36920 05JAN2026 NAVAB1 initialise
	self.allDetails.atPut(250,false);
	self.allExpiries.atPut(250,null);
	
epilog

end;</source>
    </JadeMethod>
