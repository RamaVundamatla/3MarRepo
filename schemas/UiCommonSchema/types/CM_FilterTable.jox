        <source>resizeColumn(table: Table input; column: Integer input; previousWidth: Integer input) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2015	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod(table, column, previousWidth);
	
	if self.tblFilterHeaders &lt;&gt; null then
		self.tblFilterHeaders.accessColumn( column ).width := self.accessColumn( column ).width;
		self.tblFilterHeaders.columnWidth[ column ] := self.columnWidth[ column ];
	endif;

epilog

end;</source>
