    <JadeMethod name="erase" id="553d0b7b-f31c-423f-b1f2-0c149200648b">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/02/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 21/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 08/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 28/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
//
vars
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	tisChangeTransit : CM_TISet;						// TFS 3489
	requests : CM_RequestSet;							// TFS 3516
	shift : CM_Shift;
begin
	shift := self.myShift; // TFS 39507
	
	create tisChangeTransit transient;					// TFS 3489
	foreach	wle in self.workListEntries discreteLock do
		ti := wle.myTrackedItem;
		if ti &lt;&gt; null and ti.isTBAorIsRRP() then
			ti.doForcedUnqueue(app.myPassport);
			ti.doForcedUnplan(app.myPassport);
		
			ti.erase(_eraseLevel);
			continue;
		endif;
		if ti &lt;&gt; null and self.isDischarge and ti.getTransitStatus.isOneOf(TI_TransitStatusDLR, TI_TransitStatusSOB) then	// TFS 3489
			tisChangeTransit.add(ti);																						// TFS 3489
		endif;																												// TFS 3489
	endforeach;

	// Voyage hold jobs have one request for each TI assigned to the job		// TFS 3516
	// When we delete the job, we can safely delete the requests as well,		// TFS 3516
	// rather than just disconnecting the link between the two					// TFS 3516
	create requests transient;													// TFS 3516
	self.allRequests.copy(requests);											// TFS 3516

	inheritMethod(_eraseLevel);	
	
	 // TFS 39507 - noticed in testing that if deleted voyage the shifts remained and for Pelindo1 the shift will be one per hold job.
	if shift &lt;&gt; null and shift.allJobs.isEmpty() then // TFS 39507
		shift.erase(_eraseLevel); // TFS 39507
	endif;
	
	requests.purge();															// TFS 3516
	foreach ti in tisChangeTransit do																						// TFS 3489
		ti.setTransitStatus(TI_TransitStatusNull, true, app.myPassport);													// TFS 3489
	endforeach;																												// TFS 3489
epilog
	delete tisChangeTransit;																								// TFS 3489
	delete requests;															// TFS 3516
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAutoRemarks" id="2709c581-c144-4475-bc9d-bf66678581c4">
        <updating/>
        <source>getAutoRemarks(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2017	cnwndl1	Initial creation	TFS 3647
17/03/2017	cnwdap1	TFS 3516 LNX Hold Planning Quantity
*/

vars

	request : CM_Request;
	wle : CM_WorkListEntry;
	cmif : CMIF_WorkEntry;
	allCMIFs : DynaDictionary;
	cargoType : CM_CargoType;
	product : CM_Product;
	obj : Object;
	wleWeight : Decimal [16,4];
	wleQuantity : Integer;
	autoRemark : String;
	measureType : CM_MeasurementType;
	density : Decimal [16,4];


begin

	if self.jobType &lt;&gt; JOB_TYPE_DISCHARGE
	and self.jobType &lt;&gt; JOB_TYPE_LOAD
	and self.jobType &lt;&gt; JOB_TYPE_SOB then
		return null;
	endif;
	
	create allCMIFs transient;
	allCMIFs.setMembership(CMIF_WorkEntry);
	allCMIFs.addMemberKey( CMIF_WorkEntry::myCargoType.name, false, false );
	allCMIFs.addMemberKey( CMIF_WorkEntry::myWorkListEntry.name, false, false );
	allCMIFs.endKeys(true);
	
	foreach request in self.allRequests discreteLock do
		foreach wle in request.allWorkListEntries discreteLock do
			cargoType := wle.getCargoType();
			if cargoType = null then
				continue;
			endif;
			create cmif transient;
			cmif.set(	wle.id[1:30],	//_tiCode : String;
						wle.locationTarget,	//_locationTarget : String;
						cargoType,	//_cargoType : CM_CargoType;
						wle,	//_wle : CM_WorkListEntry;
						wle.myTrackedItem,	//_ti : CM_TrackedItem;
						wle.getTerminalForAlert()	//_terminal : CM_Terminal
						);
			cmif.myProduct := wle.getProduct();
			allCMIFs.add(cmif);
		endforeach;
	endforeach;
	
	if not allCMIFs.isEmpty then
		cargoType := allCMIFs.first.CMIF_WorkEntry.myCargoType;
		product := allCMIFs.first.CMIF_WorkEntry.myProduct;
	
		foreach obj in allCMIFs do
			cmif := obj.CMIF_WorkEntry;
			wle := cmif.myWorkListEntry;
			if cmif.myCargoType &lt;&gt; cargoType or cmif.myProduct &lt;&gt; product then
				
				if autoRemark &lt;&gt; null then
					autoRemark := autoRemark &amp; ", ";
				endif;
				//create the description
				if cargoType.isBulkByVolume then
					//epr bulk do not get the measurement type from product but the defaults set on the cargo type 13/6/18
					measureType:=cargoType.myVolumeMeasurementType;
					density := 0;
					if product &lt;&gt; null then				
						density := product.getDensityValue;
					endif;
					if density &lt;= 0 then
						if cargoType.mySystemProductType &lt;&gt; null then					
							density := cargoType.mySystemProductType.getDensityValue;
						endif;
					endif;
					if density &lt;= 0 then
						measureType := cargoType.getMeasurementTypeFor(Type_Weight, true);
						autoRemark := app.convertMeasurementForDisplay(measureType.shortName, wleWeight) &amp; " " &amp; measureType.shortName &amp; " x ";
					else
						autoRemark := app.convertMeasurementForDisplay(measureType.shortName, wleWeight / density) &amp; " " &amp; measureType.shortName &amp; " x ";
					endif;
				elseif  cargoType.isBulkByWeight then
					measureType := cargoType.myWeightMeasurementType;
					autoRemark := app.convertMeasurementForDisplay(measureType.shortName, wleWeight) &amp; " " &amp; measureType.shortName &amp; " x ";
				else
					autoRemark := autoRemark &amp; wleQuantity.String &amp; " x ";
				endif;
				autoRemark := autoRemark &amp; cargoType.abbreviation;
				if product &lt;&gt; null then
					autoRemark := autoRemark &amp; "[" &amp; product.code &amp; "]";
				endif;
				//Set up the next one.
				cargoType := cmif.myCargoType;
				product := cmif.myProduct;
				wleWeight := wle.weight;
				wleQuantity := wle.quantity.max(1);
			else
				wleWeight := wleWeight + wle.weight;
				wleQuantity := wleQuantity + wle.quantity;
			endif;
		endforeach;
		
		//the last one.
		if autoRemark &lt;&gt; null then
			autoRemark := autoRemark &amp; ", ";
		endif;
		//create the description
		if cargoType.isBulkByVolume then
			density := 0;
			//epr bulk do not get the measurement type from product but the defaults set on the cargo type 13/6/18
			measureType:=cargoType.myVolumeMeasurementType;
			if product &lt;&gt; null then
				density := product.getDensityValue;
			endif;
			if density &lt;= 0 then
				if cargoType.mySystemProductType &lt;&gt; null then
					density := cargoType.mySystemProductType.getDensityValue;
				endif;
			endif;
			if density &lt;= 0 then
				measureType := cargoType.getMeasurementTypeFor(Type_Weight, true);
				autoRemark := autoRemark &amp; app.convertMeasurementForDisplay(measureType.shortName, wleWeight) &amp; " " &amp; measureType.shortName &amp; " x ";	// TFS 3516
			else
				autoRemark := autoRemark &amp; app.convertMeasurementForDisplay(measureType.shortName, wleWeight / density) &amp; " " &amp; measureType.shortName &amp; " x ";	// TFS 3516
			endif;
		elseif  cargoType.isBulkByWeight then
			measureType := cargoType.myWeightMeasurementType;
			autoRemark := autoRemark &amp; app.convertMeasurementForDisplay(measureType.shortName, wleWeight) &amp; " " &amp; measureType.shortName &amp; " x ";	// TFS 3516
		else
			autoRemark := autoRemark &amp; wleQuantity.String &amp; " x ";
		endif;
		autoRemark := autoRemark &amp; cargoType.abbreviation;
		if product &lt;&gt; null then
			autoRemark := autoRemark &amp; "[" &amp; product.code &amp; "]";
		endif;
	
	endif;
	
	return autoRemark;
	
epilog

	if allCMIFs &lt;&gt; null then
		if not allCMIFs.isEmpty then
			allCMIFs.purge();
		endif;
		delete allCMIFs;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDischargeLane" id="bef38aa4-c8b9-48c9-b01e-2b6d538cd01e">
        <source>getDefaultDischargeLane(): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
11 September 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail

*/

vars
	
	obj : CM_Object;
	crane : CM_Crane;
	wp : CM_WorkPoint;
	
begin
	obj := self.getWorkPointObject();
	if obj &lt;&gt; null and obj.isKindOf(CM_WorkPoint) then
		wp := obj.CM_WorkPoint;
	endif;
	if wp &lt;&gt; null then
		return wp.getDefaultDischargeLane(true);
	endif;
	
	crane := self.getJobCrane();
	if crane &lt;&gt; null then
		return crane.getDefaultDischargeLane();
	endif;
	
	app.raiseCMException(Crane_not_found_voyage,null,self);
	return null;
	
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="cf846ac9-5d6e-4baa-9bb9-1c77e4b459fc">
        <source>getDescription(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2017	cnwdap1		Initial creation TFS 3457 LNX Voyage Operations Enhancements
//
vars
	wle : CM_WorkListEntry;
	locationString : String;
	loc : CM_LocationsController;
	height : Integer;

begin
	wle := self.workListEntries.first;
	if wle = null then
		return null;
	endif;
	if self.isDischarge then
		locationString := wle.locationSource;
	else
		locationString := wle.locationTarget;
	endif;
	self.myTerminal.findLocationFromString(locationString, true, loc, height);
	if loc &lt;&gt; null then
		if loc.isKindOf(CM_ShipBlockController) then
			return self.myVoyage.code;
		elseif loc.isKindOf(CM_GeneralCargoController) then
			return loc.CM_GeneralCargoController.getHoldID;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEstJobTimeForJobStats" id="093ce46f-5973-4fa5-8eeb-ad4d70495606">
        <source>getEstJobTimeForJobStats(_crane: CM_Crane; _cmif_JobStats: CMIF_JobStats; _additionalMins: Integer): Integer;
/*
Purpose:		TFS 4133	
Date		Who		Reason
19 April 2017	cnwab1	Initial creation
11 Mar 2019	NDL	TFS 43713 - Don't return a number bigger than max integer.
*/

vars
	jobAdditionalMins : Integer;
	crane : CM_Crane;
	craneMoveRate : CM_CraneMoveRates;
	slodRate, //single lift on deck rate
	sludRate, //single lift under deck rate
	tlodRate, //twin lift on deck rate
	tludRate,	//twin lift under deck rate
	ovrDimRate 	: Real;
	jobMins :Real;
	numHours : Real;	//Decimal[12,4];
	numSecs : Real;	//Integer;
    incompleteWeight, targetRatePHWeight : Real;
	retValueReal : Real;
	retValueInt : Integer;
begin
	if self.estimatedTimeToCompleteMins &lt;&gt; null then
		return self.estimatedTimeToCompleteMins;
	endif;
	if self.myVoyage &lt;&gt; null then
		jobAdditionalMins:=_additionalMins;
	endif;
	
	incompleteWeight := _cmif_JobStats.totalWeight - _cmif_JobStats.completeWeight;

	targetRatePHWeight := 1;
	
	if _cmif_JobStats.myJob &lt;&gt; null
	and _cmif_JobStats.myJob.myJobSheet &lt;&gt; null
	and  _cmif_JobStats.myJob.myJobSheet.myWorkPoint &lt;&gt; null then
		if _cmif_JobStats.myJob.myJobSheet.myWorkPoint.hasDefinedCargoRates then	//08 Mar 2018	NDL TFS 37437
			targetRatePHWeight := _cmif_JobStats.myJob.myJobSheet.myWorkPoint.getDefinedTargetRateWeight( _cmif_JobStats.myJob );
		else
			targetRatePHWeight := _cmif_JobStats.myJob.myJobSheet.myWorkPoint.targetRatePHWeight;
		endif;
	endif;
	
	if targetRatePHWeight = 0 then // TFS 5025
		targetRatePHWeight:= 1; // TFS 5025
	endif;
	
	numHours := numHours + (incompleteWeight/ targetRatePHWeight);
	
	numSecs := (numHours * SecondsPerHour);
	
	retValueReal := numSecs + (jobAdditionalMins * 60);
	
	if retValueReal &lt; Max_Integer then
		retValueInt := retValueReal.Integer;
	else
		retValueInt := Max_Integer;
	endif;
	
	return retValueInt;


end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_cmif_JobStats" type="CMIF_JobStats"/>
        <Parameter name="_additionalMins" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEstJobTimeUsingWPRates" id="f47b230c-c5fc-4813-a0f3-924db18ab995">
        <source>getEstJobTimeUsingWPRates(_workpoint : CM_WorkPoint input): Integer;
/*
Purpose:	 // TFS 3631 		
Date		Who		Reason
21 March 2017	cnwab1	Initial creation
*/

vars
	jobAdditionalMins, rateWeightPH, rate : Integer;
	totalWeight : Decimal[12,4];	//31 July 2017	NDL	TFS 5518
    wle : CM_WorkListEntry;
    elapsedTS : Integer;
	job : CM_VoyageJob;
	
begin
	if self.estimatedTimeToCompleteMins &lt;&gt; null then
		return self.estimatedTimeToCompleteMins;
	endif;
	
	if self.myVoyage &lt;&gt; null then
		jobAdditionalMins:=self.myVoyage.myTerminal.getConfig(JobAdditionalTime).Integer;
	endif;
	
	
	if _workpoint = null then
		return null;
	endif;
	
	//08 Mar 2018	NDL TFS 37437
	wle := self.workListEntries.first;
	if wle &lt;&gt; null and wle.job &lt;&gt; null and wle.job.isKindOf(CM_VoyageJob) then
		job := wle.job.CM_VoyageJob;
	endif;
	
	if job &lt;&gt; null and _workpoint.hasDefinedCargoRates then	//08 Mar 2018	NDL TFS 37437
		rateWeightPH := _workpoint.getDefinedTargetRateWeight( job );
	else
		rateWeightPH := _workpoint.targetRatePHWeight;
	endif;
	if rateWeightPH = null then
		return null;
	endif;
	
	// if bulk the WLE will have a weight.
	foreach wle in self.workListEntries do
		totalWeight := totalWeight + wle.weight;
	endforeach;
	
	if totalWeight = 0 then // probably break bulk, the WLE has no weight just quantity.
		rate := self.actualEndTs.getDifferenceInMinutes(self.actualStartTs);
		return rate  + jobAdditionalMins; 
	endif;
	
	rate := (totalWeight / rateWeightPH).Integer;
	if rate = 0 then // probably a very high rate and a low weight
		rate := self.actualEndTs.getDifferenceInMinutes(self.actualStartTs);
		return rate  + jobAdditionalMins; 
	endif;
	
	return rate  + jobAdditionalMins; 

epilog

end;</source>
        <Parameter name="_workpoint" type="CM_WorkPoint" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHoldId" id="b8a99b0c-ea2a-4e09-979e-54c542e1e519">
        <source>getHoldId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2018	jlger1	Initial creation tfs 41310

*/

vars
	ti 			: CM_TrackedItem;
	lcPlanned,
	lcActual  	: CM_LocationsController;
begin
	
	if self.workListEntries.first = null then
		return app.getErrorString(Unknown);
	endif;
	
	ti := self.workListEntries.first.myTrackedItem;
	
	if self.isDischarge then
		
		lcActual := ti.myPrimaryActualLocation;
		
		if lcActual &lt;&gt; null and  lcActual.isVoyageController then
	       return  lcActual.CM_VoyageController.getHoldID;
		endif;
	else
		lcPlanned := ti.myPrimaryPlannedLocation;
		
		if lcPlanned &lt;&gt; null and  lcPlanned.isVoyageController then
	       return  lcPlanned.CM_VoyageController.getHoldID;
		endif;
	endif;
	
	return app.getErrorString(Unknown);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobClassNiceString" id="04f19c97-8a56-4a7e-a703-0538f0d8279e">
        <source>getJobClassNiceString(): String;
