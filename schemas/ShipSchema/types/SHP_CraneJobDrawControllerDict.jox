    <JadeMethod name="hasAnyVoyageJobs" id="3c46b7ad-8a16-4bc4-ac5c-fc17be37a414">
        <source>hasAnyVoyageJobs() : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	craneJobDrawController : SHP_CraneJobDrawingController;
begin
	app.writeStatement( method.name);
	foreach craneJobDrawController in self do
		if craneJobDrawController.allJobObjects.size &gt; 0 then
			return true;
		endif;
	
	endforeach;

	return false;
epilog
	
end;</source>
