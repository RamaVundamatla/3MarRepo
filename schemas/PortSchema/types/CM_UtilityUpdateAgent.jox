	self.setupVoyageStatus(woProcess, Voyage_Status_InitSerRequested, 	10, 	"Initial Marine Services Requested");
	self.setupVoyageStatus(woProcess, Voyage_Status_ApprovalPending, 	11, 	"Approval Pending");
	self.setupVoyageStatus(woProcess, Voyage_Status_ApprovalRejected, 	12, 	"Approval Rejected");
	self.setupVoyageStatus(woProcess, Voyage_Status_VoyageApproved, 	13, 	"Voyage Approved");
	self.setupVoyageStatus(woProcess, Voyage_Status_VoyageArrived, 		14, 	"Voyage Arrived");
	self.setupVoyageStatus(woProcess, Voyage_Status_CargoPreInvGen, 	15, 	"Cargo Pre-Invoice Generated");
	self.setupVoyageStatus(woProcess, Voyage_Status_CargoTaxInvGen, 	16, 	"Cargo Tax Invoice Generated");
	self.setupVoyageStatus(woProcess, Voyage_Status_DepServPending, 	17, 	"Departure Marine Services Pending");
	self.setupVoyageStatus(woProcess, Voyage_Status_DepServRequested, 	18, 	"Departure Marine Services Requested");
	self.setupVoyageStatus(woProcess, Voyage_Status_DepServApproved, 	19, 	"Departure Marine Services Approved");
	self.setupVoyageStatus(woProcess, Voyage_Status_ServPreInvGen, 		20, 	"Marine Pre-Invoice Generated");
	self.setupVoyageStatus(woProcess, Voyage_Status_ServTaxInvGen, 		21, 	"Marine Tax Invoice Generated");
	self.setupVoyageStatus(woProcess, Voyage_Status_VesselDeparted, 	22, 	"Vessel Departed");
	self.setupVoyageStatus(woProcess, Voyage_Status_VesselArchived, 	23, 	"Vessel Archived");
	self.setupVoyageStatus(woProcess, Voyage_Status_VoyCancelled, 		24, 	"Voyage Cancelled");
	
	// now check for any statuses left with priorities above 10000
	self.setupVoyageStatusDelPriority(woProcess);
	
