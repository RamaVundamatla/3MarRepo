    <JadeMethod name="fibo" id="e554a89b-8dbe-4cb2-bb93-99f86f1ec6e7">
        <source>fibo() : String;
/*
----------   ----------  --------------------------------------------------
Created:	17 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	n0,
	n1,
	n2,
	i			: Real;
	output		: String;
begin
	n0 := 0;
	n1 := 1;
	foreach i in 1 to self do
		output := output &amp; n1.String &amp; ' += ';
		n2 := n0 + n1;
		n0 := n1;
		n1 := n2;
	endforeach;

	return output;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHMS" id="ebfbdca5-3be6-4dcf-aa52-1198c0dcc778">
        <source>getHMS() : String;
// ---------------------------------------------------------------------------
// Created:		08 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		convert seconds to text
//
// ---------------------------------------------------------------------------
vars
	hours, minutes, seconds : Integer;
begin
		minutes := (self / 60).Integer;
		seconds := (self - (minutes * 60).Integer);
		hours := (minutes / 60).Integer;
		minutes := minutes - (hours * 60).Integer;
		
		if hours &gt; 0 then
			return hours.String &amp; "h " &amp; minutes.String &amp; "m";
		elseif minutes &gt; 0 then
			return minutes.String &amp; "m " &amp; seconds.String &amp; "s";
		endif;
		
		return seconds.String &amp; "s";


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInverseColour" id="bc6fd622-1aa0-450b-9a9c-5e1d0c228722">
        <source>getInverseColour() : Integer;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		Returns either a Black or White colour RGB value, depending
//				on the RGB back colour passed in. Used for Text on backgrounds.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	TGreen = 65280;	//Different to jade's Green
vars
	tmpRed : Integer;
	tmpGreen : Integer;
	tmpBlue : Integer;
	tmpColour : Integer;
	red,green,blue,
	hue,sat,lum : Integer;
begin
	
	//epr changed to check Lightness if less than 120 its a dark shade of the colour so use white else use black
	self.cnEcGetRGBValues(red,green,blue);
	app.convertRGBtoHSL(red,green,blue,hue,sat,lum);
	
	if lum &lt; 120 or (lum = 120 and blue &gt;220) then
		return White;
	else
		return Black;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValueWithBitUnset" id="5407516f-9ca8-41ac-b38c-aa7730baa3db">
        <source>getValueWithBitUnset(bitToUnset : Integer): Integer;
//----------------------------------------------------------------
//	Created:	13 October 2004	by Jason Chapman  (cnwjc2)
//
//	Valid values for bitToUnset:	#01	#02	#04	#08	#10	#20	#40	#80	#100 ...	etc.	
//									1	2	4	8	16	32	64	128	256	 ...	etc.
//
//----------------------------------------------------------------
vars
	
begin
	if (self.bitAnd(bitToUnset) &lt;&gt; 0) then
		return self.bitXor(bitToUnset);
	else
		//not set so just return self
		return self;
	endif;

end;</source>
        <Parameter name="bitToUnset" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
