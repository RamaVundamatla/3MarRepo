    <JadeMethod name="createVehicleMountedGUIAgent" id="90396620-610e-4991-984f-2044aa72d13b">
        <source>createVehicleMountedGUIAgent();
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	agentClass : Class;
	logonAgent : MobileHandHeldThin::VehicleMountedLogonAgent;
begin
	
	if self.myVehicleMountedLogonGUIAgent = null then
		return;
	endif;
	
	logonAgent:= self.myVehicleMountedLogonGUIAgent.myVehicleMountedLogonAgent;
	agentClass:=logonAgent.getAgentClass;
	
	if agentClass = null then
		return;
	endif;
	
	if agentClass.name = VehicleMountedRTGAgent.name then
		create app.myVehicleMountedRTGGuiAgent transient;
	elseif agentClass.name = VehicleMountedIMVAgent.name then
		create app.myVehicleMountedIMVGuiAgent transient;
	elseif agentClass.name = VehicleMountedRAILAgent.name then
		create app.myVehicleMountedRailGuiAgent transient;
	elseif agentClass.name = VehicleMountedSTRADAgent.name then
		create app.myVehicleMountedSTRADGuiAgent transient;
	endif;	

	app.myHandHeldGuiAgent.VehicleMountedGuiAgent.myVehicleMountedAgent.setDetails(logonAgent.myTerminal,
																					logonAgent.user,
																					logonAgent.myRTDevice,
																					logonAgent.myMachine,
																					logonAgent.myRTQueue);
	
	app.myHandHeldGuiAgent.VehicleMountedGuiAgent.startNonGuiApps;
epilog

end;</source>
    </JadeMethod>
