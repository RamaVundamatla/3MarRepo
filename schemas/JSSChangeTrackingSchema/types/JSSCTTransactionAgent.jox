    <JadeMethod name="createEntity" id="e3e25e26-7b61-4473-b000-7d55e3126c9e">
        <updating/>
        <source>createEntity(): Boolean updating;
/*
*/
begin
	on Exception do self.xHandler(exception);
	on DeadlockException do self.xHandlerDeadlock(exception);
	on LockException do self.xHandlerLock(exception);

	if self.doValidate(self.JSSM_TRX_CREATE) then
		if self.lockEntityCreate() then
			beginTransaction;
			if self.doCreate() then
				commitTransaction;
			else
				abortTransaction;
				return false;
			endif;
		endif;
	else
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createEntityInTransState" id="e82a9924-5000-4599-8de6-f19348bb8b4a">
        <updating/>
        <source>createEntityInTransState(): Boolean updating;
/*
*/
begin
	on Exception do self.xHandler(exception);
	on DeadlockException do self.xHandlerDeadlock(exception);
	on LockException do self.xHandlerLock(exception);

	if self.doValidate(self.JSSM_TRX_CREATE) then
		if self.lockEntityCreate() then
			if self.doCreate() then
			else
				return false;
			endif;
		endif;
	else
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createEntitySharedTransient" id="abc09d9f-e237-43d2-8803-757c8abcb3cc">
        <updating/>
        <source>createEntitySharedTransient(): Boolean updating;
/*
*/
begin
	on Exception do self.transientHandler(exception);
	on DeadlockException do self.xHandlerDeadlock(exception);
	on LockException do self.xHandlerLock(exception);

	if self.doValidate(self.JSSM_TRX_CREATE) then
		beginTransientTransaction;

		if self.doCreate() then
			commitTransientTransaction;
		else
			abortTransientTransaction;
			return false;
		endif;
	else
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteEntity" id="c97e5a31-186f-48ca-bec0-bdf1ac275f0c">
        <updating/>
        <source>deleteEntity(): Boolean updating;
/*
*/
begin
	on Exception do self.xHandler(exception);
	on DeadlockException do self.xHandlerDeadlock(exception);
	on LockException do self.xHandlerLock(exception);

	if self.doValidate(self.JSSM_TRX_DELETE) then

		if self.lockEntity() then
			beginTransaction;

			if self.doDelete() then
				commitTransaction;
			else
				abortTransaction;
				return false;
			endif;
		endif;
	else
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
