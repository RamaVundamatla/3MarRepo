    <JadeMethod name="ma171121" id="6d9b865f-8347-4958-86e5-a22502258939">
        <source>ma171121();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2021		navma1	Initial creation

*/

vars
	term : CM_Terminal;
	kpi  : CM_KPI;
begin
	term := app.myRoot.allTerminals['MA'];
	foreach term in app.myRoot .allTerminals do
		if term &lt;&gt; null then
			foreach kpi in term.allKPIbyTypeCodeTS do
				if not kpi.isKindOf(CM_KPILocation) then
					continue;
				endif;
				
				write  term.code &amp; ','&amp; kpi.CM_KPILocation.contentsCode &amp; "," &amp; kpi.dateTime.String &amp; ','&amp; kpi.CM_KPILocation.getDisplayLine;
			endforeach;
			
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ma20519" id="4ec83e7d-07c6-4c8a-8de1-ceb461a799da">
        <source>ma20519();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2019	jlgma1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	a,b,c : String;
	foundMatch : Boolean;
	grade : CM_MTGrade;
	code, desc : String;
begin
	ti := "2367.37793532".asOid.CM_TrackedItem;
	
	grade := app.myRoot.allAvailabilityGrades[ti.getAvailabilityGrade];
	if grade &lt;&gt; null then
		desc := grade.description;
		code := ti.myOperator.getXlationForeignCode(grade.code.String, XLATION_TYPE_MTGRADE_BYOP, foundMatch);
	else
		desc := "CNTR OK"; // default grade description if no grade found
		code := '0';
	endif;
	write code;
	write desc;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ma256" id="06297e88-812f-4b1c-85dc-6c76714b0762">
        <source>ma256();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2018	jlgma1	Initial creation

*/

vars
	hmsResource : HMS_Resource;
	hmsResourceType : HMS_ResourceType;
	harbour 	: HMS_Harbour;
	voyageStatus : CM_VoyageStatus;
	terminal : CM_Terminal;
begin
	voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_DepServPending];
	terminal := app.myRoot.allTerminals["JBL"];
	harbour:= terminal.myHarbour;
	foreach hmsResource in voyageStatus.allHMSResourcesAllowed discreteLock do
			if hmsResource.myHarbour &lt;&gt; harbour then
				continue;
			endif;
			
			hmsResourceType:=hmsResource.myResourceType;
			if hmsResourceType = null or hmsResourceType.isNotAvailableForEntry or
				hmsResourceType.isMarineService then
				continue;
			endif;
			
			if not hmsResourceType.isQuantityRequired  and
				not hmsResourceType.isActionDateTimeRequired and
				not hmsResourceType.isFromToDateTimeRequired then
				continue;
			endif;
				
			/*
			create wsResourceType transient;
			wsResourceType.setProxyFromObject(hmsResourceType);
			self.allHMSResourceTypes.add(wsResourceType);
			
			if _berth &lt;&gt; null then
				wsResourceType.setDefaultTugHours(hmsResource,_berth);
			endif;*/
			
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ma27519" id="c7f87979-c001-4962-bf05-2169bd379a3b">
        <source>ma27519();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2019	jlgma1	Initial creation

*/

vars
	terminal : CM_Terminal;
	train : CM_Train;
	dyna			: DynaDictionary;
	obj             : Object;
	checkDT 		:Date;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals["MA"];
	

	checkDT := app.actualTimeServer().Date;
	checkDT := checkDT.addDays(-2);	
	
	foreach train in terminal.allTrainsOnTerminal do
		// Populate response
		if train.isNullTrain() then
			continue;
		endif;
		if train.scheduledArrivalDT.Date &lt; checkDT then
			continue;
		endif;
		
			write train.CM_Train.code &amp; Tab &amp; train.CM_Train.scheduledArrivalDT.String
		&amp; Tab &amp; train.CM_Train.arrivalDT.String  ;
	endforeach;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ma2810" id="71c5a7d0-0486-48f6-9370-85ba77b3b09a">
        <source>ma2810();
/*

