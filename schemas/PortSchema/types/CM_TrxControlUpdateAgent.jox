    <JadeMethod name="trxUpdateInvoiceProcStatusAll" id="eee465d8-b3e0-4b29-85f5-ef6344926f7d">
        <updating/>
        <source>trxUpdateInvoiceProcStatusAll(_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2018	jlgsl4	Initial creation

*/

vars
	pxyProcess, realProcess, defaultProcess : CM_InvoiceProcess;
	invoiceStatus : CM_InvoiceStatus; // ### TFS 52047 24Sep2021 NAVPW1
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	
	// create the default invoice process and its statuses
	app.myUtilityUA.utlUpdateInvoiceProcDefault(_passport);
	if not app.myPassport.noErrors then
		return;
	endif;

	// create the Pelindo invoice process and its statuses
	app.myUtilityUA.utlUpdateInvoiceProcPel1(_passport);
	if not app.myPassport.noErrors then
		return;
	endif;

	// create the Linx invoice process and its statuses
	app.myUtilityUA.utlUpdateInvoiceProcLinx(_passport);
	if not app.myPassport.noErrors then
		return;
	endif;
	
	// create new invoiceapi process
	//TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR - 61386, Task - 61564)
	app.myUtilityUA.utlUpdateInvoiceProcInvAPI(_passport);
	if not app.myPassport.noErrors then
		return;
	endif;

	// ### TFS 52047 24Sep2021 NAVPW1
	foreach invoiceStatus in app.myRoot.allInvoiceStatuses do
		app.myRoot.mySecurityRoleTerminal.allInvoiceStatusesMaint.addNoDuplicates(invoiceStatus, false);
	endforeach;
	// ### TFS 52047 24Sep2021 NAVPW1
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
