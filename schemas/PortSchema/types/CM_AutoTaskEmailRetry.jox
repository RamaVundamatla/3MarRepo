<Class name="CM_AutoTaskEmailRetry" id="26f6b035-d1ec-45e3-85aa-63b535ccfeb1">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Retry Failed Email&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="numMaxRetries" id="a8ceb3f5-aa8c-4b2b-8e2a-0352b7757c09">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getEntryTableViewName" id="c3af03e3-93b3-4f4c-a366-4ae45ebbdfaf">
