    <JadeMethod name="cargoType" id="0b9bf401-5bed-477b-bc31-b5bee713803f">
        <source>cargoType(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2024	jlier1	Initial creation 62499

*/

vars

begin
	if self.myTrackedItem &lt;&gt; null then
		return inheritMethod();
	endif;
	
	return self.cargoTypeId;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseForTrackedItem" id="6f167388-47a2-4837-8a05-d14393a97ce2">
        <updating/>
        <source>eraseForTrackedItem(eraseLevel: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2024	jlier1	Initial creation 62513

*/

vars

begin
	if self.myVoyageRelivant &lt;&gt; null then
		self.myTrackedItem:=null;
	endif;

	inheritMethod(eraseLevel);

epilog

end;</source>
        <Parameter name="eraseLevel" type="Integer"/>
    </JadeMethod>
