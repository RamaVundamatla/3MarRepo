    <JadeMethod name="hasAdvancedOptionsBeenSet" id="85aecb42-32d6-405c-b7f0-205a7080ffb3">
        <source>hasAdvancedOptionsBeenSet(systemColour : Integer) : Boolean;

/*

Purpose:		Determine if any fields included in advanced options has been set.	

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwmd1	Initial creation

*/

vars

begin
	
	if /*self.myCarrier &lt;&gt; null or*/ self.maxHeight &lt;&gt; null or self.maxWidth &lt;&gt; null or self.maxWeight &lt;&gt; null or
	self.remarks &lt;&gt; null or	self.scheduleCode &lt;&gt; null or self.portArrivalDT.Date.isValid or self.shunterInDT.Date.isValid or
	self.shunterOutDT.Date.isValid or /* self.scheduledArrivalDT.isValid or self.scheduledDepartureDT.isValid or */
	self.cargoExchangeStartTS.Date.isValid or self.cargoExchangeEndTS.Date.isValid /*or self.colour &lt;&gt; systemColour */or
	self.myTrackClearance &lt;&gt; null	// NDL 26 Jun 2009	CCMS 1067
	then
		return true;
	else
		return false;
	endif;
		
epilog

end;</source>
        <Parameter name="systemColour" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasArrived" id="88d05ba7-8dde-43ef-8127-8ff81988c797">
        <source>hasArrived() : Boolean;
/*
