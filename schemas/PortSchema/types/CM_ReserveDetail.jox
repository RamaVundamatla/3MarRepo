    <JadeMethod name="pxyCreateUpdateProxy" id="eca7f2b2-4b9a-4393-839a-5cfa59d5d704">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 19/09/2012	cnwcs5		par 30390 - removed myTransferTerminal
// 14/05/2024	navnk30		ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial
vars
	proxy 		: CM_ReserveDetail;
	ti			: CM_TrackedItem;
	completedOK	: Boolean;
	proxyDetailActions : CM_ReserveDetailActions;
	pxyInstructions	   : CM_InstructionsIssued;
	
begin
	proxy := inheritMethod();
	
	self.allTrackedItems.copy(proxy.allTrackedItems);
	self.allTrackedItemsReleased.copy(proxy.allTrackedItemsReleased);
	self.allSlotRequestsAssigned.copy(proxy.allSlotRequestsAssigned);
	
	//14 Sep 2016	NDL	TFS 2278 / 2670
	if self.myReserveDetailActions &lt;&gt; null then
		create proxyDetailActions transient;
		proxyDetailActions.setMyReserveDetail( proxy );
		self.myReserveDetailActions.updateProxyFromSelf( proxyDetailActions );
	endif;
	
	//jlier1 TFS 53678 27/6/22
	proxy.myDeliveryAddress:=self.myDeliveryAddress;
	proxy.myDeliveryParty:=self.myDeliveryParty;
	if self.myInstructions &lt;&gt; null then			//14.05.2024 navnk30 #63607
		pxyInstructions	:= self.myInstructions.pxyCreateUpdateProxy();
		pxyInstructions.setProxy(pxyInstructions.internalInstructions, 
				pxyInstructions.externalInstruction,
				pxyInstructions.myInstructionType,
				proxy);
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="quantityOnSiteWithJobRail" id="f435eb23-bf5b-4e93-ab9f-d5790369f1b9">
        <source>quantityOnSiteWithJobRail( _weight : Decimal output ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 January 2015		cnwndl1	Initial creation	Par 35346
14 November 2022	jlizm1	TFS 54118 Assigning Releases to Wagons
*/

vars
	count 	  : Integer;
	req		  : CM_Request;
	tmpWeight : Decimal[14,4];
begin
	/*	
	if self.myReserveHeader &lt;&gt; null then
		foreach req in self.myReserveHeader.allRequestsBeingActioned do
			if req.myReserveDetail = self then
				if req.isKindOf(CM_DeliveryRequest) then
					count := count + req.CM_DeliveryRequest.totalRequested;
					_weight := _weight + req.CM_DeliveryRequest.weightRequested;
				endif;
			endif;
		endforeach; 
	endif; 
	*/
	
	foreach req in self.allDeliveryRequests do
		if req.isKindOf(CM_DeliveryRequest) then
			if req.isAnyAmount then				// TFS 54118
				tmpWeight := 0;					// TFS 54118
				count   := count   + req.CM_DeliveryRequest.getTotalActionedForAnyAmount(tmpWeight);	// TFS 54118
				_weight := _weight + tmpWeight;	// TFS 54118
			else
				count   := count   + req.CM_DeliveryRequest.totalRequested;
				_weight := _weight + req.CM_DeliveryRequest.weightRequested;
			endif;
		endif;	
	endforeach; 
	
epilog
	return count;
end;</source>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionForReserved" id="ecb18c47-014e-4920-99e8-506c9587cee2">
        <source>raiseExceptionForReserved(_tiId,_reserved,_otherOwnesrhip,_transferred:String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation

*/

vars

begin
	if _reserved &lt;&gt; null and _otherOwnesrhip &lt;&gt; null then
		app.raiseCMException4(Item_alrea_reser_plus_curre_ow,_tiId,_reserved, _otherOwnesrhip,_transferred,null,null);
	elseif _reserved &lt;&gt; null then
		app.raiseCMException3(Item_alrea_reser_canno_relea_f,_tiId,_reserved,_transferred,null,null);
	elseif _otherOwnesrhip &lt;&gt; null then
		app.raiseCMException3(Item_curre_owner_chang_canno_r,_tiId,_otherOwnesrhip,_transferred,null,null);
	endif;
	
epilog

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_reserved" type="String"/>
        <Parameter name="_otherOwnesrhip" type="String"/>
        <Parameter name="_transferred" type="String"/>
    </JadeMethod>
    <JadeMethod name="removeTIAssigned" id="b5653409-ecea-4823-9e61-39d0130a7b0a">
        <updating/>
        <source>removeTIAssigned(_ti : CM_TrackedItem) : Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 May 2007 By cnwth2

Purpose:	Retuns true if the TI is found on this reserveDetail
----------   ----------  --------------------------------------------------
*/
vars
	tiFound	: Boolean;
	ti : CM_TrackedItem;
begin

	if self.myReserveHeader &lt;&gt; null and self.myReserveHeader.allTrackedItemsAssigned.includes(_ti) then
		self.myReserveHeader.allTrackedItemsAssigned.remove(_ti);
		self.myReserveHeader.removeTIFromWorkOrders(_ti); //cnwrd1 ccms 1075 28.1.10
		//epr TFS 39624 23/7/18
		ti:=_ti;
		if process.isInTransactionState then
			self.myReserveHeader.createAssignedTransaction(ti, true);	
		endif;
	endif;
	if self.allTrackedItems.includes(_ti) then
		tiFound := true;
		self.allTrackedItems.remove(_ti);
		//13 Dec 2017	NDL	TFS 8091
		if not self.isTransient then
			self.updateObjectEdition( self );
		endif;
	endif;
	
	//25 Nov 2016	NDL	TFS 2968 / 2001
	if self.myReserveDetailActions &lt;&gt; null then
		self.myReserveDetailActions.remActionsIfNoCompletes( _ti );
	endif;
	
	return tiFound;
	
end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeTIReleased" id="72bd7f9a-9706-4ecc-928e-8875bb6f0422">
        <updating/>
        <source>removeTIReleased(_ti : CM_TrackedItem) updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	
	if self.myReserveHeader &lt;&gt; null then
		self.myReserveHeader.removeTIReleasedItemString(_ti);
		if self.myReserveHeader.allTrackedItemsReleased.includes(_ti) then
			self.myReserveHeader.allTrackedItemsReleased.remove(_ti);
			
		endif;
	endif;
	if self.allTrackedItemsReleased.includes(_ti) then
		self.allTrackedItemsReleased.remove(_ti);
		//13 Dec 2017	NDL	TFS 8091
		if not self.isTransient then
			self.updateObjectEdition( self );
		endif;
	endif;
	

end;

</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
