    <JadeMethod name="cloneReferences" id="47e4a822-2db3-476a-b3e2-2bf2109a2e55">
        <updating/>
        <source>cloneReferences(_bol : CM_BOL; _doVoyage : Boolean) updating;

vars

	ext	: CM_BOLExtension;
begin

	self.myOperator					:= _bol.myOperator;
	self.myOperatorTerminal			:= _bol.myOperatorTerminal;
	self.myYardJob					:= _bol.myYardJob;
	self.myPlannedLocation			:= _bol.myPlannedLocation;
	self.myTerminal					:= _bol.myTerminal;
	self.myManifest					:= _bol.myManifest;	
		
	if _bol.myExtension &lt;&gt; null then
		ext := _bol.myExtension.cloneSelf(false);
		self.myExtension := ext;
		ext.cloneReferences(_bol.myExtension);
	endif;

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_doVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createAStop" id="ec269567-c87c-46cc-9358-c21eafd17ccb">
        <updating/>
        <source>createAStop(_stopType : CM_StopsTable; _isManual : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	01 October 2008 By Graeme Black cnwgb1
// Purpose:	Create a Stop on a BOL
//			CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
	
*/

vars
	theStop : CM_Stops;

begin
	if _stopType = null then
		return;
	endif;
	
	self.raiseExceptionIfTransient(method);
	
	if (not _passport.myUser.canUpdateStop(self.myTerminal, _stopType)) then
		app.raiseCMWarning1(NoPermission, app.getErrorString1(Add_The_Stop, _stopType.heading) &amp; 'for ' &amp; self.number.String, null, null, self);
		return;
	endif;

	create theStop persistent;
	theStop.setForCreateBOL(self, _stopType.id, _stopType, _isManual, _passport);
	
//	self.causeEvent(Object_Update_Event, false, self);
	self.updateObjectEdition(self);
	
epilog

end;</source>
        <Parameter name="_stopType" type="CM_StopsTable"/>
        <Parameter name="_isManual" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createGLDateChangeTransaction" id="1c113810-ccbf-49fd-9ce9-187ba2c260c5">
        <updating/>
        <source>createGLDateChangeTransaction(_newGLDate : Date) updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2017		CNWAB1		Initial creation
*/
vars
	txnParams	: CMIF_TITransactionController;
	trans		: CM_BOLGeneralLandingDate;
	cusStop		: CM_EDICustomStopTI;
begin
	if _newGLDate = self.generalLandingDate then
		return;
	endif;
	
	create txnParams transient;
	txnParams.type 		:= TRANS_TYPE_BOL_GLDATE;
	txnParams.noCharge := false; 

	trans := self.createTransaction(txnParams, app.myPassport).CM_BOLGeneralLandingDate;

	if trans = null then
		return;
	endif;

	trans.datePrevious := self.generalLandingDate;
	trans.dateNew := _newGLDate;
	
	trans.createCharge();	//06 Nov 2019	NDL	TFS 47100
	
epilog	
	delete txnParams;
end;</source>
        <Parameter name="_newGLDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="createStatusMessageTransaction" id="15162dde-4995-48d3-aeeb-c3ef6a10864d">
        <updating/>
        <source>createStatusMessageTransaction(_object : Object; /*_information : StringArray512;*/ _passport : CM_Passport input) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 08 May 2008
//
//----------------------------------------------------------------------
vars
	txnParams	: CMIF_TITransactionController;
	trans		: CM_StatusMessageReceived;
	cusStop		: CM_EDICustomStopTI;
begin
	if _object = null then
		return;
	endif;
	
	create txnParams transient;
	txnParams.type 		:= TRANS_TYPE_STATUSMESSAGEREC;
	//Message is not chargable
	txnParams.noCharge := true; // TFS 3844 status messages are not chargeable

	trans := self.createTransaction(txnParams, _passport).CM_StatusMessageReceived;

	if trans = null then
		return;
	endif;
	
	if CM_EDICustomStopTI.hasInstance(_object) then
		cusStop := _object.CM_EDICustomStopTI;
		trans.setFromEDICustomTI(cusStop);
	endif;
	//trans.code := _code[1:10];
epilog	
	delete txnParams;
end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createStopsBulk" id="00e42b84-5cc9-4be2-b1d6-e9c9e727f6e5">
        <updating/>
        <source>createStopsBulk(_theStops : IntegerArray; _passport : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	Aug 2007 cnwrs1 CCMS 1017

Purpose:	Create stops, but generate only warnings so that a bulk update of stops
			does as much as it can and generates warnings about the rest

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
12 Oct 2016	cnwkpd1		TFS 2815 - JADE 7.1.08 causeEvent changes
15 Dec 2022 navma1		Defect 55852: MTN - 1090 exception while loading a Ship Manifest and BOL via EDI
*/

vars
	aStop 			: Integer;
	stopTblDict 	: CM_StopsTableByIdDict;
	tmpStopTbl,
	tmpStopTable 	: CM_StopsTable;
	tmpUser			: CM_User;
	tmpTerminal		: CM_Terminal;
	root			: CM_Root;
	
begin
	
	if _theStops = null then
		return;
	endif;
	
	if _theStops.isEmpty() then
		return;
	endif;
	
	self.raiseExceptionIfTransient(method);

	root	:= app.myRoot;										//15.12.2022 navma1 #55852
	tmpUser := _passport.myUser;
	
	if tmpUser = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_passport.myUser', null, null);
		return;
	endif;

	tmpTerminal := self.myTerminal;
	if tmpTerminal = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'self.myTerminal', null, null);
		return;
	endif;

	stopTblDict := root.allAvailableStopsTables;				//07.12.2022 navma1 #52499
	// NOTE stops are only set for the cargo types specified for the stop type in sys ops
	foreach aStop in _theStops do

		tmpStopTbl := stopTblDict[aStop];
		if tmpStopTbl = null then
			tmpStopTable := root.allStopsTable[aStop];			//07.12.2022 navma1 #52499
			if tmpStopTable &lt;&gt; null then
				if tmpStopTable.isNotAvailableForEntry then 
					app.raiseCMWarning1( WARN_STOPS_ADD, app.getString( Stop_NotAvailableForEntry, tmpStopTable.heading ), null, null, self );
					continue;
				endif;
			else
				app.raiseCMWarning1(WARN_STOPS_ADD, 'Invalid stop id (' &amp; aStop.String &amp; ')',null, null, self);
				continue;
			endif;
		endif;

		if (not tmpUser.canUpdateStop(tmpTerminal, tmpStopTbl)) then
			app.raiseCMWarning1(NoPermission, app.getErrorString1(Add_The_Stop, tmpStopTbl.heading) &amp; 'for ' &amp; self.number.String, null, null, self);
			continue;
		endif;

		if (not tmpStopTbl.isValidForCargoType(self.bolType)) then
			app.raiseCMWarning1(WARN_STOPS_ADD, "The stop (" &amp; tmpStopTbl.heading &amp; ") is not allowed for the cargo type of " &amp; self.number.String,null, null, self);
			continue;
		endif;
		
		if not tmpStopTbl.isStopRelevantBOL(self) then
			app.raiseCMWarning(CannotSetStop, null, null, self);
			continue;
		endif;
		
		if self.allStops[aStop] &lt;&gt; null then
			app.raiseCMWarning1(WARN_STOPS_ADD, "The stop (" &amp; tmpStopTbl.heading &amp; ") already exists on " &amp; self.number.String, null, null, self);
			continue;
		else
			self.createAStop( tmpStopTbl, true, _passport ); //cnwgb1 8.10.08 CCMS 1012 PAR 17931 AMS Processing
		endif;
	endforeach;

end;</source>
        <Parameter name="_theStops" type="IntegerArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="ec24c5a1-5481-4ff3-8f3a-b0305c4fd8bc">
        <updating/>
        <source>createTransaction(pTxn : CMIF_TITransactionController input; _passport : CM_Passport input) : CM_Transaction updating;
//--------------------------------------------------------------
//Created: 25 January 2001 By: cnwgd1
//--------------------------------------------------------------
vars
	transObj		: CM_Transaction;
	toDoTaskRepair	: String;

begin
	if pTxn.myBOL = null then
		pTxn.myBOL := self;
	elseif pTxn.myBOL &lt;&gt; self then
		app.raiseCMException(InvalidTIForTransaction, null, null);
		return transObj;
	endif;

	// Set defaults for other fields if they have not already been set.
	
	if (not pTxn.dateTime.isValid()) then
		if app.serverTimestampAtTrxStart.isValid then
			pTxn.dateTime := app.serverTimestampAtTrxStart;
		else
			pTxn.dateTime := app.actualTimeServer;
		endif;
	endif;
	
	if pTxn.operatorCode = null then
		pTxn.operatorCode := self.getOperatorCode();
	endif;
	
	if pTxn.myTerminal = null then
		pTxn.myTerminal	:= self.myTerminal;
	endif;
	
	if pTxn.userId = null then
		pTxn.userId := _passport.userCode;
	endif;
	// Create the transaction
	if pTxn.type = TRANS_TYPE_STORAGE then
	//	transObj := self.createStorageTransactions(pTxn, _passport);
	else
		transObj := pTxn.createTransaction(_passport);
	endif;
		
	return transObj;
end;
</source>
        <Parameter name="pTxn" type="CMIF_TITransactionController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Transaction"/>
    </JadeMethod>
    <JadeMethod name="createUpdConsigneeOrBOLTrxs" id="52e38922-6679-4c79-93d8-eada106ae421">
        <updating/>
        <source>createUpdConsigneeOrBOLTrxs( pxyBOLDtl : CM_BOLDtl; realBOLDtl : CM_BOLDtl; _passport : CM_Passport input )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Nov 2019	jlgndl1	Initial creation	TFS 47100
15 Dec 2022 navma1	Defect 55852: MTN - 1090 exception while loading a Ship Manifest and BOL via EDI
*/

vars

	txnParams : CMIF_TITransactionController;
	trans 	  : CM_BOLTransaction;

begin

	if pxyBOLDtl.consigneeCode &lt;&gt; realBOLDtl.consigneeCode then
		create txnParams transient;
		txnParams.type 		:= TRANS_TYPE_BOL_CONSEE;
		txnParams.userId 	:= _passport.userCode;
		txnParams.dateTime 	:= app.serverTimestampAtTrxStart;
	
		trans := self.createTransaction(txnParams, _passport).CM_BOLTransaction;
		trans.CM_BOLConsigneeChanged.setDetails( realBOLDtl.consigneeCode, pxyBOLDtl.consigneeCode, realBOLDtl );
		
		if trans &lt;&gt; null then			//15.12.2022 navma1 #55852
			trans.createCharge();
		endif;
		delete txnParams;
		
	endif;
	
	if pxyBOLDtl.consignorCode &lt;&gt; realBOLDtl.consignorCode then
		create txnParams transient;
		txnParams.type 		:= TRANS_TYPE_BOL_CONSOR;
		txnParams.userId 	:= _passport.userCode;
		txnParams.dateTime 	:= app.serverTimestampAtTrxStart;
	
		trans := self.createTransaction(txnParams, _passport).CM_BOLTransaction;
		trans.CM_BOLConsignorChanged.setDetails( realBOLDtl.consignorCode, pxyBOLDtl.consignorCode, realBOLDtl );
		
		if trans &lt;&gt; null then			//15.12.2022 navma1 #55852
			trans.createCharge();
		endif;
		delete txnParams;
		
	endif;

epilog

	delete txnParams;

end;</source>
        <Parameter name="pxyBOLDtl" type="CM_BOLDtl"/>
        <Parameter name="realBOLDtl" type="CM_BOLDtl"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createUpdOperatorBOLTrx" id="5f05e53d-7c34-4ce3-afd9-37b33bd84efc">
        <updating/>
        <source>createUpdOperatorBOLTrx( pxyBOL : CM_BOL; _passport : CM_Passport input )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Nov 2019	jlgndl1	Initial creation	TFS 47100
15 Dec 2022 navma1	Defect 55852: MTN - 1090 exception while loading a Ship Manifest and BOL via EDI
*/

vars

	txnParams : CMIF_TITransactionController;
	trans	  : CM_BOLTransaction;
	newCode   : String;
	oldCode   : String;

begin

	if pxyBOL.myOperator &lt;&gt; self.myOperator then
		create txnParams transient;
		txnParams.type 		:= TRANS_TYPE_BOL_OPER;
		txnParams.userId 	:= _passport.userCode;
		txnParams.dateTime 	:= app.serverTimestampAtTrxStart;
	
		trans := self.createTransaction(txnParams, _passport).CM_BOLTransaction;
		
		if pxyBOL.myOperator &lt;&gt; null then
			newCode := pxyBOL.myOperator.code;
		endif;
		
		if self.myOperator &lt;&gt; null then
			oldCode := self.myOperator.code;
		endif;
		
		trans.CM_BOLOperatorChanged.setDetails( oldCode, newCode, self );
		
		if trans &lt;&gt; null then				//15.12.2022 navma1 #55852
			trans.createCharge();
		endif;
		
		delete txnParams;
		
	endif;
epilog

end;</source>
        <Parameter name="pxyBOL" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
