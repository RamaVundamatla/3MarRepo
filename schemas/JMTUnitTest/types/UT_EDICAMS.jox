    <JadeMethod name="tCamCodecoPennICLChasGateIO2" id="9479649b-3f71-4516-88cf-adbfe1fd89a6">
        <source>tCamCodecoPennICLChasGateIO2();
// cnwrs1
// 19 Jun 2014	Par 34159
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//10 Mar 2023	jlika1	TFS 56923 - Add width to Trailer
// 16 Apr 2024	jlirs1	TFS 9999 - Fixing unitTests
constants
	VoyageName1		= 'VYPAR34159_1';				// all upper case!
	BlockStackName	= 'BS34159';
	BoatCode		= 'VSPAR34159';
    BoatCodeTrans   = 'TVS34159';
    BoatName        = 'My Vessel';
	ContainerName1	= 'PARC1230001';
	ContainerName2	= 'PARC1230002';
//	ContainerName3	= 'PARC1230003';
//	ContainerName4	= 'PARC1230004';
	Chassis1 = "CHAS34159_1";
	Chassis2 = "CHAS34159_2";
//	Chassis3 = "CHAS34159_3";
//	Chassis4 = "CHAS34159_4";
	TrailerType = "UTTT20";
	Vehicle1 = "VH34159_1";
//	Vehicle2 = "VH34159_2";
//	Vehicle3 = "VH34159_3";
//	Vehicle4 = "VH34159_4";
	TestOperator	= 'UTOP';
	CamGroup = "P34159";
	CamProtocol = "PAR34159";
    ReleaseNumber = "1234";
    CarrierCode = "UT_CA1";
    CarrierCodeTr = "CA1";
vars
	runDateTime : TimeStamp;
	bs : CM_BlockStack;
	tempStr	: String;
	idx : Integer;
	container1 : CM_Container;
	container2 : CM_Container;
	container3 : CM_Container;
	container4 : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	passport : CM_Passport;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	lRegisteredCargoTypes : IntegerArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : StringArray;
	str : String;
    bolNumber : String;
    thisTerminal : String;
    carrier : CM_Carrier;
	cargoType : CM_CargoType;
	chassis1 : CM_TILC;
	chassis2 : CM_TILC;
//	chassis3 : CM_TILC;
//	chassis4 : CM_TILC;
	ti : CM_TrackedItem;
	theLines : HugeStringArray;
	vvr : CM_VehicleVisitRecord;
	tt	: CM_TILCType;
	truck : CM_Vehicle;
//	trailer : CM_TILC;
	tiTrans : CM_TITransaction;
	dualGate : CM_Gate;
	gateArea : CM_GateArea;
	count : Integer;
	gateEntity : CMGTE_Entity;
begin
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	gateArea := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	self.setTerminalConfig(PortDestCode, "NZPOE");
	
	create objArray transient;
	
    // Delete EDI Translations for required voyages and vessels
	self.deleteEDIInwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
    self.deleteEDIOutwardXlation(BoatCodeTrans, XLATION_TYPE_VESSEL_BYOP, operator, null);
    self.deleteEDIInwardXlation(BoatCode, XLATION_TYPE_VESSEL_BYOP, operator, null);
   
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

    // Delete required voyages and vessels
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
 
	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);
	self.assertIsDeleted(vessel);
    
    //Delete the Carrier and Translation
    self.deleteEDIOutwardXlation(CarrierCodeTr, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteEDIInwardXlation(CarrierCode, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteCarrier(CarrierCode);
    carrier := self.getCarrier(CarrierCode);
    self.assertIsDeleted(carrier);

	
	// Delete the cargo - this should have already been done if on the voyage, 
    // but just in case some other test is using the same IDs, delete anyway
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
    
	// Now create the required voyages and vessels
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	
	bs := self.addBlockStack(BlockStackName, 3, 500);
	self.assertNotNull(bs);

	voyage1 := self.addVoyageWithInwardCode(VoyageName1, 
                                            null,
											BoatCode,
											TestOperator, 
											self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');

    // Now add the edi data translations for the vessels and voyages
    self.createEDIXlation(BoatCodeTrans, BoatCode,    XLATION_TYPE_VESSEL_BYOP,    true, operator, null );
    
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Chassis];
	self.deleteCargo(Chassis1, cargoType);		// 13/05/2011 cnwmh5
	tt := self.addTrailerType(TrailerType, TrailerType, cargoType, 500, 1, 50, 30000, 13000,null,null,null);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers, 1);

	self.deleteContainer(ContainerName1);
	self.deleteVehicle(Vehicle1);	
	vvr := self.gateInTrailerAndContainer(Vehicle1, Chassis1, ContainerName1, tt.code, "2200", operator.code, "", dualGate);
	self.assertNotNull(vvr);
	truck := self.getTerminal.vehicles[Vehicle1, null];
	self.assertNotNull(truck);
	chassis1 := truck.locationsController.allTrackedItemsById[Chassis1, cargoType.id].CM_TILC;
	self.assertNotNull(chassis1);
	chassis1 := vvr.myInCMGTE_Chassis.myTrackedItem.CM_TILC;
	self.assertNotNull(chassis1);
	self.assertEqual(chassis1.myPrimaryActualLocation, truck.locationsController); 
	tiTrans := chassis1.getLastTransOfType(TRANS_TYPE_REC_ROAD);
	self.assertNotNull(tiTrans);
	
	self.moveVehicleToLane(vvr.vehicle, gateArea, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(gateArea, 1));
	self.moveVehicleToYard(vvr.vehicle);
	self.moveQueuedCargo(vvr.myInCMGTE_Chassis.myYardRequest.allWorkListEntries.first);

	self.deleteCargo(Chassis2, cargoType);		// 13/05/2011 cnwmh5
	chassis2 := self.addTrailerAtLocation(Chassis2, cargoType, tt, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs.myLocationsController).CM_TILC;
	self.assertNotNull(chassis2);
	self.assertEqual(chassis2.myPrimaryActualLocation, bs.myLocationsController);
	beginTransaction;
	foreach gateEntity in vvr.allGateEntities do
		gateEntity.setMyVehicleVisit(null);
	endforeach;
	commitTransaction;
	container2 := self.addContainerForExport(ContainerName2,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR34159",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	self.move(container2, bs);

	vvr := self.gateOutTrailerAndContainer(Vehicle1, chassis2, container2, dualGate, vvr);
	truck := self.getTerminal.vehicles[Vehicle1, null];
	self.assertNotNull(truck);
	self.moveVehicleToLane(vvr.vehicle, gateArea, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(gateArea, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	foreach gateEntity in vvr.allGateEntities do
		self.moveQueuedCargo(gateEntity.myYardRequest.allWorkListEntries.first);
	endforeach;
	self.assertEqual(chassis2.myPrimaryActualLocation, truck.locationsController); 
	
	self.roadExit(vvr);
	self.assertEqual(chassis2.state, TI_STATE_OFFSITE);
	tiTrans := chassis2.getLastTransOfType(TRANS_TYPE_REL_ROAD);
	self.assertNotNull(tiTrans);

    
	// Add the Carrier &amp; Translation
	create emailCarrierAddresses transient;
    carrier := self.addCarrier(CarrierCode, "A Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
    self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
    self.createEDIXlation(CarrierCodeTr, CarrierCode,    XLATION_TYPE_CARRIER_BYOP,    true, operator, null );

	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "JAXT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	lRegisteredCargoTypes.add(TI_CargoType_Chassis);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["ICL Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "JAXT0", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	if camProtocol &lt;&gt; null then
	beginTransaction;
	camProtocol.setIncludeChassis(true);
	commitTransaction;
	endif;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
   
	count := 0;
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		count := count + 1;		
	endforeach;
	
	create strArray transient;
	strArray.add("UNB+UNOA:2+UT+REP+");	//Partial Comparison
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CN+"&amp;ContainerName1&amp;"+2200:102:5+++4'");
	strArray.add("DTM+7:");	//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:2000'");
	strArray.add("DAM+1+0'");
	strArray.add("TDT+1++3++DOUG+++"&amp;Vehicle1&amp;"'");
	strArray.add("EQD+CH+"&amp;Chassis1&amp;"+:102:5+++4'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+15+1'");
	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+2+9'");
	strArray.add("TDT+20+" &amp; VoyageName1 &amp; "+1+++++:146::"&amp;BoatName.toUpper&amp;"'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CN+"&amp;ContainerName2&amp;"+2200:102:5++2+4'");
	strArray.add("RFF+BN:");	//Partial Comparison
	strArray.add("DTM+7:");	//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("DAM+1+0'");
	strArray.add("TDT+1++3++DOUG+++"&amp;Vehicle1&amp;"'");
	strArray.add("EQD+CH+"&amp;Chassis2&amp;"+:102:5+++4'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+16+2'");
	strArray.add("UNZ+2+0'");	
	
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete objArray;
	delete strArray;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoPennICLChasGateIO3" id="84076269-4c51-4a96-9cef-197c77b67153">
        <source>tCamCodecoPennICLChasGateIO3();
// cnwrs1
// 19 Jun 2014	Par 34159
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//10 Mar 2023	jlika1	TFS 56923 - Add width to Trailer
// 16 Apr 2024	jlirs1	TFS 9999 - Fixing unitTests
constants
	VoyageName1		= 'VYPAR34159_1';				// all upper case!
	BlockStackName	= 'BS34159';
	BoatCode		= 'VSPAR34159';
    BoatCodeTrans   = 'TVS34159';
    BoatName        = 'My Vessel';
	ContainerName1	= 'PARC1230001';
//	ContainerName2	= 'PARC1230002';
//	ContainerName3	= 'PARC1230003';
//	ContainerName4	= 'PARC1230004';
	Chassis1 = "CHAS34159_1";
	Chassis2 = "CHAS34159_2";
//	Chassis3 = "CHAS34159_3";
//	Chassis4 = "CHAS34159_4";
	TrailerType = "UTTT20";
	Vehicle1 = "VH34159_1";
//	Vehicle2 = "VH34159_2";
//	Vehicle3 = "VH34159_3";
//	Vehicle4 = "VH34159_4";
	TestOperator	= 'UTOP';
	CamGroup = "P34159";
	CamProtocol = "PAR34159";
    ReleaseNumber = "1234";
    CarrierCode = "UT_CA1";
    CarrierCodeTr = "CA1";
vars
	runDateTime : TimeStamp;
	bs : CM_BlockStack;
	tempStr	: String;
	idx : Integer;
	container1 : CM_Container;
//	container2 : CM_Container;
//	container3 : CM_Container;
//	container4 : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	passport : CM_Passport;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	lRegisteredCargoTypes : IntegerArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : StringArray;
	str : String;
    bolNumber : String;
    thisTerminal : String;
    carrier : CM_Carrier;
	cargoType : CM_CargoType;
	chassis1 : CM_TILC;
	chassis2 : CM_TILC;
//	chassis3 : CM_TILC;
//	chassis4 : CM_TILC;
	ti : CM_TrackedItem;
	theLines : HugeStringArray;
	vvr : CM_VehicleVisitRecord;
	tt	: CM_TILCType;
	truck : CM_Vehicle;
//	trailer : CM_TILC;
	tiTrans : CM_TITransaction;
	dualGate : CM_Gate;
	gateArea : CM_GateArea;
	count : Integer;
	gateEntity : CMGTE_Entity;
begin
	self.setTerminalConfig(DoNotCreateBulkRelease, false);
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	gateArea := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	self.setTerminalConfig(PortDestCode, "NZPOE");
	
	create objArray transient;
	
    // Delete EDI Translations for required voyages and vessels
	self.deleteEDIInwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
    self.deleteEDIOutwardXlation(BoatCodeTrans, XLATION_TYPE_VESSEL_BYOP, operator, null);
    self.deleteEDIInwardXlation(BoatCode, XLATION_TYPE_VESSEL_BYOP, operator, null);
   
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

    // Delete required voyages and vessels
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
 
	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);
	self.assertIsDeleted(vessel);
    
    //Delete the Carrier and Translation
    self.deleteEDIOutwardXlation(CarrierCodeTr, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteEDIInwardXlation(CarrierCode, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteCarrier(CarrierCode);
    carrier := self.getCarrier(CarrierCode);
    self.assertIsDeleted(carrier);

	
	// Delete the cargo - this should have already been done if on the voyage, 
    // but just in case some other test is using the same IDs, delete anyway
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
//	self.deleteContainer(ContainerName2);
//	container2 := self.getTrackedItem(ContainerName2).CM_Container;
//	self.assertIsDeleted(container2);
    
	// Now create the required voyages and vessels
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	
	bs := self.addBlockStack(BlockStackName, 3, 500);
	self.assertNotNull(bs);

	voyage1 := self.addVoyageWithInwardCode(VoyageName1, 
                                            null,
											BoatCode,
											TestOperator, 
											self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');

    // Now add the edi data translations for the vessels and voyages
    self.createEDIXlation(BoatCodeTrans, BoatCode,    XLATION_TYPE_VESSEL_BYOP,    true, operator, null );
    
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Chassis];
	self.deleteCargo(Chassis1, cargoType);		// 13/05/2011 cnwmh5
	tt := self.addTrailerType(TrailerType, TrailerType, cargoType, 500, 1, 50, 30000, 13000,null,null,null);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers, 1);

	self.deleteContainer(ContainerName1);
	self.deleteVehicle(Vehicle1);	
	vvr := self.gateInTrailerAndContainer(Vehicle1, Chassis1, ContainerName1, tt.code, "2200", operator.code, "", dualGate);
	self.assertNotNull(vvr);
	truck := self.getTerminal.vehicles[Vehicle1, null];
	self.assertNotNull(truck);
	chassis1 := truck.locationsController.allTrackedItemsById[Chassis1, cargoType.id].CM_TILC;
	self.assertNotNull(chassis1);
	chassis1 := vvr.myInCMGTE_Chassis.myTrackedItem.CM_TILC;
	self.assertNotNull(chassis1);
	self.assertEqual(chassis1.myPrimaryActualLocation, truck.locationsController); 
	tiTrans := chassis1.getLastTransOfType(TRANS_TYPE_REC_ROAD);
	self.assertNotNull(tiTrans);
	
	self.moveVehicleToLane(vvr.vehicle, gateArea, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(gateArea, 1));
	self.moveVehicleToYard(vvr.vehicle);
	self.moveQueuedCargo(vvr.myInCMGTE_Chassis.myYardRequest.allWorkListEntries.first);

	self.deleteCargo(Chassis2, cargoType);		// 13/05/2011 cnwmh5
	chassis2 := self.addTrailerAtLocation(Chassis2, cargoType, tt, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs.myLocationsController).CM_TILC;
	self.assertNotNull(chassis2);
	self.assertEqual(chassis2.myPrimaryActualLocation, bs.myLocationsController);
	beginTransaction;
	foreach gateEntity in vvr.allGateEntities do
		gateEntity.setMyVehicleVisit(null);
	endforeach;
	commitTransaction;
/*	container2 := self.addContainerForExport(ContainerName2,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR34159",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort */
//	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
//	self.assertNotNullMsg(container2, tempStr);
//	self.move(container2, bs);

	vvr := self.gateOutTrailerAndContainer(Vehicle1, chassis2, null, dualGate, vvr);
	truck := self.getTerminal.vehicles[Vehicle1, null];
	self.assertNotNull(truck);
	self.moveVehicleToLane(vvr.vehicle, gateArea, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(gateArea, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	foreach gateEntity in vvr.allGateEntities do
		self.moveQueuedCargo(gateEntity.myYardRequest.allWorkListEntries.first);
	endforeach;
	self.assertEqual(chassis2.myPrimaryActualLocation, truck.locationsController); 
	
	self.roadExit(vvr);
	self.assertEqual(chassis2.state, TI_STATE_OFFSITE);
	tiTrans := chassis2.getLastTransOfType(TRANS_TYPE_REL_ROAD);
	self.assertNotNull(tiTrans);
    
	// Add the Carrier &amp; Translation
	create emailCarrierAddresses transient;
    carrier := self.addCarrier(CarrierCode, "A Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
    self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
    self.createEDIXlation(CarrierCodeTr, CarrierCode,    XLATION_TYPE_CARRIER_BYOP,    true, operator, null );

	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "JAXT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	lRegisteredCargoTypes.add(TI_CargoType_Chassis);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["ICL Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "JAXT0", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	if camProtocol &lt;&gt; null then
	beginTransaction;
	camProtocol.setIncludeChassis(true);
	commitTransaction;
	endif;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
   
	count := 0;
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		count := count + 1;
	endforeach;
	
	create strArray transient;
	strArray.add("UNB+UNOA:2+UT+REP+");	//Partial Comparison
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CN+"&amp;ContainerName1&amp;"+2200:102:5+++4'");
	strArray.add("DTM+7:");	//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:2000'");
	strArray.add("DAM+1+0'");
	strArray.add("TDT+1++3++DOUG+++"&amp;Vehicle1&amp;"'");
	strArray.add("EQD+CH+"&amp;Chassis1&amp;"+:102:5+++4'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+15+1'");
	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+2+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CH+"&amp;Chassis2&amp;"+:102:5+++4'");
	strArray.add("RFF+BN:");	//Partial Comparison
	strArray.add("DTM+7:");	//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("TDT+1++3++DOUG+++"&amp;Vehicle1&amp;"'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+2'");
	strArray.add("UNZ+2+0'");
    
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete objArray;
	delete strArray;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoPennICLPackComplete" id="f3316e9c-f278-48bb-83b2-e5d9b6b6c07e">
        <source>tCamCodecoPennICLPackComplete();
// cnwrs1
// 06 Jun 20	cnwrs1	Par34344 - Create ICL Codeco message
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR34344';				// all upper case!
	BoatName		= 'VSPAR34344';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
	BlockStackName	= 'BS34344';
	CamGroup = "P34344";
	CamProtocol = "PAR34344";
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	lRegisteredCargoTypes : IntegerArray;
//	time : Time;
	transObj : CM_TITransaction;
	time1 : String;
	time2 : String;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR34344",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_PackComplete), null);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["ICL Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, true, true, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
// PAR 35025	strArray.add("BGM+36+1+9'");
	strArray.add("BGM+35+1+9'"); // PAR 35025
// PAR 35025		strArray.add("TDT+20++1+++++:146::'");
	strArray.add("TDT+20+VYPAR34344+1+++++:146::VSPAR34344'"); // PAR 35025
// PAR 35025	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
// PAR 35025	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'"); // FULL
	strArray.add("RFF+BN:PAR34344'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("DAM+1+0'"); //cnwma1 21/07/2016 TFS 2217
	strArray.add("CNT+16:1'");
// PAR 35025		strArray.add("UNT+13+1'");
	strArray.add("UNT+13+1'"); //cnwma1 21/07/2016 TFS 2217
	strArray.add("UNZ+1+0'"); // PAR 35025
	
	
	/* PAR 35025
	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+2+9'");
	strArray.add("TDT+20+VYPAR34344+1+++++:146::VSPAR34344'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR34344'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+2'");
	strArray.add("UNZ+2+0'");

*/	
 	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
//		if idx = 10 then
//			time1 := tempStr[7:12];
//		elseif idx = 25 then
//			time2 := tempStr[7:12];
//		endif;
	endforeach;


epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoStatus_PackComplete" id="67817732-fb24-451b-a4f7-00c00cc15801">
        <source>tCamCodecoStatus_PackComplete();
//
//12 July 2017	jlgrs1	TFS 4465 SNO standard Codedo/Coarri
//
constants
	VoyageName		= 'VYPAR30360';				// all upper case!
	BoatName		= 'VSPAR30360';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
	BlockStackName	= 'BS30360';
	CamGroup = "P30360";
	CamProtocol = "PAR30360";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	transObj : CM_TITransaction;
	time1 : String;
	time2 : String;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR30360",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_PackComplete), null);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, true, true, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	beginTransaction;
	camProtocol.setPackUnpackStatusChange(true);
	commitTransaction;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
//return;
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+999+1+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+12+1'");
	strArray.add("UNZ+1+0'");

	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);

	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
		if idx = 10 then
			time1 := tempStr[7:12];
		elseif idx = 25 then
			time2 := tempStr[7:12];
		endif;
	endforeach;
//	if time1 &gt;= time2 then
//		self.assertEqual(time1, "the gate out MT must be before the gate in Full");
//	endif;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoStatus_UnpkComplete" id="9282f207-58ce-4285-a4bc-d4ae936d97eb">
        <source>tCamCodecoStatus_UnpkComplete();
//
//18 July 2017	jlgrs1	Initial creation
//
constants
	VoyageName		= 'VYPAR30360';				// all upper case!
	BoatName		= 'VSPAR30360';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
	BlockStackName	= 'BS30360';
	CamGroup = "P30360";
	CamProtocol = "PAR30360";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	transObj : CM_TITransaction;
	time1 : String;
	time2 : String;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										"PAR30360",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_UnpackComplete), null);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_UnpackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, true, true, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	beginTransaction;
	camProtocol.setPackUnpackStatusChange(true);
	commitTransaction;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+999+1+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+12+1'");
	strArray.add("UNZ+1+0'");
	

	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
		if idx = 10 then
			time1 := tempStr[7:12];
		elseif idx = 23 then
			time2 := tempStr[7:12];
		endif;
	endforeach;
	if time1 &lt;= time2 then
		self.assertEqual(time1, "the gate out Full must be before the gate in MT");
	endif;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoSubTermOperChg" id="f0ef5c7c-27ea-4a04-902a-c14228fd9aee">
        <source>tCamCodecoSubTermOperChg();
// cnwrs1

// Par 27289 - 
// If a cam protocol has re process operator changes turned on and sub terminal processing on if the  
// last receive transaction is a sub terminal receive then the cams processing fails.
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR27289';				// all upper case!
	BoatName		= 'VSPAR27289';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'MSL';
//	BlockStackName	= 'BS27289';
	CamGroup = "P27289";
	CamProtocol = "PAR27289";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	subTerminal : CM_SubTerminal;
	subTerminalDepot : CM_SubTerminal;
	setDateTime : TimeStamp;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	create objArray transient;
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	operator := self.getOperator("MSK");
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern), null);
	objArray.add(transObj);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Depot_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;
	setDateTime := app.actualTimeServer;//	startDateTime.addHours(-1);
	beginTransaction;
	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminal.name, subTerminalDepot);
	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::dateTime.name, setDateTime);
	commitTransaction;
	operator := self.getOperator(TestOperator);
//	container.setMyOperator(operator);
	self.opts.purge;
	self.opts.addAssoc(CM_TrackedItem::operatorCode.name, TestOperator);
	self.updateTI(container);
	self.assertEqual(container.myOperator, operator);
//	beginTransaction;
//	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_EditOperator));
//	commitTransaction;
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveDepot).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseDepot).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, true, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR27289+1+++++:146::VSPAR27289'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+12+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoSubTerm_DepotInt" id="a42fcc03-d8b7-47c5-83ae-85d9c66fc66b">
        <source>tCamCodecoSubTerm_DepotInt();
// cnwrs1
// par 26712 Test subtermibnal Depot receive internal produced the right Codeco
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//08/09/2016    cnwma1	TFS #2596:PNL- Delay on CODECO messages not working
// 14 Dec 2016	cnwrs1	TFS #3086 Delay for Codeco not working correctly
constants
	VoyageName		= 'VYPAR26712';				// all upper case!
	BoatName		= 'VSPAR26712';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'MSL';
//	BlockStackName	= 'BS26712';
	CamGroup = "P26712";
	CamProtocol = "PAR26712";
vars
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	now : TimeStamp;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	subTerminal : CM_SubTerminal;
	subTerminalDepot : CM_SubTerminal;
	sealType : CM_SealType;
	strArray : StringArray;
	str : String;
	lRegisteredCargoTypes : IntegerArray;
	theLines : HugeStringArray;
	checkTime : Time;	//09 Sep 2015	NDL	Par 36876
	runDateTime : TimeStamp;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	create objArray transient;
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	sealType := app.myRoot.allSealTypes["SHIP"];
	beginTransaction;
	container.setSealNumberValueDirect(sealType,"MSC7489118", now);
	sealType := app.myRoot.allSealTypes["CUST"];
	container.setSealNumberValueDirect(sealType,"123123", now);
	commitTransaction;
	beginTransaction;
	container.setSealNumberValueDirect(sealType,"", now);
	commitTransaction;
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern), null);
	checkTime := transObj.dateTime.Time.cnEcAddMinutes(1);	//09 Sep 2015	NDL	Par 36876
	objArray.add(transObj);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Depot_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;
	beginTransaction;
	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminal.name, subTerminalDepot);
//	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminalFrom.name, subTerminalFrom);
	commitTransaction;
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveDepot).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseDepot).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
//	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	
	self.opts.purge();	//09 Sep 2015	NDL	Par 36876
	self.opts.addAssoc("DelayMins",1);	//09 Sep 2015	NDL	Par 36876
	checkTime := transObj.camsTimeStamp.Time.cnEcAddMinutes(1);	// not now. //09 Sep 2015	NDL	Par 36876
	
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,  
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, false, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	camTaskHistory.rawDataToHSA(theLines);

	self.assertNotNull(camTaskHistory);
	create strArray transient;
	strArray.add("UNB+UNOA:2+NZCHC+");	//par 28928 test Depot Sender Code
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR26712+1+++++:146::VSPAR26712'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+12+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
		//09 Sep 2015	NDL	Par 36876
		if tempStr[1:3] = "DTM" then
			//self.assertTrueMsg( checkTime.format("HHmm") = tempStr[15:4], "Expected DTM time value to be 1 minute later than the transaction time. "&amp;checkTime.String&amp;' '&amp;checkTime.format("HHmm")&amp;' &lt;&gt; '&amp;tempStr[15:4]); //08/09/2016 cnwma1 TFS#2596
			
			self.assertTrueMsg( checkTime.addMinutes(1).format("HHmm") = tempStr[15:4], "Expected DTM time value to be 1 minute later than the transaction time. "&amp;checkTime.String&amp;' '&amp;checkTime.format("HHmm")&amp;' &lt;&gt; '&amp;tempStr[15:4]); //08/09/2016 cnwma1 TFS#2596
		endif;
	endforeach;
	
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoSubTerm_DepotInt2" id="854550cd-c15b-4639-8c5e-9d32c2f6c3e1">
        <source>tCamCodecoSubTerm_DepotInt2();
// cnwrs1
// par 29144 Test subtermibnal Depot receive internal produced the right Codeco
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR29144';				// all upper case!
	BoatName		= 'VSPAR29144';
	ContainerName	= 'PARC1230901';
	TestOperator	= 'MSC';
//	BlockStackName	= 'BS29144';
	CamGroup = "P29144";
	CamProtocol = "PAR29144";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	now : TimeStamp;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	subTerminal : CM_SubTerminal;
	subTerminalDepot : CM_SubTerminal;
	sealType : CM_SealType;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
	voyArrDate : String;
	voyDepDate : String;
begin
	create theLines transient;
	self.setSubTerminalAreaDefined(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	create objArray transient;
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');
	
	// 08/01/2020 - jlgmh5 - get arrived / departed date
	if voyage.departedDT.date.isValid() then
		voyDepDate := voyage.departedDT.date.longYearEDI() &amp; voyage.departedDT.time.shortFormatEDI();
	endif;
	if voyage.arrivedDT.date.isValid then
		voyArrDate := voyage.arrivedDT.date.longYearEDI() &amp; voyage.arrivedDT.time.shortFormatEDI();
	endif;


	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	sealType := app.myRoot.allSealTypes["SHIP"];
	beginTransaction;
	container.setSealNumberValueDirect(sealType,"MSC7489118", now);
	commitTransaction;
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReleaseDepotShip), null);
	objArray.add(transObj);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Depot_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;
	beginTransaction;
	transObj.CM_SubTermReleaseDepotShip.setPropertyValue(CM_SubTermReleaseDepotShip::mySubTerminal.name, subTerminalDepot);
//	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminalFrom.name, subTerminalFrom);
	commitTransaction;
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotShip).asStringJMT);

	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["MSC Coarri"];

	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, true, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, false, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+UT+REP");	
	strArray.add("UNH+1+COARRI:D:95B:UN:SMDG16'");	
	strArray.add("BGM+46+1+9'");
	strArray.add("TDT+20+VYPAR29144+1+++++:146::VSPAR29144'");
	strArray.add("RFF+VON:VYPAR29144'");
	strArray.add("LOC+9+NZPOE:139:6'");
	//strArray.add("DTM+132:201");
	//strArray.add("DTM+133:201");
	strArray.add("DTM+132:" &amp; voyDepDate &amp; ":203'");			// 08/01/2020 jlgmh5 - Change to get departed date from voyage
	strArray.add("DTM+133:" &amp; voyArrDate &amp; ":203'");			// 08/01/2020 jlgmh5 - Change to get arrived date from voyage
	strArray.add("NAD+CA+SHIP:172:20'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230901+2200:102:5++2+4'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230901+AP01:102:5++2+4'");
	endif;
	strArray.add("DTM+20");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("NAD+CF+SHIP:172:20'");
//	strArray.add("EQD+CN+PARC1230901+2200:102:5++2+4'");
//	strArray.add("DTM+203:202");								// 08/01/2020 jlgmh5 - will fail when we get to 2030, but code to get is too complicated to replicate
//	strArray.add("LOC+9+NZPOE");
//	strArray.add("MEA+AAE+G+KGM:4000'");
//	strArray.add("NAD+CF+SHIP:172:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+15+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	self.setSubTerminalAreaDefined(true);
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoSubTerm_DepotInt3" id="7a2d14bc-34f6-4098-9a85-8ea81000b745">
        <source>tCamCodecoSubTerm_DepotInt3();
// cnwrs1
// par 26712 Test subtermibnal Depot receive internal produced the right Codeco
// same as tCamCodecoSubTerm_DepotInt but using Maesk Codeco protocl description
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR26712';				// all upper case!
	BoatName		= 'VSPAR26712';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'MSL';
//	BlockStackName	= 'BS26712';
	CamGroup = "P26712";
	CamProtocol = "PAR26712";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	now : TimeStamp;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	subTerminal : CM_SubTerminal;
	subTerminalDepot : CM_SubTerminal;
	sealType : CM_SealType;
	strArray : StringArray;
	str : String;
	sealTI : CM_SealTI;
	theLines : HugeStringArray;
begin
	create theLines transient;
	beginTransaction;
	app.myRoot.setClient(Client_PortOtago);		// Run all tests as JMT client
	commitTransaction;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	create objArray transient;
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
//	sealType := app.myRoot.allSealTypes["SHIP"];
	beginTransaction;
//	container.setSealNumberValueDirect(sealType,"MSC7489118", now);
	sealType := app.myRoot.allSealTypes["CUST"];
	container.setSealNumberValueDirect(sealType,"MSC7489118", now);
	commitTransaction;beginTransaction;
	sealTI := container.getSealTI(sealType);
	sealTI.allSealNums.clear;
	sealTI.allSealNums.add(null);
	sealTI.setPreviousSeal("MSC7489118");
	commitTransaction;
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern), null);
	objArray.add(transObj);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Depot_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;
	beginTransaction;
	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminal.name, subTerminalDepot);
//	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminalFrom.name, subTerminalFrom);
	commitTransaction;
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveDepot).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseDepot).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,  
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, false, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	create strArray transient;
	strArray.add("UNB+UNOA:2+NZCHC+");	//par 28928 test Depot Sender Code
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR26712+1+++++:146::VSPAR26712'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+SLS+NZCHC:172:20'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+12+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	beginTransaction;
	app.myRoot.setClient(Client_JadeMaster);		// Run all tests as JMT client
	commitTransaction;
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoSubTerm_DepotInt4" id="be87f894-a63b-4960-a5b1-cb7264bd6347">
        <source>tCamCodecoSubTerm_DepotInt4();
// cnwrs1
// par 29144 Test subtermibnal Depot receive internal produced the right Codeco
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR29144';				// all upper case!
	BoatName		= 'VSPAR29144';
	ContainerName	= 'PARC1230901';
	TestOperator	= 'MSC';
//	BlockStackName	= 'BS29144';
	CamGroup = "P29144";
	CamProtocol = "PAR29144";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	now : TimeStamp;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	subTerminal : CM_SubTerminal;
	subTerminalDepot : CM_SubTerminal;
	sealType : CM_SealType;
	strArray : StringArray;
	str : String;
	sealTI : CM_SealTI;
	theLines : HugeStringArray;
	voyArrDate : String;
	voyDepDate : String;
begin
	create theLines transient;
	self.setSubTerminalAreaDefined(false);
	beginTransaction;
	app.myRoot.setClient(Client_PortOtago);		// Run all tests as JMT client
	commitTransaction;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	create objArray transient;
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');
	
	// 08/01/2020 - jlgmh5 - get arrived / departed date
	if voyage.departedDT.date.isValid() then
		voyDepDate := voyage.departedDT.date.longYearEDI() &amp; voyage.departedDT.time.shortFormatEDI();
	endif;
	if voyage.arrivedDT.date.isValid then
		voyArrDate := voyage.arrivedDT.date.longYearEDI() &amp; voyage.arrivedDT.time.shortFormatEDI();
	endif;

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	sealType := app.myRoot.allSealTypes["CUST"];
	beginTransaction;
	container.setSealNumberValueDirect(sealType,"MSC7489118", now);
	commitTransaction;beginTransaction;
	sealTI := container.getSealTI(sealType);
	sealTI.allSealNums.clear;
	sealTI.allSealNums.add(null);
	sealTI.setPreviousSeal("MSC7489118");
	commitTransaction;
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReleaseDepotShip), null);
	objArray.add(transObj);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Depot_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;
	beginTransaction;
	transObj.CM_SubTermReleaseDepotShip.setPropertyValue(CM_SubTermReleaseDepotShip::mySubTerminal.name, subTerminalDepot);
//	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminalFrom.name, subTerminalFrom);
	commitTransaction;
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotShip).asStringJMT);

	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Coarri"];

	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, true, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, false, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+UT+REP");	
	strArray.add("UNH+1+COARRI:D:95B:UN:SMDG16'");	
	strArray.add("BGM+46+1+9'");
	strArray.add("TDT+20+VYPAR29144+1+++++:146::VSPAR29144'");
	strArray.add("RFF+VON:VYPAR29144'");
	strArray.add("LOC+9+NZPOE:139:6'");
	//strArray.add("DTM+132:201");
	//strArray.add("DTM+133:201");
	strArray.add("DTM+132:" &amp; voyDepDate &amp; ":203'");			// 08/01/2020 jlgmh5 - Change to get departed date from voyage
	strArray.add("DTM+133:" &amp; voyArrDate &amp; ":203'");			// 08/01/2020 jlgmh5 - Change to get arrived date from voyage
	strArray.add("NAD+CA+SHIP:172:20'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230901+2200:102:5++2+5'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230901+AP01:102:5++2+5'");
	endif;
	strArray.add("DTM+20");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	if app.isRunningInDMAST() then
		strArray.add("NAD+CF+MSC:172:20'");
	elseif app.isRunningInWMAST() then
		strArray.add("NAD+CF+MEDI:172:20'");
	endif;
//	strArray.add("EQD+CN+PARC1230901+2200:102:5++2+5'");
//	strArray.add("DTM+203:202");								// 08/01/2020 jlgmh5 - will fail when we get to 2030, but code to get is too complicated to replicate
//	strArray.add("LOC+9+NZPOE");
//	strArray.add("MEA+AAE+G+KGM:4000'");
//	strArray.add("NAD+CF+MSC:172:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+15+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	self.setSubTerminalAreaDefined(true);
	beginTransaction;
	app.myRoot.setClient(Client_JadeMaster);		// Run all tests as JMT client
	commitTransaction;
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoSubTerm_MarineExp" id="1ddd99dd-19ef-462e-94c9-49044f1526f0">
        <source>tCamCodecoSubTerm_MarineExp();
// cnwrs1
// par 28961 Test subtermibnal Marine gate in export produced the right Codeco
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR28961';				// all upper case!
	BoatName		= 'VSPAR28961';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'MSL';
//	BlockStackName	= 'BS28961';
	CamGroup = "P28961";
	CamProtocol = "PAR28961";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	now : TimeStamp;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	subTerminal : CM_SubTerminal;
	subTerminalDepot : CM_SubTerminal;
	sealType : CM_SealType;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	create objArray transient;
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	sealType := app.myRoot.allSealTypes["SHIP"];
	beginTransaction;
	container.setSealNumberValueDirect(sealType,"MSC7489118", now);
	commitTransaction;
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReceiveMarineRoad), null);
	objArray.add(transObj);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Marine_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;
	beginTransaction;
	transObj.CM_SubTerminalReceiveMarine.setPropertyValue(CM_SubTerminalReceiveMarine::mySubTerminal.name, subTerminalDepot);
//	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminalFrom.name, subTerminalFrom);
	commitTransaction;
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveMarineRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveDepot).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseDepot).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, false, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	create strArray transient;
	strArray.add("UNB+UNOA:2+UT+REP");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR28961+1+++++:146::VSPAR28961'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+12+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoSubTerm_MarineExp2" id="fb9abd37-ae2f-4226-a099-2067c62caf7d">
        <source>tCamCodecoSubTerm_MarineExp2();
// cnwrs1
// par 28961 Test subtermibnal Marine gate in export produced the right Codeco
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR28961';				// all upper case!
	BoatName		= 'VSPAR28961';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'MSL';
//	BlockStackName	= 'BS28961';
	CamGroup = "P28961";
	CamProtocol = "PAR28961";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	now : TimeStamp;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	subTerminal : CM_SubTerminal;
	subTerminalDepot : CM_SubTerminal;
	sealType : CM_SealType;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	create objArray transient;
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	sealType := app.myRoot.allSealTypes["SHIP"];
	beginTransaction;
	container.setSealNumberValueDirect(sealType,"MSC7489118", now);
	commitTransaction;
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReleaseMarineIntern), null);
	objArray.add(transObj);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Marine_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;
	beginTransaction;
	transObj.CM_SubTermReleaseMarineIntern.setPropertyValue(CM_SubTermReleaseMarineIntern::mySubTerminal.name, subTerminalDepot);
//	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminalFrom.name, subTerminalFrom);
	commitTransaction;
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseMarineIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveDepot).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseDepot).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	self.opts.purge();	//09 Sep 2015	NDL	Par 36876
	self.opts.addAssoc("DelayMins",5);	//09 Sep 2015	NDL	Par 36876
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, false, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	create strArray transient;
	strArray.add("UNB+UNOA:2+UT+REP");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR28961+1+++++:146::VSPAR28961'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+12+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
//		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoSubTerm_RecNSN" id="0e98f4f5-8329-4055-9362-a1455c4b1136">
        <source>tCamCodecoSubTerm_RecNSN();
//
//27 Apr 2018	jlgndl1	TFS 37406 standard Codedo/Coarri
//
constants
	VoyageName		= 'VYPAR30360';				// all upper case!
	BoatName		= 'VSPAR30360';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
	CamGroup = "P30360";
	CamProtocol = "TFS37406";
vars

	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	startDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory1 : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	transObj1 : CM_TITransaction;
	transObj2 : CM_TITransaction;
	time1 : Time;
	time2 : Time;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
	camTaskHistory2 : CM_CamTaskHistory;
	mins : Integer;
	tiTrx : CM_TITransaction;
	infoSent : CM_InfoEDISent;
	order : Integer;
	subTerminal : CM_SubTerminal;
	subTerminalDepot : CM_SubTerminal;
begin

	create theLines transient;
	startDateTime := app.actualTimeServer;

	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR30360",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);

	transObj1 := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern), null);
	transObj2 := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern), null);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Depot_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;
	beginTransaction;
	transObj1.CM_SubTermReleaseDepotIntern.setPropertyValue(CM_SubTermReleaseDepotIntern::mySubTerminal.name, subTerminalDepot);
	transObj2.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminal.name, subTerminalDepot);
	commitTransaction;
	
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT);
	
	create scheduleTimes transient;
	scheduleTimes.add( startDateTime.time );
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, true, false, false,
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false,
									   false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	beginTransaction;
	camProtocol.setPropertyValue("debug", true);
	commitTransaction;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
	
	beginTransaction;
	camProtocol.setSingleContainerPerUNB(true);
	commitTransaction;
	
	app.setIsBackGroundApp (true);
	self.runCamsNow(startDateTime, camProtocol);

	//13 Aug 2020	NDL	TFS 49876
	//Check the CM_InfoEDISent to ensure the sequence of the messages / transactions match, i.e. Release s/be '1'
	// and Receive s/be '2'.
	foreach tiTrx in container.allTransactions do
		if tiTrx.isKindOf( CM_InfoEDISent ) then
			infoSent := tiTrx.CM_InfoEDISent;
			order := infoSent.getCamSeqNumber();
			if infoSent.myOtherTransaction = transObj1 then
				self.assertTrueMsg( order = 1, "First Traansaction Not the first sent");
			elseif infoSent.myOtherTransaction = transObj2 then
				self.assertTrueMsg( order = 2, "Second Traansaction Not the second sent");
			endif;
		endif;
	endforeach;

	camTaskHistory1 := camProtocol.taskHistoryByProtocolSeq.getAtKey(camProtocol,1); // I.e. The first one processed being the Release sub term trx
	self.assertNotNull(camTaskHistory1);

	//"UNB+UNOA:2+UT+REP+180430:1100+1"

	theLines.clear();
	camTaskHistory1.rawDataToHSA(theLines);
	self.assertEqual(theLines.size, 15);
	
	foreach tempStr in theLines do
		if tempStr[1:3] = 'UNB' then
			time1.setTime( tempStr[26:2].Integer,tempStr[28:2].Integer,00,000);
			break;
		endif;
	endforeach;
	
	camTaskHistory2 := camProtocol.taskHistoryByProtocolSeq.getAtKey(camProtocol,2);	// I.e. The second one processed being the Receive sub term trx
	self.assertNotNull(camTaskHistory2);
	
	theLines.clear();
	camTaskHistory2.rawDataToHSA(theLines);
	self.assertEqual(theLines.size, 15);

	foreach tempStr in theLines do
		if tempStr[1:3] = 'UNB' then
			time2.setTime( tempStr[26:2].Integer,tempStr[28:2].Integer,00,000);
			break;
		endif;
	endforeach; 
	
	self.assertTrueMsg( time2 &gt;= time1, "Time for Receive Depot '" &amp; time2.String &amp; "' should be later than Release Depot '" &amp; time1.String &amp; "'" );
	
	mins := ( ( time2.hour * 60 ) + time2.minute ) - ( ( time1.hour * 60 ) + time1.minute );
	self.assertTrueMsg( mins = 1, "Time difference should be 1 minute.");

epilog

	app.setIsBackGroundApp (false);
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoTemp" id="faa95448-d482-47b1-a354-a4eec79cfd78">
        <source>tCamCodecoTemp();
// cnwrs1 old [par 16227]
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR16227';				// all upper case!
	BoatName		= 'VSPAR16227';
	ContainerName	= 'PARC1230002';
	TestOperator	= 'MSL';
	BlockStackName	= 'BS16227';
	CamGroup = "P16227";
	CamProtocol = "PAR16227";
vars
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	transObj : CM_TITransaction;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
	runDateTime : TimeStamp;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;

	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2232",					// ISOType is not needed
										"REEF",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	beginTransaction;
	container.setTemperature(-21.1);
	commitTransaction;
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
//	self.assertNotNull(voyage.myShipBlockStack);
//	self.move(container, voyage.myShipBlockStack);
	self.move(container, bs);
    transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_ReceiveRoad), startDateTime);
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false,  false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
	endDateTime := startDateTime.addMinutes(1);
	beginTransaction;
	camProtocol.setPropertyValue(CM_CamProtocol::tempLeadingZerosNoDecimal.name, false);
	commitTransaction;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
//	foreach tempStr in camTaskHistory.fileData do
//		write tempStr;
//	endforeach;
	idx := 0;
	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+"&amp;VoyageName&amp;"+1+++++:146::"&amp;BoatName&amp;"'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("GID+1'");
	strArray.add("TMP+2+-21.1:CEL'");
	strArray.add("SGP+"&amp;ContainerName&amp;"'");
	strArray.add("EQD+CN+"&amp;ContainerName&amp;"+2232:102:5++2+5'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+15+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;

	beginTransaction;
	camTaskHistory.erase(NORMAL_ERASE);
	camProtocol.setPropertyValue(CM_CamProtocol::tempLeadingZerosNoDecimal.name, true);
	commitTransaction;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
//	foreach tempStr in camTaskHistory.fileData do
//		write tempStr;
//	endforeach;
	idx := 0;
	strArray.clear();
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+"&amp;VoyageName&amp;"+1+++++:146::"&amp;BoatName&amp;"'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("GID+1'");
	strArray.add("TMP+2+021-:CEL'");
	strArray.add("SGP+"&amp;ContainerName&amp;"'");
	strArray.add("EQD+CN+"&amp;ContainerName&amp;"+2232:102:5++2+5'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+15+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodeco_PackComplete" id="f285b355-2cef-456d-839a-0f910b639413">
        <source>tCamCodeco_PackComplete();
// cnwrs1
// par 30360
// 09/08/2013	cnwcs5	par 32148 - check times are not equal
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR30360';				// all upper case!
	BoatName		= 'VSPAR30360';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
	BlockStackName	= 'BS30360';
	CamGroup = "P30360";
	CamProtocol = "PAR30360";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	transObj : CM_TITransaction;
	time1 : String;
	time2 : String;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR30360",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_PackComplete), null);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, true, true, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
//return;
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+1'");
	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+36+2+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+2'");
	strArray.add("UNZ+2+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
		if idx = 10 then
			time1 := tempStr[7:12];
		elseif idx = 25 then
			time2 := tempStr[7:12];
		endif;
	endforeach;
	if time1 &gt;= time2 then
		self.assertEqual(time1, "the gate out MT must be before the gate in Full");
	endif;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodeco_UnpackComplete" id="16e11c39-717c-40a2-8cc6-65f8d71d92da">
        <source>tCamCodeco_UnpackComplete();
// cnwrs1
// par 30360
// 09/08/2013	cnwcs5	par 32148 - check times are not equal
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//17/06/2016    cnwma1  TFS# 2159:CPL - Wrong Header for CODECO D.95B
constants
	VoyageName		= 'VYPAR30360';				// all upper case!
	BoatName		= 'VSPAR30360';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
	BlockStackName	= 'BS30360';
	CamGroup = "P30360";
	CamProtocol = "PAR30360";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	transObj : CM_TITransaction;
	time1 : String;
	time2 : String;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										"PAR30360",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_UnpackComplete), null);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_UnpackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, true, true, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+1'");
	//strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+36+2+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++3+5'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+2'");
	strArray.add("UNZ+2+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
		if idx = 10 then
			time1 := tempStr[7:12];
		elseif idx = 23 then
			time2 := tempStr[7:12];
		endif;
	endforeach;
	if time1 &lt;= time2 then
		self.assertEqual(time1, "the gate out Full must be before the gate in MT");
	endif;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
