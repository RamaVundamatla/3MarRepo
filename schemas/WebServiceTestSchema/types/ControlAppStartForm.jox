/*

Purpose:			


Return Value:		


Date		Who		Reason
28 October 2004	cnwkpd1	Initial creation

*/

vars

begin
	beginTransaction;
	myControl.state := TestAppControl.STATE_TERMINATE;
	commitTransaction;


epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="9b9a2b7c-3f3b-4566-9f72-d596abc013f2">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 Oct 2004	cnwkpd1	Initial creation

*/

vars
	ws				: JadeWebServiceConsumer;
	url				: String;
	
begin
	myControl := TestAppControl.firstInstance;
	
	if myControl = null then
		beginTransaction;
		create myControl;
		commitTransaction;
	endif;
	
	create ws as app.getFirstConsumerClass transient;
	url := ws.getEndpointURL;
		
	txtWebURL.text := url[1:url.pos("&amp;", 1) - 1];
	

epilog
	delete ws;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMaximumConnections" id="7fcb41e5-e258-46d6-98e2-d640be880c24">
        <source>setupMaximumConnections();

/*

Purpose:			Setup the maimum concurrent connections available to the consumer
					to allow more than the standard 2


Return Value:		None


Date		Who		Reason
13 Dec 2007	cnwkpd1	Initial creation

*/

constants
	WebOptions		= "WebOptions";
	MaxConnName		= "MaximumConnections";
	Dummy			= "Dummy";
	
vars
	iniFileName		: String;
	maxConn			: String;
	
begin
	iniFileName := app.getIniFileNameAppServer;
	
	// Only set the value to the new default if it is not already present
	if app.getProfileStringAppServer(iniFileName, WebOptions, MaxConnName, Dummy) = Dummy then
		app.setProfileStringAppServer(iniFileName, WebOptions, MaxConnName, "10");
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
</GUIClass>
