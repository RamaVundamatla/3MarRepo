    <JadeMethod name="resetTerminalAreaType" id="bb68270c-261d-46c2-af42-8de661913234">
        <source>resetTerminalAreaType(pConstant : Constant; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     8 Aug 2002 by cnwsb1
//
// Purpose:     This is used as a "callBack" method from "resetTerminalAreaTypes".
//				There are no references to this method BUT it is still called
//
// Parameters:  The constant which should be of type TerminalAreaTypeConstants
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 jun 2008	cnwrs2/		PAR #16753 - Ensure old Genral Cargo Area type
//				cnwkpd1		is not recreated following migration to new type
// 01/06/2022	navcs2		Bug 53591: CUX - 75768 Error when trying to create a "Trailer Area"
// ---------------------------------------------------------------------------

vars
	text					: String;
	name					: String;
	proxyTerminalAreaType	: CM_TerminalAreaType;
	realTerminalAreaType	: CM_TerminalAreaType;
	
begin
	if pConstant.valueAsInteger &lt;= TA_TYPE_NULL or
	   pConstant.valueAsInteger &gt; TA_TYPE_MAX then
	   	return;
	endif;

	text := pConstant.text;
	
	name 	  := text.cnEcGetTagValueOfName('Name');
	if name = null and pConstant.valueAsInteger = TA_TYPE_MAX then
		// The maximum product type is not created.
		return;
	endif;
	if name = null then
		app.raiseUnexpectedProgramError(class.name, method.name,
				'Invalid format for text for terminal area type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;

	realTerminalAreaType := self.allTerminalAreaTypes[pConstant.valueAsInteger];

	if realTerminalAreaType = null then
		//epr 15/7/13 #31985
		// 01/06/2022 navcs2 Bug 53591f
		/*
		if pConstant.valueAsInteger = TA_TYPE_TRAILER then
			return;
		endif;
		**/
		
		// treat as a create
		create proxyTerminalAreaType transient;
		proxyTerminalAreaType.setProxyFromXML(pConstant.valueAsInteger, text, self);
		app.myUtilityCA.utlCreateTerminalAreaType(proxyTerminalAreaType, realTerminalAreaType, _passport);
	else
		proxyTerminalAreaType := app.createUpdateProxy(realTerminalAreaType).CM_TerminalAreaType;
		proxyTerminalAreaType.setProxyFromXML(pConstant.valueAsInteger, text, self);
		app.myUtilityUA.utlUpdateTerminalAreaType(proxyTerminalAreaType, _passport);
	endif;

epilog
	delete proxyTerminalAreaType;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
