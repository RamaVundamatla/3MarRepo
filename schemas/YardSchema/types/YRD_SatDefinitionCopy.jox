    <JadeMethod name="doOK" id="e4395de2-7691-4a05-a434-e471e205fb7f">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2010	cnwer1	Initial creation

*/

vars
	viewName : String;
	user 	: CM_User;
begin

	viewName:=self.getViewName();
	if self.optPrivate.value then
		if self.cmbUser.listIndex &gt; 0 then
			user:=self.cmbUser.itemObject[self.cmbUser.listIndex].CM_User;
		endif;
		if user = null then
		//	app.raiseCMException1(REQUIRED_FIELD,"User",null,null);
			app.raiseCMException(Input_required_field_Usr,null,null); // cnwdb2	PAR 35364
		endif;
	endif;
	
	self.myTAViewInterface.copyView(self.myTerminalAreaView,viewName,user);
	if app.myPassport.trxCompletedOK then
		inheritMethod();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enablePrivate" id="d94224ad-fbe1-42da-a952-3ec322133ebf">
        <source>enablePrivate(_enable : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars

begin
	self.optPrivate.enabled:=_enable;
	self.cmbUser.enabled:=_enable;
	self.lblUser.enabled:=_enable;
epilog

end;</source>
        <access>protected</access>
