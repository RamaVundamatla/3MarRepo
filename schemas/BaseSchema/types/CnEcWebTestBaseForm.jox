    <JadeMethod name="doClearTestResults" id="da0bad9b-e0d2-40ba-9ca1-2483c69f0ea5">
        <updating/>
        <source>doClearTestResults(pWebTest:CnEcWebTest; pTestMessage:CnEcWebTestMessage):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 June 2000 by cnwdad2
//
// Purpose:		Purges all Test Message Results for either a whole Web Test, or
//				for an individual Test Mesage.
//
// Parameters:	pWebTest (CnEcWebTest) - The Web Test whose results to delete.
//				pTestMessage (CnEcWebTestMessage) - A Web Test Message whose results to delete.
//
// Returns:		Boolean - Flag to indicate whether an error message was raised.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTestMessages	: CnEcWebTestMessageDict;

begin
	create webTestMessages transient;

	if pWebTest &lt;&gt; null then
		pWebTest.allMessagesToTest.copy(webTestMessages);
	elseif pTestMessage &lt;&gt; null then
		webTestMessages.add(pTestMessage);
	endif;

	if (webTestMessages.cnEcIsNotEmpty()) then
		self.aError	:=	self.aMyTA.valWebTestResultsPurge(webTestMessages);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxWebTestResultsPurge(webTestMessages);
		endif;
	endif;

	return self.doShowError();
epilog
	delete webTestMessages;
end;</source>
        <access>protected</access>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
        <Parameter name="pTestMessage" type="CnEcWebTestMessage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnableButtonsClientTests" id="682c055d-c52f-4734-a104-ee63487cca20">
        <source>doEnableButtonsClientTests() protected;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Purpose:		Enables/Disables all neccessary controls depending upon whether a
//				a Web Test for the Remote Test Clients has been selected.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isTestSelected	: Boolean;
	isThinClients	: Boolean;

begin
	isTestSelected	:=	(lstClientTest.listIndex &lt;&gt; CNEC_NULL_INDEX);
	isThinClients	:=	chkClientIsThin.value;

	btnClientStart.enabled		:=	isTestSelected;
	btnClientStop.enabled		:=	isTestSelected;

	btnClientSpawn.enabled		:=	(txtClientCopies.text.trimBlanks.Integer &gt; 0);
	btnClientKillCl.enabled		:=	true;
	btnClientKillSl.enabled		:=	true;

	txtClientCopies.readOnly	:=	false;
	txtClientAppSPort.readOnly	:=	(not isThinClients);
	txtClientPathBin.readOnly	:=	isThinClients;
	btnClientBinBrows.enabled	:=	(not isThinClients);
	txtClientPathIni.readOnly	:=	isThinClients;
	btnClientIniBrows.enabled	:=	(not isThinClients);

	if txtClientAppSPort.readOnly then
		txtClientAppSPort.text	:=	null;
	endif;

//	txtClientAppSPort.text	:=	"61146";
end;</source>
        <access>protected</access>
    </JadeMethod>
