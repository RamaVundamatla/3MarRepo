    <JadeMethod name="getQuantityForMove" id="6566f9a3-3dd2-4952-8423-2b838295a116">
        <source>getQuantityForMove( _moveController : CMIF_MoveController input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	form : CMUI_MoveAmountForm;
	quantity : Integer;							

begin

	if _moveController = null then
		return false;
	endif;
	ti := _moveController.myTrackedItem;
	if ti = null then
		return false;
	endif;
	if not (ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti) then
		return false;
	endif;
	
	app.myMoveController := _moveController;
	
	create form transient;
	form.myTrackedItem := ti;
	form.targetLocation := _moveController.myToPrimaryLocation.getFullId;
	form.myAspaVVR := self.myVehicleVisitRecord;
	form.myAsapRelease := self.cmbRelease.listObject.CMGTE_Release;
		
	if form.showModal &lt;&gt; IDOK then
		return false;
	endif;
	
	if form.byQuantity then
		quantity := form.getQuantity;	
		_moveController.setWeight( _moveController.weight / _moveController.quantity * quantity);											
		_moveController.setQuantity( quantity);													
	else
		_moveController.setWeight( form.getWeightMovedKgs );
	endif;
	
	return true;

epilog

	app.myMoveController := null;

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelected" id="f7afcf7b-9df9-4b17-bb15-e5186cee1de7">
        <source>getSelected( _tiArray : CM_TIArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	start : Integer;
	index : Integer;
	ti : CM_TrackedItem;

begin

	_tiArray.clear();
	
	start := self.tblCargo.fixedRows + 1;
	
	if start &lt;= self.tblCargo.rows then
		foreach index in start to self.tblCargo.rows do
			if self.tblCargo.accessRow(index).selected then
				ti := self.tblCargo.accessRow(index).itemObject.CM_TrackedItem;
				if ti &lt;&gt; null then
					_tiArray.add( ti );
				endif;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
