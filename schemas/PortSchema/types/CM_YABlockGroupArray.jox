<CollClass name="CM_YABlockGroupArray" id="0d96b5e5-9fdc-4174-9dbe-d34f6689e4fc">
    <loadFactor>66</loadFactor>
    <memberType name="CM_YABlockGroup"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="auditIdDisplay" id="c3121178-43d4-4e09-ac1c-74826f89af3d">
        <source>auditIdDisplay() : String;
// ---------------------------------------------------------------------------
// Created:     May 2006 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	obj : CM_Object;
	rtnStr : String;
begin
	foreach obj in self do
		if rtnStr = null then
			rtnStr := obj.auditId();
		else
			rtnStr := rtnStr &amp; '::' &amp; obj.auditId();
		endif;
	endforeach;
	return rtnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGroupByName" id="173769c9-9642-4706-900d-fe3a148116ac">
        <source>getGroupByName(_groupName:String):CM_YABlockGroup;
// --------------------------------------------------------------------------------
// Created:		15 June 2006 by cnwdad1
//
// Purpose:		Returns a reference to a Block Group objects who's description
//				matches the specified name value.
//
// Parameters:	_groupName - The name of the Block Group to fetch.
//
// Returns:		A reference to the Block Group, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	groupObj	: CM_YABlockGroup;
	
begin
	foreach groupObj in self do
		if groupObj &lt;&gt; null and groupObj.description = _groupName then
			return groupObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_groupName" type="String"/>
        <ReturnType type="CM_YABlockGroup"/>
    </JadeMethod>
    <JadeMethod name="isNameUsed" id="bbb294d6-a1e2-4752-a992-f2443f021065">
        <source>isNameUsed(_groupName:String; _blockGroupObj:CM_YABlockGroup):Boolean;
// --------------------------------------------------------------------------------
// Created:		15 June 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Block Group
//				name is already being used.
//
// Parameters:	_groupName - The name to check for.
//				_blockGroupObj - A reference to the Block Group object being checked.
//
// Returns:		True if the name is already used, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	groupObj	: CM_YABlockGroup;
	
begin
	foreach groupObj in self do
		if groupObj.description = _groupName then
			if _blockGroupObj &lt;&gt; null and _blockGroupObj = groupObj then
				continue;
			endif;
			
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_groupName" type="String"/>
        <Parameter name="_blockGroupObj" type="CM_YABlockGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
