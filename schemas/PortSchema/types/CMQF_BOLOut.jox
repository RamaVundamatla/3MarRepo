<Class name="CMQF_BOLOut" id="86d5ad62-2b25-446b-9f00-43dd6fa79277">
    <superclass name="CMQF_BOL"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="4ced09e2-2a6e-49c7-971e-24d4d250fe40">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     
// ----------   ----------  --------------------------------------------------

vars

	bolColl 		: CM_BOLByTypeNumberDTDict;	
	bol				: CM_BOL;
	iter			: Iterator;
	op				: CM_Operator;
	opTerm			: CM_OperatorTerminal;
	terminal		: CM_Terminal;
	breakOut		: Boolean;
begin
	op := self.myOperator;
//	self.endDate.setTime
	foreach terminal in self.allTerminals do : terminalLoop
		if op = null then
			bolColl := terminal.allBOLsReleasedByTypeNumberDT;
		else
			opTerm := op.getOperatorTerminal(terminal, false);
			if opTerm = null then
				continue terminalLoop;
			endif;
			
			bolColl := opTerm.allBOLByTypeNumber;
		endif;
		
		if self.docketNumber &lt;&gt; null and self.bolType &lt;&gt; null then
			bol := bolColl.getAtKeyGeq(self.bolType, self.docketNumber, null);

			if bol &lt;&gt; null and 
			   bol.number = self.docketNumber and 
			   self.checkStatusIncludesObject(bol, _passport, breakOut) then
				_collection.add(bol);
				break;
			endif;
		else
			
			delete iter;
			iter := bolColl.createIterator;
			bolColl.startKeyGeq(self.bolType, null, null, iter);
			
			while iter.next(bol) do	
				if self.bolType &lt;&gt; null and bol.bolType &lt;&gt; self.bolType then
					continue terminalLoop;
				endif;
				
				if self.checkStatusIncludesObject(bol, _passport, breakOut) then
//				if self.includesObject(bol, _passport, breakOut) then
					_collection.add(bol);
					if breakOut then
						break terminalLoop;
					endif;
				endif;
			endwhile;
		endif;
	endforeach;


epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="8165d3b4-ed56-48ba-94c4-aee00ffa127c">
        <updating/>
        <source>includesObject(_bol: CM_BOL; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	rtnValue			: Boolean;
begin
	rtnValue := inheritMethod(_bol, _passport, _breakOut);

	if (not CM_BOLOut.hasInstance(_bol)) then
		rtnValue := false;
	endif;
	
	return rtnValue;

end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
