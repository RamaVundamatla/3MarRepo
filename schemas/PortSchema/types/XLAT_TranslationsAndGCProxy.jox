    </JadeMethod>
    <JadeMethod name="zBuildXmlForFormControlConstan" id="ecc0acaf-71f4-42a4-b49c-7b962a804a65">
        <source>zBuildXmlForFormControlConstan():String protected;

// Use this method when updating a global constant for a form control
// same as for other TranslatableString categories
// except that schema and form class name are needed

vars
	schemaName : String;
	className : String;
	controlName : String;
	controlProperty : String;
	xmlDoc : CM_XMLDocument;
	xmlElement : JadeXMLElement;
	xmlArray : JadeXMLElementArray;

begin
	if myConstant &lt;&gt; null then
		create xmlDoc transient;
		create xmlArray transient;
		
		xmlDoc.parseString(myConstant.text);
		xmlDoc.getElementsByTagName(XMLTag_Header, xmlArray);
		xmlElement := xmlArray[1];
	
		schemaName := xmlElement.getAttributeByName(XML_Tag_SchemaName).value;
		className := xmlElement.getAttributeByName(XML_Tag_FormClass).value;
		controlName := xmlElement.getAttributeByName(XML_Tag_ControlName).value;
		controlProperty := xmlElement.getAttributeByName(XML_Tag_ControlProperty).value;
	endif;

	return	XML_Version &amp; XMLTag_Header &amp; ' ' &amp;
			XML_Tag_SchemaName &amp; '="' &amp; schemaName &amp; '" ' &amp;
			XML_Tag_FormClass &amp; '="' &amp; className &amp; '" ' &amp;
			XML_Tag_ControlName &amp; '="' &amp; controlName &amp; '" ' &amp;
			XML_Tag_ControlProperty &amp; '="' &amp; controlProperty &amp;'"&gt;
' &amp; zzBuildXmlForLocaleText(false) &amp; '&lt;/' &amp; XMLTag_Header &amp; '&gt;';

epilog
	delete xmlDoc;
	delete xmlArray;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zBuildXmlForPermissions" id="4ad9be41-2204-48ed-9b87-b4e95ac0930b">
        <source>zBuildXmlForPermissions():String protected;

// use this method when creating or updating a global constant for literal text (error messages, translatable strings)

vars

begin
	
	return	XML_Version &amp; 
			XMLTag_Header &amp; '&gt;
' &amp; zzBuildXmlForLocaleText( myCategory.usesShortText) &amp; '&lt;/' &amp; XMLTag_Header &amp; '&gt;';
		   
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zBuildXmlForReportNames" id="27f3e43f-d68d-479a-866d-469f08a23a2d">
