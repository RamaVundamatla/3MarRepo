    <PrimAttribute name="wantsClearanceBeforeMove" id="e70ac144-98e2-4365-b0e7-64af02636ebe">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="calcWharfClearances" id="cab883f5-b2ce-49a6-a97c-3588e6e4c070">
        <source>calcWharfClearances(_foreClearance, _aftClearance : Decimal io;
							 _overlapsWharfSection : Boolean io; moveWharf : HMS_Wharf;
							 currentStartPosn, currentEndPosn, moveBowMark, moveSternMark : Decimal) : Boolean protected;
//--------------------------------------------------
// Created:	1 April 2005 By: cnwgd1
//--------------------------------------------------
// Also see CMIF_HMS_WorkingMovement::calc_Clearances()
//-------------------------------------------------
vars
	minClearance : Integer;
   	section : HMS_WharfSection;
   	distToSectionLimit : Decimal[12,2];
begin
/*	if isMovementTypeDeparture then // dh 25/3/2008 par 16146 added this first condition
		if getVoyageMovementPrevious().isLogicalBerth then 	// dh
			return true;									// dh
		endif;												// dh
	else													// dh
		if self.isLogicalBerth() then
			return true;
		endif;
	endif;													// dh end of changes for par 16146
	if moveWharf = null then
		return true;
	endif;
	
	minClearance := moveWharf.getHarbourReal.minimumClearance;
	
	_overlapsWharfSection := false;
	// Calc clearances to wharf section ends if less than current clearances
	foreach section in moveWharf.allWharfSections do
		// Check to see if ship is within any part of this section
		if currentEndPosn &gt;= section.startMeterage 
		and currentStartPosn &lt;= section.endMeterage then
			// Ship overlaps some portion of this section.
			// Calc clearances to sections ends
			// Ship is closer to start of wharf than the end of this section
			distToSectionLimit := (section.endMeterage)-currentEndPosn;
			if moveBowMark &gt; moveSternMark then
				if distToSectionLimit &lt; _foreClearance then
					// Bow closer to section end than stern and....
					// Section end is closer than current foreClearance - reduce clearance;
					_foreClearance := distToSectionLimit;
					_overlapsWharfSection := _foreClearance &lt; minClearance;			
				endif;
			else
				if distToSectionLimit &lt; _aftClearance then
					// Stern closer to section end than bow and....
					// Section end is closer than current aftClearance - reduce clearance;
					_aftClearance := distToSectionLimit;
					_overlapsWharfSection := _aftClearance &lt; minClearance;			
				endif;
			endif;
			// Ship is closer to end of wharf than section start
			distToSectionLimit := currentStartPosn-(section.startMeterage);
			if moveBowMark &gt; moveSternMark then
				if distToSectionLimit &lt; _aftClearance then
					// Stern closer to section start than bow and....
					// Section start is closer than current aftClearance - reduce clearance;
					_aftClearance := distToSectionLimit;
					_overlapsWharfSection := _aftClearance &lt; minClearance;			
				endif;
			else
				if distToSectionLimit &lt; _foreClearance then
					// Bow closer to section start than stern and....
					// Section start is closer than current foreClearance - reduce clearance;
					_foreClearance := distToSectionLimit;
					_overlapsWharfSection := _foreClearance &lt; minClearance;			
				endif;
			endif;
		endif;
	endforeach;

	return _overlapsWharfSection;
	*/
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_foreClearance" type="Decimal" usage="io"/>
        <Parameter name="_aftClearance" type="Decimal" usage="io"/>
        <Parameter name="_overlapsWharfSection" type="Boolean" usage="io"/>
        <Parameter name="moveWharf" type="HMS_Wharf"/>
        <Parameter name="currentStartPosn" type="Decimal"/>
        <Parameter name="currentEndPosn" type="Decimal"/>
        <Parameter name="moveBowMark" type="Decimal"/>
        <Parameter name="moveSternMark" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="calculateClearances" id="54b2c00d-3c52-4314-b6df-1c8253a1d48a">
        <source>calculateClearances(_object : Object; _movesToCheck : HMS_VoyageMovementByDateDict;
					 _foreClearance, _aftClearance : Decimal io;
					 _overlapsWharfSection : Boolean io);
//--------------------------------------------------
// Created:	1 April 2005 By: cnwgd1
//--------------------------------------------------
// Also see CMIF_HMS_WorkingMovement::calc_Clearances()
//-------------------------------------------------
vars
	movement,
	tempNextMoveToCheck,
	movePrev,				
   	tempNextMove:			HMS_VoyageMovement;
   	closestStartPosn,
   	closestEndPosn,
   	moveStartPosn,
   	moveEndPosn,
   	currentStartPosn,
   	currentEndPosn,
   	moveBowMark,
   	moveSternMark,
   	distToSectionLimit:		Decimal[12,2];
   	moveOccursDT,
	nextMoveDT,
   	berthArrivalDT,
   	berthDepartureDT:			TimeStamp;
   	tmpLockout:				HMS_WharfLockout;
   	changed:				Boolean;
   	moveWharf:				HMS_Wharf;
   	section:				HMS_WharfSection;   
	berth 					: HMS_Berth;
	isBackward 				: Boolean;
begin
/*
	// This method calculates the clearances for a ship for its entire duration at a particular berth
	// based the following supplied information	bowMark, sternMark, and the wharf that these marks apply to.

	getParametersFromObject(moveOccursDT, nextMoveDT, moveStartPosn, moveEndPosn, moveWharf, isBackward); 
	if moveWharf = null then
		// we can ignore the clearances
		return;
	endif;
	if allSurroundingMoves = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null allSurroundingMoves Dictionary');
		return;
	endif;
	
	// Initialise the closestStartPosn and closestEndPosn variables
	closestStartPosn := -1*(ClearanceUnbounded);
	closestEndPosn := ClearanceUnbounded;

	if nextMoveDT &lt;&gt; null then
		berthDepartureDT := nextMoveDT;
	else
		berthDepartureDT := moveOccursDT;
	endif;

	berthArrivalDT := moveOccursDT;
	
	foreach movement in _movesToCheck where self.myMovementObject.IF_VoyageMovemt.isFromSameVoyageAs(movement) do
		tempNextMove := movement.getVoyageMovementNext();
		if tempNextMove = null then
			continue;
		endif;					
		if movement.isLogicalBerth then
			// at sea
			continue;
		endif;
		if movement.getMyBerth().myWharf &lt;&gt; moveWharf then
			// not on the same wharf
			continue;
		endif;

		//if movement.occursOnDT&lt;=self.getMovementNext.occursOnDT and movement.getMovementNext.occursOnDT&gt;=self.occursOnDT then //&lt;&lt;--- 6.3.4
		//if movement.occursOnDT &lt;= voyDepartureDT and tempNextMove.occursOnDT &gt;= moveOccursDT then 
		if movement.occursOnDTNEW &lt;= moveOccursDT and tempNextMove.occursOnDTNEW &gt;= moveOccursDT then 
			// ie. this movement is in existance (overlaps) at the same time as the movementToCheck occurs
			self.berthing_StartEndFromOrient(moveStartPosn, moveEndPosn, movement.bowMarkTo, movement.sternMarkTo);

			if	moveStartPosn &gt; currentStartPosn then
				// this movement starts further up the wharf than the movementToCheck
				if moveStartPosn &lt; closestEndPosn then
					// This is the closest movement on the far end side
					closestEndPosn := moveStartPosn;
				endif;
			else
				// this movement start further down the wharf than the movementToCheck 
				if moveEndPosn &gt; closestStartPosn then
					// This is the closest movement on the start (0m) side
					closestStartPosn := moveEndPosn;
				endif;	
			endif;
		endif;
	endforeach;	
	
	foreach tmpLockout in moveWharf.allWLockoutsByBothDT 
	where tmpLockout.startOfLockoutDT &lt; voyDepartureDT 
	and tmpLockout.endOfLockoutDT &gt; voyArrivalDT do
		// Check to see if ship is within any part of this lockout
		// and is closer than any other ship
		if tmpLockout.startMarkOnWharf &gt; currentStartPosn then
			// this movement starts further up the wharf than the movementToCheck
			if tmpLockout.startMarkOnWharf &lt; closestEndPosn then
				// This lockout is closest to movement on the far end side
				closestEndPosn := tmpLockout.startMarkOnWharf;
			endif;
		else
			// this lockout start further down the wharf than anything else 
			if tmpLockout.endMarkOnWharf &gt; closestStartPosn then
				// This lockout is closest to movement on the start (0m) side
				closestStartPosn := tmpLockout.endMarkOnWharf;
			endif;	
		endif;	

	endforeach;	


	// Calculate clearances
	if moveBowMark &gt; moveSternMark then
		if closestEndPosn &lt; ClearanceUnbounded then
			_foreClearance := closestEndPosn-currentEndPosn;
		else
			// Fore clearance is unrestricted
			_foreClearance := ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1*(ClearanceUnbounded)) then
			_aftClearance := currentStartPosn-closestStartPosn;
		else
			// Aft clearance is unrestricted
			_aftClearance := ClearanceUnbounded;
		endif;		
	else
		if closestEndPosn &lt; ClearanceUnbounded then
			_aftClearance := closestEndPosn-currentEndPosn;
		else
			// Fore clearance is unrestricted
			_aftClearance := ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1*(ClearanceUnbounded)) then
			_foreClearance := currentStartPosn-closestStartPosn;
		else
			// Aft clearance is unrestricted
			_foreClearance := ClearanceUnbounded;
		endif;	
	endif;

	// Modified by Russell 20/07/99
	// -----------------------------------------------------------------------------------
	// Calc clearances to wharf ends if unlimited by other vessels.

	if moveBowMark &gt; moveSternMark then
		if _foreClearance = ClearanceUnbounded then
			// Calc clearance from bow to max metre end of wharf
			_foreClearance := ((moveWharf.length)-moveBowMark);
		endif;
		if _aftClearance = ClearanceUnbounded then
			// Calc clearance from stern to zero metre end of wharf
			_aftClearance := moveSternMark;
		endif;
	else
		if _aftClearance = ClearanceUnbounded then
			// Calc clearance from stern to max metre end of wharf
			_aftClearance := ((moveWharf.length)-moveSternMark);
		endif;
		if _foreClearance = ClearanceUnbounded then
			// Calc clearance from bow to zero metre end of wharf
			_foreClearance := moveBowMark;
		endif;	
	endif;

	// Calc clearances to wharf section ends if less than current clearances
	self.calc_ClearancesWharfSection(_foreClearance, _aftClearance, _overlapsWharfSection, moveWharf,
									 currentStartPosn, currentEndPosn, moveBowMark, moveSternMark);
*/
end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_movesToCheck" type="HMS_VoyageMovementByDateDict"/>
        <Parameter name="_foreClearance" type="Decimal" usage="io"/>
        <Parameter name="_aftClearance" type="Decimal" usage="io"/>
        <Parameter name="_overlapsWharfSection" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getParametersFromObject" id="cd159e1b-f80b-4866-b2eb-78f69d73a898">
        <source>getParametersFromObject(_moveDT, _nextMoveDT 	: TimeStamp output; 
						_startPos, _endPos 		: Decimal output;
						_wharf 					: HMS_Wharf output;
						_isBackward				: Boolean output);
/*
	Created on 27 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	voyMove,
	movePrev,
	moveNext 	: HMS_VoyageMovement;
	cmifMove 	: CMIF_HMS_WorkingMovement;
	
begin
	if self.myMovementObject.isKindOf(HMS_VoyageMovement) then
		voyMove := self.myMovementObject.HMS_VoyageMovement;
		_moveDT := voyMove.occursOnDTNEW;	
		moveNext := voyMove.getVoyageMovementNext();	
		if moveNext &lt;&gt; null then
			_nextMoveDT := moveNext.occursOnDTNEW;
		else
			_nextMoveDT := null;
		endif;
		if self.wantsClearanceBeforeMove then
			movePrev := voyMove.getVoyageMovementPrevious();
			_wharf := movePrev.getMyBerth().myWharf;
			movePrev.berthing_StartEndFromOrient(_startPos, _endPos, movePrev.bowMarkTo, movePrev.sternMarkTo);
		else
			_wharf := voyMove.getMyBerth().myWharf;
			voyMove.berthing_StartEndFromOrient(_startPos, _startPos, voyMove.bowMarkTo, voyMove.sternMarkTo);
		endif;
		if _wharf = null then
			return;
		endif;
	elseif self.myMovementObject.isKindOf(CMIF_HMS_WorkingMovement) then
		cmifMove := self.myMovementObject.CMIF_HMS_WorkingMovement;
	endif;
end;</source>
        <Parameter name="_moveDT" type="TimeStamp" usage="output"/>
        <Parameter name="_nextMoveDT" type="TimeStamp" usage="output"/>
        <Parameter name="_startPos" type="Decimal" usage="output"/>
        <Parameter name="_endPos" type="Decimal" usage="output"/>
        <Parameter name="_wharf" type="HMS_Wharf" usage="output"/>
        <Parameter name="_isBackward" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="moveIsFromSameVoyage" id="250727b1-0781-4fe9-b204-bbe4f3cb2d23">
        <source>moveIsFromSameVoyage(move : Object): Boolean;
/*
	Created on 27 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	workingVoyage : CMIF_HMS_WorkingVoyage;
	cmifMove : CMIF_HMS_WorkingMovement;
	realMove : HMS_VoyageMovement;
begin
	if move.isKindOf(HMS_VoyageMovement) then
		realMove := myMovementObject.HMS_VoyageMovement;
		return move.HMS_VoyageMovement.myHMSVoyageData = realMove.myHMSVoyageData;
	elseif move.isKindOf(CMIF_HMS_WorkingMovement) then
		cmifMove := myMovementObject.CMIF_HMS_WorkingMovement;
		if cmifMove.myClonedVoyage &lt;&gt; null then
			workingVoyage := cmifMove.myClonedVoyage;
		else
			workingVoyage := cmifMove.myWorkingVoyage;
		endif;
		return move.CMIF_HMS_WorkingMovement.myWorkingVoyage = workingVoyage;
	endif;
end;</source>
        <Parameter name="move" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllSurroundingMoves" id="0fad7bf8-a207-4a1a-a72e-3a424fb8f890">
        <updating/>
        <source>setAllSurroundingMoves(_dict : MemberKeyDictionary)updating;
/*
	Created on 27 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if (not _dict.isKindOf(HMS_VoyageMovementByDateDict))
	and (not _dict.isKindOf(CMIF_HMS_WorkingMoveByDateDict)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid class for movement dictionary');
		return;
	endif;
	allSurroundingMoves := _dict;
	
end;</source>
        <Parameter name="_dict" type="MemberKeyDictionary"/>
    </JadeMethod>
    <JadeMethod name="setMyMovementObject" id="e4151ede-2364-4c25-9358-e3500e9f9393">
        <updating/>
        <source>setMyMovementObject(_obj : Object) updating;
/*
	Created on 27 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if not _obj.respondsTo(IF_VoyageMovemt) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid class for calculating clearances: ' &amp; _obj.class.name);
		return;
	endif;
	myMovementObject := _obj;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
