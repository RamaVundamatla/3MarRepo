        <source>utlUpdateShipDeckLayer(_pxyObject : CM_ShipDeckLayer; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realObject		: CM_ShipDeckLayer;
