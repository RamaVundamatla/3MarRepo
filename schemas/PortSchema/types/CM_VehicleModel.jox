        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myDutyDocRoot" id="2ab6922b-473b-4d36-a9bd-eae9641bca56">
        <kind>child</kind>
