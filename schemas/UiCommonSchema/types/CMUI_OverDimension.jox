    <JadeMethod name="doSave" id="75f008ea-ece3-48c9-b0fc-47ab7fc0fa68">
        <updating/>
        <source>doSave() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/07/2009	cnwdap1	Initial creation
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	parentForm	: CMUI_ReceiveCargoForm;

begin
	parentForm := myParentForm.CMUI_ReceiveCargoForm;
	//parentForm.setOverDimensionDetails(	tblLengthFront.text.asDecimalJMT(),		// PAR #31155
	//									tblLengthRear.text.asDecimalJMT(),			// PAR #31155
	//									tblWidthLeft.text.asDecimalJMT(),			// PAR #31155
	//									tblWidthRight.text.asDecimalJMT(),			// PAR #31155
	//									tblHeight.text.asDecimalJMT());				// PAR #31155
	parentForm.setOverDimensionDetails(	tblLengthFront.getConvertedValue,			// PAR #31155
										tblLengthRear.getConvertedValue,			// PAR #31155
										tblWidthLeft.getConvertedValue,				// PAR #31155
										tblWidthRight.getConvertedValue,			// PAR #31155
										tblHeight.getConvertedValue	);				// PAR #31155
	self.unloadForm;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setValues" id="a6c83b32-5e42-43e9-946a-306023b16b37">
        <updating/>
        <source>setValues(_front, _rear, _left, _right, _height : Decimal) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/07/2009	cnwdap1	Initial creation
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	self.setupMeasurementControls();																		// PAR #31155
	
	if _front &lt;&gt; null then
		//self.txtLengthFront.text	:= _front.cnEcStripDecimalZeros.asStringJMT();		//+cnwml2 PAR22100
		//self.tblLengthFront.text := _front.asStringMeasurementJMT();					//+cnwml2 PAR22166	// PAR #31155
		self.tblLengthFront.setValueDefault(_front.String);								//+cnwml2 PAR22166	// PAR #31155
	endif;
	if _rear &lt;&gt; null then
		//self.txtLengthRear.text		:= _rear.cnEcStripDecimalZeros.asStringJMT();	//+cnwml2 PAR22100	
		//self.tblLengthRear.text := _rear.asStringMeasurementJMT();					//+cnwml2 PAR22166	// PAR #31155
		self.tblLengthRear.setValueDefault(_rear.String);								//+cnwml2 PAR22166	// PAR #31155
	endif;
	if _left &lt;&gt; null then
		//self.txtWidthLeft.text		:= _left.cnEcStripDecimalZeros.asStringJMT();	//+cnwml2 PAR22100
		//self.tblWidthLeft.text := _left.asStringMeasurementJMT();						//+cnwml2 PAR22166	// PAR #31155
		self.tblWidthLeft.setValueDefault(_left.String);								//+cnwml2 PAR22166	// PAR #31155
	endif;
	if _right &lt;&gt; null then
		//self.txtWidthRight.text		:= _right.cnEcStripDecimalZeros.asStringJMT();	//+cnwml2 PAR22100
		//self.tblWidthRight.text := _right.asStringMeasurementJMT();					//+cnwml2 PAR22166	// PAR #31155
		self.tblWidthRight.setValueDefault(_right.String);								//+cnwml2 PAR22166	// PAR #31155
	endif;
	if _height &lt;&gt; null then
		//self.txtHeight.text			:= _height.cnEcStripDecimalZeros.asStringJMT();	//+cnwml2 PAR22100
		//self.tblHeight.text := _height.asStringMeasurementJMT();						//+cnwml2 PAR22166	// PAR #31155
		self.tblHeight.setValueDefault(_height.String);									//+cnwml2 PAR22166	// PAR #31155
	endif;
epilog

end;</source>
        <Parameter name="_front" type="Decimal"/>
        <Parameter name="_rear" type="Decimal"/>
        <Parameter name="_left" type="Decimal"/>
        <Parameter name="_right" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6b1bb752-600e-473d-b015-e3a8da9d7585">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/07/2009	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod();
	
	self.minimumHeight := 194;
	self.minimumWidth := 431;
	
	self.centreOverParent(200);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMeasurementControls" id="b5594895-0d99-452b-a6cc-c53cd1f72661">
        <source>setupMeasurementControls();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	self.tblLengthFront.setup(Type_Length, self.backColor);
	self.tblLengthRear.setup(Type_Length, self.backColor);
	self.tblHeight.setup(Type_Height, self.backColor);
	self.tblWidthLeft.setup(Type_Width, self.backColor);
	self.tblWidthRight.setup(Type_Width, self.backColor);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="fb1903c0-0df4-4cbb-80f6-9d8d714a830d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 March 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012000, locale);
	btnCancel.translateCaption(Xlat_0012001, locale);
	btnSave.translateCaption(Xlat_0012002, locale);
	lblHeading.translateCaption(Xlat_0012003, locale);
	lblHeight.translateCaption(Xlat_0014579, locale);
	lblLengthFront.translateCaption(Xlat_0014580, locale);
	lblLengthRear.translateCaption(Xlat_0014581, locale);
	lblWidthLeft.translateCaption(Xlat_0014582, locale);
	lblWidthRight.translateCaption(Xlat_0014583, locale);
end;</source>
    </JadeMethod>
</GUIClass>
