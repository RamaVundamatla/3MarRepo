    <JadeMethod name="getTIAtIndex" id="5417f78c-f91e-4510-b02e-59b292e10ad7">
        <source>getTIAtIndex(moveMode : Integer; index : Integer) : CM_TrackedItem;
/*
 ------------------------------------------------------------------------
Created:			05 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	array : CM_TIArray;
begin

	if index = 0 then
		app.raiseCMException(ERR_INVALID_INDEX, null, null);
		return null;		
	endif;
	if moveMode = REAL_MODE then
		if self.allTrackedItems.isEmpty then
			return null;
		endif;
		if self.allTrackedItems.size &gt;= index then
			return self.allTrackedItems[index];
		endif;
		return null;
	endif;

	create array transient;
	if moveMode = PLANNING_MODE then
		self.getAllPlannedTrackedItems(array, true, false);
	elseif moveMode = QUEUE_MODE then
		self.getAllQueuedTrackedItems(array, true);
	endif;
	if array.isEmpty then
		return null;
	endif;
	if array.size &gt;= index then
		return array[index];
	endif;
epilog
	delete array;	
end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="index" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTIs" id="fa050915-d4e7-4b99-b16b-b3e42a743afa">
        <source>getTIs(array : CM_TIArray input; mode : Integer; _clear : Boolean);
/*
 ------------------------------------------------------------------------
Created:			12 September 2001 by cnwdwq1
Purpose:			Loads the array with the TIs, NOTE: Does NOT clear the array by DESIGN, adds to whatever is passed in.
Parameters:		None
Returns:		Nothing
Changed On		Changed By		Reason
05 Oct 2022  	navma1			Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
*/
vars
	ti	: CM_TrackedItem;
	
begin
	if mode = REAL_MODE then
		// PAR 27749 - Add CLEAR param to this method and passed through to other methods
		if _clear then
			array.clear();
		endif;
		
		/*
		05.10.2022 navma1 #52967
		foreach ti in self.allTrackedItems discreteLock do
			array.add(ti);
		endforeach;
		*/
		self.allTrackedItems.copy(array);						//05.10.2022 navma1 #52967
	elseif mode = PLANNING_MODE then
		self.getAllPlannedTrackedItems(array, _clear, false);
	elseif mode = QUEUE_MODE then
		self.getAllQueuedTrackedItems(array, _clear);
	endif;
end;</source>
        <Parameter name="array" type="CM_TIArray" usage="input"/>
        <Parameter name="mode" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTIsForModeOperVoy" id="7424857a-7f6a-4685-b2d8-52efb73e3e63">
        <source>getTIsForModeOperVoy(_dict : Collection input; _mode : Integer;
					 _operator : CM_Operator; _voyage : CM_Voyage);
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
//--------------------------------------------------------------
//Operator and Voyage are optional, _dict and _mode are required;
vars
	ti			: CM_TrackedItem;
	lcSet 		: CM_LCSet;
	tiSet	 	: CM_TISet;
	futMove		: CM_FutureMove;
begin
	if _dict = null or
	   _mode = null then 
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Null Dict/mode passed to method. Contact Developer', null, null);
		return;
	endif;	

	//----------------------------------------------------------
	//DO NOT CLEAR THE _dict AS COULD BE FILTERING TERMINAL AREA
	//----------------------------------------------------------
	
	//Filter by yard location (site/state ignored)
	create tiSet transient;
	if _mode = DISPLAY_MODE_ACTUAL then
		self.allTrackedItemsById.copy(tiSet);
	elseif _mode = DISPLAY_MODE_QUEUE then
		foreach futMove in self.allQueuedFutureMoves do
			ti := futMove.getTrackedItem();
			if (not tiSet.includes(ti)) then //can be queued here multiple times
				tiSet.add(ti);
			endif;
		endforeach;		
	elseif _mode = DISPLAY_MODE_PLAN then
		foreach futMove in self.allPlannedFutureMoves do
			ti := futMove.getTrackedItem();
			if (not tiSet.includes(ti)) then //can be planned here multiple times
				tiSet.add(ti);
			endif;
		endforeach;				
	endif;

	//Filter by yard location and operator
	if _operator &lt;&gt; null then
		//Filter by Terminal Area and Operator
		foreach ti in tiSet do
			if ti.myOperator = _operator then
				if _voyage &lt;&gt; null then
					//Filter by Terminal Area -&gt; Operator and Voyage.
					if ti.myVoyage = _voyage then									
						if (not _dict.includes(ti)) then
							_dict.add(ti);
						endif;
					endif;
				else
					if not _dict.includes(ti) then
						_dict.add(ti);
					endif;
				endif;
			endif;	
		endforeach;
	//Filter by Terminal Area and Voyage
	elseif _voyage &lt;&gt; null then
		foreach ti in tiSet do
			if ti.myVoyage = _voyage then
				if (not _dict.includes(ti)) then
					_dict.add(ti);
				endif;
			endif;
		endforeach;
	//Filter by Terminal Area
	else
		foreach ti in tiSet do
			if (not _dict.includes(ti)) then
				_dict.add(ti);
			endif;
		endforeach;
	endif;
epilog
	delete tiSet;
end;</source>
        <Parameter name="_dict" type="Collection" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
