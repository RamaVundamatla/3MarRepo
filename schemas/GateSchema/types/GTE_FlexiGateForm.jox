    <JadeMethod name="buildErrorArrayFromPassport" id="1e937ab2-9c29-4bbc-9c57-c8d24242afa2">
        <source>buildErrorArrayFromPassport(_passport :CM_Passport; _errors :HugeStringArray input)protected;
// ---------------------------------------------------------------------------
// Created:     20 October 2008 by concms1
// Purpose:     ccms 1035 - Gate ticket printing (APM)
//				Convert persistent errors to arrays that can be passed to app.showErrorWarningDialogArray
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	error	:CM_Error;
begin
	foreach error in _passport.allErrors do
		_errors.add (error.text);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_errors" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildErrorWarningArrays" id="a53dc0e3-1fdd-4ecb-abd4-98b1ff42c2d6">
        <source>buildErrorWarningArrays(_coll : CM_ErrorsByTransNumDict; _tranNum :String; _errors, _warnings :HugeStringArray input)protected;
// ---------------------------------------------------------------------------
// Created:     15 October 2008 by concms1
// Purpose:     ccms 1035 - Gate ticket printing (APM)
//				Convert persistent errors to arrays that can be passed to app.showErrorWarningDialogArray
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	error	:CM_ErrorPersistent;
	len		:Integer;
begin
	len := _tranNum.length();
	
	foreach error in _coll where error.transactionNum[1:len] = _tranNum do
		if error.isStatement then
			continue;
		endif;
		if error.status = CM_ErrorPersistent.Status_Closed then
			continue;
		endif;
		if error.status = CM_ErrorPersistent.Status_Ignore then
			continue;
		endif;
		
		
		if error.type = CM_ErrorPersistent.Type_Error then
			_errors.add (error.text);
		elseif error.type = CM_ErrorPersistent.Type_Warning then
			_warnings.add (error.text);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_ErrorsByTransNumDict"/>
        <Parameter name="_tranNum" type="String"/>
        <Parameter name="_errors" type="HugeStringArray" usage="input"/>
        <Parameter name="_warnings" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildTruckLayout" id="d089c0ca-7eb7-4d8c-baab-826a8659c8a3">
        <source>buildTruckLayout();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2009	cnwas3	Initial creation

*/
constants
	//Height = 174; //minimum height considering the minimum height of the whole form
	Height = 130;
	Width = 888; //minimum width, same story
vars
	leftMargin,rightMargin : Real;
begin

	
	self.myTrkFlexiLayIn.width:=self.myTrkFlexiLayIn.parent.width;
	self.myTrkFlexiLayOut.width:=self.myTrkFlexiLayOut.parent.width;
	
	leftMargin:=(self.myTrkFlexiLayIn.parent.width-Width)/2+180;
	rightMargin:=(self.myTrkFlexiLayIn.parent.width-Width)/2+185;
	self.myTrkFlexiLayIn.setMargins(10, 10, leftMargin.Integer, rightMargin.Integer);	
	self.myTrkFlexiLayIn.height:=Height;	
	self.myTrkFlexiLayIn.myDoorsCheckBox.visible := false;	
	self.myTrkFlexiLayIn.setPictures();
	

	
	self.myTrkFlexiLayOut.setMargins(10, 10, leftMargin.Integer, rightMargin.Integer);	
	self.myTrkFlexiLayOut.height:=Height;
	self.myTrkFlexiLayOut.top:=self.myTrkFlexiLayIn.top+Height;	
	self.myTrkFlexiLayOut.myDoorsCheckBox.visible := false;
	self.myTrkFlexiLayOut.setPictures();
	
	
	self.myTrkFlexiLayIn.cnEcResizeContents();
	self.myTrkFlexiLayOut.cnEcResizeContents();	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkFor1StopVBS" id="3dbb1b00-5535-49ae-927e-327fa748d50c">
        <source>checkFor1StopVBS(_object : CM_Object) : Boolean;
//
// Purpose:			Make a call to 1-Stop's VBS system to see if there are any vehicle Bookings for this gate entry
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
// 01/03/2023	jlika1		TFS 56731 AAT - 1Stop VBS Booking Not Required to Drop Off Export Empty Containers
// 21/02/2025	naviv1		JIRA - 29374 - EUP | Transaction Instrumentation - Gate
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	ti 			: CM_TrackedItem;
	release 	: CM_BulkRelease;
	request 	: CMIF_1StopBookingRequest;
	response 	: CMIF_1StopBookingResponse;
	booking 	: CMIF_1StopBookingData;
	containerId, 
	pin 		: String;
	idToMatch 	: String;
	voyage 		: CM_Voyage;
begin
	if not self.myTerminal.is1STOPVBS then
		return true;
	endif;

	if _object.isKindOf(CM_TrackedItem) then
		ti := _object.CM_TrackedItem;
		containerId := ti.id;
		idToMatch := ti.id;
		voyage := ti.myVoyage;
	elseif _object.isKindOf(CM_BulkRelease) then
		release := _object.CM_BulkRelease;
		pin := release.myPinNo.pinNo;
		idToMatch := release.code;
		voyage := release.myVoyage;
	else
		app.raiseUnexpectedProgramError(_object.class.name, method.qualifiedName, "Unexpected object type when checking 1-Stop VBS");
		return false;
	endif;
	
	create request transient;
	if self.cmbCarrier.listObject &lt;&gt; null then
		request.carrierCode := self.cmbCarrier.listObject.CM_Carrier.code;
	endif;
	request.containerId := containerId;
	request.pinNumber := pin;

	if not self.myTerminal.request1StopVBS(request, response) then
		// show an error if we need to
		// - TI is a prenote
		if ti &lt;&gt; null and ti.isNotified and voyage &lt;&gt; null and voyage.structureIncludesLOLO then
			if ti.isEmpty and not self.myTerminal.getConfig(ReqVehicleBooking1Stop).Boolean and not self.hasBooking then
				return true;
			else
				app.raiseCMException1(No_vehicle_booking_prenote, ti.id, null, null);
				return false;
			endif;
		endif;
		// - release is a full container release by type
		if release &lt;&gt; null and release.releaseByType and release.fullRelease then
			app.raiseCMException1(No_vehicle_booking_release, release.code, null, null);
			return false;
		endif;
	endif;
	
	// get the booking slots from the reply, and add them to the all1StopVBSDetails
	if response &lt;&gt; null then
		// do a bit of a swap of data here so we know whether a booking belongs to a release pin
		if release &lt;&gt; null then
			foreach booking in response.data do
				booking.id := booking.id &amp; ":" &amp; idToMatch;
			endforeach;
		endif;
		self.set1StopBookingSlotsOnVVR(idToMatch, response);
		return true;
	endif;
	return false;
epilog
	delete request;
	delete response;
end;
</source>
        <Parameter name="_object" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkVBSSlot" id="11cd1bdf-0dca-4ea6-88ec-8c59152b613e">
        <updating/>
        <source>checkVBSSlot(_vbt : CM_VehicleBookingTerminal; _pinCode : String; _vbsts : CM_VehicleBookingTimeSlot output): Boolean protected, updating;
/*

Purpose:			Searches for a Vehicle Booking TimeSlot from the pin code entered.
					If we are using Slot Type validation then also checks the external reference collection.

Parameters:			_vbsProcess	CM_VBSProcess				The Vbs process that the terminal is currently using
					_vbt		CM_VehicleBookingTerminal	The vehicle booking terminal weare going to use for searching
					_pinCode	String						The pin code entered in the flexi gate form inside the new item field
					_vbsts		CM_VehicleBookingTimeSlot	If a vbs time slot is found then it is outputted in this parameter

Return Value:		Boolean	representing whether a vbs time slot was found

Date		Who		Reason
03 May 2023	navpw1	Initial creation TFS: 54049 (55840)
03 Sep 2025 navlc30 JIRA 35531 - Address the Error to allow Processing multiple Release Requests on a single VBS Slot at the Gate

*/

vars
	msg		: String;
	realVVR	: CM_VehicleVisitRecord;
	vbsProcess : CM_VBSProcess;
	
begin
	if _vbt &lt;&gt; null then
		_vbsts := _vbt.allVBTimeslotsById.getAtKey( _pinCode.trimBlanks.toUpper );
		
		vbsProcess := self.myVBSProcess;
		
		if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation and _vbsts = null then
			_vbsts := _vbt.allVBTimeslotsByExtRef.getAtKey( _pinCode.trimBlanks.toUpper );
		endif;
		
		realVVR := self.myRealVVR;
		
		if vbsProcess &lt;&gt; null and vbsProcess.isVbsStandard
			and realVVR &lt;&gt; null and _vbsts &lt;&gt; null				//03.09.2025 navlc30 #35531
			and realVVR.myVehicleBookingTimeslot &lt;&gt; null
			and realVVR.myVehicleBookingTimeslot &lt;&gt; _vbsts
		then
			msg := app.getErrorString1( Vehic_booki_times_alrea_been_a,  realVVR.myVehicleBookingTimeslot.id );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
		
		if _vbsts &lt;&gt; null then
			self.populateFromVehicleBookingTS( _vbsts );
			self.myVehicleBookingTimeslot := _vbsts;        //10/12/2015 cnwma1 PAR #37193
		endif;
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_vbt" type="CM_VehicleBookingTerminal"/>
        <Parameter name="_pinCode" type="String"/>
        <Parameter name="_vbsts" type="CM_VehicleBookingTimeSlot" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkVehicleVisit" id="86dcc2b8-3212-42e6-8e4a-4a47e335e8bb">
        <updating/>
        <source>checkVehicleVisit(_vehicle : CM_Vehicle) : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/09/2016	cnwdap1		Initial creation TFS 2720
//
vars
	vvr : CM_VehicleVisitRecord;
	vvrComplete : Boolean;
	
begin
	if myTerminal.roadProcessIsASPA then
		return true;
	endif;
	
	vvr := _vehicle.getCurrentVisit();
	if self.getMyTerminal.getConfig(SiteHasSecurityGate).Boolean then
		vvrComplete := vvr &lt;&gt; null and not vvr.isIncompleteForSecurityGate;
	else
		vvrComplete := vvr &lt;&gt; null and not vvr.isIncomplete;
	endif;
	if vvr &lt;&gt; null and not vvrComplete then
		self.txtVisitNumber.text := vvr.visitNumber;
		vvr.allVehicleBookingSlots.copyNoDuplicates(self.allVehicleBookingTimeslots, false);	// ### TFS 54049 (55840) 22May2023 NAVPW1
		self.doQuery(vvr);
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
