    <JadeMethod name="setControlsForAddEdit" id="cde3a572-5623-47a5-bed9-ec21cf15cb51">
        <updating/>
        <source>
setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.cmbCountry.setObject(null);
		theForm.cmbPortGroup.setObject(null);
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_PortCode);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_Country);
		theForm.tblInput1.enableRowByName(ETRow_Group);
		theForm.tblInput1.setValueByName(ETRow_IsPort, true);	// 09/01/2008 cnwar2 #15383
//		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);	
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_Port);
		// cannot update code		
// cnwdad1 04/07/2006 - PAR #11593: Disable to Code and Port code when editing.
		//theForm.tblInput1.disableRowByName(ETRow_Code);
		//theForm.tblInput1.disableRowByName(ETRow_PortCode);
// cnwvu1	27/10/2006	PAR12482: to relax Code and Port Code 
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_PortCode);

		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_Country);
		theForm.tblInput1.enableRowByName(ETRow_Group);
	endif;

//	theForm.tblInput1.disableRowByName(ETRow_Code);
end;</source>
    </JadeMethod>
