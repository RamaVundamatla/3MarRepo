    <JadeMethod name="cleanUpInvalidObjects" id="026fb398-f5d7-487a-b002-05a8783caa66">
        <updating/>
        <source>cleanUpInvalidObjects(_table : CM_DataTable io) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 2009 by cnwjo3
//
// Purpose:		There can be invalid objects in tables.  clean them up
//
// Parameters:	
//
// Returns:		Nothing
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	idx : Integer;
	removeObjects : CM_ObjectSet;
	obj : Object;
	startFrom : Integer;
	theTI : CM_TrackedItem;
	invalid 		: Boolean;
	id				: String;
	
begin
	startFrom := _table.fixedRows;
	
	create removeObjects transient;
	
	on Exception do app.handleDeletedObject(exception, theTI, invalid);
	
	foreach idx in startFrom to _table.rows do
		theTI := _table.CM_DataTable.accessRow(idx).itemObject.CM_TrackedItem;
		if theTI &lt;&gt; null then
//			if not app.isValidObject(theTI) then
			invalid := false;
			id := theTI.id;		// Derefernce to check it is valid
			if invalid then
				removeObjects.add(theTI);
			endif;
		endif;
	endforeach;

	foreach obj in removeObjects do
		_table.cnEcRemoveObjectRow(obj);
	endforeach;
epilog
	delete removeObjects;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
    </JadeMethod>
