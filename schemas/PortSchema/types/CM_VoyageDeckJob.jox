    <JadeMethod name="getROROImageDetailed" id="23f790dd-a239-435a-92b3-5376a51e69ef">
        <source>getROROImageDetailed(_width : Integer; _height : Integer)  : Binary;
/*

Date		Who		Reason
30 July 2013	cnwer1	Initial creation PAR

*/

vars
	aClass : Class;
	jrw : Schema;
	roroPrintForm : Form;
	deckImage : Binary;
begin
	jrw := rootSchema.getSchema("ShipSchema");
	aClass := jrw.getClass("SHP_ROROPrint");
	create roroPrintForm as aClass transient;
	deckImage:=roroPrintForm.sendMsgWithParams("getROROJobImageDetailed", self,_width, _height).Binary;
	
	return deckImage;
epilog
	delete roroPrintForm;
end;</source>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
