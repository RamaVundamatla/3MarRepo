    <PrimAttribute name="tableAlign" id="c90a9591-73fa-4da9-87cd-f226292deab3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>For a Table, specifies that the table will be aligned on the LEFT or RIGHT of
the page, allowing text to flow around it.

For a Table Row or Table Data, specifies that the text in the cells of this
row is aligned on the LEFT, CENTER or RIGHT of each cell.</text>
    </PrimAttribute>
    <PrimAttribute name="tableBackColor" id="35d81765-9e09-44a1-ab07-1b6ad23f7dd7">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <text>Specifies a background color for the entire table.

Refer to the CnEcHtml_Colors category of global constants.</text>
    </PrimAttribute>
    <PrimAttribute name="tableBackSource" id="631fa2bf-4ac5-479a-a940-dfc770d6dbfd">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <text>Specifies a URL containing an image to be used as a backgound.</text>
    </PrimAttribute>
