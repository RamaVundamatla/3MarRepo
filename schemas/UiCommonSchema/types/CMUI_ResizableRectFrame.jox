    <JadeMethod name="getAdjustedRight" id="be4f22ef-c357-421c-8af2-452a780f6ccf">
        <source>getAdjustedRight(): Real;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2009	cnwer1	Initial creation

*/

vars
	machWorkzone : CMIF_MachineWorkzone;
begin
	
	if 	self.userObject.isKindOf(CMIF_MachineWorkzone) then
		machWorkzone:=self.userObject.CMIF_MachineWorkzone;
		if machWorkzone.rotated90 then
			return self.top + self.height;
		else
			return self.left + self.width;
		endif;
	endif;
	
	return self.left + self.width;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
