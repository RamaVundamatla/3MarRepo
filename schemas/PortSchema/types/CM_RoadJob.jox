    <JadeMethod name="causeTerminalEvent" id="7e15b6ce-9ca3-4dc4-beeb-7ad87e9bb783">
        <source>causeTerminalEvent(_mode: Integer);
//--------------------------------------------------------------
//Created: 02 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_mode);
	
	if _mode = self.Event_Mode_Create then
		app.writeLog('sending CM_RoadJob::causeTerminalEvent note RoadJob_Create_Event for job ' &amp; self.id &amp; '  ' &amp; self.String, LogINFO);
		app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(RoadJob_Create_Event), self);
	elseif _mode = self.Event_Mode_Update then
		app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(RoadJob_Update_Event), self);	
	elseif _mode = self.Event_Mode_Delete then
		self.causeEvent(self.myTerminal.getTerminalEvent(RoadJob_Delete_Event), false, self);		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode ' &amp; _mode.String);
	endif;

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="ccms1061_conversion" id="7f222f95-2733-4ceb-9604-a7266e91883e">
        <updating/>
        <source>ccms1061_conversion() updating;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	icArea	:CM_TerminalArea;
	gate	:CM_Gate;
begin

	icArea := self.myTerminal.allTerminalAreas [self.roadTransAreaId];
	
	if icArea &lt;&gt; null and icArea.isYardInterchangeArea then
		// the vta would have been used to create an interchange area and if it was a dual gate or
		// the default gate, this interchange would have had its default out gate set to the new gate 
		// that was created - so use that gate even though it says 'default out gate' vta's were always in/out
		// so the assumption is ok.
		gate := icArea.CM_YardInterchangeArea.myDefaultOutGate;
	endif;
	
	if gate = null then 
		// old vta was not dual gate or default vta
		gate := self.myTerminal.getDefaultGate_IN;
	endif;
	
	self.myGate := gate;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="changeStatus" id="02c30578-42f6-42db-a030-4b9ca8bed021">
        <updating/>
        <source>changeStatus(newStatus : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 15/10/2021		navdap1			TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// ---------------------------------------------------------------------------

vars
	oldStatus : Integer;
begin

	exclusiveLock(self);

	oldStatus := self.status;

	if oldStatus = newStatus then //No change
	  	return;
	endif;


	self.status := newStatus;
	
	if self.status = JOB_COMPLETE then		// TFS 51935
		self.clearDirectDeliveryChildren;	// TFS 51935
	endif;									// TFS 51935
end;</source>
        <Parameter name="newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changeVehicle" id="e4a38351-9b0e-414c-b49b-bb4fcf856b17">
        <updating/>
        <source>changeVehicle(	_vehicle 	: CM_Vehicle;
				_passport	: CM_Passport input	) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
26 Feb 2010	consw1	PAR #21320 - Revise behaviour of Edit Registration for Vehicle Visit
12 Sep 2024 navma1	Bug 66073: SNO - Code :83948. When trying to change Vehicle registration
*/

vars
	oldVehicleLocn	: CM_VehicleController;
	newVehicleLocn	: CM_VehicleController;
	moveController	: CMIF_MoveController;
	needNotify		: Boolean;
	queueEntry		: CM_RTQueueEntry;
	task			: CM_RTQueueTask;
	updateEvent		: Integer;
	oldVehicle 		: CM_Vehicle;
	bat				: String;
	wle  			: CM_WorkListEntry;
begin
	updateEvent		:= _vehicle.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event);
	oldVehicleLocn	:= self.myVehicle.locationsController;
	newVehicleLocn	:= _vehicle.locationsController;
	bat				:= self.batNumber.trimRight;
	
	oldVehicle 		:= self.myVehicle;
	// Update Vehicle
	self.myVehicle	:= _vehicle;
	
	// Update registration number
	self.regNumber	:= _vehicle.regNumber;
	
	if bat &lt;&gt; null then												//12.09.2024 navma1 #66073
		self.jobNumber 	:= self.regNumber.trimRight &amp; '-' &amp; bat;
	else
		self.jobNumber 	:= self.regNumber.trimRight;
	endif;
	
	//jlier1 JIRA#12616 21/2/25
	foreach wle in self.workListEntries discreteLock do
		if wle.myTrackedItem &lt;&gt; null and   wle.myTrackedItem.myPrimaryActualLocation = oldVehicleLocn then
			create moveController transient;
			moveController.setMyToPrimaryLocation(newVehicleLocn);
			moveController.setMoveMode(REAL_MODE);
			moveController.setMyWorkListEntry(wle);
			moveController.setMyTrackedItem( wle.myTrackedItem);
			moveController.isSystemMove := true;
			moveController.isForcedMove:=true;
			moveController.executeMove(_passport);
			delete moveController;
		endif;
		
		
		//if wle being received into yard
		if wle.isReceipt then
			//update wle source
			wle.setLocations(newVehicleLocn.getID,wle.locationTarget);
			//is  complete -update ti vehicle receipted on
			if wle.myTrackedItem &lt;&gt; null then
				wle.myTrackedItem.setReceiveTruckWithTrans(self.regNumber,_passport);
			endif;
			
			if wle.status &lt;&gt; WLE_COMPLETED then

				foreach queueEntry in  wle.allRTQueueEntries discreteLock where queueEntry.status &lt;&gt; ENTRY_COMPLETE do
					needNotify := false;
		
					foreach task in queueEntry.allTasks discreteLock where task.status &lt;&gt; TASK_COMPLETE and task.sourceLocation = oldVehicleLocn do
						task.setSourceLocation(newVehicleLocn);
						needNotify:=true;
					endforeach;
					if needNotify then
						queueEntry.causeEvent(updateEvent, false, null);
					endif;
				endforeach;
			endif;
			//if still on truck i.e. wle not complete then
				//move to new truck
				//if queued update the source location of the queued task /fqm
		elseif not wle.isReceipt then
			wle.setLocations(wle.locationSource,newVehicleLocn.getID);
			//is  complete - update ti move history 
			if wle.status &lt;&gt; WLE_COMPLETED and wle.myTrackedItem &lt;&gt; null  then
				foreach queueEntry in  wle.allRTQueueEntries discreteLock  where queueEntry.status &lt;&gt; ENTRY_COMPLETE do
				
					foreach task in queueEntry.allTasks discreteLock where task.status &lt;&gt; TASK_COMPLETE and task.targetLocation = oldVehicleLocn do //12.09.2024 navma1 #66073
							create moveController transient;
							moveController.isRadioTelemetryMove := true;
							moveController.setMyTrackedItem(wle.myTrackedItem );
							moveController.setMyWorkListEntry(wle);
							moveController.setMyToPrimaryLocation(newVehicleLocn);
							moveController.updatePassportAndUser(_passport);			
							moveController.setMoveMode(QUEUE_MODE);
							task.changeTargetLocation(moveController, true);
							delete moveController;		
					endforeach;		
				endforeach;
			endif;
		
		else
		endif;
	endforeach;
	
	self.causeTerminalEvent(self.Event_Mode_Update);	

epilog
	delete moveController;
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkAllToDoTaskComplete" id="6030b8b8-8c32-4f05-9428-353e68d998d2">
        <source>checkAllToDoTaskComplete() : Boolean;
//--------------------------------------------------------------
// Created: 27 May 2002 By: cnwgd1
// 14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
//--------------------------------------------------------------
vars
	wle : CM_WorkListEntry;
begin

	foreach wle in self.workListEntries do
		if not wle.isKindOf(CM_WOToDoWLE) then // 14/06/2022 navcs2 ChangeRequest 53038
			continue;
		endif;
		if not wle.status = WLE_COMPLETED then
			return false;
		endif;
	endforeach;	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearDirectDeliveryChildren" id="eca193a0-2bc9-4e00-af74-b5bbac2358d5">
        <source>clearDirectDeliveryChildren();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
//
vars
	allchildWLEs : ObjectArray;
	wle, childWle : CM_WorkListEntry;
	obj : Object;

begin
	create allchildWLEs transient;
	foreach wle in self.workListEntries do
		wle.allDirectDeliveryChildWLEs.copy(allchildWLEs);
	endforeach;
	
	foreach obj in allchildWLEs do
		childWle := obj.CM_WorkListEntry;
		childWle.clearMyDirectDeliveryParentWLE;
	endforeach;
epilog
	delete allchildWLEs;
end;</source>
    </JadeMethod>
    <JadeMethod name="createStopStartTransaction" id="7f0730ef-cfb1-4c49-a737-311228ebd14e">
        <source>createStopStartTransaction(_action: Integer; _ts : TimeStamp; _obj : CM_Object); 		//23.09.2024  navbs1  #12445
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1  CR 62896 Task 62897: Jade - Job Create Transactions and Events
23 Sep 2024 navbs1  Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
30 Oct 2024 navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	vvrDetail		: CM_VehicleVisitRecordDetail;
	woTrans			: CM_WOTransaction;
	woJobTrans		: CM_WOJobDetail;
	et				: CM_EventTransaction;
	truckEvent		: CMEVT_TruckEvent;
	woDtl			: CM_WorkOrderDtl;
	eventType,
	woTransType,
	cargoTransType,
	vvrType 		: Integer;
	isStart 		: Boolean;
	resDtl			: CM_ReserveDetail;
	jobId			: String;
	cmifEventCtrl	: CMIF_TruckEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	
	// Get the type based on the action
	self.getTypesToCreate(_action, eventType, vvrType, woTransType, cargoTransType);
	
	isStart := _action = Job_Action_Start or _action = Job_Action_Resume;
	
	// Create WO Transaction
	resDtl := _obj.CM_ReserveDetail;																	//04.11.2024 navhl20 #33232
	if resDtl &lt;&gt; null then																				//04.11.2024 navhl20 #33232
		woDtl := resDtl.allWodReleases.first;
	else
		woDtl := self.getMyWorkOrderDtl();
	endif;
	if woDtl &lt;&gt; null then
		woTrans := woDtl.createWOTransaction(woTransType, null, null);
		if woTrans &lt;&gt; null then
			woJobTrans := woTrans.CM_WOJobDetail;
			woJobTrans.setJobActionDetails(self, isStart, _ts);
		endif;
	endif;
	
	// Create event
	if _action = Job_Action_Complete then																//04.11.2024 navhl20 #33232
		if self.status &lt;&gt; JOB_COMPLETE then
			return;
		endif;
	endif;
	
	if _action = Job_Action_Start then																	//05.11.2024 navhl20 #33232
		jobId := self.getJobId();
		foreach et in self.myVehicleVisit.allEventTransactions discreteLock where et.type = eventType do//06.03.2025 navma1 #MTN-34179
			if et.getJobId() = jobId then
				truckEvent := et.CMEVT_TruckEvent;
			endif;
		endforeach;
	endif;
	
	if truckEvent &lt;&gt; null then																			//05.11.2024 navhl20 #33232
		return;
	endif;
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	eventTrans := app.createEvent(eventType, _ts, self.myTerminal, app.myPassport.userCode, false, false, null);
	if eventTrans &lt;&gt; null then
		truckEvent := eventTrans.CMEVT_TruckEvent;
		truckEvent.setJobActionDetails(self, isStart, _ts);
		truckEvent.setMyWOTransaction(woJobTrans);
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := eventType;
	cmifEventCtrl.dateTime := _ts;
	cmifEventCtrl.myTerminal := self.myTerminal;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myRoadJob := self;
	cmifEventCtrl.isStart := isStart;
	cmifEventCtrl.startEndTimeStamp := _ts;
	cmifEventCtrl.myWOTransaction := woJobTrans;
	
	truckEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_TruckEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	// Create VVR Detail
	if self.myVehicleVisit &lt;&gt; null then
		vvrDetail := self.myVehicleVisit.createVisitRecordDetail(vvrType, null, null);
		// Need to set the VVR details time to be the action time
		if vvrDetail &lt;&gt; null then
			vvrDetail.setTimeStart(_ts);
		endif;
	endif;
	
epilog
	delete cmifEventCtrl;
end;</source>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="createVehicle" id="f2cf2705-055a-4eb4-b68b-befb09a9e29f">
        <updating/>
        <source>createVehicle(_passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pxyVehicle,
	realVehicle	: CM_Vehicle;

begin

	create pxyVehicle transient;
	pxyVehicle.setProxy(self.regNumber, null, null, 0, self.myCarrier, null,false, _passport.myTerminal);

	app.myUtilityCA.utlCreateVehicle(pxyVehicle, realVehicle, _passport);

	if _passport.noErrors then
		self.myVehicle := realVehicle;
	endif;

epilog
	delete pxyVehicle;
	return _passport.noErrors;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="departureProcess" id="072d7ee2-5bad-45a0-9bfb-8f6dcb536cc5">
        <updating/>
        <source>departureProcess(_passport : CM_Passport input) updating;
/* AA 2/4/01 
This encapsulates the processing performed when a road vehicle leaves the
Terminal. These rules were held in VB

Some self healing has been added to help overcome unexpected events

Receipts etc should all have been printed by now
*/
//01/09/2009	    cnwcs5	ccms1061 - gate config changes (remove vta)
//18 Jun 2013		cnwcs5	par 31670 - new _context parameter for createVehicleVisitDetail method
//07 Feb 2023		navmp20	ChangeRequest 56443: AAT - 1Stop VBS Messages Road Exit Screen
//16 Feb 2024		navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
//24/10/2024    	navma1  MTN-33181 SNO - Error 1081 When doing Road Exit,Truck Events not Deferred 
constants
	Delimiter = "^";
	Header    = "~";
vars
	vvr : CM_VehicleVisitRecord;
begin
	
	//th2 23/01/07 deadlock on CM_Terminal::allVehicleVisitRecords
	exclusiveLock(_passport.myTerminal.allVehicleVisits);
	
	/*  // ### TFS 52914 28FEB2022 NAVAB1
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,self);
		foreach wle in self.workListEntries do
			wle.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE,wle);
		endforeach;
	endif;
	*/
	
	inheritMethod(_passport);

	if _passport.hasErrors then
		return;
	endif;
	
	// 10/02/2011 cnwmh5 PAR 26925 - ensure we always have a vehicleVisitRecord
	if self.myVehicleVisit = null then
		//Make sure we have recorded the details (a little late in this case)
		self.recordVisit(true, true);
	endif;
	
	
	vvr := self.myVehicleVisit;
	
	//jlier1 TFS 57936 25/5/23 - need audits if barrier out code is created 
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(vvr, true);
	endif;
	
	// ### TFS 52631 10Jan2022 NAVPW1
	if vvr.isRoadJobAutoComplete or vvr.timeOut.isValid then		//16.02.2024 navnk30 #62414
		vvr.departureProcess( self, vvr.timeOut );
	else
		vvr.departureProcess( self, app.serverTimestampAtTrxStart );
	endif;
	// ### TFS 52631 10Jan2022 NAVPW1
	
	//jlier1 TFS 57936 25/5/23
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(vvr, false);
	endif;
	
	//Start 07.02.2023 navmp20 TFS 56443
	if _passport.myTerminal.is1STOPVBS then     
		vvr.do1StopRoadExit();
	endif;
	//End 07.02.2023 navmp20 TFS 56443
	
	if _passport.noErrors then
		// ### TFS 51853 27AUG2021 NAVAB1
		//Finally (Maybe !), erase the road job
		self.erase(NORMAL_ERASE);
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMove" id="0090bd15-75ab-49a3-ad6f-045693bec5ad">
        <updating/>
        <source>doMove(_mode : Integer; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 29 May 2002 By: cnwgd1
//--------------------------------------------------------------
// 29 Dec 2018 cnwma1 Bug 42739: POE - Urgent Road Gate Operational Error
// 14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

vars
	wle 	: CM_WorkListEntry;
	toLocn 	: CM_LocationsController;
	bol		: CM_BOL;
	bolIn 	: CM_BOLIn;
	tmpTI	: CM_TrackedItem;
	moveController : CMIF_MoveController;
begin
	
	//create moveController transient;             //29.12.2018 cnwma1 Bug # 42739
	//moveController.setMoveMode(_mode);	       //29.12.2018 cnwma1 Bug # 42739
	foreach wle in self.workListEntries do
		
		
		delete moveController;
		create moveController transient;  		   //29.12.2018 cnwma1 Bug # 42739
		moveController.setMoveMode(_mode);		   //29.12.2018 cnwma1 Bug # 42739	
		moveController.setQuantity(wle.quantity);  //29.12.2018 cnwma1 Bug # 42739
		moveController.setWeight(wle.weight);      //29.12.2018 cnwma1 Bug # 42739

		if wle.isKindOf(CM_WOToDoWLE) then //14/06/2022 navcs2 	ChangeRequest 53038
			continue;
		endif;
		exclusiveLock(wle);

		wle.setTIsForAutoComplete();
		if (not _passport.noErrors) then
			return;
		endif;

		tmpTI := wle.myTrackedItem;
		if tmpTI = null then	// 27/03/2009 cnwar2 #19123
			app.raiseCMException1(ERR_No_Items_Entered, null, null, self);
			return;
		endif;		
		exclusiveLock(tmpTI);
		
		toLocn := null;
		// Get the toLocn off the BOL first (if there is one)
		// as TI on BOLs do not have their palnned location set		
		if wle.myBOL &lt;&gt; null then
			bol := wle.myBOL;
			if bol.myPlannedLocation &lt;&gt; null then
				toLocn := bol.myPlannedLocation;
			elseif bol.isKindOf(CM_BOLIn) then
				bolIn := bol.CM_BOLIn;
				if bolIn.origTerminalAreaId &lt;&gt; null then
					continue;		//already there
				endif;
			else
				//It's a BOLOut, try putting them on the truck
				toLocn := self.myVehicle.locationsController;
			endif;
		else
			toLocn := tmpTI.getPrimaryLocation(PLANNING_MODE);					
		endif;

		if tmpTI.getPrimaryLocation(REAL_MODE) = toLocn then
			//Already there 
			continue;
		endif;		

		if (not _passport.noErrors) then
			break;
		endif;	
		
		if toLocn &lt;&gt; null then 
			moveController.setMyToPrimaryLocation(toLocn);
			wle.doMoveToLocn(moveController, _passport);
		endif;

		if (not _passport.noErrors) then
			break;
		endif;	
	endforeach;

	inheritMethod(_mode, _passport);	

epilog
	delete moveController;	
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="5b88599e-8ac8-404a-9ec5-5ce854cb9155">
        <updating/>
        <source>doPrint() updating;
//--------------------------------------------------------------
//Created: 16 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	//GD CCMS 1002 automate the printJadeReceipt and free up the batNumber.
	if not self.isReceiptRequired then
		return;
	endif;

//	self.printJadeReceipt(1, false); // CCMS 1401 JRW only
	self.printReceipt(1, false, null);

	if self.receiptPrintedDT = null then
		self.setReceiptPrintedDT();
	endif;

	self.receiptCopies := self.receiptCopies + 1; 	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="dwellTime" id="f81ad083-7118-402b-b3be-46699ecc739d">
        <methodInvocation>mapping</methodInvocation>
        <source>dwellTime(set: Boolean; _value: Integer io) mapping;

vars
	aT			  :	Time;
	isPos		  :	Integer;
	numDays		  :	Integer;
	mins 	  	  : Integer;
	vvr 		  : CM_VehicleVisitRecord;
	barrierCodeIn : CM_BarrierCode;
	vbts		  : CM_VehicleBookingTimeSlot;
	vbStartTime	  : TimeStamp;
	diffInMinutes : Integer;
	referenceTime :	TimeStamp;
begin
	if set then 
		app.raiseSetVirtualError(class.name, method.name);
		return; 
	endif;

	vvr := self.myVehicleVisit;																		//15.9.2023 navlc30 #60211		//30.09.2024 navlc30 #19284
	if vvr &lt;&gt; null then																				//15.9.2023 navlc30 #60211
		barrierCodeIn := vvr.myBarrierCodeIn;
		vbts := vvr.myVehicleBookingTimeslot;		
	endif;
	
	/*if barrierCodeIn &lt;&gt; null and barrierCodeIn.barrierDT.isValid then								//15.9.2023 navlc30 #60211
		aT := app.actualTimeServer.differenceAsTime(barrierCodeIn.barrierDT, isPos, numDays);		//15.9.2023 navlc30 #60211
	else																							//15.9.2023 navlc30 #60211
		aT := app.actualTimeServer.differenceAsTime(creationTime, isPos, numDays);
	endif;
	
	_value := (numDays * 24 * 60) + (aT.hour * 60) + aT.minute + 1;*/

	vbStartTime := null;																											//30.09.2024 navlc30 #19284
	if vbts &lt;&gt; null then
		vbStartTime	:= vbts.bookingTSstart;
	endif;		

	if vbStartTime.isValid() then																									//01.10.2024 navlc30 #19284
		if barrierCodeIn &lt;&gt; null and barrierCodeIn.barrierDT.isValid then
			referenceTime := barrierCodeIn.barrierDT;
		else
			referenceTime := self.creationTime;
		endif;
		if referenceTime &lt; vbStartTime then
			referenceTime := vbStartTime;
		endif;
		diffInMinutes := app.actualTimeAppServer.getDifferenceInMinutes(referenceTime);
	else
		diffInMinutes := app.actualTimeAppServer.getDifferenceInMinutes(self.creationTime);
	endif;
	//20 05 2025 navrv30 MTN 34504
	if app.actualTimeAppServer.getDifferenceInMinutes(referenceTime) &lt; 0 then
		_value := -1 * diffInMinutes;
	else
		_value := diffInMinutes;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="enqueueJob" id="4b455bb0-f629-4f29-870a-7d5bb03664d9">
        <source>enqueueJob();
//Works to queue a job
vars
	wle	: CM_WorkListEntry;
	arbiter	: CM_RTQueueArbiter;
	sortedWLEs	:	CM_WLEArray;
begin
	//epr par 36229 17/7/17 removed references to RadioTelemetryEnabled 
	create arbiter;
	arbiter.job := self;
	//--------------------
	//Because ROAD jobs are special, in that we take the RECEIPTS off the 
	//truck BEFORE we slap the RELEASES onto it.. we have to sort so they are in the 
	//correct order.
	//--------------------
	sortedWLEs := self.sortWLEs();
	if sortedWLEs = null then
		return;
	endif;
	
	foreach wle in sortedWLEs do
		if not wle.shouldQueueForRoadJob() then
			continue;
		endif;
		
		arbiter.reset();
		arbiter.job := self; // AKB2008SEP PAR 17703
			
		wle.enqueueWLE(arbiter);
	endforeach;

epilog
	//-----------------
	//Cleanup
	//-----------------
	if arbiter &lt;&gt; null then
		arbiter.erase(0);
	endif;
	if sortedWLEs &lt;&gt; null then
		sortedWLEs.clear;
		delete sortedWLEs;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="b5b3cc16-6693-49da-87b1-e7ec4bcb9568">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

// 15/09/2009	cnwcs5	moved 'cause rod job delete event' to always happen if there is a vehicle
vars
	jobSheet : CM_RoadJobSheet;
	request : CM_Request;
	iter : Iterator;
begin

	exclusiveLock(self);
	if not self.isTransient then
	
		if app.isUnitTestGarbageCollect then
			self.myRFIDTag := null;
		else
			self.setMyRFIDTag(null);	//23 Apr 2012	NDL	Par 29417
		endif;
		
		if self.myVehicle &lt;&gt; null then
			if (not self.vehicleStillOnSite()) then	
				//Only clear this stuff if there are no other jobs the truck is involved with
				self.myVehicle.resetLocationController(app.myPassport); 
			else
				// We need to unplan/unqueue this particular job,
				// should it be done here or by the WLE ???
			endif;
			// we used to only cause this event if the vehicle were not on site but I think we should
			// do it whenever a job is deleted
			self.causeEvent(self.myTerminal.getTerminalEvent(RoadJob_Delete_Event), false, self.myVehicle);
			
			//epr par 12790 17/10/06
			self.batNumber:=null;
			self.myBatNumber:=null;
			//self.myTerminal := null;
			
		endif;
	endif;

	//epr par 25307 6/8/10 
	// if its not a release with multi machine moves there could be rt queue entries for wles that have not been completed yet
	// ti create new internal job and set change the rt queue entries references to that
	if self.hasReceipt then
		self.updateUnfinishedQEntries();
	endif;
	
	
	iter := self.allRequests.createIterator;
	while iter.next(request) do
		request.erase(_eraseLevel);
	endwhile;

	self.causeTerminalEvent(self.Event_Mode_Delete);

	/*  // ### TFS 52914 28FEB2022 NAVAB1
	if app.myPassport.noErrors then
		if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 51853 01DEC2021 NAVAB1
			self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,self); // ### TFS 51853 01DEC2021 NAVAB1
		endif;
	endif;
	*/
	
	inheritMethod(_eraseLevel);
	
epilog
	delete iter;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findOrCreateWleForTiOnRelease" id="7f9177e5-c547-4780-8a9f-3125f99920ea">
        <source>findOrCreateWleForTiOnRelease( _ti : CM_TrackedItem ):CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars

	wle : CM_WorkListEntry;
	yardWle : CM_YardWLE;
	br : CM_BulkRelease;
	moveController : CMIF_MoveController;

begin

	foreach wle in self.workListEntries do
		if wle.isReceipt then
			continue;
		endif;
		if wle.status = WLE_UNACTIONED and wle.myRequest &lt;&gt; null then
			br := wle.myRequest.myOriginatingBulkRelease;
			if br &lt;&gt; null and br.allTrackedItemsAssigned.includes( _ti ) then
				return wle;
			endif;
		endif;
	endforeach;
	
	//If we get to here we didn't find an existing Work List Entry, consider creating and queuing one.
	
	foreach wle in self.workListEntries do
		if wle.isReceipt then
			continue;
		endif;
		if wle.myRequest &lt;&gt; null then
			br := wle.myRequest.myOriginatingBulkRelease;
			if br &lt;&gt; null and br.allTrackedItemsAssigned.includes( _ti ) then
				// found the bulk release that we could release this item form, create a queued move
				// for the ti and return the wle
				create moveController transient;
				moveController.setMyTrackedItem(_ti);
				moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
				moveController.setMoveMode(QUEUE_MODE);	
				moveController.setMyToPrimaryLocation(self.myVehicle.locationsController);
				moveController.setJobForMove(self);
			
				app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
				
				return moveController.myWorkListEntry;
				
			endif;
		endif;
	endforeach;
	
	return null;

epilog

	delete moveController;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getAnyIdWLEforTI" id="b7427293-549c-431c-bb63-ee51a7392e74">
        <source>getAnyIdWLEforTI(_ti : CM_TrackedItem) : CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Jul 2017	jlger1	Initial creation TFS 5597
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle 		: CM_WorkListEntry;
	bulkRelease : CM_BulkRelease;
	request		: CM_Request;
begin
	
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do	//06.03.2025 navma1 #MTN-34179
		
		request := wle.myRequest;
		
		if request = null then
			continue;
		endif;
		
		if wle.isReceipt then
			continue;
		endif;
		
		
		if not (request.isAnyId and request.isAnyAmount) then
			continue;
		endif;
		
		// its always a delivery request if its an Any Id
		bulkRelease := request.CM_DeliveryRequest.myOriginatingBulkRelease;
		
		if  bulkRelease = null then
			continue;
		endif;
		
		if not bulkRelease.allTrackedItemsAssigned.includes( _ti ) then
			continue;
		endif;
		
		if not _ti.isTiAvailableForAnyIdSelection then
			continue;
		endif;
		
		
		//all good 
		return wle;
	endforeach;
	
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getChassis" id="df76ddc1-b030-4221-86a4-e8b7ae4921fd">
        <source>getChassis(_in : Boolean; _hasChassis : Boolean output) : CM_TILC;
/*

Date		Who		Reason
09 Jul 2013	cnwer1	Initial creation PAR
09 Apr 2023 ChangeRequest 63148: EUP* | 53729 - Delivery Dispatch Screen - Should not update job status when trailers got completed.
06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	chassis : CM_TILC;
	wle     : CM_WorkListEntry;
	vvr     : CM_VehicleVisitRecord;
	gte		: CMGTE_Entity;
	request : CM_YardRequest;
begin
	_hasChassis := false;
	vvr 		:= self.myVehicleVisit;
	
	if vvr = null then
		return null;
	endif;
	
	if _in then
		
		gte := vvr.myInCMGTE_Chassis;
		
		if gte = null then
			return null;
		endif;
		
		_hasChassis := true;
		
		return gte.getTI.CM_TILC;
	else
		gte := vvr.myOutCMGTE_Chassis;
		
		if gte = null then
			return null;
		endif;
		
		_hasChassis := true;
		request		:= gte.myYardRequest;
		
		if request &lt;&gt; null then
			foreach wle in self.workListEntries discreteLock where wle.myRequest = request do	//06.03.2025 navma1 #MTN-34179
				chassis := wle.myTrackedItem.CM_TILC;
				break;
			endforeach;
		endif;
		
		if chassis &lt;&gt; null then
			return chassis;
		endif;

		return gte.getTI.CM_TILC;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_hasChassis" type="Boolean" usage="output"/>
        <ReturnType type="CM_TILC"/>
    </JadeMethod>
    <JadeMethod name="getChassisID" id="bc51fe02-a780-4cc5-a5af-eadcf8181947">
        <source>getChassisID(_in : Boolean) :  String;
/*

Date		Who		Reason
08 Jul 2013	cnwer1	Initial creation CCMS SFW 1338
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	vvr : CM_VehicleVisitRecord;
begin
	
	vvr := self.myVehicleVisit;
	
	if vvr = null then
		return null;
	endif;
	
	if _in then
		return vvr.getChassisID;
	else
		return vvr.getChassisOutID;
	endif;
epilog

end;</source>
        <Parameter name="_in" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCloneForPrinting" id="d65a188d-aca3-4db5-8697-cf1d01e6aee9">
        <source>getCloneForPrinting(_pxyClones : ObjectSet input) : SelfType;
/*

Date		    Who			Reason
30 June 2010	cnwas3	  	par 24727
08/04/2011		cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

PURPOSE OF THIS IS TO PATCH UP A FLAW IN THE GATE RECEIVAL DESIGN. IT ADDRESSES THE CASES IN WHICH THERE ARE SEVERAL RECEIVAL BY TYPES PER VEHICLE VISIT -&gt; THIS WILL MAKE IT REPORT "FRIENDLY".
*/

vars
	roadJob 			: SelfType;
	deleteWle,
	wle,
	newWle,
	branchedNewWle 		: CM_WorkListEntry;
	oldRequest 			: CM_Request;
	newRequest 			: CM_ReceivalRequest;
	receivalInfos 		: CM_ReceivalRequestInfoSet;
	rrInfo,
	newRrInfo 			: CM_ReceivalRequestInfo;
begin
	
	beginLoad;
	roadJob := self.pxyCreateUpdateProxy();
	endLoad;
	_pxyClones.add(roadJob);
	if roadJob.myRFIDTag &lt;&gt; null then
		_pxyClones.add(roadJob.myRFIDTag);
	endif;
	
	roadJob.workListEntries.purge();
	
	foreach wle in self.workListEntries do
		beginLoad;
		newWle := wle.pxyCreateUpdateProxy();
		_pxyClones.add(newWle);
		endLoad;
		newWle.setJob(roadJob);		
		oldRequest := wle.myRequest;
		if oldRequest &lt;&gt; null and oldRequest.isKindOf(CM_ReceivalRequest) then	
					
			receivalInfos := oldRequest.CM_ReceivalRequest.allReceivalInfo;
			if not receivalInfos.isEmpty() and receivalInfos.size() &gt; 1 then
				deleteWle := newWle;
				foreach rrInfo in receivalInfos do ///create a new wle for each of the receival request infos
					beginLoad;
					branchedNewWle := roadJob.workListEntries.last().pxyCreateUpdateProxy();
					_pxyClones.add(branchedNewWle);
					newRequest := branchedNewWle.myRequest.pxyCreateUpdateProxy().CM_ReceivalRequest;
					_pxyClones.add(newRequest);
					newRequest.allReceivalInfo.purge();
					branchedNewWle.updateRequest(newRequest);					
					newRrInfo := rrInfo.pxyCreateUpdateProxy();
					_pxyClones.add(newRrInfo);
					newRrInfo.setParent(newRequest);
					endLoad;
				endforeach;	
				delete deleteWle;
			endif;
			
		endif;
		
	endforeach;
	
	return roadJob;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_pxyClones" type="ObjectSet" usage="input"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getCustomStatus" id="627dbd2a-6ba9-4003-8398-0f494ec80b8d">
        <source>getCustomStatus(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/02/2023	navkc1 CR 62580 Task 62581: UI - Road Exit Custom Document Details

*/

vars

begin
	
	if self.myVehicleVisit &lt;&gt; null then
		return self.myVehicleVisit.getCustomStatus();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDataForDefSpecial" id="c5452de7-ed97-467b-9174-010c4c2a5b26">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
//27 Mar 2023	navbs1	    Bug 63212: POL - Door direction in Vehicle app is wrong
//06 Mar 2025   navma1 		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------
vars
	aComm : CM_Commodity;
	wle : CM_WorkListEntry;
	ti	: CM_TrackedItem;
	req : CM_DeliveryRequest;
	creationLocal: TimeStamp;
begin
	if _attrName = ETRow_JobId then
		_headings.add(_heading);
		_data.add(self.jobId);
		return true;
	
	elseif _attrName = ETRow_TimeIn then
		_headings.add(_heading);
		creationLocal := self.systemToLocalTime(self.creationTime);
		_data.add(creationLocal.time.shortFormatJMT()&amp;", " &amp; creationLocal.date.shortFormatJMT());	// 20/4/16 cnwmp6 TFS 488 - Multi timezone changes
		return true;
	
	elseif _attrName = ETRow_CargoItems then
		//if there are any cargo items add a heading
		if self.workListEntries.size &gt;0 then
			_headings.add(app.getString(Cargo_items));
			_data.add('');
		endif;
		foreach wle in self.workListEntries discreteLock do	  //06.03.2025 navma1 #MTN-34179
			if wle.myTrackedItem &lt;&gt; null then
				ti := wle.myTrackedItem;
			
				_headings.add(app.getString(IdNumber));
				_data.add(ti.id);
				_headings.add(app.getString(CM_Details));
				_data.add(ti.operatorCode.trimBlanks &amp; " " &amp; ti.getISOType &amp; " " &amp; ti.contentsStatusCode);
				// moved type and status up front par8589 rs may 2005
				_headings.add(app.getString(JobType));
				_data.add(wle.typeString);
				_headings.add(app.getString(JobStatus));
				_data.add(wle.statusString);
				if (not ti.isStorage) then		//dont want any storage ti's
				// moved commodity &amp; hazard from CCMS1304 par8589 rs may 2005 par8589
					_headings.add(app.getString(CM_Commodity_GC));
					_data.add(ti.commodity);
					
					// ### CCMS 1401
					if ti.isMAFCommodity() then
						_headings.add(app.getString(SetTemp));
						_data.add(ti.getDisplayTempForReports());
						_headings.add(app.getString(Release_date));
						_data.add(self.systemToLocalTime(ti.releasedDT).String);	// 20/4/16 cnwmp6 TFS 488 - Multi timezone changes
					endif;

					_headings.add(app.getString(CM_Hazardous));
					if ti.isHazardous then
						_data.add(app.getErrorString(Yes));
					else	
						_data.add(app.getErrorString(No));
					endif;
					_headings.add(app.getString(CM_Total_Weight));
					//_data.add(ti.weight.asStringWeightJMT());				//-cnwml2 MSL CCMS 1017
					_data.add(ti.totalWeight.asStringWeightJMT());			//+cnwml2 MSL CCMS 1017
					if ti.isKindOf(CM_Container) then

						// ### CCMS 1401
						_headings.add(app.getString(AvailabilityGrade));
						_data.add(ti.CM_Container.availabilityGradeDescription);
						
						if ti.CM_Container.isReefer then	// 11/05/2010 cnwar2 #24211
							// ### CCMS 1401
							_headings.add(app.getString(LoadOutTemp));
							_data.add(ti.CM_Container.getLastTempReadingStr(false));
							// ### CCMS 1401
							_headings.add(app.getString(Allowable_time_power));
							_data.add(ti.CM_Container.getAllowableTimeOffPower.String);
						endif;
					endif;
					///28 Sep 2010	NDL	Par 25608 - moved down, so not container dependant
					if ti.getSealNum &lt;&gt; null then
						_headings.add(app.getString(Seal_number));
						_data.add(ti.getSealNum);
					endif;
					if ti.getSealNumCustomsFirst &lt;&gt; null then
						_headings.add(app.getString(Custom_seal_number));
						_data.add(ti.getSealNumCustomsFirst);
					endif;
					if ti.getSealNumShipper &lt;&gt; null then
						_headings.add(app.getString(Shippers_seal_number));
						_data.add(ti.getSealNumShipper);
					endif;
					///
				endif;
				if ti.carrierRemarks &lt;&gt; null then
					_headings.add(app.getString(Carrier_remarks));
					_data.add(ti.carrierRemarks);	
				endif;
			elseif wle.myRequest.isKindOf(CM_DeliveryRequest) then
				req := wle.myRequest.CM_DeliveryRequest;
				_headings.add(app.getString(IdNumber)); 
				_data.add(app.getString(ISOEmpty));
				_headings.add(app.getString(Item)); 
				_data.add(req.operatorCode &amp; " " &amp; req.isoType);
				// moved type and status up front par8589 rs may 2005
				_headings.add(app.getString(JobType));
				_data.add(wle.typeString);
				_headings.add(app.getString(JobStatus));
				_data.add(wle.statusString);
			endif;
	
			if wle.myRequest.isKindOf(CM_YardRequest) and
			   wle.myRequest.CM_YardRequest.deliveryNumber &lt;&gt; null then
				_headings.add(app.getString(CM_Delivery_Number));
			 	_data.add(wle.myRequest.CM_YardRequest.deliveryNumber);
			endif;		
			_headings.add(app.getString(Door_direction));	//27.03.2024 navbs1 #63212
			_data.add(self.getDoorDirection(wle));			//27.03.2024 navbs1 #63212
			_headings.add(" ");
			_data.add(" ");
		endforeach;
		return true;
		
	elseif _attrName = ETRow_ReceiptsIssued then
		_headings.add(_heading);
		_data.add(self.receiptCopies.String);
		return true;
	endif;	

	return inheritMethod(_attrName, _heading, _headings, _data);

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDefaultInterchangeArea_IN" id="aa98cc4d-0ba8-471b-b6fb-9cd43564c6b1">
        <source>getDefaultInterchangeArea_IN():CM_TerminalArea;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     The interchange area thevehicle will go to when it enters the yard
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	icArea	:CM_InterchangeArea;
	gate	:CM_Gate;
begin
	icArea := self.getOverride_YardICArea;
	
	if icArea &lt;&gt; null then
		return icArea;
	endif;
	
	gate := self.myGate;
	
	if gate = null then
		return null;
	endif;
	
	return gate.getDefaultInterchangeArea_IN (self.myVehicle);
epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getDetailForRemoteQuery" id="063e703b-48d2-4e6c-90bd-bdaff8b58e0f">
        <source>getDetailForRemoteQuery(_type: String): String;

vars



begin

	if self.myVehicle &lt;&gt; null then
		return self.myVehicle.regNumber;
	endif;
	return null;

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7d5e8f47-cffe-4c4c-9598-23a49afd8ec5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//22/11/2017	cnwma1  	TFS #7828  QNS - System buffering
//18/05/2022 	navhl20 	TFS 53430  EUP - Sub Carrier registration in MTN
//25/08/2022    navds21     TFS 54619  POL - Include the Door Direction field in Road Exit screen
//20 Dec 2022   navmp20     ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
//09 Mar 2023   navmp20     Bug 57024: FR | 53667 - EUP - Inspection App checks - Trailer ID - Vehicle visit
//10 Mar 2023	navsa20		Task 55843: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit - [5] - Road Exit Screen &amp; Vehicle Visit Enquiry
//16 May 2023   navma1		ChangeRequest 57714: EUP - Delivery Dispatch – Gate
//14 June 2023  navhl20   	Defect 58640: MTN - Vehicle Booking Id doesn't get populated on the delivery dispatch screen
//20 Sep 2023	navlw1		Bug 60382: MTN - The Work Order Operations form's column organizer is missing some fields.
//11 Jan 2024   navbs1      ChangeRequest 61971: FR | 55168 - Seal Numbers on Trucks (remedial) - Add columns to Road Exit and Vehicle Enquiry
//20 Feb 2024	navnk30		ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
//26 Feb 2024 	navhl20 	ChangeRequest 61869: EUP | FR | 53891 - Mobile App changes for Delivery Dispatch - Source Location
//27 Mar 2023	navbs1	    Bug 63212: POL - Door direction in Vehicle app is wrong
//29 Mar 2024 	navhl20 	ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
//01 Aug 2024 	navhl20		Bug 65363: EUP - Date format is not based on the local time format
//07 Aug 2025	naviv1		MTN-35544: FR 35007.010 Display Release Request ID in Road Ops
// ---------------------------------------------------------------------------
vars
	subCarrier  : CM_Carrier;					//18/05/2022 navhl20 TFS 53430 
	vbsSlot 	: CM_VehicleBookingTimeSlot;	//10.03.2023 navsa20 TFS 55843
	str 		: String;						//10.03.2023 navsa20 TFS 55843
	vvr			: CM_VehicleVisitRecord;		// ### TFS 54049 (55843) 24May2023 NAVPW1
	ti 			: CM_TrackedItem;				// 20.09.2023 navlw1 tfs #60382
	request		: CM_Request;					// 20.09.2023 navlw1 tfs #60382
	index		: Integer;
begin
	vvr := self.myVehicleVisit;					// ### TFS 54049 (55843) 24May2023 NAVPW1
	
	if _attrName = ETRow_BatNumber or
	   _attrName = ETRow_BatNo then
		if self.myRFIDTag &lt;&gt; null then	//20 Sep 2016	NDL	TFS 2710
			return self.myRFIDTag.code;
		endif;
		if self.batNumber = null then
			return self.jobNumber;
		else
			return self.batNumber;
		endif;
	elseif _attrName = ETRow_TransactionNum then // PAR 17703
	
	
		if self.myVehicleVisit &lt;&gt; null then
			//return self.myVehicleVisit.getDisplayStringForAttribute(_attrName,_short);   //22/11/2017 cnwma1 TFS #7828
			return self.myVehicleVisit.visitNumber;                                        //22/11/2017 cnwma1 TFS #7828
		endif;
		
		return null;
	elseif _attrName = ETRow_CarrierCode or _attrName = ETRow_CarrierId or	// 13/6/17 MAP TFS4209
		_attrName = ETRow_Carrier then										//29.03.2024 navhl20 #63251
		return self.carrierId;
		
	//Start 18/05/2022 navhl20 TFS 53430 
	elseif _attrName = ETRow_SubCarrierCodeDesc then												 
		if self.myVehicleVisit &lt;&gt; null then
			subCarrier := self.myVehicleVisit.getSubCarrier;	
			if subCarrier&lt;&gt; null then
				return subCarrier.code &amp; " - " &amp; subCarrier.description;
			endif;
		endif;
		return null;
	//End 18/05/2022 navhl20 TFS 53430 
	
	elseif _attrName = ETRow_CreationTime then
		return self.systemToLocalTime(self.createdTime).time.format("HH:mm, ");	// 20/4/16 cnwmp6 TFS 488 - Multi timezone changes
	
	elseif _attrName = ETRow_CreationDate then
		return self.systemToLocalTime(self.creationTime).date.format("MMM dd");	// 20/4/16 cnwmp6 TFS 488 - Multi timezone changes

	/*
	//Commented because we already did this in super class
	//01.08.2024 navhl20 #65363
	elseif _attrName = ETRow_CreationDateTime then
		return self.systemToLocalTime(self.createdTime).String;	// 20/4/16 cnwmp6 TFS 488 - Multi timezone changes*/

	elseif _attrName = ETRow_LocationId then
		if (not self.isRelease) then
			return self.myVehicle.regNumber;
		else
			return null;
		endif;
	elseif _attrName = ETRow_RegNumber then
		if self.myVehicle &lt;&gt; null then
			return self.myVehicle.regNumber;
		else
			return self.regNumber;
		endif;
	
	elseif _attrName = ETRow_Seperator then
		return null;
	
	elseif _attrName = ETRow_JobRoadRelease then
		return self.jobNumber;
	elseif _attrName = ETRow_JobRoadReceive then
		return self.jobNumber;
	/*27.03.2024 navbs1 #63212
	// Start 25/08/2022 navds21 TFS 54619
	elseif _attrName = ETRow_DoorDirection then
        return self.getDoorDirection();
	// End 25/08/2022 navds21 TFS 54619	
	*/
	//Start 20.12.2022 navmp20 TFS 55580
	elseif _attrName = ETRow_GateInCheckStatus then
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.gateInCheckStatus;
		endif;
		return null;
	elseif _attrName = ETRow_GateInCheckTS then
		if self.myVehicleVisit &lt;&gt; null and self.myVehicleVisit.gateInCheckTS &lt;&gt; null then
			return self.myVehicleVisit.gateInCheckTS.String;
		endif;
		return null;
	elseif _attrName = ETRow_GateOutCheckStatus then
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.gateOutCheckStatus;
		endif;
		return null;
	elseif _attrName = ETRow_GateOutCheckTS then
		if self.myVehicleVisit &lt;&gt; null and self.myVehicleVisit.gateOutCheckTS &lt;&gt; null then
			return self.myVehicleVisit.gateOutCheckTS.String;
		endif;
		return null;
	elseif _attrName = ETRow_TrailerIn then		
		if self.myVehicleVisit &lt;&gt; null and self.myVehicleVisit.myInCMGTE_Chassis &lt;&gt; null then
			return self.myVehicleVisit.myInCMGTE_Chassis.id;
		endif;
		return null;
	elseif _attrName = ETRow_TrailerOut then	
		if self.myVehicleVisit &lt;&gt; null and self.myVehicleVisit.myOutCMGTE_Chassis &lt;&gt; null then
			return self.myVehicleVisit.myOutCMGTE_Chassis.id;
		endif;
		return null;
	//End 20.12.2022 navmp20 TFS 55580
	//Start 09.03.2023 navmp20 TFS 57024
	elseif _attrName = ETRow_TrailerType then                       
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.getTrailerTypeCode(null);
		endif;
		return null;
	//End 09.03.2023 navmp20 TFS 57024
	//start 10.03.2023 navsa20 TFS 55843
	elseif _attrName = ETRow_ExternalRef then                                                               
		if vvr &lt;&gt; null then
			if vvr.allVehicleBookingSlots.isEmpty then 
				return null;
			endif;
			
			str := null;
			foreach vbsSlot in vvr.allVehicleBookingSlots do
				str &amp;= vbsSlot.externalReference &amp; ", ";
			endforeach;
			
			str := str.stripTrailingChar(",");
			
			return str;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_VbsId then
		if vvr &lt;&gt; null then
			if vvr.allVehicleBookingSlots.isEmpty then
				return null;
			endif;
			
			str := null;
			foreach vbsSlot in self.myVehicleVisit.allVehicleBookingSlots do
				str &amp;= vbsSlot.id &amp; ", ";
			endforeach;
			
			str := str.stripTrailingChar(",");
			
			return str;
			
		endif;
		
		return null;
	//End 10.03.2023 navsa20 TFS 55843
	elseif _attrName = ETRow_BarrierInCode then  //jlier1 TFS  57936 18/5/23
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.getBarrierInCode();
		endif;
		return null;
	elseif _attrName = ETRow_BarrierOutCode then  //jlier1 TFS  57936 18/5/23
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.getBarrierOutCode();
		endif;
		return null;
	elseif _attrName = ETRow_BarrierInTime then  //jlier1 TFS  57936 18/5/23
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.getBarrierInTime();
		endif;
		return null;
	elseif _attrName = ETRow_BarrierOutTime then  //jlier1 TFS  57936 18/5/23
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.getBarrierOutTime();
		endif;
		return null;
	elseif _attrName = ETRow_BarrierValidityIn then  //jlier1 TFS  57936 18/5/23
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.getBarrierValidityIn();
		endif;
		return null;
	elseif _attrName = ETRow_BarrierValidityOut then  //jlier1 TFS  57936 18/5/23
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.getBarrierValidityOut();
		endif;
		return null;
	elseif _attrName = ETRow_InspectionCheck then											//14.6.2023 navhl20 #58543
		if vvr &lt;&gt; null then
			if vvr.allVehicleBookingSlots.isEmpty then
				return null;
			endif;
			if vvr.allVehicleBookingSlots.first.preGateInCheck then
				return vvr.allVehicleBookingSlots.first.preGateInCheck.getYes();
			elseif vvr.allVehicleBookingSlots.first.preGateOutCheck then
				return vvr.allVehicleBookingSlots.first.preGateInCheck.getYes();
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_CargoLocation then // 20.09.2023 navlw1 tfs #60382
		ti := self.getFirstTrackedItem();
		if ti &lt;&gt; null then
			return ti.locationId;
		endif;
		return null;
	elseif _attrName = ETRow_CargoSubType then // 20.09.2023 navlw1 tfs #60382
		return self.getCargoSubType();
	elseif _attrName = ETRow_Commodity then // 20.09.2023 navlw1 tfs #60382
		return self.getCommodity();
	elseif _attrName = ETRow_IMEXStatus then // 20.09.2023 navlw1 tfs #60382
		return self.getIMEXStatus();
	/*
	//29.03.2024 navhl20 #63251
	elseif _attrName = ETRow_Carrier then // 20.09.2023 navlw1 tfs #60382
		ti := self.getFirstTrackedItem();
		if ti &lt;&gt; null then
			return ti.getCarrierDescription();
		endif;
		return null;*/
	elseif _attrName = ETRow_FirstWarehouse then // 22.09.2023 navlw1 tfs #60382
		//return self.plannedLocations;					//26.02.2024 navhl20 #61869
		//return self.plannedLocation; 					//26/08/2024	navkc1 CR 63588 Task 63589
		//19/11/2024	navkc1 JIRA Bug MTN-33448
		if self.plannedTerminalAreas &lt;&gt; null then
			index := 1;
			return self.plannedTerminalAreas.scanUntil(Comma, index);
		endif;
		return null;
	elseif _attrName = ETRow_TruckSeals then 			//11.01.2024 navbs1 #61971
		if self.myVehicleVisit &lt;&gt; null then
			return self.myVehicleVisit.getSealNumbersOnly();
		endif;
		return null;
	elseif _attrName = ETRow_RetrospectiveDT then		//20.02.2024 navnk30 #62414
		return self.retrospectiveDT.asStringJMT();
	elseif _attrName = ETRow_ReleaseNumber then		//07-Aug-2025 naviv1 MTN-35544
		return self.getReleaseNumber();
	endif;															//16.05.2023 navma1 #57714
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDoorDirection" id="ef111aec-3b90-41b5-8935-414e5f999656">
        <source>getDoorDirection(wle :CM_WorkListEntry):String;
/*



Purpose:            



Parameters:            



Return Value:        	

Date		Who		Reason
25 Aug 2022	navds21 TFS 54619 POL - Include the Door Direction field in Road Exit screen
27 Mar 2023 navbs1	Bug 63212: POL - Door direction in Vehicle app is wrong

*/
vars
	doorDirection : String;
begin
	/*27.03.2024 navbs1 #63212
    if self.allRequests.size &gt;0  then
        if self.allRequests.first.getDoorsDirection = TI_DOORSDIRN_FWD then    
            return app.getErrorString(Forward);
        elseif self.allRequests.first.getDoorsDirection = TI_DOORSDIRN_AFT then    
            return app.getErrorString(AftWord);
        else
            return app.getErrorString(NotApplicable);
        endif;    
    endif;*/
	
	//27.03.2024 navbs1 #63212
	if wle.myRequest &lt;&gt; null then 
		doorDirection := wle.myRequest.getDoorDirectionDescription(wle.getTargetLocation(), wle.myTrackedItem);
	endif;
	if doorDirection = null then
		doorDirection := app.getErrorString(NotApplicable);
	endif;
	return doorDirection;
epilog

end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
        <ReturnType type="String"/>
    </JadeMethod>
