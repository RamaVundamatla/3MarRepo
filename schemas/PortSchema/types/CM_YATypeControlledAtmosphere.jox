begin
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="d1e6e251-434b-4240-a142-84329fa9124a">
        <source>isCMIFDataMatch( _cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean ): Boolean;
// --------------------------------------------------------------------------------
// Created:		18 September 2007 by cnwvu1
// --------------------------------------------------------------------------------

vars

begin
	return _cmifAutoPlan.isControlledAtmosphere_Match(_yaData);
end;
</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPrimitiveValue" id="f53bab4e-f477-4673-a265-477d5838623c">
