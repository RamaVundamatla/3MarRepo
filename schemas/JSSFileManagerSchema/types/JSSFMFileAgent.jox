//
// Purpose:		AppServer node wrapper for the closeDiskFile method.
// --------------------------------------------------------------------------------
begin
	self.closeDiskFile(pDiskFileObj);
end;</source>
        <access>protected</access>
        <Parameter name="pDiskFileObj" type="File" usage="io"/>
    </JadeMethod>
