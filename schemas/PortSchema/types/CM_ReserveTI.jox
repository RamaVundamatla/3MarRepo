    <JadeMethod name="getReleaseNumberDescr" id="5c0ac011-d566-4e0a-a000-bb4f698325a9">
        <source>getReleaseNumberDescr(): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 16 September 2008
//
// Implemented version:
// 
// PAR17915 - cnwsh3 17/9/2008 - display a different format for tracked items
// SFW1035	- consw1 24/9/2009 - Changed CM_ReserveTI methods to use getTI for consistency.
//----------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	//PAR17915 - identified but not causing any issues - The releaseTI should display the ti it is related to.
	//as there should only ever be one ti.  If there are more then we display the generic 
	//display
	ti := self.getTI();
	if ti &lt;&gt; null then
		return self.myReserveHeader.code &amp; " " &amp; ti.id;
	else
		return inheritMethod();
	endif;

epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
