    <JadeMethod name="getDiscrepancy" id="8cbef8a4-1d70-422b-b9e0-07f06ce49fe9">
        <source>getDiscrepancy(aStr : String output): Boolean;
/*
 ------------------------------------------------------------------------
Created:			07 February 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	aStr := null;
	if self.availability = PAD_USER_UNAVAILABLE then
		aStr := app.getErrorString1(DiscrepancyLocnUnavailable, self.getFullId);
		return true;
	endif;
	return inheritMethod(aStr);	//Also call superclass (cm_gridController's version)
end;</source>
        <Parameter name="aStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDrawingAttributes" id="9b0b8e01-cd63-4190-b237-5294ddc4b885">
        <source>getDrawingAttributes(pDisplay, pView : Integer; pHeight : Integer; 
					 pColour : Integer output; pLetter : String output);
/*
----------   ----------  --------------------------------------------------
Created:	11 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpSize,
	tmpUsage,
	tmpAvail	: Integer;
	array		: CM_TIArray;
	ls			: Boolean;
	sbs 		: CM_BlockStack;
begin
	inheritMethod(pDisplay, pView,pHeight, pColour, pLetter);

	tmpUsage	:= self.usage;
	tmpAvail	:= self.availability;

	sbs := self.mySubBlockStack;
	if sbs &lt;&gt; null then
		pColour := LightYellow;
		if sbs.myLayoutGraphic &lt;&gt; null then
			pColour := sbs.myLayoutGraphic.drawLineColour;
		endif;
		pLetter := GridPointType_SubBlock  &amp; sbs.id;

	elseif tmpUsage = BUILDING_USE then
		pColour := WindowsGrey;
		pLetter := GridPointType_Building;
		
	elseif tmpUsage = LIGHT_TOWER_USE then
		pColour := Yellow;
		pLetter := GridPointType_Light;
	
	elseif self.usage = REEFERGANTRY_USE then
		pColour := Color_ReeferGantry;
		pLetter := GridPointType_ReeferGantry;
		
	elseif tmpAvail &gt; PAD_USER_UNAVAILABLE then 
		if pHeight &gt;= tmpAvail - 2 or pHeight = 0 then
			pColour := Grey;
			pLetter := GridPointType_RestHeight;
		endif;

	elseif tmpUsage = UNAVAILABLE_USE or 
		   tmpAvail = PAD_USER_UNAVAILABLE or 
		   tmpAvail = PAD_UNAVAILABLE then 
		pColour := WindowsGrey;
		pLetter := GridPointType_Unavailable;

	elseif pHeight &gt; 0 then

		create array transient;	
		self.getTIs(array, PLANNING_MODE, true); // PAR 27749
		tmpSize := array.size;

		if tmpSize &gt; 0 and pHeight &lt;= tmpSize then
			if array[pHeight] &lt;&gt; null then
				pLetter := "P";
				if pColour = NULL_COLOURCODE then // this may have been set for restrictions in superclass so keep the restriction colour
					pColour := Gray;
				endif;
			endif;
		else
			self.getTIs(array, QUEUE_MODE, true); // PAR 27749
			tmpSize := array.size;
			if tmpSize &gt; 0 and pHeight &lt;= tmpSize then
				if array[pHeight] &lt;&gt; null then
					pLetter := "Q";
					if pColour = NULL_COLOURCODE then
						pColour := Gray;
					endif;
				endif;
			else
				tmpSize := self.allTrackedItems.size;
				if tmpSize &gt; 0 and pHeight &lt;= tmpSize then
					if self.allTrackedItems[pHeight] &lt;&gt; null then
						pLetter := "A";
						if pColour = NULL_COLOURCODE then
							pColour := Gray;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;

epilog
//	app.cmsEndLoad(ls);
	delete array;
end;</source>
        <Parameter name="pDisplay" type="Integer"/>
        <Parameter name="pView" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pColour" type="Integer" usage="output"/>
        <Parameter name="pLetter" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFirstUnavailableHeight" id="a7dc0edd-2c05-476c-9a9d-340eec2a55b5">
        <source>getFirstUnavailableHeight(): Integer;
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.amIAvailable then
		if self.availability &gt; 2 then
			return inheritMethod();
		else
			//all heights are available
			return 0;
		endif;
	else
		return 1;	//unavailable from height 1
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFullId40" id="61029821-171a-42b4-9e4e-1cd32fdfcdfd">
        <source>getFullId40(): String;
// ---------------------------------------------------------------------------
// Created:		18 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16/11/2011	cnwmh5	#28693 - Change back so doesn't have space between area and id
vars
	areaId : String; 
begin
	//epr par 19259 26/3/09
	areaId :=  self.myGridArea.getID();
	
	return areaId &amp; self.getID40();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdForTIForMode" id="adc96ac7-2a82-4bf9-a91a-f7b1b0bf7348">
        <source>getFullIdForTIForMode(_moveMode: Integer): String;
// ---------------------------------------------------------------------------
// Created:		25 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	theTIS: CM_TIArray;
	stackPos : Integer;
begin
	
	
	if _moveMode = REAL_MODE then
		theTI := self.allTrackedItems.first;
		stackPos := self.numTIs;
	elseif _moveMode = PLANNING_MODE then
		create theTIS transient;
		self.getAllPlannedTrackedItems(theTIS, true, false);
		theTI := theTIS.first;
		stackPos := self.numPlannedTIs; //epr par 20498 14/9/09 removed the + 1 
	elseif _moveMode = QUEUE_MODE then
		create theTIS transient;
		self.getAllQueuedTrackedItems(theTIS, true);
		theTI := theTIS.first;
		stackPos := self.numQueuedTIs;// epr par 14555 6/8/07
	endif;

	return self.getFullIdTI(theTI) &amp; " " &amp; stackPos.String; 
	
epilog
	delete theTIS;

end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdTI" id="543c6867-675d-4d6b-8936-135e5250ec9b">
        <source>getFullIdTI(_ti: CM_TrackedItem): String;
// ---------------------------------------------------------------------------
// Created:		21 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _ti = null then
		return self.getFullId(); 
	endif;
	if not self.myGridArea.use40ftIds then
		return self.getFullId(); 
	endif;
	if  (_ti.isAttributeTrue(TI_Attrib_IsForty) or _ti.isOverSizedContainer) then
		return self.getFullId40(); 
	else
		return self.getFullId(); 
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
