    <JadeMethod name="btnSaveIconToDisk_click" id="cd6ef197-c2eb-45e9-822b-122a86c8d7d7">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSaveIconToDisk_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
09 September 2021	navab1	TFS 51853
*/

vars

	folder : FileFolder;
	fileNode : FileNode;
	file : File;
	localfiles : FileNodeArray;
	bin, key : Binary;
	icon : CMUI_ToolbarIcon;
	newName : String;
begin
	if self.txtIconName.text = "" then
		global.beep;
		return;
		
	endif;
	
	icon := self.tblData.allSelectedObjects.first.CMUI_ToolbarIcon;
	
	if icon = null then
		global.beep;
		return;
	endif;
	
	create folder;
	folder.fileName := "F:\Documentation\Internal\Resources\Graphics\JMTIcons\16x16Missing\";
	
	create file;
	
	// ### ENABLED
	if icon.enabledIconOld &lt;&gt; null 
	and icon.enabledIconNameDisk = "" then // I do not know what this is called
		file.kind := File.Kind_Binary;
		file.fileName := "F:\Documentation\Internal\Resources\Graphics\JMTIcons\16x16Missing\" &amp; self.txtIconName.text &amp; "_EN.ico";
		file.writeBinary(icon.enabledIconOld);
		file.commit;
		file.close;
		beginTransaction;
		icon.enabledIconNameDisk := self.txtIconName.text &amp; "_EN.ico";
		commitTransaction;
	endif;
	
	
	// ### DISABLED
	if icon.disabledIconOld &lt;&gt; null 
	and icon.disabledIconNameDisk = "" then // I do not know what this is called
		file.fileName := "F:\Documentation\Internal\Resources\Graphics\JMTIcons\16x16Missing\" &amp; self.txtIconName.text &amp; "_DIS.ico";
		file.writeBinary(icon.disabledIconOld);
		file.commit;
		file.close;
		beginTransaction;
		icon.disabledIconNameDisk := self.txtIconName.text &amp; "_DIS.ico";
		commitTransaction;
	endif;
	
	global.beep;
	self.tblData.deselectAll();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
