<Class name="CMIF_OutputField_Min" id="93987376-5b04-43de-8374-f34bf0c19ebc">
    <superclass name="CMIF_OutputField"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="min" id="f239e4d0-2c1f-4ff5-9ac9-28da99474d84">
        <precision>23</precision>
        <scaleFactor>8</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="618e0de6-62d9-4959-8c7d-d00d7109efd0">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// if we leave 'min' at zero we can't handle min values &gt; 0
	self.min := Max_Integer.Decimal;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCollectionForDrillDown" id="794e32dc-4a17-4e8c-9e60-01f5d77f78e5">
        <source>getCollectionForDrillDown(): ObjectSet;
// ---------------------------------------------------------------------------
// Created:     22 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2010	cnwcs5		par 22435 - release summary changes
// ---------------------------------------------------------------------------
vars

begin
	return self.allObjects;
epilog

end;</source>
        <ReturnType type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="329a7e39-2785-45dc-81e0-1a56712bf4f4">
        <source>getValue(): String;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwcs5		ccms 1028 - supress 0 values
// ---------------------------------------------------------------------------
vars
	value	:Decimal[23,8];
begin
	value := self.min;		// cnwcs5 07/12/2009
	
	if value = 0 then		// cnwcs5 07/12/2009
		return null;		// cnwcs5 07/12/2009
	endif;					// cnwcs5 07/12/2009
	
	return value.roundedTo (self.decimals).asStringJMTWithPrecision (self.decimals, self.useSeperator);	// cnwcs5 07/12/2009

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isMin" id="8ff54dcb-79c0-4b45-ba1c-f70c770d2ecf">
        <source>isMin(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSelf" id="70644d93-ea35-4601-bde9-b5a69a22b234">
        <updating/>
        <source>updateSelf(_value: Any; _obj :Object) updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2010	cnwcs5		par 22435 - release summary extenstions
// ---------------------------------------------------------------------------
vars

begin
	if _value.isKindOf (CM_SnapshotField_Min) then
		if _value.CM_SnapshotField_Min.min &lt; self.min then
			self.min := _value.CM_SnapshotField_Min.min;
		endif;
	else
		if _value.Decimal = self.min then					// 22/02/2010 par 22435
			// keep all objects that have the min value
			self.allObjects.addNoDuplicates (_obj, false);	// 22/02/2010 par 22435
		endif;	
		
		if _value.Decimal &lt; self.min then
			self.min := _value.Decimal;
			
			self.allObjects.clear;							// 22/02/2010
			self.allObjects.addNoDuplicates (_obj, false);	// 22/02/2010
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
