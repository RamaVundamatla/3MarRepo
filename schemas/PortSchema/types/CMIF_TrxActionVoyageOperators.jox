<Class name="CMIF_TrxActionVoyageOperators" id="5ecc7f05-429c-4210-9f4f-15e19fe1ef34">
    <superclass name="CMIF_TrxPostAction"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmsmap"/>
    <ImplicitInverseRef name="myVoyage" id="17aac434-23bd-4e03-8828-0ce55e0cb574">
        <embedded/>
        <type name="CM_Voyage"/>
    </ImplicitInverseRef>
    <PrimAttribute name="operatorCode" id="d7b5a7c8-8b55-4c1b-aaf8-25ef8b8b7d17">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="action" id="e9162ce6-b460-4cf6-81f3-5c7cfa6cbff9">
        <updating/>
        <source>action(_passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2025	naviv1	Initial creation - JIRA MTN-34341 NSW | 34310.020 Setting Operators on Voyage from IFCSUM files

*/

vars
	operator : CM_Operator;
	passport : CM_Passport;
begin
	
	if self.myVoyage = null or not global.isValidObject(self.myVoyage) then
		return;
	endif;
	
	operator := app.myRoot.allOperators[self.operatorCode];
	if operator = null then
		return;
	endif;
	
	passport := _passport;
	passport.setWarningsIgnored(true);
	passport.setWarningsAcknowledged(true);
	
	app.myTrxUA.trxUpdateVoyageWithOperator(self.myVoyage,operator,passport);
	
	passport.clearErrorsWarnings;
	passport.initialiseTransaction;
	passport.finaliseTransaction(TRXStatus_Committed);
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createAction" id="14d595ba-b08a-4ca8-968f-ae2bfd4340b2">
        <options>4</options>
        <source>createAction(_voyage : CM_Voyage input; _operatorCode : String; _passport : CM_Passport) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2025	naviv1	Initial creation - JIRA MTN-34341 NSW | 34310.020 Setting Operators on Voyage from IFCSUM files

*/

vars
	trxPA					: CMIF_TrxPostAction;
	tvoyagePortTrxAction	: CMIF_TrxActionVoyageOperators; 
begin
	if (_voyage = null or _operatorCode = null)  then
		return;
	endif;
	
	foreach trxPA in _passport.allTrxPostActions where trxPA.isKindOf(CMIF_TrxActionVoyageOperators) do
		if trxPA.CMIF_TrxActionVoyageOperators.myVoyage = _voyage and 
			trxPA.CMIF_TrxActionVoyageOperators.operatorCode = _operatorCode then
			return;
		endif;
	endforeach;
		
	create tvoyagePortTrxAction transient;
	tvoyagePortTrxAction.myVoyage := _voyage;
	tvoyagePortTrxAction.operatorCode := _operatorCode;
		
	_passport.addTrxPostAction(tvoyagePortTrxAction);
		
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
