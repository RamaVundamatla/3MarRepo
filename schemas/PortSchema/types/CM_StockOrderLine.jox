    <JadeMethod name="doMatch" id="4884c8be-67a3-43a7-bf71-6d3550b028d7">
        <updating/>
        <source>doMatch(_bolOut : CM_BOLOut; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2004	cnwth2
//
// Purpose:     Need to re-implement this - sub-class will have it's own way of matching
//				with bolOut.allTrackedItems
//			 
// ----------   ----------  --------------------------------------------------
vars

begin


end;</source>
