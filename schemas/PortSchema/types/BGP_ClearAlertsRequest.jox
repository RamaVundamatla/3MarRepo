<Class name="BGP_ClearAlertsRequest" id="6d6384ba-06bc-4c4d-9b93-0e6490a4b2b9">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
