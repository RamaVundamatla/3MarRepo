    <JadeMethod name="doInputReadyLogGrade" id="0acd62e7-2ab9-4012-a408-b2d913c8dab8">
        <updating/>
        <source>doInputReadyLogGrade(_assistantObj:GTE_Assistant input; _comboboxObj:GTE_ComboBox input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		19 August 2008 by cnwdad1
//
// Purpose:		Processes the cellInputReady event of a data input table control
//				for the Log Grade combobox control.
//
// Parameters:	_assistantObj - A reference to the Gate Assistant object.
//				_comboboxObj - A reference to the combobox control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	extraTbl		: CM_EntryTable;
	sheetObj		: GTE_Sheet;
	speciesCmb		: GTE_ComboBox;
	lengthCmb		: GTE_ComboBox;
	treatmentCmb	: GTE_ComboBox;
	typeCmb			: GTE_ComboBox;
	
begin
	sheetObj	:=	_comboboxObj.mySheet;
	speciesCmb	:=	sheetObj.getControlByName(Cntrl_cmbLogSpecies).GTE_ComboBox;
	self.setCellTextFromControl(sheetObj, speciesCmb, speciesCmb.text);
	
	if self.origValueStr &lt;&gt; speciesCmb.text then
		self.origValueStr	:=	_comboboxObj.text;
		extraTbl			:=	sheetObj.myTblExtra;
		lengthCmb			:=	sheetObj.getControlByName(Cntrl_cmbLogLength).GTE_ComboBox;
		treatmentCmb		:=	sheetObj.getControlByName(Cntrl_cmbTreatment).GTE_ComboBox;
		typeCmb				:=	sheetObj.getControlByName(Cntrl_cmbLogType).GTE_ComboBox;
		
		_assistantObj.setLogGrade(	speciesCmb.listObject.CM_LogSpecies,
									null,
									null,
									null,
									null,
									extraTbl,
									_comboboxObj,
									typeCmb,
									treatmentCmb,
									lengthCmb);
		
		//_assistantObj.mySpecies := speciesCmb.listObject.CM_LogSpecies;
		sheetObj.myLogSpecies := speciesCmb.listObject.CM_LogSpecies;		// PAR 15424
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_assistantObj" type="GTE_Assistant" usage="input"/>
        <Parameter name="_comboboxObj" type="GTE_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doInputReadyLogType" id="c5e78221-2367-42d5-9927-fd5cd5400168">
        <updating/>
        <source>doInputReadyLogType(_assistantObj:GTE_Assistant input; _comboboxObj:GTE_ComboBox input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		19 August 2008 by cnwdad1
//
// Purpose:		Processes the cellInputReady event of a data input table control
//				for the Log Type combobox control.
//
// Parameters:	_assistantObj - A reference to the Gate Assistant object.
//				_comboboxObj - A reference to the combobox control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	logGrade		: CM_LogGrade;
	sheetObj		: GTE_Sheet;
	entryTable		: CM_EntryTable;
	gradeCmb		: GTE_ComboBox;
	treatmentCmb	: GTE_ComboBox;
	lengthCmb		: GTE_ComboBox;
	
begin
	sheetObj	:=	_comboboxObj.mySheet;
	gradeCmb	:=	sheetObj.getControlByName(Cntrl_cmbLogGrade).GTE_ComboBox;
	self.setCellTextFromControl(sheetObj, gradeCmb, gradeCmb.text);
	
	if self.origValueStr &lt;&gt; gradeCmb.text then
		self.origValueStr	:=	gradeCmb.text;
		entryTable			:=	sheetObj.myTblExtra;
		treatmentCmb		:=	sheetObj.getControlByName(Cntrl_cmbTreatment).GTE_ComboBox;
		lengthCmb			:=	sheetObj.getControlByName(Cntrl_cmbLogLength).GTE_ComboBox;
		logGrade			:=	gradeCmb.listObject.CM_LogGrade;
		
		_assistantObj.setLogType(entryTable, _comboboxObj, logGrade, null);
		_assistantObj.setLogTreatment(entryTable, treatmentCmb, logGrade, null);
		_assistantObj.setLogLength(entryTable, lengthCmb, logGrade, null);
		//_assistantObj.myLogGrade := logGrade;		PAR - 15424
		sheetObj.myLogGrade := logGrade;				// PAR - 15424
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_assistantObj" type="GTE_Assistant" usage="input"/>
        <Parameter name="_comboboxObj" type="GTE_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadLogDocketData" id="1803d771-ee5d-43d9-9757-d129335da6fe">
        <updating/>
        <source>doLoadLogDocketData() protected, updating;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	logDocketData			: CM_LogDocketData;

begin
	if not self.myTerminal.getConfig(WeighBridgeEnabled).Boolean then
		return;
	endif;
	
	self.tblLogDocketData.rows := self.tblLogDocketData.fixedRows;
	foreach logDocketData in self.myTerminal.allLogDocketDataByDocketNo do
		self.addLogDocketDataRow(logDocketData);
	endforeach;
	
	self.doLogDocketDataSort();
	self.tblLogDocketData.leftColumn := 1;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLogComboSetup" id="06f4d441-bf2a-48d1-9c8e-29e84cf661c1">
        <updating/>
        <source>doLogComboSetup(_assistantObj:GTE_Assistant input; _comboboxObj:GTE_ComboBox input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		19 August 2008 by cnwdad1
//
// Purpose:		Sets up the various comboboxes for Log Dockets, such as Operator,
//				Log Species, Log Grade, Log Type, Log Treatment and Log Length.
//
//				These comboboxes have dependencies on each other which dictates
//				what data they are populated with.
//
// Parameters:	_assistantObj - A reference to the Gate Assistant object.
//				_comboboxObj - A reference to the combobox control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	extraTbl		: CM_EntryTable;
	sheetObj		: GTE_Sheet;
	speciesCmb		: GTE_ComboBox;
	tempCmb			: GTE_ComboBox;
	supplierCmb		: GTE_ComboBox;
	gradeCmb		: GTE_ComboBox;
	typeCmb			: GTE_ComboBox;
	treatmentCmb	: GTE_ComboBox;
	lengthCmb		: GTE_ComboBox;
	subSubCmb		: GTE_ComboBox;
	docketErrorCmb	: GTE_ComboBox; //ccms 1110
	tmpOperator		: CM_Operator;
	tmpLogSpecies	: CM_LogSpecies;
	tmpLogGrade		: CM_LogGrade;
	tmpLogType		: CM_LogType;
	tmpLogTreat		: CM_LogTreatment;
	tmpLogLength	: CM_LogLength;
	
begin

	sheetObj	:=	_comboboxObj.mySheet;

	extraTbl		:= sheetObj.myTblExtra;
	supplierCmb		:= sheetObj.getControlByName(GTE_InOutForm::cmbSupplier.name).GTE_ComboBox;
	speciesCmb 		:= sheetObj.getControlByName(GTE_InOutForm::cmbLogSpecies.name).GTE_ComboBox;		
	gradeCmb 		:= sheetObj.getControlByName(GTE_InOutForm::cmbLogGrade.name).GTE_ComboBox;			
	typeCmb 		:= sheetObj.getControlByName(GTE_InOutForm::cmbLogType.name).GTE_ComboBox;			
	treatmentCmb	:= sheetObj.getControlByName(GTE_InOutForm::cmbTreatment.name).GTE_ComboBox;			
	lengthCmb		:= sheetObj.getControlByName(GTE_InOutForm::cmbLogLength.name).GTE_ComboBox;		
	docketErrorCmb  := sheetObj.getControlByName(GTE_InOutForm::cmbDocketError.name).GTE_ComboBox;	//ccms 1110

	tmpOperator	   :=	supplierCmb.listObject.CM_Operator;
	tmpLogSpecies  := speciesCmb.listObject.CM_LogSpecies;
	tmpLogGrade    :=gradeCmb.listObject.CM_LogGrade;
	tmpLogType     :=typeCmb.listObject.CM_LogType;
	tmpLogTreat	   :=treatmentCmb.listObject.CM_LogTreatment;
	tmpLogLength   :=lengthCmb.listObject.CM_LogLength;
	
	if _comboboxObj.name = GTE_InOutForm::cmbLogLength.name then
		// need to check for change of operator, species, grade, type, treat
		if tmpLogLength &lt;&gt; sheetObj.myLogLength then
			sheetObj.myLogLength	:=	tmpLogLength;
		endif;
		
	elseif _comboboxObj.name = GTE_InOutForm::cmbTreatment.name then
		// need to check for change of operator, species, grade, type
		if tmpLogTreat &lt;&gt; sheetObj.myLogTreatment then
			sheetObj.myLogTreatment	:=	tmpLogTreat;
		endif;
			
	elseif _comboboxObj.name = GTE_InOutForm::cmbLogType.name then	
	// need to check for change of operator, species, grade
		if tmpLogType &lt;&gt; sheetObj.myLogType then
			sheetObj.myLogType := tmpLogType;
			self.myAssistant.GTE_Assistant.setLogTreatment(extraTbl, treatmentCmb, tmpLogGrade, null);
		endif;
			
	elseif _comboboxObj.name = GTE_InOutForm::cmbLogGrade.name then	
	// need to check for change of operator, species
		if tmpLogGrade &lt;&gt; sheetObj.myLogGrade then
			// need to reset all fields further down
			
			sheetObj.myLogGrade	:=	_comboboxObj.listObject.CM_LogGrade;
			typeCmb := sheetObj.getControlByName(GTE_InOutForm::cmbLogType.name).GTE_ComboBox;			
			
			self.myAssistant.GTE_Assistant.setLogType(extraTbl, typeCmb, tmpLogGrade, null);
			self.myAssistant.GTE_Assistant.setLogTreatment(extraTbl, treatmentCmb, tmpLogGrade, null);	
			self.myAssistant.GTE_Assistant.setLogLength(extraTbl, lengthCmb, tmpLogGrade, null);
		endif;

	elseif _comboboxObj.name = GTE_InOutForm::cmbLogSpecies.name then
		// need to check for change of operator
		if tmpLogSpecies &lt;&gt; sheetObj.myLogSpecies then
			// need to reset all fields further down
			sheetObj.myLogSpecies := _comboboxObj.listObject.CM_LogSpecies;
			gradeCmb := sheetObj.getControlByName(GTE_InOutForm::cmbLogGrade.name).GTE_ComboBox;
			lengthCmb := sheetObj.getControlByName(GTE_InOutForm::cmbLogLength.name).GTE_ComboBox;
			treatmentCmb := sheetObj.getControlByName(GTE_InOutForm::cmbTreatment.name).GTE_ComboBox;
			typeCmb := sheetObj.getControlByName(GTE_InOutForm::cmbLogType.name).GTE_ComboBox;			
			
			self.myAssistant.GTE_Assistant.setLogGrade(tmpLogSpecies, null, null, null, null, extraTbl, 
													gradeCmb, typeCmb, treatmentCmb, lengthCmb);
		endif;
		
	elseif tmpOperator &lt;&gt; sheetObj.myOperator then
			
		sheetObj.clearLogSpecReferences();
		sheetObj.myOperator := tmpOperator;

		extraTbl			:=	sheetObj.myTblExtra;
	
		
		_assistantObj.setLogSpecies(sheetObj.myOperator,
									sheetObj.myLogSpecies,
									sheetObj.myLogGrade,
									sheetObj.myLogType,
									sheetObj.myLogTreatment,
									sheetObj.myLogLength,
									extraTbl,
									speciesCmb,
									gradeCmb,
									typeCmb,
									treatmentCmb,
									lengthCmb);
		
		tempCmb	:=	sheetObj.getControlByName(cmbSrcLocn.name).GTE_ComboBox;
		if tempCmb &lt;&gt; null then					
			_assistantObj.setSourceLocns(extraTbl, tempCmb, tmpOperator);
		endif;
		
		tempCmb		:=	sheetObj.getControlByName(cmbSrcSubLocn.name).GTE_ComboBox;
		subSubCmb	:=	sheetObj.getControlByName(cmbSrcSubSubLocn.name).GTE_ComboBox;
		if _comboboxObj &lt;&gt; null and subSubCmb &lt;&gt; null then									
			_assistantObj.setSourceSubLocns(extraTbl, tempCmb,subSubCmb, null);	
		endif;
		
		tempCmb	:=	sheetObj.getControlByName(Cntrl_cmbStockOrder).GTE_ComboBox;
		
		if tempCmb &lt;&gt; null then					
			_assistantObj.comboBoxStockOrderHeader(tempCmb, tmpOperator, null);
		endif;		
	endif;
	
	/*
	self.setCellTextFromControl(sheetObj, supplierCmb, supplierCmb.text);
	
	if self.origValueStr &lt;&gt; supplierCmb.text then		// Supplier has changed.
		//_comboboxObj			:=	sheetObj.getControlByName(Cntrl_cmbLogSpecies).GTE_ComboBox;
		self.origValueStr	:=	_comboboxObj.text;
		extraTbl			:=	sheetObj.myTblExtra;
		operator			:=	supplierCmb.listObject.CM_Operator;
		
		sheetObj.clearLogSpecReferences();		// PAR 15424
		//_assistantObj.myOperator	:=	operator;
		sheetObj.myOperator := operator;		// PAR 15424
		
		speciesCmb 		:= sheetObj.getControlByName(GTE_InOutForm::cmbLogSpecies.name).GTE_ComboBox;		
		gradeCmb 		:= sheetObj.getControlByName(GTE_InOutForm::cmbLogGrade.name).GTE_ComboBox;			
		typeCmb 		:= sheetObj.getControlByName(GTE_InOutForm::cmbLogType.name).GTE_ComboBox;			
		treatmentCmb	:= sheetObj.getControlByName(GTE_InOutForm::cmbTreatment.name).GTE_ComboBox;			
		lengthCmb		:= sheetObj.getControlByName(GTE_InOutForm::cmbLogLength.name).GTE_ComboBox;			
		
		_assistantObj.setLogSpecies(operator,
									null,
									null,
									null,
									null,
									null,
									extraTbl,
									_comboboxObj,
									gradeCmb,
									typeCmb,
									treatmentCmb,
									lengthCmb);
		
		tempCmb	:=	sheetObj.getControlByName(cmbSrcLocn.name).GTE_ComboBox;
		if tempCmb &lt;&gt; null then					
			_assistantObj.setSourceLocns(extraTbl, tempCmb, operator);
		endif;
		
		tempCmb		:=	sheetObj.getControlByName(cmbSrcSubLocn.name).GTE_ComboBox;
		subSubCmb	:=	sheetObj.getControlByName(cmbSrcSubSubLocn.name).GTE_ComboBox;
		if _comboboxObj &lt;&gt; null and subSubCmb &lt;&gt; null then									
			_assistantObj.setSourceSubLocns(extraTbl, tempCmb,subSubCmb, null);	
		endif;
		
		tempCmb	:=	sheetObj.getControlByName(Cntrl_cmbStockOrder).GTE_ComboBox;
		
		if tempCmb &lt;&gt; null then					
			_assistantObj.comboBoxStockOrderHeader(tempCmb, operator, null);
		endif;		
	endif;
	*/
end;</source>
        <access>protected</access>
        <Parameter name="_assistantObj" type="GTE_Assistant" usage="input"/>
        <Parameter name="_comboboxObj" type="GTE_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLogDocketDataContext" id="b2045cbb-dd81-45f3-8205-47bfd64fe579">
        <updating/>
        <source>doLogDocketDataContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, y1					: Real;
	logDocketData				: CM_LogDocketData;
	idx						: Integer;
begin
	logDocketData := cntrl.accessRow(cntrl.row).itemObject.CM_LogDocketData;
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	  
	self.popupMenu(self.mnuLogDocketData, x1.Integer, y1.Integer);
	    
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogDocketDataPrefill" id="80afd463-147d-4501-ae85-c7ffc9d2f060">
        <source>doLogDocketDataPrefill(_docketNo : String) protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	logDocketData				: CM_LogDocketData;
	cargoType				: CM_CargoBOLType;
	rowIdx					: Integer;
	jRow					: JadeTableRow;
begin
	if _docketNo = null then//user double clicked one
		logDocketData := self.tblLogDocketData.accessRow(self.tblLogDocketData.row).itemObject.CM_LogDocketData;	
		if logDocketData = null then
			return;
		endif;
	else  //we've been given a docket number, so try and match it
		logDocketData := self.myTerminal.allLogDocketDataByDocketNo.getAtKey(_docketNo);
	endif;
	if logDocketData &lt;&gt; null then
		self.createMenuActionSheet(NavObj_GTE_In, logDocketData);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_docketNo" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLogDocketDataSort" id="9a5b93ff-7bf1-4865-ba27-bffd64bd5092">
        <updating/>
        <source>doLogDocketDataSort() protected, updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	self.sortColumnLogDocketData := self.tblLogDocketData.column;

	self.tblLogDocketData.accessColumn(self.sortColumnLogDocketData).sortOrder := 1;
	self.tblLogDocketData.accessColumn(self.tblLogDocketData.column).sortAsc := self.logDocketDataSortAscending;
	self.tblLogDocketData.accessedColumn.sortType := Table.SortType_Alpha;
	self.tblLogDocketData.resort;
	self.logDocketDataSortAscending := (not self.logDocketDataSortAscending);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuTransferDelete" id="d1809f96-a5b4-4fec-b23b-61c3a6f36be8">
        <updating/>
        <source>doMnuTransferDelete() updating;
//----------------------------------------------------------------
//	Created:	29 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti					: CM_TrackedItem;
	sht					: GTE_Sheet;
	sheetIdx			: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	ti := self.tblTransfers.accessRow(self.tblTransfers.row).itemObject.CM_TrackedItem;
	
	if ti = null then
		app.msgBox('Please select a Log Docket Data item to delete first.', ' Nothing selected', 0);
		return;
	endif;

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxRemoveTransfer(ti, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.fillTblTransfers();
			break;
		else
			theResult := app.showErrorWarningDialog('Delete Log Docket Data', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

end;</source>
    </JadeMethod>
