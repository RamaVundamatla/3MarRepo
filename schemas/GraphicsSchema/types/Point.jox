<PrimType name="Point">
    <JadeMethod name="insidePolygon" id="b5e1eeed-8986-4444-8196-8cb77a952fd1">
        <source>insidePolygon(polygon : PointArray) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	i, j     : Integer;
	c : Boolean;
begin

	c:=false;
	i := 1;
	j := polygon.size;
	while i &lt;= polygon.size do
 
		if (((polygon[i].y&gt;self.y) &lt;&gt; (polygon[j].y&gt;self.y)) and ( self.x &lt; (polygon[j].x- polygon[i].x) * (self.y-polygon[i].y)/(polygon[j].y-polygon[i].y)+polygon[i].x)) then
			c:=not c;
		endif;
	 
		i:=i+1;
		j:=i - 1;
	endwhile;
	 
	return c;
epilog

end;</source>
        <Parameter name="polygon" type="PointArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</PrimType>
