    <JadeMethod name="getSelectedObject" id="09eb54c0-e092-4baa-89ff-39de982b988c">
        <updating/>
        <source>getSelectedObject(): CM_SystemAlert updating;
//27 August 2008	cnwdw1	
//
vars

begin
	if self.row &gt; 0 then
		return self.accessRow(self.row).itemObject.CM_SystemAlert;
	endif;
end;</source>
        <ReturnType type="CM_SystemAlert"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObjects" id="1a0283a8-5fc6-43c1-a7ae-0bbc8f7d3134">
        <updating/>
        <source>getSelectedObjects() : ObjectArray updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2009	cnwml2	Initial creation PAR19594

*/

vars
	alert : CM_SystemAlert;
	row : Integer;
	oa : ObjectArray;

begin
	create oa transient;
	row := 2;
	while self.rows &gt;= row do
		if self.accessRow(row).selected then
			alert := self.accessRow(row).itemObject.CM_SystemAlert;
			oa.add(alert);
		endif;
		row := row + 1;
	endwhile;
	
	return oa;
epilog

end;</source>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="9b4a4a17-8ba0-4b3e-b2c9-3f6a4274373f">
        <updating/>
        <source>initialise() updating;
//15 August 2008	cnwdw1	
//
vars
begin
	self.clear();
	self.gridLines := true;
	self.fixedRows := 1;
	self.rows					:=	self.fixedRows;
	self.partialTextIndication	:=	true;
	self.wordWrap 				:=	true;
	self.selectionType := CM_BaseTable.SelectionType_Row;
	self.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.disallowColumnSorter := false;
	self.backColor := self.myForm.CM_BaseForm.colorControlBack;
	
	// Do the Column Headings
	self.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_FailToPlan));
	
	self.refresh;
	
	self.registerNotes();
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="refresh" id="6e336922-ca1a-490e-90fb-5cb1d6d77154">
        <updating/>
        <source>refresh() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Dec 2008	cnwdw1	Initial creation
11 Nov 2010	cnwkpd1	PAR #26238 - Speed up the refresh by using a path from the Alert Type

*/

vars
	alert			: CM_SystemAlert;
	alertType		: CM_SystemAlertType;
	iter			: Iterator;
	terminal		: CM_Terminal;
	
begin
	self.clearAllData();
	
	alertType := app.myRoot.allSystemAlertTypes[EVENT_AT_FailedAutoPlan];
	if alertType &lt;&gt; null then
		iter := alertType.allSystemAlerts.createIterator();
		alertType.allSystemAlerts.startKeyGeq(false, null, iter);
	
		terminal := self.getTerminal();
		
		while iter.next(alert) do
			if alert.reviewed then			// Only interested in unreviewed alerts
				break;
			endif;
			if alert.myTerminal = terminal and alert.myTrackedItem &lt;&gt; null then
				self.addItemObject(alert, alert.getAttributeStringForDefArray(self.allTblDataEntRows));
			endif;
		endwhile;
	endif;
	
	self.setParentCaption();	//09 Jan 2012	NDL	Par 28953
	
/*	PAR #26238 - old code replaced

	// Make sure nothing changes while loading the alert collection
	beginLoad;
		foreach alert in self.getTerminal.allSystemAlertsByDateTime 
			where alert.isType(EVENT_AT_FailedAutoPlan) and not alert.reviewed and alert.myTrackedItem &lt;&gt; null do
			self.addItemObject(alert, alert.getAttributeStringForDefArray(self.allTblDataEntRows));
		endforeach;
	endLoad;
*/

epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="registerNotes" id="b676fb88-1eba-48af-b0c0-72ac788ef180">
        <source>registerNotes();
//21 August 2008	cnwdw1	
//
vars
	terminal: CM_Terminal;
begin
	terminal := self.getTerminal();
	self.beginNotification(terminal, terminal.getTerminalEvent(EventTerminalAlertAdd), Response_Continuous, 0);
	self.beginNotification(terminal, terminal.getTerminalEvent(EventTerminalAlertDelete), Response_Continuous, 0);
	self.beginNotification(terminal, terminal.getTerminalEvent(EventTerminalAlertUpdate), Response_Continuous, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="selectRows" id="f139cc0a-c49d-4e61-b939-f79cd3a57766">
        <updating/>
        <source>selectRows(_tis: CM_TIArray) updating;
//14 April 2009	cnwdw1	
//Select all rows in the table that match a tracked item in the param list
vars
	rowObjects: ObjectSet;
	rowObject: Object;
	alert: CM_SystemAlert;
	first: Boolean;
begin
	create rowObjects transient;
	self.getAllRowObjects(rowObjects);
	first := true;
	foreach rowObject in rowObjects do
		alert := rowObject.CM_SystemAlert;
		if _tis.includes(alert.myTrackedItem) then
			self.selectObject(alert, first);
			first := false;
		endif;
	endforeach;
epilog
	delete rowObjects;
end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="setParentCaption" id="6dec5a78-2e0c-4efc-b7e8-4166923407b7">
        <source>setParentCaption();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation	Par 28953

*/

vars

	heading : String;
	count : Integer;
	sheet : CMUI_Sheet;

begin

	if self.parent  &lt;&gt; null and self.parent.isKindOf( CMUI_Sheet ) then
		sheet := self.parent.CMUI_Sheet;
		heading := "Failed 'Cargo' Auto Plan";
		if self.rows &gt; self.fixedRows then
			count := self.rows - self.fixedRows;
		endif;
		heading := "(x" &amp; count.String &amp; ") " &amp; heading;
		sheet.caption := heading;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="78995cb3-4733-4568-926e-b14d9e0da0f4">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, clientExecution;
//21 August 2008	cnwdw1	
//
vars
	localEvent : Integer;
	rowIndex: Integer;
    invalidObject : Boolean;
	alert: CM_SystemAlert;
begin
	if userInfo &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, userInfo.Object, invalidObject);
	endif;
	alert := userInfo.CM_SystemAlert;
	if alert &lt;&gt; null then
		localEvent := self.getTerminal.getEventFromTerminalEvent(eventType);
		
		if localEvent = EventTerminalAlertAdd and alert.isType(EVENT_AT_FailedAutoPlan) and not alert.reviewed then
			self.addItemObject(alert, alert.getAttributeStringForDefArray(self.allTblDataEntRows));
		endif;
		
		if localEvent = EventTerminalAlertDelete 
		or (localEvent = EventTerminalAlertUpdate and alert.reviewed) then
			self.removeItemObject(alert);
		endif;
		
		self.setParentCaption();	//09 Jan 2012	NDL	Par 28953
		
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
