<Class name="CMQF_SOHLocationLog">
    <JadeMethod name="setFromAgent" id="9184d0ab-b745-4ed5-bc7d-875922d7d006">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	show,
	rowStr,
	voyStr		: String;
	voy			: CM_Voyage;
	obj			: Object;

begin
	inheritMethod(_agent);
	
//	self.myVoyageGlobal := _agent.getSelectedActualVoyage();	

	if self.getMyVoyageGlobal = null then
		self.setMyVoyageGlobal( _agent.getSelectedAllocatedVoyage() );
	endif;
	
	if _agent.getValueByName(ETRow_ExtraDetail).String &lt;&gt; null then
		_agent.getSelectedLogLots(self.allLogLots);
	endif;

	rowStr := _agent.getValueByName(ETRow_RowId).String;
	if rowStr &lt;&gt; null then
		self.setMyLocationsController( _agent.getSelectedRowId() );
	endif;	
	
	// Par 9481
	if _agent.isRowIncluded(ETRow_DischargePort) then
		self.setMyDischargePort( _agent.getSelectedPort() );
	endif;
	
	// Par 9481
	if _agent.isRowIncluded(ETRow_Consignee) then
		self.setMyConsignee( _agent.getSelectedConsignee() );
	endif;

	if _agent.isRowIncluded(ETRow_ShowWeight) then		
		show :=  _agent.getValueByName(ETRow_ShowWeight).String;
		if show.length = 0 then 
			self.showWeightColumn 		:= false;
		elseif show[1] = '1' then
			self.showWeightColumn 		:= true;
		else
			self.showWeightColumn 		:= show.Boolean;		
		endif;		
	endif;	

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
