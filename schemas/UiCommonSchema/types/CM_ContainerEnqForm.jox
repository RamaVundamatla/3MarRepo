    <JadeMethod name="mnuAutoVolumeCalculate_click" id="4aaa8be5-2535-4399-ba36-00bbb9be294c">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAutoVolumeCalculate_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars
	tiArray	: CM_TIArray;
	ti : CM_TrackedItem;
begin
	create tiArray transient;
	
	if not self.tblData.allSelectedObjects.isEmpty then				
		self.tblData.allSelectedObjects.copy(tiArray); 										
	else															
		tiArray.add(self.myCurrentObject.CM_TrackedItem);
		
	endif;
	if tiArray.isEmpty then
		return;
	endif;

	self.myAssistant.showAutoVolumeCalcForm( tiArray );

epilog
	delete tiArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
