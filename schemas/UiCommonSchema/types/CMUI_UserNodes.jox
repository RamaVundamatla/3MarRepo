    </JadeMethod>
    <JadeMethod name="doBtnPrintClick" id="b0d7b13e-56c0-41ee-9581-98fa51fed9a8">
        <source>doBtnPrintClick();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyJadeReport	: JadeReport;
//	tblPrintParams	: CMIF_PrintTableParams;

begin
/*
	create tblPrintParams transient;
	tblPrintParams.closePrinter := true;
	tblPrintParams.jadeReport := pxyJadeReport;
	tblPrintParams.newReport := true;
	tblPrintParams.printFrame := self.frmPrint;
	tblPrintParams.printLabel := self.lblPrint;
	tblPrintParams.title := self.caption[1:100];
*/
	if self.viewMode = self.ViewMode_Locks then
		if self.viewLocksMode = self.ViewLocksBy_Table then
			self.doPrintOutTable(self.tblLocks, self.caption[1:100], true, false, true, false);
			/* PAR 19503
			self.tblLocks.doPrintTable(tblPrintParams);
			*/
		else
			self.grfLocks.printGraph(Print_Landscape, true, pxyJadeReport);
		endif;
	else
		self.doPrintOutTable(self.tblNodes, self.caption[1:100], true, false, true, false);
		/* PAR 19503
		self.tblNodes.doPrintTable(tblPrintParams);
		*/
	endif;
	
epilog
	//delete tblPrintParams;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayNodes" id="ba5a88b9-bd3c-4411-85c2-5ceab78976bb">
        <source>doDisplayNodes();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 Apr 2008	cnwkpd1	PAR #16421 - Rework to remove extended share locking on JADE system
					objects
18 Sep 2023	navmd1	TFS 60524 Implement column organiser

*/

vars
	tmpCode			: String;
	theNodes 		: NodeDict;
	theProcesses	: ProcessDict; 
	aNode 			: Node;	
	aProcess 		: Process;
	numTotal,
	numServer,
	numJade			: Integer;
//	idx				: Integer;
//	nodeDesc,
//	processDesc		: String;
	invalidNode,
	invalidProcess	: Boolean;
	visibleColumns	: EntTableRowArray;
	
begin
	if process.isInTransactionState then		// PAR #16421
		app.raiseUnexpectedProgramError(class.name, method.name, 'Already in transaction state');
    	return;
    endif;
	
	if process.isInLoadState then				// PAR #16421
		endLoad;
    endif;

	self.tblNodes.rows := self.tblNodes.fixedRows;
	visibleColumns := self.tblNodes.allTblDataEntRows;

	theNodes := system.nodes.cloneSelf(true);			// PAR #16421
	
	on Exception do app.handleDeletedObject(exception, aNode, invalidNode);
	on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);

	foreach aNode in theNodes do
	
		invalidNode := false;
		
		// Get the description of this Node
		// Moved down to part of the process call
		/*nodeDesc := self.getComputerDetail(aNode);
		if nodeDesc = null then		// CCMS1150 cnwrs1 16 June 2011
			continue;
		endif;*/
		
		// Clone the nodes collection of processes
		delete theProcesses;
		theProcesses := aNode.processes.cloneSelf(true);
		
		// If we had an exception accessing the node, then skip it
		if invalidNode then
			continue;
		endif;
		
		foreach aProcess in theProcesses do
		
			tmpCode := null;
			tmpCode := aProcess.userCode.toUpper;
			if tmpCode = CLIENT_BACKGROUND_PROCNAME or
			   tmpCode = SRVR_BACKGROUND_PROCNAME then
			   numJade := numJade +1;
				continue;
			endif;

			numTotal := numTotal + 1;
			if tmpCode = SRVR_TASK_USER then
				numServer := numServer + 1;
			endif;
			
			//idx := self.tblNodes.addItem(aNode.name &amp; Tab &amp; self.getDisplayStrForProcess(aProcess));
//			idx := self.tblNodes.addItem(self.getComputerDetail(aNode) &amp; Tab &amp; self.getDisplayStrForProcess(aProcess));

			// Allow for exception handler to resume after an invlid process
			/*processDesc := null;
			processDesc := self.getDisplayStrForProcess(aProcess);
			
			idx := self.tblNodes.addItem(nodeDesc &amp; Tab &amp; processDesc);
			
			self.tblNodes.accessRow(idx).itemObject := aProcess;*/
			
			self.tblNodes.addItemObject(aProcess, aProcess.getAttributeStringForDefArray(visibleColumns));
			
			
			aProcess.causeEvent( EVENT_APP_LOG_LEVEL_Req, true, 0 );	//29 Nov 2019	NDL	TFS 47053
			
		endforeach;
	endforeach;
	
	self.doHighLights();

	staMain.caption := app.getErrorString5(CMUI_UserNodes_UserStatusLine, numTotal.String,
										(numTotal - numServer).String, 
										numServer.String, numJade.String, (numTotal + numJade).String);
	
epilog
	delete theNodes;
	delete theProcesses;
	
end;</source>
    </JadeMethod>
