    <JadeMethod name="filterObjects" id="9dbb41b3-572d-46c9-8655-8b9dd014cd62">
        <updating/>
        <source>filterObjects(
	_collection	: Collection input;
	_passport	: CM_Passport ) updating;
	
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

//constants											// cnwrl1 07/09/2009 PAR 20198 - what it was
//	TRANS_TYPE_UNKNOWN = -1;						// cnwrl1 07/09/2009 PAR 20198 - what it was
	
vars
//	str				: String;						// cnwrl1 07/09/2009 PAR 20198 - what it was
	tranType		: Integer;
	terminal		: CM_Terminal;
	endDateTime		: TimeStamp;
	tempCollection	: Collection;
	iter1			: Iterator;
	object			: Object;
	
begin
	endDateTime.setTime("23:59:59".Time);
	endDateTime.setDate(self.endDate);
	
	create tempCollection as _collection.class transient;
	
//	foreach str in self.allTransTypeDescriptions do : transType_loop		// cnwrl1 07/09/2009 PAR 20198 - what it was
//		// attempt to get the transaction type from this description string	// cnwrl1 07/09/2009 PAR 20198 - what it was
//		tranType := self.getTransTypeFromString( str );						// cnwrl1 07/09/2009 PAR 20198 - what it was
	foreach tranType in self.allTxnTypes do : transType_loop
		if tranType = self.TRANS_TYPE_UNKNOWN then
			continue transType_loop;
		endif;
		
		// now for each transaction type process all allowed terminals for transaction filtered as required.
		tempCollection.clear();
		foreach terminal in self.allTerminals do : terminal_loop
			terminal.getTITxnsForTypeAll(	tranType,
											self.startDate.TimeStamp,
											endDateTime,
											CMQF_Transactions::checkStatusIncludesObject.name, 
											self,
											tempCollection );
			endLoad;
		endforeach terminal_loop;
		
		// now add any found transactions as long as they are not duplicates.
		if tempCollection.isEmpty then
			continue transType_loop;
		endif;
		
		iter1	:= tempCollection.createIterator;
		while iter1.next( object ) do
			if not _collection.includes( object ) then
				_collection.add( object );
			endif;
		endwhile;
		delete iter1;
	endforeach transType_loop;
	
	/* cnwrl1 21/07/2009 PAR 20198 - SFW1070 - what it was
	foreach str in self.allTransTypeDescriptions do
		tranType := self.getTransTypeFromString(str);
		if tranType &gt; -1 then
			//moved for par 19234.   cnwjo3
			tempCollection.clear();
			foreach terminal in self.allTerminals do
				terminal.getTITxnsForTypeAll(tranType, self.startDate.TimeStamp, endDateTime,
													 CMQF_Transactions::checkStatusIncludesObject.name, 
													 self, tempCollection);
				endLoad;
			endforeach;
			//moved for par 19234.   cnwjo3
			tempCollection.copy(_collection);
		endif;
	endforeach;
	cnwrl1 21/07/2009 PAR 20198 - SFW1070 - end of what it was */
	
epilog
	endLoad;
	delete tempCollection;
	delete iter1;
	
end;
</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="0f7aa3e0-2f28-4288-8da8-522ed1e5e80a">
        <updating/>
        <source>includesObject(_trx: CM_TITransaction; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti					: CM_TrackedItem;
	querySelf			: CMQF_ContainerTrans;
	failedDAC  :CM_DataAccessController;
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	ti := _trx.myTrackedItem;
	if ti = null or (not ti.isKindOf(CM_Container)) then
		return false;
	endif;
	
	if self.ignoreDeleted and _trx.deleted then
		return false;
	endif;

	if not ti.canUserAccessSelf(null, failedDAC,_passport) then
		return false;
	endif;

	if (self.myOperator = null or (self.myOperator.code = ti.operatorCode))
	and (self.getMySubTerminal = null or (self.getMySubTerminal = ti.mySubTerminal))  //28/04/2009 cwndz2 ccms1735
	then
		querySelf.numFound := querySelf.numFound + 1;
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
