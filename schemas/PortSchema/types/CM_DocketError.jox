    <JadeMethod name="setForCreate" id="84af9e67-9321-4c3c-82eb-fc0f59d4605e">
        <updating/>
        <source>setForCreate(_pxy : CM_DocketError) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/

vars

begin
	
	
	self.myDocketErrorType := _pxy.myDocketErrorType;
	self.myBol := _pxy.myBol;
	
	self.setForUpdate(_pxy);
epilog

end;</source>
        <Parameter name="_pxy" type="CM_DocketError"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5a42b643-6ac6-48cf-b227-e0a9eb5cc8b6">
        <updating/>
        <source>setForUpdate(_pxy : CM_DocketError) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/

vars

begin
	_pxy.raiseExceptionIfNotTransient(method);

	self.setDocketErrorCode(_pxy.getDocketErrorCode()); //PAR 10280
	self.setDocketErrorDescription(_pxy.getDocketErrorDescription());
	/*self.setDocketErrorCount(_pxy.getDocketErrorCount());	commented by #23894 21/05/2010
	self.setIsPieceCountError(_pxy.getIsPieceCountError());*/
	
	//self.setMyDocketErrorType(_pxy.myDocketErrorType);
	//self.notAvailableForEntry := _pxy.notAvailableForEntry;
epilog

end;</source>
        <Parameter name="_pxy" type="CM_DocketError"/>
    </JadeMethod>
    <JadeMethod name="setMyBol" id="1ac6de1b-565a-4806-9d3c-4023a0b3800e">
        <updating/>
        <source>setMyBol(_bol : CM_BOL) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/

vars

begin
	if self.myBol &lt;&gt; _bol then
		self.myBol := _bol;
	endif;
epilog

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="setMyDocketErrorType" id="c1099544-13af-4f16-a748-2f731894a2b1">
        <updating/>
        <source>setMyDocketErrorType(_docketErrorType : CM_DocketErrorType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/

vars

begin
	if self.myDocketErrorType &lt;&gt; _docketErrorType then
		self.myDocketErrorType := _docketErrorType;
		self.docketErrorCode := _docketErrorType.code;
		self.docketErrorDesc := _docketErrorType.description;
	endif;
epilog

end;</source>
        <Parameter name="_docketErrorType" type="CM_DocketErrorType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="07c0d123-8d45-499a-ab68-5aae5bcbf437">
        <updating/>
        <source>setProxy(_myDocketErrorType : CM_DocketErrorType; 
		_myBol : CM_BOL; 
		_pieceCountError : Boolean; 
		_docketErrorCount : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwas3	Initial creation

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.myBol := _myBol;
	self.myDocketErrorType := _myDocketErrorType;	
	self.docketErrorCode := self.myDocketErrorType.code;
 	self.docketErrorDesc := self.myDocketErrorType.description;
	//self.docketErrorCount := _docketErrorCount;	commented by #23894 21/05/2010
	//self.isPieceCountError := _pieceCountError;	

end;</source>
        <Parameter name="_myDocketErrorType" type="CM_DocketErrorType"/>
        <Parameter name="_myBol" type="CM_BOL"/>
        <Parameter name="_pieceCountError" type="Boolean"/>
        <Parameter name="_docketErrorCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7c9f07c1-4dfe-4139-b361-493c616cea6d">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/

vars

begin
	if app.myRoot.allDocketErrorTypes[self.docketErrorCode] = null then
		/*if self.docketErrorCount &lt;&gt; 0 then	commented by #23894 21/05/2010
			app.raiseCMWarning(Warni_drive_piece_count_needs, null, null, self);*/
		if self.docketErrorCode &lt;&gt; null then
			app.raiseCMException(Specif_docket_error_type_valid, null, null);
		endif;
	endif;

	//self.validateMe;
epilog

end;</source>
    </JadeMethod>
