    <JadeMethod name="getJblWorkerConf" id="96a83c42-c323-41e8-b01c-101a62b47bd1">
        <source>getJblWorkerConf():String;

vars
	f:File;
begin
	create f transient;
	f.fileName := "c:\thinbin\tools\jblworker.conf";
