        <updating/>
        <source>btnFindTi_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
22/06/2023		navkc1	Bug 58784: EUP - Inv Maint Find Items use Debtor for Operators

*/

vars
	tiArray: CM_TIArray;
	form   : CMUI_CargoSearchFormModal;
begin
	form := app.loadForm(CMUI_CargoSearchFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							true, 
							self.myTerminal,
							null).CMUI_CargoSearchFormModal;	

	if form = null then
		return;
	endif;
	
	form.setColumnsAndControlWidth(3, 175);
	form.setParentForm(self);
	form.setMyDebtor(self.myCurrentInvoice.debtor); //22/06/2023	navkc1	Bug 58784
	form.showModal();
epilog
	delete tiArray;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
