    <JadeMethod name="addGCAllocGroupToTable" id="44a2d576-a561-4f7c-ba6d-6fd8d6f99a62">
        <source>addGCAllocGroupToTable(_group : CM_GeneralCargoAllocGroup; _afterIndex : Integer) : Integer protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Sartellite View Screen for Flexible Terminal Areas
//
vars
	gcGroupLineStr : String;
	index : Integer;

begin
	gcGroupLineStr := 	" " &amp; Tab 					// Col_Incl_TA
						&amp; " " &amp; Tab					// Col_Ta_Name
						&amp; " " &amp; Tab					// Col_Expand_TA
						&amp; "0" &amp; Tab					// Col_Incl_SubArea
						&amp; _group.getFullId &amp; Tab 	// Col_SubArea_Name
						&amp; Exp_Hide &amp; Tab			// Col_Expand_SubArea
						&amp; " " &amp; Tab 				// Col_Incl_Location
						&amp; " ";						// Col_Location_Name
						
	if _afterIndex &gt; 0 then
		index := _afterIndex + 1;
		self.tblAreas.addItemAt(gcGroupLineStr, index);
	else
		index := self.tblAreas.addItem(gcGroupLineStr);
	endif;
	self.allLoadedObjects.addNoDuplicates(_group, false);
	self.tblAreas.accessRow(index).itemObject := _group;
	self.tblAreas.accessCell(index,Col_Incl_SubArea).inputType := Table.InputType_CheckBox;
	self.tblAreas.accessRow( index ).visible := false;
	
	if self.locationAlreadyUsed( _group ) then
		self.tblAreas.accessRow(index).enabled := false;
		self.tblAreas.accessRow(index).backColor := Grey;
	endif;
	
	return index;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_group" type="CM_GeneralCargoAllocGroup"/>
        <Parameter name="_afterIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addGridObjectToTable" id="38701ca8-2609-40c2-94a4-e31b9426fbd3">
        <source>addGridObjectToTable( _gridObject : CM_GridObject; _afterIndex : Integer ):Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	locationControllerArray : ObjectArray;
	expandGridObject : String;
	gridObjectLineStr : String;
	index : Integer;
	iter : Iterator;
	obj : Object;
	lc : CM_LocationsController;
	lastIndexAdded : Integer;

begin

	create locationControllerArray transient;
	_gridObject.getAllLocationsControllers( locationControllerArray, false );

	if locationControllerArray.size &lt; 2 then
		expandGridObject := Exp_Hide;
	else
		expandGridObject := Exp_Expand;
	endif;
	
	gridObjectLineStr :=	" " &amp; Tab // Col_Incl_TA
							&amp; " " &amp; Tab // Col_Ta_Name
							&amp; " " &amp; Tab // Col_Expand_TA
							&amp;  "0" &amp; Tab // Col_Incl_SubArea
							&amp; _gridObject.getFullLabel &amp; Tab // Col_SubArea_Name
							&amp; expandGridObject &amp; Tab // Col_Expand_SubArea
							&amp; " " &amp; Tab // Col_Incl_Location
							&amp; " ";  //Col_Location_Name

	if _afterIndex &gt; 0 then
		index :=  _afterIndex + 1;
		self.tblAreas.addItemAt( gridObjectLineStr, index );
	else
		index := self.tblAreas.addItem( gridObjectLineStr );
	endif;
	self.allLoadedObjects.addNoDuplicates( _gridObject, false );
	self.tblAreas.accessRow(index).itemObject := _gridObject;
	self.tblAreas.accessCell(index,Col_Incl_SubArea).inputType := Table.InputType_CheckBox;
	self.tblAreas.accessRow( index ).visible := false;
	
	
		
//	if _gridObject.isInAnyLOBExcluding( self.myCurrentWorkArea ) then
	if self.locationAlreadyUsed( _gridObject ) then
		self.tblAreas.accessRow(index).enabled := false;
		self.tblAreas.accessRow(index).backColor := Grey;
		return index;
	endif;
	
	if locationControllerArray.size &lt; 2 then
		return index;
	endif;
	
	iter := locationControllerArray.createIterator;
	while iter.next( obj ) do
		lc := obj.CM_LocationsController;
		if _afterIndex &gt; 0 then
			lastIndexAdded := self.addLocationControllerToTable( lc, index );
			index := lastIndexAdded;
		else
			self.addLocationControllerToTable( lc, 0 );
		endif;
	endwhile;
	
	return index;
		
epilog

	delete locationControllerArray;
	delete iter;

end;
	</source>
        <access>protected</access>
        <Parameter name="_gridObject" type="CM_GridObject"/>
        <Parameter name="_afterIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addLocationControllerToTable" id="43c3be4d-a1f4-48d8-8317-e12740e9c003">
        <source>addLocationControllerToTable( _lc : CM_LocationsController; _afterIndex : Integer ):Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	lcObjectLineStr : String;
	index : Integer;
	lc : CM_LocationsController;

begin
	
	lcObjectLineStr :=	  " " &amp; Tab // Col_Incl_TA
						&amp; " " &amp; Tab // Col_Ta_Name
						&amp; " " &amp; Tab // Col_Expand_TA
						&amp; " " &amp; Tab // Col_Incl_SubArea
						&amp; " " &amp; Tab // Col_SubArea_Name
						&amp; " " &amp; Tab // Col_Expand_SubArea
						&amp; "0" &amp; Tab // Col_Incl_Location
						&amp; _lc.getFullId;  //Col_Location_Name

	if _afterIndex &gt; 0 then
		index :=  _afterIndex + 1;
		self.tblAreas.addItemAt( lcObjectLineStr, index );
	else
		index := self.tblAreas.addItem( lcObjectLineStr );
	endif;
	self.allLoadedObjects.addNoDuplicates( _lc, false );
	self.tblAreas.accessRow(index).itemObject := _lc;
	self.tblAreas.accessCell(index,Col_Incl_SubArea).inputType := Table.InputType_None;
	self.tblAreas.accessCell(index,Col_Incl_Location).inputType := Table.InputType_CheckBox;
	self.tblAreas.accessRow( index ).visible := false;
	
	//if _lc.isInAnyLOBExcluding( self.myCurrentWorkArea ) then
	if self.locationAlreadyUsed( _lc ) then
		self.tblAreas.accessRow(index).enabled := false;
		self.tblAreas.accessRow(index).backColor := Grey;
	endif;
	
	return index;
	
epilog

end;
	</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_afterIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
