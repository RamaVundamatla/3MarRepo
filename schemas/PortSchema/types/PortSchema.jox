    </JadeMethod>
    <JadeMethod name="getDateEditMaskForShortFormat" id="ced2c290-87e8-4f79-8a79-f8acb89104f3">
        <source>getDateEditMaskForShortFormat() : String;
// ---------------------------------------------------------------------------
// Created:     04 April 2006 by cnwrs2
//
// Purpose:     
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 01/05/2006	cnwdad1		If the user has set a different separator on their workstation
//							to the one defined for the appServer's machine, then an invalid
//							date will result. Changed this to define the mask using the
//							DateFormat's defined separator, which is fetched from the appServer
//							node (this should also work for fat clients, because the
//							parseForCurrentLocale should also use the local format).
//
// 31/08/2010	cnwdad1		PAR #20064.
// --------------------------------------------------------------------------------
vars
	tmpDateInfo	: DateFormat;
	yearStr		: String;
	str			: String;
	separator	: String;

begin
// cnwdad1 31/08/2010 - PAR #20064.
//	tmpDateInfo	:=	app.currentLocaleInfo.dateInfo;
	tmpDateInfo	:=	self.getMyLocaleInfoJMT().dateInfo;
	separator	:=	tmpDateInfo.separator;

	if tmpDateInfo.showFullCentury then
		yearStr := 'yyyy';
	else
		yearStr := 'yy';
	endif;
	
	if tmpDateInfo.shortFormatOrder = DateFormat.MonthDayYear then
//		str := 'MM/dd/' &amp; yearStr;
		str := 'MM\' &amp; separator &amp; 'dd\' &amp; separator &amp; yearStr;
	elseif tmpDateInfo.shortFormatOrder = DateFormat.DayMonthYear then
//		str := 'dd/MM/' &amp; yearStr;
		str := 'dd\' &amp; separator &amp; 'MM\' &amp; separator &amp; yearStr;
	elseif tmpDateInfo.shortFormatOrder = DateFormat.YearMonthDay then
//		str := yearStr &amp; '/MM/dd';
		str := yearStr &amp; '\' &amp; separator &amp; 'MM' &amp; '\' &amp; separator &amp; 'dd';
	else
		// the default
//		str := 'dd/MM/' &amp; yearStr;
		str := 'dd\' &amp; separator &amp; 'MM\' &amp; separator &amp; yearStr;
	endif;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDateShortFormat" id="1c42fd1f-216a-494e-a489-ee731381c91c">
        <source>getDateShortFormat() : String;
// ---------------------------------------------------------------------------
// Created:     04 April 2006 by cnwrs2
//
// Purpose:     
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/08/2010	cnwdad1		PAR #20064.
// --------------------------------------------------------------------------------
vars
	tmpDateInfo	: DateFormat;
	yearStr		: String;
	sep			: String;
	str			: String;

begin
// cnwdad1 31/08/2010 - PAR #20064.
//	tmpDateInfo := app.currentLocaleInfo.dateInfo;
	tmpDateInfo := app.getMyLocaleInfoJMT().dateInfo;
		
	sep := tmpDateInfo.separator;
	
	if tmpDateInfo.showFullCentury then
		yearStr := 'yyyy';
	else
		yearStr := 'yy';
	endif;

	if tmpDateInfo.shortFormatOrder = DateFormat.MonthDayYear then
		str := 'MM' &amp; sep &amp; 'dd' &amp; sep &amp; yearStr;
	elseif tmpDateInfo.shortFormatOrder = DateFormat.DayMonthYear then
		str := 'dd' &amp; sep &amp; 'MM' &amp; sep &amp; yearStr;
	elseif tmpDateInfo.shortFormatOrder = DateFormat.YearMonthDay then
		str := yearStr &amp; sep &amp; 'MM' &amp; sep &amp; 'dd';
	else
		// the default
		str := 'dd' &amp; sep &amp; 'MM' &amp; sep &amp; yearStr;
	endif;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDebtorTypeDesc" id="ac0089fa-7ede-4632-a11b-a8b7e197bba8">
        <source>getDebtorTypeDesc(_debtorTypeCode : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
01.06.2022 navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
16-06-2023 navtnr20 Task 58368: Jade - New Debtor Types for INCO Terms
*/

vars

begin
	if _debtorTypeCode = CM_DebtorType.DT_EMPTY_POOL_PARTY    		then    // SDT0
		return CM_DebtorType.DT_EMPTY_POOL_PARTY_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_CARGO_OPERATOR  		then    // SDT1
		return CM_DebtorType.DT_CARGO_OPERATOR_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_CONSIGNEE       		then    // SDT2
		return CM_DebtorType.DT_CONSIGNEE_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_CONSIGNOR     		then   	// SDT3
		return CM_DebtorType.DT_CONSIGNOR_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_SHIP_OPERATOR 	    then    // SDT4
		return CM_DebtorType.DT_SHIP_OPERATOR_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_BUSINESS_UNIT	 		then    // SDT5
		return CM_DebtorType.DT_BUSINESS_UNIT_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_CUSTOMS_AGENT	 		then	// SDT6
		return CM_DebtorType.DT_CUSTOMS_AGENT_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_FREIGHT_FORWARDER	 	then    // SDT7
		return CM_DebtorType.DT_FREIGHT_FORWARDER_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_EVENT_TYPE 			then	// SDT8
		return CM_DebtorType.DT_EVENT_TYPE_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_CARRIER 				then	// SDT9
		return CM_DebtorType.DT_CARRIER_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_STEVEDORE_VOYAGE 	    then	// SDT10
		return CM_DebtorType.DT_STEVEDORE_VOYAGE_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_BOL_OPERATOR	 		then	// SDT11
		return CM_DebtorType.DT_BOL_OPERATOR_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSEE	then	// SDT12
		return CM_DebtorType.DT_BOL_ITEM_FIRST_CONSEE_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSOR	then	// SDT13
		return CM_DebtorType.DT_BOL_ITEM_FIRST_CONSOR_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_BOL_VOY_OPERATOR 		then	// SDT14
		return CM_DebtorType.DT_BOL_VOY_OPERATOR_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_STEVEDORE_RECEIVE 	then	// SDT15
		return CM_DebtorType.DT_STEVEDORE_RECEIVE_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_STEVEDORE_RELEASE 	then    // SDT16
		return CM_DebtorType.DT_STEVEDORE_RELEASE_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE 	then    	// 01.06.2022 navak20 DTSL TFS 53195
		return CM_DebtorType.DT_SHIPPING_LINE_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_COO_OPERATOR_OLD 	then    	//navtnr20 16-06-2023	58368
		return CM_DebtorType.DT_COO_OPERATOR_OLD_DESC;
	elseif _debtorTypeCode = CM_DebtorType.DT_COO_OPERATOR_NEW 	then    	//navtnr20 16-06-2023	58368
		return CM_DebtorType.DT_COO_OPERATOR_NEW_DESC;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_debtorTypeCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeckingInCaption" id="614c47e6-fdae-4f58-8db4-6c109b8cd5cd">
        <source>getDeckingInCaption(_key: Integer): String;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str, capt	: String;
	constant 	: GlobalConstant;
	translation : XLAT_Translation;
begin

	if _key = DeckingMenu_In_Sep1
	or _key = DeckingMenu_In_Sep2
	or _key = DeckingMenu_In_Sep3 then
		return "-";
	endif;
	
	// par#13514 Mohammad 29/3/2007	
	str := 'DeckingOptionInName_' &amp; (_key - DeckingMenuOffset_In).String;
	constant := currentSchema.getConstant(str);
	if constant &lt;&gt; null then
		translation := app.zGetTranslatedText(XLAT_Exceptions, constant.valueAsInteger);
		if translation &lt;&gt; null then
			capt := translation.text;
		else
			capt := 'Unknown Menu ' &amp; _key.String;
		endif;
	endif;
	
	
	/*
	capt := app.currentLocale.getStringValue(str);
	if capt = null then
		capt := str;
	endif;*/
	
	return capt;
	
end;</source>
        <Parameter name="_key" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeckingMenuIndexFromOption" id="0c7c1f19-4d0f-4c9a-be7f-4f786a3d99c4">
        <source>getDeckingMenuIndexFromOption(_deckingOption: Integer): Integer;
//----------------------------------------------------------------
//	Created:	25 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	//default
	if _deckingOption = DeckingRule_Default then
		return 1;
	
	//straddle/fork rules
	elseif _deckingOption = Height_Then_Next_Row_Pos then
		return 3;
	elseif _deckingOption = Height_Then_Prev_Row_Pos then
		return 4;
	elseif _deckingOption = Layer_Then_First_Row_Pos then
		return 5;
	elseif _deckingOption = Layer_Then_Last_Row_Pos then
		return 6;
	
	//fork only rules
	elseif _deckingOption = Height_Then_Next_Col_Pos then
		return 8;
	elseif _deckingOption = Height_Then_Prev_Col_Pos then
		return 9;
	elseif _deckingOption = Layer_Then_First_Col_Pos then
		return 10;
	elseif _deckingOption = Layer_Then_Last_Col_Pos then
		return 11;
	
	//custom
	elseif _deckingOption = DeckingRule_Custom then
		return 13;
	elseif _deckingOption = DeckingRule_ReverseOfOther then
		return 14;
	else
	
		return null; //invalid
	endif;
	

end;</source>
        <Parameter name="_deckingOption" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
