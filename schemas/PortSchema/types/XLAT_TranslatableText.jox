    <JadeMethod name="vTranslationList" id="c12f220c-370d-490c-8965-05a89f5718ce">
        <methodInvocation>mapping</methodInvocation>
        <source>vTranslationList(set: Boolean; _value: String io) mapping;

// [VIRTUAL] quick list of recorded translations for each locale

vars
	translation	: XLAT_Translation;
begin
	if set then
		// read only
	else
		foreach translation in allTextByLocale do
			_value := _value &amp; CrLf &amp; Tab &amp; translation.myLocale.vLocaleIdAndDescription &amp; ' ' &amp; translation.text;
			if myCategory &lt;&gt; null and myCategory.usesShortText then 
				_value := _value &amp; CrLf &amp; Tab &amp; translation.myLocale.vLocaleIdAndDescription &amp; ' ' &amp; translation.shortText;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
