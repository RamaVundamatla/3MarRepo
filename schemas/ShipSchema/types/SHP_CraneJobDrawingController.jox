    <JadeMethod name="getXYZsForJob" id="23ffe6db-e220-4b63-a846-58aa47e95e64">
        <updating/>
        <source>getXYZsForJob(_job  : CM_VoyageJob; _x1,_y1,_x2,_y2 : Real output; z : Integer output) : Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin	
	if _job = null then
		return false;
	endif;
	return self.allJobObjects.findObjectInDictGetXY(_job , _x1,_y1,_x2,_y2,z);

epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_x1" type="Real" usage="output"/>
        <Parameter name="_y1" type="Real" usage="output"/>
        <Parameter name="_x2" type="Real" usage="output"/>
        <Parameter name="_y2" type="Real" usage="output"/>
        <Parameter name="z" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getYRangeAtXRange" id="5144e02e-9590-4dfb-8106-c1e9942bf14d">
        <source>getYRangeAtXRange(	_x1, _x2  : Real input ; 
				  _y1,  _y2 : Real output) : Boolean;
/*

Purpose:	// at any x point there should be only one object 
			return the object and its full co-ordinates


Return Value:		


Date		Who		Reason
09 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	iter : Iterator;
	obj : Object;
	x1, y1, x2, y2 : Real;
	found : Boolean;
	z : Integer;
begin
	found:=false;
	iter:=self.allJobObjects.createIterator;
	
	self.allJobObjects.startKeyLeq(_x1,null,_x1,null,null,iter);
	while iter.next(obj) do
		self.allJobObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);
		
		if _x1 &gt; x2 then
			_y1:=y1;
			_y2:=y2;
			found :=true;
			break;
		endif;
		if x1 &gt; _x2 then
			_y1:=y1;
			_y2:=y2;
			found :=true;
			break;	
		endif;
		found:=true;
		if _y1 &lt;&gt; null then
			_y1:=y1.min(_y1);
		else
			_y1:=y1;
		endif;
		if _y2 &lt;&gt; null then
			_y2:=y2.max(_y2);
		else
			_y2:=y2;
		endif;
	endwhile;

	
	return found;
epilog
	delete iter;
end;</source>
        <Parameter name="_x1" type="Real" usage="input"/>
        <Parameter name="_x2" type="Real" usage="input"/>
        <Parameter name="_y1" type="Real" usage="output"/>
        <Parameter name="_y2" type="Real" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeAllJobs" id="db01297d-f5fa-4cba-b046-fe89f77a4d0e">
        <source>removeAllJobs(_allJobs : CM_VoyageJobArray input);

vars
	job : CM_VoyageJob;
	_x1,_y1,_x2,_y2 : Real;
	z : Integer;
begin
	
	foreach job in _allJobs discreteLock do
		if self.allJobObjects.findObjectInDictGetXY(job , _x1,_y1,_x2,_y2,z) then
			self.allJobObjects.removeKeyEntry(_x1,_y1,_x2,_y2,z,job);
		endif;
		if self.allJobsInOrderAdded.includes(job) then
			self.allJobsInOrderAdded.remove(job);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_allJobs" type="CM_VoyageJobArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeJobAt" id="5d08b4b5-e9b3-45a3-8c74-bdcf581708cd">
        <updating/>
        <source>removeJobAt(_obj : Object;x1,y1,x2,y2 : Real; z : Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.allJobObjects.getAtKey(x1,y1,x2,y2,z) &lt;&gt; null then
		self.allJobObjects.removeKeyEntry(x1,y1,x2,y2,z,_obj);
		self.allJobsInOrderAdded.remove(_obj);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
        <Parameter name="z" type="Integer"/>
    </JadeMethod>
