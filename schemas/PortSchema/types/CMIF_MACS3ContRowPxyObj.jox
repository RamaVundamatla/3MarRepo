    <JadeMethod name="cloneSelf" id="ddfdeee0-5540-4a6c-8186-b466423eabdf">
        <source>cloneSelf(bTransient: Boolean): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	clonedObj 		: SelfType;
	existingStack,
	clonedStack 	: CMIF_MACS3ContStackPxyObj;
begin
	clonedObj := inheritMethod(bTransient);
	
	clonedObj.common := self.common.cloneSelf(bTransient);
	
	foreach existingStack in self.containerStacks do
		clonedStack := existingStack.cloneSelf(bTransient);
		clonedObj.containerStacks.add(clonedStack);
	endforeach;
	
	return clonedObj;
epilog

end;</source>
        <Parameter name="bTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="delete" id="1291cd62-bccb-4785-9061-03f9d03b501b">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin
	self.containerStacks.purge();
	
	delete common;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getId" id="96aad232-2598-4ce4-bcf6-0faa035db170">
        <source>getId(): String;
/*

Purpose:			Returns a (semi)sensible id for the 'bay'

Parameters:			

Return Value:		

Date				Who		Reason
23 March 2021		navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

constants
	BAY_PADDING_SIZE : Integer = 2;
vars
	id		: String;
begin
	id := self.common.nameComponent;
	id := id[id.length-(BAY_PADDING_SIZE-1):end];	// Just the last 2 digits thank you

	return id;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="is20" id="eefaefaf-66a6-4768-af82-ac60244445b0">
        <source>is20(): Boolean;
/*

Purpose:			If any slot in a Bay is marked for 20ft then return true.
					A 'bay' can only have one 'length' associated to it at one time - so just checking the first one works.
					(This does mean that there are multiple entries for the same bay in a JSON file!)

Parameters:			

Return Value:		

Date				Who		Reason
10 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	stack		: CMIF_MACS3ContStackPxyObj;
	stackLen	: CMIF_MACS3ContStackLenPxyObj;
	
	isTwenty	: Boolean;
begin
	// Doing it this way just saves extra null checks ;)
	foreach stack in self.containerStacks do :loop
		foreach stackLen in stack.containerStackLengths do
			isTwenty := stackLen.is20;
			break loop;
		endforeach;
	endforeach;
	
	return isTwenty;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
