<Class name="CM_AutoInvCatExtNumberGen" id="34f836a9-9fcc-4c07-9a72-3ca20071ec84">
    <superclass name="CM_AutoIdGenerator"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="idGen"/>
