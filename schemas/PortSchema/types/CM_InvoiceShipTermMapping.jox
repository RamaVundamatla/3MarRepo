    <JadeMethod name="setForUpdate" id="25925c99-412c-495d-934d-257cbed33a66">
        <updating/>
        <source>setForUpdate(_proxy : CM_InvoiceShipTermMapping)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
15 Dec 2022 navtnr20	TFS CR 55622 Task 55690: Jade - Shipping Terms TRX

*/

vars

begin
	self.priority := _proxy.priority;
	self.myShippingTerm := _proxy.myShippingTerm;
	self.myDebtorType := _proxy.myDebtorType;
	self.allInvoiceLineTypes.clear();
	_proxy.allInvoiceLineTypes.copy(self.allInvoiceLineTypes);
	
	self.myShippingTerm.setInvLineTypeCollection();  // ### TFS CR 55622 TASK 55690 30DEC2022 NAVAB1
epilog

end;</source>
