    <JadeMethod name="utlDeleteEventTransations" id="0976dd0a-7913-4224-968d-f747337e31a9">
        <source>utlDeleteEventTransations(_event :CM_EventTransaction io; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	16 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
14/05/2012	cnwcs5		par 29450 - split event delete into &gt; 1 transaction
*/
vars
	
begin
	// I do not call self.initialiseActivity because I want the calling method to decide whether
	// to set app.continueCMExceptions
	self.raiseExceptionIfNotInTranState(method);

	if not self.exclusiveLockObjectToDelete(_event) then
	    return;
	endif;
	
	app.myValDA.valEventTransactions(_event);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	//29 Jan 2021	NDL	TFS 50152
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_event);
	endif;
		
	_event.erase(NORMAL_ERASE);
epilog


end;

</source>
        <Parameter name="_event" type="CM_EventTransaction" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
