    <JadeMethod name="addJob" id="6bb20c01-c62d-4bb9-837d-563b7b56552b">
        <source>addJob(_job : CM_Job; index : Integer);
/*
 ------------------------------------------------------------------------
Created:			22 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if (index = 0) or (index &gt; self.allJobsByOrder.size) then
		self.allJobsByOrder.add(_job);
	else	
		self.allJobsByOrder.insert(index, _job);
	endif;
	
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="index" type="Integer"/>
    </JadeMethod>
