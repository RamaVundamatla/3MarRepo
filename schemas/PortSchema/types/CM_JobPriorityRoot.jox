<Class name="CM_JobPriorityRoot" id="d3cab853-1323-4c62-a1e9-147b7a93cdf8">
    <superclass name="CM_JobPriority"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <ExplicitInverseRef name="myRoot" id="e77654c4-083c-4f19-af2b-a552069c55ea">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allJobPriorities"/>
    </ExplicitInverseRef>
    <JadeMethod name="pxyCreateUpdateProxy" id="8970d9f8-88f8-4f47-a2d2-f9b2cc78ee0a">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		04 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	jp : CM_JobPriorityRoot;
	completedOK		: Boolean;
begin
	jp :=  inheritMethod();
	
	jp.myRoot := self.myRoot;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return jp;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete jp;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b653e9ed-13e2-4c99-8532-7e045dc0b362">
        <updating/>
        <source>setForCreate(_pxyPriority: CM_JobPriorityRoot) updating;
// ---------------------------------------------------------------------------
// Created:		04 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxyPriority);

	self.myRoot := _pxyPriority.myRoot;
end;</source>
        <Parameter name="_pxyPriority" type="CM_JobPriorityRoot"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5a7ff690-520f-4aa9-9e62-7891045d58e8">
        <updating/>
        <source>setForUpdate(_pxyPriority: CM_JobPriorityRoot) updating;
// ---------------------------------------------------------------------------
// Created:		04 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxyPriority);

	self.myRoot := _pxyPriority.myRoot;
end;</source>
        <Parameter name="_pxyPriority" type="CM_JobPriorityRoot"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="857f08d6-6f68-4c09-9011-c2b063864aae">
        <updating/>
        <source>setProxy(_ct: Integer; _jt: Integer; _p: Integer; _object: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_ct, _jt, _p, _object);

	self.myRoot := _object.CM_Root;
end;</source>
        <Parameter name="_ct" type="Integer"/>
        <Parameter name="_jt" type="Integer"/>
        <Parameter name="_p" type="Integer"/>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
</Class>
