end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstFormatClassesPopulate" id="401cd0ce-c52b-4142-8e00-27687726ebc9">
        <source>lstFormatClassesPopulate() protected;

vars
	classObj		: Class;
	className		: String;
	subclassesObj	: ClassColl;
	propertyCollObj	: PropertyColl;
	baseRootObj		: CnEcBaseRoot;
	formatObj		: CnEcXmlFormat;
	formatClassObj	: CnEcXmlFormatClass;

begin
	baseRootObj	:= app.myBaseRoot;
	classObj	:= app.myCnEcXmlSchema.getClass("Object");
	formatObj	:= app.cnEcGetXmlFormat(cmbOutputFormats.text);

	create subclassesObj transient;
	classObj.allLocalSubclasses(subclassesObj);
	
	if baseRootObj.getAllXmlExcludedClasses() &lt;&gt; null then
		foreach className in baseRootObj.getAllXmlExcludedClasses() do
		//foreach className in baseRoot.allXmlExcludedClasses do
			classObj := app.myCnEcXmlSchema.getClass(className); 
			
			if subclassesObj.includes(classObj) then
				subclassesObj.remove(classObj);
			endif;
		endforeach;
	endif;
	
	lstFormatClasses.clear();
	lstFormatAttribs.clear();
	btnAddLiteral.enabled	:= false;
	btnAddMethod.enabled	:= false;
	btnSample.enabled		:= false;

	foreach classObj in subclassesObj do		
		if formatObj &lt;&gt; null then
			formatClassObj := formatObj.cnEcGetFormatClass(classObj.name);
		endif;
		
		lstFormatClasses.itemObject[lstFormatClasses.addItem(classObj.name)] := formatClassObj;
		
		if lstFormatClasses.itemObject[lstFormatClasses.newIndex] = null then
			lstFormatClasses.itemForeColor[lstFormatClasses.newIndex] := Red;
		elseif formatClassObj.isShowTagData then
			lstFormatClasses.itemForeColor[lstFormatClasses.newIndex] := Blue;	
		endif;
		
		propertyCollObj	:=	classObj.allPropertiesUpTo(Object);
		
		if propertyCollObj.isEmpty() then
			lstFormatClasses.itemEnabled[lstFormatClasses.newIndex] := false;
		endif;		
	endforeach;

	lstFormatAttribs.listIndex := CNEC_NULL_INDEX;
    self.clearPropertyPanel();
epilog
	delete propertyCollObj;
	delete subclassesObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstFormatClasses_click" id="607015ca-eba3-4936-b9f5-17689e659328">
