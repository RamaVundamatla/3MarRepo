    <JadeMethod name="complete" id="ee130499-b4c8-4788-afd7-0450b88cdf93">
        <updating/>
        <source>complete() updating;
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars

begin
	if self.jobMode = JobModeLoad then
			self.completeLoadMove();
	elseif self.jobMode = JobModeDischarge then
		if self.moveMode = MoveModeMachine then
			self.completeDischargeMove();
		elseif self.moveMode = MoveModeGround then
			self.completeDischargeGround();
		elseif self.moveMode = MoveModeTransit then
			self.completeDischargeTransit();
		endif;
	elseif self.jobMode = JobModeSOB then
		self.completeSOBMove();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="completeDischargeGround" id="8dac25de-9ce4-43bc-80b7-cef0899b9289">
        <updating/>
        <source>completeDischargeGround() : Boolean updating;
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars
	checksSubCargo : CM_TrackedItem;
	tmpFoundLC, currentLocation : CM_LocationsController;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	errMess : String;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	errorMess : String;
begin
	
	if self.myTrackedItem = null then
		self.findCargo();
	endif;
	
	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		self.findLocation();
	endif;
	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		app.raiseCMException1(Err_InvalidLocation, "", null,null);
		return false;
	
	endif;
	errorMess :=  self.validateRequiredChecks(CARGO_CHECK_CONTEXT_SHIP_DISC, self.myTrackedItem, checksSubCargo);
	if errorMess &lt;&gt; "" then 
		app.raiseCMException2(Cargo_check_required,"'" &amp; errorMess &amp; "'", self.myTrackedItem.id, null,null); // TFS 1490 added ID
		return false;
	endif;
	
	
	if self.myTrackedItem.myPrimaryActualLocation = tmpFoundLC then
		app.raiseCMException2(Cargo_already_located,self.myTrackedItem.id,self.locationTarget, null,null);
		return false;
	endif;
	if not self.validateLanderDischarge(self.myTrackedItem, tmpFoundLC, errMess) then
		return false;
	endif;
	
	if not self.getImportGetJobWLE(self.myTrackedItem, job, wle, self.toGroundAllowed,errMess,quantity,weight, null) then
		app.raiseCMException(Work_list_entry_found,null,null);
		return false;
	endif;
	
	return self.movedischargeToGroundTrx(GroundComplete,self.myTrackedItem,tmpFoundLC,job, wle, null, quantity, weight);	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="completeDischargeMove" id="b2b3367e-577c-46b7-bc2f-f738c70be95a">
        <updating/>
        <source>completeDischargeMove() : Boolean updating;
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars
	checksSubCargo : CM_TrackedItem;
	tmpFoundLC : CM_LocationsController;
	errMess : String;
	voyJob : CM_VoyageJob;
	wle : CM_WorkListEntry;
	machine : CM_Machine;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	errorMess : String;
begin
	
	if self.myTrackedItem = null then
		self.findCargo();
	endif;
	
	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		self.findLocation();
	endif;
	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		app.raiseCMException1(Err_InvalidLocation, "", null,null);
		return false;
	
	endif;
	errorMess :=  self.validateRequiredChecks(CARGO_CHECK_CONTEXT_SHIP_DISC, self.myTrackedItem, checksSubCargo);
	if errorMess &lt;&gt; "" then 
		app.raiseCMException2(Cargo_check_required,"'" &amp; errorMess &amp; "'",self.myTrackedItem.id,  null,null); // TFS 1490 added ID
		return false;
	endif;
		
	// no machine involved, straight instant move. Refactor PAR 34665
	self.validateLanderDischarge(self.myTrackedItem, tmpFoundLC, errMess);

	if tmpFoundLC.isMachineController then
		
		machine := tmpFoundLC.CM_MachineController.myMachine;
		app.autoPlanAlertOverride(app.myPassport.myTerminal);
		
		//epr par 35893 CCMS 1411 20/3/15
		app.myTrxUA.trxDischargeCargoAutoPlan(machine,self.myTrackedItem,quantity, weight,voyJob, wle,app.myPassport);
		
		if wle = null then
			if   self.myTrackedItem.myPrimaryPlannedLocation = null then
				app.raiseCMException1(Failed_auto_plan, self.myTrackedItem.id.trimBlanks,null,null);
			endif;
			return false;
		endif;
		//epr par 27/2/15 par 35702 ccms 2457 quantity weight added
		self.moveTIToMachine(machine, self.myTrackedItem, wle, voyJob,quantity, weight);   // 35429
		if not app.myPassport.trxCompletedOK then
			return false;
		endif;
			
	else
		self.getImportGetJobWLE(self.myTrackedItem, voyJob, wle, self.toGroundAllowed,  errMess,quantity, weight, tmpFoundLC);  // 35429
		if not self.moveTI( self.myTrackedItem, null, tmpFoundLC, wle, false, quantity, weight ) then
			return false;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="completeDischargeTransit" id="e111e439-14ca-457d-93e8-c25b191acf9e">
        <updating/>
        <source>completeDischargeTransit() : Boolean updating;
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars
	checksSubCargo : CM_TrackedItem;
	tmpFoundLC, currentLocation : CM_LocationsController;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	errMess : String;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	groundOption : Integer;
	errorMess : String;
begin
	
	if self.myTrackedItem = null then
		self.findCargo();
	endif;
	
	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		self.findLocation();
	endif;
	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		app.raiseCMException1(Err_InvalidLocation, "", null,null);
		return false;
	
	endif;
	errorMess :=  self.validateRequiredChecks(CARGO_CHECK_CONTEXT_SHIP_DISC, self.myTrackedItem, checksSubCargo);
	if errorMess &lt;&gt; "" then 
		app.raiseCMException2(Cargo_check_required,"'" &amp; errorMess &amp; "'",self.myTrackedItem.id,  null,null); // TFS 1490 added ID
		return false;
	endif;
	
	
	if self.myTrackedItem.myPrimaryActualLocation = tmpFoundLC then
		app.raiseCMException2(Cargo_already_located,self.myTrackedItem.id,self.locationTarget, null,null);
		return false;
	endif;
	if not self.validateLanderDischarge(self.myTrackedItem, tmpFoundLC, errMess) then
		return false;
	endif;
	
	if not self.getImportGetJobWLE(self.myTrackedItem, job, wle, self.toGroundAllowed,errMess,quantity,weight, null) then
		app.raiseCMException(Work_list_entry_found,null,null);
		return false;
	endif;
	
	
	if self.moveMode = MoveModeTransit and not self.myTrackedItem.isQueued then	
		if self.myTrackedItem.isPlanned(PLANNING_MODE) then	
			self.movePromotePlannedToQueued( self.myTrackedItem, wle );
		else
			self.moveRePlanTi( self.myTrackedItem, job );
		endif;
	endif;
	
	return self.movedischargeToGroundTrx(GroundInTransit,self.myTrackedItem,tmpFoundLC,job, wle, null, quantity, weight);	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="completeLoadMove" id="e1eb1fc0-6f39-4115-a4e2-2fb1f3b1c753">
        <updating/>
        <source>completeLoadMove() :  Boolean updating;
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars

	errMess : String;
	tmpFoundLC : CM_LocationsController;
	qLocation : CM_LocationsController; 
	qwle : CM_WorkListEntry;
	machine : CM_Machine;
	voyJob : CM_VoyageJob;
	wle : CM_WorkListEntry;
	otherDDWle : CM_WorkListEntry;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	useYardWle : Boolean;
	mustSelectWle : Boolean;
	checksSubCargo : CM_TrackedItem;
	errorMess : String;
begin
	
	if self.myTrackedItem = null then
		self.findCargo();
	endif;

	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		self.findLocation();
	endif;
	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		app.raiseCMException1(Err_InvalidLocation, "", null,null);
		return false;
	
	endif;
	
	errorMess :=  self.validateRequiredChecks(CARGO_CHECK_CONTEXT_SHIP_LOAD, self.myTrackedItem, checksSubCargo);
	if errorMess &lt;&gt; "" then 
		app.raiseCMException2(Cargo_check_required,"'" &amp; errorMess &amp; "'",self.myTrackedItem.id,  null,null); // TFS 1490 added ID
		return false;
	endif;
					
	if tmpFoundLC.isMachineController then
	
		machine := tmpFoundLC.CM_MachineController.myMachine;
//		app.myPassport.clearErrorsWarnings();
		app.autoPlanAlertOverride(app.myPassport.myTerminal);
	
		if self.myTrackedItem.isExport 
		or self.myTrackedItem.isTranshipOutbound									// PAR #25021
		or (self.myTrackedItem.isRehandle and self.myTrackedItem.isOnSite) then 
			app.myTrxUA.trxUpdateShipMoveExport(machine,self.myTrackedItem, null, app.myPassport);
			if not app.myPassport.trxCompletedOK then
				return false;
			else
				return true;
			endif;
			
		endif;
		
	else
		if not self.getExportVoyageJobWle( wle, mustSelectWle ) then
			if self.allWorkListEntries.size &gt; 1 then
				return false;
			endif;
		endif;
		
		//05 Feb 2013	NDL	Par 31102 - Make sure the DD wles that are VoyageWles are loaded to operations.
		if self.myTrackedItem.directDelivery then
			if not validateDirectDelsLoadedToOps( wle, otherDDWle ) then
				return false;
			endif;
			if wle.getTargetLocation = null and otherDDWle.getTargetLocation = tmpFoundLC then
				wle := otherDDWle;
			endif;
		endif;
		
		if wle = null then
			// if there isn't a voyage related one, check for a yard wle.
			// If we DON'T find one, that's ok just carry on
			// if we DO find a yard wle targetting a crane transfer area do this as a separate move first.
			// But if we find a yard wle targetting somewhere else, raise an error.
			qwle := self.myTrackedItem.getIncompleteYardWleInRTQueue();
			
			
			
			if qwle &lt;&gt; null then
				//07 Aug 2013	NDL	Par 32152
				useYardWle := self.myVoyage.isHOLDSorSHIP() and ( self.myTrackedItem.myPrimaryActualLocation.isVehicle or self.myTrackedItem.myPrimaryActualLocation.isWagon );
				
				qLocation := qwle.CM_YardWLE.getTargetLocation;
				//if not qLocation.isCraneLaneController then
				if not qLocation.isCraneLaneController and not useYardWle then	//07 Aug 2013	NDL	Par 32152
					app.raiseCMException3(Move_not_permit_while_queued, tmpFoundLC.getFullId, self.myTrackedItem.id, qLocation.getFullId,null,null);
					return false;
				else
					// shift to the crane transfer area via the yard wle
					//epr  par 33223 3/2/14 changed to use the location entered in the lander not the wle queued location
					return  self.moveTI( self.myTrackedItem, null, tmpFoundLC, qwle, false, quantity, weight );   //20/10/2014 cnwma1 PAR #35011
					
				endif;
			else
				
				//epr par  32868 30/10/13
				if self.myTrackedItem.myPrimaryActualLocation.isVehicle and self.myVoyage.isHOLDSorSHIP() then
					//find road wle 
					wle:=self.myTrackedItem.getIncompleteRoadWleForJob(self.myTrackedItem.myPrimaryActualLocation.CM_VehicleController.vehicle,true);
				endif;
			endif;
		endif;
		
		//16 Oct 2013	NDL	Par 32805
		if not self.validateLoadDPH( tmpFoundLC ) then
			return false;
		endif;
		
		if not self.moveTI( self.myTrackedItem, null, tmpFoundLC, wle, false, quantity, weight ) then
			return false;
		endif;
	
	endif;
		
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="completeSOBMove" id="2dddef74-261d-4a8d-8b64-29ad74082051">
        <updating/>
        <source>completeSOBMove() : Boolean updating;
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars
	wle : CM_WorkListEntry;
	tmpFoundLC : CM_LocationsController;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
begin
	
	if self.myTrackedItem = null then
		self.findCargo();
	endif;
	if self.myTrackedItem &lt;&gt; null then
		if not self.myTrackedItem.isSOB then
		app.raiseCMException2(Location_Not_Marked_SOB, "", self.myTrackedItem.id,null,null);
		return false;
		
		endif;
	endif;

	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		self.findLocation();
	endif;
	tmpFoundLC := self.myLocation;
	if tmpFoundLC = null then
		app.raiseCMException1(Shift_that_not_plann_must_plan, self.myTrackedItem.id, null,null);
		return false;
	
	endif;

	if not tmpFoundLC.isVoyageController() then
		app.raiseCMException(Location_must_be_Onship, null,null);
		return false;
	
	endif;

		
	wle := self.myTrackedItem.getVoyageWLEUnactioned( false );	
	if not self.validateSOBDetails(wle.CM_VoyageWLE) then
		return false;
	endif;
	
	if not self.moveTI( self.myTrackedItem, null, tmpFoundLC, wle, false, quantity, weight ) then
		return false;
	endif;
			
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCargoCheckForTI" id="d4257c83-80fe-4d6f-8f3c-551432ac147f">
        <updating/>
        <source>createCargoCheckForTI(_requiredInfo : String; _context : Integer; _touched : String) updating;
/*
Purpose:			
Date		Who		Reason
28 July 2015	cnwab1	Initial creation
*/

vars
	cargoCheck : CM_CargoCheck;
	cargoCheckItem : CM_CargoCheckItem;
	cmifAutoPlan : CMIF_YAAutoPlanNormal;
begin
	
	if self.myTrackedItem = null then
		self.findCargo();
	endif;
	if self.myTrackedItem = null then
		return;
	endif;
	
	if _touched.trimBlanks = "" then
		return;
	endif;
	
	cargoCheck:= myTerminal.allCargoChecks[_context];

	if cargoCheck &lt;&gt; null then
	
	
		create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
		cmifAutoPlan.attachTI(self.myTrackedItem);
			
		foreach cargoCheckItem in cargoCheck.allCargoCheckItems do
			
			if _requiredInfo = cargoCheckItem.requiredExtraInfo then
				if cargoCheckItem.doesTIMatchMe(cmifAutoPlan) then
					self.updateEquipmentCheckSettings(self.myTrackedItem, cargoCheckItem, _touched);
				endif;
			endif;
		endforeach;	
	endif;

epilog

end;</source>
        <Parameter name="_requiredInfo" type="String"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_touched" type="String"/>
    </JadeMethod>
    <JadeMethod name="findCargo" id="15d61732-88da-4ae2-8cd1-c6b61f4dfddc">
        <updating/>
        <source>findCargo() updating;
/*
Purpose:			
Date		Who		Reason
25 June 2015	cnwab1	Initial creation
*/

vars
	firstTi : CM_TrackedItem;
begin

	if self.cargoUid &lt;&gt; "" then
		firstTi := self.cargoUid.asOid.CM_TrackedItem;
		if firstTi &lt;&gt; null then
			self.allTrackedItems.addExclusive(firstTi);
		endif;
	else	
		if self.jobMode = JobModeLoad then
			self.findLoadCargo();
		elseif self.jobMode = JobModeDischarge then
			self.findDischargeCargo();
		elseif self.jobMode = JobModeSOB then
			self.findSOBCargo();
		endif;

	endif;

	
	self.myTrackedItem := null;
	if self.allTrackedItems.size = 1 then
		self.myTrackedItem := self.allTrackedItems.first;
	endif;
	
	self.validateCargo();
	
	self.populateLocationTarget();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findDischargeCargo" id="780f38a6-9cb9-4f33-9993-4e01c0f9002c">
        <source>findDischargeCargo();
/*
Purpose:			
Date		Who		Reason
29 June 2015	cnwab1	Initial creation
*/

vars

	firstTi : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;
	cargoIdLength : Integer;	
	cargoIdReversed : String;	

begin
	self.allTrackedItems.clear;
	
	cargoIdLength := cargoId.length;	
	cargoIdReversed := cargoId.reverse;	
	if cargoIdLength = 0 then
	return;
endif;
	
	firstTi := self.myVoyage.allOnshipTIsByIdCargoType.getAtKeyGeq(cargoId,null);
	if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
		iter := self.myVoyage.allOnshipTIsByIdCargoType.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
		
		
			if ti.id[1:cargoIdLength] &lt;&gt; cargoId then	
				break;
			endif;
			
			
			if (ti.isContainer and ti.myPrimaryActualLocation.isSlotController) // LOLO CONTAINERS ONLY
			or ti.myPrimaryActualLocation.isVoyageROROController then // ANY RORO
				self.allTrackedItems.addExclusive(ti);
			endif;
		endwhile;
		delete iter;
	endif;

	if self.allTrackedItems.isEmpty then
		firstTi := self.myVoyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := self.myVoyage.allOnshipTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				if (ti.isContainer and ti.myPrimaryActualLocation.isSlotController) // LOLO CONTAINERS ONLY
				or ti.myPrimaryActualLocation.isVoyageROROController then // ANY RORO
					self.allTrackedItems.addExclusive(ti);
				endif;
			endwhile;
			delete iter;
		endif;
	endif;
		
	self.findTIsInTransferArea(cargoId,self.allTrackedItems);
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="findDischargeLocation" id="de250314-a728-42de-adf7-f19c43950df7">
        <updating/>
        <source>findDischargeLocation() updating;
/*
Purpose:			
Date		Who		Reason
29 June 2015	cnwab1	Initial creation
*/

vars
	tmpFoundHeight : Integer;
begin
	if self.myTerminal = null then
		return;
	endif;
	
	
	if self.locationTarget= null then
		if self.moveMode = self.MoveModeGround or self.moveMode = self.MoveModeTransit then
			self.locationTarget := self.laneId;
		endif;
		if self.locationTarget= null then
			return;
		endif;
	endif;

	self.myTerminal.findLocationFromString(self.locationTarget, true, self.myLocation, tmpFoundHeight);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findLoadCargo" id="e4c16496-1c8c-45b3-b55d-0d003cb69159">
        <source>findLoadCargo();
/*
Purpose:			
Date		Who		Reason
25 June 2015	cnwab1	Initial creation
*/

vars

	firstTi : CM_TrackedItem;
	plannedTiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	revDict : CM_TIByIdCargoTypeDictRev;
	cargoIdLength : Integer;	
	cargoIdReversed : String;	
	location: CM_LocationsController;

begin
	self.allTrackedItems.clear;
	
	if self.cargoUid &lt;&gt; "" then
		firstTi := self.cargoUid.asOid.CM_TrackedItem;
		if firstTi &lt;&gt; null then
			self.allTrackedItems.addExclusive(firstTi);
			return;
		endif;
	endif;
	voyage := self.myVoyage;
	
	if voyage = null then
		return;
	endif;
	
	cargoIdLength := cargoId.length;	
	cargoIdReversed := cargoId.reverse;	
		
	firstTi := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
	if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
		iter := voyage.allOnsiteTIsByIdCargoType.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
			if ti.id[1:cargoIdLength] &lt;&gt; cargoId then	
				break;
			endif;
			self.allTrackedItems.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
	
	if self.allTrackedItems.isEmpty and not voyage.allOnsiteTIsByIdCargoType.isEmpty then
		create revDict transient;
		voyage.allOnsiteTIsByIdCargoType.copy( revDict );
		firstTi := revDict.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := revDict.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				self.allTrackedItems.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		delete revDict;
	endif;
	
	if self.allTrackedItems.isEmpty and not voyage.allTranshipTIsExport.isEmpty then
		firstTi := voyage.allTranshipTIsExport.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
			iter := voyage.allTranshipTIsExport.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				if voyage.allOnshipTIsByCargoTypeId.includes(ti) then
					continue;
				endif;
				self.allTrackedItems.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
	
	if self.allTrackedItems.isEmpty and not voyage.allTranshipTIsExport.isEmpty then
		create revDict transient;
		voyage.allTranshipTIsExport.copy( revDict );
		firstTi := revDict.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := revDict.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				if voyage.allOnshipTIsByCargoTypeId.includes(ti) then
					continue;
				endif;
				self.allTrackedItems.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		delete revDict;
	endif;			
	
	if self.allTrackedItems.isEmpty then
		create plannedTiArray transient;
		foreach location in voyage.allVoyageLocations do
			location.getAllPlannedTrackedItems(plannedTiArray, true, true);
			foreach ti in plannedTiArray do
				if ti.id = cargoId or ti.id[1:cargoId.length] = cargoId then
					self.allTrackedItems.add(ti);
				endif;
			endforeach;
		endforeach;
	endif;

	if self.allTrackedItems.isEmpty then
		// if we don't find it related to the voyage, then check the terminal, in case it has been scanned in
		// and is actually for teh wrong voyage, then we can raise an error in the 'populateTrackedItem' method.
		firstTi := voyage.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id = cargoId then
			self.allTrackedItems.addExclusive(firstTi);
		endif;
	endif;
epilog
	delete plannedTiArray;
	delete iter;
	delete revDict;	

end;</source>
    </JadeMethod>
    <JadeMethod name="findLoadLocation" id="37f9e98f-ee70-46c5-b6e0-2b8fde221144">
        <updating/>
        <source>findLoadLocation() updating;
/*
Purpose:			
Date		Who		Reason
29 June 2015	cnwab1	Initial creation
*/

vars
	tmpFoundHeight, pos : Integer;
	strs : StringArray;

begin
	self.myLocation := null;			
	
	if self.locationTarget= null then
		return;
	endif;
	
	// Remove voyage code if present
	if self.locationTarget.startsWith(self.myVoyage.code &amp; " ") then
		pos := self.locationTarget.pos(" ", 1);
		self.locationTarget := self.locationTarget[pos+1:end];
	endif;
	
	create strs transient; 
	self.locationTarget.getTokensForDelimiter(Space,strs);
	self.myVoyage.findLocation(strs, true, self.myLocation, tmpFoundHeight);
	
	if self.myLocation = null then
		self.myTerminal.findLocationFromString(self.locationTarget, true, self.myLocation, tmpFoundHeight);
	else
		if self.myLocation = self.myVoyage.myShipBlockStack and self.locationTarget &lt;&gt; self.myVoyage.code then
			self.myLocation := null;
		endif;
	endif;

epilog
	delete strs;
end;</source>
    </JadeMethod>
    <JadeMethod name="findLocation" id="4b2603a2-ffcc-4eca-b224-3a9310de717d">
        <updating/>
        <source>findLocation() updating;
/*
Purpose:			
Date		Who		Reason
25 June 2015	cnwab1	Initial creation
*/

vars

begin
	if self.jobMode = JobModeLoad then
		self.findLoadLocation();
	elseif self.jobMode = JobModeDischarge then
		self.findDischargeLocation();
	elseif self.jobMode = JobModeSOB then
		self.findSOBLocation();
	endif;
	
	validateLocation();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findSOBCargo" id="a6e4be06-b49d-497c-a09d-5757c8606f68">
        <source>findSOBCargo();
/*
Purpose:			
Date		Who		Reason
29 June 2015	cnwab1	Initial creation
*/

vars

	firstTi : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;
	cargoIdLength : Integer;	
	cargoIdReversed : String;	

begin
	self.allTrackedItems.clear;
	
	if self.cargoUid &lt;&gt; "" then
		firstTi := self.cargoUid.asOid.CM_TrackedItem;
		if firstTi &lt;&gt; null then
			self.allTrackedItems.addExclusive(firstTi);
			return;
		endif;
	endif;
	
	cargoIdLength := cargoId.length;	
	cargoIdReversed := cargoId.reverse;	
	
	
	firstTi := self.myVoyage.allOnshipTIsByIdCargoType.getAtKeyGeq(cargoId,null);
	if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
		iter := self.myVoyage.allOnshipTIsByIdCargoType.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
			if ti.id[1:cargoIdLength] &lt;&gt; cargoId then	
				break;
			endif;
			
			if not ti.isSOB then
				continue;
			endif;
			
			if ti.getVoyageWLEUnactioned(false) = null then // SOB that has been moved.
				continue;
			endif;
			
			self.allTrackedItems.addExclusive(ti);
		endwhile;
		delete iter;
	endif;

	if self.allTrackedItems.isEmpty then
		firstTi := self.myVoyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := self.myVoyage.allOnshipTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
			
				if not ti.isSOB then
					continue;
				endif;
				self.allTrackedItems.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="findSOBLocation" id="e961771c-76ca-48e2-96e9-2f7f8df0182a">
        <updating/>
        <source>findSOBLocation() updating;
/*
Purpose:			
Date		Who		Reason
29 June 2015	cnwab1	Initial creation
*/

vars
	tmpFoundHeight, pos : Integer;
	strs : StringArray;

begin
	self.myLocation := null;			
	
	if self.locationTarget= null then
		return;
	endif;
		
	// Remove voyage code if present
	if self.locationTarget.startsWith(self.myVoyage.code &amp; " ") then
		pos := self.locationTarget.pos(" ", 1);
		self.locationTarget := self.locationTarget[pos+1:end];
	endif;

	create strs transient; 
	self.locationTarget.getTokensForDelimiter(Space,strs);
	self.myVoyage.findLocation(strs, true, self.myLocation, tmpFoundHeight);
	
	if self.myLocation = null then
		self.myTerminal.findLocationFromString(self.locationTarget, true, self.myLocation, tmpFoundHeight);
	else
		if self.myLocation = self.myVoyage.myShipBlockStack and self.locationTarget &lt;&gt; self.myVoyage.code then
			self.myLocation := null;
		endif;
	endif;

epilog
	delete strs;
end;</source>
    </JadeMethod>
    <JadeMethod name="findTIsInTransferArea" id="52d39495-d16e-48d5-8fb3-103a56d47a73">
        <source>findTIsInTransferArea(_cargoId : String; _tiArray :CM_TIArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2011	cnwer1	Initial creation CCMS MES 1033 - extracted code from selectCargoItems 
						added the WorkPointQueue stuff

*/

vars
	trackedItems : CM_TIArray;
	voyageQueue : CM_VoyageQueue;
	subQueue : CM_RadioTelemetryQueue;
	crane : CM_Crane;
	craneTA : CM_CraneTransferArea;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	cargoIdLength : Integer;	//11 Oct 2010	NDL	Par 25836
	cargoIdReversed : String;	//11 Oct 2010	NDL	Par 25836
	interChangeArea : CM_InterchangeArea;
	workPoint : CM_WorkPoint;
begin
	cargoIdLength := _cargoId.length;
	cargoIdReversed := _cargoId.reverse;
	//need to check any that are grounded in one of the crane transfer areas or associated interchange area.
	create trackedItems transient;
	voyage := self.myVoyage;
	voyageQueue := voyage.myQueue;
	if voyageQueue = null then
		return;
	endif;
	
	foreach subQueue in voyageQueue.allSubQueuesById do : outerLoop	
		if subQueue.isKindOf(CM_VoyageCraneQueue) then
			crane := subQueue.CM_VoyageCraneQueue.crane;
			if crane = null then
				continue;
			endif;
			craneTA := crane.transferArea;
			if craneTA = null then
				continue;
			endif;
			
			trackedItems.clear();
			craneTA.getTIs(trackedItems, null);
			foreach ti in trackedItems do
				if ti.id = _cargoId then
					_tiArray.addExclusive(ti);
					break outerLoop;
				elseif ti.idReversed[1:cargoIdLength] = cargoIdReversed then	
					_tiArray.addExclusive(ti);
					break outerLoop;
				endif;
			endforeach;
			
			interChangeArea := craneTA.myDefaultInterchangeArea;
			if interChangeArea &lt;&gt; null then
				trackedItems.clear();
				interChangeArea.getTIs(trackedItems, null);
				foreach ti in trackedItems do
					if ti.id = _cargoId then
						_tiArray.addExclusive(ti);
						break outerLoop;
					elseif ti.idReversed[1:cargoIdLength] = cargoIdReversed then	
						_tiArray.addExclusive(ti);
						break outerLoop;
					endif;
				endforeach;
			endif;
		elseif 	subQueue.isKindOf(CM_VoyageWorkPointQueue) then
			workPoint:=subQueue.CM_VoyageWorkPointQueue.myWorkPoint;
			if workPoint = null then
				continue;
			endif;
			interChangeArea :=workPoint.myWorkPointInterchangeArea;
			if interChangeArea = null then
				continue;
			endif;
			trackedItems.clear();
			interChangeArea.getTIs(trackedItems, null);
			foreach ti in trackedItems do
				if ti.myVoyage &lt;&gt; voyage then	
					continue;
				endif;
				if ti.id = _cargoId then
					_tiArray.addExclusive(ti);
					break outerLoop;
				elseif ti.idReversed[1:cargoIdLength] = cargoIdReversed then	
					_tiArray.addExclusive(ti);
					break outerLoop;
				endif;
			endforeach;
		endif;
	endforeach;
		
epilog
	delete trackedItems;
end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExportVoyageJobWle" id="b710bda1-c6c1-44ab-bc9d-67787834a150">
        <updating/>
        <source>getExportVoyageJobWle( _wle : CM_WorkListEntry output; _forceSelection : Boolean ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	row : Integer;
	msg : String;
	tmpWle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	
begin

	ti := self.myTrackedItem;
	if ti = null then
		return false;
	endif;

	_wle := self.myTrackedItem.getVoyageWLEUnactioned( true );
	

	return (_wle &lt;&gt; null);
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_forceSelection" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getImportGetJobWLE" id="ddf576a2-68c2-4236-a54d-8b032118b9f6">
        <source>getImportGetJobWLE(	_ti : CM_TrackedItem input; 
					_job : CM_VoyageJob output;
					_wle : CM_WorkListEntry output; 
					_toGroundAllowed: Boolean; 
					msgStr : String output;
					_quantity : Integer;
					_weight  : Decimal;
					_target : CM_LocationsController	//25 Mar 2015	NDL	Par 35884
					) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2010	cnwndl1	Initial creation PAR 35862
29 May 2017	 cnwma1 TFS #4310 75664 error when using Lander App
*/

vars
	voyage : CM_Voyage;
	currentLocation : CM_LocationsController;
	rtQueuetask : CM_RTQueueTask;
	rtQueueEntry : CM_RTQueueEntry;
	vehicle : CM_Vehicle;
	
begin

	_job := _ti.getFirstAvailableDischargeJob();
	
	//13 Apr 2015	NDL	Par 36021 - Now that we can use Planned and Non-planned in parallel, we might have a NWNP wle
	// as well as a completed Planned WLE.  DPH did this, i.e. planned and discharged from a LOLO slot, then NWNP'd it back to
	// voyage stack, before NWNP'ing off again. HH failed to find teh NWNP, because it found teh original Job, which it tried to use.
	if _job &lt;&gt; null then
		_wle := _ti.getVoyageWLEForJob(_job);
		if _wle &lt;&gt; null and _wle.isCompleteForJob then
			_job := null;
		endif;
	endif;
	
	//20 May 2010	NDL	Par23603
	if _job = null then
		//_wle := _ti.getVoyageWLEUnactioned( false );
		_wle := _ti.getVoyageWLEForLCUnactioned( false, _target );	//23 Jun 2016	NDL	TFS 2172
		if _wle &lt;&gt; null then
			_job := _wle.job.CM_VoyageJob;
		endif;
		//25 Mar 2015	NDL	Par 35884 - If there is a truck sucker floating around use it before creating a nwnp type.
		if _wle = null and _target &lt;&gt; null and _target.isVehicle then
			vehicle := _target.CM_VehicleController.vehicle;
			_wle := _ti.getIncompleteRoadWleForJob( vehicle, false );
		endif;
	endif;
//	if _job = null then
	if _job = null and _wle = null then	//25 Mar 2015	NDL	Par 35884
		currentLocation := _ti.myPrimaryActualLocation;
		voyage := self.myVoyage;
		if currentLocation &lt;&gt; null and voyage &lt;&gt; null then
			if currentLocation = voyage.myShipBlockStack or
			//epr par 34978 2/10/14
				(currentLocation.isKindOf(CM_GeneralCargoController) and currentLocation.CM_GeneralCargoController.myVoyage = voyage) then
				// it is unplanned unworked cargo, on the ship, try autoplaning and queuing it
				self.moveQueueUnplannedUnworkCargo(_ti, _job, _wle,_quantity ,_weight);
				//21 Sep 2012	NDL	Par 30299
				if _ti.myPrimaryQueuedLocation = null and _job = null then
					app.raiseCMException1(Failed_auto_plan, _ti.id.trimBlanks,null,null);
					
					return false;
				endif;
			elseif currentLocation = voyage.myNotNotifiedStack then
				// this is a piece of cargo we have created on the fly
				if _ti.myVoyage &lt;&gt; null and not _ti.myVoyage.isCellularVoyage then
					// conro or roro, just carry on...
					self.moveQueueUnplannedUnworkCargo(_ti, _job, _wle,_quantity ,_weight);
					//21 Sep 2012	NDL	Par 30299
					if _ti.myPrimaryQueuedLocation = null and _job = null then
						app.raiseCMException1(Failed_auto_plan, _ti.id.trimBlanks, null, null);
						return false;
					endif;
				endif;
			elseif (currentLocation.isCraneLaneController or currentLocation.isWorkPointLaneController) then
				
				self.moveQueueUnplannedUnworkCargo(_ti, _job, _wle,_quantity ,_weight);
				//21 Sep 2012	NDL	Par 30299
				if _ti.myPrimaryQueuedLocation = null and _job = null then
					app.raiseCMException1(Failed_auto_plan, _ti.id.trimBlanks, null,null);
					return false;
				endif;
			//11 Jul 2012	NDL	Par 29961
			elseif ( currentLocation.isCraneLaneController  or ( currentLocation.isYardLocation and currentLocation.CM_YardController.isInterchangeAreaLocation )) then 
				if _toGroundAllowed then
					if _ti.isQueued then
						rtQueuetask := _ti.queueTask;
						if rtQueuetask &lt;&gt; null then
							if ( rtQueuetask.status = TASK_UNACTIONED )
							or ( rtQueuetask.isMove and ( rtQueuetask.status = TASK_OFFERED or rtQueuetask.status = TASK_ACCEPTED ))
							then
								rtQueueEntry := rtQueuetask.myEntry;
								if rtQueueEntry &lt;&gt; null and rtQueueEntry.myJob &lt;&gt; null 
// TFS 4859								and rtQueueEntry.myJob.isVoyageJob then
								and rtQueueEntry.myJob.isVoyageTypeJob() then // TFS 4859
									_job := rtQueueEntry.myJob.CM_VoyageJob;
									_wle := rtQueueEntry.myWorkListEntry;
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	//if _job = null then
	if _job = null and _wle = null then	//25 Mar 2015	NDL	Par 35884
		//Error! Not a voyage Job
		app.raiseCMException2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks, app.getErrorString(NoCompatibleJobFound), null, null); //29/05/2017 cnwma1 TFS #4310
		return false;					
	endif;
	
	if _wle = null then
		_wle := _job.getWLEForTI(_ti);
	endif;

	return (_wle &lt;&gt; null);
	

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_toGroundAllowed" type="Boolean"/>
        <Parameter name="msgStr" type="String" usage="output"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_target" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="89768b18-cd67-48ad-a59c-595d1711599d">
        <updating/>
        <source>initialise(_cargoUid, _cargoid, _voyagecode, _jobmode, _movemode, _targetLocation, _craneid,_laneid  : String; _term : CM_Terminal) updating;
/*
Purpose:			
Date		Who		Reason
25 June 2015	cnwab1	Initial creation
*/

vars
	voyagecode : String;
begin
	self.cargoId := _cargoid.trimBlanks.toUpper;
	self.cargoUid := _cargoUid;
	self.jobMode := _jobmode;
	self.moveMode := _movemode;
	self.myTerminal := _term;
	self.locationTarget := _targetLocation;
	
	self.craneId := _craneid;
	self.laneId := _laneid;
	
	
	if _voyagecode &lt;&gt; null and _term &lt;&gt; null then
		voyagecode := _voyagecode.trimBlanks.toUpper();
		self.myVoyage := _term.allVoyagesByCode.getAtKeyGeq(voyagecode,null);
		if self.myVoyage &lt;&gt; null and self.myVoyage.code &lt;&gt; voyagecode then
			self.myVoyage := null;
		endif;
	endif;
	
	self.validateInitialise();
	
//	self.hhLanderGroundingOpt := self.myTerminal.getConfig(HhLanderGroundingOpt).Integer;

epilog

end;</source>
