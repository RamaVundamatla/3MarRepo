    <JadeMethod name="setMyCurrentListObjects" id="a2b485df-3242-4284-9e62-769815f2a79d">
        <updating/>
        <source>setMyCurrentListObjects(_object : CM_Object)updating;
//--------------------------------------------------------------
//Created: 27 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.myCurrentRailArea := null;
	self.myCurrentRailJSIO := null;
	self.myCurrentRailJob := null;
	self.myCurrentRailLine := null;
	self.myCurrentJSIORake := null;
	self.myCurrentWagon := null;

	inheritMethod(_object);
	
	if _object = null then
		return;
	endif;

	if _object.isKindOf(CM_RoadJobSheet) then
		self.loadListJobsAll();
		return;
	endif;
		
	if _object.isKindOf(CM_RailJSInOut) then
		self.myCurrentRailJSIO := _object.CM_RailJSInOut;		
	elseif _object.isKindOf(CM_RailJob) then
		self.myCurrentRailJob := _object.CM_RailJob;
		self.myCurrentJSIORake := self.myCurrentRailJob.inOutRakeSheet;
		self.myCurrentRailJSIO := self.myCurrentJSIORake.inOut;
		self.myCurrentRailArea := self.myCurrentJSIORake.myRail;
	elseif _object.isKindOf(CM_RailLine) then
		self.myCurrentRailLine := _object.CM_RailLine;
		self.myCurrentRailArea := self.myCurrentRailLine.myRailArea;
	elseif _object.isKindOf(CM_RailJSInOutRake) then
		self.myCurrentJSIORake := _object.CM_RailJSInOutRake;
		self.myCurrentRailArea := self.myCurrentJSIORake.myRail;
		self.myCurrentRailJSIO := myCurrentJSIORake.inOut;
	elseif _object.isKindOf(CM_Wagon) then
		self.myCurrentWagon := _object.CM_Wagon;
		self.myCurrentRailLine := self.myCurrentWagon.myRailLine;
		self.myCurrentRailArea := self.myCurrentRailLine.myRailArea;		
	elseif _object.isKindOf(CM_Rail) then
		self.myCurrentRailArea := _object.CM_Rail;		
	endif;
	
end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
