    <JadeMethod name="translateForm" id="2582fd89-6a88-4e09-bd5a-6f7b4af705fa">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 July 2019 11:44:03.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019552, locale);
	btnUpdCargo.translateBubbleHelp(Xlat_0019553, locale);
	btnUpdCargo.translateCaption(Xlat_0019554, locale);
	btnUpdChassis.translateBubbleHelp(Xlat_0019555, locale);
	btnUpdChassis.translateCaption(Xlat_0019556, locale);
	btnUpdGenny.translateBubbleHelp(Xlat_0019557, locale);
	btnUpdGenny.translateCaption(Xlat_0019558, locale);
	btnUpdMachine.translateBubbleHelp(Xlat_0019559, locale);
	btnUpdMachine.translateCaption(Xlat_0019560, locale);
	btnUpdTruck.translateBubbleHelp(Xlat_0019561, locale);
	btnUpdTruck.translateCaption(Xlat_0019562, locale);
	btnUpdate.translateCaption(Xlat_0023634, locale);
	btnWeigh.translateCaption(Xlat_0019563, locale);
	chkCertified.translateCaption(Xlat_0019564, locale);
	lblCargo.translateCaption(Xlat_0019565, locale);
	lblGenerator.translateCaption(Xlat_0019567, locale);
	lblLastReading.translateCaption(Xlat_0023635, locale);
	lblMachine.translateCaption(Xlat_0019568, locale);
	lblManual.translateCaption(Xlat_0019569, locale);
	lblReason.translateCaption(Xlat_0019570, locale);
	lblScale.translateCaption(Xlat_0019571, locale);
	lblScaleWeight.translateCaption(Xlat_0019572, locale);
	lblTrailer.translateCaption(Xlat_0023349, locale);
	lblTruck.translateCaption(Xlat_0019573, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtPlusMinus_change" id="0ade3809-f19b-4b13-b088-9c9672c39ef2">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtPlusMinus_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation

*/

vars

begin

	if self.txtPlusMinus.text &lt;&gt; self.AddingWeight and self.txtPlusMinus.text &lt;&gt; self.SubtractingWeight then
		self.txtPlusMinus.text := self.AddingWeight;
		self.txtPlusMinus.bubbleHelp := app.getErrorString(Click_make_adjust_value_negati);
		self.calculate( false, txtPlusMinus );
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtPlusMinus_click" id="35061274-f6f4-467f-8783-f5ff99134a35">
        <controlMethod name="TextBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtPlusMinus_click(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if self.txtPlusMinus.text = self.AddingWeight then
		self.txtPlusMinus.text := self.SubtractingWeight;
		self.txtPlusMinus.bubbleHelp := app.getErrorString(Click_make_adjust_value_positi);
	else
		self.txtPlusMinus.text := self.AddingWeight;
		self.txtPlusMinus.bubbleHelp := app.getErrorString(Click_make_adjust_value_negati);
	endif;
	
	self.calculate( false, self.txtPlusMinus );

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
