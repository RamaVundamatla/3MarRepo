	int					: Integer;
begin
	on Exception do app.handleDeletedObject (exception, area, invalidObject);
	listBoxCount := lstICAreas_Avail.listCount;
	
	count := 1;
    while count &lt;= listBoxCount do	
		area := lstICAreas_Avail.itemObject[count].CM_TerminalArea;	//31 Jan 2013	NDL	Par 31102		 												
		area.edition;														//11-06-2025 MTN-35032	
		if invalidObject then			// par 20800
			invalidObject	:= false; 	// par 20800
			count += 1;														//11-06-2025 MTN-35032	
