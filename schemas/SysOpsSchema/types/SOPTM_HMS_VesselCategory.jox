//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars

begin
	app.myTrxDA.trxDeleteHMSObject(pObj, app.myPassport);

epilog

end;</source>
        <Parameter name="pObj" type="HMS_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="fc8a0397-22bc-48b1-996e-dea86565eff0">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyVesselCat	:	HMS_VesselCategory;
	theForm			:	SOP_TableMaintForm;
		
begin
//	return inheritMethod();
	theForm := self.myForm.SOP_TableMaintForm;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_VesselCategory transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
		pxyVesselCat := theForm.myProxyObject.HMS_VesselCategory;
		theForm.tblInput1.setObjectFromTable(pxyVesselCat, null, false);
		pxyVesselCat.setProxy(app.myRoot);
		
		//Are we adding or updating
		if theForm.mode = theForm.Mode_Add then
			app.myTrxCA.trxCreateHMSObject( pxyVesselCat, theForm.myCurrentObject, app.myPassport );
		elseif theForm.mode = theForm.Mode_Update then
			app.myTrxUA.trxUpdateHMSObject(pxyVesselCat, app.myPassport );
		else
			app.raiseUnexpectedProgramError( class.name,
											 method.name, 
											 '  Invalid mode (' &amp; theForm.mode.String &amp; ')' );
			return false;
		endif;
		
		return app.myPassport.trxCompletedOK;
		
	end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
