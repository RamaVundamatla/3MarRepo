    <JadeMethod name="setDirectDelivery" id="7bee2ccb-59be-43e4-a1fe-2b7e116b2a27">
        <updating/>
        <source>setDirectDelivery( _value : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2013	cnwndl1	Initial creation	CCMS 1299 Par 31102

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	invalidTi : Boolean;

begin

	if self.directDelivery = _value then
		return;
	endif;

	on Exception do app.handleDeletedObject( exception, ti, invalidTi);
	if not self.allTrackedItems.isEmpty and _value then
		iter := self.allTrackedItems.createIterator;
		while iter.next( ti ) do
			if ti.myTerminal = self.myTerminal then
				if ti.myPrimaryActualLocation &lt;&gt; null then
					// if any are already in the yard (or on a machine) it can't be made a 'direct delivery'
					if ti.myPrimaryActualLocation.isKindOf( CM_YardController ) then
						app.raiseCMException1(No_DD_Cargo_inYard_or_OnMach, app.getErrorString(BOL), app.getErrorString(Direct_delivery), null);
						return;
					elseif ti.myPrimaryActualLocation.isKindOf( CM_MachineController ) then
						app.raiseCMException1(No_DD_Cargo_inYard_or_OnMach, app.getErrorString(BOL), app.getErrorString(Direct_delivery), null);
						return;
					endif;
				endif;
			endif;
		endwhile;
		delete iter;
	endif;
	
	self.directDelivery := _value;
	
	if not self.isTransient then
		iter := self.allTrackedItems.createIterator;
		while iter.next( ti ) do
			if ti.myTerminal = self.myTerminal then
				ti.setDirectDelivery( _value, true );
			endif;
		endwhile;
		delete iter;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setExtraData" id="76827d28-fbef-4fe2-bcaa-f626a1e56add">
        <source>setExtraData(_key : String; _value : Any);
