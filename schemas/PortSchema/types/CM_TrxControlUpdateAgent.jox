	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_pxySource.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	beginTransaction;

	_pxySource.pxyGetRealObjectAndEdition(realSource, expectedEdition);
	if realSource = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrderTISource.name, null, null);
		return;
	endif;
	
	reserveLock(realSource);
	
	if _passport.noErrors() and realSource.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Work Order TI Source", null, null);
		return;
