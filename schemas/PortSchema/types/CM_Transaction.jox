    <JadeMethod name="incoTermCode" id="6219c68d-881c-4820-a266-05d4b895d7a8">
        <methodInvocation>mapping</methodInvocation>
        <source>incoTermCode(set: Boolean; _value: String io) mapping;
/*
Purpose:			

Date		Who		Reason
16 May 2023	navab1	TFS CR 57138 TASK 57310
08/12/2023	navkc1 ChangeRequest 58261 Task 58262: Jade - COO Storage Debtor
*/

vars

begin
	if set then
		// set code here
		//08/12/2023	navkc1 ChangeRequest 58261 Task 58262
		global.setExtraData(self.allExtraData, self, IncoTermCode, _value);
	else
		// get code here
		//08/12/2023	navkc1 ChangeRequest 58261 Task 58262
		global.getExtraData(self.allExtraData, IncoTermCode, _value);
	endif;


epilog

end;</source>
