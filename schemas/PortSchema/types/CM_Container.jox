    <JadeMethod name="hasSameUnderStowAttribute" id="156fcf3a-3028-47b5-8d7d-c90d1b66c29e">
        <source>hasSameUnderStowAttribute(tiToCompareTo: CM_TrackedItem; testType: Integer): Boolean;
/*
 ------------------------------------------------------------------------
Created:			19 October 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------		-----------		-----------------------------------------
12/05/2010  	cnwdap1     	CCMS 1116 Tranship changes
---------------------------------------------------------------------------
*/
vars
	cont : CM_Container;
	cmdty 	: CM_Commodity;
begin
	inheritMethod(tiToCompareTo, testType);
	sharedLock(tiToCompareTo);
	if testType = TI_Test_CommodityGroup then
		//if self.myTranshipExport &lt;&gt; null then																	// PAR #23645 CCMS 1116
		//	return self.myTranshipExport.commodityGroup.trimBlanks = tiToCompareTo.commodityGroup.trimBlanks;	// PAR #23645 CCMS 1116
		//else																									// PAR #23645 CCMS 1116
			return self.commodityGroup.trimBlanks = tiToCompareTo.commodityGroup.trimBlanks;
		//endif;																								// PAR #23645 CCMS 1116
				
	// CCMS 1357
	elseif testType = TI_Test_Consignee then
		//if self.myTranshipExport &lt;&gt; null then
		//	return self.myTranshipExport.consignee.trimBlanks() = tiToCompareTo.consignee.trimBlanks();
		//else
			return self.consignee.trimBlanks() = tiToCompareTo.consignee.trimBlanks();
		//endif;
	elseif testType = TI_Test_Carrier then
		//if self.myTranshipExport &lt;&gt; null then
		//	return self.myTranshipExport.carrier.trimBlanks() = tiToCompareTo.carrier.trimBlanks();
		//else
		//	return self.carrier.trimBlanks() = tiToCompareTo.carrier.trimBlanks();
			return self.releaseCarrier.trimBlanks() = tiToCompareTo.releaseCarrier.trimBlanks();	// 04 Aug 2011	NDL	Par 27953
		//endif;
		
	elseif testType = TI_Test_DischargePort then
		//if self.myTranshipExport &lt;&gt; null then																	// PAR #23645 CCMS 1116
		//	return self.myTranshipExport.dischargePort.trimBlanks = tiToCompareTo.dischargePort.trimBlanks;		// PAR #23645 CCMS 1116
		if self.myTranshipDetail &lt;&gt; null and self.myTranshipDetail.myDischargePort &lt;&gt; null then					// PAR #23645 CCMS 1116
			return self.myTranshipDetail.myDischargePort.code = tiToCompareTo.getTranshipDischargePort.trimBlanks;	// PAR 25972
		else
			return self.dischargePort.trimBlanks = tiToCompareTo.dischargePort.trimBlanks;
		endif;
		
	elseif testType = TI_Test_ImExStatus then
		//Imex is also contents for this I think. DQ *** adm 100609 Par 15989 remove check for contentsStatus
		
		//if self.myTranshipExport &lt;&gt; null then																	// PAR #23645 CCMS 1116
		//	if self.myTranshipExport.imexStatus &lt;&gt; tiToCompareTo.imexStatus then								// PAR #23645 CCMS 1116
		//		return false;																					// PAR #23645 CCMS 1116
		//	endif;																								// PAR #23645 CCMS 1116
		//else																									// PAR #23645 CCMS 1116
			if self.imexStatus &lt;&gt; tiToCompareTo.imexStatus then
				return false;
			endif;
		//endif;																								// PAR #23645 CCMS 1116
		if not tiToCompareTo.isKindOf(CM_Container) then // PAR 14443
			return false;
		else
			return true; // adm 100609 Par 15989 remove check for contentsStatus
		endif;

//		return self.contentsStatus &lt;&gt; tiToCompareTo.CM_Container.contentsStatus; // PAR 7861 remove
//		return self.contentsStatus = tiToCompareTo.CM_Container.contentsStatus; // PAR 7861 changed to
		
		
	elseif testType = TI_Test_Operator then
		//if self.myTranshipExport &lt;&gt; null then										// PAR #23645 CCMS 1116
		//	return self.myTranshipExport.myOperator = tiToCompareTo.myOperator;		// PAR #23645 CCMS 1116
		//else																		// PAR #23645 CCMS 1116
			return self.myOperator = tiToCompareTo.myOperator;
		//endif;																	// PAR #23645 CCMS 1116
		
	elseif testType = TI_Test_Voyage then
		//if self.myTranshipExport &lt;&gt; null then										// PAR #23645 CCMS 1116
		//	return self.myTranshipExport.myVoyage = tiToCompareTo.myVoyage;			// PAR #23645 CCMS 1116
		if self.isTranshipItem then													// PAR #23645 CCMS 1116
			// for autoplanning always compare with the outbound voyage.
			return self.myExportVoyage = tiToCompareTo.myExportVoyage;				// PAR 25972
		else
			return self.myVoyage = tiToCompareTo.myVoyage;
		endif;
		
	elseif testType = TI_Test_Temperature then
		if not tiToCompareTo.isKindOf(CM_Container) then
			return false;
		endif;
		if tiToCompareTo.CM_Container.getTemperature = NULL_TEMPERATURE then
			return true;
		endif;
		return self.getTemperature = tiToCompareTo.CM_Container.getTemperature;
		
	elseif testType = TI_Test_CmdtyTemp then
		//---------------------
		//The ti MUST be a container
		//---------------------
		if not tiToCompareTo.isKindOf(CM_Container) then
			return false;
		endif;
		cont := tiToCompareTo.CM_Container;
		if cont.getTemperature = NULL_TEMPERATURE then
			return true;
	  	endif;
	  	
	  	//if self.myTranshipExport &lt;&gt; null then							// PAR #23645 CCMS 1116
	  	//	cmdty := self.myTranshipExport.getCommodityObject();		// PAR #23645 CCMS 1116
	  	//else															// PAR #23645 CCMS 1116
	  		cmdty := self.getCommodityObject();
		//endif;														// PAR #23645 CCMS 1116
		
		if cmdty &lt;&gt; null then
		 	if (cont.getTemperature &lt; cmdty.minTemp) or (cont.getTemperature &gt; cmdty.maxTemp) then
				return false;
			endif;
		endif;
		
	endif;
	
	return true;
epilog
	unlock(tiToCompareTo);
end;</source>
        <Parameter name="tiToCompareTo" type="CM_TrackedItem"/>
        <Parameter name="testType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasUnpackAsLastPackActivity" id="abe6c2f8-31d9-4957-8fe1-a4ec4ce84df7">
        <source>hasUnpackAsLastPackActivity() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2011	cnwndl1	Initial creation	Par 27344

*/

vars

	packCompleteType : Integer;
	unpackCompleteType : Integer;
	packType : Integer;
	unpackType : Integer;
	
	trans : CM_TITransaction;
	
begin

	// the packing type transactions
	packCompleteType := TRANS_TYPE_PackComplete;
	unpackCompleteType := TRANS_TYPE_UnpackComplete;
	packType := TRANS_TYPE_PACK;
	unpackType := TRANS_TYPE_UNPACK;
	
	//return true if the most recent packing type transaction was an unpack.	
	foreach trans in self.allTransactions reversed do
	
		if trans.deleted = true then
			continue;
		endif;
		
		if trans.type = packCompleteType 
		or trans.type = unpackCompleteType
		or trans.type = packType
		then
			return false;
		endif;
		
		if trans.type = unpackType then
			return true;
		endif;
		
	endforeach;


	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasVGMDetails" id="5d666633-80e6-4c21-a8de-be8df613e348">
        <source>hasVGMDetails(): Boolean;
