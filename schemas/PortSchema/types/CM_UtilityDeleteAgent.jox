    <JadeMethod name="utlDeleteBulkInvLineDescMap" id="5dc590c5-5c81-48e2-826b-176e726765fb">
        <source>utlDeleteBulkInvLineDescMap(_realInvoiceLineDescMappings : CM_InvLineDescMapByDebtorLType io; _passport : CM_Passport input);
/*

Purpose:			Deletes Invoice Line Mappings

Parameters:			_realInvoiceLineDescMappings	CM_InvLineDescMapByDebtorLType	A collection of real invocie line mappings to delete
					_passport						CM_Passport						The passport to use for the transaction

Return Value:		NONE

Date		Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	toDelete			: CM_InvoiceLineDescMapping;
	theLine				: CM_InvoiceLineDesc;
	invoiceLineDescMap	: CM_InvoiceLineDescMapping;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	foreach invoiceLineDescMap in _realInvoiceLineDescMappings do
		app.myValDA.valInvoiceLineDescMap(invoiceLineDescMap);
	endforeach;
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	foreach invoiceLineDescMap in _realInvoiceLineDescMappings do
		if _passport.noErrors then
			self.myDeleteAuditAgent.audDeleteGeneric(invoiceLineDescMap);
		endif;
		
		if _passport.noErrors then
			toDelete := invoiceLineDescMap;
			theLine := invoiceLineDescMap.myInvoiceLineDesc;
			invoiceLineDescMap.erase(NORMAL_ERASE);
		endif;
		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_DELETE),false,theLine);
		endif;
		
	endforeach;
	
end;</source>
        <Parameter name="_realInvoiceLineDescMappings" type="CM_InvLineDescMapByDebtorLType" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
