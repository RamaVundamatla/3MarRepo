    <JadeMethod name="setInTransit" id="275e57eb-ea03-4255-b3c9-93ca36f7f36e">
        <source>setInTransit(_status : Integer);
// ---------------------------------------------------------------------------
// Created:     27 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 26/02/2021   	cnwma1     	 	Bug 50855: ASPA - Edit Departed Wagon gives Exception
// ---------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	lController : CM_LocationsController;
	tiArray : CM_TIArray;
begin
	create tiArray transient;
	
	// Only set to In Transit if on the wagon.
	//foreach lController in self.allLocationsControllers discreteLock do
	foreach lController in self.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
		foreach ti in lController.allTrackedItems discreteLock do
			if (not tiArray.includes(ti)) then
				tiArray.add(ti);
			endif;
		endforeach;
	endforeach;
	
	foreach ti in tiArray discreteLock do
		if self.allTIsReceived.includes(ti) or ti.getTransReceive() = null then
			ti.setImExStatus(_status); // status will be TI_IMEX_STATUS_TRANSIT or TI_IMEX_STATUS_EXPORT
		endif;
	endforeach;
	
	// 26.02.2021  cnwma1 #50855
	if self.getTerminal() &lt;&gt; null then   
		self.causeEvent(self.getTerminal().getTerminalEvent(Wagon_Update_Event),true,self);	// cause a notification to update tables where used
	endif;													
epilog
	delete tiArray;

end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
