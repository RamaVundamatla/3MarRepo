    <JadeMethod name="setForArchiving" id="db4d6e88-ffed-4ab7-8edc-446b5bfe3314">
        <updating/>
        <source>setForArchiving( _afterAdd : Boolean; afterRemoveOrRelease : Boolean; _passedTS : TimeStamp ) updating;
/*

Purpose:			

Parameters:			Check and sets as appropriate

Return Value:		

Date		Who		Reason
22 June 2015	cnwndl1	Initial creation	Par 36338
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	now : TimeStamp;

begin

	if _afterAdd then	// just assigned a cargo item to the group.
		if self.releasedDT &lt;&gt; null and self.releasedDT.date.isValid then	// means potentially marked for archive
			if self.hasOnsiteAssignedCargo	// but we have on-site cargo assigned
			or self.hasPrenotifiedAssignedCargo	// but we have pre-notified cargo assigned	//15 Feb 2016	NDL	Par 37544
			then	
				self.setReleasedDT(null);	// unset the potential for archiving.
			endif;
		endif;
	
	elseif afterRemoveOrRelease then	// just unassigned a cargo item from the group,
		//or one of the assigned cargo items has been released.
		if self.releasedDT = null or not self.releasedDT.date.isValid then
			if not self.hasOnsiteAssignedCargo
			and not self.hasPrenotifiedAssignedCargo	//15 Feb 2016	NDL	Par 37544
			then	
				if _passedTS &lt;&gt; null and _passedTS.date.isValid then
					now := _passedTS;
				else
					now := app.actualTimeServer;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				endif;
				self.setReleasedDT(now);	// set the potential for archiving.
			endif;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_afterAdd" type="Boolean"/>
        <Parameter name="afterRemoveOrRelease" type="Boolean"/>
        <Parameter name="_passedTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e27b8ae9-9d4d-46b4-b6fe-8adf07581385">
        <updating/>
        <source>setForCreate(_pxyTI: CM_CargoGroup; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	pxyCargoId : String;

begin

	inheritMethod(_pxyTI, _passport);
	
	self.minWeight := _pxyTI.minWeight;
	self.maxWeight := _pxyTI.maxWeight;
	
	self.myCargoGroupTerminal := _pxyTI.myCargoGroupTerminal;
	
	//02 Oct 2018	NDL	TFS 39186
	self.defaultLocation := _pxyTI.defaultLocation;
	self.remarks := _pxyTI.remarks;
	self.setAllPreAssigned( _pxyTI.allPreAssignedCargoIds );
	
	self.allPreAssignedCargoIdsDict.purge();
	foreach pxyCargoId in _pxyTI.allPreAssignedCargoIds do
		self.allPreAssignedCargoIdsDict.putAtKey(pxyCargoId, self); // the object doesn't matter, just want a keyed dict.
	endforeach;
	
	//22/03/2024	navkc1 Defect 63095
	self.allOperators.add(self.myOperator);

epilog

end;</source>
        <Parameter name="_pxyTI" type="CM_CargoGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateActual" id="394d053f-583a-45da-b620-1084f2937daa">
        <updating/>
        <source>setForUpdateActual(_pxyTI: CM_CargoGroup; _tiUpdateCntrlr: CMIF_TIUpdateController input; _passport: CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2015	cnwndl1	Initial creation	Par 36338
*/

vars

	setOper : Boolean;
	subTi : CM_TrackedItem;
	pxyCargoId : String;

begin

	if _pxyTI.myCargoType &lt;&gt; self.myCargoType then
		if not _pxyTI.myCargoType.isCargoGroup then
			app.raiseCMException2( Chang_cargo_type_from_not_perm, self.myCargoType.description, _pxyTI.myCargoType.description, null, null );
		endif;
	endif;

	setOper := _pxyTI.operatorCode &lt;&gt; self.operatorCode;
	if setOper then
		app.raiseCMWarning( Chang_opera_cargo_group_will_c, null, null, null );
	endif;

	inheritMethod(_pxyTI, _tiUpdateCntrlr, _passport);
	
	self.minWeight := _pxyTI.minWeight;
	self.maxWeight := _pxyTI.maxWeight;
	self.defaultLocation := _pxyTI.defaultLocation;	//01 Oct 2018	NDL	TFS 39186
	self.myCargoGroupAssignment := _pxyTI.myCargoGroupAssignment;	//01 Oct 2018	NDL	TFS 39186
	self.myCargoGroupTerminal := _pxyTI.myCargoGroupTerminal;	//01 Oct 2018	NDL	TFS 39186
	
	//01 Oct 2018	NDL	TFS 39186
	self.setAllPreAssigned( _pxyTI.allPreAssignedCargoIds );
	self.allPreAssignedCargoIdsDict.clear();
	
	foreach pxyCargoId in _pxyTI.allPreAssignedCargoIds do
		self.allPreAssignedCargoIdsDict.putAtKey(pxyCargoId, self); // the object doesn't matter, just want a keyed dict.
	endforeach;
	
	if setOper then
		foreach subTi in self.allAssignedTrackedItems do
			subTi.setMyOperator( self.myOperator );
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_CargoGroup"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromEDIUpdate" id="df87b9ae-076a-479e-a6bc-188ad48b4df1">
        <updating/>
        <source>setFromEDIUpdate( 	_oper : CM_Operator;
					_minWeight : Decimal;
					_maxWeight : Decimal;
					_remarks : String;
					_defaultLocation : String
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2016	cnwndl1	Initial creation	Par 37544

*/

vars

begin

	if _oper &lt;&gt; self.myOperator then
		self.setMyOperator(_oper);
	endif;
	if _minWeight &lt;&gt; self.minWeight then
		self.minWeight := _minWeight;
	endif;
	if _maxWeight &lt;&gt; self.maxWeight then
		self.maxWeight := _maxWeight;
	endif;
	if _remarks &lt;&gt; self.remarks then
		self.remarks := _remarks;
	endif;
	//01 Oct 2018	NDL	TFS 39186
	if _defaultLocation &lt;&gt; self.defaultLocation then
		self.defaultLocation := _defaultLocation;
	endif;

epilog

end;</source>
        <Parameter name="_oper" type="CM_Operator"/>
        <Parameter name="_minWeight" type="Decimal"/>
        <Parameter name="_maxWeight" type="Decimal"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_defaultLocation" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementValue" id="b17216f6-7b06-41df-8dee-777abee54b91">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2015	cnwndl1	Initial creation

*/

vars

begin
	
	if _entRowName = ETRow_MinWeight then
		self.minWeight :=_value;
	elseif _entRowName = ETRow_MaxWeight then
		self.maxWeight :=_value;
	else
		inheritMethod(_entRowName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
