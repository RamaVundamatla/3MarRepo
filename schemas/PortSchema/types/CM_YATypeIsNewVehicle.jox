    <JadeMethod name="isCMIFDataMatch" id="181db8c3-1d7d-4778-9587-a4d878e99063">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2013	cnwdap1		Initial creation PAR #32215
//
vars

begin
	return _cmifAutoPlan.isNewVehicle_Match(_yaData);

epilog

end;</source>
