    <JadeMethod name="getBerthForMarks" id="7ec70268-5c5a-41ff-a52d-e41f6cebd65b">
        <source>getBerthForMarks(_berthForMarks : HMS_Berth output; 
					_bowMark, 
					_sternMark : Decimal;
					_raiseError : Boolean //epr TFS  42627 19/12/18
					);//:Boolean;
//--------------------------------------------------
// Created:	19 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
  	// This method checks to see if the bow &amp; stern marks that have been 
  	// entered match the berth that is selected.
	
	if (not self.checkWharfOverhang(_bowMark, _sternMark,_raiseError)) then
		return;
	endif;
	
	// Get the correct berth for the marks supplied
	_berthForMarks := self.myWharf.getBerthForMarks(_bowMark, _sternMark);

end;</source>
        <Parameter name="_berthForMarks" type="HMS_Berth" usage="output"/>
        <Parameter name="_bowMark" type="Decimal"/>
        <Parameter name="_sternMark" type="Decimal"/>
        <Parameter name="_raiseError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBerthServiceTimeRate" id="dbbe9bf2-53f9-4674-ab43-5873dbc910ea">
        <source>getBerthServiceTimeRate(_service : CM_Service; _ts : TimeStamp) : CM_RateEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	serviceRate : CM_BerthRate;
	rateEntry : CM_RateEntry;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	serviceRate := self.allServiceRates[_service];
	if serviceRate &lt;&gt; null then
		rateEntry := serviceRate.getTimeRate(_service.bank, _ts);
		if canLogExtra then	//28.02.2025 navah1	#34141
			if rateEntry &lt;&gt; null then
				app.invLog("Rate for " &amp; _service.name &amp; " derived from berth '" &amp; self.description &amp; "' found", LogTRACE.String);
			else
				app.invLog("Rate for " &amp; _service.name &amp; " derived from berth '" &amp; self.description &amp; "' NOT found", LogTRACE.String);
			endif;
		endif;
		return rateEntry;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="getBollardForMark" id="7f5d4dcc-fe3d-4bf8-8da5-95cfc3b50d51">
        <source>getBollardForMark(_metre : Integer; _bollardMark : Integer output; _bollard : HMS_Resource output);
//
// Purpose:			Find the bollard closest to but less than _metre 
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/03/2023	navdap1		Initial creation TFS 56593 EUP - Show Bollard+Meters in all instances
//
vars
	resource, bollard : HMS_Resource;
	distance, closest : Integer;

begin
	_bollardMark := null;
	_bollard := null;
	
	foreach resource in self.allBerthResources where resource.myResourceType.isBollard do
		if resource.startPosnAlongWharf &lt;= _metre then
			distance := _metre - resource.startPosnAlongWharf;
			if distance &lt; closest or closest = null then
				closest := distance;
				bollard := resource;
			endif;
		endif;
	endforeach;
	
	if bollard &lt;&gt; null then
		_bollardMark := closest;
	endif;
	_bollard := bollard;
epilog

end;</source>
        <Parameter name="_metre" type="Integer"/>
        <Parameter name="_bollardMark" type="Integer" usage="output"/>
        <Parameter name="_bollard" type="HMS_Resource" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getBowSternBridgeMarksFromLOA" id="c2fdc719-bdef-4988-8a7f-e9b57ac49552">
        <source>getBowSternBridgeMarksFromLOA(_loa, _bridgeToBow : Decimal; _sideTo : Integer;
							 _bowMark, _sternMark, _bridgeMark : Decimal io;
							 _baseMark : String;
							 _berthForMarks : HMS_Berth output;
							 _raiseError : Boolean); //epr TFS  42627 19/12/18
//--------------------------------------------------
// Created:	19 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	berthEnd,
	berthStart		: Integer;
	shipStart,
	shipEnd			: Decimal[12,2];
	displayLeftRight,
	waterOnLeftOfWharf:	Boolean;
begin
   	// This method returns the preferred marks for the specified berth
	
	//if (not self.myWharf.isLogicalWharf) then
		// Target berth is not a preferred berth - centre ship on berth
		berthStart := self.startPosition;
		berthEnd := berthStart + self.length;
		
		// Calc bow and stern marks	based on the orientation of the ship:wharf:sea
		waterOnLeftOfWharf := self.myWharf.waterOnLeft;				
		displayLeftRight := self.myWharf.displayLeftToRight;
		
		if _baseMark = null then
			// no mark supplied, centre on berth
			self.getMarksForCentringOnBerth(_loa, _sideTo, _bowMark, _sternMark);
			_berthForMarks := self;	
		else
			// A mark has been supplied, calculate other mark and correct berth for mark
			if _baseMark = app.getErrorString(HMS_BowMark) then
				shipStart := _bowMark;
				if waterOnLeftOfWharf=true and _sideTo=OrientPortSideTo
				or waterOnLeftOfWharf=false and _sideTo=OrientStarboardSideTo then
				// CASE: bowMark=min, sternMark=max
					shipEnd := _bowMark + _loa;		
				else
					//CASE: bowMark=max, sternMark=min
					shipEnd := _bowMark - _loa;						
				endif;
			elseif _baseMark = app.getErrorString(HMS_SternMark) then
				shipEnd := _sternMark;
				if waterOnLeftOfWharf=true and _sideTo=OrientPortSideTo
				or waterOnLeftOfWharf=false and _sideTo=OrientStarboardSideTo then
					// CASE: bowMark=min, sternMark=max
					shipStart := _sternMark - _loa;		
				else
					//CASE: bowMark=max, sternMark=min
					shipStart := _sternMark + _loa;									
				endif;			
			elseif _baseMark = app.getErrorString(HMS_BridgeMark) then
				shipStart := _bridgeMark + _bridgeToBow;
	
				if waterOnLeftOfWharf=true and _sideTo=OrientPortSideTo
				or waterOnLeftOfWharf=false and _sideTo=OrientStarboardSideTo then
					// CASE: bowMark=min, sternMark=max
					shipEnd := shipStart + _loa;		
				else
					//CASE: bowMark=max, sternMark=min
					shipEnd := shipStart - _loa;						
				endif;
			endif;
			
			//Outputs the correct berth for the marks supplied
			self.getBerthForMarks(_berthForMarks, shipStart, shipEnd,_raiseError);
		 	_bowMark := shipStart;
		 	_sternMark := shipEnd;	   
		 				
		endif;

		// calculate the bridge mark
	   	if _bowMark &lt; _sternMark then
			_bridgeMark := _bowMark + _bridgeToBow;
		else
			_bridgeMark := _bowMark - _bridgeToBow;		
		endif;


end;</source>
        <Parameter name="_loa" type="Decimal"/>
        <Parameter name="_bridgeToBow" type="Decimal"/>
        <Parameter name="_sideTo" type="Integer"/>
        <Parameter name="_bowMark" type="Decimal" usage="io"/>
        <Parameter name="_sternMark" type="Decimal" usage="io"/>
        <Parameter name="_bridgeMark" type="Decimal" usage="io"/>
        <Parameter name="_baseMark" type="String"/>
        <Parameter name="_berthForMarks" type="HMS_Berth" usage="output"/>
        <Parameter name="_raiseError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getClosestArrivalMovement" id="e3206f2c-c275-449a-ae89-252c7ed9b1c8">
        <source>getClosestArrivalMovement(_time : TimeStamp; _voyagesToIgnore : CM_VoyageSet ) : HMS_Movement;
/*

Purpose:	Should get the closest arrival/shift  movement to the time , can be either side of the time.
			Will ignore movements that have departed before the _time
			Will ignore movements for the voyages in the _voyagesToIgnore method


Return Value:		


Date		Who		Reason
10 April 2008	cnwer1	Initial creation - PAR#16514

*/
vars
	iter :Iterator;
	movement,ourMovement : HMS_Movement;
	found : Boolean;
	movementTime,
	departureTimeBerth,
	arrivalTimeBerth: TimeStamp;
begin	
	iter := self.getAllVoyageMovements.createIterator();
	
	self.getAllVoyageMovements.startKeyGeq(_time, iter);
	
	while iter.next(movement) do
		departureTimeBerth:=movement.getDepartureTimeFromBerth(self);
		arrivalTimeBerth:=movement.getArrivalTimeAtBerth(self);
		if _voyagesToIgnore &lt;&gt; null and _voyagesToIgnore.includes(movement.getVoyage) then
			continue;
		endif;
		if departureTimeBerth &gt;= _time and
			arrivalTimeBerth &gt;= _time then
			found := true;
			break;
		endif;
	endwhile;
		
	if found then
			
		if ourMovement = null or _time.getDifferenceInMinutes(arrivalTimeBerth)&lt; _time.getDifferenceInMinutes(movementTime)  then
			ourMovement := movement;
			movementTime := arrivalTimeBerth;
		
		endif;
	endif;
	delete iter;
	found:=false;
	iter := self.getAllVoyageMovements.createIterator();
	self.getAllVoyageMovements.startKeyLeq(_time, iter);
	while iter.back(movement) do
		departureTimeBerth:=movement.getDepartureTimeFromBerth(self);
		arrivalTimeBerth:=movement.getArrivalTimeAtBerth(self);
		if _voyagesToIgnore &lt;&gt; null and _voyagesToIgnore.includes(movement.getVoyage) then
			continue;
		endif;
		if departureTimeBerth &gt;= _time and
			arrivalTimeBerth &lt;= _time then
			found := true;
			break;
		endif;	
	endwhile;	
		
	delete iter;
	if found then
		if ourMovement = null or _time.getDifferenceInMinutes(arrivalTimeBerth) &lt; _time.getDifferenceInMinutes(movementTime) then
			ourMovement := movement;
			movementTime := arrivalTimeBerth;
		endif;
	endif;
	
	return ourMovement;
epilog
	delete iter;
end;</source>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_voyagesToIgnore" type="CM_VoyageSet"/>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="670dad94-cb9e-47ee-b8eb-951cc1025042">
        <source>getDisplayString(): String;
//--------------------------------------------------
