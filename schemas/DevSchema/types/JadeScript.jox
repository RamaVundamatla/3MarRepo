    <JadeMethod name="ndlDeleteTruckRoadJobWle" id="b28f349f-7056-4996-99b4-4104b15745a8">
        <source>ndlDeleteTruckRoadJobWle();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
