    <JadeMethod name="addError" id="bc62db22-8b3f-47a9-b220-5eaff487aaf2">
        <source>addError(_errorNum : Integer; _errorDescr : String; _errorMsgs : DTO_HandHeldGateErrorDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	error		: DTO_HandHeldGateError;
begin
	if _errorMsgs = null then
		return;
	endif;
	create error transient;
	if _errorMsgs.includesKey(_errorNum) then
		return;
	endif;
	
	error.errorNo := _errorNum;
	error.errorDescr := _errorDescr;
	_errorMsgs.add(error);

end;


</source>
        <access>protected</access>
        <Parameter name="_errorNum" type="Integer"/>
        <Parameter name="_errorDescr" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="completeExportMove" id="ea6fb537-d42c-49b0-92d9-da83079c6e04">
        <updating/>
        <source>completeExportMove(_fwd : Boolean; _ti : CM_TrackedItem; _errorMsgs : DTO_HandHeldGateErrorDict input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		19 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 29 May 2017	cnwma1 		TFS #4310 75664 error when using Lander App
vars
	msgStr : String;
	ti : CM_TrackedItem;
	crane	:	CM_Crane;
	shipLC : CM_LocationsController;
	term : CM_Terminal;
	alert : CM_SystemAlert;
	queue 	: CM_RadioTelemetryQueue;
	task : CM_RTQueueTask;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	arbiter : CM_RTQueueArbiter;
	txnParams : CMIF_TITransactionController;
	craneQueue : CM_RadioTelemetryQueue;
begin
	ti := _ti;
	term := self.myTerminal;
	
	app.myPassport.useTIDictDeferUpdate := true;
	app.myPassport.useTITransactionDeferUpdate := true;
	
	beginTransaction;
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	//----------------
	//Check the status of the TI
	//---------------
	queue := self.myMachine.myPrimaryQueue;
	//---------------------
	//Get the task
	//---------------------
	exclusiveLock(ti);
	task := queue.locateTaskForTI(ti, -1);
	if task = null then
		//-------------------
		//a Worry!!! Could NOT locate the TI in the Queue....
	//-------------------
		if queue.myParentQueue &lt;&gt; null then
			task := queue.myParentQueue.locateTaskForTI(ti, -1);
		else
			task := queue.locateTaskForTI(ti, -1);
		endif;

		if task = null then
			if  ti.isQueued()  then //epr par 35597 30/1/15
				//-------------------
				//Its queued, Create a System Alert
				//-------------------
				create alert;
				alert.details := app.getErrorString2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC &amp; " for " &amp; ti.id.trimBlanks, queue.id.trimRight);
				alert.setSeverity(SEVERE_INFO);
				//-----------
				//Tell alert to add itself to system
				//-----------
				alert.add;
				msgStr := app.getErrorString2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC &amp; " for " &amp; ti.id.trimBlanks, queue.id.trimRight);
				self.addError(ERR_NOTASKOFTYPE, msgStr, _errorMsgs);

				app.cmsAbortTransaction();
				return false;					
			endif;
		endif;
	endif;

	job := ti.getFirstAvailableLoadJob();
	if job = null then
		//Error! Not a voyage Job
		//msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE, ti.id.trimBlanks, "Not Export"); //29/05/2017 cnwma1 TFS #4310
		 msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE, ti.id.trimBlanks,app.getErrorString(NoCompatibleJobFound)); //29/05/2017 cnwma1 TFS #4310
		self.addError(ERR_TINOT_MACH_TYPE, msgStr, _errorMsgs);
		app.cmsAbortTransaction();
		return false;					
	endif;

	//--------------------
	//The task maybe in another crane queue for the voyage...
	//--------------------
	if task.queue &lt;&gt; queue then
		queue := task.queue;
	endif;
	//---------------------
	//Test the task's job (is it a pickup!)
	//---------------------
	if not task.myEntry.myJob.isKindOf(CM_VoyageJob) then
		//Error! Not a voyage Job
		msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE,ti.id.trimBlanks,  app.getErrorString(NoCompatibleJobFound)); //29/05/2017 cnwma1 TFS #4310
		self.addError(ERR_TINOT_MACH_TYPE, msgStr, _errorMsgs);
		app.cmsAbortTransaction();
		return false;					
	endif;
	
	
	
	
	// check IMV MOVE
	if task.taskType &lt;&gt; TASK_MOVE then
		//Error! Not an imv move task!
		msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE,ti.id.trimBlanks,   "No IMV MOVE task");
		self.addError(ERR_TINOT_MACH_TYPE, msgStr, _errorMsgs);
		app.cmsAbortTransaction();
		return false;					
	endif;
	//---------------
	//Is the job "released" to ops?
	//---------------
	if task.myEntry.myJob.isKindOf(CM_VoyageJob) then
		if (not task.myEntry.myJob.CM_VoyageJob.isLoadedToOperations) then
			//-------------------
			//Job is not loaded to ops, therefore its not "workable"
			//Create a System Alert!!!
			//-------------------
			create alert;
			alert.details := app.getErrorString2(ERR_TINOT_MACH_TYPE, ti.id.trimBlanks &amp; " in Load Job " &amp; task.myEntry.myJob.jobId, "Job NOT LOADED.");
			alert.setSeverity(SEVERE_ERROR);
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
			msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE,ti.id.trimBlanks &amp; " in Load Job " &amp; task.myEntry.myJob.jobId, "Job NOT LOADED.");
			self.addError(ERR_TINOT_MACH_TYPE, msgStr, _errorMsgs);
			app.cmsAbortTransaction();
			return false;					
		endif;
	endif;

	crane := job.myJobSheet.CM_VoyageJobSheet.getMyCrane();
	shipLC	:= ti.getPrimaryLocation(PLANNING_MODE);
	if shipLC = null then
		//Error! TI not planned
		/*msgStr := app.getErrorString1(Full_Replacement_Message,ti.id.trimBlanks &amp; " is not planned for export. Cannot place on ship.");
		self.addError(Full_Replacement_Message, msgStr, _errorMsgs);*/ //+ cnwmd1, Par 20524
		self.addError(Planne_export_cannot_place_shi, app.getErrorString1(Planne_export_cannot_place_shi, ti.id.trimBlanks), _errorMsgs);
		app.cmsAbortTransaction();
		return false;					
	endif;

	app.myPassport.useTIDictDeferUpdate := true;
	app.myPassport.useTITransactionDeferUpdate := true;

//	beginTransaction;
	app.myEventManager.initialise();
	self.myMachine.executeSetDownShipLander(task);	
	crane.releaseToShip(ti, wle, shipLC);
	app.myPassport.doDeferredUpdates();
	app.myEventManager.dispatchAllEvents();
	app.cmsCommitTransaction(app.myPassport);

	// set to false here as well as in the epilog
	app.myPassport.useTIDictDeferUpdate := false;
	app.myPassport.useTITransactionDeferUpdate := false;
		
end;</source>
        <Parameter name="_fwd" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="bf937dad-67c2-4665-afd1-5b4ba6afda39">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwer1	Initial creation

*/

vars

begin
	self.sealsMissing:=app.getErrorString(Seal_Missing);
	self.sealsPresent:=app.getErrorString(Seal_Present);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createHandHeldAlert" id="8d94da91-6eed-44e8-ad6c-4ebcd88faaf4">
        <source>createHandHeldAlert(_vehicleID, _descr : String);
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	vehicle			: CM_Machine;
	linkedObj		: CM_Object;
begin
	vehicle := self.myTerminal.machines[_vehicleID];
	if vehicle &lt;&gt; null then
//		linkedObj := vehicle..first;
	endif;
	
	if linkedObj = null then
		linkedObj := self.myRTDevice;	
	endif;
	
	if app.myPassport.myTerminal = null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	app.myPassport.createAlert(SEVERE_ERROR, 
				'Sent from hand held ' &amp; self.myRTDevice.id &amp; ': ' &amp; _descr,
				EVENT_AT_HandHeldAlert,
				linkedObj);
	
	beginTransaction;
	app.commitAlert();
	commitTransaction;

end;


</source>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_descr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doAddTIsToQueue" id="635ba9b1-fb40-4b85-9557-1a0123acdff0">
        <updating/>
        <source>doAddTIsToQueue(_errorMsgs : DTO_HandHeldGateErrorDict input) updating;
// ---------------------------------------------------------------------------
// Created:		20 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	items, worked : Boolean;
	job : CM_VoyageJob;
	wle : CM_WorkListEntry;
begin
	app.myPassport.clearErrorsWarnings();
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	app.autoPlanAlertOverride(app.myPassport.myTerminal);
	worked := true;
	// ### FORWARD TI
	if self.myTI_FWD &lt;&gt; null then
		items := true;
		// ### EXPORT TO  SHIP
		if self.myTI_FWD.isExport 
		or self.myTI_FWD.isTranshipOutbound								// PAR #25021
		or (self.myTI_FWD.isRehandle and self.myTI_FWD.isOnSite) then // PAR 21958
			app.myTrxUA.trxUpdateShipMoveExport(self.myMachine,self.myTI_FWD, null, app.myPassport); //cnwrd1 par 29286 ,26/7/2012 
			if self.createErrorsFromPassport(_errorMsgs) then
				return;
			endif;

		// ### IMPORT FROM SHIP
		else
			if not self.doImportGetJobWLE(self.myTI_FWD,job,wle,_errorMsgs) then
				//self.addError(Full_Replacement_Message, app.getErrorString1(Full_Replacement_Message, "Work list entry not found for job"), _errorMsgs);
				self.addError(Work_list_entry_found, app.getErrorString(Work_list_entry_found), _errorMsgs);
				//self.
				
				return;
			endif;
			app.myTrxUA.trxUpdateShipMoveImport(self.myMachine,self.myTI_FWD, wle,job,null,null,app.myPassport);
			if self.createErrorsFromPassport(_errorMsgs) then
				return;
			endif;
		endif;
	endif;
	
	// ### AFT TI
	if self.myTI_AFT &lt;&gt; null then
		items := true;
		// ### EXPORT TO  SHIP
		if self.myTI_AFT.isExport 
		or (self.myTI_AFT.isRehandle and self.myTI_AFT.isOnSite)  then // PAR 21958
			app.myTrxUA.trxUpdateShipMoveExport(self.myMachine,self.myTI_AFT, null, app.myPassport); //cnwrd1 par 29286 ,26/7/2012 
			if self.createErrorsFromPassport(_errorMsgs) then
				return;
			endif;
		// ### IMPORT FROM SHIP
		else
			if not self.doImportGetJobWLE(self.myTI_AFT,job,wle,_errorMsgs) then
				//self.addError(Full_Replacement_Message, app.getErrorString1(Full_Replacement_Message, "Work list entry not found for job"), _errorMsgs); //- cnwmd1, Par 20524
				self.addError(Work_list_entry_found, app.getErrorString(Work_list_entry_found), _errorMsgs);
				return;
			endif;
			app.myTrxUA.trxUpdateShipMoveImport(self.myMachine,self.myTI_AFT, wle,job,null,null,app.myPassport);
			if self.createErrorsFromPassport(_errorMsgs) then
				return;
			endif;
		endif;
	endif;
	if not items then
			self.addError(Please_enter_some_contain, app.getErrorString(Please_enter_some_contain), _errorMsgs);
	endif;
	if worked then
//		self.init(); // do not do this here as need TI refs back on form
	endif;
epilog
	app.myPassport.clearErrorsWarnings();
end;</source>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doConfirmContainerShipLander" id="ca7769cf-15ff-4571-8379-7cb25fb1b423">
        <updating/>
        <source>doConfirmContainerShipLander(_fwd : Boolean; _vehicleID, _containerId, _voyageCode, _sealCust, _sealOp, _sealShip : String; _errorMsgs : DTO_HandHeldGateErrorDict input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.isValidContainer(false, _fwd,_vehicleID, _containerId, _voyageCode, _sealCust, _sealOp, _sealShip,_errorMsgs);
end;


</source>
        <Parameter name="_fwd" type="Boolean"/>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_containerId" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_sealCust" type="String"/>
        <Parameter name="_sealOp" type="String"/>
        <Parameter name="_sealShip" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doConfirmDamageShip" id="b50a0014-f4c0-4456-84e9-822d4c68db4c">
        <updating/>
        <source>doConfirmDamageShip(_fwd : Boolean; _vehicleID, _cargoID, _damageRemarks : String; 
				// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
				//_damageDict : CM_DamageInstanceByLocDict;
				_damageDict : CM_DamageInstanceByDmgePos;
				_errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	Note that the damageInstanceDict might be empty, but they may still want
			to record the damage free text remarks. In this case, the container should
			be flagged as damaged.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	vehicle		: CM_Machine;
	foundTI			: CM_TrackedItem;
	pxyTI		: CM_TrackedItem;
	now			: TimeStamp;
	error		: CM_Error;
	damageInstance	: CM_DamageInstance;
	voyCode : String;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	vehicle := self.doConfirmIMV(_vehicleID, _errorMsgs);
	if vehicle = null then
		return;
	endif;
	if self.myVoyage &lt;&gt; null then
		voyCode := self.myVoyage.code;
	endif;
	
	foundTI := 	self.isValidContainer(true, _fwd,_vehicleID, _cargoID, voyCode,null,null,null,_errorMsgs);

	if foundTI = null then
		return;
	endif;
	
	
	//create proxy, clear all damage instances and copy the new ones onto it
	pxyTI := app.createUpdateProxy(foundTI).CM_TrackedItem;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//pxyTI.allDamageInstances.purge();
	pxyTI.allDamageInstancesByPos.purge();
	foreach damageInstance in _damageDict do
		damageInstance.setMyTrackedItem(pxyTI);
	endforeach;
	
	if _damageRemarks &lt;&gt; null and _damageRemarks &lt;&gt; foundTI.remarks then				// 05/09/2011 cnwmh5 #27399
		//	pxyTI.setRemarks(_damageRemarks, false);//add to existing remarks
		pxyTI.setRemarks(_damageRemarks, true);//21 Dec 2010	NDL	Par 26610
	endif;
	//might be actually setting damaged to false here
	pxyTI.setDamaged(_damageRemarks &lt;&gt; null or (not _damageDict.isEmpty));
	
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		//turn then into errors to be passed back to the hand held
		//app.myPassport.createAlertsFromErrors(EVENT_AT_PreGateAlert, roadJob);
		foreach error in app.myPassport.allErrors do
			self.addError(error.errorCode,error.text, _errorMsgs);
		endforeach;
	endif;

epilog
	
	delete pxyTI;
end;


</source>
        <Parameter name="_fwd" type="Boolean"/>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_damageRemarks" type="String"/>
        <Parameter name="_damageDict" type="CM_DamageInstanceByDmgePos"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doConfirmIMV" id="57adab74-0962-4d1c-a862-11a1fd697ac3">
        <updating/>
        <source>doConfirmIMV(_vehicleID : String; _errorMsgs : DTO_HandHeldGateErrorDict input) : CM_Machine updating;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	vehicle		: CM_Machine;
	error		: DTO_HandHeldGateError;
	roadJob		: CM_RoadJob;
begin
	vehicle := self.myTerminal.machines[_vehicleID];
	// epr par 20080 24/6/09
	if vehicle = null or _vehicleID = null then
		self.addError(Err_Gate_VehicleId, app.getErrorString(Err_Gate_VehicleId), _errorMsgs);
		return null;
	endif;
	
	if not vehicle.loggedOn  then
		//self.addError(Full_Replacement_Message, app.getErrorString1(Full_Replacement_Message, vehicle.id &amp; " is not logged on!" &amp; CrLf &amp; "Must be logged on to move items."), _errorMsgs);
		self.addError(Logged_onmust_logged_move_item, app.getErrorString1(Logged_onmust_logged_move_item, vehicle.id), _errorMsgs);
		return null;
	endif;
	self.myMachine := vehicle;

	return vehicle;
end;


</source>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="doConfirmVoyage" id="3274976c-0d3a-4a99-aaf0-6f5d1a402f32">
        <updating/>
        <source>doConfirmVoyage(_voyageID : String; _errorMsgs : DTO_HandHeldGateErrorDict input) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	voyage	: CM_Voyage;
	error		: DTO_HandHeldGateError;
	roadJob		: CM_RoadJob;
	checkSeals 	: Any;
begin
	voyage := self.myTerminal.allVoyagesByCode.getAtKeyGeq(_voyageID,null);
	// epr par 20080 24/6/09
	if voyage = null or _voyageID = null then
		//self.addError(Full_Replacement_Message, app.getErrorString1(Full_Replacement_Message, "Voyage code '" &amp; _voyageID &amp; "' is invalid!"), _errorMsgs); //- cnwmd1, Par 20524
		self.addError(Voyage_code_invalid, app.getErrorString1(Voyage_code_invalid, _voyageID), _errorMsgs);
		return null;
	elseif voyage.code &lt;&gt; _voyageID then
		//self.addError(Full_Replacement_Message, app.getErrorString1(Full_Replacement_Message, "Voyage code '" &amp; _voyageID &amp; "' is invalid. " &amp; voyage.code), _errorMsgs); //- cnwmd1, Par 20524
		self.addError(Voyage_code_invalid_2, app.getErrorString2(Voyage_code_invalid_2, _voyageID, voyage.code), _errorMsgs);
		return null;
	endif;
	
	self.myVoyage := voyage;
	
	//epr par 21806 CCMS 1900
	global.getExtraData(voyage.allStateData,IsShipLanderSealCheck,checkSeals);
	self.checkSealsForDischarge:=checkSeals.Boolean;

	return voyage;
end;


</source>
        <Parameter name="_voyageID" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="doImportGetJobWLE" id="a41ec3f8-d0b6-440c-9b2f-3fed0ea9c691">
        <updating/>
        <source>doImportGetJobWLE(_ti : CM_TrackedItem input; _job : CM_VoyageJob io; _wle : CM_WorkListEntry io; _errorMsgs : DTO_HandHeldGateErrorDict input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		01 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//29 May 2017	 cnwma1 TFS #4310 75664 error when using Lander App
// ---------------------------------------------------------------------------
vars
	msgStr : String;
begin
	_job := _ti.getFirstAvailableDischargeJob();
	if _job = null then
		//Error! Not a voyage Job
		msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks, app.getErrorString(NoCompatibleJobFound));//29/05/2017 cnwma1 TFS #4310
		self.addError(ERR_TINOT_MACH_TYPE, msgStr, _errorMsgs);
		return false;					
	endif;
	
	_wle := _job.getWLEForTI(_ti);

	return (_wle &lt;&gt; null);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="io"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doImportGetQueueTask" id="b2ca404d-d7b5-41bb-bd31-e54041ddf4b7">
        <source>doImportGetQueueTask(ti : CM_TrackedItem; _errorMsgs : DTO_HandHeldGateErrorDict input; 	task : CM_RTQueueTask io; queue 	: CM_RadioTelemetryQueue io; _job : CM_Job) : Boolean;
// ---------------------------------------------------------------------------
// Created:		01 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Change to user queryMachineAssign
29 May 2017	 cnwma1 TFS #4310 75664 error when using Lander App					
*/

vars
	term : CM_Terminal;
	alert : CM_SystemAlert;
	msgStr : String;
	laneLC : CM_LocationsController;
	messageLogger : CM_MachineRTQueueEntryLogger;
	
begin
	term := self.myTerminal;
	task := queue.locateTaskForTI(ti, -1);
	if task = null then
		if queue.myParentQueue &lt;&gt; null then
			task := queue.myParentQueue.locateTaskForTI(ti, -1);
		else
			task := queue.locateTaskForTI(ti, -1);
		endif;
	endif;
	if task = null then
		//----------------
		//Try the Master Queue as a last resort.
		//----------------
		task := term.radioTelemetry.masterQueue.locateTaskForTI(ti, -1);
	endif;
	if task = null then
		//-------------------
		//a Worry!!! Could NOT locate the TI in the Queue....
		//Create a System Alert
		//-------------------
		create alert;
		alert.details := app.getErrorString2(ERR_NOTASKOFTYPE, TASK_MOVE_DESC &amp; " for " &amp; ti.id.trimBlanks, queue.id.trimBlanks);
		alert.setSeverity(SEVERE_INFO);
		//-----------
		//Tell alert to add itself to system
		//-----------
		alert.add;
		msgStr := app.getErrorString2(ERR_NOTASKOFTYPE, TASK_MOVE_DESC &amp; " for " &amp; ti.id.trimBlanks, queue.id.trimBlanks);
		self.addError(ERR_NOTASKOFTYPE, msgStr, _errorMsgs);
		return false;					
	endif;
	//--------------------
	//The task maybe in another crane queue for the voyage...
	//--------------------
	if task.queue &lt;&gt; queue then
		queue := task.queue;
	endif;
	//---------------------
	//Test the task's job (is it a move!)
	//---------------------
	if not task.myEntry.myJob.isKindOf(CM_VoyageJob) then
		//Error! Not a voyage Job
		msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE,ti.id.trimBlanks,  app.getErrorString(NoCompatibleJobFound)); //29/05/2017 cnwma1 TFS #4310
		self.addError(ERR_TINOT_MACH_TYPE, msgStr, _errorMsgs);
		return false;					
	endif;
	if task.taskType &lt;&gt; TASK_MOVE then // IMVs have MOVE tasks not MOVE
		//Error! Not a MOVE task!
		msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE,ti.id.trimBlanks,   "No move task for IMV");
		self.addError(ERR_TINOT_MACH_TYPE, msgStr, _errorMsgs);
		return false;					
	endif;
	//---------------
	//Update the Tasks' location with the ref of the new lane. (if its on the ship)
	//---------------
	laneLC := _job.CM_VoyageJob.getDefaultDischargeLane();
	task.setSourceLocation(laneLC);

	create messageLogger transient;
	messageLogger.myMachine:=self.myMachine;
	if not task.queryMachineAssign(self.myMachine, false, false,false,true,true, messageLogger) then
	//Error! Machine cannot MOVE
		msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE,ti.id.trimBlanks,  "Machine unsuitable");
		self.addError(ERR_TINOT_MACH_TYPE, msgStr, _errorMsgs);
		return false;					
	endif;
	//---------------
	//Is the job "released" to ops?
	//---------------
	if task.myEntry.myJob.isKindOf(CM_VoyageJob) then
		if (not task.myEntry.myJob.CM_VoyageJob.isLoadedToOperations) then
		//-------------------
		//Job is not loaded to ops, therefore its not "workable"
		//Create a System Alert!!!
		//-------------------
			create alert;
			alert.details := app.getErrorString2(ERR_TINOT_MACH_TYPE, ti.id.trimBlanks &amp; " in Disch Job " &amp; task.myEntry.myJob.jobId, "Job NOT LOADED to Voyage Job Operations.");
			alert.setSeverity(SEVERE_ERROR);
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
			msgStr := app.getErrorString2(ERR_TINOT_MACH_TYPE,ti.id.trimBlanks &amp; " in Disch Job " &amp; task.myEntry.myJob.jobId, "Job NOT LOADED to Voyage Job Operations.");
			self.addError(ERR_TINOT_MACH_TYPE, msgStr, _errorMsgs);
			return false;					
		endif;
	endif;
	return true;
	
epilog
	delete messageLogger;
	
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <Parameter name="task" type="CM_RTQueueTask" usage="io"/>
        <Parameter name="queue" type="CM_RadioTelemetryQueue" usage="io"/>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateRemoveChildren" id="f1d7687c-2b9e-4de4-a577-d5d43cfd27f1">
        <source>doUpdateRemoveChildren(_tiSet : CM_TISet input);
// ---------------------------------------------------------------------------
// Created:     21 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
begin

	foreach ti in _tiSet discreteLock do
		if ti.isChild() then
			_tiSet.remove(ti);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateSeals" id="c4cd195a-21ca-4e35-a757-7b296c105ce0">
        <updating/>
        <source>doUpdateSeals(_ti : CM_TrackedItem; _sealCust, _sealOp, _sealShip : String; _errorMsgs : DTO_HandHeldGateErrorDict input) updating;
// ### AKB2007JUN POLAND
vars
	foundTI			: CM_TrackedItem;
	pxyTI		: CM_TrackedItem;
	now			: TimeStamp;
	error		: CM_Error;
begin
	
	foundTI := 	_ti;

	if foundTI = null then
		return;
	endif;
	
	//epr par 22102 6/1/2010
	now:=app.actualTimeServer;
	//create proxy
	pxyTI := app.createUpdateProxy(foundTI).CM_TrackedItem;
	pxyTI.setSealDetails(_sealOp, now, false);
	pxyTI.setSealNumCustoms(_sealCust);
	pxyTI.setSealNumShippers(_sealShip);

	app.myPassport.clearErrorsWarnings; //epr par 22102 7/1/09
	//app.myPassport.setWarningsIgnored(true);
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	//epr par 21806 CCMS 1900
	app.myTrxUA.trxUpdateTIShipperSeals(pxyTI,self.checkSealsForDischarge, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		//turn then into errors to be passed back to the hand held
		foreach error in app.myPassport.allErrors do
			self.addError(error.errorCode,error.text, _errorMsgs);
		endforeach;
	endif;

epilog
	
	delete pxyTI;
end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_sealCust" type="String"/>
        <Parameter name="_sealOp" type="String"/>
        <Parameter name="_sealShip" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
