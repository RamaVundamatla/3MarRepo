    <JadeMethod name="sendEmail" id="fc81d14a-5b37-4079-9f8c-95bcceb989d8">
        <source>sendEmail(	_toAddress : String;
			_alertDescription : String;
			_subject : String;
			_body : String	);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/09/2018	jlgdap1		Initial creation TFS 40202 PEL1 Estimation SAP Integration
//
vars
	sender : String;

begin
	if _toAddress = null then
		return;
	endif;
	
	sender := self.myTerminal.getConfig(CamsEmailAddress).String;
	
	app.myUtilityCA.utlCreateEmailSendRequest(	true, 					// _checkCanBeProcessed
												_alertDescription, 		// _alertDescription
												_toAddress, 			// _toAddress
												sender, 				// _fromAddress
												null, 					// _ccAddresses
												null, 					// _bccAddresses
												_subject,				// _sendSubject
												_body,					// _sendMessage
												null, 					// _allAttachedFilePaths
												null, 					// _allFileData
												null,					// _blob
												null, 					// _blobFileName
												EmailSource_System,		// _sourceOfEmail
												null,					// _updateCallbackObj
												app.myPassport	);		// _passport
epilog

end;</source>
        <Parameter name="_toAddress" type="String"/>
        <Parameter name="_alertDescription" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_body" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendEmailForPendingCancel" id="2e4fb4c8-42fe-41f5-91a4-da9c089a2e30">
        <source>sendEmailForPendingCancel();
/*

Purpose:			
	if status is WO_STATUS_PENDING_CANCEL  // TFS 40202 send an emaail to the work order creator
Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	address 	 : String;				    
	error  		 : String;					
	emailEntity  : CM_EmailEntity;			
begin
	emailEntity := self.myEnteredByUser.myEmailEntity;									//12.01.2023 navma1 #56141 Task#56147
	if emailEntity &lt;&gt; null and emailEntity.isKindOf(CM_EmailAddress2) then
		address := emailEntity.CM_EmailAddress2.emailAddress;
		if address &lt;&gt; null then
			error := app.getErrorString(Contain_credit_check_fail);
			self.sendEmail(	address, 
							error,
							error &amp; Space &amp; Hyphen &amp; Space &amp; error &amp; Space &amp; self.getDisplayString,
							app.getErrorString1(Work_order_estimate_rejected, self.id)	);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setApprovalExpiry" id="cf6429ea-9c48-4c48-971e-961a14284f6a">
