    <JadeMethod name="create" id="bbbe33e2-49d9-4622-a5ad-bd002c77649f">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     13 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Sep 2009	cnwkpd1		PAR #20686 - Initialise filterIMEXStatus to ensure
//							cargo is not excluded when form is opened from
//							Selector, etc
// 14/04/2023	navkc1		CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop
// ---------------------------------------------------------------------------
vars

begin
	self.permissionView := PmAdmCargoEnquiryView;
	self.permissionMaint := PmAdmCargoEnquiryMaint;

	self.filterIMEXStatus := NULL_INTEGER;
	create self.myFilterIDList transient; //cnwrd1 par 24107 12.5.2010
	create self.allMAFIOnboardNotify transient; // 14/04/2023	navkc1	CR 57036 Task 57589
end;</source>
    </JadeMethod>
    <JadeMethod name="createDefaultCritLineHolder" id="d45dd7e0-6cf9-4265-afcd-a9774d3df636">
        <updating/>
        <source>createDefaultCritLineHolder( _cargoType : CM_CargoBOLType input;
								 _object : Object	)  updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2019	jlger1	Initial creation 47132
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
06/06/2022 navtnr20 ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
18 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
04 Oct 2024 navsp1  JIRA 20762 : EUP | General Testing - Search on Client Ref on User Screens
*/

vars
	cargoType : CM_CargoBOLType;
	qDef : CM_QueryDefinition;
	terminalArea : CM_TerminalArea;
	taType : CM_TerminalAreaType;
	voyage : CM_Voyage;
	location : CM_LocationsController;
begin	
	cargoType:=_cargoType;
	
	if _object &lt;&gt; null then
		if _object.isKindOf(CM_TerminalArea) then
			terminalArea:=_object.CM_TerminalArea;
		elseif _object.isKindOf(CM_LocationsController) then
			location:=_object.CM_LocationsController;
			terminalArea:=_object.CM_LocationsController.getMyTerminalArea;
			if location.isKindOf(CM_LogVoyageController) then
				voyage:=location.CM_VoyageController.myVoyage;
			endif;
		elseif _object.isKindOf(CM_SOHLocation) then
			cargoType:=_object.CM_SOHLocation.getCargoBOLType;
			terminalArea:=_object.CM_SOHLocation.myTerminalArea;
			location:=_object.CM_SOHLocation.myLocationsController;
		endif;
	endif;
	
	//16 Mar 2021	NDL	TFS 50487
	if terminalArea &lt;&gt; null then	
		if cargoType = null then	
			cargoType := terminalArea.allCargoBOLTypes.first;
			if cargoType = null and terminalArea.myTerminal.defaultCargoType &gt; 0 then
				cargoType := app.myRoot.allCargoTypesById[terminalArea.myTerminal.defaultCargoType];
			endif;
		endif;
	endif;
	
	self.createEnqController(cargoType.id);
	delete self.myCriteriaLineHolder;
	create self.myCriteriaLineHolder;

	if terminalArea &lt;&gt; null then
		taType := terminalArea.myType;
		self.filterTAType:=taType;
		self.setFilterTerminalArea(terminalArea);
		self.filterYardLocation:=location;
	endif;
	
	if cargoType.isKindOf(CM_CargoType) then
		
		qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
//create the individual criteria query lines
		self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);		
		self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
		self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_Equal, null);	
		self.doCreateCriteriaLine( qDef, self.myCriteriaLineHolder, CM_Container::getMyTILCType.name, CM_QueryOperator.Operator_Equal, null);
		self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith,null); //21 Apr 2016	NDL	TFS 1885

		if cargoType.isCargoGroup then		
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, null);
		else
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::alternativeId.name, CM_QueryOperator.Operator_StartsWith, null);
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder,CM_TrackedItem::eirNumber.name, CM_QueryOperator.Operator_Equal,null);
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::imexStatus.name, CM_QueryOperator.Operator_Equal, null);	
			self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container], self.myCriteriaLineHolder, CM_Container::isoType.name, CM_QueryOperator.Operator_Equal, null);
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, null);
			self.doCreateCriteriaLine(qDef,  self.myCriteriaLineHolder, CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, voyage);
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::getTAType.name, CM_QueryOperator.Operator_Equal,taType);		
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::myTerminalArea.name, CM_QueryOperator.Operator_Equal,terminalArea);
			self.doCreateCriteriaLine(qDef,  self.myCriteriaLineHolder, CM_TrackedItem::myPrimaryActualLocation.name, CM_QueryOperator.Operator_Equal, location);
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::mySubTerminal.name, CM_QueryOperator.Operator_Equal,null);
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::site.name, CM_QueryOperator. Operator_Equal, TI_SITE_ONSITE);
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, null);		
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_Equal,null);
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::customsReference.name, CM_QueryOperator.Operator_StartsWith, null);
			self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::billOfLading.name, CM_QueryOperator.Operator_Equal, null);	
			self.doCreateCriteriaLine(qDef,  self.myCriteriaLineHolder, CM_TrackedItem::getMyUnpackedFromContainerId.name, CM_QueryOperator.Operator_Equal, null);
			self.doCreateCriteriaLine(qDef,  self.myCriteriaLineHolder,CM_TrackedItem::mark.name, CM_QueryOperator.Operator_Equal,null);
			self.doCreateCriteriaLine(qDef,  self.myCriteriaLineHolder,CM_TrackedItem::getStevedoreCodeRecieve.name, CM_QueryOperator.Operator_Equal,null);             //02.10.2020 cnwma1 TFS #50112
			self.doCreateCriteriaLine(qDef,  self.myCriteriaLineHolder,CM_TrackedItem::getStevedoreCodeRelease.name, CM_QueryOperator.Operator_Equal,null);             //02.10.2020 cnwma1 TFS #50112
			self.doCreateCriteriaLine(qDef,	 self.myCriteriaLineHolder,CM_TrackedItem::getShippingLineCode.name.String,CM_QueryOperator.Operator_Equal,null);				//06-06-2022 navtnr20 TFS# 53204
			self.doCreateCriteriaLine(qDef,	 self.myCriteriaLineHolder,CM_TrackedItem::getCountryOfOriginCode.name,CM_QueryOperator.Operator_Equal,null);		//18.08.2022 navtnr20 54441
			self.doCreateCriteriaLine(qDef,	self.myCriteriaLineHolder, CM_TrackedItem::clientRef.name, CM_QueryOperator.Operator_StartsWith, null);				//JIRA 20762
		endif;
	else
		
		qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.BOL_Query_Type,cargoType.id];
		self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_BOL::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
		self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null], self.myCriteriaLineHolder, CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);

		self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_BOL::myOperator.name, CM_QueryOperator.Operator_Equal, null);
		self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_BOL::number.name, CM_QueryOperator.Operator_StartsOrEndsWith, null);	//jlier1 TFS 53454 30/5/22
		if cargoType.id  = BOLType_Log then
			self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null], self.myCriteriaLineHolder, CM_TrackedItem::getTAType.name, CM_QueryOperator.Operator_Equal,taType);				
			self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null], self.myCriteriaLineHolder, CM_TrackedItem::myTerminalArea.name, CM_QueryOperator.Operator_Equal,terminalArea);
			self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null],  self.myCriteriaLineHolder, CM_TrackedItem::myPrimaryActualLocation.name, CM_QueryOperator.Operator_Equal, location);
		endif;
		self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_BOL::mySubTerminal.name, CM_QueryOperator.Operator_Equal,null);
	endif;
	
	self.setTblSearchFromSelector();
	self.setMyCurrentCargoBOLType(cargoType);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoBOLType" usage="input"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="createEnqController" id="8080fd07-bec4-44be-849d-b838c63cc2c2">
        <updating/>
        <source>createEnqController(_cargoTypeID : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation 47132

*/

vars
	cargoBolType : CM_CargoBOLType;
begin
	delete self.myEnqController;
	if (_cargoTypeID &gt; BOLType_Min) and (_cargoTypeID &lt; BOLType_Max) then
		create self.myEnqController as CM_EnqControllerBOL transient;
		create myEnqController.allObjects as CM_BOLSet transient;
		cargoBolType:= app.myRoot.allBOLTypes[_cargoTypeID];
	else
		create self.myEnqController as CM_EnqControllerTI transient;
		create self.myEnqController.allObjects as  CM_TISet transient;
		cargoBolType:= app.myRoot.allCargoTypesById[_cargoTypeID];
	endif;

	
epilog

end;</source>
        <Parameter name="_cargoTypeID" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createUpdateProxy" id="85de0cc1-f50a-432f-9e27-830c0565655a">
        <source>createUpdateProxy(_realObj: CM_Object): CM_Object protected;
// ---------------------------------------------------------------------------
// Created:	29 July 2008 By Graeme Black cnwgb1
// Purpose:	Adds the debtor type dictionary to proxies created through the 
//			standard methods
//			Added for PAR 17591 additional to PAR 16666
// ---------------------------------------------------------------------------
vars
	proxyObject : CM_Object;
begin
	proxyObject := inheritMethod(_realObj);
	if proxyObject.isKindOf( CM_TrackedItem) then
		proxyObject.CM_TrackedItem.allDebtorsByType.clear();
		_realObj.CM_TrackedItem.allDebtorsByType.copy(proxyObject.CM_TrackedItem.allDebtorsByType);
	endif;
	return proxyObject;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_realObj" type="CM_Object"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0d8d2f41-04f2-48dc-9dc3-4edade7b2331">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;

/*
Date				Who		Reason
29 January 2010		cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
15/06/2010			cnwcs5	par 24342 - no longer using CMUI_StopsListTable
 14/04/2023	navkc1	CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop
*/
	
vars
	
begin
	// take care of the possible transient CM_Stops created.
	// par 24342 self.clearStopsCollections;
	// par 24342 self.lstTblStops.clearSelected();
	delete self.myFilterIDList; //cnwrd1 par 24107 12.5.2010
	
	//22 Dec 2011	NDL	Par 28889
	if self.allColumnFilters &lt;&gt; null then
		delete self.allColumnFilters;
	endif;
	
	//epr TFS 47132 27/11/19
	delete self.myEnqController;
	delete self.myCriteriaLineHolder;
	// 14/04/2023	navkc1	CR 57036 Task 57589
	delete self.allMAFIOnboardNotify;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="dischargePort" id="ea90a6f1-482f-4fbf-9bd0-5e3973b6c442">
        <source>dischargePort(_tbl : CM_EntryTable; _row : Integer; _towName : String; _value : Any);
/*
----------   ----------  --------------------------------------------------
Created:	07 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	//do nothing - avoids exception when called by the ETRow_DischargePort lost focus sendMsgWithParams

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_towName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="displayBulkEditChanges" id="4f019926-1c34-4dc4-8cd6-95acd4ac0749">
        <source>displayBulkEditChanges() protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 15/06/2010	cnwcs5		par 24342 - no longer using CMUI_StopsListTable
// 20/07/2010	cnwdap1		PAR #25021 include Tranship tab in comparisons if displayed
// 20/10/2014   cnwma1		PAR # 35020 Bulk Edit thinks Cargo Type has changed
// 18/08/2022  	navmv20 	Bug 54530: MTN - Bulk edit Date field type change anomalies
// 19/12/2023	jlika1		TFS 61189 MTN - Issues with customer priority 
vars
	idx				: Integer;
	numDefs			: Integer;
	workStr			: String;
	changesStr		: String;
	entRowTrans		: EntTableRowTransient;
	tbl				: CM_EntryTable;
	rowObj			: Object;
	updateAlphaOrFF : Boolean;
	row 			: Integer;
	oldValue,
	newValue		: String;
	hasTranship 	: Boolean;
	pxyObj 			: Object;
	custPriority	: CM_CustomerPriority;
begin
	updateAlphaOrFF := (self.isShowingAlphabetised or (not self.canUpdate and self.canChangeFreightForwarder)); // PAR 16564
	//if focus has gone straight from a cell control to the save button, the table WON'T pick up
	//a changed field value automatically, so we must call it explicitly
	if  updateAlphaOrFF then
		tbl := self.tblAlpha;
	else
		tbl := self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);
	endif;
	
	// 28823 Mar 2012 include change of cargo type (in a different table from all the other changes)
	if self.myProxyObject.CM_TrackedItem.myCargoType &lt;&gt; self.myCurrentCargoBOLType then
		if self.myCurrentCargoBOLType &lt;&gt; null then
			oldValue := self.myCurrentCargoBOLType.description;
				
		endif;
		newValue := self.myProxyObject.CM_TrackedItem.myCargoType.description;
		foreach rowObj in self.tblInputTop.allEntRowTransients do
			entRowTrans := rowObj.EntTableRowTransient;
			if entRowTrans.name = ETRow_CargoTypeEntry and oldValue &lt;&gt; null  then	// 20/10/2014 cnwma1 PAR # 35020
				workStr := entRowTrans.getHeading(self.tblInputTop.myTerminologyCargoBOLType, tbl.myTerminologyTerminal, null);
				workStr := workStr &amp; ' from "' &amp; oldValue &amp; '"';
				workStr := workStr &amp; ' to "' &amp; newValue &amp; '"' &amp; CrLf;
				changesStr := workStr;
				break;
			endif;
		endforeach;
	endif;

	// this method resets the 3 stops collections on self of allStopsToAdd, allStopsToRemove and allStopsToUpdate
	// par 24342 self.compareStops;
	
	numDefs := self.numberOfSheets;
	
	if updateAlphaOrFF then
		numDefs := 1;
	endif;	
	
	foreach idx in 1 to numDefs do
		if updateAlphaOrFF then
			tbl := self.tblAlpha;
		else
			tbl := self.getEditTableForIndex(idx);
		endif;
				
		//+cnwml2 PAR24259
		foreach row in 1 to tbl.rows do
			if not tbl.accessRow(row).visible then	//03 Dec 2013	NDL	Par 33104
				continue;
			endif;
			entRowTrans := tbl.accessRow(row).itemObject.EntTableRowTransient;
			if entRowTrans &lt;&gt; null then
				entRowTrans.hasChanged := false;
			endif;
			tbl.doChangedComparison(row);
		endforeach;
		
		foreach rowObj in tbl.allEntRowTransients do
			entRowTrans := rowObj.EntTableRowTransient;
			if entRowTrans.hasChanged then
				// TFS 2115 07/2016 bulk-edit of seals doesn't make sense and gives errors in the update, just skip them by turning off the row changed flag
				if entRowTrans.name.length &gt; 6 and
				   entRowTrans.name[1:6] = "StRow_" then
					entRowTrans.hasChanged := false;
					continue;
				endif;
				// cnwrl1 18/01/2010 PAR 21889 - start of coding
				if entRowTrans.inputType = 0 then		//don't show read only attributes +cnwml2 PAR24259
					continue;
				endif;
				
				if entRowTrans.name = ETRow_AllStops then
					// the stops will be handled specifically in the seperate method below.
					continue;
				endif;
				
				// ### TFS 55215 18Nov2022 NAVPW1
				if entRowTrans.name = ETRow_CustomsReferences then
					continue;
				endif;				
				// ### TFS 55215 18Nov2022 NAVPW1
				
				if entRowTrans.name = ETRow_MyCustomerPriority then
					custPriority := self.myProxyObject.pxyGetRealObject().CM_TrackedItem.getCustomerPriority();
					if custPriority &lt;&gt; null and  custPriority.getDisplayDetails(false) = entRowTrans.originalValue.trimRight then
						entRowTrans.hasChanged := false;
						continue;
					endif;					
				endif;
				
				//epr par 30419 8/10/12 forget about outbound tranship will put this message up if discharge port changes and there is a tranship ti
				if self.myProxyObject.pxyGetRealObject().CM_TrackedItem.isTranshipOutbound and entRowTrans.name = ETRow_TranshipDischargePort then
					continue;
				endif;
				
				if entRowTrans.originalValue &lt;&gt; null then
					oldValue := entRowTrans.originalValue.trimRight;
				endif;
				newValue := tbl.getValueByName(entRowTrans.name).String;
				
				// 25/01/2011 cnwar2 #26807
				if oldValue = 'true' then
					oldValue := app.getString(Yes);
				elseif oldValue = 'false' then
					oldValue := app.getString(No);
				endif;
				if newValue = 'true' then
					newValue := app.getString(Yes);
				elseif newValue = 'false' then
					newValue := app.getString(No);
				endif;
				
				// cnwrl1 18/01/2010 PAR 21889 - end of coding
				workStr := entRowTrans.getHeading(tbl.myTerminologyCargoBOLType, tbl.myTerminologyTerminal, null);
				if entRowTrans.originalValue &lt;&gt; null then
					workStr := workStr &amp; ' from "' &amp; oldValue &amp; '"';
				endif;
				
				workStr := workStr &amp; ' to "' &amp; newValue &amp; '"' &amp; CrLf;
				changesStr := changesStr &amp; workStr;
				
				//epr par 30419 8/10/12
				if entRowTrans.name = ETRow_DischargePort then
					//discharge port has changed if any of the tis are tranship tell them tranship will change
					hasTranship:=false;
					foreach pxyObj in self.allProxyObjects do
						if pxyObj.CM_Object.pxyGetRealObject().CM_TrackedItem.isTranshipOutbound then
							hasTranship:=true;
							break;
						endif;
					endforeach;
					
					if hasTranship then
						workStr:=app.getEntTableRowTranslation(ETRow_TranshipDischargePort,ETGrp_TrackedItemDetails);
						if entRowTrans.originalValue &lt;&gt; null then
							workStr := workStr &amp; ' from "' &amp; oldValue &amp; '"';
						endif;
						
						workStr := workStr &amp; ' to "' &amp; newValue &amp; '"' &amp; CrLf;
						changesStr := changesStr &amp; workStr;
					endif;
				endif;
				
			endif;
		endforeach;
	endforeach;
	
	// This method establishes exactly what has been changed and builds up the change string to that affect.
	// par 24342 self.displayBulkEditChangesAllStops( changesStr );	// cnwrl1 18/01/2010 PAR 21889
	
	if self.hasEditedToDoTasks then
		changesStr := changesStr &amp; 'To Do Tasks have been changed.' &amp; CrLf;
	endif;

	self.txtBlkEditChange.text := changesStr;
	//cnwmc5 - PAR 31051
	if app.isUsingSkin then
		self.txtBlkEditChange.backColor := White;
		self.txtBlkEditChange.left := 11;
	endif;
	// START 18 Aug 2022 navmv20 TFS 54530
	if self.txtBlkEditChange.text &lt;&gt; null then 
		self.showHideBulkEditChanges(true);
	else 
		self.showHideBulkEditChanges(false); 
	endif;
	//END 18 Aug 2022 navmv20 TFS 54530
	// self.showHideBulkEditChanges(true);  // 18 Aug 2022 navmv20 TFS 54530
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayMonitorForBulkEditing" id="eb4bb03a-6577-42f4-8843-335f27e72dc4">
        <updating/>
        <source>displayMonitorForBulkEditing()updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmifMonitor			: CMIF_Monitor;
begin
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	cmifMonitor.partsInJob := self.allProxyObjects.size;
	cmifMonitor.myParent := self;
	cmifMonitor.callBackMethodName := 'updateProgressForBulkEdit';
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, 'Bulk edit saving...', null);
	self.pbProgressBar.visible := true;
	self.lblModalMessage.visible := true;
	self.lblModalInfo.visible := true;
	self.updateProgressForBulkEdit(cmifMonitor);
	self.frmModalDialog.refreshNow;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="5a0bd371-3b26-457b-afeb-e594c2f0638e">
        <updating/>
        <source>displaySelectorResults(_resultCollection : Collection; _mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2004	cnwth2
//
// Purpose:     
//			 
/*

Date		Who		Reason
31 Jul 2008	cnwkpd1	PAR #17642 - Filter objects down to only those from the same terminal as
					the first one in the list
14 May 2024 navrv30 Bug 63977: MTN - Columns not re-positioning in column organiser when new columns added ASYNC
09 Jun 2025 jlier1	MTN-347771 - changed to using display collection
*/

vars
	cargoBOLType		: CM_CargoBOLType;
	cmb					: ComboBox;
	lstCnt,
	numItems,
	intRow,
	idx				: Integer;

begin
	cmb := self.cmbFiltTiType;
	self.myDataClass := global.getClassForCargoBOLType(_mode);	
			
	if _mode &lt;&gt; null then	
		lstCnt := cmb.listCount;
		foreach idx in 1 to lstCnt do
			cargoBOLType := cmb.itemObject[idx].CM_CargoBOLType;
			if (cargoBOLType &lt;&gt; null) and (cargoBOLType.id = _mode) then
				cmb.listIndex := idx;
				self.origValueStr := cmb.text; //28/01/2011 cnwdz2 par26669
				break;
			endif;
		endforeach;
		
		self.tblSearch.setValueByName(ETRow_FilterTiType, cmb.text);
		cmb.click(cmb);
	else
		cmb.text := null;
	endif;

	//jlier1 9/6/25 MTN-347771 - changed to using display collection
	if self.tblData.isPaginated then
		self.tblData.clearAllSelected();
	else
		self.tblData.clearAllData();
	endif;
	//jlier1 9/6/25 MTN-347771 	
	self.tblData.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, _resultCollection, true);
	numItems:=_resultCollection.size;
	
	
	//05/01/2010 cnwdz2 26687
	if self.isSearcherFloating then
		self.searcherShowHideControls(true);
		self.frmSearch.visible := false;
		self.isSearcherVisible := false;
	endif;
	self.mode := self.Mode_View;

	//show something
	intRow := self.tblData.fixedRows + 1;
	if intRow &lt;= self.tblData.rows then
		self.tblData.clearAllSelected();
		self.myCurrentObject := self.tblData.accessRow(intRow).itemObject.CM_Object;
		self.tblData.accessedRow.selected := true;
		self.showThumbnailData(self.myCurrentObject.CM_Object);
	endif;
	
	self.numItemsShown	:= numItems;
	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;

epilog
	
	
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAlphaSort" id="57142097-4c4c-4da8-8f6a-a0b250a87bd9">
        <updating/>
        <source>doAlphaSort(_obj : CM_Object; _dynaDict	: DynaDictionary input) protected, updating;
// 35199 alphabetic sort taking cargo/product type attributes into account
vars

	ucTab			: CM_UserConfigTab;
	ucAttr			: CM_UserConfigAttribute;
	row				: EntTableRow;
	heading			: String;
	translation		: XLAT_Translation;
	alteredHeaderName : String;
	hideRow 		: Boolean;
	measureType 	: CM_MeasurementType;
	
begin
	// sort with an external key to keep the original EntTableRows
	_dynaDict.setMembership(EntTableRow);
	_dynaDict.addExternalKey(String, 60, false, false);
	_dynaDict.endKeys(false);
	
	foreach ucTab in self.myUserCargoType.allUserConfigTabs do
		foreach ucAttr in ucTab.allAttributes do
			row := ucAttr.myEntTableRow;
			heading := row.getHeadingUnaltered();
			_obj.hasEntTableSpecialConditions(	row,
												alteredHeaderName,
												hideRow,
												measureType);
			if alteredHeaderName = null then
				translation := row.getTranslation(app.myCurrentLocale);
				if translation &lt;&gt; null then
					alteredHeaderName := translation.text;
				endif;
			endif;
			if alteredHeaderName &lt;&gt; null then
				heading := alteredHeaderName;
			endif;
			if _dynaDict[heading] = null then
				_dynaDict[heading] := row;
			endif;
		endforeach;
	endforeach;
	if self.isReeferTabVisible then
		foreach ucTab in self.myReeferCargoType.allUserConfigTabs do
			foreach ucAttr in ucTab.allAttributes do
				row := ucAttr.myEntTableRow;
				heading := row.getHeadingUnaltered();
				_obj.hasEntTableSpecialConditions(	row,
													alteredHeaderName,
													hideRow,
													measureType);
				if alteredHeaderName = null then
					translation := row.getTranslation(app.myCurrentLocale);
					if translation &lt;&gt; null then
						alteredHeaderName := translation.text;
					endif;
				endif;
				if alteredHeaderName &lt;&gt; null then
					heading := alteredHeaderName;
				endif;
				if _dynaDict[heading] = null then
					_dynaDict[heading] := row;
				endif;
			endforeach;
		endforeach;
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_dynaDict" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAutoPlan" id="01244ff8-6ada-4e09-9814-16b10eaaada5">
        <updating/>
        <source>doAutoPlan() protected, updating;
// -------------------------------------------
// Created 24 May 2005 by cnwdvb1
// -------------------------------------------
vars

	tiArray	: CM_TIArray;
	str		: String;
	result	: Integer;
	ti		: CM_TrackedItem;
	params : CMIF_AutoplanParams;

begin

	create tiArray transient;
	create params transient;
	
	if self.tblData.allSelectedObjects.isEmpty() then
		ti := self.myCurrentObject.CM_TrackedItem;
		if ti = null then
			return;
		endif;
		params.allTrackedItems.add(ti);
	else
		self.tblData.allSelectedObjects.copy(params.allTrackedItems);		
	endif;
					
	// PAR 19450
	params.moveMode := QUEUE_MODE;
	params.myTerminalArea := null;
	params.myJob := null;
	params.showWarningWhenNoPlan := true;
		
	while true do
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	
		


epilog
	delete tiArray;
	delete params;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="b4592da2-e484-475f-a23f-30fd6a9e7493">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// cnwrs1       21 Apr 2011  if in alphabetic mode use the tblAlpha table not the tblEdit1 table to get booking ref details
// cnwdap1		17 Aug 2011	 PAR #27949 Booking Ref is sometimes in tblEdit2 (for Motor Vehicles, Generators and Clip-On Units)
// navmv20 		18 Aug 2022  Bug 54530: MTN - Bulk edit Date field type change anomalies
// jlizm1		29 Sep 2022	 TFS 54702 CUX MAFI Auto Queueing
vars
	bookingRefRow	: Integer;				// PAR #27949
	editTable		: CM_EntryTable;		// PAR #27949
	operator : CM_Operator;	//24 Jun 2013	NDL	Par 31807
	voyage : CM_Voyage;	//24 Jun 2013	NDL	Par 31807
	bookRefNumber : String;	//24 Jun 2013	NDL	Par 31807
	bookRef : CM_BookingRef;	//24 Jun 2013	NDL	Par 31807
	checkBooking : Boolean;	//24 Jun 2013	NDL	Par 31807
begin
	if self.isShowingAlphabetised then //par 27418 cnwrs1 26 Apr 2011
		//+cnwml2 PAR24395
		if self.tblAlpha.row = self.tblAlpha.getRowByName(ETRow_BookingReference) then // dh 27/2/2008 for ccms 1004
			self.doBookingRefRowChange(self.tblAlpha);
		
		//24 Jun 2013	NDL	Par 31807
		elseif self.tblAlpha.row = self.tblAlpha.getRowByName(ETRow_MyOperator) then 
			if self.tblAlpha.getRowByName(ETRow_BookingReference) &gt; 0 then
				bookRefNumber := self.tblAlpha.getValueByName(ETRow_BookingReference).String.trimRight;
				if bookRefNumber &lt;&gt; null then
					// booking was set prior so need to see if a change to voyage or operator may have effected its validity
					operator := self.cmbOperator.listObject.CM_Operator;
					voyage := cmbVoyage.listObject.CM_Voyage;
					if operator &lt;&gt; null then
						bookRef := self.myTerminal.getBookingReference(operator.code, bookRefNumber, voyage);
					else
						bookRef := self.myTerminal.getBookingReference(null, bookRefNumber, voyage);
					endif;
					if bookRef = null or bookRef.bookingReference &lt;&gt; bookRefNumber then
						// not the same as it was...
						self.doBookingRefRowChange(self.tblAlpha);
					endif;
				endif;
			endif;
		endif;
		
	else
		// PAR #27949 sort out where booking reference row is
		editTable := self.getTableForRow(ETRow_BookingReference);
		if editTable &lt;&gt; null then
			bookingRefRow := editTable.getRowByName(ETRow_BookingReference);
		endif;
		
		
	//	if bookingRefRow &lt;&gt; null and editTable &lt;&gt; null and editTable.row = bookingRefRow then
	//		self.doBookingRefRowChange(editTable);	
	//	endif;
	
		//24 Jun 2013	NDL	Par 31807 - may be pressing save directly from having changed Operator or Voyage which can also effect booking
		if bookingRefRow &lt;&gt; null and editTable &lt;&gt; null then
			if editTable.row = bookingRefRow then // direct from booking
				self.doBookingRefRowChange(editTable);
				
			else
				//24 Jun 2013	NDL	Par 31807
				bookRefNumber := editTable.getValueByName(ETRow_BookingReference).String.trimRight;
				if bookRefNumber &lt;&gt; null then
					// booking was set prior so need to see if a change to voyage or operator may have effected its validity
					editTable := self.getTableForRow(ETRow_MyOperator);
					if editTable &lt;&gt; null then
						if editTable.row = editTable.getRowByName(ETRow_MyOperator) then
							//came direct from operator field
							checkBooking := true;
						endif;
					endif;
					if checkBooking then
						operator := self.cmbOperator.listObject.CM_Operator;
						voyage := self.cmbVoyage.listObject.CM_Voyage;
						if operator &lt;&gt; null then
							bookRef := self.myTerminal.getBookingReference(operator.code, bookRefNumber, voyage);
						else
							bookRef := self.myTerminal.getBookingReference(null, bookRefNumber, voyage);
						endif;
						if bookRef = null or bookRef.bookingReference &lt;&gt; bookRefNumber then
							// not the same as it was...
							self.doBookingRefRowChange(editTable);
						endif;
					endif;
				endif;
				
			endif;
		endif;
		
	endif;
		
	if self.doingMultiEdit then
		self.displayBulkEditChanges();
	// START 18 Aug 2022 navmv20 TFS 54530
		if self.txtBlkEditChange.text = null then
			inheritMethod();
		endif;
	// END 18 Aug 2022 navmv20 TFS 54530
	else
		inheritMethod();
		//jlier1 TFS 65290 done in object - was changed to always do it with out a warning because needed to be done from API call
		//if voyageChangedMAFI then		// TFS 54702
		//	self.doQueueCargoOffMAFI();	// TFS 54702
		//endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBookingRefRowChange" id="7500621a-513d-4ddb-9331-b900743dafc5">
        <updating/>
        <source>doBookingRefRowChange(table : CM_EntryTable input) updating;
/*
	Created on 27 February 2008
	
	by Debby Hutchison
	
	Purpose:


Date		Who		Reason
31 Jul 2008	cnwkpd1	PAR #17642 - Use self.myTerminal in preference to app.getMyTerminal
18 Aug 2011	cnwdap1	PAR #27949 If we're dealing with cargo types that have booking reference on a different 
								table to operator, we can't use operator in the booking reference lookup
								(as the tab that contains operator may not have been clicked on and loaded with data)
*/


vars
	bookRefNumber 		: String;
	bookRef				: CM_BookingRef;
	terminal			: CM_Terminal;
	currentBRItem 		: CM_BookingRefItem;

begin
	// PAR #17642 - form should have terminal defined
	terminal := self.myTerminal;
	if terminal = null then
		terminal := app.getMyTerminalDO_NOT_USE;
	endif;
	
	bookRefNumber := table.getValueByName(ETRow_BookingReference).String.trimRight;
	
	//cnwrd1 ccms PNL 1804
	self.doUpdateFromBookingRefChange(table);
	
//	if cmbOperator.listObject &lt;&gt; null and terminal &lt;&gt; null then		//Lookup by operator					// PAR #27949
	if terminal &lt;&gt; null then																				// PAR #27949
		if cmbOperator.listObject &lt;&gt; null then																// PAR #27949
			bookRef := terminal.getBookingReference(cmbOperator.listObject.CM_Operator.code, bookRefNumber, cmbVoyage.listObject.CM_Voyage); // adm 150908 Par 17936
		else																								// PAR #27949
			bookRef := terminal.getBookingReference(null, bookRefNumber, cmbVoyage.listObject.CM_Voyage);	// PAR #27949
		endif;																								// PAR #27949
	endif;
	if cmbBRItem.listObject &lt;&gt; null then
		currentBRItem := cmbBRItem.listObject.CM_BookingRefItem;
	endif;
	loadBookingRefItems(bookRef);
	
	if currentBRItem &lt;&gt; null and currentBRItem.myBookingReference = bookRef then
		cmbBRItem.setObject(currentBRItem);	
	elseif bookRef &lt;&gt; null and bookRef.allBookingRefItems.size = 1 then
		cmbBRItem.setObject(bookRef.allBookingRefItems.first);
	else
		cmbBRItem.listIndex := -1;
	endif;
	cmbBRItem.lostFocus(cmbBRItem);
	//setupBookRefDetailRow(bookRef);
	self.myProxyObject.CM_TrackedItem.updateBookingRef(bookRef);		//+cnwml2 PAR23763 MSL PAR1078
	
epilog
	
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="0aa3038f-c792-4cef-b922-0149fac33452">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
18 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	
begin
	// Get a collection of ALL the rows displayed to pass to the Summary Definition form.
	app.mousePointer	:= Busy;
	create coll transient;
	
	if self.amInitialisingWithObject then
		coll.addNoDuplicates( self.myCurrentObject, false );
	else
		tblData.getAllRowObjects( coll );
	endif;
	
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksAdd" id="0aab84b0-4822-45c7-b76f-f170d8fb4fb0">
        <updating/>
        <source>doBuildMnuTasksAdd(_menuMaster: MenuItem io; _theTI : CM_TrackedItem input) updating;

// ---------------------------------------------------------------------------
// Created:		August 2003 By Jason Chapman
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// ---------------------------------------------------------------------------
vars
	dynaDict			: DynaDictionary;
	obj					: Object;
	task				: CM_ToDoTask;
	taskDesc			: CM_ToDoTaskDesc;
	tmpMenu, 
	mnuChild,
	mnuMaster			: MenuItem;
	itemEnabled			: Boolean;
	taskDict			: CM_ToDoTaskDescByCode;
	subMenuAdded		: Boolean;
begin	
	subMenuAdded := false;
	
	// ##############################################
	// Build up menu of ToDo Tasks that can be set
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	
	self.allAddTaskMenus.purge();					//TFS7151
	if taskDict.isEmpty then
		_menuMaster.visible := false;
		return;
	endif;

	mnuMaster := _menuMaster;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	//mnuMaster.caption := "Add Tasks"; // removed cnwrd1 par #18519 11.9.09
	self.mnuTaskAddSub.visible := true;
	self.mnuTaskAddSub.caption := app.getErrorString(NO_TASKS);
		
	// 36868 sort menu items by sortKey then description, so that if there is no sort key or it is not unique then the description becomes the main sort field
	create dynaDict transient;
	dynaDict.setMembership(CM_ToDoTaskDesc);
	dynaDict.addMemberKey("sortKey", false, true);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.endKeys(true);
	//app.writeStatement ( self.mnuTaskAddSub.description.String);		// Please don't leave this on in DMAST
	tmpMenu := self.mnuTaskAddSub;
	foreach taskDesc in taskDict do
		dynaDict.add(taskDesc);
	endforeach;

	foreach obj in dynaDict do
		taskDesc := obj.CM_ToDoTaskDesc;
		itemEnabled := true;
		
		foreach task in _theTI.allToDoTasksToDo do
			if task.toDoTaskDesc = taskDesc then
				itemEnabled := false;
			endif;
		endforeach;

		if taskDesc.description = null then 
			itemEnabled := false;
		endif;
		
		// DVB added to screen for cargo type.
		if itemEnabled and not taskDesc.isAvailableForCargoType(_theTI.cargoType) then
			continue;
		endif;
		
		// Par 17775. ccms1045. APM - Yard Ops, new generator Types. August 2008
		if itemEnabled and not taskDesc.isValidForGenSet( _theTI ) then
			continue;
		endif;
		mnuChild := null;
		//epr CCMS 1366 9/4/14
		
		//keep cloning until all tasks represented
		mnuChild := self.zCloneMenu(mnuMaster, tmpMenu, true); 
		self.allAddTaskMenus.add(mnuChild);																			//+TFS7151
		mnuChild.caption := taskDesc.description ;
		//mnuChild.visible := true;
		mnuChild.visible := itemEnabled; //cnwjo3 par 19156
		mnuChild.enabled := itemEnabled;
		mnuChild.helpKeyword := taskDesc.description;
		mnuChild.userObject := taskDesc;

		tmpMenu := mnuChild;
		if itemEnabled then
			subMenuAdded := true;
		endif;
	endforeach;
	
	
	//disable menu if no tasks available
	if subMenuAdded = false then
		if mnuMaster &lt;&gt; null then
			mnuChild := self.zCloneMenu(mnuMaster, tmpMenu, true); 
			mnuChild.caption := app.getErrorString(NO_TASKS);
			mnuChild.userObject := null;
			mnuChild.visible := true;
			mnuChild.enabled := true;
			tmpMenu := mnuChild;
		endif;
	
	endif;
	
	
epilog
	delete taskDict;
	delete dynaDict;
end;</source>
        <Parameter name="_menuMaster" type="MenuItem" usage="io"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksComplete" id="b325777f-ff4a-4be1-b696-14cf5ba9b31d">
        <updating/>
        <source>doBuildMnuTasksComplete(_menuMaster: MenuItem input; _theTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	task				: CM_ToDoTask;
	taskDesc			: CM_ToDoTaskDesc;
	tmpMenu,
	mnuChild,
	mnuMaster			: MenuItem;
	taskDict			: CM_ToDoTaskDescByCode;
	iter 				: Iterator;
	itemEnabled,
	subMenuAdded		: Boolean;
begin
	subMenuAdded := false;
	
	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	taskDict := app.myPassport.myUser.getToDoTasksCompleteForTerm(self.myTerminal);
	
	if taskDict.isEmpty then
		_menuMaster.visible := false;
		return;
	endif;

	mnuMaster := _menuMaster;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	// mnuMaster.caption := "Complete Tasks";// removed cnwrd1 par #18519 11.9.09
	self.mnuTaskCompleteSub.visible := true;
	self.mnuTaskCompleteSub.caption := app.getErrorString(NO_TASKS);
	
	tmpMenu := self.mnuTaskCompleteSub;

	//show todos that can be completed

	iter := taskDict.createIterator();
	while iter.next(taskDesc) do
		itemEnabled := false;
		if taskDesc.isForGenSetAttachDetach() then	// Attach/Detach generator task
			if not _theTI.canHaveGeneratorAttached() then	// Par 18227, the menu item should be vsible for reefers and trailers. Dec 2008	
				continue; 
			endif;
		else
			
			foreach task in _theTI.allToDoTasksToDo do
				if task.toDoTaskDesc = taskDesc then
					itemEnabled := true;
				endif;
			endforeach;
		endif;
		
	
		
		//keep cloning until all tasks represented
		mnuChild := self.zCloneMenu(mnuMaster, tmpMenu, true);
		mnuChild.caption := taskDesc.description;
		mnuChild.visible := itemEnabled; //cnwjo3 par 19156
		mnuChild.enabled := itemEnabled;
		mnuChild.helpKeyword := taskDesc.description;
		mnuChild.userObject := taskDesc;
		tmpMenu := mnuChild;
		if itemEnabled then
			subMenuAdded := true;
		endif;
		
		
	endwhile;
	
	//disable menu if no tasks available
	if subMenuAdded = false then
		if mnuMaster &lt;&gt; null then
			mnuChild := self.zCloneMenu(mnuMaster, tmpMenu, true);
			mnuChild.caption := app.getErrorString(NO_TASKS);
			mnuChild.visible := true;
			mnuChild.enabled := true;
			mnuChild.userObject := null;
			tmpMenu := mnuChild;
		endif;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_menuMaster" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksRemove" id="986df821-fb98-432b-b89c-d571c40a7a41">
        <updating/>
        <source>doBuildMnuTasksRemove(_menuMaster: MenuItem input; _theTI : CM_TrackedItem input) updating;
//----------------------------------------------------------------
//	Created:	11 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	task				: CM_ToDoTask;
	taskDesc			: CM_ToDoTaskDesc;
	tmpMenu,
	mnuChild,mnuMaster	: MenuItem;
	itemEnabled			: Boolean;
	taskDict			: CM_ToDoTaskDescByCode;
	iter 				: Iterator;
	subMenuAdded		: Boolean;
begin
	subMenuAdded := false;
	
	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	
	if taskDict.isEmpty then
		_menuMaster.visible := false;
		return;
	endif;

	mnuMaster := _menuMaster;//self.mnuCargoTaskComplete;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	//mnuMaster.caption := "Remove Tasks"; // removed cnwrd1 par #18519 11.9.09
	self.mnuTaskRemoveSub.visible := true;
	self.mnuTaskRemoveSub.caption := app.getErrorString(NO_TASKS);
	
	tmpMenu := self.mnuTaskRemoveSub;

	//show todos that can be completed
	iter := taskDict.createIterator();
	while iter.next(taskDesc) do
		
		itemEnabled := false;
		
		if taskDesc.isForGenSetAttachDetach() and not _theTI.canHaveGeneratorAttached() then	//Par18227. Attach/Detach GenSet should be visible only for reefers and trailers
			continue;	// hide the menu item 
		else
			foreach task in _theTI.allToDoTasksToDo do
				if task.toDoTaskDesc = taskDesc then
					itemEnabled := true;
				endif;
			endforeach;
			
		endif;

		
		//keep cloning until all tasks represented
		mnuChild := self.zCloneMenu(mnuMaster, tmpMenu, true); 
		mnuChild.caption := taskDesc.description;
		mnuChild.visible := itemEnabled; //cnwjo3 par 19156
		mnuChild.enabled := itemEnabled;
		mnuChild.helpKeyword := taskDesc.description;
		mnuChild.userObject := taskDesc;
		tmpMenu := mnuChild;
		if itemEnabled then
			subMenuAdded := true;
		endif;
		
	endwhile;
	
	//disable menu if no tasks available
	if subMenuAdded = false then
		if mnuMaster &lt;&gt; null then
			mnuChild := self.zCloneMenu(mnuMaster, tmpMenu, true);
			mnuChild.caption := app.getErrorString(NO_TASKS);
			mnuChild.userObject := null;
			mnuChild.visible := true;
			mnuChild.enabled := true;
			tmpMenu := mnuChild;
		endif;
		
		else
		//set no Tasks to visible
	endif;
epilog
	delete iter;
	delete taskDict;
end;</source>
        <Parameter name="_menuMaster" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCalculateTotalWeight" id="3b52ad57-6057-4d7f-a7d6-ab493bfc0cbc">
        <source>doCalculateTotalWeight(_theLostFocusTable : CMUI_MeasurementTable);
/*

Purpose:	on Cargo Weight &amp; Tare weight lost focus, calculate and populate the total weight

Parameters:			

Return Value:		

Date		Who		Reason
21/02/2023	navkc1 Bug 62340: MSL -- Automatic Sum of Tare + Cargo Weight does not happen using the "Use Tare/Cargo Weight" setting
19/04/2023	navra1	CR 63624 : MSL - Auto Calculate Of Weight - Tare and Total Weight

*/

vars
	totalWeightTable,
	cargoWeightTable,
	tareWeightTable		: CMUI_MeasurementTable;	
	parentTable 		: CM_EntryTable;	
	totalWeight, 
	cargoWeight			: Decimal[23,10];	
	weightStr,
	prefix,
	rowName 			: String;	
	measureToUse		: CM_MeasurementType;	
	cargoType			: CM_CargoType;	
	
begin
	
	parentTable := _theLostFocusTable.parent.CM_EntryTable;
	
	// Get measurement tables.
	totalWeightTable := parentTable.getMeasurementTableForRowName(ETRow_TotalWeight);
	cargoWeightTable := parentTable.getMeasurementTableForRowName(ETRow_WeightCargo);
	tareWeightTable := parentTable.getMeasurementTableForRowName(ETRow_WeightTare);	
	
	if _theLostFocusTable.rowName = ETRow_WeightCargo or _theLostFocusTable.rowName = ETRow_WeightTare then		
		if totalWeightTable.getRawValue().Integer = cargoWeightTable.getRawValue().Integer + tareWeightTable.getRawValue().Integer then
			return;
		endif;
		
		//If we lost focus from cargo weight -ie. probably changed cargo weight, the total weight would change
		cargoType := self.myProxyObject.CM_TrackedItem.myCargoType;
		//Set the total weight, based on the changed(maybe) on the cargoweight from which we just lost focus		
		measureToUse :=  cargoType.getDefaultMeasurementForType(totalWeightTable.measurementType);
		prefix := app.getMeasurementPrefixFromType(measureToUse.measurementType);
		rowName := prefix &amp; ETRow_TotalWeight &amp; "_" &amp; measureToUse.shortName;
		
		totalWeight := cargoWeightTable.getConvertedValue() + tareWeightTable.getConvertedValue();
		
		if totalWeight &lt;= 0 then
			return;
		endif;	
		
		weightStr := app.convertMeasurementForDisplay(measureToUse.shortName, totalWeight.Decimal);
		
		totalWeightTable.setValue(totalWeight);
		
		parentTable.setValueByName(rowName, weightStr &amp; " " &amp; totalWeightTable.getUnit());			
		
		return;	
	elseif _theLostFocusTable.rowName = ETRow_TotalWeight then				
		if totalWeightTable.getRawValue().Integer = cargoWeightTable.getRawValue().Integer + tareWeightTable.getRawValue().Integer then
			return;
		endif;
	
		//If we lost focus from total weight -ie. probably changed total weight, the cargo weight would change(NOT THE TARE WEIGHT)
		cargoType := self.myProxyObject.CM_TrackedItem.myCargoType;
		measureToUse :=  cargoType.getDefaultMeasurementForType(cargoWeightTable.measurementType);
		prefix := app.getMeasurementPrefixFromType(measureToUse.measurementType);
		rowName := prefix &amp; ETRow_WeightCargo &amp; "_" &amp; measureToUse.shortName;		
		
		cargoWeight := totalWeightTable.getConvertedValue() - tareWeightTable.getConvertedValue();		
		
		if cargoWeight &lt;= 0 then
			return;
		endif;	
		
		weightStr := app.convertMeasurementForDisplay(measureToUse.shortName, cargoWeight.Decimal);
		
		cargoWeightTable.setValue(cargoWeight);
		
		parentTable.setValueByName(rowName, weightStr &amp; " " &amp; cargoWeightTable.getUnit());				
		
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_theLostFocusTable" type="CMUI_MeasurementTable"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="91e69e22-3265-42df-bf98-23fc798cede8">
        <updating/>
        <source>doCancel(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	if (self.shtEdit1.visible and self.tblAlpha.hasChanged)
	or (self.shtEdit1.visible and self.tblEdit1.hasChanged)
	or (self.shtEdit2.visible and self.tblEdit2.hasChanged)
	or (self.shtEdit3.visible and self.tblEdit3.hasChanged)
	or (self.shtEdit4.visible and self.tblEdit4.hasChanged)
	or (self.shtEdit5.visible and self.tblEdit5.hasChanged)
	or (self.shtEdit6.visible and self.tblEdit6.hasChanged)
	or (self.shtEdit7.visible and self.tblEdit7.hasChanged)
	or (self.shtEdit8.visible and self.tblEdit8.hasChanged)
	or (self.shtEdit9.visible and self.tblEdit9.hasChanged)
	or (self.shtEdit10.visible and self.tblEdit10.hasChanged)
	then
		return self.confirmCancel('the current item');
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCargoGroupRowChange" id="f8630315-0f37-4cae-8e63-0cfc75bdc297">
        <source>doCargoGroupRowChange( table: CM_EntryTable input ) : CMUI_CargoGroupCreateForm;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation	Par 36338
30 Aug 2023		navrv30	ChangeRequest 59418: EUP - Cargo Group Creation -  Operator

*/

vars
	originalRowValue	: String;
	terminal : CM_Terminal;
	cargoGroupId : String;
	cargoGroup : CM_CargoGroup;
	msg : String;
	creatCargoGroup : CMUI_CargoGroupCreateFormModal;
begin

	terminal := self.myTerminal;
	if terminal = null then
		return null;
	endif;
	
	cargoGroupId := table.getValueByName(ETRow_CargoGroup).String.trimBlanks.toUpper;
	
	if cargoGroupId = null then
		return null;
	endif;
	
	cargoGroup := terminal.getCargoGroupItem( cargoGroupId );
	if cargoGroup &lt;&gt; null and cargoGroup.id &lt;&gt; cargoGroupId then
		cargoGroup := null;
	endif;
	
	if cargoGroup = null then
		msg := app.getErrorString1(Cargo_group_not_found_want_cre,cargoGroupId);
		if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) = MsgBox_Return_Yes then
		// TFS 2417 07/2016 calling the cargo group create form causes a gotFocus on the table with the cargoGroup row and this updates the ent row transient 'originalValue' value
		//   from the value just entered which means that for a multi-item edit it doesn't think the cargo group has changed and does not update the property.
		//  Save and restore the 'originalValue' here so the cargo group is updated to the selected items
			originalRowValue := table.getOrigValueByName(ETRow_CargoGroup).String;		// TFS 2417
			creatCargoGroup := app.loadForm(CMUI_CargoGroupCreateFormModal, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_CargoGroupCreateFormModal;
			creatCargoGroup.setCargoGroupId( cargoGroupId );	
// ### TFS CR 59942 TASK 59943 08SEP2023 NAVAB1			if self.cmbOperator.listObject &lt;&gt; null then   												//30.8.2023	navrv30	#59418
// ### TFS CR 59942 TASK 59943 08SEP2023 NAVAB1				creatCargoGroup.cmbGCOper.setObject( self.cmbOperator.listObject );                     //30.8.2023	navrv30	#59418
			creatCargoGroup.passedOperator := self.cmbOperator.listObject.CM_Operator;             //30.8.2023	navrv30	#59418
			creatCargoGroup.passedVoyage := self.cmbVoyage.listObject.CM_Voyage; // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
// ### TFS CR 59942 TASK 59943 08SEP2023 NAVAB1			endif;
// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1			creatCargoGroup.showModal();
			
			if   creatCargoGroup.showModal() = IDOK then
				cargoGroup:= creatCargoGroup.userObject.CM_CargoGroup;
				if cargoGroup &lt;&gt; null then
					table.setOrigValueByName(ETRow_CargoGroup, cargoGroup.id);
					table.setValueByName(ETRow_CargoGroup, cargoGroup.id);
				else
					table.setOrigValueByName(ETRow_CargoGroup, originalRowValue);
				endif;
			else
					table.setOrigValueByName(ETRow_CargoGroup, originalRowValue);				// TFS 2417
			endif;
			
		endif;
	endif;

epilog

	return creatCargoGroup;

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <ReturnType type="CMUI_CargoGroupCreateForm"/>
    </JadeMethod>
    <JadeMethod name="doCheckKeyDownSpecial" id="3adf4021-9467-46f5-9b7e-df4bc70c2b44">
        <updating/>
        <source>doCheckKeyDownSpecial(_keyCode : Integer; _tableCellInputReadyMethod : String): Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	return inheritMethod(_keyCode, _tableCellInputReadyMethod);
epilog

end;</source>
        <Parameter name="_keyCode" type="Integer"/>
