    <JadeMethod name="getSapRPKOPPPKBNo" id="02a269db-457c-44d6-aa10-4a279c97329b">
        <source>getSapRPKOPPPKBNo():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

	imsr : CM_WodMarineServicesInitial;
	voyCargo : CM_WodVoyageCargoRequest;

begin

	if self.myVoyage = null then
		return null;
		
	endif;
	
	if self.getSapVesselCargo = "Vessel" then
		imsr := self.myVoyage.getWorkOrderForIMSR();
		if imsr = null then
			return null;
		endif;
		return imsr.getInaportnetRPKRO;
		
	elseif self.getSapVesselCargo = "Cargo" then
		voyCargo := self.myVoyage.getWorkOrderForVoyCargoRequest();
		if voyCargo = null then
			return null;
		endif;
		return voyCargo.getInaportnetPPKB;
		
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
