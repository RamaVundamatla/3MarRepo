    <JadeMethod name="haltProgress" id="2911e835-1356-4050-b866-3ccddcad4adc">
        <source>haltProgress(pe : CM_ProgressException) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars

begin
	if app.msgBox(self.myBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		return Ex_Abort_Action;
	else
		return Ex_Continue;
	endif;
epilog

end;</source>
        <Parameter name="pe" type="CM_ProgressException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listCreditNotesToTable" id="536d5348-247b-4759-99cc-5cd5cb14434e">
        <updating/>
        <source>listCreditNotesToTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars

	debtorStr : String;
	invoice : CM_Invoice;
	debtor : CM_Debtor;
begin

	self.doQuery();
	
	// ### TFS BUG 58822 27UN2023 NAVAB1
	if self.tblCreditNotes.rows = self.tblCreditNotes.fixedRows then
		foreach invoice in self.allInvoicesToLink discreteLock do
				debtor := invoice.debtor;
				if debtor &lt;&gt; null then
					if debtorStr.pos(debtor.name,1) = 0 then
						if debtorStr = null then
							debtorStr := debtor.name;
						else
							debtorStr &amp;= "," &amp; debtor.name;
						endif;
					endif;
				endif;
		
		endforeach;
		if debtorStr &lt;&gt; null then
			app.msgBox(app.getErrorString1(There_no_credit_notes, debtorStr), app.getErrorString(Problem), MsgBox_OK_Only);
		
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
