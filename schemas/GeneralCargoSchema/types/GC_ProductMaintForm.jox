    <JadeMethod name="addObjectForHaveOperator" id="9504734b-c012-433a-b399-65ec9dfe6f97">
        <updating/>
        <source>addObjectForHaveOperator(_operator : CM_Operator; 
						_breakOut : Boolean io;
						_numItems: Integer io) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	proDict			: CM_ProductByCargoTypeCodeDict;
	pro				: CM_Product;
	iter			: Iterator;
	codeKey			: String;
	filtCargoType,
	cargoTypeKey	: Integer;
begin
	if _operator = null then
		return;
	endif;
	
	proDict := _operator.allProducts;
	iter := proDict.createIterator;
	
	if self.myFilterCargoType &lt;&gt; null then
		filtCargoType := self.myFilterCargoType.id;
	endif;
	
	proDict.startKeyGeq(filtCargoType, null, iter);
	
	while iter.next(pro) do
		proDict.getIteratorKeys(cargoTypeKey, codeKey, iter);
		
		if filtCargoType &lt;&gt; null and filtCargoType &lt;&gt; cargoTypeKey then
			break;
		endif;
		
		if (self.filterCode = null or self.filterCode.pos(pro.code, 1) = 1) and
		   (self.filterDescription = null or self.filterDescription.toUpper.pos(pro.description.toUpper, 1) = 1) and
			(self.myFilterHandlingType = null or self.myFilterHandlingType = pro.myHandlingType) then
			
			self.addObjectToTable(pro, _numItems, _breakOut);
		endif;
		
		if _breakOut then
			break;
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsForHaveCargoType" id="286bf8f6-2e8b-4563-b015-f0a8363f73d7">
        <updating/>
        <source>addObjectsForHaveCargoType(_cargoType : CM_CargoType; 
							_breakOut : Boolean io;
							_numItems: Integer io) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	proDict		: CM_ProductByOpCodeProCodeDict;
	pro			: CM_Product;
	opCodeKey,
	proCodeKey,
	filtOpCode	: String;
	iter		: Iterator;

begin
	if _cargoType = null then
		return;
	endif;
	
	proDict := _cargoType.allProducts;
	iter := proDict.createIterator();
	if self.myFilterOperator &lt;&gt; null then
		filtOpCode := self.myFilterOperator.code;
	endif;
	
	proDict.startKeyGeq(filtOpCode, null, iter);
	
	while iter.next(pro) do
		proDict.getIteratorKeys(opCodeKey, proCodeKey, iter);
		
		if filtOpCode &lt;&gt; null and filtOpCode &lt;&gt; opCodeKey then
			break;
		endif;
		
		if (self.filterCode = null or self.filterCode.pos(pro.code, 1) = 1) and
			(self.filterDescription = null or self.filterDescription.toUpper.pos(pro.description.toUpper, 1) = 1) and
			(self.myFilterHandlingType = null or self.myFilterHandlingType = pro.myHandlingType) then	
			self.addObjectToTable(pro, _numItems, _breakOut);
		endif;
		
		if _breakOut then
			break;
		endif;
	endwhile;

epilog
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="44f3a0e0-bf27-40b3-816c-919ea8f9f6ae">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars
	cargoType		: CM_CargoType;
	breakOut		: Boolean;
	cargoTypeDict	: CM_CargoTypesByIdDict;
	iter			: Iterator;
	cargoTypeKey	: Integer;
begin
	app.mousePointer := MousePointer_HourGlass;	
	
	cargoType := self.myFilterCargoType;

	if cargoType = null then
		if self.myFilterOperator &lt;&gt; null then
			self.addObjectForHaveOperator(self.myFilterOperator, breakOut, _numItems);
		else
			cargoTypeDict := app.myRoot.allCargoTypesById;
			iter := cargoTypeDict.createIterator;
			cargoTypeDict.startKeyGeq(TI_CargoBOLType_Max, iter);
			
			while iter.next(cargoType) do
				cargoTypeDict.getIteratorKeys(cargoTypeKey, iter);
				//if cargoTypeKey &gt;= TI_CargoBOLType_JMTMax then									// TFS 49252
				if cargoTypeKey &gt;= TI_CargoBOLType_JMTMax or app.myRoot.isClientCentrePort then		// TFS 49252
					break;
				endif;
				self.addObjectsForHaveCargoType(cargoType, breakOut, _numItems);
				
				if breakOut then
					break;
				endif;
			endwhile;
		endif;
	else
		self.addObjectsForHaveCargoType(cargoType, breakOut, _numItems);
	endif;
	
epilog
	delete iter;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addTblAttributeRow" id="9e803af8-bd4a-457c-89dc-63690cfd9f10">
        <source>addTblAttributeRow(_prodAttr : CM_ProductAttr);
// ---------------------------------------------------------------------------
// Created:     03 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
	debugStr,
	str			: String;
	entRow		: EntTableRow;
		
begin

	if _prodAttr = null then
		return;
	endif;
	
	foreach	entRow in self.getTblAttributesDef.allEntTableRows do
		str := str &amp; _prodAttr.getDisplayStringForAttribute(entRow.name, true) &amp; Tab;
	endforeach;
		
	idx := self.tblAttributes.addItem(str);
	self.tblAttributes.accessRow(idx).itemObject := _prodAttr;
	
end;</source>
        <Parameter name="_prodAttr" type="CM_ProductAttr"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="76aee92b-b82b-4f8a-a3d3-1f2d55cf3fbf">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
