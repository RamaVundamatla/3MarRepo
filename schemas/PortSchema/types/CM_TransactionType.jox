    <JadeMethod name="cnEcGetDuplicate" id="480a1c0d-12e4-423b-b7f0-26a6d68527cb">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	trxType : Integer;
	type : CM_TransactionType;

begin

	trxType := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "trxType" ).Integer; 
	
	if trxType &lt;&gt; null then
		type := app.myRoot.allTransactionTypes.getAtKey( trxType );
	endif;

epilog

	return type;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
