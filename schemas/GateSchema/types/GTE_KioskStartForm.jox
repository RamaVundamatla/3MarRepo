    <JadeMethod name="doKeyboardInput" id="ef750ecc-0fe7-4f38-8852-81d577f2e238">
        <updating/>
        <source>doKeyboardInput(_input: String):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	regoNo	: String;
	
begin
	if inheritMethod(_input) then
		return true;
	endif;
	
	regoNo	:=	txtRegoNo.cnEcString() &amp; _input;
	
	if self.validateText(txtRegoNo, regoNo) then
		txtRegoNo.cnEcSet(regoNo);
		self.setDefaultCarrier();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_input" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNext" id="0b8d6499-86a4-4d3a-b5c9-d3328eaac626">
        <updating/>
        <source>doNext() updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 July 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nextFormObj		: GTE_KioskPinEntryForm;
	
begin
	if self.validateForm(false) then
		self.aMyProxyLoad.myCarrier		:=	cmbCarrier.listObject.CM_Carrier;
		
		create nextFormObj;
		nextFormObj.setTerminalRef(self.aMyTerminal);
		nextFormObj.aMyProxyLoad	:=	self.aMyProxyLoad;
		nextFormObj.show();
		self.unloadMe(false);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRestart" id="21afbd08-d22a-4537-a0bd-773f971e14a4">
        <updating/>
        <source>doRestart() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 June 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.doClear();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultCarrier" id="3f4d43c5-b7e6-4ba2-8134-2f86c79db371">
        <source>setDefaultCarrier() protected;
// --------------------------------------------------------------------------------
// Created:		29 September 2006 by cnwdad1
//
// Purpose:		Sets the Carrier combobox to the carrier for the entered vehicle
//				registration number.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	vehicleObj	: CM_Vehicle;
	carrierObj	: CM_Carrier;
	
begin
	vehicleObj	:=	self.aMyTerminal.vehicles[txtRegoNo.cnEcString(), ""];
	
	if vehicleObj &lt;&gt; null then
		carrierObj	:=	vehicleObj.carrier;
		
		if carrierObj &lt;&gt; null then
			cmbCarrier.cnEcSetObjectIndex(carrierObj);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d3f7401c-8a23-4d30-8b4a-420839813a34">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.setBackgroundImage(picImage.picture);
	create self.aMyProxyLoad transient;
	self.aMyProxyLoad.setTerminal(self.aMyTerminal);
	btnEnter.enabled	:=	false;
	btnDone.visible		:=	false;
	btnNext.visible		:=	true;
	txtRegoNo.maxLength	:=	CM_Vehicle::regNumber.length - 1;
	cmbCarrier.listCollection(app.myRoot.allCarriers, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	self.doEnableControls();
	self.centreBackground();
	
	self.caption := "KIOSK"; // JLGAB1JAN20 so it shows in the Task Manager
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="txtRegoNo_lostFocus" id="e315e089-9083-4d81-8be9-37fac8e4305c">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtRegoNo_lostFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 December 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if cmbCarrier.listIndex = CNEC_NULL_INDEX then
		self.setDefaultCarrier();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForm" id="c402b2ee-b379-4193-962c-c62b8cbae6ab">
        <updating/>
        <source>validateForm(_isDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 July 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	
begin
	if self.txtRegoNo.cnEcString() = null then
		errorMessage	:=	"Please enter the Truck Registration number.";
	else
		errorMessage	:=	self.aMyProxyLoad.setVehicle(txtRegoNo.cnEcString());
	endif;
	
	if cmbCarrier.listObject = null then
		if errorMessage = null then
			errorMessage	:=	"Please select the name of the Carrier.";
		else
			errorMessage	:=	errorMessage &amp; CrLf &amp; CrLf &amp; "Please select the name of the Carrier.";
		endif;
	endif;
	
	if errorMessage = null then
		return inheritMethod(_isDelete);
	else
		app.msgBox(errorMessage, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_isDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
