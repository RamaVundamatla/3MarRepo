    <JadeMethod name="mergeBulk" id="a1b29b83-ca11-447b-af6c-e5bd3d45228e">
        <updating/>
        <source>mergeBulk(_control : CMIF_MoveController input;
					   _mergeToCargo : CM_Bulk input) protected, updating;
/*

Date		Who		Reason
31/01/2014	cnwer1	Initial creation PAR
24/02/2017	cnwdap1	TFS 3489 LNX DLR/SOB
23 May 2022 Navds20 ChangeRequest 53504: EUP - Cargo Uniqueness - PortSchema
*/

vars
	moveWeight : Decimal[14,4];
	origLocn 	: CM_LocationsController;
	passport : CM_Passport;
	moveWLE : CM_WorkListEntry;
	storageConfig	: CM_StorageConfig;
begin
	passport:=_control.myPassport;
	
	// PAR 36472
	storageConfig := self.myTerminal.myStorageConfig;
	if storageConfig &lt;&gt; null and storageConfig.includesTriggerType(CargoSplitMerge) then
		self.createStorageTransaction(_control,passport);
		if not passport.noErrors() then
			return;
		endif;
	endif;
	
	moveWeight:=_control.weight;
	
	//if no move controller quantity set then moving the entire amount
	if moveWeight = 0 then
		moveWeight := self.totalWeight;
	endif;
	
	//22 Jun 2015	NDL	Par 36338
	if self.myCargoGroup &lt;&gt; null then
		//self.myCargoGroup.removeAssignedCargo( self, passport );		//23 May 2022 Navds20 TFS 53504
		if self.myCargoType.useCargoGroupForUniqueness then 			//23 May 2022 Navds20 TFS 53504
			self.myCargoGroup.addAssignedCargo( self, passport );		//23 May 2022 Navds20 TFS 53504
		endif;															//23 May 2022 Navds20 TFS 53504
	endif;
	
	//29 Nov 2016	NDL	TFS 3016 / 2549
	self.handleMergeDocActions(	self, _mergeToCargo );
	
	self.mergeSetQVW(_control,_mergeToCargo);
	
	if self.id &lt;&gt; _mergeToCargo.id then
		_mergeToCargo.updateDetailsFromCargoMulti(true,self,true,true,true,true,passport);// ### JIRA 35283 30JUN2025 NAVAB1
	endif;
	
	origLocn:=self.myPrimaryActualLocation;
	moveWLE:=_control.myWorkListEntry;
	
	// this is the 
	if self.totalWeight = 0 then
		self.checkMergeRT(_control);
		//self.mergeNullRefs( _mergeToCargo,moveWLE);						// TFS 3489
		self.mergeNullRefs(_mergeToCargo, moveWLE, _control);				// TFS 3489
		//epr par 33195 16/12/13
		if moveWLE &lt;&gt; null and moveWLE.myRequest &lt;&gt; null and moveWLE.myRequest.isKindOf(CM_DeliveryRequest) then
			moveWLE.myRequest.CM_DeliveryRequest.removeBulkReleaseTI(self);
		endif;
	endif;
		
	//this will make sure all new transactions are on the new cargo merged into
	_control.setMyTrackedItem(_mergeToCargo);
	_control.myOriginalTI := self;	//26 Nov 2020	NDL	TFS 50422
	_control.setMyOriginatingLocation(origLocn);

	
	if  moveWLE &lt;&gt; null  then
		//epr par 35702 CCMS 2457 17/2/15
		if _control.isRTMultiMove and not _control.isRTPickupTask and _control.myRTQueueEntry &lt;&gt; null and _control.myRTQueueEntry.myBreakBulkMaster &lt;&gt; null and
			_control.myRTQueueEntry.myBreakBulkMaster.areAllTasksEqualStatus(TASK_COMPLETE)   then
			self.splitMergeUpdateWLEsTI(moveWLE,_mergeToCargo,_control);
		else
			if moveWLE.weight &gt; moveWeight then //32337
				self.splitMergeCreateNewWLE(_control,moveWLE,_mergeToCargo,true);		
			else
				//move the wle to mergeToCargo
				self.splitMergeUpdateWLEsTI(moveWLE,_mergeToCargo,_control);
			endif;
		endif;
	endif;
	
	self.handleMergeReserveDetail( _mergeToCargo );	//26 Feb 2018	NDL	TFS 37026 - after the weight etc has been updated
	
	self.handleMergeCustomDocDetail(_mergeToCargo, moveWeight); // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1

	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 53105 08JUN2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, self); // ### TFS 53105 08JUN2022 NAVAB1
	endif;
	
epilog
	

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_mergeToCargo" type="CM_Bulk" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mergeIntoDifferentId" id="7e72cc80-a3c6-4501-b153-a8fccc52d98f">
        <updating/>
        <source>mergeIntoDifferentId( _targetTi : CM_Bulk io; _passport : CM_Passport input )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Apr 2014	cnwndl1	Initial creation	CCMS 1366

*/

vars

	cmifMoveController : CMIF_MoveController;

begin

	create cmifMoveController transient;
	cmifMoveController.setMoveMode( REAL_MODE );
	cmifMoveController.setMyToPrimaryLocation( self.myPrimaryActualLocation );
	cmifMoveController.setMyPassport( _passport );
	
	self.mergeBulk(	cmifMoveController,	//_control : CMIF_MoveController input;
					_targetTi	//_mergeToCargo : CM_BreakBulkGeneric input
					);

epilog

	delete cmifMoveController;

end;</source>
        <Parameter name="_targetTi" type="CM_Bulk" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mergeSetQVW" id="4208889e-fcff-4afe-9f8b-91d694bfd5a5">
        <updating/>
        <source>mergeSetQVW(_control: CMIF_MoveController input; _mergeToTI: CM_TrackedItem input) updating, protected;
/*

Date		Who		Reason
12 Ma 2014	cnwer1	Initial creation PAR
3/05/2018   JLGNS1	Bug 38457: DQM - Dry Bulk - ( Gate in and Merge )
05/11/2018	jlgdap1	TFS 41300 PEL1 Unable to load to vessel from truck in Job Lander
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
*/

vars
	moveWeight,
	oldWeight,
	oldMergeWeight,
	adjustedWeight		: Decimal[14,4];
	adjustedVolume,
	oldVolume,
 	oldMergeVolume,
	newVolume			: Decimal[14,4];
	oldCargoWeight  	: Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	oldTareWeight   	: Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	oldMergeCargoWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	oldMergeTareWeight 	: Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	cargoType			: CM_CargoType;

begin
	cargoType  := self.myCargoType;			//05.10.2022 navma1 #52967
	moveWeight := _control.weight;
	
	//if no move controller quantity set then moving the entire amount
	if moveWeight = 0 then
		moveWeight := self.totalWeight;
	endif;

	oldVolume	:= self.totalVolume;
	oldWeight := self.totalWeight;
	if cargoType.useTareCargoWeight then	//Bug 38457
		oldCargoWeight := self.weightCargo;	//18 Jan 2018	NDL	TFS 36697
		oldTareWeight := self.weightTare;	//18 Jan 2018	NDL	TFS 36697
	endif;									//Bug 38457
	
	oldMergeVolume := _mergeToTI.totalVolume;
	oldMergeWeight := _mergeToTI.totalWeight;
	
	if  cargoType.useTareCargoWeight then				//Bug 38457
		oldMergeCargoWeight := _mergeToTI.weightCargo;	//18 Jan 2018	NDL	TFS 36697
		oldMergeTareWeight  := _mergeToTI.weightTare;	//18 Jan 2018	NDL	TFS 36697
	endif;												//Bug 38457
	
	adjustedWeight	 := self.totalWeight - moveWeight;
	
	if  self.getMyTotalVolume &lt;&gt; 0 and self.totalWeight &gt; 0 then
		// apportion weight based on the quantity
		if self.totalWeight = 0 then
			newVolume := moveWeight * self.getMyTotalVolume;						//07 Oct 2013	NDL	Par 32722
		else
			newVolume := ((moveWeight / self.totalWeight) * self.getMyTotalVolume);	//07 Oct 2013	NDL	Par 32722
		endif;
		
		// ### TFS BUG 62748 05MAR2024 NAVAB1 need to set the correct value on all the transactions as the volume and the weight on the transaction can be used in invoicing.
		if _control.volume = 0 then
			_control.setVolume(newVolume);
		endif;
	endif;
	
	adjustedVolume	:= self.getMyTotalVolume - newVolume;
	if adjustedVolume &lt; 0 then 
		adjustedVolume := 0; //07 Oct 2013	NDL	Par 32722
	endif;
	
	if cargoType.isTrackByVolume then						//05.10.2022 navma1 #52967
		if adjustedVolume = 0 then
			moveWeight		:= moveWeight + adjustedWeight;
			adjustedWeight	:= 0;
		endif;
	endif;
	
	_mergeToTI.setMyTotalVolume( _mergeToTI.totalVolume + newVolume);
	_mergeToTI.setTotalWeightWithoutTrans(_mergeToTI.totalWeight +moveWeight);
	
	if cargoType.useTareCargoWeight then										//Bug 38457
		_mergeToTI.setWeightCargo(_mergeToTI.weightCargo + oldCargoWeight );	//18 Jan 2018	NDL	TFS 36697
		_mergeToTI.setWeightTare( _mergeToTI.weightTare  + oldTareWeight );		//18 Jan 2018	NDL	TFS 36697
	endif;																		//Bug 38457
	self.setMyTotalVolume(adjustedVolume);
	self.setTotalWeightWithoutTrans(adjustedWeight);
	
	if _mergeToTI.totalQuantity = 0 then	// TFS 41300
		_mergeToTI.totalQuantity := 1;		// TFS 41300
	endif;									// TFS 41300
	
    //Merge the attachments                                                             //MTN-36700
    self.handleMergeAttachments(_mergeToTI);                                            //MTN-36700
    
	// ### JIRA 35213 27JUN2025 NAVAB1 	self.splitMergeChargesByFactor(oldWeight, oldVolume, moveWeight, newVolume, 1,1, _mergeToTI); // TFS 8275 // ### JIRA 34760 30APR2025 NAVAB1
	if adjustedWeight = 0 then // self is about to become a zombie
		self.mergeChargesByFactor(_mergeToTI); 
	else
		self.splitChargesByFactor(oldWeight, oldVolume, moveWeight, newVolume, 1,1, _mergeToTI);
	endif;

	self.createMergeTransactons(_mergeToTI,
								null,
								oldVolume,
								oldWeight, 
								oldCargoWeight, 
								oldTareWeight,
								null,
								oldMergeVolume, 
								oldMergeWeight, 
								oldMergeCargoWeight, 
								oldMergeTareWeight,
								false, 
								_control,
								_control.myPassport);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_mergeToTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="packageBulk" id="091f44fd-2473-4d63-931c-597c7becc26e">
        <updating/>
        <source>packageBulk(	_breakBulkTi : CM_BreakBulkGeneric input;
				_bbIsNew : Boolean;	//18 Feb 2020	NDL	TFS 48532
				_quantity : Integer;
				_itemNettWeight : Decimal;
				_pkgingWeight : Decimal;
				_passport : CM_Passport input
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/04/2014	cnwndl1	Initial creation
24/02/2017	cnwdap1	TFS 3489 LNX DLR/SOB
*/

vars

	oldQuantity : Integer;
	oldVolume : Decimal [16,4];
	oldWeight : Decimal [16,4]; 
	oldCargoWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	oldTareWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	newWeight : Decimal [16,4];
	newVolume : Decimal [16,4];
	grossWeight : Decimal [16,4]; 
	preMergeQuantity : Integer; 
	preMergeVolume : Real; 
	preMergeWeight : Decimal  [16,4];
	preMergeCargoWeight : Decimal[14,4];	//26 Jan 2018	NDL	TFS 36697
	preMergeTareWeight : Decimal[14,4];	//26 Jan 2018	NDL	TFS 36697
	

begin

	oldQuantity := 1; 
	oldVolume:= self.totalVolume; 
	oldWeight := self.totalWeight; 
	oldCargoWeight := self.weightCargo;	//18 Jan 2018	NDL	TFS 36697
	oldTareWeight := self.weightTare;	//18 Jan 2018	NDL	TFS 36697

	if ( _itemNettWeight * _quantity ) &gt;= self.totalWeight then
		newWeight := 0;
	else
		newWeight := self.totalWeight -( _itemNettWeight * _quantity );
	endif;
	self.setTotalWeightWithoutTrans( newWeight );
	
	if self.isBulkByVolume then
	
		if newWeight &lt;= 0 then
			newVolume := 0;
		else
			newVolume :=  newWeight / self.getDensity;
		endif;
		
		self.setMyTotalVolume( newVolume );
		
	endif;

	grossWeight := _itemNettWeight + _pkgingWeight;
	_breakBulkTi.packageBulk( self, _quantity, grossWeight, _itemNettWeight, _pkgingWeight, _passport, preMergeQuantity, preMergeVolume, preMergeWeight, preMergeCargoWeight, preMergeTareWeight, _bbIsNew );
	
	self.createSplitTransactions( 	_breakBulkTi, oldQuantity,
									oldVolume, oldWeight, oldCargoWeight, oldTareWeight,
									true, preMergeQuantity,
									preMergeVolume, preMergeWeight, preMergeCargoWeight, preMergeTareWeight, null,
									_passport);

	if newWeight = 0 then
		//self.mergeNullRefs( null,null );					// TFS 3489
		self.mergeNullRefs( null,null,null );				// TFS 3489
	endif;
	
epilog

end;</source>
        <Parameter name="_breakBulkTi" type="CM_BreakBulkGeneric" usage="input"/>
        <Parameter name="_bbIsNew" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_itemNettWeight" type="Decimal"/>
        <Parameter name="_pkgingWeight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDensity" id="9ea7b875-8753-472a-8d1d-b1e9c6233ca2">
        <updating/>
        <source>setDensity(_density: Decimal) updating, protected;
/*

Date		Who		Reason
21 April 2015	cnwer1	Initial creation PAR

*/

vars
	densityChangedForBulk : Boolean;
begin
	
	if self.isBulkByVolume then
		densityChangedForBulk:=self.density &lt;&gt; _density;
	endif;
	
	inheritMethod(_density);
		
	if densityChangedForBulk then
		self.totalVolume:=self.totalWeight/self.density;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_density" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setDimensions" id="7bbda626-6ead-4b98-8c43-d372bfe4aa31">
        <updating/>
        <source>setDimensions(_diameter: Decimal; _height: Decimal; _volume: Decimal; _rollingLength: Decimal; _length: Decimal; _grammage: Decimal; _width: Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars

begin
	self.volume := _volume;
epilog

end;</source>
        <Parameter name="_diameter" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_rollingLength" type="Decimal"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_grammage" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="be5879e8-a9e6-46af-8b89-c33f7e158332">
        <updating/>
        <source>setForCreate(_ti: CM_TrackedItem; _passport: CM_Passport input) updating;
//
// Created by cnwdvb1 on 09 November 2006
// Changed On	By			Reason
// ----------	--------	-------------------------------------------
// 16/04/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - totoal quantity for bulk should always be 1
vars

begin

	if self.cargoType &lt;&gt; _ti.cargoType then
		self.cargoType := _ti.cargoType;
	endif;
	
	inheritMethod(_ti, _passport);
	
	if self.myCargoType.isBulkMulti then			// PAR #33606
		self.totalQuantity := 1;					// PAR #33606
	endif;											// PAR #33606

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMoveControllerAmount" id="16acbeb2-fc0f-40ca-b1ee-ec85bc70a88a">
        <updating/>
        <source>setMoveControllerAmount(_control: CMIF_MoveController input) updating, protected;
/*
Purpose: Ensure that a 	the controller is set with the weight to move so that trns are created with correct weight. 
         The move controller can just have 0, which implies move all the cargo
		 PAR 35945
*/
vars

begin
	if _control.moveMode = REAL_MODE and self.myCargoType.isBulkMulti  then
		if _control.weight = 0 then  // PAR 35945
			_control.setWeight( self.totalWeight); //epr TFS 8220 6/12/17 
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyLocations" id="9497bec4-f53f-4f6d-8861-b824988e7b3c">
        <updating/>
        <source>setMyLocations(control: CMIF_MoveController input) updating, protected;
/*

Date			Who		Reason
31 January 2014	cnwer1	Initial creation PAR
24 Nov   2015   cnwma1  PAR #36930 Release Train is missing when releasing break-bulk (rebar)
18 April 2016	cnwdap1	TFS #1843 Allow an error margin when comparing weights
07 Dec 2017		cnwer1	TFS 8220 using setWeight 
12 Apr 2019		jlgzm1	TFS 44213 remaining weight less than unit precision
15 Oct 2021		navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
17 May 2022     navds20 TFS 53504 EUP - Cargo Uniqueness - PortSchema
02 May 2023		jlizm1	TFS 55453 Cargo uniqueness by subtype
06 Aug 2025 	navlw1	JIRA:35087: POB - Receive and Release Stevedore not coming through to the cargo from Voyage stevedore for non-container cargo
	
*/

vars
	targetBulkCargo : CM_Bulk;
	lc 				: CM_LocationsController;
	amount,
	totalAmount,
	amountType 	    : String;
	childTI 		: CM_TrackedItem;
	wle 			: CM_WorkListEntry;
	diff 			: Real;								// TFS #1843
	weightToUse 	: Real;								// TFS #1843
	dirRelLocn 		: CM_LocationsController;			//07 Jun 2018	NDL:	TFS 38897
	matches 		: Integer;
	cargoType		: CM_CargoType;
	stevedore 		: CM_Stevedore;
begin
	
	cargoType := self.myCargoType;										//05.10.2022 navma1 #52967
	if control.moveMode = REAL_MODE and cargoType.isBulkMulti  then		//05.10.2022 navma1 #52967
		
		//if going to same place return do nothing
		if self.allLocations.isSameArrayContents(control.allToLocations) 
		and not control.isForcedMove then // PAR 18682
			return;
		endif;
		
		diff := control.weight - self.totalWeight;						// TFS #1843
		if diff.abs &lt;= Measure_AllowableDifference then					// TFS #1843
			weightToUse := self.totalWeight;							// TFS #1843
			control.setWeight( weightToUse);							// TFS #1843
		endif;															// TFS #1843
		
		if control.weight &lt;&gt; 0 and control.weight &gt; self.totalWeight then
			//tfs44213
			//if the difference is smaller than the unit's precision, use all
			if cargoType.isTrackByWeight and 
			diff &lt; cargoType.myWeightMeasurementType.getMinimumValue then 
				weightToUse := self.totalWeight;
				
				//if there is a wle, need to update that too otherwise it will not complete
				wle := control.myWorkListEntry;
				if wle &lt;&gt; null and wle.weight = control.weight then
					wle.setWeight(weightToUse);
				endif;
				control.setWeight( weightToUse);
			else
				//raise exception 
				amount		:= cargoType.getBulkTrackByDisplayForWeight(control.weight, self.getDensity,true);
				totalAmount := cargoType.getBulkTrackByDisplayForWeight(self.totalWeight, self.getDensity,true);
				if self.isBulkByWeight then
					amountType:=app.getErrorString(CM_Total_Weight);
				elseif self.isBulkByVolume then
					amountType:=app.getErrorString(CM_Total_Volume);
				endif;
				app.raiseCMException3(Move_amount_gtr_cargo,amount,amountType,totalAmount , null,null);
				return;
			endif;
		endif;
		
		//06/08/2025 navlw1 JIRA:35087
		if control.isCreateCargoOnVoyage then
			//apparently when creating cargo on a voyage, we have to automagicly select and populate 'the' receive stevedore.
			if self.stevedoreCodeRecieve = null then
				stevedore := self.getStevedore;
				if stevedore &lt;&gt; null then
					self.setStevedoreCodeRecieve( stevedore.code );
				endif;
			endif;
		elseif control.isRealMoveToVoyagePosition then
			//and when moving existing cargo to a voyage location, we have to automagicly select and populate 'the' release stevedore.
			if self.stevedoreCodeRelease = null then
				stevedore := self.getStevedore;
				if stevedore &lt;&gt; null then
					self.setStevedoreCodeRelease( stevedore.code );
				endif;
			endif;
		endif;
		
		// figure out what to do if moved offsite  if control.isWagonMovingOffSite then	
		
		//same as to setMyLocations just display stuff for now
		foreach lc in self.allLocations do
			//-------------------
			// Update the last move date/time on the from lc
			//-------------------
			lc.setLastMoveOutDateTime(app.serverTimestampAtTrxStart);
			//-------------------
			// Call any specific cleanup methods on the source location if needed
			//-------------------
			lc.executePreMoveFromLocation(control);
			
			// do this here so all previous locations receive event
			control.doUpdateDisplayEvent(lc);
		endforeach;
		
		//first check if there is cargo in target location with same id and cargo type
		if control.myToPrimaryLocation &lt;&gt; null then
			//	targetBulkCargo:=control.myToPrimaryLocation.allTrackedItemsById[self.id,self.myCargoType.id].CM_Bulk;
		
			//epr 14/3/17 this method makes sure we don't find cargo that is merged which if there was a bug in past could cause potential problems
			targetBulkCargo := control.myToPrimaryLocation.searchForOnsiteTI(self.id,matches,cargoType.id,self.getMyCargoGroupId(),self.getCargoSubTypeCode(), self.operatorCode).CM_Bulk; //17/05/2022 navds20  TFS 53504 //03.Nov.2023 navsp TFS 61067
		else
			if control.myPackToTI &lt;&gt; null then
				foreach childTI in control.myPackToTI.allChildren discreteLock do 
					if childTI.id = self.id and childTI.myCargoType = cargoType then
						targetBulkCargo:=childTI.CM_Bulk;
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		if targetBulkCargo = null then
			// figure out what to do if moved offsite  if control.isWagonMovingOffSite then	      // 24/11/2015 cnwma1 PAR #36930
			if control.isWagonMovingOffSite then												  // 24/11/2015 cnwma1 PAR #36930
				//This is a tracked item on a wagon moving off-site
				// Retain the location controller of the wagon.	
				self.setLocationId(null);
				return;
			endif;
			//if (control.weight = 0 or self.totalWeight = control.weight) then											// TFS 51935
			if (control.weight = 0 or self.totalWeight = control.weight) and control.directExcessWeight = null then		// TFS 51935
				
				//20 May 2015	NDL	Par 36127
				wle := control.myWorkListEntry;
				if wle &lt;&gt; null and wle.weight &gt; self.totalWeight then
					// we have a pile of and no split required but the wle is for for than the ti weight,
					// need to create a new wle for this one and complete it and lower the requrired
					// weight on the existing one)
					self.splitWleCreateNewWLE( control, wle );
				elseif wle &lt;&gt; null then // TFS 3190 
					// TFS 3190 - Assign release to a hold. Now it is complete, unplan the TBA so it can be deleted.
					if wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isTBAorIsRRP then
						if wle.myRequest.isHoldRequest() and wle.myRequest.CM_HoldRequest.myBulkReleaseReserveDetail &lt;&gt; null then 
							wle.setMyTrackedItem(self);
						endif;
					endif;
				endif;
				
				//move the entire TI 
				self.allLocations.clear();
		
				//Always update the primary location property
				self.refreshMyFutureLocations(control.moveMode,null);

				self.setLocationString(control);
				
				//07 Jun 2018	NDL:	TFS 38897
				if control.myDirectReleaseArea &lt;&gt; null then
					dirRelLocn := control.myDirectReleaseArea.CM_BlockStack.myLocationsController;
					if control.allToLocations.includes( dirRelLocn ) then
						control.allToLocations.remove( dirRelLocn );
					endif;
				endif;
				
				if control.allToLocations &lt;&gt; null and not  control.allToLocations.size = 0 then
					control.allToLocations.copy(self.allLocations);
				
					self.refreshMyFutureLocations(control.moveMode,null);
					
					self.setLocationString(control);
				endif;
				
				self.directDeliveryAdjustPreNoteWLE(control, control.myWorkListEntry, control.myDDWorkListEntry);	// TFS 51935
				
			elseif control.directExcessWeight &lt;&gt; null then															// TFS 51935
				// need to split TI and WLE, move both TIs, complete both WLEs, and adjust prenote planning			// TFS 51935
				self.splitBulkOrBreakBulkAndWLE(control);															// TFS 51935
			else
				//need to split - 
				self.splitBulk(control,null);
						
			endif;
			
		else
			if control.directExcessWeight &lt;&gt; null then																// TFS 51935
				// need to split TI and WLE, move both TIs, complete both WLEs, and adjust prenote planning			// TFS 51935
				self.splitBulkOrBreakBulkAndWLE(control);															// TFS 51935
			else																									// TFS 51935
				self.mergeBulk(control,targetBulkCargo);
			endif;																									// TFS 51935
		endif;
		
		
	else	
		inheritMethod(control);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="splitBulk" id="9a4ccbdd-037b-420e-b5e8-9ab874f7204b">
        <updating/>
        <source>splitBulk(_control : CMIF_MoveController input; _newIdForSplit : String ):CM_Bulk protected, updating;
/*

Date		Who		Reason
31 Jan 2014	cnwer1	Initial creation PAR
18 Apr 2016	cnwdap1	TFS #1843 Allow for differences in calculated converted weights
28 Jul 2020	jlgdap1	TFS 49851 ASPA Satellite View Graphical Display
15 Nov 2021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
*/

vars
	passport : CM_Passport;
	cloneId : String;
	moveControl : CMIF_MoveController;
	newTI : CM_Bulk;	
	newState : Integer;
	moveWLE : CM_WorkListEntry;
	bulkRelease : CM_BulkRelease;
	trans : CM_TITransaction;
	storageConfig	: CM_StorageConfig;	
	diff : Real;									// TFS #1843
begin
	//update self quanity less the move quantity
	passport:=_control.myPassport;
	
	// PAR 36472
	storageConfig := self.myTerminal.myStorageConfig;
	if storageConfig &lt;&gt; null and storageConfig.includesTriggerType(CargoSplitMerge) then
		self.createStorageTransaction(_control,passport);
		if not passport.noErrors() then
			return null;
		endif;
	endif;
	
	if _newIdForSplit &lt;&gt; null then
		cloneId := _newIdForSplit;
	else
		cloneId := self.id;
	endif;
	
	if _control.myToPrimaryLocation &lt;&gt; null then
		create moveControl transient;
		moveControl.setMyPassport(passport);	//19 Aug 2013	NDL	Par 32175
		if _control.myToPrimaryLocation.isKindOf(CM_GeneralCargoAllocController) then	// TFS 49851
			_control.myToSecondaryLocations.copy(moveControl.myToSecondaryLocations);	// TFS 49851
		endif;																			// TFS 49851
	endif;
	//create new ti from old
	newTI:=	self.cloneMe(cloneId, self.state, moveControl, false, true, true, false, _control.myToPrimaryLocation, self.myVoyage, passport).CM_Bulk;
	newTI.setMasterTI(self);
	newState := newTI.calculateState(REAL_MODE);
	//29 May 2018	NDL	 TFS 38897
	if _control.myDirectReleaseArea &lt;&gt; null and newState = TI_STATE_UNDEFINED then
		newState := TI_STATE_OFFSITE;
	endif;
	newTI.changeState(newState, passport);
	
	if newTI = null then
		app.raiseCMException1(Err_Unexpected_Program_Error,"split cargo not created",null,null);
		return null;
	endif;
	
	self.splitSetQVW(_control,newTI);
	
	// Need to copy the last storage/received tx to prior trans so correct storage can be calculated on split cargo
	trans := self.allTransactions.findLastStorageRelevantTrans();
	// TFS 7548 splittable cargo carries forward the received transaction from the 'original' cargo item, 
	// TFS 7548 this is done by using the allPriorTransactions collection
	// TFS 7548 however this was not happending in here by looking at the allPriorTransactions
	if trans = null then // TFS 7548
		trans := self.allPriorTransactions.findLastStorageRelevantTrans(); // TFS 7548
	endif;
	if trans &lt;&gt; null then
		newTI.allPriorTransactions.add(trans);
	endif;
	
	//22 Jun 2015	NDL	Par 36338
	if self.myCargoGroup &lt;&gt; null then
		self.myCargoGroup.addAssignedCargo(newTI,passport);
	endif;
	//epr TFS 43404 14/2/19
	moveWLE:=_control.myWorkListEntry;
	if moveWLE &lt;&gt; null and moveWLE.myRequest &lt;&gt; null then
		bulkRelease:= moveWLE.myRequest.myOriginatingBulkRelease;
	endif;
	//29 Nov 2016	NDL	TFS 3016 / 2549
	self.handleSplitDocActions(	self, newTI );
	self.handleSplitReserveDetail( newTI,bulkRelease );	//22 Feb 2018	NDL	TFS 37026
		
	//epr par 32474 12/9/13 when create the new cargo needs the same stops as the cargo it was split from
	if self.id = newTI.id then
		newTI.updateDetailsFromCargoMulti(false,self,true,true,true,true,passport); // ### JIRA 35283 30JUN2025 NAVAB1
	endif;
	
	_control.setMyTrackedItem(newTI);
	_control.myOriginalTI := self;	//26 Nov 2020	NDL	TFS 50422
	_control.setMyOriginatingLocation(self.myPrimaryActualLocation);
	

	if  moveWLE &lt;&gt; null  then
		if moveWLE.job.isKindOf(CM_RoadJob) and moveWLE.myRequest.isReleaseType then //need to remove the original TI from the release collection as we arnt releasing it
			if moveWLE.job.CM_RoadJob.myVehicleVisit &lt;&gt; null then			
				if moveWLE.job.CM_RoadJob.allReleaseTrackedItems.includes(self) then
					moveWLE.job.CM_RoadJob.allReleaseTrackedItems.remove(self);
				endif;
				if moveWLE.job.CM_RoadJob.myVehicleVisit.allReleasedTrackedItems.includes(self) then					
					moveWLE.job.CM_RoadJob.myVehicleVisit.allReleasedTrackedItems.remove(self);					
				endif;
			endif;			
		elseif moveWLE.job.isKindOf(CM_RailJob) and moveWLE.myRequest.isReleaseType then	//04 Dec 2020	NDL	TFS 50031
			if moveWLE.job.CM_RailJob.allReleaseTrackedItems.includes(self) then
				moveWLE.job.CM_RailJob.allReleaseTrackedItems.remove(self);
			endif;
		endif;
		
		//epr par 33195 16/12/13 
		if moveWLE.myRequest &lt;&gt; null and moveWLE.myRequest.isKindOf(CM_DeliveryRequest) then
		//	bulkRelease:= moveWLE.myRequest.myOriginatingBulkRelease;	//13 Mar 2018	NDL	TFS 37408
		//	if bulkRelease &lt;&gt; null then	//08 Apr 2015	NDL	Par 36008
		//		self.allBulkReleasesAssigned.removeIfPresent(bulkRelease);
				moveWLE.myRequest.CM_DeliveryRequest.setBulkReleaseTI(newTI);
		//		bulkRelease.addTIAssigned(newTI,null);
		//	endif;
		endif;
		
		//epr par 35702 CCMS 2457 17/2/15
		if _control.isRTMultiMove and not _control.isRTPickupTask and _control.myRTQueueEntry &lt;&gt; null and _control.myRTQueueEntry.myBreakBulkMaster &lt;&gt; null and
			_control.myRTQueueEntry.myBreakBulkMaster.areAllTasksEqualStatus(TASK_COMPLETE)   then
				self.splitMergeUpdateWLEsTI(moveWLE,newTI,_control);
		else
			//split create new wle future planned move and future queued move
			diff := moveWLE.weight - newTI.totalWeight;									// TFS #1843
			//if diff.abs &gt; Measure_AllowableDifference then								// TFS #1843
			if ( diff.abs &gt; Measure_AllowableDifference ) and ( diff &gt; 0 ) then		//29 Oct 2018	NDL	TFS 41572
			//if moveWLE.weight - newTI.totalWeight &gt; 0 then							// TFS #1843
				if moveWLE.isAnyAmount then	//14 Mar 2017	NDL	TFS 37408	
					self.splitMergeUpdateWLEsTI(moveWLE,newTI,_control);
				else
					self.splitMergeCreateNewWLE(_control,moveWLE,newTI,true);
				endif;
			else
				self.splitMergeUpdateWLEsTI(moveWLE,newTI,_control);
			endif;
		endif;
	endif;
	
	//epr the cloneMe should already move it not sure why we do it twice
	//newTI.setMyLocations(_control);	
	newTI.refreshMyFutureLocations(_control.moveMode, null);
	newTI.setLocationString(_control);
	
	//epr par 33948 28/5/14 if moving to a voyage has to update the voyage  to where it is
	if newTI.myPrimaryActualLocation &lt;&gt; null and newTI.myPrimaryActualLocation.isKindOf(CM_VoyageController) then
		if newTI.myVoyage &lt;&gt; newTI.myPrimaryActualLocation.CM_VoyageController.myVoyage then
			newTI.setMyVoyage(newTI.myPrimaryActualLocation.CM_VoyageController.myVoyage,passport);
		endif;
		// TFS 52360 if DDWLE on the move controller is tied to a voyage hold job,
		// make sure TI is added to the job's released TIs
		if _control.myDDWorkListEntry &lt;&gt; null and _control.myDDWorkListEntry.job.isVoyageHoldJob then
			_control.myDDWorkListEntry.job.CM_VoyageHoldJob.allReleaseTrackeditems.addNoDuplicates(newTI, false);
		endif;
		// TFS 52360 end
	endif;

	if _control.myDirectReleaseArea &lt;&gt; null and newState = TI_STATE_OFFSITE then // ### TFS 51936 07SEP2021 NAVAB1
		newTI.releaseFromTransferArea(newTI.consignee,self.getBulkReleaseAssignedCode(),DEL_SNT, app.myPassport,false); // ### TFS 51936 07SEP2021 NAVAB1
	endif;
	
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 53105 08JUN2022 NAVAB1
		newTI.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, newTI); // ### TFS 53105 08JUN2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, self); // ### TFS 53105 08JUN2022 NAVAB1

	endif;
	
	return newTI;
	
epilog
	delete moveControl;

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_newIdForSplit" type="String"/>
        <ReturnType type="CM_Bulk"/>
    </JadeMethod>
    <JadeMethod name="splitSetQVW" id="e19d6e09-5b91-4c20-9dab-d5a6a526a4ca">
        <updating/>
        <source>splitSetQVW(_control: CMIF_MoveController input; 
_newTI: CM_TrackedItem input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
11/03/2014	cnwer1				Initial creation PAR
26/03/2018 	jlgrh7 	TFS37768 	PKT - Discrepancy in export cargo
28/03/2019	jlgka1	TFS 42980	PKT - Modify to trapped Division by Zero.
============================================================================*/

vars
	oldWeight,adjustedWeight	,	
	oldVolume,newVolume,adjustedVolume, moveWeight			:  Decimal[14,4];
	tiUpdateCntrlr 	: CMIF_TIUpdateController;
	oldCargoWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	oldTareWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	newCargoWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	newTareWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	adjustedCargoWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	adjustedTareWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	noAutoTareWeight  : Decimal[14,4];							//RocH Notes
begin
	moveWeight:=_control.weight; // TFS 8275
	
	oldVolume	:= self.totalVolume;
	oldWeight := self.totalWeight;
	oldCargoWeight := self.weightCargo;	//18 Jan 2018	NDL	TFS 36697
	oldTareWeight := self.weightTare;	//18 Jan 2018	NDL	TFS 36697
	
	adjustedWeight	 := self.totalWeight - _control.weight;
	if adjustedWeight &lt; 0 then
		app.raiseCMException(Remai_weigh_will_less_than_zer, null, null);
		return;		
	endif;
	
	if self.myCargoType.isTrackByWeight then
		//handle volume by setting as a ratio
		// Handle the volume
		if  self.getMyTotalVolume &lt;&gt; 0 and self.totalWeight &gt; 0 then
			// apportion weight based on the quantity
			if self.totalWeight = 0 then
				newVolume := ((_control.weight) * self.getMyTotalVolume);	//07 Oct 2013	NDL	Par 32722
			else
				newVolume := ((_control.weight / self.totalWeight) * self.getMyTotalVolume);	//07 Oct 2013	NDL	Par 32722
			endif;
		endif;
		
		adjustedVolume	:= self.getMyTotalVolume - newVolume;
		if adjustedVolume &lt; 0 then 
			adjustedVolume := 0; //07 Oct 2013	NDL	Par 32722
		endif;
	else
		
		//must have a density so 
		if self.getDensity &lt;&gt; 0 then // jlgka1 TFS 42980
			adjustedVolume	:= adjustedWeight / self.getDensity;
			newVolume		:= _control.weight / self.getDensity;
		else// jlgka1 TFS 42980 --&gt;	
			adjustedVolume	:= adjustedWeight;
			newVolume		:= _control.weight;
		endif;// jlgka1 TFS 42980 &lt;--
		if adjustedVolume = 0 then
			adjustedWeight:= 0;
		endif;	
	endif;
	
	
	//for rounding errors;
	if adjustedWeight = 0 then
		adjustedVolume :=0;
	endif;
	
	//29 Jan 2018	 NDL TFS 36697
	if self.usesAutoWeightCalculate then
		if self.weightCargo &lt;&gt; 0 and self.totalWeight &gt; 0 and moveWeight &gt; 0 then	
			newCargoWeight := ((moveWeight / self.totalWeight) * self.weightCargo);		
		endif;
		adjustedCargoWeight := self.weightCargo - newCargoWeight;
		
		if self.weightTare &lt;&gt; 0 and self.totalWeight &gt; 0 and moveWeight &gt; 0 then		
			newTareWeight := ((moveWeight / self.totalWeight) * self.weightTare);		
		endif;
		adjustedTareWeight := self.weightTare - newTareWeight;
	endif;

	
	if _newTI &lt;&gt; null then
	
		self.setTotalWeightWithoutTrans(adjustedWeight);
		self.setMyTotalVolume(adjustedVolume);
		//29 Jan 2018	 NDL TFS 36697
		if self.usesAutoWeightCalculate then
			self.setWeightCargo(  adjustedCargoWeight );	//18 Jan 2018	NDL	TFS 36697
			self.setWeightTare(  adjustedTareWeight );	//18 Jan 2018	NDL	TFS 36697
		elseif self.myCargoType.useTareCargoWeight then
			//28 Mar 2018	NDL	TFS 37621
			if oldCargoWeight &gt;= moveWeight then
				// no change to Tare Weight, just reduce cargo weight
				self.setWeightCargo(  oldCargoWeight - moveWeight  );
			elseif moveWeight &lt;= oldWeight then
				//no cargo weight left, tare must be the same as totalweight
				self.setWeightCargo( 0 );
				self.setWeightTare(  adjustedWeight );
			else
				//must be none left
				self.setWeightCargo( 0 );
				self.setWeightTare( 0 );
			endif;
		endif;
		
		_newTI.setTotalWeightWithoutTrans(_control.weight);
		_newTI.setMyTotalVolume(newVolume);
		//29 Jan 2018	 NDL TFS 36697
		if _newTI.usesAutoWeightCalculate then
			_newTI.setWeightCargo( newCargoWeight );	//18 Jan 2018	NDL	TFS 36697
			_newTI.setWeightTare( newTareWeight );	//18 Jan 2018	NDL	TFS 36697
		elseif self.myCargoType.useTareCargoWeight then	//28 Mar 2018	NDL	TFS 37621														//+TFS37768
			_newTI.setWeightCargo(  moveWeight  );	
			_newTI.setWeightTare(  0 );	
		endif;
		
        //Merge the attachments                                                             //MTN-36700
        self.handleMergeAttachments(_newTI);                                                //MTN-36700
        
		//epr 30/1/14 refactored out to method on CM_TrackedItem so can be used for bulk split
		self.createSplitTransactions(	_newTI, null,
										oldVolume, oldWeight, oldCargoWeight, oldTareWeight,
										false,
										0, 0, 0, 0, 0, _control,
										_control.myPassport);

		// TFS 1990
 // TFS 7311		self.splitCharges(oldWeight, oldVolume, self.totalWeight, newVolume, _newTI);
// TFS 8275	self.splitMergeChargesByFactor(oldWeight, oldVolume, self.totalWeight, newVolume, _newTI); // TFS 7311
		self.splitChargesByFactor(oldWeight, oldVolume, moveWeight, newVolume, 1,1,_newTI); // TFS 8275 // ### JIRA 34760 30APR2025 NAVAB1 JIRA 35213 renamed from splitMergeChargesByFactor
	else
		tiUpdateCntrlr := app.createTIUpdateControl( TI_UPDMODE_NORMAL, app.myPassport.userCode, null );
		self.beginUpdate(tiUpdateCntrlr, _control.myPassport);
		self.setTotalWeightWithoutTrans(adjustedWeight);
		self.setMyTotalVolume(adjustedVolume);
		//29 Jan 2018	 NDL TFS 36697
		if self.usesAutoWeightCalculate then
			self.setWeightCargo(  adjustedCargoWeight );	//18 Jan 2018	NDL	TFS 36697
			self.setWeightTare(  adjustedTareWeight );	//18 Jan 2018	NDL	TFS 36697
		endif;
		self.endUpdate(tiUpdateCntrlr, _control.myPassport);
	endif;
epilog
	delete tiUpdateCntrlr;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_newTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDefault" id="b3d29f62-61e4-43d9-9227-fba49d9ab231">
        <updating/>
        <source>validateForDefault(pControl: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;

// Created by cnwdvb1 on 09 November 2006
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------------------------
// 17/04/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
vars
	cType	: CM_CargoType;					// PAR #33606

begin

	if pControl.mode = TI_UPDMODE_NORMAL or
	   pControl.mode = TI_UPDMODE_RECEIPT then
		// Now do the checks which are dependent on the earlier checks
		self.validateCargoType(pControl);
		cType := app.myRoot.allCargoTypesById[self.cargoType];					// PAR #33606
		if cType.isSubCargoTypeRequired and self.myProduct = null then			// PAR #33606
		//if self.myProduct = null then											// PAR #33606
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Product), ETRow_MyProduct, pControl.myUserObject);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Product), ETRow_MyProduct, pControl.myUserObject); // cnwdb2	PAR 35364
			return;
		endif;
		
		//self.validateId(pControl);
//		self.validateImExStatus(pControl);
		//self.validateStatus(pControl);
		//self.validateOperator(pControl, _passport);
		//self.validateCommodity(pControl);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateReceiptRelease" id="c25032a2-58e1-44ff-b857-8a8d2c866ebd">
        <updating/>
        <source>validateReceiptRelease(pControl: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2014	cnwma1	Initial creation

*/

vars

begin
	validateTotalVolume(pControl);
	inheritMethod(pControl, _passport);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateTotalVolume" id="7810b9b0-2579-4cf4-be95-68dd84abd44a">
        <updating/>
        <source>validateTotalVolume(pControl: CMIF_TIUpdateController) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2014	cnwma1	Initial creation
PAR #35338 Not selecting a Volume measurement can cause 1090 errors
*/

vars
	cType	: CM_CargoType;		
begin
	
	if pControl.mode = TI_UPDMODE_NORMAL or
	   pControl.mode = TI_UPDMODE_RECEIPT then
		// Now do the checks which are dependent on the earlier checks

		cType := app.myRoot.allCargoTypesById[self.cargoType];
		if self.totalVolume = NULL_VOLUME and 
		   (not self.isMachinery)  then
			 if cType.isTrackByVolume then 
			//	app.raiseCMException1(REQUIRED_FIELD, 'volume', 'volume', pControl.myUserObject);
				app.raiseCMException(Input_required_field_volume, 'volume', pControl.myUserObject); // cnwdb2	PAR 35364
				return;
			 endif;
					
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateTotalWeight" id="865262a7-491a-49ce-86e1-b860b4c0d489">
        <updating/>
        <source>validateTotalWeight(pControl: CMIF_TIUpdateController) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2014	cnwma1	Initial creation 
PAR #35338 Not selecting a Volume measurement can cause 1090 errors
 15/12/2014  cnwdb2	PAR 35364
*/

vars
			
begin
	
	if pControl.mode = TI_UPDMODE_NORMAL or
	   pControl.mode = TI_UPDMODE_RECEIPT then
		// Now do the checks which are dependent on the earlier checks

		if self.totalWeight = NULL_WEIGHT  then
			if self.myCargoType.isTrackByWeight then
				//	app.raiseCMException1(REQUIRED_FIELD, 'weight', 'weight', pControl.myUserObject);
					app.raiseCMException(Input_required_field_weight, 'weight', pControl.myUserObject); // cnwdb2	PAR 35364
					return;
			endif;
		endif;
	endif;

	inheritMethod(pControl);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateWeight" id="f769139f-bf48-4001-8a99-8580ce702e1e">
        <updating/>
        <source>validateWeight(pControl: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;
/*

Date		Who		Reason
12 Mar 2015	cnwer1	Initial creation PAR 35851
12 Apr 2023	navkc1	CR 56431 Task 56438: UI - Cargo Enquiry
29 Apr 2024  navma1	Bug 63868: MTN - 1081 from performance test QA-PerformanceTest-Dumps_20240424
*/

vars

	weightMeasType		 : CM_MeasurementType;
	derivedDisplayWeight : Decimal [23,10];
	cargoType			 : CM_CargoType;

begin
	if pControl.mode = TI_UPDMODE_NORMAL or
	   pControl.mode = TI_UPDMODE_RECEIPT then
		// Now do the checks which are dependent on the earlier checks

		if self.totalWeight = NULL_WEIGHT  then
			
			cargoType := self.myCargoType;														//30.04.2024 navma1 #63868
			
			if cargoType.isTrackByWeight then
				//12/04/2023	navkc1	CR 56431 Task 56438
				if self.isPersistentTiWeightZero() and self.isZeroedByDiscrTrans()   then
					// Good to proceed;
				else
					app.raiseCMException(Total_weight_should_not_zero, app.getString(Total_weight), pControl.myUserObject); // cnwdb2	PAR 35364
					return;
				endif;
			//02 Aug 2017	NDL	TFS 
			elseif cargoType.isTrackByVolume and self.totalVolume &lt;&gt; NULL_VOLUME then
				// has this occurred because the density is set too low and/or the display has rounded to zero..
				weightMeasType 		 := cargoType.getMeasurementTypeFor(Type_Weight, true);
				derivedDisplayWeight := (( self.totalVolume * self.getDensity ) / weightMeasType.conversionRate ).roundedTo(10);
				
				if derivedDisplayWeight &gt; 0 then
					if derivedDisplayWeight.roundedTo(weightMeasType.getDecimalPrecision) = 0 then
						//Yep its truncated/ rounded down to zero
						app.raiseCMWarning( Weigh_deriv_from_densi_volum_s, 'weight', pControl.myUserObject, self );
					endif;
				endif;
				
			endif;
		endif;
	endif;
	inheritMethod(pControl, _passport);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
