Date		Who		Reason
09DEC2022	NAVAB1	TFS CR 55623 TASK 55677
*/
vars
	debtor : CM_Debtor;
	contractRate : CM_InvoiceContractRate;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCreateInvContractDtlRtEntry(_pxyObject);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject);
	
	// ### TFS BUG 64886 14AUG2024 NAVAB1
	if _passport.noErrors then
		contractRate := _realObject.myInvoiceContractRate;
		debtor := contractRate.getDebtor();
		contractRate.updateCharges(debtor);
	endif;

	if _passport.noErrors then
		// only required if the class is audited
		self.myCreateAuditAgent.audCreateGeneric(_realObject);
		app.myEventManager.createSingleObjInfoNoteEvt(_realObject.myInvoiceContractRate,app.myPassport.myTerminal.getTerminalEvent(Event_InvContractRateEntCreate),_realObject);	//02-02-2023 navtnr20 TFS CR 55646 TASK 55664
	endif;

end;</source>
