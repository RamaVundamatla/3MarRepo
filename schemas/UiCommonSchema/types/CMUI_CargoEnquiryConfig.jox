    <JadeMethod name="tblTabAttributes_mouseDown" id="2cafa42f-1ed6-415b-a673-fa20dc1e1d96">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTabAttributes_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;
end;
</source>
