    <JadeMethod name="delete" id="2bcad13a-8d5b-41fe-be24-d909bc00bcb5">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 December 2022	navvt20	TFS CR 55621 Task 55807: Jade - UOM Audits

*/

vars
	iter : Iterator;
	cmqfIC : CMQF_InvoiceContract;

begin
	iter := CMQF_InvoiceContract.instances.createIterator;
	while iter.next(cmqfIC) do
		if cmqfIC.allUnitOfMeasures.includes(self) then
			cmqfIC.allUnitOfMeasures.remove(self);
		endif;
	endwhile;
	
	self.resetAuditsDuringDelete();
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="efd65ea8-ed1a-468e-8a45-f0c26a4ee98b">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
13 February 2023	navhl20		TFS CR 56132 Task 56399: UI - UOM Maintenance - Type

*/

vars
	txt,
	tmpStr: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	tmpStr := null;
	tmpStr := app.getUOMInttoStr(self.type);
	txt := txt &amp; 'Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="79198601-9da4-4c59-aff5-1a2e59d29b14">
