    <JadeMethod name="setLogonDefaults" id="fbd3ed9b-d17a-417b-9065-65b5fb816c41">
        <updating/>
        <source>setLogonDefaults() updating;
/*******************************************************
*
* Description : Set up default logon values
*
* Parameters :	none
*
* Return :		None
*
* History :		pjs	04/02/97	Initial version
*
*******************************************************/

vars
	lincField : CnEcLincFieldDef;

begin
 	// simply need to go through and set the value for any field with a 
 	// default attribute set

 	// note that whilst we could set up the formatted value from here, we
 	// are using the setValue method here  to be consistent so that all 
 	// data is setup via the same code

	foreach lincField in myLincSystemDef.logonIspec.allLincFieldDefs do
		if lincField.defaultValue &lt;&gt; null then 
			setValue(myLincSystemDef.logonIspec.name,lincField.name,lincField.defaultValue);
		endif;
	endforeach;	
end;</source>
    </JadeMethod>
    <JadeMethod name="setLogonPriority" id="ed0af332-d5ec-45d6-bb01-2e6bbf8027e7">
        <updating/>
        <source>/*******************************************************
*
* Description : Set up the logon priority
*
* Parameters :	none
*
* Return :		None
*
* History :		pjs	10/02/96	Initial version
*
*******************************************************/
setLogonPriority() updating;

begin
	// avoid the 'queue' as such by putting this guy straight to the 
	// front

	priority := Logon_Priority;

	self.setTimeoutValue(0);
end;</source>
    </JadeMethod>
    <JadeMethod name="setPriority" id="e3e149d8-b3f4-4c18-a65d-c158e3feab49">
        <updating/>
        <source>setPriority(pri:Integer) updating;

begin
	// the priority should be between 1 and 5 

	if pri  &lt; 1 then 
		priority  := 1;
	elseif pri &gt; 5 then 
		priority := 5;
	else
		priority := pri;
	endif;

	 // set the timeout value here 

	self.setTimeoutValue(myLincSystemDef.timeoutValues[priority]);
end;</source>
        <Parameter name="pri" type="Integer"/>
    </JadeMethod>
