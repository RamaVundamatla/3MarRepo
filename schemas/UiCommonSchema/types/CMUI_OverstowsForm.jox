/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	entDef : EntTableDef;

begin

	entDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);
	
	self.tblCargo.setMyEntTableDef(entDef);
