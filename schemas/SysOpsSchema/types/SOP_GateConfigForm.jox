    <JadeMethod name="btnTempMaint_click" id="7960a2e4-c98c-4874-930d-af65c1b93716">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTempMaint_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2015	cnwndl1	Initial creation	Par 36234

*/

vars

	vssTemplate : CMUI_VehicleBookTermTemplate;
	vssTerm : CM_VehicleBookingTerminal;

begin

	if not self.myTerminal.isVehicleBookingEnabled then
		return;
	endif;
	
	vssTerm := self.myTerminal.myVehicleBookingTerminal;
	if vssTerm = null then
		return;
	endif;

	vssTemplate := app.loadForm(CMUI_VehicleBookTermTemplate, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookTermTemplate;
	if vssTemplate &lt;&gt; null then
		vssTemplate.CMUI_VehicleBookTermTemplate.setMyVehicleBookingTerminal( vssTerm );
		vssTemplate.setParentForm(self);
		vssTemplate.show;
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
