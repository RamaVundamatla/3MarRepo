    <JadeMethod name="keyDown" id="50969427-0bdd-44f7-9685-00b3b605d23f">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars

begin
	if keyCode = CMUI_Key_F3 then
		app.mousePointer := MousePointer_HourGlass;
		self.showHideSelector();
		return;
	elseif keyCode = J_key_Return then
		//if self.frmSelector.visible then //- cnwmd1, Par 22803
		if self.frmQueryToolbar.visible then //+ cnwmd1 Par 22803
			self.doSelection();
		endif;
	endif;

	inheritMethod(keyCode, shift);

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="8a79a9dd-9969-4c34-9d3c-b5d3737edd15">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 April 2022	navds20	Initial creation TFS 53388

*/

vars

	voyOps : SHP_VoyageOpsCargoGroupForm;
	runEUPForm : Boolean;
begin
	if not self.loadedForEUP then
		runEUPForm := CM_Root.firstInstance.isClientEuroPorts();
	
		if not runEUPForm and app.isSpecial then
			if app.msgBox("Do you want to run Euroports Voyage Operations?", "Question",MsgBox_Yes_No) = MsgBox_Return_Yes then  // ### TFS 58922 04JUL2023 NAVAB1 Yes/No
				runEUPForm := true;
			endif;
		endif;
	
		if runEUPForm then	
			voyOps:= app.loadForm(SHP_VoyageOpsCargoGroupForm, SHP_Assistant, false, false, true, self.myTerminal, null).SHP_VoyageOpsCargoGroupForm;
			if voyOps = null then
				return;
			endif;	
			
			voyOps.loadedForEUP := true;
			voyOps.show();
			
			self.unloadForm();
		else
			inheritMethod();
		endif;

	else
		inheritMethod();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCargoForTable" id="ea39483d-bf0a-48c5-9a47-d0e7f26a6c80">
        <updating/>
        <source>loadCargoForTable(_ti : CM_TrackedItem io; _rowIdx : Integer io; _table : CM_DataTable input; _isHidden, _fromNote : Boolean) updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
// 25/10/2022	navkc1	Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
// 01/12/2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
// 08/12/2022	navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
// 30/07/2025	navkc1 JIRA MTN 35478 MTN | Voyage Operations - Notification Framework
//--------------------------------------------------
vars

	str : String;

begin
	
	// 08/12/2022	navkc1	#55409
	if _table.rows &gt; self.numOfRowsPerTable then
		return;
	endif;
	
	if _ti = null then
		return;
	endif;	
	
	on Exception do self.handleExceptionTI(exception, _ti);
	_ti.fetchLatest();
	if _ti = null then
		return;
	endif;	

	if _table = null then
		return;
	endif;
		
	if (not self.includeObject(_ti)) then
		return;
	endif;
	
	if _isHidden then
		str := null;
	else
		str := _ti.getAttributeStringForDefArray(_table.allTblDataEntRows);
	endif;
	
	// 25/10/2022	navkc1	#54927
	if not self.isCargoGroupForm() then
		// Normal Voyage Operation Form
		_rowIdx := _table.addItem(str);
		_table.accessRow(_rowIdx).itemObject := _ti;
	else
		// Caro Group Voyage Operation Form
		self.loadCargoForTableCG(_ti, _table, _rowIdx, str, _fromNote);
		if _rowIdx = -1 then
			// We've added a TI to a collapsed Cargo Group, therefore no row was actually added to the table
			// So lets just bail early
			
			// After making sure we're now registering for notes for the CG
			self.doNotableAdd(_ti.myCargoGroup);
			
			return;
		endif;
	endif;
	
	//Adjust the displays to show the wle data - Kludge because table displays ti,s not wle,s
	self.adjustTableDispForMultiQueWle(_table, _rowIdx, _ti);
	
	self.doNotableAdd(_ti);
	
	self.doQueryColourUp(_table, _ti, _rowIdx);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_isHidden" type="Boolean"/>
        <Parameter name="_fromNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCargoForTableCG" id="e83a5923-655c-450c-8b6f-1417af019000">
        <updating/>
        <source>loadCargoForTableCG(_ti: CM_TrackedItem io; _table: CM_DataTable input; _rowIdx: Integer io; _str: String input; _fromNote: Boolean) protected, updating;
/*

Purpose:	Implemented in SHP_VoyageOpsCargoGroupForm		

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2022	navkc1	Initial creation Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened

*/

vars

begin
	return;
epilog

end;</source>
