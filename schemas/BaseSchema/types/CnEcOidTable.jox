    <JadeMethod name="getObject" id="4569bef6-d5f2-4501-b5e6-4e3389680a81">
        <source>getObject(pImported : String): Object;

vars
	oidTable 	: CnEcOidPair;
	object		: Object;
	
begin
	oidTable := self.allOidPairsByImported.getAtKey(pImported);
	
	if oidTable &lt;&gt; null then
		object :=  oidTable.current.asOid.Object;
		return object;
	else
		return null;
	endif;
end;</source>
        <Parameter name="pImported" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="98af27fa-305e-4ab3-a5ed-41fe27296111">
        <updating/>
        <source>initializeMe(pHubbleId : String) updating;

begin
	self.hubbleId	:=	pHubbleId;
	self.myBaseRoot	:=	app.myBaseRoot;
end;</source>
        <Parameter name="pHubbleId" type="String"/>
    </JadeMethod>
</Class>
