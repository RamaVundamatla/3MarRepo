    <JadeMethod name="getAuditText" id="32b725d3-b28b-471d-bdbf-79bd914c3d7f">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2010	cnwer1	Initial creation

*/

vars
	auditText,tmpStr : String;
	taViewPos : CM_TerminalAreaViewPosition;
begin
	auditText:= inheritMethod();
	
	foreach taViewPos in self.allTerminalAreaViewPositions do
		auditText := auditText &amp; taViewPos.getAuditTextDescription;
	endforeach;	
	
	return auditText;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="da0587c4-e688-40f0-866b-cff781053573">
        <source>getDisplayDetails( _short: Boolean ): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2012	cnwndl1	Initial creation	Par 29313

*/

vars

	str : String;

begin

	if self.myTerminal &lt;&gt; null then
		str := self.myTerminal.code;
	else
		str := app.getErrorString(Unknown);
	endif;
	
	if myUser &lt;&gt; null then
		str := str &amp; "/" &amp; self.myUser.getDisplayDetails( _short );
	endif;
	
	if name &lt;&gt; null then
		str := str &amp; "/" &amp; self.name;
	endif;

	return str;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
