    <JadeMethod name="tblFailed_mouseDown" id="36573e91-7a07-463e-952d-e29fee95515c">
        <updating/>
        <source>tblFailed_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
