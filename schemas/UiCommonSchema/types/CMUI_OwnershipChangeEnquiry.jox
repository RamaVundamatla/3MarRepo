    <JadeMethod name="doHandleNotification" id="04279c86-e2bf-4b57-80c9-15d1f361bd8a">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2023 navtnr20	TFS CR 58224 Task 58229: UI - Notifications

*/

vars
	dataLine	: String;
	coo : CM_OwnershipChange;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_OwnershipChange) then
		coo := userInfo.CM_OwnershipChange;
	elseif theObject.isKindOf(CM_OwnershipChange) then
		coo := theObject.CM_OwnershipChange;
	endif;
	
	if event = Event_COOCreate then
		if coo &lt;&gt; null then	
			if self.includeCOO(coo, true) then
				self.addRowToTable(coo);
			endif;
		endif;
	elseif event = Event_COOUpdate then
		if coo &lt;&gt; null then
			self.tblData.findObjectInRow(coo,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := coo.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_COODelete then
		self.tblData.removeItemObject(coo);
		self.doNotableClear(coo);
		
	elseif eventType = EventFileAdd	//navtnr20 12-07-2023 TFS 58237
	or eventType = EventFileDelete then // does not wrap terminal edition around the event number
		if coo &lt;&gt; null then
			self.tblData.findObjectInRow(coo,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := coo.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
