    <JadeMethod name="startBatchProcess" id="a3a5e21b-7187-4173-8a32-991a8bdeae16">
        <updating/>
        <source>startBatchProcess():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2017	cnwns1	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars
	
	startTime 	: TimeStamp;
	currentTime : TimeStamp;
	isDmast 	: Boolean;
	isWmast 	: Boolean;
	transForm 	: DEV_GenTranslateFormMethodForm;
	userSummaryDict : CM_AssociationDict;
	errorsArray		: StringArray512;
	startFrom : Integer;
begin

	//Everything runs from this method
	//Setup Stuff*****************************************
	startTime := app.actualTimeServer;
	currentTime := app.actualTimeServer;
	startFrom := textBoxResumePos.getTextAsInteger;
	
	//Check system type and name
	if not process.isUsingThinClient then
		write "Thin client only!";	
		return false;
	endif;

	if systemName.toLower().cnContains("dmast") or systemName.toLower().cnContains("emast") then
		isDmast := true;
	elseif systemName.toLower().cnContains("wmast") then
		isWmast := true;
	endif;
	
	if not isDmast and not isWmast or isDmast and isWmast  then
		write systemName &amp; " Unrecognised system";	
		return false;
	endif;
		
	write systemName;
	//***********************
	
	
	
	if xCheckStep_MarkTime(1,startTime, currentTime) then	//D Total: 0:00:00:00.001 Current: 0:00:00:00.001
															//W Total: 0:00:00:00.001 Current: 0:00:00:00.003
		//Find Xlat Constants in the wrong place - Constant points to one class but is used somewhere else
		self.doHuntForLostConstants();
	endif;
		
	if xCheckStep_MarkTime(2,startTime, currentTime) then	//D Total: 0:00:09:26.739 Current: 0:00:09:26.737
	//remove references to them							 	  W Total: 0:00:09:41.271 Current: 0:00:09:41.267
		if not	self.zFileReloadNewSchemas(Path_LostConstantChanges) then
			return false;
		endif;
	endif;
		
	if xCheckStep_MarkTime(3,startTime, currentTime) then//D Total: 0:00:09:44.033 Current: 0:00:00:17.293
	//get Constants not being used						   W Total: 0:00:09:57.811 Current: 0:00:00:16.539
		self.doFindUnusedConstants();
	endif;
		
	if xCheckStep_MarkTime(4,startTime, currentTime)then //D Total: 0:00:12:04.899 Current: 0:00:02:20.864
														 //W Total: 0:00:12:13.668 Current: 0:00:02:15.844
	//Check for uncompiled methods 
		if not self.xCheckForUncompiled() then
			return false;
		endif;
	endif;
	
	if xCheckStep_MarkTime(5,startTime, currentTime) then 	//D Total: 0:00:14:00.537 Current: 0:00:01:55.637
															//W Total: 0:00:14:10.266 Current: 0:00:01:56.597
	//Make a copy of the existing constants with new names
		self.doCloneConstants();
	endif;
	
	if xCheckStep_MarkTime(6,startTime, currentTime) then 	//D Total: 0:00:14:22.494 Current: 0:00:00:21.955
	//														//W Total: 0:00:14:33.557 Current: 0:00:00:23.290
	//Load them into the system
		if not self.zFileReloadNewSchemas(Path_NewConstants) then
			return false;
		endif;
	endif;
	
	if xCheckStep_MarkTime(7,startTime, currentTime) then   //D Total: 0:00:19:51.378 Current: 0:00:05:28.882 Effected by halted CMD window
															//W Total: 0:00:15:25.614 Current: 0:00:00:52.057
	//Point Xlat objects to new Constants
		self.doChangeXlatObjects(true);
	endif;
	
	if xCheckStep_MarkTime(8,startTime, currentTime)	then //D Total: 0:00:21:30.696 Current: 0:00:01:39.317
															 //W Total: 0:00:16:52.183 Current: 0:00:01:26.568
	//Change the source code to point to the new Constants
		self.doChangeSourceCode();
	endif;
	
	if xCheckStep_MarkTime(9,startTime, currentTime)then //D Total: 0:00:40:10.758 Current: 0:00:18:40.061
														 //W Total: 0:00:36:46.731 Current: 0:00:19:54.547
	//Load the changes
		if not self.zFileReloadNewSchemas(Path_SourceCodeChanges) then
			return false;
		endif;
	endif;
	
	if xCheckStep_MarkTime(10,startTime, currentTime)then //D Total: 0:00:41:24.373 Current: 0:00:01:13.614
	//Get all the old Constants							  //W Total: 0:00:43:47.919 Current: 0:00:07:01.188
		self.doFindUnusedConstants();
	endif;	
	if xCheckStep_MarkTime(11,startTime, currentTime)then	//D Total: 0:00:51:33.551 Current: 0:00:10:09.177
	//Remove xlat references to them						//W Total: 0:00:54:12.502 Current: 0:00:10:24.576 
		self.doChangeXlatObjects(true);
	endif;	
	if xCheckStep_MarkTime(12,startTime, currentTime)then//D Total: 0:00:51:35.697 Current: 0:00:00:02.145
														 //W Total: 0:00:54:14.944 Current: 0:00:00:02.441
	endif;
	
	if isDmast then
		//Create new translations via DEV_GenTranslateFormMethodForm
		create errorsArray transient;
		errorsArray := app.runGenXLATFormFromUnitTest(true);
		if errorsArray.first() &lt;&gt; null then
			errorsArray.inspectModal();
			return false;
		endif;
		delete errorsArray;
		
		if xCheckStep_MarkTime(13,startTime, currentTime)then//D Total: 0:01:07:22.143 Current: 0:00:15:46.445
		//Extract CSV to local folder to compare with Wmast
		doExtractCSVforConstants();
		endif;
		
		 xCheckStep_MarkTime(14,startTime, currentTime);	//D Total: 0:01:08:00.623 Current: 0:00:00:38.478
		
	endif;
	
	
	if isWmast then
		//Compare to first CSV file 
		//If no file found in your c/temp folder a modal dialog will ask if you want to try again saying no will break the process
		if xCheckStep_MarkTime(13,startTime, currentTime)then
			self.doGetMethodRefsNotInFile(false);
		endif;
		
		//Load in any differences found
		if xCheckStep_MarkTime(13,startTime, currentTime)then
			if not self.zFileReloadNewSchemas(Path_CSV_extract &amp; "constantsExtract\" ) then
				return false;
			endif;
		endif;
		
		if xCheckStep_MarkTime(14,startTime, currentTime)then	//W Total: 0:01:08:13.779 Current: 0:00:13:58.834
		
			//Compare to second CSV file
			self.doGetMethodRefsNotInFile(true);
		endif;	
			
		if xCheckStep_MarkTime(14,startTime, currentTime)then
			if not self.zFileReloadNewSchemas(Path_CSV_extract &amp; "methodsExtract\") then
				return false;
			endif;	
		endif;
	endif;
	
	if xCheckStep_MarkTime(15,startTime, currentTime)then	//D Total: 0:01:08:00.625 Current: 0:00:00:00.001
															//W Total: 0:01:35:39.327 Current: 0:00:27:25.547	
	
		//Check for uncompiled methods
		if not self.xCheckForUncompiled() then
			return false;
		endif;
	endif;	
	if xCheckStep_MarkTime(16,startTime, currentTime)then	//D Total: 0:01:09:54.070 Current: 0:00:01:53.445
															//W Total: 0:01:37:32.041 Current: 0:00:01:52.712
	
	//Final cleanup
	self.doChangeXlatObjects(true);
	endif;
	if xCheckStep_MarkTime(17,startTime, currentTime)then//D Total: 0:01:09:57.060 Current: 0:00:00:02.989
														 //W Total: 0:01:37:34.617 Current: 0:00:00:02.575
	
		//Create a JCF file
		self.doCreateJCFToDeleteConstants();
	endif;
	xCheckStep_MarkTime(99,startTime, currentTime);//D Total: 0:01:09:59.762 Current: 0:00:00:02.701
												   //W Total: 0:01:37:37.049 Current: 0:00:00:02.432
	return true;
	
	//You then need to run a JCF file to delete all the constants you just removed from code
		
epilog
 xCheckStep_MarkTime(100,startTime, currentTime);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xAddForignTransMethod" id="101665f9-ec78-4e43-bd26-26b69ad0753e">
        <updating/>
        <source>xAddForignTransMethod(_schema : Schema ; _className : String ; _methName : String; _isSpecial : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2017	cnwns1	Initial creation

*/

vars
	codeClass 	: Class; 
	codeMeth 	: Method;
	lMyLsSchema : LSschema;
	lMyLsClass 	: LSclass ;
	lMyLsMeth 	: LSmethodSource ;
begin
	if _schema = null or _className = null then
		return;
	endif;
	
	codeClass := _schema.getClass(_className);
	if codeClass = null then 
		return;
	endif;
	
	codeMeth := codeClass.getMethod(_methName);
	if codeMeth = null then
		return;
	endif;
	
	if codeMeth &lt;&gt; null then
		lMyLsSchema := getLsSchema(_schema , self.allForignLSSchemas);
		lMyLsClass := getLsClass(codeClass,lMyLsSchema);
		lMyLsMeth := getLsMethod(codeMeth,lMyLsClass,_isSpecial);
	endif;
		
epilog

end;</source>
        <Parameter name="_schema" type="Schema"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_methName" type="String"/>
        <Parameter name="_isSpecial" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xAddTransMethod" id="95338c42-987c-44f3-a0ae-599a3aa3647a">
        <updating/>
        <source>xAddTransMethod(_schema : Schema ; _className : String ; _methName : String; _isSpecial : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2017	cnwns1	Initial creation

*/

vars
codeClass : Class; 
codeMeth : Method;
 lMyLsSchema : LSschema;
 lMyLsClass : LSclass ;
 lMyLsMeth : LSmethodSource ;
begin
	if _schema = null or _className = null then
		return;
	endif;
	
	codeClass := _schema.getClass(_className);
	if codeClass = null then 
		return;
	endif;
	
	codeMeth := codeClass.getMethod(_methName);
	if codeMeth = null then
		return;
	endif;
	
	if codeMeth &lt;&gt; null then
		lMyLsSchema := getLsSchema(_schema , self.allLsSchemas );
		lMyLsClass := getLsClass(codeClass,lMyLsSchema);
		lMyLsMeth := getLsMethod(codeMeth,lMyLsClass,_isSpecial);
	endif;
	
epilog

end;</source>
        <Parameter name="_schema" type="Schema"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_methName" type="String"/>
        <Parameter name="_isSpecial" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xCheckForUncompiled" id="68344596-182c-49af-8449-f42c3395173e">
        <updating/>
        <source>xCheckForUncompiled(): Boolean updating;

/*
Purpose:	This script will list all methods in errors across all schemas.
*/

vars
	oSchema				: Schema;
	oType				: Type;
	oMethod				: Method;
	oAllClasses			: ClassColl;
	oAllTypes			: PrimTypeNDict;
	oAllMethods			: MethodNDict;
	iErrorsFound		: Integer;
	iErrorsTotal		: Integer;
	tempStr				: String;
	transArray :  HugeStringArray;
	nonTransArray : ObjectArray;
begin
	create oAllClasses transient;
	create oAllTypes transient;
	create oAllMethods transient;
	create transArray transient;
	create nonTransArray transient;

	app.writeLog(method.name,1);
	write method.name;
	
	tempStr	:= "Starting checking for Methods in Error";
	write tempStr;
	
	foreach oSchema in Schema.instances do : schema_loop
		tempStr	:= "Checking Schema " &amp; oSchema.name;
	//	write tempStr;
		
		delete oAllClasses;
		oAllClasses	:= oSchema.getAllClasses( true );
		
		foreach oType in oAllClasses do : class_loop
			oAllMethods.clear;
			oType.getMethods( oAllMethods ) ;
			foreach oMethod in oAllMethods do : method_loop
				if oMethod.getSchema &lt;&gt; oSchema then
					continue method_loop;
				endif;
				// display if in error and this method is actually in this schema not a super schema
			
				
				if 	oMethod.inError or oMethod.notCompiled then
					iErrorsFound := iErrorsFound + 1;
					tempStr	:= oSchema.name &amp; Tab &amp; oType.name &amp; Tab &amp; oMethod.name;
					write tempStr;
					if oMethod.name = "translateForm" then
						getLSFromMeth(oMethod,false,self.allDeleteLSSchemas);
					
					else
						nonTransArray.add(oMethod);
					endif;
				endif;
			endforeach method_loop;
		endforeach class_loop;
		
		if iErrorsFound &lt;&gt; null then
			tempStr	:= 'Number of errors for schema ' &amp; oSchema.name &amp; ' is ' &amp; iErrorsFound.display &amp; CrLf;
			write tempStr;
		endif;
		iErrorsTotal	:= iErrorsTotal + iErrorsFound;
		iErrorsFound	:= null;
	endforeach schema_loop;
	
	return iErrorsTotal = null;
	
	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";	

	
epilog
	if iErrorsTotal = null then
		tempStr	:= CrLf &amp; "Completed - No errors found" &amp; CrLf &amp; "Finished checking for Methods in Error";
	else
		tempStr	:= CrLf &amp; "Completed - " &amp; iErrorsTotal.display &amp; " Errors Found" &amp; CrLf &amp; "Finished checking for Methods in Error";
	endif;
	write tempStr;
	
	delete oAllTypes;
	delete oAllClasses;
	delete oAllMethods;
	delete transArray;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xCheckStep_MarkTime" id="becff20c-bad9-491e-99cb-e074c5574d53">
        <updating/>
        <source>xCheckStep_MarkTime(_step : Integer; _startTime : TimeStamp; _currentTime : TimeStamp io): Boolean  updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2017	cnwns1	Initial creation

*/

vars
	outputString : String;
begin
    
	if _step &lt; self.textBoxResumePos.getTextAsInteger then
		app.writeLog("Skipping step, Step = " &amp; _step.String &amp; " Resume from = " &amp; self.textBoxResumePos.text ,LogINFO);
		write "Skipping step, Step = " &amp; _step.String &amp; " Resume from = " &amp; self.textBoxResumePos.text;
		return false;
	endif;
	
	if self.canceled then
		app.writeLog("Cancel detected Now Skiping" ,LogINFO);
		write "ancel detected Now Skiping";
		return false;
	endif;
	
	
	outputString := _step.String &amp; " " &amp;  app.actualTimeServer.asStringJMT &amp;  " Total: " &amp; 
	(app.actualTimeServer - _startTime).asStringJMT &amp;" Current: "&amp; (app.actualTimeServer - _currentTime).asStringJMT;
	
	self.caption := "Completed Step " &amp; _step.String;
	write outputString;
	app.writeLog(outputString,LogINFO);
	
	_currentTime := app.actualTimeServer;
	
	return true;
end;
</source>
        <Parameter name="_step" type="Integer"/>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_currentTime" type="TimeStamp" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xGetChangedMethodCount" id="d0429409-9129-4368-a5c2-a8d9cb09105a">
        <source>xGetChangedMethodCount(_collection : LSschemaByName;_countType : String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2017	cnwns1	Initial creation

*/

vars
	count 		: Integer;
	lsSchema 	: LSschema;
	lsClass 	: LSclass;
	lsMethod 	: LSmethod;
begin

	foreach lsSchema in _collection do
		if xSourceHasChanged(lsSchema) then
			foreach lsClass in lsSchema.allClasses do
				if xSourceHasChanged(lsClass) then
					foreach lsMethod in lsClass.allMethods do
						if lsMethod.LSmethodSource.sourceHasChanged then
							count := count + 1 ;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endforeach;

	return count;
epilog

end;</source>
        <Parameter name="_collection" type="LSschemaByName"/>
        <Parameter name="_countType" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xGetConstantsIntoArray" id="0db55019-5f68-4ea3-b6a9-32d0699a3c66">
        <updating/>
        <source>xGetConstantsIntoArray(_constantArray : HugeStringArray io;  _methodArray : HugeStringArray io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2017	cnwns1	Initial creation

*/

vars
portSchema 		: Schema;
constantCategory: ConstantCategory;
constOb 		: Constant;
schemaName,className,controlName,controlProperty,constantName,controlCaption,methodName : String;
xmlDoc			: JadeXMLDocument;
	xmlElement		: JadeXMLElement;
	textElement		: JadeXMLElement;
	xmlAttribute	: JadeXMLAttribute;
	outputString 	: String;
	systemName 		: String;
	lsSchema : LSschema;
	lsClass : LSclass;
	lsMethod : LSmethod;
	lsMethodSource : LSmethodSource;
	lsConstant : LSconstant;
begin
	portSchema:=rootSchema.getSchema(PortSchemaName);
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);

	
	systemName := app.cnGetServerMiscPath;
	
	
	
	if allLsSchemas  &lt;&gt; null then
		allLsSchemas.purge;
	endif;	
	create allLsSchemas transient;
	
	//Refactor to put foreach inside if
	foreach constOb in constantCategory.cnEcGetConstants() do
	
		if self.allConstantsToDelete.includes(constOb) then
			continue;
		endif;
	
	
		if _methodArray &lt;&gt; null then
			getConstantRefs(constOb,self.allLsSchemas,false);
		endif;
	
		if _constantArray &lt;&gt; null then
	
			schemaName 		:= null;
			className		:= null;
			controlName		:= null;
			controlProperty := null;
			constantName	:= null;
			controlCaption 	:= null;
		
		
			delete xmlDoc;
			create xmlDoc transient;
			xmlDoc.parseString(constOb.text);
			xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
					
					// get the form Schema
			xmlAttribute := xmlElement.getAttributeByName(XML_Tag_SchemaName);
			if xmlAttribute &lt;&gt; null then
				schemaName :=  xmlAttribute.value;
			endif;
		
			// get the form class
			xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
			if xmlAttribute &lt;&gt; null then
				className :=  xmlAttribute.value;
			endif;
					
			// Get the controlName
			xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlName);
			if xmlAttribute &lt;&gt; null then
				controlName :=  xmlAttribute.value;
			endif;	
					
			// Get the controlName
			xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlProperty);
			if xmlAttribute &lt;&gt; null then
				controlProperty :=  xmlAttribute.value;
			endif;		
					
			// Get the text
			textElement := xmlElement.findElement(XMLTag_Msg, null);
			if textElement &lt;&gt; null then
				controlCaption :=  textElement.text.removeCrLfs.removeCommas;
			endif;			
				
				
		
				
			constantName := constOb.name;
				
							
			outputString := schemaName &amp; "," &amp; className &amp; "," &amp; controlName &amp; "," &amp; controlProperty &amp; "," &amp; constantName &amp; "," &amp; constOb.getSource &amp; "," &amp; controlCaption;// &amp; "," &amp; schemaName &amp; "_" &amp; className &amp; "_" &amp; controlName &amp; "_" &amp; controlProperty &amp; "_" &amp; constantName;
							
			_constantArray.add(outputString);				
							
		//	fileConstantDetails.writeLine(outputString);
			//outputString := null;
		endif;
	endforeach;
	
	if _methodArray &lt;&gt; null then
		foreach lsSchema in self.allLsSchemas	do
			schemaName := lsSchema.name;
			foreach lsClass in lsSchema.allClasses do
				className := lsClass.name;
				foreach lsMethod in lsClass.allMethods do
					methodName := lsMethod.name;
					lsMethodSource := lsMethod.LSmethodSource;
					foreach lsConstant in lsMethodSource.allConstants do
						outputString := schemaName &amp; "," &amp; className &amp; "," &amp; methodName &amp; "," &amp; lsConstant.name &amp; "," &amp; lsConstant.number.String &amp; "," &amp; lsConstant.text;// &amp; "," &amp; schemaName &amp; "_" &amp; className &amp; "_" &amp; methodName &amp; "_" &amp; lsConstant.name &amp; "_" &amp; lsConstant.number.String &amp; "_" &amp; lsConstant.text;
						
						_methodArray.add(outputString);
						
	//					fileMethodDetails.writeLine(outputString);
						//outputString := null;
					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endif;
	
epilog
delete	xmlDoc;
end;</source>
        <Parameter name="_constantArray" type="HugeStringArray" usage="io"/>
        <Parameter name="_methodArray" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xIsReleaseMeth" id="5619e092-9d01-4f91-a83a-256268768bf5">
        <source>xIsReleaseMeth(_method : Method) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2017	cnwns1	Initial creation
Checks the name of the method to see if it is called somthing like "rel812_par31628"
*/

vars
	methName : String;
	
begin

	methName := _method.name;
	
	if methName = null then 
		return false;
	endif;
	
	if methName.length &gt;= 7 then 
		if methName[1:3] = "rel" then
			if methName[4].isNumeric and methName[5].isNumeric and methName[6].isNumeric then
				if methName[7] = "_" then
					return true;
				endif;
			endif;
		endif;
	endif;

return false;
epilog

end;</source>
        <Parameter name="_method" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xScanSource" id="39147c3e-dd58-40d7-92b3-3127cacb0f68">
        <source>xScanSource( _lMyLsMethodSource : LSmethodSource input;   oldName : String;  newName : String; _removeLine : Boolean ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2017	cnwns1	Initial creation

*/

vars
	source 		: String ;
	linePos 	: Integer ;
	methChanged : Boolean ;
	line 		: String ;
	newLine 	: String ;
	newSource 	: String ;
	namesToPurge : StringArray;
  
begin

	create namesToPurge transient;

	namesToPurge.add("CMUI_ConnectAt_CchkIgnoreWarnL");
	namesToPurge.add("CMUI_ConnectAttachOld_CbtnCanc");
	namesToPurge.add("CMUI_ConnectAttachOld_CbtnOK");
		
    source := _lMyLsMethodSource.source;
							
	linePos := 1;
	methChanged := false;
	while true do
		// get the line to check
		line := source.cnEcGetNextLine(linePos);
		if linePos = 0 then 
			break;
		endif;
		
		if not self.xStringContains(line,oldName) then
			continue;
		endif;
	
		if _removeLine then
			newLine := null;
		else
			if namesToPurge.includes(oldName) then
				newLine := "//" &amp; line.replace(oldName, newName );
			else
				newLine := line.replace(oldName, newName );
			endif;
		endif;
		
		if methChanged then
			newSource := newSource.replace(line, newLine );
		else
			newSource := source.replace(line, newLine );
		endif; 
		
		methChanged := true;
		
	endwhile;
	
	if methChanged then
		_lMyLsMethodSource.setSource(newSource);
		_lMyLsMethodSource.setHasChanged(true);
	endif;
	
	return methChanged;
epilog	
	delete namesToPurge;
end;
</source>
        <Parameter name="_lMyLsMethodSource" type="LSmethodSource" usage="input"/>
        <Parameter name="oldName" type="String"/>
        <Parameter name="newName" type="String"/>
        <Parameter name="_removeLine" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xSourceHasChanged" id="bf18d45c-e96e-45be-842c-8f2e15cdbba4">
        <source>xSourceHasChanged(_inputObject : DevSchemaEntities) :Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2017	cnwns1	Initial creation

*/

vars
	lsSchema : LSschema;
	lsClass : LSclass;
	lsMethod : LSmethod;
begin
	if _inputObject.isKindOf(LSschema) then
		lsSchema := _inputObject.LSschema;
		foreach lsClass in lsSchema.allClasses do
			foreach lsMethod in lsClass.allMethods do
				if lsMethod.LSmethodSource.sourceHasChanged then
					return true;
				endif;
			endforeach;
		endforeach;
	elseif _inputObject.isKindOf(LSclass) then
		lsClass := _inputObject.LSclass;
		foreach lsMethod in lsClass.allMethods do
			if lsMethod.LSmethodSource.sourceHasChanged then
				return true;
			endif;
		endforeach;
	endif;
		
	return false;
		
epilog

end;</source>
        <Parameter name="_inputObject" type="DevSchemaEntities"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xStringContains" id="311729dd-8754-4ff6-9c6e-a5b9072420ea">
        <source>xStringContains(_methodCode : String ; _objectName : String):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2017	cnwns1	Initial creation
Scans source code for an exact match of a constant name
*/

vars
	pos 	 : Integer;
	nextChar : Character;
begin
	if 	_methodCode = null then
		return false;
	endif;
	
	pos := _methodCode.pos(_objectName,1);
	
	if pos &gt; 0 then 
		nextChar := _methodCode[pos + _objectName.length : 1].Character;
		if nextChar = "".Character then	
			return false;
		elseif nextChar = "_".Character then 
			return false;
		elseif nextChar = ",".Character then 
			return true;
		elseif nextChar = ";".Character then 
			return true;
		elseif nextChar.isAlpha then
			return false ;
		elseif nextChar.isNumeric then
			return false;
		endif;
		
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_methodCode" type="String"/>
        <Parameter name="_objectName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zFileCreateFolder" id="95751e44-fb77-45c2-a794-8f7b7d850e21">
        <source>zFileCreateFolder(_path : String; _usePresentationFileSystem : Boolean ) : FileFolder;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2017	cnwns1	Initial creation

*/

vars
fileFolder		: FileFolder;
today			: TimeStamp;
begin

	today := app.actualTimeServer;

	create fileFolder transient;
	
	if _usePresentationFileSystem then
		fileFolder.fileName := "c:\temp" &amp; Path_CSV_extract  &amp; app.computerName &amp; "\Transfer" &amp;
		today.date.year.String &amp; today.date.month.padLeadingWith("0", 2) &amp; today.date.day.padLeadingWith("0", 2);
	else
		fileFolder.fileName := app.cnGetServerMiscPath() &amp; Path_Xlat_Exports &amp; _path ;
	endif;
	
	fileFolder.usePresentationFileSystem := _usePresentationFileSystem;
	
	if not fileFolder.isAvailable then
		fileFolder.make();	
	endif;
	
	return fileFolder;
		
epilog

end;</source>
        <Parameter name="_path" type="String"/>
        <Parameter name="_usePresentationFileSystem" type="Boolean"/>
        <ReturnType type="FileFolder"/>
    </JadeMethod>
    <JadeMethod name="zFileCreateMethodExtract" id="61682633-e403-457b-a16a-c9c3b4c42943">
        <source>zFileCreateMethodExtract(_folderServer : FileFolder io;_lsSchemas : LSschemaByName );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2017	cnwns1	Initial creation

*/

vars
	lsSchema				: LSschema;
	lsClass					: LSclass;
	lsMethodSource			: LSmethodSource;
	lsMethod				: LSmethod;
	
	file					: File;
	dummyFileFolder			: FileFolder;
	outputString 			: String;
	ts						: TimeStamp;
	translateFormCreated	: Boolean;
	dontContinue			: Boolean;
	leadingcharacter	 	: String;
	firstEndOfLine 			: Integer;
begin
	foreach lsSchema in _lsSchemas do
		if  xSourceHasChanged(lsSchema) then
			
			
			delete file;
			create file transient;
			//modify the name of the extract files to make them load in the right order
			if lsSchema.name = PortSchemaName then
				leadingcharacter := "1_";
			elseif lsSchema.name = MobileUISchemaName then
				leadingcharacter := "2_";
			elseif lsSchema.name = UiCommonSchemaName then
				leadingcharacter := "3_";
			else
				leadingcharacter := "";
			endif;
			
			file.usePresentationFileSystem := _folderServer.usePresentationFileSystem;
			file.openOutput(_folderServer.fileName &amp; "\" &amp; leadingcharacter &amp; lsSchema.name &amp; '-FormNewConstSource-partial.scm');
			
			file.writeLine(lsSchema.zScmHeader);
			file.writeLine("typeDefinitions");
			
			translateFormCreated := false;
			
			foreach lsClass in lsSchema.allClasses do
				if xSourceHasChanged(lsClass) then
									
					foreach lsMethod in lsClass.allMethods do
						if not lsMethod.LSmethodSource.sourceHasChanged then
							continue;
						endif;
						
						app.log(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Extracting: " &amp; lsSchema.name &amp; "::" &amp; lsClass.name &amp; "::" &amp; lsMethod.name );
						
						file.writeLine(lsClass.name &amp; " partialDefinition");
						file.writeLine(Tab &amp; "(");
						file.writeLine(Tab &amp; "jadeMethodDefinitions");
					
					//	file.writeLine(Tab &amp; Tab &amp; lsMethod.myMethod.makeHeader &amp; " updating;");	// cnwkpd1 05/06/2008
						firstEndOfLine := 1;
						file.writeLine(Tab &amp; Tab &amp; lsMethod.LSmethodSource.source.scanUntil(";",firstEndOfLine) &amp; ";");	// cnwkpd1 05/06/2008
						
						file.writeLine(Tab &amp; Tab &amp; 'setModifiedTimeStamp "jlgns1" "6.2.17" 7 ' &amp; 
							ts.date.year.String &amp; ":" &amp; ts.date.month.padLeadingWith("0", 2) &amp; ":" &amp; ts.date.day.padLeadingWith("0", 2) &amp; ":" &amp; 
							ts.time.hour.padLeadingWith("0", 2) &amp; ":" &amp; ts.time.minute.padLeadingWith("0", 2) &amp; ":" &amp; 
							ts.time.second.padLeadingWith("0", 2) &amp; "." &amp; ts.time.milliSecond.String &amp; ";");
						file.writeLine(Tab &amp; ")");
				
				
					endforeach;
				endif;
			endforeach;
			
			file.writeLine("typeSources");
			foreach lsClass in lsSchema.allClasses do
				if  xSourceHasChanged(lsClass) then
					
				//	str := str &amp; CrLf &amp; Tab &amp; lsClass.myClass.name &amp; " (" &amp; CrLf &amp;
				//	Tab &amp; "jadeMethodSources" &amp; CrLf ;
					foreach lsMethod in lsClass.allMethods do 
						lsMethodSource := lsMethod.LSmethodSource;
						if lsMethodSource.sourceHasChanged then
							outputString := outputString &amp; Tab &amp; lsMethodSource.myClass.name &amp; " (" &amp; CrLf &amp; Tab &amp; "jadeMethodSources" &amp; CrLf &amp; lsMethodSource.myMethod.name &amp; CrLf &amp;
																						"{" &amp; CrLf &amp; lsMethodSource.source &amp; CrLf &amp; "}" &amp; CrLf &amp; Tab &amp; ")";
						endif;
					endforeach;
				
				endif;
			//	str := str &amp; CrLf &amp; " )";  
			endforeach;
			file.writeLine(outputString);
			outputString := null;
		endif;	
	endforeach;
	if file &lt;&gt; null then
		file.close();
	endif;	

epilog

end;</source>
        <Parameter name="_folderServer" type="FileFolder" usage="io"/>
        <Parameter name="_lsSchemas" type="LSschemaByName"/>
    </JadeMethod>
    <JadeMethod name="zFileFolderArchive" id="b261ad47-50ed-4cf8-8868-57e0c1ba399b">
        <source>zFileFolderArchive(_file : File io ; _folder : FileFolder io) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwns1	Initial creation

---Not used---

Checks if a file exists with the name we want to use.
Renames existing file if found.
*/
	

vars

	fileCount 	: Integer;
	fileName 	: String;
	file2 		: File;
	file3 		: File;
	folder2		: FileFolder;
	folder3		: FileFolder;
	firstPart 	: String;
	secontPart 	: String;
	newName 	: String;
	
begin
	if _file &lt;&gt; null then
		fileName := _file.fileName;
		if _file.isAvailable then
			firstPart := fileName[1:fileName.length - 4 ];
			secontPart := fileName[fileName.length - 3 :End];
			
			create file2	 transient;
			file2.fileName := _file.fileName;
				
			create file3 transient;
			file3.fileName := fileName;
			while file3.isAvailable do
				fileCount := fileCount + 1;
				file3.fileName := firstPart &amp; fileCount.String &amp; secontPart;
				newName := file3.fileName;
			endwhile;
			delete file3;	
			delete _file;
					
			file2.rename(newName);
			delete file2;
				
			create _file transient;
			_file.fileName := fileName;
		endif;
	else
		fileName := _folder.fileName;
		if _folder.isAvailable then
						
			create folder2	 transient;
			folder2.fileName := _folder.fileName;
				
			create folder3 transient;
			folder3.fileName := fileName;
			while folder3.isAvailable do
				fileCount := fileCount + 1;
				folder3.fileName := fileName &amp; fileCount.String;
				newName := folder3.fileName;
			endwhile;
			delete folder3;	
			delete _folder;
					
			folder2.rename(newName);
			delete folder2;
				
			create _folder transient;
			_folder.fileName := fileName;
		endif;
	
	
	endif;
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_folder" type="FileFolder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zFileMakeScm_FormXlatGC" id="fa6b579f-d5ce-4577-b0d2-5d0c8f47f80a">
        <source>zFileMakeScm_FormXlatGC(folder : FileFolder; _myLsSchema : LSschema);

// produce a PortSchema partial schema file to load global constants required for translation of form text
// (captions, bubbleHelp)

vars
	file			: File;
	constantCategory : ConstantCategory;	
	lsClass 		: LSclass;
	lsConstant 		: LSconstant;
	text 			: String;
	constantNumberOut : Integer;
	constantCount 	: Integer;
	fileCount 		: Integer;
begin
	
	foreach lsClass in _myLsSchema.allClasses do
		foreach lsConstant in lsClass.allConstants do
			if constantCount = 0 or constantCount mod 1000 = 0 then				
				fileCount := fileCount + 1;
				
				if file &lt;&gt; null then
					delete file;
				endif;
				create file transient;
				file.usePresentationFileSystem := folder.usePresentationFileSystem;
				file.openOutput(folder.fileName  &amp; _myLsSchema.mySchema.name &amp; '-FormCaptions-partial'&amp; fileCount.padLeadingWith("0",2) &amp;'.scm');
				file.writeLine(_myLsSchema.zScmHeader);
				constantCategory := rootSchema.getSchema(PortSchemaName).getConstantCategory(XLAT_FormCaptions);
				file.writeLine('constantDefinitions');
				// constant category
				file.writeLine(Tab &amp; 'categoryDefinition ' &amp; constantCategory.name);
				file.writeLine(Tab &amp; 'documentationText');
				file.writeLine('`' &amp; XML_Version &amp; 'TranslationClass ClassName="' &amp; XLAT_FormCaption.name &amp; '"&gt;');
				file.writeLine('&lt;/TranslationClass&gt;`');
				
			endif;
				
			constantCount := constantCount + 1;
			
			// increment constant value
			if lsConstant.number &gt; 0 then
				constantNumberOut := lsConstant.number;
			else
				continue;
			endif;
			
			text := lsConstant.text;
	
			// now write the constant definition to the scm file	
			file.writeLine(Tab &amp; Tab &amp; lsConstant.name &amp; ':	Integer = ' &amp; constantNumberOut.String &amp; ';');
			file.writeLine(Tab &amp; 'documentationText');
			file.writeLine('`' &amp; XML_Version &amp; XMLTag_Header &amp; ' ' &amp;
							XML_Tag_SchemaName &amp; '="' &amp; lsConstant.schemaName &amp; '" ' &amp;
							XML_Tag_FormClass &amp; '="' &amp; lsConstant.formName &amp; '" ' &amp;
							XML_Tag_ControlName &amp; '="' &amp; lsConstant.controlName &amp; '" ' &amp;
							XML_Tag_ControlProperty &amp; '="' &amp; lsConstant.controlProperty &amp; '"&gt;');
			file.writeLine('&lt;' &amp; XMLTag_LocaleMsg &amp; ' ' &amp; XMLTag_LocaleName &amp; '="' &amp; StandardTextLocaleStr &amp; '"&gt;');
			file.writeLine('&lt;' &amp; XMLTag_Msg &amp; '&gt;' &amp; text.xmlReplaceReservedChars(true) &amp; '&lt;/' &amp; XMLTag_Msg &amp; '&gt;');
			file.writeLine('&lt;/' &amp; XMLTag_LocaleMsg &amp; '&gt;');
			file.writeLine('&lt;/' &amp; XMLTag_Header &amp; '&gt;`');
	
		endforeach;
	endforeach;
	

	
	

epilog
	delete file;
end;</source>
        <Parameter name="folder" type="FileFolder"/>
        <Parameter name="_myLsSchema" type="LSschema"/>
    </JadeMethod>
    <JadeMethod name="zFileReloadNewSchemas" id="10b97066-113a-4a04-8f3e-9b071cec1e4c">
        <executionLocation>server</executionLocation>
        <source>zFileReloadNewSchemas(_path : String):Boolean serverExecution;

/*

Purpose:			Relaod the partial PortSchema (Constants) and Schema for Form 

					Need have PortSchema as the first file to load so that any new constants that are created will be
					there when there relevent translateForm method is loaded so no compile errors occur.

Date				Who		Reason
27/01/2012			cnwmh5	Initial creation
16/03/0215			cnwmh5	Tranisent Leaks
*/

vars
	fileNode 	: FileNode;
	allFiles	: FileNodeArray;
	args		: StringArray512;
	rtnStr		: String;
	result		: Integer;
	
	fileFolder 	: FileFolder;
begin

	app.writeLog(method.name,1);
	write method.name;

	write "Starting File load";
	
	
	
	
	app.writeLog(class.name &amp; '::' &amp; method.name, LogINFO);


	fileFolder := self.zFileCreateFolder(_path,false);
	
	create allFiles transient;
	fileFolder.mask := "*-partial*.scm";
	allFiles := fileFolder.files();
		
	if allFiles = null or allFiles.size = 0 then
		return false;
	endif;
		
	// get the details of the Form Captions-partial scms
	foreach fileNode in allFiles do
		 
		write class.name &amp; '::' &amp; method.name &amp; Tab &amp; fileNode.String &amp; Tab &amp; fileNode.FileNode.fileName;
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; fileNode.String &amp; Tab &amp; fileNode.FileNode.fileName, LogINFO);
	

		create args transient;
		
		result := -1;
			
		// load PortSchema global constants
		rtnStr := "Loading schema file: " &amp; fileNode.fileName;
			
		args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
		args.add('schemaFile="' &amp; fileNode.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'schemaFile="' &amp; fileNode.fileName &amp; '"';
		args.add('ini="' &amp; app.getIniFileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileName &amp; '"';
		args.add('server=multiuser');
		args.add('loadStyle=onlyStructuralVersioning');
		
		write "Creating Process";
		rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
					node.createExternalProcess(app.getJadeInstallDir(), 'jadloadb.exe', args, null, false, true, result).String;
		rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; rtnStr, LogINFO);
		if result &lt;&gt; 0 and result &lt;&gt; 4 then
		
				app.writeLog(fileNode.fileName &amp; " scm failed to load (" &amp; fileFolder.fileName &amp; ").  Please check the scm file.",LogINFO);
			return false;
		endif;
		write "Finished Process";
			
	endforeach;
	
	write "Finished File load";
	
	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";	

	
	return true;
	
epilog
//	delete allFiles;
	delete fileFolder;
	delete args;
end;
</source>
        <Parameter name="_path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
