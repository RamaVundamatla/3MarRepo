    <JadeMethod name="mnuFileRunMonitor_click" id="797789ef-2f42-415e-b91a-e6aff24e459e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileRunMonitor_click(menuItem: MenuItem input) updating;

vars
	errNo : Integer;
	errTxt : String;
	
begin
	errNo := 0;
	
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	app.startApplication("JadeMonitorSchema", "JadeMonitor");
	
	if errNo &lt;&gt; 0 then
		app.msgBox("Failed to initiate the JADE Monitor." &amp; CrLf &amp; CrLf &amp;
			"Error Number: " &amp; errNo.String &amp; CrLf &amp; "Error Text: " &amp; errTxt,
			"Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileRunProfEditor_click" id="95e9a1c3-77ff-476e-8834-5a9c22353e25">
        <controlMethod name="MenuItem::click"/>
