    <JadeMethod name="getLabelForNewGCLocation" id="23f19e53-223f-4e12-ac52-9ee846b36137">
        <source>getLabelForNewGCLocation() : String;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars
	lastLocnDefn : CM_ROROLocnDefn;
	roroAutoGenerateStartEnd : Integer;
	roroDeckLabelPrefix,
	roroOOTLSuffix,roroGCSuffix,
	roroRotatedLabel,
	roroSubDeckLabelPrefix	:String;
	roroLocationNumberLength	: Integer;
	roroLocationCodeIsZeroFilled: String;
	newOrd : Integer;
//	tmpVessel : CM_Vessel;
	newCode : String;
	allStateData : CM_StateDataDict;
begin

/* PAR 28971
	tmpVessel := self.getVessel();
	
	if tmpVessel  &lt;&gt; null then
		allStateData:= tmpVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	*/
	
	allStateData := self.getAllStateDataObject(); // PAR 28971
	
	global.getExtraData(allStateData,RoRoDeckLabelPrefix,roroDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoSubDeckLabelPrefix,roroSubDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoGeneralCargoSuffix,roroGCSuffix);
	
	
	global.getExtraData(allStateData,RoRoLocationNumberLength,roroLocationNumberLength);
	if roroLocationNumberLength = 0 then
		roroLocationNumberLength := 1;
	endif;
	global.getExtraData(allStateData,RoRoLocationCodeIsZeroFilled,roroLocationCodeIsZeroFilled);
	
	//cnwmc5 - 4 March 2014 - PAR 32831 - if theres no GC suffix, need to make sure there is no chance of taking an rotated cells original location code..
	lastLocnDefn := self.allROROLocnDefnByOrdinal.last;
	if lastLocnDefn &lt;&gt; null
	and roroGCSuffix = null then
		newOrd := lastLocnDefn.ordinal + 1;
	else
		newOrd := 1;
	endif;

	// PAR 27595
	//newOrd := 1;		//cnwmc5 - 4 March 2014 - PAR 32831
	while true do : codeLoop
		// ### code
		newCode := self.buildLocationCode(roroDeckLabelPrefix, roroSubDeckLabelPrefix, "",roroGCSuffix, roroLocationCodeIsZeroFilled.Boolean, false,true, roroLocationNumberLength, newOrd);
		if self.allDeckItems[newCode] &lt;&gt; null then
			newOrd := newOrd + 1;
		else
			break codeLoop;
		endif;
	endwhile;


	return newCode;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLabelForNewLocation" id="a0e77f2e-b16d-449a-bf08-d6acc5dc3502">
        <source>getLabelForNewLocation(_rotated, _ootl : Boolean; _newLocations : StringArray; _ordinal : Integer output) : String;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/
//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
vars
	allStateData : CM_StateDataDict;
	lastLocnDefn : CM_ROROLocnDefn;
	roroAutoGenerateStartEnd : Integer;
	roroDeckLabelPrefix,
	roroOOTLSuffix,
	roroRotatedLabel,
	roroSubDeckLabelPrefix	:String;
	roroLocationNumberLength	: Integer;
	roroLocationCodeIsZeroFilled: String;
	newOrd : Integer;
//	tmpVessel : CM_Vessel;
	newCode : String;
begin

/* PAR 28971
	tmpVessel := self.getVessel();
	
	if tmpVessel  &lt;&gt; null then
		allStateData:= tmpVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	*/
	allStateData := self.getAllStateDataObject(); // PAR 28971
	
	global.getExtraData(allStateData,RoRoOutOfTwistLockSuffix,roroOOTLSuffix);
	global.getExtraData(allStateData,RoRoDeckLabelPrefix,roroDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoSubDeckLabelPrefix,roroSubDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoLocationNumberLength,roroLocationNumberLength);
	if roroLocationNumberLength = 0 then
		roroLocationNumberLength := 1;
	endif;
	global.getExtraData(allStateData,RoRoLocationCodeIsZeroFilled,roroLocationCodeIsZeroFilled);
	global.getExtraData(allStateData,RoRoRotatedLabel,roroRotatedLabel);

	global.getExtraData(allStateData,RoRoAutoGenerateStartEnd,roroAutoGenerateStartEnd);
	
	lastLocnDefn := self.allROROLocnDefnByOrdinal.last;
	if lastLocnDefn &lt;&gt; null then
		newOrd := lastLocnDefn.ordinal + 1;
	else
		newOrd := 1;
	endif;

	// PAR 27595
	while true do : codeLoop
		// ### code
		newCode := self.buildLocationCode(roroDeckLabelPrefix, roroSubDeckLabelPrefix, roroRotatedLabel, roroOOTLSuffix, roroLocationCodeIsZeroFilled.Boolean, _rotated, _ootl, roroLocationNumberLength, newOrd);
		if self.allDeckItems[newCode] &lt;&gt; null or	//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
		   (_newLocations &lt;&gt; null and _newLocations.includes(newCode)) then
			newOrd := newOrd + 1;
		else
			break codeLoop;
		endif;
	endwhile;

	_ordinal := newOrd;
	return newCode;
epilog
end;</source>
        <Parameter name="_rotated" type="Boolean"/>
        <Parameter name="_ootl" type="Boolean"/>
        <Parameter name="_newLocations" type="StringArray"/>
        <Parameter name="_ordinal" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
