    <JadeMethod name="showContextMenu" id="081d6283-e0b7-4ac9-92c3-b4424e7707c0">
        <updating/>
        <source>showContextMenu(pMenuItem : MenuItem; cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     Duplicated from UiCommonSchema::CM_BaseForm
// ---------------------------------------------------------------------------
vars
	x1 : Real;
	y1 : Real;
begin
	
	x1 := x;
	y1 := y;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(pMenuItem, x1.Integer, y1.Integer);

	return false;                  // cancel further processing

end;</source>
        <Parameter name="pMenuItem" type="MenuItem"/>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showErrorMessage" id="e000f659-fad9-444e-abca-36bf7422916b">
        <source>showErrorMessage(message : String; isError : Boolean) : Boolean;
// Show the message, If the message is not an error (ie it is a warnming),
// then ask user if they want to continue.
// If the user wants to continue, true is returned, otherwise false
begin

	if message = null then
		return false;
	endif;

	if isError then
		self.msgBox(message, app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only, false);
	else
		if self.msgBox(message &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue),	app.getErrorString(Warning),
						MsgBox_Question_Mark_Icon + MsgBox_Yes_No, false) = MsgBox_Return_Yes then
			return true;
		endif;
	endif;
	
	return false;
end;
</source>
        <Parameter name="message" type="String"/>
        <Parameter name="isError" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideHelp" id="b305f10a-c8fe-4d4a-b01b-cabe584034bd">
        <source>showHideHelp(_show : Boolean);
vars
begin
	if _show then
		self.frmHelp.visible := true;
		self.frmHelp.zOrder(1);
//		self.frmHelp.width := self.width;
//		self.frmHelp.height:= self.height;
		self.btnHelpBack.default := true;
		self.btnHelpBack.cancel := true;
		self.txtHelpDesc.text := self.getHelpDescr();
		self.txtHelpDesc.fontSize := 10;
		self.txtHelpDesc.alignment := Frame.Alignment_Left_Top;
	else
		self.frmHelp.visible := false;
	endif;
end;


</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblMeasurement_gotFocus" id="237ef2f6-d165-4ad8-8255-a112fdbe0762">
        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMeasurement_gotFocus(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2013	cnwrd1	Initial creation

*/

vars
	editTable 	: CM_MobEntryTable;
	row			: Integer;
	str			: String;

begin
	editTable := self.getEntryTableForRow(table.CMUI_MeasurementTable.rowName);
	row := editTable.getRowByControlName(table.name);
	str := editTable.accessCell(row, editTable.ColumnValue).text;
	table.CMUI_MeasurementTable.setValues(str);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMeasurement_lostFocus" id="b4d55e33-072e-41ad-a3c7-e3965002141e">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMeasurement_lostFocus(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2013	cnwrd1	Initial creation

*/
vars
	tbl : CM_MobEntryTable;
	height : Integer;
	rowHeight : Real;

begin

	tbl := self.getEntryTableForRow(table.CMUI_MeasurementTable.rowName);
	height := tbl.accessRow(1).height;
	rowHeight := height.Real;
	self.measurementTableLostFocus(tbl, rowHeight, table.CMUI_MeasurementTable);
	if tbl &lt;&gt; null then
		tbl.cnEcResizeContents();
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2e350c31-a748-405f-847f-834ad66c56e9">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0013027, locale);
	btnButton.translateCaption(Xlat_0014255, locale);
	btnFive.translateCaption(Xlat_0013028, locale);
	btnFour.translateCaption(Xlat_0013029, locale);
	btnHelpBack.translateCaption(Xlat_0013030, locale);
	btnOne.translateCaption(Xlat_0013031, locale);
//	btnSearch.translateCaption(Xlat_0017605, locale);
	btnThree.translateCaption(Xlat_0013032, locale);
	btnTwo.translateCaption(Xlat_0013033, locale);
	lblHelpTitle.translateCaption(Xlat_0013034, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="translateTableData" id="ffe16628-c281-4220-a03b-8aa7f65821a0">
        <updating/>
        <source>translateTableData(	_tbl : CM_MobEntryTable io; 
					_allEntTableRows : ObjectArray; 
					_aTI : CM_TrackedItem;	
					_cargoType : CM_CargoType;
					_cargoSubType : CM_Product	//09 Oct 2013	NDL	Par 32764
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2013	cnwndl1	Initial creation	Par 32413

*/

vars

	obj : Object;
	row : EntTableRow;
	rowIndex : Integer;
	insertAfterRow : Integer;
	controlId : Integer;
	dispObj : CM_Object;
	alteredHeaderName : String;
	hideRow : Boolean;
	measureType : CM_MeasurementType;
	
begin
	controlId := 13000;
	self.allMeasurementControls.purge;
	
	if _aTI &lt;&gt; null then
		dispObj := _aTI;
	else
		if _cargoSubType &lt;&gt; null then	//09 Oct 2013	NDL	Par 32764
			dispObj := _cargoSubType;
		else
			dispObj := _cargoType;
		endif;
	endif;
	
	if dispObj = null then
		return;
	endif;
	
	foreach obj in _allEntTableRows do
		row := obj.EntTableRow;
		rowIndex := _tbl.getRowByName(row.name);
		if rowIndex &lt;= _tbl.fixedRows or rowIndex &gt; _tbl.rows or not _tbl.accessRow(rowIndex).visible then
			continue;
		endif;

		if dispObj.hasEntTableSpecialConditions(	row,//	_attrName : String;
													alteredHeaderName,//_alteredHeaderName : String output;
													hideRow,//_hideRow : Boolean output;
													measureType//_measureType : CM_MeasurementType output;
													) then
			
			if hideRow then
				_tbl.hideRow( rowIndex );
				
			elseif measureType &lt;&gt; null then	
				if self.insertMeasurementTypeRow(_tbl, row, rowIndex, controlId, dispObj, _aTI) then
					// hide the original measurement row
					rowIndex := _tbl.getRowByName(row.name);
					_tbl.hideRow(rowIndex);
				endif;
				
			elseif alteredHeaderName &lt;&gt; null then
				_tbl.setCellText(rowIndex, 1, alteredHeaderName);
				
			endif;
		
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_tbl" type="CM_MobEntryTable" usage="io"/>
        <Parameter name="_allEntTableRows" type="ObjectArray"/>
        <Parameter name="_aTI" type="CM_TrackedItem"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="updateMeasurementTypeRow" id="20d1780b-0c29-4fe1-8f99-f733acce6087">
        <source>updateMeasurementTypeRow( 	_tbl : CM_MobEntryTable io;
							_attrName : String;
							_rowIndex : Integer;
							_columnHeadingIndex : Integer;
							_columnDataIndex : Integer;
							_prodAttr : CM_ProductAttr
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2013	cnwndl1	Initial creation	Par 32413

*/

vars

	cell : JadeTableCell;
	control : Control;
	measureControl	: CMUI_MeasurementTable;
	measurementType : CM_MeasurementType;
	prefix : String;
	newRowName : String;
	existingValue : Decimal [16,4];
	entRowTrans : EntTableRowTransient;
	name : String;

begin

	measurementType := _prodAttr.myMeasurementType;

	if measurementType &lt;&gt; null then
		cell := _tbl.accessCell( _rowIndex, _columnDataIndex );
		if cell &lt;&gt; null then
			control := cell.cellControl;
			if control &lt;&gt; null and control.isKindOf(CMUI_MeasurementTable) then
				measureControl := control.CMUI_MeasurementTable;
				entRowTrans := _tbl.getEntRowTranUsingName( measureControl.name );
			endif;
		endif;
		if measureControl &lt;&gt; null and entRowTrans &lt;&gt; null then
			existingValue := measureControl.getConvertedValue();
			
			// Has_an associated measurement type, reset the name on the associated control so we can find it later in the dict. 
			prefix := app.getMeasurementPrefixFromType(measurementType.measurementType);
			newRowName := prefix &amp; _attrName &amp; "_" &amp; measurementType.shortName;
			
			if self.allMeasurementControls.includes(measureControl) then
				self.allMeasurementControls.remove(measureControl);
			endif;
			measureControl.setRowName(newRowName);
			
			// Now reset the default measurement type
			measureControl.setMeasurementType(measurementType.measurementType);
			measureControl.setValues( app.convertMeasurementForDisplay(measurementType.shortName, existingValue) &amp; Space &amp; measurementType.shortName);
			measureControl.lostFocus( measureControl );
			
			measureControl.name := newRowName;
			entRowTrans.setControlName(newRowName);
			entRowTrans.setName(newRowName);
			self.allMeasurementControls.add(measureControl);
		endif;
		
		// reset the heading name
		_tbl.setCellText(_rowIndex, _columnHeadingIndex, _prodAttr.displayName);
		
	else
		// just reset the heading name 
		_tbl.setCellText(_rowIndex, _columnHeadingIndex, _prodAttr.displayName);
	
	endif;
	
	
	

epilog

end;</source>
        <Parameter name="_tbl" type="CM_MobEntryTable" usage="io"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_rowIndex" type="Integer"/>
        <Parameter name="_columnHeadingIndex" type="Integer"/>
        <Parameter name="_columnDataIndex" type="Integer"/>
        <Parameter name="_prodAttr" type="CM_ProductAttr"/>
    </JadeMethod>
    <JadeMethod name="wasCalledViaContext" id="ff869b41-0643-4575-8340-29c0875846fa">
        <source>wasCalledViaContext( inFormLoad : Boolean ):Boolean;

/*

Purpose:			Returns true if the form we are on or its caller down the tree
					was called via the context menu of the Enquiry screen.
					Only relevant for:
					
					MOB_HHMoveForm
					MOB_HHStopsForm
					MOB_HHGradingForm
					MOB_HHTasksForm

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

	currentBackForm : Object;
	backToFormClass : Class;
	size : Integer;

begin

	size := self.getSessionAgent.allPreviousForms.size;
	if size = 0 then
		return false;
	endif;
	
	currentBackForm := self.getSessionAgent.allPreviousForms[size];
	if currentBackForm &lt;&gt; null then
		backToFormClass := currentBackForm.Class;
	endif;
	
	if backToFormClass = MOB_HHCargoEnquiryForm or backToFormClass = MOB_HHReeferEnquiryForm then
		// we are either in the process of being loaded and were called by the enquiry form, or we are
		// already established and the form we are returning to will be the enquiry form.
		return true;
	endif;
	
	//Now check exclusively for when we are called in a chain and we are in teh process of being loaded
	if not inFormLoad then
		return false;
	endif;
	
	currentBackForm := null;
	backToFormClass := null;
	if size &gt; 1 then
		// if we are in setupForm then we our caller wont have been stripped from the form stack yet
		// so we also need to check the previous one too.
		currentBackForm := self.getSessionAgent.allPreviousForms[size - 1];
		if currentBackForm &lt;&gt; null then
			backToFormClass := currentBackForm.Class;
		endif;
	endif;

	if backToFormClass = MOB_HHCargoEnquiryForm or backToFormClass = MOB_HHReeferEnquiryForm then
		// we are either in the process of being loaded and the previous form was called by the enquiry form.
		return true;
	endif;

	return false;

epilog

end;</source>
        <Parameter name="inFormLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xHandlerFileOpen" id="538e4486-3dc8-43ba-9748-054d281c589e">
        <source>xHandlerFileOpen(_exceptionObj:Exception; _errorMsg:String output):Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Feb 2009	#cnwdz2	 CCMS MES 1005 par 22294

*/

begin
	_errorMsg	:=	process.getErrorText(_exceptionObj.errorCode);
	
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="Exception"/>
        <Parameter name="_errorMsg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
