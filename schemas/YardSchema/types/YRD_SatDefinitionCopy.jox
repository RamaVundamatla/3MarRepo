    <JadeMethod name="loadComboUser" id="b70f6672-6bb9-4f79-ad54-ea2115b80ec3">
        <source>loadComboUser() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2010	cnwer1	Initial creation

*/

vars
	userTerminal : CM_UserTerminal;
	iter		: Iterator;
begin
	iter:=self.myTerminal.allUserTerminals.createIterator;
	
	while iter.next(userTerminal) do
		if userTerminal.myUser = null then
			continue;
		endif;
		if not userTerminal.myUser.canDo(self.myTerminal,PmAdmSatellitePrivateView) then
			continue;
		endif;	
		self.cmbUser.addItemObject( userTerminal.myUser.code, userTerminal.myUser);
	
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
