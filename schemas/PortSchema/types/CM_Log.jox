    <JadeMethod name="getOldSupplierProductFromTrans" id="dc0594f0-9629-41bb-8e8d-412cebf6556e">
        <source>getOldSupplierProductFromTrans( _theFirstSupplierChangedTrans : CM_EditOperator; _theFirstProductChangedTrans : CM_EditProductCode;
								_theSupplier : CM_Operator output; _theProduct : CM_Product output ) protected;
// --------------------------------------------------------------------------------------------------------
// Created:     05 Feb 2008 by cnwvu1
//
// purpose: CCMS1089. Docket Correction.
//			Gives the old Supplier and Product from the oldest transactions from
//				Product Changed and Supplier Changed transactions
// ----------------------------------------------------------------------------------------------------------

vars

begin

	if _theFirstSupplierChangedTrans = null and _theFirstProductChangedTrans = null then
		
		_theSupplier:= null;
		_theProduct	:= null;
	
	elseif _theFirstSupplierChangedTrans = null and _theFirstProductChangedTrans &lt;&gt; null then
		
		_theSupplier:= _theFirstProductChangedTrans.myProductFrom.myOperator;
		_theProduct := _theFirstProductChangedTrans.myProductFrom;
		
	elseif _theFirstSupplierChangedTrans &lt;&gt; null and _theFirstProductChangedTrans = null then
		
		_theSupplier:= _theFirstSupplierChangedTrans.myOperatorFrom;
		_theProduct := _theFirstSupplierChangedTrans.myProductFrom;
	
	else	// both trns &lt;&gt; null
	
		if _theFirstSupplierChangedTrans.createdTime &lt; _theFirstProductChangedTrans.createdTime then
			_theSupplier:= _theFirstSupplierChangedTrans.myOperatorFrom;
			_theProduct := _theFirstSupplierChangedTrans.myProductFrom;
		else
			_theSupplier:= _theFirstProductChangedTrans.myProductFrom.myOperator;
			_theProduct := _theFirstProductChangedTrans.myProductFrom;
		endif;

	endif;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_theFirstSupplierChangedTrans" type="CM_EditOperator"/>
        <Parameter name="_theFirstProductChangedTrans" type="CM_EditProductCode"/>
        <Parameter name="_theSupplier" type="CM_Operator" usage="output"/>
        <Parameter name="_theProduct" type="CM_Product" usage="output"/>
    </JadeMethod>
