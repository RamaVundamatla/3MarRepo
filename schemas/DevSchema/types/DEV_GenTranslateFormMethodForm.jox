    <JadeMethod name="load" id="bb9046c5-01ab-4836-8961-94e63c7e31df">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:		Set up the details required for the from	

Date			Who		Reason
25/01/2012		cnwmh5	Initial creation

*/

vars
	keys : IntegerArray;
	form : Form;
begin

	self.myPortSchema := rootSchema.getSchema("PortSchema");	//11 Sep 2020	NDL
	
	create self.myFormAgent transient;
	
	create self.dictLSconstantsToDisplay transient;
	self.dictLSconstantsToDisplay.setMembership(LSconstant);
	self.dictLSconstantsToDisplay.addExternalKey(String, 35, false, true);			// form name
	self.dictLSconstantsToDisplay.addExternalKey(String, 35, false, false);			// control
	self.dictLSconstantsToDisplay.addExternalKey(String, 35, false, true);			// type   e.g. caption or bubbleHelp
	self.dictLSconstantsToDisplay.endKeys(false);
	
	create self.dictFormChanges transient;
	self.dictFormChanges.setMembership(JadeDynamicObject);
	self.dictFormChanges.addExternalKey(String, 35, false, true);					// form name
	self.dictFormChanges.addExternalKey(String, 35, false, false);					// control
	self.dictFormChanges.addExternalKey(String, 35, false, true);					// type   e.g. caption or bubbleHelp
	self.dictFormChanges.endKeys(false);
	
	self.txtNew.backColor := self.RowColourNewControl;
	self.txtTextDiff.backColor := self.RowColourDiffText;
	self.txtDeleted.backColor := self.RowColourDeleted;
	
	//10 Jun 2021	NDL TFS 51321 - Allow for duplicated forms in Jade. Use the last added.
	create self.allAvailableForms transient;
	self.allAvailableForms.setMembership(Form);
	self.allAvailableForms.addExternalKey(String, 35, false, true);					// form name
	self.allAvailableForms.endKeys(false);	
	foreach form in Form.instances reversed do
		if not self.allAvailableForms.includesKey( form.name ) then
			 self.allAvailableForms.putAtKey( form.name, form );
		endif;
	endforeach;
	
	self.initTable();
	self.loadFormCombo();
	
	self.centreWindow;
	self.cmbAllForms.setFocus();
		
	create self.unitTestErrorArray transient;			// 24/02/2015 cnwmh5
	
	// 23/09/2015 cnwmh5 - Disable required buttons and table
	if not app.isDevelopmentSystemMain() then
		//self.tblDetails.enabled := false;				// Still allow scrolling in Jade 2016 onwards
		self.tblDetails.userInputEnabled := false;		// 19/02/2019 jlgmd1
		self.btnExtractAll.enabled := false;
		self.btnSave.enabled := false;
		self.lblNonDevSystem.visible := true;
		self.btnCreateSCM.enabled := false;
	endif;
	
	create keys transient;
	keys.add(CMUI_Key_F11);
	self.registerFormKeys(keys);
	
	self.caption := "Generate / Load translateForm Method for " &amp; app.myCnKarmaCntrl.environmentId.toUpper &amp; " ";    // 14/06/2016 cnwmh5
	
	if not process.isPW() then // Phil does not like the filter
		self.cmbAllForms.filterIgnore := true;
	endif;
epilog
	delete keys;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadComboSelected" id="b80f4925-1168-4273-ab5b-2b2b62ec393e">
        <updating/>
        <source>loadComboSelected() updating;

/*

Purpose:	Get / Create the constants required to build the translateForm method

			The following rules cause an error / warning to occur.  I've included those that are checked but don't cause an error / warning to occur.
		
			No Warning / Error
			------------------
			* Constant doesn't exist and line is commented out
			
			Warning
			-------
			* Constant has no XML in its text (Needs to be addressed)
			* Form caption is still default
			* Constant exists with different text (Needs to be addressed)
			
			Error
			-----
			* Unable to find Xlat_FormCaption constant (Needs to be addressed)
			* Constant isn't a Xlat_FormCaption constant (Needs to be addressed)

Date			Who		Reason
16/01/2012		cnwmh5	Initial creation
12/04/2013		cnwmh5	Fix issue where bubbleHelp isn't getting found for at least ComboBox, Picture, TextBox, Table controls.
						These are the ones that were found so fix will do all controls.
16/03/2015		cnwmh5	Transient Leaks
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/
constants
	TranslateCaption		: String = "translateCaption";
	TranslateCaption2		: String = ".caption";
	TranslateBubbleHelp		: String = "translateBubbleHelp";
	TranslateBubbleHelp2	: String = ".bubbleHelp";
	AlphaCharacters			: String = "abcdefghijklmnopqrstuvwxyz";
vars

	lsConstant				: LSconstant;
	constantObj				: Constant;
	obj						: Object;
	
	xmlDoc					: JadeXMLDocument;
	xmlElement				: JadeXMLElement;
	textElement				: JadeXMLElement;
	
	constantText			: String;
	constantName			: String;
	
	index2					: Integer;
	addToCombo 				: Boolean;

begin

	self.cmbSelectedForms.clear();
	

	foreach index2 in 1 to self.cmbAllForms.listCount do
	
		self.dictLSconstantsToDisplay.clear();
		
		delete self.myLSschema;
		create self.myLSschema transient;
	
		self.myLSschema.mySchema := cmbAllForms.itemObject[index2].Class.schema;
		self.myLSschema.getLSclass(cmbAllForms.itemObject[index2].Class.name);
		self.myLSschema.name := self.myLSschema.mySchema.name;					//TFS 36423
		self.myLSclass := self.myLSschema.allClasses.first;
		self.btnSave.enabled := self.myLSclass &lt;&gt; null and app.isDevelopmentSystemMain();
		//write self.myLSschema.mySchema.name &amp; Tab &amp; self.myLSclass.name;

		//11 Sep 2020	NDL
//		self.staMain.caption := "Processing " &amp; self.myLSschema.mySchema.name &amp; '::' &amp; self.myLSclass.name &amp; ". Please wait...";
//		self.doWindowEvents(0);
		
		self.processFormMethodDetails();
	
		addToCombo := false;
		foreach obj in self.dictLSconstantsToDisplay do
			addToCombo := false;
			//newConst := false;
			constantText := null;
			lsConstant := obj.LSconstant;
			constantName := lsConstant.name;
	//		constantObj := rootSchema.getSchema("PortSchema").getConstant(lsConstant.name);
			constantObj := self.myPortSchema.getConstant(lsConstant.name);	//11 Sep 2020	NDL
			if constantObj &lt;&gt; null then
				delete xmlDoc;
				create xmlDoc transient;
				xmlDoc.parseString(constantObj.text);
				xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
				// Get the text
				textElement := xmlElement.findElement(XMLTag_Msg, null);
				constantText := textElement.text;
				if constantText &lt;&gt; lsConstant.text and self.optDiffOnly.value = true  then
					addToCombo := true;
				endif;
			endif;
			if constantObj = null and self.optNewOnly.value = true then
				addToCombo := true;
			endif;
			
			if addToCombo then
				if self.cmbSelectedForms.findObject(self.myLSclass.myClass) &lt; 1 then
					//write lsConstant.formName &amp; Tab &amp; self.myLSclass.myClass.name;
					self.cmbSelectedForms.addItemObject(lsConstant.formName, self.myLSclass.myClass);
				endif;
			endif;
			
		endforeach;
		
	endforeach;
	
	if self.cmbSelectedForms.listCount &gt; 0 then							// 27/06/2013 cnwmh5
		self.cmbSelectedForms.listIndex := 1;
		self.cmbSelectedForms_click(self.cmbSelectedForms);
	endif;
	
	if self.optNewOnly.value = true then
		self.noToAdd := self.cmbSelectedForms.listCount;
	elseif self.optDiffOnly.value = true then
		self.noWithDiffs := self.cmbSelectedForms.listCount;
	endif;
	
	self.setFormCaption();
	
epilog
	
	if xmlDoc &lt;&gt; null then
		delete xmlDoc;
	endif;
	
	self.staMain.caption := "";
	self.doWindowEvents(0);	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadFormCombo" id="06015a69-723f-4c6d-afd9-f56c65b0d289">
        <updating/>
        <source>loadFormCombo() updating;

/*

Purpose:		Load the Form combo with details	

Date			Who		Reason
25/01/2012		cnwmh5	Initial creation
12/04/2013		cnwmh5	Change so that only loads schemas that need to be loaded
16/03/2015		cnwmh5	Transient Leak
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars
	
	schema				: Schema;
	class				: Class;
	form				: Form;
	
	schemaArray			: SchemaColl;
	classesArray		: ClassColl;
	allowableSchemasArray		: StringArray;
	
	
begin

	app.mousePointer := MousePointer_HourGlass;	//11 Sep 2020	NDL

	self.cmbAllForms.clear();												// 27/06/2013 cnwmh5
	delete self.myLSclass;
	self.btnSave.enabled := self.myLSclass &lt;&gt; null and app.isDevelopmentSystemMain();
	delete self.myLSschema;
	
	create allowableSchemasArray transient;									// 12/04/2013 cnwmh5
	allowableSchemasArray.add(UiCommonSchemaName);
	allowableSchemasArray.add(MobileUISchemaName);
	allowableSchemasArray.add(PortSchemaName);
	allowableSchemasArray.add(GateSchemaName);
	allowableSchemasArray.add(GeneralCargoSchemaName);
	allowableSchemasArray.add(HmsSchemaName);
	allowableSchemasArray.add(InvoiceSchemaName);
	allowableSchemasArray.add(LogSchemaName);
	allowableSchemasArray.add(ShipSchemaName);
	allowableSchemasArray.add(SysOpsSchemaName);
	allowableSchemasArray.add(YardSchemaName);

	create schemaArray transient;
	schemaArray.add(rootSchema.getSchema(UiCommonSchemaName));
	schemaArray.add(rootSchema.getSchema(MobileUISchemaName));
	
	create classesArray transient;
	
	foreach schema in schemaArray do
		if schema.name &lt;&gt; MobileUISchemaName then
			schema.getClass(CM_BaseForm.name).allSubclasses(classesArray);
			schema.getClass(CM_BaseForm.name).allSubclassesInSubschemas(classesArray);
		else
			schema.getClass('MOB_BaseForm').allSubclasses(classesArray);
			schema.getClass('MOB_BaseForm').allSubclassesInSubschemas(classesArray);
		endif;
	endforeach;
	
	foreach class in classesArray do
		if not allowableSchemasArray.includes(class.schema.name) then						// 12/04/2013 cnwmh5
			continue;
		endif;	
/*		foreach form in Form.instances do
			if form.name = class.name then
				break;
			endif;
		endforeach; */
		form := self.allAvailableForms.getAtKey( class.name ).Form;	//10 Jun 2021	NDL	TFS 51321
		if self.cmbAllForms.findObject(class) &lt; 1 then
//11 Sep 2020	NDL - too slow
//			self.staMain.caption := "Extracting details for " &amp; class.schema.name &amp; "::" &amp; class.name &amp; ".  Please wait...";
//			self.doWindowEvents(0);	
			cmbAllForms.addItemObject(class.name, class);
		endif;
	endforeach;
	
	self.optAllForms.value := true;
	
//	if self.cmbAllForms.listCount &gt; 0 then											// 27/06/2013 cnwmh5
//		self.cmbAllForms.listIndex := 1;											//TFS 36423
//		self.cmbAllForms_click(self.cmbAllForms);									//TFS 36423
//	endif;																			//TFS 36423
	
	if self.optAllForms.value = true then
		self.noForms := self.cmbAllForms.listCount;
	endif;
	
	self.setFormCaption();
	
epilog

	delete schemaArray;
	delete classesArray;
	delete allowableSchemasArray;
	
	self.staMain.caption := "";
	self.doWindowEvents(0);	
	app.mousePointer := MousePointer_Default;	//11 Sep 2020	NDL
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTable" id="2c14858f-b1e6-4ac7-880c-00f5eaa23fbf">
        <updating/>
        <source>loadTable() updating;

/*

Purpose:		Load the details into the table	

Date			Who		Reason
25/01/2012		cnwmh5	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars

	lsConstant				: LSconstant;
	constantObj				: Constant;
	obj						: Object;
	
	xmlDoc					: JadeXMLDocument;
	xmlElement				: JadeXMLElement;
	textElement				: JadeXMLElement;
	
	constantText			: String;
	constantName			: String;
	backgroundColour		: Integer;
	newCount				: Integer;
	diffCount				: Integer;
	newConst				: Boolean;
	noLongerCount			: Integer;
	commentedOutCount		: Integer;
	isLineCommentedOut		: Boolean;
	klass					: Class;
	property				: Property;
	modifiedBy				: String;
	dateModified			: TimeStamp;
begin

	if self.myLSclass = null then
		return;
	endif;
	
	self.initTable();

	foreach obj in self.dictLSconstantsToDisplay do
		newConst := false;
		isLineCommentedOut := false;
		constantText := null;
		lsConstant := obj.LSconstant;
	//	if lsConstant.name = null then																		//TFS 36423
	//		lsConstant.name := self.myFormAgent.makeConstantName(lsConstant,getHighestConstantNumberInUse);	//TFS 36423
	//	endif;																								//TFS 36423
		constantName := lsConstant.name;
	//	constantObj := rootSchema.getSchema("PortSchema").getConstant(lsConstant.name);
		constantObj := self.myPortSchema.getConstant(lsConstant.name);
		if constantObj &lt;&gt; null then
			delete xmlDoc;
			create xmlDoc transient;
			xmlDoc.parseString(constantObj.text);
			xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
			// Get the text
			textElement := xmlElement.findElement(XMLTag_Msg, null);
			constantText := textElement.text;
		else
			//constantName := self.myFormAgent.makeConstantNameForGenLoadForm(lsConstant.formName, lsConstant.controlName, lsConstant.controlProperty);
//			constantName := self.makeConstantName(lsConstant.formName, lsConstant.controlName, lsConstant.controlProperty);	//TFS 36423																	
//			newConst := true;																								//TFS 36423
//			lsConstant.name := constantName;																				//TFS 36423
			
			
			lsConstant.name := self.myFormAgent.makeConstantName(lsConstant,getHighestConstantNumberInUse);									//TFS 36423	
			constantName := lsConstant.name;																				//TFS 36423
			newConst := true;
			
			
			if lsConstant.isCommentedOut then
				isLineCommentedOut := true;
			endif;
		endif;
		if lsConstant.isCommentedOut then				// 10/12/2015 cnwmh5
			isLineCommentedOut := true;
			newConst := false;
		endif;
		
		klass := rootSchema.findClassInSubschema(lsConstant.formName);
		property := klass.getProperty(lsConstant.controlName);
		if property &lt;&gt; null then
			modifiedBy := property.getModifiedBy().asStringJMT();
			dateModified := property.getModifiedTimestamp();
		else
			modifiedBy := klass.getModifiedBy();
			dateModified := klass.getModifiedTimestamp();
		endif;
		
		self.tblDetails.addItem(lsConstant.formName &amp; Tab &amp; lsConstant.controlName &amp; Tab &amp; lsConstant.controlProperty &amp; Tab &amp; modifiedBy &amp; Tab &amp; dateModified.date().asStringJMT() &amp; Tab &amp; dateModified.time().asStringJMT() &amp; Tab &amp;
			isLineCommentedOut.Integer.String &amp; Tab &amp; constantName &amp; Tab &amp; lsConstant.text &amp; Tab &amp; constantText);			// 24/09/2015 cwnmh5
			//(lsConstant.isCommentedOut).Integer.String &amp; Tab &amp; constantName &amp; Tab &amp; lsConstant.text &amp; Tab &amp; constantText);
			self.tblDetails.accessCell(self.tblDetails.rows, ColCommentOut).marginLeft := 22;
		self.tblDetails.accessCell(self.tblDetails.rows, ColConstantName).itemObject := lsConstant;
		self.tblDetails.accessCell(self.tblDetails.rows, ColConstantName).enabled := false;
		if app.isDevelopmentSystemMain() then
			self.tblDetails.accessRow(self.tblDetails.rows).enabled := true;
		else
			self.tblDetails.accessRow(self.tblDetails.rows).enabled := false;
		endif;
		if not lsConstant.matchedToFormConstant then
			self.tblDetails.accessRow(self.tblDetails.rows).enabled := false;
		endif;
		
		// 19/09/2014 cnwmh5
		if lsConstant.isCommentedOut then
			commentedOutCount := commentedOutCount + 1;
		endif;
				
		// create the dyna dict details for updating. 
		backgroundColour := self.RowColourDefault;
		
		//if lsConstant.name = null then
		if newConst then
			backgroundColour := self.RowColourNewControl;
			self.tblDetails.accessCell(self.tblDetails.rows, 5).enabled := true;
			newCount := newCount + 1;
		elseif constantText &lt;&gt; lsConstant.text then
			backgroundColour := self.RowColourDiffText;
			diffCount := diffCount + 1;
		elseif not lsConstant.matchedToFormConstant then
			backgroundColour := self.RowColourDeleted;
			noLongerCount := noLongerCount + 1;													// 19/09/2014 cnwmh5
		endif;
		self.tblDetails.accessRow(self.tblDetails.rows).backColor := backgroundColour;
	endforeach;
	
	self.lblSchema.caption := self.lblSchema.caption;
	self.lblChanged.caption := self.lblChanged.caption;
	self.lblNoCntrlCount.caption := self.dictLSconstantsToDisplay.size.padLeadingWith(" ", 5);
	self.lblNoCntrlXNew.caption := newCount.padLeadingWith(" ", 5);
	if newCount &gt; 0 then
		self.lblNoCntrlXNew.fontBold := true;
		self.lblNewCntrlXlats.fontBold := true;
	endif;
	self.lblNoTxtXDiff.caption := diffCount.padLeadingWith(" ", 5);
	self.lblNoDontExistC.caption := noLongerCount.padLeadingWith(" ", 5);						// 19/09/2014 cnwmh5
	self.lblNoCommentOutC.caption := commentedOutCount.padLeadingWith(" ", 5);					// 19/09/2014 cnwmh5
	
	self.staMain.caption := null;
	
	self.setFormCaption();
	
epilog

	delete xmlDoc;

end;

</source>
    </JadeMethod>
    <JadeMethod name="makeConstantNameOld" id="c839c13e-fe75-46f0-b5b8-c549a0b428bd">
        <source>makeConstantNameOld(formClass : String; controlName : String; controlProperty : String) : String protected;

// make a unique constant name up to max 30 chars based on form (class) and control name
// &lt;class-part&gt;_&lt;control-name-part&gt;
// &lt;class-part&gt; minimum length ClassPartMin, &lt;control-name-part&gt; gets priority, up to remainder
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out

constants
	ClassPartMin = 9;
	MaxLength	 = 30;
	MaxTries = 30;
	AscSpace = ' '.Character.Integer;
	Suffices = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwx';
	
vars
	classPart	: String;
	prefix		: String;
	overflow	: Integer;
	remainder	: Integer;
	classPartLen: Integer;
	randomChar	: String[1];
	constantName: String;
	triesCount	: Integer;
	logMsg		: String;

begin
	if controlProperty = 'caption' then
		prefix := 'C';
	elseif  controlProperty = 'bubbleHelp' then
		prefix := 'B';
	else
		beginTransaction;beginTransaction; // error
	endif;

	overflow := (formClass.length + controlName.length - MaxLength);

	if overflow &gt; 0 then
		classPartLen := (MaxLength - controlName.length).max(ClassPartMin);
	else
		classPartLen := MaxLength - controlName.length;
	endif;

	classPart := formClass[1:classPartLen] &amp; '_' &amp; prefix;
	remainder := MaxLength - classPart.length;

	constantName := classPart &amp; controlName[1:remainder];


	// make sure the constant name is unique (simple algorithm swaps last character)
	//while allConstantsByName[constantName] &lt;&gt; null do
//	while rootSchema.getSchema(PortSchemaName).getConstant(constantName) &lt;&gt; null or 							// 12/11/2015 cnwmh5
	while self.myPortSchema.getConstant(constantName) &lt;&gt; null or 							// 12/11/2015 cnwmh5
			self.myLSschema.allConstants[self.myLSschema.name, formClass, controlName, controlProperty] &lt;&gt; null or	
			self.myLSclass.allConstants[self.myLSschema.name, formClass, controlName, controlProperty] &lt;&gt; null do

		randomChar := Suffices[app.random(Suffices.length-1)+1].String;
		if constantName.length &lt; MaxLength then
			// append another character
			constantName := constantName &amp; randomChar;
		else
			constantName := constantName[1:constantName.length-1] &amp; randomChar;
//			constantName := classPart[1:classPart.length-2] &amp; randomChar &amp; '_' &amp; controlName[1:remainder];
		endif;

		logMsg	:=	"*** INFO *** Control constant name conflict, resolved for " &amp; formClass &amp; '::' &amp; controlName &amp; ' -&gt; ' &amp; constantName;
		app.log(logMsg);
		////app.createAlert(logMsg, true);	// #27657

		// get out of jail card
		triesCount := triesCount + 1;
		if triesCount &gt; MaxTries then
			logMsg	:=	"*** ERRROR *** Control constant name conflict, could not be resolved for " &amp; formClass &amp; '::' &amp; controlName &amp; ' -&gt; ' &amp; constantName;
			app.log(logMsg);
			app.createAlert(logMsg, true);
//			process.debug;
			break;
		endif;
	endwhile;

	return constantName;			
end;</source>
        <access>protected</access>
        <Parameter name="formClass" type="String"/>
        <Parameter name="controlName" type="String"/>
        <Parameter name="controlProperty" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
