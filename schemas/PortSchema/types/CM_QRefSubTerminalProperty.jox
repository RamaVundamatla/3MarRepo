    <JadeMethod name="setComboValues" id="3e7720f9-a9af-4a42-a752-29b29b81d646">
        <source>setComboValues(comboBox 				: ComboBox input; 
				queryCriteriaLineHolder : CM_QueryCriteriaLineHolder; 
				queryOperator 			: CM_QueryOperator; 
				passport 				: CM_Passport);
/*
----------   ----------  --------------------------------------------------
Created:	14 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  TFS#		Reason
07/09/2018	 jlgka1		 40200		Change the way how we get the Terminal entry in the CriteriaLine.
----------   ----------	 ----------	--------------------------------------------------
*/
vars
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	subTerminal				: CM_SubTerminal;
	idx						: Integer;
	objectSet				: ObjectSet;
	value					: Any;
	userTerminal			: CM_UserTerminal;
	object					: Object;
	multiTerminal			: Boolean;
	referenceLookup			: CM_QReferenceLookup;
	tmpLbl 					: String;
begin

	comboBox.clear;
	
	if queryCriteriaLineHolder = null then
		return;
	endif;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	

	create objectSet transient;
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		foreach userTerminal in passport.myUser.allUserTerminals do
			objectSet.add(userTerminal.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);

	foreach object in objectSet do
		foreach subTerminal in object.CM_Terminal.allSubTerminals do
			tmpLbl := subTerminal.code;
			
			if multiTerminal then
				idx := comboBox.addItem(tmpLbl &amp; ' - ' &amp; subTerminal.myTerminal.code);
			else
				idx := comboBox.addItem(tmpLbl);
			endif;
			comboBox.itemObject[idx] := subTerminal;
		endforeach;
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(queryOperator) then
		referenceLookup := queryOperator.CM_QReferenceLookup;
		if global.isValidObject(referenceLookup.mySelectionValue) then
			if comboBox.findObject(referenceLookup.mySelectionValue) &gt; 0 then
				comboBox.listObject := referenceLookup.mySelectionValue;
			endif;
		endif;
	endif;
	
epilog
	delete objectSet;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="b55107e7-6670-4ea3-9791-31ff4fc29c95">
        <source>setListValues(table : Table input; 
			queryCriteriaLineHolder : CM_QueryCriteriaLineHolder; 
			operator : CM_QReferenceIsOneOf; 
			passport : CM_Passport);
/*
----------   ----------  --------------------------------------------------
Created:	14 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  TFS#		Reason
07/09/2018	 jlgka1		 40200		Change the way how we get the Terminal entry in the CriteriaLine.	
----------   ----------  --------------------------------------------------
*/
vars
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	tmpTerminal				: CM_Terminal;
	subTerminal				: CM_SubTerminal;
	idx						: Integer;
	objectSet				: ObjectSet;
	value					: Any;
	userTerminal			: CM_UserTerminal;
	object					: Object;
	multiTerminal			: Boolean;
	selectionValue			: Integer;
begin

	table.rows := table.fixedRows;
	table.sortColumn[1] := 2; // TFS 7821

	
	if queryCriteriaLineHolder = null then
		return;
	endif;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	

	create objectSet transient;
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		foreach userTerminal in passport.myUser.allUserTerminals do
			objectSet.add(userTerminal.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);

	foreach object in objectSet do
		foreach subTerminal in object.CM_Terminal.allSubTerminals do
			selectionValue := 0;
			if operator &lt;&gt; null and operator.allSelectionValues.includes(subTerminal) then
				selectionValue := 1;
			endif;
			
			if multiTerminal then
				idx := table.addItem(selectionValue.String &amp; Tab &amp; subTerminal.code &amp; ' - ' &amp; subTerminal.myTerminal.code);
			else
				idx := table.addItem(selectionValue.String &amp; Tab &amp; subTerminal.code);
			endif;
			table.accessRow(idx).itemObject := subTerminal;
			table.row := idx;
			table.change(table);
		endforeach;
	endforeach;
	
epilog
	delete objectSet;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="065c3b4f-b1fb-40af-ba70-c001e5e0fd3f">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*
----------   ----------  --------------------------------------------------
Created:	14 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str				: String;
	numRows,
	idx				: Integer;
	taSet				: CM_ObjectSet;
	subTerminal		: CM_SubTerminal;
begin

	create taSet transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			subTerminal := _tbl.accessRow(idx).itemObject.CM_SubTerminal;
			taSet.add(subTerminal);
		endif;
	endforeach;
	
	_op.setSearchValue(taSet);
	
epilog
	delete taSet;	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showCriteria" id="5518e54e-a4fa-43b6-b031-2c74de80646c">
        <source>showCriteria(lineHolder : CM_QueryCriteriaLineHolder input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Nov 2019	jlger1	Initial creation  47132

*/

vars

	objectSet				: ObjectSet;
	terminal : CM_Terminal;
begin
	if not app.isSubTerminalsLicensed then
		return false;
	endif;
	
	create objectSet transient;
	lineHolder.getTerminals(objectSet,app.myPassport);
	
	if objectSet.size = 1 then
		terminal:=objectSet.first.CM_Terminal;
		return terminal.isSubTerminalsOn;
	else
		return true;
	endif;
	
	
epilog
	delete objectSet;


end;</source>
        <Parameter name="lineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="c9cb2880-026a-4c11-b82f-ea114b36fb58">
        <source>translateToDisplayValue(_value: Any): String;
/*
----------   ----------  --------------------------------------------------
Created:	14 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars

begin
	if _value = null then
		return null;
	endif;
	
	if _value.isKindOf(CM_SubTerminal)then
		return _value.CM_SubTerminal.code;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="2273392b-2c4c-4ff0-b0d3-ccb184631925">
        <source>translateToSearchValue(_value: Any): Any;
/*
----------   ----------  --------------------------------------------------
Created:	14 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;

		if _value.isKindOf(CM_SubTerminal) then
			return _value.CM_SubTerminal;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="24d0c3c7-f660-4ec6-8d3e-f4fc9fc427fd">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	term : CM_Terminal;

begin
	if _value.isKindOf(String) then
		term := app.myPassport.myTerminal;
		if term &lt;&gt; null then
			return term.allSubTerminals[_value.String];
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
