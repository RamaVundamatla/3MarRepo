    <JadeMethod name="pxyCreateUpdateProxy" id="94826b98-3813-42fd-9ae8-c98d66b57333">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/

vars
	pxyCountryRegion 	: CM_CountryRegion;
	completeOK			: Boolean;
	
begin
	pxyCountryRegion := inheritMethod();
	
	self.allCountries.copy(pxyCountryRegion.allCountries);
	pxyCountryRegion.myRoot := self.myRoot;
	
	completeOK := true;
	return pxyCountryRegion;
	
epilog
	if not completeOK then
		delete pxyCountryRegion;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9cff8d75-dc94-4ac8-a086-f8aef9e2d2d6">
        <updating/>
        <source>setForCreate(_pxyCountryRegion: CM_CountryRegion) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/

vars

begin
	_pxyCountryRegion.raiseExceptionIfNotTransient(method);
	
	self.raiseExceptionIfTransient(method);
	
	self.setForUpdate(_pxyCountryRegion);
epilog

end;</source>
        <Parameter name="_pxyCountryRegion" type="CM_CountryRegion"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="23a5965d-00f8-4ac2-af84-63fe80acbda2">
        <updating/>
        <source>setForUpdate(_pxyCountryRegion : CM_CountryRegion) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/

vars

begin
	_pxyCountryRegion.raiseExceptionIfNotTransient(method);
	
	self.raiseExceptionIfTransient(method);
	
	self.code 				:= _pxyCountryRegion.code;
	self.description 		:= _pxyCountryRegion.description;
	self.homeRegion 		:= _pxyCountryRegion.homeRegion;
	self.notAvailForEntry	:= _pxyCountryRegion.notAvailForEntry;
	self.myRoot 			:= _pxyCountryRegion.myRoot;
	
	self.allCountries.clear();
	_pxyCountryRegion.allCountries.copy(self.allCountries);
epilog

end;</source>
        <Parameter name="_pxyCountryRegion" type="CM_CountryRegion"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="d8331d89-7546-41f5-b3d0-5fb134286e6b">
        <updating/>
        <source>setProxy(_code : String; _desc : String; _homeRegion : Boolean; _notAvailForEntry : Boolean; _allCountries : CM_CountryByCodeDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/

vars

begin
	self.code := _code;
	self.description := _desc;
	self.homeRegion := _homeRegion;
	self.notAvailForEntry := _notAvailForEntry;
	self.myRoot := app.myRoot;
	
	self.allCountries.clear();
	
	if _allCountries &lt;&gt; null then
		_allCountries.copy(self.allCountries);
	endif;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_homeRegion" type="Boolean"/>
        <Parameter name="_notAvailForEntry" type="Boolean"/>
        <Parameter name="_allCountries" type="CM_CountryByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="bc92f661-89a2-46be-8b9d-62d005696dff">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/

vars
	countryRegion 	: CM_CountryRegion;
	root			: CM_Root;
begin
	// No code entered
	if self.code.trimBlanks() = null then
		app.raiseCMException(NoCountryRegionCodeEntered, null, null);
	endif;
	
	// No descrtion entered
	if self.description.trimBlanks() = null then
		app.raiseCMException(NoCountryRegionDescEntered, null, null);
	endif;
	
	root := app.myRoot;
	
	// Code already exist
	countryRegion := root.allCountryRegions[self.code];
	if countryRegion &lt;&gt; null then
		app.raiseCMException1(CountryRegionCodeInUsed, countryRegion.code, null, null);
	endif;
	
	// Only 1 region can be home region
	if self.homeRegion then
		foreach countryRegion in root.allCountryRegions discreteLock do
			if countryRegion.homeRegion then
				app.raiseCMException1(OnlyOneHomeRegion, countryRegion.code, null, null);
				break;
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
