    <JadeMethod name="txtLoadLines_change" id="a48ff8f2-e0b3-46c0-beaa-ebb402c5dce6">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLoadLines_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2014	cnwah9	Initial creation CCMS1380

*/

vars

begin
	if not (self.txtLoadLines.text="0") then
		self.lblFileName.enabled:=true;
		self.txtFileName.enabled:=true;
		self.btnBrowse.enabled:=true;
		self.lblCharPos.enabled:=true;
		self.btnLoad.enabled:=true;
		self.tblSampleData.enabled:=true;
	else
		self.lblFileName.enabled:=false;
		self.txtFileName.enabled:=false;
		self.btnBrowse.enabled:=false;
		self.lblCharPos.enabled:=false;
		self.btnLoad.enabled:=false;
		self.tblSampleData.enabled:=false;
	endif;
epilog

end;</source>
