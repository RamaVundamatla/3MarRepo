    <JadeMethod name="validateMe" id="45613c3d-d859-4b9c-b1b6-a438d947e30a">
        <source>validateMe() protected;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpLotIDs,
	tmpSummaryID,
	tmpOrderIDs : String;
begin

	inheritMethod();
	if self.myStockOrderSummary = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Stock Order Summary', 'stockOrderSummary', null);
		app.raiseCMException(Input_required_field_stkOrdSum, 'stockOrderSummary', null); // cnwdb2	PAR 35364
	endif;
	
	if self.myStockOrderSummary &lt;&gt; null then
		if self.mySOHLocation &lt;&gt; null then
			if self.myStockOrderSummary.myProduct &lt;&gt; self.mySOHLocation.myProduct then
				app.raiseCMWarning2(ProductInconsistancyWarning, self.myStockOrderSummary.myProduct.code,
									self.mySOHLocation.myProduct.code, app.getErrorString(Product), null, self);
			endif;
		endif;
		if self.allocQuantity &gt; self.myStockOrderSummary.reqdQuantity then
			app.raiseCMWarning2(AllocateQtyWarning, self.allocQuantity.String,
								self.myStockOrderSummary.reqdQuantity.String,
								ETRow_AllocQuantity, null, self);		
		endif;
		if not self.mySOHLocation.canAllocateToOrder(self, false, self.allocType) then
			self.mySOHLocation.getAllocatedLotAndSummaryIDs(tmpLotIDs, tmpSummaryID);
			if tmpLotIDs &lt;&gt; null then
				tmpOrderIDs := '(Order: ' &amp; tmpLotIDs &amp; ' )';
			else
				tmpOrderIDs := '(Order: ' &amp; tmpSummaryID &amp; ' )';
			endif;		
			app.raiseCMException3(ERR_CANNOT_ALLOCATE, self.mySOHLocation.myLocationsController.getID(),
								  self.myStockOrderSummary.myProduct.code, tmpOrderIDs, ETRow_Location, null);		
		endif;						
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
