    <JadeMethod name="setMyMachine" id="96ceaad8-4a1f-49c7-9cdf-82c312b9a956">
        <updating/>
        <source>setMyMachine( _machine : CM_Machine input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2016	cnwndl1	Initial creation	TFS 1667

*/

vars

	user : CM_User;

begin

	user := app.getMyUser;

	if user &lt;&gt; null then
		//log off the current machine
		if self.myMachine &lt;&gt; null and self.myMachine &lt;&gt; _machine then
			if self.myMachine.loggedOn and self.myMachine.user = user then
				app.myTrxUA.trxUpdateLogoff( self.myMachine, app.myPassport );
			endif;
		endif;
		
		//log on to the new machine
		if _machine &lt;&gt; null and self.myMachine &lt;&gt; _machine then
			if not _machine.loggedOn then
				app.myTrxUA.trxHHAgentDirectMachineLogON( _machine, user, app.myPassport );
			endif;
		endif;
	endif;

	self.myMachine := _machine;

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
    </JadeMethod>
