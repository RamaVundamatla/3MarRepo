    <JadeMethod name="deleteInvoiceLines" id="b7088b16-9f5c-490b-8b42-e013e73160f2">
        <updating/>
        <source>deleteInvoiceLines(_lc : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:     21 July 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	invLine : CM_InvoiceLine;
	inv : CM_Invoice;
	event : CMEVT_LocationActivity;
begin
	foreach ti in _lc.allTrackedItems discreteLock do
		foreach invLine in ti.invoiceLines discreteLock do
			inv := invLine.invoice;
			self.deleteInvoiceLine(invLine);
		endforeach;
		
	endforeach;

	
	 // ### TFS 51219 16JUN2021 NAVAB1
	foreach event in _lc.allLocationActivity discreteLock do
		foreach invLine in event.allInvoiceLines discreteLock do
			inv := invLine.invoice;
			self.deleteInvoiceLine(invLine);
		endforeach;
		
	endforeach;
	self.deleteInvoice(inv);
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
