    <JadeMethod name="getData" id="ded127ea-489d-41ed-bed0-357a17016b2a">
        <updating/>
        <source>getData(pText: String input; pType: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		Passback method called from CMUI_GetData form
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars
	loadStateSet : Boolean;
	aProxyTI : CM_TrackedItem;
	result : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	if pType = self.GetData_SetRowWidth then
		if pText.isReal then
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateLogRowWidth(self.myRowAreaRow, pText.Real, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Row Width', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;

			self.drawGridArea();
		endif;
	endif;
	if pType = self.GetData_SetPrevWidth then
		if pText.isReal then
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateLogRowWidth(self.myRowAreaRow, pText.Real, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Row Width', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;

			self.drawGridArea();
		endif;
	endif;
	
	if pType = self.GetData_Remarks then
		app.cmsBeginLoad(loadStateSet);
		aProxyTI := self.mnuRemarks.userObject.CM_TrackedItem.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadStateSet);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateTIRemarks(aProxyTI, pText, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Grid Area', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;

	endif;
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	if aProxyTI &lt;&gt; null then
		delete aProxyTI;
	endif;
	self.myRowAreaRow := null;
end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDataArray" id="5afb2d1a-85fe-40a6-be1d-e30c649b7a83">
        <source>getDataArray(_terminalArea : CM_TerminalArea; _gridArea : YRD_GridArea input;
			_controller : CMIF_DrawingAttrController input) protected;
// ---------------------------------------------------------------------------
// Created:     01 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	tmpArray	: StringArray512;
	theTIs		: CM_TIArray;
	st			: Integer;

begin

	create tmpArray transient;
	create theTIs transient;

//	st := app.clock;	
	// do not put the beginLoad prior to this as it is a serverExecution method
	// that takes care of loadState itself
	_terminalArea.CM_GridArea.getGridDefinitionArray(tmpArray, _controller, theTIs);
//	write class.name &amp; '::' &amp; method.name &amp; '  ARR serverTime = ' &amp; (app.clock-st).String;

	beginLoad;
//	st := app.clock;
	_gridArea.setForCreateArray(_terminalArea, tmpArray, self.myAssistant, _controller, false);
//	write class.name &amp; '::' &amp; method.name &amp; '  ARR createTime = ' &amp; (app.clock-st).String;

epilog
	endLoad;
	delete theTIs;
	delete tmpArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_gridArea" type="YRD_GridArea" usage="input"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
