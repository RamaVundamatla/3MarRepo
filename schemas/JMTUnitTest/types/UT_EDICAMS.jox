	endDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);	
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);	
	
	//reassociate the transactions - CM_DamageLocation and CM_RepairDetail with the camsProtocol
	//and associate EVT_VoyageDeparture with the protocol and disassociate EVT_VoyGeneralLandingDate
	beginTransaction;
		camProtocol.registeredTransactions.add(global.getTiTxnTypeForClass(CM_DamageLocation).asStringJMT);
		camProtocol.registeredTransactions.add(global.getTiTxnTypeForClass(CM_RepairDetail).asStringJMT);
		
		camProtocol.allTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);		
		camProtocol.allTrainEventTypes.remove(app.myRoot.allEventTypesByType[EVT_VoyGeneralLandingDate]);		
	commitTransaction;	
	
