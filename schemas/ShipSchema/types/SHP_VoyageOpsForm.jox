    <JadeMethod name="getAllSelectedTIs" id="226115fd-3b3f-476d-8c27-edf1cdca32d4">
        <source>getAllSelectedTIs(_context : String; _tiSet : CM_TISet input; _all : Boolean; _table : CM_DataTable input);
//--------------------------------------------------------------
//Created: 10 September 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rowIdx,
	rows : Integer;
	obj : Object;
	ti : CM_TrackedItem;
begin
	
	if _tiSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiSet passed to method');
		return;
	endif;

	if _table = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _table passed to method');
		return;
	endif;	

	if _all then
		rows := _table.rows;
		foreach rowIdx in 2 to rows do
			obj := _table.accessRow(rowIdx).itemObject;
			if obj = null then
				continue;
			endif;
			
			// ### TFS 58922 04JUL2023 NAVAB1
			ti := obj.CM_TrackedItem;
			if _context = Select_Context_Plan then
				if ti.allPlannedFutureMoves.size &gt; 0 then
					continue;
				endif;
			elseif _context = Select_Context_Unplan then
				if ti.allPlannedFutureMoves.size = 0 then
					continue;
				endif;
			elseif _context = Select_Context_Unqueue then
				if ti.allQueuedFutureMoves.size = 0 then
					continue;
				endif;
			endif;
			/*  // ### TFS 58922 04JUL2023 NAVAB1
			if self.cmbTerminalArea.text = app.getErrorString(Planned_location) and obj.CM_TrackedItem.allPlannedFutureMoves.size = 0 then		// 26/7/17 MAP TFS4719
				continue;
			endif;
			*/
			_tiSet.add(ti);			
		endforeach;		
	else
		foreach obj in _table.allSelectedObjects do
			// ### TFS 58922 04JUL2023 NAVAB1
			ti := obj.CM_TrackedItem;
			if _context = Select_Context_Plan then
				if ti.allPlannedFutureMoves.size &gt; 0 then
					continue;
				endif;
			elseif _context = Select_Context_Unplan then
				if ti.allPlannedFutureMoves.size = 0 then
					continue;
				endif;
			elseif _context = Select_Context_Unqueue then
				if ti.allQueuedFutureMoves.size = 0 then
					continue;
				endif;
			endif;
			/*  // ### TFS 58922 04JUL2023 NAVAB1
			if self.cmbTerminalArea.text = app.getErrorString(Planned_location) and obj.CM_TrackedItem.allPlannedFutureMoves.size = 0 then		// 26/7/17 MAP TFS4719
				continue;
			endif;
			*/
			_tiSet.add(ti);			
		endforeach;	
	endif;
	
end;</source>
        <Parameter name="_context" type="String"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTIsInCurrentTable" id="7141cc4b-1a9d-46ed-8ba4-39ffa081d700">
        <updating/>
        <source>getAllTIsInCurrentTable(_table : CM_DataTable; _tiSet : CM_TISet input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/01/2015	cnwdap1		Initial creation PAR #35397 CCNS SFW 1394 Voyage Rationalisation
//
vars
	idx,
	rows	: Integer;
	ti		: CM_TrackedItem;
	isLoad	: Boolean;
	table	: CM_DataTable;
	
begin
	if _table = null then
		return;
	endif;
	
	rows := _table.rows;
	table := _table;
	_tiSet.clear;
	isLoad := _table = self.tblOnsite;
	
	foreach idx in _table.fixedRows + 1 to rows do
		ti := table.accessRow(idx).itemObject.CM_TrackedItem;
		if ti = null then
			continue;
		endif;
		if not _tiSet.includes(ti) then
			_tiSet.add(ti);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCaption" id="e6104aa1-a325-4e3a-81b5-c9dd9b797289">
        <source>getCaption(str : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2022	navlw1	Initial creation tfs 53330

*/

vars
	vess 	: CM_Vessel;
	caption : String;
begin
	vess := self.myCurrentVoyage.getMyVessel();
	if vess &lt;&gt; null then
		caption := str &amp; " " &amp; vess.structureTypeString;
	endif;
	
	caption := str &amp; " " &amp; self.myCurrentVoyage.getId.trimBlanks;
	return caption;
epilog

end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypesForCounter" id="43b010c9-d536-46e4-863a-03daedb93397">
        <source>getCargoTypesForCounter(_cargoTypes : CM_CargoTypeSet input; _selected : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	idx : Integer;
	ti 	: CM_TrackedItem;

begin
	if not _selected or self.myCurrentContextTbl = self.tblOnship then
		foreach idx in self.tblOnship.fixedRows + 1 to self.tblOnship.rows do
			ti := self.tblOnship.accessRow(idx).itemObject.CM_TrackedItem;
			if not _selected or self.tblOnship.allSelectedObjects.includes(ti) then
				_cargoTypes.addNoDuplicates(ti.myCargoType, false);
			endif;
		endforeach;
	endif;
	if not _selected or self.myCurrentContextTbl = self.tblOnsite then
		foreach idx in self.tblOnsite.fixedRows + 1 to self.tblOnsite.rows do
			ti := self.tblOnsite.accessRow(idx).itemObject.CM_TrackedItem;
			if not _selected or self.tblOnsite.allSelectedObjects.includes(ti) then
				_cargoTypes.addNoDuplicates(ti.myCargoType, false);
			endif;
		endforeach;
	endif;
	if not _selected or self.myCurrentContextTbl = self.tblOffsite then
		foreach idx in self.tblOffsite.fixedRows + 1 to self.tblOffsite.rows do
			ti := self.tblOffsite.accessRow(idx).itemObject.CM_TrackedItem;
			if not _selected or self.tblOffsite.allSelectedObjects.includes(ti) then
				_cargoTypes.addNoDuplicates(ti.myCargoType, false);
			endif;
		endforeach;
	endif;
	if not _selected or self.myCurrentContextTbl = self.tblPreNote then
		foreach idx in self.tblPreNote.fixedRows + 1 to self.tblPreNote.rows do
			ti := self.tblPreNote.accessRow(idx).itemObject.CM_TrackedItem;
			if not _selected or self.tblPreNote.allSelectedObjects.includes(ti) then
				_cargoTypes.addNoDuplicates(ti.myCargoType, false);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_cargoTypes" type="CM_CargoTypeSet" usage="input"/>
        <Parameter name="_selected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCurrentlySelectedTIs" id="f910c0f4-900b-42e0-ac22-e128a728dc66">
        <source>getCurrentlySelectedTIs(_tiSet : CM_TISet input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2006 By cnwth2

Purpose:	

Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
12 Jul 2022	navsrk20	Bug 53905: EUP - Planning issues for Cargo Groups in Voyage Operations screen
*/

vars
	objArray		: ObjectArray;
	obj				: Object;
begin
	_tiSet.clear();
	if self.myCurrentContextTbl = self.tblOnship then
		objArray := self.tblOnship.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblOnsite then
		objArray := self.tblOnsite.allSelectedObjects;	
	elseif self.myCurrentContextTbl = self.tblOffsite then
		objArray := self.tblOffsite.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblPreNote then
		objArray := self.tblPreNote.allSelectedObjects;
	else
		return;
	endif;
	
	foreach obj in objArray do
		if (not CM_TrackedItem.hasInstance(obj)) then
			continue;
		endif;
		
		_tiSet.add(obj.CM_TrackedItem);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getData" id="cad6366d-95cd-4b8f-abec-7cc27c999e58">
        <updating/>
        <source>getData(pAny: Any input; pType: Integer input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars

begin
	//This method deliberately left blank..... NDL
	//inheritMethod(pAny, pType);
	if pType = GETVALUE_QUANTITY then
		self.wleQuantity := pAny.Integer;
		self.wleWeight := 0;
	endif;
	if pType = GETVALUE_WEIGHT then // TFS 3873
		self.wleQuantity := 0;
		self.wleWeight := pAny.Real;
	endif;
epilog

end;</source>
        <Parameter name="pAny" type="Any" usage="input"/>
