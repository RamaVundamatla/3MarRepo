    <JadeMethod name="addToolbarControls" id="1e62e26d-b505-44d6-8970-78a3a225735f">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 25 Aug 2022 	navhl20 	ChangeRequest 54281: EUP - Wagon Track Planning
// ---------------------------------------------------------------------------
vars
	frm				: CMUI_Toolbar;
begin	
	
	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnConfirmIn, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnConfirmOut, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnIntransit, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnIntransitNO, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnDeparture, CMUI_Toolbar.Control_Alignment_Left); taken out for now, problems with it currently not cleaning up its jobs and if then this is re run might lose TI info on wagons.
	frm.addButton(self.btnRemarks, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnAddRequest, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
//	frm.addButton(self.btnMoveToRail, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCargoEnqIN, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCargoEnqOUT, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTransactions, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	//25.8.2022 navhl20 TFS 54281
	frm.addButton(self.btnMoveWagon, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnUndoWagon, CMUI_Toolbar.Control_Alignment_Left);
	//25.8.2022 navhl20 TFS 54281

	
end;</source>
        <access>protected</access>
    </JadeMethod>
