<Class name="SOPTM_ExtWebService" id="08f2c8c8-48a1-430d-b366-b1cb9e3c1384">
    <superclass name="SOP_TableMaintItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <ImplicitInverseRef name="myEWSAgent" id="afb58309-68d2-4169-a8a5-f34fb623675e">
        <embedded/>
        <type name="CM_EWSTypeAgent"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="changeViews" id="0d63ff68-2cce-495d-85e5-f4768d529e97">
        <source>changeViews(_type : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2018	jlgmp6	Initial creation	TFS41999
13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
09 Apr 2020	jlgdap1	TFS 49003 MTN API Inline Agent
21 Sep 2020 cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice
15 Mar 2021 navmd1	TFS 49052 MACS3 Vessel Library API
04 Oct 2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
02 Nov 2022	navpw1	TFS: 55215 - Added support for ExternalWebServiceEDBIC to load its view
15 Dec 2022 navmp20 ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
28 Mar 2023 jlier1	TFS 56856
09 Sep 2024 navdap1	TFS 66034 NSW OnePort Integration Post-Dev Demo Issues
11 Sep 2024 jlier1  TFS 65950: CR 65949 NSW | Dynamics Integration - External Web Service Definition Changes
22 Oct 2024	navdap1	MTN-14005 NSW | OnePort Integration - Requested Changes
25 Aug 2025	navnk30	JIRA 35713: 5 - YARA | Create a external webservice history class(EWS) and agent for AgGateway
*/

vars
	currentStatus : String;
	type : String;
	entTableDef : EntTableDef;
	entTableView : EntTableView;
begin
	type:= _type.removeString(" ").toUpper;
	entTableDef := app.myController.getEntTableDef(ETDef_ExtWebService);
	if type &lt;&gt; null then
		entTableView:=entTableDef.allEntTableViews[type];
	else
		entTableView:=entTableDef.allEntTableViews['DefaultNew'];
	endif;
	
	self.myForm.tblInput1.setEntTableFromView(entTableDef,entTableView,null,null);
	self.myForm.btnAdvanced.visible := (_type = ExternalWebServiceCARGOCHAIN or _type = ExternalWebServiceOPSVIEW); //21.09.2020 cnwma1 #49906
	self.myForm.btnAdvancedOnToolbar.visible := (_type = ExternalWebServiceCARGOCHAIN or _type = ExternalWebServiceOPSVIEW);  // ### TFS 51853 17NOV2021 NAVAB1
	self.myForm.btnSubTerms.visible	:=	false;	 // ### TFS 51853 17NOV2021 NAVAB1

	if _type = ExternalWebServiceINAPORTNET then
		CM_InaportnetWebService@comboVersion(self.myForm.cmbVersion);
	elseif _type = ExternalWebServiceOPSVIEW then // ### TFS 50669 02AUG2021 NAVAB1
		if self.myForm.myCurrentObject &lt;&gt; null then
			currentStatus := self.myForm.myCurrentObject.CM_OpsViewServiceDef.status;
			if currentStatus = EWS_STATUS_STARTING 
			or currentStatus = EWS_STATUS_READYTORUN then // ### TFS 50669 02AUG2021 NAVAB1
				self.myForm.tblInput1.hideRowByName(ETRow_StatusMessage, false); // ### TFS 50669 02AUG2021 NAVAB1
			endif;
			if currentStatus = EWS_STATUS_RUNNING then // ### TFS 50669 02AUG2021 NAVAB1
				self.myForm.tblInput1.hideRowByName(ETRow_LastSuccessfullSequence, false); // ### TFS 50669 02AUG2021 NAVAB1
				self.myForm.tblInput1.hideRowByName(ETRow_StatusMessage, false); // ### TFS 50669 02AUG2021 NAVAB1
				self.myForm.tblInput1.hideRowByName(ETRow_LastSuccessfullTS, false); // ### TFS 50669 02AUG2021 NAVAB1
			endif;

		endif;
	// TFS 66034 start
	elseif _type = ExternalWebServiceAPIEndpoint then
		if app.myRoot.canDoEDIFileType(EDIFileType_JSONOnePortVoyage) then
			//self.myForm.tblInput1.showRowByName(ETRow_LastSuccessfullTS, false);                                              //MTN-36366 - removed from ENT Table View as well.
			self.myForm.tblInput1.showRowByName(ETRow_TerminalsLastSuccessDT, false);       //MTN-36362
			// MTN-14005 start
			if app.myRoot.isClientPortBrisbane then
				self.myForm.tblInput1.hideRowByName(ETRow_BaseAuthEndpoint, false);
			else
				self.myForm.tblInput1.showRowByName(ETRow_BaseAuthEndpoint, false);
			endif;
			// MTN-14005 end
		else
			self.myForm.tblInput1.hideRowByName(ETRow_LastSuccessfullTS, false);
            self.myForm.tblInput1.hideRowByName(ETRow_TerminalsLastSuccessDT, false);       //MTN-36362
		endif;
	// TFS 66034 end
	elseif _type = ExternalWebServiceAgGateway then		//25AUG2025 navnk30 JIRA-35713
		self.myForm.tblInput1.setValueByName(ETRow_IsForCams, true);
		self.myForm.tblInput1.disableRowByName(ETRow_IsForCams);
	endif;
	
	if _type = ExternalWebServiceNavisMACS3 then	// TFS 49052
		self.setMACS3Defaults();
	endif;
	
	// Default new WS to 'active'
	self.myForm.tblInput1.setValueByName(ETRow_Active, true);	// TFS 49052
	
	self.setGrantTypeData(_type, null);		//TFS 63842

epilog

end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="clearThumbnailData" id="2dff7b71-5557-41fb-8faf-da5c99558d49">
        <updating/>
        <source>clearThumbnailData() updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="a6cd7027-d095-4372-b3cf-d1ebd4e4f138">
        <updating/>
        <source>create() updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars

begin
	self.name := SOP_TableMaintForm.Table_ExtWebService;
	self.permissionView	:= PmAdmExtwebSrvView;
	self.permissionMaint := PmAdmExtwebSrvMaint;
	self.myDataClass := CM_ExternalWebServiceDef;
	
	// ### JIRA 33544 17DEC2024 NAVAB1
	create self.myEWSAgent transient;
	self.myEWSAgent.init();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="f16b4d0f-f936-42fe-81b3-391070ceef9e">
        <updating/>
        <source>delete() updating;
/*
Purpose:	

Date		Who		Reason
17 December 2024	navab1	JIRA 33544
*/

vars

begin
	delete self.myEWSAgent;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnAdvanced" id="c5052fdf-bd6c-47fe-b6f5-4db4b8e62743">
        <updating/>
        <source>doBtnAdvanced() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Dec 2018	jlgmp6	Initial creation	TFS42015
21 Sep 2020 cnwma1  ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/
vars
	theForm 		: SOP_TableMaintForm;
	selectedObj		: Object;
	settingsFormObj	: SOP_ExtWebService;
	termForm        : SOP_ExtWSTerminal;
	ext             : CM_ExternalWebServiceDef;
begin
	theForm := self.myForm;
	selectedObj	:= theForm.myCurrentObject;
	
	if selectedObj.isKindOf(CM_CargoChainServiceDef) then
		create settingsFormObj;
		settingsFormObj.setExtWebService(selectedObj.CM_ExternalWebServiceDef);
		settingsFormObj.showModal();
	
	elseif selectedObj.isKindOf(CM_OpsViewServiceDef) then           //21.09.2020 cnwma1 #49906
		if theForm.mode = theForm.Mode_Update then
			ext := theForm.myProxyObject.CM_ExternalWebServiceDef;
		else 
			ext := selectedObj.CM_ExternalWebServiceDef;
		endif;
		
		create termForm;
		termForm.mode :=theForm.mode;
		termForm.setExtWebService(ext);
		termForm.showModal();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="b4238b7e-a9b4-41ba-a705-79c0b86eddd1">
        <updating/>
        <source>doDelete(_obj: Object io) updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars

begin
	app.myTrxDA.trxDeleteExtWebService(_obj.CM_ExternalWebServiceDef, app.myPassport);
epilog

end;</source>
        <Parameter name="_obj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doGrantTypeChange" id="be73e7bd-507b-4c4a-8bf5-28d7886b0feb">
        <updating/>
        <source>doGrantTypeChange(_value : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2024	navsp1	Initial creation ChangeRequest 63842: NSW | OnePort Integration Dev

*/

vars

begin
	if _value = SOP_TableMaintForm.GT_ClientSecret then
		self.myForm.tblInput1.hideRowByName(ETRow_UserCode, false);
		self.myForm.tblInput1.hideRowByName(ETRow_Password, false);
		self.myForm.tblInput1.showRowByName(ETRow_ClientSecret, false);
		
	elseif _value = SOP_TableMaintForm.GT_UserCode_Password then
		self.myForm.tblInput1.hideRowByName(ETRow_ClientSecret, false);
		self.myForm.tblInput1.showRowByName(ETRow_UserCode, false);
		self.myForm.tblInput1.showRowByName(ETRow_Password, false);
	else
		self.myForm.tblInput1.showRowByName(ETRow_ClientSecret, false);
		self.myForm.tblInput1.showRowByName(ETRow_UserCode, false);
		self.myForm.tblInput1.showRowByName(ETRow_Password, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext1Click" id="f8d90b45-204d-45ec-97c3-9da961e9723a">
        <updating/>
        <source>doMnuContext1Click(theMenuItem: MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	webDef		: CM_ExternalWebServiceDef;
	msg			: String;
	now			: TimeStamp;
	logLevel	: Integer;
begin
	logLevel := app.logLevel;
	
	webDef := self.myForm.myCurrentObject.CM_ExternalWebServiceDef;
	if webDef = null then
		webDef := self.myForm.myProxyObject.CM_ExternalWebServiceDef;
	endif;
	if webDef = null then
		return;
	endif;
	
	app.changeLogLevel(LogTRACE);
	
	// Do a connection test...
	if webDef.doConnectionTest(msg) then
		app.msgBox(msg,"Success",MsgBox_OK_Only);
	else
		app.msgBox(msg,"Error " &amp; now.formatAsYYYYMMDDHHMMSSMMM, MsgBox_OK_Only);
	endif;
	
epilog
	app.changeLogLevel(logLevel);
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="42cbc4f9-aeec-47e9-85c9-8e95b0c551c1">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jun 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
21 Sep 2020 cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice
05 Oct 2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
15 Dec 2022 navmp20 ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
31 May 2023	navra1	TFS 58203 - FR 54536 - EDI Message Type - Damage &amp; Repair Blur Security Fields
31 Aug 2023 navra1  TFS 59839 - POB | QShips Integration - Editable Last Run Time
05 Oct 2023	jlika1	TFS 60754	POB | QShip 55715.070 - Default Vessel Type 
10 Oct 2023	jlika1	TFS 60753	POB | Q-Ships 55717.080 - Date Range of QShips Query
14 Nov 2023	navra1	TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61355/Task 61370)
06 Aug 2024 navsp1  TFS ChangeRequest 63842: NSW | OnePort Integration Dev
05 Sep 2024 navsp1  TFS Bug 65991: MTN - API Endpoint External Webservice definition client secret and subscription key value update as *********
09 Sep 2024	navdap1	TFS 66034 NSW OnePort Integration Post-Dev Demo Issues
11 Sep 2024 jlier1  TFS 65950: CR 65949 NSW | Dynamics Integration - External Web Service Definition Changes
04 Feb 2025 naviv1  JIRA-12173 : MTN - JSON CAM Protocol and APIConsumerAgent hard codes EUP as the customer
10 Sep 2025	navnk30	JIRA 35757: 7 - Use the "EWS History Retainment Period" in the AG Gateway ext web service create a service runs periodically and clears out EWS history older than the specified period
*/

vars
	proxyExtWebService 		: CM_ExternalWebServiceDef;
	theForm		 	   		: SOP_TableMaintForm;
	msg 		 	   		: String;
	serviceType  	   		: Class;
	proxyMapping 	   		: CM_ExtWebServiceEventMapping; // TFS 40360
	eventType          		: CM_EventType;					// TFS 40360
	realExtWebService  		: CM_ExternalWebServiceDef;	//navra1 - TFS 58203 - 31st May 2023
	origClientSecret   		: String;					//navra1 - TFS 58203 - 31st May 2023
	origTenantId       		: String;					//navra1 - TFS 58203 - 31st May 2023
	origSubKeyValue    		: String;					//navra1 - TFS 58203 - 31st May 2023	
	clientSecretFromFrm		: String;					//navra1 - TFS 58203 - 31st May 2023
	tenantIdFromFrm       	: String;					//navra1 - TFS 58203 - 31st May 2023
	subKeyValueFromFrm    	: String;					//navra1 - TFS 58203 - 31st May 2023	
	grantType				: String;					//TFS 63842
	lastTS					: TimeStamp;				//TFS 66034
	endPoint 				: CM_Endpoint;
	oldProxy				: CM_ExternalWebServiceDef;
begin
	theForm := self.myForm; 

 	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			serviceType:=theForm.cmbWebServiceType.listObject.Class;
			if serviceType = null then
				msg := app.getErrorString1(Type_invalid, app.getErrorString(Type_GC));
				app.msgBox("External Web Service " &amp; msg, app.getErrorString(Error), MsgBox_OK_Only);
				return false;
			endif;
			
			if theForm.myProxyObject &lt;&gt; null then
				oldProxy:=theForm.myProxyObject.CM_ExternalWebServiceDef;
				theForm.myProxyObject:=null;
			endif;
			create theForm.myProxyObject as serviceType transient;
			if oldProxy &lt;&gt; null then
				foreach endPoint in oldProxy.allEndpoints do
						endPoint.setMyExternalWebServiceDef(theForm.myProxyObject.CM_ExternalWebServiceDef);
				endforeach;
				delete oldProxy;
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyExtWebService := theForm.myProxyObject.CM_ExternalWebServiceDef;
	theForm.tblInput1.setObjectFromTable(proxyExtWebService, null, false);
	
	if proxyExtWebService.isKindOf(CM_InaportnetWebService) then
		proxyExtWebService.setVersionString(theForm.cmbVersion.text);
		
	elseif proxyExtWebService.isKindOf(CM_AllotracServiceDef) then	//04 Aug 2020	NDL	TFS 49869
		proxyExtWebService.CM_AllotracServiceDef.setExtras(	theForm.tblInput1.getValueByName(ETRow_DeviceID).String,	//_deviceID : String;
															theForm.tblInput1.getValueByName(ETRow_SendOnReceive).Boolean,	//_sendJobCompleteOnReceive : Boolean;
															theForm.tblInput1.getValueByName(ETRow_SendOnRelease).Boolean	//_sendJobCompleteOnRelease : Boolean
															);
	elseif proxyExtWebService.isKindOf(CM_OpsViewServiceDef) then //21.09.2020 cnwma1 #49906
		proxyExtWebService.CM_OpsViewServiceDef.setOpsViewData( theForm.tblInput1.getValueByName(ETRow_IsVesselData).Boolean,
																theForm.tblInput1.getValueByName(ETRow_ForceSnapshot).Boolean); // ### TFS 50669 06AUG2021 NAVAB1
																
	elseif proxyExtWebService.isKindOf(CM_NavisMACS3Service) then	// 15 Mar 2021	navmd1 TFS 49052 MACS3 Vessel Library API
		proxyExtWebService.CM_NavisMACS3Service.setExtras(	theForm.tblInput1.getValueByName(ETRow_CreditWarning).Integer,
															theForm.tblInput1.getValueByName(ETRow_FeedID).String
															);
	elseif proxyExtWebService.isKindOf(CM_KiwiRailCheckInWSDef) then	//26 Aug 2021	NDL	TFS 51632
		proxyExtWebService.setProxyPw( theForm.enteredPassword2, CM_KiwiRailCheckInWSDef::messagePassword.name);	
		
	elseif proxyExtWebService.isKindOf(CM_1StopVBSWebServiceDef) then	// ### TFS 52268 17Dec2021 NAVPW1
		proxyExtWebService.CM_1StopVBSWebServiceDef.setExtras(	theForm.cmbTerminal.listObject.CM_Terminal,
																theForm.tblInput1.getValueByName(ETRow_BaseEndPointGateEvent).String,
																theForm.tblInput1.getValueByName(ETRow_ClientID).String,
																theForm.tblInput1.getValueByName(ETRow_SenderCode).String,
																theForm.tblInput1.getValueByName(ETRow_BaseEndPointSlots).String,
																theForm.tblInput1.getValueByName(ETRow_AuthKey).String,
																theForm.tblInput1.getValueByName(ETRow_CustomerId).String,
																theForm.tblInput1.getValueByName(ETRow_FacilityId).String	);
	elseif proxyExtWebService.isKindOf(CM_QshipsWebServiceDef) then
		//navra1 - TFS 59839 - 31 Aug 2023 - start
		proxyExtWebService.CM_QshipsWebServiceDef.setExtras(    theForm.tblInput1.getValueByName(ETRow_DomainName).String,	
															    theForm.tblInput1.getValueByName(ETRow_ServiceVersion).String,	
															    theForm.tblInput1.getValueByName(ETRow_ClientType).Integer,
																theForm.tblInput1.getValueByName(ETRow_LastSuccessfullTS).TimeStamp,
																theForm.cmbVesselType.listObject.HMS_VesselType,
																theForm.tblInput1.getValueByName(ETRow_QueryDaysAfterRT).Integer,
																theForm.tblInput1.getValueByName(ETRow_QueryHrsBeforeLSD).Integer);
		proxyExtWebService.setPassword(theForm.enteredPassword);
		//navra1 - TFS 59839 - 31 Aug 2023 - end
	// Start 15.12.2022 navmp20 TFS 55580
	elseif proxyExtWebService.isKindOf(CM_APIEndpointServiceDef) then
		//navra1 - TFS 58203 - 31 May 2023	
		realExtWebService := proxyExtWebService.pxyGetRealObject();
		if realExtWebService &lt;&gt; null then			
			origTenantId := realExtWebService.CM_APIEndpointServiceDef.tenantId;			
			origSubKeyValue := realExtWebService.CM_APIEndpointServiceDef.subscriptionKeyValue;			
			origClientSecret := realExtWebService.CM_APIEndpointServiceDef.clientSecret;			
		endif;

		clientSecretFromFrm		:= theForm.tblInput1.getValueByName(ETRow_ClientSecret).String;
		tenantIdFromFrm       	:= theForm.tblInput1.getValueByName(ETRow_TenantId).String;
		subKeyValueFromFrm    	:= theForm.tblInput1.getValueByName(ETRow_SubscriptionKeyValue).String;
		if clientSecretFromFrm &lt;&gt; '******' then
			origClientSecret := clientSecretFromFrm;
		endif;
		if tenantIdFromFrm &lt;&gt; '******' then
			origTenantId := tenantIdFromFrm;
		endif;
		if subKeyValueFromFrm &lt;&gt; '******' then
			origSubKeyValue := subKeyValueFromFrm;
		endif;
		//navra1 - TFS 58203 - 31 May 2023	
		
		grantType := theForm.tblInput1.getValueByName(ETRow_GrantType).String;	//TFS 63842
		if grantType = SOP_TableMaintForm.GT_ClientSecret then					//TFS 63842
			//origClientSecret	:= clientSecretFromFrm;							//TFS 63842 //TFS 65991
			proxyExtWebService.setPassword(null);								//TFS 63842
			proxyExtWebService.setUserCode(null);								//TFS 63842
		elseif grantType = SOP_TableMaintForm.GT_UserCode_Password then			//TFS 63842
			origClientSecret	:= null;										//TFS 63842
			proxyExtWebService.setPassword(theForm.enteredPassword);			//TFS 63842
		else																				//TFS 65991
			proxyExtWebService.setPassword(theForm.enteredPassword);						//TFS 65991
		endif;																	//TFS 63842
		
		proxyExtWebService.CM_APIEndpointServiceDef.setExtras(	theForm.tblInput1.getValueByName(ETRow_AuthKey).String,
																theForm.tblInput1.getValueByName(ETRow_ClientID).String,
																origClientSecret,														//navra1 - TFS 58203 - 31 May 2023	
																theForm.tblInput1.getValueByName(ETRow_ExportDetails).String,
																theForm.tblInput1.getValueByName(ETRow_Scope).String,
																theForm.tblInput1.getValueByName(ETRow_SubscriptionKeyName).String,
																origSubKeyValue,														//navra1 - TFS 58203 - 31 May 2023	
																origTenantId,															//navra1 - TFS 58203 - 31 May 2023
																theForm.tblInput1.getValueByName(ETRow_IsForCams).Boolean,
																theForm.tblInput1.getValueByName(ETRow_BaseAuthEndpoint).String,
																theForm.tblInput1.getValueByName(ETRow_OAuth2Version).Integer,
																theForm.tblInput1.getValueByName(ETRow_Resource).String,
																theForm.tblInput1.getValueByNameIfVisible(ETRow_Customer).String,  //04-Feb-2025 naviv1 MTN-12173
																theForm.cmbTerminal.listObject.CM_Terminal);										//navra1 - MTN-34782 - 15th July 2025
	
		if CM_AgGatewayServiceDef.hasInstance(proxyExtWebService) then
			proxyExtWebService.CM_AgGatewayServiceDef.setMsgRetentionPeriod(theForm.tblInput1.getValueByName(ETRow_AgMsgRetentionPeriod).Integer);
			proxyExtWebService.CM_AgGatewayServiceDef.setEWSHistoryRecording(theForm.tblInput1.getValueByName(ETRow_InboundEwsHistoryEnable).Boolean, theForm.tblInput1.getValueByName(ETRow_OutboundEwsHistoryEnable).Boolean);
		endif;
	// End 15.12.2022 navmp20 TFS 55580
		/*  replaced with Terminal Level Last Success TS                                  - MTN-36366
        // TFS 66034 allow last successful TS update
		if theForm.tblInput1.isRowVisible(ETRow_LastSuccessfullTS) then
			lastTS := theForm.tblInput1.getValueByName(ETRow_LastSuccessfullTS).TimeStamp;
			if lastTS &lt;&gt; null and lastTS.isValid() then  //MTN-33240
				proxyExtWebService.CM_APIEndpointServiceDef.setLastSuccessfulTS(lastTS);
			endif;
		endif;*/
	endif;
	
	eventType := theForm.cmbEventType.listObject.CM_EventType; // TFS 40360
	if eventType &lt;&gt; null then // TFS 40360 - only create mapping if user's chosen an Event Type
		create proxyMapping transient; // TFS 40360
		proxyMapping.setEventType(eventType); // TFS 40360
		proxyExtWebService.setMyEventMapping(proxyMapping); // TFS 40360
	endif;  // TFS 40360

	//25 Aug 2021	NDL	TFS 51632
/*	if theForm.enteredPassword.length &gt; 30 then
		msg := app.getErrorString2(ERR_STRING_TO_LONG, app.getErrorString(Password), '30');
		app.msgBox("External Web Service " &amp; msg, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif; */
	
	//proxyExtWebService.setPassword(theForm.enteredPassword);				//TFS 63842
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateExtWebService(proxyExtWebService, theForm.myCurrentObject.CM_ExternalWebServiceDef, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateExtWebService(proxyExtWebService, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, ' Invalid mode (' &amp; theForm.mode.String &amp; ')');
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog

	delete proxyMapping; // TFS 40360
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowEndpointForm" id="56496105-8240-4a63-ab71-5849b3a3a0a8">
        <source>doShowEndpointForm();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
// 24 Sep 2024 jlier1  TFS 65950: CR 65949 NSW | Dynamics Integration - External Web Service Definition Changes
vars
	form : SOP_EndPointDefForm;
	str : String;
	theForm : SOP_TableMaintForm;
	serviceType  	   		: Class;
	msg 		 	   		: String;
	webServiceDef : CM_ExternalWebServiceDef;
begin
	theForm := self.myForm; 
	if theForm.mode = theForm.Mode_Add then
		if theForm.myProxyObject = null then
			serviceType:=theForm.cmbWebServiceType.listObject.Class;
			if serviceType = null then
				msg := app.getErrorString1(Type_invalid, app.getErrorString(Type_GC));
				app.msgBox("External Web Service " &amp; msg, app.getErrorString(Error), MsgBox_OK_Only);
				return;
			endif;
			create theForm.myProxyObject as serviceType transient;	
		endif;
		webServiceDef:=theForm.myProxyObject.CM_ExternalWebServiceDef;
	elseif theForm.mode = theForm.Mode_Update then
		webServiceDef:=theForm.myProxyObject.CM_ExternalWebServiceDef;
		
	elseif  theForm.mode = theForm.Mode_View then 
		webServiceDef:=theForm.myCurrentObject.CM_ExternalWebServiceDef;
	
	endif;
	
	create form;
	
	form.setMyTerminal(self.myForm.myTerminal);

	form.myExternalWebServiceDef := webServiceDef;
	form.mode := self.myForm.mode;
	form.showModal();
	
	str:=webServiceDef.getEndpointsAsString();
	self.myForm.tblInput1.setCellText( self.myForm.tblInput1.row, 2, str );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowLastSuccDTForm" id="50c59ec9-843a-4a1c-8a07-8fbd3a40f7c6">
        <source>doShowLastSuccDTForm();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01.Dec.2025   navsp1      MTN-36362   NSW | OnePort API Last Run Date - Add a Last Successful Date/Time to Web Service Definition
vars
	form            : SOP_TermLastSuccessDTsForm;
	str             : String;
	theForm         : SOP_TableMaintForm;
	serviceType  	: Class;
	msg 		 	: String;
	webServiceDef   : CM_ExternalWebServiceDef;
begin
	theForm := self.myForm; 
	if theForm.mode = theForm.Mode_Add then
		if theForm.myProxyObject = null then
			serviceType:=theForm.cmbWebServiceType.listObject.Class;
			if serviceType = null then
				msg := app.getErrorString1(Type_invalid, app.getErrorString(Type_GC));
				app.msgBox("External Web Service " &amp; msg, app.getErrorString(Error), MsgBox_OK_Only);
				return;
			endif;
			create theForm.myProxyObject as serviceType transient;	
		endif;
		webServiceDef:=theForm.myProxyObject.CM_ExternalWebServiceDef;
	elseif theForm.mode = theForm.Mode_Update then
		webServiceDef:=theForm.myProxyObject.CM_ExternalWebServiceDef;
		
	elseif  theForm.mode = theForm.Mode_View then 
		webServiceDef:=theForm.myCurrentObject.CM_ExternalWebServiceDef;
	
	endif;
	
	create form;
	
	form.setMyTerminal(self.myForm.myTerminal);

	form.myExternalWebServiceDef := webServiceDef;
	form.mode := self.myForm.mode;
	form.showModal();
	
	str:=webServiceDef.getTerminalLastSuccDTAsString();//getEndpointsAsString();
	self.myForm.tblInput1.setCellText( self.myForm.tblInput1.row, 2, str );
epilog

end;</source>
