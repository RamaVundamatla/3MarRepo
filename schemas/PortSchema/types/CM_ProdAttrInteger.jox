epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="cd6540a1-4c1e-4db8-896b-7c0741f1542c">
        <updating/>
        <source>initialize(_name: String; _displayName: String) updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 07/03/2014	cnwdap1		PAR #33661 Set myMeasurementType if necessary
vars

begin
	inheritMethod(_name, _displayName);
	
	if _name = ETRow_MyDensity then
		self.myMeasurementType := app.getDefaultMeasurementForType(Type_Density);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_displayName" type="String"/>
    </JadeMethod>
    <JadeMethod name="multiplyValue" id="565d0015-de21-4619-8365-c61812ffbfce">
        <source>multiplyValue(_value: Decimal): Decimal;
// ---------------------------------------------------------------------------
// Created:     05 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	result			: Decimal[16,4];
begin
	result := _value * self.multiplier;
	if result mod 1 =0 then
		return result.Integer;
	else
		return result;	
	endif;
end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="parseAndAssignRange" id="9559a06c-4b6b-4eac-bb15-b7be01f933a7">
        <updating/>
        <source>parseAndAssignRange(_range : String)  : String updating;
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     Takes a string of format 'xxx-xxx', chops it up , and assigns
//				the results to min and max values. 
//				
//
// ----------   ----------  --------------------------------------------------
vars
	rangeStrArray		: StringArray;
begin
	
	rangeStrArray := _range.getTokens;
	if rangeStrArray.size &lt;= 1 then
		return 'Format does not equal "[number]:[number]"';
	endif;
		
	self.minValue := rangeStrArray[1].Integer;	
	self.maxValue := rangeStrArray[2].Integer;
	if self.minValue &gt; self.maxValue then
		return 'The minimum value specified is greater than the maximum';
	endif;
	//validate that the value is within the range specified
	if self.minValue &lt;&gt; null and self.maxValue &lt;&gt; null then
		if self.value &lt; self.minValue then
			return 'The value specified is less than the range minimum';
		elseif self.value &gt; self.maxValue then
			return 'The value specified is greater than the range maximum';
		endif;
	endif;
	
epilog
	delete rangeStrArray;
end;</source>
        <Parameter name="_range" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4c531942-361c-4963-a77b-0c5034fbdc44">
        <updating/>
        <source>setForUpdate(_pxyAttr: CM_ProdAttrInteger) updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_pxyAttr);
	//should have EITHER range OR value
	//should have EITHER range OR value
	if _pxyAttr.validationType = ValidationType_Value then
		self.value		:= _pxyAttr.value;
		self.multiplier := _pxyAttr.multiplier;
		self.minValue 	:= _pxyAttr.minValue;	
		self.maxValue 	:= _pxyAttr.maxValue;	
	endif;
	
end;</source>
        <Parameter name="_pxyAttr" type="CM_ProdAttrInteger"/>
    </JadeMethod>
