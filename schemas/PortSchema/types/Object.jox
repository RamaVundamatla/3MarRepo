    <JadeMethod name="whereAmI" id="2eb71b3f-93f3-40d2-b7f8-7ad35dc6b628">
        <source>whereAmI( _short : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2010	cnwndl1	Initial creation


	Add this line to a 'create' method for a class when you are hunting
	for where transient leaks being created in Unit tests, or what is calling certain events...
	
	
*/

vars

	callStack    : ProcessStackArray;
	methCallDesc : MethodCallDesc;
	index : Integer;
	outputString : String;

begin

	executeWhen JMTDevelopmentEnvironment;
	
	app.hideDebug := false;

	process.isNDLref;  process.isNavdap1;
	
	create callStack transient;
	process.currentStack(callStack);
	
	if _short then
		index := 0;
		foreach methCallDesc in callStack do
			index := index + 1;
			if index &lt; 4 then
				continue;
			endif;
			outputString := outputString &amp; ", " &amp; methCallDesc.display;
			if index &gt; 6 then
				break;
			endif;
		endforeach;
		app.writeStatement("&gt;&gt;&gt;&gt;---- " &amp; self.String &amp; outputString);
//write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' '&amp;self.String&amp; outputString;
	else
		app.writeStatement("&gt;&gt;&gt;&gt;--------------");
		app.writeStatement(self.String);
		foreach methCallDesc in callStack do
			app.writeStatement( methCallDesc.display);
		endforeach;
		app.writeStatement("--------------&lt;&lt;&lt;&lt;");
	endif;
	
	endExecuteWhen;

epilog

	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDisplayStringExHandler" id="82fa795b-78b8-4c94-9d51-0491ebeec34a">
        <source>zDisplayStringExHandler(exObj : Exception; obj : Object io) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2024   annamth     CR 61540: MTN - [POC - Phase 1] - Enhancing Query Performance through Multi-Process

*/

constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
	ObjectNull		: Integer = 1090;

vars 
	msg : String;
	errorObj : Object;
begin

	if exObj.errorCode = ObjectNotFound or
	   exObj.errorCode = ObjectDeleted or 
	   exObj.errorCode = ObjectNull then
		
	   //08 Apr 2016	NDL	- extra logging for data display so items don't go missing...
	   errorObj := exObj.errorObject;
	   if errorObj &lt;&gt; null and errorObj &lt;&gt; obj then
			app.cnStartTransaction( method.qualifiedName );
			app.cnEndTransaction();
			msg := method.qualifiedName &amp; ", Data display exception " &amp; exObj.errorCode.String;
			app.writeLog(msg, LogERROR);	
			if obj &lt;&gt; null then
				msg := obj.String &amp; " was trying to display data about " &amp; errorObj.String;
				app.writeLog(msg, LogERROR);	
			endif;
	   endif;
	   
		//obj := null;
		return Ex_Resume_Next;
	endif;

	
	return Ex_Pass_Back;
	
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="obj" type="Object" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
