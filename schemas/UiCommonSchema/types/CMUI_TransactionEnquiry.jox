    <JadeMethod name="doDelete" id="e9acd0a9-affd-47c2-b42a-fab98a88c56d">
        <updating/>
        <source>doDelete() protected, updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	count			: Integer;
	msg1,
	msg2			: String;
	txn				: CM_TITransaction;
	obj				: Object;
	oa				: ObjectArray;
	transactions	: ObjectArray;
	strTrans		: String;
	inputBox		: CMUI_InputBox;
	reason			: String;
begin
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries, only CM_TITransaction has a delete capability, not event or HMS transactions
	if self.mode &lt;&gt; self.Mode_Cargo_Transaction_Enquiry and
	   self.mode &lt;&gt; self.Mode_CargoItem_Enquiry then
		return;
	endif;

	create oa transient;
	if self.mode = self.Mode_CargoItem_Enquiry then
		self.tblTrans.allSelectedObjects.copy(oa);
	else
		self.tblTransactions.allSelectedObjects.copy(oa);
	endif;
	// filter out already deleted transactions
	create transactions transient;
	foreach obj in oa do
		txn := obj.CM_TITransaction;
		if not txn.deleted then
			transactions.add(txn);
		endif;
	endforeach;

	if transactions.size &lt; 1 then					//+cnwml2 PAR23495
		app.msgBox('Please select a transaction to delete', app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	else
		foreach obj in transactions do				//+cnwml2 PAR23495
			txn := obj.CM_TITransaction;
	
			if txn.myTrackedItem &lt;&gt; null and
			   txn.myTrackedItem.myTerminal &lt;&gt; self.myTerminal then
				app.msgBox('You cannot delete this transaction from this terminal.', self.caption, MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
			
			count := count + 1;
			if count = 1 then
				strTrans := "'" &amp; txn.typeString &amp; "'";
			endif;
		endforeach;
			
		// show transaction type for single delete, show count for multiple
		if count = 1 then
			msg1 := app.getErrorString(Transaction);
			msg2 := strTrans;
		else
			msg1 := count.asStringJMT();
			msg2 := app.getErrorString(Transactions);
		endif;
		if (not app.msgBox(app.getErrorString2(ConfirmDelete, msg1, msg2), app.getErrorString(Confirm_Delete), MsgBox_OK_Cancel) = MB_OK) then
			return;
		endif;
		
		create inputBox transient;		// 12/10/18 MAP TFS41191
		inputBox.init(app.getErrorString(Reason), null,
						'', 30, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, true);
		inputBox.myTerminal := self.myTerminal;
		inputBox.showModal;
	
		if inputBox.modalResult &lt;&gt; IDOK then
			return;
		endif;
		reason := inputBox.txtInput.text.String;

		foreach obj in transactions do			//+cnwml2 PAR23495
			txn := obj.CM_TITransaction;
			app.myTrxDA.trxDeleteTITransaction(txn, reason, app.myPassport);
		endforeach;
		
		if not app.myPassport.trxCompletedOK then
			app.showErrorsAsMsgBox(app.myPassport.allErrors, false);
			return;
		endif;
		
		if self.mode = self.Mode_CargoItem_Enquiry then
			self.initTblTrans();
			self.showTransactions();
		endif;
	endif;
epilog
	delete oa;
	delete transactions;
	delete inputBox;
end;</source>
        <access>protected</access>
    </JadeMethod>
