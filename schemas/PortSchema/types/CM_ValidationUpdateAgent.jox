    <JadeMethod name="valRTTaskFindTrackedItem" id="0c863782-e101-456f-b838-9369c488ae7e">
        <source>valRTTaskFindTrackedItem(_tiId : String; _task : CM_RTQueueTask input; _terminal : CM_Terminal input ) : CM_TrackedItem;
/*

Date		Who		Reason
10 May 2017	cnwer1	Initial creation TFS 995 moved from MobileServerSchema::CM_ValidationRTAgentvalFindTrackedItem
17 May 2022 navds20 TFS 53504 EUP - Cargo Uniqueness - PortSchema
02 May 2023	jlizm1	TFS 55453 Cargo uniqueness by subtype
*/

vars

	tiId			: String;
	ti				: CM_TrackedItem;
	matches			: Integer;
	cargoTypeInt : Integer;
	lc  		,
	sourceLocation : CM_LocationsController;
	invalidTask : Boolean;
	edition : Integer;
	
begin

	tiId := _tiId.toUpper().trimRight();
	
	if tiId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ID ', null, null);
		app.raiseCMException(Input_required_field_Id, null, null); // cnwdb2	PAR 35364

		return null;
	endif;
	
	//19 Jan 2016	NDL	Par 37433
	on Exception do app.handleDeletedObject( exception, _task, invalidTask );
	if _task &lt;&gt; null then
		edition := _task.edition;
	endif;
	
	//17 Nov 2014	NDL	Par 35210
	//if _task &lt;&gt; null and _task.taskType = TASK_DIRECTOR then
	if not invalidTask and _task &lt;&gt; null and _task.taskType = TASK_DIRECTOR then	//19 Jan 2016	NDL	Par 37433
		
		sourceLocation := _task.getSourceLocation;
		cargoTypeInt := _task.getRequestCargoType;
		
		if cargoTypeInt &lt; 1 then
			cargoTypeInt := TI_CargoType_Container; //default behaviour
		endif;
		
		if sourceLocation &lt;&gt; null then
			//epr TFS 6863 14/9/17 
			if sourceLocation.isGridLocation then
				foreach lc in sourceLocation.myTerminalArea.allLocationsControllers  discreteLock do
					ti:=lc.allTrackedItemsById.lookupTIUsingIDExact(_tiId);
					if ti &lt;&gt; null then
						break;
					endif;
				endforeach;
			else
			
				ti := sourceLocation.searchForOnsiteTI(tiId, matches, cargoTypeInt, null, null, null); // 17/05/2022 navds20  TFS 53504  //03.Nov.2023 navsp TFS 61067
			endif;
		else
			ti := _terminal.searchForOnsiteTI(tiId, matches, cargoTypeInt);
		endif;
		
	else
		// Par 11477
		ti := _terminal.searchForOnsiteTI(tiId, matches, TI_CargoType_Container);
		
	endif;
	
	//29 May 2012	NDL	Par 29641
	if ti = null and matches = 0 then
		ti := _terminal.searchForOnsiteTI(tiId, matches, null);
	endif;
	
	if matches &gt; 1 then
		app.raiseCMException1(ERR_MULTIPLE_ITEMS, matches.String, null, null);
		return null;
	endif;
	
	if ti = null then
		app.raiseCMException1(Err_TrackedItemsNotFound, tiId, null, null);
		return null;
	endif;
	
	return ti;

epilog

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="valRTTaskForCranePickup" id="c12120d3-935c-4930-9fd7-d7c4ca5f9c7f">
        <source>valRTTaskForCranePickup(	_rtQueueTask : CM_RTQueueTask;	
							_ti : CM_TrackedItem;
							_machine : CM_Machine);
/*

Date		Who		Reason
10 May 2017	cnwer1	Initial creation TFS 995 VMT Refactor moved from MobileServerSchema::CM_ValidationRTAgent valRTQueueTaskForCranePickup
29 May 2017	cnwma1 	TFS #4310 75664 error when using Lander App
*/

vars
	alert 			: CM_SystemAlert;
	alertsArray 	: StringArray512;
	messageLogger 	: CM_MachineRTQueueEntryLogger;
	currentLocation			: CM_LocationsController;
	nwnp		: Boolean;
begin
	// Test the task's job (is it a pickup!)
	if not _rtQueueTask.myEntry.myJob.isKindOf(CM_VoyageJob) then
		// Error! Not a voyage Job
		create alert;
		alert.details := app.getErrorString2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks,  app.getErrorString(NoCompatibleJobFound)); //29/05/2017 cnwma1 TFS #4310
		alert.setSeverity(SEVERE_INFO);
		alert.add;
				
		app.raiseCMException2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks, app.getErrorString(NoCompatibleJobFound), null, null); //29/05/2017 cnwma1 TFS #4310
		return;
	endif;

	if _rtQueueTask.taskType &lt;&gt; TASK_PICKUP  and _rtQueueTask.taskType &lt;&gt; TASK_BREAKBULK then
		// Error! Not a pickup task!
		create alert;
		alert.details := app.getErrorString2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks, "No pickup task");
		alert.setSeverity(SEVERE_INFO);
		alert.add;
		
		app.raiseCMException2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks, "No pickup task", null, null);
		return;
	endif;

	create messageLogger transient;
	messageLogger.myMachine:=_machine;
	if not _rtQueueTask.queryMachineAssign(_machine, false, false,false,true,true, messageLogger) then
		// Error! Machine cannot pickup
		create alert;
		alert.details := app.getErrorString2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks, "Machine unsuitable");
		alert.setSeverity(SEVERE_INFO);
		alert.addLogEntry(messageLogger.allMessages.concatenate(","));
		alert.add;
		
		app.raiseCMException2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks, "Machine unsuitable", null, null);
		return;
	endif;

	currentLocation := _ti.getPrimaryLocation(REAL_MODE);
	nwnp:=currentLocation.canBeDischargedNWNP();
	// Is the job "released" to ops?
	if _rtQueueTask.myEntry.myJob.isKindOf(CM_VoyageJob) and not nwnp then
		if (not _rtQueueTask.myEntry.myJob.CM_VoyageJob.isLoadedToOperations) then
			// Job is not loaded to ops, therefore its not "workable"
			create alert;
			alert.details := app.getErrorString2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks &amp; " in Disch Job " &amp; _rtQueueTask.myEntry.myJob.jobId, "Job NOT LOADED.");
			alert.setSeverity(SEVERE_INFO);
			alert.add;
		
			app.raiseCMException2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks &amp; " in Disch Job " &amp; _rtQueueTask.myEntry.myJob.jobId, "Job NOT LOADED.", null, null);
			return;
		endif;
	endif;

	
epilog
	delete messageLogger;
	

end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
