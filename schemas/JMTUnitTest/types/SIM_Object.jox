    <JadeMethod name="logMessage" id="25a4046c-bbe0-4c01-990b-77a8e3c63ed7">
        <source>logMessage(_level: Integer; _message: String);

vars

begin
	if self.mySIMTerminal.logLevel = LOG_NONE then
		return;
	endif;
	
	if _level &lt;= self.mySIMTerminal.logLevel then
		self.dsl.logMessageNow("".padBlanks(_level - 1) &amp; _message);
	endif;
epilog

end;</source>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
