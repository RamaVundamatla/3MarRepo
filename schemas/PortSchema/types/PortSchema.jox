    <JadeMethod name="fileExceptionHandler" id="c40bb00b-33f6-49dc-8f06-a0b8f867541a">
        <source>fileExceptionHandler(exObj: Exception): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwrd1	Initial creation

*/



vars
	errorText: String;
begin

	errorText := app.getErrorString2( FileOpenError, exObj.FileException.file.fileName , errorText &amp; Lf &amp; exObj.text &amp; Lf);

	//errorText := "Opening file: '" &amp; exObj.FileException.file.fileName &amp; "' caused error";
	//errorText := errorText &amp; Lf &amp; exObj.text &amp; Lf &amp; "    Aborting Export Operation!";
	
	app.msgBox(errorText, "File Open Error",
		MsgBox_OK_Only  + MsgBox_System_Modal + MsgBox_Exclamation_Mark_Icon);

	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;

	return Ex_Abort_Action;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fileExceptionWriteError" id="eaebf165-7abc-4cb4-873c-fcfd18e6bb60">
        <source>fileExceptionWriteError(exObj: Exception; _passport : CM_Passport input): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2019	jlgndl1	Initial creation	TFS 47781

*/

vars

	extendedText : String;
	currentMethodDesc : String;
	reportingMethodDesc : String;
	fileName : String;
	
	logText : String;

begin

	if not exObj.isKindOf(FileException) then
		return Ex_Pass_Back;
	endif;
	
	extendedText := exObj.extendedErrorText;
	currentMethodDesc := exObj.currentMethodDesc.getName;
	reportingMethodDesc:= exObj.reportingMethodDesc.getName;
	if exObj.FileException.file &lt;&gt; null then
		fileName := exObj.FileException.file.fileName;
	endif;
	
	if extendedText &lt;&gt; null then
		logText := 'Error : ' &amp; exObj.errorCode.String &amp; ', ' &amp;extendedText;
	else
		logText := 'Error : ' &amp; exObj.errorCode.String &amp; ', File IO Error';
	endif;
	
	if fileName &lt;&gt; null then
		logText := logText &amp; ', "' &amp; fileName &amp; '"';
	endif;
	if currentMethodDesc &lt;&gt; null then
		logText := logText &amp; ", method = " &amp; currentMethodDesc;
	endif;
	if reportingMethodDesc &lt;&gt; null then
		logText := logText &amp; ", reported by = " &amp; reportingMethodDesc;
	endif;
	
	app.writeLog(logText, LogINFO);
	
	if _passport &lt;&gt; null then
		_passport.addErrorFull(exObj.errorCode, logText, null, null, null);
	endif;
	
	if exObj.resumable then
		return Ex_Resume_Next;
	endif;
	
	abortTransaction;
	
	return Ex_Abort_Action;
	
epilog

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
