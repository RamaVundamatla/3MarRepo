    <JadeMethod name="setPxyEDITIFromTable" id="6c0a52c4-0c90-46e7-8be0-f3cfd9861690">
        <source>setPxyEDITIFromTable(_ediTi: CM_EDITrackedItem input; 
						_table : CM_DataTable input;
						_tableRow: Integer) protected;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//  parameter _table added 29.9.09 cnwgb1 for MES 1011 PAR 20320
//----------------------------------------------------------------
// 30 Apr 2012	cnwrs1	Parxxxx - get  CM_EDIPortTI Tranship Port Codes working for updates from GUI
// 26/09/2012	cnwcs5	par 30426 - save remarks to description property
// 27/11/2013	cnwdap1	PAR #33019 CCMS DPH 2285 New BOL Fields
// 14/03/2014	cnwmh5	#33648 - Include setting of imCodes if no imCode property
// 09/09/2015   cnwma1      PAR #36797 Can't create BOL via EDI
//16 Nov 2015	cnwrs1 	Par 36790 unable to update some fields
//17 Nov 2015   cnwma1  PAR #37167 17/11/2015 cnwma1 PAR #37167
// 14 Sep 2016 cnwer1	TFS 2602 copied form EDI_Form so could reuse on Edi comparison
// 16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
// 09/10/2017	jlgdap1	TFS 7204 STWR Correct real handling for non-standard locales

vars
	row			: Integer;
	col			: Integer;
	prop		: Property;
	etRow		: EntTableRow;
	columnName, 
	value		: String;
	cargoType	: CM_CargoType;	
begin
	row	:= _tableRow;

	foreach etRow in _table.allTblDataEntRows do
		columnName := etRow.name;
		
//		if columnName = ETRow_TranshipPortCodes  then 
//			prop := _ediTi.class.getPropertyInHTree(CM_EDIPortTI::allTranshipPortCodes.name);
			
//		elseif columnName = ETRow_Remarks and _ediTi.isKindOf (CM_EDILayoutTI) then	// par 30426
			// remarks are stored in the description property
//			prop := CM_EDILayoutTI::description;
			
//		else
			prop := _ediTi.getPropertyFromColumnName(columnName);
//		endif;
		
		if prop = null then
			col	:= _table.getColumnByRowName(columnName);
			value := _table.accessCell(row, col).text;
			_ediTi.setPropertyByName(columnName, value);
/*			if columnName = ETRow_ImportReleasePIN then 							//cnwgb1 PAR 21881 11.12.2009
				_ediTi.setOperatorImportReleasePIN(value);
			elseif columnName = ETRow_TotalWeight then								//+cnwml2 PAR22485
				_ediTi.setPropertyValue(ETRow_Weight, value.Decimal);
			elseif columnName = ETRow_ClientRef1 then								// PAR #33019
				_ediTi.CM_EDIBOLHdrTI.setServiceOrderNbr(value);					// PAR #33019
			elseif columnName = ETRow_ClientRef2 then								// PAR #33019
				_ediTi.CM_EDIBOLHdrTI.setPONbr(value);								// PAR #33019
			elseif columnName = ETRow_Vehicle then									// PAR #36797
				_ediTi.CM_EDIBOLHdrTI.setVehicle(value);							// PAR #36797
			elseif columnName = ETRow_SalesOrderNbr then							// PAR #33019
				_ediTi.CM_EDICargoTI.setSalesOrderNbr(value);						// PAR #33019
			elseif columnName = ETRow_ImCodes or columnName = ETRow_Hazardous or columnName = ETRow_Hazards then		// 14/03/2014 cnwmh5 #33648
				_ediTi.setImCodes(value);
			//cnwmc5 - 4 September 2014 - PAR 34533
			elseif columnName.isMeasurementType() then
				_ediTi.setMeasurementTypeValue(columnName, value);
			//13 Aug 2015	NDL	Par 36608
			elseif columnName = ETRow_Action and _ediTi.isKindOf(CM_EDICargoGroupAssign) then
				_ediTi.CM_EDICargoGroupAssign.messageMode := value;
			//13 Aug 2015	NDL	Par 36608	
			elseif columnName = ETRow_CargoIds and _ediTi.isKindOf(CM_EDICargoGroupAssign) then
				_ediTi.CM_EDICargoGroupAssign.setCargoIdsFromString(value);
			//13 Aug 2015	NDL	Par 36608
			elseif columnName = ETRow_AssignedCargoIds and _ediTi.isKindOf(CM_EDICargoGroupNotified) then
				_ediTi.CM_EDICargoGroupNotified.setAssignedCargoIdsFromString(value);
			//13 Aug 2015	NDL	Par 36608
			elseif columnName = ETRow_LocationId and _ediTi.isKindOf(CM_EDICargoGroupNotified) then
				_ediTi.CM_EDICargoGroupNotified.defaultLocation := value;
			//17 Sep 2015	NDL	Par 36906	
			elseif columnName = ETRow_CargoIds and _ediTi.isKindOf(CM_EDIMultiMoveGroup) then
				value := value.toUpper;
				_ediTi.CM_EDIMultiMoveGroup.setCargoIdsFromString(value);
			elseif columnName = ETRow_ContainerID and _ediTi.isKindOf(CM_EDIBookingItemTI) then
				value := value.toUpper;
				_ediTi.CM_EDIBookingItemTI.cargoId:=value;
			elseif columnName = ETRow_IsCertifiedWeight and _ediTi.isKindOf(CM_EDIBookingItemTI) then
				_ediTi.CM_EDIBookingItemTI.isVerifiedWeight := value.asBooleanJMT;
			elseif columnName = ETRow_ParentCargoID and _ediTi.isEDIHazDetails then	//18 Nov 2016	NDL	TFS 2843 / 2604
				value := value.toUpper;
				_ediTi.CM_EDIHazDetailsTI.id := value;
			// 16/01/2017 cnwma1 TFS #2885
			elseif columnName = ETRow_SealNum and _ediTi.isKindOf(CM_EDIStopTI) then
				_ediTi.CM_EDIStopTI.setTISealNumOperator(value);
			// 16/01/2017 cnwma1 TFS #2885
			else
				continue;	
			endif;*/
		else
			col	:= _table.getColumnByRowName(columnName);
			col := col + _table.fixedColumns;
			value := _table.accessCell(row, col).text;
/*			if prop.name = ETRow_ImCodes or prop.name = ETRow_Hazardous or prop.name = ETRow_Hazards then		//cnwmc5 - 8 Jan 2014 - PAR 31984
				_ediTi.setImCodes(value);
			elseif prop.name = CM_EDIPortTI::allTranshipPortCodes.name then //cnwrs1 CCMS 1137 01 July 2010
				_ediTi.setTranshipPortCodes(value);
			elseif prop.name = ETRow_Status then
				//allow a change to unprocessed state - only set for CusRes
				if value.String = "0" then
					_ediTi.setStatus(CM_EDIFile.EDI_STATUS_UNPROCESSED);
				endif;
			elseif prop.name = ETRow_DischargePorts then
				_ediTi.setOptDischargePorts(value);
			elseif prop.name = ETRow_CooledType then
				_ediTi.setCooledType(value);
			elseif prop.name = ETRow_OutOfGauge then
				if value.trimBlanks.toUpper = "YES" then
					_ediTi.setPropertyValue(prop.name, true);
				else
					_ediTi.setPropertyValue(prop.name, false);
				endif;	
			elseif prop.name = ETRow_Temperature then
				if value.trimBlanks = null then
					value := NULL_TEMPERATURE.String;
				endif;
				_ediTi.setPropertyValue(prop.name, value.Real);	
			elseif prop.name = ETRow_Vent then //par18451 nov 2008 cnwrs1
				if value.trimBlanks = null then
					value := NULL_VENTILATION.String;
				endif;
				_ediTi.setPropertyValue(prop.name, value.Decimal);	//par19252 cnwrs1 may 2009
			elseif prop.name = ETRow_CarbonDioxide or prop.name = ETRow_Oxygen or prop.name = ETRow_Humidity then //par18451 nov 2008 cnwrs1
				if value.trimBlanks = null then
					value := NULL_INTEGER.String;
				endif;
				_ediTi.setPropertyValue(prop.name, value.Integer);
			//17/11/2015 cnwma1 PAR #37167 
			elseif prop.name = ETRow_TimeAllowedOffPower then 
				if value.trimBlanks = null then
					value := NULL_ALLOWABLE_TIME_OFF_POWER.String;
				endif;
				_ediTi.setPropertyValue(prop.name, value.Decimal);	
			elseif prop.name = ETRow_PackTempC then 
				if value.trimBlanks = null then
					value := NULL_TEMPERATURE.String;
				endif;
				_ediTi.setPropertyValue(prop.name, value.Real);	
			elseif prop.name = ETRow_PackTempF then 
				if value.trimBlanks = null then
					value :=app.temperatureConversion(true, NULL_TEMPERATURE).String; 
				endif;
				_ediTi.setPropertyValue(prop.name, value.Real);
			elseif prop.name = ETRow_PackTime then 
				if value.trimBlanks = null then
					value := NULL_TIME.String;
				endif;
				_ediTi.setPropertyValue(prop.name, value.Time);	
			//17/11/2015 cnwma1 PAR #37167 
			elseif (prop.name = ETRow_LocationId or prop.name = ETRow_StowageId) then
				//must be saved as a 7 digit stowage id (displayed as 6)
				if value = null or (value.isInteger and value.Integer = 0) then
					_ediTi.setLocationId("");
				else
					//th2 removed padding of zeros here - this must be done in the subclasses to which it pertains
					_ediTi.setLocationId(value);	
				endif;
			elseif (prop.name = ETRow_NewStowageId) then	//PAR 19333. June 2009
				//must be saved as a 7 digit new stowage id (displayed as 6)
				if value = null or (value.isInteger and value.Integer = 0) then
					_ediTi.setNewStowageId("");
				else
					_ediTi.setNewStowageId(value);	
				endif;
			elseif prop.name = ETRow_CargoTypeDescr then
				// attempt to match the edited data to either the cargo type abbreviation or the description.
				cargoType	:= app.myRoot.getCargoTypeFromAbbrevOrDescr(value);
				if cargoType = null then
					// not found - so set the screen value as the incorrect one.
					_ediTi.setPropertyValue(ETRow_CargoType, null);
					_ediTi.setPropertyValue(ETRow_CargoTypeDescr, value[1 : CM_CargoType::description.getLengthForString]);
				else
					_ediTi.setPropertyValue(ETRow_CargoType, cargoType.id);
					_ediTi.setPropertyValue(ETRow_CargoTypeDescr, cargoType.description);	// in case abbreviation entered.
				endif;
			elseif prop.name = ETRow_IsWaterCooled then
				if value.trimBlanks.toUpper = "YES" then
					_ediTi.setCooledType("W");
				else
					_ediTi.setCooledType("X");
				endif;
			elseif prop.name = ETRow_FullOrMT then  //par 18411
				_ediTi.setPropertyValue(prop.name, value.trimBlanks[1:1]);
			elseif prop.name = ETRow_WagonSeals then	//13 Mar 2015	NDL	Par 35828
				_ediTi.setWagonSeals(value);
			elseif prop.name = ETRow_CreatedTime then //PAR22850 Prevents an attempt to change the date a file was loaded.  Should never allow a change to created time to occur.  cnwsh3 8/3/2010.
				continue;
			//cnwmc5 - 23 Jan 2014 - PAR 33001
			elseif prop.name = ETRow_OverHeight 
			or prop.name = ETRow_OverLengthFront
			or prop.name = ETRow_OverLengthBack 
			or prop.name = ETRow_OverWidthLeft 
			or prop.name = ETRow_OverWidthRight then
				if value.trimBlanks = null then
					value := NULL_INTEGER.String;
				endif;
				_ediTi.setPropertyValue(prop.name, value.Decimal);*/
			if _ediTi.setPropertyByName(prop.name, value) then
			else
				if prop.type = Integer then
					_ediTi.setPropertyValue(prop.name, value.Integer);	
				elseif prop.type = String then
					// cnwrs1 mar 2006 par 10949
					if prop.getLength() &gt; 2 then	//maximum returns as -1
						_ediTi.setPropertyValue(prop.name, value[1:prop.getLength()-1].trimBlanks);	
					else
						_ediTi.setPropertyValue(prop.name, value.trimBlanks);	
					endif;
				elseif prop.type = Decimal then
					_ediTi.setPropertyValue(prop.name, value.Decimal);	
				elseif prop.type = Real then
					//_ediTi.setPropertyValue(prop.name, value.Real);					// TFS 7204
					_ediTi.setPropertyValue(prop.name, value.asRealJMT);				// TFS 7204
				elseif prop.type = Boolean then
					_ediTi.setPropertyValue(prop.name, value.asBooleanJMT);	// AER 20/06/2008  Par 17155
				elseif prop.type = Date then			// cnwrl1 09/09/2009 PAR 20320 - MES 1011 New Messina Messages
					_ediTi.setPropertyValue(prop.name, value.asDateJMT);
				elseif prop.type = TimeStamp then		// cnwrl1 09/09/2009 PAR 20320 - MES 1011 New Messina Messages
					_ediTi.setPropertyValue(prop.name, value.asTimeStampJMT);
				elseif prop.type = Time then
					_ediTi.setPropertyValue(prop.name, value.asTimeJMT);
				else
//					write class.name&amp;'::'&amp;method.name&amp;' ';
				endif;
			endif;
		endif;
		prop := null;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_ediTi" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_tableRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showEDIForm" id="bf84a6c0-3085-48cc-bd1c-58add8cfd16f">
        <source>showEDIForm(_object :CM_EDIData; _masterMenuAction : CMUI_MenuAction;_thumbnailOnly, _doEdit:Boolean):CMUI_EDIForm;
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form		: CMUI_EDIForm;
	menuAction	: CMUI_MenuAction;
begin
	menuAction := app.myController.createMenuAction(PmAdmEdiopersView, _object, _masterMenuAction, self.myTerminal);
	
	if menuAction = null then
		return null;
	endif;
	
	form := menuAction.goToObject(null, null, false, null).CMUI_EDIForm;
	
	if form = null then
		return null;
	endif;

	if _object &lt;&gt; null then
		form.showWithObject(_object, _thumbnailOnly, _doEdit);
	else
		form.show();
	endif;

	return form;
end;</source>
        <Parameter name="_object" type="CM_EDIData"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
        <ReturnType type="CMUI_EDIForm"/>
    </JadeMethod>
    <JadeMethod name="showEDIFormWithColl" id="138607cb-dcad-4019-b9e2-71cfe48f81f8">
        <source>showEDIFormWithColl(_coll :ObjectArray input; _masterMenuAction : CMUI_MenuAction; _doEdit :Boolean):CMUI_EDIForm;
// ---------------------------------------------------------------------------
// Created:     09 September 2010 by cnwcs5
// Purpose:     Show EDI form with a collection of CM_EDIData of type
//				Custom Stops or Operator Stops
// Parameters:  _coll
//				_masterMenuAction
//				
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form		: CMUI_EDIForm;
begin
	
	//epr par 37090 2/11/15
	if self.isCollectionOfStopTypeEDIData(_coll) then
		form := app.loadForm (CMUI_EDIForm_TIMaint, CMUI_Assistant, false, false, false, self.myTerminal, _masterMenuAction).CMUI_EDIForm;
	else
		form := app.loadForm (CMUI_EDIForm, CMUI_Assistant, false, false, false, self.myTerminal, _masterMenuAction).CMUI_EDIForm;
	endif;
	if form = null then 
		return null;
	endif;

	if _coll &lt;&gt; null then
		form.showWithCollection(_coll, _doEdit);
	else
		form.show();
	endif;

	return form;
end;</source>
        <Parameter name="_coll" type="ObjectArray" usage="input"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_doEdit" type="Boolean"/>
        <ReturnType type="CMUI_EDIForm"/>
    </JadeMethod>
    <JadeMethod name="showVerifyError" id="590125a4-256a-4121-886c-64e5aedff876">
        <source>showVerifyError(_table 				: CM_DataTable input; 
				_obj 				: Object;
				_warningOnly 		: Boolean;
				_hideWarnings 		: Boolean;
				_fieldName, 	
				_msg 				: String;
				_colorController	: CM_ColorController) protected;
/*
Date		Who		Reason
07 Aug 2012	cnwcs5	Initial creation - par 30136
14 sep 2016 cnwer1	TFS 2606 
*/
vars
	text			: String;
	gotException	: Boolean;
	idx, 
	colour			: Integer;
begin
	on Exception do app.handleDeletedObject (exception, _obj, gotException);	 
	
	if _obj &lt;&gt; null then
		if _obj.isKindOf(CM_EDITrackedItem) then
			text := _obj.CM_EDITrackedItem.getErrorID() &amp; Tab;
			
		elseif _obj.isKindOf(CM_EDIDataBayPlan) then
			text := _obj.CM_EDIDataBayPlan.voyageCode   &amp; Tab;
			
		elseif _obj.edition &gt;= 0 then				// will cause exception if invalid object
			text := "See error text." &amp; Tab;		//par 27385 cnwrs1 12 April 2011
		endif;
	endif;
	// if obj is invalid we we end up here
	if gotException or _obj = null then			
		text 			:= "See error text." &amp; Tab;
	endif;
		
	if not _warningOnly then
		text	:= text &amp; CMUI_EDIForm.ERROR_STR &amp; Tab;
		colour 	:= LightRed;
	else
		text 	:= text &amp; CMUI_EDIForm.WARNING_STR &amp; Tab;
		
		//create colorController transient;						//30.11.2022 navma1 #52499
		colour 	:= _colorController.rowColor2;					//30.11.2022 navma1 #52499
	endif;
	
	text := text &amp; _fieldName &amp; Tab &amp; _msg;
	
	idx := _table.addItem(text);				 
	
	if not gotException then
		_table.accessRow(idx).itemObject 	:= _obj;
		_table.accessedRow.backColor		:= colour;	//10 July 2014	NDL	Par 33373 - Only if we have actually added a row...
	endif;
	
	//epr par 37090 2/11/15
	if _warningOnly and _hideWarnings then
		_table.accessRow(idx).visible:=false;
	endif;
	
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_warningOnly" type="Boolean"/>
        <Parameter name="_hideWarnings" type="Boolean"/>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_colorController" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="showVerifyErrors" id="ffb945d9-05ce-4cfd-a992-af4e37a9088f">
        <source>showVerifyErrors(_ediData : CM_EDIData input; 
				_table : CM_DataTable input;
				 _hideWarnings : Boolean;
				_passport :CM_Passport);
/*

Date		Who		Reason
15 September 2016	cnwer1	Initial creation TFS 2606
// 11 Oct 2016	cnwrs1	TFS 2774/2795 PAR38277 EDI Operations Error display can be incorrect
*/

vars

begin
	_table.rows := 1;
	if _ediData = null then
		self.showVerifyErrors_Passport (_table,_hideWarnings,_passport);
		return;
	endif;
	
	if _ediData.storePersistentErrors then
		self.showVerifyErrors_EDIData(_ediData,_table,_hideWarnings);
	else
		self.showVerifyErrors_Passport (_table,_hideWarnings,_passport);
		// so if there are any of these show them here (as at 20/08/2013 - only releases)
		if _ediData.allErrorWarnings.size &gt; 0 then
			self.showVerifyErrors_EDIData (_ediData,_table,_hideWarnings);
		endif;
	endif;
epilog	

end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_hideWarnings" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="showVerifyErrors_EDIData" id="e11e7241-9730-4512-a286-fc84ef60a009">
        <source>showVerifyErrors_EDIData(	_ediData 	  : CM_EDIData;
							_table 		  : CM_DataTable input;
							_hideWarnings : Boolean	) protected;
/*

Date		Who		Reason
15 September 2016	cnwer1	Initial creation TFS 2606
11 Oct 2016	cnwrs1	TFS 2774/2795 PAR38277 EDI Operations Error display can be incorrect
30 Nov 2022 navma1 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
*/

vars
	gotException	 : Boolean;
	err				 : CM_EDIError;
	exOccurred 		 : Boolean;
	sptData			 : CMUI_SplitContainer;
	isError 		 : Boolean;
	colorController  : CM_ColorController;
begin
	on Exception do app.handleUE14051(exception, exOccurred);	//25 Nov 2014	NDL	Par 35248

	on Exception do app.handleDeletedObject (exception, err, gotException);	 
	
	if _table &lt;&gt; null and
	   _table.parent &lt;&gt; null and
	   _table.parent.isKindOf(CMUI_SplitContainer) then
		sptData := _table.parent.CMUI_SplitContainer;
	endif;	

	create colorController transient;					//30.11.2022 navma1 #52499
	
	foreach err in _ediData.allErrorWarnings do			//par 27392 13 Apr 2011
		self.showVerifyError (_table, err.myUserObject, err.warningOnly,_hideWarnings, err.fieldName, err.text,colorController);
		if exOccurred then
			break;
		endif;
		isError := true;
	endforeach;
	
	// if there is an error to display reinstate the Right Error control
	if isError and  sptData &lt;&gt; null then
		sptData.showRightControl(35, true);
	endif;
epilog
	delete colorController;						//30.11.2022 navma1 #52499
end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_hideWarnings" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showVerifyErrors_Passport" id="b7fff882-cd8c-4704-a7f1-4a6f3fa88039">
        <source>showVerifyErrors_Passport(_table 		  : CM_DataTable input;
							_hideWarnings : Boolean;
							_passport 	  : CM_Passport) protected;
/*

Date		Who		Reason
08 September 2016	cnwer1	Initial creation TFS 2606
11 Oct 2016	cnwrs1	TFS 2774/2795 PAR38277 EDI Operations Error display can be incorrect
30 Nov 2022 navma1 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
*/

vars
	error			 : CM_Error;
	sptData 		 : CMUI_SplitContainer;
	isError			 : Boolean;
	colorController  : CM_ColorController;
begin
	if _table &lt;&gt; null and
	   _table.parent &lt;&gt; null and
	   _table.parent.isKindOf(CMUI_SplitContainer) then
		sptData := _table.parent.CMUI_SplitContainer;
	endif;	
	
	create colorController transient;						//30.11.2022 navma1 #52499
	
	foreach error in _passport.allErrorWarnings do	
		self.showVerifyError (_table, error.myUserObject, error.warningOnly,_hideWarnings, error.fieldName, error.text,colorController);  //30.11.2022 navma1 #52499
		isError := true;
	endforeach;
	// if there is an error to display reinstate the Right Error control
	if isError and
	   sptData &lt;&gt; null then
		sptData.showRightControl(35, true);
	endif;
epilog
	delete colorController;						//30.11.2022 navma1 #52499
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_hideWarnings" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
