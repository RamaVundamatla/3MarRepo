end;</source>
        <ReturnType type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="getMyFutureTIs" id="f4fb0fb2-63e8-44c8-b154-59db1413dba7">
        <source>getMyFutureTIs(_currentTIs : CM_TIArray input) protected;
//----------------------------------------------------------------
//	Created:	25 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
04 Jun 2010	cnwkpd1	PAR #24281 - Speed up Planning performance

*/

vars
	tis			: CM_TIArray;
	allWLETIs	: CM_TISet;			// Changed from Array to Set to speed up includes and remove
	sr			: CM_SlotRequest;
	ti			: CM_TrackedItem;
	fm			: CM_FutureMove;
	include		: Boolean;
begin
	// we want to allow for the following scenarios (however unlikely or impossible):
	// discharge
	// load
	// discharge - load
	// load - discharge
	// discharge - load - discharge
	// etc
	
	
	create tis transient;
	create allWLETIs transient;

	foreach sr in self.allSlotRequestsDischarge do
		sr.getAllUnworkedTIs(tis);	// get TI's with uncompleted wle's (they will be discharge wle's)
		foreach ti in tis do
			if not allWLETIs.includes(ti) then
				allWLETIs.add(ti);
			endif;
		endforeach;
	endforeach;

	foreach sr in self.allSlotRequestsLoad do
		sr.getAllUnworkedTIs(tis);	// get TI's with uncompleted wle's (they will be load wle's)
		foreach ti in tis do
			if ti.allPlannedFutureMoves.isEmpty then
				// there is no future move (as it has not been planned yet) so
				// we assume that this is the final target location
				if not _currentTIs.includes(ti) then
					_currentTIs.add(ti);
				endif;
			elseif not allWLETIs.includes(ti) then
				allWLETIs.add(ti);
			endif;
		endforeach;
	endforeach;

	//we now have all TIs to be loaded/discharged to/from this spot 
	//check their final target locn
	foreach ti in allWLETIs do
		include := false;
		foreach fm in ti.allPlannedFutureMoves do
			if not CM_FutureMovePlanned.hasInstance(fm) 
			or CM_FutureMovePlannedEDI.hasInstance(fm) then // PAR 8667 added
				continue;
			endif;
			//global.processDebug("CNWJC2", true);
			if fm.CM_FutureMovePlanned.allLocationsControllers.includes(self) then
				//we have a load
				include := true;
				break; // PAR 9089. if a DLR disch is unplanned and replanned it is then the 2nd FM for this TI so the include is set to false.
			else
				//ti has some other destination
				include := false;
			endif;
		endforeach;

		if include then
			// add TI if not already here	
			if not _currentTIs.includes(ti) then
				_currentTIs.add(ti);
			endif;
		else
			// remove TI if it's here
			if _currentTIs.includes(ti) then
				_currentTIs.remove(ti);
			endif;
		endif;
		
	endforeach;

epilog
	delete tis;
	delete allWLETIs;
end;</source>
        <access>protected</access>
        <Parameter name="_currentTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyWorkedTIs" id="dbdf490b-7214-4ed3-ac0a-88bba890532b">
        <source>getMyWorkedTIs(_workTIs : CM_TIArray input) protected;
//----------------------------------------------------------------
//	Created:	07 January 2005	by Jason Chapman  (cnwjc2)
//
//	Returns TI's worked or to be worked to/from this controller.
//	This is not "Proposed" as it will return imports worked from this controller plus TI's loaded/planned to this controller	
//
//----------------------------------------------------------------
vars
	tis,
	allWLETIs	: CM_TIArray;
	sr			: CM_SlotRequest;
	ti			: CM_TrackedItem;
	fm			: CM_FutureMove;
	include		: Boolean;
begin
	
	create tis transient;

	//from this slot
	foreach sr in self.allSlotRequestsDischarge do
		sr.getAllTrackedItems(tis);	// get TI's (they will be from discharge wle's)
		foreach ti in tis do
			if not (ti.isSOB or ti.isRehandle or _workTIs.includes(ti)) then	//only count dlr/sob for load part
				_workTIs.add(ti);
			endif;
		endforeach;
	endforeach;

	//to this slot
	foreach sr in self.allSlotRequestsLoad do
		sr.getAllTrackedItems(tis);	// get TI's (they will be from load wle's)
		foreach ti in tis do
			if not _workTIs.includes(ti) then
				_workTIs.add(ti);
			endif;
		endforeach;
	endforeach;

epilog
	delete tis;
end;</source>
        <access>protected</access>
        <Parameter name="_workTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
