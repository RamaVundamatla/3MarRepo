<Class name="CM_QStrCustomsStatusMethod" id="060c465e-3d0f-4e2d-93ba-ce8664ae935d">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="c2cf91ca-88d8-44a9-ade2-79919ef6d544">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2023	navkc1 CR 62396 Task 62401: Jade - TI Selector Query Customs Status Property

*/

vars
	operator		: CM_QStringIsOneOf;
	
begin
	
	if self.isTransient() then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="df067349-90e0-4231-a127-d445e172f465">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2023	navkc1 CR 62396 Task 62401: Jade - TI Selector Query Customs Status Property

*/

vars

begin
	
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbCustomsStatus';
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="15b6e3e5-6500-4894-a5a2-68e0a7bf1c63">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2023	navkc1 CR 62396 Task 62401: Jade - TI Selector Query Customs Status Property

*/

vars

begin
	
	_combo.clear();
	
	_combo.addItem(app.getErrorString(CustomsStatus_Customs));
	_combo.addItem(app.getErrorString(CustomsStatus_Cleared));
	_combo.addItem(app.getErrorString(CustomsStatus_Free));

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="a4c3aeda-0f63-440f-828e-9713d8e1ef04">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2023	navkc1 CR 62396 Task 62401: Jade - TI Selector Query Customs Status Property

*/

vars
	strArray	: StringArray;
	str			: String;
	idx,
	selectionValue : Integer;
	strObj : CM_String;
begin
	_tbl.purgeTableObjects();
	_tbl.clear();
	_tbl.rows := 0;

	create strArray transient;
	
	strArray.add(app.getErrorString(CustomsStatus_Customs));
	strArray.add(app.getErrorString(CustomsStatus_Cleared));
	strArray.add(app.getErrorString(CustomsStatus_Free));
	
	foreach str in strArray do
		selectionValue := 0;
		
		if _operator &lt;&gt; null then
			if _operator.CM_QStringIsOneOf.allSelectionValues.includes(str) then
				selectionValue := 1;
			endif;
		endif;
		
		create strObj transient;
		strObj.string := str;
		
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; str);
		_tbl.accessRow(idx).itemObject := strObj;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
epilog
	delete strArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="b680df07-16d5-4462-9267-b6b2589c17ef">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2023	navkc1 CR 62396 Task 62401: Jade - TI Selector Query Customs Status Property

*/

vars
	strObj			: CM_String;
	stringArray		: StringArray;
	numRows,
	index			: Integer;
	string			: String;
begin
	create stringArray transient;

	numRows := _tbl.rows;
	
	foreach index in (_tbl.fixedRows + 1) to numRows do
		string := _tbl.accessCell(index, 1).text;
		
		if string = TableCheckBox_Selected then
			strObj := _tbl.accessRow(index).itemObject.CM_String;
			stringArray.add(strObj.string);
		endif;
	endforeach;
	
	_op.setSearchValue(stringArray);

epilog
	delete stringArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="1af2395c-8d75-414c-9f99-2e67c82397e4">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2023	navkc1 CR 62396 Task 62401: Jade - TI Selector Query Customs Status Property

*/

vars

begin
	if _value.isKindOf(CM_String) then
		if _value &lt;&gt; null then
			return _value.CM_String.string;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="ac61493e-7e10-48da-a641-5b463ccfa9ed">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2023	navkc1 CR 62396 Task 62401: Jade - TI Selector Query Customs Status Property

*/

vars
	invalidObj 	: Boolean;
	object 		: CM_String;
	returnVal 	: String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_String) then
			return _value.CM_String.string;
		endif;
	endif;
	
	return _value;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
