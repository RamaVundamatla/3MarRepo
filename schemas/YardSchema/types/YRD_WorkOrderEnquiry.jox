    <JadeMethod name="doSendToReport" id="d2f0612e-c79a-4a09-b13c-d41f9920c9c4">
        <source>doSendToReport(_objArray : ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	arrayCheck		: ObjectArray;
	pathList		: StringArray;
	obj				: Object;
	outputType		: Integer;
	filePath		: String;
begin
	if _objArray.isEmpty() then
		app.msgBox(app.getErrorString(NoWOForReport), app.getErrorString(NoWOForReport), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	create pathList transient;
	pathList.add( CM_JRWWorkOrder::allWorkOrders.name );
	//Get the report we want to send our invoice items to and find out whether we want a print preview.
	if app.getReportToSendItems(CM_WorkOrderView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then
		//Have to ensure we don't have multiples so check this out here.
		create arrayCheck transient;
		foreach obj in _objArray do
			if arrayCheck.includes(obj) then
				continue;
			endif;
			
			arrayCheck.add(obj);
		endforeach;
		
		app.sendItemsToReport(CM_JRWWorkOrder, arrayCheck, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	delete arrayCheck;
	delete pathList;
end;</source>
        <Parameter name="_objArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doSetApproved" id="73c5120c-f474-409b-827e-87d9fafbc2b2">
        <updating/>
        <source>doSetApproved() updating;

/*

Purpose: to approve a work order from the enquiry screen. We set the approved user(text) and the timestamp and update 

Parameters:			

Return Value:		


Date		Who		Reason
11 Nov 2009	cnwrd1	Initial creation
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/


vars
 	realWorkOrder	: CM_WorkOrder;
	selObj 			: Object;
	result			: Integer;
	wod				: CM_WorkOrderDtl;
	grpMethod		: CM_WorkOrderJobGroupMethod;
	grpData			: Any;
begin
	selObj := self.tblData.allSelectedObjects.first;
	
	if self.isEnqType_WorkOrder then
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if selObj.isKindOf(CM_WorkOrder) then
			realWorkOrder := selObj.CM_WorkOrder;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		
	elseif self.isEnqType_Task() then		
		// shouldnt be an option in task type view
		return;	
	endif;
	
	if self.hasVasSubscription and self.myTerminal.getConfig(AllowAutoActionCargoWo).Boolean then	//02.05.2024 navhl20 #63971
		wod := realWorkOrder.allWoDtls.first;
		grpData := self.isWorkOrderNeedGrpMethod(wod);
		if grpData.isKindOf(CM_WorkOrderJobGroupMethod) then
			grpMethod := grpData.CM_WorkOrderJobGroupMethod;
		elseif grpData.isKindOf(Integer) and grpData.Integer = MsgBox_Return_Cancel then
			return;
		endif;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	while true do
		//epr TFS 44018 25/3/19
		app.myTrxUA.trxUpdateWOApproved(realWorkOrder,false,null,grpMethod, app.myPassport);		//02.05.2024 navhl20 #63971

		if app.myPassport.trxCompletedOK then
			return;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;

		return;
	endwhile;
	

epilog

	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetArchived" id="293c9aa9-fd4e-466d-b11e-da847ad30ce1">
        <updating/>
        <source>doSetArchived() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 January 2010	cnwrd1	Initial creation
26 March 2024	navpw1	TFS: 62849 (62927) - Reverted Code by changing call to trxUpdateWorkOrder

*/


vars
	workOrder,
 	realWorkOrder	: CM_WorkOrder;
	selObj 			: Object;
	result			: Integer;
begin
	selObj := self.tblData.allSelectedObjects.first;
	
	if self.isEnqType_WorkOrder then
	
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if selObj.isKindOf(CM_WorkOrder) then
			realWorkOrder := selObj.CM_WorkOrder;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		workOrder := app.createUpdateProxy(realWorkOrder).CM_WorkOrder; //create proxy wo
		
	elseif self.isEnqType_Task() then		
		// shouldnt be an option in task type view
		return;	
	endif;
	

	app.mousePointer := MousePointer_HourGlass;
	
	/*
	setApproved( _approvedBy : String ; _approvedBtDT : TimeStamp ; _passport : CM_Passport input) updating;
	workOrder.approvedBy := process.userCode;
	workOrder.taskStatus := WO_STATUS_APPROVED;
	*/
	
	workOrder.setProxy(
		workOrder.allEmailAddresses,
		workOrder.customerReference,
		workOrder.emailNotification,
		workOrder.enteredByDT,
		workOrder.myEnteredByUser,
		app.getMyUser().userName.trimBlanks,
		workOrder.myOrganisation,
		workOrder.myTerminal,
		workOrder.remarks,
		workOrder.requiredByDT,
		workOrder.startAtDT,
		workOrder.taskStatus
		);
		
	workOrder.setArchived(true);
	
	while true do

		app.myTrxUA.trxUpdateWorkOrder(workOrder,false, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
	endwhile;
	

epilog
	delete workOrder;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetNotApproved" id="dd9957ef-8151-411a-83d6-dec896596570">
        <source>doSetNotApproved(_reason : CM_PredefinedRemark);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
26 March 2024		navpw1	TFS: 62849 (62927) - Reverted Code by changing call to trxUpdateWorkOrder

*/

vars

	workOrder, realWorkOrder : CM_WorkOrder;
	selObj : Object;
	result : Integer;
	
begin
	selObj := self.tblData.allSelectedObjects.first;
	
	if self.isEnqType_WorkOrder then
	
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if selObj.isKindOf(CM_WorkOrder) then
			realWorkOrder := selObj.CM_WorkOrder;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		workOrder := app.createUpdateProxy(realWorkOrder).CM_WorkOrder; //create proxy wo
		
	elseif self.isEnqType_Task() then		
		// shouldnt be an option in task type view
		return;	
	endif;
	
	if _reason = null then
		app.msgBox( app.getErrorString(Input_required_field_reason), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	workOrder.setProxy(
		realWorkOrder.allEmailAddresses,
		realWorkOrder.customerReference,
		realWorkOrder.emailNotification,
		realWorkOrder.enteredByDT,
		realWorkOrder.myEnteredByUser,
		app.getMyUser().userName.trimBlanks,
		realWorkOrder.myOrganisation,
		realWorkOrder.myTerminal,
		_reason.description,
		realWorkOrder.requiredByDT,
		realWorkOrder.startAtDT,
		WO_STATUS_NOTAPPROVED
		);
	
	while true do
		app.myTrxUA.trxUpdateWorkOrder(workOrder,false, app.myPassport);
		if app.myPassport.trxCompletedOK then
			return;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
	endwhile;
	

epilog

	delete workOrder;
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <Parameter name="_reason" type="CM_PredefinedRemark"/>
    </JadeMethod>
    <JadeMethod name="doSetPendingApproval" id="982e7fb6-a786-423c-b01f-2f79248e0f13">
        <updating/>
        <source>doSetPendingApproval() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/06/2018	jlgdap1		Initial creation TFS 39286 PEL1 Work Order Enquiry Voyage Requests
// 26/03/2024	navpw1	TFS: 62849 (62927) - Reverted Code by changing call to trxUpdateWorkOrder
//
vars
	workOrder, realWorkOrder : CM_WorkOrder;
	selObj : Object;
	result : Integer;
	
begin
	selObj := self.tblData.allSelectedObjects.first;
	
	if self.isEnqType_WorkOrder then
	
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if selObj.isKindOf(CM_WorkOrder) then
			realWorkOrder := selObj.CM_WorkOrder;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		workOrder := app.createUpdateProxy(realWorkOrder).CM_WorkOrder; //create proxy wo
		
	elseif self.isEnqType_Task() then		
		// shouldnt be an option in task type view
		return;	
	endif;
	

	app.mousePointer := MousePointer_HourGlass;
	
	workOrder.setProxy(
		realWorkOrder.allEmailAddresses,
		realWorkOrder.customerReference,
		realWorkOrder.emailNotification,
		realWorkOrder.enteredByDT,
		realWorkOrder.myEnteredByUser,
		app.getMyUser().userName.trimBlanks,
		realWorkOrder.myOrganisation,
		realWorkOrder.myTerminal,
		realWorkOrder.remarks,
		realWorkOrder.requiredByDT,
		realWorkOrder.startAtDT,
		WO_STATUS_PENDING
		);
	
	while true do
		app.myTrxUA.trxUpdateWorkOrder(workOrder,false, app.myPassport);
		if app.myPassport.trxCompletedOK then
			return;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		
		return;
	endwhile;
	

epilog
	delete workOrder;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowBulkRelease" id="e7a958bd-1dac-4d4d-b240-d1c7197edb65">
        <source>doShowBulkRelease(_bulkRelease : CM_BulkRelease);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Mar 2023 navma1	ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
*/

