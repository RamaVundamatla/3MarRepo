    <JadeMethod name="getDisplayStringForAttribute" id="3dd001fb-be0a-42c6-9fb0-3987e154406a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		    Who			Reason
02 May 2011	cnwas3	  Initial creation: CCMS 1031 par 27498
*/

vars

begin
	if _attrName = ETRow_Code or _attrName = ETRow_DeckItemCode then
		return self.code;
	elseif _attrName = ETRow_DeckCode then
		return self.getMyDeckCode();
	elseif _attrName = ETRow_DeckItemType then
		return self.typeName();
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	else	
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getItemLength" id="c87ba2fd-7834-442b-ae82-1403da117f18">
        <source>getItemLength(_ti : CM_TrackedItem) : Decimal;
/*
Purpose:			
Date		Who		Reason
30 November 2011	cnwab1	Initial creation
*/

vars

begin
	if self.myDeckItem &lt;&gt; null then
		return self.myDeckItem.getItemLength(_ti);
	endif;
	
	return 2; // default in metres
epilog

end;</source>
