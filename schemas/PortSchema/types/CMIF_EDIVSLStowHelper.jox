<Class name="CMIF_EDIVSLStowHelper" id="9d4ec0b7-8814-404e-9f2d-fbfa676d1ad7">
    <superclass name="CMIF_EDIFACTHelper"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="setFirstField" id="b877add7-eeb9-4d19-bf10-d973eeb3e117">
        <updating/>
        <source>setFirstField() updating;

/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes

*/

vars
	msg,
	str				: String;
	pos				: Integer;
	
begin
	self.currentFieldNumber := 1;
	msg := self.currentMessage;
	
	if msg &lt;&gt; null then
		pos := 1;
		str := msg.scanUntil(Tab, pos);
	endif;
	
	self.currentField := str;
	
	self.setFirstSubItem;
	
end;

/* 	old code replaced

vars
	str: String;
	pos1,start,stop: Integer;
begin
	self.currentFieldNumber := 1;
	start := 1;
	pos1 := self.getCurrentMessage.pos(Tab,start);
	stop := pos1-start;
	if pos1 &lt; 1 then
		stop := self.getCurrentMessage.length - start;
	endif;
	if stop &lt; 1 then
		self.currentField := "";
	else
		self.currentField := self.getCurrentMessage[start:stop];
	endif;
	self.setFirstSubItem;

end;
*/</source>
    </JadeMethod>
    <JadeMethod name="setNextField" id="e229bbc5-b8b3-4761-b91d-890bc2b1bbd4">
        <updating/>
        <source>setNextField() updating;

/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes

*/

vars
	str,
	msg				: String;
	msgLen,
	pos,
	index,
	currentIndex	: Integer;
	
begin
	currentIndex := self.currentFieldNumber + 1;
	self.currentFieldNumber := currentIndex;
	
	msg := self.currentMessage;
	msgLen := msg.length;
	
	pos := 1;
	index := 0;
	
	while index &lt; currentIndex do
		index := index + 1;
		
		if pos &gt; msgLen then
			str := null;
			break;
		endif;
		
		// Find field number "index"
		str := msg.scanUntil(Tab, pos);
		
		if pos = null then			// No more Tab delimiters, must be the end of the line
			break;
		endif;
		
		pos := pos + 1;				// Step over delimiter
	endwhile;
	
	self.currentField := str;
	self.setFirstSubItem;
	
end;

/*	Old code replaced

vars
	pos1,pos2,index,start,stop: Integer;
begin
	self.currentFieldNumber := self.currentFieldNumber + 1;
	index := 1;
	start := 1;
	while index &lt; self.currentFieldNumber do
		pos1 := self.getCurrentMessage.pos(Tab,start);
		if pos1 = 0 then // got all the fields
			start	:= 1;
			pos2	:= 1; // this ensures stop := 0 and currentField is set to blank
			break;
		endif;
		start :=  pos1 + 1; //skip the delimiter
		pos2 := self.getCurrentMessage.pos(Tab,start);
		index := index + 1;
	endwhile;
	stop := pos2-start;
	if pos2 &lt; 1 then
		stop := self.getCurrentMessage.length - start + 1;
	endif;
	if stop &lt; 1 then
		self.currentField := "";
	else
		self.currentField := self.getCurrentMessage[start:stop];
	endif;
	self.setFirstSubItem;

end;
*/</source>
    </JadeMethod>
</Class>
