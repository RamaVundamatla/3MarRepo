<Class name="CMQF_HMSMovements">
    <JadeMethod name="setFromAgent" id="fd0cd078-fe57-4312-b995-8b8e4b1fe027">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
// -------------------------------------------
// Created 25 February 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 03/03/2020	jlgdap1		TFS 48731 PNL New Web Portal not generating reports / timing out
//							Web Portal returns dates in dd/mm/yyyy hh:mm format, regardless of 
//							whether the time portion is displayed or not. So here we need to 
// 							cater for a Date (if the parameter is hidden) or a timestamp
//							(if the parameter is shown)
vars
	str : String;				// TFS 48731

begin
	inheritMethod(_agent);
	// Arrival
	
	//27 Feb 2012	NDL	Par 29121
	if _agent.isRowIncluded(ETRow_MovementIncludeInPort) then
		self.movementIncludeInPort := _agent.getValueByNameIfVisible(ETRow_MovementIncludeInPort).Boolean;
	endif;
	
	if _agent.isRowIncluded(ETRow_MovementDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_MovementDateFrom).String, 
								self.movementDateFromType, self.movementDateFromFactor, ETRow_MovementDateFrom);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_MovementDateFrom), 
								self.movementDateFromType, self.movementDateFromFactor, ETRow_MovementDateFrom);
		else
			//self.movementDateFrom := _agent.getSelectedHMSDate(ETRow_MovementDateFrom);		PAR 10970
			//self.movementDateFrom := _agent.getValueByNameIfVisible(ETRow_MovementDateFrom).Date;		// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_MovementDateFrom).String;						// TFS 48731
			if str.Date.isValid then																	// TFS 48731
				self.movementDateFrom := str.Date;														// TFS 48731
			elseif str.TimeStamp.isValid then															// TFS 48731
				self.movementDateFrom := str.TimeStamp.date;											// TFS 48731
			endif;																						// TFS 48731
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_MovementDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_MovementDateTo).String, 
								self.movementDateToType, self.movementDateToFactor, ETRow_MovementDateTo);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_MovementDateTo), 
								self.movementDateToType, self.movementDateToFactor, ETRow_MovementDateTo);
		else
			//self.movementDateTo := _agent.getSelectedHMSDate(ETRow_MovementDateTo);		PAR 10970
			//self.movementDateTo := _agent.getValueByNameIfVisible(ETRow_MovementDateTo).Date;			// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_MovementDateTo).String;							// TFS 48731
			if str.Date.isValid then																	// TFS 48731
				self.movementDateTo := str.Date;														// TFS 48731
			elseif str.TimeStamp.isValid then															// TFS 48731
				self.movementDateTo := str.TimeStamp.date;												// TFS 48731
			endif;																						// TFS 48731
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_MovementTimeFrom) then
//		self.movementTimeFrom := _agent.getSelectedHMSTime(ETRow_MovementTimeFrom);
		self.movementTimeFrom  := _agent.getValueByNameIfVisible(ETRow_MovementTimeFrom).Time;
	endif;
	
	if _agent.isRowIncluded(ETRow_MovementTimeTo) then
//		self.movementTimeTo := _agent.getSelectedHMSTime(ETRow_MovementTimeTo);
		self.movementTimeTo  := _agent.getValueByNameIfVisible(ETRow_MovementTimeTo).Time;
	endif;
	
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
