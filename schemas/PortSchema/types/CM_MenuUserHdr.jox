//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTemplateHeader" id="480dfed9-b6ef-48ab-9b38-463a724f49c4">
        <source>isTemplateHeader() : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity	: CM_MenuEntity;
	parent		: CM_MenuEntity;
	rootFound	: Boolean;
begin
	menuEntity := self;
	rootFound := false;
	while not rootFound do
		parent := menuEntity.myParent;
		if parent &lt;&gt; null then
			if parent.isKindOf(CM_MenuRootUserTemplates) then
				rootFound := true;
				break;
			else
				menuEntity := parent;
			endif;	
		else
			break;
		endif;
	endwhile;

	return rootFound;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUserDefinedReportsHeader" id="1c7e634e-6720-4356-9e5c-3a0a92cc5cc9">
        <source>isUserDefinedReportsHeader(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2015	cnwndl1	Initial creation	Par 36846

*/

vars

begin

	return self.getHeading = "User Defined Reports";

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveAsMenuHdrSystem" id="7dddfe80-a2a7-431e-902b-ebc47d4b0ba1">
        <updating/>
        <source>saveAsMenuHdrSystem(_constValue, _pos : Integer; 
					_parent : CM_MenuEntity input;
					_menuRoot : CM_MenuRoot input;
					_hdrPrefix : String) : CM_MenuHdrSystem updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyMenHdr,
	realMenHdr	: CM_MenuHdrSystem;

begin

	create pxyMenHdr transient;
	pxyMenHdr.setProxy(_constValue, self.heading, false, self.pictureStringButton,
					self.pictureStringButtonDown, self.pictureStringIcon, _hdrPrefix);
					
	create realMenHdr persistent;
	realMenHdr.setForCreate(pxyMenHdr, _parent, _pos, _menuRoot);
	
	self.setMyMenuRoot(_menuRoot);
	self.myMenuItem := realMenHdr;
	
	return realMenHdr;

end;</source>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_hdrPrefix" type="String"/>
        <ReturnType type="CM_MenuHdrSystem"/>
    </JadeMethod>
    <JadeMethod name="saveAsSystemEntity" id="f0835e33-577c-4dfd-b00b-eaba892c7d67">
        <updating/>
        <source>saveAsSystemEntity(_parent : CM_MenuEntity input; 
				_pos : Integer; 
				_agent : CM_MenuAgent input;
				_deleteSet : CM_MenuEntitySet input;
				_menuRoot : CM_MenuRoot input;
				_hdrPrefix : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	systemHdr		: CM_MenuHdrSystem;
	parentEntity,
	childEntity		: CM_MenuEntity;
	idx				: Integer;

begin
	inheritMethod(_parent, _pos, _agent, _deleteSet, _menuRoot, _hdrPrefix);
				
	if self.myMenuItem &lt;&gt; null then
		if self.myMenuItem.isKindOf(CM_MenuHdrSystem) then
			systemHdr := self.myMenuItem.CM_MenuHdrSystem;
			systemHdr.setPictures(self.pictureStringButton,
									self.pictureStringButtonDown,
									self.pictureStringIcon);
									
			if systemHdr.heading &lt;&gt; self.heading then
				systemHdr.setHeading(self.heading);
			endif;
			
			if _deleteSet.includes(systemHdr) then
				_deleteSet.remove(systemHdr);
			endif;
			// need to update heading and other properties here
			
			systemHdr.myParent := null;
			_parent.addChild(systemHdr, _pos);
			systemHdr.setMyMenuRoot(_menuRoot);
		else
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  Unhandled userHdr.myMenuItem ' &amp; self.myMenuItem.String);
		endif;
	else
		// need to create CM_MenuHdrSystem object.
		systemHdr := self.saveAsMenuHdrSystem(_agent.getNextMenuHdrTransientValue, _pos, _parent, _menuRoot, _hdrPrefix);	
	endif;

	foreach idx in 1 to self.allChildren.size do
		childEntity := self.allChildren[idx];
		if childEntity.isKindOf(CM_MenuUserItem) then
			childEntity.CM_MenuUserItem.saveAsSystemEntity(systemHdr, idx, _agent, _deleteSet, _menuRoot, _hdrPrefix);
		endif;
	endforeach;

end;</source>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_agent" type="CM_MenuAgent" usage="input"/>
        <Parameter name="_deleteSet" type="CM_MenuEntitySet" usage="input"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_hdrPrefix" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="58483810-77fd-40a6-8aa8-9095cb1554bf">
        <updating/>
        <source>setForCreate(_proxy: SelfType; _parent: CM_MenuEntity input; _pos: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy, _parent, _pos);
	
	self.level := _parent.getLevel() + 1;
//	self.level := 2;

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromSystemMenuItem" id="754e75a2-ccc9-4a87-b1b3-95b675b8cb70">
        <updating/>
        <source>setFromSystemMenuItem(_sysMenuHdr: CM_MenuHdr; _menuRoot: CM_MenuRoot) updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.level					:= 2;
	self.heading 				:= _sysMenuHdr.heading;
	self.myMenuItem				:= _sysMenuHdr;
	self.pictureStringButton	:= _sysMenuHdr.pictureStringButton;
	self.pictureStringButtonDown:= _sysMenuHdr.pictureStringButtonDown;
	self.pictureStringIcon		:= _sysMenuHdr.pictureStringIcon;
	self.toolTip				:= _sysMenuHdr.toolTip;
	self.myMenuRoot				:= _menuRoot;
	


end;</source>
        <Parameter name="_sysMenuHdr" type="CM_MenuHdr"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="8ffbce49-673c-4bab-af8b-bc0fcd13fba3">
        <updating/>
        <source>setProxy(_heading, _pictureButton,_pictureButtonDown, _pictureIcon, _toolTip : String; 
		 _menuHdr : CM_MenuHdr; _menuRoot : CM_MenuRoot) updating;

vars

begin

	self.setProxyMenuUserItem(_heading, _pictureButton,_pictureButtonDown, _pictureIcon,_toolTip, 
							  _menuHdr, _menuRoot);

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
        <Parameter name="_pictureIcon" type="String"/>
        <Parameter name="_toolTip" type="String"/>
        <Parameter name="_menuHdr" type="CM_MenuHdr"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
    </JadeMethod>
</Class>
