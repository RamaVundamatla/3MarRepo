    <JadeMethod name="setForCreate" id="ce819868-6d0e-453e-9f72-ceeec2d5f03a">
        <updating/>
        <source>setForCreate(_myTerminalArea : CM_TerminalArea) updating;
/*
 ------------------------------------------------------------------------
Created:			12 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.myTerminalArea := _myTerminalArea;
end;</source>
        <Parameter name="_myTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7e5270a9-0c4e-49f1-bf6d-0db6144f3853">
        <updating/>
        <source>setForUpdate(_proxyTest : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.testAvailability := _proxyTest.testAvailability;
	self.testCapacity := _proxyTest.testCapacity;
	self.testCommodityGroup := _proxyTest.testCommodityGroup;
	self.testDischargePort := _proxyTest.testDischargePort;
	self.testFirstInFirstOut := _proxyTest.testFirstInFirstOut;
	self.testHuntToFirstSimiliar := _proxyTest.testHuntToFirstSimiliar;
	self.testIDMasking := _proxyTest.testIDMasking;
	self.testIMEXStatus := _proxyTest.testIMEXStatus;
	self.testLabourRestriction := _proxyTest.testLabourRestriction;
	self.testLocationRestriction := _proxyTest.testLocationRestriction;
	self.testOverstowWeight := _proxyTest.testOverstowWeight;
	self.testPlannedOrQueuedOverstow := _proxyTest.testPlannedOrQueuedOverstow;
	self.test45 := _proxyTest.test45;
	self.testPower := _proxyTest.testPower;
	self.testTIVoyageOnOppTower := _proxyTest.testTIVoyageOnOppTower;
	self.testTower := _proxyTest.testTower;
	self.testTowerSpecificTemperature := _proxyTest.testTowerSpecificTemperature;
	self.testTowerCommodityGroup := _proxyTest.testTowerCommodityGroup;
	self.testVoyage := _proxyTest.testVoyage;
	self.maxInBlockToTest := _proxyTest.maxInBlockToTest;
	
	
end;</source>
        <Parameter name="_proxyTest" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b7999af1-04f6-4905-9cc4-79063d2c03ae">
        <updating/>
        <source>setProxy(_testAvailability,_testCapacity,_testCommodityGroup,_testDischargePort,_testFirstInFirstOut,_testHuntToFirstSimiliar,_testIDMasking,_testIMEXStatus,
_testLabourRestriction,_testLocationRestriction,_testOverstowWeight,_testPlannedOrQueuedOverstow,_testPower,_testTIVoyageOnOppTower,_testTower,
_testTowerCommodityGroup,_testTowerSpecificTemperature,_testVoyage, _test45 : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.testAvailability := _testAvailability;
	self.testCapacity := _testCapacity;
	self.testCommodityGroup := _testCommodityGroup;
	self.testDischargePort := _testDischargePort;
	self.testFirstInFirstOut := _testFirstInFirstOut;
	self.testHuntToFirstSimiliar := _testHuntToFirstSimiliar;
	self.testIDMasking := _testIDMasking;
	self.testIMEXStatus := _testIMEXStatus;
	self.testLabourRestriction := _testLabourRestriction;
	self.testLocationRestriction := _testLocationRestriction;
	self.testOverstowWeight := _testOverstowWeight;
	self.testPlannedOrQueuedOverstow := _testPlannedOrQueuedOverstow;
	self.testPower := _testPower;
	self.test45 := _test45;
	self.testTIVoyageOnOppTower := _testTIVoyageOnOppTower;
	self.testTower := _testTower;
	self.testTowerSpecificTemperature := _testTowerSpecificTemperature;
	self.testTowerCommodityGroup := _testTowerCommodityGroup;
	self.testVoyage := _testVoyage;
	

end;</source>
        <Parameter name="_testAvailability" type="Boolean"/>
        <Parameter name="_testCapacity" type="Boolean"/>
        <Parameter name="_testCommodityGroup" type="Boolean"/>
        <Parameter name="_testDischargePort" type="Boolean"/>
        <Parameter name="_testFirstInFirstOut" type="Boolean"/>
        <Parameter name="_testHuntToFirstSimiliar" type="Boolean"/>
        <Parameter name="_testIDMasking" type="Boolean"/>
        <Parameter name="_testIMEXStatus" type="Boolean"/>
        <Parameter name="_testLabourRestriction" type="Boolean"/>
        <Parameter name="_testLocationRestriction" type="Boolean"/>
        <Parameter name="_testOverstowWeight" type="Boolean"/>
        <Parameter name="_testPlannedOrQueuedOverstow" type="Boolean"/>
        <Parameter name="_testPower" type="Boolean"/>
        <Parameter name="_testTIVoyageOnOppTower" type="Boolean"/>
        <Parameter name="_testTower" type="Boolean"/>
        <Parameter name="_testTowerCommodityGroup" type="Boolean"/>
        <Parameter name="_testTowerSpecificTemperature" type="Boolean"/>
        <Parameter name="_testVoyage" type="Boolean"/>
        <Parameter name="_test45" type="Boolean"/>
    </JadeMethod>
