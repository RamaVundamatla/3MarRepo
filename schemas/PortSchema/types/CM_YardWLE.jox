    <JadeMethod name="jobHasTurnAroundWLE" id="fa09c793-1888-4f54-af9a-6d1cb0fa956e">
        <source>jobHasTurnAroundWLE(): Boolean;
//----------------------------------------------------------------
//	Created:	12 November 2005	by Jason Chapman  (cnwjc2)
//
//	If self is a receipt - returns true if a release for the same ti can be found
//	If self is a release - returns true if a receipt for the same ti can be found
//  06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
//----------------------------------------------------------------
vars
	job		: CM_Job;
	wle		: CM_WorkListEntry;
begin

	job := self.job;
	
	if job = null then
		return false;
	endif;
	
	foreach wle in job.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		if wle.myTrackedItem = null or wle.isReceipt = self.isReceipt then
			continue;
		endif;
		
		if wle.myTrackedItem = self.myTrackedItem then
			//receipt and release for same TI - must be a turn around
			return true;
		endif;
	endforeach;

	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveEvent" id="2e158b95-2dac-4b7c-ba92-1acc2208a8ea">
        <updating/>
        <source>moveEvent(_moveController : CMIF_MoveController) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 07/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
// 28/01/2025	navpw1		MTN-33663 - Added move controller parameter to method
//
vars
	terminal : CM_Terminal;
	prenote : CM_TrackedItem;
	wle, prenoteWle, roadWLE : CM_WorkListEntry;
	fm : CM_FutureMove;
	fmsToDelete : ObjectArray;
	checkWeight : Boolean;

begin
	inheritMethod(_moveController);

	//if self.myTrackedItem = null or not self.myTrackedItem.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then	// TFS 52293
	if self.myTrackedItem = null or self.job = null or not self.job.isDirectDeliveryJob then							// TFS 52293
		return;
	endif;
	if self.status &lt;&gt; WLE_COMPLETED then
		return;
	endif;
	
	terminal := self.myTrackedItem.myTerminal;
	
	// Tidy up the prenote WLEs - get rid of the completed one that matches this WLE, 
	// and any future move attached to the prenote WLE
	prenote := terminal.allNotifiedTIsByIdCargoType[self.myTrackedItem.id, self.myTrackedItem.cargoType];
	if prenote = null then
		return;
	endif;
	checkWeight := prenote.myCargoType.isBulkByWeight or prenote.myCargoType.isBulkByVolume;
	foreach wle in prenote.allWorklistEntries do
		if wle.locationTarget = self.locationTarget then
			if (checkWeight and wle.weight = null) or (not checkWeight and wle.quantity = null) then
				prenoteWle := wle;
				break;
			endif;
		endif;
	endforeach;
	if prenoteWle = null then
		return;
	endif;
	
	fm := prenoteWle.myFutureMove;
	if fm &lt;&gt; null then
		delete fm;
	endif;
	prenoteWle.setStatus(self.status);
	prenoteWle.erase(NORMAL_ERASE);
	
	// Tidy up any future moves on completed WLEs associated with the road WLE
	create fmsToDelete transient;
	foreach wle in self.allDirectDeliveryChildWLEs do
		if wle.myFutureMove &lt;&gt; null and wle.status = WLE_COMPLETED then
			fmsToDelete.add(wle.myFutureMove);
		endif;
	endforeach;
	
	fmsToDelete.purge;
	
epilog
	delete fmsToDelete;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="railChangeReleaseToReceipt" id="c6ddb639-d533-4e90-92e6-c50cdb724ed5">
        <updating/>
        <source>railChangeReleaseToReceipt(_passport : CM_Passport input) updating, protected;
//-----------------------------------------
//Changed: April 2003 By: cnwgd1 - V7ised
//-----------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 18/03/2024	navpw1		TFS: 62857 (62858) - Changed signature of createRailReceiveJob
vars
	theWagon : CM_Wagon;
	newJob : CM_RailJob;
	aReq : CM_Request;
	aRes : CM_ReserveDetail;
begin

	//Check: Must be a release job and must be 100% complete
	sharedLock(self.job);

	// wle must be rail and it must be worked and completed for it to be returned as a 
	if (not self.job.isRelease) then
		app.setContinueCMExceptions(false);	
		app.raiseCMException3(ERR_WLE_INCORRECT_STATUS, '"Return Work Entry"', '[' &amp;self.getFullDescription&amp;']', 'of type Completed Release', null, null);
		return;
	endif;

	if self.status &lt;&gt; WLE_COMPLETED then
		app.setContinueCMExceptions(false);	
		app.raiseCMException3(ERR_WLE_INCORRECT_STATUS, '"Return Work Entry"', '[' &amp;self.getFullDescription&amp;']', 'Complete', null, null);
		return;
	endif;

	sharedLock(self.myTrackedItem);
	theWagon := self.myTrackedItem.getMyWagon();

	//newJob := theWagon.getReceiveJob();

	if newJob = null then
		newJob := theWagon.createRailReceiveJob(_passport, null);
	endif;
	//epr par 34466 7/7/14 new quantity/weight param
	newJob.addJobRequest(self.myTrackedItem, true, null,null, _passport);
	self.myTrackedItem.confirmWagon( null, TI_STATE_NORMAL, _passport);

	if self.job.workListEntries.size = 1 then

		// ### PAR 9514 AKB2005FEB this will unassign from the RESERVE. We do not want to delete the reserve
		aReq := self.myRequest;// ### PAR 9514 AKB2005FEB
		if self.myTrackedItem &lt;&gt; null and aReq &lt;&gt; null then// ### PAR 9514 AKB2005FEB
			aRes := aReq.myReserveDetail;// ### PAR 9514 AKB2005FEB
			if aRes &lt;&gt; null  then// ### PAR 9514 AKB2005FEB
				aRes.removeTIAssigned(self.myTrackedItem);// ### CCMS 1282 AKB2004NOV
			endif;
		endif;

		//get rid of the lot of the bastards!
		self.job.erase(NORMAL_ERASE);		
	else
		if self.myTrackedItem &lt;&gt; null then
			self.unassignTI();
		endif;
		self.erase(NORMAL_ERASE);	// Like the salmon, we have spawned, so we must die
	endif;
	
	newJob.rebuildStatus;

epilog

end;</source>
        <access>protected</access>
        <text>/* 
	PAR 3527 AJA 11/5/00: This turns a completed release job into a new receipt jobs.

	Andrew attempted to convert worked releases into receipts at the job level.
	I wrote this to replace that functionality to work at the wle level as required.
	I disabled the menu on the tree the fired off his jade code and replaced it with a
	entry that works on the table.

	stg 8 jun 2000

*/</text>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="railReturnRelease" id="4ce7b993-e7a8-4fb6-afa3-73eb78a16d5c">
        <updating/>
        <source>railReturnRelease(_passport : CM_Passport input) updating, protected;
//-----------------------------------------
//Changed: April 2003 By: cnwgd1 - V7ised
//-----------------------------------------
vars
	oldJobStatus,
	tmpHeight : Integer;
	targetLocn : CM_LocationsController;
begin
	// the container has been associated with a wle release but is not on a wagon.
	// They want it returned and the wle freed up.
	sharedLock(self.myTrackedItem);
	
	//self.id := null;
	self.job.updateTICollectionsUnassign(self.myTrackedItem);	
	//self.myTrackedItem.setJobRelease(null, TI_TRANSMODE_RAIL);
	self.myRequest.removeBulkReleaseTI(self.myTrackedItem);
	
	_passport.myTerminal.findLocationFromString(self.myTrackedItem.priorLocation, false, targetLocn, tmpHeight);
	//self.myTrackedItem.moveToLocation(targetLocn, null, self, null, REAL_MODE, true, false, false, false, false,  false, null,null,_passport);		// TFS 2651
	self.myTrackedItem.moveToLocation(targetLocn, null, self, null, REAL_MODE, true, false, false, false, false,  false, null,null,null,null,null,_passport);		// TFS 2651
	
	self.setMyTrackedItem(null);
	
	// do the update status stuff in the service layer for notification purposes.	
	app.myUtilityUA.utlUpdateJobStatus(self.job, _passport);
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="railReturnWorkEntry" id="93eeea3d-f6b3-4212-bb8e-ba23ee95a8d0">
        <updating/>
        <source>railReturnWorkEntry(_passport : CM_Passport input)updating;
//-----------------------------------------
//Changed: April 2003 By: cnwgd1 - V7ised
//-----------------------------------------
vars
begin

	exclusiveLock(self);
	sharedLock(self.job);
	
	// Do some self healing first
	self.rebuildStatus(); //epr par 25573 6/2/2011 trying to not have so many status update methods was updateStatus();
	
	if (not self.job.isKindOf(CM_RailJob)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid job type. Contact Developer.');
		return;
	endif;

	// wle must be rail and it must be worked and completed for it to be returned as a 
	if (not self.job.isRelease) then
		app.setContinueCMExceptions(false);
		app.raiseCMException3(ERR_WLE_INCORRECT_STATUS, '"Return Work Entry"', '[' &amp;self.getFullDescription&amp;']', 'of type Completed Release', null, null);
		return;	
	endif;

	if self.status &lt;&gt; WLE_COMPLETED then
		app.setContinueCMExceptions(false);
		app.raiseCMException3(ERR_WLE_INCORRECT_STATUS, '"Return Work Entry"', '[' &amp;self.getFullDescription&amp;']', 'Complete', null, null);
		return;		
	endif;

	if self.myTrackedItem.isOnWagon then
		self.railChangeReleaseToReceipt(_passport);
	else
		self.railReturnRelease(_passport);
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rebuildStatus" id="a4b6b1a6-c00d-4b64-8f12-e259c21c2e49">
        <updating/>
        <source>rebuildStatus() updating;
//Checks the condition of the WLE, and rebuilds the status appropriatly
//23 Mar 11 	cnwer1 	Par 25573 no need to call rebuildStatsYard
//22 May 2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail
//24 Aug 2022	navcs2	Bug 54274: MTN - Export Return Work Order - Can not process road exit
//27 Mar 2023	navma1  ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order

vars
	wle 		: CM_WorkListEntry;
	omanMadness : Boolean;						//25 Oct 2018	NDL	TFS 41180
	vvr 		: CM_VehicleVisitRecord;		//25 Oct 2018	NDL	TFS 41180
	drWLE 		: CM_WorkListEntry; 			// tfs42840
begin

	if (not self.myRequest.isKindOf(CM_YardRequest)) then
		//We only handle yard (road/rail) stuff here
		return;
	endif;

	if self.job.isKindOf(CM_YardJob) then			// 29/09/2011 cnwmh5 #28197
		if self.myRequest.isReleaseType then					
			if not self.job.isMultiQueueJob() then
				if not self.job.isA(CM_YardInternalJob) then
					if not app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then // ### TFS 52914 25FEB2022 NAVAB1 was changing to unactioned then the inheritMethod was changing it to complete and it looped 15 times. so 15 times we sent JSON to opsview

						self.setStatus(WLE_UNACTIONED);
					endif;
				endif;
			endif;
		endif;
	endif;
	
	inheritMethod();
	
	// tfs42840 start
	// if is part of a direct release move, and the other wle is not complete then neither are we
	if self.myFutureMove &lt;&gt; null then
		if self.myFutureMove.myWorkListEntryDR &lt;&gt; null then
			drWLE := self.myFutureMove.myWorkListEntryDR;
			if drWLE.status &lt;&gt; WLE_COMPLETED then
				if self.status = WLE_COMPLETED then
					self.setStatus(WLE_UNACTIONED);
				endif;
			endif;
		endif;
	elseif self.myFutureMoveDR &lt;&gt; null then
		if self.myFutureMoveDR.myWorkListEntry &lt;&gt; null then
			drWLE := self.myFutureMoveDR.myWorkListEntry;
			if drWLE.status &lt;&gt; WLE_COMPLETED then
				if self.status = WLE_COMPLETED then
					self.setStatus(WLE_UNACTIONED);
				endif;
			endif;
		endif;
	endif;
	// tfs42840 end
	
	//epr ccms 1338 
	if self.job.isKindOf(CM_RoadJob) then
		if  self.status = WLE_COMPLETED and self.myTrackedItem.isKindOf(CM_TILC) then
			
			//rebuild status for any more wles in the job where the ti is on the Trailer
			foreach wle in self.job.workListEntries where wle &lt;&gt; self do
				if wle.myTrackedItem = null then
					 continue;
				endif;
				
				if self.myTrackedItem.CM_TILC.hasTIonChassis(wle.myTrackedItem) then
					wle.rebuildStatus();
				endif;
				
			endforeach;		
		endif;
		if self.status = WLE_UNACTIONED and  self.isReleaseToChassis then
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myPrimaryActualLocation = self.job.CM_RoadJob.myVehicle.myUnknownChassis then
				self.setStatus(WLE_PART_COMPLETE);
			endif;
		endif;
		//25 Oct 2018	NDL	TFS 41180 - Oman increasing the amount they unloaded from the truck to a value greater
		// than they brought thru the gate.
		if self.status = WLE_UNACTIONED and self.myTrackedItem &lt;&gt; null and self.myTrackedItem.hasBeenMerged then
			omanMadness := self.getMyTerminal.getConfig( HhTUnloadEdit ).Boolean;
			if omanMadness then
				vvr := self.job.CM_RoadJob.myVehicleVisit;
				if vvr &lt;&gt; null then
					vvr.addAdjCommentToLastUnLoaded();
					self.setStatus( WLE_COMPLETED );
					self.unqueueUnplanMyTrackedItem(app.myPassport);
				endif;
			endif;
		endif;
		
		// 24/08/2022	navcs2	Bug 54274
		if self.status = WLE_COMPLETED and self.myTrackedItem &lt;&gt; null then
			foreach wle in myTrackedItem.allWorklistEntries do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if wle.isKindOf(CM_WOExportReturnedWLE) then
					wle.getWorkOrderTIDtl.setTIComplete(myTrackedItem,null);	//27.03.2023 navma1 #56614:[56615]
				endif;
			endforeach;
		endif;
	endif;
	
	//epr par 25573 most checking will be done above which calls isCompleteForJob
	// we may need to raise some alerts in certain situations
	self.checkForStatusAlerts();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="removeQueueEntry" id="31452b65-a928-4179-9695-dd6d4ba11b4f">
        <updating/>
        <source>removeQueueEntry() updating;

vars

begin
	inheritMethod;	//set QeueEntry = null
	if self.job.isKindOf(CM_YardInternalJob) then
		//-----------------
		//If we are removing an entry from a Yard Internal job,
		//then remove the WLE as well. They have no way of re-doing it.
		//-----------------
		self.erase(0);
  endif;
end;</source>
