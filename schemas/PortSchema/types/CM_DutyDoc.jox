    <JadeMethod name="setForCreate" id="c9724a14-33b1-4011-8cdf-7e526c024b9a">
        <updating/>
        <source>setForCreate(	_proxyDutyDoc : CM_DutyDoc ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	
	//generate ID
	self.id:=_proxyDutyDoc.myDutyDocTerminalRoot.getNextDutyDocId;
	self.myDutyDocTerminalRoot:=_proxyDutyDoc.myDutyDocTerminalRoot;
	self.setForUpdate(_proxyDutyDoc);
	
epilog

end;</source>
        <Parameter name="_proxyDutyDoc" type="CM_DutyDoc"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8a370d19-a503-4182-8c42-5de04b0384b1">
        <updating/>
        <source>setForUpdate(_proxyDutyDoc : CM_DutyDoc) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwer1	Initial creation HAT 2189
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	dutyDocItem: CM_DutyDocItem;
	tiUpdateCntrl : CMIF_TIUpdateController;
begin
	self.ticket := _proxyDutyDoc.ticket;
	self.type 	:= _proxyDutyDoc.type;
	self.manifest :=_proxyDutyDoc.manifest;
	self.forwarder	:= _proxyDutyDoc.forwarder;
	self.forwarderExpiryDate :=_proxyDutyDoc.forwarderExpiryDate;
	self.forwarderLicenseNo :=_proxyDutyDoc.forwarderLicenseNo;
	self.consignee	:= _proxyDutyDoc.consignee;
	self.consigneeExpiryDate :=_proxyDutyDoc.consigneeExpiryDate;
	self.consigneeLicenseNo :=_proxyDutyDoc.consigneeLicenseNo;
	self.deliveryOrder	:=_proxyDutyDoc.deliveryOrder;
	self.deliveryOrderExpiryDate :=_proxyDutyDoc.deliveryOrderExpiryDate;
	self.reExportNumber:=_proxyDutyDoc.reExportNumber;
	self.driver:=_proxyDutyDoc.driver;
	self.transportation:=_proxyDutyDoc.transportation;
	self.border:=_proxyDutyDoc.border;
	self.gcCountry:=_proxyDutyDoc.gcCountry;
	self.exitPort:=_proxyDutyDoc.exitPort;
	self.invTerms:=_proxyDutyDoc.invTerms;
	self.docDeposit:=_proxyDutyDoc.docDeposit;
	self.status:=_proxyDutyDoc.status;
	self.dutyDeposit:=_proxyDutyDoc.dutyDeposit;
	self.customsInspectorUser:=_proxyDutyDoc.customsInspectorUser;
	self.reason:=_proxyDutyDoc.reason;
	self.remarks:=_proxyDutyDoc.remarks;
	self.customRemarks:=_proxyDutyDoc.customRemarks;
	self.effectiveDate:=_proxyDutyDoc.effectiveDate;
	self.voyage := _proxyDutyDoc.voyage;
	self.goodsDescription:=_proxyDutyDoc.goodsDescription; //08 Aug 2013	NDL	Par 32305
	self.destination:=_proxyDutyDoc.destination;  // PAR 32924

	if self.dutyDocUserId = null and _proxyDutyDoc.dutyDocUserId &lt;&gt; null then
		self.dutyDocUserDate := app.actualTimeServer;				// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	self.dutyDocUserId:=_proxyDutyDoc.dutyDocUserId;
	
	if self.supervisorUserId = null and _proxyDutyDoc.supervisorUserId &lt;&gt; null then
		self.supervisorUserDate	:= app.actualTimeServer;				// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	self.supervisorUserId:=_proxyDutyDoc.supervisorUserId;
	
	if  self.docInChargeUserId = null and _proxyDutyDoc.docInChargeUserId &lt;&gt; null then
		self.docInChargeUserDate := app.actualTimeServer;			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.status:=DutyDoc_Validated;
	endif;
	self.docInChargeUserId:=_proxyDutyDoc.docInChargeUserId;
	
	if self.groupSuperUserId = null and _proxyDutyDoc.groupSuperUserId &lt;&gt; null then
		self.groupSuperUserDate	:= app.actualTimeServer;				// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	self.groupSuperUserId:=_proxyDutyDoc.groupSuperUserId;
	
	if _proxyDutyDoc.consignee &lt;&gt; null then      // PAR 34223
		foreach dutyDocItem in self.allDutyDocItems do
			if dutyDocItem.getMyTrackedItem.myConsignee = null or dutyDocItem.getMyTrackedItem.myConsignee.code &lt;&gt; _proxyDutyDoc.consignee then
				dutyDocItem.setConsignee(_proxyDutyDoc.consignee);
				tiUpdateCntrl:=app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
				tiUpdateCntrl.saveTIDataPriorUpdate(dutyDocItem.getMyTrackedItem, app.myPassport);
				dutyDocItem.getMyTrackedItem.setConsigneeByString(_proxyDutyDoc.consignee);
				dutyDocItem.getMyTrackedItem.endUpdate(tiUpdateCntrl,app.myPassport);
				delete tiUpdateCntrl;
			endif;	
		endforeach;
	endif;
	
	app.myEventManager.createSingleObjInfoNoteEvt(self,self.myDutyDocTerminalRoot.myTerminal.getTerminalEvent(EVENT_DUTYDOC_UPDATE),self);
epilog
	delete tiUpdateCntrl;
end;</source>
        <Parameter name="_proxyDutyDoc" type="CM_DutyDoc"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a67f0033-ff12-47b4-9391-089f909cbdd0">
        <updating/>
        <source>setProxy( 	_dutyDocTerminalRoot : CM_DutyDocTerminalRoot;
			_ticket : String;
			_type : String;
			_manifest	: String;
			_forwarder : CM_ConsigneeConsignor;
			_deliveryOrder : String;
			_deliveryOrderExpiry : Date;
			_reexportNumber : String;
			_driver : String;
			_transporation : String;
			_border : String;
			_gcCountry : String;
			_exitPort  :String;
			_invTerms : String;
			_docDeposit : Boolean;
			_status : Integer;
			_dutyDeposit : Decimal;
			_groupSupervisorUser: String;
			_reason,
			_custRemarks : String;
			_remarks : String;
			_effectiveDate : Date;
			_voyage : CM_Voyage;
			_consignee : CM_ConsigneeConsignor;
			_goodsDescription : String;
			_destination : String
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwer1	Initial creation HAT 2189
*/

vars

begin
	
	self.ticket := _ticket;
	self.type 	:= _type;
	self.manifest :=_manifest;
	if _forwarder &lt;&gt; null then 
		self.forwarder	:= _forwarder.code;
		self.forwarderExpiryDate :=_forwarder.licenseExpiryDate;
		self.forwarderLicenseNo :=_forwarder.license;
	endif;
	
	self.deliveryOrder	:=_deliveryOrder;
	self.deliveryOrderExpiryDate :=_deliveryOrderExpiry;
	self.reExportNumber:=_reexportNumber;
	self.driver:=_driver;
	self.transportation:=_transporation;
	self.border:=_border;
	self.gcCountry:=_gcCountry;
	self.exitPort:=_exitPort;
	self.invTerms:=_invTerms;
	self.docDeposit:=_docDeposit;
	self.status:=_status;
	self.dutyDeposit:=_dutyDeposit;
	self.destination:=_destination;  // PAR 32924
	
	self.customsInspectorUser:=_groupSupervisorUser;
	self.reason:=_reason;
	self.customRemarks:=_custRemarks;
	self.remarks:=_remarks;
	self.goodsDescription:=_goodsDescription;//08 Aug 2013	NDL	Par 32305
	
	self.effectiveDate := _effectiveDate;
	if _voyage &lt;&gt; null then
		self.voyage := _voyage.code;
	endif;
	if _consignee &lt;&gt; null then
		self.consignee := _consignee.code;
		self.consigneeExpiryDate :=_consignee.licenseExpiryDate;
		self.consigneeLicenseNo :=_consignee.license;
	endif;
	
	self.myDutyDocTerminalRoot:=_dutyDocTerminalRoot;
epilog

end;</source>
        <Parameter name="_dutyDocTerminalRoot" type="CM_DutyDocTerminalRoot"/>
        <Parameter name="_ticket" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_manifest" type="String"/>
        <Parameter name="_forwarder" type="CM_ConsigneeConsignor"/>
        <Parameter name="_deliveryOrder" type="String"/>
        <Parameter name="_deliveryOrderExpiry" type="Date"/>
        <Parameter name="_reexportNumber" type="String"/>
