	cashToPay := 520; 	// 440 + 80 is the actual amount required
*/
/* TFS 45953 change to use the single unit test 'create cash receipt'		cashReceipt2 := self.createFullCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
