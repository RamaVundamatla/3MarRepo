// ---------------------------------------------------------------------------
// Created:     20 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.myGridColumn &lt;&gt; null then  // PAR 20345
		_value := self.myGridColumn.x1;
	else // PAR 28701
		_value := 42;
	endif;

end;</source>
