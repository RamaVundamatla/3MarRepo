    <JadeMethod name="processOfflineFutureActor" id="4d527afc-32a6-4223-9c4a-b86480790178">
        <updating/>
        <source>processOfflineFutureActor(actor : CM_OfflineFutureActor io) protected, updating;

/*

Purpose:			Process the passed in offline actor, then delete it


Return Value:		None


Date		Who		Reason
					An exception (4) during finaliseTransaction meant that the transaction was aborted, and 'actor' was resurrected.
					'actor' was not added to 'allNonProcessableActors', so it was immediately and repeatedly reprocessed.
22/01/2019	jlgdap1	TFS 42925 PEL1 Container Services - Estimation Approval Countdown
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	edition: Integer;
	invalid: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, actor, invalid);

	if actor.doAction() then
		// TFS 42925 CM_CashStatusAdvanceProcess actors get deleted as part of their processing
		edition := actor.edition();
		if not invalid and not actor.isCashStatusAdvanceActor then				//28.05.2024 navma1 #64224
			delete actor;
		endif;
	else
		self.logErrorMessage("doAction failed for " &amp; actor.longDisplay &amp; ", adding to non-processing list");
		self.allNonProcessableActors.addNoDuplicates(actor, false);			// prevent any attempts to reprocess
	endif;


epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="actor" type="CM_OfflineFutureActor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processOfflineFutureActorTrx" id="3a235133-e7c3-4888-a9d8-37f7337e849d">
        <updating/>
        <source>processOfflineFutureActorTrx(actor : CM_OfflineFutureActor io) updating;

/*

Purpose:			Process the passed in OfflineFutureActor, handling exception arming and
					transaction state


Return Value:


Date		Who		Reason
17 Jan 2005	KPD		PAR #5202 - SUTARE 1007 Timer Task

*/

vars

	doAbort : Boolean;	//09 Apr 2019	NDL	TFS 44253
	
begin
	on Exception do actionExceptionHandler(exception, actor);
	on LockException do lockExceptionHandler(exception, actor);
	on DeadlockException do lockExceptionHandler(exception, actor);

	doAbort := true;
	beginTransaction;
	self.processOfflineFutureActor(actor);
	commitTransaction;
	doAbort := false;

epilog

	if doAbort then
		abortTransaction;
	endif;

end;</source>
        <Parameter name="actor" type="CM_OfflineFutureActor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processReadyActors" id="1011ded8-d8ff-478b-9111-2c85ab51a788">
        <updating/>
        <source>processReadyActors() protected, updating;

/*

Purpose:			Process any CM_OfflineFutureActor instances that are ready for processing


Return Value:		


Date		Who		Reason
13 Sep 2017 cnwma1  TFS #6784 UE 4 in app UiCommonSchema::BGP_FutureTimerController of DPHPJMT3
02 May 2019	jlgdi1	TFS# 44399 Added a check to prevent it from getting stuck processing the same actor
					not advancing to the next actor due to invalid / deleted object
*/

vars
	count		: Integer;
	actor		: CM_OfflineFutureActor;
	invalidObj  : Boolean;
	edition : Integer;
	doAbort : Boolean;	//09 Apr 2019	NDL	TFS 44253
	lastProcessedActor : CM_OfflineFutureActor;
	
begin
	on Exception do app.handleDeletedObject( exception, actor, invalidObj ); // 13.9.2017 cnwma1 TFS #6784
	while true do
		
		// Get the next OfflineFutureActor ready to process
		actor := self.getNextActorToProcessNow();
       
		// If there are none, then exit
		if actor = null then
			break;
		endif;
		
		// 13.9.2017 cnwma1 TFS #6784
		invalidObj := false;
		edition := actor.edition;
		if invalidObj then
			break;
		endif;
		
		// TFS 44399
		if (lastProcessedActor &lt;&gt; null) and 
		   (lastProcessedActor = actor)
		then
			self.allNonProcessableActors.addNoDuplicates(actor, false);
			actor := self.getNextActorToProcessNow();
			if actor = null then
				break;	// Nothing to do
			endif;
		endif;
		
		self.processOfflineFutureActorTrx(actor);
		count := count + 1;
		
		lastProcessedActor := actor;
	endwhile;

	// at the end if anything has been done update the BGP_Controller last completed date/time
	if self.myBGPController &lt;&gt; null and
	   count &gt; 0 then
		doAbort := true;
		beginTransaction;
		self.myBGPController.setLastCompleted();
		commitTransaction;
		doAbort := false;
	endif;

epilog

	if doAbort then
		abortTransaction;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="registerForNotifications" id="adc1c486-2d41-4759-a676-9a2c03675dca">
        <source>registerForNotifications() protected;

/*

Purpose:			Register for notifications to wake up early for immediate
					processing if required.  This will allow other applications to
					request an immediate check of any OfflineFutureActor instances 
					to process.


Return Value:		None


Date		Who		Reason
17 Jan 2005	cnwkpd1	PAR #5202 - SUTARE 1007 Timer Task

*/

vars

begin
	beginNotification(app.myRoot, EVENT_OFFLINEFUTURE_PROCESS, Response_Continuous, null);
	self.logMessage("Registered for EVENT_OFFLINEFUTURE_PROCESS notifications");
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="start" id="276e293e-7bc2-4152-a004-d360a40af213">
        <updating/>
        <source>start(_bgpController : BGP_Controller) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
17 Jan 2005	cnwkpd1	PAR #5202 - SUTARE 1007 Timer Task

*/

vars

begin
	on Exception do startupExceptionHandler(exception);
	
	self.myBGPController := _bgpController;
	
	// Unconditionally get a stack dump from CardSchema
	app.myCnCntrl.setLogCallStackDump(true);
	
	// Register for additions to the queue of OfflineFutureActor objects to be created
	self.registerForNotifications;
	
	// Drop deadlock priority
	process.setPersistentDeadlockPriority(process.getPersistentDeadlockPriority - 1);

	// Start a continuous timer to ensure regular checks
	self.startContinuousTimer;
	
	// Start a one shot timer to do the first check once the offline actor handler has had a chance to process
	self.startOneShotTimer(Timer_Startup_Delay);

	// Now go to idle state and let notifications and timers take over


epilog

end;</source>
        <Parameter name="_bgpController" type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="startContinuousTimer" id="1c478977-2812-4f9a-ad57-22d466718f69">
        <source>startContinuousTimer() protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
17 January 2005	cnwkpd1	PAR #5202 - SUTARE 1007 Timer Task

*/

vars

begin
	self.beginTimer(Standard_Timer_Delay, Timer_Continuous, EVENT_TIMER_OFFLINEFUTURE_CONT);
	self.logDiagMessage("Timer " &amp; EVENT_TIMER_OFFLINEFUTURE_CONT.String &amp; " started, delay=" &amp; Standard_Timer_Delay.String);


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="startOneShotTimer" id="114a5f1f-b6fe-43d0-a392-a39a0e84a098">
        <source>startOneShotTimer(delay : Integer) protected;

/*

Purpose:			Start the process timer with the specified delay


Return Value:		


Date		Who		Reason
17 Jan 2005	cnwkpd1	PAR #5202 - SUTARE 1007 Timer Task

*/

vars

begin
	// First stop any existing timer, if there is one
	self.stopOneShotTimer();
		
	// And start a new one
	self.beginTimer(delay, Timer_OneShot, EVENT_TIMER_OFFLINEFUTURE_ONE);
	self.logDiagMessage("Timer " &amp; EVENT_TIMER_OFFLINEFUTURE_ONE.String &amp; " started, delay=" &amp; delay.String);
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="delay" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startupExceptionHandler" id="7539c63d-7a27-4a1e-b279-4d11fee95573">
        <source>startupExceptionHandler(exc : Exception) : Integer protected;

/*

Purpose:			Handle any exception during OfflineActorApp Handler startup, by doing 
					an Ex_Resume_Next, to ensure that the app stays running 


Return Value:


Date		Who		Reason
					
*/

vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	if exc.resumable then
		self.logMessage(exc.class.name &amp; " " &amp; exc.errorCode.String &amp; " during startup, returning Ex_Resume_Next");
	
		app.cmsAbortTransaction();
		returnVal := Ex_Resume_Next;
		return returnVal;
	endif;
	
epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="stopOneShotTimer" id="ca2bd1dd-e29d-4f89-8cdf-df231845bc03">
        <source>stopOneShotTimer() protected;

/*

Purpose:			Stop the current timer if there is one active


Return Value:		


Date		Who		Reason
17 Jan 2005	cnwkpd1	PAR #5202 - SUTARE 1007 Timer Task

*/

vars
	option,
	timeRemaining	: Integer;
	
begin
	if getTimerStatus(EVENT_TIMER_OFFLINEFUTURE_ONE, option, timeRemaining) then
		endTimer(EVENT_TIMER_OFFLINEFUTURE_ONE);
		logDiagMessage("Timer " &amp; EVENT_TIMER_OFFLINEFUTURE_ONE.String &amp; " stopped, option=" &amp; 
			option.String &amp; ", timeRemaining=" &amp; timeRemaining.String);
	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="test" id="9fa9380d-d8a5-490c-a8de-de4cde6f7b13">
        <updating/>
        <source>test(_startTime : TimeStamp; _endTime : TimeStamp) updating;
//	Call this method instead of 'start' from a test environment, to process
//		all future actors within the nominated time period.

vars

begin
	// set the start and end times to limit the processing
	self.startTime := _startTime;
	self.endTime := _endTime;

	self.processReadyActors();

end;
</source>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_endTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="8a736359-6f75-4a19-8758-85706c5656f6">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason

*/

vars
	msg				: String;
	
begin

	if eventTag = EVENT_TIMER_OFFLINEFUTURE_ONE or eventTag = EVENT_TIMER_OFFLINEFUTURE_CONT then
	
		if system.getDatabaseRole = SDS_RoleSecondary then
			// If we're a secondary, then just log a message, in case we become the primary
			self.logMessage("Timer event " &amp; eventTag.String &amp; " received, running in SDS Secondary, ignored");
			return;
		endif;		
	
		msg := "Timer event " &amp; eventTag.String &amp; " received, processing ready actors";
		if eventTag = EVENT_TIMER_OFFLINEFUTURE_ONE then
			self.logDiagMessage(msg);
		else
			// Always log message for continuous timer, so we can see it is working OK
			self.logMessage(msg);
		endif;
		
		// Process any actors ready to go
		self.processReadyActors;
		
		// Fire off another timer if required
		self.calculateDelayAndStartTimer;
	endif;
	
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="8a971a0f-345c-4358-9eac-58090ff90a87">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Purpose:			Handle possible wakeup call from another application 


Return Value:		


Date		Who		Reason
17 Jan 2005	cnwkpd1	PAR #5202 - SUTARE 1007 Timer Task
20 Jun 2005	KPD		PAR #6096 - SDS secondary - don't want to process anything if
					we are a secondary

*/

vars

begin
	if eventType = EVENT_OFFLINEFUTURE_PROCESS and theObject = app.myRoot then
		if system.getDatabaseRole = SDS_RoleSecondary then
			// If we're a secondary, do nothing
			self.logDiagMessage("EVENT_OFFLINEFUTURE_PROCESS notification received, running in SDS Secondary, ignored");
			return;
		endif;
		
		self.logDiagMessage("EVENT_OFFLINEFUTURE_PROCESS notification received");
		
		// Handle this by simply calling the recalculate to check when/if the new timer
		// needs to fire
		self.calculateDelayAndStartTimer;
		
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
