    <JadeMethod name="hideAuditValues" id="0c5d6bad-0823-45f5-bce7-e2e0f970da7b">
        <source>hideAuditValues( _lDetail : String ; _toHide : String ; mask : Character) : String;

/*

Purpose:	to mask values in the audit record string (based on prior security permissions check)

Parameters:		string of audit changes, attribute field to mask values for, mask character	

Return Value:		masked String of audit changes


Date		Who		Reason
13 November 2008	cnwrd1	Initial creation

//cnwrd1 10.11.08 CCMS JMT 1743/1764 
*/

vars
	str : String;
	attrPos : Integer;
	sepPos : Integer;
	endPos : Integer;
	attrLen : Integer;
	maskLooper : Integer;
begin

//write '';
//write '*********';
//write '(' &amp; _lDetail &amp; ')(' &amp; _toHide &amp; ')(' &amp; mask &amp;')';

	str := _lDetail;
	
	//write str;
	
	attrPos := str.pos (_toHide, 1); // find if we have the attribute name in the string
	
	//write 'attrPos=' &amp; attrPos.String;
	
	if attrPos &lt;&gt; 0 then // yes so we have values to mask
	
		//find the separator position 
		//sepPos:= str.pos (" =&gt; ", attrPos);
		sepPos:= str.pos (" =&gt;", attrPos);  //par 18852 cnwjo3
		
		//get the length of the attribute for late calcs
		attrLen := _toHide.length;
		
		//write 'attrLen=' &amp; attrLen.String;		
		//write 'sepPos=' &amp; sepPos.String;
		
		//check for the prior value 		
		if sepPos = ( attrPos+attrLen +1 ) then
			//no prior value do nuffin to that.
			//write ' blank b4 set';
		else
		// have to mask out the prior value	(?)			
			foreach maskLooper in ( attrPos+attrLen +1 ) to ( sepPos-1) do
				str[maskLooper] := mask;
			endforeach;
		
		endif;

		//find the new value and mask
		//look for the end of the attr set, can be ':' or new line I think
		
		endPos := str.pos (":", sepPos);
		//write 'endPos=' &amp; endPos.String;
		
		if ((str.pos (CrLf, sepPos) &lt;&gt; 0 ) and (str.pos (CrLf, sepPos) &lt; endPos )) or endPos = 0 then //eol before ':'
			endPos := str.pos (CrLf, sepPos);
		//	write 'endPos=' &amp; endPos.String;
		endif;
		
		//24 Jan 2011	NDL Par 26802 - Only one item on the line, so no separator.
		if endPos = 0 then
			endPos := str.length + 1;
		endif;
		
		
		//mask out the value
		foreach maskLooper in ( sepPos + 4  ) to ( endPos -1 ) do
			str[maskLooper] := mask;
		endforeach;
		
	endif;
	
	
//write '';
//write 'result :(' &amp; str;
//write '';

return str;

epilog

end;</source>
        <Parameter name="_lDetail" type="String"/>
        <Parameter name="_toHide" type="String"/>
        <Parameter name="mask" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isChangedId" id="9fcbe55d-e240-4aa4-a513-854a54699fed">
        <source>isChangedId( _oldId : String output):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwndl1	Initial creation	TFS 2277 / 2561

*/

constants
	ChangeFieldId : String = "id ";
	ChangeInd : String = "=&gt;";
vars

	editStrings	: HugeStringArray;
	string : String;
	id1 : String;
	id2 : String;
	pos : Integer;

begin

	if self.deleted then
		return false;
	endif;

	if self.fieldsValues &lt;&gt; null then 
	
		create editStrings transient;
		
		self.fieldsValues.getStrings(editStrings);
		
		foreach string in editStrings do
			
			if string[1:3] = ChangeFieldId then
				//example "id BISH1112223 =&gt; XXXX1112223"
				pos := string.pos(ChangeInd,1);
				if pos &gt; 0 then
					id1 := string[4 : (pos - 5)].trimBlanks;
					id2 := string[(pos + 3) : end].trimBlanks;
					if id1 &lt;&gt; null and id1 &lt;&gt; id2 and id2 = self.myTrackedItem.id then
						_oldId := id1;
						return true;
					endif;
				endif;
			endif;
		
		endforeach;
	endif;
	
	return false;

epilog

	delete editStrings;

end;</source>
        <Parameter name="_oldId" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
