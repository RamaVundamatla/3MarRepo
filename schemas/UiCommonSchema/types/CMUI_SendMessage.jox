    <JadeMethod name="setupForm" id="2b863f43-ffaa-4e6b-b20d-c654a5455bc8">
        <updating/>
        <source>setupForm() updating;
/*
---------------------------------------------------------------------------
Created:		26 November 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:		Nothing
Changed On		Changed By		Reason
--------------	--------------	-------------------------------------------
03 Apr 2008		cnwkpd1			PAR #16421 - Remove notifications from this
								form to reduce locking on system objects and
								collections
---------------------------------------------------------------------------
*/

begin
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;

	inheritMethod();
	self.setNavigatorHeading('Send Message');
	self.endNotificationForSubscriber(self);
	self.loadUsers();
//	self.beginClassNotification(Process, false, Object_Create_Event, Response_Continuous, null);		// PAR #16421
//	self.beginClassNotification(Process, false, Object_Delete_Event, Response_Continuous, null);
//	self.beginClassNotification(Process, false, Event_ProcessUserCodeUpdate, Response_Continuous, null);
end;</source>
    </JadeMethod>
