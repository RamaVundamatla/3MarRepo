    <JadeMethod name="getFwdShipReportDetails" id="a631564f-c00e-4bee-9ecb-f24c15e10c17">
        <updating/>
        <source>getFwdShipReportDetails(voyage: CM_Voyage; strArrayOut: StringArray input; strOut: String output) updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------------
// 14/09/2012	cnwdap1		PAR #30248 Put real arrival time in report instead of "Not Selected"
//
vars
	mov: 			HMS_VoyageMovement;
	str,sVessel,sBerth,sCode,sGRT,sLOA,sAgent,sCargoDis,sCargoLoad,sLast,sNext,sWWD,sETA : String;
	arriveDate,departDate : TimeStamp;
	sStevedoreLoad, sStevedoreDischarge:	String;
	agent:			CM_ShippingAgent;
	allAgents: 		CM_ShippingAgentByCodeDict;
	//cargo:			CM_Commodity;	// ### TFS 53132 20Apr2022 NAVPW1
	cargoForecast	: CM_CargoForecast;	// ### TFS 53132 20Apr2022 NAVPW1
	toFileMode,
	dischargeCommoditiesFound,
	loadCommoditiesFound	: Boolean;
	cargoStr:		String;
	voyageData:		HMS_VoyageData;	
	tmpBerth		: HMS_Berth;
begin
	// This is a generic method that is shared by the "print to printer (printForwardShippingReport)"
	// and "write to file (writeReportToFile)" methods

	voyageData := voyage.myHMSVoyageData;
	if voyageData = null then
		return;
	endif;
	// Initialise arriveDate,departDate
	arriveDate:=null;
	departDate:=null;

	// Set the "to file mode" flag
//	if init.cbxSendToFile.value=true then
	if strArrayOut=null then
		// To printer
		toFileMode:=false;
	else
		// To file
		toFileMode:=true;
	endif;
	//vesselData := voyage.getMyHMSVesselData();

	// Create holding collection of all agents used on this voyage
	create allAgents transient;

 	if voyageData &lt;&gt; null then
		sVessel := voyage.vesselName;
		sGRT	:= voyageData.dim_GrossRegTonnes.String;
		sLOA	:= voyageData.dim_LengthOverall.String;
		//if voyage.vessel.CM_HMS_Vessel.country &lt;&gt; null then
		//	sFlag := voyage.vessel.CM_HMS_Vessel.country.description;
		//endif;
	endif;
	// Build colelction of all agents assigned to this voyage
	allAgents.clear;
	foreach mov in voyageData.allVoyageMovements do
		if mov.myShippingAgent &lt;&gt; null and mov.isAgentDefault then
			if allAgents.includes(mov.myShippingAgent)=false then
				// Add agent to collection of agents for this voyage
				allAgents.add(mov.myShippingAgent);
			endif;
		endif;
	endforeach;
	if allAgents.size&gt;0 then
		foreach agent in allAgents do
			sAgent:=sAgent &amp; agent.description &amp; "; ";
		endforeach;
		// Trim last comma from string
		sAgent:=sAgent.String[1:((sAgent.length)-2)];
	else
		sAgent:=app.getErrorString(NoneSelected);
	endif;

	// ------------------------------------------------------------------
	// Voyage No. field is the number of times the vessel has visited the harbour
	sCode := self.myHarbour.getVesselVisitCountStr(voyage.vesselCode, voyage.arrivedDT);
	if sCode = '0' then
		sCode := app.getErrorString(ShipVoyageCodeInvalid);	
	endif;
	// ------------------------------------------------------------------

	// Build Cargo to discharge list
	/*if voyageData.allCommodityDischarge.isEmpty then
		sCargoDis:="-";	
	else
		foreach cargo in voyageData.allCommodityDischarge do
			cargoStr:=cargo.description.trimRight; // RH
			cargoStr.replaceChar(",".Character, "/".Character); // RH
			sCargoDis:=sCargoDis &amp; cargoStr &amp; "; "; // RH
		endforeach;
		// Trim last comma from string
		sCargoDis:=sCargoDis.String[1:((sCargoDis.length)-2)];
	endif;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out

	// ### TFS 53132 11Apr2022 NAVPW1
	// Replaces above commented block
	// Build Cargo to discharge list
	foreach cargoForecast in voyage.allCargoForecasts where cargoForecast.mode = CM_CargoForecast.Mode_Discharge do
		if cargoForecast.myCargoType = null and cargoForecast.myCommodity = null then
			continue;
			
		elseif cargoForecast.myCargoType &lt;&gt; null then
			cargoStr := cargoForecast.myCargoType.description.trimRight;
			
		elseif cargoForecast.myCommodity &lt;&gt; null then
			cargoStr := cargoForecast.myCommodity.description.trimRight;
			
		endif;
		
		cargoStr.replaceChar(",".Character, "/".Character);
		sCargoDis := sCargoDis &amp; cargoStr &amp; "; ";
		
		if not dischargeCommoditiesFound then
			dischargeCommoditiesFound := true;
			
		endif;
	endforeach;
	
	if not dischargeCommoditiesFound then
		sCargoDis := "-";	
	else
		// Trim last comma from string
		sCargoDis := sCargoDis.String[1:((sCargoDis.length)-2)];
	endif;
	// ### TFS 53132 11Apr2022 NAVPW1
	
	// Build Cargo to load list
	/*if voyageData.allCommodityLoad.isEmpty then
		sCargoLoad:="-";	
	else
		foreach cargo in voyageData.allCommodityLoad do
			cargoStr:=cargo.description.trimRight; // RH
			cargoStr.replaceChar(",".Character, "/".Character); // RH
			sCargoLoad:=sCargoLoad &amp; cargoStr &amp; "; ";
		endforeach;
		// Trim last comma from string
		sCargoLoad:=sCargoLoad.String[1:((sCargoLoad.length)-2)];
	endif;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
	
	// ### TFS 53132 19Apr2022 NAVPW1
	foreach cargoForecast in voyage.allCargoForecasts where cargoForecast.mode = CM_CargoForecast.Mode_Load do
		if cargoForecast.myCargoType = null and cargoForecast.myCommodity = null then
			continue;
			
		elseif cargoForecast.myCargoType &lt;&gt; null then
			cargoStr := cargoForecast.myCargoType.description.trimRight;
			
		elseif cargoForecast.myCommodity &lt;&gt; null then
			cargoStr := cargoForecast.myCommodity.description.trimRight;
			
		endif;
		
		cargoStr.replaceChar(",".Character, "/".Character);
		sCargoLoad := sCargoLoad &amp; cargoStr &amp; "; ";
		
		if not loadCommoditiesFound then
			loadCommoditiesFound := true;
			
		endif;
	endforeach;
	
	if not loadCommoditiesFound then
		sCargoLoad := "-";
		
	else
		// Trim last comma from string
		sCargoLoad := sCargoLoad.String[1:((sCargoLoad.length)-2)];
		
	endif;
	// ### TFS 53132 19Apr2022 NAVPW1
	
	// Modified by Russell 04/05/99
	// ---------------------------------------------------------
	// Build stevedore to load list
	if voyageData.allStevedoresLoad.size&gt;0 then
		// get Stevedores to load	
		sStevedoreLoad:=getStevedoresLoad(voyageData, toFileMode);
	else
		sStevedoreLoad:="-";
	endif;

	// Build stevedore to discharge list
	if voyageData.allStevedoresDischarge.size&gt;0 then
		// get Stevedores to discharge	
		sStevedoreDischarge:=getStevdoresDischarge(voyageData, toFileMode);
	else
		sStevedoreDischarge:="-";
	endif;
	// ---------------------------------------------------------


	if voyageData.myPortFrom &lt;&gt; null then
		sLast := voyageData.myPortFrom.description;
	endif;	
	if voyageData.myPortTo &lt;&gt; null then
		sNext := voyageData.myPortTo.description;
	endif;	
	foreach mov in voyageData.allVoyageMovements do
		tmpBerth := mov.getMyBerth();
		
		if mov.moveType=HMSMovementTypeArrival then
			if tmpBerth &lt;&gt; null then
				arriveDate := mov.occursOnDTNEW;									// PAR #30248
				if tmpBerth.myWharf &lt;&gt; null and (not mov.isLogicalBerth()) then
					//arriveDate := mov.occursOnDTNEW;								// PAR #30248
 			  		//AJA 19/5/00: Add planned berth to report
	   				sBerth := tmpBerth.code;
				endif;
			endif;	
		endif;		
		if mov.moveType=HMSMovementTypeShift and arriveDate = null then
			// note this is the arrival at the berth - the arrival movement may be to the roadstead so the
			// arrival at a berth is a shift movement
			arriveDate := mov.occursOnDTNEW;
	  		//AJA 19/5/00: Add planned berth to report
			sBerth := tmpBerth.code;
		endif;
		if mov.moveType=HMSMovementTypeDeparture then
   			departDate := mov.occursOnDTNEW;
   		endif;

	endforeach;

	if arriveDate=null or departDate=null then
		sWWD:="0";
	else
		sWWD := (departDate.date - arriveDate.Date).String;
	endif;
	if arriveDate=null then
		sETA:=app.getErrorString(NoneSelected);
	else	
		sETA := arriveDate.date.shortFormatJMT() &amp; " " &amp; arriveDate.Time.userFormat($CM_HMS_Time24Hour);
 	endif;

	// Determine whether to pass back an array or a string
	if strArrayOut&lt;&gt;null then
		// Pass back an array
		strArrayOut.add(sVessel);
		strArrayOut.add(sETA);		//AJA 22/11/00: Shuffled columns
		strArrayOut.add(sBerth);
		strArrayOut.add(sCode);
		strArrayOut.add(sGRT);
		strArrayOut.add(sLOA);
		strArrayOut.add(sAgent);
		strArrayOut.add(sCargoDis);
		strArrayOut.add(sCargoLoad);
		strArrayOut.add(sStevedoreDischarge);
		strArrayOut.add(sStevedoreLoad);
		strArrayOut.add(sLast);
		strArrayOut.add(sNext);
		strArrayOut.add(sWWD);
	else 
		// Pass back string
		str := 	sVessel &amp; Tab &amp; sETA &amp; Tab &amp; sBerth &amp; Tab &amp; sCode &amp; Tab &amp; sGRT &amp; Tab &amp; sLOA &amp; Tab &amp; sAgent &amp; Tab &amp; sCargoDis &amp; Tab;
		str := str &amp; sCargoLoad &amp; Tab &amp; sStevedoreDischarge &amp; Tab &amp; sStevedoreLoad &amp; Tab &amp; sLast &amp; Tab &amp; sNext &amp; Tab &amp; sWWD;

		//str := 	sVessel &amp; Tab &amp; sCode &amp; Tab &amp; sAgent &amp; Tab &amp; sStevedoreDischarge &amp; " " &amp; sStevedoreLoad 
		//&amp; Tab &amp;sBerth &amp; Tab &amp; "" &amp; Tab &amp; sETA &amp; Tab &amp; sWWD &amp; Tab &amp; sCargoDis &amp; Tab;
		//str := str &amp; sCargoLoad &amp; Tab &amp;  sLast &amp; Tab &amp; sNext &amp; Tab  ;

		strOut:=str;
	endif;
epilog
	delete allAgents;
end;</source>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="strArrayOut" type="StringArray" usage="input"/>
        <Parameter name="strOut" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getShipReportDetails" id="49e1cbf7-be92-4cfb-a5e7-0924f15cd4a3">
        <updating/>
        <source>getShipReportDetails(voyage: CM_Voyage; strArrayOut: StringArray input; strOut: String output) updating;

vars
	mov,movPrev: 	HMS_VoyageMovement;
	last: 			Boolean;
	str,sVessel,sCode,sAgent,sStevedore,sBerth,sPhone,sArrive,sDepart,sCargoLoad,sCargoDis,sLast,sNext : String;	
	allAgents: 		CM_ShippingAgentByCodeDict;
	agent:			CM_ShippingAgent;
	//cargo:			CM_Commodity;	// ### TFS 53132 20Apr2022 NAVPW1
	cargoForecast	: CM_CargoForecast; // ### TFS 53132 14Apr2022 NAVPW1
	resUsed:		HMS_ResourceUsed;
	toFileMode,
	dischargeCommoditiesFound,
	loadCommoditiesFound		: Boolean;	// ### TFS 53132 14Apr2022 NAVPW1
	cargoStr:		String; // RH 21/12/99
//	vesselData:		HMS_VesselData;
	voyageData:		HMS_VoyageData;		
begin
	// This is a generic method that is shared by the "print to printer (printShippingReport)"
	// and "write to file (writeReportToFile)" methods
	if voyage = null then
		return;
	endif;
	
//	vesselData := voyage.getMyHMSVesselData();
	voyageData := voyage.myHMSVoyageData;
	if voyageData = null then
		return;
	endif;

	// Set the "to file mode" flag
	if strArrayOut=null then
		// To printer
		toFileMode:=false;
	else
		// To file
		toFileMode:=true;
	endif;

	// Create holding collection of all agents used on this voyage
	create allAgents transient;

	sVessel := voyage.vesselName;

	// Build colelction of all agents assigned to this voyage
	allAgents.clear;
	foreach mov in voyageData.allVoyageMovements do
		if mov.myShippingAgent&lt;&gt;null and mov.isAgentDefault=true then
			if allAgents.includes(mov.myShippingAgent)=false then
				// Add agent to collection of agents for this voyage
				allAgents.add(mov.myShippingAgent);
			endif;
		endif;
	endforeach;
	if allAgents.size&gt;0 then
		foreach agent in allAgents do
			sAgent:=sAgent &amp; agent.description &amp; "; ";
		endforeach;
		// Trim last comma from string
		sAgent:=sAgent.String[1:((sAgent.length)-2)];
	else
		sAgent:=app.getErrorString(NoneSelected);
	endif;

	// Get Stevedores working the ship
	// -----------------------------------------------------------------
	// Return Stevedores who are loading ship - if no one loading, then who is discharging.
	if voyageData.allStevedoresLoad.size&gt;0 then
		// get Stevedores to load	
		sStevedore:=getStevedoresLoad(voyageData, toFileMode);
	else
		// See if any stevedores for discharge
		if voyageData.allStevedoresDischarge.size&gt;0 then
			// get Stevedores to discharge	
			sStevedore:=getStevdoresDischarge(voyageData, toFileMode);
		else
			sStevedore:="-";
		endif;
	endif;
	// -----------------------------------------------------------------


	// ------------------------------------------------------------------
	// Voyage No. field is the number of times the vessel has visited the harbour
	sCode := self.myHarbour.getVesselVisitCountStr(voyage.vesselCode, voyage.arrivedDT);
	if sCode = '0' then
		sCode := app.getErrorString(ShipVoyageCodeInvalid);	
	endif;
	// ------------------------------------------------------------------
	
	//sPhone	:= '???';	// phone
	// Build Cargo to discharge list
	/*if voyageData.allCommodityDischarge.size&gt;0 then
		foreach cargo in voyageData.allCommodityDischarge do
			cargoStr:=cargo.description.trimRight; // RH
			cargoStr.replaceChar(",".Character, "/".Character); // RH
			sCargoDis:=sCargoDis &amp; cargoStr &amp; "; "; //RH
		endforeach;
		// Trim last comma from string
		sCargoDis:=sCargoDis.String[1:((sCargoDis.length)-2)];
	else
		sCargoDis:="-";
	endif;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
	
	// ### TFS 53132 11Apr2022 NAVPW1
	// Replaces above commented block
	// Build Cargo to discharge list
	// Added Cargo type to be included if set by Andrews Recommendation
	foreach cargoForecast in voyage.allCargoForecasts where cargoForecast.mode = CM_CargoForecast.Mode_Discharge do
		if cargoForecast.myCargoType = null and cargoForecast.myCommodity = null then
			continue;
			
		elseif cargoForecast.myCargoType &lt;&gt; null then
			cargoStr := cargoForecast.myCargoType.description.trimRight;
			
			
		elseif cargoForecast.myCommodity &lt;&gt; null then
			cargoStr := cargoForecast.myCommodity.description.trimRight;
			
		endif;
		
		cargoStr.replaceChar(",".Character, "/".Character);
		sCargoDis := sCargoDis &amp; cargoStr &amp; "; ";
		
		if not dischargeCommoditiesFound then
			dischargeCommoditiesFound := true;
			
		endif;
	endforeach;
	
	if not dischargeCommoditiesFound then
		sCargoDis := "-";
		
	else
		// Trim last comma from string
		sCargoDis := sCargoDis.String[1:((sCargoDis.length)-2)];
		
	endif;
	// ### TFS 53132 11Apr2022 NAVPW1
	
	// Build Cargo to load list
	/*if voyageData.allCommodityLoad.size&gt;0 then
		foreach cargo in voyageData.allCommodityLoad do
			cargoStr:=cargo.description.trimRight; // RH
			cargoStr.replaceChar(",".Character, "/".Character); // RH
			sCargoLoad:=sCargoLoad &amp; cargoStr &amp; "; ";   // RH
		endforeach;
		// Trim last comma from string
		sCargoLoad:=sCargoLoad.String[1:((sCargoLoad.length)-2)];
	else
		sCargoLoad:="-";
	endif;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out

	// ### TFS 53132 12Apr2022 NAVPW1
	// Added Cargo type to be included if set by Andrews Recommendation
	foreach cargoForecast in voyage.allCargoForecasts where cargoForecast.mode = CM_CargoForecast.Mode_Load do
		if cargoForecast.myCargoType = null and cargoForecast.myCommodity = null then
			continue;
			
		elseif cargoForecast.myCargoType &lt;&gt; null then
			cargoStr := cargoForecast.myCargoType.description.trimRight;
			
			
		elseif cargoForecast.myCommodity &lt;&gt; null then
			cargoStr := cargoForecast.myCommodity.description.trimRight;
		endif;
		
		cargoStr.replaceChar(",".Character, "/".Character);
		sCargoLoad := sCargoLoad &amp; cargoStr &amp; "; ";
		
		if not loadCommoditiesFound then
			loadCommoditiesFound := true;
			
		endif;
	endforeach;
	
	if not loadCommoditiesFound then
		sCargoLoad := "-";
		
	else
		// Trim last comma from string
		sCargoLoad := sCargoLoad.String[1:((sCargoLoad.length)-2)];
		
	endif;
	// ### TFS 53132 12Apr2022 NAVPW1
	
	if voyageData.myPortFrom &lt;&gt; null then
		sLast := voyageData.myPortFrom.description;
	endif;	
	if voyageData.myPortTo &lt;&gt; null then
		sNext := voyageData.myPortTo.description;
	endif;
	
	// rules for the report 
	// pType = 0  - In Port
	//      berth = the berth at the "report from time" (pFirstTimeStamp)
	//		arrive / depart dates are the arrive and depart dates for the voyage in the terminal, not a shift	

	// roadstead, berth, arrival, departure
	foreach mov in voyageData.allVoyageMovements do
		if mov.moveType=HMSMovementTypeArrival then
			if mov.getMyBerth &lt;&gt; null then
				if mov.isLogicalBerth() then
					//sRoad := mov.occursOnDT.Date.format('dd/MM') &amp; "- " &amp; mov.occursOnDT.Time.userFormat($CM_HMS_Time24Hour);
				else
					// note this is the arrival at the berth - the arrival movement may be to the roadstead so the
					// arrival at a berth is a shift movement
	       			sArrive:= mov.occursOnDTNEW.date.shortFormatJMT() &amp; "  " &amp; mov.occursOnDTNEW.Time.userFormat($CM_HMS_Time24Hour);
					if pType=0 then
						sBerth 	:= mov.getMyBerth.code;
						// Get phone/s at this berth if connected
						if mov.allResourceUsed.size&gt;0 then
							foreach resUsed in mov.allResourceUsed do
								// Is the resource a phone
								if resUsed.myResource &lt;&gt; null then
									if resUsed.myResource.myResourceType = self.myHarbour.ofPhoneGroup then
										sPhone := sPhone &amp; resUsed.myResource.description &amp; "; ";
									endif;
								endif;
							endforeach;
							if sPhone.length&gt;2 then
								// Trim last comma from string
								sPhone:=sPhone.String[1:((sPhone.length)-2)];
							endif;
						endif;
					endif;
				endif;
			endif;	
		endif;		
		if mov.moveType=HMSMovementTypeShift and				// sArrive = '' // commented out PAR 12323
		   mov.occursOnDTNEW &lt;= self.pFirstTimeStamp		// PAR 12323
		   then
			// note this is the arrival at the berth - the arrival movement may be to the roadstead so the
			// arrival at a berth is a shift movement
			if sArrive = null then
	      		sArrive	:= mov.occursOnDTNEW.date.shortFormatJMT() &amp; "  " &amp; mov.occursOnDTNEW.Time.userFormat($CM_HMS_Time24Hour);
			endif;
			if pType=0 then
				sBerth 	:= mov.getMyBerth.code;
				// Get phone/s at this berth if connected
				if mov.allResourceUsed.size&gt;0 then
					foreach resUsed in mov.allResourceUsed do
						// Is the resource a phone
						if resUsed.myResource &lt;&gt; null then						
							if resUsed.myResource.myResourceType = self.myHarbour.ofPhoneGroup then
								sPhone:=sPhone &amp; resUsed.myResource.description &amp; "; ";
							endif;
						endif;
					endforeach;
					if sPhone.length&gt;2 then
						// Trim last comma from string
						sPhone:=sPhone.String[1:((sPhone.length)-2)];
					endif;
				endif;
			endif;
		endif;
		if mov.moveType=HMSMovementTypeDeparture then
   			sDepart := mov.occursOnDTNEW.date.shortFormatJMT() &amp; "  " &amp; mov.occursOnDTNEW.Time.userFormat($CM_HMS_Time24Hour);
			if pType=1 then
  				movPrev:= voyageData.allVoyageMovements.getAtKeyLss(mov.occursOnDTNEW).HMS_VoyageMovement;			
				if movPrev &lt;&gt; null then
					sBerth 	:= movPrev.getMyBerth.code;
					// Get phone/s at this berth if connected
					if movPrev.allResourceUsed.size&gt;0 then
						foreach resUsed in movPrev.allResourceUsed do
							// Is the resource a phone
							if resUsed.myResource &lt;&gt; null then							
								if resUsed.myResource.myResourceType = self.myHarbour.ofPhoneGroup then
									sPhone:=sPhone &amp; resUsed.myResource.description &amp; "; ";
								endif;
							endif;
						endforeach;
						if sPhone.length&gt;2 then
							// Trim last comma from string
							sPhone:=sPhone.String[1:((sPhone.length)-2)];
						endif;
					endif;
				endif;	
  			endif;   			
    	endif;	
    endforeach;

	if sPhone = null then
		sPhone := "-";
	endif;

	// Determine whether to pass back an array or a string
	if strArrayOut&lt;&gt;null then
		// Pass back an array
		strArrayOut.add(sVessel);
		strArrayOut.add(sCode);
		strArrayOut.add(sAgent);
		strArrayOut.add(sStevedore);
		strArrayOut.add(sBerth);
		strArrayOut.add(sPhone);
		strArrayOut.add(sArrive);
		strArrayOut.add(sDepart);
		strArrayOut.add(sCargoDis);
		strArrayOut.add(sCargoLoad);
		strArrayOut.add(sLast);
		strArrayOut.add(sNext);
	else 
		// Pass back string
		str := sVessel &amp; Tab &amp; sCode &amp; Tab &amp; sAgent &amp; Tab &amp; sStevedore &amp; Tab &amp; sBerth &amp; Tab &amp; sPhone &amp; Tab;
		str := str &amp; sArrive &amp; Tab &amp; sDepart &amp; Tab &amp; sCargoDis &amp; Tab &amp; sCargoLoad &amp; Tab &amp; sLast &amp; Tab &amp; sNext;
		strOut:=str;
	endif;
epilog
	delete allAgents;
end;</source>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="strArrayOut" type="StringArray" usage="input"/>
        <Parameter name="strOut" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getStevdoresDischarge" id="052ffa81-6284-4b97-8c2c-2c9391b0a360">
        <updating/>
        <source>getStevdoresDischarge(_voyageData : HMS_VoyageData; toFile: Boolean):String updating;

vars
	stevedore:				CM_Stevedore;
	maxColumnWidth:			Integer;
	numSteveDischarge:			Integer;
	widthAllocPerStevedore:	Integer;
	returnStr:				String;
	stvdNameStr:			String;
	numChars:				Integer;
	widthAllocExceeded:		Boolean;
	stvdNumber:				Integer;
begin
	// This method returns a string that is constructed from a concatinated series
	// of stevedore names
	if _voyageData = null then
		return null;
	endif;
	// Get maxColumnWidth
	if toFile=false then
		maxColumnWidth:=tableBody.columnWidth[09]; // Stevedores to discharge
	else
		maxColumnWidth:=20;  // 20 Chars wide
	endif;

	// get number of stevedores for loading
	numSteveDischarge:=_voyageData.allStevedoresDischarge.size;

	if numSteveDischarge=0 then
		// No stevedores for discharging
		return "";
	else
		// Stevedores to discharging
		widthAllocPerStevedore:=(maxColumnWidth/numSteveDischarge).Integer;
		stvdNumber:=1;
		foreach stevedore in _voyageData.allStevedoresDischarge do
			if stvdNumber&lt;numSteveDischarge then
				// Not last stevedore - add "; " to end of stevedore name
				stvdNameStr:="";
				numChars:=1;
				widthAllocExceeded:=false;
				// Extract a substring from the stevedores name description that doesn't
				// exceed the alloacted columnWidth space for each stevedore 
				while numChars&lt;=stevedore.description.length and widthAllocExceeded=false do
					stvdNameStr:=stevedore.description.String[1:numChars];
					stvdNameStr:=stvdNameStr &amp; "; ";
					if toFile=false then
						if tableBody.getTextExtent(stvdNameStr)&gt;=widthAllocPerStevedore then
							// Width Allocation for each stevedore has been exceeded
							stvdNameStr:=stevedore.description[1:(numChars-1)];
							stvdNameStr:=stvdNameStr &amp; "; ";
							widthAllocExceeded:=true;
						else
							numChars:=numChars+1;
						endif;
					else
						// To file mode
						if stvdNameStr.length&gt;=widthAllocPerStevedore then
							// Width Allocation for each stevedore has been exceeded
							stvdNameStr:=stevedore.description[1:(numChars-1)];
							stvdNameStr:=stvdNameStr &amp; "; ";
							widthAllocExceeded:=true;
						else
							numChars:=numChars+1;
						endif;
					endif;
				endwhile;
				// Add extracted stevedore name string to returnStr
				returnStr:=returnStr &amp; stvdNameStr;				
			else
				// Last stevedore - don't add "; " to end of stevedore name
				stvdNameStr:="";
				numChars:=1;
				widthAllocExceeded:=false;
				// Extract a substring from the stevedores name description that doesn't
				// exceed the alloacted columnWidth space for each stevedore 
				while numChars&lt;=stevedore.description.length and widthAllocExceeded=false do
					stvdNameStr:=stevedore.description[1:numChars];
					stvdNameStr:=stvdNameStr &amp; " ";
					if toFile=false then
						if tableBody.getTextExtent(stvdNameStr)&gt;=widthAllocPerStevedore then
							// Width Allocation for each stevedore has been exceeded
							stvdNameStr:=stevedore.description[1:(numChars-1)];
							widthAllocExceeded:=true;
						else
							numChars:=numChars+1;
						endif;
					else
						// To file mode
						if stvdNameStr.length&gt;=widthAllocPerStevedore then
							// Width Allocation for each stevedore has been exceeded
							stvdNameStr:=stevedore.description[1:(numChars-1)];
							widthAllocExceeded:=true;
						else
							numChars:=numChars+1;
						endif;
					endif;
				endwhile;
				// Add extracted stevedore name string to returnStr
				returnStr:=returnStr &amp; stvdNameStr;		
			endif;
			stvdNumber:=stvdNumber+1;
		endforeach;	
		return returnStr;
	endif;	

end;</source>
        <Parameter name="_voyageData" type="HMS_VoyageData"/>
        <Parameter name="toFile" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStevedoresLoad" id="2d4334bd-42ad-4400-987c-0255d6f468e7">
        <updating/>
        <source>getStevedoresLoad(_voyageData : HMS_VoyageData; toFile: Boolean):String updating;

vars
	stevedore:				CM_Stevedore;
	maxColumnWidth:			Integer;
	numSteveLoad:			Integer;
	widthAllocPerStevedore:	Integer;
	returnStr:				String;
	stvdNameStr:			String;
	numChars:				Integer;
	widthAllocExceeded:		Boolean;
	stvdNumber:				Integer;
begin
	// This method returns a string that is constructed from a concatinated series
	// of stevedore names

	// Get maxColumnWidth
	if toFile=false then
		maxColumnWidth:=tableBody.columnWidth[10]; // Stevedores to load
	else
		maxColumnWidth:=20;  // 20 Chars wide
	endif;

	// get number of stevedores for loading
	numSteveLoad:=_voyageData.allStevedoresLoad.size;

	if numSteveLoad=0 then
		// No stevedores for loading
		return "";
	else
		// Stevedores to load
		widthAllocPerStevedore:=(maxColumnWidth/numSteveLoad).Integer;
		stvdNumber:=1;
		foreach stevedore in _voyageData.allStevedoresLoad do
			if stvdNumber&lt;numSteveLoad then
				// Not last stevedore - add "; " to end of stevedore name
				stvdNameStr:="";
				numChars:=1;
				widthAllocExceeded:=false;
				// Extract a substring from the stevedores name description that doesn't
				// exceed the alloacted columnWidth space for each stevedore 
				while numChars&lt;=stevedore.description.length and widthAllocExceeded=false do
					stvdNameStr:=stevedore.description.String[1:numChars];
					stvdNameStr:=stvdNameStr &amp; "; ";
					if toFile=false then
						if tableBody.getTextExtent(stvdNameStr)&gt;=widthAllocPerStevedore then
							// Width Allocation for each stevedore has been exceeded
							stvdNameStr:=stevedore.description[1:(numChars-1)];
							stvdNameStr:=stvdNameStr &amp; "; ";
							widthAllocExceeded:=true;
						else
							numChars:=numChars+1;
						endif;
					else
						// To file mode
						if stvdNameStr.length&gt;=widthAllocPerStevedore then
							// Width Allocation for each stevedore has been exceeded
							stvdNameStr:=stevedore.description[1:(numChars-1)];
							stvdNameStr:=stvdNameStr &amp; "; ";
							widthAllocExceeded:=true;
						else
							numChars:=numChars+1;
						endif;
					endif;
				endwhile;
				// Add extracted stevedore name string to returnStr
				returnStr:=returnStr &amp; stvdNameStr;				
			else
				// Last stevedore - don't add "; " to end of stevedore name
				stvdNameStr:="";
				numChars:=1;
				widthAllocExceeded:=false;
				// Extract a substring from the stevedores name description that doesn't
				// exceed the alloacted columnWidth space for each stevedore 
				while numChars&lt;=stevedore.description.length and widthAllocExceeded=false do
					stvdNameStr:=stevedore.description[1:numChars];
					stvdNameStr:=stvdNameStr &amp; " ";
					if toFile=false then
						if tableBody.getTextExtent(stvdNameStr)&gt;=widthAllocPerStevedore then
							// Width Allocation for each stevedore has been exceeded
							stvdNameStr:=stevedore.description[1:(numChars-1)];
							widthAllocExceeded:=true;
						else
							numChars:=numChars+1;
						endif;
					else
						if stvdNameStr.length&gt;=widthAllocPerStevedore then
							// Width Allocation for each stevedore has been exceeded
							stvdNameStr:=stevedore.description[1:(numChars-1)];
							widthAllocExceeded:=true;
						else
							numChars:=numChars+1;
						endif;
					endif;
				endwhile;
				// Add extracted stevedore name string to returnStr
				returnStr:=returnStr &amp; stvdNameStr;		
			endif;
			stvdNumber:=stvdNumber+1;
		endforeach;	
		return returnStr;
	endif;	

end;</source>
        <Parameter name="_voyageData" type="HMS_VoyageData"/>
        <Parameter name="toFile" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialReportSetup" id="55d5f2c9-4082-4a36-ac37-59bcf45d7664">
        <updating/>
        <source>initialReportSetup() updating;

vars
	tmpLeft : Real;
	date : TimeStamp;
	usr  : String;
begin
	inheritMethod();

	if app.getMyUser &lt;&gt; null then
		usr := app.getMyUser.userName;
	else
		usr := '** User Not Defined **';
	endif;		

	lblReportTitle.caption 	:= 'SHIPPING REPORT';
	txtUserCode.text		:= usr;
	txtReportDate.text 		:= date.date.String &amp; ", " &amp; date.Time.userFormat($CM_HMS_Time24Hour);

	txtFooterLeft.text 		:= 'Shipping Report';
	txtHeaderLeft.text 		:= app.myPassport.myTerminal.name;//'Port of Tauranga';
	txtHeaderRight.text 	:= 'Printed by: ' &amp; usr;
	app.printer.setHeader(fHeader);
	app.printer.setFooter(fFooter);

	tableHeader.accessMode  := Table.AccessMode_Row;
	tableHeader.rowHeight[1]:= 34;
	tableHeader.gridLines	:= false;
	tableBody.borderStyle 	:= Table.BorderStyle_None;
	tableBody.gridLines		:= false;
	
	picIcon.picture := app.getPicLogoPort();
	picTitleLogo.picture	:= picIcon.picture;
	tmpLeft := picTitleLogo.left + picTitleLogo.width + 20;
	self.lblReportTitle.left := tmpLeft;
	self.lblUsrCodeTitle.left := tmpLeft;
	self.lblRepDateTitle.left := tmpLeft;
	tmpLeft := tmpLeft + self.lblUsrCodeTitle.width + 20;
	self.txtUserCode.left := tmpLeft;
	self.txtReportDate.left := tmpLeft;
end;</source>
    </JadeMethod>
    <JadeMethod name="printForwardShippingReport" id="b69df582-0262-4649-8757-c40c48fdeddd">
        <updating/>
        <source>printForwardShippingReport(_textFileLines: HMS_TextFileLineArray input)updating;

vars
	iterTerm,
	iter: 					Iterator;
	term:					CM_Terminal;
	voyage: 				CM_Voyage;
	strOut: 				String;	
	strArrayOut:			StringArray;
	arriveDate,departDate: 	TimeStamp;
	sStevedoreLoad:			String;
	sStevedoreDischarge:	String;
	int:	 				Integer;
	arrivesInPort, offsetArr : TimeStamp;
	voyageData:				HMS_VoyageData;
begin

	if _textFileLines = null then
		//They are printing the report to printer
		app.printer.print(fBlank);
		app.printer.print(fTableHeader);
		txtHeading.text := headText;
		app.printer.print(fHeading);
	endif;	
	
	int := 1;
	iterTerm := self.myHarbour.allTerminalsByCode.createIterator;
	while iterTerm.next(term) do
		if iter &lt;&gt; null then
			delete iter;
		endif;
		iter := term.allVoyagesByArrivalDTCode.createIterator;
		offsetArr.setDate((pFirstTimeStamp.date - 10));	//AA 27/9/01: Start 10 days ahead for anchored vsls
		offsetArr.setTime(pFirstTimeStamp.Time);	
		term.allVoyagesByArrivalDTCode.startKeyGeq(offsetArr, null, iter);

		while (iter.next(voyage)) do
			if voyage.arrivedDT &gt; pSecondTimeStamp then
				break;
			endif;
			voyageData := voyage.myHMSVoyageData;
			if voyageData = null then
				continue;
			endif;
			if voyageData.excludeReport then
				continue;
			endif;			
			
			if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
 
 
			arrivesInPort := voyage.arrivedDT;		//AA 27/9/01: Vessels at anchor appear in fwd section
			if arrivesInPort&gt;=pFirstTimeStamp and arrivesInPort &lt;= pSecondTimeStamp then
				
				if _textFileLines &lt;&gt; null then
					create strArrayOut transient;				
				endif;
				
				self.getFwdShipReportDetails(voyage, strArrayOut, strOut);
				
				if strArrayOut &lt;&gt; null then
					// Add line to fileColl
					if (not strArrayOut.isEmpty) then
						_textFileLines.add(strArrayOut);
					endif;
				elseif strOut &lt;&gt; null then
					// print the line				
					self.doPrinting(strOut,int);	
				endif;
			endif;
			// reset variables
			strOut := null;
		endwhile;
	endwhile;		
epilog
	delete iter;
	delete iterTerm;
end;</source>
        <Parameter name="_textFileLines" type="HMS_TextFileLineArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printShippingReport" id="1b71b320-b652-46b4-abb7-37bd7116811d">
        <updating/>
        <source>printShippingReport(_textFileLines: HMS_TextFileLineArray input) updating;

vars
	iterTerm,
	iter: 			Iterator;
	term: 			CM_Terminal;
	voyage: 		CM_Voyage;
	strOut: 		String;	
	strArrayOut:	StringArray;
	int: 			Integer;
	ok: 			Boolean;
	arrivesInPort:	TimeStamp;
	voyageData:		HMS_VoyageData;
begin

	if _textFileLines = null then
		//They are printing the report to printer
		// print the header information
		app.printer.print(fBlank);
		app.printer.print(fTableHeader);
		txtHeading.text := headText;
		app.printer.print(fHeading);
	endif;

	// if the report is run for type 0 (vessels currently in the port), get the extended date range
	// for the target dates - this allows for picking up voyages that arrive and depart either side of 
	// the selected date.

	if pType = 0 then
		// Vessels in port
		offset2.setDate((pFirstTimeStamp.date - self.myHarbour.shippingReportOffsetDays).Date);
		offset2.setTime(pFirstTimeStamp.Time);
		offset.setDate((pSecondTimeStamp.date + self.myHarbour.shippingReportOffsetDays).Date);
		offset.setTime(pSecondTimeStamp.Time);	
	elseif pType = 1 then
		// Vessels Departed	
		offset2 := pFirstTimeStamp;
	endif;

	// build the iterator
	int := 1;
	iterTerm := self.myHarbour.allTerminalsByCode.createIterator;
	while iterTerm.next(term) do
		if iter &lt;&gt; null then
			delete iter;
		endif;
		iter := term.allVoyagesByDepartDTCode.createIterator;
		term.allVoyagesByDepartDTCode.startKeyGeq(offset2, null, iter);

		while (iter.next(voyage)) do
			ok := false;
			voyageData := voyage.myHMSVoyageData;
			if voyageData = null then
				continue;
			endif;
			if voyageData.excludeReport then
				continue;
			endif;	
			
			if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
						
			if pType = 0 then
				arrivesInPort := voyage.arrivedDT;
				if arrivesInPort &lt;= pFirstTimeStamp and voyage.departedDT &gt;= pSecondTimeStamp then
					ok := true;
				elseif arrivesInPort &gt;= pFirstTimeStamp and arrivesInPort &lt;= pSecondTimeStamp then
					ok := true;
				elseif voyage.departedDT &gt;= pFirstTimeStamp and voyage.departedDT &lt;= pSecondTimeStamp then	
					ok := true;
				endif;	
			elseif pType = 1 then 
			   	if voyage.departedDT &gt;= pFirstTimeStamp and voyage.departedDT &lt;= pSecondTimeStamp then
			   		ok := true;
			   	endif;	
			endif;

			if ok = true then
				
				if _textFileLines &lt;&gt; null  then
					create strArrayOut transient;
				endif;
				
				self.getShipReportDetails(voyage, strArrayOut, strOut);

				if strArrayOut &lt;&gt; null then
					// Add line to fileColl
					if (not strArrayOut.isEmpty) then
						_textFileLines.add(strArrayOut);
					endif;
				elseif strOut &lt;&gt; null then
					// print the line
					self.doPrinting(strOut,int);	
				endif;
				
			endif;		
			// reset variables
			strOut := null;
	
			if pType = 0 then
				if voyage.departedDT &gt; offset then
					break;
				endif;
			elseif pType = 1 then
				if not ok then
					break;
				endif;			
			endif;
		endwhile;
	endwhile;

epilog
	delete iter;
	delete iterTerm;
end;</source>
        <Parameter name="_textFileLines" type="HMS_TextFileLineArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processReport" id="1cafcfa8-4540-4088-9e44-7190164e72a5">
        <updating/>
        <source>processReport() updating;

vars
//	pxyJadeReport		: JadeReport;	// cnwvu1 commented - 5/12/2006 PAR13089
begin
	// this method drives the report
	inheritMethod();

//	create pxyJadeReport transient;		// cnwvu1 commented - 5/12/2006 PAR13089
//	app.printer.printPreview := true;
//	app.printer.setReport(pxyJadeReport);	
		
	// setup the report headings etc
	self.initialReportSetup();

	// print the initial report header and attributes strips
	app.printer.print(fTitle);
	app.printer.print(fTitleSep);

	// Modified by Russell 05/04/99
	// ----------------------------------
	tableBody.gridLines:=true;
	tableBody.gridColor:=Gray;
	// ----------------------------------

	// print the report

	if self.portDate_From.isValid() then
		self.setupShippingReport();
		headText := 'Vessels in Port at ' &amp; portDate_From.date.String &amp; ' ' &amp; portDate_From.Time.userFormat($CM_HMS_Time24Hour) &amp; ' - ' &amp; portDate_To.date.String &amp; ' - ' &amp; portDate_To.Time.userFormat($CM_HMS_Time24Hour);
		pFirstTimeStamp := portDate_From;
		pSecondTimeStamp := portDate_To;
		pType := 0;
		self.printShippingReport(null);
	endif;

	if arriveDate_From &lt;&gt; null then
		self.setupForwardShippingReport();
		headText := 'Expected Arrivals between ' &amp; arriveDate_From.date.String &amp; ' - ' &amp; arriveDate_To.date.String;
		pFirstTimeStamp:=arriveDate_From;
		pSecondTimeStamp:=arriveDate_To;
		pType := 0;
		self.printForwardShippingReport(null);
	endif;	

	if departDate_From.isValid then
		setupShippingReport();
		headText := 'Vessels Departed between ' &amp; departDate_From.date.String &amp; ' - ' &amp; departDate_To.date.String;
		pFirstTimeStamp:=departDate_From;
		pSecondTimeStamp:=departDate_To;
		pType:=1;
		self.printShippingReport(null);
	endif;	

	app.printer.print(fTitleSep);


	// Modified by Russell 05/04/99
	// ----------------------------------
	tableBody.gridLines:=false;
	// ----------------------------------

epilog
	app.printer.close();		
end;</source>
    </JadeMethod>
    <JadeMethod name="sendEMailToDistributionList" id="cb196231-65e4-454d-915d-c31c6c499cf5">
        <source>sendEMailToDistributionList(_fileName : String io; _group : CM_EmailGroup);
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
// -------------------------------------------
// 10/12/2014  cnwdb2	PAR 35364

vars


	toAddress,	
	bccAddress,
	fromAddress,
	sendSubject,
	sendMessage,
	error		: String;
	attachedFiles	: HugeStringArray;	

begin

	if _group = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour Email Group', null,  null); 
		app.raiseCMException(Input_required_field_harborGrp, null,  null); // cnwdb2	PAR 35364
	endif;
	
	toAddress	:= app.myRoot.getConfig(AutoSupportEmailAddress).String;
	bccAddress	:= _group.getEmailAddress();
	create attachedFiles transient;
	attachedFiles.add(_fileName);

	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	sendMessage	:= 'Please find attached the Shipping Report from ' &amp; self.myHarbour.description &amp; ', prepared on ' &amp; app.actualTimeServer.display; 
	sendSubject	:= self.myHarbour.description &amp; " Shipping Report";

	app.myTrxCA.trxCreateEmailSendRequest('HMS Report',
										  toAddress, 
										  fromAddress,
										  null,
										  bccAddress,
										  sendSubject,
										  sendMessage,
										  attachedFiles,
										  null,
										  null,
										  null,
										  EmailSource_HMS,
										  null,
										  app.myPassport);
										  
	if not app.myPassport.trxCompletedOK then
		error := app.getErrorString2(FailureWithError, app.getErrorString(Email_Request), app.myPassport.returnCode.String);
		app.remoteErrorWarningToAlert(error, null, app.myPassport.allErrors, null, false, true);
		return;
	endif;
epilog
	delete attachedFiles;
end;</source>
        <Parameter name="_fileName" type="String" usage="io"/>
        <Parameter name="_group" type="CM_EmailGroup"/>
    </JadeMethod>
