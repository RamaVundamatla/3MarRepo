    <JadeMethod name="getTerminalsForUser" id="983a0c7b-2357-412f-b492-1576b97713cb">
        <source>getTerminalsForUser();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwmp6	Initial creation	TFS 2443

*/

vars
	user : CM_User;
	userTerminal : CM_UserTerminal;
	iter : Iterator;
begin
	self.allTerminalsForThisUser.clear();
	user := app.getMyUser();
	iter := user.allUserTerminals.createIterator();
	while iter.next(userTerminal) do
		self.allTerminalsForThisUser.add(userTerminal.getRealTerminal);
	endwhile;
epilog
	delete iter;	
end;</source>
    </JadeMethod>
    <JadeMethod name="initShtDataTable1" id="7bf686ec-dc0b-48ec-bda1-a3ff008df259">
        <updating/>
        <source>initShtDataTable1() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwmp6	Initial creation	TFS 2443

*/

vars
	form	:SOP_TableMaintForm;
	table	:Table;
begin 
	inheritMethod(); 
	
	form 	:= self.myForm;
	table	:= form.tblData1;
	
	form.shtDataTable1.visible	:= true;
	form.shtDataTable1.caption	:= app.getErrorString (Task_terminals);
	
	table.clear;
	table.rows		:= 0;
	table.columns	:= 2;
	table.fixedRows	:= 0;
	table.selectMode 	:= Table.SelectMode_CurrentRow;
	
	table.accessColumn(1).inputType	:= Table.InputType_None;
	table.wordWrap					:= true;
	table.columnWidth[1]			:= 200;
	table.columnWidth[2]			:= table.clientWidth - table.columnWidth[1];
	table.autoSize					:= Table.AutoSize_Row;
	table.top						:= form.frmTBDataTable1.height + 1;
	form.frmTBDataTable1.visible	:= true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="07f4e644-5e94-46fe-b4ee-f5e7eed55d48">
        <source>initShtMultiSelect();
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par
// 02/11/2022   navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
// 08/05/2025	navlw1	JIRA-34582: MTN | Filtering order Issue in system Admin Table as terminal collection cannot be re-ordered
vars

	form			: SOP_TableMaintForm;
	coll 			: CM_ObjectSetActual;
	resourceType    : CM_ResourceType;
begin
	inheritMethod;	
	
	form := self.myForm;
	
	form.mulSelect1.setVisibleButtons(false,false,true);

	self.setupMultiSelect1(app.getErrorString(CargoTypes), app.myRoot.allCargoTypesById, SOP_TableMaintForm::displayEntryCargoType.name);
	
	form.mulSelect1.myBaseForm					:= form;
	form.mulSelect1.mySelectedListBox.sorted 	:= false;
	
	//18 Dec 2009	NDL	CCMS MES 1006
	form.mulSelect2.setVisibleButtons(false,false,true);
	
	// Only show those which are available
	create coll transient;

	foreach resourceType in app.myRoot.allTaskResourceTypes 
		where (resourceType.type = TODO_TYPE_GROUP_TI or resourceType.type = TODO_TYPE_GROUP_ALL) // ### TFS #56635[54261] 22NOV2022 NAVAB1
			and resourceType.isAvailable do 													  //02/11/2022 navds20 TFS #56635[54261]
		coll.add(resourceType);
	endforeach;

	self.setupMultiSelect2(app.getErrorString(ToDoTaskResources), coll, SOP_TableMaintForm::displayToDoResourceType.name);
	
	form.mulSelect2.myBaseForm					:= form;
	form.mulSelect2.mySelectedListBox.sorted 	:= false;
	
	//13 Oct 2010	NDL Par 23991
	self.setupMultiSelect3(app.getErrorString(Allowed_release_terminals), app.myRoot.allTerminals, SOP_TableMaintForm::displayEntryTerminal.name);
	form.mulSelect3.setVisibleButtons(true,true,false);
	form.mulSelect3.myBaseForm					:= form;
	form.mulSelect3.mySelectedListBox.sorted 	:= false;
	
	//13 Oct 2010	NDL Par 23991
	if app.isSubTerminalsLicensed then
		self.setupMultiSelect6(app.getErrorString(Allowed_edit_terminals), app.myRoot.allSubTerminals, SOP_TableMaintForm::displayEntrySubTerminal.name);
		form.mulSelect6.setVisibleButtons(true,true,false);
		form.mulSelect6.myBaseForm					:= form;
		form.mulSelect6.mySelectedListBox.sorted 	:= false;
	endif;

epilog

	delete coll;
	
end;</source>
    </JadeMethod>
