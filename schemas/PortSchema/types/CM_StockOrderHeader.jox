    <JadeMethod name="validateMe" id="3df850f5-ad0b-40e6-a4ae-c1a4e8b70968">
        <source>validateMe(_passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//27/06/2022 		NAVDS20 			TFS 53760  DuplicateItem not Translatable
// ---------------------------------------------------------------------------
vars
	pxyLine			: CM_StockOrderLine;
	realObjForProxy	: CM_StockOrderHeader;
	realObjFound	: CM_StockOrderHeader;
	port			: CM_Port;
	tmpStr,
	operatorStr		: String;

begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'terminal', 'terminal', null);
		app.raiseCMException(Input_required_field_terminal, 'terminal', null); // cnwdb2	PAR 35364
	endif;
	
	self.validateTransportMode();
	
	if self.transportMode = TI_TRANSMODE_SHIP then
		if self.dischargePort &lt;&gt; null then
			// If a port is given then it must be valid
			//port := app.myRoot.allPorts[self.dischargePort];
			port := app.myRoot.allPorts[self.dischargePort];
			if port = null then
				app.raiseCMException1(ERR_INVALID_DIS_PORT, self.dischargePort, 'dischargePort', null);
			else
				if self.myVoyage = null then
					// A voyage is required if a discharge port has been entered
				//	app.raiseCMException1(REQUIRED_FIELD, 'voyage', 'voyage', null);
					app.raiseCMException(Input_required_field_voyage, 'voyage', null); // cnwdb2	PAR 35364
				else
					self.myVoyage.validateDischargePort(port, null);
				endif;
			endif;
		endif;
	endif;
	
	if self.myOperator = null then
		tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, 'operator', null);
		app.raiseCMException1(Input_required_field_Required, tmpStr, 'operator', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	// Checks that require an operator
	if self.orderNo = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'orderNo', 'orderNo', null);
		app.raiseCMException(Input_required_field_orderNo, 'orderNo', null); // cnwdb2	PAR 35364
	else
		// Check that the order number is unique for the operator.
		// Works for creates and updates.
		realObjFound	:= self.myOperator.allStockOrderHeaders[self.orderNo];
		realObjForProxy	:= self.pxyGetRealObject;
		if realObjFound &lt;&gt; null and realObjFound &lt;&gt; realObjForProxy then
			if self.myOperator &lt;&gt; null then
				operatorStr := self.myOperator.code;
			endif;
			tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
			//app.raiseCMException2(DuplicateItem,"Order " &amp; self.orderNo, tmpStr &amp; " " &amp; operatorStr, null, null); //27/06/2022 NAVDS20 TFS 53760
			//Order %1 already exists for %2 %3 : Order_already_exist
			app.raiseCMException3(Order_already_exist, self.orderNo, tmpStr , operatorStr, null, null); //27/06/2022 NAVDS20 TFS 53760
		endif;
	endif;
	
	// Now validate the order lines
	foreach pxyLine in self.allStockOrderLines do
		if pxyLine.pxyIsProxy then
			pxyLine.validateForUpdate(_passport);
		else
			pxyLine.validateForCreate(_passport);
		endif;
	endforeach;
	
	// Now validate uniqueness of the order lines
	self.validateDetailsUnique();
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateOrderFullyAllocated" id="6862ea73-5831-4e1c-88c9-2f3f86050aa1">
        <source>validateOrderFullyAllocated();
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	line : CM_StockOrderLine;

begin
	foreach line in self.allStockOrderLines where line.calUnallocatedAmount &gt; 0 do
		app.raiseCMException2(BOLOutStockOrderAllocPartial, self.orderNo,
							  line.getErrorString, null, null);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateTransportMode" id="e85b3e9e-f54b-4b89-b06b-63bd081a26c7">
        <source>validateTransportMode() protected;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin
	if self.processOption = Process_Pack then
		return;
	endif;
	
	if self.transportMode &lt; TI_TRANSMODE_NULL or
			self.transportMode &gt; TI_TRANSMODE_MAX then
		app.raiseCMException1(InvalidTransportMode, self.transportMode.String, "transportMode", null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
