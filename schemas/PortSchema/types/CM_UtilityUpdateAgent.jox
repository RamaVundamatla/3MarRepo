	expectedEdition     : Integer;
	
begin

	self.initialiseActivity();

	pProxyPalletType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyPalletType.pxyGetRealObjectAndEdition(realPalletType, expectedEdition);
	
	if realPalletType = null then	
