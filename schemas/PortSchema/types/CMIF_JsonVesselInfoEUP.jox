<Class name="CMIF_JsonVesselInfoEUP" id="01efe56d-a848-4096-b613-84c1f2cd2533">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="callSign" id="93147943-2746-4c6c-a190-1cee7b42ae26">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="dischargingPort" id="563ad96e-788d-40ad-9491-6d4e03cc9579">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="finalDestinationPort" id="1156f027-a504-44e9-a4f9-c028b13a58a4">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="iMO" id="ad2f5476-2572-46f0-8492-59fc824dad49">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="loadingPort" id="a3ffe415-4cb7-4a9c-a172-3f9e6f0c1727">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="vesselAgent" id="c42f0d32-cc3b-42c0-80b5-00cd678f9e56">
        <embedded/>
        <type name="CMIF_JsonVesselAgentEUP"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="vesselName" id="1a0d1789-54eb-4270-ba26-1449e03673d3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="voyageNumber" id="9a6d957b-bada-40f4-ae7c-33239253396d">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="351f6381-bea3-4c64-8e7c-69aeaa1e82dc">
        <updating/>
        <source>delete() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 July 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if self.vesselAgent &lt;&gt; null then
		delete self.vesselAgent;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setVesselInfo" id="4eb82598-12fc-4b15-bc5a-b1b91fbca46e">
        <updating/>
        <source>setVesselInfo(voyage : CM_Voyage input; theTI : CM_TrackedItem input; _translationOperator : CM_Operator) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
12 Mar 2025 	naviv1		MTN-34287 	EUP FR | Expected and Effective amounts are incorrect for cargo received via ship
****************************************************/

vars
	vesselAgent : CMIF_JsonVesselAgentEUP;
	foundMatch	: Boolean;
	terminal	: CM_Terminal;
begin
	terminal := app.myPassport.myTerminal;	//JIRA-34287
	if terminal.getConfig(AllowDupVoyageInOutCodes).Boolean then	 //JIRA-34287	
		self.voyageNumber 			:= voyage.inwardCodeAuto;
	else
		self.voyageNumber 			:= voyage.inwardCode;
	endif;
	self.vesselName 			:= voyage.vesselName;
	self.callSign 				:= voyage.callSign;
	self.iMO 					:= voyage.lloydsNumber;
	self.loadingPort 			:= theTI.loadPort;
	self.finalDestinationPort 	:= theTI.destinationPort;
	self.dischargingPort 		:= theTI.dischargePort;
	
	create vesselAgent transient;
	vesselAgent.setFromVoyage(voyage, _translationOperator);	
	
	self.vesselAgent			:= vesselAgent;	
	
	if _translationOperator &lt;&gt; null then
		self.voyageNumber := _translationOperator.getXlationForeignCode(self.voyageNumber, XLATION_TYPE_VOYAGETERMINAL , foundMatch);
	endif;
end;</source>
        <Parameter name="voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
    </JadeMethod>
</Class>
