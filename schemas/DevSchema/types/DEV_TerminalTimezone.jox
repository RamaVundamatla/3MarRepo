        <updating/>
        <source>comboTerminals_displayEntry(combobox: ComboBox input; _terminal: CM_Terminal; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwns1	Initial creation

*/

vars

begin
	if _terminal = null then
		return null;
	endif;
	return _terminal.code.padBlanks(5) &amp; Tab &amp; _terminal.name;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
