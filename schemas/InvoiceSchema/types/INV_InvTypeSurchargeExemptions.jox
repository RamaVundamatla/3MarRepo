    <JadeMethod name="showHideFrmET" id="e598bcf0-5799-4651-9e80-335a415f2a52">
        <updating/>
        <source>showHideFrmET( _hide : Boolean; _tax : CM_InvoiceTypeExternalTax )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37821

*/

vars

	invalidObj : Boolean;
	load : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, self.myProxyETTax, invalidObj );
	if self.myProxyETTax &lt;&gt; null then
		delete self.myProxyETTax;
	endif;
	
	if not _hide then
		self.resize();
	endif;
	
	self.frmET.visible := not _hide;
	self.frmMain.enabled := _hide;
	
	self.cmbETDebtor.listIndex := -1;
	self.cmbETTaxRule.listIndex := 1;
	self.txtETRangeStart.text := null;
	self.txtETRangeEnd.text := null;
	self.txtETTaxCode.text := null;
	
	if not _hide then
		self.frmET.ignoreSkin := true;
		if _tax &lt;&gt; null then
			if _tax.myDebtor &lt;&gt; null then
				self.cmbETDebtor.listIndex := self.cmbETDebtor.findObject( _tax.myDebtor );
			endif;
			if _tax.isTaxExempt then
				self.cmbETTaxRule.listIndex := 2;
			endif;
			self.txtETTaxCode.text := _tax.externalTaxCode;
			self.txtETRangeStart.text := _tax.rangeStart.asStringJMT();
			self.txtETRangeEnd.text := _tax.rangeEnd.asStringJMT();
			app.cmsBeginLoad( load );
			self.myProxyETTax := _tax.pxyCreateUpdateProxy();
			app.cmsEndLoad( load );
		else
			create self.myProxyETTax transient;
		endif;
		self.frmMain.zOrder(0);
	endif;


epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_tax" type="CM_InvoiceTypeExternalTax"/>
    </JadeMethod>
    <JadeMethod name="showHideFrmGMC" id="26e505df-8b49-47bf-8d14-9cda763295ed">
        <updating/>
        <source>showHideFrmGMC( _hide : Boolean; _minChg : CM_InvTypeGroupingMinCharge ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	invalidObj : Boolean;
	load : Boolean;
	allSelected : CM_InvoiceLineDescSet;

begin

	on Exception do app.handleDeletedObject( exception, self.myProxyGMCharges, invalidObj );
	if self.myProxyGMCharges &lt;&gt; null then
		delete self.myProxyGMCharges;
	endif;
	
	if not _hide then
		self.resize();
	endif;
	
	self.frmGMC.visible := not _hide;
	self.frmMain.enabled := _hide;
	
	self.cmbGMCInvLineType.listIndex := -1;
	self.txtGMCMinCharge.text := null;
	self.optGMCWholeInv.value := true;
	self.mulGMCInvLineTypes.setSelected( null );
	self.txtGMCDescription.text := null;
	self.cmbGMCMoveType.listIndex := -1;
	
	if not _hide then
		self.frmGMC.ignoreSkin := true;
		if _minChg &lt;&gt; null then
			if  _minChg.getMinimumChargeInvLineType &lt;&gt; null then
				self.cmbGMCInvLineType.listIndex := self.cmbGMCInvLineType.findObject( _minChg.getMinimumChargeInvLineType );
			endif;
			
			create allSelected transient;
			_minChg.getAllSelectedInvLineTypes( allSelected );	
			if not allSelected.isEmpty then
				self.mulGMCInvLineTypes.setSelected( allSelected );
			endif;
			
			self.txtGMCMinCharge.text := _minChg.minimumChargeAmount.asStringJMT();
			
			self.txtGMCDescription.text := _minChg.description;
			
			if _minChg.moveType &lt;&gt; null then
				self.cmbGMCMoveType.listIndex := self.cmbGMCMoveType.findStringExact( 1, _minChg.moveType );
			endif;
			
			if _minChg.groupLinesBy = _minChg.GroupTypeMovement then
				self.optGMCMovement.value := true;
			endif;
			
			app.cmsBeginLoad( load );
			self.myProxyGMCharges := _minChg.pxyCreateUpdateProxy();
			app.cmsEndLoad( load );
		else
			create self.myProxyGMCharges transient;
		endif;
		self.frmMain.zOrder(0);
	endif;
	
	self.clickGMCOpts();

epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_minChg" type="CM_InvTypeGroupingMinCharge"/>
    </JadeMethod>
    <JadeMethod name="showHideFrmISA" id="0459124a-8325-4ee6-8d2f-5162a9106a77">
        <updating/>
        <source>showHideFrmISA( _hide : Boolean; _invTypeDebtorSep : CM_InvTypeDebtorSeparation ) updating;
/*

Purpose:			Shows and hides the panel for creating/editing a Invoice Type Debtor Separation

Parameters:			_hide				Boolean						Whether or not to hide the panel
					_invTypeDebtorSep	CM_InvTypeDebtorSeparation	The Invoice Type Debtor Separation to populate the panel with

Return Value:		NONE

Date		Who		Reason
24 August 2022	navpw1	Initial creation TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges

*/

vars
	invalidObj 	: Boolean;
	index 		: Integer;
	
begin
	on Exception do app.handleDeletedObject( exception, self.myProxyInvTypeDebtorSep, invalidObj );
	if self.myProxyInvTypeDebtorSep &lt;&gt; null then
		delete self.myProxyInvTypeDebtorSep;
	endif;
	
	if not _hide then
		self.resize();
	endif;
	
	self.frmISA.visible := not _hide;
	self.frmMain.enabled := _hide;
	
	self.cmbISADebtor.listIndex := -1;
	self.cmbISAAccuralType.listIndex := -1;
	
	if not _hide then
		self.frmISA.ignoreSkin := true;
		
		self.optISAVoyageSepNo.value 		:= true;
		self.optISAVoyageGrpSepNo.value 	:= true;
		self.optISACargoIdSepNo.value 		:= true;
		self.optISACargoGrpIdSepNo.value 	:= true;
		self.optISABolSepNo.value 			:= true;
		self.optISABookingSepNo.value 		:= true;
		self.optISAReleaseReqSepNo.value 	:= true;
		self.optISAPONumberNo.value 	:= true; // ### BUG 56925 07MAR2023 NAVAB1
		
		if _invTypeDebtorSep &lt;&gt; null then
			index := self.cmbISADebtor.findObject(_invTypeDebtorSep.myDebtor);
			self.cmbISADebtor.listIndex := index;
			self.cmbISADebtor.text := _invTypeDebtorSep.myDebtor.name;
			
			if  _invTypeDebtorSep.myDebtor &lt;&gt; null then
				self.cmbISADebtor.listIndex := self.cmbISADebtor.findObject( _invTypeDebtorSep.myDebtor );
			endif;
			
			if  _invTypeDebtorSep.myAccrualType &lt;&gt; null then
				self.cmbISAAccuralType.listIndex := self.cmbISAAccuralType.findObject( _invTypeDebtorSep.myAccrualType );
			else
				self.cmbISAAccuralType.listIndex := 1;
			endif;
			
			if _invTypeDebtorSep.separatedByVoyage then
				self.optISAVoyageSepYes.value		:= true;
			else
				self.optISAVoyageSepNo.value 		:= true;
			endif;
			
			if _invTypeDebtorSep.separatedByVoyageGroup then
				self.optISAVoyageGrpSepYes.value	:= true;
			else
				self.optISAVoyageGrpSepNo.value 	:= true;
			endif;
			
			if _invTypeDebtorSep.separatedByCargoId then
				self.optISACargoIdSepYes.value		:= true;
			else
				self.optISACargoIdSepNo.value 		:= true;
			endif;
			
			if _invTypeDebtorSep.separatedByCargoGroupId then
				self.optISACargoGrpIdSepYes.value	:= true;
			else
				self.optISACargoGrpIdSepNo.value 	:= true;
			endif;
			
			if _invTypeDebtorSep.separatedByBillOfLading then
				self.optISABolSepYes.value			:= true;
			else
				self.optISABolSepNo.value 			:= true;
			endif;
			
			if _invTypeDebtorSep.separatedByBooking then
				self.optISABookingSepYes.value		:= true;
			else
				self.optISABookingSepNo.value 		:= true;
			endif;
			
			if _invTypeDebtorSep.separatedByReleaseRequest then
				self.optISAReleaseReqSepYes.value	:= true;
			else
				self.optISAReleaseReqSepNo.value 	:= true;
			endif;
			
			if _invTypeDebtorSep.separatedByPONumber then // ### BUG 56925 07MAR2023 NAVAB1
				self.optISAPONumberYes.value	:= true; // ### BUG 56925 07MAR2023 NAVAB1
			else
				self.optISAPONumberNo.value 	:= true; // ### BUG 56925 07MAR2023 NAVAB1
			endif;
			
			self.myProxyInvTypeDebtorSep := app.createUpdateProxy(_invTypeDebtorSep).CM_InvTypeDebtorSeparation;
			
		else
			create self.myProxyInvTypeDebtorSep transient;
			
		endif;
		self.frmMain.zOrder(0);
		
	endif;
	
end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_invTypeDebtorSep" type="CM_InvTypeDebtorSeparation"/>
    </JadeMethod>
    <JadeMethod name="showHideFrmSCT" id="b38406d4-c815-48d9-bb6b-43e45e745624">
        <updating/>
        <source>showHideFrmSCT( _hide : Boolean; _rate : CM_InvTypeCargoMultiSurcharge ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgndl1	Initial creation	TFS 37822
20 Jun 2018		NDL		TFS 39305
15 Sep 2022		navpw1	TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
	invalidObj					: Boolean;
	load						: Boolean;
	allSelected					: CM_InvoiceLineDescSet;
	allSelectedCargoTypes		: CM_CargoTypeSet;			// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	allSelectedCargoSubTypes	: CM_ProductSet;			// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	allSelectedCommodities		: CM_CommoditySet;			// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	allSelectedDebtors			: CM_DebtorSet;				// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	applyGreaterThanLineTotal	: Boolean;					// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	cargoSubTypeArray			: CM_ProductArray;			// ### TFS 54565 (54385) 16Sep2022 NAVPW1
	commodityArray				: CM_CommodityArray;		// ### TFS 54565 (54385) 16Sep2022 NAVPW1
	cargoType					: CM_CargoType;				// ### TFS 54565 (54385) 16Sep2022 NAVPW1
	cargoSubType				: CM_Product;				// ### TFS 54565 (54385) 16Sep2022 NAVPW1
	commodity					: CM_Commodity;				// ### TFS 54565 (54385) 16Sep2022 NAVPW1
	
begin
	on Exception do app.handleDeletedObject( exception, self.myProxyCTSurRate, invalidObj );
	if self.myProxyCTSurRate &lt;&gt; null then
		delete self.myProxyCTSurRate;
	endif;
	
	if not _hide then
		self.resize();
	endif;
	
	self.frmSCT.visible := not _hide;
	self.frmMain.enabled := _hide;
	
	self.cmbSCTInvLineType.listIndex := -1;
	//self.cmbSCTCargoType.listIndex := -1; // ### TFS 54565 (54385) 19Sep2022 NAVPW1
	//self.doCmbSCTCargoTypeChg();			// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	self.txtSCTPercent.text := null;
	self.mulSCTInvLineTypes.setSelected( null );
	
	// ### TFS 54565 (54385) 16Sep2022 NAVPW1
	self.mulSCTCargoTypes.setSelected(null);
	self.mulSCTSubCargoTypes.setAvailable(null, true);
	self.mulSCTSubCargoTypes.setSelected(null);
	self.mulSCTCommodities.setAvailable(null, true);
	self.mulSCTCommodities.setSelected(null);
	self.mulSCTDebtors.setSelected(null);
	self.txtSCTSurchargeFixAmnt.text := null;
	self.txtSCTSurchargeGrtrTh.text := null;
	
	self.optSCTSurchargeLnTl.value := false;
	self.optSCTSurchargeQty.value := false;
	
	self.txtSCTSurchargeFrmDte.text := null;
	self.txtSCTSurchargeFrmTme.text := null;
	self.txtSCTSurchargeToDte.text := null;
	self.txtSCTSurchargeToTme.text := null;
	// ### TFS 54565 (54385) 16Sep2022 NAVPW1
	
	if not _hide then
		self.frmSCT.ignoreSkin := true;
		if _rate &lt;&gt; null then
			/*create allSelected transient;
			_rate.getAllSelectedInvLineTypes( allSelected );
			
			if  _rate.getCargoSurchargeInvLineType &lt;&gt; null then
				self.cmbSCTInvLineType.listIndex := self.cmbSCTInvLineType.findObject( _rate.getCargoSurchargeInvLineType );
			endif;
			if  _rate.myCargoType &lt;&gt; null then
				self.cmbSCTCargoType.listIndex := self.cmbSCTCargoType.findObject( _rate.myCargoType );
				self.doCmbSCTCargoTypeChg();
			endif;
	
			if  _rate.mySubCargoType &lt;&gt; null then
				self.cmbSCTSubCargoType.listIndex := self.cmbSCTSubCargoType.findObject( _rate.mySubCargoType );
			else
				if  _rate.myCargoType &lt;&gt; null then // ### TFS 51219 03JUN2021 NAVAB1
					self.cmbSCTSubCargoType.listIndex := 1;
				else
					self.cmbSCTSubCargoType.listIndex := -1; // ### TFS 51219 03JUN2021 NAVAB1
				endif;
			endif;
			if  _rate.myCommodity &lt;&gt; null then
				self.cmbSCTCommodity.listIndex := self.cmbSCTCommodity.findObject( _rate.myCommodity );
			else
				if  _rate.myCargoType &lt;&gt; null then // ### TFS 51219 03JUN2021 NAVAB1
					self.cmbSCTCommodity.listIndex := 1;
				else
					self.cmbSCTCommodity.listIndex := -1; // ### TFS 51219 03JUN2021 NAVAB1
				endif;
			endif;
			if _rate.allSelectedInvLineTypes.isEmpty then
				self.mulSCTInvLineTypes.setSelected( null );
			else
				self.mulSCTInvLineTypes.setSelected( allSelected );
			endif;
			self.txtSCTPercent.text := _rate.surchargeRate.asStringJMT();
			app.cmsBeginLoad( load );
			self.myProxyCTSurRate := _rate.pxyCreateUpdateProxy();
			app.cmsEndLoad( load );
			*/
			// ### TFS 54565 (54385) 15Sep2022 NAVPW1
			create allSelected transient;
			_rate.getAllSelectedInvLineTypes( allSelected );
			
			if _rate.getCargoSurchargeInvLineType &lt;&gt; null then
				self.cmbSCTInvLineType.listIndex := self.cmbSCTInvLineType.findObject( _rate.getCargoSurchargeInvLineType );
			endif;
			
			if _rate.allSelectedInvLineTypes.isEmpty then
				self.mulSCTInvLineTypes.setSelected( null );
			else
				self.mulSCTInvLineTypes.setSelected( allSelected );
			endif;
			self.txtSCTPercent.text := _rate.surchargeRate.asStringJMT();
			
			create allSelectedCargoTypes transient;
			_rate.getAllSelectedCargoTypes( allSelectedCargoTypes );
			
			if _rate.allCargoTypes.isEmpty then
				self.mulSCTCargoTypes.setSelected( null );
			else
				self.mulSCTCargoTypes.setSelected( allSelectedCargoTypes );
				
				create cargoSubTypeArray transient;
				create commodityArray transient;
				
				foreach cargoType in allSelectedCargoTypes discreteLock do
					
					foreach cargoSubType in cargoType.allProducts discreteLock do
						cargoSubTypeArray.addExclusive(cargoSubType);
						
					endforeach;
					
					foreach commodity in cargoType.allCommodities discreteLock do
						commodityArray.addExclusive(commodity);
						
					endforeach;
					
				endforeach;
				
				self.mulSCTSubCargoTypes.setAvailable(cargoSubTypeArray, true);
				self.mulSCTCommodities.setAvailable(commodityArray, true);
				
			endif;
			
			create allSelectedCargoSubTypes transient;
			_rate.getAllSelectedCargoSubTypes( allSelectedCargoSubTypes );
			
			if _rate.allCargoSubTypes.isEmpty then
				self.mulSCTSubCargoTypes.setSelected( null );
			else
				self.mulSCTSubCargoTypes.setSelected( allSelectedCargoSubTypes );
			endif;
			
			create allSelectedCommodities transient;
			_rate.getAllSelectedCommodities( allSelectedCommodities );
			
			if _rate.allCommodities.isEmpty then
				self.mulSCTCommodities.setSelected( null );
			else
				self.mulSCTCommodities.setSelected( allSelectedCommodities );
			endif;
			
			create allSelectedDebtors transient;
			_rate.getAllSelectedDebtors( allSelectedDebtors );
			
			if _rate.allDebtors.isEmpty then
				self.mulSCTDebtors.setSelected( null );
			else
				self.mulSCTDebtors.setSelected( allSelectedDebtors );
			endif;
			
			self.txtSCTSurchargeFixAmnt.text := _rate.surchargeAmount.asStringJMT();
			self.txtSCTSurchargeGrtrTh.text := _rate.applyGreaterThanAmount.asStringJMT();
			
			applyGreaterThanLineTotal := _rate.applyGreaterThanLineTotal;
			
			if applyGreaterThanLineTotal then
				self.optSCTSurchargeLnTl.value := applyGreaterThanLineTotal;
			else
				self.optSCTSurchargeQty.value := true;
			endif;
			
			self.txtSCTSurchargeFrmDte.text := _rate.validFrom.Date.asStringJMT();
			self.txtSCTSurchargeFrmTme.text := _rate.validFrom.Time.asStringJMT();
			self.txtSCTSurchargeToDte.text := _rate.validTo.Date.asStringJMT();
			self.txtSCTSurchargeToTme.text := _rate.validTo.Time.asStringJMT();
			
			self.myProxyCTSurRate := app.createUpdateProxy(_rate).CM_InvTypeCargoMultiSurcharge;
			
			// ### TFS 54565 (54385) 15Sep2022 NAVPW1
		else
			create self.myProxyCTSurRate transient;
		endif;
		self.frmMain.zOrder(0);
	endif;

epilog
	delete allSelectedCargoTypes;		// ### TFS 54565 (54385) 16Sep2022 NAVPW1
	delete allSelectedCargoSubTypes;	// ### TFS 54565 (54385) 16Sep2022 NAVPW1
	delete allSelectedCommodities;		// ### TFS 54565 (54385) 16Sep2022 NAVPW1
