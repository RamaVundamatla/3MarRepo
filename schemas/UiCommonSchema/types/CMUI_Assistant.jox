        <source>displayEntryVehicleTrnsferArea(pTerminal : CM_Terminal; pTerminalArea : CM_TerminalArea) : String;

begin
	if pTerminal = null or pTerminalArea = null then
		return null;
	endif;
	
	if pTerminalArea.myTerminal &lt;&gt; pTerminal then
		return null;
	endif;

	if pTerminalArea.isKindOf(CM_VehicleTransferArea) then
		return pTerminalArea.id;
	endif;
end;
</source>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
        <ReturnType type="String"/>
    </JadeMethod>
