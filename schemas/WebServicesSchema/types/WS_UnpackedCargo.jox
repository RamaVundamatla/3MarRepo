    </JadeMethod>
    <JadeMethod name="setDetailsFromChild" id="cb0b7c56-a257-4d2c-a298-573a5f6a9070">
        <updating/>
        <source>setDetailsFromChild(child : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2017	jlghl1	Initial creation

*/

vars
	proxyCargoType : WS_CargoType;
begin
	self.id := child.id;
	self.location := child.locationId;
	self.cmObjectId := child.getOidAsString;
	create proxyCargoType transient;
	proxyCargoType.setProxyFromObject(child.myCargoType);
	self.cargoType := proxyCargoType;
epilog

end;</source>
        <Parameter name="child" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="f0e051f5-5e29-4084-8ebf-fda564d65f50">
        <updating/>
        <source>setProxyFromObject(_object: CM_Unpack) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2017	jlghl1	Initial creation

*/

vars
begin
	inheritMethod(_object);
	self.amountString := _object.getUnpackAmount;

	self.totalAmount := _object.totalQuantity;
	self.totalWeight := _object.totalWeight;
	
epilog
	
end;</source>
        <Parameter name="_object" type="CM_Unpack"/>
    </JadeMethod>
</Class>
