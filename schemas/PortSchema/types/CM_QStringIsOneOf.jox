<Class name="CM_QStringIsOneOf" id="ce0e1a36-9ab8-4e0f-86da-d1ff5109736d">
    <superclass name="CM_QueryLookupOperators"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <CompAttribute name="allSelectionValues" id="8537afc5-1404-4af8-a2a2-4c17b33a7f17">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="create" id="58d1801f-af5b-4ce4-9c44-db0ca2f7fc37">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.description := self.Operator_IsOneOf;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="cff7dffa-d741-45a7-94e5-4a60d2f320c7">
        <source>doMatch(_value: String): Boolean;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.allSelectionValues.includes(_value);


end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getControlType" id="33df77c8-30cc-4cd3-b282-0160696f8cd3">
        <source>getControlType(): Integer;
// ---------------------------------------------------------------------------
// Created:     12 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return QueryControl_MultiSelect;


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="3494be01-5dd9-417a-8fb2-e5e2b26b8478">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
// -------------------------------------------
// Created 03 may 2008 by cnwvu1
// -------------------------------------------

vars

begin

	app.raiseCMException1( ERR_QueryForRTMustUseEqualTo, '"'&amp; self.description &amp;'"', null, null);

end;
</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSearchValue" id="51f8e86b-503e-4af3-a32d-5efde1bd4a89">
        <source>getSearchValue(): Any;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.allSelectionValues;


end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueAsStringArray" id="6fc2e02c-3179-4e5d-9b89-39bf7d42a826">
        <source>getSearchValueAsStringArray(_arr: StringArray input);
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.allSelectionValues.copy(_arr);

end;</source>
        <Parameter name="_arr" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="0f09eb7e-0c9f-4c40-9d63-e2c8645a0ae8">
        <source>getSearchValueStr(_prop : CM_QueryProperty) : String;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	displayStr,
	str				: String;
	
begin

	foreach str in self.allSelectionValues do
		if displayStr = null then
			displayStr := _prop.translateToDisplayValue(str);
		else
			displayStr := displayStr &amp; ', ' &amp; _prop.translateToDisplayValue(str);
		endif;
	endforeach;
	
	return displayStr;

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidForRT" id="14417568-6d49-4b32-9a73-388839f12ce8">
        <source>isValidForRT(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	par 27890

*/

vars

begin

	//Queries for RT must only use the operations having only one searching value.
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="e3e30c35-71e0-41ef-b693-96892d1ef20b">
        <updating/>
        <source>setSearchValue(_value : Any) updating;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.allSelectionValues.clear;
	if _value &lt;&gt; null then // par 18123
		if _value.isKindOf(StringArray) then //17 Jun 2015	NDL	Par 36338
			_value.StringArray.copy(self.allSelectionValues);
		elseif _value.isKindOf(String) then
			self.allSelectionValues.add(_value.String);
		endif;
	endif;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="d5d6bbdd-140e-46dc-8486-c72ed83aac61">
        <source>validateForRT( _queryName, _propName : String );
// -------------------------------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
//
// Purpose:	Queries for RT must only use the operations having only one searching value.
//			A set of selected values is not valid for the RT Drivers screen. 
// -------------------------------------------------------------------------------------

vars
	str		: String;
	strValue: String;
	
begin
	
	foreach strValue in self.allSelectionValues do
		str := str &amp; strValue &amp; ', ';
	endforeach;
	str := str[1 : str.length()-2];		// removing the last comma
	
	//26 Jul 2011	NDL	Par 27890
	//app.raiseCMException1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;' '&amp; str &amp;'"', null, null);
	app.raiseCMWarning1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;' '&amp; str &amp;'"', null, null, null);
	
end;
</source>
        <Parameter name="_queryName" type="String"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
</Class>
