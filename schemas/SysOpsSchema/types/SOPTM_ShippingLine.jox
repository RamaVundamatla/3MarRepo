    <JadeMethod name="includeObject" id="a9e0eae8-a077-444b-8014-adf1753cbdb8">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_ShippingLine.isNotAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="263bb0a0-2519-4ca4-a57e-b58e398573aa">
        <source>initShtMultiSelect();

//
// 10 April 2013	PJS  PAR # 31408
//


vars
	theForm	: SOP_TableMaintForm;
	tmpCol : ObjectSet;
begin

	theForm := self.myForm;
	inheritMethod;	
	
	// 31408 
	if allowAccessPortsGroups then
		theForm.shtSingleSelect1.visible := true;
		theForm.lstSingleSelect1.visible :=true;
		theForm.shtSingleSelect1.caption := 'Port Groups';
		theForm.btnSingle1Edit.enabled:=true;
		theForm.btnSingle1Delete.enabled:=true;
		theForm.btnSingle1New.enabled:=true;
	else
		theForm.shtSingleSelect1.visible := false;
	endif;
	
	create tmpCol transient;
	app.myRoot.getEmailAddresses(tmpCol,false);
	self.setupMultiSelect1("Contacts",tmpCol,SOP_TableMaintForm::displayEntryEmailAddress.name);	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		theForm.btnSingle1Delete.enabled:=false;
		theForm.btnSingle1New.enabled:=false;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
