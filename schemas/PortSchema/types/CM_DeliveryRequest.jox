    <JadeMethod name="cloneReferences" id="cce6912a-c8b9-4205-8851-12e80564f4ec">
        <updating/>
        <source>cloneReferences(_origRequest : CM_DeliveryRequest) updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
06 Jul 2015	cnwkpd1	PAR #36578 - Tidy up leaked CM_Strings objects
	
*/
vars
	hugeStrings		: HugeStringArray;
	strings			: StringArray;
	s				: String;
	
begin
	self.setMyOriginatingBulkRelease(_origRequest.myOriginatingBulkRelease);
	self.myOperatorGroup := _origRequest.myOperatorGroup;
	self.myCargoType := _origRequest.myCargoType;
	self.mySubTerminalSource := _origRequest.mySubTerminalSource;		// CCMS 1735
	self.myTransferToTerminal := _origRequest.myTransferToTerminal; //cnwrd1 par 26036 18.10.2010
	
	_origRequest.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	
	if _origRequest.ids &lt;&gt; null then
		create hugeStrings transient;
		_origRequest.ids.getStrings(hugeStrings);
		
		create strings transient;
		hugeStrings.copy(strings);
				
		self.setIds(strings);
	endif;
	
epilog
	delete hugeStrings;
	delete strings;
end;</source>
        <Parameter name="_origRequest" type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="completeExtraAnyIdDirTasks" id="b16b5eed-b64b-4156-9378-44e9bfe0c86e">
        <source>completeExtraAnyIdDirTasks();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 August 2014		cnwndl1	Initial creation	Par 34675
17/03/2015			cnwmh5	Tranisent Leaks
12 September 2024	navpw1	TFS: 65623 (65624) - Added code to cleanup the work order wle when the unfilled delivery request is removed for Any ID Any Amount
09 October 2024		navpw1	JIRA: MTN-33060 (MTN-33061) - Added code to only cleanup the work order wle if the release request is fully filled and the work order is completed
04 Dec 2025 		navma1 	MTN-36742 AAT- Webb Dock West (WDCT) experiencing slowness 
*/

vars

	wle				: CM_WorkListEntry;
	rtQueueEntry	: CM_RTQueueEntry;
	delWles			: CM_WLEArray;
	jobs			: CM_JobArray;
	job				: CM_Job;
	reserveDetail	: CM_ReserveDetail;
	isForBulkMulti	: Boolean;
	outstanding		: Decimal[14,4];
	
begin
	
	if not self.isAnyId() then
		return;
	endif;
	
	//find the unactioned tasks and delete them.
	create delWles transient;
	create jobs transient;
	foreach wle in self.allWorkListEntries do
		
		if wle.myTrackedItem &lt;&gt; null then
			continue;
		endif;
		
		rtQueueEntry := wle.allRTQueueEntries.first;
		if rtQueueEntry &lt;&gt; null then
			app.myUtilityDA.utlDeleteQueueEntry(rtQueueEntry, false, null, app.myPassport);
		endif;
		
		delWles.add( wle );				//04.12.2025 navma1 #MTN-36742
		jobs.tryAdd( wle.job );			//04.12.2025 navma1 #MTN-36742
	
		// ### JIRA: MTN-33060 (MTN-33061) 09Oct2024 NAVPW1
		reserveDetail := wle.myRequest.myReserveDetail;
		if reserveDetail &lt;&gt; null then
			isForBulkMulti:= reserveDetail.isBulkMulti or reserveDetail.byTypeByWeight;	// 6/12/2023 navcs2 ChangeRequest 57537		
			if isForBulkMulti or reserveDetail.byTypeByWeight then
				outstanding := reserveDetail.getWeightOutstanding();
			else
				outstanding := reserveDetail.getTotalOutstanding() - reserveDetail.getTotalLoaded();
			endif;
		endif;
		
		if wle.myWorkOrderWLE &lt;&gt; null and reserveDetail &lt;&gt; null and outstanding = 0 then
			delWles.add( wle.myWorkOrderWLE );
			jobs.tryAdd( wle.myWorkOrderWLE.job );			//04.12.2025 navma1 #MTN-36742
		endif;
		// ### JIRA: MTN-33060 (MTN-33061) 09Oct2024 NAVPW1
		
	endforeach;
	
	foreach wle in delWles do
		wle.erase(NORMAL_ERASE);
	endforeach;
	foreach job in jobs do
		job.rebuildStatus();
	endforeach;

epilog
	delete jobs;
	delete delWles;
end;</source>
    </JadeMethod>
    <JadeMethod name="completeUnactionedWLEs" id="daf21495-f6eb-4af9-a602-858e893a2f9c">
        <source>completeUnactionedWLEs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 November 2022	jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons
12 November 2024	navpw1	JIRA: MTN-33361 - Added code to remove the last remaining work order wle that is a placeholder and not neeeded

*/

vars

	wle : CM_WorkListEntry;
	rtQueueEntry : CM_RTQueueEntry;
	delWles : CM_WLEArray;
	jobs : CM_JobArray;
	job : CM_Job;
	invalid : Boolean;
	reserveDetail	: CM_ReserveDetail;
	isForBulkMulti	: Boolean;
	outstanding		: Decimal[14,4];
	
begin

	//find the unactioned tasks and delete them.
	create delWles transient;
	create jobs transient;
	
	on Exception do app.handleDeletedObject( exception, wle, invalid );
	
	foreach wle in self.allWorkListEntries do
		invalid := false;
		if wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		
		if invalid then
			continue;
		endif;
		
		rtQueueEntry := wle.allRTQueueEntries.first;
		if rtQueueEntry &lt;&gt; null then
			app.myUtilityDA.utlDeleteQueueEntry(rtQueueEntry, false, null, app.myPassport);
		endif;
		
		// ### JIRA: MTN-33361 12Oct2024 NAVPW1
		reserveDetail := wle.myRequest.myReserveDetail;
		if reserveDetail &lt;&gt; null then
			isForBulkMulti:= reserveDetail.isBulkMulti or reserveDetail.byTypeByWeight;	// 6/12/2023 navcs2 ChangeRequest 57537		
			if isForBulkMulti or reserveDetail.byTypeByWeight then
				outstanding := reserveDetail.getWeightOutstanding();
			else
				outstanding := reserveDetail.getTotalOutstanding() - reserveDetail.getTotalLoaded();
			endif;
		endif;
		
		if wle.myWorkOrderWLE &lt;&gt; null and reserveDetail &lt;&gt; null and outstanding = 0 then
			delWles.add( wle.myWorkOrderWLE );
			jobs.addExclusive( wle.myWorkOrderWLE.job );
		endif;
		// ### JIRA: MTN-33361 12Oct2024 NAVPW1
		
		delWles.add( wle );
		jobs.addExclusive( wle.job );
	endforeach;
	
	foreach wle in delWles do
		wle.erase(NORMAL_ERASE);
	endforeach;
	
	foreach job in jobs do
		job.rebuildStatus();
	endforeach;

epilog

	delete jobs;
	delete delWles;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createAutoplanTIDepreciated" id="2028c658-60b7-4e79-a239-9d37b6e5a943">
        <source>createAutoplanTIDepreciated(obj : CMIF_AutoMovePlan io; _theTerminal : CM_Terminal);
//Special method that populates the properties of a passed in
//transient container
vars
  ti : CM_Container;
  now : TimeStamp;
  term	:	CM_Terminal;
begin
	create obj.myTrackedItem.CM_Container transient;	//Destroyed in destructor of CMIF_AutoMovePlan
	ti := obj.myTrackedItem.CM_Container;
	obj.request := self;

	ti.setFromDeliveryRequest(self,_theTerminal);	

end;</source>
