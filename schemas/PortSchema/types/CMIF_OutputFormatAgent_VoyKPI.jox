    <JadeMethod name="getSelectedTrackedItems" id="eb587d01-3ac0-471a-86c6-4b3426917453">
        <source>getSelectedTrackedItems(_table :Table input; _coll :CM_TISet input);
/*
Date		Who		Reason
31 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	row, 
	col, col2, columns,
	offset		:Integer;
	text		:String;
	obj			:Object;
	kpi			:CM_KPIVoyageMoveDtl;
	request		:CM_Request;
	trx			:CM_Transaction;
	ti			:CM_TrackedItem;
	gotException	:Boolean;
	test		:Integer;
begin
	columns	:= _table.columns;
	
	on Exception do app.handleDeletedObject (exception, trx, gotException);
	on Exception do app.handleDeletedObject (exception, ti, gotException);
	
	foreach row in _table.fixedRows + 1 to _table.rows do	:rowLoop
		foreach col in 3 to _table.columns do				:columnLoop
			if not  _table.accessCell (row, col).selected then 
				continue;
			endif;
			
			if self.isSplitterColumn (_table, col) then
				continue;
			endif;
			
			obj := _table.accessCell (row, col).itemObject; 
			
			if obj = null then
				continue;
			endif;
			if obj.isKindOf(CM_KPIVoyageMoveDtlDict) then
				// the set will contain all relevant CM_KPIVoyageMoveDtl objects
				foreach kpi in obj.CM_KPIVoyageMoveDtlDict do
					foreach trx in kpi.allTransactions do
						if trx.isKindOf (CM_TITransaction) then
							ti := trx.CM_TITransaction.myTrackedItem;
							
							if gotException then
								// transaction is no longer valid
								gotException := false;
								continue;
							endif;
						endif;
	
						test := ti.edition;
						
						if gotException then
							// transaction is no longer valid
							gotException := false;
							continue;
						endif;
						
						_coll.addNoDuplicates (ti, false);
					endforeach;
				endforeach;
			elseif obj.isKindOf (CM_TISet) then
				obj.CM_TISet.copyNoDuplicates (_coll, false);
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_coll" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTableColours" id="60cc0761-7f53-486b-899d-d2b75caa6bc3">
