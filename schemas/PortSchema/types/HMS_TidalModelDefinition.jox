    <JadeMethod name="getData_TidalCurrent" id="b730f433-e351-4e0b-9ad5-a8a37145618a">
        <source>getData_TidalCurrent(_tsArray 		: TimeStampArray input; 
					_currentDataArray : RealArray input);
/*
----------   ----------  --------------------------------------------------
Created:	12 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ts				: TimeStamp;
	tidalData		: HMS_TidalData;
	heighestVal		: Integer;
	dict			: HMS_TidalDataByTSDict;
begin
	dict := self.allHMSTidalData;
	foreach ts in _tsArray do
		//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-ts:' &amp; ts.String);
		tidalData := dict.getAtKeyGeq(ts);
		if tidalData &lt;&gt; null then
			_currentDataArray.add(tidalData.HMS_CurrentTidalData.flow);
			/*
			if tidalData.HMS_DraftTidalData.height &gt; heighestVal then
				heighestVal := tidalData.HMS_DraftTidalData.height;
			endif;
			*/
		endif;
	endforeach;

end;</source>
        <Parameter name="_tsArray" type="TimeStampArray" usage="input"/>
        <Parameter name="_currentDataArray" type="RealArray" usage="input"/>
    </JadeMethod>
