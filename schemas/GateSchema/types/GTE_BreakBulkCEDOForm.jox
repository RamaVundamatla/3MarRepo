    <JadeMethod name="setSearchAttribute" id="5285ce27-32d4-4b0c-a1d4-905fb533f521">
        <updating/>
        <source>setSearchAttribute(_entRowName: String; _value: String) updating, protected;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if _entRowName = ETRow_Any then
		self.anyFilterText := _value;
	elseif _entRowName = ETRow_BookingRef then
		self.bookingRefFilterText := _value;
	elseif _entRowName = ETRow_CustomExportEntryNumber then
		self.cedoFilterText := _value;
	elseif _entRowName = ETRow_Consignor then
		self.consignorFilterText := _value;
	elseif _entRowName = ETRow_VesselName then
		self.vesselFilterText := _value;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTextSearchAttributes" id="c0cd9557-0cc7-46c2-af3e-0aea51bcf62b">
        <updating/>
        <source>setTextSearchAttributes() updating, protected;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl	: CM_EntryTable;
	entTableDef		: EntTableDef;
	entTableView	: EntTableView;
	entRow			: EntTableRowTransient;
	intRow			: Integer;
begin
	tbl := self.tblSearchText;
	
	foreach intRow in 2 to tbl.rows do
		entRow := tbl.accessRow(intRow).itemObject.EntTableRowTransient;
		self.setSearchAttribute(entRow.name, tbl.accessCell(intRow, 2).text);
	endforeach;


	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTextTable" id="c761b9af-b7c2-4199-99d0-436ba5f3eedb">
        <source>setTextTable() protected;
//----------------------------------------------------------------
//	Created:	06 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl				: CM_EntryTable;
	entTableDef		: EntTableDef;
	entTableView	: EntTableView;
	entRow			: EntTableRow;
	idx				: Integer;
begin
	tbl := self.tblSearchText;
	
//	tbl.rows := 1;
//	tbl.fixedRows := 1;
//	tbl.fixedColumns := 1;
//	tbl.accessColumn(1).width := 90;
//	tbl.accessCell(1,1).text := "Column" &amp; Tab &amp; "Contains";
///
//	tbl.accessRow(1).backColor :=  self.colorHeadingColumn;
//	
	entTableDef := app.myController.getEntTableDef(ETDef_BreakBulkCEDO);

	entTableView := entTableDef.allEntTableViews[ETView_TextSearchView];
	tbl.setEntTableDef(entTableDef, 'getControl', null);//ETView_TextSearchView, 
	tbl.showHideRowsByView(entTableView, tbl.ShowHideRows, false);

	tbl.accessColumn(1).backColor :=  self.colorHeadingColumn;

	tbl.accessColumn(2).inputType := Table.InputType_TextBox;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e632aa49-851e-4c6d-a367-75b0db790cfa">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	05 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.usesQueryFrame := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableInfo := true;
	self.useTableSorting := false;
	inheritMethod();

	
	self.initTable();

	// dont want to 
//	self.tblData.disallowColumnSorter := false;
	
	self.cmbVoyage.show3D := 0;
	self.mnuContextTIEdit.caption := app.getErrorString(EditSelected);
	self.btnHideSearcher.bubbleHelp := app.getErrorString(Hide);
	self.btnShowSearcher.bubbleHelp := app.getErrorString(Show);
	self.btnShowSearcher.caption := app.getErrorString(ShowSearcher);
	
	self.frmModalDialog.height := 100;
	self.frmModalDialog.width := 400;
	self.frmModalDialog.centreWindow;
	self.frmModalDialog.top := 50;

	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.lblModalMessage.move(0,10,self.frmModalDialog.width,40);
	self.lblModalMessage.alignment := Frame.Alignment_Center_Middle;
	self.lblModalInfo.move(0,55,self.frmModalDialog.width,20);
	self.lblModalInfo.alignment := Frame.Alignment_Center_Middle;
	self.lblModalMessage.visible := true;
	self.lblModalInfo.visible := true;
	self.frmModalDialog.visible := false;
	
	self.setFormCaption;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnEditItem.enabled:= false;
	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="d604c5ee-54f4-45a5-a544-4c39de294693">
        <source>showColourLegend();
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
	
begin

	create colLegend;
//	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;
	
	colLegend.addLegendItem(app.getErrorString(System_Voyage) &amp; " not set", Black, self.ColourYellowLight, null, false);
	colLegend.addLegendItem(app.getErrorString(System_Voyage) &amp; " set", Black, self.ColorGreenLight, null, false);
	
	colLegend.showModal;


epilog
	delete colLegend;


end;</source>
    </JadeMethod>
