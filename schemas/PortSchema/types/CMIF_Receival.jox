        <source>setHumidity(_humidity : Decimal) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2009	cnwdap1	Initial creation
*/
vars

begin
	self.humidity	:= _humidity;
epilog

end;</source>
        <Parameter name="_humidity" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementValue" id="b57cc2f5-d465-4ccc-8f1f-6299c9fedb6c">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
16/04/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	if _entRowName = ETRow_MyHeight then
		self.height := _value;
	elseif _entRowName = ETRow_MyLength then
		self.length := _value;
	elseif _entRowName = ETRow_MyWidth then
		self.width := _value;
	elseif _entRowName = ETRow_MyWeight then 	//cnwrd1 par 31941
		self.weightTotal := _value;			
	elseif _entRowName = ETRow_MyVolume then 	//cnwrd1 par 31941
		self.volumeTotal := _value;					
	elseif _entRowName = ETRow_MyDensity then 	//cnwrd1 par 31941
		self.density := _value; 				// ### TFS 52193 22Nov2021 NAVPW1			
	else
		inheritMethod(_entRowName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
