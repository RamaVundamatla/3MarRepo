    <JadeMethod name="sealNumberVent" id="4c2597da-125b-4297-99ef-5dc62f783c2b">
        <methodInvocation>mapping</methodInvocation>
        <source>sealNumberVent(set : Boolean; _value : String io) mapping;
//
// 28 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if set then
		self.setSealsAsObjects(_value, SealType_Vent);
	else
		_value := self.getSealsAsString(SealType_Vent);
		if _value = null then
			_value := self.sealNumberVent;
		endif;
	endif;	
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
