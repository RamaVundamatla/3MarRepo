    <JadeMethod name="setControlsForAddEdit" id="f7427d52-280f-45c9-89f7-a0b28e4768d0">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_HsCode);
		theForm.tblInput1.enableRowByName(ETRow_LongDescription);
		theForm.tblInput1.enableRowByName(ETRow_ShortDescription);
		theForm.tblInput1.enableRowByName(ETRow_DutyType);
		theForm.tblInput1.enableRowByName(ETRow_DutyRate);
		theForm.tblInput1.enableRowByName(ETRow_DutyExempt);
		theForm.tblInput1.enableRowByName(ETRow_PriceCargo);
		theForm.tblInput1.enableRowByName(ETRow_ChemicalCargo);
		theForm.tblInput1.enableRowByName(ETRow_NuclearCargo);
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_DutyDocHSCode);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_HsCode);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_ShortDescription);
		theForm.tblInput1.enableRowByName(ETRow_DutyType);
		theForm.tblInput1.enableRowByName(ETRow_DutyRate);
		theForm.tblInput1.enableRowByName(ETRow_DutyExempt);
		theForm.tblInput1.enableRowByName(ETRow_PriceCargo);
		theForm.tblInput1.enableRowByName(ETRow_ChemicalCargo);
		theForm.tblInput1.enableRowByName(ETRow_NuclearCargo);
	endif;

epilog

end;</source>
    </JadeMethod>
