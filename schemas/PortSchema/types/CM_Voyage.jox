    <JadeMethod name="getEventDTOfTypeCodeFirst" id="3214eca2-e212-4412-b945-75836b9e2b36">
        <source>getEventDTOfTypeCodeFirst(_eventCode : Integer) : TimeStamp;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2019	jlgdap1		Initial creation TFS 44328 ASPA New Report Attributes for CM_InvoiceView
//
vars
	event : CM_EventTransaction;
begin
	foreach event in self.allEventTransactionsByDateTime discreteLock do
		if event.myEventType.type = _eventCode then
			return event.dateTime;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_eventCode" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEventOfTypeFirst" id="0d95abe6-01c1-4b50-b3ea-b789f75bf53f">
        <source>getEventOfTypeFirst(_eventType : CM_EventType) : CM_EventTransaction;
/*
Purpose:			
Date		Who		Reason
03 February 2017	cnwab1	Initial creation
*/

vars
	event : CM_EventTransaction;
begin
	foreach event in self.allEventTransactionsByDateTime discreteLock do
		if event.myEventType = _eventType then
			return event;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
