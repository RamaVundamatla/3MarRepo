    <JadeMethod name="trxCreateCustomsReferences" id="72474c64-a9d0-496f-92b6-b855b772a624">
        <updating/>
        <source>trxCreateCustomsReferences(_pxyCustomsReferenceDict: CM_CustomsReferenceDict input; _ti : CM_TrackedItem; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Mar 2023	navpw1	Initial creation TFS: 55215
29 Jan 2024	navhn30	ChangeRequest 57637: CUX | EDBIC MTN Populate customs reference table using POST/CustomsStatus (.040)
11 Mar 2024	navdap1	TFS 56853 CUX - MTN-EDBIC - 190 - Cargo Details Query
20 Mar 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - allow customs references to be deleted
09 Apr 2024	navlw1	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode
29 Apr 2024	naviv1	TFS 63619 : CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
21 May 2024	navdap1	TFS 63619 : CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
25 May 2024 naviv1	TFS 64243 : CUX | POST &amp; PUT /Cargo APIs - Edit Transaction not created when customs reference data updated via API
*/

vars
	beforeEditStr,
	afterEditStr					: String;
	trackedItem						: CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	
	// navlw1 #62959
	if _ti = null then
		// riase an error
		app.raiseUnexpectedProgramError(CM_TransactionAgent.name, method.name, "Tracked Item is null");
		return;
	endif;
	
	trackedItem := _ti;
	beforeEditStr := _ti.getCustomsReferenceAuditString();	// TFS 63619
	if beforeEditStr = null then							// TFS 63619
		beforeEditStr := "null";							// TFS 63619
	endif;													// TFS 63619
	
	trackedItem.saveCustomsReferences(_pxyCustomsReferenceDict, _passport);		//29.04.2024 naviv1 #63619
	
	afterEditStr := _ti.getCustomsReferenceAuditString();
	if afterEditStr = null then
		afterEditStr := "null";
	endif;
	
	// 25/02/2024 navcs2	Defect 62587 Start
	if _passport.noErrors and beforeEditStr &lt;&gt; afterEditStr then
		trackedItem.createEditForCustomsReferences(beforeEditStr,afterEditStr,_passport); //30-May-2024 naviv1 #64243
		//25/02/2024 navcs2	Defect 62587 End
	endif;
	
	if _passport.noErrors then
		// fire off an update to the ti to trigger the update event on UI
		if _ti &lt;&gt; null then
			_ti.updateObjectEdition(_ti);
		endif;
	endif;
	// end navlw1 #62959
epilog
	self.finaliseActivityWithPassport(_passport);	
end;</source>
        <Parameter name="_pxyCustomsReferenceDict" type="CM_CustomsReferenceDict" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateDBPurgeRequest" id="2c1796bf-ef90-493c-a5fe-ac0282e56466">
        <updating/>
        <source>trxCreateDBPurgeRequest(	_user						: CM_User;
							_term 						: CM_Terminal;
							_date 						: Date;
							_voyage,
							_location,
							_docket,
							_offsite,
							_prenote,
							_bookingRef,
							_nsActivity, 							// ### TFS 50669 06AUG2021 NAVAB1
							_discrep,
							_machine, _sundry, _xlation,
							_ddExtractHistory, _lockTransactions,
							_ediData, _yardAllocationLogs, _menuUserItems,
							_logCheckScaleHdr, _vehicleVisit, _eventRequests, 
							_cargoPhoto 				: Boolean;
							_dutyDocs 					: Boolean;
							_vehicleBookingSlots 		: Boolean;
							_cargoGroups				: Boolean;	//22 Jun 2015	NDL	Par 36338
							//_sleepInterval			: Integer;	//TFS 6960
							_interTerminalRailBOLs		: Boolean; 	//epr TFS 4157 28/4/17
							_truncateEDIInfoXML			: Boolean;	//13 Sep 2021	NDL	TFS 51718
							_maxDurationMinutes			: Integer;	//TFS 6960
							_purgeSecGateUnknTrucks 	: Boolean;	// ### TFS 51994 01Oct2021 NAVPW1
							_purgeReleaseRequests       : Boolean;  //16/09/2022 navmv20 TFS 53403
							_purgeAttachCargoTypes   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
							_purgeAttachContracts   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
							_purgeAttachInvoices   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
							_purgeAttachVoyages   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
							_purgeAttachWorkOrders   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
							_purgeWorkOrderJobSheet	 : Boolean;	  //21.7.2023 navhl20 #58158
							_purgeVisitPhotos		: Boolean;	 //11.08.2025 navhl20 #35650
							_purgeAgGatewayMessages		: Boolean;	 //11.08.2025 navhl20 #35650
							_passport					: CM_Passport input) updating;
//
//23/05/2012	cnwrs1	Par 29613
//20 September 2022 navmv20 ChangeRequest 53403: MTN - Garbage Collection of Release Request
//13 Feb 2023 		navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 		navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025		navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars

begin

// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateDBPurgeRequest(_user,
											_term,
											_date,
											_voyage,
											_location,
											_docket,
											_offsite,
											_prenote,
											_bookingRef,
											_nsActivity, 				// ### TFS 50669 06AUG2021 NAVAB1
											_discrep,
											_machine,
											_sundry, 
											_xlation,
											_ddExtractHistory, 
											_lockTransactions,
											_ediData,
											_yardAllocationLogs,
											_menuUserItems,
											_logCheckScaleHdr,
											_vehicleVisit,
											_cargoPhoto, 				//01/12/2009 cnwdz2 par21808
											_eventRequests,
											_dutyDocs,
											_vehicleBookingSlots,
											_cargoGroups,				//22 Jun 2015	NDL	Par 36338
											//_sleepInterval,			//TFS 6960	
											_interTerminalRailBOLs,
											_truncateEDIInfoXML,		//13 Sep 2021	NDL	TFS 51718
											_maxDurationMinutes,		//TFS6960
											_purgeSecGateUnknTrucks, 	// ### TFS 51994 29Sep2021 NAVPW1
											_purgeReleaseRequests,      //16/09/2022 navmv20 TFS 53403
											_purgeAttachCargoTypes,  // 13/02/2023 navhl20 #54900[56518]
											_purgeAttachContracts,   // 13/02/2023 navhl20 #54900[56518]
											_purgeAttachInvoices,  // 13/02/2023 navhl20 #54900[56518]
											_purgeAttachVoyages,   // 13/02/2023 navhl20 #54900[56518]
											_purgeAttachWorkOrders,  // 13/02/2023 navhl20 #54900[56518]
											_purgeWorkOrderJobSheet,	//21.7.2023 navhl20 #58158
											_purgeVisitPhotos,			//11.08.2025 navhl20 #35650
											_purgeAgGatewayMessages,	//navra1 - MTN-35875- 5th Sep 2025-2
											_passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
