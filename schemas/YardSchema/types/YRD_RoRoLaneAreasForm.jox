    <JadeMethod name="showYardAllocation" id="9dfa521d-0f5e-4821-9023-1c7f60ad8e1b">
        <updating/>
        <source>showYardAllocation( _ya : CM_YardAllocation ) updating;

/*

Purpose:			Position to given Yard Allocation in YAM table

Parameters:			

Return Value:		


Date				Who		Reason
13 November 2008	consw1	Initial creation

*/

vars
	row	: Integer;
	
begin
	if not self.tblYAM.findObjectInRow( _ya, row ) then
		return;
	endif;
	
	self.tblYAM.topRow := row;
	
	// PAR 19142
	self.tblYAM.clearAllSelected();
	self.tblYAM.row := row;
	self.tblYAM.selected := true;
	
	self.frmStatusLine.myFrameCaption.caption := _ya.code;
	
