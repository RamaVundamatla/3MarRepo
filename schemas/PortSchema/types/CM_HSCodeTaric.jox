    <JadeMethod name="getMyHeading" id="26856491-f015-4180-b2eb-163e8b11bff5">
        <source>getMyHeading(): CM_HSCodeHeading;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars
	subCode		: CM_HSCodeSubCode;
begin
	
	subCode := self.myHSSubCode;
	
