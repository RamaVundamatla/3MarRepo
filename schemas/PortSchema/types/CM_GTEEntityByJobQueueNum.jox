<CollClass name="CM_GTEEntityByJobQueueNum" id="b313dd17-55ec-4136-a147-e5c4769fa569">
    <loadFactor>66</loadFactor>
    <memberType name="CMGTE_Entity"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmgte_data"/>
    <MemberKey>
        <property name="CMGTE_Entity::jobQueueNum"/>
    </MemberKey>
    <JadeMethod name="getMatchingGTEReceive" id="31b6d189-2a0e-41e4-aa02-52d4b95271db">
        <source>getMatchingGTEReceive( _cargoType : Integer; _cargoId : String ):CMGTE_Receival;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2018	jlgndl1	Initial creation	TFS 39769

*/

vars

	iter : Iterator;
	gtEntity : CMGTE_Entity;
	gteReceive : CMGTE_Receival;

begin

	iter := self.createIterator;
	while iter.next( gtEntity ) do
		if not gtEntity.isCMGTE_Receival then
			continue;
		endif;
		gteReceive := gtEntity.CMGTE_Receival;
		if gteReceive.cargoType &lt;&gt; _cargoType then
			continue;
		endif;
		if gteReceive.id &lt;&gt; _cargoId then
			continue;
		endif;
		return gteReceive;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="CMGTE_Receival"/>
    </JadeMethod>
</CollClass>
