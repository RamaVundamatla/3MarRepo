        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

epilog
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="47a7c0a9-3206-4cac-805d-0e1ecb829695">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		11 July 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/07/1999	cnwdad1		Added logic to handle a refresh event notification.
//
// --------------------------------------------------------------------------------
begin
	if (eventType = self.NOTIFY_REFRESH) then
		self.loadClasses();
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="viewClass" id="b80d1f22-0760-4c0a-bd7b-6681e27d60b7">
        <source>viewClass() protected;
// --------------------------------------------------------------------------------
// Created:		09 January 1999 by cnwdad1
//
// Purpose:		Gets the selected class in the listbox, and loads the ObjectBrowserForm which
//				shows all of the classes attributes and its instances.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	browserForm	: CnEcObjectBrowserForm;

begin
	if (lstClasses.listIndex = CNEC_NULL_INDEX) then
		app.msgBox("Select the class you wish to view from the list.", "View Class", MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	else
		create browserForm;
		browserForm.setMyClass(lstClasses.itemObject[lstClasses.listIndex].Class);
		browserForm.show();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
