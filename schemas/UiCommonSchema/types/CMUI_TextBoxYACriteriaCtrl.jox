<GUIClass name="CMUI_TextBoxYACriteriaCtrl" id="d1b6ee65-e643-43c0-a6d4-3a03a42f5922">
    <superclass name="CMUI_TextBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="oldText" id="561ca39b-7ff7-4786-ae00-68367a776593">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doApplyBubbleHelp" id="751a3389-18ed-452b-815c-c61da2355471">
        <updating/>
        <source>doApplyBubbleHelp() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2014	cnwndl1	Initial creation	Par 33542

*/

vars

	parentCtl : Window;	
	yaCritCntl : CMUI_YACriteriaCntl;	

begin
	
	parentCtl := self.parent;	
	if parentCtl &lt;&gt; null and parentCtl.isKindOf( CMUI_YACriteriaCntl ) then
		yaCritCntl := parentCtl.CMUI_YACriteriaCntl;
		yaCritCntl.doApplyBubbleHelp();
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="8beccba4-89f0-45f4-9ea0-8fb4659472de">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>gotFocus(textbox: TextBox input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation

*/

vars

begin
	inheritMethod(textbox);

	oldText := self.text;
	
	//24 Feb 2014	NDL	Par 33542	
	self.doApplyBubbleHelp();
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="ce56eba2-9cad-459b-934e-79edbeadde40">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(textbox: TextBox input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation

*/

vars

begin
	inheritMethod(textbox);

	if self.text &lt;&gt; self.oldText then
		self.parent.CMUI_YACriteriaCntl.doCriteriaChanged();
	endif;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="921715e5-89db-445d-abaa-0d132cc33b7a">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/* ---------------------------------------------------------------------------
Created:     31 December 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	str	: String;
	
begin
	inheritMethod(cntrl, persistCntrl);
	
	if not self.isInPainter then	
		str := app.getErrorString(CriteriaValuesStringFormat);
		cntrl.bubbleHelp := str;
	endif;

epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
