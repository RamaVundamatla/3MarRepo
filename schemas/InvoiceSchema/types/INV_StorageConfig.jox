    <JadeMethod name="getAvailableYACriteria" id="1d7910b1-528d-4e87-adff-a7cf21006cda">
        <source>getAvailableYACriteria(_availYACriteria : CM_YACritetriaTypeByTypeDict input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Sept2012	cnwer1	Initial creation SFW 1295
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria
22 May 2023		navmk20	Task 58016: UI - Storage Config - Storage Detail Attributes
20 June 2023	navpw1	TFS: 58429 (58517) - Added Sorting Method Yard Allocation Criteria Type
14/08/2023		navkc1	Bug 59753: FR | EUP 54187 - EUP - Invoicing - Storage Configuration - Free day attributes - Shipping Line (Cargo)
*/

vars

begin
	
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CommodityGroup]);
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ContainerLength]);
