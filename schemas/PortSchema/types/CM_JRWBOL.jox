    <JadeMethod name="getQryEndDateLocalTZ" id="2ddb52c2-e196-41b1-986e-66c6bf184856">
        <source>getQryEndDateLocalTZ():Date;
/*

Purpose:			Return the local timezone version of the receiver's qryEndDate (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars
	systemTS : TimeStamp;
begin
	systemTS.cnEcSetDateAndTime(self.qryEndDate,TimeEndOfDay);
	return self.systemToLocalTime(systemTS).date();
	
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getQryStartDateLocalTZ" id="781c07f0-ac8d-476e-9bf8-100ecf2b2722">
        <source>getQryStartDateLocalTZ():Date;
/*

Purpose:			Return the local timezone version of the receiver's qryStartDate (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars
	systemTS : TimeStamp;
begin
	systemTS.cnEcSetDateAndTime(self.qryStartDate,TimeStartOfDay);
	return self.systemToLocalTime(systemTS).date();
	
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="24e94d5d-ef8b-449a-bf85-37bcc46cbc06">
        <source>noOutputReturned(): Boolean;
// -------------------------------------------
// Created 21 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allBOLs.isEmpty() then
		return true;
	endif;
	return false;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="transportModeDescr" id="d33935b1-d5f5-425c-a011-bb05877ab369">
        <methodInvocation>mapping</methodInvocation>
        <source>transportModeDescr(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     17 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if (not set) then
		_value := app.transModeToString(self.transportMode);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
