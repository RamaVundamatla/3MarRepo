    <JadeMethod name="rel822_par33107" id="19ab6b5c-de1d-4817-895a-7e39c0ac54df">
        <source>rel822_par33107();
/*

Purpose:			Need to rebuild all the CM_Terminal BOL Terminal dictionaries that 
					may have been corrupted by this issue

Parameters:			None

Return Value:		None

Date		Who		Reason
29 Nov 2013	cnwkpd1	PAR #33107 - Docket number changes corrupting dictionary keys

*/

vars
	term : CM_Terminal;
	
begin
	foreach term in CM_Terminal.instances do
		
		beginTransaction;
		term.allBOLTermsByTypeNum.rebuild();
		term.allBOLTermsByTypeOpNum.rebuild();
		commitTransaction;

	endforeach;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="rel822_par33174" id="e7324746-7c65-479b-8a07-65ae49ae0892">
        <source>rel822_par33174();
// C3 CCMS 1124 Log Voyage Operations enhancements
//	Update permissions, ent table defs
vars

	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
	newPerms : IntegerArray;
	agent	: EntTableAgent;
	array : StringArray;

begin
	app.initialize;
	
	create newPerms transient;
	newPerms.add(PmLogBerthMaint);
	newPerms.add(PmLogBerthView);
	newPerms.add(PmLogVoyageOpsAdmin);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, true);	// true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, false);	// true if system permission
	commitTransaction;

	create agent transient;
	create array transient;
	agent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	array.add ("ETRow_Berth");
	array.add ("ETRow_IMO");
	array.add ("ETRow_Side");
	array.add ("ETRow_ArriveDT");
	array.add ("ETRow_ArrivalTime");
	array.add ("ETDef_TblVoyage");
	array.add ("ETDef_TblTerminalData");
	array.add ("ETDef_TblArchiveVoyage");
	agent.trxUpdateFromConstant(array);
	
	return;
	
	write ETRow_Berth;
	write ETRow_IMO;
	write ETRow_Side;
	write ETRow_ArriveDT;
	write ETRow_ArrivalTime;
	write ETDef_TblVoyage;
	write ETDef_TblTerminalData;
	write ETDef_TblArchiveVoyage;

end;</source>
    </JadeMethod>
