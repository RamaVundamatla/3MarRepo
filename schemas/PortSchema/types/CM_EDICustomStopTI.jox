    <JadeMethod name="setVoyage" id="0e406e05-b811-41e9-8c5a-6d63954b65b7">
        <updating/>
        <source>setVoyage(_voyage: CM_Voyage) updating;
//----------------------------------------------------------------
//	Created:	26 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.myVoyage := _voyage;
	if _voyage &lt;&gt; null then
//		self.voyageCode := _voyage.code;	// cnwrl1 09/06/2010 PAR 24299 - what it was
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.setVoyageCode( _voyage.code );
		self.vesselName := _voyage.vesselName;
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
