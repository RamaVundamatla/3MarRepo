<GUIClass name="CMUI_CargoPhotosFormModal" id="65cc11a4-91b5-496d-ab18-a855f8ab800c">
    <superclass name="CMUI_CargoPhotosForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="doDelete" id="ff11c019-a8d0-4f28-b31c-d31dbfb4df8f">
        <updating/>
        <source>doDelete() updating;
/*

Date		Who		Reason
24 October 2013	cnwer1	Initial creation PAR 31845
05 Dec 2024 navlc30 JIRA 33478 Match functionality in the thin client for Damage Recording Improvement

*/

vars
	msgStr : String;
	photo : CM_Photo;
	index,index1 : Integer;
		thumbnail : Object; 
	thumbnailFrame : Window;
	tiSet : CM_ObjectSet;
begin
	if self.myTrackedItem &lt;&gt; null then				//05.12.2024 navlc30 #33478
		inheritMethod();
		create tiSet transient;						//11.12.2024 navlc30 #33478
		tiSet.add(self.myTrackedItem);
		app.myProxyManager.updateProxyEditions(tiSet);	
	else 
		index := self.getCurrentSelectedPhotoIndex();
		photo:=self.getSelectedPhoto();
		if photo = null then
			return;
		endif;
		
		
		msgStr := app.getErrorString2(ConfirmDelete, '', "the selected photo");
		if not  app.msgBox(msgStr,app.getErrorString(ConfirmDeletion), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
			return;
		endif;
		
		index1 := index + 1;
		if index1 &lt;= self.thumbnails.size() then				
			while index1 &lt;= self.thumbnails.size() do				
				thumbnailFrame := self.thumbnails[index1].Picture.parent;
				thumbnailFrame.left := thumbnailFrame.left - CMUI_CargoPhotosForm.Thumbnail_Width - CMUI_CargoPhotosForm.Thumbnail_Space;
				index1 := index1 + 1;
			endwhile;	
		endif;
		
		self.allPhotos.removeAt(index);
		thumbnail := self.thumbnails.removeAt(index);
		thumbnailFrame := thumbnail.Control.parent;
		delete thumbnail;
		delete thumbnailFrame;
		
		self.currentSelectedThumbnail:=null;
		
		if self.allPhotos.size &gt; 0 then
			self.photoThumbnailClick(self.thumbnails[1].Picture);
		else
			self.photo.picture := null;
			self.currentSelectedThumbnail := null;
			self.setControlsForSetup(); //17 Mar 2010	cnwdz2	Initial creation 22645
		endif;
	endif;
epilog
	delete tiSet;				//11.12.2024 navlc30 #33478
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteAll" id="108b15da-ae78-480a-a253-4c5d69127e40">
        <updating/>
        <source>doDeleteAll() updating;
/*

Date		Who		Reason
24 October 2013	cnwer1	Initial creation PAR 31845
05 Dec 2024 navlc30 JIRA 33478 Match functionality in the thin client for Damage Recording Improvement

*/

vars
	index : Integer;
	photo : CM_Photo;
		msgStr : String;
		thumbnail : Object; 
	thumbnailFrame : Window;
	tiSet : ObjectSet;
begin
	if self.myTrackedItem &lt;&gt; null then				//05.12.2024 navlc30 #33478
		inheritMethod();
		create tiSet transient;						//11.12.2024 navlc30 #33478
		tiSet.add(self.myTrackedItem);
		app.myProxyManager.updateProxyEditions(tiSet);
	else 
		index := self.getCurrentSelectedPhotoIndex();
		photo:=self.getSelectedPhoto();
		if photo = null then
			return;
		endif;
		
		
		msgStr := app.getErrorString2(ConfirmDelete, '', app.getErrorString(All_Photos));
		if not  app.msgBox(msgStr, app.getErrorString(ConfirmDeletion), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
			return;
		endif;

		self.allPhotos.purge;
		
		while true do
			thumbnail := self.thumbnails.removeAt(index);
			thumbnailFrame := thumbnail.Control.parent;
			delete thumbnail;
			delete thumbnailFrame;
			index := self.thumbnails.size;
			
			if index &lt; 1 then
				break;
			else
				continue;
			endif;
		endwhile;
		
			self.photo.picture := null;
				self.currentSelectedThumbnail := null;
				self.setControlsForSetup(); 
	endif;
epilog
	delete tiSet;				//11.12.2024 navlc30 #33478
end;</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="88c8c0e4-7958-4912-9ed5-e7dfc343e8c9">
        <updating/>
        <source>doEdit() updating;
/*

Date		Who		Reason
24 October 2013	cnwer1	Initial creation PAR 31845
05 Dec 2024 navlc30 JIRA 33478 Match functionality in the thin client for Damage Recording Improvement

*/

vars
	tiSet : CM_ObjectSet;
begin
	if self.myTrackedItem &lt;&gt; null then				//05.12.2024 navlc30 #33478
		inheritMethod();
		create tiSet transient;						//16.12.2024 navlc30 #33478
		tiSet.add(self.myTrackedItem);
		app.myProxyManager.updateProxyEditions(tiSet);	
	else
		self.mode := self.Mode_Update;
		self.setControlsForAddEdit();
	endif;	

epilog
	delete tiSet;									//16.12.2024 navlc30 #33478
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="6fb440f3-720d-43c1-a1d9-368fc8295bde">
        <updating/>
        <source>doSave() updating;
/*

Date		Who		Reason
24 October 2013	cnwer1	Initial creation PAR 31845
05 Dec 2024 navlc30 JIRA 33478 Match functionality in the thin client for Damage Recording Improvement

*/

vars
	proxyPhoto	: CM_Photo;
	tiSet : ObjectSet;
	
begin
	if self.myTrackedItem &lt;&gt; null then				//05.12.2024 navlc30 #33478
		inheritMethod();
		create tiSet transient;						//16.12.2024 navlc30 #33478
		tiSet.add(self.myTrackedItem);
		app.myProxyManager.updateProxyEditions(tiSet);	
	else 
		if self.mode = self.Mode_Add then
			proxyPhoto := self.createProxyPhoto(self.photo.picture, self.thumbnails.last.Picture.picture); //04/02/2011 cnwdz2 26872	
			self.allPhotos.add(proxyPhoto);
		elseif self.mode = self.Mode_Update then
		
			proxyPhoto := self.getSelectedPhoto();
			if proxyPhoto &lt;&gt; null then
				proxyPhoto.setDescription(self.tblInput1.getValueByName(ETRow_Description).asStringJMT());
			endif;
		endif;
		
		self.mode := self.Mode_View;		
		self.setControlsForView();
	endif;
	
epilog
	delete tiSet;									//16.12.2024 navlc30 #33478
end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectedPhoto" id="e3147793-3132-40fd-9acf-92ecae79f90d">
        <source>getSelectedPhoto() : CM_Photo;
/*

Date		Who		Reason 
24 October 2013	cnwer1	Initial creation PAR 31845

*/

vars
	index : Integer;
begin
	index := self.getCurrentSelectedPhotoIndex();
	if index &lt; 1 then
		return null;
	endif;
	return  self.allPhotos[index].CM_Photo;
epilog

end;</source>
        <ReturnType type="CM_Photo"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="87cda823-43ec-4e9a-8495-02dee50fcd8e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 November 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	//self.translateCaption(Xlat_0017261, locale);
end;</source>
    </JadeMethod>
</GUIClass>
