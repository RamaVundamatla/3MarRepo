    <JadeMethod name="isMatchedToDoTemplate" id="1bd5f01b-5936-42c3-8be3-d27de01438b3">
        <source>isMatchedToDoTemplate(template: CM_ToDoTemplate): Boolean protected;
/*
 ------------------------------------------------------------------------
Created:			12 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	rtnValue	: Boolean;
	isoGrp 		: CM_ISOTypeGroup;
	iso			: CM_ISOType;
	mtGrade		: CM_MTGrade;
begin
	if (not inheritMethod(template)) then
		// Does not match operator, contents and status
		return false;
	endif;

	//Check types and groups as one entity: ie an item may match an
	//iso type or an iso group: it doesn't have to match both
	if template.isoGroups.isEmpty
	and template.isoTypes.isEmpty
	and template.availabilityGrades.isEmpty then
		return true;
	endif;
	
	// Check availability grade first
	mtGrade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];
	if mtGrade &lt;&gt; null and template.availabilityGrades.isNotEmpty then
		if (not template.availabilityGrades.includes(mtGrade))  then
			// Does not match Availability Grade - no need to check further		
			return false;
		else
			// Matches but need to continue further and check it matches ISO Group or ISO Type
			rtnValue := true;
		endif;
	else
		rtnValue := true;			
	endif;		
		
	// Check ISO group	
	isoGrp := app.myRoot.allISOTypeGroups[self.isoTypeGroup];
	if isoGrp &lt;&gt; null and template.isoGroups.isNotEmpty then
		if (not template.isoGroups.includes(isoGrp)) then
			// Does not match ISO Group but continue to see if it matches ISO Type
			rtnValue := false;
		else // AKB2005JULY this was left out
			// Matches but need to continue further and check it matches ISO Type
			rtnValue := true;
		endif;
	endif;
	
	// Could match ISO Group or ISO Type
	
	// Check ISO Type
	iso := app.myRoot.allISOTypes[self.isoType];	
	if iso &lt;&gt; null and (not template.isoTypes.isEmpty) then
		if (not template.isoTypes.includes(iso)) then
			// Does not match ISO Type		
			rtnValue := false;
		else // AKB2005JULY this was left out
			// Matches 
			rtnValue := true;
		endif;
	endif;

	return rtnValue;
end;</source>
        <access>protected</access>
        <Parameter name="template" type="CM_ToDoTemplate"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNonStandardHeight" id="cafffdca-6100-4bdd-b8f1-5e76b6dad3d5">
        <source>isNonStandardHeight() : Boolean;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpISOType	: CM_ISOType;
	tmpRoot		: CM_Root;
		
begin

	// do this to avoid hitting app.myRoot as called from serverExecution method
	if self.myTerminal &lt;&gt; null then
		tmpRoot := self.myTerminal.myRoot;
	elseif self.myVoyage &lt;&gt; null then
		tmpRoot := self.myVoyage.myTerminal.myRoot;
	else
		tmpRoot := app.myRoot;
	endif;
	tmpISOType := tmpRoot.allISOTypes[self.isoType];
	if tmpISOType = null then
		return false;
	else
		return tmpISOType.isNonStandardHeight;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
