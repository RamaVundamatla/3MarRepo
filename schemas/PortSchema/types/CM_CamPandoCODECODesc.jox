    <JadeMethod name="getMessageType" id="2dfd8ae9-0ce9-4b49-90c8-ec0ba6c6f86b">
        <source>getMessageType(_transaction: CM_TITransaction;
				_messageTypeArray: IntegerArray input;
				_camProtocol: CM_CamProtocol;
				_camAgent : CM_CamControllerAgent input);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
vars
	taSource, taTarget : CM_TerminalArea;
	ti : CM_Container;
	contentsStatus : Integer;
	exclusionReason : String;
begin
	//_messageTypeArray.clear;
	ti := _transaction.myTrackedItem.CM_Container;
	contentsStatus := _transaction.contentsStatus;
	//epr TFS 2387 deleted a whole lot of code that was done in the inherit method 
	// inherit method does lots of logging now
	
	if _transaction.isCamsRoadReceiveType() then
		if (contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isDepotActivity()) or
		   (not contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isTerminalActivity()) then
			_messageTypeArray.add(CODECO_GATEIN);
		else
			if _camProtocol.isDepotActivity then
				exclusionReason := "Depot Activity only include empty cargo";
			elseif _camProtocol.isTerminalActivity then
				exclusionReason := "Terminal Activity only include non empty cargo";
			else
				exclusionReason := "Cam protocol not set for depot or terminal activity";
			endif;
		endif;
	elseif _transaction.isCamsRailReceiveType() then
		if (contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isDepotActivity()) or
		   (not contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isTerminalActivity()) then
			_messageTypeArray.add(CODECO_GATEIN);
		else
			if _camProtocol.isDepotActivity then
				exclusionReason := "Depot Activity only include empty cargo";
			elseif _camProtocol.isTerminalActivity then
				exclusionReason := "Terminal Activity only include non empty cargo";
			else
				exclusionReason := "Cam protocol not set for depot or terminal activity";
			endif;
		endif;
	elseif _transaction.isCamsShipReceiveType() then //CCMS 1670 Apr 2008 cnwrs1
		if ti.isEmpty() then
			if _camProtocol.isTerminalActivity() and 
			   not _camProtocol.isDepotActivity() then
				if _camProtocol.special_MSCForNZPOE and //MSC special MT processing for POE
				   ti.isEmpty() and
				   ti.consignee = "POW" and
				   ti.availabilityGrade &gt; 0 then
					return; //do nothing						
				endif;
				_messageTypeArray.add(CODECO_GATEOUT);
			endif;
			if _camProtocol.isDepotActivity() and 
			   not _camProtocol.isTerminalActivity() then
				_messageTypeArray.add(CODECO_GATEIN);
			endif;
			if _messageTypeArray.isEmpty then
				exclusionReason:= "Cam Protocol has either both or neither of depot or terminal activity set";
			endif;
		else
			exclusionReason :="Not empty";	
		endif;
	elseif _transaction.isCamsShipReleaseType() then //CCMS 1670 Apr 2008 cnwrs1
		ti := _transaction.myTrackedItem.CM_Container;
		if ti.isEmpty() then
			if _camProtocol.isDepotActivity() and 
			   not _camProtocol.isTerminalActivity() then
				_messageTypeArray.add(CODECO_GATEOUT);
			endif;
			if _camProtocol.isTerminalActivity() and 
			   not _camProtocol.isDepotActivity() then
				_messageTypeArray.add(CODECO_GATEIN);
			endif;
			if _messageTypeArray.isEmpty then
				exclusionReason:= "Cam Protocol has either both or neither of depot or terminal activity set";
			endif;
		else
			exclusionReason :="Not empty";	
		endif;
	else
		inheritMethod(_transaction, _messageTypeArray, _camProtocol,_camAgent);//22/04/2009 cnwdz2 ccms1735
	endif;
	
	if _messageTypeArray.isEmpty then
		//epr TFS 2387 19/7/16
		//log reasons why this transaction has no messages
		if _camAgent &lt;&gt; null and  exclusionReason &lt;&gt; null then
			_camAgent.logReasonForExclusion(_transaction,exclusionReason);
		endif;
	endif;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_BN" id="f2e796ec-9ec4-4e5f-a3e0-a7fb6ee09cd6">
        <source>makeMessageRFF_BN(_camProtocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer;  _ti :CM_TrackedItem; _transaction :CM_TITransaction)protected;
/*
Purpose:	Refactored code	

Date		Who		Reason
19 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	bookingNumber, contentsStatus :String;
begin
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _activity, _transaction.type);	
	
	// only include the booking reference number when the container comes in
	if _activity = CODECO_GATEIN then
		if _camProtocol.isUseCarrierRefForBooking then
			bookingNumber := _ti.getCarrierReference;
		else
			if _ti.bookingReference.trimRight &lt;&gt; null then
				bookingNumber := _ti.bookingReference.trimRight;
			elseif _ti.deliveryRelease.trimRight &lt;&gt; null then
				bookingNumber := _ti.deliveryRelease.trimRight;
			endif;
		endif;
		
		if bookingNumber = "" then //***********************************************************
			if _transaction.isCamsMoveType() and //CCMS1651 &amp; 1670 MSC terminal/depot changes
			   _ti.isKindOf(CM_Container) and
			   contentsStatus = '4' then  //MT
				if _ti.CM_Container.availabilityGrade = 1 then
					bookingNumber := 'Fonterra';
				endif;
			endif;
		endif; //*******************************************************
		
		if bookingNumber &lt;&gt; null then
			self.makeRFFSegment (_camProtocol, _group, "BN",  bookingNumber );	// par 27460 17/05/2011 cnwcs5 					
		endif;
	endif;
    // only include the delivery release number when the container exits
	if _activity = CODECO_GATEOUT then
		if _camProtocol.isUseCarrierRefForBooking then
			bookingNumber := _ti.getCarrierReference;
		else
			if _ti.deliveryRelease.trimRight &lt;&gt; null then
				bookingNumber := _ti.deliveryRelease.trimRight;
			elseif _ti.bookingReference.trimRight &lt;&gt; null then
				bookingNumber := _ti.bookingReference.trimRight;
			endif;
		endif;
		
		if bookingNumber = null then //***********************************************************
			if _transaction.isCamsMoveType() and //CCMS1651 &amp; 1670 MSC terminal/depot changes
			   _ti.isKindOf(CM_Container) and
			   contentsStatus = '4' then  //MT
				if _ti.CM_Container.availabilityGrade = 1 then
					bookingNumber := 'Fonterra';
				endif;
			endif;
		endif; //*******************************************************
		
		if bookingNumber &lt;&gt; null then
			if _camProtocol.special_MSCForNZPOE and //MSC special MT processing for POE
			   _transaction.contentsStatus = TI_CONTENTS_STATUS_EMPTY then //CCMS1491 Jan 2007 cnwrs1
				self.makeRFFSegment (_camProtocol, _group, "BN",  bookingNumber );	// par 27460 17/05/2011 cnwcs5 			
			else
				self.makeRFFSegment (_camProtocol, _group, "BN",  bookingNumber );	// par 27460 17/05/2011 cnwcs5 			
			endif;
		endif;
	endif;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="26b37323-bd24-4afe-b086-86b31fa329b2">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
// 18/05/2011	cnwcs5	ccms sct 2058/par27460 - user defined special characters
// 05 Jan 2012	cnwrs1	Par 28933 - do not produce SEL message for MT containers
// 30/05/2016	cnwdap1	TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 15/07/2016   cnwma1  TFS #2376 POL - CODECO NAD lines in wrong segment and doubling up on information
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
vars
    fCode 			: String;
    code 			: String;
	imExStatus		: String;
	ti 				: CM_TrackedItem;
	contentsStatus	: String;
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
begin
// PANDO
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);	
	// cnwrl1 19/10/2010 PAR 25867 - start of replacement coding
	if contentsStatus = "5" then
		// set up the potential group of GID, TMP, SGP and DGS records.
		if ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE or ti.allTIHazards.isNotEmpty then
			// GID+ - Goods Item Details
			self.makeGIDSegment (_camProtocol, _camMessage.group3, 1);	// par 27460 09/05/2011 cnwcs5 
			// TMP Segment
			self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");	// par 27460 17/05/2011 cnwcs5 	
			// Split Goods Placement
			self.makeSGPSegment (_camProtocol, _camMessage.group3, ti.id.trimRight, null);		// par 27460 09/05/2011 cnwcs5 	
			// ie Dangerous Goods
			if not _camProtocol.dgsDetailsInGroup14  then							//JIRA-20814
				self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
			endif;																	//JIRA-20814	
		endif;
	endif;
	// EQD segment
    if contentsStatus = "5" then
    	imExStatus := imExStatusToString(ti); //full
    else
    	imExStatus := ""; //empty
    endif;
	//self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, ti.CM_Container.isoType, '102', '5', null, imExStatus, contentsStatus); // par 27460 17/05/2011 cnwcs5 	 //23/08/2017 cnwma1 TFS #5834
	isoCode := ti.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, imExStatus, contentsStatus); //23/08/2017 cnwma1 TFS #5834
    _camMessage.eqdCount := _camMessage.eqdCount + 1;

	// RFF+BN
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);	// par 27460 cnwcs5

	// RFF+CN - special18 field
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs

	// if creating extra messages for pack/unpack add 1 minute to the second message
	self.makeDTMSegment(_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754

	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;

    if _camMessage.activity = CODECO_GATEIN then
		// LOC segments
		self.makeMessageLOC_GATEIN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5

    elseif _camMessage.activity = CODECO_GATEOUT then
		// LOC segments
		self.makeMessageLOC_GATEOUT (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5		
    endif;
	
	// LOC+165
	code := _terminal.getConfig(PortDestCode).String;
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);
	self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '160', '20', null, null, null);	// par 27460 09/05/2011 cnwcs5 
	
	// LOC+164
	code := ti.destinationPort.trimRight;
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);
	self.makeLOCSegment (_camProtocol, _camMessage.group5, '164', fCode, '160', '20', null, null, null);	// par 27460 09/05/2011 cnwcs5 
	
	// MEA+ segment
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,null); //epr par 37551 TFS 1429 16/2/16
	
	// DIM+ segements
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group5, ti);		// par 27460 17/05/2011 cnwcs5
	
	//the SEL for the seal number
	self.makeMessageSealsData( ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);	//15 Sep 2010	NDL	Par 25608

	// FTX+AAI
	self.makeMessageFTX_DeliveryReason (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs5	
	if includeVGM then
		self.makeMessageFTX_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;

	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment (_camProtocol, _camMessage.group5, 'RG', ti);	// par 27460 09/05/2011 cnwcs5
	
	// TDT+1
	self.makeMessageTDT1Segment (_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti);	// par 27460 cnwcs5
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);									// 15/07/2016 cnwma1  TFS #2376
	endif;																								// TFS #2061
	
	// ie Dangerous Goods													//JIRA-20814
	if _camProtocol.dgsDetailsInGroup14  then								//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group5);	//JIRA-20814
	endif;																	//JIRA-20814
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="a09f5ba9-7b74-4ddc-b901-eb727c0f5601">
        <updating/>
        <source>processTransaction(_transaction:CM_TITransaction; _camProtocol:CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile:CM_CamFile input) updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
// 12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 17 Dec 2012 	cnwcs5	CCMS SFW 1294 / par 30855
// 04 Feb 2013	cnwcs5	CCMS SFW 1294 /par 30855
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
vars
	camMessage 			: CM_CamMessage;
	messageTypeArray 	: IntegerArray;
	messageType 		: Integer;
	xlVoyageId 			: String;
	contentsStatus 		: String;
	arrayPos3, arrayPos4, arrayPos5 : Integer;
	theTI 				: CM_TrackedItem;
	vesselName 			: String; //par18987 cnwrs1 Mar 2007
	firstTime			: Boolean;					// cnwrl1 05/08/2010 PAR 21961
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);
	
	theTI := _transaction.myTrackedItem;
	
	create messageTypeArray transient;

	//get the translated voyage Code
	xlVoyageId := self.getVoyageCode(_transaction, _camProtocol, vesselName); //par18987 cnwrs1 Mar 2009
	
	// Only need to clear the camTask tiMessages for each new transaction not each messageType.
	firstTime	:= true;					// cnwrl1 05/08/2010 PAR 21961
	
	self.getMessageType(_transaction, messageTypeArray, _camProtocol, _camAgent);
	
	if messageTypeArray.size &gt; 0 then
		foreach messageType in messageTypeArray do
			camMessage := self.getCamMessage(_camFile, xlVoyageId, vesselName, messageType, _camProtocol.singleContainerPerBGM); //ccms1747 cnwrs1 aug 2008 
			
			if camMessage &lt;&gt; null then
				contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, camMessage.activity, _transaction.type);
				
				arrayPos3 := camMessage.group3.size;
				arrayPos4 := camMessage.group4.size;
				arrayPos5 := camMessage.group5.size;
				
				camMessage.camVoyage.voyageOid := _transaction.myTrackedItem.myVoyage;
				
				camMessage.dateTime := self.transDateTime(_transaction, camMessage.activity, _camProtocol);
				
				self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyageId, _camProtocol.terminal, null);

				camMessage.setupCAMSInfoDetails(_camProtocol, arrayPos3, arrayPos4, arrayPos5, _transaction);	//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs

				firstTime	:= false;		// cnwrl1 05/08/2010 PAR 21961
			else
				if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
				endif;
			endif;
		endforeach;

	endif;
epilog
	if messageTypeArray &lt;&gt; null then
		delete messageTypeArray;
	endif;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="special_MSCForNZPOE" id="097868c5-dca1-47d5-98fe-d0a21b073685">
        <source>special_MSCForNZPOE(): Boolean;
//
// CCMS1491 Jan 2007 cnwrs1
//
vars

begin
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="transDateTime" id="eb0b775c-b5b6-4b49-a665-53fccf22abe7">
        <source>transDateTime(_transaction : CM_TITransaction; _activity : Integer; _camProtocol : CM_CamProtocol) : TimeStamp;
//this exists so the protocols that want to create more than one message per transaction can
// manipulate the datetime for subsequant messages.
vars
	dateTime: TimeStamp;
	
begin
	dateTime := _transaction.dateTime;
	
	if _transaction.isCamsShipReceiveType() then
		if _activity = CODECO_GATEOUT then
			//tranTime.setTime(tranTime.hour, tranTime.minute+1, tranTime.second, 0);// add minute to pack SNT time so it does not match pack RCV time
			//dateTime.setTime(tranTime);
			dateTime.addMinutes(1);		// 12/03/2013 cnwar2 #31281
		elseif _activity = CODECO_GATEIN then
			//tranTime.setTime(tranTime.hour, tranTime.minute+2, tranTime.second, 0);// add minute to pack SNT time so it does not match pack RCV time
			//dateTime.setTime(tranTime);
			dateTime.addMinutes(2);		// 12/03/2013 cnwar2 #31281
		endif;
	endif;
	if _transaction.isCamsShipReleaseType() then //ccms 1670 Apr 2008
		if _activity = CODECO_GATEIN then
			//tranTime.setTime(tranTime.hour, tranTime.minute+1, tranTime.second, 0);// add minute to pack SNT time so it does not match pack RCV time
			//dateTime.setTime(tranTime);
			dateTime.addMinutes(1);		// 12/03/2013 cnwar2 #31281
		elseif _activity = CODECO_GATEOUT then
			//tranTime.setTime(tranTime.hour, tranTime.minute+2, tranTime.second, 0);// add minute to pack SNT time so it does not match pack RCV time
			//dateTime.setTime(tranTime);
			dateTime.addMinutes(2);		// 12/03/2013 cnwar2 #31281
		endif;
	endif;
	
	//08 Sep 2015	NDL	Par 36876
	if _camProtocol &lt;&gt; null then
		if self.useDelayMinutes and _camProtocol.delayMinutes &gt; 0 then
			dateTime := dateTime.addMinutes( _camProtocol.delayMinutes );
		endif;
	endif;
	
	return dateTime;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</Class>
