        <source>trxCreateVoyage(_proxyVoyage:CM_Voyage input; _newVoyage:CM_Voyage output; _realVessel : CM_Vessel input;
			_realVoyGlobal : CM_VoyageGlobal; _createSPS : Boolean;	_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
