<Class name="CM_VesselLayoutGraphic" id="cf381938-8b8e-4abd-a7e2-c57ed7874d2c">
    <superclass name="CM_Graphic"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vessel"/>
    <ExplicitInverseRef name="myVessel" id="a7dfd875-5372-441f-9324-f9f1319624e2">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_Vessel"/>
        <access>readonly</access>
        <Inverse name="CM_Vessel::myLayoutGraphic"/>
    </ExplicitInverseRef>
    <JadeMethod name="copyToVoyage" id="a4301dd2-2973-4013-befa-250971a1dca7">
        <source>copyToVoyage() : CM_VoyageLayoutGraphic;
/*
------------------------------------------------------------------------
Created:			16 January 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	voyLG : CM_VoyageLayoutGraphic;
begin
	if self.locked then
		app.raiseCMException1(Err_VesselIsLocked, self.myVessel.name, null, null);
		return null;
	endif;
	create voyLG;
	self.pointsPolygon.copy(voyLG.pointsPolygon);
	voyLG.lineColour := self.lineColour;
	voyLG.fillColour := self.fillColour;
end;</source>
        <ReturnType type="CM_VoyageLayoutGraphic"/>
    </JadeMethod>
</Class>
