        <updating/>
        <source>extLengthMetres(set: Boolean; _value: Integer io) mapping, updating;
// --------------------------------------------------------------------------------
// Created:		19 February 2009 by cnwdad1
//
// Purpose:		When setting: Sets the non-virtual External Length of the reciever
//				(which is stored in centimetres) by converting from the specified value.
//
//				When retrieving: Returns the External Length of the receiver in metres,
//				by converting from the non virtual External Length which is stored
//				in centimetres.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if set then
		self.extLength	:=	(_value / 100);
	else
		_value			:=	(self.extLength * 100).rounded();
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
