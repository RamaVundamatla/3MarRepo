    <JadeMethod name="mainExtraShowRow" id="22d04431-5d12-4e9c-b326-39e36c705e6c">
        <source>mainExtraShowRow(pTblMain, pTblExtra : CM_EntryTable input; pName : String);
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	: Integer;
	
begin

	row := pTblMain.getRow(pName);
	if row &gt; 0 then
		pTblMain.showRow(row);
	else
		pTblExtra.showRowByName(pName, true);
	endif;
	
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="mainExtraShowRowWithValue" id="36faf315-7e58-438b-863b-1154bf9d2212">
        <source>mainExtraShowRowWithValue(pTblMain, pTblExtra : CM_EntryTable io; pName : String; pValue : Any; pDisabled : Boolean);
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row			: Integer;
	tmpTable	: CM_EntryTable;

begin

	row := pTblMain.getRow(pName);
	if row &gt; 0 then
		tmpTable := pTblMain;
	else
		row := pTblExtra.getRow(pName);
		if row &gt; 0 then
			tmpTable := pTblExtra;
		endif;
	endif;

	if tmpTable &lt;&gt; null then
		tmpTable.showRow(row);
		tmpTable.setValue(row, pValue);
		if pDisabled then
			tmpTable.disableRow(row);
		else
			tmpTable.enableRow(row);
		endif;
	endif;
	
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="io"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pDisabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mainExtraSplitterRatio" id="d99cbaf2-cd8b-45f5-8891-409549479f86">
        <source>mainExtraSplitterRatio(pMainTbl, pExtraTbl : CM_BaseTable input; pSplitter : CMUI_SplitContainer input);
// ---------------------------------------------------------------------------
// Created:     26 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpHeight,
	ratio			: Integer;

begin

	if pSplitter.height = 0 then
		return;
	endif;

	// calculate the number of rows in the main Table and determine the splitter percentage
	if pExtraTbl.visible then
		tmpHeight := pMainTbl.getMaxHeight();
	
		if tmpHeight &gt; pSplitter.height then
			// calculate height of extra table and
			tmpHeight := pExtraTbl.getMaxHeight();
			ratio := (tmpHeight / pSplitter.height * 100).Integer + 2;
			if ratio &gt; 20 then
				// set ratio to max of 20% of total height for the extra table
				ratio := 20;
			endif;
			// reverse ratio as it applies to the main table.
			ratio := 100 - ratio;
		else
			ratio := (tmpHeight / pSplitter.height * 100).Integer + 2;
			if ratio &gt; 90 then
				ratio := 90;
			endif;
		endif;
	else
		ratio := 100;
	endif;

	pSplitter.setLeftToRightRatioAndResize(ratio);

end;</source>
        <Parameter name="pMainTbl" type="CM_BaseTable" usage="input"/>
        <Parameter name="pExtraTbl" type="CM_BaseTable" usage="input"/>
        <Parameter name="pSplitter" type="CMUI_SplitContainer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mainExtraSyncColWidths" id="04108ba9-415c-4d40-aec4-6073f64bcaf9">
        <source>mainExtraSyncColWidths(pTblMain, pTblExtra : CM_EntryTable io);
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	colWidth	: Integer;
	
begin

	// Synchronize the heading column widths
	colWidth := pTblMain.accessColumn(CM_EntryTable.ColumnHeading).width;
	colWidth := colWidth.max(pTblExtra.accessColumn(CM_EntryTable.ColumnHeading).width);
	
	pTblMain.accessColumn(CM_EntryTable.ColumnHeading).width := colWidth;
	pTblMain.setValueColumnWidth();
	
	pTblExtra.accessColumn(CM_EntryTable.ColumnHeading).width := colWidth;
	pTblExtra.setValueColumnWidth();
	
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="measurementTableLostFocus" id="2e8229d3-4cf0-4fe6-9798-e6b0b230fbb6">
        <source>measurementTableLostFocus(	_tbl : CM_EntryTable input; 
							_saveRowHeight : Real io; 
							_measTbl : CMUI_MeasurementTable	);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
11/03/2014	cnwdap1	PAR #33603 Correct measurement handling for different locales
					Can't just type-cast as Decimal otherwise we lose locale-sensitive info
*/
vars
	tbl 		: CM_EntryTable;
	measurement : CMUI_MeasurementTable;
	row		 	: Integer;
	str			: String;
	value		: Decimal [23,10];
	valueStr	: String;
	conValue	: String;
	entRow		: EntTableRowTransient;
	measureType	: CM_MeasurementType;
	overflowed : Boolean;
begin
	tbl := _tbl;
	measurement := _measTbl;
	if tbl = null then
		return;
	endif;
	row := tbl.getRowByControlName(measurement.name);
	on Exception do app.handlePrecisionError(exception,overflowed); //epr tfs 3888 21/4/17
	if row &gt; tbl.fixedRows and row &lt;= tbl.rows then
		entRow := tbl.accessRow(row).itemObject.EntTableRowTransient;
		tbl.accessRow(row).height := _saveRowHeight.Integer;
		measurement.height := _saveRowHeight.Integer;
		_saveRowHeight := 0;
		tbl.scrollBars := Table.ScrollBars_Both;
		
		measureType := app.myRoot.allMeasurementTypesByShortName[measurement.accessCell(1,3).text];
		//value := measurement.accessCell(1,1).text.Decimal;					// PAR #33603
		value := measurement.accessCell(1,1).text.asDecimalJMT;					// PAR #33603
		if overflowed then
			value:=null;
		endif;
		valueStr := measurement.accessCell(1,1).text;
		if measureType &lt;&gt; null then
			str := " " &amp; measurement.accessCell(1,3).text;
			if value &lt;&gt; null then
				conValue := measureType.formatValue(value);
				if conValue.length &gt; valueStr.length then
					conValue := conValue[1:valueStr.length];
				endif;
				str := conValue &amp; str;
			endif;
		endif;
		
		tbl.setValue(row, str);
		tbl.doChangedComparison(row);
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_saveRowHeight" type="Real" usage="io"/>
        <Parameter name="_measTbl" type="CMUI_MeasurementTable"/>
    </JadeMethod>
    <JadeMethod name="menuSetGradeBuild" id="27a5e295-8103-4e89-85b0-cdc38ce322f5">
        <source>menuSetGradeBuild(_mnuSetGrade, _mnuSubSetGrade : MenuItem input; _ti : CM_TrackedItem);
/*

Date		Who		Reason
19 August 2013	cnwer1	Initial creation PAR 32261

*/

vars
idx			: Integer;
	tmpMenu,
	mnuChild	: MenuItem;
	grade,
	checkedGrade: CM_MTGrade;
	code		: CM_MTGradeCode;
	canDisplay,
	isVisible,
	checked		: Boolean;
	description	: String;
	oidStr	: String;
begin

	// Build up menu of Grades 
	//_mnuSetGrade.visible := _ti.canSetAvailabilityGrade;
	
	if not _ti.canSetAvailabilityGrade then
		_mnuSetGrade.visible:=false;
		return;
	endif;
	
	_mnuSetGrade.enabled := true;
	_mnuSetGrade.caption := app.getErrorString(Grade_SET);
	_mnuSetGrade.userObject := _ti;
	_mnuSubSetGrade.visible := true;
	_mnuSubSetGrade.caption := app.getErrorString(Grades_NOooo);
	tmpMenu :=_mnuSubSetGrade;

	//epr par 34695 8/8/14
	if _mnuSetGrade.form.isKindOf(CM_ContainerEnqForm) then
		idx:=_mnuSetGrade.form.CM_ContainerEnqForm.getClonedMenuCount;
	else
		idx:=_mnuSetGrade.form.menuItemCount; //epr par 33531
	endif;
	// CCMS 1235
	foreach grade in app.myRoot.allAvailabilityGrades do
		if _ti.getAvailabilityGrade = grade.code then
			checkedGrade := grade;
			checked := true;
		else
			checked := false;
		endif;

		if checked or app.myRoot.allAvailableAvailabilityGrades.includes(grade) then
			idx := idx + 1;
			/*mnuChild := _mnuSetGrade.getMenuItem(idx); // check if the menu is already cloned
			if mnuChild &lt;&gt; null then
				delete mnuChild;
			endif;*/
			_mnuSubSetGrade.visible := false;			
			grade.getTranslationForOperator(checkedGrade,_ti.myOperator, null, code, canDisplay);
			isVisible:=true;
			if code &lt;&gt; null then
				description := code.description;
			elseif canDisplay then
				description := grade.description;
			else
				isVisible:=false;
			endif;	
			
			_mnuSetGrade.visible:=true;
			//epr par 33531
			oidStr:=tmpMenu.description;
			if oidStr &lt;&gt; null then
				mnuChild := oidStr.asOid.MenuItem;
			endif;
			
			if mnuChild = null then
				mnuChild := _mnuSetGrade.loadSubMenu(idx); // Clone menu
				tmpMenu.description	:= mnuChild.getOidString;
			endif;
			//epr par 33325 20/1/14 looks like jade made a change so that if the caption started with - then its a seperator
			//otago have grades like -20 etc. Changed so if description starts with - add leading space so doesn't display as seperator
			if description[1:1] = "-" then
				description:=" " &amp; description;
			endif;
			mnuChild.caption := description;
			mnuChild.visible := isVisible;
			mnuChild.enabled := true;
			mnuChild.helpKeyword := description;
			mnuChild.checked := checked;
			mnuChild.userObject := grade;
			tmpMenu:=mnuChild;
			mnuChild:=null;
		endif;
	endforeach; 
	
	//epr par 34695 8/8/14
	if _mnuSetGrade.form.isKindOf(CM_ContainerEnqForm) then
		_mnuSetGrade.form.CM_ContainerEnqForm.setClonedMenuCount(idx);
	endif;

epilog

end;</source>
        <Parameter name="_mnuSetGrade" type="MenuItem" usage="input"/>
        <Parameter name="_mnuSubSetGrade" type="MenuItem" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="menuSetGradeClick" id="5a960e7c-9e2f-4d7b-a13f-2f713d9d6ccd">
        <source>menuSetGradeClick(_cargoMenu, _gradeMenu : MenuItem input);
/*

Date		Who		Reason
20 August 2013	cnwer1	Initial creation PAR

*/

vars
	cargo	: CM_TrackedItem;
	result		: Boolean;
	tmpGrade	: CM_MTGrade;
	
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	if _gradeMenu = _cargoMenu then
		return;
	endif;
	tmpGrade := _gradeMenu.userObject.CM_MTGrade;
	if tmpGrade = null then
		return;
	endif;
	
	cargo := _cargoMenu.userObject.CM_TrackedItem;
	if cargo = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'current object is null');
		return;
	endif;
	
	if tmpGrade.code = cargo.getAvailabilityGrade then
		// already set.
		return;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIAvailabilityGrade(cargo, tmpGrade.code, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Grade_SET), app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

	_gradeMenu.checked := not _gradeMenu.checked;

epilog


end;</source>
        <Parameter name="_cargoMenu" type="MenuItem" usage="input"/>
        <Parameter name="_gradeMenu" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="multiSelectEntityFields" id="396063af-0b10-4e1d-8de7-93a1ac7b45dc">
        <source>multiSelectEntityFields(_mulSelect: CMUI_MultiSelectGroupBox input; _entTableDefName: String; _includedFieldHeaders: StringArray);
//----------------------------------------------------------------
//	Created:	23 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	strDict,
	inclDict		: CM_StringDict;
	entTableRow		: EntTableRow;
	strObjStr		: CM_StringWithString;
	strObj			: CM_String;
	str				: String;
	entTableDef		: EntTableDef;
	tmpArray		: StringArray;
begin
	tmpArray := _includedFieldHeaders;
	
	entTableDef := app.myController.getEntTableDef(_entTableDefName);

	create strDict transient;
	create inclDict transient;

	foreach entTableRow in entTableDef.allEntTableRows do
		create strObjStr transient;
		str := entTableRow.getHeading(null,null,app.myCurrentLocale);
		if tmpArray.includes(str) then
			strObjStr.set(tmpArray.indexOf(str).String.padLeadingZeros(2), str);
			inclDict.add(strObjStr);
		else
			strObjStr.set("~", str);
		endif;
		
		strDict.add(strObjStr);
	endforeach;
	
	_mulSelect.setAvailable(strDict, true);
	_mulSelect.setSelected(inclDict);
	
epilog
	delete inclDict;
	delete strDict;	
end;</source>
        <Parameter name="_mulSelect" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_entTableDefName" type="String"/>
        <Parameter name="_includedFieldHeaders" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="multiSelectExceptions" id="c2544cb2-49a9-456a-87ed-738b36e4e89e">
        <source>multiSelectExceptions(_mulSelect : CMUI_MultiSelectGroupBox input);
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	iter			: Iterator;
	dict			: XLAT_TranslationByCatAndNumber;
	errorObj		: XLAT_Translation;
	idKey,
	idx				: Integer;
	categoryKey,
	tmpStr		: String;
	tmpLocale		: CM_Locale;
	lstBox			: CM_MultiSelectListBox;
begin
	app.myPassport.myActivityCapture.startCaptureDebugMisc('Loading exceptions');
	
	_mulSelect.clearSelected();

	tmpLocale := app.myRoot.allLocales['0000'];
	
	dict := tmpLocale.allXlatTranslationsByCatNumber;
	iter := dict.createIterator();
	lstBox := _mulSelect.myAvailableListBox;
	lstBox.clear();
	
	dict.startKeyGeq(XLAT_Exceptions, null, iter);
	while iter.next(errorObj) do
		dict.getIteratorKeys(categoryKey, idKey, iter);
		if categoryKey &lt;&gt; XLAT_Exceptions then
			break;
		endif;
		tmpStr := self.displayEntryErrorWarning(errorObj);
		lstBox.itemObject[lstBox.addItem(tmpStr)] := errorObj;
		
	endwhile;
epilog
	delete iter;

	app.myPassport.myActivityCapture.stopCaptureDebugMisc();
end;
	
	



</source>
        <Parameter name="_mulSelect" type="CMUI_MultiSelectGroupBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="myCurrentGateScanRecord" id="a8d0e8ed-9615-4b52-a558-dd96a9056454">
        <methodInvocation>mapping</methodInvocation>
        <source>myCurrentGateScanRecord(_set : Boolean; _value : CM_GenericGateScanRecord io) mapping;
/*

Purpose:			If the current record is changed, then update the remaining cargo items list

Parameters:			

Return Value:		

Date			Who		Reason
28 July 2022	navmd1	Initial creation TFS 52777 Generic API

*/

vars

begin
	if _set then
		if self.myCurrentGateScanRecord &lt;&gt; _value then
			self.allRemainingGSRCargo.clear();
			if _value &lt;&gt; null then
				_value.allCargoItems.copy(self.allRemainingGSRCargo);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="CM_GenericGateScanRecord" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pickerForReceivalRequestInfo" id="ceb5934e-4f0e-4ad4-9d67-2dc889a383ab">
        <source>pickerForReceivalRequestInfo(pObjects : ObjectArray; _selectedObject : CM_Object output):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 October 2011	cnwndl1	Initial creation	Par 28285
\15 Mar 2017	NDL	TFS 3758 - Make use EntTables

*/

vars

	pickWin : CMUI_Picker;
	obj : Object;
	recReqInfo : CM_ReceivalRequestInfo;
	allObjects : CM_ObjectArrayActual;
	
begin

	create allObjects transient;
	
	foreach obj in pObjects do
		recReqInfo := obj.CM_ReceivalRequestInfo;
		allObjects.add(recReqInfo);
	endforeach;

	create pickWin transient;
	
	pickWin.setListTableUsingEntTable( allObjects, ETDef_RecRequestInfo, 700, true );
	
	if pickWin.showModal() = MsgBox_Return_OK then
		// get selected object
		_selectedObject := pickWin.selectedObject.CM_Object;
		return MsgBox_Return_OK;
	else 
		_selectedObject := null;
		return MsgBox_Return_Cancel;
	endif;

epilog

	delete allObjects;

end;</source>
        <Parameter name="pObjects" type="ObjectArray"/>
        <Parameter name="_selectedObject" type="CM_Object" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pickerWindowForBOLDetails" id="055f9126-f75a-40cc-9ac7-5577130ba0dd">
        <source>pickerWindowForBOLDetails(pObjects : ObjectArray) : CM_BOLDtl;
// 04/02/2010	cnwjre1	copied from pickerWindowForBookingRefs
//15 Mar 2017	NDL	TFS 3758 - Make use EntTables
vars
	pickWin	: CMUI_Picker;
	obj	: Object;
	bol	: CM_BOL;
	bolDetail : CM_BOLDtl;
	allObjects : CM_ObjectArrayActual;
	sortedItems : DynaDictionary;
	itemIterator : Iterator;

begin
	//Create Dictionary so the items come in timestamp order
	create sortedItems transient;
	sortedItems.setMembership( CM_BOLDtl);
	sortedItems.addMemberKey( "myBOL.dateTime", true, false );
	sortedItems.endKeys( true );

	// Add the objects to the dictionary to sort them
	foreach obj in pObjects do
		bol := obj.CM_BOL;
		foreach bolDetail in bol.allBOLDtls do
			sortedItems.add(bolDetail);
		endforeach;
	endforeach;
	
	//Produce the text for the picker table
	create allObjects transient;
	
	itemIterator := sortedItems.createIterator();
	while itemIterator.next(bolDetail) do
		allObjects.add(bolDetail);
	endwhile;
	
	create pickWin transient;
	pickWin.setListTableUsingEntTable( allObjects, ETDef_BolDetails, 0, true );
	if pickWin.showModal() = MsgBox_Return_OK then
		// get selected object
		bolDetail := pickWin.selectedObject.CM_BOLDtl;
	else 
		bolDetail := null;
	endif;
	return bolDetail;
	
epilog
	
	delete sortedItems;
	delete allObjects;
	delete itemIterator;
end;</source>
        <Parameter name="pObjects" type="ObjectArray"/>
        <ReturnType type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="pickerWindowForBookingRefs" id="9aa05888-2117-4438-bd19-fcc053aa383b">
        <source>pickerWindowForBookingRefs(pObjects : ObjectArray) : CM_BookingRefItem;
/*
This method was substatially reorganised for PAR 18704 by cnwgb1 on 8.1.09
The changes added voyage and create Time stamp to the picker columns and 
sorted the results in reverse date order
--------------------------------------------------------------------------
Changed On	By			Reason
----------	--------	--------------------------------------------------
26/06/2014	cnwdap1		PAR #34066 Disable rows that are fully allocated
15/03/2017	NDL			TFS 3758 - Make use EntTables
05/11/2020	jlgdap1		TFS 50136 POL Prenote Picker Disables Wrong Rows
*/
vars
	pickWin	: CMUI_Picker;
	obj, brItem		: Object;
	bookRef	: CM_BookingRef;
	bookRefItem : CM_BookingRefItem;
	rows : Integer;
	allObjects : CM_ObjectArrayActual;
	sortedItems : DynaDictionary;
	itemIterator : Iterator;
	
	//disabledRows : IntegerArray;				// PAR #34066	// TFS 50136
	disabledRows : ObjectArray;					// PAR #34066	// TFS 50136
begin
	//Create Dictionary so the items come in timestamp order
	create sortedItems transient;
	sortedItems.setMembership( CM_BookingRefItem);
	sortedItems.addMemberKey("creationTS", true, false );
	sortedItems.endKeys( true );
	
	create disabledRows transient;					// PAR #34066

	// Add the objects to the dictionary to sort them
	foreach obj in pObjects do
		bookRef := obj.CM_BookingRef;
		foreach brItem in bookRef.allBookingRefItems do
			bookRefItem := brItem.CM_BookingRefItem;
			sortedItems.add(bookRefItem);
		endforeach;
	endforeach;
	
	//Produce the text for the picker table
	create allObjects transient;
	
	itemIterator := sortedItems.createIterator();
	while itemIterator.next(bookRefItem) do
		bookRef := bookRefItem.myBookingReference;
		if bookRef.status &lt;&gt; BOOKING_REF_ACTIVE then			// PAR #34066
			continue;											// PAR #34066
		endif;													// PAR #34066
		
		allObjects.add(bookRefItem);

		if self.myTerminal.getConfig(BookingRefRequired).Integer = BookingRequired_Strict then	// PAR #34066
			if bookRefItem.isCompleteWithPrenotes() then
				//disabledRows.add(rows+1+1);				// TFS 50136
				disabledRows.add(bookRefItem);				// TFS 50136
			endif;																			// PAR #34066
		endif;	
		rows := rows + 1;// PAR #34066
	endwhile;
	
	create pickWin transient;
	pickWin.setListTableUsingEntTable(allObjects, ETDef_BookingRefs, 0, true);
	if self.myTerminal.getConfig(BookingRefRequired).Integer = BookingRequired_Strict then			// PAR #34066
		pickWin.setDisabledItems(disabledRows);														// PAR #34066
	endif;																							// PAR #34066
	if pickWin.showModal() = MsgBox_Return_OK then
		// get selected object
		bookRefItem := pickWin.selectedObject.CM_BookingRefItem;
	else 
		bookRefItem := null;
	endif;
	return bookRefItem;
	
epilog
	
	delete sortedItems;
	delete allObjects;
	delete itemIterator;
	delete disabledRows;
end;</source>
        <Parameter name="pObjects" type="ObjectArray"/>
        <ReturnType type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="pickerWindowForBreakBulk" id="2030cea9-6470-4a46-981f-5ea0ff16259f">
        <source>pickerWindowForBreakBulk(_tis : CM_TISet; _terminal: CM_Terminal; _allowMultiSelect : Boolean; _selectedTi : CM_TrackedItem output; _callingForm : CM_BaseForm) : Integer;
// Picker for a list of break bulk items
//15 Mar 2017	NDL	TFS 3758 - Make use EntTables
vars
	pickWin		: CMUI_Picker;
	ti          : CM_TrackedItem;
	allTIs 		: CM_ObjectArrayActual;
begin
	
	create allTIs transient;
		
	foreach ti in _tis do
		allTIs.add(ti);
	endforeach;
	
	create pickWin transient;
	pickWin.setTerminal(_terminal);  // 31610
	
	pickWin.setListTableUsingEntTable( allTIs, ETDef_BreakBulk, 700, true );
	pickWin.allowMultiSelect := _allowMultiSelect;		// 29287 Apr 2012 multi-select pre-notes in road gate
	pickWin.allowCreateJobsBtn := app.myCurrentUserCan( self.myTerminal, PmGteMultiJob );	//22 Dec 2016	NDL	TFS 3134
	pickWin.setMyCallingForm( _callingForm );	//22 Dec 2016	NDL	TFS 3134
	
	if pickWin.showModal() = MsgBox_Return_OK then
		_selectedTi := pickWin.selectedObject.CM_TrackedItem;
		return MsgBox_Return_OK;
	else 
		_selectedTi := null;
		return MsgBox_Return_Cancel;
	endif;
	
epilog
	
	delete allTIs;
end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allowMultiSelect" type="Boolean"/>
        <Parameter name="_selectedTi" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_callingForm" type="CM_BaseForm"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pickerWindowForGenericApi" id="4c9f201e-8392-4ddd-809d-0593677579c3">
        <source>pickerWindowForGenericApi(_scanRecords : CM_GenericGateScanRecs; _selectedObject: CM_GenericGateScanRecord output) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 May 2022		navhl20	ChangeRequest 52777: EUP - INT - Generic API: record-scan- Web Service / Form Changes
16 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

vars
	pickWin 		: CMUI_Picker;
	allObjects 		: CM_ObjectArrayActual;
	gateScanRecord 	: CM_GenericGateScanRecord;
	choice 			: Integer;
begin
	create pickWin transient;
	create allObjects transient;
	
	if _scanRecords = null or _scanRecords.size = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, "No Scan Records sent to the picker, nothing to pick");
		return MsgBox_Return_Cancel;
	endif;
	
	foreach gateScanRecord in _scanRecords do
		allObjects.add(gateScanRecord);
	endforeach;
	
	pickWin.setIsGenericScanMode(true);
	pickWin.setListTableUsingEntTable( allObjects, ETDef_GateScanRecord, 600, true );
	pickWin.setTitle(app.getErrorString(Gate_Scan_Records));
	
	choice := pickWin.showModal();
	if choice = MsgBox_Return_OK then
		_selectedObject := pickWin.selectedObject.CM_GenericGateScanRecord;
	endif;
	
	return choice;
	
epilog
	delete allObjects;
	delete pickWin;
end;</source>
        <Parameter name="_scanRecords" type="CM_GenericGateScanRecs"/>
        <Parameter name="_selectedObject" type="CM_GenericGateScanRecord" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pickerWindowForObject" id="3ebd79a3-69b1-4af8-a9a0-2395fa6e2147">
        <source>pickerWindowForObject(	pObjects : ObjectArray; 
						_allowMultiSelect : Boolean; 
						_selectedObject : Object output; 
						_callingForm : CM_BaseForm;
						_forWorkOrder : Boolean	) : Integer;
// -----------------------------------------------------------------------------
// Created:		11 August 2009 by cnwjo3
//
// Purpose:		Moved here from GTE_FlexiGateForm for par 23674
//
// Changed on	By		Reason
// ----------	-------	------------------------------------------------------
// 25/08/2010	cnwjo3	PAR #25538 Changed details for ReserveTI
// 25/06/2014	cnwdap1	PAR #34066 Include prenote count if "Booking Required" setting is "Strict"
//	15 Mar 2017	NDL	TFS 3758 - Make use EntTables
// 22/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders - new parameter to hide "Create Jobs" button for work orders
// 05/11/2020	jlgdap1	TFS 50136 POL Prenote Picker Disables Wrong Rows
// ---------------------------------------------------------------------------

vars

	pickWin		: CMUI_Picker;
	obj	: Object;
	bookRef		: CM_BookingRef;
	bookRefItem : CM_BookingRefItem;
	bulkRelease : CM_BulkRelease;
	ti          : CM_TrackedItem;
	reserveDtl	: CM_ReserveDetail;
	rows 		: Integer;
	allObjects 	: CM_ObjectArrayActual;
	//disabledRows : IntegerArray;				// TFS 50136
	disabledRows : ObjectArray;					// TFS 50136
	reserveTI : CM_ReserveTI;
	etDefName : String;
	bolDtl : CM_BOLDtl; //06 Oct 2020	NDL	TFS 49189
	
begin
	
	create allObjects transient;
	create disabledRows transient;
	
	rows := 0;
	foreach obj in pObjects do
		
		if obj.isKindOf(CM_BOLDtl)then	//06 Oct 2020	NDL	TFS 49189
			bolDtl := obj.CM_BOLDtl;
			
			allObjects.add(bolDtl);
			rows := rows + 1;
			
		elseif obj.isKindOf(CM_BookingRefItem)then
			bookRefItem := obj.CM_BookingRefItem;
			bookRef := bookRefItem.myBookingReference;
			
			if bookRef.status &lt;&gt; BOOKING_REF_ACTIVE then
				continue;
			endif;
			
			if self.myTerminal.getConfig(BookingRefRequired).Integer = BookingRequired_Strict then	// PAR #34066
				if bookRefItem.isCompleteWithPrenotes() then
					//disabledRows.add(rows+1+1);					// TFS 50136
					disabledRows.add(bookRefItem);					// TFS 50136
				endif;
			endif;																					// PAR #34066
	
			allObjects.add(bookRefItem);
			rows := rows + 1;
			
		elseif obj.isKindOf(CM_ReserveTI)then
			reserveDtl	:= obj.CM_ReserveDetail;
			
			allObjects.add(reserveDtl);
			rows := rows + 1;
			
		elseif obj.isKindOf(CM_ReserveDetail)then
			reserveDtl	:= obj.CM_ReserveDetail;
			allObjects.add(reserveDtl);
			rows := rows + 1;
			
		elseif obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_TrackedItem;
			allObjects.add(ti);
			rows := rows + 1;
			
		elseif obj.isKindOf(CM_BulkRelease)then
			bulkRelease := obj.CM_BulkRelease;	
			allObjects.add(bulkRelease);
			rows := rows + 1;
		endif;
		
	endforeach;
	
	create pickWin transient;
	if not allObjects.isEmpty and allObjects.first.isKindOf(CM_BulkRelease) then	//30 May 2011	NDL	Par 27573
		etDefName := ETDef_BulkRel;
	else
		etDefName := ETDef_GenPicker;
	endif;

	pickWin.setListTableUsingEntTable( allObjects, etDefName, 700, true);
	pickWin.allowMultiSelect := _allowMultiSelect;		// 29287 Apr 2012 multi-select pre-notes in road gate
	//pickWin.allowCreateJobsBtn := app.myCurrentUserCan( self.myTerminal, PmGteMultiJob );	//22 Dec 2016	NDL	TFS 3134	// TFS 38560
	pickWin.allowCreateJobsBtn := app.myCurrentUserCan( self.myTerminal, PmGteMultiJob ) and not _forWorkOrder;				// TFS 38560
	pickWin.setMyCallingForm( _callingForm );	//22 Dec 2016	NDL	TFS 3134
	
	if disabledRows.size &gt; 0 then
		pickWin.setDisabledItems(disabledRows);
	endif;
		
	if pickWin.showModal() = MsgBox_Return_OK then
		// get selected object
		_selectedObject := pickWin.selectedObject.Object;
		return MsgBox_Return_OK;
	else 
		_selectedObject := null;
		return MsgBox_Return_Cancel;
	endif;
	
epilog
	
	delete allObjects;
	delete disabledRows;
end;</source>
        <Parameter name="pObjects" type="ObjectArray"/>
        <Parameter name="_allowMultiSelect" type="Boolean"/>
        <Parameter name="_selectedObject" type="Object" usage="output"/>
        <Parameter name="_callingForm" type="CM_BaseForm"/>
        <Parameter name="_forWorkOrder" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pickerWindowForReserveDetails" id="9acce17b-e193-4e12-aa23-727aed8732ac">
        <source>pickerWindowForReserveDetails(_arrObjects : ObjectArray) : CM_ReserveDetail protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/06/2009	cnwjk3	CCMS 1035
18/10/2016	cnwdap1	TFS 2831 don't display complete or archived bulk releases
15 Mar 2017	NDL	TFS 3758 - Make use EntTables
*/

vars
	pickWin			: CMUI_Picker;
	sa				: HugeStringArray;
	obj				: Object;
	returnReserve	: CM_ReserveDetail;
	reserve			: CM_ReserveDetail;
	objects : CM_ObjectArrayActual;

begin

	create objects transient;
	foreach obj in _arrObjects where obj.isKindOf(CM_ReserveDetail) do
		reserve := obj.CM_ReserveDetail;
		objects.add( reserve );
	endforeach;
		
	create pickWin transient;
	
	pickWin.setListTableUsingEntTable( objects, ETDef_ResDetails,600, true);
	if pickWin.showModal() = MsgBox_Return_OK then
		returnReserve := pickWin.selectedObject.CM_ReserveDetail;
	endif;
	
	return returnReserve;
epilog
	delete objects;
end;</source>
        <access>protected</access>
        <Parameter name="_arrObjects" type="ObjectArray"/>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="pickerWindowForTrackedItem" id="c746babb-0f98-4682-a303-3e0c2daf6acf">
        <source>pickerWindowForTrackedItem(pObjects : ObjectArray; 
							_terminal: CM_Terminal; 
							_consignee: CM_ConsigneeConsignor; 
							_voyage: CM_Voyage;
							_imex 	: Integer;
							_allowMultiSelect : Boolean;
							_selectedObject : Object output):Integer;
// Picker for a list of tracked items
// 18 Mar 2013 epr par 31299 
vars
	pickWin		: CMUI_TrackedItemPicker;
	tiPickWin	: CMUI_TrackedItemPicker;
	sa			: HugeStringArray;
	obj	: Object;
	ti          : CM_TrackedItem;
	rows 		: Integer;
	allObjects 	: ObjectArray;
	operatorCode : String;	
	description : String;
	disabledRows : IntegerArray;
	bol: String;
	voyage: String;
	consignee: String;
begin
	create sa transient;
	create allObjects transient;
	create disabledRows transient;
	
	rows := 0;
	foreach obj in pObjects do
	
		if obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_TrackedItem;
			voyage := null;
			if ti.myVoyage &lt;&gt; null then
				voyage := ti.myVoyage.code;
			endif;
			consignee := null;
			if ti.myConsignee &lt;&gt; null then
				consignee := ti.myConsignee.code;
			endif;			
			sa.add(ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; voyage &amp; Tab &amp; consignee &amp; Tab &amp; ti.operatorCode);	
			
			allObjects.add(ti);
			rows := rows + 1;
		endif;
	endforeach;
	
	if allObjects.size = 0 then

		create tiPickWin transient;
		tiPickWin.width := 700;
		tiPickWin.setConsignee(_consignee);
		tiPickWin.setVoyage(_voyage);
		tiPickWin.setImex(_imex);
		tiPickWin.setTerminal(_terminal);
		tiPickWin.allowMultiSelect := _allowMultiSelect;		// 29287 Apr 2012 multi-select pre-notes in road gate
		if tiPickWin.showModal() = MsgBox_Return_OK then
			_selectedObject := tiPickWin.selectedObject.Object;
			return MsgBox_Return_OK;
		else 
			_selectedObject := null;
			return MsgBox_Return_Cancel;
		endif;
	else
		create pickWin transient;
		pickWin.setTerminal(_terminal);  // 31610
		pickWin.hideFind := true;     // 34041
		pickWin.width := 700;
		pickWin.setHeadings(	5, 
								app.getErrorString(Id) &amp; Tab
								&amp; app.getErrorString(CM_Cargo_Type) &amp; Tab
								&amp; app.getErrorString(Voyage) &amp; Tab
								&amp; app.getErrorString(Consignee) &amp; Tab
								&amp; app.getErrorString(Operator)
								);					
		pickWin.setListTable(rows ,allObjects, sa);
		pickWin.allowMultiSelect := _allowMultiSelect;		// 29287 Apr 2012 multi-select pre-notes in road gate
		
		if pickWin.showModal() = MsgBox_Return_OK then
			_selectedObject := pickWin.selectedObject.Object;
			return MsgBox_Return_OK;
		else 
			_selectedObject := null;
			return MsgBox_Return_Cancel;
		endif;
	endif;
	
epilog
	delete sa;
	delete allObjects;
	delete disabledRows;
end;</source>
        <Parameter name="pObjects" type="ObjectArray"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_allowMultiSelect" type="Boolean"/>
        <Parameter name="_selectedObject" type="Object" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pickerWindowForTrailers" id="c40be30a-915c-4485-a881-fc475e2d046f">
        <source>pickerWindowForTrailers(_tis : CM_TISet input;_selectedTi : CM_TrackedItem output): Integer;
/*

Date		Who		Reason
24 September 2013	cnwer1	Initial creation PAR
15 Mar 2017	NDL	TFS 3758 - Make use EntTables

*/

vars
	pickWin		: CMUI_Picker;
	ti          : CM_TrackedItem;
	allTIs 		: CM_ObjectArrayActual;
	terminal 	: CM_Terminal;
begin
	
	create allTIs transient;
	
	if _tis = null or _tis.size = 0 then
		return MsgBox_Return_Cancel;
	endif;
	terminal:=_tis.first.myTerminal;
		
	foreach ti in _tis do
		if not ti.isKindOf(CM_TILC) then
			continue;
		endif;
		allTIs.add(ti);
	endforeach;
	
	create pickWin transient;
	pickWin.setTerminal(terminal);  // 31610
	pickWin.setListTableUsingEntTable( allTIs, ETDef_Trailers, 700, true );
	pickWin.allowMultiSelect := false;		
	
	if pickWin.showModal() = MsgBox_Return_OK then
		_selectedTi := pickWin.selectedObject.CM_TrackedItem;
		return MsgBox_Return_OK;
	else 
		_selectedTi := null;
		return MsgBox_Return_Cancel;
	endif;
	
epilog
	
	delete allTIs;

end;</source>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_selectedTi" type="CM_TrackedItem" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateScanData" id="faf7d173-c1fb-4f5d-84ba-53f7365218f8">
        <updating/>
        <source>populateScanData(	_isFromNotification,
					_isFromGateLaneChange	: Boolean;
					_detailsChangedVehicle	: Boolean io;
					_txtRegoCtrl,
					_txtDriverCodeCtrl,
					_txtDriverNameCtrl,
					_txtChassisCtrl,
					_txtCargoIdCtrl			: CMUI_TextBox input;					// Might be worth creating a CMIF for these ... especially if there are any more
					_cmbRFIDCtrl,
					_cmbCarrierCtrl			: CMUI_ComboBox input;
					_txtWeightCtrl			: CMUI_MeasurementTable input;
					_newScanRecord			: CM_GenericGateScanRecord input
					) updating;
/*

Purpose:			Pre-populate fields on the form if we have any data from a weigh bridge or scan device

Parameters:			

Return Value:		

Date			Who		Reason
31 March 2022	navhl20	Initial creation  TFS 52777
12 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

vars
	gateScanRecord,
	selectedScanRecord,
	currentScanRecord		: CM_GenericGateScanRecord;
	showModal				: Integer;
	weighBridge				: CM_WeighBridgeObj;
	deviceId,
	scanDeviceId,
	wBdeviceid				: String;
	gate					: CM_Gate;
	gateArea				: CM_GateArea;
	gateLane				: CM_GateAreaLaneController;
	gateAreaUsage			: CM_GateAreaUsage;
	allRecordsForDevice		: CM_GenericGateScanRecs;
	overwriteValues			: Boolean;
begin
	// If we have no generic weightbridges or scan readers for our currently selected gate/lane, then nothing for us to do
	if self.allAssociatedDevices.size = 0 then
		return;
	endif;
	
	
	if not _isFromNotification or (_isFromNotification and _isFromGateLaneChange) then
		// If we're being called from setup/load (and not a note) then if there aren't any unassigned records, we can bail early
		if self.myTerminal.allGenericScanRecsUnassigned.size = 0 then
			return;
		else
			// Add a fudge for setupForm - set both _isFromNotification and _isFromGateLaneGate to true
			// Normally this can't be possible
			overwriteValues := _isFromNotification and _isFromGateLaneChange;
			
			create allRecordsForDevice transient;
			
			foreach gateScanRecord in self.myTerminal.allGenericScanRecsUnassigned discreteLock do
				if self.allAssociatedDevices[gateScanRecord.deviceId] &lt;&gt; null then
					allRecordsForDevice.add(gateScanRecord);
				endif;
			endforeach;
			
			// Not a note for us, then we're done here
			if allRecordsForDevice.size = 0 then
				return;
			endif;
			
			if allRecordsForDevice.size = 1 then
				self.myCurrentGateScanRecord := allRecordsForDevice.first;
			else
				showModal := self.pickerWindowForGenericApi( allRecordsForDevice, selectedScanRecord );
				if showModal = MsgBox_Return_Cancel then
					return; 
				elseif showModal = MB_DISCARD_ALL then
					app.myTrxDA.trxDeleteGateScanRecords(allRecordsForDevice, app.myPassport);
				endif;
				
				self.myCurrentGateScanRecord := selectedScanRecord;
			endif;
			
			// If the user didn't decide to terf all the records, then use them to pre-populate the fields
			if self.myCurrentGateScanRecord &lt;&gt; null then
				self.populateScanDataFields(overwriteValues, _isFromGateLaneChange, _detailsChangedVehicle, _txtRegoCtrl, _txtDriverCodeCtrl, _txtDriverNameCtrl,
					_txtChassisCtrl, _txtCargoIdCtrl, _cmbRFIDCtrl, _cmbCarrierCtrl, _txtWeightCtrl);
			endif;
		endif;
	
	else // _isFromNotification = true
		if _newScanRecord = null then
			app.raiseUnexpectedProgramError(method.name, class.name, "Passed in ScanRecord is null, unable to process");
			return;
		endif;
	
		// Make sure the note is for one of our devices, if not, bail
		if self.allAssociatedDevices[_newScanRecord.deviceId] = null then
			return;
		endif;
		
		if _newScanRecord = self.myCurrentGateScanRecord then
			// Must be an update to an existing record, so just go ahead and overwrite any fields
			overwriteValues := true;
			self.populateScanDataFields(overwriteValues, _isFromGateLaneChange, _detailsChangedVehicle, _txtRegoCtrl, _txtDriverCodeCtrl, _txtDriverNameCtrl,
				_txtChassisCtrl, _txtCargoIdCtrl, _cmbRFIDCtrl, _cmbCarrierCtrl, _txtWeightCtrl);
			_newScanRecord.allCargoItems.copyNoDupsNoTransaction(self.allRemainingGSRCargo);	// This doesn't really handle the situation where we've already *used* one of these
		else
			// Must be a new record
			if self.myCurrentGateScanRecord = null then
				self.myCurrentGateScanRecord := _newScanRecord;
				self.populateScanDataFields(overwriteValues, _isFromGateLaneChange, _detailsChangedVehicle, _txtRegoCtrl, _txtDriverCodeCtrl, _txtDriverNameCtrl,
					_txtChassisCtrl, _txtCargoIdCtrl, _cmbRFIDCtrl, _cmbCarrierCtrl, _txtWeightCtrl);
			endif;
		endif;
	endif;
	
epilog
	delete allRecordsForDevice;
end;</source>
        <Parameter name="_isFromNotification" type="Boolean"/>
        <Parameter name="_isFromGateLaneChange" type="Boolean"/>
        <Parameter name="_detailsChangedVehicle" type="Boolean" usage="io"/>
        <Parameter name="_txtRegoCtrl" type="CMUI_TextBox" usage="input"/>
        <Parameter name="_txtDriverCodeCtrl" type="CMUI_TextBox" usage="input"/>
        <Parameter name="_txtDriverNameCtrl" type="CMUI_TextBox" usage="input"/>
        <Parameter name="_txtChassisCtrl" type="CMUI_TextBox" usage="input"/>
        <Parameter name="_txtCargoIdCtrl" type="CMUI_TextBox" usage="input"/>
        <Parameter name="_cmbRFIDCtrl" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_cmbCarrierCtrl" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_txtWeightCtrl" type="CMUI_MeasurementTable" usage="input"/>
        <Parameter name="_newScanRecord" type="CM_GenericGateScanRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateScanDataFields" id="5ec2629e-4756-4928-8376-a9d21afe7716">
        <updating/>
        <source>populateScanDataFields(	_overwriteValues, _gateLaneChanged : Boolean;
						_detailsChangedVehicle	: Boolean io;
						_txtRegoCtrl,
						_txtDriverCodeCtrl,
						_txtDriverNameCtrl,
						_txtChassisCtrl,
						_txtCargoIdCtrl			: CMUI_TextBox input;
						_cmbRFIDCtrl,
						_cmbCarrierCtrl			: CMUI_ComboBox input;
						_tblWeightCtrl			: CMUI_MeasurementTable input
						) protected, updating;
/*

Purpose:			Takes the current scan record and puts any data in their equivalent fields.

					Go through each control and equivalent scan record data
					if either are null, then skip
					otherwise if the control is not populated, then populate it with the record data.
					
					If the control is already populated, and we're changing lanes (aka, devices)
					then ask the user if they wish to use the new record or not
					
					Special case: If overwriteValues is set to true, then always just blat everything

Parameters:			

Return Value:		

Date			Who		Reason
14 July 2022	navmd1	Initial creation TFS 52777 Tidy up/review code
27 Oct 2025 	navhl20 Bug MTN-36207: MTN - Generic API for Bulk Gate IN/OUT
*/

vars
	scanRecord		: CM_GenericGateScanRecord;
	msgBoxVal		: Integer;
	overwriteValues,
	questionAsked	: Boolean;
	txtControl		: CMUI_TextBox;
	cmbControl		: CMUI_ComboBox;
	tblControl		: CMUI_MeasurementTable;
	carrier			: CM_Carrier;
	rfidTag			: CM_RFIDTag;
	idx,
	numEntries		: Integer;
	cargoId			: String;
begin
	scanRecord := self.myCurrentGateScanRecord;
	if scanRecord = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, "ScanRecord is null, nothing to populate");
		return;
	endif;

	overwriteValues := _overwriteValues;
	
	// Rego
	txtControl := _txtRegoCtrl;
	if txtControl &lt;&gt; null and txtControl.enabled and scanRecord.licenseNumber &lt;&gt; null then
		if overwriteValues or txtControl.text = null then
			txtControl.text := scanRecord.licenseNumber;
			txtControl.lostFocus(txtControl);
			_detailsChangedVehicle := true;
		else
			if txtControl.text.toUpper() &lt;&gt; scanRecord.licenseNumber.toUpper() and _gateLaneChanged and not questionAsked then
				msgBoxVal := app.msgBox(app.getErrorString(EXISTING_GATE_SCAN_REC), app.getErrorString(Overwrite_existing_values), MsgBox_Yes_No);
				questionAsked := true;
				if msgBoxVal = MsgBox_Return_Yes then
					overwriteValues := true;
					txtControl.text := scanRecord.licenseNumber;
					txtControl.lostFocus(txtControl);
					_detailsChangedVehicle := true;
				else
					self.myCurrentGateScanRecord := null;	// Then don't actually associate the record with the VVR
				endif;
			endif;
		endif;
	endif;
	
	// RFID
	cmbControl := _cmbRFIDCtrl;
	if cmbControl &lt;&gt; null and cmbControl.enabled and scanRecord.batNumber &lt;&gt; null then
		if overwriteValues or cmbControl.listObject = null then
			// This could be RFID or BAT, so just try a string search - rather than an object one
			cmbControl.listIndex := cmbControl.findString(1, scanRecord.batNumber);
			cmbControl.lostFocus(cmbControl);
		else
			if cmbControl.text.toUpper() &lt;&gt; scanRecord.batNumber.toUpper() and _gateLaneChanged and not questionAsked then
				msgBoxVal := app.msgBox(app.getErrorString(EXISTING_GATE_SCAN_REC), app.getErrorString(Overwrite_existing_values), MsgBox_Yes_No);
				questionAsked := true;
				if msgBoxVal = MsgBox_Return_Yes then
					overwriteValues := true;
					cmbControl.listIndex := cmbControl.findString(1, scanRecord.batNumber);
					cmbControl.lostFocus(cmbControl);
				else
					self.myCurrentGateScanRecord := null;	// Then don't actually associate the record with the VVR
				endif;
			endif;
		endif;
	endif;
	
	// Try and set the driver
	// Prefer Code &gt; Name
	
	// Driver Code
	txtControl := _txtDriverCodeCtrl;
	if txtControl &lt;&gt; null and txtControl.enabled and scanRecord.driverCode &lt;&gt; null then
		if overwriteValues or txtControl.text = null then
			txtControl.text := scanRecord.driverCode;
			txtControl.lostFocus(txtControl);
			_detailsChangedVehicle := true;
		else
			if txtControl.text.toUpper() &lt;&gt; scanRecord.driverCode.toUpper() and _gateLaneChanged and not questionAsked then
				msgBoxVal := app.msgBox(app.getErrorString(EXISTING_GATE_SCAN_REC), app.getErrorString(Overwrite_existing_values), MsgBox_Yes_No);
				questionAsked := true;
				if msgBoxVal = MsgBox_Return_Yes then
					overwriteValues := true;
					txtControl.text := scanRecord.driverCode;
					txtControl.lostFocus(txtControl);
					_detailsChangedVehicle := true;
				else
					self.myCurrentGateScanRecord := null;	// Then don't actually associate the record with the VVR
				endif;
			endif;
		endif;
	endif;
	
	// Driver Name
	txtControl := _txtDriverNameCtrl;
	if txtControl &lt;&gt; null and txtControl.enabled and scanRecord.driverName &lt;&gt; null then
		if overwriteValues or txtControl.text = null then
			txtControl.text := scanRecord.driverName;
			txtControl.lostFocus(txtControl);
			_detailsChangedVehicle := true;
		else
			if txtControl.text.toUpper() &lt;&gt; scanRecord.driverName.toUpper() and _gateLaneChanged and not questionAsked then
				msgBoxVal := app.msgBox(app.getErrorString(EXISTING_GATE_SCAN_REC), app.getErrorString(Overwrite_existing_values), MsgBox_Yes_No);
				questionAsked := true;
				if msgBoxVal = MsgBox_Return_Yes then
					overwriteValues := true;
					txtControl.text := scanRecord.driverName;
					txtControl.lostFocus(txtControl);
					_detailsChangedVehicle := true;
				else
					self.myCurrentGateScanRecord := null;	// Then don't actually associate the record with the VVR
				endif;
			endif;
		endif;
	endif;
		
	// Carrier
	cmbControl := _cmbCarrierCtrl;
	if cmbControl &lt;&gt; null and cmbControl.enabled and scanRecord.carrierCode &lt;&gt; null then
		if overwriteValues or cmbControl.listObject = null then
			numEntries := cmbControl.listCount;
			foreach idx in 1 to numEntries do
				carrier := cmbControl.itemObject[idx].CM_Carrier;
				if carrier.code = scanRecord.carrierCode then
					cmbControl.setIndexFromObject(carrier);
					_detailsChangedVehicle := true;
					cmbControl.lostFocus(cmbControl);
					break;
				endif;
			endforeach;
		else
			carrier := cmbControl.listObject.CM_Carrier;
			if carrier.code &lt;&gt; scanRecord.carrierCode.toUpper() and _gateLaneChanged and not questionAsked then
				msgBoxVal := app.msgBox(app.getErrorString(EXISTING_GATE_SCAN_REC), app.getErrorString(Overwrite_existing_values), MsgBox_Yes_No);
				questionAsked := true;
				if msgBoxVal = MsgBox_Return_Yes then
					overwriteValues := true;
					numEntries := cmbControl.listCount;
					foreach idx in 1 to numEntries do
						carrier := cmbControl.itemObject[idx].CM_Carrier;
						if carrier.code = scanRecord.carrierCode then
							cmbControl.setIndexFromObject(carrier);
							_detailsChangedVehicle := true;
							cmbControl.lostFocus(cmbControl);
							break;
						endif;
					endforeach;
				else
					self.myCurrentGateScanRecord := null;	// Then don't actually associate the record with the VVR
				endif;
			endif;
		endif;
	endif;
	
	// Cargo / NewItem
	txtControl := _txtCargoIdCtrl;
	if txtControl &lt;&gt; null and txtControl.enabled and scanRecord.allCargoItems.size &gt; 0 then
		cargoId := scanRecord.allCargoItems.first.CM_CargoScanRecordData.id;
		if overwriteValues or txtControl.text = null then
			txtControl.text := cargoId;
			txtControl.lostFocus(txtControl);
		else
			if txtControl.text &lt;&gt; cargoId and _gateLaneChanged and not questionAsked then
				msgBoxVal := app.msgBox(app.getErrorString(EXISTING_GATE_SCAN_REC), app.getErrorString(Overwrite_existing_values), MsgBox_Yes_No);
				questionAsked := true;
				if msgBoxVal = MsgBox_Return_Yes then
					overwriteValues := true;
					txtControl.text := cargoId;
					txtControl.lostFocus(txtControl);
				else
					self.myCurrentGateScanRecord := null;	// Then don't actually associate the record with the VVR
				endif;
			endif;
		endif;
	endif;
	
	// Weight
	tblControl := _tblWeightCtrl;
	if tblControl &lt;&gt; null and tblControl.enabled and scanRecord.scaleWeight &lt;&gt; null then
		if overwriteValues or tblControl.getRawValue() = null then
			tblControl.setValueDefault(scanRecord.scaleWeight.String);
			tblControl.lostFocus(tblControl);
		else
			//if tblControl.getRawValue() &lt;&gt; scanRecord.scaleWeight.String and _gateLaneChanged and not questionAsked then	//27.10.2025 navhl20 #36207
			if tblControl.getRawValue() &lt;&gt; scanRecord.scaleWeight.String and not questionAsked then							//27.10.2025 navhl20 #36207
				msgBoxVal := app.msgBox(app.getErrorString(EXISTING_GATE_SCAN_REC), app.getErrorString(Overwrite_existing_values), MsgBox_Yes_No);
				questionAsked := true;
				if msgBoxVal = MsgBox_Return_Yes then
					overwriteValues := true;
					tblControl.setValueDefault(scanRecord.scaleWeight.String);
					tblControl.lostFocus(tblControl);
				else
					self.myCurrentGateScanRecord := null;	// Then don't actually associate the record with the VVR
				endif;
			endif;
		endif;
	endif;
	
	// Chassis
	txtControl := _txtChassisCtrl;
	if txtControl &lt;&gt; null and txtControl.enabled and scanRecord.chassisId &lt;&gt; null then
		if overwriteValues or txtControl.text = null then
			txtControl.text := scanRecord.chassisId;
			txtControl.lostFocus(txtControl);
		else
			if txtControl.text.toUpper() &lt;&gt; scanRecord.chassisId.toUpper() and _gateLaneChanged and not questionAsked then
				msgBoxVal := app.msgBox(app.getErrorString(EXISTING_GATE_SCAN_REC), app.getErrorString(Overwrite_existing_values), MsgBox_Yes_No);
				questionAsked := true;
				if msgBoxVal = MsgBox_Return_Yes then
					txtControl.text := scanRecord.chassisId;
					txtControl.lostFocus(txtControl);
				else
					self.myCurrentGateScanRecord := null;	// Then don't actually associate the record with the VVR
				endif;
			endif;
		endif;
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_overwriteValues" type="Boolean"/>
        <Parameter name="_gateLaneChanged" type="Boolean"/>
        <Parameter name="_detailsChangedVehicle" type="Boolean" usage="io"/>
        <Parameter name="_txtRegoCtrl" type="CMUI_TextBox" usage="input"/>
        <Parameter name="_txtDriverCodeCtrl" type="CMUI_TextBox" usage="input"/>
