    <JadeMethod name="setupForm" id="f385a70b-f387-4a3f-b717-9278128ebe98">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.caption := app.getErrorString( MT_cont_avail_enq );
	self.lblLastUpdated.caption := null;
	
	self.frmQuery.visible := true;
	
	inheritMethod();
	
	self.minimumHeight := 400;
	self.minimumWidth := 800;
//	self.splRatioSaved := self.splTables.leftToRightRatio;
	
	self.initTblData();
	
	if self.myUserWindow = null then
		self.doSetSearchDefaults();
	endif;

epilog

end;</source>
