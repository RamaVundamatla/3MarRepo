<PrimType name="TimeStamp">
    <JadeMethod name="yyyymmddhhmmss" id="8d52e50d-0739-4dff-9662-28eae55d407b">
        <source>yyyymmddhhmmss() : String;

/*****************************************************
	Written by	:	cnwpra1		25 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	return date.format('yyyyMMdd') &amp; time.format('hhmmss');
epilog

end;</source>
