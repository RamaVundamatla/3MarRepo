    <JadeMethod name="setForCreate" id="48e629cd-4738-443b-911c-b4d4b9b2e69a">
        <updating/>
        <source>setForCreate(_proxyRadioTelemetryDevice : CM_RadioTelemetryDevice) updating;
// 17/08/2016 cnwrh7	TFS	2501
vars

begin

	self.id 					:= _proxyRadioTelemetryDevice.id;
	self.myRadioTelemetry		:= _proxyRadioTelemetryDevice.myRadioTelemetry;
	self.model 					:= _proxyRadioTelemetryDevice.model;
	self.computerName			:= _proxyRadioTelemetryDevice.computerName.toUpper.trimBlanks;
	self.useSerialConnection	:= _proxyRadioTelemetryDevice.useSerialConnection;
	self.useLocalTCPConnection := _proxyRadioTelemetryDevice.useLocalTCPConnection;				// +17/08/2016 cnwrh7	TFS	2501
	self.cameraType				:= _proxyRadioTelemetryDevice.cameraType;	//07 Dec 2010	NDL	Par 23831
	self.myLabelPrinter 		:= _proxyRadioTelemetryDevice.myLabelPrinter;	// TFS 978 
	// Default password to true;
	self.isPasswordCompulsory	:= true;
end;</source>
        <Parameter name="_proxyRadioTelemetryDevice" type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a44d5430-788c-4fbf-941c-433c66e4c64b">
        <updating/>
        <source>setForUpdate(_proxyRTDevice : CM_RadioTelemetryDevice) updating;
// ---------------------------------------------------------------------------
// Created:		26 March 2003  by Jason Chapman  (cnwjc2)
// 17/08/2016 cnwrh7	TFS	2501
// ---------------------------------------------------------------------------

vars

begin

	self.id					:= _proxyRTDevice.id;
	self.myRadioTelemetry	:= _proxyRTDevice.myRadioTelemetry;
	self.model 				:= _proxyRTDevice.model;
	self.computerName		:= _proxyRTDevice.computerName.toUpper.trimBlanks;
	self.useSerialConnection:= _proxyRTDevice.useSerialConnection;
	self.useLocalTCPConnection := _proxyRTDevice.useLocalTCPConnection;			//+ 17/08/2016 cnwrh7	TFS	2501
	self.cameraType			:= _proxyRTDevice.cameraType; //07 Dec 2010	NDL	Par 23831
	self.myLabelPrinter 	:= _proxyRTDevice.myLabelPrinter;	// TFS 978 
	// Default password to true;
	self.isPasswordCompulsory	:= true;

end;</source>
        <Parameter name="_proxyRTDevice" type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="setLastMessageId" id="6fe4e986-bf77-45eb-91f9-361c23f9400d">
        <updating/>
        <source>setLastMessageId(_id : Integer) updating;

vars

	rollOverValue : Integer;

begin

	rollOverValue := self.getRolloverValue();
	// Par 7850 DVB 9/03/04
	 if (_id  = rollOverValue) then
	 	self.lastMessageId := 0;
	 elseif _id &gt; rollOverValue then
	 	// Will fall back to appropriate xml message.
	 	app.raiseCMException(Invalid_message, null,null);
	 	return;
	 else
	 	self.lastMessageId := _id;
	 endif;
end;</source>
        <Parameter name="_id" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyRTDevice" id="bebcdfe4-a081-4512-8610-02c9b11da762">
        <updating/>
        <source>setProxyRTDevice(	_id : String; 
					_radioTelemetry : CM_RadioTelemetry; 
					_model,
					_computerName	: String;
					_useSerialConnection : Boolean;
					_useLocalTCPConnection: Boolean;		// +17/08/2016 cnwrh7	TFS	2501
					_cameraType : Integer;	//07 Dec 2010	NDL	Par 23831
					_labelPrinter : CM_PrinterDef	// Mar 2016 cnwjre1 TFS 978
					) updating;

vars

begin
	
	self.id					:= _id;
	self.myRadioTelemetry	:= _radioTelemetry;
	self.model				:= _model;
	self.computerName		:= _computerName;
	self.useSerialConnection := _useSerialConnection;
	self.useLocalTCPConnection	:= _useLocalTCPConnection; 	// +17/08/2016 cnwrh7	TFS	2501
	self.cameraType 		:= _cameraType; //07 Dec 2010	NDL	Par 23831
	self.myLabelPrinter		:= _labelPrinter;
end;</source>
