    <JadeMethod name="sdlVoyageMovementMultiplePilots" id="645524b8-9cc3-4e96-bd56-ece9cd1d31c3">
        <source>sdlVoyageMovementMultiplePilots();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	voyageMovement : HMS_VoyageMovement;
	pilot: HMS_Pilot;
begin
	app.initialize();
	foreach voyageMovement in HMS_VoyageMovement.instances where voyageMovement.allPilots.size &gt; 1 do //voyageMovement.allMovementPilotDetails.size &gt; 1 do
		write "Voyage global " &amp; voyageMovement.myVoyageGlobal.code;
		foreach pilot in voyageMovement.allPilots do
			write "  Pilot " &amp; pilot.code;
			if voyageMovement.myPilotLaunch &lt;&gt; null then
				write "  Pilot launch " &amp; voyageMovement.myPilotLaunch.description;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sdlVygMvmntMyPilot" id="65ad077d-2200-47c5-8680-cde5958cace6">
        <source>sdlVygMvmntMyPilot();
/*

Purpose:			See if they are any

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2019	jlgsl4	TFS 44983 - Historic Pilot and Pilot Launch Details not in Pelindo Test

*/

vars
	voyageMovement : HMS_VoyageMovement;
	pilot : HMS_Pilot;
	myPilot : HMS_PilotLaunch;
	pilotDesc, pilotLaunchDesc : String;
begin
	app.initialize();
	foreach voyageMovement in HMS_VoyageMovement.instances where voyageMovement.allMovementPilotDetails.size = 0 do
		if voyageMovement.allPilots.size &gt; 0 then
			pilotDesc := voyageMovement.allPilots.first.description;
			if voyageMovement.myPilotLaunch &lt;&gt; null then
				pilotLaunchDesc := voyageMovement.myPilotLaunch.description;
			else
				pilotLaunchDesc := "not set";
			endif;
			write "Voyage " &amp; voyageMovement.getMyHMSVoyageData.myVoyage.code &amp; ", pilot " &amp; pilotDesc &amp; ", pilotLaunch " &amp; pilotLaunchDesc;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="925e13f2-7a1b-4e71-96fd-63c5933b987d">
        <source>sendEmail();
//
// cnwrs1 22 Feb 2013 - test sending an email
//
constants
	NORMAL_RECIPIENT = 0;  
	CARBON_COPY	= 1;
	BLIND_CARBON_COPY = 2;
	
vars
	oSmtp 	: AOSMTP_Mail;
	timeOut	: Integer;
	file,
	userName,
	password,
	tmpStr	: String;
	obj		: Object;
//	huge	: HugeStringArray;	
	auth	: Integer;
	thePort,
	theSSL	: Integer;
	theServer,
	theCharSet,
	err		: String;
	isSSL	: Boolean;
	messageRecipientsTest : String; //par 17833 cnwrs1 sept 2008
	systemTestMode : Boolean;
	tmpDir	: String;
	msg : String;
	
	fromAddress : String;
	toAddress : String;
	ccAddresses : String;
	bccAddresses : String;
	sendSubject : String;
	sendMessage : String;
//	allAttachedFiles : CM_FileDataStorageHdrSet;
begin
	app.initialize;
	//systemTestMode := app.myRoot.getConfig(BgpEmailTestMode).Boolean; // systemTestMode is deleted by CCMS 1163 PAR25611. new BgpEmailTestMode flag is introduced in Config System. 11/11/2010
	systemTestMode	:= false;	// Now, emailing mechanism is intact regardless BGP Email Mode: either test or standard. 11/11/2010

	fromAddress := "arjman@test.com";
	toAddress := "rsargent@jadeworld.com";
	sendSubject := "Testing email";
	create oSmtp transient;
	
	theServer := app.myRoot.getConfig(AutoSmtpServer).String.trimBlanks();
	oSmtp.serverAddr := theServer;
	msg := 'SMTP Server = ' &amp; theServer;
	app.writeLog(app.getMyUserCode&amp;' '&amp;app.name&amp;' '&amp;msg, LogINFO);		//25 Nov 2019	NDL	TFS 47053
	
	thePort := app.myRoot.getConfig(AutoSmtpServerPort).Integer;
	oSmtp.serverPort := thePort;
	msg := 'SMTP Port = ' &amp; thePort.String;
	app.writeLog(app.getMyUserCode&amp;' '&amp;app.name&amp;' '&amp;msg, LogINFO);		//25 Nov 2019	NDL	TFS 47053
	
	/* This application utilizes a licensed copy of ADS Objects. ADS
	Objects is copyrighted and owned exclusively by ADMINSYSTEM SOFTWARE
	LIMITED. All rights reserved. Use of the objects outside of the
	context of this application is a violation of federal copyright laws
	and international treaty provisions */
	
	// oSmtp.registerKey := "AM-XS1088813180-00998-0FAD79BC40F009177DCE61A34C4DF1AC";
	// PAR 22506
	app.emailArchitectSetLicenseSMTP(oSmtp);

	theCharSet := app.myRoot.getConfig(AutoCharset).String;
	oSmtp.charset := theCharSet;
	msg := 'Charset = ' &amp; theCharSet;
	app.writeLog(app.getMyUserCode&amp;' '&amp;app.name&amp;' '&amp;msg, LogINFO);		//25 Nov 2019	NDL	TFS 47053
	
	msg := "Version = " &amp; oSmtp.version_1;
	app.writeLog(app.getMyUserCode&amp;' '&amp;app.name&amp;' '&amp;msg, LogINFO);		//25 Nov 2019	NDL	TFS 47053
	
	timeOut := app.myRoot.getConfig(AutoEmailTimeout).Integer;
	
	if timeOut &lt; 2 or timeOut &gt; 60 then
		timeOut := 30;
	endif;
	
	oSmtp.timeout := timeOut;
	
	theSSL := app.myRoot.getConfig(AutoUseSSL).Integer;
	
	if theSSL &lt;&gt; BGP_EmailSendRequest.SSL_NONE then
		msg := 'Init SSL connection';
		app.writeLog(app.getMyUserCode&amp;' '&amp;app.name&amp;' '&amp;msg, LogINFO);		//25 Nov 2019	NDL	TFS 47053
		if oSmtp.sSL_init() &lt;&gt; 0 then
			err := oSmtp.getLastErrDescription();
			app.raiseCMException1(Email_SSL_Failure, err, null, null);
			return;
		endif;
		msg := 'Setting SSL value to ' &amp; theSSL.String;
		app.writeLog(app.getMyUserCode&amp;' '&amp;app.name&amp;' '&amp;msg, LogINFO);		//25 Nov 2019	NDL	TFS 47053
		oSmtp.sSL_starttls := theSSL;
		isSSL := true;
	endif;
	
	// All this needs to be configurable.
	auth := app.myRoot.getConfig(AutoAuthType).Integer;
	
	if auth &lt;&gt; BGP_EmailSendRequest.AUTH_NONE then
		oSmtp.authType := auth;
		userName := app.myRoot.getConfig(AutoOutwardAccount).String;
		password := app.myRoot.getPwForUse(AutoOutwardPassword).String;
		
		if userName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Outward Account', null, null);
			app.raiseCMException(Input_required_field_outwrdAcc, null, null); //cnwdb2 PAR 35364
			return;
		endif;
		
		if password = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Outward Password', null, null);
			app.raiseCMException(Input_required_field_outwrdPas, null, null); //cnwdb2 PAR 35364

			return;
		endif;
		
		oSmtp.userName := userName;
		oSmtp.password := password;
		msg := 'AuthType = ' &amp; auth.String;
		app.writeLog(app.getMyUserCode&amp;' '&amp;app.name&amp;' '&amp;msg, LogINFO);		//25 Nov 2019	NDL	TFS 47053
	endif;

	oSmtp.from     := fromAddress;
    oSmtp.fromAddr  := fromAddress;
	
	tmpStr := toAddress.doInvalidCharacterSweep();
	
	if tmpStr = null then
		app.raiseCMException1(ERR_Email_Blank, app.getErrorString(Recipients), null, null);
		return;
	endif;
	
	if not systemTestMode then //par17833 cnwrs1 sep 2008
		oSmtp.addRecipientEx(tmpStr, NORMAL_RECIPIENT);
	else
		messageRecipientsTest := "To:" &amp; tmpStr;
	endif;
	
	tmpStr := ccAddresses.doInvalidCharacterSweep();
	
	if tmpStr &lt;&gt; null then
		if not systemTestMode then //par17833 cnwrs1 sep 2008
			oSmtp.addRecipientEx(tmpStr, CARBON_COPY);
		else
			messageRecipientsTest := messageRecipientsTest &amp; " CC:" &amp; tmpStr;
		endif;
	endif;
	
	tmpStr := bccAddresses.doInvalidCharacterSweep();
	
	if tmpStr &lt;&gt; null then
		if not systemTestMode then //par17833 cnwrs1 sep 2008
			oSmtp.addRecipientEx(tmpStr, BLIND_CARBON_COPY);
		else
			messageRecipientsTest := messageRecipientsTest &amp; " BCC:" &amp; tmpStr;
		endif;
	endif;
	
	oSmtp.subject := sendSubject;
	
	if not systemTestMode then //par17833 cnwrs1 sep 2008
		oSmtp.bodyText := sendMessage;
	else
		tmpStr := app.myRoot.getConfig(AutoSupportEmailAddress).String;
		oSmtp.addRecipientEx(tmpStr, NORMAL_RECIPIENT);
		oSmtp.bodyText := "Test message, original was to " &amp; messageRecipientsTest &amp; CrLf &amp; sendMessage;
	endif;

	
	if oSmtp.sendMail() &lt;&gt; 0 then
		err := oSmtp.getLastErrDescription();
		app.writeLog( app.getMyUserCode&amp;' '&amp;app.name&amp;' SMTP Error = ' &amp; err, LogINFO);		//25 Nov 2019	NDL	TFS 47053
		app.raiseCMException1(Email_Send_Failure, err, null, null);
	endif;
epilog
	if isSSL then
		oSmtp.sSL_uninit();
	endif;
	
	delete oSmtp;
	

end;

</source>
    </JadeMethod>
    <JadeMethod name="setUnusedYAType" id="71ccde1c-b0e8-463d-82b4-ff137b747126">
        <source>setUnusedYAType();
