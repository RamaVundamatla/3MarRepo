    <JadeMethod name="getActualHeightOfPickupQdMoves" id="b0ad7b0c-777b-4e01-a725-93715c564d60">
        <source>getActualHeightOfPickupQdMoves(_tiToIgnore : CM_TrackedItem): Real;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwer1	Initial creation

*/

vars
	move : CM_FutureMove;
	ti	: CM_TrackedItem;
	fma : CM_FutureMoveArray;
	rtQueueEntry : CM_RTQueueEntry;
	theHeight 	: Real;
begin

	fma := self.allQueuedFutureMoves;
	theHeight := 0;
	foreach move in fma discreteLock do
		//20/06/03  Needed this check because overstows was breaking future move. 
		foreach rtQueueEntry in move.CM_FutureMoveQueued.allRTQueueEntries do
			ti := rtQueueEntry.getTrackedItem;
			if ti &lt;&gt; null  and ti = _tiToIgnore then
				continue;				
			endif;
			if rtQueueEntry.findTaskOfType(TASK_PICKUP,TASK_WORKING) &lt;&gt; null or rtQueueEntry.findTaskOfType(TASK_PICKUP,TASK_COMPLETE) &lt;&gt; null or rtQueueEntry.findTaskOfType(TASK_PICKUP,TASK_ACCEPTED) &lt;&gt; null then
				theHeight:=theHeight + ti.getActualHeight;
			endif;
		endforeach;
	endforeach;
	
	return theHeight;

epilog

end;</source>
        <Parameter name="_tiToIgnore" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getActualQueuedPlannedLoadTI" id="0ac9e47a-d979-4b75-903c-c7da07d5b3eb">
        <source>getActualQueuedPlannedLoadTI() : CM_TrackedItem;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/12/2011	cnwdap1	Initial creation PAR #28881
21/12/2011	cnwdap1	PAR #26619 changes to deal correctly with Discharge / Remian on Board cargo in a load slot
29/06/2012	cnwer1	29764 give warning for containers that are ROB aswell
*/
vars
	ti, theTI	: CM_TrackedItem;
	futureMove	: CM_FutureMove;

begin
	// check actual tis first
	foreach ti in self.allTrackedItems do
		//  imports and tranships on their import voyages
		if  ti.isImport or ti.isTranshipInbound then
			continue;
		endif;
		theTI := ti;
	endforeach;
	
	// then check queued TIs
	if theTI = null and not self.allQueuedFutureMoves.isEmpty then
		foreach futureMove in self.allQueuedFutureMoves where futureMove.moveType &lt;&gt; TI_FutureMoveEDI do
			theTI := futureMove.CM_FutureMoveQueued.myTrackedItem;
		endforeach;
	endif;
	
	// then check planned TIs
	if theTI = null and not self.allPlannedFutureMoves.isEmpty then
		foreach futureMove in self.allPlannedFutureMoves where futureMove.moveType &lt;&gt; TI_FutureMoveEDI do
			theTI := futureMove.CM_FutureMovePlanned.myTrackedItem;
		endforeach;
	endif;
	
	return theTI;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
