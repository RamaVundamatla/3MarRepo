    <JadeMethod name="addToolbarControls" id="506a5e78-5338-4575-987f-f0086cac83df">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// -------------------------------------------
vars

	toolbar	: CMUI_Toolbar;

begin
	inheritMethod();

	toolbar := self.frmToolbar;

	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);


end;</source>
        <access>protected</access>
    </JadeMethod>
