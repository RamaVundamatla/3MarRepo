    <JadeMethod name="translateForm" id="930f4f9c-4d11-42f2-a343-8c2b558b7293">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:40:35.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017314, locale);
	btnCancel.translateBubbleHelp(Xlat_0023239, locale);
	btnCancel.translateCaption(Xlat_0023238, locale);
	btnOK.translateBubbleHelp(Xlat_0023241, locale);
	btnOK.translateCaption(Xlat_0023240, locale);
	lblCode.translateCaption(Xlat_0023243, locale);
	lblDescription.translateCaption(Xlat_0023244, locale);
	lblInfoSuggest.translateCaption(Xlat_0023242, locale);
end;</source>
    </JadeMethod>
