    <JadeMethod name="cmbLoadList_click" id="c8056172-2892-43fb-9b48-9a2b17942269">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLoadList_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ediData : CM_EDIDataLoadList;
begin
	self.setFormCaption;
	ediData := self.cmbLoadList.listObject.CM_EDIDataLoadList;	//cnwrs1 CCMS 1137 01 July 2010
	if ediData &lt;&gt; null then //ccms 1137 cnwrs1 14 July 2010
		if ediData.listType = 'D' then			
			self.btnDischargeComp.value := true;
			self.comparisonMode := DISCHARGE_COMPARISON;
			self.btnDischargeComp_click(btnDischargeComp); //if we know it is a discharge list then set the discharge button						
		elseif ediData.listType = 'L' then		
			self.btnLoadComp.value := true;
			self.comparisonMode := LOAD_COMPARISON;
			self.btnLoadComp_click(btnDischargeComp); //if we know it is a discharge list then set the discharge button
		endif;
	endif;
	//27 Apr 2010	NDL	Par 23912
	self.hasWarnedOfVoyageDiscreps := false;
	self.hasVoyageDiscreps := false;
end;</source>
