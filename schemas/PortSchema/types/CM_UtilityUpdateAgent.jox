    <JadeMethod name="utlUpdateParentFromFirstChild" id="f0935eb6-0e68-4879-acec-77a069ad56d6">
        <source>utlUpdateParentFromFirstChild(	_parent : CM_TrackedItem input;
								_child : CM_TrackedItem input;
								_passport : CM_Passport input
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2014	cnwndl1	Initial creation	Par 34571

*/

vars

begin

	//Only set these items on the parent if its the first child being loaded into a
	// a storage 'container' ( pallet or whatever )

	if not _parent.allChildren.isEmptyOrContainsOnlyEquipment then
		return;
	endif;
	
	if not _parent.isStorage then
		return;
	endif;
	
	_parent.setMyVoyage( _child.myVoyage, _passport );
	_parent.setImExStatus( _child.getImExStatus );
	_parent.setDischargePort( _child.dischargePort );
	
	//24 Apr 2015 NDL	Par 36111
	//Its the first real cargo child, but there could already be equipment children, so set them too.
	if not _child.isEquipment then
		_child.updateForPackOfChildEquipment( _parent, true );
	endif;

epilog

end;</source>
        <Parameter name="_parent" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_child" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePartialVoyagEDIStatus" id="305fdcd8-4a6b-4cd4-97e2-3030be993189">
        <source>utlUpdatePartialVoyagEDIStatus(_ediData : CM_EDIDataVoyage; _validateOnly : Boolean; _failedVoyages, _successfulVoyages : StringArray; _errors : CM_ErrorSet; _passport : CM_Passport);
//
// Purpose:			Derive the correct status to set on EDI TIs for a Voyage object that has partial updates allowed
//					1. If there are any passport errors on individual EDI TIs, status is VERIFIED_ERRORS
//					2. If the voyage code from an individual EDI TI matches one of our successful voyage udpates.
//					   status is VERIFIED or DBLOADED (depending on _validateOnly setting)
//					3. For Qships / OnePort voyage EDI TIs, set the same status on all linked movements and vessel EDI TIs
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/08/2025	navdap1		Initial creation MTN-35604 NSW - Load Partial Voyage EDI
//
vars
	ediTI, otherEdiTI : CM_EDITrackedItem;
	voyageCode : String;
	status : Integer;
	error : CM_Error;

begin
	// Do passport errors first
	foreach error in _errors where error.myUserObject &lt;&gt; null do
		if error.myUserObject.isKindOf(CM_EDITrackedItem) then
			ediTI := error.myUserObject.CM_EDITrackedItem;
			ediTI.setStatus(CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
		endif;
	endforeach;
	
	// Then sort out the failed / successful EDI TIs
	foreach ediTI in _ediData.allEDITrackedItems discreteLock do
		if ediTI.CM_EDIVoyageConsistTI.getVoyageCode = null then
			continue;
		endif;
		if ediTI.status &lt;&gt; null then
			continue;
		endif;
		
		voyageCode := ediTI.CM_EDIVoyageConsistTI.getVoyageCode;
		status := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
		if _successfulVoyages.includes(voyageCode) then
			if _validateOnly then
				status := CM_EDIFile.EDI_STATUS_VERIFIED;
			else
				status := CM_EDIFile.EDI_STATUS_DBLOADED;
			endif;
		endif;
		ediTI.setStatus(status);
		
		if ediTI.isQshipsVoyageTI then
			foreach otherEdiTI in ediTI.CM_EDIQshipsVoyageTI.allQshipsMovementTIs do
				otherEdiTI.setStatus(status);
			endforeach;
			if ediTI.CM_EDIQshipsVoyageTI.myQshipsVesselTI &lt;&gt; null then
				ediTI.CM_EDIQshipsVoyageTI.myQshipsVesselTI.setStatus(status);
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIDataVoyage"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_failedVoyages" type="StringArray"/>
        <Parameter name="_successfulVoyages" type="StringArray"/>
        <Parameter name="_errors" type="CM_ErrorSet"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePassword" id="bd9cc278-9c25-4d80-9f52-ebc27dbf7ff5">
        <source>utlUpdatePassword(pUser : CM_User input; pEdition : Integer; pPassword : String;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     07 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	checkRecentPasswords	: Boolean;

begin

	self.initialiseActivity();
	
	if pEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, pEdition.String, method.name, null, null);
		return;
	endif;

	exclusiveLock(pUser);
	
	if _passport.noErrors then
		if pUser.edition &lt;&gt; pEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'user', null, null);
			return;
		endif;
	endif;
	
	if _passport.noErrors then
		checkRecentPasswords := (pUser = app.getMyUser() and app.myRoot.getConfig(NumberOfPrevPasswords).Integer &gt; 0);
		pUser.setPassword(pPassword, checkRecentPasswords);	
	endif;

epilog
	
end;</source>
        <Parameter name="pUser" type="CM_User" usage="input"/>
        <Parameter name="pEdition" type="Integer"/>
        <Parameter name="pPassword" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePathSegment" id="7a942a78-7711-44c4-a9b2-1d5f4ac1273d">
        <updating/>
        <source>utlUpdatePathSegment(_pxyPathSegment : HMS_PathSegment; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	realPathSegment : HMS_PathSegment;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_pxyPathSegment.raiseExceptionIfNotProxy(method);
	_pxyPathSegment.validateMe(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyPathSegment.pxyGetRealObjectAndEdition(realPathSegment, expectedEdition);
	app.setContinueCMExceptions(true);

	if realPathSegment = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyPathSegment.code, null, null);
		return;
	endif;
	
	exclusiveLock(realPathSegment);

	if _passport.noErrors and realPathSegment.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'PathSegment', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPathSegment, true);
	endif;
	
	if _passport.noErrors then
		realPathSegment.setForUpdate(_pxyPathSegment, _passport);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPathSegment, false);
	endif;
	
end;</source>
        <Parameter name="_pxyPathSegment" type="HMS_PathSegment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
