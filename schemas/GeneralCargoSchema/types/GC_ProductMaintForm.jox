    <JadeMethod name="cmbCommodity_gotFocus" id="5c3cef42-a2c6-47de-8e70-dca0a976e997">
        <controlMethod name="CMUI_ComboBoxObject::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCommodity_gotFocus(combobox: ComboBox input) updating;
/* ---------------------------------------------------------------------------
Created:	15 July 2009	by cnwvu1

Purpose:	CCMS 1080. User-defined cargo types. Organize cmbCommodity to show
			only relevant commodities for this cargo type.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	currentCommodity	: CM_Commodity;
	currentCargoType	: CM_CargoType;
	
begin

	currentCommodity := self.cmbCommodity.listObject.CM_Commodity;

	currentCargoType := self.cmbEntCargoType.listObject.CM_CargoType;
	
	// It can be null, when the form has just started. Trying to retrieve commodity code from combo cargo type
	if currentCommodity = null and currentCargoType &lt;&gt; null then	
		if not currentCargoType.allCommodities.isEmpty then
			currentCommodity := currentCargoType.allCommodities[currentCargoType.defaultCommodityCode];
		else
			currentCommodity := app.myRoot.allCommodities[currentCargoType.defaultCommodityCode];
		endif;
	endif;
	
	
	self.myAssistant.comboBoxCommodityMultiSelected(self.cmbCommodity, currentCargoType.allCommodities, currentCommodity);

	self.cmbCommodity.setInitialised(true); // not to call getJMTCollection()- it gives all commodities
	

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
