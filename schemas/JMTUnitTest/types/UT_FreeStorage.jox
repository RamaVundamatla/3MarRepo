    <JadeMethod name="tConfigLastDay" id="73ca9ed2-e6d0-4ef1-87d2-d7c134cf9e4b">
        <updating/>
        <source>tConfigLastDay() updating;
// cnwmp6
// cnwjre1
/*

Purpose:			Test using storage config with use last days only but with no free storage days
					(This should be the same as the no-config test??)
Parameters:			

Return Value:		


Date		Who		Reason
02 October 2012	cnwjre1	Initial creation

*/

vars
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
begin
	self.deleteStorageConfig( false );
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// set the options
	includeFirstDay := false;
	includeLastDay := true;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, deriveDebtorFrom, triggers, false, 0, 0, 0);	// TFS 2570
	self.importExportStorage3(storageConfig);
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete triggers;
	self.deleteStorageConfig( true );
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateFutureStorageBGPActor" id="4c1ce0ca-8031-4fa0-997f-985ea7b78a91">
        <source>tCreateFutureStorageBGPActor();
/*

Purpose: To test that calling createFutureStorageBGPActor method will create BGP Future Storage Actor (CM_FutureStorageProcess)

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2019	jlgdi1	Initial creation
05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
*/

constants
	CARGO_ID = "ID160419";  // max id length is 11
	TAGroup1 : String = "TAGROUPX";
	BlockStackId1 : String = "UTSBTBSX";
vars
	cargo : CM_TrackedItem;
	iter : Iterator;
	actor : CM_OfflineFutureActor;
	now : Date;
	found : Boolean;
	
	deriveDebtorFrom : CM_DebtorType;
	calendar : CM_Calendar;
	triggers : CM_StorageTriggerByType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	criteriaTypes : CM_YACriteriaTypeArray;
	shipReceivalType : Integer;
	shipReleaseType : Integer;
	chargedDaysWorking : Boolean;
	freeDaysWorking : Boolean;
	storageConfig : CM_StorageConfig;
	storageDetail : CM_StorageDetail;
	bs1 : CM_BlockStack;
	termAreas : CM_TerminalAreaArray;
	tasg1 : CM_TerminalAreaStorageGroup;
	invLineType1 : CM_InvoiceLineDesc;
	
	fsm : CM_FutureStorageMapping;
	
	
begin

	self.deleteStorageConfig( false );
	
	// Arrange
	self.deleteContainer(CARGO_ID);
	cargo := self.addContainer(CARGO_ID, 
							   self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 
							   "2200", 
							   "MT",
							   TI_IMEX_STATUS_EXPORT).CM_Container;
	
	// Setup Storage configuration
	deriveDebtorFrom := app.myRoot.allDebtorTypes["STO"];
	calendar := self.setupCalendar2();
	create triggers transient;
	includeFirstDay := true;
	includeLastDay := true;
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus]);
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking,
						deriveDebtorFrom, triggers, true, 7, 10, 0);
	
	// Setup Storage Detail
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	storageDetail := cargo.getMatchingFreeStorageDetail( null );
	// terminal areas
	bs1 := self.addBlockStack(BlockStackId1, 99, null);
	create termAreas transient;
	termAreas.add(bs1);
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "inside", termAreas);
	invLineType1 := self.getInvoiceLineType("StorageIn");
	fsm := self.addFutureStorageMapping(tasg1, invLineType1, storageDetail);
	
	// Act
	if not process.isInTransactionState then
		beginTransaction;
	endif;
	
	cargo.createFutureStorageBGPActor(now, now.addDays(1), true,storageDetail, false);				//05.10.2022 navma1 #52967
	
	iter := app.myRoot.allOfflineFutureActorParents.createIterator();
	app.myRoot.allOfflineFutureActorParents.startKeyGeq(cargo, iter);
	while iter.next(actor) do
		if actor.myParentObject &lt;&gt; cargo then
			break;
		endif;
		if CM_FutureStorageProcess &lt;&gt; null and
		   actor.class &lt;&gt; CM_FutureStorageProcess then
			continue;
		endif;
		
		found := true;
		delete actor;
	endwhile;
	
	abortTransaction;
	
	// Assert
	self.assertEqualMsg(found, true, "Future Storage Process has been created");
	
epilog
	delete iter;	
	delete triggers;
	delete criteriaTypes;
	delete termAreas;
	
	self.deleteStorageConfig( true );
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateTermAreaStorageGroup" id="a6865a07-1caf-492a-8ccf-1974405e41da">
        <source>tCreateTermAreaStorageGroup();
// cnwmp6
// cnwjre1 test create, delete of terminal areas and storage groups, checking inverses
vars
	count		: Integer;
	ta1Code,
	ta2Code,
	ta3Code	: String;
	ta,
	ta1, ta2, ta3	: CM_TerminalArea;
	foundTasg,
	tasg,
	tasg1, tasg2	: CM_TerminalAreaStorageGroup;
	termAreas		: CM_TerminalAreaArray;
begin
	self.deleteStorageConfig( false );
	ta1Code := "UTTAA1";
	ta2Code := "UTTAA2";
	ta3Code	:= "UTTAA3";
	self.deleteTerminalArea(ta1Code);
	self.deleteTerminalArea(ta2Code);
	self.deleteTerminalArea(ta3Code);
	
	ta1 := self.addBlockStack(ta1Code, 10, null);
	ta2 := self.addBlockStack(ta2Code, 10, null);
	ta3 := self.addBlockStack(ta3Code, 10, null);
	
	self.deleteTerminalAreaStorageGroup(ta1Code);
	self.deleteTerminalAreaStorageGroup(ta2Code);
	
	create termAreas transient;
	termAreas.add(ta1);
	termAreas.add(ta2);
	
	tasg1 := self.addTerminalAreaStorageGroup(ta1Code, "first", termAreas);
	count := 0;
	foreach ta in tasg1.allTerminalAreas do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(ta, ta1, "First TASG terminal area");
		elseif count = 2 then
			self.assertEqualMsg(ta, ta2, "Second TASG terminal area");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "First TASG has two terminal areas");
	
	count := 0;
	foreach tasg in ta1.allTerminalAreaStorageGroups do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(tasg, tasg1, ta1.id &amp; " first TASG");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, ta1.id &amp; " has one terminal area storage group");
	
	count := 0;
	foreach tasg in ta2.allTerminalAreaStorageGroups do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(tasg, tasg1, ta2.id &amp; " first TASG");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, ta2.id &amp; " has one terminal area storage group");
	
	self.deleteTerminalArea(ta1Code);
	count := 0;
	foreach ta in tasg1.allTerminalAreas do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(ta, ta2, "First TASG terminal area after TA delete");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "First TASG has two terminal areas after TA delete");
	
	count := 0;
	foreach tasg in ta2.allTerminalAreaStorageGroups do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(tasg, tasg1, ta2.id &amp; " first TASG after TA delete");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, ta2.id &amp; " has one terminal area storage group after TA delete");
	
	termAreas.clear();
	termAreas.add(ta2);
	// should get an error on ta2 already in a storage group
	self.clearExpectedTrxErrors();
	self.expectTrxError(Term_area_in_other_stg_group);
	tasg2 := self.addTerminalAreaStorageGroup(ta2Code, "second", termAreas);
	self.assertNull(tasg2);
	self.assertTrxError(Term_area_in_other_stg_group);
	self.clearExpectedTrxErrors();
	
	termAreas.clear();
	termAreas.add(ta3);
	tasg2 := self.addTerminalAreaStorageGroup(ta2Code, "second", termAreas);

	self.deleteTerminalAreaStorageGroup(ta1Code);
	count := 0;
	foreach tasg in ta2.allTerminalAreaStorageGroups do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 0, ta2.id &amp; " has no terminal area storage groups after TASG delete");

	count := 0;
	// terminal may have other storage groups from other tests - just look for the ones created and deleted here
	foreach tasg in self.getTerminal().allTerminalAreaStorageGroups do
		if tasg.code = ta1Code or tasg.code = ta2Code or tasg.code = ta3Code then
			count := count + 1;
			foundTasg := tasg;
		endif;
	endforeach;
	self.assertEqualMsg(foundTasg, tasg2, ta2.id &amp; " first TASG in terminal");
	self.assertEqualMsg(count, 1, "Terminal has one terminal area storage group from this test after TASG delete");
epilog
	delete termAreas;
	self.deleteStorageConfig( true );
end;
</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingChargesFSD1" id="88017a5f-d5f7-49ea-8fab-ef6e7cabfd3d">
        <updating/>
        <source>tEscalatingChargesFSD1() updating;
// cnwmp6
// cnwjre1 test 1279 in the 1295 free storage context
//	escalating but a single invoice line for the open-ended range
vars
	start,
	expiry : TimeStamp;
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	debtorRate	: CM_DebtorRate;
	pxyDebtorRate	: CM_DebtorRate;
 	rateEntry		: CM_RateEntry;
	storeTrans		: CM_TITransaction;
	invoiceLines	: ObjectArray;
	perDays, rangeStart, rangeEnd	: IntegerArray;
	costs : DecimalArray;

	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	pxyStorageTrigger	: CM_StorageTrigger;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
begin

	self.deleteStorageConfig( false );

	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// just imex change as a trigger
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_ST_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	// set the options
	includeFirstDay := false;
	includeLastDay := true;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, deriveDebtorFrom, triggers, true, 5, 5, 0);	// TFS 2570


	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteTransactionMaps();

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageEsc1');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);
	self.deleteInvoiceCalcType("UT_ESC");

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	// create an escalating charge cargo calculation type based on INV_CALC_TYPE_DAYS_SINCE_RECVL
	create perDays transient;
	create rangeStart transient;
	create rangeEnd transient;
	/* set up as in the functional spec - 1 to 5 days free
		6 - 10 days at $10 per day, 11 to 20 at $15 per day
		21 days plus at $20 per day, rate increasing by $8 every 10 days
	*/
	perDays.add(0); perDays.add(0); perDays.add(0); perDays.add(10);
	rangeStart.add(1); rangeStart.add(6); rangeStart.add(11); rangeStart.add(21);
	rangeEnd.add(5); rangeEnd.add(10); rangeEnd.add(20); rangeEnd.add(99999999);

	calType1 := self.createInvoiceCalcType(null, INV_CALC_TYPE_DAYS_SINCE_RECVL, "UT_ESC", "Escalating", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  true, false, false,
										  perDays, rangeStart, rangeEnd, null);
	self.assertNotNullMsg(calType1, "Calculation type Escalating Storage not created");
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadEscalatingChg1();
	
	// set up rates for this debtor and service used
	create costs transient;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(theService, debtor);
	// rates are: $0 for 1-5, $10 for 6-10, $15 for 11-20, $20 for 21-max with $8 increment every 10 days
	costs.add(0.00);
	costs.add(10.00);
	costs.add(15.00);
	costs.add(20.00);
	costs.add(8.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, expiry, false, costs, 0, 0, null, null);

	// create a container with retrospective transactions (refer example on PAR 24160)
	voy := self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 65 days ago
	// ##################
	tranDate := tranDate - 65;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	// this creates the first storage transaction for 5 days
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);


	// gate it out -  creates a second storage transaction 
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	

	self.validateEscalatingCharges1(cargo);	// last invoice line qty is 45 not 44 with storage config
	
	// change the rates - add a dollar to each
	debtorRate := rateEntry.rate.CM_DebtorRate;
	costs.clear();
	costs.add(0.00);
	costs.add(11.00);
	costs.add(16.00);
	costs.add(21.00);
	costs.add(9.00);
	self.updateInvoiceRateEntry(debtorRate, rateEntry, start, expiry, false, costs, 0, 0, null,null);

	self.validateEscalatingCharges1a(cargo, 1);
	self.reevalStorageTrans(cargo);	
	// the transaction re-evaluate should not have changed anything
	self.validateEscalatingCharges1a(cargo, 2);
	
	storeTrans := cargo.getLastTransOfType(TRANS_TYPE_STORAGE);
	create invoiceLines transient;
	storeTrans.allInvoiceLines.copy(invoiceLines);
	self.invoiceLineReevaluate(invoiceLines);
	// the re-evaluate should not have changed anything
	self.validateEscalatingCharges1a(cargo, 3);

	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete perDays;
	delete rangeStart;
	delete rangeEnd;
	delete costs;
	delete pxyDebtorRate;
	delete invoiceLines;
	if triggers &lt;&gt; null then
		triggers.purge();
		delete triggers;
	endif;
	
	self.deleteStorageConfig( true );
	if calendar &lt;&gt; null then
		self.deleteCalendar(calendar.code, null);
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tFirstFalseLastFalse" id="69be73bf-96fa-4e9d-a50c-dc3c166911d5">
