    <JadeMethod name="getMethodsCallingTrx" id="9dbe830a-48a1-488a-a692-e4e58c6dd68f">
        <updating/>
        <source>getMethodsCallingTrx(_trxClassesToCheck, _methodsToCheckFor : StringArray) updating;

/*

Purpose:		Get lowest level of methods called trx

Parameters:		_trxClassesToCheck - The trx class(es) that you want to check for
				_methodsToCheckFor - Specific method(s) you want to check for

Date			Who		Reason
06/01/2014		cnwmh5	Initial creation

*/

vars

	schema							: Schema;
	trxClass						: Class;
	meth							: Method;
	obj								: Object;
	
	methodsDict						: MethodNDict;
	
	iter							: Iterator;
		
	classToCheck					: String;
	level							: Integer;
	className						: String;
	methodName						: String;
	methodClassName					: String;
	methodMethodName				: String;
	usedByFormUnitTest				: Character;
	
begin

	// don't do anything if no classes passed in
	if _trxClassesToCheck.isEmpty() then
		return;
	endif;

	// can't find PortSchema then return
	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		return;
	endif;
	
	self.myTrxUsage.clearCollections(true);
	
	foreach classToCheck in _trxClassesToCheck do
		// get the class
		trxClass := schema.getClass(classToCheck);
		if trxClass = null then
			continue;
		endif;
		
		// get all the methods for the class
		methodsDict := trxClass.cnGetMethods();
		
		// read through the methods getting the correct lowest level method
		foreach meth in methodsDict do
		
			// check to see if _methodsToCheckFor is empty or check method name occurs
			if not _methodsToCheckFor.isEmpty() and not _methodsToCheckFor.includes(meth.name) then
				continue;
			endif;
			
			// set variables
			level := 1;
			self.myTrxUsage.clearCollections(false);
			self.myTrxUsage.setCurrentMethod(meth);
			self.myTrxUsage.addMethodToList(meth, level, false);
		
		endforeach;
		
	endforeach;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_trxClassesToCheck" type="StringArray"/>
        <Parameter name="_methodsToCheckFor" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="summarizeTrx" id="0182b45e-e71f-4494-a4c3-1177fecd9cd1">
        <updating/>
        <source>summarizeTrx(_trxClass: String; _verbose: Boolean): String updating;
//25 August 2010	cnwdw1	
//
vars
	sum: String;
	schema, schemaUT: Schema;
	trxClass: Class;
	testMethod: Method;
	profile: UT_Profile;
	//allMethods, allRefs, noRefs, noUnitTests: MethodSet;
	meth, refMeth: Method;
	count, countUnitTest: Integer;
	hasUnitTest: Boolean;
	
	obj							: Object;
	
	trxClassesToCheck			: StringArray;
	methodsToCheck				: StringArray;
	noRefs						: StringArray;
	noUnitTests					: StringArray;
	
	iter						: Iterator;
	
	firstTime					: Boolean;
	className					: String;
	methodName					: String;
	methodClassName				: String;
	methodMethodName			: String;
	trxClassName				: String;
	trxMethodName				: String;
	usage						: Character;
	countUnreferenced			: Integer;
	str							: String;
	unitTestCount				: Integer;
	unrefCount					: Integer;
	
begin
	
	
	create trxClassesToCheck transient;
	trxClassesToCheck.add(_trxClass);
	
	create methodsToCheck transient;
//	methodsToCheck.add("trxUpdateRadioTelemetryLastMsg");
	
	create noRefs transient;
	create noUnitTests transient;
	
	
	self.getMethodsCallingTrx(trxClassesToCheck, methodsToCheck);
	
	firstTime := true;
	iter := self.myTrxUsage.tempDictionary.createIterator;
	while iter.next(obj) do
		self.myTrxUsage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usage, iter);
		//write className &amp; Tab &amp; methodName &amp; Tab &amp; methodClassName &amp; Tab &amp; methodMethodName &amp; Tab &amp; usage;
		if trxClassName &lt;&gt; className then
			if not firstTime then
				if _verbose then
					sum := sum &amp; CrLf &amp; "Summary of Trx " &amp; _trxClass &amp; CrLf;
					sum := sum &amp; "Trx Count: " &amp; count.String &amp; " Unit Tested Count: " &amp; countUnitTest.String &amp; CrLf;
					sum := sum &amp; "Unreferenced Trxs: " &amp; noRefs.size.String &amp; CrLf;
					foreach str in noRefs do
						sum := sum &amp; "  " &amp; str &amp; CrLf;
					endforeach;
					sum := sum &amp; "Untested Trxs: " &amp; noUnitTests.size.String &amp; CrLf;
					foreach str in noUnitTests do
						sum := sum &amp; "  " &amp; str &amp; CrLf;
					endforeach;
				else	
					sum := _trxClass &amp; " Count: " &amp; count.String &amp; " Unit Tested Count: " &amp; countUnitTest.String &amp; " Unreferenced Trxs: " &amp; noRefs.size.String;
				endif;
			else
				firstTime := false;
				trxMethodName := methodName;
			endif;
			count := 0;
			trxClassName := className;
			noUnitTests.clear();
			noRefs.clear();
		endif;
		
		if trxMethodName &lt;&gt; methodName then
			//write Tab &amp; Tab &amp; trxMethodName &amp; Tab &amp; unitTestCount.String &amp; Tab &amp; unrefCount.String;
			if unrefCount = 1 and unitTestCount = 0 then
				if not noRefs.includes(trxMethodName) then
					noRefs.add(trxMethodName);
				endif;
				countUnreferenced := countUnreferenced + 1;
			elseif unitTestCount = 0 then
				if not noUnitTests.includes(trxMethodName) then
					noUnitTests.add(trxMethodName);
				endif;
				countUnitTest := countUnitTest + 1;
			endif;
			
			/*
			if unitTestCount = 0 then
				if not noUnitTests.includes(trxMethodName) then
					noUnitTests.add(trxMethodName);
				endif;
			else	
				countUnitTest := countUnitTest + 1;
			endif;
			if unrefCount = 1 and unitTestCount = 0 then
				if not noRefs.includes(trxMethodName) then
					noRefs.add(trxMethodName);
				endif;
			else 
				countUnreferenced := countUnreferenced + 1;
			endif;
			*/
			trxMethodName := methodName;
			unitTestCount := 0;
			unrefCount := 0;
			count := count + 1;
		endif;
		
		if usage = "U" then
			unitTestCount := unitTestCount + 1;
		else
			unrefCount := unrefCount + 1;
		endif;
		
	endwhile;
	
	if _verbose then
		sum := "Summary of Trx " &amp; _trxClass &amp; CrLf;
		sum := sum &amp; "Trx Count: " &amp; count.String &amp; " Unit Tested Count: " &amp; countUnitTest.String &amp; CrLf;
		sum := sum &amp; "Unreferenced Trxs: " &amp; noRefs.size.String &amp; CrLf;
		foreach str in noRefs do
			sum := sum &amp; "  " &amp; str &amp; CrLf;
		endforeach;
		sum := sum &amp; "Untested Trxs: " &amp; noUnitTests.size.String &amp; CrLf;
		foreach str in noUnitTests do
			sum := sum &amp; "  " &amp; str &amp; CrLf;
		endforeach;
	else	
		sum := _trxClass &amp; " Count: " &amp; count.String &amp; " Unit Tested Count: " &amp; countUnitTest.String &amp; " Unreferenced Trxs: " &amp; noRefs.size.String;
	endif;
	
	/*
	create noRefs transient;
	create noUnitTests transient;
	create allMethods transient;
	create allRefs transient;
	
	schemaUT := rootSchema.getSchema("JMTUnitTest");
	schema := rootSchema.getSchema("PortSchema");
	if schema &lt;&gt; null then
		trxClass := schema.getClass(_trxClass);
		if trxClass &lt;&gt; null then
			allMethods.clear;
			trxClass.allMethods(allMethods);
			count := 0;
			foreach meth in allMethods do
				if meth.name = "trxCreateCamTaskHistory" then
					write "Debugging " &amp; meth.name;
				endif;
				count := count + 1;
				allRefs.clear;
				meth.getMethodRefs(allRefs);
				if allRefs.isEmpty then
					noRefs.add(meth);
				endif;
				hasUnitTest := false;
				foreach refMeth in allRefs do
					if refMeth.getSchema = schemaUT then
						hasUnitTest := true;
						break;
					endif;
				endforeach;
				if hasUnitTest then
					countUnitTest := countUnitTest + 1;
				else
					noUnitTests.add(meth);
				endif;
			endforeach;
			
		endif;
	endif;		
	
	if _verbose then
		sum := "Summary of Trx " &amp; _trxClass &amp; CrLf;
		sum := sum &amp; "Trx Count: " &amp; count.String &amp; " Unit Tested Count: " &amp; countUnitTest.String &amp; CrLf;
		sum := sum &amp; "Unreferenced Trxs: " &amp; noRefs.size.String &amp; CrLf;
		foreach meth in noRefs do
			sum := sum &amp; "  " &amp; meth.name &amp; CrLf;
		endforeach;
		sum := sum &amp; "Untested Trxs: " &amp; noUnitTests.size.String &amp; CrLf;
		foreach meth in noUnitTests do
			sum := sum &amp; "  " &amp; meth.name &amp; CrLf;
		endforeach;
	else
		sum := _trxClass &amp; " Count: " &amp; count.String &amp; " Unit Tested Count: " &amp; countUnitTest.String &amp; " Unreferenced Trxs: " &amp; noRefs.size.String;
	endif;
	*/
	
	return sum;
epilog
	//delete allMethods;
	//delete allRefs;
	delete noRefs;
	delete noUnitTests;
	
	delete trxClassesToCheck;
	delete methodsToCheck;
	
	delete iter;
	
	
end;</source>
        <Parameter name="_trxClass" type="String"/>
        <Parameter name="_verbose" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="summarizeTrx_OLD" id="23bfad87-b2a4-4527-aa01-f15ec6a317dd">
        <source>summarizeTrx_OLD(_trxClass: String; _verbose: Boolean): String;
//25 August 2010	cnwdw1	
//
vars
	sum: String;
	schema, schemaUT: Schema;
	trxClass: Class;
	testMethod: Method;
	profile: UT_Profile;
	allMethods, allRefs, noRefs, noUnitTests: MethodSet;
	meth, refMeth: Method;
	count, countUnitTest: Integer;
	hasUnitTest: Boolean;
begin
	create noRefs transient;
	create noUnitTests transient;
	create allMethods transient;
	create allRefs transient;
	
	schemaUT := rootSchema.getSchema("JMTUnitTest");
	schema := rootSchema.getSchema("PortSchema");
	if schema &lt;&gt; null then
		trxClass := schema.getClass(_trxClass);
		if trxClass &lt;&gt; null then
			allMethods.clear;
			trxClass.allMethods(allMethods);
			count := 0;
			foreach meth in allMethods do
				if meth.name = "trxCreateCamTaskHistory" then
					write "Debugging " &amp; meth.name;
				endif;
				count := count + 1;
				allRefs.clear;
				meth.getMethodRefs(allRefs);
				if allRefs.isEmpty then
					noRefs.add(meth);
				endif;
				hasUnitTest := false;
				foreach refMeth in allRefs do
					if refMeth.getSchema = schemaUT then
						hasUnitTest := true;
						break;
					endif;
				endforeach;
				if hasUnitTest then
					countUnitTest := countUnitTest + 1;
				else
					noUnitTests.add(meth);
				endif;
			endforeach;
			
		endif;
	endif;		
	
	if _verbose then
		sum := "Summary of Trx " &amp; _trxClass &amp; CrLf;
		sum := sum &amp; "Trx Count: " &amp; count.String &amp; " Unit Tested Count: " &amp; countUnitTest.String &amp; CrLf;
		sum := sum &amp; "Unreferenced Trxs: " &amp; noRefs.size.String &amp; CrLf;
		foreach meth in noRefs do
			sum := sum &amp; "  " &amp; meth.name &amp; CrLf;
		endforeach;
		sum := sum &amp; "Untested Trxs: " &amp; noUnitTests.size.String &amp; CrLf;
		foreach meth in noUnitTests do
			sum := sum &amp; "  " &amp; meth.name &amp; CrLf;
		endforeach;
	else
		sum := _trxClass&amp;" Count: " &amp; count.String &amp; " Unit Tested Count: " &amp; countUnitTest.String &amp; " Unreferenced Trxs: " &amp; noRefs.size.String;
	endif;
	
	return sum;
epilog
	delete allMethods;
	delete allRefs;
	delete noRefs;
	delete noUnitTests;
end;</source>
        <Parameter name="_trxClass" type="String"/>
        <Parameter name="_verbose" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxDisplayMethodsCalledBy" id="49e75519-a86c-48e7-9cf6-02ff88bdf1b5">
        <updating/>
        <source>trxDisplayMethodsCalledBy(_classesToCheck, _methodsToCheck : StringArray; _formsUsedBy, _unitTestsUsedBy, _methodsUsedBy : Boolean) updating;

/*

Purpose:		Display the Forms / Unit Test that for each trx method	

Date			Who		Reason
07/01/2014		cnwmh5	Initial creation

*/

vars

	meth							: Method;
	obj								: Object;
	file							: File;
	file2							: File;
	file3							: File;
	file4							: File;
	
	formsArray						: StringArray;
	tokensArray						: StringArray;
	
	iter							: Iterator;
	
	trxClassName					: String;
	className						: String;
	methodName						: String;
	methodClassName					: String;
	methodMethodName				: String;
	usage							: Character;
	formsUsedBy						: String;
	unitTestsUsedBy					: String;
	methodsUsedBy					: String;
	firstTime						: Boolean;
	trxMethodName					: String;
	str								: String;
	index							: Integer;
	pos								: Integer;

begin
	
	// get the details
	self.getMethodsCallingTrx(_classesToCheck, _methodsToCheck);
	
	create file transient;
	file.fileName := "c:\temp\" &amp; method.name &amp; ".txt";
	if file.isAvailable then
		file.purge;
	endif;
	
	create file2 transient;
	file2.fileName := "c:\temp\" &amp; method.name &amp; ".csv";
	if file2.isAvailable() then
		file2.purge();
	endif;
	file2.writeLine("Trx Class/Method,Class,Method,Usage,Class/Method,Class,Method");
		
	create file3 transient;
	file3.fileName := "c:\temp\" &amp; method.name &amp; "FormsWithUnitTests.csv";
	if file3.isAvailable() then
		file3.purge();
	endif;
	
	create file4 transient;
	file4.fileName := "c:\temp\" &amp; method.name &amp; "TrxWithNoUnitTests.csv";
	if file4.isAvailable() then
		file4.purge();
	endif;
	file4.writeLine("Full Name,Class,Method");
	
	create tokensArray transient;
	create formsArray transient;
		
	firstTime := true;
	iter := self.myTrxUsage.tempDictionary.createIterator;
	while iter.next(obj) do
		meth := obj.Method;
	
		self.myTrxUsage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usage, iter);
		file2.writeLine(className &amp; "::" &amp; methodName &amp; "," &amp; className &amp; "," &amp; methodName &amp; "," &amp; usage &amp; "," &amp;
			methodClassName &amp; "::" &amp; methodMethodName &amp; "," &amp; methodClassName &amp; "," &amp; methodMethodName);
	
		if trxMethodName &lt;&gt; methodName then
			if not firstTime then
				write trxClassName &amp; "::" &amp; trxMethodName &amp; Tab &amp; trxClassName &amp; Tab &amp; trxMethodName;
				file.writeLine(trxClassName &amp; "::" &amp; trxMethodName &amp; Tab &amp; trxClassName &amp; Tab &amp; trxMethodName);
				if formsUsedBy &lt;&gt; null then
					write Tab &amp; "Used by Form(s):" &amp; formsUsedBy;
					file.writeLine(Tab &amp; "Used by Form(s):" &amp; formsUsedBy);
				endif;
				if unitTestsUsedBy &lt;&gt; null then
					write Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy;
					file.writeLine(Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy);
				endif;	
				if methodsUsedBy &lt;&gt; null then
					write Tab &amp; "Used by Method(s)" &amp; methodsUsedBy;
					file.writeLine(Tab &amp; "Used by Method(s):" &amp; methodsUsedBy);
				endif;	
				if unitTestsUsedBy &lt;&gt; null and formsUsedBy &lt;&gt; null then
					formsUsedBy := formsUsedBy.replaceString(CrLf, "");
					formsUsedBy := formsUsedBy.replaceString(Tab &amp; Tab, Tab);
					tokensArray := formsUsedBy.cnGetTokens(Tab);
					formsArray.clear();
					foreach index in 1 to tokensArray.size step 1 do
						str := tokensArray[index];
						pos := 1;
						str := str.scanUntil(":", pos);
						if not formsArray.includes(str) then
							formsArray.add(str);
						endif;
					endforeach;
					file3.writeLine(trxClassName &amp; "::" &amp; trxMethodName &amp; Tab &amp; trxClassName &amp; Tab &amp; trxMethodName &amp; Tab &amp; formsArray.concatenate(Tab));
				endif;
				if unitTestsUsedBy = null then
					file4.writeLine(trxClassName &amp; "::" &amp; trxMethodName &amp; "," &amp; trxClassName &amp; "," &amp; trxMethodName);
				endif;
				write CrLf;
				file.writeLine(CrLf);
			else	
				firstTime := false;
			endif;
			trxClassName := className;
			trxMethodName := methodName;
			formsUsedBy := null;
			unitTestsUsedBy := null;
			methodsUsedBy := null;
		endif;
	
		// set the various details based on the usage flag
		if _formsUsedBy and usage = "F" then
			formsUsedBy := formsUsedBy &amp; CrLf &amp; Tab &amp; Tab &amp; meth.getSchemaType().name &amp; "::" &amp; meth.name;
		elseif _unitTestsUsedBy and usage = "U" then
			unitTestsUsedBy := unitTestsUsedBy &amp; CrLf &amp; Tab &amp; Tab &amp; meth.getSchemaType().name &amp; "::" &amp; meth.name;
		elseif _methodsUsedBy and usage = "M" and meth.name &lt;&gt; trxMethodName then
			methodsUsedBy := methodsUsedBy &amp; CrLf &amp; Tab &amp; Tab &amp; meth.getSchemaType().name &amp; "::" &amp; meth.name;
		endif;
		
	
	endwhile;
	
	write trxClassName &amp; "::" &amp; trxMethodName &amp; Tab &amp; trxClassName &amp; Tab &amp; trxMethodName;
	file.writeLine(trxClassName &amp; "::" &amp; trxMethodName &amp; Tab &amp; trxClassName &amp; Tab &amp; trxMethodName);
	if formsUsedBy &lt;&gt; null then
		write Tab &amp; "Used by Form(s):" &amp; formsUsedBy;
		file.writeLine(Tab &amp; "Used by Form(s):" &amp; formsUsedBy);
	endif;
	if unitTestsUsedBy &lt;&gt; null then
		write Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy;
		file.writeLine(Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy);
	endif;	
	if methodsUsedBy &lt;&gt; null then
		write Tab &amp; "Used by Method(s)" &amp; methodsUsedBy;
		file.writeLine(Tab &amp; "Used by Method(s):" &amp; methodsUsedBy);
	endif;	
	
	
	if unitTestsUsedBy &lt;&gt; null and formsUsedBy &lt;&gt; null then
		formsUsedBy := formsUsedBy.replaceString(CrLf, "");
		formsUsedBy := formsUsedBy.replaceString(Tab &amp; Tab, Tab);
		tokensArray := formsUsedBy.cnGetTokens(Tab);
		formsArray.clear();
		foreach index in 1 to tokensArray.size step 1 do
			str := tokensArray[index];
			pos := 1;
			str := str.scanUntil(":", pos);
			if not formsArray.includes(str) then
				formsArray.add(str);
			endif;
		endforeach;
		file3.writeLine(trxClassName &amp; "::" &amp; trxMethodName &amp; Tab &amp; trxClassName &amp; Tab &amp; trxMethodName &amp; Tab &amp; formsArray.concatenate(Tab));
		//file3.writeLine(trxClassName &amp; "::" &amp; trxMethodName &amp; Tab &amp; trxClassName &amp; Tab &amp; trxMethodName &amp; Tab &amp; formsUsedBy);
	endif;
	
	if unitTestsUsedBy = null then
		file4.writeLine(trxClassName &amp; "::" &amp; trxMethodName &amp; "," &amp; trxClassName &amp; "," &amp; trxMethodName);
	endif;
	
	
epilog

	delete iter;
	delete file;
	delete file2;
	delete file3;
	delete file4;
	delete formsArray;
	delete tokensArray;
	
end;</source>
        <Parameter name="_classesToCheck" type="StringArray"/>
        <Parameter name="_methodsToCheck" type="StringArray"/>
        <Parameter name="_formsUsedBy" type="Boolean"/>
        <Parameter name="_unitTestsUsedBy" type="Boolean"/>
        <Parameter name="_methodsUsedBy" type="Boolean"/>
    </JadeMethod>
</Class>
