<Class name="CM_BOLTransferred" id="397ee145-cf98-43f9-a543-2d963c2503b6">
    <superclass name="CM_BOLTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transactbol"/>
    <PrimAttribute name="fromBolNumber" id="fd9434e6-d17d-4073-811e-96f96cd0ad9d">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numberOfCargoTransferred" id="ac6f2eab-4fb9-43ed-9746-5454cead1625">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="quantityOfCargoTransferred" id="1d4ea9ba-9479-43d9-9bd8-205008488379">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="toBolNumber" id="d114353d-1645-4dc8-9879-5035c274e4d2">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="volumeOfCargoTransferred" id="85cf1f0c-a28e-4482-85c8-c83ece0abe73">
        <precision>23</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="weightOfCargoTransferred" id="4ecf23bc-d60f-4b50-9dd7-2938e9a91cf6">
