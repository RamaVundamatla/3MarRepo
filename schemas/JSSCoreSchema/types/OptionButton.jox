<GUIClass name="OptionButton">
    <JadeMethod name="controlNamePrefix" id="8f38f391-0cd0-4e33-b979-3168aa85cd64">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		05 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "opt";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssSet" id="3c68feec-8c78-4561-89e5-e8a30daf4a7a">
        <updating/>
        <source>jssSet(pValue:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's boolean flag with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.value &lt;&gt; pValue then
		self.value	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
</GUIClass>
