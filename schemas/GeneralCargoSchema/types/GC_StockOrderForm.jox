    <JadeMethod name="validateOrderLineProduct" id="15b40fe5-7f48-415c-a0df-f02ed08ddebb">
        <source>validateOrderLineProduct(_orderLineProduct : CM_StockOrderProductLine; _goToRow : String io) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     05 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
	product			: CM_Product;
	tbl				: CM_DataTable;
	reqdQuantity,
	row,
	numRows			: Integer;
	hitDuplicate	: Boolean;
	orderLine		: CM_StockOrderLine;
begin

	tbl := self.tblDataDetail;
	numRows := tbl.rows;
	product := self.cmbProduct.listObject.CM_Product;
	if product = null then
		app.msgBox(app.getErrorString(Must_select_cargo_subtype) ,app.getErrorString(Cargo_subtype_not_selected), MsgBox_Exclamation_Mark_Icon);
		_goToRow := ETRow_MyProduct;
		return false;
	endif;
	reqdQuantity := self.tblDetailEnt.getValueByName(ETRow_ReqdQuantity).Integer;
	
	if reqdQuantity &lt; 1 then
		app.msgBox('You must specify a required quantity','No quantity specified', MsgBox_Exclamation_Mark_Icon);
		_goToRow := ETRow_ReqdQuantity;
		return false;
	endif;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		orderLine := tbl.accessRow(row).itemObject.CM_StockOrderLine;
		if (not CM_StockOrderProductLine.hasInstance(orderLine)) then
			continue;
		endif;
		
		if (_orderLineProduct &lt;&gt; null) and 
		   (orderLine = _orderLineProduct) then //we've hit ourselves - ignore
			continue;
		endif;
	
		if orderLine.CM_StockOrderProductLine.myProduct = product then
			hitDuplicate := true;
			break;
		endif;
	endforeach;

	if hitDuplicate then
		app.msgBox(app.getErrorString1(AlreadyOrderLineForCargoSubtyp,product.code),app.getErrorString(Duplicate_cargoSub_allocation), MsgBox_Exclamation_Mark_Icon);
		_goToRow := ETRow_MyProduct;
		return false;
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_orderLineProduct" type="CM_StockOrderProductLine"/>
        <Parameter name="_goToRow" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateOrderLineTI" id="69775dd0-66cc-4825-8f0f-1ca07119f964">
        <source>validateOrderLineTI(_orderLineTI : CM_StockOrderTILine; _goToRow : String io) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     05 May 2004	cnwth2
//
// Purpose:     _orderLine will be null if adding, and populated if updating the order line
//			 
// ----------   ----------  --------------------------------------------------
vars
	
	ti				: CM_TrackedItem;
	tbl				: CM_DataTable;
	row,
	numRows			: Integer;
	hitDuplicate	: Boolean;
	orderLine		: CM_StockOrderLine;
begin
	ti := self.cmbTI.listObject.CM_TrackedItem;
	
	if ti = null then
		app.msgBox('You must select a general cargo item to assign to the order line first', 'No item selected', MsgBox_Exclamation_Mark_Icon);
		_goToRow := ETRow_Id;
		return false;
	endif;
	
	tbl := self.tblDataDetail;
	numRows := tbl.rows;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		orderLine := tbl.accessRow(row).itemObject.CM_StockOrderLine;
		if (not CM_StockOrderTILine.hasInstance(orderLine)) then
			continue;
		endif;
		
		if (_orderLineTI &lt;&gt; null) and 
		   (orderLine = _orderLineTI) then //we've hit ourselves - ignore
			continue;
		endif;
	
		if orderLine.CM_StockOrderTILine.myTrackedItem = ti then
			hitDuplicate := true;
			break;
		endif;
	endforeach;

	if hitDuplicate then
		app.msgBox('There is already an order line added for this item','Duplicate order line', MsgBox_Exclamation_Mark_Icon);
		_goToRow := ETRow_Id;
		return false;
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_orderLineTI" type="CM_StockOrderTILine"/>
        <Parameter name="_goToRow" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDoRemoveDetail" id="8e166a85-2597-4fab-9a90-2345ab4e1756">
        <updating/>
        <source>zDoRemoveDetail()updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 October 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	row, numObjRows, numRows  : Integer;
	table 	: CM_DataTable;
	selectedRowArray : BooleanArray;
	blnSelected : Boolean;
begin
	table := self.tblDataDetail;
	numRows := table.rows;

	if self.mode = self.Mode_View then
		// must remember selected for removing as zDoEdit() clears the table and re-populates it. 
		create selectedRowArray transient;
		
		foreach row in table.fixedRows + 1 to table.rows do
			selectedRowArray.add(table.accessRow(row).selected);
		endforeach;	

		self.zDoEdit();	

		// reset selected rows. 
		row := table.fixedRows + 1;
		foreach blnSelected in selectedRowArray do 
			if blnSelected then 
				table.selectRow(row,false);
			endif;
			row := row + 1;
		endforeach;		
	endif;
	
	self.doRemoveDetailLine();
	
	if self.showTblDetailCount then
		self.staMain.caption := (self.tblDataDetail.rows - self.tblDataDetail.fixedRows).String &amp; ' ' &amp;
									self.getDataEntityDescription(false) &amp; ' listed';
	endif;
	
	self.myCurrentDetailObject := null;
	
epilog
	delete selectedRowArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
