    <JadeMethod name="includeObject" id="455c23b9-4741-4986-be15-b55259dc9db2">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*
Purpose:	

Date		Who		Reason
03 October 2024	navab1	JIRA 33001
*/

vars

begin

	if _obj.CM_VoyageProcess.isAutomaticProcess
	and not app.myRoot.canDo(Mod_VoyageAutoClosure) then
		return false;
	endif;

	return inheritMethod(_obj, _passport);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
