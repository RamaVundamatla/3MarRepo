<CollClass name="CM_YardAllocationSet" id="96338723-7efc-4762-83df-0c93e5e85336">
    <loadFactor>98</loadFactor>
    <memberType name="CM_YardAllocation"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="doComparison" id="e5d7e97b-65d3-4af0-8485-599c0e8f6803">
        <lockReceiver/>
        <updating/>
        <source>doComparison(_yaSet : CM_YardAllocationSet) updating;

vars

	iter	: Iterator;
	ya		: CM_YardAllocation;

begin

	iter := self.createIterator();
	while iter.next(ya) do
		if not _yaSet.includes(ya) then
			self.remove(ya);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_yaSet" type="CM_YardAllocationSet"/>
    </JadeMethod>
    <JadeMethod name="findHatchedYA" id="8399f026-7305-4527-ba04-70ac70e5cb78">
        <source>findHatchedYA() : CM_YardAllocation;
// --------------------------------------------------------------------------------
// Created:		10 June 2010 by cnwjo3
//
// Purpose:		looks through self and finds the YA which has YA.displayHatched = true
//
vars
	ya : CM_YardAllocation;
begin
	foreach ya in self discreteLock do
		if ya.displayHatched then
			return ya;
		endif;
	endforeach;
	
	return null;
end;</source>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
</CollClass>
