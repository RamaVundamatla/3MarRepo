    <JadeMethod name="cmbData_displayEntry" id="130ac0e8-ba9b-43e5-b0e2-016daa562d2d">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbData_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:	12 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
//31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
vars
	edition : Integer;
	invalid : Boolean;
begin
	//12 Sep 2016	NDL	TFS 2278 / 2670
	on Exception do app.handleDeletedObject(exception,obj.Object,invalid);
	if obj = null then
		return null;
	endif;
	edition := obj.Object.edition;
	if invalid then
		return null;
	endif;
	
	if self.ediFileType = EDIFileTypeX12_350_4010
	or self.ediFileType = EDIFileTypeCAMIR_CustomsStatus then		//cnwmc5 - 10 July 2014 - CCMS 2353 PEN
		return obj.CM_Object.getEDIActionName();		//ChangeRequest 46721
	elseif self.ediFileType = EDIFileType_CusRes
	or self.ediFileType = EDIFileType_XMLOneStopCust	//08 Sep 2016	NDL	TFS 2278 / 2670
	or self.ediFileType = EDIFileType_JMTInternal // TFS 39133
	then
		return obj.CM_Object.getEDIActionName();
	endif;
epilog
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
