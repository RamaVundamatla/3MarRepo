    <JadeMethod name="uRunSim4" id="ae861b60-e137-4184-998e-065c836da703">
        <updating/>
        <source>uRunSim4() updating;
/*

*/
constants
	PREFIX = "Y";

	SCALE = 1;    // Slow the run by increasing the SCALE factor
	
	// All times in seconds
	CRANE_MIN = 30 * SCALE;
	CRANE_MAX = 120 * SCALE;
	MACHINE_MIN = 100 * SCALE;
	MACHINE_MAX = 300 * SCALE;

vars
	terminal: SIM_Terminal;
	voyage1: SIM_Voyage;
	startTime, finishTime: TimeStamp;
	exports, imports: CM_TISet;
	iter: Iterator;
	txn: CM_Transaction;

begin
	app.seedRandom(1999);
	startTime := app.actualTimeServer;
	
	create terminal;
	terminal.add(self, PREFIX, 600, SIM_Object.LOG_BRIEF);
	terminal.addBlockStacks("BS", 3, 500);
	terminal.addCranes("CR", 3, CRANE_MIN, CRANE_MAX);
	terminal.addForklifts("FL", 6, MACHINE_MIN, MACHINE_MAX);
	terminal.addMachineRules("CR1 CR2 CR3", SIM_Terminal.MACHINE_RULE_FORKLIFT);
	
	create voyage1;
	voyage1.add(terminal, "SIM1", 10, 20);
	voyage1.useTerminalArea("BS1 BS2 BS3");
	voyage1.useCrane("CR1 CR2 CR3");
	voyage1.plan();
	voyage1.queue();
	voyage1.assignMachineToCraneQueue("FL1 FL2", "CR1");
	voyage1.assignMachineToCraneQueue("FL3 FL4", "CR2");
	voyage1.assignMachineToCraneQueue("FL5 FL6", "CR3");
	
	terminal.addWorkForVoyage(voyage1);
	terminal.displayTasks();
	
	terminal.workMachines();
	finishTime := app.actualTimeServer;
	
	//self.xGetMovements(startTime, finishTime);
	
	// Check txns
	create imports transient;
	voyage1.getImports(imports);
	iter := imports.first.allTransactions.createIterator;
	iter.back(txn);
	self.assertTrue(txn.isA(CM_SetDown));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Pickup));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Move));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Wharfage));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_ReceiveShip));
	delete iter;
	
	create exports transient;
	voyage1.getExports(exports);
	iter := exports.first.allTransactions.createIterator;
	iter.back(txn);
	self.assertTrue(txn.isA(CM_SetDown));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Wharfage));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_ReleaseShip));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Pickup));
	delete iter;
	
epilog
	delete terminal;
	delete voyage1;
	delete imports;
	delete exports;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="uRunTerminalSimulation" id="7306da4e-0a78-4d03-8c43-bcccb148b756">
        <updating/>
        <source>uRunTerminalSimulation() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2012	cnwdw1	Initial creation
*/
constants
	PREFIX = "D";
	MTCONTAINER = PREFIX&amp;"MT12345";
	SHIP_IMPORT_CONTAINER = PREFIX&amp;"IMP00";
	SHIP_EXPORT_CONTAINER = PREFIX&amp;"EXP00";
	TRUCK = PREFIX&amp;"KEATK";
	
	CRANE_NAME = "CR";
	SLOT_COUNT = 20;
	BAY_COUNT = 2;
	CRANE_COUNT = 2;
	TA_COUNT = 2;
	TRUCK_COUNT = 5;
	
	// All Times in Seconds
	SLEEP = 10;

	// Scale of 5 takes about 30 minutes
	SCALE = 10;    // Slow the run by increasing the SCALE factor
	
	CRANE_MIN = 3 * SCALE;
	CRANE_RANGE = 3 * SCALE;
	MACHINE_MIN = 3 * SCALE;
	MACHINE_RANGE = 6 * SCALE;
	
	VISIT_MIN = 3 * SCALE;
	VISIT_RANGE = 6 * SCALE;
	
	MAX_RUN_TIME = 10 * SCALE * 60;  // 100 min
	
vars
	slots: CM_SlotControllerArray;
	loadPort, dischargePort: CM_Port;
	cargo: CM_TIArray;
	craneName, crane1Name, crane2Name: String;
	i, b, s: Integer;
	job: CM_Job;
	voyageJob : CM_VoyageJob;
	request: CM_Request;
	wle: CM_WorkListEntry;
	crane, crane1, crane2: CM_Crane;
	tas: StringArray;
	voyageQueue: CM_VoyageQueue;
	craneQueue: CM_VoyageCraneQueue;
	ti, ti1, ti2: CM_TrackedItem;
	sheet: CM_JobSheet;
	wles : CM_WLEArray;
	wlesToDo, wlesCompleted: Integer;
	machineIndex, craneIndex: Integer;
	currentDateTime: TimeStamp;
	voyageMachines: CM_MachineByIdDict;
	machine: CM_Machine;
	startTime, finishTime: TimeStamp;
	voyageJobsComplete: Boolean;
	voyAlloc: CM_VoyageAllocation;
	slot: CM_SlotController;
	jobs: CM_JobArray;
	terminalAreas: CM_TerminalAreaArray;
	bayName: String;
	trucks: CM_VehicleArray;
	wlesByCrane: DynaDictionary;
	iterator1, iterator2, iterator3: Iterator;
	
	machineSetdownTime, machinePickupTime, craneCompletedTime: TimeStampArray;
	
	nextVisitTime: TimeStamp;
	vvr: CM_VehicleVisitRecord;
	truckCount: Integer;
	defVoyage : CM_Voyage;

begin

	self.setTerminalConfig(DefVoyage, self.getTerminal().getNullVoyage());

	self.setupForRun(PREFIX);
	
	app.seedRandom(1999);
	
	loadPort := app.myRoot.allPorts[self.voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	crane1Name := CR1;
	crane2Name := CR2;
	
	create jobs transient;
	create terminalAreas transient;
	terminalAreas.add(bs1);
	terminalAreas.add(bs2);
	
	self.logMessageNow("Create Discharge Jobs");

	foreach b in 1 to BAY_COUNT do 
		bayName := ((b * 2) - 1).cnEcPad(2);
		self.logMessageNow("Create Discharge Jobs for bay " &amp; bayName);
		create slots transient;
		self.getJobSlotControllers(self.voyage.code, bayName, DeckOnDeck, 1, 1, SLOT_COUNT, slots);
		assertEqual(slots.size, SLOT_COUNT);
		create cargo transient;
		foreach s in 1 to SLOT_COUNT do
			cargo.add(self.addContainerAtLocnDisch(SHIP_IMPORT_CONTAINER &amp; b.cnEcPad(2) &amp; s.cnEcPad(3), "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[s], loadPort, self.voyage));
		endforeach;
		delete cargo;
		
		// Color code and Create Discharge Jobs
		self.voyageDischargeColourCode(self.voyage);
		
		craneName := CRANE_NAME &amp; (((b - 1) / (BAY_COUNT / CRANE_COUNT)) + 1).Integer.String;   // slpit bay over cranes
		voyageJob := self.addVoyageJob(self.voyage, craneName, slots, true);
		assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
		jobs.add(voyageJob);
		
		foreach wle in voyageJob.workListEntries do
			self.movePlannedWLE(wle.myTrackedItem, terminalAreas[app.random(TA_COUNT-1)+1].getLocationsController, wle);
		endforeach;
		delete slots;
	endforeach;
	
	self.logMessageNow("Create Load Jobs");
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,"GEN2",null,1,false,false);
	foreach b in 1 to BAY_COUNT do 
		bayName := ((b * 2) - 1).cnEcPad(2);
		self.logMessageNow("Create Load Jobs for bay " &amp; bayName);
		create slots transient;
		self.getJobSlotControllers(self.voyage.code, bayName, DeckOnDeck, 1, 1, SLOT_COUNT, slots);
		assertEqual(slots.size, SLOT_COUNT);

		self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
		
		craneName := CRANE_NAME &amp; (((b - 1) / (BAY_COUNT / CRANE_COUNT)) + 1).Integer.String;   // slpit bay over cranes
		voyageJob := self.addVoyageJob(self.voyage, craneName, slots, false);
		assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
		jobs.add(voyageJob);
		
		i := 0;
		foreach slot in slots do
			i := i + 1;
			ti := self.addContainerForExport(SHIP_EXPORT_CONTAINER &amp; b.cnEcPad(2) &amp; i.cnEcPad(3), operator,
						"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
			self.move(ti, terminalAreas[app.random(TA_COUNT-1)+1].getLocationsController);
			self.deleteStops(ti);
			self.movePlannedRequestToJob(ti, slot, slot.getRequest(true));
		endforeach;
		
		delete slots;
	endforeach;
	
	self.logMessageNow("Load to Ops");
	self.loadAllJobsToOps(self.voyage, true);
	
	self.logMessageNow("Work the jobs");
	// Create Queues
	crane1 := self.getCrane(crane1Name);
	voyageQueue := self.addVoyageQueue(self.voyage);
	craneQueue := self.addVoyageCraneQueue(self.voyage, voyageQueue, crane1);
	crane2 := self.getCrane(crane2Name);
	craneQueue := self.addVoyageCraneQueue(self.voyage, voyageQueue, crane2);
	
	create tas transient;
	create voyageMachines transient;
	tas.add(self.bs1.id);
	tas.add(self.bs2.id);
	tas.add(crane1.transferArea.id);
	tas.add(crane2.transferArea.id);
	tas.add("DPIC1");
	
	foreach i in 1 to 5 do
		machine := self.getMachine(TSFKL&amp;i.String);
		voyageMachines.add(machine);
		self.machineAssignToQueue(machine, craneQueue);
		self.machineLogon(machine);
	endforeach;

	create wles transient;
	create machinePickupTime transient;
	create machineSetdownTime transient;
	create craneCompletedTime transient;

	// Sort wles into interleaving cranes
	create wlesByCrane transient;
	wlesByCrane.setMembership(CM_WorkListEntry);
	wlesByCrane.addExternalKey(String, 30, false, false);
	wlesByCrane.endKeys(true);
	
	i := 1;
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wlesByCrane.putAtKey(wle.job.CM_VoyageJob.getJobCrane().id, wle);
				//wles.add(wle);
				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	
	iterator1 := wlesByCrane.createIterator();
	wlesByCrane.startKeyGeq(CR1, iterator1);
	iterator2 := wlesByCrane.createIterator();
	wlesByCrane.startKeyGeq(CR2, iterator2);
	iterator3 := wlesByCrane.createIterator();
	wlesByCrane.startKeyGeq(CR3, iterator3);

	while true do
		iterator1.next(wle);
		if wle &lt;&gt; null and wle.job.CM_VoyageJob.getJobCrane().id = CR1 then
			wles.add(wle);
		endif;
		iterator2.next(wle);
		if wle &lt;&gt; null and wle.job.CM_VoyageJob.getJobCrane().id = CR2 then
			wles.add(wle);
		endif;
		iterator3.next(wle);
		if wle &lt;&gt; null and wle.job.CM_VoyageJob.getJobCrane().id = CR3 then
			wles.add(wle);
		endif;
		
		if iterator1.current(wle) or iterator2.current(wle) or iterator3.current(wle) then
			continue;
		endif;
		
		break;
	endwhile;
	
	
/*	i := 1;
	foreach request in voyageJob2.allRequests do
		foreach wle in request.allWorkListEntries do
			wles.insert(i, wle);
			i := i + 2;
			self.queueWLE(wle);
		endforeach;
	endforeach;
*/	
	
	startTime := app.actualTimeServer;
	finishTime := startTime.addSeconds(MAX_RUN_TIME);
	craneCompletedTime[1] := startTime;
	craneCompletedTime[2] := startTime;
	
	wlesToDo := wles.size;
	while currentDateTime &lt; finishTime and wlesCompleted &lt; wlesToDo do
		currentDateTime := app.actualTimeServer;
		self.logMessageNow(currentDateTime.asStringForWebInterface &amp; " WLEs completed: " &amp; wlesCompleted.String &amp; " WLEs ToDo: " &amp; (wlesToDo - wlesCompleted).String);
	
		voyageJobsComplete := true;
		foreach wle in wles where wle.status = WLE_UNACTIONED do
			if wle.job.isVoyageJob then
				voyageJobsComplete := false;
				break;
			endif;
		endforeach;
		
		// Time for another Truck Visit
		if nextVisitTime &lt; currentDateTime and nextVisitTime &lt; finishTime and not voyageJobsComplete then
			truckCount := truckCount + 1;
			self.deleteVehicle(TRUCK&amp;truckCount.String);
			self.deleteContainer(MTCONTAINER&amp; (10 + truckCount).String);
			vvr := self.gateInContainer(TRUCK&amp;truckCount.String, MTCONTAINER&amp; (10 + truckCount).String, "2200", operator.code, "MT", singleGate);
			self.moveVehicleToYard(vvr.vehicle);
			wle := vvr.vehicle.allRoadJobs.first.workListEntries.first;
			wles.insert(1, wle);
			wlesToDo := wlesToDo + 1;
			nextVisitTime := currentDateTime.addSeconds(VISIT_MIN + app.random(VISIT_RANGE));
			self.logMessageNow(currentDateTime.asStringForWebInterface &amp; " Create Truck Visit: " &amp; TRUCK&amp;truckCount.String &amp; " Cont: " &amp; MTCONTAINER&amp; (10 + truckCount).String);
		endif;
		
		// First look at all wles being worked
		foreach wle in wles do
		
			if wle.allRTQueueEntries.size &lt; 1 or wle.allRTQueueEntries.first.status &lt;&gt; ENTRY_WORKING then
				continue;
			endif;
			
			machine := wle.allRTQueueEntries.first.allTasks.first.machine;
			if machine = null then
				machine := wle.allRTQueueEntries.first.allTasks.last.machine;
			endif;
			assertNotNull(machine);
			
			machineIndex := machine.id[4].Integer - '0'.Integer;
			
			// Is the machine about to do a setdown?
			if machine.allCurrentQueueTasks.first.isSetDown and machineSetdownTime[machineIndex] &lt; currentDateTime then
				if wle.isReceipt or not wle.job.isVoyageJob then   // Complete the discharge into yard
					self.logMessageNow(currentDateTime.asStringForWebInterface &amp; " Machine: " &amp; machine.id &amp; " Setdown " &amp; wle.myTrackedItem.id);
					self.machineSetdownTask(machine, wle.allRTQueueEntries.first.allTasks.last, self.bs1.id);
					if wle.job.isRoadJob then
						self.roadExit(wle.job.CM_RoadJob.myVehicleVisit);
					endif;
					wlesCompleted := wlesCompleted + 1;
				else  // Try to complete load 
					crane := wle.job.CM_VoyageJob.getJobCrane();
					craneIndex := crane.id[3].Integer - '0'.Integer;
					// Is crane available to do the load
					if crane &lt;&gt; null and craneCompletedTime[craneIndex].addSeconds(CRANE_MIN + app.random(CRANE_RANGE)) &lt; currentDateTime then
						// Crane ready to do load so do the machine setdown which will also do the crane load
						self.logMessageNow(currentDateTime.asStringForWebInterface &amp; " Machine: " &amp; machine.id &amp; " Setdown " &amp; wle.myTrackedItem.id);
						self.machineSetdownTask(machine, wle.allRTQueueEntries.first.allTasks.last, wle.allRTQueueEntries.first.allTasks.last.targetLocationId);  
						craneCompletedTime[craneIndex] := currentDateTime;
						wlesCompleted := wlesCompleted + 1;
					endif;
				endif;
				continue;
			endif;
			
			// Is the machine about to do a pickup
			if machine.allCurrentQueueTasks.first.isPickUp and machinePickupTime[machineIndex] &lt; currentDateTime then
				if wle.isReceipt and wle.job.isVoyageJob then   // Complete the discharge into yard
					crane := wle.job.CM_VoyageJob.getJobCrane();
					craneIndex := crane.id[3].Integer - '0'.Integer;
					// Is crane available to do the discharge
					if crane &lt;&gt; null and craneCompletedTime[craneIndex].addSeconds(CRANE_MIN + app.random(CRANE_RANGE)) &lt; currentDateTime then
						ti1 := wle.myTrackedItem;
						ti2 := null;
						self.machineCraneActionPickup(machine, ti1, ti2);
						craneCompletedTime[craneIndex] := currentDateTime;
						self.logMessageNow(currentDateTime.asStringForWebInterface &amp; " Machine: " &amp; machine.id &amp; " Pickup " &amp; wle.myTrackedItem.id);
						self.machinePickup(machine);
						machineSetdownTime[machineIndex] := currentDateTime.addSeconds(MACHINE_MIN + app.random(MACHINE_RANGE));
					endif;
				else
					self.logMessageNow(currentDateTime.asStringForWebInterface &amp; " Machine: " &amp; machine.id &amp; " Pickup " &amp; wle.myTrackedItem.id);
					self.machinePickup(machine);
					machineSetdownTime[machineIndex] := currentDateTime.addSeconds(MACHINE_MIN + app.random(MACHINE_RANGE));
				endif;
			endif;
		endforeach;
		
		// remove any road job wles that have been completed
		wles.removeInvalidObjects;
		
		// Assign tasks to idle voyageMachines
		foreach machine in voyageMachines do
			machineIndex := machine.id[4].Integer - '0'.Integer;
			if machine.status.status = STATUS_IDLE then
				foreach wle in wles where wle.status = WLE_UNACTIONED do
					self.logMessageNow(currentDateTime.asStringForWebInterface &amp; " Machine: " &amp; machine.id &amp; " Accept " &amp; wle.myTrackedItem.id);
					self.machineAcceptTask(machine, wle.allRTQueueEntries.first.allTasks.first);
					machinePickupTime[machineIndex] := currentDateTime.addSeconds(MACHINE_MIN + app.random(MACHINE_RANGE));
					break;
				endforeach;
			endif;
		endforeach;
		
		process.sleep(SLEEP*1000);    // 10 seconds
	endwhile;

	foreach machine in voyageMachines do
		self.machineLogOff(machine);
	endforeach;

	self.logMessageNow(currentDateTime.asStringForWebInterface &amp; " Simulation Complete");
	
epilog

	delete slots;
	delete jobs;
	delete terminalAreas;
	delete cargo;
	delete tas;
	delete wles;
	delete voyageMachines;
	delete machinePickupTime;
	delete machineSetdownTime;
	delete craneCompletedTime;
	delete wlesByCrane;
	delete iterator1;
	delete iterator2;
	delete iterator3;
end;</source>
    </JadeMethod>
    <JadeMethod name="uRunTerminalSimulation1" id="92184be2-9950-4fb1-8b54-f3586b8b9f4d">
        <updating/>
        <source>uRunTerminalSimulation1() updating;
/*

*/
constants
	PREFIX = "X";

	SCALE = 1;    // Slow the run by increasing the SCALE factor
	
	// All times in seconds
	CRANE_MIN = 3 * SCALE;
	CRANE_MAX = 6 * SCALE;
	MACHINE_MIN = 9 * SCALE;
	MACHINE_MAX = 30 * SCALE;

vars
	terminal: SIM_Terminal;
	voyage1: SIM_Voyage;
	startTime, finishTime: TimeStamp;
	exports, imports: CM_TISet;
	iter: Iterator;
	txn: CM_Transaction;

begin
	app.seedRandom(1999);
	startTime := app.actualTimeServer;
	
	create terminal;
	terminal.add(self, PREFIX, 5, SIM_Object.LOG_BRIEF);
	terminal.addBlockStacks("BS", 3, 10);
	terminal.addCranes("CR", 2, CRANE_MIN, CRANE_MAX);
	terminal.addForklifts("FL", 5, MACHINE_MIN, MACHINE_MAX);
	terminal.addMachineRules("CR1 CR2", SIM_Terminal.MACHINE_RULE_FORKLIFT);
	
	create voyage1;
	voyage1.add(terminal, "SIM1", 2, 2);
	voyage1.useTerminalArea("BS1 BS2 BS3");
	voyage1.useCrane("CR1 CR2");
	voyage1.plan();
	voyage1.queue();
	voyage1.assignMachineToCraneQueue("FL1 FL2", "CR1");
	voyage1.assignMachineToCraneQueue("FL3 FL4 FL5", "CR2");
	
	terminal.addWorkForVoyage(voyage1);
	terminal.displayTasks();
	
	terminal.workMachines();
	finishTime := app.actualTimeServer;
	
	self.xGetMovements(startTime, finishTime);
	
	// Check txns
	create imports transient;
	voyage1.getImports(imports);
	iter := imports.first.allTransactions.createIterator;
	iter.back(txn);
	self.assertTrue(txn.isA(CM_SetDown));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Pickup));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Move));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Wharfage));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_ReceiveShip));
	delete iter;
	
	create exports transient;
	voyage1.getExports(exports);
	iter := exports.first.allTransactions.createIterator;
	iter.back(txn);
	self.assertTrue(txn.isA(CM_SetDown));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Wharfage));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_ReleaseShip));
	iter.back(txn);
	self.assertTrue(txn.isA(CM_Pickup));
	delete iter;
	
epilog
	delete terminal;
	delete voyage1;
	delete imports;
	delete exports;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="uRunTerminalSimulation2" id="c897aaa3-8999-49cf-b89b-6e250dc0a1e2">
        <updating/>
        <source>uRunTerminalSimulation2() updating;
/*

*/
constants
	PREFIX = "A";

	SCALE = 1;    // Slow the run by increasing the SCALE factor
	
	// All times in seconds
	CRANE_MIN = 3 * SCALE;
	CRANE_MAX = 6 * SCALE;
	MACHINE_MIN = 9 * SCALE;
	MACHINE_MAX = 30 * SCALE;

vars
	terminal: SIM_Terminal;
	voyage1: SIM_Voyage;
	startTime, finishTime: TimeStamp;

begin
	app.seedRandom(1999);
	startTime := app.actualTimeServer;
		
	create terminal;
	terminal.add(self, PREFIX, 5, SIM_Object.LOG_FULL);
	terminal.addBlockStacks("BS", 3, 10);
	terminal.addCranes("CR", 2, CRANE_MIN, CRANE_MAX);
	terminal.addIMVs("MV", 4, MACHINE_MIN, MACHINE_MAX);
	terminal.addForklifts("FL", 4, MACHINE_MIN, MACHINE_MAX);
	terminal.addMachineRules("CR1 CR2", SIM_Terminal.MACHINE_RULE_IMV);
	
	create voyage1;
	voyage1.add(terminal, "SIM2", 2, 2);
	voyage1.useTerminalArea("BS1 BS2 BS3");
	voyage1.useCrane("CR1 CR2");
	voyage1.plan();
	voyage1.queue();
	voyage1.assignMachineToCraneQueue("FL1 FL2 MV1 MV2", "CR1");
	voyage1.assignMachineToCraneQueue("FL3 FL4 MV3 MV4", "CR2");
		
	terminal.addWorkForVoyage(voyage1);
	terminal.displayTasks();
	terminal.workMachines();
	finishTime := app.actualTimeServer;
	
	self.xGetMovements(startTime, finishTime);

epilog
	delete terminal;
	delete voyage1;
end;</source>
    </JadeMethod>
    <JadeMethod name="uRunTerminalSimulation3" id="817f219a-89a0-4dee-8fd3-7288a131d485">
        <updating/>
        <source>uRunTerminalSimulation3() updating;
/*

*/
constants
	PREFIX = "A";

	SCALE = 1;    // Slow the run by increasing the SCALE factor
	
	// All times in seconds
	CRANE_MIN = 3 * SCALE;
	CRANE_MAX = 6 * SCALE;
	MACHINE_MIN = 9 * SCALE;
	MACHINE_MAX = 18 * SCALE;
	GATE_MIN = 20 * SCALE;
	GATE_MAX = 40 * SCALE;

vars
	terminal: SIM_Terminal;
	voyage1: SIM_Voyage;
	gate1: SIM_Gate;

begin
	app.seedRandom(1999);
	
	create terminal;
	terminal.add(self, PREFIX, 5, SIM_Object.LOG_BRIEF);
	terminal.addBlockStacks("BS", 3, 10);
	terminal.addCranes("CR", 2, CRANE_MIN, CRANE_MAX);
	terminal.addForklifts("FL", 7, MACHINE_MIN, MACHINE_MAX);
	terminal.addMachineRules("CR1 CR2", SIM_Terminal.MACHINE_RULE_FORKLIFT);
	
/*	create voyage1;
	voyage1.add(terminal, "SIM3", 2, 2);
	voyage1.useTerminalArea("BS1 BS2");
	voyage1.useCrane("CR1 CR2");
	voyage1.plan();
	voyage1.queue();
	voyage1.assignMachineToCraneQueue("FL1 FL2", "CR1");
	voyage1.assignMachineToCraneQueue("FL3 FL4 FL5", "CR2");
*/	
	create gate1;
	gate1.add(terminal, "SGATE1", GATE_MIN, GATE_MAX);
	gate1.useTerminalArea("BS3");
	//gate1.assignMachineToGateQueue("FL6 FL7");
	
	//terminal.addWorkForVoyage(voyage1);
	terminal.displayTasks();
	//terminal.workMachines();

epilog
	delete terminal;
	delete voyage1;
end;</source>
    </JadeMethod>
    <JadeMethod name="uSetupTerminalForSimulation" id="bb0a981b-77d3-497d-b9bf-3f6f5b4b5958">
        <updating/>
        <source>uSetupTerminalForSimulation() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2012	cnwdw1	Initial creation
*/
vars
	 crane1, crane2: CM_Crane;
	 bs1, bs2: CM_BlockStack;
	 tas: StringArray;
	 i: Integer;
	 
	ica : CM_YardInterchangeArea;
	taSet : CM_TerminalAreaSet;
begin
	
	self.logMessageNow("Setup Terminal for Simulation");
	
	bs1 := addBlockStack(BS1, 500, null);
	self.addYACatchAll(self.getProfileSetting(UT_Profile.P_YA).asString, bs1);

	bs2 := addBlockStack(BS2, 500, null);
	
	crane1 := self.getCrane(CR1);
	crane2 := self.getCrane(CR2);
	
	create taSet transient;
	taSet.add(bs1);
	taSet.add(bs2);
	taSet.add(crane1.transferArea);
	taSet.add(crane2.transferArea);
	taSet.add(self.getTerminalArea("BS1"));
	self.deleteTerminalArea(ICA);
	ica := self.addInterchangeArea(ICA, taSet);
	
	self.addMachineRule (crane1.transferArea, bs1, RTMoveMethod_24);
	self.addMachineRule (crane2.transferArea, bs1, RTMoveMethod_24);
	self.addMachineRule (crane1.transferArea, bs2, RTMoveMethod_24);
	self.addMachineRule (crane2.transferArea, bs2, RTMoveMethod_24);

	self.addMachineRule (bs1, crane1.transferArea, RTMoveMethod_24);
	self.addMachineRule (bs1, crane2.transferArea, RTMoveMethod_24);
	self.addMachineRule (bs2, crane1.transferArea, RTMoveMethod_24);
	self.addMachineRule (bs2, crane2.transferArea, RTMoveMethod_24);

	self.logMessageNow("Create Machines");
	create tas transient;
	tas.add(bs1.id);
	tas.add(bs2.id);
	tas.add(crane1.transferArea.id);
	tas.add(crane2.transferArea.id);
	tas.add(ica.id);
	
	foreach i in 1 to 5 do
		self.addForkLift(TSFKL&amp; i.String, 90+i, tas, null);
	endforeach;

epilog
	delete tas;
	delete taSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="xGetMovements" id="cdba156b-d021-4198-897d-76f0ea777656">
        <source>xGetMovements(_from, _too: TimeStamp);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2012	cnwdw1	Initial creation
*/
vars
	agent: CM_KEAAgent;
	movements: CM_KPIMovementDtlArray;
	movement: CM_KPIMovementDtl;
	leg: CM_KPIMovementLegDtl;
	from, too: String;
	message: String;
	errorCount: Integer;
	lastTarget: String;
	errorList: StringArray;
begin
	create agent transient;
	create movements transient;

	agent.getMovements(_from, _too, app.myPassport.myTerminal, movements);
	//movements.inspectModal;
	foreach movement in movements do
		message := "";
	    if movement.allMovementLegs.size = 0  or 
		   //movement.source = null or movement.sourceType = null or movement.target = null or movement.targetType = null or
		   (not movement.isInstantMove and movement.sourceType = "SHIP" and movement.allMovementLegs.size &lt; 2) or
		   (not movement.isInstantMove and movement.targetType = "SHIP" and movement.allMovementLegs.size &lt; 2) then		   
			message := "****";
			errorCount := errorCount + 1;
		endif;
		self.logMessageNow(message &amp; movement.displayString);
		lastTarget := null;
		foreach leg in movement.allMovementLegs do
			message := "";
			if //leg.source = null or leg.sourceType = null or leg.target = null or leg.targetType = null or
			   (lastTarget &lt;&gt; null and leg.source &lt;&gt; lastTarget) or
			   not leg.finishTime.isValid or not leg.startTime.isValid then
				message := "****";
				errorCount := errorCount + 1;
		   endif;
		   lastTarget := leg.target;
			self.logMessageNow("  "&amp; message &amp; leg.displayString);
		endforeach;
		
	endforeach;
		
	self.logMessage("Found " &amp; errorCount.String &amp; " Errors");
	
	assertEqual(errorCount, 0);
	
//	foreach movement in movements do
//		create ws_movement transient;
//		ws_movement.setFrom(movement);
//		response.allMovements.add(ws_movement);
//	endforeach;

epilog
	delete agent;
	movements.purge;
	delete movements;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_too" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="xGetShipMovements" id="02e35edf-2561-4926-b4aa-cac2da6d3ba3">
        <source>xGetShipMovements(_from, _too: TimeStamp);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2012	cnwdw1	Initial creation
*/
vars
	agent: CM_KEAAgent;
	movements: CM_KPIMovementDtlArray;
	movement: CM_KPIMovementDtl;
	leg: CM_KPIMovementLegDtl;
	message: String;
	errorCount: Integer;
	lastTarget: String;
	errorList: StringArray;
begin
	create agent transient;
	create movements transient;

	agent.getMovements(_from, _too, app.myPassport.myTerminal, movements);

	foreach movement in movements do
		if movement.sourceType &lt;&gt; "SHIP" and movement.targetType &lt;&gt;"SHIP" then
			continue;
		endif;
		
		message := "";
	    if movement.allMovementLegs.size = 0  or 
		   movement.source = null or movement.sourceType = null or movement.target = null or movement.targetType = null or
		   (not movement.isInstantMove and movement.sourceType = "SHIP" and movement.allMovementLegs.size &lt; 2) or
		   (not movement.isInstantMove and movement.targetType = "SHIP" and movement.allMovementLegs.size &lt; 2) then		   
			message := "****";
			errorCount := errorCount + 1;
		endif;
		self.logMessageNow(message &amp; movement.displayString);
		lastTarget := null;
		foreach leg in movement.allMovementLegs do
			message := "";
			if leg.source = null or leg.sourceType = null or leg.target = null or leg.targetType = null or
			   (lastTarget &lt;&gt; null and leg.source &lt;&gt; lastTarget) or
			   not leg.finishTime.isValid or not leg.startTime.isValid then
				message := "****";
				errorCount := errorCount + 1;
		   endif;
		   lastTarget := leg.target;
			self.logMessageNow("  "&amp; message &amp; leg.displayString);
		endforeach;
		
	endforeach;
		
	self.logMessageNow("Found " &amp; errorCount.String &amp; " Errors");
	
	assertEqual(errorCount, 0);
	

epilog
	delete agent;
	movements.purge;
	delete movements;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_too" type="TimeStamp"/>
    </JadeMethod>
</Class>
