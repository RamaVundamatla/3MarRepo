    <JadeMethod name="canUserAccessSelf" id="9bee90f9-aecd-4353-81b6-84cbd2841bc5">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport : CM_Passport): Boolean;
//--------------------------------------------------
// Created:	13 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpUser : CM_User;
begin
	if _user &lt;&gt; null then
		return _user.getUserTerminal(self) &lt;&gt; null;
	elseif _passport &lt;&gt; null then
		tmpUser := _passport.myUser;
		if tmpUser &lt;&gt; null then
			return tmpUser.getUserTerminal(self) &lt;&gt; null;
		endif;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="ccms1061_conversion_areas" id="35f07aa2-3f4a-4fea-ac46-5e163e2a0b69">
        <source>ccms1061_conversion_areas();
// ---------------------------------------------------------------------------
// Created:     08 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	gate	:CM_Gate;
	master	:CM_TerminalAreaMaster;
	area	:CM_TerminalArea;
	icArea	:CM_InterchangeArea;
	str		:String;
begin
	str	:= 'Starting ' &amp; method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT &amp; Tab &amp;
			'Terminal'  &amp; Tab &amp; self.code;

	app.writeStatement( str );
	app.writeLog( str, LogINFO );
	
	// all interchange areas will have their default out gate set to the default gate
	// all terminal areas will have their associated interchange set to the interchange area
	// for the default gate
	gate 	:= self.getDefaultGate_OUT;
	
	if gate &lt;&gt; null then
		icArea 	:= gate.myDefaultInterchangeArea;
	endif;
	
	if icArea &lt;&gt; null then
		beginTransaction;
		foreach master in self.allTerminalAreasByTypeId do
			if not master.isTAArea then
				continue;
			endif;
			area := master.CM_TerminalArea;
			
			if area.isInterchangeArea then
				// set default out-gate
				if area.CM_InterchangeArea.myDefaultOutGate = null then
					area.setPropertyValue (CM_InterchangeArea::myDefaultOutGate.name, gate);
				endif;
			else
				// set associated interchange area
				if area.allAssociatedInterchangeAreas.isEmpty then
					area.allAssociatedInterchangeAreas.add (icArea);
				endif;
			endif;
		endforeach;
		commitTransaction;
	endif;
	str	:= 'Completed ' &amp; method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT &amp; Tab &amp;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			'Terminal'  &amp; Tab &amp; self.code;
	
	app.writeStatement( str );
	app.writeLog( str, LogINFO );	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ccms1061_conversion_rules" id="863055a4-39f8-4945-a3a9-7d7c4c59d3ed">
        <source>ccms1061_conversion_rules();
// ---------------------------------------------------------------------------
// Created:     08 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	vtaType, icAreaType, 
	gateAreaType	:CM_TerminalAreaType;
	rule, pxyRule	:CM_RTQueueMultiRuleTAType;
	newRule			:CM_RTQueueMultiRule;
	error			:CM_Error;
	str				:String;
begin
	str	:= 'Starting ' &amp; method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT &amp; Tab &amp;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			'Terminal'  &amp; Tab &amp; self.code;

	app.writeStatement( str );
	app.writeLog( str, LogINFO );
	
	icAreaType 		:= self.myRoot.allTerminalAreaTypes[TA_TYPE_YARD_INTERCHANGE];
	gateAreaType 	:= self.myRoot.allTerminalAreaTypes[TA_TYPE_GATE_ROAD];
	vtaType 		:= self.myRoot.allTerminalAreaTypes[TA_TYPE_ROAD_TRANS];	// leave till after conversion
	
	beginTransaction;
	// now make sure that we create Machine Rules that correspond to the old VTA Machine Rules
	foreach rule in self.allRTQueueMultiRuleTATypes do 
		if rule.myFromTAType &lt;&gt; vtaType and
			rule.myToTAType &lt;&gt; vtaType then
			continue;	// not one we are interested in
		endif;
		// i will update this rule to be for yard interchange areas and
		// also create a corresponding rule for gate areas
		if rule.myFromTAType = vtaType then
			
			rule.setPropertyValue (CM_RTQueueMultiRuleTAType::myFromTAType.name, icAreaType);
			
			create pxyRule transient;
			pxyRule.setForProxyTAType (gateAreaType, rule.myToTAType,  rule.myTerminal);
			
			app.myUtilityCA.utlCreateRTQueueMultiRule (pxyRule, newRule, app.myPassport);
		endif;
		if rule.myToTAType = vtaType then
			rule.setPropertyValue (CM_RTQueueMultiRuleTAType::myToTAType.name, icAreaType);
			
			create pxyRule transient;
			pxyRule.setForProxyTAType (rule.myFromTAType, gateAreaType,  rule.myTerminal);
			
			app.myUtilityCA.utlCreateRTQueueMultiRule (pxyRule, newRule, app.myPassport);
		endif;
		if app.myPassport.hasErrors then
			str := 'Errors have occured during rules conversion.' &amp; CrLf;
			
			foreach error in app.myPassport.allErrorWarnings do
				str := str &amp; error.errorCode.String &amp; ": " &amp; error.text &amp; CrLf;
			endforeach;
			
			app.writeStatement( str );
			app.writeLog( str, LogINFO );
		endif;
	endforeach;
	commitTransaction;
	
	str	:= 'Completed ' &amp; method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT &amp; Tab &amp;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			'Terminal'  &amp; Tab &amp; self.code;
	
	app.writeStatement( str );
	app.writeLog( str, LogINFO );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ccms1061_conversion_unknownLC" id="60bdebc9-242d-41ab-bf17-dc54f010ff63">
        <source>ccms1061_conversion_unknownLC();
// ---------------------------------------------------------------------------
// Created:     08 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	unknownLC	:CM_YardController;
	vehicle		:CM_VehicleMachine;
	job			:CM_RoadJob;
	gate		:CM_Gate;
	icArea		:CM_InterchangeArea;
	vc			:CM_VehicleController;
	str			:String;
begin
	str	:= 'Starting ' &amp; method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT &amp; Tab &amp;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			'Terminal'  &amp; Tab &amp; self.code;

	app.writeStatement( str );
	app.writeLog( str, LogINFO );
	
	gate	:= self.getDefaultGate_IN;
	
	if gate &lt;&gt; null then
		icArea	:= gate.myDefaultInterchangeArea;
	endif;
	
	// we are just trying to catch any leftover vehicles
	unknownLC := self.myRoadJobSheet.myInTerminalUnknownLC;

	if icArea &lt;&gt; null and unknownLC &lt;&gt; null then
		beginTransaction;
		foreach vehicle in unknownLC.allVehicleMachines do
			if not vehicle.isKindOf (CM_Vehicle) then
				continue;
			endif;
			
			job := vehicle.CM_Vehicle.allRoadJobs.first.CM_RoadJob;
			
			if job &lt;&gt; null then
				if job.isCompleteForExit then
					vehicle.setMyPrimaryActualLocation (icArea.myInTransitFromLocation, false);
				else
					vehicle.setMyPrimaryActualLocation (icArea.myInTransitToLocation, false);
				endif;
				
				// belt and braces - make sure the in terminal job sheet is set
				if vehicle.CM_Vehicle.myInTerminalJobSheet = null then
					vehicle.CM_Vehicle.setMyInTerminalJobSheet (self.myRoadJobSheet);
				endif;
			else
				vehicle.setMyPrimaryActualLocation (null,false);
			endif;
			
			// make sure the vehicle does not reference the deleted VTA
			vc := vehicle.CM_Vehicle.locationsController;
				
			if vc &lt;&gt; null and vc.myTerminalArea &lt;&gt; null and not global.isValidObject (vc.myTerminalArea) then
				vc.setMyTerminalArea (null);
			endif;
		endforeach;
		
		if unknownLC.allVehicleMachines.size &gt; 0 then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Unknown location still has vehicles');
		endif;
		
		commitTransaction;
	endif;
	
	str	:= 'Completed ' &amp; method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT &amp; Tab &amp;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			'Terminal'  &amp; Tab &amp; self.code;
	
	app.writeStatement( str );
	app.writeLog( str, LogINFO );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkHMSVoyageCode" id="8fafc624-408d-400a-8973-12f464f218d6">
        <source>checkHMSVoyageCode(_code : String; _passport : CM_Passport) : String;
//--------------------------------------------------
// Created:	23 August 2004 By: cnwgd1
//--------------------------------------------------
//_code is the new scenario voyage system code, return new code if already used
vars

begin
	
	if _code = null then
		return self.getHMSNextVoyageCode();
	endif;
	
	if self.lookupVoyage(_code, null, false) &lt;&gt; null then
		return self.getHMSNextVoyageCode();
	endif;
	
	return _code;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkIfDaylightSaving" id="e3e483be-4aa1-4511-9751-be74400d63ce">
        <source>checkIfDaylightSaving(_time : TimeStamp; _clocksChangeToday : Boolean output) : Boolean;
//--------------------------------------------------
// Created:	27 April 2005 By: cnwgd1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/08/2010	cnwdad1		PAR #20064.
// --------------------------------------------------------------------------------
vars
	zone : String;
begin
	if (not _time.isValid) then
		return false;
	endif;
	//----------------------------------------------------------------
	//TEMPORARY - NO GOOD FOR MULTI HARBOUR IN DIFFERENT TIME ZONES
	//HARBOUR WILL NEED TO KNOW WHAT TIME ZONE TO USE
	//----------------------------------------------------------------
// cnwdad1 31/08/2010 - PAR #20064.
//	zone := app.currentLocaleInfo.englishCountryName;
	zone := app.getMyLocaleInfoJMT().englishCountryName;
	
	//20 Mar 2012	NDL	Par 28251
	if self.myHarbour &lt;&gt; null then
		zone := self.myHarbour.getTimezoneDescr();	
	endif;
	
	//THE BELOW METHOD IS NEW ZEALAND SPECIFIC
	return _time.checkIfDaylightSaving(_clocksChangeToday, zone);
end;</source>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_clocksChangeToday" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkVesselHasFutureVoyage" id="a824951c-a177-46f5-9d85-1ec9b4c7e0cc">
        <source>checkVesselHasFutureVoyage(_vesselCode : String; _fromDT : TimeStamp) : Boolean;
//--------------------------------------------------
// Created:	06 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	iter : Iterator;
	tmpVoyage : CM_Voyage;
	tmpFromDT : TimeStamp;
begin
	
	if (not _fromDT.isValid) then
		tmpFromDT := app.actualTimeServer();
	else
		tmpFromDT := _fromDT;
	endif;
	
	iter := self.allVoyagesByVesselCodeArrivDT.createIterator;
	
	// need to check the departed date, not the arrival so don't use tmpFromDT as iter key
	self.allVoyagesByVesselCodeArrivDT.startKeyGeq(_vesselCode, null, iter);
	
	while iter.next(tmpVoyage) do
		if tmpVoyage.vesselCode &lt;&gt; _vesselCode then
			break;
		endif;
		if (not tmpVoyage.departedDT.isValid) then
			// hasn't departed therefore it qualifies
			return true;
		elseif tmpVoyage.departedDT &gt;= tmpFromDT then
			// departs sometime after date to check therefore it qualifies		
			return true;
		endif;
	endwhile;
	
	// no match found
	return false;
epilog
	delete iter;	
end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_fromDT" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="c5f80067-c0c1-487b-90b6-fe6d3ed00f90">
        <updating/>
        <source>create() updating;

/*
Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
14/07/16	cnwns1		TFS 2300 	Multi-timezone not set by default - gives error	
18 Sep 2018	jlgrs1		TFS 40627 STWR Make EDI MultiThreaded
10 Sep 2019	jlgdi1		45802	Added a method call on addTerminalToInternalUser
19 Aug 2020 cnwma1 		ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
03 May 2023	navhl20		ChangeRequest 57712:[54558] EUP - Delivery Dispatch – Adding Work Point Types
--------------------------------------------------------------------------- */

vars
	aRT: CM_RadioTelemetry;
	aEC: CM_EDIConfig;
	callStack		: ProcessStackArray;
	methCallDesc	: MethodCallDesc;
	found			: Boolean;
	root			: CM_Root;
	nulltrain : CM_NullTrain;
	superUser, proxyUser : CM_User;
	pxyUT, userTerm	 : CM_UserTerminal;
	secRole : CM_SecurityRoleTerminal;	
	internalUser : CM_User;
	
begin

	if self.isTransient then
		return;
	endif;
	
	// Validate that this was called from a "licensed call"
	create callStack transient;
	process.currentStack(callStack);
	
	foreach methCallDesc in callStack do
	    if methCallDesc.getReceiver.class = CM_UtilityCreateAgent and
	       methCallDesc.method.name = 'utlCreateTerminal' then
	    	found := true;
	    endif;
	endforeach;
	
	if (not found) then
		// do NOT give an error/exception here as this would enable users
		// to more easily trace back to this method as the one causing the problem
		delete self;
		return;
	endif;
	
	self.initLayout(); //c method

	self.createJobSheets();

	//Populate a NULL Voyage object
	self.createNullVoyage();

	//Create the r/t control object
	create aRT persistent;
	self.radioTelemetry := aRT;
	self.radioTelemetry.createMasterQueue;
	
	self.createTerminalAreaForOps();
	
	create aEC persistent;
	root := CM_Root.firstInstance;
	if root.myEdiConfig = null then
		aEC.setForCreate(self, root);
	else
		aEC.setForCreate(self, null);
	endif;
	
	//th2 added 01/07/2007
	self.setupPINEmailDefaults();
	
	self.setConfig(DefYardBackColSelected,Gray);
	self.setConfig(DefYardBackColUnselected,Gray);

	//cnwjo3 par 24883
	self.setConfig(IncludeLQasHazardous,true);  //make this the default value for terminal
	
	//cnwmc5 - PAR #30949
	if root.isDeprecated("8.1.2") then
		self.setConfig(UseBookingSummView, true);
	endif;
	
	//0 i.e. default is invalid on terminal, set to None.;
	self.sealCheckPack := SEAL_CHECK_NONE;
	self.sealCheckRailReceival := SEAL_CHECK_NONE;
	self.sealCheckRailRelease := SEAL_CHECK_NONE;
	self.sealCheckRoadReceival := SEAL_CHECK_NONE;
	self.sealCheckRoadRelease := SEAL_CHECK_NONE;
	self.sealCheckShipReceival := SEAL_CHECK_NONE;
	self.sealCheckShipRelease := SEAL_CHECK_NONE;
	self.sealCheckUnpack := SEAL_CHECK_NONE;
	
	create nulltrain;
	nulltrain.init(self);
	
	//epr 12/12/12 HAT 2189
	self.createDutyDocTerminalRoot();
	
	//08 Apr 2013	NDL	Par 31393
	self.createVehicleBookingTerm();
	
	//14/07/16		cnwns1		TFS 2300 	Multi-timezone not set by default - gives error	
	self.setTimeZoneID(app.systemTimeZoneID);
	

	addTerminalToInternalUser(SUPERUSER_Str);
	addTerminalToInternalUser(JMTSUPPORT_Str);	  // 45802
	addTerminalToInternalUser(OPSVIEWUSER_Str);	  //21.09.2020 cnwma1 TFS #49758
	
//	self.initBGPMutex();                          // 18 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	self.addUpdateTerminalMutexes();	//15 Sep 2021	NDL	TFS 51142
	
	self.createWorkPointTypeShip();				//3.5.2023 navhl20 57712[54558]
epilog
	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;
	delete pxyUT;
	delete proxyUser;
end;</source>
    </JadeMethod>
    <JadeMethod name="createAlert" id="cd2b3653-7107-482a-a048-05a42b52417b">
        <source>createAlert(errorNum	:	Integer);
// ---------------------------------------------------------------------------
// Created:			25 May 2001 by cnwdwq1
// Purpose:			Called from C++     
//Can be called even when a trans is puking, alert guananteed to be there!
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	alert	:	CM_SystemAlert;
begin
	create alert transient;
	alert.details := "System Alert. Double-click to view details...";
	alert.addLogEntry(app.getErrorString(errorNum));
	alert.setSeverity(SEVERE_WARNING);
	//-----------------
	//pass the alert object back.
	//------------------
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
end;</source>
        <Parameter name="errorNum" type="Integer"/>
    </JadeMethod>
