    <JadeMethod name="addObjectsToTable" id="c97ff6b6-70bd-446d-aab0-66c0d4968648">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	objSet				: ObjectSet;
	obj					: Object;
	breakOut			: Boolean;
	reportType,
	numItems			: Integer;	
	
begin
	create objSet transient;
	self.tblData.rows := self.tblData.fixedRows;
	
	reportType := self.cmbReportFilter.itemData[self.cmbReportFilter.listIndex];	
	app.myRoot.getQryReportsOfType(objSet, reportType);
					
	foreach obj in objSet do
		numItems := numItems + 1;

		self.addObjectToTable(obj, numItems, breakOut);
		if breakOut then
			break;
		endif;
	endforeach;

epilog
	delete objSet;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addSystemTypeToCombo" id="6c33658c-0975-4aa4-b2f7-2a81635248e0">
        <source>addSystemTypeToCombo() protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx				: Integer;
begin
	idx := self.cmbReportType.findString(1, CM_QryReport.ReportTypeDescr_SystemDefined);
	if idx &lt;= 0 then
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReport.ReportTypeDescr_SystemDefined)] := CM_QryReport.ReportType_SystemDefined;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addTblParamDataRow" id="5f458d9b-db75-4b4f-b38b-3df033d2e2cc">
        <source>addTblParamDataRow(_qryParam : CM_QueryReportParam; _entDef : EntTableDef; _idx : Integer) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str				: String;
	entRow			: EntTableRow;
	idx				: Integer;
	entRowName : String;
begin
	if _entDef = null or _qryParam = null then
		return null;
	endif;
	
	foreach entRow in _entDef.allEntTableRows do
		entRowName := entRow.name;
		if _qryParam.type = Date.number and 
		   entRow.name = ETRow_DefaultValData then
			entRowName := ETRow_DefaultValDate;
		endif;
		if _qryParam.type = Time.number and 
		   entRow.name = ETRow_DefaultValData then
			entRowName := ETRow_DefaultValTime;
		endif;
		str := str &amp; _qryParam.getDisplayStringForAttribute(entRowName, null) &amp; Tab;
	endforeach;
	
	if _idx = null then
		idx := self.tblParamData.addItem(str);
	else
		self.tblParamData.addItemAt(str, _idx);
		idx := _idx;
	endif;
	
	self.tblParamData.accessRow(idx).itemObject := _qryParam;
end;</source>
        <access>protected</access>
        <Parameter name="_qryParam" type="CM_QueryReportParam"/>
        <Parameter name="_entDef" type="EntTableDef"/>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="58854035-5d69-421a-b2ab-d22d2aa7d7db">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar:= self.frmToolbar;
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
