		self.myUpdateAuditAgent.audUpdateGeneric(realDutyDocType, true);
	endif;
	
	if _passport.noErrors then
		realDutyDocType.setForUpdate(_proxyDutyDocType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDutyDocType, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyDutyDocType" type="CM_DutyDocType" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDwellDayRange" id="4c5e6051-1de9-410d-8427-4f2236bb9a78">
        <source>utlUpdateDwellDayRange(pProxyDwellDayRange:CM_DwellDayRange; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars
	cancelSave:Boolean;
	realDwellDayRange:CM_DwellDayRange;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	
begin

	self.initialiseActivity();

	pProxyDwellDayRange.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyDwellDayRange.pxyGetRealObjectAndEdition(realDwellDayRange, expectedEdition);
	
	if realDwellDayRange = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DwellDayRange.name, null, null);
		return;
	endif;

	app.myValUA.valDwellDayRange(realDwellDayRange, pProxyDwellDayRange);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realDwellDayRange);

	if _passport.noErrors and realDwellDayRange.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'DwellDayRange', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDwellDayRange, true);
	endif;
	
	if _passport.noErrors then
		if realDwellDayRange.colour &lt;&gt; pProxyDwellDayRange.colour then
			codeChanged := true;
		endif;
		realDwellDayRange.setForUpdate(pProxyDwellDayRange);
	endif;

	if _passport.noErrors then
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realDwellDayRange.upper.String  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realDwellDayRange.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realDwellDayRange.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realDwellDayRange, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyDwellDayRange" type="CM_DwellDayRange"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIAction" id="2b9e6d38-7f39-46f6-be79-fa6f25121bd3">
        <updating/>
        <source>utlUpdateEDIAction(_pxyEDIAction : CM_EDIAction input; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	realEDIAction	: CM_EDIAction;
	expectedEdition	: Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	if _pxyEDIAction = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'the proxy object is null');
		return;
	endif;
	
	_pxyEDIAction.pxyGetRealObjectAndEdition(realEDIAction, expectedEdition);
	
	if realEDIAction = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EDIAction.name, null, null);
		return;
	endif;

	_pxyEDIAction.validateForUpdate(); //cnwgb1 17.9.08 CCMS SFW 1012 Customs AMS Interface (PAR 17931)
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realEDIAction);

	if _passport.noErrors and realEDIAction.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'country', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEDIAction, true);
	endif;
	
	if _passport.noErrors then
		realEDIAction.setForUpdate(_pxyEDIAction);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEDIAction, false);
	endif;
	
end;</source>
        <Parameter name="_pxyEDIAction" type="CM_EDIAction" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIAutoMove" id="7967f4ab-4e4e-4436-a25f-7c6930a91f69">
        <updating/>
        <source>utlUpdateEDIAutoMove(_pxyObject : CM_EDIAutoMovements; _passport : CM_Passport input) updating;
// ##### CR 64615 TASK 64646 NAVAB1 03JUL2024
vars
	realObject		: CM_EDIAutoMovements;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'EDIAutoMove');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valEDIAutoMove(_pxyObject);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'EDIAutoMove', _passport).CM_EDIAutoMovements;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyObject);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_EDIAutoMovements"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDICompCon" id="196f6d0c-ef20-4eb1-83f5-a81dd643d54d">
        <updating/>
        <source>utlUpdateEDICompCon(_pxyObject : CM_EDIComparisonConfig; _passport : CM_Passport input) updating;
// ##### CR 64614 TASK 64643 NAVAB1 03JUL2024
vars
	realObject		: CM_EDIComparisonConfig;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'EDICompCon');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valEDICompCon(_pxyObject);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'EDICompCon', _passport).CM_EDIComparisonConfig;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyObject);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_EDIComparisonConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDICustomStop" id="86688062-9fde-40a1-91b9-a029c0704326">
        <updating/>
        <source>utlUpdateEDICustomStop(_pxyTI: CM_TrackedItem input; _ediData: CM_EDIDataCustomStop; _ediCusStopTI: CM_EDICustomStopTI input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2018	jlgrh7	Initial creation
11 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window
11 Sep 2018	jlgsl4	TFS 39133 - TSW - IM1/EX1 'all clear' messages; 18/10/18 - IM1/EX1 trump ICR/CRE only
30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
01 Oct 2019	jlgrs1	TFS nnnn should only get those appliable for our cargo type
22 Apr 2021	navdap1	TFS 51073 PNL TSW B07 removing stop CEDO Stop
29 Apr 2021	navdap1	TFS 51121 POL "Retain Storage as Import" Stop configuration not working for TSW message processing
07 Sep 2022	jlizm1	TFS 54673 SNO Additional data mappings for CUSRES
22 Aug 2023	navdap1	TFS 59953 PNL - CIDO stop not removed on Transshipping container
05 Jan 2024	navpw1	TFS: 61906 (61907) - Fixed duplicate transaction being created below for 'Customs Stop Cleared'
16 Oct 2025	navpw1	JIRA: MTN-35793 - Made it possible to process tsw stops for storage containers
*/
vars
	passport					: CM_Passport;
	ediTI						: CM_EDICustomStopTI;
	trackedItem					: CM_TrackedItem;
	theRealTI					: CM_TrackedItem;
	tiSet						: CM_TISet;
	ediFileType					: CM_EDIFileType;
	informationArray			: StringArray512;
	allFileLinesObj				: StringArray512;
	ediFileObj					: CM_EDIFile;
	emailFrom					: String;		
	stops						: IntegerArray;
	isOneStopCustomsType		: Boolean;
	response					: String;	
	expectedEdition				: Integer;
	sepEmail					: String;
	theLines					: HugeStringArray;
	fileLine					: String;
	fileTypeString				: String;
	comment						: String;				// TFS 39133 - IM1/EX1
	strArray					: StringArray;
	tiWasImport					: Boolean;				// TFS 51121
	updatedTiCUstomsEntryNumber : Boolean;
	
begin
	passport := _passport;
	create stops transient;
	
	_pxyTI.getStopsToBeProcessed(StopProcessEDICustomImport, stops);
	_pxyTI.getStopsToBeProcessed(StopProcessEDICustomExport, stops);

	app.myValUA.valTIForCustomClearance(_pxyTI, _ediCusStopTI, passport);

	if not self.checkValidationWithPassport(passport) then
		return;
	endif;
	
	ediTI 				:= _ediCusStopTI;
	isOneStopCustomsType := ediTI.typeString = "One Stop Customs";	//09 Sep 2016	NDL	TFS 2278 / 2670
	response			:= ediTI.responseStatus;		// cnwcs5	Nov 2012
	trackedItem 		:= _pxyTI.pxyGetRealObject();
	tiWasImport			:= trackedItem.isStorageWasImportOnShip;			// TFS 51121
	
	create tiSet transient;	 //+ cnwmd1, Par 19903
	
	tiSet.add( trackedItem ); //+ cnwmd1, Par 19903

	//beginTransaction;
	
	_pxyTI.raiseExceptionIfNotProxy(method); //par22953 cnwrs1 5 feb 2010
	_pxyTI.pxyGetRealObjectAndEdition(theRealTI, expectedEdition);
	
	if isOneStopCustomsType then	//09 Sep 2016	NDL	TFS 2278 / 2670
		ediFileType := ediTI.myEDIFile.myEDIFileType;		
		if ediFileType &lt;&gt; null	and not (ediFileType.allEDIActions.isEmpty) then
			//perform the edi actions and update customs entry number
			app.myUtilityUA.utlUpdateTIFromOneStopAction(_pxyTI, ediTI, ediFileType, passport);
			
			if not self.checkValidationWithPassport(passport) then
				return;
			endif;
		endif;

	//elseif _pxyTI.isImport then 										// TFS 51121 // cnwrs1 par 25961 6 oct 2010 or _pxyTI.isTranshipOnInboundVoyage then		// PAR #23645 CCMS 1116
	elseif _pxyTI.isImport or tiWasImport								// TFS 51121 // cnwrs1 par 25961 6 oct 2010 or _pxyTI.isTranshipOnInboundVoyage then		// PAR #23645 CCMS 1116
		or _pxyTI.isStorage												// ### JIRA: MTN-35793 30Oct2025 NAVPW1
	then
		if response = Polish_Customs_Cleared then 
			_pxyTI.zSetPxyCustomExportEntryNumber(ediTI.entryNumber, passport);
			app.myUtilityUA.utlUpdateTICustomsEntryNum(_pxyTI, ediTI.entryNumber, ediTI.getVoyageCode(), true, passport);

			if not self.checkValidationWithPassport(passport) then
				return;
			endif;
			
		elseif response = Customs_Import_Cleared or response = MAF_ActionRequired or response = Customs_Deliver_BreakBulk or // TFS 39133
			 	ediTI.hasTSWClearance(true) or ediTI.isToBeMPIHeld() then // adm 300909 Par 20752 reworked this section // TFS 39133- MPI stop applied using EDIAction
			if ediTI.hasInstructions or response = Customs_Import_Cleared or ediTI.hasTSWClearance(true) or ediTI.isToBeMPIHeld() then // TFS 39133
			// 24/08/2009 	cnwsh3 		CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES
			// if the response is Customs Import Cleared there may be actions associated with the clearance. (eg, Remove the CSI Stop when it has been import cleared.
				
				ediFileType := ediTI.myEDIFile.myEDIFileType;
				
				if ediFileType &lt;&gt; null and not (ediFileType.allEDIActions.isEmpty) then
					//perform the edi actions and update customs entry number
					app.myUtilityUA.utlUpdateTIDoEDIAction(_pxyTI, ediTI, passport);
					
					if not self.checkValidationWithPassport(passport) then
						return;
					endif;
					if ediTI.hasNZCSClearance() then // TFS 39133 - in NZ Customs clearance case, set CEN
						app.myUtilityUA.updateTICustomsEntryNum(theRealTI, ediTI.entryNumber, ediTI.getVoyageCode(), true, _passport); // TFS 39133
						// ### TFS 61906 (61907) 04Jan2024 NAVPW1
						if self.checkValidationWithPassport(passport) then
							updatedTiCUstomsEntryNumber := true;
						endif;
						// ### TFS 61906 (61907) 04Jan2024 NAVPW1
					endif; // TFS 39133
				endif;				
			endif;
			//update entry number
			if not ediTI.hasInstructions or response = Customs_Import_Cleared or // TFS 39133 - multiple stops - allow for TSW and Cusres
				(response = Customs_Deliver_BreakBulk and not ediTI.hasTSWClearance(true)) then // TFS 39133 -  'shared' use of 819
			// update the customs entry number // TFS 39133 - CusRes clearance Customs_Deliver_BreakBulk, 819, is also TSW clearance, NZCS_Clearance_6, caught above
				// always clear the customs stop for "834" and "819" whether there were instructions or not
				// TFS 51073 DON'T clear the customs entry number stop if this is just an MPI clearance
				if not ediTI.isMPIClearance then		// TFS 51073
					if not updatedTiCUstomsEntryNumber then	// ### TFS 61906 (61907) 04Jan2024 NAVPW1
						app.myUtilityUA.updateTICustomsEntryNum(theRealTI, ediTI.entryNumber, ediTI.getVoyageCode(), true, _passport); //par 22953 cnwrs1 Feb 2010
					endif;									// ### TFS 61906 (61907) 04Jan2024 NAVPW1
					app.myUtilityDA.utlDeleteStops(trackedItem, stops, passport);
				endif;									// TFS 51073

				if not self.checkValidationWithPassport(passport) then
					return;
				endif;								
			endif;
			if not ediTI.hasInstructions and response = MAF_ActionRequired then // TFS 39133
				//there was an action required but no instructions ???
				app.writeLog("Processing MAF CusRes: There was an action required but no instructions. Check " &amp; ediTI.id, LogINFO);
			endif;

		elseif response = Customs_Import_Cancel or response = MAF_ContainerCancellation or ediTI.isToBeTSWHeld() then // TFS 39133 - 16/08/18 - TSW NZCS stop applied
			// CCMS 1469 cnwrs1 June 2006 only cancel if the customs entry numbers match
			if trackedItem.customsEntryNumber = ediTI.entryNumber then //par 29798 cnwrs1 12/06/2012
				//update entry number
				app.myUtilityUA.updateTICustomsEntryNum(theRealTI, ediTI.entryNumber, ediTI.getVoyageCode(), true, _passport); //par 22953 cnwrs1 Feb 2010
				stops.clear;
				app.myRoot.getCustomImportStops(stops, theRealTI.cargoType, app.getMyTerminalDO_NOT_USE);	//stops to add
				if stops.size &gt; 0 and theRealTI.hasTSWAllClear(stops[1]) and ediTI.isICRMessage then // TFS 39133 - don't re-add Customs stops after AllClear
					return; // TFS 39133 - 18/10/18 - *if* it's an ICR message...
				endif; // TFS 39133
	
				_pxyTI.addStopsProxy(stops);
				
				if not self.checkValidationWithPassport(passport) then
					return;
				endif;
	        	
				app.myUtilityCA.utlCreateStopsForTIs(tiSet, stops, passport); //+ cnwmd1, Par 19903 //+ cnwmd1, Par 19903
			else
				create informationArray transient;
				informationArray.add(ediTI.typeString &amp; " for "&amp;ediTI.entryNumber&amp;" rejected as current Customs Entry Number is "&amp;trackedItem.customsEntryNumber); //par 29798 cnwrs1 12/06/2012
				trackedItem.createInfomationTransaction(CustomsEntryNumberReject, informationArray, null, _passport);
			endif;
		else
			return;
		endif;
	/*elseif _pxyTI.isStorage then
		//don't apply
	*/ // ### JIRA: MTN-35793 30Oct2025 NAVPW1 - This check has merged with _pxyTI.isImport
	else				// Export or Export Tranship
		if response = Customs_Export_Cleared or response = SEP_ContainerRelease or response = Customs_Tranship_Cleared or ediTI.hasTSWClearance(false) or // TFS 39133
			response = Customs_Deliver_BreakBulk then // TFS 39133
			//update export entry number // TFS 39133 - Customs_Deliver_BreakBulk is used as clearance by TSW			
			if not(response = MPI_QualifiedClearance_2 or response = MPI_QualifiedClearance_3) then // TFS 39133 - 04/12/18 - TSW MPI messages can't clear tranship Customs stops
				_pxyTI.zSetPxyCustomExportEntryNumber(ediTI.entryNumber, passport);
				stops.clear;
				app.myRoot.getCustomExportStops(stops, app.getMyTerminalDO_NOT_USE); //par 15536 cnwrs1 dec 2007
				_pxyTI.deleteStops(false, stops, false, passport);
			else // TFS 39133 - 04/12/18 - MPI tranship movement approved - do EDI Actions eg. remove stops...
				app.myUtilityUA.utlUpdateTIDoEDIAction(_pxyTI, ediTI, passport); // TFS 39133 - 04/12/18			
				if not self.checkValidationWithPassport(passport) then // TFS 39133 - 04/12/18
					return; // TFS 39133 - 04/12/18
				endif; // TFS 39133 - 04/12/18
			endif; // TFS 39133 - 04/12/18

//			if not ediTI.allCustomsSeals.isEmpty then
//				_pxyTI.zSetPxyCustomsSealNums(ediTI.allCustomsSeals);
//			endif;
			if strArray = null then
				create strArray transient;
			else
				strArray.clear();
			endif;
			ediTI.getAllCustomsSeals(strArray);
			if not strArray.isEmpty then
				_pxyTI.zSetPxyCustomsSealNums(strArray);
			endif;
			if response = SEP_ContainerRelease then	
				stops.clear;
				app.myRoot.getCustomsInspectionStops(stops, app.getMyTerminalDO_NOT_USE); //par 15536 cnwrs1 dec 2007
				app.myRoot.getCustomsScanInspectionStops(stops, app.getMyTerminalDO_NOT_USE); //par 15536 cnwrs1 dec 2007
				_pxyTI.deleteStops(false, stops, false, passport);
			endif;
		
			if passport.noErrors then
				if ediTI.isTSWAllClearMessage() &lt;&gt; null then // TFS 39133 - EX1 'precedence'
					comment := EDIAction_TSWExportAllClear; // TFS 39133
				endif; // TFS 39133
				//might need txnController wiht customStopCleared passed in here - CCMS spec JC
				if not(response = MPI_QualifiedClearance_2 or response = MPI_QualifiedClearance_3) then // TFS 39133 - 04/12/18 - TSW MPI mustn't re-add MPI stop				
					app.myUtilityUA.utlUpdateTrackedItem(_pxyTI, comment, TI_UPDMODE_NORMAL, null, null, null, passport); //cnwrd1 28.8.09 par 20545 // TFS 39133
				endif; // TFS 39133 - 04/12/18				
			endif;
			
			// 19/08/2009 	cnwsh3 		CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES
			if passport.noErrors then
				if response = Customs_Export_Cleared
				or (response = NZCS_QualifiedClearance_1 and ediTI.entryNumber &lt;&gt; null) then	// TFS 59953
					app.myUtilityUA.utlUpdateTIDoEDIAction(_pxyTI, ediTI, passport);
				endif;
			endif;
			
		elseif response = Customs_Export_Cancel or response = SEP_ContainerCancellation or response = Customs_Tranship_Cancel or ediTI.isToBeTSWHeld() then // TFS 39133
			// CCMS 1469 cnwrs1 June 2006 only cancel if the CEDO numbers match
			if trackedItem.customExportEntryNumber = ediTI.entryNumber then
				//update CEDO
				_pxyTI.zSetPxyCustomExportEntryNumber("", passport);
				stops.clear;
				app.myRoot.getCustomExportStops(stops, app.getMyTerminalDO_NOT_USE);
				if stops.size &gt; 0 and theRealTI.hasTSWAllClear(stops[1]) and ediTI.isCREMessage then // TFS 39133 - don't re-add Customs stops after TSW AllClear
					return; // TFS 39133 - 18/10/18 - *if* it's CRE message... 
				endif; // TFS 39133
				_pxyTI.addStopsProxy(stops);
				
/*				if not ediTI.allCustomsSeals.isEmpty then
					_pxyTI.zSetPxyCustomsSealNums(ediTI.allCustomsSeals);
				endif;*/
				if strArray = null then
					create strArray transient;
				else
					strArray.clear();
				endif;
				ediTI.getAllCustomsSeals(strArray);
				if not strArray.isEmpty then
					_pxyTI.zSetPxyCustomsSealNums(strArray);
				endif;
				
				app.myUtilityUA.utlUpdateTrackedItem(_pxyTI, null, TI_UPDMODE_NORMAL, null, null, null, passport);//cnwrd1 28.8.09 par 20545
			else
				create informationArray transient;
				informationArray.add(ediTI.typeString &amp; " for "&amp;ediTI.entryNumber&amp;" rejected as current CEDO "&amp;trackedItem.customExportEntryNumber);
				trackedItem.createInfomationTransaction(CEDOCancellationRejection, informationArray, null, _passport);
			endif;
		elseif response = SEP_InspectionRequired then
/*			if not ediTI.allCustomsSeals.isEmpty then
				_pxyTI.zSetPxyCustomsSealNums(ediTI.allCustomsSeals);
				trackedItem.setCustomsSealNums(_pxyTI);
			endif;*/
			if strArray = null then
				create strArray transient;
			else
				strArray.clear();
			endif;
			ediTI.getAllCustomsSeals(strArray);
			if not strArray.isEmpty then
				_pxyTI.zSetPxyCustomsSealNums(strArray);
				trackedItem.setCustomsSealNums(_pxyTI);
			endif;
			stops.clear;
			app.myRoot.getCustomsInspectionStops(stops, app.getMyTerminalDO_NOT_USE);
			app.myRoot.getCustomsScanInspectionStops(stops, app.getMyTerminalDO_NOT_USE);
			//app.myUtilityCA.utlCreateStops(trackedItem, stops, passport); //- cnwmd1, Par 19903
			app.myUtilityCA.utlCreateStopsForTIs(tiSet, stops, passport); //+ cnwmd1, Par 19903
			
			if passport.noErrors then
				sepEmail := passport.myTerminal.getConfig(EDISEPInspectionEmail).String;
				if sepEmail &lt;&gt; null then
					emailFrom := app.myRoot.getConfig(AutoSendersEmailAddress).String;
					app.myUtilityCA.utlCreateEmailSendRequest(false, null, sepEmail, emailFrom, null, null, "SEP Inspection Required " &amp; trackedItem.id,
															  trackedItem.getDetailForEmail, null, null, null, null, EmailSource_System,  null, passport);
				endif;	
			endif;
		else
			return;
		endif;
	endif;
	
	if passport.hasErrors then
		return;
	endif;
	

// par 12197 cnwrs1 17 Aug 2006 set staus to db loaded even if still on ship
// cnwrs1 19 sept 2006 although this worked it also processed customs stops before the were released I need to try a different approach
//	if not trackedItem.isOnShip then
		//don't "complete" these while the ti is onship - only after the TI hits the wharf
//		ediTI.setStatus(CM_EDIFile.EDI_STATUS_DBLOADED);
//		ediTI.setTrackedItem(trackedItem);
//	endif;

	// ccms 1003 rs1 apr 2006 
	// when processing cusres for cuscar items update the consignor and customs agent
	if passport.myTerminal.getConfig(EDICusresCargoAddDetails).Boolean // TFS 54673
	or (trackedItem.isKindOf(CM_Car) and not isOneStopCustomsType)	//09 Sep 2016	NDL	TFS 2278 / 2670
	then
		trackedItem.updateAdditionalCusresDetails(	ediTI.consignor,
													ediTI.consignee,
													ediTI.customsAgent,
													ediTI.clientRef,
													ediTI.billOfLading,
													ediTI.description,
													ediTI.remarksAdditional1);
	endif;
	
	// par 13018
	ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
	ediTI.setTrackedItem(trackedItem);
	
	if ediTI.myEDIFile &lt;&gt; null then //par 13277 Feb 2007 cnwrs1
		create allFileLinesObj transient;
		ediFileObj	:=	ediTI.myEDIFile;
		
		// cnwdad1 20/06/2008 - PAR #17042.
		if ediFileObj &lt;&gt; null then
			create theLines transient;
			ediFileObj.myEDIFileType.rawDataToHSA(ediFileObj, theLines);
			foreach fileLine in theLines do
				
				if fileLine.length() &gt; 512 then
					allFileLinesObj.add(fileLine[1:512]);
				else
					allFileLinesObj.add(fileLine);
				endif;
			endforeach;
		endif;
		
		//09 Sep 2016	NDL	TFS 2278 / 2670
		if isOneStopCustomsType then
			fileTypeString := 'One Stop Customs';
		else
			fileTypeString := 'CusRes file';
		endif;
		
		trackedItem.createInfomationTransaction(fileTypeString &amp; " " &amp; ediTI.myEDIFile.createdTime.formatAsYYYYMMDDHHmmSS(),
												allFileLinesObj, null, app.myPassport);
												
		app.myUtilityUA.utlSetupEDIInfoTransaction(trackedItem, ediTI.rawEDIDataArray); //ccms1845
	endif;
epilog
	delete theLines;
	delete tiSet;
	delete stops;
	delete informationArray;
	delete allFileLinesObj;
	delete strArray;
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIDataCustomStop"/>
        <Parameter name="_ediCusStopTI" type="CM_EDICustomStopTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIData" id="2fb782a2-bf76-4d50-a763-eaa65d6fa308">
        <updating/>
        <source>utlUpdateEDIData(_realEdiData: CM_EDIData input; _realEdiFile : CM_EDIFile input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		03 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
vars

begin
	self.initialiseActivity();
	
	//04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(_realEdiFile, true);
	endif;
	if _passport.noErrors then
		_realEdiData.setForUpdateNoProxy(_realEdiFile);
	endif;
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(_realEdiFile, false);
	endif;
end;</source>
        <Parameter name="_realEdiData" type="CM_EDIData" usage="input"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIDataDetails" id="066a1ee6-4ef8-4920-af89-eb3188feb061">
        <source>utlUpdateEDIDataDetails(_proxyEDIData:CM_EDIData; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave		:Boolean;
	realEDIData		:CM_EDIData;
	expectedEdition	:Integer;
	
begin

	self.initialiseActivity();

	_proxyEDIData.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyEDIData.pxyGetRealObjectAndEdition(realEDIData, expectedEdition);
	
	if realEDIData = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EDIData.name, null, null);
		return;
	endif;

	app.myValUA.valEDIDataDetails(realEDIData, _proxyEDIData);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realEDIData);

	if _passport.noErrors and realEDIData.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Operator', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEDIData, true);
	endif;
	
	if _passport.noErrors then
		realEDIData.setForUpdate(_proxyEDIData);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEDIData, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyEDIData" type="CM_EDIData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIDataErrorsStatus" id="6aae56ab-f775-4248-a599-ac805df9f964">
        <updating/>
        <source>utlUpdateEDIDataErrorsStatus(_ediData : CM_EDIData io; _errors : CM_EDIErrorSet; _status : Integer; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/06/2023	navdap1		Initial creation TFS 58813 EUP Manifest Instructions and corrections
//
vars

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	exclusiveLock(_ediData);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_ediData, true);
	endif;
	
	if _passport.noErrors then
		_ediData.updateErrorsAndStatus(_errors, _status);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_ediData, false);
	endif;

epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="io"/>
        <Parameter name="_errors" type="CM_EDIErrorSet"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
