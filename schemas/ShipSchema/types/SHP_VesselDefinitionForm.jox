    <JadeMethod name="unload" id="28329812-3a68-4347-9d12-1d28b5262b85">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//--------------------------------------------------
// Created:	29 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.allProxies.purge();
	self.allProxyVessDataHarbour.purge();
	
	if self.myCurrentVessel &lt;&gt; null then
		if self.myCurrentVessel.isTransient() then
			delete self.myCurrentVessel;
		endif;
	endif;	
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="14abd48c-3f4b-4636-8a0a-fb0ccda5a145">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.doUserNotifyStructuralTables(eventType,theObject,eventTag, userInfo);
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
