    <JadeMethod name="setAllSubSystems" id="b899b97a-a78b-4382-9132-4902ef2817c6">
        <source>setAllSubSystems() protected;
// ---------------------------------------------------------------------------
// Created:     30 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	classCol	: ClassColl;
	class		: Class;
	subSystem	: CMUI_SubSystem;
	
begin

	create classCol transient;
	CMUI_SubSystem.allSubclassesInSubschemas(classCol);
	
	foreach class in classCol do
		create subSystem as class transient;
		self.allSubSystems.add(subSystem);
	endforeach;
	
epilog
	delete classCol;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showAuditsOnThumbnail" id="fe3f8b64-823e-43d2-b0a5-b1877cd11a4d">
        <source>showAuditsOnThumbnail(pDict : CM_AuditObjectDictByTimestamp; pTable : Table);
// ---------------------------------------------------------------------------
// Created:     10 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	audit	: CM_AuditObject;
	
begin

	pTable.addItem('');
	pTable.addItem('Audit Details');
	
	foreach audit in pDict do
		pTable.addItem(audit.typeCode &amp; Tab &amp; audit.userCode &amp; ' ' &amp; audit.timestamp.date.shortFormatJMT() &amp; ' '&amp;audit.timestamp.time.shortFormatJMT());
	endforeach;
	
	pTable.addItem('');
	
end;</source>
        <Parameter name="pDict" type="CM_AuditObjectDictByTimestamp"/>
        <Parameter name="pTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="showWindow" id="9dc34f24-44ae-458d-8d86-31f04e538be4">
        <updating/>
        <source>showWindow(pCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	
begin

	navObject := self.getNavObjectByCode(pCode);
	if navObject &lt;&gt; null then
		navObject.goToObject(null, null, true);
	endif;

end;</source>
        <Parameter name="pCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateInputObject" id="63b9a8fc-ff11-43a4-ab20-9bca31ebabf0">
        <source>updateInputObject(pNavObject : CMUI_NavigatorObject);
// ---------------------------------------------------------------------------
// Created:     20 November 2000 by cnwrs2
//
// Purpose:     Send out a notification to indicate that a NavigationObject has
//				been changed.  Primarily that the itemText has been updated
//				and display of this will need to be updated.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.causeEvent(CMUI_NavObject_Update, true, pNavObject);
	
end;</source>
        <Parameter name="pNavObject" type="CMUI_NavigatorObject"/>
    </JadeMethod>
</Class>
