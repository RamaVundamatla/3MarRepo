    <JadeMethod name="getMasterMachines" id="b77317fa-0d26-41cd-8446-df26da5e1d76">
        <source>getMasterMachines(_machines: CM_MachineByIdDict input; _includeCranes: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2009	cnwer1	Initial creation par 21354 moved from CM_MasterQueue and made it recursive

*/

vars
	queue	: CM_RadioTelemetryQueue;
	iter	: Iterator;

begin
	
	
	
	self.getPrimaryMachines(_machines, false,_includeCranes);	
	iter := self.allSubQueuesById.createIterator;
	while iter.next(queue) do
		queue.getMasterMachines(_machines, _includeCranes);
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_machines" type="CM_MachineByIdDict" usage="input"/>
        <Parameter name="_includeCranes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMatchPriority" id="638d5d87-2b58-4af0-9378-00419e56c495">
        <source>getMatchPriority(	arbiter: CM_RTQueueArbiter io;
					_fromLocation,
					_toLocation 	: CM_LocationsController): Integer abstract, number = 1017;</source>
        <abstract/>
