    <JadeMethod name="duplicateOf" id="6ef9bd71-783a-441d-b06b-cc4277b397f7">
        <updating/>
        <source>duplicateOf(pObject : Object) updating;

vars
	pCurrent : String;
	
begin
	pCurrent := pObject.getOidString();
	
	if self.current &lt;&gt; pCurrent and pCurrent &lt;&gt; "" then
		self.current := pCurrent;
	endif;		 
end;</source>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="intializeMe" id="b625e6f9-a6a0-462f-9a28-170da1b1f8ef">
        <updating/>
        <source>intializeMe(pCurrent:String; pImported : String; pMyOidTableRoot : CnEcOidTable ) updating;

begin
	self.current 	:= pCurrent;
	self.imported 	:= pImported;
	self.myOidTable	:= pMyOidTableRoot; 	
end;</source>
        <Parameter name="pCurrent" type="String"/>
        <Parameter name="pImported" type="String"/>
        <Parameter name="pMyOidTableRoot" type="CnEcOidTable"/>
    </JadeMethod>
</Class>
