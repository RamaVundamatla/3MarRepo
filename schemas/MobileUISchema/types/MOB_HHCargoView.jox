    <JadeMethod name="doResizeControls" id="0e63eb7d-ced0-4359-bd90-79d619cbe710">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation	TFS 3008 / 2370

*/

vars

	vHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	
	tabIndex := 4000;
	
	inheritMethod(_initialSetup);
	
	vHeight := self.clientHeight - ( 3 * self.resizedMargin ) - self.getCMDButtonsHeight();
	if _initialSetup then
		self.tblCargo.setAndIncrementTabIndex( tabIndex );
		self.tblCargo.visible := true;
	endif;
	self.tblCargo.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - self.resizedMargin -self.resizedMargin,
						vHeight );

	self.tblCargo.cnAdjustColumnWidths();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="4c0957e1-d02a-4006-b42e-6c6f3a2fc7bd">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation	TFS 3008 / 2370

*/

vars

begin

	self.myMobileGenericAgent.setMyNextTiToAction(null);
	self.doBackButtonClick();
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleUnknownPropertyValue" id="274bca53-1c8a-4978-9155-cc98850dc37d">
        <source>handleUnknownPropertyValue(_exc : Exception; _attr : String; _skip : Boolean output) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation	TFS 3008 / 2370

*/

constants
	InvalPropertyValue	= 1011;
vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = InvalPropertyValue then
		if _exc.resumable then
			_skip := true;
			returnVal := Ex_Resume_Next;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_attr" type="String"/>
        <Parameter name="_skip" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadTblCargo" id="0a91c0da-cb8e-4fc0-956e-1b820fe007b5">
        <source>loadTblCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation	TFS 3008 / 2370

*/

vars

	row : EntTableRow;
	dataValue : String;
	rowIndex : Integer;
	rowName : String;
	skip : Boolean;
	msg : String;
	group : EntTableGroup;

begin

	self.tblCargo.setCellText( 1,1, app.getErrorString(Heading_Attribute) &amp; Tab &amp; app.getErrorString(Value) );
	
	on Exception do self.handleUnknownPropertyValue( exception, rowName, skip );

	foreach row in self.myHandHeldConfig.allVisibleViewRows do
		rowName := row.name;
		skip := false;
		dataValue := self.myTrackedItem.getDisplayStringForAttribute( rowName, true );
		if not skip then
			rowIndex := self.tblCargo.addItem( row.getRawHeadingValue &amp; Tab &amp; dataValue );
		endif;
	endforeach;
	
	if self.tblCargo.rows = self.tblCargo.fixedRows then
		group := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_CargoDetails);
		row := group.allEntTableRowsByName.getAtKey(ETRow_CargoId);
		rowName := row.name;
		skip := false;
		dataValue := self.myTrackedItem.getDisplayStringForAttribute( rowName, true );
		if not skip then
			rowIndex := self.tblCargo.addItem( row.getRawHeadingValue &amp; Tab &amp; dataValue );
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="07c832d0-55ea-4088-a4e0-5cafc018e329">
        <updating/>
        <source>setupControls()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation	TFS 3008 / 2370

*/

vars

begin

	self.myHandHeldConfig := self.myTerminal.getHandHeldConfig( null );

	self.setupTable();

	self.doResizeControls(true);
	
	self.loadTblCargo();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8053d377-7ddd-4a52-8380-6ae18d2442f0">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation	TFS 3008 / 2370

*/

vars

	

begin
	
	self.myTrackedItem := app.myMobileCargoFindAgent.myTrackedItemToView;
	
	if self.myTrackedItem = null then
		self.msgBox(app.getErrorString(No_Cargo_selected),app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;
	
	self.setupCmdButtons( 1,app.getErrorString(Back), null, null, null, null );
	
	inheritMethod();
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="4713b16a-5bfc-4e15-9118-ecda842fa3ab">
        <source>setupTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation	TFS 3008 / 2370


*/

vars

begin

	self.tblCargo.parentAspect:=Table.ParentAspect_StretchBoth;
	self.tblCargo.rows := 1;
	self.tblCargo.fixedRows := 1;
	self.tblCargo.columns := 2;
	self.tblCargo.fixedColumns := 1;
	self.tblCargo.accessColumn(1).inputType := Table.InputType_None;
	self.tblCargo.accessColumn(2).inputType := Table.InputType_None;
	self.tblCargo.selectMode := Table.SelectMode_None;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2bb9645a-297e-4582-88f7-e9f7ff0f3368">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 December 2016 08:54:41.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021632, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
