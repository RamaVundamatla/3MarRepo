    <JadeMethod name="trxUpdateWleDelReqUnDo" id="d4c79a82-e0b2-4497-992c-1f7aca84aecd">
        <updating/>
        <source>trxUpdateWleDelReqUnDo( _wle : CM_WorkListEntry io; delRequest : CM_DeliveryRequest io; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2010	cnwndl1	Initial creation	Par 26055

*/
vars

	job : CM_Job;
	moveController	: CMIF_MoveController;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	exclusiveLock(_wle);
	exclusiveLock(_wle.myTrackedItem);
	job := _wle.job;
	
	beginTransaction;

	// we need to set the wle back to unactioned.
	app.myUtilityUA.utlUpdateWLEStatusDirectWLE(_wle.CM_YardWLE, WLE_UNACTIONED, _passport);

	if _passport.hasErrors then
		return;
	endif;
	
	// disaasociate the wle from the tracked item
	_wle.unassignTI();
	
	if delRequest.totalRequested = 0  then
		// this wle was created from a template.  We need to delete this wle.
		_wle.erase(0);
	endif;
	
	
epilog

	delete moveController;
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="delRequest" type="CM_DeliveryRequest" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
