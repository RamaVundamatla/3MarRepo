    <JadeMethod name="setProxyForYardRequest" id="f7ca2f64-aa53-47c6-bddb-fe83f9f9b2ab">
        <updating/>
        <source>setProxyForYardRequest(_consigneeCode, _consignorVoyageCode, _deliveryNumber : String;
						_doorsDirection : Integer;
						_eirNumber, _freightForwarderCode, _freightPayerCode : String;
						_isReceipt, _needCOU, _needGenerator : Boolean;
						_reasonCode : Integer; 
						_reasonCodeDescr, _remarks : String;
						_removeStops : Boolean; 
						_userCode, _voyageCode : String;
						_job : CM_Job; _pinNo : String;
						_transToTermminal : CM_Terminal) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setProxyForRequest(_freightForwarderCode, _freightPayerCode, _job, _userCode);

	self.consignee 		:= _consigneeCode;
	self.consignorVoyageCode := _consignorVoyageCode;
	self.setDeliveryNumber(_deliveryNumber);
	self.doorsDirection := _doorsDirection;  
	self.eirNumber 		:= _eirNumber; 
	self.isReceipt 		:= _isReceipt; 
	self.needCOU 		:= _needCOU; 
	self.needGenerator 	:= _needGenerator; 
	self.reasonCode 	:= _reasonCode;
	self.reasonCodeDescr	:= _reasonCodeDescr;
	self.setRemarks(_remarks &amp; Cr &amp; self.setCouGenRemarks());
	self.myTransferToTerminal := _transToTermminal;
	self.removeStops	:= _removeStops;
	self.voyageCode := _voyageCode;
	self.pinNo			:= _pinNo;
	
end;</source>
        <access>protected</access>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_consignorVoyageCode" type="String"/>
        <Parameter name="_deliveryNumber" type="String"/>
        <Parameter name="_doorsDirection" type="Integer"/>
        <Parameter name="_eirNumber" type="String"/>
        <Parameter name="_freightForwarderCode" type="String"/>
        <Parameter name="_freightPayerCode" type="String"/>
        <Parameter name="_isReceipt" type="Boolean"/>
        <Parameter name="_needCOU" type="Boolean"/>
        <Parameter name="_needGenerator" type="Boolean"/>
        <Parameter name="_reasonCode" type="Integer"/>
        <Parameter name="_reasonCodeDescr" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_removeStops" type="Boolean"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_pinNo" type="String"/>
        <Parameter name="_transToTermminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="35ce0c83-6181-4601-99ca-d1fa9d96b5fc">
        <updating/>
        <source>setRemarks(_value : String) updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.remarks &lt;&gt; _value then
		// RJS 14/3/01 - remove Tab, CrLf from string as these are put in
		// at entry time to display data so that it fits in the table.  If
		// not removed then auditing can screw up and record as a change.
		self.remarks := _value.trimBlanks.removeTabCrLfs;
	endif;

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="7d5a74a1-6a07-4485-b519-53747d111be7">
        <source>typeString(): String;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.isReceipt then
		return "Receival";
	else
		return "Release";
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="unplanWLEGhostTI" id="d29fe993-b27c-4de1-9f48-cddd57329090">
        <updating/>
        <source>unplanWLEGhostTI() updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle 		: CM_WorkListEntry;
	iter	 	: Iterator;
begin
	
	if self.allWorkListEntries.isEmpty then
		return;
	endif;
	
	iter := self.allWorkListEntries.createIterator;
	while iter.next(wle) do
		sharedLock(wle);
		//unplan all that has been planned thus far.
		if wle.CM_YardWLE.ghostTrackedItem &lt;&gt; null then
			//wle.CM_YardWLE.ghostTrackedItem.moveToLocation(null, wle.job, wle, null, PLANNING_MODE, true, true, false, false, false,  false, 0,0,app.myPassport);		// TFS 2651
			wle.CM_YardWLE.ghostTrackedItem.moveToLocation(null, wle.job, wle, null, PLANNING_MODE, true, true, false, false, false,  false, 0,0,null,null,null,app.myPassport);	// TFS 2651
		endif;
	endwhile;
	
epilog
	delete iter;	
end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="5b08b9fe-f6da-46f8-ab6b-8f0a89ac32ac">
        <source>validate(pUserObject: Object);
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
