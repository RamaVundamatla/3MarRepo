vars


begin
	inheritMethod(_showCaptions);
	self.resetTopPositions();

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1b437d79-1672-45d0-83a6-02594d6503b1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006335, locale);
	btnNextT.translateBubbleHelp(Xlat_0002435, locale);
	btnNextT.translateCaption(Xlat_0002436, locale);
	optLogId.translateCaption(Xlat_0002437, locale);
	optStockMovement.translateCaption(Xlat_0002434, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForSave" id="829ab906-3c95-44f3-9485-c1a6b53f6c5c">
        <source>validateForSave() : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	09 December 2009	by cnwvu1

Purpose:	PAR 21688
			There are some errors in GUI phase, not in trx level. It is because we need to manage 
			some required fields before trx starts eihter in GUI or BGP mode.
			In this case, errors are populated in self.allErrorsWarnings and the ErrorsWarning dialog to be displayed later.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	logId	: String;
	
begin

	// when ID enetered and no tabbing done (or log not found). PAR 21688 Dec 2009
	if self.optLogId.value then	
	
		logId := self.tblSelection.getValueByName(ETRow_LogId).String;
		
		if self.myTi = null then
			app.msgBox(app.getErrorString1(LogNotFound, logId), null, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
		
		if (self.myTi.id &lt;&gt; logId) then
			app.msgBox(app.getErrorString(RefreshLogdata), null, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
		
	endif;	

	return true;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
