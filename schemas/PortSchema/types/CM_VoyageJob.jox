        <source>isCustomSequenced() : Boolean;
/*
Purpose:			
Date		Who		Reason
24 October 2014	cnwab1	Initial creation
*/

vars
	req : CM_Request;
begin
	foreach req in self.allRequests discreteLock do
		if req.isSlotRequest()
		and  req.CM_SlotRequest.isCustomSequenced() then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
