//
// ---------------------------------------------------------------------------

vars
    req : CM_Request;
begin

    foreach req in self.allRequests do
		if not (req.getAttrIs40() or req.getAttrIsBackend()) then // PAR 21746 
		   return false;
		endif;          
    endforeach;

    return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
