    <JadeMethod name="btnNew_click" id="0e75ec57-9cbd-459d-aee1-7fea26e05e6f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNew_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint
20/06/2023	navkc1		CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
*/

vars
	form : INV_ContractMaint;
	bank :CM_Bank;
begin
	//16/10/2023	navmv20	Bug 60893 - start
	form := self.myContractMaintForm;
	/*if form = null then
		form := app.loadForm(INV_ContractMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractMaint;
		self.myContractMaintForm := form;
		form.myParentForm := self;
	else
		return;
	endif;*/
	if form &lt;&gt; null then
		form.unloadForm();
	endif;
	form := app.loadForm(INV_ContractMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractMaint;
	self.myContractMaintForm := form;
	form.myParentForm := self;
	//form := app.loadForm(INV_ContractMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractMaint;
	//16/10/2023 navmv20	Bug 60893 -end
	
	if form &lt;&gt; null then
		form.updateMode := false;
		form.btnRemove.enabled := false;
		form.btnAdd.enabled := false;
		form.btnUpdate.enabled := false;
		form.btnCopy.enabled := false;
		form.btnAttachments.enabled := false;
		form.btnAccumulate.enabled := false; //20/06/2023	navkc1	CR 55653 Task 58729
		form.btnAudit.enabled := false;			//11/07/2023 navrv30 #58391
		form.setMyCurrentBank(self.myCurrentBank);
		form.centreWindow();
		//form.showModal; ///16/10/2023 navmv20	Bug 60893
		form.show; ///16/10/2023 navmv20	Bug 60893
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
