<Class name="CMQF_ReeferCurr">
    <JadeMethod name="setFromAgent" id="eb37cdc1-0b1b-4f80-bfd9-6e548215ca21">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
//----------------------------------------------------------------
//	Created:	11 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_agent);
	//connection date set on superclass
	if _agent.isRowIncluded(ETRow_LastConnectDT) then
		if _agent.state &lt;&gt; _agent.STATE_TEMPLATE_SAVE and
		   _agent.state &lt;&gt; _agent.STATE_TEMPLATE_EDIT then
			self.endDate := '12/12/9999'.Date;
			self.connected := true;
		endif;
	endif;

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
