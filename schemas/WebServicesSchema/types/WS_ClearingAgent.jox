<Class name="WS_ClearingAgent" id="45f9fa26-dec8-4cd5-bb8d-49042f5fa801">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="41807267-4657-49e1-b5ef-1d5306c5d4e5">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="940c28ab-ca40-4df3-b300-45b7132cea21">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="64e57702-5041-4957-a8c4-aa806fd8ee1a">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	if _object.isKindOf(CM_CustomsAgent) then
		self.code:=_object.CM_CustomsAgent.code;
		self.description:=_object.CM_CustomsAgent.name;
	elseif _object.isKindOf(CM_ConsigneeConsignor) then
		self.code:=_object.CM_ConsigneeConsignor.code;
		self.description:=_object.CM_ConsigneeConsignor.description;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
