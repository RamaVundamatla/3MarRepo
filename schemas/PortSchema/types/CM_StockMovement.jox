    <JadeMethod name="init" id="1eee6b7b-ed3f-4018-8362-7217c1db9f94">
        <updating/>
        <source>init(_type : Integer; _bucket : CM_StockMoveBucket) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.type		:= _type;
	self.myStockMoveBucket	:= _bucket;

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_bucket" type="CM_StockMoveBucket"/>
    </JadeMethod>
    <JadeMethod name="isInwards" id="a7775e0b-7838-4a25-8e8d-48b635b0a36c">
        <source>isInwards() : Boolean;
// ---------------------------------------------------------------------------
// Created:     22 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.type = StkMove_MoveIn or
	   self.type = StkMove_OperatorChangeIn or
	   self.type = StkMove_ProdChangeIn or
	   self.type = StkMove_Reassembly or
	   self.type = StkMove_ValueUpdateIn then
	   	return true;
	elseif self.type = StkMove_Fixup then
		if self.adjustQuantity &gt; 0 or 
		   self.adjustVolume &gt; 0 or
		   self.adjustWeightKgs &gt; 0 then
			return true;
		else
			return false;
		endif;
	else
		return false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeTrackedItem_DocketCorrec" id="532a2609-f42a-419f-a0c2-6c7c3fcb5ff9">
        <updating/>
        <source>removeTrackedItem_DocketCorrec(_ti : CM_TrackedItem; _ts : TimeStamp; _quantity: Integer; _weight : Decimal; _volume : Decimal;
			   _txn : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2008 by cnwvu1
// ---------------------------------------------------------------------------
vars

begin

	self.adjustQuantity	:= self.adjustQuantity + _quantity;
	self.adjustVolume	:= self.adjustVolume + _volume;
	self.adjustWeightKgs := self.adjustWeightKgs + _weight;
	
	// According to addTrackedItem(). However, this functionality is not used at all.
	//if self.myExtension &lt;&gt; null then
	//	self.myExtension.addTrackedItem(_ti, _quantity, _weight, _volume);
	//endif;

	if self.myExtension &lt;&gt; null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Docket Correction. StockMovement myExtension &lt;&gt; null' );
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
</Class>
