    <JadeMethod name="addSummaryRows" id="27bbbb88-7427-47fd-a97a-b11afc0197c7">
        <source>addSummaryRows() protected;
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tbl 			: Table;
	i : Integer;
begin
	tbl := self.tblReport;
	/*i := 4;
	while i &gt; 0 do 
	  tbl.accessCell(30-i,1).mergeCells := Table.MergeCells_Merge;
	  tbl.accessCell(30-i,4).mergeCells := Table.MergeCells_NotAvailable;
	 
	  tbl.accessCell(30-i,4).alignment := Table.Alignment_Left_Middle;
	  i :=i -1;
	endwhile;
	 tbl.accessCell(30-i,1).text := "TOTAL MOVES";
	*/
	tbl.accessCell(30,1).mergeCells := Table.MergeCells_Merge;
	tbl.accessCell(30,6).mergeCells := Table.MergeCells_NotAvailable;
	tbl.accessCell(30,1).text := "TOTAL MOVES";
	tbl.accessedCell.alignment := Table.Alignment_Right_Middle;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="craneTotalMoves" id="b1cf7ac1-8863-4df8-b838-99d64251ee69">
        <source>craneTotalMoves(_jobSheet : CM_VoyageJobSheet input) : Integer;

vars
	voyageJob :CM_Job;
	no2, no4 ,r_no2, r_no4 ,moves :Integer;
begin
		moves :=0;
		foreach voyageJob in _jobSheet.allJobsByOrder do
			voyageJob.CM_VoyageJob.getNum20sAnd40s(r_no2, r_no4, no2,no4);
					moves := moves + (no2 + no4 +r_no2 + r_no4);
		endforeach;
		return moves;
end;
</source>
        <Parameter name="_jobSheet" type="CM_VoyageJobSheet" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLoad" id="51b95ec1-baf4-4f78-9d7e-b5052ce3ba80">
        <updating/>
        <source>doLoad() updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 October 2003		cnwaer1	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.setupControls();
	self.setupHeader();
	self.loadJobSheets();

	app.printer.setHeader(self.frmHeader);
	
	self.tblReport.visible := false;
	self.tblFooter.visible := false;
	
	self.printTable();

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="hideTblsAfterPrint" id="32e4d21b-1d01-4f2d-842c-024b0284dda1">
        <source>hideTblsAfterPrint(currentPrintTables,currentPrintFooter :ObjectArray input);

vars
	 obj		: Object;
	 tblRpt, tblFoot	: Table;

begin

		foreach obj in currentPrintTables do
			tblRpt := obj.Table;
			// hide the Crane tables that have already been printed
			tblRpt.visible := false;
		endforeach;
		foreach obj in currentPrintFooter do
			tblFoot := obj.Table;
			// hide the Footer tables that have already been printed
			tblFoot.visible := false;
		endforeach;

end;
</source>
        <Parameter name="currentPrintTables" type="ObjectArray" usage="input"/>
        <Parameter name="currentPrintFooter" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTblFooter" id="09ec4cb5-6a75-4412-9751-f359cce2aeb5">
        <source>initTblFooter(_tbl : Table input; left :Real) protected;

constants

vars
	column,
	numColumns				: Integer;

begin
	_tbl.borderStyle := Frame.BorderStyle_Single;
	_tbl.left := self.frmFooter.left + left;
	_tbl.width := 340;//self.frmFooter.width;
	_tbl.height := self.frmFooter.height;
	_tbl.fontSize := 9;
	_tbl.rows := 5;
	_tbl.columns := 4;
		
	_tbl.accessCell(1,1).text := 'Load';
	_tbl.accessCell(2,1).text := 'Discharge';
	_tbl.accessCell(3,1).text := 'DLR OFF';
	_tbl.accessCell(4,1).text := 'DLR ON';
	_tbl.accessCell(5,1).text := 'TOTAL MOVES';
	_tbl.accessCell(5,4).mergeCells := Table.MergeCells_NotAvailable;
	_tbl.accessCell(5,1).mergeCells := Table.MergeCells_Merge;
	
	_tbl.accessColumn(1).width := 91;
	_tbl.accessColumn(2).width := 38;
	_tbl.accessColumn(3).width := 38;
	_tbl.accessColumn(4).width := 173;
	_tbl.accessRow(5).alignment := 2;
	_tbl.accessColumn(4).alignment := 2;
	_tbl.accessColumn(2).alignment := 3;
	_tbl.accessColumn(3).alignment := 3;

	
	_tbl.gridLines :=	true;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="left" type="Real"/>
    </JadeMethod>
    <JadeMethod name="initTblReport" id="7e1e2e57-08be-407f-b8ca-5bd8f5022e96">
        <source>initTblReport(_tbl : Table input; left: Real) protected;

constants

vars
	column,
	numColumns : Integer;

begin
	_tbl.borderStyle := Frame.BorderStyle_Single;
	_tbl.left := self.frmTable.left +left;
	_tbl.width := 340;//self.frmTable.width;
	_tbl.height := self.frmTable.height;
	
	_tbl.fontSize := 9;
	_tbl.rows := 2;
	_tbl.accessRow(2).height := 30;
	_tbl.fixedRows := 2;
	_tbl.columns := 7;
	_tbl.accessRow(1).alignment := 3;
	_tbl.accessRow(1).fontBold := true;
	_tbl.accessRow(2).alignment := 3;
	_tbl.accessCell(1,1).mergeCells := Table.MergeCells_Merge;
	
	_tbl.accessCell(2,1).text := 'BAY';
	_tbl.accessCell(2,2).text := 'OD'&amp; CrLf &amp;'UD';
	_tbl.accessCell(2,3).text := 'D'&amp; CrLf &amp;'L';
	_tbl.accessCell(2,4).text := '20FT';
	_tbl.accessCell(2,5).text := '40FT';
	_tbl.accessCell(2,6).text := 'REMARKS';
	_tbl.accessCell(2,7).text := 'MOVES';
	
	_tbl.accessColumn(1).width := 33;
	_tbl.accessColumn(2).width := 40;
	_tbl.accessColumn(3).width := 18;
	_tbl.accessColumn(4).width := 38;
	_tbl.accessColumn(5).width := 38;
	_tbl.accessColumn(6).width := 120;
	_tbl.accessColumn(7).width := 53;

	_tbl.gridLines :=	true;
		
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="left" type="Real"/>
    </JadeMethod>
    <JadeMethod name="loadFootTable" id="eb376610-62d3-426d-870d-6fec57ed7ea2">
        <source>loadFootTable( td20, td40,tl20, tl40, drl_off2, drl_off4, drl_on2, drl_on4 : Integer input; _tblFoot : Table input) protected;

vars
	str, tl2, tl4, td2 , td4, drl_off20, drl_off40, drl_on20, drl_on40:String;
	tl, td, drl_on_total, drl_off_total :Integer;
begin
	tl := tl20 + tl40;
	td := td20 + td40;
	drl_on_total := drl_on2 + drl_on4;
	drl_off_total := drl_off2 + drl_off4;
// Load Row	
	if tl20 &lt;&gt; 0 then 
			tl2 := tl20.String;
		else
			tl2 :='';
	endif;
	if tl40 &lt;&gt; 0 then 
			tl4 := tl40.String;
		else
			tl4 := '';
	endif;

	str := tl2 &amp; Tab &amp; tl4&amp; Tab &amp; tl.String &amp; "     ";
	_tblFoot.accessCell(1,2).text := str;
//Discharge Row		
	if td20 &lt;&gt; 0 then 
			td2 := td20.String;
		else
			td2 :='';
	endif;
	if td40 &lt;&gt; 0 then 
			td4 := td40.String;
		else
			td4 := '';
	endif;
	
	str := td2&amp; Tab &amp;  td4 &amp; Tab &amp;  td.String &amp; "     ";
	_tblFoot.accessCell(2,2).text := str;
//RDL OFF Row
	if drl_off2 &lt;&gt; 0 then 
			drl_off20 := drl_off2.String;
		else
			drl_off20 :='';
	endif;
	if drl_off4 &lt;&gt; 0 then 
			drl_off40 := drl_off4.String;
		else
			drl_off40 := '';
	endif;
	str := drl_off20&amp; Tab &amp;  drl_off40 &amp; Tab &amp;   drl_off_total.String &amp; "     ";
	_tblFoot.accessCell(3,2).text := str;
//RDL ON Row	
	if drl_on2 &lt;&gt; 0 then 
			drl_on20 := drl_on2.String;
		else
			drl_on20 :='';
	endif;
	if drl_on4 &lt;&gt; 0 then 
			drl_on40 := drl_on4.String;
		else
			drl_on40 := '';
	endif;
	str := drl_on20 &amp; Tab &amp;   drl_on40 &amp; Tab &amp;   drl_on_total.String &amp; "     ";
	_tblFoot.accessCell(4,2).text := str;
	
	_tblFoot.accessCell(5,4).text := (tl + td + drl_off_total + drl_on_total).String &amp; "     ";
	

end;
</source>
        <access>protected</access>
        <Parameter name="td20" type="Integer" usage="input"/>
        <Parameter name="td40" type="Integer" usage="input"/>
        <Parameter name="tl20" type="Integer" usage="input"/>
        <Parameter name="tl40" type="Integer" usage="input"/>
        <Parameter name="drl_off2" type="Integer" usage="input"/>
        <Parameter name="drl_off4" type="Integer" usage="input"/>
        <Parameter name="drl_on2" type="Integer" usage="input"/>
        <Parameter name="drl_on4" type="Integer" usage="input"/>
        <Parameter name="_tblFoot" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadJobSheets" id="1df0fe5c-b26c-4b82-b6e5-fdff377e7fed">
        <updating/>
        <source>loadJobSheets() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	jobSheet	: CM_VoyageJobSheet;
	idx, i, count : Integer;
	left: Real;	
	tblRpt,
	tblFoot	: Table;
	obj : Object;
begin
	left := 0;
	self.lblFooter1.visible := false;
	idx := 0;

	foreach jobSheet in self.myVoyage.allJobSheets do
			if jobSheet = null then
				continue;
			endif;
			idx := idx + 1;
			self.allJobSheets.add(jobSheet);
			
			tblRpt := self.tblReport.loadControl(idx).Table;
			self.allJobTables.add(tblRpt);
		
			tblFoot := self.tblFooter.loadControl(idx).Table;
			self.allFooterTables.add(tblFoot);
			self.loadTable(jobSheet, tblRpt, tblFoot, left);
		   
			left:= left + tblFoot.width;
	
			self.frmFooter.width := tblFoot.left + tblFoot.width;
			self.frmTable.width := tblRpt.left + tblRpt.width;
		
	endforeach;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTable" id="b143ab6c-fe17-4a65-b6cf-82302270cb77">
        <updating/>
        <source>loadTable(_jobSheet	: CM_VoyageJobSheet; _tblRpt, _tblFoot : Table input; left :Real) updating, protected ;
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	jobSheet			: CM_VoyageJobSheet;
	idx, countColumn, column , no2, no4, r_no2, r_no4, moves, tl20, tl40,
	count,td20, td40, drl_off2,drl_off4, drl_on2,drl_on4 : Integer;
	str, ud_uk , dl , n2, n4	: String;
	voyageJob			: CM_Job;
	noRowsOnTable : Real;
begin
	jobSheet := _jobSheet;
	moves := self.craneTotalMoves(jobSheet);
	ud_uk := "";
	
	self.initTblReport(_tblRpt, left);
	self.initTblFooter(_tblFoot, left);

	_tblRpt.accessCell(1,1).text := "CRANE : "&amp; _jobSheet.crane;
	count := 2;
	self.noRowsOnTbl := ((_tblRpt.height - (_tblRpt.accessRow(1).height + _tblRpt.accessRow(2).height))/_tblRpt.accessRow(1).height).rounded;
	foreach voyageJob in jobSheet.allJobsByOrder do
	
		voyageJob.CM_VoyageJob.getNum20sAnd40s(r_no2,r_no4,no2,no4);	
		if voyageJob.CM_VoyageJob.hasOverDeckRequests() then
			ud_uk := "OD";
		else	
			ud_uk := "UD";
		endif;					
		if voyageJob.CM_VoyageJob.isDischarge then 
			dl := "D" ;
			td20 := td20+ no2;
			td40 := td40+ no4;
			drl_off2 := drl_off2 + r_no2;
			drl_off4 := drl_off4 + r_no4;
		else 
			dl:= "L";
			tl20 := tl20+ no2;
			tl40 := tl40+ no4;
			drl_on2 := drl_on2 + r_no2;
			drl_on4 := drl_on4 + r_no4;
		endif;
		
		// Polulate table
		if (no2 + r_no2) &lt;&gt; 0 then 
			n2 := (no2 + r_no2).String;
		else
			n2 :='';
		endif;
		if (no4 + r_no4)&lt;&gt; 0 then 
			n4 := (no4 + r_no4).String;
		else
			n4 := '';
		endif;
		str := voyageJob.CM_VoyageJob.bayId &amp; Tab &amp;
				ud_uk &amp; Tab &amp;
				dl    &amp; Tab &amp;
				n2    &amp; Tab &amp;
				n4    &amp; Tab &amp;
				voyageJob.CM_VoyageJob.remarks &amp; Tab &amp;
				moves.String;

		idx := _tblRpt.addItem(str);
	
		_tblRpt.accessRow(idx).alignment := 3;
		moves := moves - (no2 + no4 + r_no2 + r_no4);
		count := count+1;
		
	endforeach;
	self.noPages := ((count-2)/self.noRowsOnTbl).roundedUp();
	self.loadFootTable(td20,td40, tl20, tl40, drl_off2, drl_off4, drl_on2, drl_on4, _tblFoot);

end;


</source>
        <access>protected</access>
        <Parameter name="_jobSheet" type="CM_VoyageJobSheet"/>
        <Parameter name="_tblRpt" type="Table" usage="input"/>
        <Parameter name="_tblFoot" type="Table" usage="input"/>
        <Parameter name="left" type="Real"/>
    </JadeMethod>
    <JadeMethod name="printJobSheets" id="8f582e61-efac-43f6-b617-8b64109cd784">
