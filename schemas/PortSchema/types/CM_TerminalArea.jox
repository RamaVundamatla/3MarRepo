    </JadeMethod>
    <JadeMethod name="getSOHLevelsForDate" id="66a6d00a-aa99-49dc-be97-0785440ef477">
        <source>getSOHLevelsForDate(_date : Date; 
					_closingLevel 	: Boolean; 
					_totQty			: Integer io;
					_totVol			: Decimal io;
					_totWeight 		: Decimal io);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	
begin

	if (not self.isStockControlled) then
		return;
	endif;

	foreach lc in self.allLocationsControllers do
		lc.getSOHLevelsForDate(_date, _closingLevel, _totQty, _totVol, _totWeight);
	endforeach;
	
	// PAR 18081
	foreach lc in self.allLCsArchived do
		lc.getSOHLevelsForDate(_date, _closingLevel, _totQty, _totVol, _totWeight);
	endforeach;
	

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="io"/>
        <Parameter name="_totVol" type="Decimal" usage="io"/>
        <Parameter name="_totWeight" type="Decimal" usage="io"/>
    </JadeMethod>
