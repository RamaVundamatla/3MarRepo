        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_colorControl);
	self.setColorsForEntryTable(self.tblProperties);
	self.frmProperties.backColor := self.backColor;
	self.fldProperties.backColor := self.backColor;
	self.shtPropOne.backColor := self.backColor;
	self.shtPropTwo.backColor := self.backColor;
	self.shtPropThree.backColor := self.backColor;
