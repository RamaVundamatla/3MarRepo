    <JadeMethod name="setGraphTimer" id="207b6fd6-37d8-4367-845a-5c34aedde1cc">
        <updating/>
        <source>setGraphTimer(interval : Integer) updating, protected;

vars
	timerWasRunning : Boolean;
	
begin
	timerWasRunning := self.graphTimerRunning;
	
	self.stopGraphTimer;

	if interval &lt;= 0 then
		self.graphTimerInterval := 0;
		return;
	endif;
	
	self.graphTimerInterval := interval;
	
	if timerWasRunning then
		self.startGraphTimer;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="interval" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStatsTableDefaultWidths" id="8d6ee961-c095-47a2-8374-833e54577a32">
        <source>setStatsTableDefaultWidths() protected;

vars
	tbl : Table;
	
begin
	tbl := self.tblStats;
	
	tbl.columnWidth[1] := 120;
	tbl.columnWidth[2] := (tbl.clientWidth - 120) div 2;
	tbl.columnWidth[3] := tbl.clientWidth - tbl.columnWidth[1] - tbl.columnWidth[2];
end;</source>
