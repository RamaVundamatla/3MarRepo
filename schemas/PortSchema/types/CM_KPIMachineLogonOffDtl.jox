<Class name="CM_KPIMachineLogonOffDtl" id="de08cdc5-35cf-44e3-b65b-ae197ed9c924">
    <superclass name="CM_KPIMachineDtl"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="statistic"/>
    <JadeMethod name="setForLogoff" id="e2983ffe-d01c-4125-b780-79eeab3df729">
        <updating/>
        <source>setForLogoff(_history :CM_MachineLogOnOffHistory; _kpi :CM_KPIMachineEntity) : Boolean updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
05 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars
	logStart, logEnd,
	kpiStart, kpiEnd	:TimeStamp;
	logon				:CM_MachineLogOnOffHistory;
	elapsedTime			:Integer;
begin
	logon 	:= _history.myPriorHistory.CM_MachineLogOnOffHistory;
	logEnd	:= _history.dateTime;
	
	if logon &lt;&gt; null then
		logStart := logon.dateTime;
	endif;
	
	kpiStart	:= _kpi.getStartTS;
	kpiEnd		:= _kpi.getEndTS;
	
	if logEnd &lt; kpiStart or logEnd &gt; kpiEnd then
		return false; // PAR 34931
		// PAR 34931	app.raiseUnexpectedProgramError (self.class.name, method.name, "Incorrect logon/logoff timestamp");
	endif;
	
	// update gross running time (time logged on)
	if logon = null or 				// still logged on
		logStart &lt; kpiStart then	// logged on outside day/shift
		// workout gross running time from logon till end of day
		elapsedTime := kpiStart.getDifferenceInSeconds (logEnd).rounded;
	else
		elapsedTime := logStart.getDifferenceInSeconds (logEnd).rounded;
	endif;
	
	self.duration 		:= elapsedTime;
	self.grossDuration	:= elapsedTime;
	self.startTS		:= logStart;
	self.finishTS		:= logEnd;
	
	self.allMachineHistory.add (_history);
	
	if logon &lt;&gt; null then
		self.allMachineHistory.add (logon);
	endif;
	
	self.myKPIMachineEntity	:= _kpi;
	
	return true;// PAR 34931
epilog

end;</source>
        <Parameter name="_history" type="CM_MachineLogOnOffHistory"/>
        <Parameter name="_kpi" type="CM_KPIMachineEntity"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForLogon" id="907f14e1-f84c-402b-9fc0-7f98e55c8ef1">
        <updating/>
        <source>setForLogon(_history :CM_MachineLogOnOffHistory; _kpi :CM_KPIMachineEntity) : Boolean updating;
/*
Date		Who		Reason
05 Apr 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
17 Oct 2012	cnwcs5	par 30382 - handle consecutive logons after connetivity loss
*/
vars
	logStart, logEnd,
	kpiStart, kpiEnd,
	now					:TimeStamp;
	logoff				:CM_MachineLogOnOffHistory;
	elapsedTime			:Integer;
begin
	logoff 		:= _history.myNextHistory.CM_MachineLogOnOffHistory;
	logStart	:= _history.dateTime;
	
	if logoff = null then
		// par 30382 - either they are still logged on or there is a subsequent logon
		// because they lost connectivity or shut down app without logging off.
		// In this case we will look for the next logon in the history and treat the machine
		// as if it were logged on 
		logoff := _history.findNextLogonHistory;
	endif;
	
	if logoff &lt;&gt; null then
		logEnd := logoff.dateTime;
	endif;
	
	kpiStart	:= _kpi.getStartTS;
	kpiEnd		:= _kpi.getEndTS;
	
	if kpiEnd &gt; now then
		kpiEnd := now;
	endif;
	
	if logStart &lt; kpiStart or logStart &gt; kpiEnd then
		return false; // PAR 34931
		// PAR 34931	app.raiseUnexpectedProgramError (self.class.name, method.name, "Incorrect logon timestamp");
	endif;
	
	// update gross running time (time logged on)
	if logoff = null or 				// still logged on
		logEnd &gt; kpiEnd then			// logged off outside day/shift
		// workout gross running time from logon till end of day
		elapsedTime := logStart.getDifferenceInSeconds (kpiEnd).rounded;
	else
		elapsedTime := logStart.getDifferenceInSeconds (logEnd).rounded;
	endif;
	
	self.duration 		:= elapsedTime;
	self.grossDuration	:= elapsedTime;
	self.startTS		:= logStart;
	self.finishTS		:= logEnd;
	
	self.allMachineHistory.add (_history);
	
	if logoff &lt;&gt; null then
		self.allMachineHistory.add (logoff);
	endif;
	
	self.myKPIMachineEntity	:= _kpi;
	
	return true; // PAR 34931
epilog

end;</source>
        <Parameter name="_history" type="CM_MachineLogOnOffHistory"/>
        <Parameter name="_kpi" type="CM_KPIMachineEntity"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
