    <JadeMethod name="getNotReadyInvLineType" id="41865d34-a1a8-4ad9-a1e0-7f05880d2b6a">
        <source>getNotReadyInvLineType() : CM_InvoiceLineDesc;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharge
//
vars
	lineType : CM_InvoiceLineDesc;
	edition : Integer;
	invalid : Boolean;

begin
	lineType := self.myPilotSurchargeInvLineTypeVNR;
	if lineType = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, lineType, invalid );
	edition := lineType.edition;
	if invalid then
		return null;
	endif;
	
	return lineType;
epilog

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
