    <JadeMethod name="getColHeadingByRowName" id="f81c4c0a-a1c2-41fa-9eed-91f53fd57c4c">
        <source>getColHeadingByRowName(_rowName : String) : String;
//--------------------------------------------------
// Created:	14 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	idx		: Integer;
	str		: String;
	entRow : EntTableRow;
begin

	foreach entRow in self.allTblDataEntRows do
		if entRow.name = _rowName then
			return entRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale);
		endif;
	endforeach;
	
	return _rowName; // returning rowName is better than nothing
	
end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getColourColumnNumber" id="357044f7-cf0f-4a76-b33f-7ecec5fafa10">
        <source>getColourColumnNumber() : Integer;

/*
Purpose:		Return the column number if it exists for the table in use.

Date			Who		Reason
05 July 2010	cnwrl1	Initial creation as part of PAR 24606 - System Admin Export option does not export the colour values.
*/
	
vars
	
begin
	//cnwmc5 - 17 Oct 2013 - PAR 32609
	//epr par 33214 16/12/13
	if self.myEntTableDef &lt;&gt; null and  self.myEntTableDef.name = ETDef_VehicleColour then
		return null;
	endif;
	
	return self.getColumnByRowName( ETRow_Colour );
	
epilog
	
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColumnByHeading" id="700ec573-47a9-43ae-aa18-d1fc32af447e">
        <source>getColumnByHeading(_heading : String) : Integer;
//--------------------------------------------------------------
//Created: 25 November 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	idx		: Integer;
	str		: String;
	
begin

	foreach str in self.allTblDataColHeadings do
		idx := idx + 1;
		if str.toUpper = _heading.toUpper then
			return idx;
		endif;
	endforeach;
	
	return 0;
			
end;</source>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColumnByRowName" id="6cb646ea-0d12-4b35-866e-c5a35680eeae">
        <source>getColumnByRowName(_rowName : String) : Integer;
//--------------------------------------------------------------
//Created: 05 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	
begin
	return self.allTblDataColPropertyNames.indexOf(_rowName);
/*
	foreach str in self.allTblDataColPropertyNames do
		idx := idx + 1;
		if str = _rowName then
			return idx;
		endif;
	endforeach;
	
	return 0;
*/			
end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColumnIndexOf" id="5b72fef6-4f8d-4097-b3da-30ae447a6d8a">
        <source>getColumnIndexOf(_entableRowHeading: String; _savedIndex : Integer ): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation

*/

vars

	entTableRow : EntTableRow;
	entableRowHeading : String;
	index : Integer;

begin

	if not self.allTblDataEntRows.isEmpty then
		// it will usualy be the same one as we saved
		if self.allTblDataEntRows.size &gt;= _savedIndex then
			entTableRow := self.allTblDataEntRows[ _savedIndex ];
			if entTableRow &lt;&gt; null then
				entableRowHeading := entTableRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale);
				if entableRowHeading = _entableRowHeading then
					return _savedIndex;
				endif;
			endif;
		endif;
		// the user has set up filters, and then moved the column positions, find the new position.
		foreach index in 1 to self.allTblDataEntRows.size do
			entTableRow := self.allTblDataEntRows[ index ];
			entableRowHeading := entTableRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale);
				if entableRowHeading = _entableRowHeading then
					return index;
				endif;
		endforeach;
	endif;
	
	return inheritMethod(_entableRowHeading, _savedIndex);

epilog

end;</source>
        <Parameter name="_entableRowHeading" type="String"/>
        <Parameter name="_savedIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColumnStartX" id="d346a16d-3ea8-4b27-8098-9028676115f7">
        <updating/>
        <source>getColumnStartX(_col : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		04 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	enCol, ex, idx : Integer;
begin
	enCol := self.columns;
	foreach idx in 1 to enCol do
		if idx = _col then
			break;
		endif;
		ex := ex + self.accessColumn(idx).width;
	endforeach;
	return ex;
end;</source>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDataAndDisplayRowsMultith" id="abb93b8b-d23c-4d79-9ec8-f97fcb8d36ac">
        <updating/>
        <source>getDataAndDisplayRowsMultith(tblDataObjects:Collection; needProgress : Boolean; _form : CM_BaseForm io; _doDisplayFunctionality : Boolean) updating;

/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason

19 Apr 2024 annamth CR 61540: MTN - [POC - Phase 1] - Enhancing Query Performance through Multi-Process
28 May 2024 navlc30 ChangeRequest 64321: MTN - Multithreading For Work Order Enquiry and Work Order Operation Screen
01 Aug 2024 navhl20	Bug 65363: EUP - Date format is not based on the local time format
02 Feb 2025	navrv30 JIRA 33828 MTN - When using multi-threading form showing two progress bars
*/
 
vars 
	  objecInt:Object;
	  dynObj:JadeDynamicObject;
	  dynArray:JadeDynamicObjectArray;
	  aswMgr:ASW_Manager;
	  theTable : CM_DataTable;		//navra1 - TFS 63751/Task 63752 - 13th May 2024
	  iter : Iterator;				//navra1 - TFS 63751/Task 63752 - 13th May 2024
	  obj : Object;					//navra1 - TFS 63751/Task 63752 - 13th May 2024
  	  theDataLine : String;			//navra1 - TFS 63751/Task 63752 - 13th May 2024
	  strObj : CM_StringWithString;	//navra1 - TFS 63751/Task 63752 - 13th May 2024
	  syncCount : Integer;
	  objCount : Integer;
	  idx : Integer;
	  table : CM_DataTable;
	  minNumberOfRows : Integer;	
		startTs,
		endTs			: TimeStamp;
begin
	if process.isNavnk30() then
		startTs := app.actualTimeServer();
	endif;
	//if nothing is passed to show, go back
	if tblDataObjects = null then
		app.writeLog("No objects to show on table, passed list is null", LogERROR);
		
		if process.isRam() then
			write "No objects to show on table, passed list is null";
		endif;
		return;
	endif;	
	
	if self.allTblDataObjDict &lt;&gt; null then
		self.allTblDataObjDict.purge();
	else
		create self.allTblDataObjDict transient;
	endif;
	//navra1 - TFS 63751/Task 63752 - 13th May 2024 - end	
	minNumberOfRows := _form.getMinRowsForAsync();						//28.05.2024 navlc30 #64321
	if app.myRoot.isAsynchronousMethodEnabled() and 					//28.05.2024 navlc30 #64321
		tblDataObjects.size() &gt; minNumberOfRows then//and tblDataObjects.size() &lt; 32000 then		//you dont want to upper limit it here, since otherwise if we 
																						//wanted more than JadeTableRowLimit we will not async at all, 
																						//should we remove objects above the limit in the tblDataObjects?
		if not process.isInTransientTransactionState() then 
			beginTransientTransaction;
		endif;
			  create aswMgr transient; 
			  create dynArray sharedTransient;
			  
			  foreach objecInt in self.allTblDataEntRows do
				  create dynObj sharedTransient;
				  dynObj.addProperty("attrName",String);
				  dynObj.setPropertyValue("attrName",objecInt.EntTableRow.name);
				  dynObj.addProperty("inputType",Integer);
				  dynObj.setPropertyValue("inputType",objecInt.EntTableRow.inputType);
				  dynObj.addProperty("sortFieldName",String);
				  dynObj.setPropertyValue("sortFieldName",objecInt.EntTableRow.sortFieldName);
				  dynArray.add(dynObj);				  
			  endforeach; 
		commitTransientTransaction;
		if process.isRam() then
			write "Async fetch";
		endif;	
		//02/02/2025 navrv30 JIRA 33828
		_form.frmModalDialog.visible := false;
		_form.doWindowEvents(0);
		aswMgr.handletblDisplayRowAsync(tblDataObjects,dynArray,allTblDataObjDict, needProgress);
	else
		if process.isRam() then
			write "Going Sync, not performing Async fetch for " &amp; tblDataObjects.size().String &amp; " objects";
		endif;		
	endif;
	
	//navra1 - TFS 63751/Task 63752 - 13th May 2024
	//if some lines failed to fill up or if async is not enabled, get the data sync and fill it up in allTblDataObjDict
	if aswMgr = null or aswMgr.wasCancelled = true then											//navra1 - BUG 66089 - 12th Sep 2024
		//self.allTblDataObjDict.clear();											//01.08.2024 navhl20 #65363 to avoid date format issue
		iter := tblDataObjects.createIterator();	
		while(iter.next(obj)) do
			if self.allTblDataObjDict &lt;&gt; null then
				if self.allTblDataObjDict.getAtKey(obj.getOidAsString()) = null then
					syncCount := syncCount+1;
					theDataLine := obj.getAttributeStringForDefArray(self.allTblDataEntRows);
					create strObj transient;
					strObj.set(obj.getOidAsString(), theDataLine);
					self.allTblDataObjDict.tryAdd(strObj);		
				endif;
			endif;
			//02/02/2025 navrv30 JIRA 33828
			if syncCount mod 50 = 0 then
				_form.modalDialogShow(null, 'Cancel', null, null,'Loading data into table',"Loaded " &amp; tblDataObjects.size().String &amp; " Items");
				_form.modalDialogProgressBar(tblDataObjects.size());
				if _form.caption &lt;&gt; null then
					_form.modalDialogUpdateInfo(_form.caption &amp; ", " &amp; syncCount.String &amp; ' of ' &amp; tblDataObjects.size().String &amp; " Items");
				else
					_form.modalDialogUpdateInfo("Loaded " &amp; syncCount.String &amp; ' of ' &amp; tblDataObjects.size().String &amp; " Items");
				endif;				
				_form.pbProgressBar.partsDone := syncCount;
				_form.frmModalDialog.refreshNow;
				_form.btnModalDefault.doWindowEvents(0);
				if _form.modalDialogReturnValue = _form.ModalDialogReturn_Default then
					// Cancel
					break;
				endif;
			endif;
		endwhile;
	endif;																		//navra1 - BUG 66089 - 12th Sep 2024
	
	if process.isRam() then
		write "Performed " &amp; syncCount.String &amp; " syncronous fetches!";
	endif;
	
	if not _doDisplayFunctionality then
		return;
	endif;
	
	//at this point, we are sure we have all the data to display the table, 
	//now go ahead and display each row and do additional stuff using the callback passed
	//navra1 - TFS 63751/Task 63752 - 13th May 2024
	iter := tblDataObjects.createIterator();	
	while(iter.next(obj)) do
		if not global.isValidObject(obj) then
			continue;
		endif;
	
		if self.rows &gt;= JadeTableRowLimit then
			app.msgBox("Maximum Rows Reached!", "INFO", MsgBox_OK_Only);
			break;			
		endif;
		
		table := self;
		
		if not _form.rowPreprocess(table, obj) then
			continue;
		endif;
		
		theDataLine := self.getDisplayStringAttributeArray(obj.getOidAsString());
		
		//navra1 - BUG 66089 - 12th Sep 2024 - start
		//dont add empty lines
		if theDataLine = null then
			continue;
		endif;
		//navra1 - BUG 66089 - 12th Sep 2024 - end
		
		idx := self.addItemObject(obj, theDataLine);
		
		if idx = 0 then		// TFS 1788 6/4/2016 cnwjre1 after handling the &gt;32000 exception rowIdx is zero so exit the rest of the processing
			break;
		endif;		
			
		_form.rowPostprocess(table, idx, obj);		
		
	endwhile;		
	if process.isNavnk30() then
		endTs := app.actualTimeServer();
		write "Started = " &amp; startTs.displayWithMilliSeconds__() &amp; ", Ended = " &amp; endTs.displayWithMilliSeconds__() &amp; 
			"Rows = " &amp; tblDataObjects.size().String &amp; " Time Taken = " &amp; (endTs - startTs).getMilliseconds.String &amp; "ms. " &amp; " method : " &amp; method.name &amp; " userID : " &amp; app.getMyUserCode();
	endif;
epilog
	if aswMgr &lt;&gt; null then							//navra1 - BUG 66089 - 12th Sep 2024
		aswMgr.wasCancelled := false;				//navra1 - BUG 66089 - 12th Sep 2024
	endif;											//navra1 - BUG 66089 - 12th Sep 2024
	_form.frmModalDialog.visible := false;			//02/02/2025 navrv30 JIRA 33828
end;</source>
        <Parameter name="tblDataObjects" type="Collection"/>
        <Parameter name="needProgress" type="Boolean"/>
        <Parameter name="_form" type="CM_BaseForm" usage="io"/>
        <Parameter name="_doDisplayFunctionality" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataAndDisplayRowsPaginat" id="61702068-fc2d-4a54-b245-85f90d78f7c3">
        <updating/>
        <source>getDataAndDisplayRowsPaginat(_showHow : Integer; _startObj : Object; _coll : Collection; _doNotify : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
11 Sep 2025 navhl20 Bug MTN-35804: Notifications are not handled on the Work Order Operations form and Work Order Enquiry form
*/

vars
	noteObj			: Object;
	tvForm			: CM_TableViewForm;
	obj 			: Object;
	iter 			: Iterator;
	baseForm 		: CM_BaseForm;
	theDataLine 	: String;
	idx 			: Integer;
	table 			: CM_DataTable;
	invalidObj 		: Boolean;
	useDisplayColl 	: Boolean;
begin

	app.mousePointer := MousePointer_HourGlass;	 // ### JIRA 35966 08DEC2025 NAVAB1

	useDisplayColl:=(app.myRoot.isPaginated()) or (self.form &lt;&gt; null and self.form.isKindOf(CMUI_CargoListView)); //jlier1 JIRA-35567 24/7/25
	//do same test as the asnch workers to see if it will work
	
	if not  useDisplayColl then
		
		on Exception do app.handleDeletedObject(exception, obj, invalidObj);
		if self.form &lt;&gt; null and self.form.isKindOf(CM_BaseForm) then
			baseForm:=self.form.CM_BaseForm;
		endif;
		table := self;
		iter := _coll.createIterator();	
		while(iter.next(obj)) do
			if self.rows &gt;= JadeTableRowLimit then
				app.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String), app.getErrorString(Info), MsgBox_OK_Only);
				break;			
			endif;
				
			obj.edition;
			if invalidObj then
				invalidObj:=false;
				continue;
			endif;
			
			
			if baseForm &lt;&gt; null and not baseForm.rowPreprocess(self, obj) then
				continue;
			endif;
			
			theDataLine := obj.getAttributeStringForDefArray(self.allTblDataEntRows);

			if theDataLine = null then
				continue;
			endif;
			
			idx := self.addItemObject(obj, theDataLine);
			
			if idx = 0 then		// TFS 1788 6/4/2016 cnwjre1 after handling the &gt;32000 exception rowIdx is zero so exit the rest of the processing
				break;
			endif;		
			
			/*
			//11.09.2025 navhl20 #35804 Moved this code to add item object method
			if baseForm &lt;&gt; null then
				baseForm.rowPostprocess(table, idx, obj);	
			endif;*/
		endwhile;
		return;
	endif;


	if self.myPaginationParams = null then
		self.myPaginationParams := create CMIF_PaginationParams(_showHow, _startObj, _doNotify) transient;
	else
		self.myPaginationParams.setValues(_showHow, _startObj, _doNotify);
	endif;
	
	//jlier1 9/6/25 MTN-34771 - show in sorted column order
	self.resortForPagination(_coll);
	
	if not self.myPaginationParams.doNotify then
		return;
	endif;
	
	foreach noteObj in _coll as CM_Object discreteLock do
	
		//23/06/2025	navkc1 JIRA MTN 34973
		if self.isPaginatedNotification() then
			self.doPaginatedNoteAdd(noteObj.CM_Object);
		endif;
		
	endforeach;

epilog
	app.mousePointer := MousePointer_Default; // ### JIRA 35966 08DEC2025 NAVAB1
	
	delete iter;
end;</source>
        <Parameter name="_showHow" type="Integer"/>
        <Parameter name="_startObj" type="Object"/>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_doNotify" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringAttributeArray" id="4dbd8935-9147-4b87-ba95-644dd7a8688e">
        <source>getDisplayStringAttributeArray(oid:String):String;
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
20 Apr 2024 annamth Task 63752: Jade - CM_Datable Workers
 
*/
 
vars
	strObj:CM_StringWithString;
	rtnStr:String;
begin
	rtnStr:=null;
	if allTblDataObjDict &lt;&gt; null then
		strObj := allTblDataObjDict.getAtKey(oid).CM_StringWithString;
	endif;
	if strObj &lt;&gt; null then
		rtnStr:= strObj.strString;
	endif;
	return rtnStr;
epilog
 
end;</source>
        <Parameter name="oid" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getETViewForETDef" id="07b0e008-eaf6-45a4-88c6-492ef75cfbf7">
        <source>getETViewForETDef(_viewName :String; _def :EntTableDef):EntTableView protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	view	:EntTableView;
begin
	if _viewName = null then
		view := self.myEntTableDef.allEntTableViews[SystemDefault];
	else
		view := self.myEntTableDef.allEntTableViews[_viewName];
	endif;
	
	if view = null then	
		//No system default view so use JMT default instead	
		view := self.myEntTableDef.allEntTableViews[Default];
	endif;

	return view;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_viewName" type="String"/>
        <Parameter name="_def" type="EntTableDef"/>
        <ReturnType type="EntTableView"/>
    </JadeMethod>
    <JadeMethod name="getEntRowColumnByRowName" id="2fa61d90-cec0-4568-ba1a-a8aface9da63">
        <source>getEntRowColumnByRowName(_rowName : String; _column : Integer output) : EntTableRow;
//--------------------------------------------------
// Created:	15 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	entRow : EntTableRow;
begin
	_column := 0;
	foreach entRow in self.allTblDataEntRows do
		_column := _column + 1;
		if entRow.name = _rowName then
			return entRow;
		endif;
	endforeach;
	
	return null; // not found
	
end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_column" type="Integer" usage="output"/>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="getEntTableRowAtColumn" id="8067f21c-02e4-460f-8df3-1e1dfd552d8a">
        <source>getEntTableRowAtColumn(_atColumnIndex: Integer): EntTableRow;
/*
Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars
	size : Integer;
begin
	size := self.allTblDataEntRows.size;

	if _atColumnIndex &lt;= size then
		return self.allTblDataEntRows[_atColumnIndex];
	endif;
	
	return inheritMethod(_atColumnIndex);
epilog

end;</source>
        <Parameter name="_atColumnIndex" type="Integer"/>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="getHeadingByName" id="429762be-f73a-49fa-b184-a102e2e53945">
        <source>getHeadingByName(_name : String) : String;
//
// ccms 2044 cnwrs1 05 May 2011
//
vars
	entRow : EntTableRow;
	tmpLocale : CM_Locale;	
	tmpStr : String;
begin
	tmpLocale := app.myCurrentLocale;
	foreach entRow in self.allTblDataEntRows do
		if entRow.name = _name then
			tmpStr := entRow.getShortHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, tmpLocale);
		endif;
	endforeach;
	return tmpStr;
end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIF_CM_DataTable" id="1511cb70-b719-4a52-af1e-68900d53fd75">
        <source>getIF_CM_DataTable(): IF_CM_DataTable;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2010	cnwer1	Initial creation

*/

vars

begin
	if self.myForm = null then
		return null;
	endif;
	
	if self.myForm.respondsTo(IF_CM_DataTable) then
		return  self.myForm.IF_CM_DataTable;
	endif;

epilog

end;</source>
        <ReturnType type="IF_CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="getMyUserWindow" id="9fc7a5c1-2304-4efa-b1d6-b302bab3300e">
        <updating/>
        <source>getMyUserWindow(): CM_UserWindow updating, protected;
//--------------------------------------------------------------
//Created: 7 October 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theUser : CM_User;
begin
	if self.form = null then
		return null;
	endif;
	
	theUser := app.getMyUser();
	if theUser = null then
		return null;
	endif;
	
	return app.getUserWindow(self.form.name, false);
	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="getName" id="db5729e7-1991-4a6a-91d8-d5c35484db0e">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     01 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return inheritMethod() &amp; ' (' &amp; self.name &amp; ')';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfSortColumns" id="91deb0c7-34e4-4dd8-8744-1df4b74a6159">
        <source>getNumberOfSortColumns():Integer protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.allTblDataSortColumns.size;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowCount" id="408c5c82-bf1e-44c6-9258-84cd1e29e899">
        <updating/>
        <source>getRowCount() : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 August 2025		jlizm1	Initial creation MTN 35316 Pagination - Work Order Complete

*/

vars
	col : CM_ObjectArray;
	
begin
	if self.isPaginated then
		create col transient;
		self.getAllRowObjects(col);
		return col.size();
	else
		return self.rows - self.fixedRows;
	endif;
	
epilog
	delete col;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCellsStrings" id="8d6710d5-60d8-4737-87be-2e920825777f">
        <updating/>
        <source>getSelectedCellsStrings(_stringArray : StringArray input) updating;
/*

Date		    Who			Reason
04 October 2010	cnwas3	  par 25163

*/

vars
	numRows,
	numCols,
	i, j	: Integer;
	str		: String;
begin

	if _stringArray &lt;&gt; null then
		_stringArray.clear();
	else
		return;
	endif;
	
	numRows := self.rows;
	numCols := self.columns;

	
	foreach i in 1 to numRows do
		foreach j in 1 to numCols do
			if self.accessCell(i,j).selected and self.accessedCell.fontBold = false then	//measure put in to exclude some cells from the summing up process
				str := self.accessedCell.text;
				if str &lt;&gt; null then
					_stringArray.add(str);
				endif;
			endif;
		endforeach;
	endforeach;
				
end;</source>
        <Parameter name="_stringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCellsSumAsString" id="2ee49cd8-b335-41ab-bd0d-096c808ae367">
        <updating/>
        <source>getSelectedCellsSumAsString() : String updating;
/*

Date		    Who			Reason
04 October 2010	cnwas3	  par 25163

*/

vars
	strSet : StringArray;
	str : String;
	sum : Decimal[23,5];	
begin
	create strSet transient;
	self.getSelectedCellsStrings(strSet);
	if strSet = null or strSet.size() = 0 then
		return null;
	endif;
	foreach str in strSet where str.isDecimal do
		sum := sum + str.asDecimalJMT();
	endforeach;
	return sum.cnEcStripDecimalZeros();
epilog
	delete strSet;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSortColumnEntRows" id="68c9fd2e-ff38-44be-967b-7b01198229a4">
        <source>getSortColumnEntRows(_entRowArray : EntTableRowArray input);
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
// 28/02/2011	cnwcs5	par 19489 - fix 1090 UE - add exception handler
vars
	strSort, strRow	: String;
	entRow 			: EntTableRow;
	gotException	: Boolean;		// 28/02/2011 cnwcs5 par 19489 
begin
	if _entRowArray = null then
		return;
	endif;

	on Exception do app.handleDeletedObject (exception, entRow, gotException);	// 28/02/2011 cnwcs5 par 19489 
	
	foreach strSort in self.allTblDataSortColumns do
		strSort := strSort.trimBlanks;											// 28/02/2011	cnwcs5	par 19489 
		
		foreach entRow in self.allTblDataEntRows do
			// 32345 if the selector system default attribute list and current selector attribute list are out of step, CMUI_Selector::doCreateTableOrganisor
			//	can populate this array with gaps, so just skip over any null entries - note this is probably the problem that the 19489 fixes here are trying to handle ...
			if entRow = null then
				continue;
			endif;
			strRow := entRow.name.trimBlanks;									// 28/02/2011	cnwcs5	par 19489 
			
			if gotException then												// 28/02/2011	cnwcs5	par 19489 
				gotException := false;											// 28/02/2011	cnwcs5	par 19489 
				continue;														// 28/02/2011	cnwcs5	par 19489 
			endif;																// 28/02/2011	cnwcs5	par 19489 
			
			if strRow = strSort then
				_entRowArray.add(entRow);
			endif;
 		endforeach;
	endforeach;
	
end;</source>
        <Parameter name="_entRowArray" type="EntTableRowArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="ae52337d-2ae9-4113-a89a-eefcecf06afe">
        <source>getTerminal() : CM_Terminal;
//28 August 2008	cnwdw1	
//	myForm MUST be set to a valida CM_BaseForm
begin
	return self.myForm.CM_BaseForm.myTerminal;
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getXMLStrForColItems" id="c4fc2032-1217-4078-8562-e48c81e714d1">
        <source>getXMLStrForColItems() : String;
/*

Purpose:		Extracted code block from getXMLStrForColumns		


Return Value:		


Date		Who		Reason
23 April 2008	cnwer1	Initial creation - PAR#16584

*/
vars
	entRow  : EntTableRow;
	tmpStr : String;
begin
	foreach entRow in self.allTblDataEntRows do
		tmpStr := tmpStr &amp; global.formatAsXML(XMLTag_Column, entRow.name);
	endforeach;

epilog
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLStrForColSort" id="94664c39-1d6a-491b-91a6-43ff225468c8">
        <source>getXMLStrForColSort() : String;
/*

Purpose:	Extracted code block from getXMLStrForColumns			


Return Value:		


Date			Who		Reason
23 April 2008	cnwer1	Initial creation - PAR#16584
14/10/2009		cnwcs5	par 21171 - sorting problems

*/
vars
	str,sortStr : String;
	idx : Integer;
begin
	if self.maxSortColumns &lt;= self.MaxJadeSortColumns then	// par 21171
		idx := 0;
		foreach str in self.allTblDataSortColumns do
			idx := idx +1;
			
			str := str &amp; Tab &amp; self.sortColumn[idx].String &amp; Tab &amp; self.sortAsc[idx].String;
			if sortStr &lt;&gt; null then
				sortStr := sortStr &amp; ',' &amp; str;
			else
				sortStr := str;
			endif;
			if idx = self.MaxJadeSortColumns then	// par 21171
				// Jade max sort order
				break;
			endif;
		endforeach;
	
	else
		// using dynsDict to sort more than 6 columns
		idx := 0;
		foreach str in self.allTblDataSortColumns do
			idx := idx +1;
			str := str &amp; Tab &amp; idx.String &amp; Tab &amp; (not self.allTblDataSortDescending[idx]).String;			
			if sortStr &lt;&gt; null then
				sortStr := sortStr &amp; ',' &amp; str;
			else
				sortStr := str;
			endif;				
		endforeach;
	endif;

	
epilog
	return sortStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLStrForColWidths" id="609f17fc-2d1a-414c-b6ca-c0b29fa70199">
        <updating/>
        <source>getXMLStrForColWidths() :String updating;
/*

Purpose:	Extracted code block from getXMLStrForColumns		


Return Value:		


Date		Who		Reason
23 April 2008	cnwer1	Initial creation - PAR#16584

*/
vars
	widthStr : String;
	idx , numCols: Integer;
begin

	numCols := self.columns;
	foreach idx in 1 to numCols do
		if widthStr = null then
			widthStr := self.accessColumn(idx).width.String;
		else
			widthStr := widthStr &amp; ',' &amp; self.accessColumn(idx).width.String;
		endif;
	endforeach;

	
epilog
	return widthStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXmlStrForColumns" id="0cd41d4b-74fd-4592-8426-5c3b8249fd0e">
        <updating/>
        <source>getXmlStrForColumns(_includeColumnWidths : Boolean) : String updating;
//--------------------------------------------------------------
//Created: 15 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str,
	xmlStr,
	tmpStr,
	sortStr,
	widthStr 	: String;
	entRow		: EntTableRow;		
	numCols,
	idx			: Integer;
begin

	if self.allTblDataEntRows.isEmpty then
		return null;
	endif;
	
	//epr par 16584 refactored code into new methods
	tmpStr := self.getXMLStrForColItems();
	
	if _includeColumnWidths then
		widthStr:=self.getXMLStrForColWidths();
	endif;
	
	sortStr :=self.getXMLStrForColSort();
	
	xmlStr := xmlStr &amp;
			global.formatAsXMLPrefix(XMLTag_Table &amp; self.name) &amp;
			global.formatAsXMLPrefix(XMLTag_EntTblDef &amp; self.myEntTableDef.name) &amp;
			tmpStr &amp;
			global.formatAsXML(XMLTag_ColWidth, widthStr) &amp;
			global.formatAsXML(XMLTag_SortOrder, sortStr) &amp;
			global.formatAsXMLSuffix(XMLTag_EntTblDef &amp; self.myEntTableDef.name) &amp;
			global.formatAsXMLSuffix(XMLTag_Table &amp; self.name);

	return xmlStr;
end;</source>
        <Parameter name="_includeColumnWidths" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="48952fd4-2fbb-4564-93cc-7e61d95bee6e">
        <updating/>
        <source>gotFocus(table: Table input) updating;

vars
	tmpFixedRows	: Integer;

begin
	inheritMethod(table);
	if (not self.fromMouseDown) then
		// if the user tabs to the table then set the first row to the non-fixed row
		tmpFixedRows := table.fixedRows;
		if table.rows &gt; tmpFixedRows and table.row &lt;= tmpFixedRows then
			table.row := tmpFixedRows + 1;
		endif;
	else
		self.fromMouseDown := false;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleFormTab" id="a0ea2625-9e93-4cd8-9363-f7f97c49e048">
        <source>handleFormTab(keyCode: Integer io; shift: Integer; pPrev, pNext : Control);
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 02 August 2007
//
//----------------------------------------------------------------------

vars
	entTable	: CM_DataTable;
	lastRowControl,
	prevControl,
	nextControl,
	theActiveControl,
	tmpControl	: Control;
	
begin
	if keyCode &lt;&gt; J_key_Tab then
		// Tab has not been pressed so no need to handle
		return;
	endif;

	theActiveControl := app.activeControl;

	if CM_DataTable.hasInstance(theActiveControl.parent) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	
	prevControl := pPrev;
	nextControl := pNext;

	if shift = 0 and theActiveControl = prevControl then
		// moving forward into table
		if CM_DataTable.hasInstance(prevControl) then
			entTable := prevControl.CM_DataTable;
			//if entTable.row = entTable.bottomEntryRow then
				// on last row of previous table so move to first row of this table
			//	self.moveFirst();
			//endif;
		else
			//self.moveFirst();
		endif;
		
	elseif shift = 1 and theActiveControl = nextControl then
		// moving back into table
		
		if CM_DataTable.hasInstance(nextControl) then
			entTable := nextControl.CM_DataTable;
			//if entTable.row = entTable.topEntryRow then
				// on top row of next table so move to last row of this table
				//self.moveLast();
			//endif;
		else
			//self.moveLast();
		endif;
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="pPrev" type="Control"/>
        <Parameter name="pNext" type="Control"/>
    </JadeMethod>
    <JadeMethod name="hasNoData" id="0660f711-bca2-40e3-9e04-866118023b4f">
        <source>hasNoData(): Boolean;
// created 05/09/2006  cnvwu1

begin

 return (self.rows &lt;= self.fixedRows);
 	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideColumnByColName" id="2e4d445f-d465-4691-bf7b-4c3a5728523d">
        <updating/>
        <source>hideColumnByColName(_name : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx		: Integer;
	str		: String;
	entRow : EntTableRow;
begin

	foreach entRow in self.allTblDataEntRows do
		idx := idx + 1;
		if entRow.name.trimBlanks = _name.trimBlanks then
			self.accessColumn(idx).visible := false;
			return idx;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideColumnByColPropertyName" id="c533a07b-d702-4e23-8e0b-dc1e6bdf5e69">
        <updating/>
        <source>hideColumnByColPropertyName(_entRowName : String) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	heading : String;
	column, i  : Integer;
	idx, entIdx,offset, colIdx	: Integer;
	found 	: Boolean;
	entTableRow : EntTableRow;
	cell : JadeTableCell;
begin
	idx:=self.myEntTableDef.getRowByName(_entRowName);
	if idx = 0 then
		return;
	endif;
	entTableRow:=self.myEntTableDef.allEntTableRows[idx];
	heading:=entTableRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale).trimBlanks;
	row:= self.fixedRows;
	i:=1;
	foreach column in i to self.columns do
		cell:=self.accessCell(row,column);
		if cell.text = heading then		
			colIdx:=i;
			self.accessColumn(column).visible := false;
			found:=true;
			break;
		endif;	
		i:=i+1;
	endforeach;
	
	if not found then
		return;
	endif;
	offset:=self.columns - self.allTblDataEntRows.size;
	self.allTblDataColHeadings.removeAt(column-offset);
	self.allTblDataEntRows.removeAt(column-offset);
	self.allTblDataColPropertyNames.removeAt(column-offset);
	self.allTblDataColInputTypes.removeAt(column-offset);
	
	//11.May.2023 navsp1 TFS 57934
	self.deleteColumn(colIdx);

	
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTableObjectsDynaDict" id="60343b97-9641-4702-aa47-cdc5e5c401b8">
        <updating/>
        <source>initTableObjectsDynaDict(_class : Class; _maxSort : Integer) updating;
//--------------------------------------------------------------
//Created: 12 September 2005 By: cnwgd1
//--------------------------------------------------------------
// 14/10/2009	cnwcs5	par 21171 - sorting issues
vars
	oldDynaDict,
	tmpDynaDict : CM_ExtKeyDynaDictionary;
	obj			: Object;
begin
	
	if _class = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null class');
		return;
	endif;
	
	if self.myDataClass = null then
		self.setMyDataClass(_class);
	endif;
	
	self.setMaxSortColumns(_maxSort);
	
	if self.maxSortColumns &lt;= self.MaxJadeSortColumns then	// par 21171
		// Jade will handle sort upto 6 columns
		return;
	endif;
	
	// use dynaDict to sort table
	oldDynaDict := self.allTableObjects;
		
	create tmpDynaDict transient;
	tmpDynaDict.setMembership(self.myDataClass);
	self.allTableObjects := tmpDynaDict;

	// lastly set the keys
	if not self.addTableObjectsMemberKeys() then
		return;
	endif;
	
	if oldDynaDict &lt;&gt; null then
		foreach obj in oldDynaDict do
			self.allTableObjects.addObject(obj.CM_Object);
		endforeach;
		//oldDynaDict.copy(self.allTableObjects);
	endif;
					
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_maxSort" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isGenFilterableYAMcolumn" id="45b5e681-a7f0-4a84-ba44-09029b76361e">
        <source>isGenFilterableYAMcolumn( entRowName : String ):Boolean;

/*

Purpose:			

Parameters:		Provide a more generic way of determining that this is an entable row we can 
use in the YAM table as a simple display value....  instead of hard coding in multiple places....	

Return Value:		


Date		Who		Reason
04 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if entRowName.trimBlanks &lt;&gt; null then

		if entRowName = ETRow_HasRemarks
		or entRowName = ETRow_Remarks
		or entRowName = ETRow_AvailabilityGrade
