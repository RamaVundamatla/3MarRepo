    <JadeMethod name="getOneStopAperakValues" id="f7af3d3c-993d-451c-bcf8-e4beb6cda257">
        <updating/>
        <source>getOneStopAperakValues( _ediFile: CM_EDIFile output; _docRef : String output; _sentTs : TimeStamp output ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	 ediFile: Any;
	 docRef : Any;
	 sentTs : Any;

begin

	global.getExtraData(self.allExtraData, CM_EDIFileTypeXMLOneStopPre.EDIFileRef, ediFile);
	global.getExtraData(self.allExtraData, CM_EDIFileTypeXMLOneStopPre.TagDocumentRefNum, docRef);
	global.getExtraData(self.allExtraData, CM_EDIFileTypeXMLOneStopPre.TagLocalDateTimeSent, sentTs);
	
	if ediFile &lt;&gt; null and CM_EDIFile.hasInstance( ediFile.Object ) then
		_ediFile := ediFile.CM_EDIFile;
	endif;
	if docRef &lt;&gt; null then
		_docRef := docRef.String;
	endif;
	if sentTs &lt;&gt; null then
		_sentTs := sentTs.TimeStamp;
	endif;
	
epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="output"/>
        <Parameter name="_docRef" type="String" usage="output"/>
        <Parameter name="_sentTs" type="TimeStamp" usage="output"/>
    </JadeMethod>
