    <JadeMethod name="tblJobs_contextMenu" id="2fc2d045-e5c3-4f7f-9608-ba913a1aff93">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobs_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	xLeft, yTop : Real;
begin
	if not app.isRunningOnCE then
		xLeft := x;
		yTop := y;
		conwin.windowToScreen(xLeft, yTop);
		self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
		self.mnuInspect.userObject:=table.accessRow(table.row).itemObject;
		self.popupMenu(mnuContext, xLeft.Integer, yTop.Integer);	
		
		return true;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
