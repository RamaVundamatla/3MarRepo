    <JadeMethod name="populateColourSourceCombo" id="8b920347-c2e3-4e4a-b118-e987dabdf6e1">
        <source>populateColourSourceCombo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwrd1	Initial creation

*/

vars
	opCriteriaColl : CM_YACriteriaTypeArray;
	prevSelected,
	aYACT: CM_YACriteriaType;
begin
	create opCriteriaColl transient;


	self.mltFields.getSelected(opCriteriaColl);
	
	prevSelected := self.cmbCriteriaColou.listObject.CM_YACriteriaType;
	
	self.cmbCriteriaColou.clear();
	
	foreach aYACT in opCriteriaColl do
		if aYACT.hasColourOption then
			self.cmbCriteriaColou.addItemObject( aYACT.description, aYACT);
		endif;
	endforeach;

	if self.cmbCriteriaColou.findObject( prevSelected) &gt; 0 then
		self.cmbCriteriaColou.setObject(prevSelected);
	else
		self.cmbCriteriaColou.setObject(null);
		self.cmbCriteriaColou.text := '';
	endif;

epilog
	delete opCriteriaColl;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateForm" id="3cae7862-f50f-4dea-b9c1-1702f6bcad3d">
        <source>populateForm();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 August 2008	consw1	Initial creation
26/04/2016  cnwma1  PAR #36914 TFS1768 Communicating/NonCommunciating Reefer Yard Allocation Criteria
*/

vars
	imexConfig : CM_YAIMEXConfig;
	imexStatus : CM_IMEXStatus;
	criteriaTypes: ObjectArray;
	criteriaType : CM_YACriteriaType;
begin
	
	imexConfig := self.myProxyYAIMEXConfig.pxyGetRealObject;

	imexStatus := imexConfig.myIMEXStatus;
	
	if imexStatus.code = TI_IMEX_STATUS_NULL then
		self.lblIMEX.caption := "No IMEX";
	else
		self.lblIMEX.caption := "IMEX = " &amp; imexStatus.description;
	endif;
	
	// PAR 19462
	create criteriaTypes transient;
	// PAR 35833 app.myRoot.allYACriteriaTypes.copy(criteriaTypes);
	foreach criteriaType in app.myRoot.allYACriteriaTypes discreteLock where criteriaType.isForCargo()  do// PAR 35833 
		if not criteriaType.isUsed then   //26/04/2016 cnwma1 PAR #36914 TFS1768 
			continue;
		endif;
		criteriaTypes.add(criteriaType);// PAR 35833 
	endforeach;// PAR 35833 
	
	
	criteriaTypes.remove(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus]);
	
	self.mltFields.setAvailable(criteriaTypes, true); 
	self.mltFields.setSelected(imexConfig.allOpCriteria);
	
	self.populateColourSourceCombo();
	self.cmbCriteriaColou.setObject(imexConfig.myDefaultColourType);

	// cnwjk3 SFW1030
	//self.mltGroup.setAvailable(app.myRoot.allYACriteriaTypes, true);  
	self.populateGroupAvailable();
	self.mltGroup.setSelected(imexConfig.allGroupLabelCriteria);
	self.clrColour.setColor(imexConfig.colour);
	
	self.mltFields.setFocus();
epilog
	delete criteriaTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateGroupAvailable" id="111aefda-b215-467f-a508-6599be354d36">
        <source>populateGroupAvailable();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2009	cnwjk3	SFW1030

*/

vars
	obj : Object;
	objFieldSelectedArray : ObjectArray;
begin
	create objFieldSelectedArray transient; 

	// Get a list of Fields selected
	self.mltFields.getSelected(objFieldSelectedArray);
	
	// Populate Group available list with filtered list of items
	self.mltGroup.setAvailable(objFieldSelectedArray, true);  
epilog
	delete objFieldSelectedArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="11dfd14a-a2fd-4142-92e5-cf49d0008977">
        <updating/>
        <source>saveData() : Boolean updating;

/*

Purpose:		Persist data.

Parameters:			

Return Value:	True when update was successful.


Date			Who		Reason
29 August 2008	consw1	Initial creation

*/

vars
	opCriteriaColl, groupLabelCriteriaColl : CM_YACriteriaTypeArray;
	defColourType : CM_YACriteriaType;

begin
	create opCriteriaColl transient;
	create groupLabelCriteriaColl transient;
	
	self.mltFields.getSelected(opCriteriaColl);
	self.mltGroup.getSelected(groupLabelCriteriaColl);
	defColourType := self.cmbCriteriaColou.listObject.CM_YACriteriaType;
	// cnwjk3 SFW1030
	//self.myProxyYAIMEXConfig.setProxy(opCriteriaColl, groupLabelCriteriaColl);
	self.myProxyYAIMEXConfig.setProxy(opCriteriaColl, groupLabelCriteriaColl, self.clrColour.getColor(), defColourType);
	
	app.myTrxUA.trxUpdateYAIMEXConfig(self.myProxyYAIMEXConfig, app.myPassport);

	return app.myPassport.trxCompletedOK;
	
epilog
	delete opCriteriaColl;
	delete groupLabelCriteriaColl;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set" id="6170c541-2691-4460-b19c-907692020332">
        <updating/>
        <source>set( _imexConfig : CM_YAIMEXConfig ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 August 2008	consw1	Initial creation

*/

vars
	
begin
	delete self.myProxyYAIMEXConfig;
	self.myProxyYAIMEXConfig := app.createUpdateProxy(_imexConfig).CM_YAIMEXConfig;		
epilog

end;</source>
        <Parameter name="_imexConfig" type="CM_YAIMEXConfig"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3181be79-f0b5-4e48-9bf5-365b89bbcd04">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
29 Aug 2008	consw1	Initial creation
24 Jun		cnwcs5	par 31719 - xlate Save button caption
*/

vars

begin
	self.centreOverParent(100);
	inheritMethod();

	self.modalResult := IDCANCEL;

	self.btnOk.caption := app.getErrorString (Save);

	self.mltFields.userInputEnabled 			:= true;
	self.mltFields.formDisplayEntryMethodName 	:= CMUI_YAIMEXConfigForm::displayCriteria.name;
	self.mltFields.displayOrderBtns(true, false);
	self.mltFields.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltFields.myAvailableListBox.sorted 	:= true;		
	self.mltFields.mySelectedListBox.sorted 	:= false;
	self.mltFields.setTabIndex();
	self.mltFields.displayAddRemoveBtns(true, false);		//cnwmc5 - 23 October 2013 - PAR 32833
	
	// cnwjk3 SFW1030
	self.mltFields.myBaseForm := self;
	
	self.mltGroup.userInputEnabled := true;
	self.mltGroup.formDisplayEntryMethodName 	:= CMUI_YAIMEXConfigForm::displayCriteria.name;
	self.mltGroup.displayOrderBtns(true, false);
	self.mltGroup.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltGroup.myAvailableListBox.sorted 	:= true;		
	self.mltGroup.mySelectedListBox.sorted 		:= false;
	self.mltGroup.setTabIndex();
	self.mltGroup.displayAddRemoveBtns(true, false);		//cnwmc5 - 23 October 2013 - PAR 32833

	self.populateForm();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="fd706469-19de-43ea-a885-100ceacb2da8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010165, locale);
	cMUI_Label6.translateCaption(Xlat_0010166, locale);
	clrColour.translateBubbleHelp(Xlat_0014634, locale);
	lblColourSource.translateCaption(Xlat_0016924, locale);
	lblFields.translateCaption(Xlat_0010168, locale);
	lblGroup.translateCaption(Xlat_0010169, locale);
	lblIMEX.translateCaption(Xlat_0010170, locale);
end;</source>
    </JadeMethod>
