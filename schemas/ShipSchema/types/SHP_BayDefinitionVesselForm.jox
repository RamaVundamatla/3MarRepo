Date		Who		Reason
28 July 2010	cnwndl1	Initial creation		Par 25127	/ CCMS 1140

*/

vars

begin

	if newSheet = self.shtBayCellLimit then
		return self.doLoadTblCellLimits();
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="folder" type="Folder"/>
