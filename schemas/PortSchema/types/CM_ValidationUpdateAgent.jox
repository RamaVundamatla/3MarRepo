    <JadeMethod name="valTwinCargoForCranePickup" id="f186d176-3c72-45f3-b9d0-5bf2cf4ff0d1">
        <source>valTwinCargoForCranePickup(	_ti,
							_twinTI :CM_TrackedItem input;						
							_tiQdLoc,
							_twinQdLoc: CM_LocationsController);
/*

Purpose:			we have validated the tis for pickup individually now
					have to validate they are ok to be twinned together and are both
					in the right planning state

Date		Who		Reason
10 May 2017	cnwer1	Initial creation TFS 995 VMT refactor moved from MobileServerSchema::CM_ValidationRTAgent valTwinTIsForCranePickup
22 Jan 2020 jlgka1	TFS 47394: Web Apps - To be able to switch error message for twin lift and tandem lift as we use only one error code for both. 
*/

vars
	direction : Integer;
	reasonString,
	twinLocId	: String;
begin


	if not _ti.myPrimaryActualLocation.canTwinLiftWithLocation(_twinTI.myPrimaryActualLocation,_ti,_twinTI,REAL_MODE,direction,reasonString) then
		if _twinTI.myPrimaryActualLocation &lt;&gt; null then
			twinLocId:=_twinTI.myPrimaryActualLocation.getFullId;
		endif;
			//need to change the error but the tracked items should be in the same job since they should be twin
		app.raiseCMException4(Twin_lift_locations, "Twin", _ti.myPrimaryActualLocation.getFullId, twinLocId, reasonString, null, null); //jlgka1 TFS 47394
		return;	
	endif;
		
	//if both containers are either q'd or plannd then check if they are twinabled if not raise an exception
	if _tiQdLoc &lt;&gt; null and _twinQdLoc &lt;&gt; null then
		if not _tiQdLoc.canTwinLiftWithLocation(_twinQdLoc,_ti,_twinTI,QUEUE_MODE,direction,reasonString) then
			//need to change the error but the tracked items should be in the same job since they should be twin
			app.raiseCMException4(Twin_lift_locations, "Twin", _tiQdLoc.getFullId, _twinQdLoc.getFullId, reasonString, null, null); //jlgka1 TFS 47394
			return;	
		endif;	
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tiQdLoc" type="CM_LocationsController"/>
        <Parameter name="_twinQdLoc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="valUNDGCode" id="6f457ccc-9b20-40b4-a1a0-4afba94e1fc0">
        <source>valUNDGCode(_existingUNDGCode, _proxyUNDGCode: CM_UNDangerousGoods);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(_proxyUNDGCode, 'HazardClass Proxy');
	self.raiseExceptionIfNull(_existingUNDGCode, "HazardClass Existing");
	_proxyUNDGCode.raiseExceptionIfNotProxy(method);
	if _existingUNDGCode.code = _proxyUNDGCode.code then
		_proxyUNDGCode.validateForUpdate;
	else
		_proxyUNDGCode.validateForCreate;
	endif;

epilog
	
end;</source>
        <Parameter name="_existingUNDGCode" type="CM_UNDangerousGoods"/>
        <Parameter name="_proxyUNDGCode" type="CM_UNDangerousGoods"/>
    </JadeMethod>
