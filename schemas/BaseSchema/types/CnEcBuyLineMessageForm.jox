    <JadeMethod name="sendTestMessage" id="b0ae1236-b07b-4356-a489-3f0803a4061e">
        <source>sendTestMessage();

vars
	messageObj		: CnEcBNZBuyLineMsg;
	purchaseObj		: CnEcBNZBuyLinePurchase;
	refundObj		: CnEcBNZBuyLineRefund;
	rootObj			: CnEcBaseRoot;
	managerObj		: CnEcBNZBuyLineMgr;
	agentObj		: CnEcBuyLineAgent;
	errorMessage	: String;
	isSuccess		: Boolean;
	expiryDate		: Date;
	expiryMonth		: Integer;
	expiryYear		: Integer;
	trxMethodName	: String;
	
begin

	
	rootObj		:=	app.myBaseRoot;
	managerObj	:=	rootObj.myBuyLineMgr;
	expiryMonth := txtExpiry.text[1:2].Integer;
	expiryYear := txtExpiry.text[3:2].Integer;
	expiryDate.setDate(01,expiryMonth,expiryYear);
		
	create agentObj transient;
	
	if optPurchase.value then
	
		trxMethodName := "trxBNZBuyLinePurchaseCreate";  
		errorMessage := agentObj.trxBNZBuyLinePurchaseCreate(managerObj,	//pBuyLineMgr : CnEcBNZBuyLineMgr io; 
															txtAmount.text.Integer,	//pAmount : Integer;
															txtCardNumber.text,	//pCardNum : String;
															expiryDate,	//pExpiry : Date;	
															purchaseObj	//pBNZBuyLinePurchaseNew : CnEcBNZBuyLinePurchase output
															);
		messageObj := purchaseObj;
															
	elseif optRefund.value then
		
		trxMethodName := "trxBNZBuyLineRefundCreate";  
		errorMessage := agentObj.trxBNZBuyLineRefundCreate(	managerObj,	//pBuyLineMgr : CnEcBNZBuyLineMgr io; 
															txtAmount.text.Integer,	//pAmount : Integer;
															txtCardNumber.text,	//pCardNum : String;
															expiryDate,	//pExpiry : Date;	
															refundObj	//pBNZBuyLineRefundNew : CnEcBNZBuyLineRefund output
															);
		messageObj := refundObj;
		 
	endif;
														
	if errorMessage &lt;&gt; null then
		app.msgBox("theTA." &amp; trxMethodName &amp; " returned : '" &amp; errorMessage &amp; "'.", "Error", MsgBox_OK_Only);
		txtResponse.text := errorMessage;
	else
		/*
		// Commented out portion is purely a sample of how to handle an alternate currency, in this case Australian dollars;
		// See BNZBuyLineMsg::setCurrency for a list of valid currencies.
		 
		errorMessage := agentObj.trxBNZBuyLineMsgSetCurrency(msg,	//pBNZBuyLineMsgToUpdate : CnEcBNZBuyLineMsg io;
															msg.edition,	//pRequiredEdition : Integer;
															"AUD"	//pCurrency : String
															);
		if errorMessage &lt;&gt; null then
			app.msgBox("myTA.trxBNZBuyLineMsgSetCurrency returned : '" &amp; errorMessage &amp; "'.","Error",MsgBox_OK_Only);
			txtResponse.text := errorMessage;
		endif;
		*/
	endif;		
			
	if errorMessage &lt;&gt; null then																																																				
		txtResponse.text := messageObj.sendMessage(isSuccess);
		txtResponse.text := "Success = " &amp; isSuccess.String &amp; CrLf &amp; CrLf &amp; txtResponse.text; 		
	endif;												 

	folder1Sheet3.setFocus();
epilog
	delete agentObj;	
end;</source>
    </JadeMethod>
    <JadeMethod name="setVisibility" id="48d1b2d5-e403-412f-bef7-b7c3251d3edc">
        <source>setVisibility();

begin
	if optPurchase.value or optRefund.value then
		lblAmount.visible		:=	true;
		lblCardNumber.visible	:=	true;
		lblExpiry.visible		:=	true;
		txtAmount.visible		:=	true;
		txtCardNumber.visible	:=	true;
		txtExpiry.visible		:=	true;
	else
		lblAmount.visible		:=	false;
		lblCardNumber.visible	:=	false;
		lblExpiry.visible		:=	false;
		txtAmount.visible		:=	false;
		txtCardNumber.visible	:=	false;
		txtExpiry.visible		:=	false;		
	endif;		
end;</source>
    </JadeMethod>
</GUIClass>
