<CollClass name="CM_ISOTypeGroupByCodeColourDic" id="09641164-0ca1-4e02-9898-de4bc64fc0cb">
    <memberType name="CM_ISOTypeGroup"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CM_Group::code"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Group::colour"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="9126a5ca-52f1-4c36-a75c-8b7290b0bc6e">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj : MemberType) : Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyCode	: String;
	keyNum	: Integer;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyCode, keyNum, iter);
			self.removeKey(keyCode, keyNum);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
