    <JadeMethod name="changeSplitInto" id="e2cf486c-34e3-49f2-bd0d-b7a55cac8152">
        <source>changeSplitInto();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

	numDataRows : Integer;
	totalRows : Integer;
	selectRow : Integer;

begin

	numDataRows := self.txtSplitInto.text.Integer;
	totalRows := numDataRows + 1;

	if totalRows = self.tblSplits.rows then
		//no change
		return;
	endif;
	
	if self.tblSplits.rows = 1 then
		//not currently populated select the first data entry row
		selectRow := 2;
	endif;
	
	self.tblSplits.rows := totalRows;
	
	if selectRow &gt; 1 then
		self.tblSplits.accessRow( selectRow ).selected := true;	
	endif;
	
	self.setFromSelectedLine();
	
	
epilog

end;</source>
    </JadeMethod>
