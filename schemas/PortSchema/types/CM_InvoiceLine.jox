    <JadeMethod name="zzGetVoyageCode" id="46954259-1c1e-467c-8518-79766aa9cc39">
        <source>zzGetVoyageCode() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navpw1	Initial creation TFS: 60965

*/

vars
	voyage				: CM_Voyage;
	currentTrackedItem	: CM_TrackedItem;
	
begin
	voyage := self.getMyVoyageObject();
	currentTrackedItem := self.trackedItem;
	
	if voyage &lt;&gt; null then		
		return voyage.code;			//03.09.2020 cnwma1 #49996
	else
		if currentTrackedItem &lt;&gt; null then
			return currentTrackedItem.voyageCode;
		endif;
	endif;
	
	return null;
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
