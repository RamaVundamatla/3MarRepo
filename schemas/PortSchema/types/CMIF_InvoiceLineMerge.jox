<Class name="CMIF_InvoiceLineMerge" id="e8f7fb77-840f-4505-a28f-4d1ffb811604">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="allInvoices" id="f2374b63-4541-4e8e-9bd5-9c36c10b12c8">
        <memberTypeInverse/>
        <type name="CM_InvoiceSet"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTargetInvoice" id="66a97661-ec14-483a-9d9a-c3a23f7f1ba9">
        <embedded/>
        <type name="CM_Invoice"/>
    </ImplicitInverseRef>
    <JadeMethod name="validateInvoices" id="b492550a-8444-41ab-86b7-328287a123f1">
        <source>validateInvoices();
/*
Purpose:			

Date		Who		Reason
08 January 2024	navab1	CR 58085 TASK 61342
*/

vars
	targetInvoice, invoice, otherInvoice : CM_Invoice;
	debtor : CM_Debtor;
	numTASCN, numTASINV : Integer;
	hasTAS : Boolean;
begin
	targetInvoice := self.myTargetInvoice;
	
	if not targetInvoice.canMerge() then
		app.raiseCMException(Invoi_with_statu_canno_part_me,"",null);
	endif;
	
	if targetInvoice.isTASCreditNote() then
		numTASCN += 1;
	endif;
	if targetInvoice.isTASInvoice() then
		numTASINV += 1;
	endif;
	
	debtor := targetInvoice.debtor;
	
	foreach invoice in self.allInvoices discreteLock do
		if invoice.debtor &lt;&gt; debtor then
			app.raiseCMException(Invoi_merge_opera_must_have_sa,"",null);
		endif;
	
		if not invoice.canMerge() then
			app.raiseCMException(Invoi_with_statu_canno_part_me,"",null);
		endif;
		
		if invoice.category &lt;&gt; targetInvoice.category  then
			app.raiseCMException(Invoi_merge_opera_same_cate,"",null);
		endif;
		
		if invoice.isTASCreditNote() then
			hasTAS := true;
			numTASCN += 1;
			
			if numTASCN &gt; 1 then
				app.raiseCMException1(Canno_merge_more_than_credi_no,self.myTargetInvoice.sequenceNum.String,"",null);
			endif;
		endif;
		if invoice.isTASInvoice() then
			hasTAS := true;
			numTASINV += 1;
			
			if numTASINV &gt; 1 then
				app.raiseCMException1(Canno_merge_more_than_invoi_in,self.myTargetInvoice.sequenceNum.String,"",null);
			endif;
		endif;
	endforeach;
	
	if hasTAS then // if merge includes TAS invoice then check that we do not already have one, can only have 1 TAS invoice .
		if targetInvoice.isCreditNote then
			foreach otherInvoice in targetInvoice.allMergedInvoices discreteLock do
				if otherInvoice.isTASCreditNote() then
					app.raiseCMException1(Invoi_alrea_credi_note_canno_a,targetInvoice.sequenceNum.String,"",null);
				endif;
			
			endforeach;
		endif;
		if targetInvoice.category = InvoiceCategory_Invoice then
			foreach otherInvoice in targetInvoice.allMergedInvoices discreteLock do
				if otherInvoice.isTASInvoice() then
					app.raiseCMException1(Invoic_alread_invoic_cannot_an,targetInvoice.sequenceNum.String,"",null);
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
