    <JadeMethod name="cleanUpStorageDetailPriority" id="799e7a24-f63e-47e8-a038-47f40935131a">
        <source>cleanUpStorageDetailPriority(_controller: CnEcReleaseController);
/*

Purpose:		TFS 4271	

Parameters:			

Return Value:		

Date		Who		Reason
*/

vars
	r : CM_Root;
	t : CM_Terminal;
	s : CM_StorageConfig;
	d, pxyStorageDetail : CM_StorageDetail;
	f : CM_FutureStorageMapping;
	total : Integer;
	yavalue, itemCode : String;
	c, proxyCriteria : CM_YACriteria;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Fixing storage config detail priority", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Fixing storage config detail priority") ;	
	endif;
	
	r := CM_Root.firstInstance();
	
	beginTransaction;
	foreach t in r.allTerminals do
		s := t.myStorageConfig;
		
		if s &lt;&gt; null then

			s.allYACriteriaTypes.rebuild();

			foreach d in s.allStorageDetails do
			
				beginLoad;
				pxyStorageDetail := d.pxyCreateUpdateProxy();
				pxyStorageDetail.setPropertyValue("myStorageConfig",s);
				endLoad;
				
				
				// The storage detail allocations wrongly have all the criteria types that are configured including ones with no data.
				// This is wrong because it means all allocations will have the same generated priority
				// The following will create proxy criteria  that only has values for the proxy storage detail
				foreach c in d.allCriteriaByType do
					yavalue:= c.myYACriteriaType.getDataDisplay(c.myYAData);
					if yavalue.trimBlanks &lt;&gt; null then
					
						beginLoad;
						proxyCriteria := c.pxyCreateUpdateProxy();
						endLoad;

						proxyCriteria.CM_YACriteria.setYardAllocation(pxyStorageDetail);
					endif;
				endforeach;
					
				// update the storage detail so that it only has the criteria with values, this also resets the priority
				app.myUtilityUA.utlUpdateStorageDetail(pxyStorageDetail, app.myPassport);
				total := total+ 1;

				// Seperatly set all the mappings to SINGLE
				foreach f in d.allFutureStorageMappings do
					f.myQuantityMap.setMappingType(CM_QuantityMap.MapType_Single);
				endforeach;
				
				delete pxyStorageDetail;
			endforeach;
		
		endif;
	
	endforeach;	
	
	commitTransaction;
	
epilog

	app.writeLog(method.qualifiedName &amp; " Completed fixing storage config detail priority, " &amp; total.String &amp; " done", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Fixing storage config detail priority - COmpleted") ;	
	endif;
	
	
	self.addScriptRun(method.name);


end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAutoGenIdResetSeq" id="73c68a86-797a-4425-86b2-82203a7e38ec">
        <source>convertAutoGenIdResetSeq(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2019	jlgndl1	Initial creation

*/

vars

	autoId : CM_AutoIdGenerator;
	objArray : ObjectArray;
	obj : Object;

begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; 'Configuring Auto Id Generators to use new resetSeq attribute ', LogINFO);
	create objArray transient;
	CM_AutoIdGenerator.allInstances(objArray, 0, true);
	beginTransaction;
	foreach obj in objArray do
		autoId := obj.CM_AutoIdGenerator;
		autoId.convertForResetData();	
	endforeach;
	commitTransaction;
	app.writeLog( method.qualifiedName &amp; 'Completed Configuring Auto Id Generators to use new resetSeq attribute ', LogINFO);
	
	self.addScriptRun(method.name);
	
epilog

	delete objArray;

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertEmailReceivalSetting" id="dbb8565c-827a-4345-9d8d-6d7606a07d86">
        <source>convertEmailReceivalSetting(_updController : CnEcReleaseController);
//
// 03 Feb 2017	cnwrs1	TFS 3247 not deleting emails at NXL
//
vars
	terminal : CM_Terminal;
	converted : Boolean;
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; 'Upgrading Email Receival Imap Flags from 8.5.1 to 8.6.1', LogINFO);
	foreach terminal in app.myRoot.allTerminals do
		converted := terminal.getExtensionObjectValue(Obj_Extn_terminalImapFlags).Boolean;
		if converted then
			return;
		endif;
		beginTransaction;
		terminal.setExtensionObjectValue(Obj_Extn_terminalImapFlags, true);
		terminal.setConfig(AutoImapFlags, 1);
		commitTransaction;
	endforeach;
	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of Email Receival Imap Flags from 8.5.1 to 8.6.1', LogINFO);
	
	self.addScriptRun(method.name);
epilog
end;
</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertOperatorCarriers" id="f4c53a6e-8bd8-4ed2-b148-307b578d434f">
        <source>convertOperatorCarriers(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	operator : CM_Operator;
	iter : Iterator;
	cargoTypeKey : Integer;
	cargoType : CM_CargoType;
	carrierSet : CM_CarrierSet;
	criterionType : CM_YACriteriaType;
	obj : Object;
	criteria : CMIF_Array;
	proxyCriterion : CM_YACriteria;
	cmifCriterion : CMIF_YACriteriaPriority;
	itemCode : String;
	value : Any;
	proxy : CM_OperatorCarrierCriteria;
	realCriteria : CM_ObjectMatchCriteria;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Convert CM_Operator::allCarriersByCargoTypeId info to CM_OperatorCarrierCriteria", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(method.qualifiedName &amp; " Convert CM_Operator::allCarriersByCargoTypeId info to CM_OperatorCarrierCriteria");
	endif;
	
	criterionType := app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType];
	create criteria transient;
	
	beginTransaction;
	foreach operator in CM_Operator.instances do
		if operator.allCarriersByCargoTypeId.isEmpty then
			continue;
		endif;
		
		iter := operator.allCarriersByCargoTypeId.createIterator;
		while iter.next(obj) do
			operator.allCarriersByCargoTypeId.getIteratorKeys(cargoTypeKey, iter);
			cargoType := app.myRoot.allCargoTypesById[cargoTypeKey];
			if cargoType = null then
				continue;
			endif;
			
			carrierSet := obj.CM_CarrierSet;
			
			// set up the proxy criteria details
			create proxyCriterion transient;
			itemCode := "Cargo Type";
			value := cargoType.getYAIdentifier;
			
			proxyCriterion.setProxy(criterionType, value, itemCode);
			cmifCriterion := proxyCriterion.getTransient();
			criteria.add(cmifCriterion);
			
			// create a proxy CM_OperatorCarrierCriteria object
			create proxy transient;
			proxy.setProxy(criteria, null);
			proxy.setAllCarriers(carrierSet);
			proxy.setMyOperator(operator);
			
			app.myUtilityCA.utlCreateObjMatchCrit(proxy, realCriteria, app.myPassport);
			if app.myPassport.hasErrorsOrWarnings then
				// log an error
				app.writeLog(method.qualifiedName &amp; " Conversion for Operator " &amp; operator.code &amp; " cargo Type " &amp; value.String &amp; " has FAILED *********", LogINFO);
				app.writeLog(method.qualifiedName &amp; app.myPassport.getErrorsAndWarningsAsString, LogINFO);
				if _controller &lt;&gt; null then
					_controller.logEntry(method.qualifiedName &amp; " Conversion for Operator " &amp; operator.code &amp; " cargo Type " &amp; value.String &amp; " has FAILED *********");
					_controller.logEntry(method.qualifiedName &amp; app.myPassport.getErrorsAndWarningsAsString);
				endif;
			endif;
			
			// tidy up transients
			delete proxy;
			delete proxyCriterion;
			delete cmifCriterion;
			criteria.clear;
		endwhile;
		delete iter;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Convert CM_Operator::allCarriersByCargoTypeId info to CM_OperatorCarrierCriteria", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(method.qualifiedName &amp; " Convert CM_Operator::allCarriersByCargoTypeId info to CM_OperatorCarrierCriteria");
	endif;
	self.addScriptRun(method.name);
	
epilog
	delete criteria;
	delete iter;
	delete proxy;
	delete proxyCriterion;
	delete cmifCriterion;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertTermConfigToBank" id="bda6b2a5-6940-420e-a026-bdd3c30de57c">
        <source>convertTermConfigToBank(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

	terminal : CM_Terminal;
	bank : CM_Bank;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Convert Term Configs to Default Bank Configs", LogINFO);

	beginTransaction;
	
	foreach terminal in app.myRoot.allTerminals do
		bank := null;
		bank := terminal.getDefaultCompanyBank;
		if bank = null then
			continue;
		endif;
		bank.setConfig( CashInvoiceType, terminal.getConfig( CashInvoiceType ) );
		bank.setConfig( CashRoundInvLineType, terminal.getConfig( CashRoundInvLineType ) );
		bank.setConfig( CashRoundUpAmount, terminal.getConfig( CashRoundUpAmount ) );
		bank.setConfig( CashRoundingType, terminal.getConfig( CashRoundingType ) );
		bank.setConfig( CashTaxInvLineType, terminal.getConfig( CashTaxInvLineType ) );
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Convert Term Configs to Default Bank Configs - Complete", LogINFO);
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertTidalClassRates" id="ae61d3cf-2519-4db5-92e8-7e24ebd0b251">
        <source>convertTidalClassRates(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgndl1	Initial creation	TFS 39338

*/

vars
	rateIter : Iterator;
	rate : CM_Rate;
	allRateObjs : ObjectArray; 
	allTidalClasses : ObjectArray; 
	idx,rateidx, numCPUs, numTCs : Integer;
	ct : CM_CalculationType;
	lFile	: File;
	obj : Object;
	service : CM_Service;
	found : Boolean;
	tidalClass : HMS_TidalClass;
	rateEntry : CM_RateEntry;
	cpu : Decimal[23,6];
	tcr : CM_TidalClassRate;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Updating Tidal Class Rates to new structure", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating Tidal Class Rates to new structure") ;	
	endif;
	
	create allRateObjs transient;
	CM_Rate.allInstances(allRateObjs,0,true);
	rateIter := allRateObjs.createIterator;

	create allTidalClasses transient;
	app.sortTidalClasses(allTidalClasses);
	numTCs := allTidalClasses.size;
	
	while rateIter.next(rate) do
	
		service := rate.service;
		
		if service &lt;&gt; null then
			ct := service.myCalculationType;
			
			if ct &lt;&gt; null then
				if ct.calculationType = INV_CALC_TYPE_TIDAL_CLASS then
					beginTransaction;
					foreach rateEntry in rate.rateEntries do
						if rateEntry.allRatesByTidalClass.isEmpty() then // NOT Converted yet
							idx := 1;
							numCPUs := rateEntry.allCostPerUnits.size;
							
							foreach rateidx in 1 to numCPUs do
								tidalClass := null;
								if rateidx &lt;= numTCs then
									tidalClass := allTidalClasses[rateidx].HMS_TidalClass;
									cpu := rateEntry.allCostPerUnits[rateidx];
								endif;
								if tidalClass &lt;&gt; null then
									create tcr persistent;
									tcr.setDetails(	cpu,	//_costPerUnit : Decimal;
													tidalClass,	//_myTidalClass : HMS_TidalClass;
													rateEntry	//_myRateEntry : CM_RateEntry
													);
								endif;
								
							endforeach;
							
							if numCPUs &gt; 0 and rateEntry.allRatesByTidalClass.size = numCPUs then
								//conversion has been successfull
								rateEntry.allCostPerUnits.clear();
							endif; 
							
						endif;
					endforeach;
					commitTransaction;
				endif;
			endif;
		endif;
	endwhile;
	
	app.writeLog(method.qualifiedName &amp; " Updating Tidal Class Rates to new structure complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating Tidal Class Rates to new structure complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

	delete allRateObjs;
	delete allTidalClasses;
	delete rateIter;
	
end;
</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertToUseStorageConfig" id="eead1be4-2a35-4142-9b54-3809798412c9">
        <source>convertToUseStorageConfig( _controller : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2019	jlgndl1	Initial creation	TFS 45574

*/

vars

	terminal : CM_Terminal;
	storageConfig : CM_StorageConfig;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	triggersIntArray : IntegerArray;
	includeFirstDay : Boolean;
	
	allPxyTriggers : CM_StorageTriggerByType;
	triggerInt : Integer;
	pxyStorageTrigger : CM_StorageTrigger;
	proxyStorageConfig : CM_StorageConfig;
	
	realStorageConfig : CM_StorageConfig;
	operatorTerminal : CM_OperatorTerminal;
	tempOperTerminals : CM_OperatorTermByOperatorDict;

begin

	//Have we run it before
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;	
	
	app.writeLog( method.qualifiedName &amp; " Convert all Terminals to use 'Storage Config'", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert all Terminals to use 'Storage Config'") ;	
	endif;
	
	firstDayTimeCutoff := "00:00".Time;
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ContentsStatus]);
	
	create triggersIntArray transient;
	triggersIntArray.add( StorageDebtor );
	triggersIntArray.add( IMEX_EX_TO_IM );
	triggersIntArray.add( IMEX_EX_TO_ST );
	triggersIntArray.add( IMEX_IM_TO_EX );
	triggersIntArray.add( IMEX_IM_TO_ST );
	triggersIntArray.add( IMEX_IM_TO_TR );
	triggersIntArray.add( IMEX_ST_TO_EX );
	triggersIntArray.add( IMEX_ST_TO_IM );
	triggersIntArray.add( IMEX_TR_TO_EX );
	triggersIntArray.add( IMEX_TR_TO_IM );
	triggersIntArray.add( IMEX_TR_TO_ST );
	triggersIntArray.add( SubTerminal );
	triggersIntArray.add( VoyageChange );
	
	create tempOperTerminals transient;
	
	foreach terminal in app.myRoot.allTerminals discreteLock do
		storageConfig := terminal.myStorageConfig;
		if terminal.myStorageConfig &lt;&gt; null then
			app.writeLog( method.qualifiedName &amp; " " &amp; terminal.code &amp; " already using 'Storage Config'", LogINFO );
			if _controller &lt;&gt; null then
				_controller.logEntry( " " &amp; terminal.code &amp; " already using 'Storage Config'" ) ;	
			endif;
		else
		
			tempOperTerminals.clear();
			foreach operatorTerminal in terminal.allOperatorTerminals do
				if operatorTerminal.emptyFreeStorageDays &gt; 0
				or operatorTerminal.freeStorageDays &gt; 0
				or operatorTerminal.fullFreeStorageDays &gt; 0
				then
					tempOperTerminals.add( operatorTerminal );
				endif;
			endforeach;
		
			create allPxyTriggers transient;
			foreach triggerInt in triggersIntArray do
				create pxyStorageTrigger transient;
				pxyStorageTrigger.setProxy( triggerInt, false, null);
				allPxyTriggers.add(pxyStorageTrigger);
			endforeach;
			
			includeFirstDay := terminal.getConfig(InvStorageDaysInclusive).Boolean;
		
			create proxyStorageConfig transient;
			proxyStorageConfig.setProxy(criteriaTypes,	//_criteria : CM_YACriteriaTypeArray; 
										allPxyTriggers,	//_triggers : CM_StorageTriggerByType;
										firstDayTimeCutoff,	//_firstDayTimeCutoff : Time;
										includeFirstDay,	//_includeFirstDay : Boolean;
										true,	//_includeLastDay : Boolean; 
										terminal,	//_terminal : CM_Terminal;
										CM_StorageConfig.ShipReceivalActualDischarge,	//_shipReceivalType : Integer;
										CM_StorageConfig.ShipReleaseActualLoad,	//_shipReleaseType : Integer;
										null,	//_calendar : CM_Calendar;
										null,	//_compulsory : CM_Calendar
										-1,		//_roadReceivalType : Integer;
										-1,		//_railReceivalType : Integer;
										-1		//_unpackReceivalType : Integer;
										);
			
			app.myTrxCA.trxConvertToNewStorageConfig( proxyStorageConfig, realStorageConfig, tempOperTerminals, app.myPassport );
			
			if not app.myPassport.trxCompletedOK then
				app.writeLog( method.qualifiedName &amp; " Convert all Terminals to use 'Storage Config' - Error " &amp; app.myPassport.getErrorsAndWarningsAsString, LogINFO);
				if _controller &lt;&gt; null then
					_controller.logEntry(" Convert all Terminals to use 'Storage Config' - Error " &amp; app.myPassport.getErrorsAndWarningsAsString) ;	
				endif;
				return;
			endif;
			
			if allPxyTriggers &lt;&gt; null then
				if not allPxyTriggers.isEmpty then
					allPxyTriggers.purge();
				endif;
				delete allPxyTriggers;
			endif;
			delete proxyStorageConfig;
			
			app.writeLog( method.qualifiedName &amp; " " &amp; terminal.code &amp; " now using 'Storage Config'", LogINFO );
			if _controller &lt;&gt; null then
				_controller.logEntry( " " &amp; terminal.code &amp; " now using 'Storage Config'" ) ;	
			endif;
			
			foreach operatorTerminal in tempOperTerminals where operatorTerminal.myOperator &lt;&gt; null do
				app.writeLog( method.qualifiedName &amp; " - added storage detail for " &amp; terminal.code &amp; "/" &amp; operatorTerminal.myOperator.code, LogINFO );
				if _controller &lt;&gt; null then
					_controller.logEntry( " - added storage detail for " &amp; terminal.code &amp; "/" &amp; operatorTerminal.myOperator.code ) ;	
				endif;
			endforeach;

		endif;
	endforeach;
	
	
	app.writeLog( method.qualifiedName &amp; " Convert all Terminals to use 'Storage Config' - Complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert all Terminals to use 'Storage Config' - Complete") ;	
	endif;	
	// Log that it already ran.
	self.addScriptRun(method.name);

epilog

	delete criteriaTypes;
	delete triggersIntArray;
	if allPxyTriggers &lt;&gt; null then
		if not allPxyTriggers.isEmpty then
			allPxyTriggers.purge();
		endif;
		delete allPxyTriggers;
	endif;
	delete proxyStorageConfig;
	
	delete tempOperTerminals;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="copyHireDTtoPlannedDT" id="1686194d-0dea-484f-8c4c-b2a6ed62d01e">
        <updating/>
        <source>copyHireDTtoPlannedDT(_controller: CnEcReleaseController) updating;
/*

Purpose:	As part of replacing hireDT with plannedDT in future storage-date calculations,
			copy any valid hireDT values to plannedDT if plannedDT is null

Parameters:			

Return Value:		

Date		Who		Reason
26 Feb 2018	jlgsl4	Initial creation
05 Oct 2022 navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
*/

vars
	container 		: CM_TrackedItem;
	hiredate  		: TimeStamp;
	storageDetail   : CM_StorageDetail;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Copying non-null hireDT value to plannedDT when plannedDT is null", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Copying non-null hireDT value to plannedDT when plannedDT is null") ;	
	endif;

	beginTransaction;
		foreach container in CM_Container.instances discreteLock do
			hiredate := container.hireDT;
			if hiredate &lt;&gt; null and container.plannedDT = null then // if hireDT is valid and plannedDT null, plannedDT := hireDT
				//container.setFutureStorageAnniversary(hiredate.Date,storageDetail);	//05.10.2022 navma1 #52967 //21/06/2023 navmv20 CR 58373 Task 58381
				container.setFutureStorageAnniversary(hiredate.Date,storageDetail,false); //21/06/2023 navmv20 CR 58373 Task 58381
			endif;
		endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Copying non-null hireDT value to plannedDT when plannedDT is null complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Copying non-null hireDT value to plannedDT when plannedDT is null complete") ;	
	endif;
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
