    <JadeMethod name="getAllQueuesForType" id="58c12b9e-e8be-45ed-b3a8-416fa4a3f145">
        <source>getAllQueuesForType(_queues : Collection input;
					_queueType : Integer);
/*

Purpose:	gets all the queues depending on the queue type i.e. primary or secondary queue


Return Value:		


Date		Who		Reason
13 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	ta : CM_TerminalAreaMaster;
	subQueue : CM_RadioTelemetryQueue;
	machineType	: CM_MachineType;
	masterQueue : CM_MasterQueue;
begin
	if self.myMachine = null then
		return;
	endif;

	if self.myTerminal.radioTelemetry = null then
		return;
	endif;
	masterQueue	:= self.myTerminal.radioTelemetry.masterQueue;
	if _queueType = self.Primary then
		masterQueue.getAllQueuesForMachineTA(self.myMachine,_queues);
	elseif _queueType = self.Secondary then
		if self.myMachine.allQueues.size &gt; 0 then
			self.myMachine.allQueues.copy(_queues);
		endif;	
	endif;
	
	
epilog

end;</source>
        <Parameter name="_queues" type="Collection" usage="input"/>
        <Parameter name="_queueType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentSetdownTask" id="3e0de46a-3ecb-4e4c-8b51-ce651b8497fc">
        <source>getCurrentSetdownTask() : CM_RTQueueTask;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	currentTask ,task: CM_RTQueueTask;
	entry : CM_RTQueueEntry;
begin

	currentTask :=self.getCurrentTask;
	if currentTask = null then
		return null;
	endif;
	entry:=currentTask.myEntry;
	foreach task in entry.allTasks do
		if task.taskType = TASK_SETDOWN then
			return task;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
