    <JadeMethod name="updateMoveToLogBerth" id="7e7043c8-0b58-416f-8efd-a3325d443373">
        <updating/>
        <source>updateMoveToLogBerth(berth:HMS_Berth):Boolean updating;

vars
	origCurrent			: CMIF_HMS_WorkingMovement;
	origNext			: CMIF_HMS_WorkingMovement;
	clonedMovement		: CMIF_HMS_WorkingMovement;
	clonedMovementNext	: CMIF_HMS_WorkingMovement;
	clonedVoyage		: CMIF_HMS_WorkingVoyage;
	wp					: CMIF_HMS_WharfPosnCheckParams;
	cntrl				: Control;
	changeOK			: Boolean;
	harbourObj			: HMS_Harbour;

begin
	// Set default for changeOK
	changeOK := false;
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();		

	cntrl := myGraphicalViewForm.myCurrentDragPicture;//.defaultShip.getControl(myGraphicalView.currentlySelectedShip);
	origCurrent 	:= cntrl.DragPicture.myMovement;
	origNext		:= cntrl.DragPicture.myNextMovement;

	// Clone voyage and movements
	//origCurrent.myWorkingVoyage.createClone;
	clonedVoyage:= origCurrent.myWorkingVoyage.createClone(); //self.myViewController.ofCurrentClonedVoyage;
    clonedMovement 		:= origCurrent.myClone;
	clonedMovementNext	:= clonedMovement.getMovementNext;


	// Update berth details		
	clonedMovement.myBerth 			:= berth;
	clonedMovement.setBerthMark(0, 0, clonedMovement.sideTo, ClearanceUnbounded, ClearanceUnbounded);

	clonedMovement.cloneHasChanged := true;
	
	if self.myTerminal &lt;&gt; null then
		harbourObj	:=	self.myTerminal.myHarbour;
	endif;
	
	//	Validate voyage
	if harbourObj &lt;&gt; null and (not clonedVoyage.validateVoyage(harbourObj.isDoClearanceCheck)) then
		return false;
	endif;

	if app.myPassport.hasErrorsOrWarnings() then
		if app.showErrorWarningDialog('Update Movement', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings) = IDOK then
			//Warnings have been accepted
		else
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
	endif;
	self.clearErrorWarnings();
	// disarm the validation ex handler	
	on CM_Exception do null;	
		
	// Update views following the result of the validation
	foreach clonedMovement in clonedVoyage.allClonedMovements where clonedMovement.cloneHasChanged=true do
		clonedMovement.createWorkingMovement(null,false,false, false);
	endforeach;
	clonedVoyage.ofViewController.view_BuildEntireForeground();  		
	return true;

epilog
	// Delete clonedVoyage, resources and movements
	foreach clonedMovement in clonedVoyage.allClonedMovements do
		clonedMovement.allWorkingResUsed.purge;
	endforeach;
	clonedVoyage.allClonedMovements.purge;
	delete clonedVoyage;
	delete wp;	
end;</source>
        <Parameter name="berth" type="HMS_Berth"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
