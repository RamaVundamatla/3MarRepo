    <JadeMethod name="btnDocActions_click" id="37214e68-3157-4ce1-bad6-839c9069173f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDocActions_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/09/2016	cnwdap1		Initial creation TFS 2653
//
vars
	bookingItemSet : CM_BookingRefItemSet;
	obj : Object;
	docAction : CM_BookingItemActions;

begin
	create bookingItemSet transient;
	foreach obj in self.docActsToDisplay do
		docAction := obj.CM_BookingItemActions;
		bookingItemSet.addNoDuplicates(docAction.myBookingItem, false);
	endforeach;
	
	self.myMobileGenericAgent.setAllBookingRefItems(bookingItemSet);
	self.myMobileGenericAgent.setStringField1( self.fldCargo.topSheet.name );
	self.myMobileGenericAgent.setMyNextTiToAction( null );
	self.gotoForm( MOB_HHDocumentActions, false );
	
epilog
	delete bookingItemSet;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clickInYardItem" id="2a9fb076-04a2-4eb5-819a-3388e19f0ad8">
        <updating/>
        <source>clickInYardItem(_obj : Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#			Description
============================================================================
03/02/2010	cnwndl1	CCMS MES 1005	Initial creation	
20/03/2019	jlgka1 	TFS 43259		STWO - HH Truck Unloader with Edit Config Issue.
									Only give an option to increase and decrease
									unloaded quantity when all cargo in the Gate
									Receival are unloaded.
============================================================================*/


vars
	trackedItem			 : CM_TrackedItem;
	opt1Str 			 : String;
	opt2Str 			 : String;
	opt3Str 			 : String;
	matchingCargoOnTruck : CM_Cargo;
	returnValue 		 : Integer;
	moveCargoBack 		 : Boolean;
	defaultOption 		 : Integer;
	unloadedQuantity 	 : Integer;
	unloadedWeight 		 : Decimal [16,4];
	reloadQuantity 		 : Integer;
	reloadWeight 		 : Decimal [16,4];
	msg 				 : String;
	cmgteReceive 		 : CMGTE_Receival;	
	vvr 				 : CM_VehicleVisitRecord;
begin

	if CM_TrackedItem.hasInstance( _obj ) then
		trackedItem := _obj.CM_TrackedItem;
	endif;
	
	vvr := self.myMobileGenericAgent.myTruck.getCurrentVisit();
	if vvr &lt;&gt; null then
		cmgteReceive := vvr.allGateEntities.getMatchingGTEReceive( trackedItem.myCargoType.id, trackedItem.id );				
	endif;
	//27 Aug 2018	NDL	TFS 40309 - 'STWO &amp; Steve' view of the world
	if cmgteReceive &lt;&gt; null then // jlgka1 TFS 43259
		if trackedItem.myTerminal.getConfig( HhTUnloadEdit ).Boolean then // jlgka1 TFS 43259
			if trackedItem &lt;&gt; null and trackedItem.myTerminal &lt;&gt; null and trackedItem.myCargoType.allowDuplicates then
				
				self.myMobileGenericAgent.getUnloadedAmountMatching( trackedItem, unloadedQuantity, unloadedWeight );
			
				opt1Str := app.getErrorString( Change_amount_unloaded );
				opt2Str :=app.getErrorString( Move_cargo_back_truck );
				opt3Str := app.getErrorString(None_above_cancel);
				defaultOption := 2;
				matchingCargoOnTruck := self.myMobileGenericAgent.myTruck.getMatchingCargoOnBoard( trackedItem.myCargoType, trackedItem.id );
				if matchingCargoOnTruck &lt;&gt; null then
					defaultOption := 1;
				endif;
				if cmgteReceive.isFromPrenote and self.isCargoUnloaded(trackedItem, cmgteReceive) then // jlgka1 TFS 43259				
					returnValue := self.optBox(opt1Str, opt2Str, opt3Str, null, defaultOption, app.getErrorString(Select_option) );
					if returnValue = 1 then
						self.doChangeAmountProcessing( trackedItem, unloadedQuantity, unloadedWeight, matchingCargoOnTruck );
						return;					
					elseif returnValue = 2 then
						app.myTrxUA.trxAdjustBreakBulkUnloaded( matchingCargoOnTruck,	//_targetTi : CM_Cargo io;
																trackedItem.CM_Cargo,	//_sourceTi : CM_Cargo io;
																unloadedQuantity, //_quantity : Integer;
																unloadedWeight,	//_weight : Decimal;
																self.myMobileGenericAgent.myTruck,	//_truck : CM_Vehicle;
																true,	//_isMoveAllCargoBack : Boolean;
																app.myPassport	//_passport : CM_Passport input
																);
													
						msg := app.myPassport.getErrorsAndWarningsAsString();
						if msg &lt;&gt; null then
							self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
						endif;
						return;					
					else
						//bail
						return;
					endif;
				else // jlgka1 TFS 43259 --&gt;
					defaultOption := 1;
					returnValue := self.optBox(opt2Str, opt3Str, null, null, defaultOption, app.getErrorString(Select_option) );
					
					if returnValue = 1 then						
						app.myTrxUA.trxAdjustBreakBulkUnloaded( matchingCargoOnTruck,	//_targetTi : CM_Cargo io;
																trackedItem.CM_Cargo,	//_sourceTi : CM_Cargo io;
																unloadedQuantity, //_quantity : Integer;
																unloadedWeight,	//_weight : Decimal;
																self.myMobileGenericAgent.myTruck,	//_truck : CM_Vehicle;
																true,	//_isMoveAllCargoBack : Boolean;
																app.myPassport	//_passport : CM_Passport input
																);
													
						msg := app.myPassport.getErrorsAndWarningsAsString();
						if msg &lt;&gt; null then
							self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
						endif;
						return;					
					else
						//bail
						return;
					endif;
				endif; // jlgka1 TFS 43259 &lt;--
			endif;		
		endif;
	endif; // jlgka1 TFS 43259
		
	// its allowed to be null, just means we are adding one.
	self.myMobileGenericAgent.setMyNextTiToAction(trackedItem);
	//27 Aug 2018	NDL	TFS 39769
	if moveCargoBack then
		self.myMobileGenericAgent.setReloadValues( reloadQuantity, reloadWeight );
	else
		self.myMobileGenericAgent.setReloadValues( 0, 0 );
	endif;
	self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckLoad);//28 May 2010	NDL	Par 23698
	self.myMobileGenericAgent.setDoingReversal( true ); //epr tfs 1842 28/4/16
	self.gotoForm( MOB_HHTruckLoaderCargo, false );
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="clickOnTruckItem" id="2b1a5cbf-e13b-4081-a814-f01a55e74f06">
        <updating/>
        <source>clickOnTruckItem(obj : Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	booking : CM_BookingRef;
	reqInfo : CM_ReceivalRequestInfo;
	
	tiArray : CM_TIArray;
	selectedWle : CM_WorkListEntry; 
	checksSubCargo : CM_TrackedItem;
	errMsg : String;
	
begin

	if CM_TIArray.hasInstance( obj ) then
		tiArray := obj.CM_TIArray;
		self.myMobileGenericAgent.setMyMultiUnloadArrayContent( tiArray );
		self.gotoForm( MOB_HHTruckMultiUnload, false );
		return;
	endif;

	self.myMobileGenericAgent.setStringField1( null );	//28 Aug 2013	NDL	Par 32337
	self.myMobileGenericAgent.setDecimalField1(0);
	if CM_WorkListEntry.hasInstance( obj ) then
		wle := obj.CM_WorkListEntry;
		//Par 32337 - Pre-set the quantity 
		if wle.quantity &gt; 0 then
			self.myMobileGenericAgent.setStringField1( wle.quantity.String );
			self.myMobileGenericAgent.setDecimalField1(wle.weight);
		endif;
	endif;
	if CM_TrackedItem.hasInstance( obj ) then
		ti := obj.CM_TrackedItem;
		
		//25 Sep 2013	NDL	Par 32557
		if ti.isKindOf( CM_TILC ) then
			if self.myMobileGenericAgent.isWaitingOnRequiredChecks( CARGO_CHECK_CONTEXT_TRUKUNLOAD, ti, checksSubCargo ) &lt;&gt; null then
				if checksSubCargo &lt;&gt; null then
					errMsg := app.getErrorString5(Chassis_Subcargo_checks, app.getErrorString(Unload), ti.id, checksSubCargo.id, checksSubCargo.id, ti.id);
					self.msgBox(errMsg, app.getErrorString(Warning), MsgBox_OK_Only, false);
					return;
				endif;
			endif;
		endif;
		
		//Par 32337 - Attempt to pre-set the quantity based on a Wle that we might have....
		if ti.canSplitTotalQuantity then
			foreach wle in ti.allWorklistEntries do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if wle.job = null or not wle.job.isRoadJob then
					continue;
				endif;
				selectedWle := wle;
				break;
			endforeach;
			wle := null;
			if selectedWle &lt;&gt; null and selectedWle.quantity &gt; 0 then
				self.myMobileGenericAgent.setStringField1( selectedWle.quantity.String );
			endif;
			if selectedWle &lt;&gt; null and selectedWle.weight &gt; 0 then
				self.myMobileGenericAgent.setDecimalField1( selectedWle.weight );
			endif;
		endif;
		
	endif;
	if CM_BookingRef.hasInstance( obj ) then
		booking := obj.CM_BookingRef;
	endif;
	if CM_ReceivalRequestInfo.hasInstance( obj ) then
		reqInfo := obj.CM_ReceivalRequestInfo;
	endif;
	
	self.myMobileGenericAgent.setMyWle(wle);
	self.myMobileGenericAgent.setMyNextTiToAction(ti);
	self.myMobileGenericAgent.setMyBookingRef(booking);
	self.myMobileGenericAgent.setMyReceivalRequestInfo(reqInfo);
	//self.myHandHeldCheckerAgent.setChecksState(MOB_HandHeldCheckerAgent.GateReceipt);
	self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckUnload);//28 May 2010	NDL	Par 23698
	self.gotoForm( MOB_HHTruckUnloaderCargo, false );

epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doChangeAmountProcessing" id="aa51ab57-cf34-4ca4-a150-23e906a53a7d">
        <source>doChangeAmountProcessing(	ti : CM_TrackedItem io;
							unloadedQuantity : Integer;
							unloadedWeight : Decimal;
							matchingCargoOnTruck : CM_Cargo input
							);
/*

Purpose:			// They want to have a go at the Steve's STWO editing of Unloaded Cargo fiasco...

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2018	jlgndl1	Initial creation	TFS 39769

*/

vars

	amountForm : MOB_HHCargoAmountForm;
	modifyQuantity : Integer;
	modifyWeight : Decimal [16,4];
	mtShortName : String;
	measurementType : CM_MeasurementType;
	cargoType : CM_CargoType;
	convertedAmount : String;
	msg : String;
	
	modifiedQtyIncrease : Integer;
	modifiedWeightIncrease : Decimal [16,4];
	bookingRefItem : CM_BookingRefItem;
	booking : CM_BookingRef;
	preNote : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	cmgteReceive : CMGTE_Receival;
	
	puttingBack : Boolean;
	gettingMore : Boolean;

begin

	create amountForm transient;
	amountForm.lblInfo.caption := app.getErrorString1( Change_amount_unloaded_to , ti.id );
	amountForm.myTrackedItem := ti;
	amountForm.setPrePopulated( unloadedWeight, unloadedQuantity );
	if amountForm.showModal = IDOK then
		if amountForm.byQuantity then
			modifyQuantity := amountForm.getQuantity;
		else
			modifyWeight := amountForm.getWeightMovedKgs;
		endif;
		if ( modifyQuantity = unloadedQuantity ) and ( modifyWeight = unloadedWeight ) then
			return;  // No change requested
		endif;
	else
		return; // User Cancelled
	endif;
	
	//validation
	cargoType := ti.myCargoType;
	if modifyQuantity = 0 and modifyWeight = 0 then
		msg := app.getErrorString(Chang_amoun_value_must_great_t);
		
	//25 Oct 2018	NDL	- TFS 41180 Steve and Oman have dreamed up another set of rules, now its allowed to be greater than what was on the truck,
	//but not greater than the booking, and the increment between the two may not be greater han the amount left on the pre-note.
	elseif modifyQuantity &gt; unloadedQuantity then
		modifiedQtyIncrease := modifyQuantity - unloadedQuantity;
	elseif modifyWeight &gt; unloadedWeight then
		modifiedWeightIncrease := modifyWeight - unloadedWeight;
	endif;
	
	if modifiedQtyIncrease &gt; 0 or modifiedWeightIncrease &gt; 0 then
	
		gettingMore := true;
		//lets try and work out what the pre-note and booking were if there were any.
		vvr := self.myMobileGenericAgent.myTruck.getCurrentVisit();
		if vvr &lt;&gt; null then
			cmgteReceive := vvr.allGateEntities.getMatchingGTEReceive( ti.myCargoType.id, ti.id );
			if cmgteReceive &lt;&gt; null then
				preNote := self.myTerminal.allNotifiedTIsByCargoTypeId[ ti.myCargoType.id, ti.id ];
				if preNote &lt;&gt; null then
					if modifiedQtyIncrease &gt; preNote.totalQuantity then
						//%1 Exceeds the %2 available on the %3
						msg := app.getErrorString3(Exceeds_available, modifyQuantity.asStringJMT, app.getErrorString(CM_Quantity), app.getErrorString(Prenote) );
					elseif modifiedWeightIncrease &gt; preNote.totalWeight then
						if cargoType.isTrackByWeight then
							mtShortName := cargoType.myWeightMeasurementType.shortName;
							measurementType := app.myRoot.allMeasurementTypesByShortName[ mtShortName ];
							convertedAmount := app.convertMeasurementForDisplay(mtShortName, modifyWeight) &amp; " " &amp; mtShortName;
							msg := app.getErrorString3(Exceeds_available, convertedAmount, app.getErrorString(CM_Weight), app.getErrorString(Prenote) );
						else
							mtShortName := cargoType.myVolumeMeasurementType.shortName;
							measurementType := app.myRoot.allMeasurementTypesByShortName[ mtShortName ];
							convertedAmount := app.convertMeasurementForDisplay(mtShortName, modifyWeight / ti.getDensity ) &amp; " " &amp; mtShortName;
							msg := app.getErrorString3(Exceeds_available, convertedAmount, app.getErrorString(CM_Volume), app.getErrorString(Prenote) );
						endif; 
					endif;
				else
					msg := app.getErrorString(Preno_not_found_alrea_compl_us);
				endif;
				if msg &lt;&gt; null then
					self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
					return; 
				endif;
				bookingRefItem := cmgteReceive.getMyBookingRefItem;
				if bookingRefItem &lt;&gt; null then
					if modifiedQtyIncrease + bookingRefItem.getRecievedCount &gt; bookingRefItem.quantity then
						msg := app.getErrorString3(Exceeds_available, modifyQuantity.asStringJMT, app.getErrorString(CM_Quantity), app.getErrorString(Booking_Item) );
					elseif modifiedWeightIncrease + bookingRefItem.getReceivedWeight &gt; bookingRefItem.weight then
						if cargoType.isTrackByWeight then
							mtShortName := cargoType.myWeightMeasurementType.shortName;
							measurementType := app.myRoot.allMeasurementTypesByShortName[ mtShortName ];
							convertedAmount := app.convertMeasurementForDisplay(mtShortName, modifyWeight) &amp; " " &amp; mtShortName;
							msg := app.getErrorString3(Exceeds_available, convertedAmount, app.getErrorString(CM_Weight), app.getErrorString(Booking_Item) );
						else
							mtShortName := cargoType.myVolumeMeasurementType.shortName;
							measurementType := app.myRoot.allMeasurementTypesByShortName[ mtShortName ];
							convertedAmount := app.convertMeasurementForDisplay(mtShortName, modifyWeight / ti.getDensity ) &amp; " " &amp; mtShortName;
							msg := app.getErrorString3(Exceeds_available, convertedAmount, app.getErrorString(CM_Volume), app.getErrorString(Booking_Item) );
						endif; 
					endif;
					if msg &lt;&gt; null then
						self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
						return; 
					endif;
				endif;
			endif;
		endif;
	endif;
/*	25 Oct 2018	NDL	- TFS 41180 - OLD rule, ie.e must be less NEVER can be greater than what was on the truck.... Yeah Right
 
	elseif modifyQuantity &gt; unloadedQuantity then
		msg := app.getErrorString2(ERR_LOWER_GT_UPPER,app.getErrorString(CM_Quantity), unloadedQuantity.asStringJMT );
	elseif modifyWeight &gt; unloadedWeight then
		if cargoType.isTrackByWeight then
			mtShortName := cargoType.myWeightMeasurementType.shortName;
			measurementType := app.myRoot.allMeasurementTypesByShortName[ mtShortName ];
			convertedAmount := app.convertMeasurementForDisplay(mtShortName, unloadedWeight) &amp; " " &amp; mtShortName;
			msg := app.getErrorString2(ERR_LOWER_GT_UPPER,app.getErrorString(CM_Weight), convertedAmount );
		else
			mtShortName := cargoType.myVolumeMeasurementType.shortName;
			measurementType := app.myRoot.allMeasurementTypesByShortName[ mtShortName ];
			convertedAmount := app.convertMeasurementForDisplay(mtShortName, unloadedWeight / ti.getDensity ) &amp; " " &amp; mtShortName;
			msg := app.getErrorString2(ERR_LOWER_GT_UPPER,app.getErrorString(CM_Volume), convertedAmount ); 
		endif; 
	endif; */
	if msg &lt;&gt; null then
		self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
		return; 
	endif;
	
	puttingBack := not gettingMore;	//25 Oct 2018	NDL	- TFS 41180
	
	if puttingBack then
		// They want to change the unloaded amount downwards.
		app.myTrxUA.trxAdjustBreakBulkUnloaded( matchingCargoOnTruck,	//_targetTi : CM_Cargo io;
												ti.CM_Cargo,	//_sourceTi : CM_Cargo io;
												(unloadedQuantity - modifyQuantity), //_quantity : Integer;
												(unloadedWeight - modifyWeight),	//_weight : Decimal;
												self.myMobileGenericAgent.myTruck,	//_truck : CM_Vehicle;
												false,	//_isMoveAllCargoBack : Boolean;
												app.myPassport	//_passport : CM_Passport input
												);
											
	elseif gettingMore then
		//need to create CMGTE, against PreNote / Booking then a new WLE and unload the sucker into the existing pile.
		self.doGateInMoreDuringAmountProc(	preNote	, //_preNoteToUse : CM_TrackedItem;
											bookingRefItem,	// _bookingRefItem : CM_BookingRefItem;
											modifiedQtyIncrease,	// _modifiedQtyIncrease : Integer;
											modifiedWeightIncrease,	// _modifiedWeightIncrease : Decimal;
											ti,	//	_targetTi : CM_TrackedItem;
											vvr,	//	_vvr : CM_VehicleVisitRecord;
											app.myPassport	//_passport : CM_Passport input
											);
	endif;
	
	msg := app.myPassport.getErrorsAndWarningsAsString();
	if msg &lt;&gt; null then
		self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;
	
epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="unloadedQuantity" type="Integer"/>
        <Parameter name="unloadedWeight" type="Decimal"/>
        <Parameter name="matchingCargoOnTruck" type="CM_Cargo" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCheckRecReqTotals" id="12a12430-5df9-46b3-aee2-02006219d1cf">
        <source>doCheckRecReqTotals():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwndl1	Initial creation

*/

vars
	
	wleArray: CM_WLEArray;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	receivalRequest : CM_ReceivalRequest;
	receivalRequestInfo : CM_ReceivalRequestInfo;
	cargoTypeString : String;
	errMsg : String;
	numRecText : String;
	qtyRecd : Integer;
	
begin

	wleArray := self.myMobileGenericAgent.allLoadedWles;
	
	foreach  wle in wleArray do
		ti := wle.myTrackedItem;
		if ti &lt;&gt; null then
			continue;
		else
			receivalRequest := wle.myRequest.CM_ReceivalRequest;
			if receivalRequest &lt;&gt; null and not receivalRequest.allReceivalInfo.isEmpty then
				foreach receivalRequestInfo in receivalRequest.allReceivalInfo do
					//05 Mar 2014	NDL	Par 33596
					qtyRecd := receivalRequestInfo.getTotalQuantityUnloaded();
				//	foreach ti in receivalRequestInfo.allTrackedItems do
				//		qtyRecd := qtyRecd + ti.totalQuantity;
				//	endforeach;
					
					if receivalRequestInfo.quantity &gt; qtyRecd then
						if receivalRequestInfo.myCargoType = null then
							cargoTypeString := app.getErrorString(Undeclared_cargo_type);
						else
							cargoTypeString := receivalRequestInfo.myCargoType.description;
						endif;
						if receivalRequestInfo.allTrackedItems.isEmpty then
							numRecText := app.getErrorString(Currently_none_received);
						else
							numRecText := app.getErrorString1(Currently_received_only,qtyRecd.String);
						endif;
						errMsg := app.getErrorString2(Receival_indicates_but, receivalRequestInfo.quantity.String, cargoTypeString) &amp; numRecText;
						errMsg := errMsg &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue);
						if not self.msgBox(errMsg, app.getErrorString(Warning),  MsgBox_Yes_No, false) = MsgBox_Return_Yes then
							return false;
						endif;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;


	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCleanUpTiArraysOnBtns" id="97573648-a8e5-4b02-8e10-477c5ea1d812">
        <source>doCleanUpTiArraysOnBtns() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

begin

	if not self.multiObjArray.isEmpty then
		self.multiObjArray.purge();  // deletes any existing TI Arrays.
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGateInMoreDuringAmountProc" id="98e2ddc5-7ec9-4fdb-bf61-490b2163c53e">
        <source>doGateInMoreDuringAmountProc(	_preNoteToUse : CM_TrackedItem;
								_bookingRefItem : CM_BookingRefItem;
								_modifiedQtyIncrease : Integer;
								_modifiedWeightIncrease : Decimal;
								_targetTi : CM_TrackedItem;
								_vvr : CM_VehicleVisitRecord;
								_passport : CM_Passport input
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2018	jlgndl1	Initial creation	TFS 41180

*/

vars

	term : CM_Terminal;
	cargoType : CM_CargoType;
	flexiController : CMIF_FlexiGateController;
	pxyGateEntity : CMGTE_Receival;
	ti : CM_TrackedItem;

	
begin
	
	cargoType := _preNoteToUse.myCargoType;	
	term := self.myMobileDataAgent.myTerminal;
	
	// get the values we know about, and populate into a flexi gate controller.
	create flexiController transient;
	flexiController.setFromExistingPrenote( _preNoteToUse );

	if _bookingRefItem &lt;&gt; null and _bookingRefItem.myBookingReference &lt;&gt; null then
		flexiController.bookingNumber := _bookingRefItem.myBookingReference.bookingReference;
	endif;
	flexiController.myBookingRefItem :=  _bookingRefItem;
	flexiController.jobType := CMGTE_Entity.JobType_GeneralIN;
	
	
	if cargoType.isTrackByWeight then
		flexiController.weightTotal := _modifiedWeightIncrease;
		flexiController.volumeTotal := _preNoteToUse.totalVolume * ( _modifiedWeightIncrease / _preNoteToUse.totalWeight );  //% basis
	elseif cargoType.isTrackByVolume then
		flexiController.volumeTotal := _modifiedWeightIncrease / _preNoteToUse.getDensity;
		flexiController.weightTotal := _modifiedWeightIncrease;
	else
		flexiController.numItems := _modifiedQtyIncrease;
		flexiController.weightTotal := _preNoteToUse.totalWeight * ( _modifiedQtyIncrease / _preNoteToUse.totalQuantity );  //% basis
		flexiController.volumeTotal := _preNoteToUse.totalVolume * ( _modifiedQtyIncrease / _preNoteToUse.totalQuantity );  //% basis
	endif;

	flexiController.myVehicle := _vvr.vehicle;
	flexiController.myVehicleVisitRecord := _vvr;

	flexiController.yardLocationTxt := _targetTi.myPrimaryActualLocation.getFullId;
	flexiController.myTerminal := term;
	
	// create a CMGTE_Receival proxy and populate from the flexi gate controller
	pxyGateEntity := flexiController.createCMGTE_ReceivalProxy(cargoType);
	pxyGateEntity.setMyTrackedItem( _preNoteToUse );
	
	self.myMobileGenericAgent.doRealTrackedItemCreate( pxyGateEntity, null, ti );
	
epilog

	delete flexiController;
	delete pxyGateEntity;

end;</source>
        <Parameter name="_preNoteToUse" type="CM_TrackedItem"/>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem"/>
        <Parameter name="_modifiedQtyIncrease" type="Integer"/>
        <Parameter name="_modifiedWeightIncrease" type="Decimal"/>
        <Parameter name="_targetTi" type="CM_TrackedItem"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="91e9b00c-661c-44ca-a567-49eb0c75e439">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/02/2015	cnwndl1	Initial creation	Par 35604
29/09/2016	cnwdap1	TFS 2653 Bookings and Stops/Tasks
*/
vars
	buttonHeight 	: Integer;			// TFS 2653
	buttonWidth 	: Real;				// TFS 2653
	buttonTop 		: Integer;			// TFS 2653
	index 			: Integer;			// TFS 2653
	menuButton 		: MOB_Button;		// TFS 2653
	vHeight, vTop, vLeft : Real;		// TFS 2653

begin

	inheritMethod(_initialSetup);
	
	// TFS 2653 make document actions button visible if required, resize other buttons to fit
	self.btnDocActions.visible := false;
	if self.onTruckButtonCount &gt; 0
	or self.inYardButtonCount &gt; 0
	then
		if not self.docActsToDisplay.isEmpty then
			vHeight := self.btnOne.height;
			self.frmCargoOnTruck.height := self.frmCargoOnTruck.height - self.resizedMargin - vHeight;
			self.frmCargoInYard.height := self.frmCargoInYard.height - self.resizedMargin - vHeight;
			vTop := self.frmCargoOnTruck.height + self.resizedMargin;
			vLeft := 1; //14 Nov 2016	NDL	TFS 2921 / 2419
			self.btnDocActions.parent := self.shtOnTruck;
			self.btnDocActions.visible := true;
			self.btnDocActions.move(	vLeft,
										vTop,
										self.btnOne.width,
										vHeight );
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
