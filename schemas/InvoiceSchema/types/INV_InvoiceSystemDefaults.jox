        <source>btnProfInvoice_click(btn: Button input) updating;
// non-cash invoice proforma - 35992 always use INV_CashReceiptBOL not INV_CashReceiptMulti
vars
	
	newForm : INV_CashReceiptList;
begin
	// TFS 45953 NEW CASH COLLECTION
	newForm := app.loadForm(INV_CashReceiptList, INV_Assistant, false, false, false, self.myTerminal, null).INV_CashReceiptList;
	if newForm = null then
		return;
	endif;
	newForm.myTerminal := self.myTerminal;
	newForm.isInvoiceProforma:=true;
	newForm.show;
	
end;
</source>
