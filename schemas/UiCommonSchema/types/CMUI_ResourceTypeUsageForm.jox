    <JadeMethod name="addUsageToTblResources" id="ea03d1dd-e40e-4a5b-a76b-f711f11b8d9f">
        <source>addUsageToTblResources( usage : CM_ResourceTypeUsage ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	str : String;
	index : Integer;
	
begin

	str := usage.getAttributeStringForDefArray(self.tblResources.allTblDataEntRows);
	index := self.tblResources.addItemObject(usage, str);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="usage" type="CM_ResourceTypeUsage"/>
    </JadeMethod>
