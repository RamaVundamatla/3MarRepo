    <JadeMethod name="doValidate" id="eb3a79a5-10d8-4af4-9f33-4d35d52cd3fb">
        <updating/>
        <source>doValidate() : Boolean updating, protected;
// show a message if any attributes are not assigned to a tab
vars
	count,
	row,
	value	: Integer;
	result	: Boolean;
	obj		: Object;
	attr	: CM_UserConfigAttribute;
	table	: CM_DataTable;
begin
	table := self.tblAllAttributes;
	foreach row in table.fixedRows+1 to table.rows do
		obj := table.accessRow(row).itemObject;
		attr := obj.CM_UserConfigAttribute;
		// see if not attached to a tab
		if attr.myUserConfigTab = null then
			count := count + 1;
		endif;
	endforeach;
	
	if count = 1 then
		app.msgBox("There is one attribute not on a tab", app.getErrorString(Error), 0);
		return false;
	elseif count &gt; 1 then
		app.msgBox("There are " &amp; count.String &amp; " attributes not on a tab", app.getErrorString(Error), 0);
		return false;
	endif;

	count := 0;
	table := self.tblTabs;
	foreach row in table.fixedRows+1 to table.rows do
		value := table.accessCell(row, 2).text.Integer;
		if value &lt;&gt; 0 then
			count := count + 1;
		endif;
	endforeach;
	
	if count &lt; 2 then
		return true;
	else
		app.msgBox("There must be at most one Reefer tab", app.getErrorString(Error), 0);
		return false;
	endif;

end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="duplicateProxyException" id="1cad6e59-b0fa-4160-89b8-e3bc2d1dfdbc">
        <source>duplicateProxyException(exObj : Exception; hadException : Boolean output) : Integer protected;
// when two or more copies of this form are run for the same user/cargo type which has a persistent CM_UserConfigCargoType
// the new copies get a ProxyAlreadyExists exception from user getUserCargoTypeForEdit
vars

begin

	if exObj.errorCode = ProxyAlreadyExists then
		hadException := true;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="hadException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="enableAttributesArrows" id="f1ad30c5-a0a8-4dae-92b5-8deacf8bb7d0">
        <updating/>
        <source>enableAttributesArrows() updating, protected;

vars
	row	: Integer;
	table	: CM_DataTable;
begin
	table := self.tblTabAttributes;
	row := table.row;
	self.btnAttrDown.enabled := false;
	self.btnAttrUp.enabled := false;
	self.btnAttrRemove.enabled := true;

	if row &gt; table.fixedRows then
		if row &lt; table.rows then
			self.btnAttrDown.enabled := true;
		endif;
		if row &gt; table.fixedRows + 1 then
			self.btnAttrUp.enabled := true;
		endif;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableTabsArrows" id="cfa0f96c-7928-416c-8f1b-1f52665bdde9">
        <updating/>
        <source>enableTabsArrows() updating, protected;

vars
	row	: Integer;
	table	: CM_DataTable;
begin
	table := self.tblTabs;
	row := table.row;
	self.btnTabDown.enabled := false;
	self.btnTabUp.enabled := false;
	if row &gt; table.fixedRows then
		if row &lt; table.rows then
			self.btnTabDown.enabled := true;
		endif;
		if row &gt; table.fixedRows + 1 then
			self.btnTabUp.enabled := true;
		endif;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="moveAttributeItem" id="3b8802b8-d7a5-4d74-b904-856a1f058ed8">
        <updating/>
        <source>moveAttributeItem(_row : Integer; _up : Boolean) protected, updating;
// move up or down the tab attribute table
vars
	table	: CM_BaseTable;
	text	: String;
	idx,
	nextRow	: Integer;
	obj		: Object;
begin
	table := self.tblTabAttributes;
	if _up then
		nextRow := _row - 1;
	else
		nextRow := _row + 1;
	endif;
	text := table.accessCell(_row, 1).text;
	obj := table.accessRow(_row).itemObject;
	
	table.removeItem(_row);
	table.addItemAt(text, nextRow);
	table.accessRow(nextRow).backColor := self.colorRow1;
	table.accessRow(nextRow).itemObject := obj;
	table.row := nextRow;
	table.accessRow(nextRow).selected := true;
	
	self.setChanged();
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveTabItem" id="df2ad67c-753b-4d46-8e0c-a60267e77ff6">
        <updating/>
        <source>moveTabItem(_row : Integer; _up : Boolean) protected, updating;
// move up or down the tab table
vars
	table	: CM_BaseTable;
	tabType,
	text	: String;
	idx,
	nextRow	: Integer;
	obj		: Object;
begin
	table := self.tblTabs;
	if _up then
		nextRow := _row - 1;
	else
		nextRow := _row + 1;
	endif;
	text := table.accessCell(_row, 1).text;
	tabType := table.accessCell(_row, 2).text;
	obj := table.accessRow(_row).itemObject;
	
	table.removeItem(_row);
	table.addItemAt(text &amp; Tab &amp; tabType, nextRow);
	table.accessCell(nextRow, 2).inputType := Table.InputType_CheckBox;
	table.accessRow(nextRow).backColor := self.colorRow1;
	table.accessRow(nextRow).itemObject := obj;
	table.row := nextRow;
	table.accessRow(nextRow).selected := true;
	
	self.setChanged();
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateAllAttributes" id="9634a4b4-d6b9-4cbe-8774-e556d9428746">
        <updating/>
        <source>populateAllAttributes() updating, protected;

vars
	str		: String;
	obj		: Object;
	uctab	: CM_UserConfigTab;
	attr	: CM_UserConfigAttribute;
	row				: EntTableRow;
	heading			: String;
	translation		: XLAT_Translation;
	alteredHeaderName : String;
	hideRow 		: Boolean;
	measureType 	: CM_MeasurementType;
begin
	self.allAttributes.clear();

	foreach uctab in self.myProxyUserCargoType.allUserConfigTabs do
		foreach attr in uctab.allAttributes do
			str := attr.getHeading(self.myCargoType, null, app.myCurrentLocale);
			if self.allAttributes[str] = null then
				self.allAttributes[str] := attr;
			endif;
		endforeach;
	endforeach;

	self.tblAllAttributes.rows := 0;
	self.tblAllAttributes.clearAllSelected();
	self.tblAllAttributes.addItemAt("Attribute  ^" &amp; Tab &amp; app.getErrorString(CM_Sheet), 1);
	self.tblAllAttributes.accessRow(1).fontBold := true;
	self.tblAllAttributes.fixedRows := 1;
	
	foreach obj in self.allAttributes do
		attr := obj.CM_UserConfigAttribute;
		if self.setGeneralCargoInfoRows(self.myCargoType, attr.myEntTableRow.name ) then	// 35199 if hidden then skip the rest of the code as it can show them again
			continue;
		endif;
		// 35199 use the cargo type attributes instead of the ent row names
		row := attr.myEntTableRow;
		heading := attr.getHeading(self.myCargoType, null, app.myCurrentLocale);	// default name
		self.myCargoType.hasEntTableSpecialConditions(	row,
													alteredHeaderName,
													hideRow,
													measureType);
		if hideRow and not row.name = ETRow_TotalWeight then		// 35846 Total Weight is not dependent on the cargo type visibility
			continue;
		endif;
		if alteredHeaderName = null then
			translation := row.getTranslation(app.myCurrentLocale);
			if translation &lt;&gt; null then
				alteredHeaderName := translation.text;
			endif;
		endif;
		if alteredHeaderName &lt;&gt; null then
			heading := alteredHeaderName;
		endif;
		str := heading;
		self.tblAllAttributes.addItemObject(attr, heading &amp; Tab &amp; attr.getTabDescription());
		//self.tblAllAttributes.addItemObject(attr, attr.getHeading(self.myCargoType, null, app.myCurrentLocale) &amp; Tab &amp; attr.getTabDescription());
	endforeach;

	self.recolourTable(self.tblAllAttributes);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTableAttributes" id="4836430f-5359-4ca5-817a-5ed960478e4e">
        <updating/>
        <source>populateTableAttributes() updating, protected;

vars
	idx		: Integer;
	attr	: CM_UserConfigAttribute;
	row				: EntTableRow;
	heading			: String;
	translation		: XLAT_Translation;
	alteredHeaderName : String;
	hideRow 		: Boolean;
	measureType 	: CM_MeasurementType;
begin
	self.tblTabAttributes.rows := 0;
	self.tblTabAttributes.clearAllSelected();
	self.tblTabAttributes.addItemAt(self.myUserConfigTab.description, 1);
	self.tblTabAttributes.accessRow(1).fontBold := true;
	self.tblTabAttributes.fixedRows := 1;
	
	foreach attr in self.myUserConfigTab.allAttributes do
		if self.setGeneralCargoInfoRows(self.myCargoType, attr.myEntTableRow.name ) then	// 35199 if hidden then skip the rest of the code as it can show them again
			continue;
		endif;
		// 35199 use the cargo type attributes instead of the ent row names
		row := attr.myEntTableRow;
		heading := attr.getHeading(self.myCargoType, null, app.myCurrentLocale);		// default name
		self.myCargoType.hasEntTableSpecialConditions(	row,
													alteredHeaderName,
													hideRow,
													measureType);
		if hideRow and not row.name = ETRow_TotalWeight then		// 35846 Total Weight is not dependent on the cargo type visibility
			continue;
		endif;
		if alteredHeaderName = null then
			translation := row.getTranslation(app.myCurrentLocale);
			if translation &lt;&gt; null then
				alteredHeaderName := translation.text;
			endif;
		endif;
		if alteredHeaderName &lt;&gt; null then
			heading := alteredHeaderName;
		endif;
		idx := self.tblTabAttributes.addItemObject(attr, heading);
		//idx := self.tblTabAttributes.addItemObject(attr, attr.getHeading(self.myCargoType, null, app.myCurrentLocale));
	endforeach;
	
	self.recolourTable(self.tblTabAttributes);
	self.enableAttributesArrows();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="recolourTable" id="a7da535f-5714-4a7f-9a4f-dbef90200586">
        <updating/>
        <source>recolourTable(_table : Table input) updating, protected;

vars
	idx,
	startRow,
	endRow		: Integer;
begin
	startRow	:= _table.fixedRows + 1;
	endRow		:= _table.rows;
	
	// re-colour
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			_table.accessRow(idx).backColor := self.colorRow1;
		else
			_table.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
