    <JadeMethod name="doCheckTI" id="e209a91d-27fa-40e9-b182-17d11ab32d43">
        <source>doCheckTI(_tmpTI : CM_TrackedItem) :Boolean;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming

*/

vars
	aCT : CM_CargoType;
	taGroup : CM_TerminalAreaGroup;
	includesGroup : Boolean;
	didError : Boolean;
	ta	: CM_TerminalArea;
	primLC : CM_LocationsController;
	
begin

	if self.doChkCargoType then
		if not self.allQryCargoTypes.includes(_tmpTI.myCargoType) then
			return false;
		endif;
	endif;
	
	if self.doChkContents then
		if not self.allQryContents.includes(app.myRoot.allContentsStatuses[_tmpTI.getContentsStatus()]) then
			return false;
		endif;
	endif;
	
	if self.doChkIMEX then
		if not self.allQryIMEX.includes(_tmpTI.getImExStatusObject()) then
			return false;
		endif;
	endif;
	
	if self.doChkISO then
		if not self.allQryISOGroups.includes(app.myRoot.allISOTypeGroups[_tmpTI.isoTypeGroup]) then
			if _tmpTI.isoTypeGroup &lt;&gt; null then
			return false;
			endif;
		endif;
	endif;
	if self.doChkOperator then
		if not self.allQryOperator.includes(_tmpTI.myOperator) then
			return false;
		endif;
	endif;
	if self.doChkPorts then
		if not self.allQryPorts.includes(app.myRoot.allPorts[_tmpTI.dischargePort]) then
			return false;
		endif;
	endif;
	
	if self.doChkTerminalArea then
		if not self.allQryTerminalAreas.includes(_tmpTI.myTerminalArea) then
			primLC := _tmpTI.myPrimaryActualLocation;
			if primLC = null then
				return false;
			endif;
			ta := primLC.myTerminalArea;
			if ta = null then	//14 Oct 2009	NDL	Par 21211
				return false;
			// if quirying by RTG LANE then double check this
			else
				//epr 10/8/09 ccms 1076 
				includesGroup:=false;
				
				on Exception do app.handleDeletedObject( exception, ta, didError );	//14 Oct 2009	NDL	Par 21211
				
				foreach taGroup in ta.allTerminalAreaGroups discreteLock do
					if self.allQryTerminalAreas.includes(taGroup) then	
						includesGroup:=true;
						break;
					endif;
				endforeach;
				
				if didError then	//14 Oct 2009	NDL	Par 21211
					return false;
				endif;
				
				if not includesGroup then
					return false;
				endif;
			endif;
		endif;
	endif;
	
	if self.doChkVoyages then
		if not self.allQryVoyages.includes(_tmpTI.myVoyage) then
			return false;
		endif;
	endif;

	return true;
end;</source>
        <Parameter name="_tmpTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCheckTerminalArea" id="b1a2cfae-da87-4d65-93f3-eddc51c88933">
        <source>doCheckTerminalArea(_tas : CM_TerminalAreaSet) : Boolean;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aTA : CM_TerminalArea;
begin
	if not self.doChkTerminalArea then
		return true; // all OK
	endif;
	
	foreach aTA in _tas discreteLock do
		if self.allQryTerminalAreas.includes(aTA) then
			return true;
		elseif aTA.isRTGArea then
			return true; // yard allocations are not specified for RTG LANES, so if RTG then always include
		endif;
	endforeach;
	
	return false;
	
end;</source>
        <Parameter name="_tas" type="CM_TerminalAreaSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="bd9cadc0-8116-450d-9e31-ddffe2dec68a">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	
	if self.doChkHAZ then
		if not self.doQueryHAZ() then
			self.allNonMatchTIsHAZ.clear;
			return;
		endif;
	endif;
	
	if self.doChkSpace then
		if not self.doQuerySPACE() then
			return;
		endif;
	endif;
	if self.doChkYA then
		self.doQueryYA();
	endif;

	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		app.myPassport.myCMIFMonitor.updateProgress("Finished", 3,3);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryHAZ" id="293b7325-6861-4431-9227-4535c3f3d885">
        <source>doQueryHAZ() : Boolean;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Mar 2015	cnwkpd1	PAR #35843 - Make progress bar updates time-based, not object counts
	
*/

vars
	tmpTIS : CM_TIByIdDups;
	tmpTI : CM_TrackedItem;
	allErrors 	: CM_ErrorSet;
	idx, a, monitorReturnValue: Integer;
	cmifMonitor : CMIF_Monitor;
	lastUpdate : Decimal[20];
	
begin

	cmifMonitor := app.myPassport.myCMIFMonitor;
	create tmpTIS transient;
	create allErrors transient;
	self.allNonMatchTIsHAZ.clear;
	

	a := self.myTerminal.allOnsiteTIsByCargoTypeId.size;
	app.myPassport.myCMIFMonitor.partsInJob := a;
	
	foreach tmpTI in self.myTerminal.allOnsiteTIsByCargoTypeId discreteLock do
		idx := idx + 1;
		if tmpTI.isHazardous then
			tmpTIS.add(tmpTI);
		endif;
		if (app.relativeMachineTime() - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
			cmifMonitor.updateProgress("Getting Hazadous Cargo", a, idx);
			
			monitorReturnValue := cmifMonitor.monitorReturnValue;
			if (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) 
			or (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
				return false;
			endif;
			lastUpdate := app.relativeMachineTime();

		endif;
	endforeach;

	
	a := tmpTIS.size;
	app.myPassport.myCMIFMonitor.partsInJob := a;
	idx := 1;
	lastUpdate := null;
	
	// check TI against query params
	foreach tmpTI in tmpTIS do
		idx := idx + 1;
		if (app.relativeMachineTime() - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
			cmifMonitor.updateProgress("Checking Hazadous Segregation", a, idx);
			monitorReturnValue := cmifMonitor.monitorReturnValue;
			if (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) 
			or (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
				return false;
			endif;
			lastUpdate := app.relativeMachineTime();
		endif;

		if self.doCheckTI(tmpTI) then
			if tmpTI.isBreakingHazSegregation(allErrors) then
				self.allNonMatchTIsHAZ.add(tmpTI);
			endif;
		endif;
	endforeach;
	
	return true;
epilog
	delete tmpTIS;
	allErrors.purge;
	delete allErrors;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQuerySPACE" id="d9aad1bb-3db2-4f7c-aa60-8ef243b29409">
        <updating/>
        <source>doQuerySPACE() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	aTA : CM_TerminalAreaMaster;
	anLC : CM_LocationsController;
	ls : Boolean;
	tmpLCs : CM_LCSet;
	tmpKPI : CM_KPILocation;
	tmpKPITA : CM_KPITerminalArea;
	a, idx : Integer;
	lastRow, row, column, monitorReturnValue : Integer; 
	cmifMonitor : CMIF_Monitor;
	roroLaneArea	: CM_RoRoLaneArea;
	isRoRoLaneArea : Boolean;
begin
	cmifMonitor := app.myPassport.myCMIFMonitor;
	
	self.dateTime := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	foreach aTA in self.allQryTerminalAreas discreteLock do
		tmpLCs := aTA.getLCSet();
		a := a + tmpLCs.size;
	endforeach;

	if cmifMonitor &lt;&gt; null then
		cmifMonitor.partsInJob := a;
	endif;

	foreach aTA in self.allQryTerminalAreas discreteLock do
		
		isRoRoLaneArea := aTA.isRoRoLaneArea(); //05/09/2025	navkc1 JIRA 35622
		
		// Is RORO Lane Area, we create 1 for each lanes. Done in the tmpLCs loop
		if isRoRoLaneArea then
			create tmpLCs transient;
			roroLaneArea := aTA.CM_RoRoLaneArea;
			
			roroLaneArea.allLanesById.copy(tmpLCs);
		else
		// Not RORO Lane Area, we only create 1 for the area
			create tmpKPITA transient;
			tmpKPITA.setProxyKPI(self.myTerminal, aTA.id,self.dateTime, KPI_Type_TerminalArea, app.myPassport.getUserCode());
			self.allKPITerminalAreas.add(tmpKPITA);
			self.myCurrentKPITerminalArea := tmpKPITA;
			self.maxStack := aTA.getHeightOfStack();
			tmpKPITA.initTA(self.maxStack, aTA.getID());
			self.setKPIQueryParams(tmpKPITA);
			tmpLCs := aTA.getLCSet();
		endif;
		
		foreach anLC in tmpLCs discreteLock do
			// Is RORO Lane Area, we create 1 for each lanes
			if isRoRoLaneArea then
				create tmpKPITA transient;
				tmpKPITA.setProxyKPI(self.myTerminal, anLC.getFullId(),self.dateTime, KPI_Type_TerminalArea, app.myPassport.getUserCode());
				self.allKPITerminalAreas.add(tmpKPITA);
				self.myCurrentKPITerminalArea := tmpKPITA;
				self.maxStack := aTA.getHeightOfStack();
				tmpKPITA.initTA(self.maxStack, aTA.getID());
				self.setKPIQueryParams(tmpKPITA);
			endif;
			
			if anLC.isGridLocation() and not anLC.CM_GridController.amIAvailable() then
				continue;
			endif;
			
			anLC.getKPILocation(self);
			idx := idx + 1;
			
			anLC.getRowColumn(row, column,false,false);
			if lastRow &lt;&gt; row then
				if row &lt;&gt; null then
					if cmifMonitor &lt;&gt; null then
						cmifMonitor.updateProgress("Area " &amp; aTA.id &amp; " Row " &amp; row.String , a, idx);
						monitorReturnValue := cmifMonitor.monitorReturnValue;
						if (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) 
						or (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
							return false;
						endif;
					endif;
				endif;
				lastRow := row;
			endif;
		endforeach;

		if tmpLCs &lt;&gt; null and tmpLCs.isTransient then
			delete tmpLCs;
		endif;
	endforeach;
	
	return true;
epilog
	if tmpLCs &lt;&gt; null and tmpLCs.isTransient then
		delete tmpLCs;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryYA" id="655b04bd-147e-4e54-97d8-0828d7e3236f">
        <source>doQueryYA() : Boolean;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	allocationObj : CM_YardAllocation;
	tmpTIS : CM_TIByIdDict;
	tmpTI : CM_TrackedItem;
	a, idx, monitorReturnValue : Integer;
	cmifMonitor : CMIF_Monitor;
begin
	cmifMonitor := app.myPassport.myCMIFMonitor;

	create tmpTIS transient;
	self.allNonMatchTIsYA.clear;

	a := self.myTerminal.allYardAllocatonsByCode.size;
	app.myPassport.myCMIFMonitor.partsInJob := a;
	
	foreach allocationObj in self.myTerminal.allYardAllocatonsByCode discreteLock do
		idx := idx + 1;
		cmifMonitor.updateProgress("Checking Allocations " , a, idx);
		monitorReturnValue := cmifMonitor.monitorReturnValue;
		if (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) 
		or (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
			return false;
		endif;

		if 	not global.isValidObject(allocationObj) or allocationObj.isDisabled then
			continue;
		endif;
		
		if not self.doCheckTerminalArea(allocationObj.allTerminalAreas) then
			continue;
		endif;

		self.myYAQueryAgent.getNonMatchingTIs(allocationObj.CM_YardAllocation, tmpTIS);
	endforeach;
	
	
	
	a := tmpTIS.size;
	idx := 0;
	app.myPassport.myCMIFMonitor.partsInJob := a;
	
	// check TI against query params
	foreach tmpTI in tmpTIS do
		idx := idx + 1;
		cmifMonitor.updateProgress("Checking Cargo Against Allocations" , a, idx);
		monitorReturnValue := cmifMonitor.monitorReturnValue;
		if (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) 
		or (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
			return false;
		endif;

		if self.doCheckTI(tmpTI) then
			self.allNonMatchTIsYA.add(tmpTI);
		endif;
	endforeach;
	return true;
epilog
	delete tmpTIS;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasCONT" id="49fa1a0c-78d6-4273-b239-8770266fc8d3">
        <source>hasCONT() : Boolean;
/*

Purpose:			Check whether we have query for ISO CONT

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2025	navkc1 JIRA 35623

*/

vars
	kpi		: CM_KPI;
	kpiTA 	: CM_KPITerminalArea;
begin
	
	foreach kpi in self.allKPITerminalAreas discreteLock do
		if not kpi.isKPITerminalArea() then
			continue;
		endif;
		
		kpiTA := kpi.CM_KPITerminalArea;
		
		if kpiTA.hasCONT() then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasRoRoOnly" id="36a4f55f-0df3-4800-ade9-5e63e8553ed1">
        <source>hasRoRoOnly() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2025	navkc1 JIRA 35623

*/

vars
	kpiTA			: CM_KPITerminalArea;
begin

	foreach kpiTA in self.allKPITerminalAreas as CM_KPITerminalArea discreteLock do
		if not kpiTA.isRoRoLane() then
			return false;
		endif;
	endforeach;
	
	return self.allKPITerminalAreas.isNotEmpty();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="b522b91a-949e-46d7-a19e-a6f8c3c91b5f">
        <updating/>
        <source>init() updating;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.allKPITerminalAreas.purge();
	self.myCurrentKPITerminalArea := null;
	self.maxStack := 0;
	self.allNonMatchTIsHAZ.clear;
	self.allNonMatchTIsYA.clear;
	self.allQryCargoTypes.clear;
	self.allQryContents.clear;
	self.allQryIMEX.clear;
	self.allQryISOGroups.clear;
	self.allQryOperator.clear;
	self.allQryPorts.clear;
	self.allQryTerminalAreas.clear;
	self.allQryVoyages.clear;
	
	self.doChkCargoType := false;
	self.doChkContents := false;
	self.doChkHAZ := false;
	self.doChkIMEX := false;
	self.doChkISO := false;
	self.doChkOperator := false;
	self.doChkPorts := false;
	self.doChkSpace := false;
	self.doChkTerminalArea := false;
	self.doChkVoyages := false;
	self.doChkYA := false;
	
end;</source>
    </JadeMethod>
