    <JadeMethod name="run" id="a215b33c-a4c9-4d3f-b63d-d73e8eb3ea14">
        <updating/>
        <source>run(className: String; methodName: String; profileName: String; _form : JUnitForm) updating;
// 01/04/2011	cnwmh5	Remove registering for notifications
// 20/09/2011	cnwmh5 	Change to allow for scheduling
// 22/08/2012 	cnwmh5 	Change so that if logResult then creates UM_TestRun as logResult coudl be called for schedule which doesn't do 
//					   	all the tests, but may do individual ones.  e.g. SCHEDULE_Weekly
// 14/02/2013	cnwmh5	Add stopping of all BGP Processes

vars
	schema: Schema;
	testClass: Class;
	testMethod: Method;
	profile: UT_Profile;
	category : UM_Category;
	catObj		: Object;
	obj			: Object;
	testRun		: UM_TestRun;
	
	allClassMethodsArray	: ObjectArray;
	
	totalRunnableTests		: Integer;
	
begin

	// check to see if any methods have process.debug in them
	self.checkForProcessDebugInCode();				// 27/04/2011 cnwmh5	
	
	self.checkForNewDeveloper();					//cnwmc5 - 12/10/2012
	
	self.stopAllBGPProcesses();						// 14/02/2012 cnwmh5
	
	self.dumpTerminalConfig();						// 30/04/2013 cnwmh5
	
	// get total runnable tests
	self.getTotalRunnableTests();
	
	// get the details of what we need to run
	app.populateAllCategories(className, methodName, scheduleName, self.logResult);
			
	//12 Apr 2021	NDL	TFS 51023
	self.startTime := app.actualTimeServer();
	if self.startTime.Date.dayOfWeek = 6 then // was friday, now saturday. TODO: Remove this 'hack' when the weekly schedule works properly again
		app.writeLog( method.qualifiedName &amp; " - Friday profiling set", LogINFO);
		self.findBlame := true;
		self.methods := true;
		self.logResult := true;
	endif;

	create allClassMethodsArray transient;
	
	foreach category in app.allCategories do
		allClassMethodsArray.clear();
		category.allCategoryClassMethods.copy(allClassMethodsArray);
		foreach obj in allClassMethodsArray do
			if obj.isKindOf(Class) then
				testClass := obj.Class;
				testMethod := null;
			elseif obj.isKindOf(Method) then
				testMethod := obj.Method;
				testClass := testMethod.getSchemaType().Class;
			endif;
			if testClass &lt;&gt; null then
				if profileName &lt;&gt; null then
					delete profile;									// 13/09/2012 cnwmc5  transient leak issue, also deleted in the epilog
					self.getProfile(profileName, profile);
				endif;
				if testMethod &lt;&gt; null then
					if _form = null and self.logResult then			// 22/08/2012 cnwmh5 
						beginTransaction;
						create testRun;
						commitTransaction;
					endif;
					self.runMethodTest(testRun, testClass, testMethod, profile);
				else
					self.runClassTests(testClass, profile, null);
				endif;
			endif;
			
		endforeach;	
	endforeach;

	self.finishTime := app.actualTimeServer();

epilog
	delete profile;
	delete allClassMethodsArray;
end;

</source>
        <Parameter name="className" type="String"/>
        <Parameter name="methodName" type="String"/>
        <Parameter name="profileName" type="String"/>
        <Parameter name="_form" type="JUnitForm"/>
    </JadeMethod>
    <JadeMethod name="runClassTests" id="05390269-cc05-487d-9c88-c76933dab0fe">
        <updating/>
        <source>runClassTests(_klass: Class; _profile: UT_Profile; _form : JUnitForm) updating;
//03 February 2009	cnwdw1	
// Run all tests in a class
//Date			Who		Reason
//30 April 2025	navpw1	JIRA: MTN-34212 - Added true to updateTesterAttributes so that results are by team not by user as default

vars
	tester: UT_UnitTest;
begin
	on Exception do self.exHandlerLastResort(exception);
	create tester as _klass transient;
	//cnwmc5 - 8/10/2012 - now using 'updateTesterAttributes' method
	tester.updateTesterAttributes(self.checkLeaks, self.logMessages, self.logResult, self.findBlame, self.methods, self.scheduleName, true);
	tester.setTesterProfile(_profile);
	tester.runAll( _form );
	self.saveTestResults(tester);
epilog
	delete tester;
end;
</source>
        <Parameter name="_klass" type="Class"/>
        <Parameter name="_profile" type="UT_Profile"/>
        <Parameter name="_form" type="JUnitForm"/>
    </JadeMethod>
    <JadeMethod name="runMethodTest" id="bd1e25ee-2965-42e6-b939-2d35cbc0b458">
        <updating/>
        <source>runMethodTest(_testRun : UM_TestRun; _klass: Class; _method: Method; _profile: UT_Profile) updating;
//03 February 2009	cnwdw1	
// Run a single method test
//Date			Who		Reason
//30 April 2025	navpw1	JIRA: MTN-34212 - Added true to updateTesterAttributes so that results are by team not by user as default

vars
	tester: UT_UnitTest;
begin
	on Exception do self.exHandlerLastResort(exception);
	create tester as _klass transient;
	//cnwmc5 - 8/10/2012 - now using 'updateTesterAttributes' method
	tester.updateTesterAttributes(self.checkLeaks, self.logMessages, self.logResult, self.findBlame, self.methods, self.scheduleName, true); //,
	tester.setTesterProfile(_profile);
	tester.runOne(_testRun, _method);
	self.saveTestResults(tester);
epilog
	delete tester;
end;</source>
        <Parameter name="_testRun" type="UM_TestRun"/>
        <Parameter name="_klass" type="Class"/>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_profile" type="UT_Profile"/>
    </JadeMethod>
    <JadeMethod name="runTests" id="ba0b15aa-0ec8-43af-bdc7-8c2d89dd4e9a">
        <updating/>
        <source>runTests(_profile: UT_Profile; _form : JUnitForm) updating;

/*

Purpose:		Runs the unit tests based on what is selected

Date			Who		Reason
16/12/2014		cnwmh5	Initial creation

*/

vars

	klass 							: Class;
	tester							: UT_UnitTest;
	obj								: Object;
	
	classes							: ClassColl;
	tempClasses						: ClassColl;
	
	index							: Integer;
	oNightClassEmpty				: Boolean;

begin

	/*
	app.mousePointer := Window.MousePointer_HourGlass;	

	on Exception do self.exHandlerLastResort(exception);

	create classes transient;
	
	if _form &lt;&gt; null then
	
		foreach index in 1 to _form.lbxTests.listCount where _form.lbxTests.itemSelected[index] do
			obj := _form.lbxTests.itemObject[index];
			if obj.isKindOf(Class) then
				klass := obj.Class;
			elseif obj.isKindOf(Method) then
				klass := obj.Method.getSchemaType().Class;
			endif;
			if klass.name = "UT_DSL" then
				classes.add(klass);
				app.getListOfClassesToCheck(klass, classes);
				classes.removeAt(1);	// remove UT_DSL
				break;					// since UT_DSL don't need to check anything else
			elseif not classes.includes(klass) then
				classes.add(klass);
			endif;
		endforeach;
		
	else
	
		if self.oNightClassName &lt;&gt; null then
			klass := currentSchema.getClass(self.oNightClassName);
			if self.oNightClassName &lt;&gt; "UT_DSL" then
				oNightClassEmpty := true;
			endif;
		endif;
		
		if klass = null then
			klass := currentSchema.getClass("UT_DSL");
		endif;
	
		classes.add(klass);
		
		if not oNightClassEmpty then
			app.getListOfClassesToCheck(klass, classes);
			if klass.name = "UT_DSL" then
				classes.removeAt(1);	// remove UT_DSL
			endif;
		endif;
				
	endif;

	// have the class that we are running with so let's run the tests
	foreach klass in classes where not klass.abstract do
	
		////write klass.String &amp; Tab &amp; klass.name;
		delete tester;
		create tester as klass transient;
		tester.updateTesterAttributes(self.checkLeaks, self.logMessages, self.logResult, self.findBlame, self.scheduleName, 
			self.oNightClassName, self.oNightMethodName);
		tester.setTesterProfile(_profile);
		tester.runAll( _form );
		if _form &lt;&gt; null and _form.doStop then
			break;
		endif;
		
		self.saveTestResults(tester);
		
	endforeach;
	
	*/
epilog

	app.mousePointer := Window.MousePointer_Default;

	delete classes;
	delete tester;

end;</source>
        <Parameter name="_profile" type="UT_Profile"/>
        <Parameter name="_form" type="JUnitForm"/>
    </JadeMethod>
