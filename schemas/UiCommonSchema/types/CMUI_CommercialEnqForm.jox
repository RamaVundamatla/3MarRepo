    <JadeMethod name="initQueryStuff" id="0ce8ef1d-8f02-49c6-ad88-6688302d2e02">
        <source>initQueryStuff();
// ---------------------------------------------------------------------------
// Created:     21 November 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	con			: CM_ConsigneeConsignor;
	allConDict,
	ffDict		: CM_ConsignByCodeDict;
	date,
	actualDate 	: Date;
begin
//Sheet 1
	self.shtQuery1.visible := true;
	self.shtQuery1.caption := 'Time Settings';
	//Set date From the first day of the current month To the actual current date
	actualDate := self.systemToLocalTime(app.actualTimeServer()).Date;	// 26/4/16 cnwmp6 TFS 488 - Multi timezone support
	date.setDate(1,actualDate.month, actualDate.year);
	self.timeFrom.CMUI_DateMask.setDate(date);
	self.timeTo.CMUI_DateMask.setDate(actualDate);
	self.shtQuery1.cnEcResizeContents();
// Sheet 2	
	self.shtQuery2.visible := true;
	create ffDict transient;
	allConDict  := app.myRoot.allConsigneeConsignors;
	foreach con in allConDict  do
		if con.isFreightFwdr then 
			ffDict.add(con);
		endif;
	endforeach;
	self.mulFF.formDisplayEntryMethodName := CMUI_CommercialEnqForm::displayEntryFF.name;
	self.mulFF.setAvailable(ffDict, true);
	self.mulFF.availableHeading := 'Available';
	self.mulFF.selectedHeading  := 'Selected';
	self.mulFF.userInputEnabled := true;
	self.mulFF.multiSelect				:= ListBox.MultiSelect_Extended;
	self.mulFF.setSorted(true);
	self.shtQuery2.caption := 'Freight Forwarders';
	self.shtQuery2.cnEcResizeContents();
//Sheet 3
	self.shtQuery3.visible := true;
	self.mulServices.formDisplayEntryMethodName := CMUI_CommercialEnqForm::displayEntryServices.name;
	self.mulServices.setAvailable(app.myRoot.allTransactionTypes, true);
	self.mulServices.availableHeading := 'Available';
	self.mulServices.selectedHeading  := 'Selected';
	self.mulServices.userInputEnabled := true;
	self.mulServices.multiSelect				:= ListBox.MultiSelect_Extended;
	self.mulServices.setSorted(true);
	self.shtQuery3.caption := 'Services';
	self.shtQuery3.cnEcResizeContents();
//Sheet 4
	self.shtQuery4.visible := true;
	self.mulCargoType.formDisplayEntryMethodName := CMUI_CommercialEnqForm::displayEntryCargoType.name;
	self.mulCargoType.setAvailable(app.myRoot.allCargoTypesById, true);
	self.mulCargoType.availableHeading := 'Available';
	self.mulCargoType.selectedHeading  := 'Selected';
	self.mulCargoType.userInputEnabled := true;
	self.mulCargoType.multiSelect				:= ListBox.MultiSelect_Extended;
	self.mulCargoType.setSorted(true);
	self.shtQuery4.caption := 'Cargo Types';
	self.shtQuery4.cnEcResizeContents();
//Sheet 5
	self.shtQuery5.visible := true;
	self.mulOperator.formDisplayEntryMethodName := CMUI_CommercialEnqForm::displayEntryOperator.name;
	self.mulOperator.setAvailable(app.myRoot.allOperators, true);
	self.mulOperator.availableHeading := 'Available';
	self.mulOperator.selectedHeading  := 'Selected';
	self.mulOperator.userInputEnabled := true;
	self.mulOperator.multiSelect				:= ListBox.MultiSelect_Extended;
	self.mulOperator.setSorted(true);
	self.cmbVoyage.initialise(false);
	self.shtQuery5.caption := 'Operators';
	self.shtQuery5.cnEcResizeContents();
epilog
	delete ffDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTableData" id="523663d2-e2d5-43a7-bb67-3f5edf6457b4">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
// ---------------------------------------------------------------------------
// Created:     21 November 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------

// DUMMY FOR SPEC
vars
	tmpSheet	: JadeTableSheet;
	i 			: Integer;
	isOwn		: Boolean;
	
begin
	inheritMethod(_theEntDef);
	self.tblData.selectMode := Table.SelectMode_Multiple;
	self.tblData.selectionType := CM_BaseTable.SelectionType_Cell;
	self.tblData.fixed3D := false;
	self.tblData.sheets := 3;
	//Container Detail Sheet (1) ----------------------------------------
	tmpSheet := self.tblData.accessSheet(1);
	tmpSheet.caption := 'Container Activity';
	tmpSheet.columns := 10;
	tmpSheet.fixedRows := 2;
	tmpSheet.accessRow(1).fontBold := true;
	tmpSheet.accessColumn(1).fontBold := true;
	tmpSheet.fixedColumns := 0;
	tmpSheet.gridBottom := false;
	tmpSheet.accessCell(1,1).text := 
		Tab &amp; Tab &amp;
		'20' &amp; Tab &amp;
		'40' &amp; Tab &amp;
		'30' &amp; Tab &amp;	//ccms 1029	cnwvu1	16 May 2008
		'45' &amp; Tab &amp;	//ccms 1029	cnwvu1	16 May 2008
		'53' &amp; Tab &amp;	//ccms 1029	cnwvu1	16 May 2008
		'Other' &amp; Tab &amp;	//ccms 1029	cnwvu1	16 May 2008
		'TEU' &amp; Tab &amp;
		'Reefer';
	tmpSheet.accessColumn(3).alignment := Table.Alignment_Right;
	tmpSheet.accessColumn(4).alignment := Table.Alignment_Right;
	tmpSheet.accessColumn(5).alignment := Table.Alignment_Right;
	tmpSheet.accessColumn(6).alignment := Table.Alignment_Right;
	tmpSheet.accessColumn(7).alignment := Table.Alignment_Right;
	tmpSheet.accessColumn(8).alignment := Table.Alignment_Right;	//ccms 1029	cnwvu1	16 May 2008
	tmpSheet.accessColumn(9).alignment := Table.Alignment_Right;	//ccms 1029	cnwvu1	16 May 2008
	tmpSheet.accessColumn(10).alignment := Table.Alignment_Right;	//ccms 1029	cnwvu1	16 May 2008
	//Row 2	black line	
	tmpSheet.accessRow(2).backColor := Gray;
	tmpSheet.accessRow(2).height := 1;
	tmpSheet.accessCell(2, 1).text := "";
	
	// Container Summary Sheet (2) ----------------------------------------
	tmpSheet := self.tblData.accessSheet(2);
	tmpSheet.visible := true;
	tmpSheet.caption := 'Container Summary';
	tmpSheet.columns := 29;	
	tmpSheet.fixedRows := 6;
	tmpSheet.fixedColumns := 0;
	tmpSheet.accessRow(1).fontBold := true;
	tmpSheet.accessRow(3).fontBold := true;
	tmpSheet.accessRow(5).fontBold := true;
	tmpSheet.fixedColumns := 0;
	tmpSheet.gridBottom := false;
	i:= 2;
	while i &lt; 30 do	
		tmpSheet.accessColumn(i).alignment := Table.Alignment_Right;
		i := i+1;
	endwhile;
// Row 1	
	tmpSheet.accessCell(1,16/*10*/).mergeCells := Table.MergeCells_NotAvailable;
	tmpSheet.accessCell(1,2).mergeCells := Table.MergeCells_MergeSelectable;
	tmpSheet.accessCell(1,2).text := "Import";
	tmpSheet.accessCell(1,2).alignment := Table.Alignment_Center;
