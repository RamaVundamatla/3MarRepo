<Class name="CM_YATypeParentTILCType" id="43103e07-f924-4a14-a2cc-bc4cad4143be">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="21868249-9cfc-4f4e-a5c7-b821ef3dba4f">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2024	jlier1	Initial creation 63834

*/

vars
	iter : Iterator;
	tilcType : CM_TILCType;
begin
	
	iter:=app.myRoot.allTILCTypes.createIterator;
	
	while iter.next(tilcType) do
		if tilcType.isNotAvailableForEntry then
			continue;
		endif;
		_allCriteriaValues.add(tilcType);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="0782fdb6-49ae-4ab4-baf4-16d3b08dad4b">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2024	jlier1	Initial creation 63834

*/

vars

begin
	
	_criteriaObject:=_ti.getCurrentTrailerTypeObject;
	

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="cacb98de-de48-489f-81fd-bf5be1a6477f">
        <source>getDisplay(dataObj: CM_TILCType): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2024	jlier1	Initial creation 63834
TFS BUG 65603 - Extract / Load of Invoiace Cargo Allocations, the load only wants the code. This makes it the same as CM_YATypeTrailerType
*/

vars

begin
	return dataObj.code; // ### TFS BUG 65603 14AUG2024 NAVAB1  &amp; " - " &amp; dataObj.description;
epilog

end;</source>
        <Parameter name="dataObj" type="CM_TILCType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="9fef6d31-fbdf-41c5-b470-832e142e1490">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2024	jlier1	Initial creation 63834

*/

vars
	iter : Iterator;
	tilcType : CM_TILCType;
begin
	
	iter:=app.myRoot.allTILCTypes.createIterator;
	
	while iter.next(tilcType) do
		if tilcType.isNotAvailableForEntry then
			continue;
		endif;
		objects[tilcType.getYAIdentifier()] := tilcType;
		
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
