    <JadeMethod name="jssSetCellObject" id="52ddc686-9c7d-4705-87e4-7e38d67fd1ff">
        <updating/>
        <source>jssSetCellObject(pRow:Integer; pColumn:Integer; pObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - cnEcSetCellObject
// By:			cnwdad1
//
// Purpose:		Assigns the specified object to a cell for the specified row and
//				column, whilst preserving the currently selected cell(s).
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pObject (Object) - The object to assign to the cell.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cRow	: Integer;
	cColumn	: Integer;

begin
	cRow		:=	self.row;
	cColumn		:=	self.column;
	self.row	:=	pRow;
	self.column	:=	pColumn;
	self.jssSetItemObject(pRow, pColumn, pObject);
	self.row	:=	cRow;
	self.column	:=	cColumn;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

