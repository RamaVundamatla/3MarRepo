<Class name="CMIF_JsonTransform" id="f2af8c5a-4bcc-417b-8eb7-f45cfd5ae10a">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="cams"/>
    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="e3d69edc-046f-44e4-923f-c6a9361e37fa">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/04/2023	navdap1		Initial creation TFS 57362 CUX Changes to Outgoing Message Formats
//
vars

begin
	if _property.name = CMIF_Object::warningsHaveBeenAcknowledged.name then
		return true;
	elseif _property.name = CMIF_Object::myTestRecordObject.name then
		return true;
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getJSON" id="4aca22ad-ee6a-49cb-8182-843bfa5825b4">
        <source>getJSON() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jun 2023	jlier1	Initial creation 58839
19 Aug 2024	navmd1	TFS 61725 Change jsonHelper to use JMTJadeJson to output ISO8601 dates

*/

vars
	jsonHelper : JMTJadeJson;
begin
	create jsonHelper transient;
	return jsonHelper.generateJson(self, JadeJson.Format_Json_Microsoft);
epilog
	delete jsonHelper;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
