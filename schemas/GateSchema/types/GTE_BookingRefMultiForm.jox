    <JadeMethod name="isFilterByStevedore" id="f708a9ea-422b-494a-be3d-9aa0c8560288">
        <source>isFilterByStevedore(_bookingRef : CM_BookingRef):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores

*/

vars
begin
	if _bookingRef.myStevedore &lt;&gt; null then
		if self.filterStevedoreCode &lt;&gt; _bookingRef.myStevedore.code then
			return false;
		else
			return true;
		endif;
	else
		return false;
	endif;
	
epilog

end;</source>
