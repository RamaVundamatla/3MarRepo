    <JadeMethod name="getMyCargoTypeDescription" id="5a2a0ca5-8490-4751-8287-727b2ff84c2d">
        <source>getMyCargoTypeDescription():String;
// ---------------------------------------------------------------------------
// Created:     14 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cargoType	:CM_CargoBOLType;
begin
	cargoType := self.myCargoType;
	
	if cargoType &lt;&gt; null then
		return cargoType.description;
	endif;
	
	return app.getErrorString (Unknown);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTrackedItemId" id="44c41286-e431-4de5-8c08-19423cb35dc5">
        <source>getMyTrackedItemId():String;
// ---------------------------------------------------------------------------
// Created:     14 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti	:CM_TrackedItem;
begin
	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null then
		return ti.id;
	endif;
	
	return self.cargoId;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="22a519e4-25d1-49ee-8a33-3c5fe8744836">
        <source>getName(): String;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return inheritMethod() &amp; ' ' &amp; self.cargoId;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="matchesSearchCriteria" id="014bd300-3005-4991-97f6-55e81339ae80">
        <source>matchesSearchCriteria(_search: CMIF_SearchEventRequest): Boolean;
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if (not inheritMethod(_search)) then
		return false;
	endif;

	if _search.cargoId &lt;&gt; null then
		if self.cargoId &lt;&gt; _search.cargoId then
			return false;
		endif;
	endif;
	if _search.myCargoType &lt;&gt; null then
		if self.myCargoType &lt;&gt; _search.myCargoType then
			return false;
		endif;
	endif;	
	return true;
end;</source>
        <Parameter name="_search" type="CMIF_SearchEventRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8943caff-5bc7-48ec-a29b-31618132f3b3">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 			: SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myCargoType := self.myCargoType;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9f79e7b1-59c2-4cf8-9131-83f00484fa11">
        <updating/>
        <source>setForUpdate(_pxyEventRequest: CM_EventRequestTI; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_pxyEventRequest, _passport);
	self.isClear := _pxyEventRequest.isClear;	
	self.cargoId := _pxyEventRequest.cargoId.toUpper;
	self.myCargoType := _pxyEventRequest.myCargoType;
end;</source>
        <Parameter name="_pxyEventRequest" type="CM_EventRequestTI"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="5416c0c1-fb3f-4913-bff9-ad7589a00010">
        <updating/>
        <source>setMyTrackedItem(_trackedItem : CM_TrackedItem; _passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	rtnValue : Boolean;
	failedDAC  :CM_DataAccessController;
	accessStr : String;
begin

	if _trackedItem = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _trackedItem');
		return false;
	endif;
	
	if self.cargoId &lt;&gt; _trackedItem.id then
		return false;
	endif;
	
	//30/10/2009 cnwdz2 par20717
	if self.myCargoType &lt;&gt; _trackedItem.myCargoType then
		return false;
	endif;
	
	self.myTrackedItem := _trackedItem;
		
	if (not self.canUserAccessSelf(self.myUser, failedDAC, _passport)) then
		if failedDAC &lt;&gt; null then
			accessStr := failedDAC.getClassName() &amp; ' access ' &amp; failedDAC.name;
		endif;
		self.actionFailedReason := app.getErrorString1(UserAccessDenied, self.myUser.code &amp; '(' &amp; accessStr &amp; ')');
		rtnValue := false; // for completeness				
	else
		self.actionFailedReason	:= null;
		rtnValue := true;		
	endif;
	
	if self.status = EventRequestPending then
		//Don't overwrite may have already been actioned/emailed
		self.updateStatusAndStatusInfo(EventRequestMatched, null);	
	endif;
	
	return rtnValue;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
