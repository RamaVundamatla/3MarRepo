    <JadeMethod name="setupForLogBOL" id="5660a3f0-ea80-4d25-8dac-bd438120b184">
        <updating/>
        <source>setupForLogBOL(_job : CM_RoadJob) updating;
//--------------------------------------------------------------
//Created: 28 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	wle 	: CM_WorkListEntry;
	bol		: CM_BOL;
	i, dim 	: Integer;
	req 	: CM_YardRequest;
	str		: String;
	now		: TimeStamp;
	loadStateSet : Boolean;
begin
	if _job.jobType &lt;&gt; BOLType_Log then
		return;
	endif;
	
	//Set column widths
	self.tblBody.columnWidth[1] := 75;
	self.tblBody.columnWidth[2] := 100;
	self.tblBody.columnWidth[3] := 100;
	
	//Adjust width of table and frame
	foreach i in 1 to 3 do
		dim := dim + self.tblBody.columnWidth[i];
	endforeach;
	
	self.tblBody.width := dim;
	self.fBody.width := dim;
	
	//Add the title line in bold
	str := "Docket Number" &amp; Tab &amp; 
		   "Yard Location" &amp; Tab &amp; 
		   "Number of Lifts";
		   
	self.tblBody.addItem(str);
	self.tblBody.accessRow(1).fontBold := true;
	
	//Build each line of report data
	app.cmsBeginLoad(loadStateSet);
	
	foreach wle in _job.workListEntries do
		if wle.isKindOf(CM_WOToDoWLE) then
			continue;
		endif;
		bol := wle.myBOL;
	
		//Add data row
		if bol &lt;&gt; null then
			str := bol.number.String;
			if bol.myPlannedLocation &lt;&gt; null then
				str := str &amp; bol.myPlannedLocation.getID &amp; Tab &amp; bol.numberOfLifts.String;
			endif;
		endif;
		
		self.tblBody.addItem(str);
	endforeach;
	
	//Adjust the table and frame height to accomodate the rows we added
	dim := 0;
	foreach i in 1 to self.tblBody.rows do
		self.tblBody.rowHeight[i] := 30;
		dim := dim + self.tblBody.rowHeight[i];
	endforeach;
	
	self.tblBody.height := dim;
	self.fBody.height := self.tblBody.height + 5;
	//Overwrite 
//	self.lblReleaseDT.caption := now.String;	
epilog
	app.cmsEndLoad(loadStateSet);		
end;</source>
        <Parameter name="_job" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="setupReport" id="a7c258b6-5c48-40eb-852a-7cbbfb1b8551">
        <updating/>
        <source>setupReport(pJob : CM_RoadJob) updating;
//--------------------------------------------------------------
//Created: 14 January 2002 By: cnwgd1
//--------------------------------------------------------------
//Fills the report with data ready for printing
vars
	now : TimeStamp;
	columnWidths : IntegerArray;
	defCompany	 : CM_Bank;
	aTerm : CM_Terminal;
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	lblReportDT.caption := now.String;
	
	//Setup the job data stuff at the top	
	//lblVehicle.caption := pJob.regNumber;
//	lblCarrier.caption := pJob.carrierId;
//	lblBatLane.caption := pJob.jobNumber;
//	lblTransferArea.caption := pJob.roadTransAreaId;
	if pJob.vehicleReleased &lt;&gt; null then
		//lblReleaseDT.caption := pJob.vehicleReleased.time.shortFormatJMT()&amp;' '&amp;pJob.vehicleReleased.date.shortFormatJMT;
	endif;
//	lblDwellTime.caption := pJob.recordedDwellTime.String;
	
	//Set up table body and fill with data
	self.setupTable(pJob);
		
	//Setup the footer stuff
	//defCompany := app.getMyTerminalConfigDO_NOT_USE(DefCompany).CM_Bank;
	//17 Apr 2012	NDL	Par 29393
	aTerm := pJob.getMyTerminal();
	if aTerm &lt;&gt; null then
		defCompany := aTerm.getDefaultCompanyBank();
	endif;
	
	if defCompany &lt;&gt; null then
		lblPortName.caption := defCompany.mailingName;
	elseif pJob.myTerminal &lt;&gt; null then
		lblPortName.caption := pJob.myTerminal.name;
	endif;
	lblSignatureDate.caption := now.String; 
	
end;</source>
        <Parameter name="pJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="setupTable" id="e64ca939-19ab-4cdb-8207-b1c31068037b">
        <updating/>
        <source>setupTable(pJob : CM_RoadJob) updating;
//--------------------------------------------------------------
//Created: 14 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	wle 	: CM_WorkListEntry;
	ti 		: CM_TrackedItem;
	i, dim 	: Integer;
	req 	: CM_YardRequest;
	consignStr,
	str, refStr : String;
	loadStateSet : Boolean;
begin
	if pJob.jobType = BOLType_Log then
		self.setupForLogBOL(pJob);
		return;
	endif;
	//Set column widths
	tblBody.columnWidth[1] := 70;	//service
	tblBody.columnWidth[2] := 95;	//type
	tblBody.columnWidth[3] := 95;	//id
	tblBody.columnWidth[4] := 50;	//status
	tblBody.columnWidth[5] := 45;	//iso
	tblBody.columnWidth[6] := 55;	//weight
	tblBody.columnWidth[7] := 70;	//operator
	tblBody.columnWidth[8] := 80;	//commodity
	tblBody.columnWidth[9] := 70;	//consignor
	tblBody.columnWidth[10] := 150;	//ref
	tblBody.columnWidth[11] := 95;	//voy
	tblBody.columnWidth[12] := 150;	//vess
	
	//Adjust width of table and frame
	foreach i in 1 to 12 do
		dim := dim + tblBody.columnWidth[i];
	endforeach;
	tblBody.width := dim;
	fBody.width := dim;
	
	//Add the title line in bold
	str := "Service" &amp; Tab &amp; 
		   "CargoType" &amp; Tab &amp; 
		   "ID Number" &amp; Tab &amp; 
		   "Status" &amp; Tab &amp; 
		   "ISO" &amp; Tab &amp; 
		   "Weight" &amp; Tab &amp; 
		   "Operator" &amp; Tab &amp; 
		   "Commodity" &amp; Tab &amp; 
		   "Consign." &amp; Tab &amp; 
		   "Reference" &amp; Tab &amp; 
		   "Voyage" &amp; Tab &amp; 
		   "Vessel";
	tblBody.addItem(str);
	tblBody.accessRow(1).fontBold := true;
	
	//Build each line of report data
	app.cmsBeginLoad(loadStateSet);
	foreach wle in pJob.workListEntries do
		if (not global.isValidObject(wle)) then
			continue;
		endif;
		ti := wle.myTrackedItem;
		if ti = null then
			continue;
		endif;
		
		//Set properties that depend on pJob type
		if wle.typeString.trimBlanks = "Receival" then
			consignStr := ti.consignor;
			refStr := ti.bookingReference;
		else
			req := wle.myRequest.CM_YardRequest;
			if req &lt;&gt; null then
				consignStr := req.consignee;
				refStr := ti.deliveryRelease;
				if refStr = null then
					refStr := req.deliveryNumber;		//ISO req usually
				endif;
			endif;
		endif;
		
		//Add data row
		str := wle.typeString &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; ti.id &amp; Tab &amp; ti.contentsStatusCode &amp; Tab &amp; ti.getISOType
			 &amp; Tab &amp; ti.totalWeight.asStringWeightJMT() &amp; Tab &amp; ti.operatorCode &amp; Tab &amp; ti.commodity &amp; Tab &amp; consignStr &amp; Tab &amp; 
			 refStr &amp; Tab &amp; ti.voyageCode &amp; Tab &amp; ti.vesselName;
		tblBody.addItem(str);
		
		//Add carrier instructions if any. To accomodate a long string,
		//merge all the table cells in this row together
		if ti.carrierRemarks &lt;&gt; null then
			str := "Carrier Instructions: " &amp; ti.carrierRemarks;
			tblBody.addItem(str);
			tblBody.accessCell(tblBody.rows, 1).mergeCells := Table.MergeCells_Merge;
		endif;
	endforeach;
	
	//Adjust the table and frame height to accomodate the rows we added
	dim := 0;
	foreach i in 1 to tblBody.rows do
		tblBody.rowHeight[i] := 30;
		dim := dim + tblBody.rowHeight[i];
	endforeach;
	
	tblBody.height := dim;
	fBody.height := tblBody.height + 5;
epilog
	app.cmsEndLoad(loadStateSet);		
end;</source>
        <Parameter name="pJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="setupTableForGCRelease" id="0c66a2bc-04f1-4153-be36-d68f54edce44">
        <updating/>
        <source>setupTableForGCRelease(_obj : Object) updating;
//--------------------------------------------------------------
//Created: 14 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti 		: CM_TrackedItem;
	i, dim 	: Integer;
	consignStr,
	str, refStr : String;
	loadStateSet : Boolean;
	tmpSet : Collection;
	rd		: CM_ReserveDetail;
	obj		: Any;
	_bol : CM_BOLIn;
	tmpBR	: CM_BulkRelease;
begin

	if CM_BOLIn.hasInstance(_obj) then
		tmpSet := _obj.CM_BOLIn.allReserveDetails;
	elseif CM_BulkRelease.hasInstance(_obj) then
		tmpSet := _obj.CM_BulkRelease.allReserveDetails;
	else
		return;
	endif;

	tblBody.fontSize := 9;
	//Set column widths
	tblBody.columns := 7;
	tblBody.columnWidth[1] := 110;
	tblBody.columnWidth[2] := 50;
	tblBody.columnWidth[3] := 95;
	tblBody.columnWidth[4] := 95;
	tblBody.columnWidth[5] := 95;
	tblBody.columnWidth[6] := 95;
	tblBody.columnWidth[7] := 95;	
	
	//Adjust width of table and frame
	foreach i in 1 to tblBody.columns do
		dim := dim + tblBody.columnWidth[i];
	endforeach;
	tblBody.width := dim;
	fBody.width := dim;
	
	//Add the title line in bold
	str := "DATE" &amp; Tab &amp; 
		   "QTY" &amp; Tab &amp; 
		   "RECEIVED BY" &amp; Tab &amp; 
		   "LOADER" &amp; Tab &amp; 
		   "GATE PASS #" &amp; Tab &amp; 
		   "DELIVERED BY" &amp; Tab &amp; 
		   "EXCEPTIONS";
	tblBody.addItem(str);
	tblBody.accessRow(1).fontBold := true;
	
	//Build each line of report data
	app.cmsBeginLoad(loadStateSet);
	
	foreach obj in tmpSet do
		rd := obj.CM_ReserveDetail;
		if (not global.isValidObject(rd)) then
			continue;
		endif;
		tmpBR := rd.myReserveHeader;
		str := tmpBR.getDisplayStringForAttribute(ETRow_PickupDate, true) &amp; Tab &amp; 
			   tmpBR.getDisplayStringForAttribute(ETRow_Bundles, true) &amp; Tab &amp; 
			   tmpBR.getDisplayStringForAttribute(ETRow_ReceivedBy, true) &amp; Tab &amp; 
			   tmpBR.getDisplayStringForAttribute(ETRow_Loader, true) &amp; Tab &amp; 
			   tmpBR.getDisplayStringForAttribute(ETRow_GatePass, true) &amp; Tab &amp; 
			   tmpBR.getDisplayStringForAttribute(ETRow_Clerk, true) &amp; Tab &amp; 
			   tmpBR.getDisplayStringForAttribute(ETRow_Exception, true);
		
		tblBody.addItem(str);
	endforeach;

	//Adjust the table and frame height to accomodate the rows we added
	dim := 0;
	foreach i in 1 to tblBody.rows do
		tblBody.rowHeight[i] := 25;
		dim := dim + tblBody.rowHeight[i];
	endforeach;
	
	tblBody.height := dim;
	fBody.height := tblBody.height + 5;
epilog
	app.cmsEndLoad(loadStateSet);		
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</GUIClass>
