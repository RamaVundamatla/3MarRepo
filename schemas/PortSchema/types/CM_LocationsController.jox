    <JadeMethod name="doesTIMatchOffsetForPrime" id="94750be2-bebe-4d3b-938f-6d938077dca5">
        <source>doesTIMatchOffsetForPrime(_ti : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _ti.isAttributeTrue(TI_Attrib_IsThirty) then
		return (self.is30ft and self.offset30 &lt;&gt; CM_LocationsController.Offset30_Unavailable);
	elseif _ti.isAttributeTrue(TI_Attrib_IsForty) then
		return (self.is40ft and self.offset40 &lt;&gt; CM_LocationsController.Offset40_Unavailable);
	elseif _ti.isAttributeTrue(TI_Attrib_IsFortyFive) then
		return (self.is45ft and self.offset45 &lt;&gt; CM_LocationsController.Offset45_Unavailable);
	elseif _ti.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		return (self.is53ft and self.offset53 &lt;&gt; CM_LocationsController.Offset53_Unavailable);
	elseif _ti.isTwenty() then
		return (self.is20ft);
	endif;

	return false;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
