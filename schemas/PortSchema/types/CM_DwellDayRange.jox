    <JadeMethod name="validateMe" id="d983582e-d590-4d1e-87a8-98cfbd9f6c0b">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation

*/

vars

	root : CM_Root;
	realMe : CM_DwellDayRange;
	iter : Iterator;
	existingDwellDayRange : CM_DwellDayRange;

begin

	root := app.myRoot;
	realMe := self.pxyGetRealObject();
	
	if self.lower &lt; 0 then
		app.raiseCMException(Lower_less_than_zero, null,null);
	endif;
	
	if self.lower &gt; self.upper then
		app.raiseCMException(Lower_not_more_than_upper, null,null);
	endif;
	
	if root.allDwellDayRanges.isEmpty() then
		return;
	endif;

	iter := root.allDwellDayRanges.createIterator;
	while iter.next( existingDwellDayRange ) do
		if existingDwellDayRange = realMe then
			continue;
		endif;
		if existingDwellDayRange = self then
			continue;
		endif;
		if existingDwellDayRange.isValueWithinRange( self.lower) then
 		// write "lower of self is within range of existingDwellDayRange ";
			app.raiseCMException(Range_Overlaps_Dwell, null,null);
		endif;
		if existingDwellDayRange.isValueWithinRange( self.upper) then
		//	write "upper of self is within range of existingDwellDayRange ";
			app.raiseCMException(Range_Overlaps_Dwell, null,null);
		endif;
		if self.isValueWithinRange( existingDwellDayRange.lower) then
		//	write "lower of existingDwellDayRange is within range of self ";
			app.raiseCMException(Range_Overlaps_Dwell, null,null);
		endif;
		if self.isValueWithinRange( existingDwellDayRange.upper) then
		//	write "upper of existingDwellDayRange is within range of self ";
			app.raiseCMException(Range_Overlaps_Dwell, null,null);
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
</Class>
