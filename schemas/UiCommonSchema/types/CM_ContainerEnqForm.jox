    <JadeMethod name="doUnQueueSelected" id="2ef02b6c-0d1f-46d0-bda8-4157bee3772c">
        <updating/>
        <source>doUnQueueSelected() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 December 2013	cnwndl1	Initial creation	Par 32900

*/

vars

	obj : Object;
	ti : CM_TrackedItem;
	count : Integer;
	tiSet : CM_TISet;

begin
	
	if self.tblData.allSelectedObjects.size &lt; 2 then
		return;
	endif;
	
	create tiSet transient;
	
	foreach obj in self.tblData.allSelectedObjects do
		if CM_TrackedItem.hasInstance( obj ) then
			ti := obj.CM_TrackedItem;
			if not ti.isQueued then
				continue;
			endif;
			tiSet.addNoDuplicates( ti, false );
		endif;
	endforeach;
	
	foreach ti in tiSet do
		doUnqueueTI( ti );
	endforeach;
	
epilog
	delete tiSet; 
end;</source>
    </JadeMethod>
    <JadeMethod name="doUnplanTI" id="c109330e-3ebb-4f87-80be-34b59da1a0d2">
