    <JadeMethod name="setProxyFromObject" id="d63652c2-9cad-44b5-8f9d-81c8b1bd3a5c">
        <updating/>
        <source>setProxyFromObject(_object: CM_WorkOrderDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520
28 Jun 2018 cnwma1	ChangeRequest 39462: PEL1 WP - Cargo Request by Permit
17 Jul 2018 cnwma1	ChangeRequest 39645: PEL1 WP - Work Order List Invoice Acceptance Time Stamp
15 Nov 2018 cnwma1  ChangeRequest 42045: PEL1 - SAP Integration : Additional Changes - Extended
31 Jan 2019 cnwma1	ChangeRequest 42943: PEL1 - Recheck Finance for WSDL 1.4 on Web Portal
07 Feb 2019	jlgdap1	TFS 43160 PEL1 Container Services - Show Pre Invoice / Tax Invoice on Web
06 Mar 2019	jlgdap1	TFS 43535 PEL1 Container Services - Freight Forwarder access and visibility in WP
14 Mar 2019 cnwma1	Bug 43732: PEL1 - Container Services - Cancel Load (Export Return) showing up Report in WP after payment
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
29 Nov 2021 navma1  Bug 52473: SAL - Web portal - Cargo Request description
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	ti 				: CM_TrackedItem;
	failedDAC		: CM_DataAccessController;
	workOrder 		: CM_WorkOrder;	
	allTIs			: CM_TISet;
	voyage 			: CM_Voyage;
	preInvoiceDT    : TimeStamp;
	vessel 			: CM_Vessel;
	preInv			: CM_Invoice;
	woTI         	: WS_WorkOrderTrackedItem;
	user			: CM_User;
begin
	if _object = null then
		return;
	endif;
	
	inheritMethod(_object);
	user				:= app.getMyUser();										//12.01.2023 navma1 #56141 Task#56147 
	workOrder 			:= _object.getMyParent;
	self.workOrderId	:= workOrder.id;
	self.description    := _object.getTypeDescription();						//29.09.2021 navma1 #51925
	
	if self.description = null then												//29.11.2021 navma1 #52473
		self.description :=	_object.getDisplayString(true);
	endif;
	
	self.requiredByDT := _object.requiredByDT.asStringForWebInterface;
	self.statusDesc   := _object.getStatusString;
	self.status 	  := _object.getStatus;
	self.type	  	  := _object.detailType;
	voyage 			  := _object.getMyVoyageObject;
	
	//05 Oct 2018	NDL	TFS 41272
	self.locationCurrent	 := _object.getCurrentLocation();
	self.locationDestination := _object.getDestinationLocation();
	
	if voyage &lt;&gt; null then	//24 Jan 2019	NDL	TFS 43019
		self.voyage		:= voyage.getOidAsString;
		self.voyageDesc	:= voyage.code &amp; " " &amp; voyage.description;
		self.voyageCode := voyage.code;								//14 Sep 2018	NDL	TFS 40806
		vessel 			:= voyage.myVessel;
		if vessel &lt;&gt; null then
			self.vesselName := vessel.name;							//14 Sep 2018	NDL	TFS 40806
		endif;
	endif;
	
	if workOrder &lt;&gt; null then
		if  workOrder.isKindOf(CM_WorkOrderTI) then
			workOrder			:= workOrder.CM_WorkOrderTI;
			//source 			:= workOrderTI.mySource;			//12.01.2023 navma1 #56141 Task#56147
			//self.cargoTypeId	:= source.cargoType;				//12.01.2023 navma1 #56141 Task#56147
			
			create allTIs transient;								//27 Jun 2018	NDL	TFS 39246
			//workOrder.CM_WorkOrderTI.getAllTIs( allTIs );			//08.02.2023 navma1 #56457 Task#56458
			_object.CM_WorkOrderTIDtl.allSelectedTIs.copy(allTIs);	//08.02.2023 navma1 #56457 Task#56458
			foreach ti in  allTIs do
				if not ti.canUserAccessSelf(user, failedDAC, app.myPassport) then 
					continue;
				endif;
				// TFS 43535 Freight Forwarder access
				if ti.myFreightForwarder &lt;&gt; null then
					if not ti.myFreightForwarder.canUserAccessSelf(user, failedDAC, app.myPassport) then
						continue;
					endif;
				else
					if user.getUserIsFreightForwarder then
						continue;
					endif;
				endif;
				// TFS 43535 end
				/* 9.09.2021 navma1 #51925
				self.allCargoIds.add(ti.id);
				self.allCargoOids.add(ti.getOidAsString);
				*/
				//29.09.2021 navma1 #51925
				create woTI transient;
				woTI.setProxyFromObject(ti);
				self.allTIs.add(woTI);
			endforeach;		
		endif;
	endif;
	
	//20.6.2018 cnwma1 TFS #38815
	if _object.isKindOf(CM_WodReceive) 
		or _object.isKindOf(CM_WodRelease)
		or _object.isKindOf(CM_WodReleaseExtension)					//12 Mar 2019	NDL	TFS 43405
		then
		self.canReport := _object.canPrintWOReportOnWeb();			//27 Aug 2018	NDL	TFS 40213
	endif;
	
	
	self.lengthOfTime	   := workOrder.getLengthOfTime();			
	self.canEstimate	   := workOrder.canEstimate();				//24.01.2023 navma1 #56141 Task#56147
	self.canRecheckFinance := workOrder.canReCheckFinance();		//24.01.2023 navma1 #56141 Task#56147
	self.canEdit           := _object.canEdit();					//24.01.2023 navma1 #56141 Task#56147
	
	//17.7.2018 cnwma1 TFS #39645
	if workOrder &lt;&gt; null then	
		foreach preInv in workOrder.allInvoices discreteLock do 
			if not preInv.debtor.canUserAccessSelf(user, failedDAC, app.myPassport) then
				app.writeLog("Debtor " &amp; preInv.debtor.name &amp; " not accessible to user " &amp; user.code, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				continue;
			endif;
			
			if not workOrder.isVoyageWorkOrder then																					// TFS 43160
				self.canPreInvoice := preInv.status.isOneOf(preInv.INVOICE_PREPEND, preInv.INVOICE_PENDING, preInv.INVOICE_POSTED);	// TFS 43160
				self.canTaxInvoice := preInv.status.isOneOf(preInv.INVOICE_PENDING, preInv.INVOICE_POSTED);							// TFS 43160
			endif;																													// TFS 43160
			
			if self.invoiceActionDT = null then																						// TFS 43160
				preInvoiceDT := self.getPreInvoiceApprovalDT(preInv);
				if preInvoiceDT.isValid then
					self.invoiceActionDT := preInvoiceDT.asStringForWebInterface;
					//break;																										// TFS 43160
				endif;
			endif;																													// TFS 43160
		endforeach;
	endif;
	
epilog
	delete allTIs;
end;</source>
        <Parameter name="_object" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyToDoTasks" id="4d3d1d6e-68c4-41fe-aeaa-d51df94a333f">
        <source>setProxyToDoTasks(_object: CM_WorkOrderTIDtl);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlger1	Initial creation 39642
*/

vars
	todoDesc 	: CM_ToDoTaskDesc;
	wsTodo 		: WS_ToDoTaskDesc;
	todoSet 	: CM_ToDoTaskDescSet;
begin
	create todoSet transient;
	_object.getAllToDoTaksDescsUsed(todoSet);
	
	foreach todoDesc in todoSet do
		create wsTodo transient;
		wsTodo.setProxyFromObject(todoDesc);
		self.allToDoTasks.add(wsTodo);
	endforeach;
	
epilog
	delete todoSet;

end;</source>
        <Parameter name="_object" type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="updateProxyToDoTasks" id="c99ac7d7-aef5-4ceb-96a0-57a801e06f95">
        <source>updateProxyToDoTasks(_pxyWorkOrder : CM_WorkOrderTIDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlger1	Initial creation 39642
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	todoSet 	: CM_ToDoTaskDescSet;
	todoDesc 	: CM_ToDoTaskDesc;
	wsTodo 		: WS_ToDoTaskDesc;
	passport	: CM_Passport;
begin
	
	passport := app.myPassport;
	
	create todoSet transient;

	foreach wsTodo in self.allToDoTasks do
		todoDesc := passport.getObjectOfTypeFromOid(wsTodo.cmObjectId,CM_ToDoTaskDesc).CM_ToDoTaskDesc;
		if todoDesc &lt;&gt; null then
			todoSet.addNoDuplicates(todoDesc,false);
		endif;
	endforeach;
	
	_pxyWorkOrder.setProxyAllToDoRequests(todoSet);
	
epilog
	delete todoSet;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrderTIDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="e39297cf-8832-4440-b4b5-e3dc163dd130">
        <source>updateProxyWorkOrder(_pxyWorkOrder : CM_WorkOrderDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation

*/

vars

begin
	if _pxyWorkOrder &lt;&gt; null then
		_pxyWorkOrder.setProxy(self.requiredByDT.asTimeStampFromWebInterface,null,false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrderDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDateIsDuringVoyage" id="12e35318-3f25-449a-aae4-f700cac79b23">
        <source>validateDateIsDuringVoyage( _voyageOid : String; _ts : TimeStamp );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2018	jlgndl1	Initial creation	TFS 41148

*/

vars

	voyage : CM_Voyage;

begin

	if _voyageOid &lt;&gt; null and _ts.date.isValid then
		voyage := app.myPassport.getObjectOfTypeFromOid( _voyageOid, CM_Voyage ).CM_Voyage;
		if voyage &lt;&gt; null then
			if _ts &lt; voyage.arrivedDT then
				app.raiseCMException1( Not_betwe_voyag_arriv_depar_da, _ts.asStringJMT, null, null );
			elseif _ts &gt; voyage.departedDT then
				app.raiseCMException1( Not_betwe_voyag_arriv_depar_da, _ts.asStringJMT, null, null );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_voyageOid" type="String"/>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
</Class>
