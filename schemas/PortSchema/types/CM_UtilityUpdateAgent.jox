    <JadeMethod name="utlUpdateHarmonizedSysActivate" id="0affa0a2-01f7-42a2-9724-0fa2f801a257">
        <updating/>
        <source>utlUpdateHarmonizedSysActivate(_pxyHSCodes : CM_HarmonizedSystemSet; _isActive : Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes
31 August   2024        navrv30 CR 65205: EUP - HS Code Purge Validation
*/

vars
	proxyHS, realHS : CM_HarmonizedSystem;
	expectedEdition : Integer;
begin

	self.initialiseActivity();
	
	foreach proxyHS in _pxyHSCodes do
		proxyHS.raiseExceptionIfNotProxy(method);
		proxyHS.pxyGetRealObjectAndEdition(realHS, expectedEdition);
		
		if realHS = null then
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_HarmonizedSystem.name, null, null);
			return;
		endif;
		
		realHS.validateForDelete();				//31.08.2024 navrv30 CR 65205
		
		self.exclusiveLock(realHS);
		
		if not _passport.noErrors then
			return;
		endif;
		
		if not _passport.noWarnings then			//31.08.2024 navrv30 CR 65205
			if not _passport.warningsAcknowledged then
				continue;
			endif;
		endif;
		
		self.myUpdateAuditAgent.audUpdateGeneric(realHS, true);

		realHS.setIsActive(_isActive);
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realHS, false);
			realHS.causeEvent(EVENT_HS_ACTIVATE, false, realHS);
		endif;
		
	endforeach;

epilog
	
end;</source>
        <Parameter name="_pxyHSCodes" type="CM_HarmonizedSystemSet"/>
        <Parameter name="_isActive" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
