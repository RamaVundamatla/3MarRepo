    <JadeMethod name="getRecordDetailDescription" id="1e20dc04-d22e-4145-bfce-0ee52dbcfa30">
        <source>getRecordDetailDescription() : String;
/*

Date		Who		Reason
22 July 2013	cnwer1	Initial creation PAR 31985
21/10/2025	navcs2 	MTN-36397 
*/

vars
	description : String;
	extraInfoString : String;
	cargoTypeDescr  : String;
	ti : CM_TrackedItem;
	invalidTI : Boolean;
	measure : CM_MeasurementType;
	scaleWeight : Decimal [16,4];
	otherVVRD : CM_VehicleVisitRecordDetail;
	bulkGateModValue : String;
begin
	description :=self.recordTypeString;
			
	if self.isCargoMove then
		//for chassis wanted to know the cargo type was a chassis - however have enhanced to just display
		// the ti cargo type;
		on Exception do app.handleDeletedObject(exception, ti, invalidTI);
		ti:=self.getExtraInfo_TrackedItem;
		if ti &lt;&gt; null then
			cargoTypeDescr:=ti.cargoBOLTypeDescr;
		endif;
		
		if cargoTypeDescr = null then
			cargoTypeDescr:= app.getErrorString(Cargo);
		endif;
		if self.recordType = VisitRecord_CargoRemoved then
			description:=app.getErrorString1(Cargo_removed,cargoTypeDescr);
		elseif self.recordType = VisitRecord_CargoPlaced then
			description:=app.getErrorString1(Cargo_placed,cargoTypeDescr);
		elseif self.recordType = VisitRecord_CargoDiscrepancy then //epr par 33221 3/3/2014
			description:=app.getErrorString1(Cargo_Discrepancy,cargoTypeDescr); 
		endif;
		
		extraInfoString := self.getExtraInfo_CargoMove;
		
		if ti &lt;&gt; null and ti.canSplitTotalQuantity and extraInfoString &lt;&gt; null and not self.recordType = VisitRecord_CargoPlaced then		// 20 October 2025	navcs2	MTN-36215 21/10/2025	navcs2 	MTN-36397 
			extraInfoString :=   ti.totalQuantity.String &amp; 'x' &amp; extraInfoString;															// 20 October 2025	navcs2	MTN-36215 21/10/2025	navcs2 	MTN-36397 
		endif;
		
	elseif self.recordType = VisitRecord_Cancel then					// cnwcs5 21/09/2009
		extraInfoString := self.getExtraInfo_Cancel[1:50];					// 21/12/2009 cnwmh5 #21864
		
	elseif self.recordType = VisitRecord_Deleted_Entry then			// 18 Feb 2011	NDL	Par 27046
		extraInfoString := self.getExtraInfo_DeletedEntry[1:50];			// par 31670
						
	elseif  self.recordType = VisitRecord_Turnaround then	 			// cnwrd1 par 22624 3.5.2010
		extraInfoString := self.getExtraInfo_Turnaround[1:50];
	elseif self.recordType = VisitRecord_AssignRFIDTag or
			self.recordType = VisitRecord_DeassignRFIDTag then
		extraInfoString :=self.getExtraInfo_AssignRFIDTag;
	elseif self.recordType = VisitRecord_Create or
		self.recordType = VisitRecord_Complete_AGate_In or
		self.recordType = VisitRecord_Arrive_PGate_In or
		self.recordType = VisitRecord_Arrive_PGate_Out or
		self.recordType = VisitRecord_Complete_PGate_Out  then
		extraInfoString :=self.getExtraInfo_GateLane;
	elseif self.recordType = VisitRecord_WeighBridge or
		self.recordType = VisitRecord_WeighBridgeIn or
		self.recordType = VisitRecord_WeighBridgeOut  then	//19 Mar 2014	NDL	Par 33268
		extraInfoString := self.getExtraInfo_Weighing(); 						
	elseif self.recordType = VisitRecord_WayBillPrint then	//26 Aug 2015	NDL	Par 36677
		extraInfoString := self.getExtraInfo_WaybillPrint;
	elseif recordType = VisitRecord_Bulk_In or recordType = VisitRecord_Bulk_Out then	//10 Nov 2016	NDL	TFS 2867 / 2779
		if  self.getExtraInfo_BulkGateModified(bulkGateModValue) then
			extraInfoString := bulkGateModValue;
		else
			measure := app.getDefaultMeasurementForType(Type_Weight);
			scaleWeight := self.getExtraInfo_BulkGateInOrOut;
			extraInfoString := app.convertMeasurementForDisplay(measure.shortName, scaleWeight) &amp; Space &amp; measure.shortName;
			if recordType = VisitRecord_Bulk_In then
				otherVVRD :=  self.myVehicleVisitRecord.getBulkGateIn(self);
				if otherVVRD &lt;&gt; null then
					extraInfoString := extraInfoString &amp; " [" &amp; self.userCode &amp; "] " &amp; self.computerName;
				endif;
			endif;
		endif;
	elseif recordType = VisitRecord_TruckGrsWeightIn or recordType = VisitRecord_TruckGrsWeightOut then		// 20/6/17 MAP TFS4273
		measure := app.getDefaultMeasurementForType(Type_Weight);
		extraInfoString := app.convertMeasurementForDisplay(measure.shortName, self.extraInfo.Decimal) &amp; Space &amp; measure.shortName;
	else
		extraInfoString:= self.extraInfo; //epr par 34174
	endif;
	
	if extraInfoString &lt;&gt; null then
		// make sure we are not adding &gt; 62 characters
		description :=description &amp; ' (' &amp; extraInfoString &amp; ')';
	endif;
	
	return description;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasBeenInTheLocation" id="e2af828b-a75f-422e-8284-ce28c1ae1435">
        <source>hasBeenInTheLocation(_vvrTrackedItem   : CM_TrackedItem;
					 _cargoTrackedItem : CM_TrackedItem;
					 _moveTransaction  : CM_Move) : Boolean;
/*
Purpose: Returns true if the 
		 - cargo is in the target location
		 - or cargo is queue to target location
		 - or removed from target location
		 - or the cargo was return back to Truck

Parameters:			

Return Value:		

Date		Who		TFS		Reason
20 Dec 2019	jlgdi1	47879	Initial creation
*/
vars
	cargoActualLocation,
	vvrActualLocation,
	vvrQueuedLocation   : CM_LocationsController;
begin
	
	cargoActualLocation := _cargoTrackedItem.myPrimaryActualLocation;
	vvrActualLocation   := _vvrTrackedItem.myPrimaryActualLocation;
	vvrQueuedLocation   := _vvrTrackedItem.myPrimaryQueuedLocation;
	
	if (vvrActualLocation &lt;&gt; null and vvrActualLocation = cargoActualLocation) or 
	   (vvrQueuedLocation &lt;&gt; null and vvrQueuedLocation = cargoActualLocation) or
	   (_moveTransaction.sourceLocn.pos(cargoActualLocation.ident, 1) &gt; 0) or 
	   (vvrActualLocation = null and vvrQueuedLocation = null and _moveTransaction.sourceLocn.toUpper.pos(ROAD, 1) &gt; 0)
	then 
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_vvrTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_cargoTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_moveTransaction" type="CM_Move"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
