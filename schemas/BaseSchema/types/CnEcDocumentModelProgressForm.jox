    <JadeMethod name="btnClose_click" id="e0e97c52-c9a2-4d5e-9360-d4d2df341bbc">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="a7f9ad05-8e28-4eed-986c-94b7b96e9d07">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	centreWindow();
	
	self.aPartsDone		:=	0;
	self.aPartsToDo		:=	0;
	self.aIsDone		:=	false;
	btnClose.enabled	:=	false;
	
	beginNotification(global, CNEC_DOCMODEL_STEP_STARTING, Response_Continuous, 0);
	beginNotification(global, CNEC_DOCMODEL_STEP_SCHEMACOUNT, Response_Continuous, 0);
	beginNotification(global, CNEC_DOCMODEL_STEP_CLASSCOUNT, Response_Continuous, 0);
	beginNotification(global, CNEC_DOCMODEL_STEP_SCHEMA, Response_Continuous, 0);
	beginNotification(global, CNEC_DOCMODEL_STEP_CLASS, Response_Continuous, 0);
	beginNotification(global, CNEC_DOCMODEL_STEP_DONE, Response_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="0eae05dc-626b-4e06-9f73-dc416b73a1f7">
        <updating/>
        <source>doFormUpdate(): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtSchema.text	:=	self.aCurrentSchema;
	txtClass.text	:=	self.aCurrentClass;

	prgProgress.partsInJob	:=	self.aPartsToDo;
	prgProgress.partsDone	:=	self.aPartsDone;
	
	if self.aIsDone then
		btnClose.enabled	:=	true;
		app.mousePointer	:=	Idle;
		txtSchema.text		:=	"Model Documentation completed";
		txtClass.text		:=	null;
	else
		btnClose.enabled	:=	false;
		app.mousePointer	:=	Busy;
	endif;
	
	self.refreshControls();
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="ef3e16cf-317d-4c1d-8a11-409e58cbc3b0">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if reason = Form.QueryUnload_User then
		if self.aIsDone then
			cancel	:=	0;
		else
			cancel	:=	1;
		endif;
	endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="refreshControls" id="2df1062c-6d7e-4995-8068-3a66bae93e2d">
        <source>refreshControls() protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	lblSchema.refreshNow();
	lblSchema.doWindowEvents(0);
	txtSchema.refreshNow();
	txtSchema.doWindowEvents(0);
	lblClass.refreshNow();
	lblClass.doWindowEvents(0);
	txtClass.refreshNow();
	txtClass.doWindowEvents(0);
	prgProgress.refreshNow();
	prgProgress.doWindowEvents(0);
	btnClose.refreshNow();
	btnClose.doWindowEvents(0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="unload" id="e23c60b9-e3e8-48b1-963e-7dda767f1882">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		07 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="86dea4be-9898-43f7-a636-24d03d044e9a">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if theObject = global then
		if eventType = CNEC_DOCMODEL_STEP_STARTING then
			self.aCurrentSchema	:=	userInfo.String;
			self.aPartsToDo		:=	0;
			self.aPartsToDo		:=	0;
			self.aIsDone		:=	false;

		elseif eventType = CNEC_DOCMODEL_STEP_SCHEMACOUNT then
			self.aPartsToDo		:=	userInfo.Integer;
			self.aPartsDone		:=	0;
		
		elseif eventType = CNEC_DOCMODEL_STEP_CLASSCOUNT then
			self.aPartsToDo		:=	self.aPartsToDo + userInfo.Integer;
			
		elseif eventType = CNEC_DOCMODEL_STEP_SCHEMA then
			self.aCurrentSchema	:=	userInfo.String;
			self.aPartsDone		:=	self.aPartsDone + 1;
		
		elseif eventType = CNEC_DOCMODEL_STEP_CLASS then
			self.aCurrentClass	:=	userInfo.String;
			self.aPartsDone		:=	self.aPartsDone + 1;
		
		elseif eventType = CNEC_DOCMODEL_STEP_DONE then
			self.aIsDone		:=	true;
			self.aPartsDone		:=	self.aPartsToDo;
			
		else
			return;
		
		endif;
		
		self.doFormUpdate();
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
