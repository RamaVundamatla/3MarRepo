    <JadeMethod name="trxCreateProformaInvLinesVess" id="dc49dfb0-5bcb-4bb5-a197-e634e3308a56">
        <updating/>
        <source>trxCreateProformaInvLinesVess(_agent : CM_CashProformaVoyageAgent;_voyage : CM_Voyage;
								_passport : CM_Passport input
								) : CM_InvoiceLineBySeqNumDict updating;
/*
Purpose:			TFS 37454
Date				Who			Reason
MARCH 2018		JLGAB1		Initial creation
*/
vars
	lines : CM_InvoiceLineBySeqNumDict;
	line : CM_InvoiceLine;
begin
	// we are going to abort this, so do a limited pre-transaction setup
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	_passport.initialiseTransaction();	
	
	// ### JIRA 33576 05DEC2024 NAVAB1
	/* already done in calling method
	if _agent.selectedTrxCriteria = null then
		return null;
	endif;
	*/
	
	beginTransaction;
	
	app.setIsInProformaMode( true );

	lines := app.myUtilityCA.utlCreateProformaInvLinesVess(_agent, _voyage, _passport);

	return lines;
	
epilog
	app.setIsInProformaMode( false );
	abortTransaction;
	
end;
</source>
        <Parameter name="_agent" type="CM_CashProformaVoyageAgent"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
