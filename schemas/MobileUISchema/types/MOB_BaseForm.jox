    <JadeMethod name="getVehicleMountedScreenSize" id="50d0135f-d182-497e-9925-3c1f60fb283d">
        <source>getVehicleMountedScreenSize(_width, _height : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwer1	Initial creation

*/

vars
	theLeft, theTop, theWidth, theHeight :Integer;
begin
	if app.isOnDevice() then
		self.getMonitorWorkArea(theLeft, theTop, theWidth, theHeight);
		_width:=theWidth;
		_height:=theHeight;
	else
		
		self.getSessionAgent().getLastScreenPosition( theLeft, theTop, theWidth, theHeight );
		if theWidth &lt;&gt; 0 and theHeight &lt;&gt; 0 then
			_width:=theWidth;
			_height:=theHeight;
		else
			_width:=600;
			_height:=400;
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="_width" type="Integer" usage="output"/>
        <Parameter name="_height" type="Integer" usage="output"/>
    </JadeMethod>
