    <JadeMethod name="userNotify" id="c9d38d5a-3f23-4929-8e71-0fd050329004">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if eventType = Event_ProcessUserCodeUpdate then
		self.handleProcessUserCodeUpdate(theObject.Process);
	//29 Nov 2019	NDL	TFS 47053
	elseif eventType = EVENT_APP_LOG_LEVEL_Resp then
		self.handleLogLevelResp(theObject.Process, userInfo.Integer);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateTerminate" id="30664bf7-74be-4a13-a4c0-7026edfb7fdb">
        <source>validateTerminate(_row : Integer io) : Boolean;
// ---------------------------------------------------------------------------
// Created:     14 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if not app.myCurrentUserCan(self.myTerminal, PmAdmKilluserMaint) then
		app.msgBox(app.getErrorString1(VB_SECMOVE,"System Supervisor") ,
										"System Supervisor",
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;

	_row := self.tblNodes.row;
	if _row &lt;= self.tblNodes.fixedRows then
		app.msgBox(app.getErrorString2(PleaseSelectAnObject, app.getErrorString(Process_GC), app.getErrorString(Terminate)) ,
										app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="_row" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
