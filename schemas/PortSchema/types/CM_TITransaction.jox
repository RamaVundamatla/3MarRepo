    <JadeMethod name="getDetails" id="2716c720-6645-4516-9497-3acb6b0a2749">
        <source>getDetails() : String;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars

	desc : String;

begin

	desc :=  self.getDisplayStringForAttribute(ETRow_Details, false);
	
	//27 Aug 2012	NDL	Par 29968
	if desc = null or desc.pos("double-click",1) &gt; 0 then
		desc := self.typeString;
	endif;
	
	return desc;
	
end;
