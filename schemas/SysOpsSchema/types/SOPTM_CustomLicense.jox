    <JadeMethod name="initShtMultiSelect" id="3e9cd321-a9b5-487e-9574-4a1b0ca9882e">
        <source>initShtMultiSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars

begin
	inheritMethod();
	// Terminal Area
	self.setupMultiSelect1(app.getErrorString(TerminalArea), self.myForm.myTerminal.allTerminalAreas, SOP_TableMaintForm::displayEntryTerminalArea.name);
	
	// Custom Document Types
	self.setupMultiSelect2(app.getErrorString(Custom_document_type), self.myForm.myTerminal.allCustomDocumentTypes, SOP_TableMaintForm::displayEntryCustDocType.name);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="4cde7669-9ec7-4fa4-aa48-df5a32cf9164">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars
	theForm 			: SOP_TableMaintForm;
begin
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.shtMultiSelect1.visible := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.shtMultiSelect2.visible := true;
	theForm.mulSelect2.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_NotAvailForEntry);
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);
		theForm.fldInput.initSheetBackColors();
		self.doPopulateMsgForAdd();
	else
		self.showThumbnail(theForm.myProxyObject.CM_CustomLicense);
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_NotAvailForEntry);
	endif;
	
	self.enableMulSelect1Contents();
	self.enableMulSelect2Contents();
	theForm.tblInput1.cnEcResizeContents();
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="e106d114-0e05-4232-a0c7-611bf52c29d5">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars
	theForm : SOP_TableMaintForm;
	
begin
	
	inheritMethod();  
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
  	theForm.tblInput1.cnEcResizeContents();
  	theForm.shtMultiSelect1.visible := true;
	theForm.shtMultiSelect2.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="df7b6257-bc7a-461d-8230-33d87db72a8c">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars
	theForm : SOP_TableMaintForm;
begin

	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CustomLicenseMaintList);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CustomLicenseMaintTbl);
	theForm.shtTblInput1.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a8b0df44-14eb-4506-a549-312f2dcca77f">
        <updating/>
        <source>showThumbnail(pCustomLicense : CM_CustomLicense) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars
	theForm 			: SOP_TableMaintForm;
	ta					: CM_TerminalArea;
	allTAs				: CM_TerminalAreaSet;
	terminal			: CM_Terminal;
begin
	theForm := self.myForm;
	
	theForm.tblInput1.clearValues;
	theForm.mulSelect1.multiClear();
	
	theForm.tblInput1.setValueByName(ETRow_Code, pCustomLicense.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pCustomLicense.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailForEntry, pCustomLicense.notAvailForEntry);
	
	create allTAs transient;
	terminal := theForm.myTerminal;
	
	foreach ta in terminal.allTerminalAreas discreteLock do
		if ta.myCustomLicense = null or pCustomLicense.allTerminalAreas.includes(ta) then
			allTAs.add(ta);
		endif;
	endforeach;
	
	theForm.mulSelect1.setAvailable(allTAs, true);
	theForm.mulSelect1.setSelected(pCustomLicense.allTerminalAreas);	
	
	self.disableMulSelect1Contents();
	
	theForm.mulSelect2.setSelected(pCustomLicense.allCustomDocumentTypes);
	self.disableMulSelect2Contents();
epilog
	delete allTAs;
end;</source>
        <Parameter name="pCustomLicense" type="CM_CustomLicense"/>
    </JadeMethod>
</Class>
