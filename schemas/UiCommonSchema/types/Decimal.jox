<PrimType name="Decimal">
    <JadeMethod name="asStringOrBlank" id="653d0753-690f-409c-bf4b-cf0a657e3db2">
        <source>asStringOrBlank():String;
/*
	Purpose:		Output receiver as string only if it has a value.
					Used in reporting
	Parameters:			
	Return Value:	The receiver as a string - blank string if self = null	

Date			Who		Reason
05 August 2008	concms1	Initial creation
*/

vars

begin
	if self &lt;&gt; null then
		return self.String;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
