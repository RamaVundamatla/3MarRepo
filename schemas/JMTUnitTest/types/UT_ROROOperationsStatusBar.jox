begin

	app.writeLog("STEP 2", LogINFO);
	app.writeLog("Colour coding discharge slots.  Creating dischargeJobs.  Please wait...", LogINFO);
	
	create strs transient;
	create roroLCs transient;
	
	// locations to discharge colour code
	create dischargeLocn transient;
	dischargeLocn.clear;
	dischargeLocn.add("D4230190");
	dischargeLocn.add("D4230192");
	dischargeLocn.add("D4210190");
	dischargeLocn.add("D4210192");
	dischargeLocn.add("D4270690");
