<Class name="HMS_Pilot">
    <JadeMethod name="importPLXMLReference" id="7da6299c-05c4-4202-9fd1-cf2a40ac7114">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = "myRoot" then
		return app.myRoot;
	elseif _name = "myCurrentHarbour" then
		return app.getMyHarbour();
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
