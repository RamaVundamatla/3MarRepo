    <JadeMethod name="range" id="e59ef795-02fe-46c3-9d56-3194e9e820c6">
        <source>range(_pattern : String): Boolean;
//13 April 2010	cnwml2
//PAR 23586 POL CCMS 1878
vars
	pattern: CMIF_YAPattern;
begin
	create pattern transient;
	pattern.setPattern(_pattern, CMIF_YAPattern.YAPattern_Range);
	if pattern.isPattern() or _pattern.containsOneOf(",")then
		return pattern.match(self);
	else
		return self.startsWith(_pattern);
	endif;
	
epilog
	delete pattern;
end;</source>
        <Parameter name="_pattern" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
