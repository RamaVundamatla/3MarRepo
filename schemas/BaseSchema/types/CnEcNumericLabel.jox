    <PrimAttribute name="isStripDecimalZeros" id="56e9a0c3-cdd5-4a79-8a40-60f4ddd7348a">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myNumberFormat" id="b98dc4b0-9e02-4d72-839f-13174cd65094">
        <embedded/>
        <type name="NumberFormat"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="numberLayout" id="00793b58-50fd-4401-9c3d-8ff367694af2">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="caption" id="5a7ed476-dea3-4cc4-ac93-c811a12e9e90">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>caption(set: Boolean; value: String io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		08 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/07/2002	cnwdad1		Added a feature to optionally strip out trailing zeros
//							from the values following the decimal point.
// --------------------------------------------------------------------------------
vars
	negative	: String;

begin
	if set then
		if self.myNumberFormat &lt;&gt; null then
			negative := self.myNumberFormat.negativeSign;
		else
			negative := "-";
		endif;
		
		self.cnEcSetPositiveValueColor(value.pos(negative, 1) = 0);
		
		if self.numberLayout = self.LAYOUT_DECIMAL then
			value	:=	value.Decimal.numberFormat();
			
			if self.isStripDecimalZeros then					// cnwdad1 27/07/2002.
				value	:=	value.cnEcStripDecimalZeros();		// cnwdad1 27/07/2002.
			endif;												// cnwdad1 27/07/2002.
			
		elseif self.numberLayout = self.LAYOUT_INTEGER then
			value	:=	value.Integer.String;
		elseif self.numberLayout = self.LAYOUT_REAL then
			value	:=	value.Real.numberFormat();
		endif;
	else
		value 	:=	value.cnEcAsNumeric(self.myNumberFormat);
	endif;
	
	inheritMethod(set, value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAlignment" id="e888d170-0f8a-4152-a1e6-c1bdda25f026">
        <updating/>
        <source>setAlignment() updating, protected;
// --------------------------------------------------------------------------------
// Created:		19 September 2002 by cnwdad3
//
// Purpose:		Sets the receiver's alignment to be right-aligned, and vertically middle.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.alignment		:=	Label.Alignment_Right_Middle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="8e7b1081-573c-4dbb-91eb-785afaa6c3b9">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		08 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);

	self.myNumberFormat	:=	app.currentLocaleInfo.numericInfo;

	if self.numberLayout = null then
		self.numberLayout	:=	self.LAYOUT_DECIMAL;
	endif;

	self.setAlignment();
	self.caption	:=	self.caption;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
