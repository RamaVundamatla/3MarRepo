    <JadeMethod name="generateSOAPFault" id="34c318ed-9304-416f-a9f3-3a7416775c45">
        <source>generateSOAPFault(_interrupted: Boolean): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2021	navmd1	Initial creation

*/

vars
	message : String;
begin
	if _interrupted then
		message := "Method interrupted due to execution taking longer than the specified timeout";
	else
		message := "Exception occurred in reply generation";
	endif;
	
	return	'&lt;?xml version="1.0" encoding="UTF-8"?&gt;' &amp;
			'&lt;soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"&gt;' &amp; 
			'&lt;soap:Body&gt;' &amp; 
			'&lt;soap:Fault&gt;' &amp; 
			'&lt;faultcode&gt;soap:Sender&lt;/faultcode&gt;' &amp; 
			'&lt;faultstring&gt;Error 11051 - Exception occurred in reply generation&lt;/faultstring&gt;' &amp;
			'&lt;detail&gt;' &amp; 
			'&lt;tns:faultDetails xmlns:tns="urn:JadeWebServices/JMTWebService/"&gt;' &amp; 
			'&lt;errorCode&gt;11051&lt;/errorCode&gt;' &amp;
			'&lt;errorItem&gt;Server&lt;/errorItem&gt;' &amp; 
			'&lt;errorText&gt;' &amp; message &amp; '&lt;/errorText&gt;' &amp; 
			'&lt;/tns:faultDetails&gt;' &amp; 
			'&lt;/detail&gt;' &amp; 
			'&lt;/soap:Fault&gt;' &amp; 
			'&lt;/soap:Body&gt;';
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_interrupted" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMethodName" id="06b7274e-f7e8-4645-b932-305ad4768ff5">
        <source>getMethodName() : String protected;
/*

