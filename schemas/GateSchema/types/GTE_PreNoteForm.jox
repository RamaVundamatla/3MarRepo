    <JadeMethod name="entTableSetObjectWarning" id="347339ff-143d-41cc-bc8a-4d75458f9456">
        <updating/>
        <source>entTableSetObjectWarning(pTableName: String; pPropertyName: String; pMsg: String) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pPropertyName = 'allDischargePorts' or
	   pPropertyName = 'allHazards' or
	   pPropertyName = 'couISOType' or
	   pPropertyName = 'couTypeString' or
	   pPropertyName = 'couId' or
	   pPropertyName = 'isOverDimensions' or
	   pPropertyName = 'idTextBox' or
	   pPropertyName = 'cargoType' then
	   	return;
	endif;
	
	inheritMethod(pTableName, pPropertyName, pMsg);

end;</source>
        <Parameter name="pTableName" type="String"/>
        <Parameter name="pPropertyName" type="String"/>
        <Parameter name="pMsg" type="String"/>
