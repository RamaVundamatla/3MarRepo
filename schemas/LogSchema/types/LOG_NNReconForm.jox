    <JadeMethod name="displaySummaryNNlogs" id="9f20005e-3f31-49e5-8b0b-edef935c512c">
        <updating/>
        <source>displaySummaryNNlogs() updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	iter		: Iterator;
	nnLog		: CMIF_LogNNReconDtl;
begin

	self.tblNNSummary.rows := self.tblNNSummary.fixedRows;
	self.myCurrentCMIFNNReconDtl := null;
	
	iter := self.allCMIF_LogNNReconDtls.createIterator;
	//pop da table
	while iter.next(nnLog) do
		self.addTblNNSummaryRow(nnLog);
	endwhile;
	tblNNSummary.colourRows(self.colorRow1, self.colorRow2);
	
epilog
	delete iter;	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayWarning" id="dd50f0a8-cb7d-4d9a-93dd-0e37c8b024bf">
        <updating/>
        <source>displayWarning(_errorMsg : String)updating;
//--------------------------------------------------------------
//Created: 08 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	savePointer	: Integer;
	errorForm	: CMUI_WarningMsgForm;
	result		: Integer;
	frmCaption	: String;
begin
	if (not self.isShowError) or _errorMsg = null then
		return;
	endif;
	
	if self.myFiltLogVoyage.myLogVoyageStructure = null then 
		return;
	endif;
	if self.myFiltLogVoyage.myLogVoyageStructure.allLogBOLsInError.isEmpty then	
		return;
	endif;
	
	frmCaption := 'WARNING: Voyage ' &amp; self.myFiltLogVoyage.code;
	savePointer := app.mousePointer;
	app.mousePointer := MousePointer_Default;
	
	create errorForm transient;
	errorForm.lbErrorMessage.caption := _errorMsg;
	errorForm.caption := frmCaption;
	errorForm.centreWindow();
	errorForm.backColor := self.backColor;
	errorForm.showModal();
	if errorForm.cbxDontShow.value then
		self.isShowError := false;
	else
		self.isShowError := true;		
	endif;
epilog
	app.mousePointer := savePointer;
end;</source>
        <Parameter name="_errorMsg" type="String"/>
    </JadeMethod>
