    <JadeMethod name="addOptionalColumnsToCol" id="da8155ce-8356-4424-ae19-05815ef9c3a3">
        <updating/>
        <source>addOptionalColumnsToCol(_sqlTable       : CM_DataDumpExtractClass;
                        _columnPosDict  : CM_SQLColumnByOrdinalPosDict io;
						_sqlColumnArray : CM_ObjectArray io) : Boolean updating;
/*

Purpose:			Adds the optional (including oidColumn) to the columnDict
					uses _sqlColumnArray to keep track of transient sqlCoumns so we can delete them

Parameters:			

Return Value:		


Date			Who		Reason
31 May 2010		conkc1	Initial creation

PAR 24641
*/

vars
	sqlColumn   : CM_DataDumpSQLColumn;
	tsqlColumn  : CM_DataDumpSQLColumn;
begin
	if _sqlTable.oidColumnPos = 0 then
		app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, _sqlTable.myDataDumpExtractDef.oidColumnName),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		app.raiseCMException1(ERR_BulkLoadNullColumnPos, _sqlTable.myDataDumpExtractDef.oidColumnName, null, null);
		return false;
	endif;
		
	create sqlColumn transient;
	sqlColumn.setupOptionalColumns(_sqlTable.myDataDumpExtractDef.oidColumnName, _sqlTable.oidColumnPos, 1);
	//write self.myExternalDatabaseAgent.getColumnOrdinalPosition(_sqlTable.sqlTableName, _sqlTable.myDataDumpExtractDef.oidColumnName).String &amp; " " &amp; "oidColumn";

	tsqlColumn := _columnPosDict[sqlColumn.sqlColumnOrdinalPosition];
	if tsqlColumn = null then
		_columnPosDict.add(sqlColumn);
		_sqlColumnArray.add(sqlColumn);
	else
		//write "Error - " &amp; sqlColumn.name &amp; " " &amp; sqlColumn.sqlColumnOrdinalPosition.String;
		app.msgBox(app.getErrorString2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		app.raiseCMException2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String, null, null);
		return false;
	endif;

	if _sqlTable.lastOperationColumnName &lt;&gt; null then
		if _sqlTable.lastOperationColumnPos = 0 then
		   app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, _sqlTable.lastOperationColumnName),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		   app.raiseCMException1(ERR_BulkLoadNullColumnPos, _sqlTable.lastOperationColumnName, null, null);
		   return false;
		endif;
		
		create sqlColumn transient;
		//write self.myExternalDatabaseAgent.getColumnOrdinalPosition(sqlTable.sqlTableName, sqlTable.lastOperationColumnName).String &amp; " " &amp; "lastOperation";
		sqlColumn.setupOptionalColumns(_sqlTable.lastOperationColumnName, _sqlTable.lastOperationColumnPos, 0);

		tsqlColumn := _columnPosDict[sqlColumn.sqlColumnOrdinalPosition];
		if tsqlColumn = null then
			_columnPosDict.add(sqlColumn);
			_sqlColumnArray.add(sqlColumn);
		else
			app.msgBox(app.getErrorString2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
			app.raiseCMException2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String, null, null);
			return false;
		endif;
	endif;

	if _sqlTable.exportedTimestampColumnName &lt;&gt; null then
		if _sqlTable.exportedTimestampColumnPos = 0 then
		   app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, _sqlTable.exportedTimestampColumnName),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		   app.raiseCMException1(ERR_BulkLoadNullColumnPos, _sqlTable.exportedTimestampColumnName, null, null);
		   return false;
		endif;
		
		create sqlColumn transient;
		//write self.myExternalDatabaseAgent.getColumnOrdinalPosition(sqlTable.sqlTableName, sqlTable.exportedTimestampColumnName).String &amp; " " &amp; "lastExported";
		sqlColumn.setupOptionalColumns(_sqlTable.exportedTimestampColumnName, _sqlTable.exportedTimestampColumnPos, 0);

		tsqlColumn := _columnPosDict[sqlColumn.sqlColumnOrdinalPosition];
		if tsqlColumn = null then
			_columnPosDict.add(sqlColumn);
			_sqlColumnArray.add(sqlColumn);
		else
			app.msgBox(app.getErrorString2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
			app.raiseCMException2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String, null, null);
			return false;
		endif;
	endif;

	if _sqlTable.deleteActionColumnName &lt;&gt; null then
		if _sqlTable.deleteActionColumnPos = 0 then
		   app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, _sqlTable.deleteActionColumnName),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		   app.raiseCMException1(ERR_BulkLoadNullColumnPos, _sqlTable.deleteActionColumnName, null, null);
		   return false;
		endif;
		
		create sqlColumn transient;
		//write self.myExternalDatabaseAgent.getColumnOrdinalPosition(sqlTable.sqlTableName, sqlTable.deleteActionColumnName).String &amp; " " &amp; "isDeleted";
		sqlColumn.setupOptionalColumns(_sqlTable.deleteActionColumnName, _sqlTable.deleteActionColumnPos, 0);

		tsqlColumn := _columnPosDict[sqlColumn.sqlColumnOrdinalPosition];
		if tsqlColumn = null then
			_columnPosDict.add(sqlColumn);
			_sqlColumnArray.add(sqlColumn);
		else
			app.msgBox(app.getErrorString2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
			app.raiseCMException2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String, null, null);
			return false;
		endif;
	endif;

	return true;
	
epilog

end;</source>
        <Parameter name="_sqlTable" type="CM_DataDumpExtractClass"/>
        <Parameter name="_columnPosDict" type="CM_SQLColumnByOrdinalPosDict" usage="io"/>
        <Parameter name="_sqlColumnArray" type="CM_ObjectArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildAssignmentStrForBulkLoad" id="b2eb877c-c209-4085-b92a-b046ae3c3375">
        <source>buildAssignmentStrForBulkLoad(_extractClass : CM_DataDumpExtractClass; _extDBFeature : CM_ExternalDBFeatureDict io; _class : Class; _subClassName : String; _tabs : String; _assignmentString : String io; _sqlColumnLenDict : DynaDictionary) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	#cnwdz2	 26049

*/

vars
	sqlColumn        : CM_DataDumpSQLColumn;
	feature          : CM_DataDumpFeature;
	featureName      : String;
	maxLength        : Boolean;
	length           : Integer;
	scaleFactor      : Integer;
	type             : String;
	validateTimeMethod : String;
	featuresToDelete : CM_ExternalDBFeatureDict;
	truncatedMethod  : String;
begin
	create featuresToDelete transient;
	
	foreach feature in _extDBFeature do
		if _class.findProperty(feature.featureName) = null and _class.findMethod(feature.featureName) = null then
			continue;			
		endif;
		//
		// Have to use sendMsg and getPropertyValue for protected items
		//
		if feature.returnValueIsAnObject = true then
		
			if feature.isProtected = true then

				if feature.isFeatureMethod() then				
					featureName := "o.sendMsgWithParams('" &amp; feature.featureName &amp; "').Object" &amp; feature.getFeatureType(null,length, scaleFactor, maxLength);
				else
					featureName := "o.getPropertyValue('" &amp; feature.featureName &amp; "').Object";
				endif;
			else
				if _subClassName &lt;&gt; null then
					featureName := "o." &amp; _subClassName &amp; "." &amp; feature.featureName;
				else
					featureName := "o." &amp; feature.featureName;
				endif;
			endif;

			_assignmentString := _assignmentString &amp; _tabs &amp; feature.featureName.padBlanks(30) &amp; " := " &amp;
								"app.dataDumpBuildOIDValue(" &amp; _extractClass.myDataDumpExtractDef.oidFormat.String &amp; ", " &amp; featureName &amp; ")." &amp;
								_extractClass.myDataDumpExtractDef.getOIDCasting() &amp; ";" &amp; CrLf;
		else
			//
			//  Handle truncation here
			//
			type := feature.getFeatureType(null,length, scaleFactor, maxLength);
			truncatedMethod := null;
			if type.startsWith("String") or type.startsWith("Binary") then
				sqlColumn := _sqlColumnLenDict.getAtKey(feature).CM_DataDumpSQLColumn;
				if sqlColumn.isMaximumLength = false then
					truncatedMethod := ".truncatedAt(" &amp; sqlColumn.length.String &amp; ")";
				endif;
			endif;

			if feature.isProtected = true then
				if feature.isFeatureMethod() then
					featureName := "o.sendMsgWithParams('" &amp; feature.featureName &amp; "')." &amp; type;
				else
					//
					// Getting Decimals via getProperty - drop length and precision
					//
					if type.startsWith("Decimal") then
						featureName := "o.getPropertyValue('" &amp; feature.featureName &amp; "').Decimal";
					else
						featureName := "o.getPropertyValue('" &amp; feature.featureName &amp; "')." &amp; type;
					endif;
				endif;
				_assignmentString := _assignmentString &amp; _tabs &amp; feature.featureName.padBlanks(30) &amp; " := " &amp; featureName &amp; truncatedMethod &amp; ";" &amp; CrLf;
			else
				if _subClassName &lt;&gt; null then
					_assignmentString := _assignmentString &amp; _tabs &amp; feature.featureName.padBlanks(30) &amp; " := " &amp;
									"o." &amp; _subClassName &amp; "." &amp; feature.featureName &amp; truncatedMethod &amp; ";" &amp; CrLf;
				else
					_assignmentString := _assignmentString &amp; _tabs &amp; feature.featureName.padBlanks(30) &amp; " := " &amp;
									"o." &amp; feature.featureName &amp; truncatedMethod &amp; ";" &amp; CrLf;
				endif;
			endif;
		endif;			
		
		if _subClassName = null then
			featuresToDelete.add(feature);
		endif;
	endforeach;
	
	if _subClassName = null then
		foreach feature in featuresToDelete do
			_extDBFeature.removeIfPresent(feature);
		endforeach;
	endif;
epilog
	delete featuresToDelete;
end;</source>
        <access>protected</access>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_extDBFeature" type="CM_ExternalDBFeatureDict" usage="io"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_subClassName" type="String"/>
        <Parameter name="_tabs" type="String"/>
        <Parameter name="_assignmentString" type="String" usage="io"/>
        <Parameter name="_sqlColumnLenDict" type="DynaDictionary"/>
    </JadeMethod>
    <JadeMethod name="buildTransientBulkDataDump" id="28eb4861-ed24-4e98-a42e-95ac21bb2512">
        <updating/>
        <source>buildTransientBulkDataDump(_transClass : CM_DataDumpTransSpecClass io; _methodSource : String output) : Boolean updating;
/*
Purpose:			Build Jade source for Bulk extract
					

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2010	conkc1	Initial creation

PAR 24641
*/
constants
	Line1       : String = "(_file : File io;  _oidFile : File io; __sequenceNumber : Integer io";
	Line2       : String = "";
	Line3       : String = ") : Integer updating;" &amp; CrLf;
	Line4       : String = "constants" &amp; CrLf &amp; Tab &amp; 
						   "NullDate : Date = null;" &amp; CrLf &amp; Tab &amp;
						   "NullTime : Time = null;" &amp; CrLf &amp; Tab &amp;
						   "NullTimeStamp : TimeStamp = null;" &amp; CrLf &amp;
						   "vars" &amp; CrLf &amp; 
						   Tab &amp; "__objectCount : Integer;" &amp; CrLf &amp;
						   Tab &amp; "today : TimeStamp;" &amp; CrLf &amp; 
						   Tab &amp; "result : Integer;" &amp; CrLf &amp; 
						   Tab &amp; "__data : Binary;" &amp; CrLf &amp;
						   Tab &amp; "__errorCode : Integer;" &amp; CrLf &amp;
						   "// -- Generated ";
	OBJECTLine  : String = Tab &amp; "o" &amp; Tab &amp; ": ";
	Line5       : String = "begin " &amp; CrLf &amp; 
	                       Tab &amp; "result := -1;" &amp; CrLf &amp;
	                       Tab &amp; "on Exception do self.handleExceptionFromTransientM(exception, o, __errorCode);" &amp; CrLf &amp;
						   Tab &amp; "on LockException do app.cnGlobalLockExceptionHandler(exception);" &amp; CrLf &amp; CrLf;
	Line5a      : String = Tab &amp; "self.log('Dumping Class - ";
	FOREACHLine : String = Tab &amp; "foreach o in ";
	Line6       : String = ".instances do" &amp; CrLf &amp; CrLf &amp;
						   Tab &amp; Tab &amp; "if __errorCode &lt;&gt; 0 then break; endif;" &amp; CrLf &amp;
	                       Tab &amp; Tab &amp; "__objectCount := __objectCount + 1;" &amp; CrLf &amp;
						   Tab &amp; Tab &amp; "__sequenceNumber := __sequenceNumber + 1;" &amp; CrLf &amp;
	//					   Tab &amp; Tab &amp; "if __objectCount &gt; 1000 then break; endif;" &amp; CrLf &amp;
						   Tab &amp; Tab &amp; "if __objectCount mod 100000 = 0 then" &amp; CrLf &amp;
						   Tab &amp; Tab &amp; Tab &amp; "self.log('Objects dumped - ' &amp; __objectCount.String);" &amp; CrLf &amp;
						   Tab &amp; Tab &amp; "endif;" &amp; CrLf;   
	Line10      : String = Tab &amp; "self.log('Total Objects dumped - ' &amp; __objectCount.String);" &amp; CrLf &amp;
	                       Tab &amp; "result := __objectCount;" &amp; CrLf &amp;
	                       Tab &amp; "return result;" &amp; CrLf &amp; 
						   "epilog" &amp; CrLf &amp;
						   "end;";
	OUTPUTLine  : String = Tab &amp; Tab &amp; "__data := (" &amp; CrLf;
	WRITELine   : String = Tab &amp; Tab &amp; "_file.writeBinary(__data);" &amp; CrLf &amp; 
						   Tab &amp; Tab &amp; "if _oidFile &lt;&gt; null then" &amp; CrLf &amp; 
						   Tab &amp; Tab &amp; "   _oidFile.writeLine(__sequenceNumber.padLeadingWith('0', 8) &amp; ' ' &amp; o.String);" &amp; CrLf &amp; 
						   Tab &amp; Tab &amp; "endif;" &amp; CrLf &amp; 
						   Tab &amp; "endforeach;" &amp; CrLf;
	
vars

	sqlColumn        : CM_DataDumpSQLColumn;
	extractClass     : CM_DataDumpExtractClass;
	feature          : CM_DataDumpFeature;
	columnPosDict    : CM_SQLColumnByOrdinalPosDict;
	extDBFeature     : CM_ExternalDBFeatureDict;
	sqlColumnArray   : CM_ObjectArray;
	sqlColumnLenDict : DynaDictionary;

	procedureName    : String;
	varString        : String;
	outputString     : String;
	assignmentStringTmp,
	assignmentString : String;
	optParamString   : String;
	returnString     : String;
	subClassName     : String;
	tabs             : String;
	varName          : String;
	maxLength        : Boolean;
	length           : Integer;
	scaleFactor      : Integer;
	numberOfColumns  : Integer;
	count            : Integer;
    featureName      : String;
	type             : String;
	truncatedMethod  : String;
	today            : TimeStamp;
	dataDumpClass    : CM_DataDumpClass;
	subClasses       :ClassColl;
	subClass,
	class		     : Class;
begin

	extractClass := _transClass.myExtractClass;
	create extDBFeature   transient;
	create columnPosDict  transient;
	create sqlColumnArray transient;
	create sqlColumnLenDict transient;
	//
	//  Require this to get SQL Defined lengths for Jade Feature so we can truncate the data to the SQL
	//  defined lengths. If the extracted data is longer than the SQL Definition, the Bulk Insert fails
	//  without giving any clues to what row or column is wrong
	//
	sqlColumnLenDict.setMembership(CM_DataDumpSQLColumn);
	sqlColumnLenDict.addMemberKey("myDataDumpFeature", false, false);
	sqlColumnLenDict.endKeys(true);

	addOptionalColumnsToCol(extractClass, columnPosDict, sqlColumnArray);
	//
	// Sort into column order so we can extract in column order
	//
	foreach sqlColumn in extractClass.allDataDumpSQLColumns do
		columnPosDict.add(sqlColumn);
	endforeach;

	procedureName   := extractClass.sqlTableName;
	returnString    := BulkData_MethodName &amp; Line1 &amp; 
	                   Line2 &amp; Line3 &amp; Line4 &amp; today.String &amp; CrLf;
					   
	returnString    := returnString &amp; OBJECTLine &amp; extractClass.className &amp; ";" &amp; CrLf;
	outputString    := OUTPUTLine;
	numberOfColumns := columnPosDict.size;

	foreach sqlColumn in columnPosDict do

		if sqlColumn.myDataDumpFeature = null then
			// process optional columns
			varName   := sqlColumn.name;
		else
			varName   := sqlColumn.myDataDumpFeature.featureName;
			sqlColumnLenDict.add(sqlColumn);
		endif;
		
		varString := varString &amp; Tab &amp; varName.padBlanks(30) &amp; " : ";
		//
		//  Decimals returned from a method have no length so we use the SQL user defined lengths
		//  If these do not match the actual SQL Database a run time error will occur
		//
		if sqlColumn.myDataDumpSQLDataType = null then
			// process optional columns
			if sqlColumn.name = extractClass.deleteActionColumnName then
				varString := varString &amp; "Boolean" &amp; ";" &amp; CrLf;
				assignmentString := assignmentString &amp; Tab &amp; sqlColumn.name.padBlanks(30) &amp; " := false;" &amp; CrLf;
				type := "Boolean";
			elseif sqlColumn.name = extractClass.lastOperationColumnName then
				varString := varString &amp; "Character" &amp; ";" &amp; CrLf;
				assignmentString := assignmentString &amp; Tab &amp; sqlColumn.name.padBlanks(30) &amp; " := 'L';" &amp; CrLf;
				type := "Character";
			elseif sqlColumn.name = extractClass.exportedTimestampColumnName then
				varString := varString &amp; "TimeStamp" &amp; ";" &amp; CrLf;
				assignmentString := assignmentString &amp; Tab &amp; sqlColumn.name.padBlanks(30) &amp;  " := today;" &amp; CrLf;
				type := "TimeStamp";
			elseif sqlColumn.name = extractClass.myDataDumpExtractDef.oidColumnName then
				// is it String or Binary
				if extractClass.myDataDumpExtractDef.oidFormat = CM_DataDumpExtractDef.OIDFormatHex then
					varString := varString &amp; "Binary" &amp; ";" &amp; CrLf;
				elseif extractClass.myDataDumpExtractDef.oidFormat = CM_DataDumpExtractDef.OIDFormatString then
					varString := varString &amp; "String" &amp; ";" &amp; CrLf;
				else
				endif;
				type := "String";
				assignmentString := assignmentString &amp; Tab &amp; sqlColumn.name.padBlanks(30) &amp; " := " &amp;
								"app.dataDumpBuildOIDValue(" &amp; extractClass.myDataDumpExtractDef.oidFormat.String &amp; ", " &amp; "o)." &amp;
								extractClass.myDataDumpExtractDef.getOIDCasting() &amp; ";" &amp; CrLf;

			endif;
		else
		
			if sqlColumn.myDataDumpSQLDataType.name = CM_DataDumpSQLDataType.SQLDecimal then
				varString := varString &amp; "Decimal[" &amp; sqlColumn.length.String &amp; ", " &amp; sqlColumn.decimalDigits.String &amp; "];" &amp; CrLf;
				type      := "Decimal";
			else
				type      := sqlColumn.myDataDumpFeature.getFeatureType(extractClass.myDataDumpExtractDef.oidFormat,length, scaleFactor, maxLength);
				varString := varString &amp; type  &amp; ";" &amp; CrLf;
			endif;

		endif;
		
		
		if type.startsWith("String") or type.startsWith("Binary") then
			outputString  := outputString &amp; Tab &amp; Tab &amp; varName &amp; ".length.Binary.String &amp; " &amp; varName &amp; ".String";
		elseif type = "Boolean" then
			outputString  := outputString &amp; Tab &amp; Tab &amp; varName &amp; ".Integer.String";
		elseif type = "TimeStamp" then
			// format and validate timestamps
			outputString  := outputString &amp; Tab &amp; Tab &amp; varName &amp; ".getValidSQLTimestamp";
		elseif type = "Time" then
			if extractClass.myDataDumpExtractDef.sqlServerVersion &lt;&gt; CM_DataDumpExtractDef.SQLVersion2008 then //29/06/2010 cnwdz2 24829
				outputString  := outputString &amp; Tab &amp; Tab &amp; varName &amp; ".getValidSQLTime2005" &amp; ".date.format('yyyy-MM-dd')" &amp; " &amp; ' ' &amp; " &amp; varName &amp; ".getValidSQLTime2005" &amp; ".time.String" &amp; 
						"&amp; '.000'" &amp; ".String";
			else
				outputString  := outputString &amp; Tab &amp; Tab &amp; varName &amp; ".getValidSQLTime" &amp; ".String";
			endif;
		elseif type = "Date" then
			if extractClass.myDataDumpExtractDef.sqlServerVersion &lt;&gt; CM_DataDumpExtractDef.SQLVersion2008 then //29/06/2010 cnwdz2 24829
				outputString  := outputString &amp; Tab &amp; Tab &amp; varName &amp; ".getValidSQLDate2005" &amp; ".date.format('yyyy-MM-dd')" &amp; " &amp; ' ' &amp; " &amp; varName &amp; ".getValidSQLDate2005" &amp; ".time.String" &amp; 
						"&amp; '.000'" &amp; ".String";
			else
				outputString  := outputString &amp; Tab &amp; Tab &amp; varName &amp; ".getValidSQLDate" &amp; ".format('yyyy-MM-dd')";//.String"; 10/11/2010 cnwdz2 26281
			endif;
		else
			outputString  := outputString &amp; Tab &amp; Tab &amp; varName &amp; ".String";
		endif;

		count  := count + 1;
		if count &lt; numberOfColumns then
			outputString := outputString &amp; " &amp; Tab &amp; " &amp; CrLf;
		else
			outputString := outputString &amp; " &amp; CrLf" &amp; CrLf;
		endif;

		if sqlColumn.myDataDumpFeature &lt;&gt; null then
			extDBFeature.add(sqlColumn.myDataDumpFeature);
		endif;

	endforeach;	
	
	returnString := returnString &amp; varString &amp; CrLf &amp; Line5 &amp; 
					Line5a &amp; _transClass.myClass.name &amp; "');" &amp; CrLf &amp; 
					FOREACHLine &amp; _transClass.myClass.name &amp; Line6;
	tabs := Tab;

	assignmentString := assignmentString &amp; extractClass.buildInitialiseDateTime(true);

	dataDumpClass := extractClass.myDataDumpClass;
	class         := dataDumpClass.myClass;
	
	//26/10/2010 cnwdz2 26049
	//create assignment string for the class
	self.buildAssignmentStrForBulkLoad(extractClass,extDBFeature,class,null,tabs,assignmentString,sqlColumnLenDict);
	
	create subClasses transient;
	class.allSubclasses(subClasses);
	tabs := Tab &amp; Tab;
	foreach subClass in subClasses do	
		assignmentStringTmp := null;
		self.buildAssignmentStrForBulkLoad(extractClass,extDBFeature, subClass, subClass.name, tabs, assignmentStringTmp,sqlColumnLenDict);
		if assignmentStringTmp &lt;&gt; null then
			if subClassName &lt;&gt; null then
				assignmentString := assignmentString &amp; Tab &amp; "elseif ";
			else
				assignmentString := assignmentString &amp; CrLf &amp; Tab &amp; "if ";
			endif;			
			
			subClassName     := subClass.name;
// PAR 33412			assignmentString := assignmentString &amp; Tab &amp; "o.isKindOf(" &amp; subClassName &amp; ") then" &amp; CrLf;
			assignmentString := assignmentString &amp; Tab &amp; "o.class.name = " &amp; subClassName &amp; ".name then" &amp; CrLf; // PAR 33412
			assignmentString := assignmentString &amp; assignmentStringTmp;
		endif;
	endforeach;	
	
	if subClassName &lt;&gt; null then
		assignmentString := assignmentString &amp; Tab &amp; "endif;";
	endif;

	assignmentString := assignmentString &amp; CrLf;

	returnString := returnString &amp; assignmentString;

	returnString := returnString &amp; outputString &amp; ").Binary;" &amp; CrLf &amp; WRITELine;
	returnString := returnString &amp; CrLf &amp; Line10;
	
	_methodSource := returnString;
	//write returnString;
	return true;

epilog
	delete subClasses;
	delete extDBFeature;
	delete columnPosDict;
	sqlColumnArray.purge;
	delete sqlColumnArray;
	delete sqlColumnLenDict;

end;</source>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass" usage="io"/>
        <Parameter name="_methodSource" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="closeCurrentJournalLog" id="c4a0b2ab-5b24-40ef-9e4c-536a34dda944">
        <updating/>
        <source>closeCurrentJournalLog() updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2003 by cnwsb1
//
// Purpose: 	Closes the current journal log so that the Change Tracker
//				agent can process the objects in it.  This should be done
//				at least a minute before starting the extract - which is
//				allowed for by calling it before the setExtractDef logic
//				(which always takes a long time!).
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Feb 2012	cnwkpd1	PAR #28906 - Change to use documented method to force close
	
*/

vars
	jda : JadeDatabaseAdmin;

begin
	self.log("Closing current journal log");
	
	create jda transient;
	jda.closeCurrentJournal;
	
epilog
	delete jda;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="af1ebc9a-0742-41d7-a22a-38f297a65427">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	create self.allSystemAlertMessages transient;
	self.myTransientMethodIterator := self.allDataDumpTransientMethod.createIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="createSQLNativeAlert" id="535f8d85-7297-4930-81e0-585dc77cc6ff">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>createSQLNativeAlert(_details : String) clientExecution, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 June 2010	conkc1	Initial creation
*/
vars
	string : String;
begin
	if self.alertCounter &gt; self.alertLimit then
		return;
	elseif self.alertCounter = self.alertLimit then
		string := app.getErrorString1(ERR_AlertLimitReached,self.alertLimit.String); 
	else
		string := _details;
		string.replaceChar(Tab, " ");
	endif;
	self.alertCounter := self.alertCounter + 1;
	app.myPassport.createAlert(SEVERE_ERROR, string, EVENT_SQL_NativeRT, null);
	app.commitAlert();
epilog

end;</source>
        <Parameter name="_details" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6da1f21d-117b-4cfa-97f6-9e4923bac603">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.allDataDumpTransientMethod.purge();		//cnwmc5 - 8 July 2015 - PAR 36599
	self.allSystemAlertMessages.purge;
	delete self.allSystemAlertMessages;
	delete self.myTransientMethodIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractClassSetChanges" id="7468f54b-95e4-4e38-bed2-71df774e53ba">
        <updating/>
        <source>doExtractClassSetChanges(_dataDumpExtractClassSet : CM_DataDumpExtractClassSet;
							_def : CM_DataDumpExtractDef;
							_volumeTestMode: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
01 Feb 2012	cnwkpd1	PAR #28906 - Remove forced close of journal for normal operations
//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal	
//24 Jul 2013	cnwrs1	Par #32087 - stop processing sub classes after an exception
//03 Jul 2014	cnwrs1	Par #34448 - go back to setting the processed up to date time to the date time of the latest object
*/

constants
	VolumeTestPauseSecs = 30;

vars
	transExtractClass : CM_DataDumpTransExtractClass;
	transClass : CM_DataDumpTransSpecClass;
	gotException : Boolean;
	extractClass : CM_DataDumpExtractClass;
	extractClassEdition : Integer;
	latestChangeTs, startClassTs, finishClassTs : TimeStamp;
	extractFromTS, changeTs : TimeStamp;
	ok : Boolean;
	testStr : String;
	numSpecCreated, numSpecUpdated, numSpecDeleted : Integer;
	numClassCreated, numClassUpdated, numClassDeleted : Integer;
	logStr	 : String;
	ls : Boolean;
begin
	if _def = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Definition passed in is null');
		return;
	endif;
	
	if _dataDumpExtractClassSet = null or
	   _dataDumpExtractClassSet.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'DataDump class set passed in is null or empty');
		return;
	endif;
	
	on Exception do self.extractExHandler(exception);
	
	self.lockMutex("Change Tracker extract for selected classes  " &amp; _def.description);

	if _volumeTestMode then
		self.closeCurrentJournalLog;
	endif;
	
	self.extractClassId := null;
		
	self.myExtractDefTerminal := _def.myTerminal;
	self.extractFormat := _def.extractFormat;
	
	self.finaliseExternalDatabaseAgent;
	
	self.extractToDateTime := app.actualTimeServer;
	self.totalCreates := 0;
	self.totalDeletes := 0;
	self.totalUpdates := 0;
	
	delete self.myTransExtractDef;	
	create self.myTransExtractDef transient;

	foreach extractClass in _dataDumpExtractClassSet do
		self.myTransExtractDef.createExtractClass(extractClass, true);
	endforeach;

	foreach transExtractClass in self.myTransExtractDef.allTransExtractClasses do
		gotException := false;
		latestChangeTs := null;
		numClassCreated := 0;
		numClassUpdated := 0;
		numClassDeleted := 0;
		self.deleteOids.clear();
		self.addOids.clear();
		self.updateOids.clear();
		startClassTs := self.extractToDateTime; //app.actualTimeServer;	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
		
		// Obtain edition, as don't want to keep any JADE classes locked
		// while running extract apart from the Data Dump Mutex.
		extractClass := transExtractClass.myDataDumpExtractClass;
		extractClassEdition := app.getLatestObjEdition(extractClass);

		if self.myTransExtractDef.myDataDumpExtractDef.isFormatSQLNative then
			if self.isMatchingClassSQLNative(transExtractClass) = false then
				continue;
			endif;
		else
			if not self.isMatchingClass(transExtractClass) then
				continue;
			endif;
		endif;

		on Exception do self.localExtractClassExHandler(exception, transClass, gotException);

		foreach transClass in transExtractClass.allTransSpecClasses do
			self.purgeSystemAlerts;
			self.extractClassId := transClass.getClassId;
			
			// do deletes first in case a record with the same key as one
			// that has been deleted is then re-added.
			ok := false;
			ok := self.extractClassDeletes(transClass, changeTs, numSpecDeleted);
			// If an exception occurs the exception handler will Resume_Next here without ok being changed
			if ok then
				numClassDeleted := numClassDeleted + numSpecDeleted;

				if changeTs.isValid and 
				   changeTs &gt; latestChangeTs and
					// dont allow the extractuptodatetime get infront of the startdateTime
				   changeTs &lt; startClassTs then //cnwrs1 par ??? sept 2006
					latestChangeTs := changeTs;
				endif;
			else	//24 Jul 2013	cnwrs1	Par #32087 - stop processing sub classes after an exception
				break;
			endif;

			ok := false;
			ok := self.extractClassChanges(transClass, extractFromTS, changeTs, numSpecCreated, numSpecUpdated);
			// If an exception occurs the exception handler will Resume_Next here without ok being changed
			if ok then
				numClassCreated := numClassCreated + numSpecCreated;
				numClassUpdated := numClassUpdated + numSpecUpdated;
				
				if changeTs.isValid and 
				   changeTs &gt; latestChangeTs and
					// dont allow the extractuptodatetime get infront of the startdateTime
				   changeTs &lt; startClassTs then //cnwrs1 par ??? sept 2006
					latestChangeTs := changeTs;
				endif;
			else	//24 Jul 2013	cnwrs1	Par #32087 - stop processing sub classes after an exception
				break;
			endif;
		endforeach;

		on Exception do null;
		
		finishClassTs := app.actualTimeServer;
		
		if gotException then
			self.log("Got exception, so not setting " &amp;
					extractClass.myDataDumpClass.getClassId &amp; " latestChangeTs");

				app.myTrxUA.trxUpdateDataDumpExtrClassCmpt(
						extractClass, extractClassEdition, false,
						extractFromTS, self.extractToDateTime, startClassTs, finishClassTs,	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
						numClassCreated, numClassUpdated, numClassDeleted,
						true, app.getMyUserCode, app.getMyUserName, self.deleteOids, self.addOids, self.updateOids, app.myPassport);
		else
			if latestChangeTs.isValid then
				// Update timestamp for this extract class.
				self.log("Setting " &amp; extractClass.myDataDumpClass.getClassId &amp;
						" latestChangeTs to: " &amp; latestChangeTs.dataDumpFormat);	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
				
				app.myTrxUA.trxUpdateDataDumpExtrClassCmpt(
						extractClass, extractClassEdition, true,
						extractFromTS, latestChangeTs, startClassTs, finishClassTs,	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal Par 34448 go back to latest object dt
						numClassCreated, numClassUpdated, numClassDeleted,
						false, app.getMyUserCode, app.getMyUserName, self.deleteOids, self.addOids, self.updateOids, app.myPassport);
						
				if app.myPassport.trxCompletedOK then
					self.totalCreates := self.totalCreates + numClassCreated;
					self.totalDeletes := self.totalDeletes + numClassDeleted;
					self.totalUpdates := self.totalUpdates + numClassUpdated;
				else
					self.log(app.myPassport.getErrorsAsString);
				endif;
			else
				self.log("Nothing extracted, so not setting " &amp;
						extractClass.myDataDumpClass.getClassId &amp; " latestChangeTs");
			endif;
		endif;
		if self.isXMLFileExtract then
			transClass := transExtractClass.allTransSpecClasses.first;
			self.doWriteFinalXMLString(transClass);
		endif;
	endforeach;
	
	self.statisticsForExtract;
	
epilog
	self.unlockMutex;
	endLoad;
	
end;</source>
        <Parameter name="_dataDumpExtractClassSet" type="CM_DataDumpExtractClassSet"/>
        <Parameter name="_def" type="CM_DataDumpExtractDef"/>
        <Parameter name="_volumeTestMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExtractDataDumpDataFile" id="cecb8e11-3cd4-443d-b7fa-b1b80c80f62c">
        <updating/>
        <source>doExtractDataDumpDataFile(transExtractClass : CM_DataDumpTransExtractClass; 
                          _numCreated : Integer output; _folderPath: String) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2010	conkc1	Initial creation

PAR 24641
*/
constants

vars
	file		    : File;
	oidFile		    : File;
	filePath        : String;
	jadeMethod      : JadeMethod;
	errorCode       : Integer;
	errorPosition   : Integer;
	errorLength	    : Integer;
	errorMsg	    : String;
	methodSource    : String;
	result          : Integer;
	totalDumped     : Integer;
	sequenceNumber  : Integer;
	ok              : Boolean;
	firstTime       : Boolean;
	transClass      : CM_DataDumpTransSpecClass;
	mySelf          : CM_DataDumpExtractionAgent;
	sqlTableName    : String;
begin
	//on Exception do null;
	mySelf      := self;
	
	sqlTableName := transExtractClass.myDataDumpExtractClass.sqlTableName;
	if _folderPath.endsWith("\") then
		filePath := _folderPath &amp; sqlTableName &amp; ".tbl";
	else
		filePath := _folderPath &amp; "\" &amp; sqlTableName &amp; ".tbl";
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;
	file.kind := File.Kind_Binary;

	if (not file.tryOpen) then
		app.msgBox(app.getErrorString1(FileUnavailable, file.fileName),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);
		return false;
	endif;
	
	file.purge();
	
	if app.isSpecial() then
		if _folderPath.endsWith("\") then
			filePath := _folderPath &amp; sqlTableName &amp; ".oid";
		else
			filePath := _folderPath &amp; "\" &amp; sqlTableName &amp; ".oid";
		endif;
			
		//  File contains a sequence number (Row Count as per the .tbl file) and the class number and instance Id
		//  This is required if the Bulk Insert gives an error eg row xxxxx invalid.
		//  The sequence number will match the row number from SQL
		create oidFile transient;
		oidFile.fileName := filePath;
		oidFile.mode := File.Mode_Output;
		//oidFile.kind := File.Kind_ANSI;// 2/3/16  cnwns1 PAR 36286 unicode version
		oidFile.tryOpen();
		oidFile.purge();
	endif;

	self.log("Starting Actual Bulk Extract");

	firstTime := true;
	foreach transClass in transExtractClass.allTransSpecClasses do
		ok := self.buildTransientBulkDataDump(transClass, methodSource);
		jadeMethod  := process.createTransientMethod(BulkData_MethodName, CM_DataDumpExtractionAgent, currentSchema , methodSource, false, null, errorCode, errorPosition, errorLength);
		if errorCode &lt;&gt; 0 then
			app.msgBox(app.getErrorString2(ERR_BulkDataLoadFail, errorCode.String, process.getErrorText(errorCode)),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
			app.raiseCMException2(ERR_BulkDataLoadFail, errorCode.String, process.getErrorText(errorCode), null, null);
			return false;
		endif;
		//
		//  For diagnostic purposes we store the first generate Jade Source in the database
		//
		if firstTime = true then
			beginTransaction;
			transClass.myExtractClass.setJadeBulkDataExtractSource(methodSource);
			commitTransaction;
			firstTime := false;
		endif;

		result := process.executeTransientIOMethod(jadeMethod, mySelf, file, oidFile, sequenceNumber).Integer;
		if result = -1 then
			app.msgBox(app.getErrorString(ERR_BulkDataExeFailed),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
			app.raiseCMException(ERR_BulkDataExeFailed, null, null);
			return false;
		else
			totalDumped := totalDumped + result;
		endif;
	endforeach;

	return true;

epilog
	_numCreated := totalDumped;
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;

	if oidFile &lt;&gt; null then
		oidFile.close;
		delete oidFile;
	endif;
end;</source>
        <Parameter name="transExtractClass" type="CM_DataDumpTransExtractClass"/>
        <Parameter name="_numCreated" type="Integer" usage="output"/>
        <Parameter name="_folderPath" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExtractDataDumpFormatFile" id="c71dc082-70e4-41c0-bc40-a6e67597924b">
        <updating/>
        <source>doExtractDataDumpFormatFile(_sqlTable : CM_DataDumpExtractClass; _version : String; _folderPath: String) : Boolean updating;
/*

Purpose:			Creates a Format File for each extract class
					Format
					Line 1 - version
					Line 2 - number of columns in SQL Table
					Line 3 - end Format definition
					&lt;seq num&gt; Tab SQLCHAR Tab &lt;prefix length&gt; Tab &lt;host length&gt; Tab &lt;data terminator&gt; Tab &lt;SQL Column order&gt; Tab &lt;name&gt; Tab ""

Parameters:			Extract Class (SQL Table) Name, 
					SQL Version 
						9.0  SQL Server 2005 
						10.0 SQL Server 2008

Return Value:		

Date			Who		Reason
28 May 2010		conkc1	Initial creation

PAR 24641
*/
vars
	extractDef          : CM_DataDumpExtractDef;
	sqlTable            : CM_DataDumpExtractClass;
	sqlColumn           : CM_DataDumpSQLColumn;
	tsqlColumn          : CM_DataDumpSQLColumn;
	sqlDataType         : CM_DataDumpSQLDataType;
	columnPosDict       : CM_SQLColumnByOrdinalPosDict;
	sqlColumnArray      : CM_ObjectArray;

	prefixLength        : String;
	dataLength          : String;
	terminator          : String;
	columnCount         : Integer;
	dictSize            : Integer;
	file				: File;
	sqlType			    : String;
	filePath            : String;
begin
	create columnPosDict transient;
	create sqlColumnArray transient;

	extractDef := _sqlTable.myDataDumpExtractDef;
	sqlTable := _sqlTable;

	if not addOptionalColumnsToCol(sqlTable, columnPosDict, sqlColumnArray) then
		return false;
	endif;

	foreach sqlColumn in sqlTable.allDataDumpSQLColumns do
		tsqlColumn := columnPosDict[sqlColumn.sqlColumnOrdinalPosition];

		if sqlColumn.sqlColumnOrdinalPosition = 0 then
		   app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, sqlColumn.name),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		   app.raiseCMException1(ERR_BulkLoadNullColumnPos, sqlColumn.name, null, null);
		   return false;
		endif;

		if tsqlColumn = null then
			columnPosDict.add(sqlColumn);
		else
			app.msgBox(app.getErrorString2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
			app.raiseCMException2(ERR_BulkLoadSQLColumn, sqlColumn.name, sqlColumn.sqlColumnOrdinalPosition.String, null, null);
			return false;
		endif;
	endforeach;
		
	dictSize  := columnPosDict.size;
	if _folderPath.endsWith("\") then
		filePath := _folderPath &amp; sqlTable.sqlTableName &amp; ".fmt";
	else
		filePath := _folderPath &amp; "\" &amp; sqlTable.sqlTableName &amp; ".fmt";
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;

	if (not file.tryOpen) then
		app.msgBox(app.getErrorString1(FileUnavailable, file.fileName),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);
		return false;
	endif;
	
	file.purge();
	file.writeLine(_version);
	file.writeLine(dictSize.String);
	dataLength := "0";
	foreach sqlColumn in columnPosDict do
		sqlType := "SQLCHAR";
		columnCount := columnCount + 1;
		if columnCount = dictSize then
			terminator := '"\r\n"';
		else
			terminator := '"\t"';
		endif;
		
		if sqlColumn.myDataDumpSQLDataType &lt;&gt; null and sqlColumn.myDataDumpSQLDataType.name.toUpper() = CM_DataDumpSQLDataType.SQLDecimal then
			prefixLength := "0";
		elseif sqlColumn.isMaximumLength = true then
			prefixLength := "4";
		elseif sqlColumn.length = 0 then
			prefixLength := "0";
		elseif sqlColumn.length &lt;= Max_Integer then
			prefixLength := "4";
		else
			prefixLength := "8";
		endif;
		
		if sqlColumn.name = extractDef.oidColumnName then
			if extractDef.oidFormat = extractDef.OIDFormatHex then
				sqlType := "SQLBINARY";
			endif;
		endif;

		if sqlColumn.myDataDumpSQLDataType &lt;&gt; null and sqlColumn.myDataDumpSQLDataType.name.toUpper() = CM_DataDumpSQLDataType.SQLBinary then
			sqlType := "SQLBINARY";
		endif;
		
		file.writeLine(columnCount.String &amp; Tab &amp; sqlType &amp; Tab &amp; prefixLength &amp; Tab &amp; dataLength &amp; Tab &amp;
						terminator &amp; Tab &amp; sqlColumn.sqlColumnOrdinalPosition.String &amp; Tab &amp; sqlColumn.name &amp; Tab &amp; '""');
	endforeach;

	return true;

epilog

	delete columnPosDict;
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
	sqlColumnArray.purge;
	delete sqlColumnArray;	
end;</source>
        <Parameter name="_sqlTable" type="CM_DataDumpExtractClass"/>
        <Parameter name="_version" type="String"/>
        <Parameter name="_folderPath" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExtractDefinitonAll" id="78b716d0-7c40-4299-83ac-f844f3e3628b">
        <updating/>
        <source>doExtractDefinitonAll(_definitionName: String) updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
//
// Purpose:		Extracts all objects in definition classes, without using
//				the Change Tracker peer schema.  This is useful when
//				first populating a database.
//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
// 17/03/2015	cnmh5	Tranisent Leaks
// ---------------------------------------------------------------------------
vars
	transExtractClass : CM_DataDumpTransExtractClass;
	transClass : CM_DataDumpTransSpecClass;
	gotException : Boolean;
	extractCls,
	extractClass : CM_DataDumpExtractClass;
	extractClassEdition : Integer;
	ok : Boolean;
	version : String;
	extractFromTS, runTs, startClassTs, finishClassTs : TimeStamp;
	numSpecCreated, numSpecUpdated : Integer;
	numClassCreated, numClassUpdated : Integer;
	methodSource   : String;

	folderPath       : String;
	fileFolder     : FileFolder;
begin
	on Exception do self.extractExHandler(exception);
	on LockException do app.cnGlobalLockExceptionHandler(exception);//21/02/2011 cnwdz2 26892
	
	self.lockMutex("All objects in class extract" &amp; self.getSingleAliasDesc);

	self.setExtractDef(_definitionName, self.selectingAllClasses, null);
	runTs := app.actualTimeServer;
	extractFromTS := null;
	if self.myTransExtractDef.myDataDumpExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2005 then
		version := CM_DataDumpExtractDef.SQLBulkDataLoad_Version2005;
	else
		version := CM_DataDumpExtractDef.SQLBulkDataLoad_Version2008;
	endif;

	foreach transExtractClass in self.myTransExtractDef.allTransExtractClasses do
		gotException := false;
		startClassTs := self.extractToDateTime; //11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
		numClassCreated := 0;
		numClassUpdated := 0;
		self.deleteOids.clear();
		self.addOids.clear();
		self.updateOids.clear();

		// Obtain edition, as don't want to keep any JADE classes locked
		// while running extract apart from the Data Dump Mutex.
		extractClass := transExtractClass.myDataDumpExtractClass;
		extractClassEdition := app.getLatestObjEdition(extractClass);

		if self.myTransExtractDef.myDataDumpExtractDef.isFormatSQLNative then
			if self.isMatchingClassSQLNative(transExtractClass) = false then
				continue;
			endif;
		else
			if not self.isMatchingClass(transExtractClass) then
				continue;
			endif;
		endif;

		if self.DebugTracingToObjectLevel then
			self.log(class.name&amp;"::"&amp;method.name&amp;" transExtractClass="&amp;transExtractClass.myDataDumpExtractClass.className);		
		endif;
		if self.myExternalDatabaseAgent &lt;&gt; null then
			self.myExternalDatabaseAgent.closeSQLStatementFile(true);
		endif;
		// if we have never run before enter load mode
		if extractClass.extractedUpToDateTime = null then
			self.setLoadMode(true);
		else
			self.setLoadMode(false);
		endif;
		
		on Exception do self.localExtractClassExHandler(exception, transClass, gotException);
		//
		//  Check for Bulk data unload
		//
		if isBulkDataExtract = true then
			extractCls := transExtractClass.allTransSpecClasses[1].myExtractClass;
			folderPath := extractCls.myDataDumpExtractDef.fileFolderName;
	    
			if folderPath = null then
				create fileFolder;
				folderPath := fileFolder.browseForFolder(app.getErrorString(BrowseBulkDataLoadFolderCap),null);
				delete fileFolder;
			endif;
			app.mousePointer := Busy;
	
			if folderPath = null then
				//app.msgBox(app.getErrorString1(FolderUnavailable, folderPath),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
				//app.raiseCMException1(FolderUnavailable, folderPath, null, null);
				return;
			else
				if self.doExtractDataDumpFormatFile(extractCls, version, folderPath) then	
					ok := self.doExtractDataDumpDataFile(transExtractClass, numSpecCreated, folderPath);
					if ok = true then
						numClassCreated     := numClassCreated + numSpecCreated;
						extractClassEdition := extractClassEdition + 1;  // this will have been bumped as we stored the Jade Source
					endif;
				endif;
			endif;	
		else
			foreach transClass in transExtractClass.allTransSpecClasses do
				if self.DebugTracingToObjectLevel then
					self.log(class.name&amp;"::"&amp;method.name&amp;" transClass="&amp;transClass.myClass.name);		
				endif;
				self.purgeSystemAlerts;
				self.extractClassId := transClass.getClassId;
				ok := self.extractClassAllObjects(transClass, numSpecCreated, numSpecUpdated);
	
				// If an exception occurs the exception handler will Resume_Next here
				if ok then
					numClassCreated := numClassCreated + numSpecCreated;
					numClassUpdated := numClassUpdated + numSpecUpdated;
				endif;
			endforeach;
		endif;

		on Exception do null;
		
		finishClassTs := app.actualTimeServer;
		
		if gotException then
			self.log("Got exception, so not setting " &amp;
					extractClass.myDataDumpClass.getClassId &amp; " latestChangeTs");

			app.myTrxUA.trxUpdateDataDumpExtrClassCmpt(
					extractClass, extractClassEdition, false,
					extractFromTS, self.extractToDateTime, startClassTs, finishClassTs, numClassCreated, numClassUpdated, 0,	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
					true, app.getMyUserCode, app.getMyUserName, self.deleteOids, self.addOids, self.updateOids, app.myPassport);
			if self.isSQLNative then
				break;
			endif;
		else
			// Update timestamp for this extract class.
			self.log("Setting " &amp; extractClass.myDataDumpClass.getClassId &amp;
					" latestChangeTs to: " &amp; self.extractToDateTime.dataDumpFormat);	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
			
			app.myTrxUA.trxUpdateDataDumpExtrClassCmpt(
					extractClass, extractClassEdition, true,
					extractFromTS, self.extractToDateTime, startClassTs, finishClassTs, numClassCreated, numClassUpdated, 0,	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
					false, app.getMyUserCode, app.getMyUserName, deleteOids, addOids, updateOids, app.myPassport);
					
			if app.myPassport.trxCompletedOK then
				self.totalCreates := self.totalCreates + numClassCreated;
				self.totalUpdates := self.totalUpdates + numClassUpdated;
			else
				self.raiseAlert(app.myPassport.getErrorsAsString);
			endif;
		endif;
		if self.isXMLFileExtract then
			transClass := transExtractClass.allTransSpecClasses.first;
			self.doWriteFinalXMLString(transClass);
		endif;
	endforeach;

	self.statisticsForExtract;
	
epilog
	if fileFolder &lt;&gt; null then
		delete fileFolder;
	endif;
	self.unlockMutex;
	app.mousePointer := Idle;
end;</source>
        <Parameter name="_definitionName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doExtractDefinitonChanges" id="74568403-4513-4c54-ac3f-2a4a656aa276">
        <updating/>
        <source>doExtractDefinitonChanges(_definitionName: String; _volumeTestMode: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
//
// Purpose:		Extracts all changes and deletes for the real sub-classes
//				of the given extract definition.  Uses the timestamp stored
//				on the extract definition classes to determine which objects
//				to dump (via the change tracker peer schema).
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Feb 2012	cnwkpd1	PAR #28906 - Remove forced close of journal for normal operations
//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal	
//24 Jul 2013	cnwrs1	Par #32087 - stop processing sub classes after an exception
//03 Jul 2014	cnwrs1	Par #34448 - go back to setting the processed up to date time to the date time of the latest object
//09 Dec 2015	cnwrs1	Par37170 - SQL Native not recovering from SQL shutdown
*/

constants
	VolumeTestPauseSecs = 30;

vars
	transExtractClass : CM_DataDumpTransExtractClass;
	transClass : CM_DataDumpTransSpecClass;
	gotException : Boolean;
	extractClass : CM_DataDumpExtractClass;
	extractClassEdition : Integer;
	latestChangeTs, startClassTs, finishClassTs : TimeStamp;
	extractFromTS, changeTs : TimeStamp;
	ok : Boolean;
	testStr : String;
	numSpecCreated, numSpecUpdated, numSpecDeleted : Integer;
	numClassCreated, numClassUpdated, numClassDeleted : Integer;
	
begin
	on Exception do self.extractExHandler(exception);
	on LockException do app.cnGlobalLockExceptionHandler(exception);//21/02/2011 cnwdz2 26892
	
	self.lockMutex("Change Tracker extract" &amp; self.getSingleAliasDesc);

	if _volumeTestMode then
		self.closeCurrentJournalLog;
	endif;
	
	self.setExtractDef(_definitionName, self.selectingAllClasses, null);
	
	if _volumeTestMode and not self.selectingAllClasses then
		// Pause to allow change tracker to catch up when volume testing.
		// When selecting all classes this is not needed, because the caching
		// process takes approx 7-8 minutes anyway (ie. no need for an
		// additional 30 second pause).
		self.log("Pausing " &amp; VolumeTestPauseSecs.String &amp;
				" seconds for Change Tracker to catch up");
		app.sendHeartbeatIfRequired();								//JIRA 23326
		process.sleep(VolumeTestPauseSecs * MillisecondsPerSecond);
		app.sendHeartbeatIfRequired();								//JIRA 23326
	endif;
	
	foreach transExtractClass in self.myTransExtractDef.allTransExtractClasses do
		app.sendHeartbeatIfRequired();		// 30/8/17 MAP TFS5551
		gotException := false;
		latestChangeTs := null;
		numClassCreated := 0;
		numClassUpdated := 0;
		numClassDeleted := 0;
		self.deleteOids.clear();
		self.addOids.clear();
		self.updateOids.clear();
		startClassTs := self.extractToDateTime; //app.actualTimeServer;	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
		
		// Obtain edition, as don't want to keep any JADE classes locked
		// while running extract apart from the Data Dump Mutex.
		extractClass := transExtractClass.myDataDumpExtractClass;
		extractClassEdition := app.getLatestObjEdition(extractClass);

		if self.myTransExtractDef.myDataDumpExtractDef.isFormatSQLNative then
			if self.isMatchingClassSQLNative(transExtractClass) = false then
				continue;
			endif;
		else
			if not self.isMatchingClass(transExtractClass) then
				continue;
			endif;
		endif;
		
		on Exception do self.localExtractClassExHandler(exception, transClass, gotException);

		foreach transClass in transExtractClass.allTransSpecClasses do
			self.purgeSystemAlerts;
			self.extractClassId := transClass.getClassId;
			
			// do deletes first in case a record with the same key as one
			// that has been deleted is then re-added.
			ok := false;
			ok := self.extractClassDeletes(transClass, changeTs, numSpecDeleted);
			// If an exception occurs the exception handler will Resume_Next here
			if ok then
				numClassDeleted := numClassDeleted + numSpecDeleted;

				if changeTs.isValid and changeTs &gt; latestChangeTs then
					latestChangeTs := changeTs;
				endif;
			else	//24 Jul 2013	cnwrs1	Par #32087 - stop processing sub classes after an exception without ok being changed
				break;
			endif;

			ok := false;
			ok := self.extractClassChanges(transClass, extractFromTS, changeTs, numSpecCreated, numSpecUpdated);
			// If an exception occurs the exception handler will Resume_Next here
			if ok then
				numClassCreated := numClassCreated + numSpecCreated;
				numClassUpdated := numClassUpdated + numSpecUpdated;
				
				if changeTs.isValid and changeTs &gt; latestChangeTs then
					latestChangeTs := changeTs;
				endif;
			else	//24 Jul 2013	cnwrs1	Par #32087 - stop processing sub classes after an exception without ok being changed
				break;
			endif;
		endforeach;

		on Exception do null;
		
		finishClassTs := app.actualTimeServer;
		
		if gotException then
			self.log("Got exception, so not setting " &amp;
					extractClass.myDataDumpClass.getClassId &amp; " latestChangeTs");

				app.myTrxUA.trxUpdateDataDumpExtrClassCmpt(
						extractClass, extractClassEdition, false,
						extractFromTS, self.extractToDateTime, startClassTs, finishClassTs,	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
						numClassCreated, numClassUpdated, numClassDeleted,
						true, app.getMyUserCode, app.getMyUserName, self.deleteOids, self.addOids, self.updateOids, app.myPassport);
		else
			if latestChangeTs.isValid then
				// Update timestamp for this extract class.
				self.log("Setting " &amp; extractClass.myDataDumpClass.getClassId &amp;
						" latestChangeTs to: " &amp; latestChangeTs.dataDumpFormat);	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
				
				app.myTrxUA.trxUpdateDataDumpExtrClassCmpt(
						extractClass, extractClassEdition, true,
						extractFromTS, latestChangeTs, startClassTs, finishClassTs,	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
						numClassCreated, numClassUpdated, numClassDeleted,
						false, app.getMyUserCode, app.getMyUserName, deleteOids, addOids, updateOids, app.myPassport);
						
				if app.myPassport.trxCompletedOK then
					self.totalCreates := self.totalCreates + numClassCreated;
					self.totalDeletes := self.totalDeletes + numClassDeleted;
					self.totalUpdates := self.totalUpdates + numClassUpdated;
				else
					self.log(app.myPassport.getErrorsAsString);
				endif;
			else
				self.log("Nothing extracted, so not setting " &amp;
						extractClass.myDataDumpClass.getClassId &amp; " latestChangeTs");
			endif;
		endif;
		if self.isXMLFileExtract then
			transClass := transExtractClass.allTransSpecClasses.first;
			self.doWriteFinalXMLString(transClass);
		endif;
	endforeach;
	
	self.statisticsForExtract;
	
epilog
	self.finalise();
	self.unlockMutex;
end;</source>
        <Parameter name="_definitionName" type="String"/>
        <Parameter name="_volumeTestMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExtractSelectedObjsXML" id="31fc0e91-40a5-4b37-98d5-f4be65a5dc4c">
        <updating/>
        <source>doExtractSelectedObjsXML( _definitionName: String; _oba : ObjectArray )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2019	jlgndl1	Initial creation	TFS 43873  Allow for XML extract
 								of user selected objects in Data Export Maint
08 Nov  2019    cnwma1	Bug 47420: STWO - Data Export Maintenance(Ticket 43854)
*/

vars

	obj : Object;
	logStr : String;
	isInitialisedWithFeatures : Boolean;
	inTrxStateException : Boolean;
	extractClass : CM_DataDumpExtractClass;
	transClass : CM_DataDumpTransSpecClass;
	ok : Boolean;
	class : Class;
	transExtractClass : CM_DataDumpTransExtractClass;
	foundTransClass : Boolean;
	created, updated : Boolean;
	filterByTerminal : Boolean;
	sqlStatement : String;

begin

	self.myExtractDef := app.myRoot.allDataDumpExtractDefs[_definitionName];
	self.myExtractDefTerminal := self.myExtractDef.myTerminal;
	self.extractFormat := self.myExtractDef.extractFormat;
	self.extractToDateTime := app.actualTimeAppServer;
	
	create self.myTransExtractDef transient;

	foreach extractClass in self.myExtractDef.allDataDumpExtractClasses do
		self.myTransExtractDef.createExtractClass(extractClass, true);
	endforeach;

	if not self.isXMLFileExtract then
		self.log("  " &amp; self.myExtractDef.description &amp; " is Not an XML format");
		return;
	endif;
	
	if _oba = null or _oba.isEmpty then
		self.log("  No selected objects.");
		return;
	endif;
	
	self.log("  Processing " &amp; _oba.size.String &amp; " objects.");
	
	class := _oba.first.class; 
	foreach transExtractClass in self.myTransExtractDef.allTransExtractClasses do
		if foundTransClass then
			break;
		endif;
	/*	if transExtractClass.myDataDumpClass.myClass.name = class.name then  // 08.11.2019 cnwma1 #47420
			foreach transClass in transExtractClass.allTransSpecClasses do
				if transClass.myClass.name = class.name then                 // 08.11.2019 cnwma1 #47420
					foundTransClass := true;
					break;
				endif;
			endforeach;
		endif; */
		//23 Aug 2021	NDL	TFS 51350
		if transExtractClass.myDataDumpClass.myClass = class or class.inheritsFrom( transExtractClass.myDataDumpClass.myClass ) then  
			foreach transClass in transExtractClass.allTransSpecClasses do
				if transClass.myClass = class then                
					foundTransClass := true;
					break;
				endif;
			endforeach;
		endif;
	endforeach;

	if not foundTransClass then
		return;
	endif;
		
	foreach obj in _oba do
		if not isInitialisedWithFeatures then
			isInitialisedWithFeatures := true;
			
			self.fileOpen(self.getXMLFilename( transClass, self.ActionChange), false);
		endif;

		self.writeChangeObj( transClass, obj, obj.creationTime,
				created, updated, filterByTerminal, 
				sqlStatement, JSSCTSelectionObject.ACTION_CREATE);
				
	endforeach;
	
	self.myFile.writeString("&lt;/file&gt;");
	
epilog

	self.fileClose;
	
end;</source>
        <Parameter name="_definitionName" type="String"/>
        <Parameter name="_oba" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doExtractTestSingleObj" id="14981eb4-f8bc-4b2a-9a3d-55012f095a5f">
        <updating/>
        <source>doExtractTestSingleObj(_definitionName: String; _overrideExtractFormat: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
//
// Purpose:		The test extract selects one object (the lastInstance)
//				of each class in the definition, and extracts it in the
//				same way as the full extract.  Doesn't test Deletes.
// ---------------------------------------------------------------------------
vars
	transExtractClass : CM_DataDumpTransExtractClass;
	transClass : CM_DataDumpTransSpecClass;
	gotException : Boolean;

begin
	on Exception do self.extractExHandler(exception);
	
	self.lockMutex("Test extract of one object per class" &amp; self.getSingleAliasDesc);
	
	self.setExtractDef(_definitionName, self.selectingAllClasses,
			_overrideExtractFormat);
	
	foreach transExtractClass in self.myTransExtractDef.allTransExtractClasses do
		if not self.isMatchingClass(transExtractClass) then
			continue;
		endif;

		on Exception do self.localExtractClassExHandler(exception, transClass, gotException);

		foreach transClass in transExtractClass.allTransSpecClasses do
			self.purgeSystemAlerts;
			self.extractClassId := transClass.getClassId;
			
			self.extractClassChangesTest(transClass);
			// If an exception occurs the exception handler will Resume_Next here
		endforeach;

		on Exception do null;
	endforeach;
	
epilog
	self.unlockMutex;
end;</source>
        <Parameter name="_definitionName" type="String"/>
        <Parameter name="_overrideExtractFormat" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doExtractTestSingleObject" id="2a740f43-ab10-42d5-a1db-59357a8c2021">
        <updating/>
        <source>doExtractTestSingleObject(_definitionName: String; _overrideExtractFormat: Integer; _obj : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     August 2006
//
// Purpose:		The test extract selects one object (parameter)
//				of each class in the definition, and extracts it in the
//				same way as the full extract.  Doesn't test Deletes.
// ---------------------------------------------------------------------------
vars
	transExtractClass : CM_DataDumpTransExtractClass;
	transClass : CM_DataDumpTransSpecClass;
	gotException : Boolean;

begin
	on Exception do self.extractExHandler(exception);
	
	self.lockMutex("Test extract of one object" &amp; self.getSingleAliasDesc);
	
	self.setExtractDef(_definitionName, self.selectingAllClasses,
			_overrideExtractFormat);

	foreach transExtractClass in self.myTransExtractDef.allTransExtractClasses do
		if not self.isMatchingClass(transExtractClass) then
			continue;
		endif;
		foreach transClass in transExtractClass.allTransSpecClasses do
			self.extractClassId := transClass.getClassId();
			if transClass.myClass = _obj.class then
				self.extractClassId := transClass.getClassId();
				break;
			endif;
		endforeach;
	endforeach;
	if self.extractClassId = null then
		return;
	endif;

	on Exception do self.localExtractClassExHandler(exception, transClass, gotException);
	self.purgeSystemAlerts();
			
	self.extractClassChangesSingle(transClass, _obj);
	// If an exception occurs the exception handler will Resume_Next here

	on Exception do null;
	
epilog
	self.unlockMutex;
end;</source>
        <Parameter name="_definitionName" type="String"/>
        <Parameter name="_overrideExtractFormat" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doExtractTestVolume" id="a61ee602-d864-42f2-a1a1-7b062d012b98">
        <updating/>
        <source>doExtractTestVolume(_definitionName: String; _overrideExtractFormat: Integer;
		_setExtractedUpTo: TimeStamp; _maxPerClass: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
//
// Purpose:		Allows for a volume test extract.  Updates the last _maxPerClass
//				objects in each relevant class, then extracts them.
//				NB: Must be running Change Tracker app at same time in order
//				for this to work.
// ---------------------------------------------------------------------------
vars
	transExtractClass : CM_DataDumpTransExtractClass;
	transClass : CM_DataDumpTransSpecClass;
	defEdition : Integer;

begin
	on Exception do self.extractExHandler(exception);
	
	self.lockMutex("Volume Test extract of " &amp; _maxPerClass.String &amp; " per class" &amp;
			self.getSingleAliasDesc);
	
	// initialiseAllClassesOnCreate must be false here.  setExtractDef is
	// called again later in doExtract(), and the initialisation is done then.
	self.setExtractDef(_definitionName, false, _overrideExtractFormat);

	if _setExtractedUpTo.isValid then
		// Set extract timestamp - so that we only extract the instances
		// that are about to have their editions updated.  Set to one minute before
		// selected, so the change tracker has enough time to catch up.
		defEdition := app.getLatestObjEdition(self.myExtractDef);
		self.log("Setting " &amp; _definitionName &amp; " extractedUpTo: " &amp;
				_setExtractedUpTo.dataDumpFormat);
		app.myTrxUA.trxUpdateDataDumpExtrDefTs(self.myExtractDef,
				defEdition, _setExtractedUpTo, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			self.raiseAlert(app.myPassport.getErrorsAsString);
		endif;
	endif;
	
	foreach transExtractClass in self.myTransExtractDef.allTransExtractClasses do
		if not self.isMatchingClass(transExtractClass) then
			continue;
		endif;

		foreach transClass in transExtractClass.allTransSpecClasses do
			self.purgeSystemAlerts;
			self.extractClassId := transClass.getClassId;
			
			self.doExtractTestVolumeUpdateClass(transClass, _maxPerClass);
		endforeach;
	endforeach;
	
	self.doExtractDefinitonChanges(_definitionName, true);
	
epilog
	self.unlockMutex;
end;</source>
        <Parameter name="_definitionName" type="String"/>
        <Parameter name="_overrideExtractFormat" type="Integer"/>
        <Parameter name="_setExtractedUpTo" type="TimeStamp"/>
        <Parameter name="_maxPerClass" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doExtractTestVolumeUpdateClass" id="1ed8fce0-bda1-41c7-9b38-a9beb844b411">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>doExtractTestVolumeUpdateClass(_transClass : CM_DataDumpTransSpecClass; _maxPerClass: Integer) updating, protected, serverExecution;
// ---------------------------------------------------------------------------
// Created:     24 July 2003 by cnwsb1
//
// Performance:	serverExecution to avoid pulling the objects over the LAN.
// ---------------------------------------------------------------------------
// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition

vars
	cnt : Integer;
	oba : ObjectArray;
	obj : Object;
	cls : Class;
	
begin
	on Exception do self.extractExHandler(exception);
	
	// Not using a trx as this method is for development testing purposes only.
	beginTransaction;

	cls := _transClass.myClass;
	create oba transient;
	
	cls.allInstances(oba, 0, false);

	foreach obj in oba reversed do
		obj.updateObjectEdition (obj);	// par 30292
		cnt := cnt + 1;
		if cnt &gt;= _maxPerClass then
			break;
		endif;
	endforeach;
	
	commitTransaction;

epilog
	self.log("Updated " &amp; cnt.String &amp; " " &amp; _transClass.getClassId &amp; " instances");
	delete oba;
end;</source>
        <access>protected</access>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_maxPerClass" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doProcessOdbcErrorAlert" id="154d795e-c531-4cb2-b015-75b3e7684ca5">
        <updating/>
        <source>doProcessOdbcErrorAlert( _exc: Exception ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation Par 33362

*/

vars

	errString : String;

begin

	errString := "Error Code: " &amp; _exc.errorCode.String &amp; " Extended Error Text: " &amp; _exc.extendedErrorText;
	
	self.log( errString &amp; CrLf &amp; "Method Desc: " &amp; _exc.currentMethodDesc.display );
	self.createSQLNativeAlert(method.qualifiedName &amp; " " &amp; errString);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
    </JadeMethod>
    <JadeMethod name="doWriteFinalXMLString" id="cbfc032d-9685-46d7-aed9-d1e067b118ff">
        <updating/>
        <source>doWriteFinalXMLString(transClass : CM_DataDumpTransSpecClass) updating, protected;
/*

Purpose:			To write the final XML tag &lt;/file&gt;
					Handles both change and delete files

Parameters:			transClass for file

Return Value:		


Date		Who		Reason
29 May 2009	conkc1	Initial creation

*/

vars

begin
	if transClass &lt;&gt; null then
		self.fileOpen(self.getXMLFilename(transClass, self.ActionChange), true);
	endif;

	if transClass &lt;&gt; null then
		self.fileOpen(self.getXMLFilename(transClass, self.ActionDelete), true);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="transClass" type="CM_DataDumpTransSpecClass"/>
    </JadeMethod>
    <JadeMethod name="extractClassAllObjects" id="d0fcd79a-9482-409a-97ab-be9297688f9b">
        <updating/>
        <source>extractClassAllObjects(_transClass : CM_DataDumpTransSpecClass input;
		_numCreated, _numUpdated: Integer output) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	cls : Class;
	classStr : String;
	logStr : String;
	gotException : Boolean;
	isInitialisedWithFeatures : Boolean;
	exceptionStr : String;
	ok : Boolean;
	successStr : String;
	oba : ObjectArray;
	obj : Object;
	created, updated : Boolean;
	filterByTerminal : Boolean;
	sqlStatement: String;
	inTrxStateException : Boolean;
	numberOfRecordsToExtracted : Integer; // AKB
begin
	cls := _transClass.myClass;
	classStr := _transClass.getClassId;
	filterByTerminal := self.isTerminalFilteredClass(_transClass);
	
	self.log("Selecting " &amp; classStr &amp; " changes" &amp; CrLf &amp;
		"  from : " &amp; _transClass.getExtractFromDateTime.dataDumpFormat &amp; CrLf &amp;
		"  to   : " &amp; self.extractToDateTime.dataDumpFormat);

	self.myChangeTrackingInterface.selectClassChanges(cls.name,
			_transClass.getExtractFromDateTime, self.extractToDateTime,//);
			self.getIgnoreDeleteUserCode);	//07 Jan 2014	NDL	Par 33264
			
	// The object being extracted, or any one of the references
	// on the object, can be invalid.  In this case we want to log
	// the invalid object and move on, rather than abandoning the
	// entire class.
	on Exception do self.localInvalidObjExHandler(
			exception, obj, exceptionStr, gotException);
			
	create oba transient;
	cls.allInstances(oba, 0, false);
	self.log("  Processing "&amp;oba.size.String&amp;" objects.");

	foreach obj in oba do
		if not isInitialisedWithFeatures then
			// Delayed initialisation of the Features list
			isInitialisedWithFeatures := true;
			
			//24 Jan 2013	NDL	Par 31070
			on Exception do self.localExtDbaseInTransHandler( exception, inTrxStateException );
			
			if self.isExternalDatabaseExtract then
				// Delayed begin to the external transaction, as there
				// is no point starting one if there are no changes to
				// extract for this class.
				logStr := logStr &amp; CrLf &amp; "Begin external transaction";
				self.myExternalDatabaseAgent.beginTrans;
			elseif self.isXMLFileExtract then
				self.fileOpen(self.getXMLFilename(_transClass, self.ActionChange), false);
			elseif self.isSQLNative then
				logStr := logStr &amp; CrLf &amp; "SQL Native Begin external transaction";
				self.myExternalDatabaseAgent.beginTrans;			
			else
				app.raiseCMException1(DataDumpInvalidFormat, self.extractFormat.String, null, null);
			endif;
	
			//24 Jan 2013	NDL	Par 31070
			if inTrxStateException then
				ok := false;
				return ok;
			else
				on Exception do null;
			endif;
	
			logStr := logStr &amp; CrLf &amp;
					"New class initialisation" &amp; CrLf &amp;
					"  start : " &amp; app.actualTimeServer.Time.dataDumpFormat;
			_transClass.initialiseWithFeatures;
			logStr := logStr &amp; CrLf &amp;
					"  end   : " &amp; app.actualTimeServer.Time.dataDumpFormat;
			self.log(classStr &amp; logStr);
			logStr := null;
		endif;

		gotException := false;
		self.writeChangeObj(_transClass, obj, obj.creationTime,
				created, updated, filterByTerminal, 
				sqlStatement, JSSCTSelectionObject.ACTION_CREATE);
		
		if gotException then			
			// Attempted to extract an Invalid object.  We assume the object has been
			// deleted, and will be extracted in the Class Deletes.
			logStr := logStr &amp; CrLf &amp; exceptionStr;
			if self.isSQLNative then
				self.myExternalDatabaseAgent.abortTrans("SQL Native");				
				ok := false;
				return ok;
			endif;
		else
			if created then
				_numCreated := _numCreated + 1;
				self.addOids.add(obj.getOidString());
			elseif updated then
				_numUpdated := _numUpdated + 1;
				self.updateOids.add(obj.getOidString());
			endif;
			//
			// Commit if required
			//
			if self.isSQLNative then
				if (self.myExternalDatabaseAgent.transNumCreates + self.myExternalDatabaseAgent.transNumUpdates) mod self.myExternalDatabaseAgent.MaxPerExternalTransaction = 0 then
					self.myExternalDatabaseAgent.commitTrans("SQL Native");
					self.myExternalDatabaseAgent.beginTrans;
				endif;
			endif;
			if sqlStatement &lt;&gt; null then
				self.myExternalDatabaseAgent.writeSQLStatementToFile(sqlStatement, _transClass.getClassAlias);
			endif;
			
			// ### For Testing ###
			if self.numberOfRecordsToExtract &gt; 0 then
				numberOfRecordsToExtracted := numberOfRecordsToExtracted + 1;
				if numberOfRecordsToExtracted &gt;= self.numberOfRecordsToExtract	then
					write classStr &amp; " " &amp; numberOfRecordsToExtract.String &amp; " Extracted";
					break;
				endif;
			endif;
		endif;
	endforeach;
	
	on Exception do null;
		
	if self.isExternalDatabaseExtract and
			isInitialisedWithFeatures then
		logStr := logStr &amp; CrLf &amp; "Commit external transaction";
		self.myExternalDatabaseAgent.commitTrans("EDB");
	elseif self.isSQLNative and
			isInitialisedWithFeatures then
		self.myExternalDatabaseAgent.commitTrans("SQL Native");
	endif;

	ok := true;
	return ok;
	
epilog
	if ok then
		successStr := "extracted";
	else
		successStr := "abandoned";
		//29/06/2010 cnwdz2 24830
		if self.isSQLNative then
			self.myExternalDatabaseAgent.abortTrans("SQL Native");
		endif;
	endif;
	self.log(classStr &amp; logStr &amp; CrLf &amp;
			"Changes " &amp; successStr &amp; ".  Creates " &amp; _numCreated.String &amp;
			", Updates " &amp; _numUpdated.String);
	self.fileClose;
	delete oba;
end;</source>
        <access>protected</access>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass" usage="input"/>
        <Parameter name="_numCreated" type="Integer" usage="output"/>
        <Parameter name="_numUpdated" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="extractClassChanges" id="b7a92cba-c085-4358-8d21-7ab57b1bcedd">
        <updating/>
        <source>extractClassChanges(_transClass : CM_DataDumpTransSpecClass input;
		_extractFromTS, _latestUpdateTs: TimeStamp output; _numCreated, _numUpdated: Integer output) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
//24 Jul 2013	cnwrs1	Par #32087 - stop processing sub classes after an exception
// 17 Jun 2014	cnwrs1	Par 34413 lost updates in DSS
// 08 Oct 2014	cnwkpd1	PAR #34868 - Ensure _latestUpdateTs is never set to a later time than the original
//						selection criteria
// 15 May 2015	cnwkpd1	PAR #36237 - Add in CardSchema lock exception handler to do some lock retrying
//04 Feb 2015	cnwrs1	Par37170 - SQL Native not recovering from SQL shutdown
// 21 May 2018	jlgrs1	TFS 38693 C3 stop trying to write out CM_LogNoNumbers

vars
	obj : Object;
	cls : Class;
	changedTs : TimeStamp;
	classStr : String;
	logStr : String;
	gotException : Boolean;
	isInitialisedWithFeatures : Boolean;
	exceptionStr : String;
	ok : Boolean;
	successStr : String;
	created, updated : Boolean;
	filterByTerminal : Boolean;
	sqlStatement: String;
	inTrxStateException : Boolean;
	numberToChange : Integer;
	changeArray : StringArray;
	updateArray : ObjectArray;
	str : String;
	cnt : Integer;
	msg : String;
begin
	create changeArray transient;
	create updateArray transient;
	cls := _transClass.myClass;
	classStr := _transClass.getClassId;
	filterByTerminal := self.isTerminalFilteredClass(_transClass);
	_latestUpdateTs := null;
	_extractFromTS := _transClass.getExtractFromDateTime;
	self.log("Selecting " &amp; classStr &amp; " changes from " &amp; 
		_extractFromTS.dataDumpFormat &amp; " to " &amp; self.extractToDateTime.dataDumpFormat);

	self.myChangeTrackingInterface.selectClassChanges(cls.name,
			_transClass.getExtractFromDateTime, self.extractToDateTime,//);
			self.getIgnoreDeleteUserCode);	//07 Jan 2014	NDL	Par 33264
			
	numberToChange := self.myChangeTrackingInterface.getClassChangesNumber(cls.name, changeArray);		
	self.log("  Processing "&amp;numberToChange.String&amp;' '&amp;changeArray.size.String&amp;" objects.");
	numberToChange := changeArray.size;
	// The object being extracted, or any one of the references
	// on the object, can be invalid.  In this case we want to log
	// the invalid object and move on, rather than abandoning the
	// entire class.
	on Exception do self.localInvalidObjExHandler(
			exception, obj, exceptionStr, gotException);
			
	on LockException do app.cnGlobalLockExceptionHandler(exception);		// PAR #36237
	
	while self.myChangeTrackingInterface.getNextClassChange(obj, changedTs) = 0 do
		updateArray.add(obj);
		if not isInitialisedWithFeatures then
			// Delayed initialisation of the Features list
			isInitialisedWithFeatures := true;
			
			//24 Jan 2013	NDL	Par 31070
			on Exception do self.localExtDbaseInTransHandler( exception, inTrxStateException );
			
			if self.isExternalDatabaseExtract then
				// Delayed begin to the external transaction, as there
				// is no point starting one if there are no changes to
				// extract for this class.
				logStr := logStr &amp; CrLf &amp; "Begin external transaction";
				self.myExternalDatabaseAgent.beginTrans;
			elseif self.isXMLFileExtract then
				self.fileOpen(self.getXMLFilename(_transClass, self.ActionChange), false);
			elseif self.isSQLNative then
				logStr := logStr &amp; CrLf &amp; "SQL Native Begin external transaction";
				self.myExternalDatabaseAgent.beginTrans;			
			else
				app.raiseCMException1(DataDumpInvalidFormat, self.extractFormat.String, null, null);
			endif;
	
			//24 Jan 2013	NDL	Par 31070
			if inTrxStateException then
				ok := false;
				return ok;
			else
				on Exception do null;
			endif;
	
			logStr := logStr &amp; CrLf &amp;
					"New class initialisation" &amp; CrLf &amp;
					"  start : " &amp; app.actualTimeServer.Time.dataDumpFormat;
			_transClass.initialiseWithFeatures;
			logStr := logStr &amp; CrLf &amp;
					"  end   : " &amp; app.actualTimeServer.Time.dataDumpFormat;
			self.log(classStr &amp; logStr);
			logStr := null;
		endif;

		gotException := false;
		
		self.writeChangeObj(_transClass, obj, changedTs,
				created, updated, filterByTerminal, sqlStatement,
				self.myChangeTrackingInterface.mySelectionObject.changeAction);
				
		if gotException then
			// Attempted to extract an Invalid object.  We assume the object has been
			// deleted, and will be extracted in the Class Deletes.
			logStr := logStr &amp; CrLf &amp; exceptionStr;
			self.log(classStr&amp;' Exception='&amp;logStr);
			if self.isSQLNative then
				self.myExternalDatabaseAgent.abortTrans("SQL Native");
				ok := false;
				return ok;
			endif;
		else
			if created then
//rs par 10908 this should be using CM_ExternalDatabaseAgent.transNumCreates
				_numCreated := _numCreated + 1;
				self.addOids.add(obj.getOidString());
			elseif updated then
				_numUpdated := _numUpdated + 1;
				self.updateOids.add(obj.getOidString());
			endif;
			if changedTs &gt; _latestUpdateTs and changedTs &lt;= self.extractToDateTime then		// PAR #34868
				_latestUpdateTs := changedTs;
			endif;
			if sqlStatement &lt;&gt; null then
				self.myExternalDatabaseAgent.writeSQLStatementToFile(sqlStatement, _transClass.getClassAlias);
			endif;
		endif;
	endwhile;
	
	on Exception do null;
		
	if self.isExternalDatabaseExtract and
			isInitialisedWithFeatures then
		logStr := logStr &amp; CrLf &amp; "Commit external transaction";
		self.myExternalDatabaseAgent.commitTrans("EDB");
	elseif self.isSQLNative and isInitialisedWithFeatures then
		self.myExternalDatabaseAgent.commitTrans("SQL Native");
	endif;
	
	ok := true;
epilog
	if ok then
		successStr := "extracted";
	else
		successStr := "abandoned";
		//29/06/2010 cnwdz2 24830
//		if self.isSQLNative then
//			self.myExternalDatabaseAgent.abortTrans("SQL Native");
//		endif;
	endif;
	self.log(classStr &amp; logStr &amp; CrLf &amp;
			"Changes " &amp; successStr &amp; ".  Creates " &amp; _numCreated.String &amp;
			", Updates " &amp; _numUpdated.String);
//	if (_numCreated + _numUpdated) &lt;&gt; numberToChange then
	if (_numCreated + _numUpdated) &lt;&gt; numberToChange and ok then	//20 Nov 2014	NDL	Par 35264 - as per Rob in technical notes of Par.
		logStr := classStr&amp;" ###### Expected number of changes = "&amp;numberToChange.String&amp;" but did "&amp;(_numCreated + _numUpdated).String&amp;" ######";
		self.log(logStr);
		app.createAlert(logStr, true);
		cnt := 0;
		self.log("List of objects expected to update");
		foreach str in changeArray do
			cnt := cnt + 1;
			msg := msg&amp;str&amp;' ';
			if (cnt mod 10 = 0)then
				self.log(msg);
				msg := null;
			endif;
		endforeach;
		if (cnt mod 10 &lt;&gt; 0)then
			self.log(msg);
			msg := null;
		endif;
		cnt := 0;
		self.log("List of objects created/updates");
		foreach obj in updateArray do
			cnt := cnt + 1;
			msg := msg&amp;obj.String&amp;' ';
			if (cnt mod 10 = 0)then
				self.log(msg);
				msg := null;
			endif;
		endforeach;
		if (cnt mod 10 &lt;&gt; 0)then
			self.log(msg);
			msg := null;
		endif;
		if app.myRoot.getConfig(DataDumpExtNumsDontMatch).Boolean then
			ok := false;
		endif;
	endif;
	delete changeArray;
	delete updateArray;
	self.fileClose;
	if not ok then
		if self.isSQLNative then
			self.myExternalDatabaseAgent.abortTrans("SQL Native");
		endif;
	endif;
	return ok;
end;</source>
        <access>protected</access>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass" usage="input"/>
        <Parameter name="_extractFromTS" type="TimeStamp" usage="output"/>
        <Parameter name="_latestUpdateTs" type="TimeStamp" usage="output"/>
        <Parameter name="_numCreated" type="Integer" usage="output"/>
        <Parameter name="_numUpdated" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="extractClassChangesSingle" id="64e1f384-d845-4553-b266-74ca973713c0">
        <updating/>
        <source>extractClassChangesSingle(_transClass : CM_DataDumpTransSpecClass input; _obj : CM_Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2006 cnwrs1
//
// Purpose:		The test extract selects one object (parameter)
//				, and extracts it in the same way as the full extract.  Doesn't do Deletes.
// ---------------------------------------------------------------------------
vars
	obj : Object;
	cls : Class;
	changedTs : TimeStamp;
	logStr : String;
	classStr : String;
	numChanged : Integer;
	gotException : Boolean;
	exceptionStr : String;
	created, updated : Boolean;
	filterByTerminal : Boolean;
	sqlStatement: String;
begin
	cls := _obj.class;
	classStr := "TEST MODE: " &amp; _transClass.getClassId;
	filterByTerminal := self.isTerminalFilteredClass(_transClass);
	
	obj := _obj;
	
	if obj = null then
		logStr := logStr &amp; CrLf &amp; "No objects in class";
		return;
	endif;
	
	if self.isExternalDatabaseExtract then
		logStr := logStr &amp; CrLf &amp; "Begin external transaction";
		self.myExternalDatabaseAgent.beginTrans;
	elseif self.isXMLFileExtract then
		self.fileOpen(self.getXMLFilename(_transClass, self.ActionTest), false);
	elseif self.isSQLNative then
		logStr := logStr &amp; CrLf &amp; "SQL Native Begin external transaction";
		self.myExternalDatabaseAgent.beginTrans;			
	else
		app.raiseCMException1(DataDumpInvalidFormat, self.extractFormat.String, null, null);
	endif;
	
	gotException := false;
	
	// Delayed initialisation of the Features list
	logStr := logStr &amp; CrLf &amp;
			"New class initialisation" &amp; CrLf &amp;
			"  start : " &amp; app.actualTimeServer.Time.dataDumpFormat;
	_transClass.initialiseWithFeatures;
	logStr := logStr &amp; CrLf &amp;
			"  end   : " &amp; app.actualTimeServer.Time.dataDumpFormat;
	self.log(classStr &amp; logStr);
	logStr := null;
	
	// The object being extracted, or any one of the references
	// on the object, can be invalid.  In this case we want to log
	// the invalid object and move on, rather than abandoning the
	// entire class.
	on Exception do self.localInvalidObjExHandler(
			exception, obj, exceptionStr, gotException);
	
	gotException := false;
	
	self.writeChangeObj(_transClass, obj, changedTs, created, updated, filterByTerminal, 
						sqlStatement, JSSCTSelectionObject.ACTION_CREATE);
	
	on Exception do null;
	on Exception do null;	//03 Sep 2015	NDL	Par 36724

	if gotException then
		// Attempted to extract an Invalid object.  We assume the object has been
		// deleted, and will be extracted in the Class Deletes.
		logStr := logStr &amp; CrLf &amp; exceptionStr;
	else
		if created or updated then
			numChanged := numChanged + 1;
		endif;
		if sqlStatement &lt;&gt; null then
			self.myExternalDatabaseAgent.writeSQLStatementToFile(sqlStatement, _transClass.getClassAlias);
		endif;
	endif;

	if self.isExternalDatabaseExtract then
		logStr := logStr &amp; CrLf &amp; "Commit external transaction";
		self.myExternalDatabaseAgent.commitTrans("DSS");
		if created or updated then
			// Trace the JADE and External objects
			self.log(self.myExternalDatabaseAgent.traceStrForObject(obj));
			self.log(self.myExternalDatabaseAgent.traceStrForExternalObject(obj));
		endif;
	elseif self.isSQLNative then
		logStr := logStr &amp; CrLf &amp; "SQL Native Commit external transaction";
		self.myExternalDatabaseAgent.commitTrans("SQL Native");			
	endif;

epilog
	self.log(classStr &amp; logStr &amp; CrLf &amp; "Changes extracted: " &amp; numChanged.String);
	self.fileClose;
end;</source>
        <access>protected</access>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass" usage="input"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="extractClassChangesTest" id="6f6ff3ea-369d-474d-a118-29213c21a9e1">
        <updating/>
        <source>extractClassChangesTest(_transClass : CM_DataDumpTransSpecClass input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
//
// Purpose:		The test extract selects one object (the lastInstance)
//				of each class in the definition, and extracts it in the
//				same way as the full extract.  Doesn't test Deletes.
// ---------------------------------------------------------------------------
vars
	obj : Object;
	cls : Class;
	changedTs : TimeStamp;
	logStr : String;
	classStr : String;
	numChanged : Integer;
	gotException : Boolean;
	exceptionStr : String;
	created, updated : Boolean;
	filterByTerminal : Boolean;
	sqlStatement: String;
begin
	cls := _transClass.myClass;
	classStr := "TEST MODE: " &amp; _transClass.getClassId;
	filterByTerminal := self.isTerminalFilteredClass(_transClass);
	
	obj := cls.lastInstance;
	
	if obj = null then
		logStr := logStr &amp; CrLf &amp; "No objects in class";
		return;
	endif;
	
	if self.isExternalDatabaseExtract then
		logStr := logStr &amp; CrLf &amp; "Begin external transaction";
		self.myExternalDatabaseAgent.beginTrans;
	elseif self.isXMLFileExtract then
		self.fileOpen(self.getXMLFilename(_transClass, self.ActionTest), false);
	elseif self.isSQLNative then
		logStr := logStr &amp; CrLf &amp; "SQL Native Begin external transaction";
		self.myExternalDatabaseAgent.beginTrans;			
	else
		app.raiseCMException1(DataDumpInvalidFormat, self.extractFormat.String, null, null);
	endif;
	
	gotException := false;
	
	// Delayed initialisation of the Features list
	logStr := logStr &amp; CrLf &amp;
			"New class initialisation" &amp; CrLf &amp;
			"  start : " &amp; app.actualTimeServer.Time.dataDumpFormat;
	_transClass.initialiseWithFeatures;
	logStr := logStr &amp; CrLf &amp;
			"  end   : " &amp; app.actualTimeServer.Time.dataDumpFormat;
	self.log(classStr &amp; logStr);
	logStr := null;
	
	// The object being extracted, or any one of the references
	// on the object, can be invalid.  In this case we want to log
	// the invalid object and move on, rather than abandoning the
	// entire class.
	on Exception do self.localInvalidObjExHandler(
			exception, obj, exceptionStr, gotException);
	gotException := false;
	
	self.writeChangeObj(_transClass, obj, changedTs, created, updated, filterByTerminal, 
						sqlStatement, JSSCTSelectionObject.ACTION_CREATE);
	
	on Exception do null;

	if gotException then
		// Attempted to extract an Invalid object.  We assume the object has been
		// deleted, and will be extracted in the Class Deletes.
		logStr := logStr &amp; CrLf &amp; exceptionStr;
	else
		if created or updated then
			numChanged := numChanged + 1;
		endif;
		if sqlStatement &lt;&gt; null then
			self.myExternalDatabaseAgent.writeSQLStatementToFile(sqlStatement, _transClass.getClassAlias);
		endif;
	endif;

	if self.isExternalDatabaseExtract then
		logStr := logStr &amp; CrLf &amp; "Commit external transaction";
		self.myExternalDatabaseAgent.commitTrans("EDB");

		if created or updated then
			// Trace the JADE and External objects
			self.log(self.myExternalDatabaseAgent.traceStrForObject(obj));
			self.log(self.myExternalDatabaseAgent.traceStrForExternalObject(obj));
		endif;
	endif;

epilog
	self.log(classStr &amp; logStr &amp; CrLf &amp; "Changes extracted: " &amp; numChanged.String);
	self.fileClose;
end;</source>
        <access>protected</access>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractClassDeletes" id="0407ab53-4536-4d0d-911e-79cf84b8a929">
        <updating/>
        <source>extractClassDeletes(_transClass : CM_DataDumpTransSpecClass;
		_latestDeleteTs: TimeStamp output; numDeleted: Integer output) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
//24 Jul 2013	cnwrs1	Par #32087 - stop processing sub classes after an exception
// 08 Oct 2014	cnwkpd1	PAR #34868 - Ensure _latestDeleteTs is never set to a later time than the original
//						selection criteria

vars
	objId : String;
	cls : Class;
	changedTs : TimeStamp;
	classStr : String;
	logStr : String;
	isAnyDataExtracted : Boolean;
	ok : Boolean;
	successStr : String;

begin
	cls := _transClass.myClass;
	classStr := _transClass.getClassId;
	_latestDeleteTs := null;
	
	if self.getIgnoreDeleteUserCode = null then
		self.log("Selecting " &amp; classStr &amp; " deletes" &amp; CrLf &amp;
				"  from : " &amp; _transClass.getExtractFromDateTime.dataDumpFormat &amp; CrLf &amp;
				"  to   : " &amp; self.extractToDateTime.dataDumpFormat);
				
	else	//07 Jan 2014	NDL	Par 33264
		self.log("Selecting " &amp; classStr &amp; " deletes" &amp; CrLf &amp;
				"  from : " &amp; _transClass.getExtractFromDateTime.dataDumpFormat &amp; CrLf &amp;
				"  to   : " &amp; self.extractToDateTime.dataDumpFormat &amp; CrLf &amp;
				"  ignoring user   : " &amp; self.getIgnoreDeleteUserCode.code );
	endif;
			
	self.myChangeTrackingInterface.selectClassDeletes(cls.name,
			_transClass.getExtractFromDateTime, self.extractToDateTime,//);
			self.getIgnoreDeleteUserCode);	//07 Jan 2014	NDL	Par 33264
			
	while self.myChangeTrackingInterface.getNextClassDelete(objId, changedTs) = 0 do

		if not isAnyDataExtracted then
			isAnyDataExtracted := true;
			
			// Delayed begin to the external transaction, as there
			// is no point starting one if there are no changes to
			// extract for this class.

			if self.isExternalDatabaseExtract then
				logStr := logStr &amp; CrLf &amp; "Begin external transaction";
				self.myExternalDatabaseAgent.beginTrans;
			elseif self.isXMLFileExtract then
				self.fileOpen(self.getXMLFilename(_transClass, self.ActionDelete), false);
			elseif self.isSQLNative then
				logStr := logStr &amp; CrLf &amp; "SQL Native Begin external transaction";
				self.myExternalDatabaseAgent.beginTrans;			
			else
				app.raiseCMException1(DataDumpInvalidFormat, self.extractFormat.String, null, null);
			endif;
		endif;
		
		ok := self.writeDeleteObj(_transClass, objId, changedTs);
		if not ok then
			return ok;
		endif;
		numDeleted := numDeleted + 1;
		self.deleteOids.add(objId);		
		if changedTs &gt; _latestDeleteTs and changedTs &lt;= self.extractToDateTime then		// PAR #34868 
			_latestDeleteTs := changedTs;
		endif;
	endwhile;
	
	if self.isExternalDatabaseExtract and isAnyDataExtracted then
		logStr := logStr &amp; CrLf &amp; "Commit external transaction";
		self.myExternalDatabaseAgent.commitTrans("EDB");
	endif;

	if self.isSQLNative and isAnyDataExtracted then
		logStr := logStr &amp; CrLf &amp; "Commit SQL Native transaction";
		self.myExternalDatabaseAgent.commitTrans("SQL Native");
	endif;
	
	ok := true;
epilog
	if ok then
		successStr := "extracted";
	else
		successStr := "abandoned";
	endif;
	self.log(classStr &amp; logStr &amp; CrLf &amp;
			"Deletions " &amp; successStr &amp; ": " &amp; numDeleted.String);
	self.fileClose;
	return ok;
end;</source>
        <access>protected</access>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_latestDeleteTs" type="TimeStamp" usage="output"/>
        <Parameter name="numDeleted" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="extractExHandler" id="9bdc7248-3a3e-4e72-8b85-506d958d0a01">
        <updating/>
        <source>extractExHandler(exObj: Exception) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 29/12/2017	jlgdap1		TFS 36403 MSL Nested exception in BGP SQL extract
constants
	ServerMethodAborted = 1242;
	
vars
	errStr : String;
	sqlParams : String;
	mthString	: String; //cnwrd1 36135 log sqlparams
begin
	abortTransaction;
	
	if exObj.errorCode = ServerMethodAborted then
		// Already handled by server method exception handler.
		return Ex_Resume_Next;
	endif;
	
	// 29200 Mar 2012 extend the exception reporting
	if exObj.currentMethodDesc &lt;&gt; null then
		mthString := exObj.currentMethodDesc.displayForUnitTest();
	endif;

	//cnwrd1 36135 log sqlparams
	if self.isSQLNative  then
		//if self.myExternalDatabaseAgent &lt;&gt; null then																// TFS 36403
		if self.myExternalDatabaseAgent &lt;&gt; null and self.myExternalDatabaseAgent.myExtractionAgent &lt;&gt; null then		// TFS 36403
			sqlParams := CrLf &amp; " SQL Parameters : " &amp; self.myExternalDatabaseAgent.myExtractionAgent.sqlCallInfo;
		endif;
	endif;
	
	
	errStr := "Extract exception - abandoned extract of all classes" &amp; CrLf &amp;
			"Error Code: " &amp; exObj.errorCode.String &amp; CrLf &amp;
			"Error item: " &amp; exObj.errorItem &amp; " " &amp; mthString &amp;
			" Extended Error Text: " &amp; exObj.extendedErrorText &amp;
			 sqlParams; //cnwrd1 36135 log sqlparams
			 
	self.log(errStr);

	// 29200 Mar myExternalDatabaseAgent may not be set up yet - got 1090's from here as well as the original exception
	if self.isExternalDatabaseExtract then
		if self.myExternalDatabaseAgent &lt;&gt; null then
			self.myExternalDatabaseAgent.abortTrans("EDB");
		endif;
	elseif self.isSQLNative  then
		if self.myExternalDatabaseAgent &lt;&gt; null then
			self.myExternalDatabaseAgent.abortTrans("SQL Native");
		endif;
	endif;

	self.raiseAlert(self.extractClassId);

	// DVB 20/01/04 Want to pass control back to
	// BGP exception handler so we can clean up process correctly.
	if app.isBackGroundApp then
		return Ex_Pass_Back;
	endif;
	
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fileClose" id="5a730719-18df-44e1-b25d-cb3d79a4a471">
        <updating/>
        <source>fileClose() updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	logStr : String;
	
begin
	if self.myFile &lt;&gt; null then
		logStr := "Closing file: " &amp; self.myFile.fileName;
		self.myFile.close;
		delete self.myFile;
	endif;
	
epilog
	if logStr &lt;&gt; null then
		self.log(logStr);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fileOpen" id="e3eecabe-80a2-4907-a216-7eaa64ee215e">
        <updating/>
        <source>fileOpen(_fileName: String; _final : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
// Changed:		29 May 2009 by conkc1
//				Code added for XML version and encoding;
//				Code added to place &lt;file&gt; tag at the start of all files
//				Code added to place &lt;/file&gt; tag at the end of all files
// ---------------------------------------------------------------------------
begin
	self.fileClose;
	
	self.log("Opening file: " &amp; _fileName);
	
	create self.myFile transient;
	self.myFile.fileName := _fileName;
	self.myFile.mode := File.Mode_Append;
	//self.myFile.kind := File.Kind_ANSI;
	self.myFile.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version
	self.myFile.shareMode := File.Share_Read;
	self.myFile.allowReplace := false;
	
	self.myFile.open;
	if _final = false then
		if self.myFile.fileLengthDec = 0 then
			self.myFile.writeString('&lt;?xml version="1.0" encoding="ISO-8859-1"?&gt;' &amp; CrLf);
			self.myFile.writeString('&lt;file&gt;' &amp; CrLf);
		endif;
	else
		if self.myFile.fileLengthDec = 0 then
			self.myFile.close;
			self.myFile.purge;
		else
			self.myFile.writeString('&lt;/file&gt;');
			self.myFile.close;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_final" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="finalise" id="40117635-eddc-4f30-9678-90089c1c1f95">
        <updating/>
        <source>finalise() updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
//04 Feb 2015	cnwrs1	Par37170 - SQL Native not recovering from SQL shutdown
begin
	on Exception do null global;		// 33033 move to top so it gets done even if following code fails
	
	delete self.myTransExtractDef;
	self.fileClose;
	
	if self.myChangeTrackingInterface &lt;&gt; null then
		self.myChangeTrackingInterface.finalizeChangeTracker();
		delete self.myChangeTrackingInterface;
	endif;
	
	self.finaliseExternalDatabaseAgent;
epilog	
	self.log("Change Tracker extract finished" &amp; CrLf);
	self.deleteLog;
end;</source>
    </JadeMethod>
    <JadeMethod name="finaliseExternalDatabaseAgent" id="e31dfb52-3a1e-4a06-88e9-b66026b8917f">
        <updating/>
        <source>finaliseExternalDatabaseAgent() updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
//09 Dec 2015	cnwrs1	Par37170 - SQL Native not recovering from SQL shutdown
begin
	if self.myExternalDatabaseAgent &lt;&gt; null then
		self.myExternalDatabaseAgent.finalise();
	endif;
epilog	
	delete self.myExternalDatabaseAgent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateTransientMethods" id="2de4e376-e5fd-4628-811f-cc431012c122">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>generateTransientMethods() : Boolean serverExecution, updating;
/*
Purpose:			Generate all transient methods once per run and stores them in a transient object.
					This object is added to a Transient dictionary keyed by Class Number and Action.


Parameters:			

Return Value:		

Date			Who		Reason
04 May 2010		conkc1	Initial creation
09 Nov 2012		cnwkpd1	PAR #30706 - Extend error reporting to include error position and length

*/
vars
	extractClass    : CM_DataDumpExtractClass;
	feature         : CM_DataDumpFeature;
	transientMethod : CM_DataDumpTransientMethod;
	jadeMethodI     : JadeMethod;
	jadeMethodU     : JadeMethod;
	jadeMethodD     : JadeMethod;
	class           : Class;
	classNumber     : Integer;
	source          : String;
	subClassName    : String;
	methodName      : String;

	errorCode       : Integer;
	errorPosition   : Integer;
	errorLength	    : Integer;
	errorMsg	    : String;

begin
	if self.allDataDumpTransientMethod.size() &gt; 0 then
		return true;
	endif;

	foreach extractClass in self.myExtractDef.allDataDumpExtractClasses do

		methodName  := CM_ExternalDatabaseAgent.StoredProcPrefix &amp; extractClass.sqlTableName[ 1 : 26];

		class       := currentSchema.getClass(extractClass.className);
		classNumber := class.number;

		source      := extractClass.jadeSourceInsert;
		jadeMethodI := process.createTransientMethod(methodName, class, currentSchema , source, false, null, errorCode, errorPosition, errorLength);
		if errorCode &lt;&gt; 0 then
			self.log(method.qualifiedName &amp; " :  Insert - " &amp; extractClass.className);
			self.log("Error : " &amp; errorCode.String &amp; " Position : " &amp; errorPosition.String &amp; " Length : " &amp; errorLength.String);
			self.log("Source :- " &amp; CrLf &amp; "'" &amp; source &amp; "'");
			
			self.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; errorCode.String &amp; " : Insert - " &amp; extractClass.className);
			return false;
		endif;
		create transientMethod transient;
		transientMethod.myJadeMethod := jadeMethodI;
		transientMethod.classNumber  := classNumber;
		transientMethod.action       := self.SQL_Insert;
		transientMethod.sqlTableName := extractClass.sqlTableName;
		self.allDataDumpTransientMethod.add(transientMethod);

		source      := extractClass.jadeSourceUpdate;
		jadeMethodU := process.createTransientMethod(methodName, class, currentSchema , source, false, null, errorCode, errorPosition, errorLength);
		if errorCode &lt;&gt; 0 then
			self.log(method.qualifiedName &amp; " :  Update - " &amp; extractClass.className);
			self.log("Error : " &amp; errorCode.String &amp; " Position : " &amp; errorPosition.String &amp; " Length : " &amp; errorLength.String);
			self.log("Source :- " &amp; CrLf &amp; "'" &amp; source &amp; "'");
		
			self.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; errorCode.String &amp; " : Update - " &amp; extractClass.className);
			return false;
		endif;
		create transientMethod transient;
		transientMethod.myJadeMethod := jadeMethodU;
		transientMethod.classNumber  := classNumber;
		transientMethod.action       := self.SQL_Update;
		transientMethod.sqlTableName := extractClass.sqlTableName;
		self.allDataDumpTransientMethod.add(transientMethod);

		source      := extractClass.jadeSourceUpdateDelete;
		jadeMethodD := process.createTransientMethod(methodName, CM_ExternalDatabaseAgent, currentSchema , source, false, null, errorCode, errorPosition, errorLength);
		if errorCode &lt;&gt; 0 then
			self.log(method.qualifiedName &amp; " :  Delete - " &amp; extractClass.className);
			self.log("Error : " &amp; errorCode.String &amp; " Position : " &amp; errorPosition.String &amp; " Length : " &amp; errorLength.String);
			self.log("Source :- " &amp; CrLf &amp; "'" &amp; source &amp; "'");

			self.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; errorCode.String &amp; " : Delete - " &amp; extractClass.className);
			return false;
		endif;
		create transientMethod transient;
		transientMethod.myJadeMethod := jadeMethodD;
		transientMethod.classNumber  := classNumber;
		transientMethod.action       := SQL_UpdateDelete;
		transientMethod.sqlTableName := extractClass.sqlTableName;
		if extractClass.deleteAction = CM_DataDumpExtractClass.DeleteOpt_SendNo then
			transientMethod.ignoreDeletes := true;
		endif;
		self.allDataDumpTransientMethod.add(transientMethod);

	endforeach;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getExtractFormatDescr" id="251f6281-9366-4ab7-8dda-b1709f9c41fe">
