    <JadeMethod name="utlDeleteInvoiceLineDescMap" id="88cc91c8-a021-401b-8c96-fa1baa8612eb">
        <source>utlDeleteInvoiceLineDescMap(_invoiceLineDescMap : CM_InvoiceLineDescMapping io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	toDelete	: CM_InvoiceLineDescMapping;
	theLine		: CM_InvoiceLineDesc;
	objOid		: String;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValDA.valInvoiceLineDescMap(_invoiceLineDescMap);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	objOid := _invoiceLineDescMap.getOidAsString();
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_invoiceLineDescMap);
	endif;
	
	if _passport.noErrors then
		toDelete := _invoiceLineDescMap;
		theLine := _invoiceLineDescMap.myInvoiceLineDesc;
		_invoiceLineDescMap.erase(NORMAL_ERASE);
	endif;
	
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_DELETE),false,theLine);
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_DELETEOID), false, objOid); //For Invoice Line Desc Form Specifically
	endif;
	
epilog
	return;
	
end;</source>
        <Parameter name="_invoiceLineDescMap" type="CM_InvoiceLineDescMapping" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInvoiceLineNarr" id="9c75ddf3-38e8-4fc1-8266-62ceaf5a0cca">
        <source>utlDeleteInvoiceLineNarr(_realInvoiceLineNarration : CM_InvoiceLineNarration io; _passport : CM_Passport input);
/*

Purpose:			Deletes an Invoice Line Narration

Parameters:			_pxyInvoiceLineNarration	CM_InvoiceLineNarration	The proxy copy of the Invoice Line Narration to remove
					_passport					CM_Passport				The passport to use to hold errors and other information

Return Value:		NONE

Date		Who		Reason
01 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valInvoiceLineNarr(_realInvoiceLineNarration);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_realInvoiceLineNarration);
	endif;
	
	if _passport.noErrors then
		delete _realInvoiceLineNarration;
	endif;

end;</source>
        <Parameter name="_realInvoiceLineNarration" type="CM_InvoiceLineNarration" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInvoiceShipMapping" id="41fa1110-86fe-4f51-bff2-c623ccb89ba1">
        <source>utlDeleteInvoiceShipMapping(_invoiceShipTermMapping : CM_InvoiceShipTermMapping io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
15 Dec 2022 navtnr20	TFS CR 55622 Task 55690: Jade - Shipping Terms TRX
*/

vars

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valInvShipMapping(_invoiceShipTermMapping);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_invoiceShipTermMapping);
		app.myEventManager.createSingleObjInfoNoteEvt(_invoiceShipTermMapping.myShippingTerm.myBusinessUnit,app.myPassport.myTerminal.getTerminalEvent(Event_InvShipMappingDelete),_invoiceShipTermMapping);
	endif;

	if _passport.noErrors then
		_invoiceShipTermMapping.setForDelete(); // ### TFS CR 55622 TASK 55690 24JAN2023 NAVAB1
	endif;

epilog
	return;

end;</source>
        <Parameter name="_invoiceShipTermMapping" type="CM_InvoiceShipTermMapping" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
