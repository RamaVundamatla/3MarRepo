    <JadeMethod name="addGapRow" id="5b2a9c26-2815-4901-bb03-d2fc701fa85f">
        <source>addGapRow() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	newRow : Integer;
begin
