    <JadeMethod name="setDuration" id="55238c99-fff4-41fa-b976-23ed067ff954">
        <source>setDuration(_startTime : Time);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2023	navmd1	Initial creation

*/

vars

begin
	if self.myReport &lt;&gt; null then
		self.myReport.setGenerationTime((app.actualTime.time - _startTime).Time);
	endif;
epilog

end;</source>
        <Parameter name="_startTime" type="Time"/>
    </JadeMethod>
