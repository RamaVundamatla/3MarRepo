        <source>dblClick(frame: Frame input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		15 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myContainerDrawingFrame.dblClick(self.myContainerDrawingFrame);
