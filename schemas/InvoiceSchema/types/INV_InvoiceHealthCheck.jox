    <JadeMethod name="doTblDataDBClick" id="3fc369de-d1fe-478a-93c9-80b80c4dc522">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	inheritMethod(table);

	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if app.isDevelopmentSystem() or app.isAllowedToInspect() then
		table.accessRow(table.row).itemObject.inspect;
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="2b5627ba-e928-434a-be0e-d72564461b99">
        <source>initDataTable(_table : CM_DataTable input);
/*
Purpose:			
Date		Who		Reason
14 September 2016	cnwab1	Initial creation
*/

vars
	entTableDef		: EntTableDef;

begin
	_table.userInputEnabled := false;
	_table.selectMode := Table.SelectMode_CurrentRow;
	_table.selectionType := CM_DataTable.SelectionType_Row;
	_table.multiSelect := _table.MultiSelect_Simple;

	_table.autoSize := Table.AutoSize_Column;
	
	entTableDef := app.myController.getEntTableDef(ETDef_InvoiceHealthCheck);
	if entTableDef &lt;&gt; null then
		_table.setTblDataEntRowsFromDef(entTableDef);
	endif;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initHealthAgent" id="d6063236-ceae-4f22-9b38-87437415b36b">
        <updating/>
        <source>initHealthAgent(_agent : CMIF_InvoiceHealthAgent input) updating;
/*
Purpose:			
Date		Who		Reason
14 September 2016	cnwab1	Initial creation
*/

vars

begin
	self.lstTerms.allSelectedObjects.copy(_agent.allBusinessUnits);
	

	// ### ITEM TYPES
	if self.chkItemTranMap.value then
		_agent.itemTypesToQuery.add(CMIF_InvoiceHealthAgent.ItemType_TranMapCargo);
	endif;
	if self.chkItemInvLineType.value then
		_agent.itemTypesToQuery.add(CMIF_InvoiceHealthAgent.ItemType_InvoiceLineType);
	endif;
	if self.chkItemInvTypes.value then
		_agent.itemTypesToQuery.add(CMIF_InvoiceHealthAgent.ItemType_InvoiceType);
	endif;
	if self.chkItemServices.value then
		_agent.itemTypesToQuery.add(CMIF_InvoiceHealthAgent.ItemType_Service);
	endif;
	if self.chkItemCalcType.value then
		_agent.itemTypesToQuery.add(CMIF_InvoiceHealthAgent.ItemType_CalculationType);
	endif;

	// ### CHECK TYPES
	if self.chkTypeBank.enabled and self.chkTypeBank.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_Bank);
	endif;
	if self.chkTypeCalcType.enabled and self.chkTypeCalcType.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_CalcType);
	endif;
	if self.chkTypeInvoiceType.enabled and self.chkTypeInvoiceType.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_InvoiceType);
	endif;
	if self.chkTypeMinCharge.enabled and self.chkTypeMinCharge.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_MinCharge);
	endif;
	if self.chkTypeService.enabled and self.chkTypeService.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_Service);
	endif;
	if self.chkTypeTransMap.enabled and self.chkTypeTransMap.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_TranMapCargo);
	endif;
	if self.chkTypeGLCode.enabled and self.chkTypeGLCode.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_GLCode);
	endif;
	if self.chkTypeTax.enabled and self.chkTypeTax.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_Tax);
	endif;
	if self.chkTypeHookQuantity.enabled and self.chkTypeHookQuantity.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_HookQuantity);
	endif;
	if self.chkTypeHookRate.enabled and self.chkTypeHookRate.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_HookRate);
	endif;
	
	if self.chkTypeMeasure.enabled and self.chkTypeMeasure.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_Measure);
	endif;
	if self.chkTypeCalendar.enabled and self.chkTypeCalendar.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_Calendar);
	endif;
	
	
	if self.chkTypeInvoiceLines.enabled and self.chkTypeInvoiceLines.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_InvoiceLineType);
	endif;
	if self.chkTypeFinancial.enabled and self.chkTypeFinancial.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_FinancialPeriods);
	endif;
	if self.chkTypeTermsTrade.enabled and self.chkTypeTermsTrade.value then
		_agent.checkTypesToQuery.add(CMIF_InvoiceHealthAgent.CheckType_TermsTrade);
	endif;
	
	if _agent.allBusinessUnits.isEmpty() then
		app.msgBox("Please choose a business unit to query","Health Check",MsgBox_OK_Only);
		return;
	endif;
	
	if _agent.itemTypesToQuery.isEmpty() then
		app.msgBox("Please choose an item type to query","Health Check",MsgBox_OK_Only);
		return;
	endif;

	if _agent.checkTypesToQuery.isEmpty() then
		app.msgBox("Please choose a check type to query","Health Check",MsgBox_OK_Only);
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="3446bbd6-d3c6-402f-84b7-d11e10f95464">
        <updating/>
        <source>initQueryFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	sht			: CMUI_Sheet;
	lstTable : CMUI_ListTable;
	term :CM_Terminal;
	terms : CM_TerminalByCodeDict;
	bu : CM_Bank;
begin
	
	self.frmQuery.height := 400;
	
	
	
	sht := self.shtQuery1;
	sht.caption := app.getErrorString(Item_types);

	self.setQueryControl(self.chkItemCalcType);
	self.setQueryControl(self.chkItemServices);
	self.setQueryControl(self.chkItemInvTypes);
	self.setQueryControl(self.chkItemInvLineType);
	self.setQueryControl(self.chkItemTranMap);

	sht.visible := true;

	
	sht := self.shtQuery2;
	sht.caption := app.getErrorString(Check_types);

	self.setQueryControl(self.chkTypeBank);
	self.setQueryControl(self.chkTypeCalcType);
	self.setQueryControl(self.chkTypeGLCode);
	self.setQueryControl(self.chkTypeHookRate);
	self.setQueryControl(self.chkTypeHookQuantity);
	self.setQueryControl(self.chkTypeInvoiceType);
	self.setQueryControl(self.chkTypeMinCharge);
	self.setQueryControl(self.chkTypeService);
	self.setQueryControl(self.chkTypeTransMap);
	self.setQueryControl(self.chkTypeTax);
	self.setQueryControl(self.chkTypeCalendar);
	self.setQueryControl(self.chkTypeMeasure);
	self.setQueryControl(self.chkTypeInvoiceLines);
	self.setQueryControl(self.chkTypeFinancial);
	self.setQueryControl(self.chkTypeTermsTrade);

	sht.visible := true;


	sht := self.shtQuery3;
	sht.height := self.fldQuery.clientHeight;
	
	sht.caption := app.getErrorString(Business_units);
	lstTable := self.lstTerms;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;
	
	create terms transient;
	app.getMyUser().getTerminals(terms);
	
	foreach term in terms discreteLock do
		foreach bu in term.companies where bu.isBusinessUnit = true do
		lstTable.addItemObject(term.name &amp; " - " &amp; bu.code, bu);
		endforeach;
	endforeach;
	lstTable.selectAll();

epilog

delete terms;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCheckTypesEnabled" id="57e63ad7-1dd4-4b06-9e7c-cef8f2de6d80">
        <source>setCheckTypesEnabled();
/*
Purpose:			
Date		Who		Reason
15 September 2016	cnwab1	Initial creation
*/

vars
	
begin
	self.chkTypeBank.enabled := false;
	self.chkTypeCalcType.enabled := false;
	self.chkTypeInvoiceType.enabled := false;
	self.chkTypeMinCharge.enabled := false;
	self.chkTypeService.enabled := false;
	self.chkTypeTransMap.enabled := false;
	self.chkTypeGLCode.enabled := false;
	self.chkTypeTax.enabled := false;
	self.chkTypeHookRate.enabled := false;
	self.chkTypeHookQuantity.enabled := false;
	self.chkTypeCalendar.enabled := false;
	self.chkTypeMeasure.enabled := false;
	self.chkTypeInvoiceLines.enabled := false;
	self.chkTypeFinancial.enabled := false;
	self.chkTypeTermsTrade.enabled := false;
	
	if self.chkItemTranMap.value then
		self.chkTypeCalcType.enabled := true;
	endif;
	if self.chkItemCalcType.value then
		self.chkTypeHookRate.enabled := true;
		self.chkTypeHookQuantity.enabled := true;
		self.chkTypeCalendar.enabled := true;
		self.chkTypeMeasure.enabled := true;
	endif;
	
	if self.chkItemServices.value then
		self.chkTypeBank.enabled := true;
		self.chkTypeCalcType.enabled := true;
		self.chkTypeGLCode.enabled := true;
		self.chkTypeTax.enabled := true;
	endif;
	
	
	if self.chkItemInvLineType.value then
		self.chkTypeBank.enabled := true;
		self.chkTypeCalcType.enabled := true;
		self.chkTypeInvoiceType.enabled := true;
		self.chkTypeMinCharge.enabled := true;
		self.chkTypeService.enabled := true;
		self.chkTypeTransMap.enabled := true;
	endif;
	if self.chkItemInvTypes.value then
		self.chkTypeInvoiceLines.enabled := true;
		self.chkTypeFinancial.enabled := true;
		self.chkTypeTermsTrade.enabled := true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="55ef6856-6999-47fb-8eb4-e4ba191c5641">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	
	self.usesQueryFrame := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.useTableSorting := true;
	self.showToolbar := true;

	// This needs to be set before the inheritMethod because it is used in it to set mnuContextHide visibility.
	self.useTableInfo	:= false;		
	inheritMethod();
	

	self.setCaption("Invoice Module Health Checks");
	self.initDataTable(self.tblData);

	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7adb2741-f921-43c9-8405-23ca1f66dbf7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 November 2017 09:38:20.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021381, locale);
	btnRefresh.translateCaption(Xlat_0021382, locale);
	chkItemCalcType.translateCaption(Xlat_0021383, locale);
	chkItemInvLineType.translateCaption(Xlat_0021384, locale);
	chkItemInvTypes.translateCaption(Xlat_0021385, locale);
	chkItemServices.translateCaption(Xlat_0021386, locale);
	chkItemTranMap.translateCaption(Xlat_0021387, locale);
	chkTypeBank.translateCaption(Xlat_0021388, locale);
	chkTypeCalcType.translateCaption(Xlat_0021389, locale);
	chkTypeCalendar.translateCaption(Xlat_0021390, locale);
	chkTypeFinancial.translateCaption(Xlat_0022162, locale);
	chkTypeGLCode.translateCaption(Xlat_0021391, locale);
	chkTypeHookQuantity.translateCaption(Xlat_0021392, locale);
	chkTypeHookRate.translateCaption(Xlat_0021393, locale);
	chkTypeInvoiceLines.translateCaption(Xlat_0022163, locale);
	chkTypeInvoiceType.translateCaption(Xlat_0021394, locale);
	chkTypeMeasure.translateCaption(Xlat_0021395, locale);
	chkTypeMinCharge.translateCaption(Xlat_0021396, locale);
	chkTypeService.translateCaption(Xlat_0021397, locale);
	chkTypeTax.translateCaption(Xlat_0021398, locale);
	chkTypeTermsTrade.translateCaption(Xlat_0022164, locale);
	chkTypeTransMap.translateCaption(Xlat_0021399, locale);
end;</source>
    </JadeMethod>
