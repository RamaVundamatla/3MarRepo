    <JadeMethod name="runSummaryGenerator" id="fd8281f8-1a5a-43fe-aa53-4dc13d18f08e">
        <updating/>
        <source>runSummaryGenerator() updating;

vars
	sfb:FrmServerFileBrowser;
	statsDir,cmdLine,pattern,tag,s,t:String;
	ff:FileFolder; fn:FileNode;
begin
	if lastStatsFile = null then
		lastStatsFile:=app.dbPath[1:2]&amp;"\BenchMarkResults";
	endif;

	create sfb;
	sfb.myParentForm:=self;
	sfb.selectedItem:="r"&amp;lastStatsFile.withoutFileName.withoutFileName[2:end];  // change to R drive
	sfb.init("Browse for File on " &amp; app.dbServerComputerName, "Select results folder", null);
	sfb.showModal;
	statsDir:=sfb.selectedItem;

	if statsDir &lt;&gt; null then
		secondLastStatsFile:=lastStatsFile;
		lastStatsFile:=statsDir&amp;"\bogus\bogus";
		statsDir:=OtherResultsFolder&amp;statsDir[3:end];
		create ff;
		ff.fileName:=statsDir;
		foreach fn in ff.files where fn.isKindOf(FileFolder) do
			s:=fn.name[1:fn.name.length-1];
			/*if s[s.length] = "_" then
				s:=s[1:s.length-1];
			endif;*/
			if s = t then continue; endif;
			if pattern = null then
				pattern:=s;
			else
				pattern:=pattern&amp;","&amp;s;
			endif;
			t:=s;
		endforeach;
		//pattern:=pattern&amp;" -renamer true";  // only useful for comparing different jade releases
		s:=pattern;
		read pattern;
		if pattern = "all" then
			pattern:=s;
		endif;
		tag:=(process.getUserCode&amp;"abcdefg")[4:3];
		if pattern &lt;&gt; null then
			cmdLine:="c:\cardinal\bin\jblsummarygenerator -basedir "&amp;statsDir&amp;"  -pattern "&amp;pattern&amp;" -outfile "&amp;statsDir&amp;"\jblsummary_"&amp;pattern.replace(" -renamer true", "")&amp;"_"&amp;tag&amp;".xls";
			//cmdLine:=cmdLine&amp;" -renamer true";
			addResults(null);
			doCmd(cmdLine, " &gt;&gt; "&amp;statsDir&amp;"\sumgen.log");
			addResults("summary file: "&amp;statsDir&amp;"\jblsummary_"&amp;pattern&amp;".xls");
		endif;
	endif;
epilog
	delete sfb;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="saveLogFiles" id="22062b26-af6d-45d7-a55a-6215591f50a7">
        <updating/>
        <source>saveLogFiles() updating;

begin
	addResults("Ensure you stop the rap first, so the pdb and tdb stats logs are complete.");
	addResults("Saving log files from "&amp;myBmkControl.rapHost&amp;"...");
	global.causeEvent(Bmk0_Save_Log_Files, true, myBmkControl.session);
end;</source>
    </JadeMethod>
    <JadeMethod name="saveLogFilesGui" id="7e84d62f-3f6b-4f7b-8fbb-0f6acf38fced">
        <updating/>
        <source>saveLogFilesGui() updating;

vars
	s:String;
begin
	s:=myBmkControl.runid;
	read s;
	if s = null then
		return;
	endif;
	if s &lt;&gt; myBmkControl.runid then
		beginTransaction;
		myBmkControl.runid:=s;
		commitTransaction;
	endif;
	saveLogFiles;
end;
</source>
    </JadeMethod>
    <JadeMethod name="saveSession" id="20b5fcd1-47ef-4fde-a76d-82326efa69f0">
        <updating/>
        <source>saveSession() updating;

vars
	oldEnvid,newEnvid:String;
begin
	if myBmkControl &lt;&gt; null then
		oldEnvid := myBmkControl.envid;
		newEnvid := txtEnvid.text;
		if newEnvid[1:4] = oldEnvid[1:4] and newEnvid[5:end] &lt;&gt; oldEnvid[5:end] and oldEnvid[5:end] = myBmkControl.runid then
			txtSystemFolder.text := txtSystemFolder.text.replace(oldEnvid, newEnvid);
			txtBinFolder.text := txtBinFolder.text.replace(oldEnvid, newEnvid);
			txtIniFileName.text := txtIniFileName.text.replace(oldEnvid, newEnvid);
			txtRunid.text := newEnvid[5:end];
		endif;
		myBmkControl.setParams(txtEnvid.text, txtHost.text, txtRunid.text, txtControlPort.text, txtProduct.text, txtSchema.text, txtApp.text
				,txtAppServers.text.Integer, txtBmkBasePort.text, txtRapHost.text, txtSystemFolder.text, txtBinFolder.text, txtIniFileName.text);
		loadSessions;
	else
		global.beep;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCaption" id="0af9896d-fa95-4c16-95e9-7b8e56b5f585">
        <updating/>
        <source>setCaption() updating;

vars
	envid:String;
begin
	envid:=app.getEnvid;
	if envid = 'jblpcre' then
		envid:="Creator";
	endif;
	if myBmkControl = null then
		caption:=envid&amp;" Control App - ("&amp;process.getUserCode&amp;")";
	else
		caption:=envid&amp;" Control App - ("&amp;process.getUserCode&amp;") "
				&amp;myBmkControl.envid&amp;" on "&amp;myBmkControl.rapHost;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showCreatorCreators" id="8b178ba3-4f9f-420c-85be-d56ec1ca9251">
        <updating/>
        <source>showCreatorCreators() updating;

vars
	bc:BmkControlSession;
begin
	create bc transient;
	bc.setParams(app.getEnvid, app.computerNameAppServer.toLower, null, null, null, currentSchema.name, 0.asCreatorName, null, null, null, null, null, null);
	txtResults.text:="";
	txtResults.refreshNow;
	addResults(bc.countEverything(myBmkControl));
	addResults(myBmkControl.countEverything(null));
epilog
	delete bc;
end;</source>
    </JadeMethod>
