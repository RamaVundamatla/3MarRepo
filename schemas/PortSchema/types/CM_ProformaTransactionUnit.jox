<Class name="CM_ProformaTransactionUnit" id="50990002-4898-4e99-a70d-b2ca0f440fc7">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="proForma"/>
    <ExplicitInverseRef name="myProformaTransactionCriteria" id="2d2b55c9-8c0c-4631-93ae-3d34d5342961">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_ProformaTransactionCriteria"/>
        <access>readonly</access>
        <Inverse name="CM_ProformaTransactionCriteria::allProformaTransactionUnits"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myTransactionType" id="2be974b7-7e8d-489c-bd41-d634aef25d7f">
        <embedded/>
        <type name="CM_TransactionType"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="unitType" id="98f1273f-9fef-4ea8-b571-3c17d4c04316">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="unitValue" id="2919b173-54a8-4c36-9d15-ff8aa2a8fced">
        <precision>16</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getUnitTypeString" id="6fe558a7-29a9-43be-bfb8-7360994b1916">
        <source>getUnitTypeString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if self.unitType = CM_ProformaTransactionCriteria.UnitType_UserUnit then
		return CM_ProformaTransactionCriteria.UserUnit;
	elseif self.unitType = CM_ProformaTransactionCriteria.UnitType_PerDay then
		return CM_ProformaTransactionCriteria.PerDay;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnitValueAsString" id="e870548f-f5e0-4c98-9b41-292ba3aec782">
        <source>getUnitValueAsString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if self.unitType = CM_ProformaTransactionCriteria.UnitType_UserUnit then
		return self.unitValue.Integer.String;
	elseif self.unitType = CM_ProformaTransactionCriteria.UnitType_PerDay then
		return null;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="aaed8506-9886-45c9-b947-d774a709a8c8">
        <updating/>
        <source>setForUpdate( pxy : CM_ProformaTransactionUnit ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.myTransactionType := pxy.myTransactionType;
	self.unitType := pxy.unitType;
	self.unitValue := pxy.unitValue;
	self.myProformaTransactionCriteria := pxy.myProformaTransactionCriteria;

epilog

end;</source>
        <Parameter name="pxy" type="CM_ProformaTransactionUnit"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="06a4959e-67b6-4b51-8967-5da09ba330e8">
        <updating/>
        <source>setProxy(	_myTransactionType : CM_TransactionType;
			_unitType : Integer;
			_unitValue : Decimal;
			_myProformaTransactionCriteria : CM_ProformaTransactionCriteria
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

begin

	self.myTransactionType := _myTransactionType;
	self.unitType := _unitType;
	self.unitValue := _unitValue;
	self.myProformaTransactionCriteria := _myProformaTransactionCriteria;

epilog

end;</source>
        <Parameter name="_myTransactionType" type="CM_TransactionType"/>
        <Parameter name="_unitType" type="Integer"/>
        <Parameter name="_unitValue" type="Decimal"/>
        <Parameter name="_myProformaTransactionCriteria" type="CM_ProformaTransactionCriteria"/>
    </JadeMethod>
</Class>
