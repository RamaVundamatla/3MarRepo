    <JadeMethod name="cloneReferences" id="d949869c-1390-4f90-8401-bd3b1df051ca">
        <updating/>
        <source>cloneReferences(_obj: CMQF_Container; _transient: Boolean) updating;
//----------------------------------------------------------------
//	Created:	30 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _transient);
	
	self.allQryAvaGrades.clear();
	_obj.allQryAvaGrades.copy(self.allQryAvaGrades);

end;</source>
        <Parameter name="_obj" type="CMQF_Container"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="2b1e8ab5-a9e9-46ad-870b-29cdac40c5fd">
        <updating/>
        <source>filterObjects(_collection  : Collection input; 	_passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     13 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

vars
	ta			: CM_TerminalArea;
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
begin

	ta := self.getMyTerminalArea;

	if ta &lt;&gt; null then
		foreach lc in ta.allLocationsControllers discreteLock do :locLoop
			foreach ti in lc.allTrackedItems  discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
						self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
					endif;
				endif;
				
			endforeach;
		endforeach;
		return;
	endif;
	
	foreach terminal in self.allTerminals do : terminalLoop
		//need to scan onsite, onship, notified as default when no ta specified
		
		//search onsite ti's
		//TI_STATE_NORMAL
		foreach ti in terminal.allOnsiteTIsByCargoTypeId discreteLock where ti.tiType = TI_CargoType_Container do 
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
				endif;
				
			endif;
		endforeach;
		
		//search notified ti's
		//TI_STATE_NOTIFIED
		//foreach ti in terminal.allNotifiedTIsByIdCargoType do
		foreach ti in terminal.allNotifiedTIsByIdCargoType discreteLock do	//07 Mar 2011	NDL	Par 27085
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
				endif;
			endif;
		endforeach;
		
		//search onship ti's for selected voyage
		//TI_STATE_ONSHIP
		if self.getMyVoyage &lt;&gt; null then
			//foreach ti in self.myVoyage.allOnshipTIsByIdCargoType do
			foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do	//07 Mar 2011	NDL	Par 27085
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
						self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
					endif;
				endif;
				
			endforeach;
		endif;
	endforeach;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getConnectedDT" id="966bdc18-09d2-45bc-a5c7-3b6ffb205303">
        <source>getConnectedDT() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     21 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ts		: TimeStamp;
begin
	ts.setDate(self.onDate);
	ts.setTime(self.onTime);
	return ts;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="be6e5553-17e1-4157-85a5-2249e6eca795">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	runDate				: Date;
	oid 	: String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_IsConnected then
		return self.connected.cnEcGetTableCheckBoxValue;
	elseif _attrName = ETRow_AvaGrade then
		return self.getQryAvaGradesStr;
	elseif _attrName = ETRow_LastConnectDT then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.onDateTplType, self.onDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.onDateTplType, self.onDateTplFactor);
		endif;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);
*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="35ccf3a1-d4de-4a9e-bf79-f403e377628c">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	runDate				: Date;
begin
	runDate := self.systemToLocalTime(app.actualTimeServer()).Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_IsConnected then
		return self.connected.cnEcGetTableCheckBoxValue;
	elseif _attrName = ETRow_AvaGrade then
		return self.getQryAvaGradesStr;
	elseif _attrName = ETRow_LastConnectDT then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.onDateTplType, self.onDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.onDateTplType, self.onDateTplFactor);
		endif;
// cnwdad1 19/11/2010 - PAR #25218.
//	elseif _attrName = ETRow_FromPackByDate then
	elseif _attrName = ETRow_FromPackByDate or _attrName = ETRow_FromEstReqDate then	// 30 Dec 2010	NDL Par 26650
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.startDateTplType, self.startDateTplFactor);
		endif;
//	elseif _attrName = ETRow_ToPackByDate then
	elseif _attrName = ETRow_ToPackByDate or _attrName = ETRow_ToEstReqDate then	// 30 Dec 2010	NDL Par 26650
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.endDateTplType, self.endDateTplFactor);
		endif;
// cnwdad1 19/11/2010 - PAR #25218, END.
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQryAvaGradesStr" id="f794db3c-5131-4885-b541-b9878cf8784e">
        <source>getQryAvaGradesStr(): String;
//----------------------------------------------------------------
//	Created:	05 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str			: String;
	int			: Integer;
	mtGrade		: CM_MTGrade;
	mtGradeCode	: CM_MTGradeCode;
	canDisplay	: Boolean;
begin
	
	foreach int in self.allQryAvaGrades do
		mtGrade := app.myRoot.allAvailabilityGrades[int];
		if mtGrade &lt;&gt; null then
			mtGradeCode := null;
			mtGrade.getTranslationForOperator(mtGrade, self.myOperator, self.getMyOperatorGroup, mtGradeCode, canDisplay);
			if mtGradeCode &lt;&gt; null then
				str := str.appendCommaSeparatedValue(mtGradeCode.code, false);
			elseif canDisplay then
				str := str.appendCommaSeparatedValue(int.String, false);
			endif;
		endif;
	endforeach;
	
	if str.length &gt; 30 then
		str := str[1:27] &amp; "...";
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQryPackAreasStr" id="7521a921-949b-4b57-8eba-9ba593fd6929">
        <source>getQryPackAreasStr(): String;
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str			: String;
	area		: CM_TerminalArea;
//	mtGrade		: CM_MTGrade;
//	mtGradeCode	: CM_MTGradeCode;
	canDisplay	: Boolean;
begin
	
	foreach area in self.allQryPackAreas do
		str := str.appendCommaSeparatedValue(area.id, false);
	endforeach;
	
	if str.length &gt; 128 then
		str := str[1:125] &amp; "...";
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestCountForDetail" id="84e3a630-b2e9-470c-b43e-740f73a7ba34">
        <source>getRequestCountForDetail(_mtRepDetail: CMIF_MTReportDetail input);
//----------------------------------------------------------------
//	Created:	28 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj				: Any;
	bulk 			: CM_BulkRelease;
	opTerm			: CM_OperatorTerminal;
	passport 		: CM_Passport;
	coll			: Collection;
	theOp			: CM_Operator;
	numRequest		: Integer;
	term			: CM_Terminal;
	reqsOutstanding	: Integer;
begin
	passport	:= app.myPassport;
	numRequest	:= 0;
	theOp		:= app.myRoot.allOperators[_mtRepDetail.operatorCode];
	
	if theOp = null then
		_mtRepDetail.requestCount := 0;
		return;
	endif;
	
	foreach term in self.allTerminals do
		opTerm := theOp.getOperatorTerminal(term, false);
		if opTerm &lt;&gt; null then
			coll := opTerm.allBulkReleases;
		endif;
		
		if coll &lt;&gt; null then
			foreach obj in coll discreteLock do
				bulk := obj.CM_BulkRelease;
				if _mtRepDetail.matchesBR(bulk, reqsOutstanding) then
					numRequest :=  numRequest + reqsOutstanding;
				endif;
			endforeach;	
		endif;	
	endforeach;
	_mtRepDetail.requestCount := numRequest;

end;</source>
        <Parameter name="_mtRepDetail" type="CMIF_MTReportDetail" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includeGen" id="d4852c17-9e7c-46b6-93df-498e40b0d5f2">
        <source>includeGen(_ti: CM_TrackedItem; _passport: CM_Passport): Boolean;
//----------------------------------------------------------------
//	Created:	17 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;

begin
	if (self.myOperator = null or _ti.myOperator = self.myOperator)
	//	dont check ISOgroup - we want all generators for op / op group 
	and (self.getMyOperatorGroup = null or _ti.operatorBelongsToGrp(self.getMyOperatorGroup)) then
		if (not _ti.canUserAccessSelf(null, failedDAC, _passport)) then
			return false;
		endif;
	
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObjectForPackDate" id="72aa0b60-2400-407c-a580-173acd602185">
        <source>includeObjectForPackDate(_br: CM_BulkRelease):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		19 November 2010
//
// Purpose:		Refer to "Dialogue" comments for CCMS 1934.
//
// Parameters:	_br - A reference to the Bulk Release.
//
// Returns:		True if the pack date range is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation. PAR #25218.
// --------------------------------------------------------------------------------
begin
	if self.fromPackByDate &lt;&gt; null
	and self.fromPackByDate.isValid()
	and self.toPackByDate &lt;&gt; null
	and self.toPackByDate.isValid()
	then
		if _br.dateEstimatedRequired = null
		or not _br.dateEstimatedRequired.isValid()
		then
			return false;
		else
			if _br.dateEstimatedRequired.date() &lt; self.fromPackByDate
			or _br.dateEstimatedRequired.date() &gt; self.toPackByDate
			then
				return false;
			endif;
		endif;
	endif;
	
	if self.fromPackByDate &lt;&gt; null
	and self.fromPackByDate.isValid()
	and self.toPackByDate = null
	then
		// Note, if the Bulk Release's estimated date required is null, this will allow it thru.
		if _br.dateEstimatedRequired &lt;&gt; null
		and _br.dateEstimatedRequired.isValid()
		then
			if _br.dateEstimatedRequired.date() &lt; self.fromPackByDate then
				return false;
			endif;
		endif;
	endif;
	
	if self.fromPackByDate = null
	and self.toPackByDate &lt;&gt; null
	and self.toPackByDate.isValid()
	then
		if _br.dateEstimatedRequired = null
		or not _br.dateEstimatedRequired.isValid()
		then
			return false;
		else
			if _br.dateEstimatedRequired.date() &gt; self.toPackByDate then
				return false;
			endif;
		endif;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_br" type="CM_BulkRelease"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="731af6f5-5629-49ff-a9f7-6153ff7fd82a">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _ti.cargoType = TI_CargoType_Container and inheritMethod(_ti, _passport, _breakOut) then
		if (self.allQryAvaGrades.isEmpty or self.allQryAvaGrades.includes(_ti.CM_Container.availabilityGrade)) then
			return true;
		endif;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="b4fb6adc-36d5-4471-bb01-b4043406336c">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData : CM_EventDataByTypeDict) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _runDate, _allEventData);

	self.onDate	:= self.setDateFromTemplate(self.onDateTplType, self.onDateTplFactor, _runDate);

// cnwdad1 19/11/2010 - PAR #25218.
	self.fromPackByDate	:=	self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, _runDate);
	self.toPackByDate	:=	self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, _runDate);
end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
</Class>
