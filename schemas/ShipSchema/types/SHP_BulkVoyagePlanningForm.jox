    <JadeMethod name="getBulkDrawingFrame" id="2699e114-a79c-4ac7-8ab8-11997aac8f81">
        <source>getBulkDrawingFrame(maxFrames : Integer io) : SHP_BulkDrawingFrame;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	frame : SHP_BulkDrawingFrame;

begin
	maxFrames := maxFrames + 1;
	frame := self.frmBay.getControl(maxFrames).SHP_BulkDrawingFrame;
	if frame = null then
		frame := self.frmBay.loadControl(maxFrames).SHP_BulkDrawingFrame;
	endif;
	frame.caption := null;
	frame.transparent := true;

	return frame;
epilog

end;</source>
        <Parameter name="maxFrames" type="Integer" usage="io"/>
        <ReturnType type="SHP_BulkDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="getDisplayMode" id="1900c2b5-a7c7-444d-8d28-b0453cd795e8">
        <source>getDisplayMode(): Integer;
//
// Purpose:			This is called via a callback method
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/02/2016	cnwdap1		Initial creation PAR #36766
//
vars
	mode : Integer;

begin
	mode := self.myBulkDrawingController.actPlanQueMode;
	if mode = ShpDisplayMode_Actual then
		return DISPLAY_MODE_ACTUAL;
	elseif mode = ShpDisplayMode_Proposed then
		return DISPLAY_MODE_PLAN;
	elseif mode = ShpDisplayMode_Queued then
		return DISPLAY_MODE_QUEUE;
	else
		return DISPLAY_MODE_ACTUAL;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForObject" id="8cba1ff9-94d2-4f1b-8792-dd8b9d1f4dd4">
        <updating/>
        <source>getExtraInfoForObject(_obj: Object; _dataContainer: CM_DataContainer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	ti : CM_TrackedItem;
	gcController : CM_GeneralCargoController;
	shipController : CM_ShipBlockController;
	bulkDrawingFrame : SHP_BulkDrawingFrame;
	object : Object;
	locationsController : CM_LocationsController;
	myNeighbour	: CM_SlotController;
	voyage : CM_Voyage;
	amInEDIMode : Boolean;
	slotRequest : CM_SlotRequest;
	block : CM_DataContainerBlock;
	wle : CM_WorkListEntry;
	slotDefn : CM_SlotDefn;
	bay : CM_Bay;
	ediIndex,
	numTIs : Integer;
	cellDef : CM_CellDefn;
	dummyContainer : CM_DataContainer;
	dummyBlock : CM_DataContainerBlock;
	dummyItem : CM_DataContainerItem;
	dummyIcon : CM_DataContainerIcon;

begin
	if _obj = null then
		return;
	endif;

	if (not CM_ShipBlockController.hasInstance(_obj) and 
	not CM_GeneralCargoController.hasInstance(_obj) and
	not SHP_BulkDrawingFrame.hasInstance(_obj)) then
		return;
	endif;
	
	self.picCargo.picture := null;
	
	if CM_GeneralCargoController.hasInstance(_obj) then
		gcController := _obj.CM_GeneralCargoController;
	elseif CM_ShipBlockController.hasInstance(_obj) then
		shipController := _obj.CM_ShipBlockController;
	elseif SHP_BulkDrawingFrame.hasInstance(_obj) then
		bulkDrawingFrame := _obj.SHP_BulkDrawingFrame;
	endif;
	
	if gcController &lt;&gt; null then
		gcController.getExtraInfo(_dataContainer);
	elseif shipController &lt;&gt; null then
		shipController.getExtraInfo(_dataContainer);
	elseif bulkDrawingFrame &lt;&gt; null then
		bulkDrawingFrame.getExtraInfo(_dataContainer);
	endif;
	
	if app.isSpecial() then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Bay Point", DC_Label, 1, self.myBulkDrawingController);
		block.addNewItem(self.myBulkDrawingController.String, DC_Data, 1, self.myBulkDrawingController);
		
		block := _dataContainer.addNewBlock;
		if gcController &lt;&gt; null then
			block.addNewItem("General Cargo Controller", DC_Label, 1, gcController);
			block.addNewItem(gcController.String, DC_Data, 1, gcController);
		elseif shipController &lt;&gt; null then
			block.addNewItem("Ship Controller", DC_Label, 1, shipController);
			block.addNewItem(shipController.String, DC_Data, 1, shipController);
		endif;
	endif;
	
epilog
	delete dummyContainer;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoTI" id="acc1d9db-b1ee-4fa3-9b9b-3c37fff9abda">
        <source>getExtraInfoTI(_controller : CM_LocationsController; _dataContainer : CM_DataContainer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	ti : CM_TrackedItem;
	numTIs,
	idx : Integer;
	block : CM_DataContainerBlock;
	theTIs : CM_TIArray;

begin
	if _controller = null then
		return;
	endif;

	if self.displayMode = ShpDisplayMode_Actual or self.displayMode = ShpDisplayMode_EDI then
		theTIs := _controller.allTrackedItems;
   	elseif self.displayMode = ShpDisplayMode_Proposed then
   		create theTIs transient;
		_controller.getProposedTIs(theTIs);
	endif;

	if theTIs &lt;&gt; null then
		numTIs := theTIs.size;
		if numTIs = 1 then
			ti := theTIs.first;
			if ti &lt;&gt; null then	
				ti.getExtraInfo(_dataContainer);
			endif;
		else
			foreach ti in theTIs do
				if ti &lt;&gt; null then	
					idx := idx + 1;
					ti.getExtraInfo(_dataContainer);
					if numTIs &lt;&gt; idx then
						block := _dataContainer.addNewBlock;
						block.addNewItem(GridPointStringMoreCargo, DC_MoreInfo, 1, null);
					endif;
				endif;
			endforeach;
		endif;
   	endif;

epilog
	if self.displayMode = ShpDisplayMode_Proposed then
		delete theTIs;
	endif;
end;</source>
        <Parameter name="_controller" type="CM_LocationsController"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfColumns" id="64dfe1d8-f24a-43f6-8bcd-2625540bb194">
