    <JadeMethod name="doAutoPlanMoveIt" id="7a2e60e4-bf2e-4398-9bed-7f3beb2997d1">
        <updating/>
        <source>doAutoPlanMoveIt( moveMode : Integer ) protected, updating;
// -------------------------------------------
// Created 16 February 2005 by cnwdvb1
// -------------------------------------------
vars

	result			: Integer;
	str				: String;
	params : CMIF_AutoplanParams;

begin

	// PAR 19450
	create params transient;
	if moveMode = AUTO_PLAN_ONLY_MODE then	//18 July 2014	NDL	Par 34602
		params.moveMode := PLANNING_MODE;
	else
		params.moveMode := QUEUE_MODE;
	endif;
	params.myTerminalArea := self.cmbTermArea.listObject.CM_TerminalArea;
	params.myJob := null;
	params.showWarningWhenNoPlan := true;
	self.allTrackedItems.copy(params.allTrackedItems);


	while true do
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	
epilog

	delete params;
end;</source>
        <access>protected</access>
        <Parameter name="moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="94f11776-0d7c-459e-8475-a4b7b82ea3cc">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	rtValue : Integer;
begin
	if self.tblMove.hasChanged then
		rtValue := app.msgBox("You have changed data on the table." &amp; Cr &amp; "Do you want to continue?","Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if rtValue = MsgBox_Return_No then
			return;
		endif;
	endif;
	inheritMethod();
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveIt" id="f9806eb4-7ccd-43d6-a63a-099cc1785023">
        <updating/>
        <source>doMoveIt()updating, protected;
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//19/01/2015 cnwma1 PAR #35204  Machine History not including Instant Moves
//30/07/2019 jlgzm1	TFS 42863 Direct Release Between RORO Voyages and Rail - Break Bulk
//--------------------------------------------------------------
vars
//	wle 				: CM_WorkListEntry;
//	req : CM_Request;
	moveController		: CMIF_MoveController;
	currentLocn,
	targetLocn			: CM_LocationsController;
	tmpCombo			: ComboBox;
	lcnStr,
	str					: String;

	result,
	weight		: Decimal[14,4];	
	moveMode,
	volume,
	quantity 			: Integer;
	machine			:CM_Machine;
	ti  ,currentTI				: CM_TrackedItem;
	tis : CM_TISet;
	showMoveConfirmation: Boolean;
	origWLE				: CM_WorkListEntry;
begin

	app.mousePointer := MousePointer_HourGlass;	
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	//tmpCombo := self.tblMove.accessCell(self.tblMove.getRowByName(ETRow_MoveType), self.tblMove.ColumnValue).cellControl.ComboBox;	
	//moveMode := tmpCombo.itemData[tmpCombo.listIndex].Integer;
	str := self.tblMove.getValueByName(ETRow_MoveType).String;
	moveMode	:= app.moveModeStringToMoveMode(str);
	
	if moveMode &lt;&gt; AUTO_PLAN_MODE  
	and moveMode &lt;&gt; QUEUE_PLAN_ON_PICKUP 
	and moveMode &lt;&gt; AUTO_PLAN_INSTANT_MODE // TFS 6536
	and moveMode &lt;&gt; AUTO_PLAN_ONLY_MODE then
		targetLocn := self.getTargetLocation(true);
	endif;
	currentTI:=self.myCurrentTI;
	if self.myCurrentTI = null and not self.isMultipleMove then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Id', ETRow_CargoId, null);
		app.raiseCMException(Input_required_field_cargoId, ETRow_CargoId, null); // cnwdb2	PAR 35364
	endif;

	// PAR 17496
	if self.myCurrentTI &lt;&gt; null then
		if self.myCurrentTI.isOffSite() then
			app.msgBox(self.myCurrentTI.id &amp; " is currently offsite, cannot be moved.", "Move Error",MsgBox_OK_Only);
			return;
		
		endif;
	endif;

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_Add);
		return;
	endif;

	
	if targetLocn &lt;&gt; null then
		lcnStr := targetLocn.getFullId();
	elseif self.cmbTermArea.listObject &lt;&gt; null then
		lcnStr := 'Terminal Area ' &amp; self.cmbTermArea.listObject.CM_TerminalArea.getID();
	else
		lcnStr := app.getErrorString(Unknown);
	endif;
	
	if moveMode = INSTANT_PACK_MODE then
		self.doPackAndMove( moveMode );
		return;
	endif;
	
	if moveMode = AUTO_PLAN_MODE 
	or moveMode = AUTO_PLAN_ONLY_MODE 	//18 July 2014	NDL	Par 34602
	or moveMode = AUTO_PLAN_INSTANT_MODE then // TFS 6536
		if app.msgBox(app.getErrorString2(UiAPMoveTrackedItem, str, self.getIDs() ), app.getErrorString(ConfirmMove) &amp; " - " &amp; self.allTrackedItems.size.String &amp; " Items", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
	else
		if app.msgBox(app.getErrorString3(UiMoveTrackedItem, str, self.getIDs(), lcnStr), app.getErrorString(ConfirmMove) &amp; " - " &amp; self.allTrackedItems.size.String &amp; " Items", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	if moveMode = AUTO_PLAN_INSTANT_MODE then // TFS 6536
		self.doAutoPlanMoveIt( AUTO_PLAN_ONLY_MODE ); // TFS 6536
		
		create tis transient; // TFS 6536
		self.allTrackedItems.copy(tis); // TFS 6536
		app.myTrxUA.trxMoveTrackedItemsToPlannedLC(tis,REAL_MODE,null,app.myPassport,VESSEL_TYPE_LOLO); // TFS 6536
		return; // TFS 6536
	
	endif;
	if moveMode = AUTO_PLAN_MODE or moveMode = AUTO_PLAN_ONLY_MODE then
		self.doAutoPlanMoveIt( moveMode );
		
		return;
	endif;
	
	if moveMode = QUEUE_PLAN_ON_PICKUP then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		self.doQueuePlanLater();
		return;
	endif;

	create moveController transient;
	//jlier1 TFS 53515 27/5/22
	if self.myCurrentTI &lt;&gt; null then
		quantity := self.tblMove.getValueByName(ETRow_Quantity).Integer; //self.getQuantity();
		moveController.setQuantity(quantity);
		weight := self.getWeight();
		moveController.setWeight(weight);
	endif;
	
	if self.myCurrentTI = null then
		self.setMyCurrentTI(self.allTrackedItems.first);
		moveController.setMyTrackedItem(self.allTrackedItems.first);	
		moveController.setAllOtherTrackedItems(self.allTrackedItems);
		moveController.allOtherTrackedItems.remove(moveController.myTrackedItem);
	else
		moveController.setMyTrackedItem(self.myCurrentTI);
	endif;
	moveController.setMyToPrimaryLocation(targetLocn);

	moveController.setMoveMode(moveMode);
	
	// DVB CCMS 1235 15/09/04
	moveController.setMyMachine(cmbMachineId.myObject.CM_Machine);
	moveController.isNoChargeMove := tblMove.getValueByName(ETRow_NoCharge).Boolean;
	moveController.userAuthorityCode := tblMove.getValueByName(ETRow_RequestInfo).String;

	//jlier1 TFS 53515 27/5/22
	if targetLocn.isKindOf(CM_VoyageController) then
		moveController.isNonCraneVoyageMove := true;
	endif;
	
	self.getWorkListEntryForMove( moveController );	//20 Sep 2013	NDL	Par 32479
	
	showMoveConfirmation := app.myPassport.myTerminal.getConfig(HhShowUnplanOptions).Boolean;		// 8/9/17 MAP TFS6818
	if showMoveConfirmation then
		moveController.nonWorkedInstantPreMove();	//01 Aug 2013	NDL	Par 32140
	
		if moveController.priority = 888 then		// 28/6/17 MAP TFS4719
			return;		// user has cancelled attempt to move cargo already planned
		endif;
	endif;

	while true do
		if targetLocn.isWagon() then // 20556
			app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport); // 20556
		elseif targetLocn.isVoyagePlanningLC() then // PAR 31878
			origWLE := moveController.myWorkListEntry;		// TFS 42863
			app.myTrxUA.trxMoveTrackedItemAssignToJob(moveController, app.myPassport); // PAR 31878
		else
			app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// trxMoveTrackedItemAssignToJob used to reset myWorkListEntry in epilog
				// have had to move it up a level in case wle gets deleted during transaction
				if origWLE &lt;&gt; null then							// TFS 42863
					moveController.setMyWorkListEntry(origWLE);	// TFS 42863
				endif;											// TFS 42863
				
				continue;
			endif;
			break;
		endif;
		//break;
	endwhile;
	
	if app.myPassport.trxCompletedOK then
		// add Machine Move History   //19/01/2015 cnwma1 PAR #35204
		if moveMode = REAL_MODE  and self.cmbMachineId.listObject.CM_Machine &lt;&gt; null then
			machine := self.cmbMachineId.listObject.CM_Machine;
			while true do 
				foreach ti in self.allTrackedItems do
					app.myTrxCA.trxCreateInstantMoveHistory(machine,moveController.myOriginatingLocation.getFullId,targetLocn.getFullId,ti,moveController,app.myPassport);
				endforeach;
				if app.myPassport.trxCompletedOK then
					break;
				else
				result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					break;
				endif;
			endwhile;
		endif;
	endif;
	
epilog
	//jlier1 TFS 53515 27/5/22
	if self.isMultipleMove then
		self.setMyCurrentTI(null);
	else
		self.setMyCurrentTI(self.myCurrentTI);
	endif;
	delete moveController;
	app.mousePointer := MousePointer_Default;	
	delete tis; // TFS 6536
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveItMultiToGrid" id="c5ad7a4e-1c4a-4b14-be8d-9eae3192821b">
        <updating/>
        <source>doMoveItMultiToGrid()updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	moveModeTypeStr : String;
	moveMode : Integer;
	allSelectedTis : CM_TIArray;
	targetLocns : CM_LCArray;
	targetLocationStr : String;
	processedMoves : CM_TIArray;
	ti : CM_TrackedItem;
	idx : Integer;
	targetIsBlockCont : Boolean;
	targetLocn : CM_LocationsController;
begin

	app.mousePointer := MousePointer_HourGlass;
	
	moveModeTypeStr := self.tblMove.getValueByName(ETRow_MoveType).String;
	moveMode	:= app.moveModeStringToMoveMode(moveModeTypeStr);
	
	if (moveMode &lt;&gt; QUEUE_MODE and moveMode &lt;&gt; PLANNING_MODE) then
		//i.e. Not valid for QUEUE_PLAN_ON_PICKUP or AUTO_PLAN_MODE or REAL_MODE.
		//use the existing methods.
		self.doMoveIt();
		return;
	endif;
	
	// PAR 32308 - allow multi move to a single GC Shelf
	if (moveMode = QUEUE_MODE or moveMode = PLANNING_MODE) then
		targetLocn := self.getTargetLocation(true);
		if targetLocn &lt;&gt; null and targetLocn.isGCRackLC() then
			self.doMoveIt();
			return;
		endif;
	endif;
	
	// get the collection of tis to attaempt to move
	create allSelectedTis transient;
	self.multiItems.getSelected( allSelectedTis );
	
	//get the collection of target locations to consider ( in order )
	create targetLocns transient;
	if not self.getTargetLocationControllers( targetLocns, targetLocationStr ) then
		return;
	endif;
	
	//18 Nov 2011	NDL	Par 28692
	if targetLocns.size = 1 then
		//  PAR 34865 if targetLocns.first.isKindOf( CM_BlockController ) then
		//  PAR 34865	targetIsBlockCont := true;	//10 Sep 2012	NDL	Par 30211
		//  PAR 34865 endif;
		targetIsBlockCont := not targetLocns.first.isGridLocation(); //  PAR 34865
	endif;
	//jlier1 TFS 53515 27/5/22
	if targetLocns.size = 1 and targetLocns.first.isKindOf(CM_VoyageController) then
			self.doMoveIt();
		return;
	endif;
	
	create processedMoves transient;
	
	if targetIsBlockCont then
		//10 Sep 2012	NDL	Par 30211
		self.myAssistant.doBulkMovePdOrQdToBlock(	tblMove.getValueByName(ETRow_NoCharge).Boolean,	//_noChargeMove : Boolean;
													tblMove.getValueByName(ETRow_RequestInfo).String,	//_userAuthorityCode : String;
													moveMode,	//moveMode : Integer;
													allSelectedTis,	//_allTrackedItems : CM_TIArray;
													targetLocns.first, //  PAR 34865 .CM_BlockController,	//_targetLocn : CM_LocationsController;
													targetLocationStr,	//_targetLocationStr : String;
													processedMoves	//_processedMoves : CM_TIArray io
													);
												
	else
		self.myAssistant.doBulkMoveToGridArea(	tblMove.getValueByName(ETRow_NoCharge).Boolean,	//_noChargeMove : Boolean;
												tblMove.getValueByName(ETRow_RequestInfo).String,	//_userAuthorityCode : String;
												moveMode,	//moveMode : Integer;
												allSelectedTis,	//_allTrackedItems : CM_TIArray;
												targetLocns,	//_targetLocns : CM_LCArray;
												targetLocationStr,	//_targetLocationStr : String;
												processedMoves	//_processedMoves : CM_TIArray io
												);
											
	endif;
	
	foreach ti in processedMoves do
		self.allTrackedItems.remove( ti );
		idx := self.multiItems.mySelectedListBox.findObject(ti);
		if idx &gt; 0 then
			self.multiItems.mySelectedListBox.removeItem(idx);
		endif;
	endforeach;
	
	self.setMyCurrentTI(null);

epilog

	delete targetLocns;
	delete processedMoves;
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPackAndMove" id="7eb54c09-145e-4522-b84b-c0e7ac823389">
        <source>doPackAndMove( _moveMode : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/06/2014	cnwndl1	Initial creation	Par 34665
11/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars

	targetParent : CM_TrackedItem;
	allSelectedTis : CM_TIArray;
	ti : CM_TrackedItem;
	msg : String;
	header : String;
	setParentFromChild : Boolean;
	packTi : CM_TrackedItem;
	result : Integer;

begin

	if _moveMode &lt;&gt; INSTANT_PACK_MODE then
		return;
	endif;
	
	targetParent := self.cmbParent.listObject.CM_TrackedItem;
	if targetParent = null then
		app.msgBox( app.getErrorString(Must_choose_parent_pack_into), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	create allSelectedTis transient;
	self.multiItems.getSelected( allSelectedTis );
	if allSelectedTis.isEmpty and self.myCurrentTI &lt;&gt; null then		// TFS 46405
		allSelectedTis.add(self.myCurrentTI);						// TFS 46405
	endif;															// TFS 46405
	
	if allSelectedTis.includes( targetParent ) then
		app.msgBox( app.getErrorString(Cannot_pack_cargo_inside_itsel) &amp; " [" &amp; targetParent.id &amp; "]", app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	foreach ti in allSelectedTis do
		if ti.isChild then
			msg := app.getErrorString4(Cargo_already_packed, ti.id, targetParent.id, ti.id, targetParent.id );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			return;
		endif;
	endforeach;
	
	if ( not targetParent.allChildren.isEmpty ) then
		packTi := targetParent.allChildren.first;
	else
		packTi := allSelectedTis.first;
	endif;
	foreach ti in allSelectedTis do
		if ( ti.myVoyage &lt;&gt; packTi.myVoyage
		or ti.dischargePort &lt;&gt; packTi.dischargePort
		or ti.getImExStatus &lt;&gt; packTi.getImExStatus
		) then
			//make sure the childrens (delivery details) match the parents
			msg := app.getErrorString2( Voyag_imex_disch_port_Mismatch, packTi.id, ti.id );
			app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
			return;
		endif;
	endforeach;
	
	msg := app.getErrorString2(Pack_cargo_items_into, self.getIDs(), targetParent.id);
	header := app.getErrorString1(ConfirmAction,app.getErrorString(Pack)) &amp; " - " &amp; self.allTrackedItems.size.String &amp; " Items";
	if app.msgBox( msg , header, MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;

	app.mousePointer:=Window.MousePointer_HourGlass;
	
	msg := null;
	setParentFromChild := ( targetParent.allChildren.isEmptyOrContainsOnlyEquipment and targetParent.isStorage );	//24 Apr 2015	NDL	Par 36111
	
	foreach packTi in allSelectedTis do
	
		while true do
	
			app.myTrxUA.trxUpdatePackCargo(targetParent, packTi, ti.totalQuantity, ti.totalWeight, setParentFromChild,null, null,false,null, app.myPassport);		//19.03.2024 navhl20 #62863
	
			if app.myPassport.trxCompletedOK() then
				setParentFromChild := false;	//only valid for the first one
				break;
				
			else
				result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); // ErrWarnMode_Update); ErrWarnMode_AddUpdate
				if app.myPassport.noErrors()
				and result = IDOK
				then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
				break;
			endif;
			
		endwhile;
	
	endforeach;
	

epilog

	delete allSelectedTis;

end;</source>
        <access>protected</access>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueuePlanLater" id="9ddd2f34-f7de-4910-b0cc-833fed8eb3c5">
        <updating/>
        <source>doQueuePlanLater() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2011	cnwrd1	Initial creation

*/

vars
	result			: Integer;
	str				: String;
	params : CMIF_PlanOnPickup;

begin

	create params transient;
	params.moveMode := QUEUE_PLAN_ON_PICKUP;
	params.myTargetTA := self.cmbTermArea.listObject.CM_TerminalArea;
	params.myJob := null;
	self.allTrackedItems.copy(params.allTrackedItems);

	while true do
		str := app.myTrxUA.trxUpdateQueuePlanOnPickup(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	
epilog
	delete params;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="3bb9be06-b01b-42fb-b49e-de7e989d9499">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	height	: Real;

begin

	self.fldMove.top := self.frmToolbar.height;
	
	height := self.clientHeight - self.frmToolbar.height;
	self.fldMove.height := height;	
	
	self.frmToolbar.repositionAfterResize();
	if self.multiItems.visible then
		self.multiItems.cnEcResizeContents();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getIDs" id="f883fbf2-6370-4cf1-9b83-125ce962995a">
        <source>getIDs() : String protected;
// -------------------------------------------
// Created 18 February 2005 by cnwdvb1
// -------------------------------------------
vars

	idStr	: String;
	ti		: CM_TrackedItem;

begin

	if self.isMultipleMove then
		self.allTrackedItems.clear();
		self.multiItems.getSelected(self.allTrackedItems);
		foreach ti in self.allTrackedItems do
			idStr := idStr &amp; ', ' &amp; ti.id;
		endforeach;
		if idStr.length &gt; 1 then
			idStr := idStr[3:end];
		endif;
	else
		if self.myCurrentTI &lt;&gt; null then
			idStr := self.myCurrentTI.id;
		endif;	
	endif;
	
	return idStr;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocation" id="93502bff-ccef-48c5-816f-0b7f65e32ed9">
        <updating/>
        <source>getTargetLocation( _raiseError : Boolean ) : CM_LocationsController updating, protected;
//--------------------------------------------------------------
//Created: 07 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	targetController : CM_LocationsController;
	tmpTA : CM_TerminalArea;
	foundHeight : Integer;
	newLocn,
	tmpStr : String;
begin

	// Se if they have entered a location string
	newLocn := tblMove.getValueByName(ETRow_NewLocn).String;
	newLocn := newLocn.trimBlanks;
	if self.cmbTermArea.listObject.isKindOf(CM_TerminalArea) then
		tmpTA := self.cmbTermArea.listObject.CM_TerminalArea;
	endif;
	
	 //jlier1 TFS 53515 23/5/22 
	if self.tblMove.isRowVisible(ETRow_TerminalArea) then
		if self.cmbYardLocation.listObject &lt;&gt; null then
			
			if tmpTA &lt;&gt; null and tmpTA.isRTGArea() then
				tmpStr := self.tblMove.getValueByName(ETRow_TerminalArea).String  &amp; self.tblMove.getValueByName(ETRow_YardLocation).String;
			else
				tmpStr := self.tblMove.getValueByName(ETRow_TerminalArea).String &amp; ' ' &amp; self.tblMove.getValueByName(ETRow_YardLocation).String;
			endif;
			// changed as full location (terminal + yard) can be listed in ETRow_NewLocn HG 11/01/05
			if tmpStr &lt;&gt; null then
				targetController := self.cmbYardLocation.listObject.CM_LocationsController;
			endif;
		elseif tmpTA &lt;&gt; null then
			tmpStr := self.tblMove.getValueByName(ETRow_TerminalArea).String;
			if tmpStr &lt;&gt; null then	
				targetController := tmpTA.getLocationsController();	
			endif;
		endif;
	elseif self.tblMove.isRowVisible(ETRow_CurrentVoyages) then  //jlier1 TFS 53515 23/5/22 
		if self.cmbLoadLocation.listObject &lt;&gt; null then
			tmpStr := self.tblMove.getValueByName(ETRow_CurrentVoyages).String &amp; ' ' &amp; self.tblMove.getValueByName(ETRow_LoadLocation).String;
			// changed as full location (terminal + yard) can be listed in ETRow_NewLocn HG 11/01/05
			if tmpStr &lt;&gt; null then
				targetController := self.cmbLoadLocation.listObject.CM_LocationsController;
			endif;
		endif;
	endif;
	
	if targetController &lt;&gt; null then
		if newLocn = null or newLocn = tmpStr.trimBlanks then
			return targetController;
		endif;
	endif;

	self.myTerminal.findLocationFromString(newLocn, false, targetController, foundHeight);

	if targetController = null then
		if _raiseError then
			app.raiseCMException1(ERR_INVALID_LOCN, newLocn, ETRow_NewLocn, null);
		endif;
	endif;

	return targetController;
	
end;</source>
        <access>protected</access>
        <Parameter name="_raiseError" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocationControllers" id="488045be-7502-434c-8578-e1004bfbd3fa">
        <source>getTargetLocationControllers( _targetLocns : CM_LCArray io; _lcnStr : String output ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2011	cnwndl1	Initial creation	Par 28035
						Find the target location controllers for the selected areas in 'decking in' order 

*/

vars

	userSelectedLocns : CM_LCArray;
	allTargetAreaLocnsInOrder : CM_LCArray;
	targetString : String;
	looksLikeTermArea : Boolean;
	topLeft, bottomRight: CM_LocationsController;	
	targetTermArea : CM_TerminalArea;	
	targetLocn : CM_LocationsController;
	yaLocnCells: CM_YALocationCellArray;
	yaCell : CM_YALocationCell;
	locn : CM_YardController;
	yaAgent: CM_YAAgent;	
	msg : String;

begin

	_targetLocns.clear();
	
	// get the target area entered by the user and attempt to decipher it.
	targetString := tblMove.getValueByName(ETRow_NewLocn).String;
	_lcnStr := targetString;
	looksLikeTermArea := self.myTerminal.findYABlock(targetString, topLeft, bottomRight, null);
	
	//Ok we have something that thinks its a target terminal area.
	if looksLikeTermArea then
	
		if topLeft &lt;&gt; null and topLeft.myTerminalArea &lt;&gt; null then
			targetTermArea := topLeft.myTerminalArea.CM_TerminalArea;
		else
			msg := app.getErrorString1(Not_recognised_valid_location,targetString);
			app.msgBox(msg, app.getErrorString(Multi_move) ,MsgBox_OK_Only);
			return false;
		endif;
		
		if targetTermArea.isKindOf(CM_YardInterchangeArea) then
			msg := app.getErrorString(Select_area_not_interc_area);
			app.msgBox(msg, app.getErrorString(Multi_move) ,MsgBox_OK_Only);
			return false;
		endif;
		
		_lcnStr := targetTermArea.id;
		
		// convert the string to a range of locations.
		create yaAgent transient;
		create userSelectedLocns transient;
		
		yaAgent.findAllLocations(topLeft, bottomRight, userSelectedLocns);
		
		//get a collection of all locations in the terminal areas 'decking in' order.
		// but only the ones that have space available (I.e. nothing in or queued or planned to that specific cell)
		yaLocnCells := targetTermArea.myYADeckingOptions.allYALocationCellsIn;
		
	else
		//jlier1 TFS 53515 23/5/22 
		if self.tblMove.isRowVisible(ETRow_CurrentVoyages) then  
			if self.cmbLoadLocation.listObject &lt;&gt; null then
					targetLocn := self.cmbLoadLocation.listObject.CM_LocationsController;
					if targetLocn &lt;&gt; null then
							_targetLocns.add( targetLocn );
					endif;
			endif;
		endif;
		if 	_targetLocns.isEmpty then
			msg := app.getErrorString1(Not_recognised_valid_location,targetString);
			app.msgBox(msg, app.getErrorString(Multi_move) ,MsgBox_OK_Only);
			return false;
		else
			return true;
		endif;
	endif;
	
	create allTargetAreaLocnsInOrder transient;
	
	if yaLocnCells &lt;&gt; null then
		foreach yaCell in yaLocnCells do
			if yaCell.isAvailForMultiMove() then
				locn := yaCell.myYardController;
				if locn &lt;&gt; null then
					allTargetAreaLocnsInOrder.add( locn );
				endif;
			endif;
		endforeach;
	else
		//To deal with any that do not use decking options...
		msg := app.getErrorString1(Not_recognised_valid_location,targetString);
		app.msgBox(msg, app.getErrorString(Multi_move) ,MsgBox_OK_Only);
		return false;
		
	endif;
	
	// add in 'the decking in' order the ones that are in both collections.
	foreach targetLocn in allTargetAreaLocnsInOrder do
		if not userSelectedLocns.includes(targetLocn) then
			continue;
		endif;
		if not targetLocn.isAvailForMultiMove() then
			// it is occupied in some way. Actual, Queued or Planned.
			continue;
		endif;
		_targetLocns.add( targetLocn );
	endforeach;
	
	
	if _targetLocns.isEmpty then
		app.msgBox( app.getErrorString(No_Locs_Found_For_multi_move), app.getErrorString(Move_error),MsgBox_OK_Only);
		return false;
	endif;
	
	return true;

epilog

	delete userSelectedLocns;
	delete allTargetAreaLocnsInOrder;
	delete yaAgent;

end;</source>
        <access>protected</access>
        <Parameter name="_targetLocns" type="CM_LCArray" usage="io"/>
        <Parameter name="_lcnStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWeight" id="fd38f093-87e7-4adb-a7d1-32e4d846e6b4">
        <source>getWeight() : Decimal;
/*
----------   ----------  --------------------------------------------------
Created:	05 December 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	volume	: Decimal[14,4];
begin
	if self.myCurrentTI = null then
		return null;
	endif;
	if self.myCurrentTI.myCargoType.isTrackByWeight then
		return self.tblMove.getMeasurementValueByName(ETRow_Weight).Decimal;
	else
		volume :=self.tblMove.getMeasurementValueByName(ETRow_Volume).Decimal;
		return volume * self.myCurrentTI.getDensity;
	endif;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWorkListEntryForMove" id="ce91f560-883d-4574-84e5-63723f92ee3d">
        <source>getWorkListEntryForMove( moveController : CMIF_MoveController io ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	tmpWle : CM_WorkListEntry;
	wle : CM_WorkListEntry;
	receiveWle : CM_WorkListEntry;
	targetLocn : CM_LocationsController;
	moveMode : Integer;
	req : CM_Request;
	hasMultipleWles : Boolean;
	form : CMUI_SelectWorkListEntry;
	allProspectWles : CM_WLESet;
	msg : String;
	moveTypeStr : String;
	moveLocn : String;

begin

	moveMode := app.moveModeStringToMoveMode( self.tblMove.getValueByName(ETRow_MoveType).String );
		
	hasMultipleWles := false;
	if self.myCurrentTI.canMergeBreakBulk and moveMode = REAL_MODE then
		create allProspectWles transient;
		foreach tmpWle in self.myCurrentTI.allWorklistEntries do
			if tmpWle.status = WLE_COMPLETED then
				continue;
			endif;
			allProspectWles.addNoDuplicates( tmpWle, false );
		endforeach;
		hasMultipleWles := 	allProspectWles.size &gt; 1;
	endif;
	
	if hasMultipleWles then
	
		app.mousePointer := MousePointer_Default;
		
		//we need the user to select the appropriate wle to associate this move with.
		create form transient;
		form.setMyTerminal( self.myTerminal );
		form.setProspectWles( allProspectWles );
		form.showModal();
		
		app.mousePointer := MousePointer_HourGlass;
		
		if form.modalResult = IDOK then
			wle := form.myUserSelectedWle;
			if wle &lt;&gt; null then
				moveController.setMyWorkListEntry(wle);	
				moveController.setJobForMove(wle.job);
			endif;
		endif;
		
		return;
	
	else
		// Just use the Pre-Break Bulk code....
		wle := self.myCurrentTI.getWLEforFailedAutoPlan();	// in case this move it is to override of a failed auto plan
		if wle &lt;&gt; null then
			moveController.setMyWorkListEntry(wle);	
			moveController.setJobForMove(wle.job);	
		endif;
		
		
		if self.myCurrentTI &lt;&gt; null then
			targetLocn := moveController.myToPrimaryLocation;
			if targetLocn &lt;&gt; null then
				//check for a road receive wle
				receiveWle := self.myCurrentTI.getIncompleteRoadReceiveWle();
				
				if receiveWle = null then
					//check for a rail receive wle
					receiveWle := self.myCurrentTI.getIncompleteRailReceiveWle();
				endif;
				
				if receiveWle = null then
					//check for a ship receive wle
					if targetLocn.isVoyagePlanningLC() and moveMode = PLANNING_MODE then
						req := targetLocn.getRequest(true);
						if req &lt;&gt; null then
							receiveWle := req.getFirstUnactionedWLE(moveMode);
						endif;
					endif; 
				endif;
			
			endif;
		
		endif;
		
		if receiveWle &lt;&gt; null and receiveWle &lt;&gt; wle then
			// we have a receive wle and its not our failed auto plan one...
			
			if receiveWle.getTargetLocation = moveController.myToPrimaryLocation then
				//but the same target location as the receive, so just use the wle.
				moveController.setMyWorkListEntry(receiveWle);
				moveController.setJobForMove(receiveWle.job);
				
			else
				//There is a Receive job associated with this move but with a different target location,
				//ask the user if they want to associate it.
				moveLocn := receiveWle.locationTarget.trimBlanks;
				if receiveWle.isQueued then
					moveTypeStr := "Queued";
				else
					moveTypeStr := "Planned";
					if moveLocn = null then
						moveLocn := "Undefined Location";
					endif;
				endif;
				
				msg := app.getErrorString2( Is_replacement_move, moveTypeStr, moveLocn );//"This item is '%1' to '%2', does this move replace it?";
				
				app.mousePointer := MousePointer_Default;
				
				if app.msgBox(msg, app.getErrorString(Continue), MsgBox_Yes_No) = MsgBox_Return_Yes then
					moveController.setMyWorkListEntry(receiveWle);
					moveController.setJobForMove(receiveWle.job);
				else
					moveController.userSpecifiedTheWle := true; // It is null and we want it to stay that away.
				endif;
				
				app.mousePointer := MousePointer_HourGlass;
			endif;
			
			
			
		endif;
	
	endif;

epilog

	delete allProspectWles;

end;</source>
        <access>protected</access>
        <Parameter name="moveController" type="CMIF_MoveController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="378333fc-f187-44d3-8cc7-609b1e012c19">
        <updating/>
        <source>initForm(_ti:CM_TrackedItem) updating;
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 17/01/2018	jlgdap1		TFS 36658 STWR Cargo Scanning Enhancements
//							Cargo Groups can only be planned
vars
	entTableDef : EntTableDef;
	currentLocn : CM_LocationsController;
	newLocn, 
	tmpModes			: String;
	tmpCargoTypeDict : CM_CargoTypesByIdDict;
begin
	if self.isMultipleMove then
		self.shtItems.visible := true;
		self.setupMultiItems();
		self.multiItems.cnEcResizeContents();
		
		// TFS 36658 if we're moving cargo group(s), disable the Items selection 	// TFS 36658
		// control, and disable the Move Type row in the table						// TFS 36658
		if allTrackedItems.first.isCargoGroupItem then								// TFS 36658
			self.multiItems.enabled := false;										// TFS 36658
		endif;																		// TFS 36658
	else
		self.shtItems.visible := false;
	endif;

	self.tblMove.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef(ETDef_MoveTo);
	self.tblMove.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	//epr par 36096 11/5/15
	self.resetMeasurementRows(self.tblMove);																								
	self.loadMeasurementTypes(self.tblMove, self.tblMove.myEntTableDef.name, self.tblMove.myEntTableDef.allEntTableRows, true);	

	
	create tmpCargoTypeDict transient;
	
	if self.isMultipleMove then
		self.tblMove.showHideRowsByViewName('viewMultipleTis', CM_EntryTable.ShowHideRows, false);
		self.tblMove.hideRowByName(ETRow_Quantity,false);
		self.tblMove.hideRowByName(ETRow_Weight,false);
		self.tblMove.hideRowByName(ETRow_Volume,false);
		self.myAssistant.comboBoxTAType(cmbTAType,null, true);	
		self.loadTACombos(null, null);
	else
		self.tblMove.showHideRowsByViewName('viewSingleTi', CM_EntryTable.ShowHideRows, false);
		
		if _ti &lt;&gt; null then
			//we've just passed in the currentTI - so no point doing this 
			//YES THERE IS AS IT POPULATES THE FROM LOCATION AND TO LOCATION IF QUEUED OR PLANNED 
			//these rows are disabled so no point loading other stuff
			self.cmbCargoType.itemObject[self.cmbCargoType.addItem(_ti.myCargoType.description)] := _ti.myCargoType;
			self.cmbCargoType.listObject := _ti.myCargoType;
			
			self.cmbCargoId.itemObject[self.cmbCargoId.addItem(_ti.id)] := _ti;
			self.cmbCargoId.listObject := _ti;
			self.cmbCargoId.lostFocus(cmbCargoId);	
			
			self.tblMove.disableRowByName(ETRow_CargoType);
			self.tblMove.disableRowByName(ETRow_CargoId);
			
			self.setMyCurrentTI(_ti);	//this does loadTACombos
		else
			//epr par 36096 11/5/15
			self.tblMove.hideRowByName(ETRow_Quantity,false);
			self.tblMove.hideRowByName(ETRow_Weight,false);
			self.tblMove.hideRowByName(ETRow_Volume,false);
			//self.myAssistant.comboBoxCargoTypes(cmbCargoType, app.myPassport.getDefaultCargoType());
			self.myAssistant.comboBoxCargoBolType(cmbCargoType, app.myPassport.getDefaultCargoType().id,true, true, true, true);
			self.myAssistant.comboBoxTrackedItemCmb(cmbCargoId, cmbCargoType.listObject.CM_CargoType.id, TI_STATE_NORMAL, null);		
			self.loadTACombos(null, null);
			self.setNavigatorHeading(self.caption);		
		endif;	
	endif;
	self.tblMove.setValueByName(ETRow_CargoType, cmbCargoType.text);
	
	// DVB CCMS 1235 15/09/04
	self.cmbMachineId.myTerminal := self.myTerminal;
	self.cmbMachineId.lostFocus(cmbMachineId);
	
	if self.isCargoGroup then														// TFS 36658
		tmpModes := app.getErrorString(Planned_Move);								// TFS 36658
	else																			// TFS 36658
		tmpModes := app.getErrorString(Instant_Move) &amp; Tab
					&amp; app.getErrorString(Queued_Move) &amp; Tab
					&amp; app.getErrorString(Planned_Move) &amp; Tab
					&amp; app.getErrorString(Auto_Planned_Queued_Move) &amp; Tab
					&amp; app.getErrorString(Auto_plan_instant_move) &amp; Tab // TFS 6536
					&amp; app.getErrorString(AutoPlan_On_Pickup) &amp; Tab
					&amp; app.getErrorString(Autoplan_plan_only);	//18 July 2014	NDL	Par 34602
	endif;																			// TFS 36658
	
	//31 July 2014	NDL	Par 34665
	//if _ti = null or not _ti.isChild then											// TFS 36658
	if (_ti = null or not _ti.isChild) and not self.isCargoGroup then				// TFS 36658
		tmpModes := tmpModes &amp; Tab &amp; app.getErrorString(Pack);	
	endif;
	
	self.myAssistant.comboBoxMoveModeSpecific(self.tblMove, ETRow_MoveType, self.initMoveType,tmpModes);	
	
	self.tblMove.setFocus();
	self.tblMove.moveFirst();

	if self.myCurrentTI &lt;&gt; null then
		self.tblMove.goToRowByName(ETRow_MachineId);
	else
		self.tblMove.goToRowByName(ETRow_CargoId);	
	endif;
	
	self.populateParents;	//31 July 2014	NDL	Par 34665
	
	//jlier1 TFS 53515 23/5/22
	self.tblMove.hideRowByName(ETRow_CurrentVoyages,false);
	self.tblMove.hideRowByName(ETRow_LoadLocation,false);
	self.myAssistant.comboBoxVoyageCurrent(self.cmbVoyages,null,true,false,false,true,false,false,true,false,false);
	
epilog
	delete tmpCargoTypeDict;	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="f0fda7f5-2541-4e1c-8c4d-9bb5d781ff3d">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theActiveControl	: Control;
	
begin

	inheritMethod(keyCode, shift);
	if keyCode = J_key_Tab then

		tblMove.handleFormTab(keyCode, shift, btnCancelBase, btnMoveIt);

		theActiveControl := app.activeControl;
		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.Control;
		endif;
		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
		
		self.populateParents();
	endif;
			
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadCargoId" id="d2a3b70b-e5f8-474c-bfcd-09ad03e9045e">
        <updating/>
        <source>loadCargoId()updating, protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpCargoType : Integer;
	obj : Object;
begin
    //tmpCargoType := cmbCargoType.listObject.CM_CargoBOLType.id;
	/*
		Date		 Who		Reason
    	4 July 2008	cnwdz2	    Par17431 - check type before performing downcasting and changed CM_CargoType to CMCargoBOLType
	*/
	obj := self.cmbCargoType.listObject;
	if obj.isKindOf(CM_CargoBOLType) then
		tmpCargoType := obj.CM_CargoBOLType.id;
	endif;
	
	self.myAssistant.comboBoxTrackedItemCmb(cmbCargoId, tmpCargoType, TI_STATE_NORMAL, null);
	self.setMyCurrentTI(null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="c8f1670d-6b1e-4769-b9eb-f6fb69454b8f">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	if self.allTrackedItems.size = 1 then
		self.initForm(self.allTrackedItems.first);	
	else
		self.initForm(null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTACombos" id="f21599bb-f4a4-43a5-a3f7-fea80f223fc8">
        <updating/>
        <source>loadTACombos(_taType : CM_TerminalAreaType; _theLocation : CM_LocationsController)protected, updating;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	
	ta		: CM_TerminalArea;
	type	: Integer;
	idx		: Integer;
begin
	
	type := TA_TYPE_NULL;
	
	if _taType &lt;&gt; null then
		type := _taType.type;
		if _theLocation &lt;&gt; null then
			ta := _theLocation.myTerminalArea;
		endif;
	endif;
	
	self.myAssistant.comboBoxTAType(cmbTAType, _taType, true);
	//jlier1 TFS 53515 23/5/22
	if self.showVoyageLocations then
		self.cmbTAType.addItem(app.getErrorString(ToVoyage));
	endif;
	self.tblMove.setValueByControlName(cmbTAType.name, cmbTAType.text);

	self.myAssistant.comboBoxTerminalArea(cmbTermArea, type, ta);	
	self.cmbTermArea.lostFocus(cmbTermArea);
	
	if ta = null then
		self.myAssistant.comboBoxLocationControllers(cmbYardLocation, null, false);		
	elseif (not ta.isKindOf(CM_BlockStack)) then 
		// #######
		// TFS 43424 this needs to be the same as cmbTermArea_lostFocus
		// #######
		if ta.isKindOf(CM_Rail) then
			self.allLCsSet.clear();
			ta.CM_Rail.getValidLCsCollectionForMove(self.allLCsSet);
			self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, self.allLCsSet, false);
		elseif ta.isKindOf(CM_IrregularBlockArea) then
			self.allLCsSet.clear(); 
			ta.CM_IrregularBlockArea.getValidLCsCollectionForMove(self.allLCsSet);
			self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, self.allLCsSet, false);
		else
			self.myAssistant.comboBoxLocationControllers(cmbYardLocation, ta.getLCsCollectionForDisplay, false);
			//epr par 15879 19/5/08 not checking for the index will mean in some cases you will get a 14008 exception
		endif;
		idx := self.cmbYardLocation.findObject(_theLocation);
		if idx &gt; 0 then
			cmbYardLocation.listObject := _theLocation;		
		endif;
		self.cmbYardLocation.lostFocus(cmbYardLocation);		
	endif;
	
	self.populateParents();

end;</source>
        <access>protected</access>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
