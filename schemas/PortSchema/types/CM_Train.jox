    <JadeMethod name="getWagonTareWeight" id="7cf01ed0-537d-417e-979f-a51d5ba59202">
        <source>getWagonTareWeight(_isInward : Boolean) : Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2009	cnwmd1	Initial creation

*/

vars
	wagon : CM_Wagon;
	wagons : CM_WagonByIdDict;
	weight : Decimal[12,2];
begin
	create wagons transient;
	if _isInward then
		self.allWagonsByIdInward.copy(wagons);
	else
		self.allWagonsByIdOutward.copy(wagons);
	endif;
	
	foreach wagon in wagons do
	//	weight := weight + wagon.tareWeight;
		weight := weight + wagon.getWagonTareWeight();	//07 Oct 2009	NDL Par 20908
	endforeach;
	
	return weight;
epilog
	delete wagons;
end;</source>
        <Parameter name="_isInward" type="Boolean"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
