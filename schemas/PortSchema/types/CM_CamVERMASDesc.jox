    </JadeMethod>
    <JadeMethod name="outputHeader_UNA" id="d839990f-e9c7-4827-88a8-7070d7092f0e">
        <updating/>
        <source>outputHeader_UNA(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input) : String updating, protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//28 Jun 2016  cnwma1  TFS #2226 POL - Update to VERMAS structure from Ship Operators
//
vars

begin
	//if _protocol.requiresUNASegment then    //28/06/2016 cnwma1 TFS #2226 
	if _protocol.isVermas then                //28/06/2016 cnwma1 TFS #2226 
		return self.outputFileMessage(_camTaskHistory, self.makeUNASegment(_protocol), null);
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="60d8a65b-064b-420e-a878-20cccfb22a47">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
vars
	msg : String;
begin
	msg := self.makeUNBSegment(_protocol, "UNOA", 2, self.getSenderCode_UNB(_protocol), null, _protocol.camGroup.recipient.trimBlanks, null, _seqNumber, null, false, _camTaskHistory.runDateTime);
	return self.outputFileMessage(_camTaskHistory, msg, _coll);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNH_BGM" id="8f921269-8214-4036-96cc-492cf2007bcf">
        <updating/>
        <source>outputHeader_UNH_BGM(_camFile :CM_CamFile input; _camTaskHistory :CM_CamTaskHistory input; _activity :Integer; 
					_unhSeq, _segmentCount :Integer io; _coll :HugeStringArray input) : String updating, protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
constants
	VERMAS = "VERMAS";
vars
	strLine : String;
begin
	if _activity = VERMAS_WEIGHED then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, "XXX", VERMAS, _coll);
		_segmentCount := _segmentCount + 2;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_unhSeq" type="Integer" usage="io"/>
        <Parameter name="_segmentCount" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="76cc904a-b170-4099-8d5f-8271959bfdce">
        <updating/>
        <source>processTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//09/05/2016    cnwma1	TFS 1964 CPL - Missing EDI CAMS Report transaction line on VERMAS messages
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
//
vars
	camMessage : CM_CamMessage;
	voyageOid : CM_Voyage;
	code : String;
	xlVoyage : String;
	messageTypeArray : IntegerArray;
	arrayPos3, arrayPos4, arrayPos5 : Integer;
	messageType : Integer;
	theTI : CM_TrackedItem;
	term : CM_Terminal;
	vesselName : String;
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);
	term := _camProtocol.terminal;

	theTI := _transaction.myTrackedItem;
	create messageTypeArray transient;

	if theTI.isRehandle or theTI.isSOB then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction is for a rehandle or SOB and they are not set to be included.");
		endif;
		return;
	endif;

	self.getMessageType(_transaction, messageTypeArray, _camProtocol,_camAgent);
	if messageTypeArray.size &gt; 0 then
		foreach messageType in messageTypeArray do
			//translate the voyage Code
			code := theTI.myVoyage.code;
			xlVoyage := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);

			camMessage := self.setCamMessage(messageType, _camProtocol, _camFile, _transaction, xlVoyage, vesselName, voyageOid,term);

			if camMessage &lt;&gt; null then
				arrayPos3 := camMessage.group3.size;			 //09/05/2016 cnwma1 TFS #1964
				arrayPos4 := camMessage.group4.size;			 //09/05/2016 cnwma1 TFS #1964
				arrayPos5 := camMessage.group5.size;			 //09/05/2016 cnwma1 TFS #1964
				
				camMessage.camVoyage.voyageOid := null;
				camMessage.camVoyage.vesselName := vesselName;
				camMessage.tiId := theTI.id.trimRight;
				self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyage, _camProtocol.terminal, null);
				camMessage.setupCAMSInfoDetails(_camProtocol, arrayPos3, arrayPos4, arrayPos5, _transaction);	     //09/05/2016 cnwma1 TFS #1964
			else
				if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
				endif;
			endif;
		endforeach;
	endif;
epilog
	if messageTypeArray &lt;&gt; null then
		delete messageTypeArray;
	endif;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCamMessage" id="65a81309-ab51-4469-914a-9d5b5306250f">
        <updating/>
        <source>setCamMessage(_messageType: Integer; _camProtocol: CM_CamProtocol; _camFile: CM_CamFile input; _transaction: CM_TITransaction; _voyageCode: String output; _vesselName: String output; _voyageOid: CM_Voyage output; _terminal: CM_Terminal): CM_CamMessage updating;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
vars
	camMessage : CM_CamMessage;
	theTI : CM_TrackedItem;
begin
	theTI := _transaction.myTrackedItem;
	camMessage := self.getCamMessageById(_camFile, _voyageCode, _vesselName, _messageType, theTI.id);
	_voyageOid := null;
	return camMessage;
end;
</source>
        <Parameter name="_messageType" type="Integer"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_voyageCode" type="String" usage="output"/>
        <Parameter name="_vesselName" type="String" usage="output"/>
        <Parameter name="_voyageOid" type="CM_Voyage" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_CamMessage"/>
    </JadeMethod>
</Class>
