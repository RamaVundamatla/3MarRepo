<GUIClass name="GTE_PrintConfirmationForm" id="6d6305d6-47bd-4c8a-80d8-923ecd4e9443">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="cmbPrinter" id="2cf3a617-9dae-4b8a-aed4-18b67a6424cf">
        <embedded/>
        <type name="CMUI_ComboBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblNbrCopies" id="bf3903c6-40fa-45be-af4c-cbb3ad5a2b02">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblPrinterName" id="58a3bbe9-bf2f-48e5-8a45-a1b915bfadc6">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <PrimAttribute name="selectedPrinterName" id="e758faa4-d6e6-429a-954b-d8c606744dd3">
        <length>61</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="txtNbrCopies" id="f6f41eab-1eb2-4802-acf3-0ffdf3aedc5f">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="8f0f38bc-ddcd-42a9-94c5-e030e0529878">
        <updating/>
        <source>doOK() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/11/2011	cnwdap1	Initial creation PAR #28733 CCMS SFW 1261
*/
vars
	comboPrinter	: CMUI_ComboBox;

begin
	// do we have a printer selected?
	//if self.cmbPrinter.listObject =  null then
	if self.cmbPrinter.text =  null then	//08 Jul 2013	NDL	Par 31842
	//	app.raiseCMException1(REQUIRED_FIELD,"Printer",null,null);
		app.raiseCMException(Input_required_field_printer,null,null); //cnwdb2 PAR 35364

		return;
	endif;
	
	// pass back printer name
	if GTE_FlexiGateForm.hasInstance(self.myParentForm) then
		comboPrinter := self.myParentForm.GTE_FlexiGateForm.cmbPrinter;
		//comboPrinter.listIndex := comboPrinter.findObject(self.cmbPrinter.listObject);
		//8.2.2 version 18 June 2013	NDL	Par 31842
		comboPrinter.listIndex := comboPrinter.findStringExact(1,self.cmbPrinter.text);
		
	elseif GTE_VehicleVisitEnqForm.hasInstance(self.myParentForm) then
		self.myParentForm.GTE_VehicleVisitEnqForm.printerName := self.cmbPrinter.text;//8.2.2 version 18 June 2013	NDL	Par 31842
	endif;
	
	// and the number of copies as the modal result
	self.modalResult := self.txtNbrCopies.text.Integer;
	self.unloadForm;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setPrintDetails" id="b70d95ca-faed-423b-8e95-0e7c184157db">
        <updating/>
        <source>setPrintDetails(_copies : Integer; _printerName : String; _parentForm : CM_BaseForm) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/11/2011	cnwdap1	Initial creation PAR #28733 CCMS SFW 1261
*/
vars

begin
	self.txtNbrCopies.text := _copies.String;
	self.selectedPrinterName := _printerName;
	self.myParentForm := _parentForm;
epilog

end;</source>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a8325a80-c32c-4854-b85e-4d07c360df91">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/11/2011	cnwdap1	Initial creation PAR #28733 CCMS SFW 1261
*/
vars
//	printerDef	: CM_PrinterDef;

begin
	inheritMethod();
	
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	
	self.myAssistant.comboBoxPrintersLocal( self.cmbPrinter, self.selectedPrinterName );
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0fe9e3a1-747b-46a8-8a7a-82c46b81695e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018154, locale);
	lblNbrCopies.translateCaption(Xlat_0018155, locale);
	lblPrinterName.translateCaption(Xlat_0018156, locale);
end;</source>
    </JadeMethod>
</GUIClass>
