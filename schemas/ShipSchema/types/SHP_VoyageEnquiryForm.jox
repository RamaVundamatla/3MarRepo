    <JadeMethod name="doDelete" id="557fd9dc-6853-4751-9c70-985c1849dd5f">
        <updating/>
        <source>doDelete()updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
// 11/11/2015  cnwma1 PAR #36753 Colour Coding Criteria not getting deleted when voyage deleted
//--------------------------------------------------
vars
	result			: Integer;
	msgStr			: String;
	selectedObj 	: CM_Object;
	elementObj		: CM_Object;
	objectArray		: CM_ObjectArrayActual;
	globalVoyageObj	: CM_VoyageGlobal;
	voyageObj		: CM_Voyage;
	voyAllocations  : CM_YardAllocationSet;
	
begin
	if self.tblData.allSelectedObjects.size() &gt; 1 then
	   	msgStr	:=	app.getErrorString2(ConfirmDelete, 'selected', 'voyages');
	elseif self.myCurrentVoyage &lt;&gt; null then
		selectedObj := self.myCurrentVoyage;
		msgStr	:=	app.getErrorString2(ConfirmDelete, 'the selected', 'voyage ' &amp; self.myCurrentVoyage.code);
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	create objectArray transient;
	
	if selectedObj &lt;&gt; null then	// R Barr 30/10/2006 Chg = to &lt;&gt;
	  	objectArray.add(selectedObj);
	else
		self.tblData.allSelectedObjects.copy(objectArray);
	endif;
	
// cnwdad1 15/09/2006 - Added the following validation stuff for new Global Voyage rules.
	foreach elementObj in objectArray do
		if elementObj.isKindOf(CM_VoyageGlobal) then
			globalVoyageObj	:=	elementObj.CM_VoyageGlobal;
			
			if globalVoyageObj.allVoyages.size() &gt; 1 then
				// A Global Voyage that has multiple Voyages (visits) can only be deleted from the Voyage Maint form.
				msgStr	:=	app.getString(Voyage_Delete_Multi_Visit);
				app.msgBox(msgStr, self.caption, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
				return;
			endif;
			
		elseif elementObj.isKindOf(CM_Voyage) then
			voyageObj		:=	elementObj.CM_Voyage;
			
			if voyageObj.myVoyageGlobalArrival &lt;&gt; null then
				globalVoyageObj	:=	voyageObj.myVoyageGlobalArrival.CM_VoyageGlobal;
			elseif voyageObj.myVoyageGlobalDeparture &lt;&gt; null then
				globalVoyageObj	:=	voyageObj.myVoyageGlobalDeparture.CM_VoyageGlobal;
			endif;
			
			if globalVoyageObj &lt;&gt; null then//added by cnwyl1 par 12960
				if globalVoyageObj.allVoyages.size() &gt; 1 then
					// A Global Voyage that has multiple Voyages (visits) can only be deleted from the Voyage Maint form.
					msgStr	:=	app.getString(Voyage_Delete_Multi_Visit);
					app.msgBox(msgStr, self.caption, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
					return;
				endif;
			endif;
		endif;
	endforeach;
	
	
	//Delete Voyage Allocation 							// 11/11/2015 cnwma1 PAR #36753
	create voyAllocations transient;										
	foreach elementObj in objectArray  do
		if elementObj.isKindOf(CM_Voyage) then
			voyageObj		:=	elementObj.CM_Voyage;
		endif;
		if voyageObj = null then
			continue;
		endif;
		if not voyageObj.allVoyageAllocations.isEmpty then
			voyageObj.allVoyageAllocations.copy(voyAllocations);
		endif;
	endforeach;
	
	if not voyAllocations.isEmpty then										// 11/11/2015 cnwma1 PAR #36753
		while true do
			app.myTrxDA.trxDeleteVoyageAllocations(voyAllocations, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;			
			break;
		endwhile;	
	endif;
	//End Voyage allocation
	
	while true do

	  	app.myTrxDA.trxDeleteCMObjects(objectArray, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			break;
		else
			result	:=	app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
		endif;
		
		break;
	endwhile;
epilog
	delete objectArray;
	delete voyAllocations;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="bfa8ed38-cda8-4279-a347-a4b8ef53d9b5">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2022	navtnr20	Initial creation	TFS 53051
1 April 2022    navhl20     TFS 53315  Invalid search not clear bottom of the table records in Voyage Screen
*/

vars
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: CM_DataTable;
begin
    /* //23/04/2024	navkc1 CR63736 Task 63770
	rows := 0;
	filterText  := self.txtFilterBox.text.toUpper();
	tbl			:= self.tblData;
	
	if filterText = "" then
		self.clearFilter();
		return;
	else
		self.btnClearFilter.enabled := true;
	endif;

	start := tbl.fixedRows + 1;
	
	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.setSelectedVoyage(null);
				self.tblInfo.rows := 0;       //TFS 53315
				tbl.accessedRow.visible := true;
				rows := rows+1;
				continue rowLoop;
			endif;
		endforeach;
		
		tbl.accessedRow.visible := false;
	endforeach;
	*/
	
	//05/06/2024	navkc1 CR 63736 Task 63770
	rows := self.frmTableFilter.numOfRowVisible;
	
	self.statusLine.caption := rows.String &amp; ' rows found.';
	
	if rows = 0 then 
		self.setSelectedVoyage(null);
		self.tblInfo.rows := 0;           //TFS 53315
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenEventScheduleSelector" id="ecb4fc56-095b-40e0-935e-b7a19a7733a0">
        <source>doOpenEventScheduleSelector() protected;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

	attachFrm 		: CMUI_EventScheduleSelector;
	sender			: String;
	allSchedules	: CM_AutoSchedulesByStartTsDict;
	schedule		: CM_AutoSchedule;
	strArray		: StringArray;
begin

	app.mousePointer := MousePointer_Default;
				
	attachFrm := app.loadForm(CMUI_EventScheduleSelector, self.myAssistant.class, false, false, false, self.myTerminal, null).CMUI_EventScheduleSelector;

	if attachFrm = null then
		return;
	endif;
	
	create allSchedules transient;
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(PleaseSelectAVoyage) ,app.getErrorString(PleaseSelectAVoyage), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	create strArray transient;
	attachFrm.setupSelector(EventDataVoyage, allSchedules,app.getErrorString2(EventScheduleCaption, app.getErrorString(Voyage), self.myCurrentVoyage.code), self.myCurrentVoyage, strArray);
	
	attachFrm.showModal;

	app.mousePointer := MousePointer_HourGlass;
	foreach schedule in allSchedules do
		app.runEventScheduleVoyage(schedule, self.myCurrentVoyage, strArray.first);
	endforeach;
	return;
	
epilog
	if attachFrm &lt;&gt; null then
		delete attachFrm;
	endif;
	delete strArray;
	delete allSchedules;
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
