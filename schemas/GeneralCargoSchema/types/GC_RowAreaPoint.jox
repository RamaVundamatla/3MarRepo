    <JadeMethod name="drawBlankSpace" id="a70f0d22-c55e-4033-80c6-e4e5f2286eaa">
        <source>drawBlankSpace(_theColor: Integer; _theHeight: Integer; _theFrame: CMUI_GridAreaFrame input; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		A_theril  2002 By Andrew Bisho_the cnwab1
//
// Pur_theose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
//	inheritMethod(_theColor, _theHeight, _theFrame, _theX1, _theY1, _theX2, _theY2);

	_theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  _theColor);
end;</source>
        <access>protected</access>
        <Parameter name="_theColor" type="Integer"/>
        <Parameter name="_theHeight" type="Integer"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawInformation" id="b8dfbe9e-7c3d-4223-aec7-90eeb3654316">
        <source>drawInformation(_theFrame: CMUI_GridAreaFrame input; _theX1, _theY1 : Real; _theRowController : CM_RowController; _theColour : Integer);
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	LineSpace = 18;
	
vars
	tmpY1				: Real;
	tmpX1				: Real;
	
begin
	if self.myGridArea.scaleXFactor &gt;= 2 then
		tmpX1 := _theX1 + 4;
		tmpY1 := _theY1 + 2;
	
		_theFrame.drawFontName := "Arial";
		_theFrame.drawFontSize := 8;
		
		_theFrame.drawTextAt(self.label, tmpX1, tmpY1, _theColour);
	endif;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theRowController" type="CM_RowController"/>
        <Parameter name="_theColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="3875c34d-8323-4cc1-a0c0-92157861136e">
        <updating/>
        <source>drawSelf(pFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		NOTE. The mark up labels are not put in the column label area, instead they have been drawn at the bottom of the point area
//				This means that at the top of this method we have to work out new x and ys to only use the area above these labels
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRowController	: CM_RowController;
	tmpX1				: Real;
	tmpY1				: Real;
	tmpX2				: Real;
	tmpY2				: Real;
	tmpPercentY			: Real;
	rowHeight			: Real;
	pointHeight			: Real;
	lLogsLabel			: String;
	idx					: Integer;
	theColourFill		: Integer;
	lPercentFull		: Decimal[12,2];
	hasAccess			: Boolean;
	failedDAC  :CM_DataAccessController;
	
begin
	// #######################
	// Set the colours
	tmpRowController := self.myLocationsController.CM_RowController;

	if tmpRowController.canUserAccessSelf(null, failedDAC, app.myPassport) then
		hasAccess := true;
	endif;

	self.myGridArea.mySDF.backColor := self.myGridArea.myHLabelsFrame.backColor;

	// sgp 9 June 2003 : only show colour if user has access
	if hasAccess then
// need to move this hasAccess call to YRD_GridPoint - setForCreate ????
// is this being called twice ???
		tmpRowController.getDrawingAttributes(self.myGridArea.mySDF.displayMode, self.myGridArea.mySDF.viewMode,null,theColourFill, lLogsLabel);
	else
		theColourFill := Cn_MediumGray;
	endif;
		
	pFrame.drawFillColor := theColourFill;

	// #######################
	// Work out the row and point height and width
	rowHeight := self.myGridRow.y2 - self.myGridRow.y1 - 20;
	idx := tmpRowController.myRow.allRowControllers.indexOf(tmpRowController);
	
	pointHeight := rowHeight / (tmpRowController.myRow.allRowControllers.size);
	tmpX1 := self.x1;
	tmpY1 := self.y1;
	
	if idx = 1 then
		tmpY1 := 1;
	else
		tmpY1 := (idx - 1) * pointHeight;
	endif;
	
	tmpX2 := self.x2;
	tmpY2 := tmpY1 + pointHeight;


	// #######################
	// Draw a box

	self.drawTrackedItem(pFrame, null, tmpX1, tmpY1, tmpX2, tmpY2);
	
	// sgp 10 June 2003 : don't show extra details if user has no access to the row
	if not hasAccess then
		return;
	endif;
	
	// ######################
	// sgp 9 June 2003 : show if this is a mixed row
	if tmpRowController.isMixedRowForView(self.myGridArea.mySDF.viewMode) then
		pFrame.drawFillStyle := Window.DrawFillStyle_DownDiagonal;
		pFrame.drawFillColor := Cn_MediumGray;
		self.drawTrackedItem(pFrame, null, tmpX1, tmpY1, tmpX2, tmpY2);
	endif;
		
	// #######################
	// draw a box to represent the area filling up
	
	self.drawInformation(pFrame, tmpX1, tmpY1, tmpRowController, theColourFill.getInverseColour);

epilog
	pFrame.drawFillStyle := pFrame.DrawFillStyle_Solid;
	pFrame.drawMode := pFrame.DrawMode_Copy	;
end;</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawTrackedItem" id="bbc706bd-c546-4eb0-9013-4bec51bc6bb0">
        <source>drawTrackedItem(_theFrame: CMUI_GridAreaFrame input; _theTI: CM_TrackedItem; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	_theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  Black);
end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForPoint" id="f52a1193-055e-405e-9fd9-5f7b4a98aa0c">
        <source>getExtraInfoForPoint(x, y : Real; _dataContainer : CM_DataContainer) : Object;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// ---------------------------------------------------------------------------
begin
	if self.myLocationsController.isKindOf(CM_RowController) then
		self.myLocationsController.CM_RowController.getExtraInfo(_dataContainer);
	endif;
	
	return self.myLocationsController;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getMyRowAreaRow" id="8972281f-a4f4-4d89-ab69-e0e32e9902d5">
        <source>getMyRowAreaRow():GC_RowAreaRow;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	return self.myRowAreaRow;
end;</source>
        <ReturnType type="GC_RowAreaRow"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f371ef28-8096-41a1-8479-6041964d2422">
        <updating/>
        <source>setForCreate(_controller : CM_RowController; _idx : Integer; _rowArea : GC_RowArea) updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow	: Integer;
	yrdRow	: GC_RowAreaRow;
	
begin
	tmpRow := 1;
	
	while _rowArea.allGridPoints.includesKey(tmpRow, _idx) do
		tmpRow := tmpRow + 1;
	endwhile;
	
	while _rowArea.allGridRows.size &lt; tmpRow do
		// Add a dummy row
		create yrdRow transient;
		yrdRow.setForCreate(tmpRow, _rowArea);
	endwhile;

	self.label := _controller.id;
	self.myLocationsController := _controller;
	self.myGridRow		:= _rowArea.allGridRows[tmpRow];
	self.myGridColumn 	:= _rowArea.allGridColumns[_idx];
	self.myGridArea 	:= _rowArea;

// This does not handle split rows!
//	self.setForCreateSuperClass(_rowArea, 1, _idx);
end;</source>
        <Parameter name="_controller" type="CM_RowController"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_rowArea" type="GC_RowArea"/>
    </JadeMethod>
