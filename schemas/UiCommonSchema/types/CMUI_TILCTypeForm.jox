    <JadeMethod name="openTiLCTypeMaintForm" id="0d3e61fd-6ba3-4455-9dd5-a7efb9632084">
        <source>openTiLCTypeMaintForm(_isEdit : Boolean) protected;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars

	form			: CMUI_TILCType;
	tiEditLCType 	: CM_TILCType;

begin

	tiEditLCType := self.myCurrentTiLCType;
	
	if tiEditLCType = null and _isEdit then
		return;
	endif;
	
	form := app.loadForm(CMUI_TILCType, CMUI_Assistant, false, false, false, null, null).CMUI_TILCType;

	if form = null then
		return;
	endif;

	if _isEdit then
		form.setMyTILCType(tiEditLCType,_isEdit);
	endif;
	form.centreWindow;

	form.showModal;
	
	


end;</source>
        <access>protected</access>
        <Parameter name="_isEdit" type="Boolean"/>
    </JadeMethod>
