    <JadeMethod name="doClearAdditionalDetails" id="43bbee5f-843f-451e-aa59-63eb21cb9541">
        <updating/>
        <source>doClearAdditionalDetails() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/08/2009	cnwdap1	Initial creation
12/08/2013	cnwdap1	PAR #32123 Added colour list table
25/11/2015	cnwma1  PAR #36943 Shipping Reference error during extract
20 may 2022	navgm20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
21 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
*/
vars

begin
	self.txtAllStops.text := null;
	self.lstAllStops.allSelectedObjects.clear;
	self.txtToDoTasks.text := null;
	self.lstToDoTasks.allSelectedObjects.clear;
	self.cmbSpecialStow.setValue(null);
	self.cmbShippingLine.setValue(null);	//20 may 2022	navgm20	TFS 53204
	self.cmbCtryOfOrigin.setValue(null);	// 16.08.2022 navak20 TFS 54441
	self.txtSpecialLift.text := null;
	self.lstSpecialLift.allSelectedObjects.clear;
	self.txtDescription.setValue(null);
	self.cmbFreightFwdr.setValue(null);
	self.cmbCustomsAgent.setValue(null);
	self.txtHouseBOL.setValue(null);
	self.txtConsignVoy.setValue(null);
	self.txtEquipXchg.setValue(null);
	self.txtPurchaseOrder.setValue(null);
	self.cmbBusUnit.setValue(null);
	self.lstColourList.clearSelected();				// PAR #32123
	self.txtShippingRef.setValue(null);			    //25/11/2015 cnwma1 PAR #36943
	self.cmbInvContractID.setValue(null);//21.02.2023 navtnr20 TFS CR 55648 Task 55663
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
