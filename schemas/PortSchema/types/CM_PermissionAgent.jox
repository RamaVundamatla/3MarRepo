    <JadeMethod name="addConstantsServer" id="0acdf434-35fc-4a82-82d0-7eff8b1d5c7e">
        <executionLocation>server</executionLocation>
        <source>addConstantsServer(_constantStr : String; _rtnStr : String output) : Integer protected, serverExecution;
// ---------------------------------------------------------------------------
// Created:     21 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
constants
	Hdr	: String = 	'jadeVersionNumber "5.2.08";' &amp; CrLf &amp;
					'schemaDefinition' &amp; CrLf &amp;
					'PortSchema subschemaOf BaseSchema partialDefinition, patchVersion=802, patchVersioningEnabled = true;' &amp; CrLf &amp;
					'constantDefinitions';
vars
	f		: File;
	args	: StringArray;
	result	: Integer;
	rtnStr	: String;
		
begin

	result := -1;

	create f transient;
	f.mode := File.Mode_Output; // 29/2/16  cnwns1 PAR 36286 unicode version
	f.fileName := 'c:\temp\etLoad' &amp; app.actualTimeServer.Date.formatAsYYYYMMDD() &amp; app.actualTimeServer.Time.format('HHmmss') &amp; '.scm';// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	f.writeLine(Hdr);

	rtnStr := rtnStr &amp; CrLf &amp; '  creating ' &amp; f.fileName;

	f.writeLine('categoryDefinition Permissions');
	f.writeLine(_constantStr);
	
	f.close;
	
	create args transient;
	args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
	args.add('schemaFile="' &amp; f.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'schemaFile="' &amp; f.fileName &amp; '"';
	args.add('ini="' &amp; app.getIniFileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileName &amp; '"';
	args.add('server=multiuser');
	
	rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
				node.createExternalProcess(app.getJadeInstallDir(), 'jadloadb.exe', args, null, false, true, result).String;
	rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
	
	return result;
	
epilog
	_rtnStr := rtnStr;
	delete args;
	if f &lt;&gt; null then
		f.close;
//		f.purge;
	endif;
	delete f;
	
end;</source>
        <access>protected</access>
        <Parameter name="_constantStr" type="String"/>
        <Parameter name="_rtnStr" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkAdvancedPermissions" id="a53d2b0d-c79f-47a7-8a21-0d35528462aa">
        <source>checkAdvancedPermissions(_constValue : Integer; _permValue : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2022	navkc1	Initial creation - ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1

*/

vars

begin
	if _constValue = PmAdmDamageCodeAdvancedMaint or
		_constValue = PmAdmDamageCodeAdvancedView then
		
		return	app.myRoot.isClientJadeMaster() 
			or app.myRoot.isClientJMTTesting() // 23MAR2023	NAVAB1	BUG 57270
			or app.myRoot.isClientEuroPorts();
		
	endif;
	
	return _permValue;
epilog

end;</source>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_permValue" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllHandHeldAppsUsed" id="91b2f575-7f4a-4f98-bd74-dadfca9e2ff4">
        <source>getAllHandHeldAppsUsed(_allUsed : StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlger1	Initial creation 36402

*/

vars
	permissionObject : CM_PermissionObject;
	handheldApp : String;
begin

	foreach permissionObject in self.allPermissionsByName discreteLock do
		foreach handheldApp in permissionObject.allHandheldApps discreteLock do
			if not _allUsed.includes(handheldApp) then
				_allUsed.add(handheldApp);
			endif;
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_allUsed" type="StringArray" usage="input"/>
    </JadeMethod>
