    <JadeMethod name="getNetContainersPerHour" id="ea5cfa68-b33f-4390-b361-623d3ded8e24">
        <source>getNetContainersPerHour():Decimal;

/*

Purpose:		Return containers per hour (net)	

Parameters:			

Return Value:		


Date			Who		Reason
22 July 2008	concms1	Par 17586 - Initial creation

*/

vars
	hours	:Decimal[23,8];
begin
	hours := self.getNetHours;
	
	if hours &lt;&gt; 0 then
		return (self.getTotalContainers / hours).roundedTo (1);
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNetHours" id="2978174d-9ff7-42e7-ad30-548c9c8fb937">
        <source>getNetHours():Decimal;
/*
Date			Who		Reason
07 August 2008	concms1	Vessel Operations reports - Initial creation
*/

vars
	aKPI		:CM_KPI;
	result	:Decimal [23, 8];
begin
	foreach aKPI in self.myVoyage.allVoyageKPIEntities discreteLock where aKPI.type = KPI_Type_VoyageCraneShift  do
		//result := result + aKPI.CM_KPIVoyageCraneShift.hoursNet;
		result := result + aKPI.CM_KPIVoyageCraneShift.getHoursNetLessDownTime;	//04 Apr 2012	NDL	Par 29369
	endforeach;
	
	return result.roundedTo (2);
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNetMovesPerHour" id="26c42a69-8c19-4c92-a159-8912b56c1830">
        <source>getNetMovesPerHour():Decimal;

/*

Purpose:		Data for Vessel Summary Report 

Parameters:			

Return Value:	Return moves per hour (gross)	


Date			Who		Reason
22 July 2008	concms1	Par 17586 - Initial creation

*/

vars
	hours	:Decimal[23, 8];
begin
	hours := self.getNetHours;
	
	if hours &lt;&gt; 0 then
		return (self.getTotalMoves / hours).roundedTo (1);
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
