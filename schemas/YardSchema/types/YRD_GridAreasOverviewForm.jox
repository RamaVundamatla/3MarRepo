    <JadeMethod name="doNotesForLegend" id="20d4e093-88d4-40ea-9bca-89542370d928">
        <source>doNotesForLegend(_startNote : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	idx, numRows : Integer;
	theTable : Table;
begin
	theTable := self.frmColLegendTIs.myLegendTable;
	numRows := theTable.rows;
	foreach idx in 2 to numRows do
		anObject := theTable.accessRow(idx).itemObject;
		if anObject &lt;&gt; null then
			if _startNote then
				self.beginNotification(anObject, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			else
				self.endNotification(anObject, EVENT_CODE_COLOUR_CHANGE);
			endif;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_startNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegendStartStop" id="a48b5fe4-bf55-494f-a244-10936d70ce56">
        <updating/>
        <source>doNotesForLegendStartStop(_theIndex : Integer; _ydc : YRD_ContainerDrawingController) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.doNotesForLegend(false);
	if (not self.frmColLegendTIs.displayCodesForMode(_ydc.viewMode, _ydc.myDrawingAttrController)) then
		// could not find any codes/colours in controller so display them all
		self.frmColLegendTIs.doChangeViewMode(_theIndex);
	endif;
	self.doNotesForLegend(true);

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_ydc" type="YRD_ContainerDrawingController"/>
    </JadeMethod>
