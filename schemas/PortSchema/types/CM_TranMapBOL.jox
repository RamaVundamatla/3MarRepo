    <JadeMethod name="initialise" id="0792477d-9427-48a5-9f73-be442256ea50">
        <updating/>
        <source>initialise(_bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation

*/

vars
	bolSB : CM_BOLServiceBroker;
begin

	self.myBank := _bank;

	bolSB := self.allBOLServiceBrokers[CM_BOLServiceBroker.DEFAULT_SERVICEBROKER_MAP];
	if bolSB = null then
		create bolSB;
		bolSB.initialiseRes(self);
	endif;

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b2191638-4671-4091-a994-66355af40fd7">
        <updating/>
        <source>setForCreate( _pxyTranMap : CM_TranMapBOL )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	_pxyTranMap.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.name := _pxyTranMap.name;
	self.description := _pxyTranMap.description;
	self.initialise(_pxyTranMap.myBank);

epilog

end;</source>
        <Parameter name="_pxyTranMap" type="CM_TranMapBOL"/>
    </JadeMethod>
