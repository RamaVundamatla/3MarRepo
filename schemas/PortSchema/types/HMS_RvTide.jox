    <JadeMethod name="convertTSArrayToDaysArray" id="6ca10978-2ba5-4c9f-9c1a-58329d70cee0">
        <source>convertTSArrayToDaysArray(_tsArray : TimeStampArray; _daysArray : RealArray io);
//
// cnwrs1 par 26283 01 dec 2010
//
vars
	refDate: Date;
	refTime : Time;
	refTimeStamp : TimeStamp;
	timeInteval : TimeStampInterval;
	timeStamp : TimeStamp;
	days : Real;
begin
	refDate.setDate(01,01,1900);
	refTime.setTime(0,0,0,0);
	refTimeStamp.setDate(refDate);
	refTimeStamp.setTime(refTime);
	foreach timeStamp in _tsArray do
		timeInteval := timeStamp - refTimeStamp;
		days := timeInteval.inDaysAndPartOf();
//		write days.String &amp; ' '&amp; timeStamp.String;
		_daysArray.add(days);
	endforeach;

end;
</source>
        <Parameter name="_tsArray" type="TimeStampArray"/>
        <Parameter name="_daysArray" type="RealArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="filterWindowsByHighTide" id="5fa2c2f2-3b6e-403f-8e3b-5650e818d9a8">
        <updating/>
        <source>filterWindowsByHighTide(_windowArray : TimeStampArray io; _checkPoint : HMS_CheckPoint io) updating;
//
// Purpose:				Filter out low tide times from an array of timestamps marking window starts and ends
//
// Parameters:			_windowArray - TimeStampArray holding start adn end times of tidal windows
//						_checkPoint - harbour region check point
//
// Return Value:		None
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/01/2014	cnwdap1		Initial creation PAR #33337 CCMS PTR 2214 HMS Enhancements
//
vars
	timesToRemove		: TimeStampArray;
	timeToCheck			: TimeStamp;
	timeOfTide			: TimeStamp;
	idx 				: Integer;
	highLow				: Integer;
	firstNull, lastNull	: Boolean;

begin
	create timesToRemove transient;
	
	// Read through _windowArray, checking each second time to see if it's closer to a low tide or a high tide
	// The first entry and the last entry in _windowArray could be null, so need special handling
	firstNull := false;
	lastNull := false;
	foreach idx in 1 to _windowArray.size do
		if idx mod 2 = 0 then
			if idx = _windowArray.size then
				timeToCheck := _windowArray[idx-1];
			else
				timeToCheck := _windowArray[idx];
			endif;
			
			// Low Tide? - remove this window from the _windowArray
			self.getNearestHighLowTide(_checkPoint, timeToCheck, timeOfTide, highLow);
			if highLow = TideLow then
				timesToRemove.add(timeToCheck);
				if idx = 2 and _windowArray[1] = null then
					firstNull := true;
				elseif idx = _windowArray.size and _windowArray[idx] = null then
					lastNull := true;
				elseif idx &lt;&gt; _windowArray.size then
					timesToRemove.add(_windowArray[idx-1]);
				endif;
			endif;
		endif;
	endforeach;
	
	if firstNull then
		_windowArray.removeAt(1);
	endif;
	if lastNull then
		idx := _windowArray.size;
		_windowArray.removeAt(idx);
	endif;
	foreach timeToCheck in timesToRemove do
		_windowArray.remove(timeToCheck);
	endforeach;
	
epilog
	delete timesToRemove;
end;</source>
        <Parameter name="_windowArray" type="TimeStampArray" usage="io"/>
        <Parameter name="_checkPoint" type="HMS_CheckPoint" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findExactPoint" id="33b2ee6e-ad29-472f-8b56-ef3ef24a6f26">
        <updating/>
        <source>findExactPoint(rvTideParams: CMIF_HMS_RvTide_WindowParams input):Boolean updating, protected;

vars
 	statePrevious:		Boolean;
 	stateNext:			Boolean;
 	newPointToCheck:	TimeStamp;
 	stepSize:			Time;
 	errMsg:				String;
begin
 	// This method finds the exact point for a change in tidal state by step wise iteration.
 	// between pointA and pointB

	/* PAR 3537 AJA 15/5/00: Corrected so that tidal state changes close to the point B boundary
	can be picked up. Old situation for example was:

	Point A = 1534, Point B = 1803, Tide changes at 1756
	last period that actually gets checked with 00:32 step size is 1710 - 1742

	When newPointToCheck = 1742 + stepSize = 1814, the 'while' loop ends and getTidalWindowState
	is not called. So the period between 1742 and 1803 (point B) is not checked.

	Code change: The 'While' loop does not end until Point B + stepSize (1835), so last period checked
	is 1742 - 1814. So the 1756 tide change IS detected. Note that code protects against using any value 
	after Point B. So if the tide change was 1810, it would be detected in the algorithm,
	but not used as a valid value.

	Same applies to the backwards stepping algorithm.
	*/

	stepSize:="00:32:00".Time;	//PAR 3484 AJA 27/4/00: Adjust time steps

 	// Set initial state to point A or B depending on direction
 	if rvTideParams.directionFwd=true then
 		// Iterate forward from A to B
 		rvTideParams.pointToCheck:=rvTideParams.pointA;
 		statePrevious:=getTidalWindowState(rvTideParams,errMsg);
 		stateNext:=statePrevious;
    	newPointToCheck:=rvTideParams.pointA+stepSize;	
    	while stepSize&gt;"00:00:20".Time and newPointToCheck&lt;=(rvTideParams.pointB + stepSize) do	//PAR 3537
			rvTideParams.pointToCheck:=newPointToCheck;
    		stateNext:=getTidalWindowState(rvTideParams,errMsg);
    		if stateNext&lt;&gt;statePrevious then
    			// State change has occurred
    			// Iterate again at half stepSize
    			newPointToCheck:=newPointToCheck-stepSize;
    			stepSize.setTime(0,0,((((stepSize.hour*3600)+(stepSize.minute*60)+(stepSize.second))/2).Integer),0);
    			newPointToCheck:=newPointToCheck+stepSize;
    		else
    			newPointToCheck:=newPointToCheck+stepSize;	
    		endif;
    		
    	endwhile;


    	if newPointToCheck&lt;=rvTideParams.pointB then
    		// Set point B to the new state change point (if this exists)
    		rvTideParams.pointB:=newPointToCheck;
    	endif;

        return stateNext;

    else
    	// Iterate backward from B to A
    	rvTideParams.pointToCheck:=rvTideParams.pointB;
    	statePrevious:=getTidalWindowState(rvTideParams,errMsg);
    	stateNext:=statePrevious;
 		newPointToCheck:=rvTideParams.pointB-stepSize;	
    	while stepSize&gt;"00:00:20".Time and newPointToCheck&gt;=(rvTideParams.pointA - stepSize) do
   			rvTideParams.pointToCheck:=newPointToCheck;
   			stateNext:=getTidalWindowState(rvTideParams,errMsg);
    		if stateNext&lt;&gt;statePrevious then
    			// State change has occurred
    			// Iterate again at half stepSize
    			// if state changes, then step forward from previous point at half resolution
 				// continue to do this until step size =1sec
    			newPointToCheck:=newPointToCheck+stepSize;
    			stepSize.setTime(0,0,((((stepSize.hour*3600)+(stepSize.minute*60)+(stepSize.second))/2).Integer),0);
    			newPointToCheck:=newPointToCheck-stepSize;
    		else
    			newPointToCheck:=newPointToCheck-stepSize;	
    		endif;
		
    	endwhile;
		if newPointToCheck&gt;=rvTideParams.pointA then
    		// Set point A to the new state change point (if this exists)
    		rvTideParams.pointA:=newPointToCheck;
    	endif;

		return not(stateNext);

 	endif;


end;</source>
        <access>protected</access>
        <Parameter name="rvTideParams" type="CMIF_HMS_RvTide_WindowParams" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChkPointState" id="c1fbd259-d359-4a8e-a7b5-2e6b3203dc58">
        <updating/>
        <source>getChkPointState(region: HMS_HarbourRegion; moveToCheck: CMIF_HMS_WorkingMovement; moveType: String; timeToCheck: TimeStamp; errMsg:String io; enterLeaveStatus: String):Boolean updating;

vars
	moveDT					: TimeStamp;
	rvTideParams:			CMIF_HMS_RvTide_WindowParams;
	currentLimitPosve:		Real;
	currentLimitNegve:		Real;
	draftLimit:				Real;
 	tidalClass:				HMS_TidalClass;
	voyageData:				HMS_VoyageData;
begin
	// This method returns true or false depending on whether the checkpoints
	// for a region are valid for the checkAtDT time
	if moveToCheck = null then
		return true;
	endif;
	
	moveDT := moveToCheck.occursOnDT;
	// Check to see if movement is a clone - in which case use the references from the original movement	
	if moveToCheck.myClonedMovement &lt;&gt; null then
		voyageData := moveToCheck.myClonedMovement.myWorkingVoyage.myHMSVoyageData;
	else
		// Modified by Russell 24/03/99
		// -------------------------------------------------
		if moveToCheck.myWorkingVoyage &lt;&gt; null then
			voyageData := moveToCheck.myWorkingVoyage.myHMSVoyageData;
		else
			voyageData := moveToCheck.myClonedVoyage.myHMSVoyageData;			
		endif;	
		// -------------------------------------------------
	endif;

	// Determine currentlimits
	if moveToCheck.myMoveTidalClass = null then
		// Modified by Russell 26/03/99
		// ---------------------------------------------------
		if moveToCheck.moveType=HMSMovementTypeArrival then
			tidalClass := voyageData.myTidalClass;
		else
			if voyageData.myTidalClassDept &lt;&gt; null then
				tidalClass := voyageData.myTidalClassDept;
			else
				tidalClass := voyageData.myTidalClass;
			endif;
		endif;	
		// ---------------------------------------------------
	else
		tidalClass := moveToCheck.myMoveTidalClass;
	endif;

	if tidalClass &lt;&gt; null then
		if enterLeaveStatus = HMSMovementTypeEntering then
			currentLimitPosve := tidalClass.allMaximumCurrents[1];	// flood tide
			currentLimitNegve := (tidalClass.allMaximumCurrents[2])*-1;	// ebb tide
		else
			currentLimitPosve := tidalClass.allMaximumCurrents[3];	// flood tide
			currentLimitNegve := (tidalClass.allMaximumCurrents[4])*-1;	// ebb tide
		endif;
	else			
		currentLimitPosve := 100;
	 	currentLimitNegve := -100;
	endif;
		
	// Determine draft limit
	if voyageData.dim_DraftFore&gt;voyageData.dim_DraftAft then
		draftLimit := (voyageData.dim_DraftFore).Decimal;
	else
		draftLimit := (voyageData.dim_DraftAft).Decimal;
	endif;

	create rvTideParams transient;

	rvTideParams.currentLimitPosve := currentLimitPosve;
 	rvTideParams.currentLimitNegve := currentLimitNegve;
 	rvTideParams.draftLimit := draftLimit;	
	rvTideParams.chartDatum := region.getHarbourReal().chartDatum;
	rvTideParams.pointToCheck := timeToCheck;

	//set checkpoint references
	rvTideParams.myCurrentCheckpoint 	:= region.myCurrentCheckpoint;
	rvTideParams.myHeightCheckpoint 	:= region.myHeightCheckpoint;
	rvTideParams.myDaylightCheckpoint 	:= region.myTimeGapCheckpoint;
	rvTideParams.myHiLoCheckpoint 		:= region.myHiLoCheckpoint;

	errMsg := null;
	
	// Check the checkpoints
	if self.getTidalWindowState(rvTideParams,errMsg)=true then
		// Points OK
		return true;
	else
		// At least one point has failed
		errMsg := "For the '" &amp; moveType &amp; "' movement dated " &amp; moveDT.shortCurrentLocaleFormat() &amp; " , the " &amp; errMsg;
		return false;
	endif;

epilog
	delete rvTideParams;
end;</source>
        <Parameter name="region" type="HMS_HarbourRegion"/>
        <Parameter name="moveToCheck" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="moveType" type="String"/>
        <Parameter name="timeToCheck" type="TimeStamp"/>
        <Parameter name="errMsg" type="String" usage="io"/>
        <Parameter name="enterLeaveStatus" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getClosestWindow" id="1f9ce3c0-19f0-4ac1-be62-3a3c79f8ca70">
        <updating/>
        <source>getClosestWindow(earlistTimeStamp: TimeStamp io; latestTimeStamp: TimeStamp io; region: HMS_HarbourRegion; moveDT: TimeStamp; currentLimitPosve: Real; currentLimitNegve:Real ; draftLimit: Real; baseTimeOffSet: Integer io; current: Real io; draft: Real io):String updating;

vars
 	finishOfWindow:			TimeStamp;
 	lastPointFoundIsStart:	Boolean;
 	count:					Integer;
 	checkPoint:				HMS_CheckPoint;
 	harbour:				HMS_Harbour;
	rvTideParams:			CMIF_HMS_RvTide_WindowParams;
	errMsg:					String;
	offsetAsTime:			Time;
	firstPointFwd:			TimeStamp;
	firstPointFwdIsStart:	Boolean;
	nextPointFwdIsStart:	Boolean;
	firstPointBwd:			TimeStamp;
	firstPointBwdIsStart:	Boolean;
	nextPointBwdIsStart:	Boolean;
	secsToPtFwd:			Integer;
	secsToPtBwd:			Integer;
	diffInt:				Integer;
	days:					Integer;
	timeDiff:				Time;
	unRestrictFwd:			Boolean;
	unRestrictBwd:			Boolean;
	chkPtTime:				TimeStamp;
begin
	// This method returns two time stamps - 
	// EarlistTimeStamp = the start timestamp of the closest window to the movement time
	// LatestTimeStamp = the start timestamp of the closest window to the movement time
	create rvTideParams transient;

	rvTideParams.currentLimitPosve := currentLimitPosve;
 	rvTideParams.currentLimitNegve := currentLimitNegve;
 	rvTideParams.draftLimit := draftLimit;	

	rvTideParams.chartDatum := region.getChartDatum();	
	rvTideParams.pointA := moveDT;

	finishOfWindow := rvTideParams.pointA+"23:59:00".Time;

	rvTideParams.pointB := finishOfWindow;
	rvTideParams.directionFwd := true;

	//set checkpoint references on rvTideParams for each type
	rvTideParams.myCurrentCheckpoint := region.myCurrentCheckpoint;
	rvTideParams.myHeightCheckpoint := region.myHeightCheckpoint;
	rvTideParams.myHiLoCheckpoint := region.myHiLoCheckpoint;
	rvTideParams.myDaylightCheckpoint := region.myTimeGapCheckpoint;
	
	// Set default values for checkpointIDs and limits if they do not exist
	if rvTideParams.myCurrentCheckpoint = null then
	//	rvTideParams.currentChkPointID:=1;
		// set current limit so that is never invalid
		rvTideParams.currentLimitPosve:=50;
		rvTideParams.currentLimitNegve:=-50;
	endif;
	if rvTideParams.myHeightCheckpoint = null then
	//	rvTideParams.draftChkPointID:=1;
		// set current limit so that is never invalid
		rvTideParams.draftLimit:=0.5;
	endif;

	// Get current and draft values at moveDT
	// NOTE: Need to adjust time for offset

	if baseTimeOffSet&lt;0 then
		offsetAsTime.setTime(0,(baseTimeOffSet*-1),0,0);
		chkPtTime:=moveDT-offsetAsTime;
	else
		offsetAsTime.setTime(0,baseTimeOffSet,0,0);
		chkPtTime:=moveDT+offsetAsTime;
	endif;	
	rvTideParams.pointToCheck:=chkPtTime;

	if (not getTidalWindowState(rvTideParams,errMsg)) then
		return app.getErrorString(MoveUnrestricted);
	endif;

	current:=rvTideParams.valueCurrent;
	draft:=rvTideParams.valueDraft;

	// Find first point fwd of current time
	firstPointFwdIsStart:=self.findExactPoint(rvTideParams);
	if rvTideParams.pointB&lt;finishOfWindow then
         	firstPointFwd:=rvTideParams.pointB;
    else
    	unRestrictFwd:=true;
   	endif;

   	rvTideParams.pointB:=moveDT;
	finishOfWindow:=rvTideParams.pointB-"23:59:00".Time;
	rvTideParams.pointA:=finishOfWindow;
	rvTideParams.directionFwd:=false;

   	// Find first point backward of current time
	firstPointBwdIsStart:=self.findExactPoint(rvTideParams);
	if rvTideParams.pointA&gt;finishOfWindow then
    	firstPointBwd:=rvTideParams.pointA;
    else
    	unRestrictBwd:=true;
   	endif;

	// Determine which point is closest to movement time
   	timeDiff:=firstPointFwd.differenceAsTime(chkPtTime,diffInt,days);
   	secsToPtFwd:=(days*86400)+((timeDiff.hour)*3600)+((timeDiff.minute)*60)+((timeDiff.second));
   	timeDiff:=firstPointBwd.differenceAsTime(chkPtTime,diffInt,days);
   	secsToPtBwd:=(days*86400)+((timeDiff.hour)*3600)+((timeDiff.minute)*60)+((timeDiff.second));

	if unRestrictFwd=true and unRestrictFwd=true then
		return app.getErrorString(MoveUnrestricted);
	elseif unRestrictFwd=true and unRestrictBwd=false then
		secsToPtFwd:=999999999;
		firstPointFwdIsStart:=true;
	elseif unRestrictFwd=false and unRestrictBwd=true then
		secsToPtBwd:=999999999;		
		firstPointBwdIsStart:=false;
	endif;

	

	if secsToPtFwd&lt;secsToPtBwd then
		// Forward point is closest
		if firstPointFwdIsStart=false and firstPointBwdIsStart=true then
			// points found so far are the start and end of the closest window
			earlistTimeStamp:=firstPointBwd;
			latestTimeStamp:=firstPointFwd;
		else
			// First point fwd is the start of the closest window - find the next point forward
			earlistTimeStamp:=firstPointFwd;
			rvTideParams.pointA:=firstPointFwd+"00:02:00".Time;
			finishOfWindow:=rvTideParams.pointA+"23:59:00".Time;
			rvTideParams.pointB:=finishOfWindow;
			rvTideParams.directionFwd:=true;
			// Find next point fwd of first fwd point
			nextPointFwdIsStart:=self.findExactPoint(rvTideParams);
			if rvTideParams.pointB&lt;finishOfWindow and nextPointFwdIsStart=false then
  		       	// set latestTimeStamp to end of this window;
  		       	latestTimeStamp:=rvTideParams.pointB;
   			endif;
   		endif;			
	else
		// Backward point is closest
		if firstPointFwdIsStart=false and firstPointBwdIsStart=true then
			// points found so far are the start and end of the closest window
			earlistTimeStamp:=firstPointBwd;
			latestTimeStamp:=firstPointFwd;
		else
			// First point bwd is the end of the closest window - find the next point backward
			latestTimeStamp:=firstPointBwd;
			rvTideParams.pointB:=firstPointBwd-"00:02:00".Time;
			finishOfWindow:=rvTideParams.pointB-"23:59:00".Time;
			rvTideParams.pointA:=finishOfWindow;
			rvTideParams.directionFwd:=false;
			// Find next point Bwd of first Bwd point
			nextPointBwdIsStart:=self.findExactPoint(rvTideParams);
			if rvTideParams.pointA&gt;finishOfWindow and nextPointBwdIsStart=true then
  		       	// set earliestTimeStamp to start of this window;
  		       	earlistTimeStamp:=rvTideParams.pointA;
   			endif;
   		endif;		
	endif;
    return "";

epilog
	delete rvTideParams;
end;</source>
        <Parameter name="earlistTimeStamp" type="TimeStamp" usage="io"/>
        <Parameter name="latestTimeStamp" type="TimeStamp" usage="io"/>
        <Parameter name="region" type="HMS_HarbourRegion"/>
        <Parameter name="moveDT" type="TimeStamp"/>
        <Parameter name="currentLimitPosve" type="Real"/>
        <Parameter name="currentLimitNegve" type="Real"/>
        <Parameter name="draftLimit" type="Real"/>
        <Parameter name="baseTimeOffSet" type="Integer" usage="io"/>
        <Parameter name="current" type="Real" usage="io"/>
        <Parameter name="draft" type="Real" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getClosestWindows" id="cfc44181-ac2c-4431-a021-e38a9348dfbe">
        <updating/>
        <source>getClosestWindows(earlistTimeStamp: TimeStamp io; latestTimeStamp: TimeStamp io; region: HMS_HarbourRegion; moveDT: TimeStamp; currentLimitPosve: Real; currentLimitNegve:Real ; draftLimit: Real; baseTimeOffSet: Integer io; current: Real io; draft: Real io) updating;

vars
 	finishOfWindow:			TimeStamp;
 	lastPointFoundIsStart:	Boolean;
 	count:					Integer;
 	checkPoint:				HMS_CheckPoint;
 	harbour:				HMS_Harbour;
	rvTideParams:			CMIF_HMS_RvTide_WindowParams;
	windowArray:			TimeStampArray;
	errMsg:					String;
	offsetAsTime:			Time;
begin
	// This method returns two time stamps - 
	// EarlistTimeStamp = the first valid window start time prior to the movement time
	// LatestTimeStamp = the first valid window end time prior to the movement time


	create rvTideParams transient;
	create windowArray transient;

	rvTideParams.currentLimitPosve:=currentLimitPosve;
 	rvTideParams.currentLimitNegve:=currentLimitNegve;
 	rvTideParams.draftLimit:=draftLimit;	

 	rvTideParams.chartDatum := region.getChartDatum;	
	rvTideParams.pointA		:= moveDT;
	finishOfWindow			:= rvTideParams.pointA + "12:00:00".Time;
	rvTideParams.pointB		:= finishOfWindow;
	rvTideParams.directionFwd := true;

	//set checkpoint references on rvTideParams for each type
	rvTideParams.myCurrentCheckpoint := region.myCurrentCheckpoint;
	rvTideParams.myHeightCheckpoint := region.myHeightCheckpoint;
	rvTideParams.myHiLoCheckpoint := region.myHiLoCheckpoint;
	rvTideParams.myDaylightCheckpoint := region.myTimeGapCheckpoint;
	

	// Set default values for checkpointIDs and limits if they do not exist
	if rvTideParams.myCurrentCheckpoint = null then
		// set current limit so that is never invalid
		rvTideParams.currentLimitPosve:=50;
		rvTideParams.currentLimitNegve:=-50;
	endif;
	if rvTideParams.myHeightCheckpoint = null then
		// set current limit so that is never invalid
		rvTideParams.draftLimit:=0.5;
	endif;

	// Get current and draft values at moveDT
	// NOTE: Need to adjust time for offset

	if baseTimeOffSet&lt;0 then
		offsetAsTime.setTime(0,(baseTimeOffSet*-1),0,0);
		rvTideParams.pointToCheck:=moveDT-offsetAsTime;
	else
		offsetAsTime.setTime(0,baseTimeOffSet,0,0);
		rvTideParams.pointToCheck:=moveDT+offsetAsTime;
	endif;	
	getTidalWindowState(rvTideParams,errMsg);
	current:=rvTideParams.valueCurrent;
	draft:=rvTideParams.valueDraft;



	if rvTideParams.directionFwd=true then
		lastPointFoundIsStart:=self.findExactPoint(rvTideParams);
		if rvTideParams.pointB&lt;finishOfWindow then
         	windowArray.add(rvTideParams.pointB);
         
        endif;
		while rvTideParams.pointB&lt;finishOfWindow and lastPointFoundIsStart=true do
			rvTideParams.pointA:=rvTideParams.pointB+"00:02:00".Time;
			rvTideParams.pointB:=finishOfWindow;
			lastPointFoundIsStart:=self.findExactPoint(rvTideParams);
			if rvTideParams.pointB&lt;finishOfWindow then
				// End of time period to check is not yet reached
  		       	windowArray.add(rvTideParams.pointB);
  		       
  		    else
  		    	// End of time period to check has been reached
  		    	// Check to see is lastPointFoundIsStart=true
  		    	if lastPointFoundIsStart=true then
  		    		// Find end of this window
  		    		rvTideParams.pointA:=finishOfWindow;
  		    		finishOfWindow:=rvTideParams.pointA+"12:00:00".Time;
  		    		rvTideParams.pointB:=finishOfWindow;
  		    		lastPointFoundIsStart:=self.findExactPoint(rvTideParams);
					if rvTideParams.pointB&lt;finishOfWindow then
						// End of time period to check is not yet reached
  		       			windowArray.add(rvTideParams.pointB);
  		       		
  		       			rvTideParams.pointB:=finishOfWindow;
  		       		endif;
  		       	endif;
  			endif;
  		endwhile;
	endif;

	rvTideParams.pointB:=moveDT;
	finishOfWindow:=rvTideParams.pointB-"12:00:00".Time;
	rvTideParams.pointA:=finishOfWindow;
	rvTideParams.directionFwd:=false;



	if rvTideParams.directionFwd=false then
		lastPointFoundIsStart:=self.findExactPoint(rvTideParams);
		if rvTideParams.pointA&gt;finishOfWindow then
         	windowArray.insert(1,rvTideParams.pointA);
         	
        endif;
		while rvTideParams.pointA&gt;finishOfWindow and lastPointFoundIsStart=false do
			rvTideParams.pointB:=rvTideParams.pointA-"00:02:00".Time;
			rvTideParams.pointA:=finishOfWindow;
			lastPointFoundIsStart:=self.findExactPoint(rvTideParams);
			if rvTideParams.pointA&gt;finishOfWindow then
				// End of time period to check is not yet reached
  		       	windowArray.insert(1,rvTideParams.pointA);
  		       
  		    else
  		    	// End of time period to check has been reached
  		    	// Check to see is lastPointFoundIsStart=true
  		    	if lastPointFoundIsStart=false then
  		    		// Find end of this window
  		    		rvTideParams.pointB:=finishOfWindow;
  		    		finishOfWindow:=rvTideParams.pointB-"12:00:00".Time;
  		    		rvTideParams.pointA:=finishOfWindow;
  		    		lastPointFoundIsStart:=self.findExactPoint(rvTideParams);
					if rvTideParams.pointA&gt;finishOfWindow then
						// End of time period to check is not yet reached
  		       			windowArray.insert(1,rvTideParams.pointA);
  		       		
  		       			rvTideParams.pointA:=finishOfWindow;
  		       		endif;
  		       	endif;
  			endif;
  		endwhile;
	endif;

 	if windowArray.size&gt;1 then
 		earlistTimeStamp:=windowArray[1];
 		latestTimeStamp:=windowArray[(windowArray.size)];
 	endif;



epilog
	delete rvTideParams;
	delete windowArray;
end;</source>
        <Parameter name="earlistTimeStamp" type="TimeStamp" usage="io"/>
        <Parameter name="latestTimeStamp" type="TimeStamp" usage="io"/>
        <Parameter name="region" type="HMS_HarbourRegion"/>
        <Parameter name="moveDT" type="TimeStamp"/>
        <Parameter name="currentLimitPosve" type="Real"/>
        <Parameter name="currentLimitNegve" type="Real"/>
        <Parameter name="draftLimit" type="Real"/>
        <Parameter name="baseTimeOffSet" type="Integer" usage="io"/>
        <Parameter name="current" type="Real" usage="io"/>
        <Parameter name="draft" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDaylightData" id="961a2d5b-621f-43fb-80f1-86d9bc869b2d">
        <source>getDaylightData(_tidalModel 	: HMS_TidalModelDefinition; 
			_tsArray 			: TimeStampArray input; 
			_daylightArray 		: RealArray input);
/*
----------   ----------  --------------------------------------------------
Created:	13 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ngauge		: Integer;
begin
	if _tidalModel = null then
		return;
	endif;
	
	if _tidalModel.dataSource = HMS_TidalDataSource_File then
		_tidalModel.getData_TidalDaylight(_tsArray, _daylightArray);
	elseif _tidalModel.dataSource = HMS_TidalDataSourceGetTideFile then //CCMS1640 cnwrs1 jan 2009
	endif;

end;


</source>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_tsArray" type="TimeStampArray" usage="input"/>
        <Parameter name="_daylightArray" type="RealArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFloodCurrent" id="353531c4-ec82-4fe8-b6af-8835b14a9e32">
        <source>getFloodCurrent(_tidalModel : HMS_TidalModelDefinition; _tsArray : TimeStampArray input; _currentSpeedsArray : RealArray input);
/*
----------   ----------  --------------------------------------------------
Created:	13 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ngauge : Integer;
	str : String;
	dayArray : RealArray;
begin
	if _tidalModel = null then
		return;
	endif;
	create dayArray transient;
	if _tidalModel.dataSource = HMS_TidalDataSource_File then
		_tidalModel.getData_TidalCurrent(_tsArray, _currentSpeedsArray);
	elseif _tidalModel.dataSource = HMS_TidalDataSourceGetTideFile then //CCMS1640 cnwrs1 jan 2009
		str := _tidalModel.getTideFileName;
		self.convertTSArrayToDaysArray(_tsArray, dayArray);	// cnwrs1 par 26283 01 dec 2010
		self.xGetTide(str, dayArray, _currentSpeedsArray);
	else
		//call otago dll for Tauranga - return units are knots
		ngauge := _tidalModel.getOldRvLocForDll();
		self.xGetFloodCurrent(ngauge, _tsArray, _currentSpeedsArray);
	endif;
epilog
	delete dayArray;
end;


</source>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_tsArray" type="TimeStampArray" usage="input"/>
        <Parameter name="_currentSpeedsArray" type="RealArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGraphValues" id="2fefd805-5a90-449e-91d9-47d97abe5b4a">
        <updating/>
        <source>getGraphValues(region			: HMS_HarbourRegion; 
				moveDT			: TimeStamp; 
				currentArray	: RealArray input;
				heightArray		: RealArray input; 
				hiLoArray		: RealArray input;
				tideTypeArray	: RealArray input;
				daylightArray	: RealArray input;
				timesToCheckArray: TimeStampArray input) updating;

vars
	numberOfGraphPoints:		Integer;
	timeToCheck:				TimeStamp;
	timeOffSetFromStart:		Time;
	count:						Integer;
	checkPointID:				Integer;
	checkpoint:					HMS_CheckPoint;

begin
	// This method returns an array of depth values (depthArray), an array of current value
	// (currentArray), and another arrays of another other type of checkpoint for the period +/- 12hrs 
	// from the moveDT for all checkpoint types defined for the region.

	// Set resolution for graph
	numberOfGraphPoints:=480;

	// Create timesToCheckArray
	count:=0;
	timeToCheck:=moveDT-"12:00:00".Time;
	while count&lt;numberOfGraphPoints do
		timeOffSetFromStart.setTime(0,0,((86400/numberOfGraphPoints)*count).Integer,0);
		timesToCheckArray.add((timeToCheck+timeOffSetFromStart).TimeStamp);
		count:=count+1;
	endwhile;
		

	if region = null then
		return;
	endif;
	
	if region.myCurrentCheckpoint &lt;&gt; null then
		self.getFloodCurrent(region.myCurrentCheckpoint.myTidalModel, timesToCheckArray, currentArray);
	endif;
	if region.myHeightCheckpoint &lt;&gt; null then
		self.getTideGaugeLevel(region.myHeightCheckpoint.myTidalModel, timesToCheckArray, heightArray);
	endif;
	if region.myHiLoCheckpoint &lt;&gt; null then
		//self.getHiLoData(region.myHiLoCheckpoint.myTidalModel, timesToCheckArray, hiLoArray);
	endif;
	if region.myTimeGapCheckpoint &lt;&gt; null then
		//self.getDaylightData(region.myDaylightCheckpoint.myTidalModel, timesToCheckArray, currentArray);
	endif;
	

end;</source>
        <Parameter name="region" type="HMS_HarbourRegion"/>
        <Parameter name="moveDT" type="TimeStamp"/>
        <Parameter name="currentArray" type="RealArray" usage="input"/>
        <Parameter name="heightArray" type="RealArray" usage="input"/>
        <Parameter name="hiLoArray" type="RealArray" usage="input"/>
        <Parameter name="tideTypeArray" type="RealArray" usage="input"/>
        <Parameter name="daylightArray" type="RealArray" usage="input"/>
        <Parameter name="timesToCheckArray" type="TimeStampArray" usage="input"/>
    </JadeMethod>
