    <JadeMethod name="getProposedHeightMetresTIs" id="dc963065-b90a-4bb6-a651-9b796e362c7c">
        <source>getProposedHeightMetresTIs() : Real;
/*
Date		    Who			Reason
27 October 2011	cnwas3	  Initial creation: par 28545
*/


vars
	slotDefn : CM_ROROSlotDefn;
	theTI : CM_TrackedItem;
	height : Real;
	theTIs : CM_TIArray;
begin
	create theTIs transient;
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if not slotDefn.isAvailable then
			continue;
		endif;
		
		slotDefn.CM_ROROSlotDefnVoyage.mySlotController.getProposedTIs(theTIs);
		foreach theTI in theTIs discreteLock do
			height := height + (theTI.getActualHeightRaw() / 100);
		endforeach;
		theTIs.clear();
	endforeach;

	return height;

epilog
	delete theTIs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getProposedTIs" id="bb3643a2-0138-4ce8-9d45-a4a625334b7d">
        <source>getProposedTIs(_tis: CM_TIArray input; _clear: Boolean);
/*
Purpose:			
Date		Who		Reason
16 September 2011	cnwab1	Initial creation
*/
// 28990 added in getting the AFT TIs
vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	obj : Object;
	has40s : Boolean;
	aTI : CM_TrackedItem;
	tis : CM_TIArray;
	tis40, tis20A, tis20F : CM_TIArray;
begin
	create tis transient;
	create tis40 transient;
	create tis20A transient;
	create tis20F transient;

	if _tis = null then
		return;
	endif;
	
	if _clear then
		_tis.clear();
	endif;

	create tis transient;
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC &lt;&gt; null then
			slotLC.getProposedTIs(tis);

			foreach aTI in tis do
				if aTI.isTwenty() then
					tis20F.add(aTI);
					
				else
					tis40.add(aTI); 
					if aTI.myPrimaryPlannedLocation = slotLC
					or aTI.myPrimaryActualLocation = slotLC then
							has40s := true;
					endif;
				endif;
			endforeach;
		endif;
	endforeach;	
	
	// PAR 28990 get Aft 20s
	if has40s then
		if self.myAdjacentSlotAft &lt;&gt; null then
			foreach slotDefn in self.myAdjacentSlotAft.allROROSlotDefnByOrdinal discreteLock do
				slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
				
				if slotLC &lt;&gt; null then
					tis.clear();
					slotLC.getProposedTIs(tis);
					
					foreach aTI in tis do
						if aTI.isTwenty() then
							tis20A.add(aTI); 
						endif;
					endforeach;
				endif;
			endforeach;
		
		endif;
	endif;
	
	tis20F.copy(_tis);
	tis20A.copy(_tis);
	tis40.copy(_tis);
epilog
delete tis;
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getProposedVisiblity" id="0fb4a870-585c-45ec-b08d-272f81f43836">
        <source>getProposedVisiblity(_colour : Integer output): Boolean;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	theTI : CM_TrackedItem;
begin
	_colour := White;

	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		foreach theTI in slotLC.allTrackedItems discreteLock do
			// if Remain on Board or Export etc then show me
			if self.isOOTL then
				if theTI.getImExStatus() &lt;&gt; TI_IMEX_STATUS_IMPORT then
					// PAR 31096 - DO not show discharge rehandles in proposed
					if (theTI.isRehandle or theTI.isSOB)	
					and not theTI.hasBeenLoadedToShip() then // PAR 31805 do show loaded rehandles in proposed.
						return false;
					endif;
					
					if theTI.isTranshipItem then
						if slotLC.myRORORequestDischarge &lt;&gt; null then
							if slotLC.myRORORequestDischarge.getTIofMode(REAL_MODE) = theTI then
							return false;
							endif;
						endif;
					endif;
					_colour := theTI.getDrawingColour(TI_ColourMode_DischargePort);
					return true;
				endif;
			else
				if theTI.getImExStatus() &lt;&gt; TI_IMEX_STATUS_IMPORT then
					// PAR 30924
					if theTI.isRehandle or theTI.isSOB then
						// PAR 31073 - If planned away from here then return WHITE, else if actually here continure and return a colour. 
						//					(in TEXT mode it drew a white background which meant you could not see the white text.)
						if  theTI.isPlanned(PLANNING_MODE) then 
							return true; // DRAW WHITE and EMPTY
						endif;
					endif;
					if theTI.isTranshipItem then
						if slotLC.myRORORequestDischarge &lt;&gt; null then
							if slotLC.myRORORequestDischarge.getTIofMode(REAL_MODE) = theTI then
								return true; // DRAW WHITE and EMPTY
							endif;
						endif;
					endif;

					
					_colour := theTI.getDrawingColour(TI_ColourMode_DischargePort);
				endif;
			endif;
		endforeach;
		

		// Is colour coded and planned for load
		if not slotLC.allRequestsLoad.isEmpty()  then
			if  slotLC.allRequestsLoad.first.getProposedVisiblity(_colour) then
				return true;
			endif;
		endif;
		
		
	endforeach;
	if self.isOOTL then
		return false;
	endif;
	
	return true;
		
epilog

end;</source>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getProposedWeightsForLocn" id="5614ebca-6835-4119-8a7c-b683cd785d9c">
        <source>getProposedWeightsForLocn( _tisWeight, _locnMaxWeight : Real output);
/*
Date		    Who			Reason
27 October 2011	cnwas3	  Initial creation: par 28545
*/
vars
	slotDefn : CM_ROROSlotDefn;
	theTI : CM_TrackedItem;
	weight : Real;
	theTIs : CM_TIArray;
	has20, has40, isBE : Boolean;
begin
	create theTIs transient;
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if not slotDefn.isAvailable then
			continue;
		endif;
		
		slotDefn.CM_ROROSlotDefnVoyage.mySlotController.getProposedTIs(theTIs);
		foreach theTI in theTIs discreteLock do
				if theTI.is20 then
					has20 := true;
				else
					has40 := true;
				endif;
			
			if theTI.myPrimaryActualLocation = slotDefn.CM_ROROSlotDefnVoyage.mySlotController or
				theTI.myPrimaryPlannedLocation = slotDefn.CM_ROROSlotDefnVoyage.mySlotController or
				theTI.myPrimaryQueuedLocation = slotDefn.CM_ROROSlotDefnVoyage.mySlotController	then // ignore back ends
				if theTI.is20 then
					_tisWeight := _tisWeight + theTI.totalWeight;
				else
					if has20 then
						_tisWeight := _tisWeight + (theTI.totalWeight / 2);
					else
						_tisWeight := _tisWeight + theTI.totalWeight;
					endif;
				endif;
			else
				if has20 then
					_tisWeight := _tisWeight + (theTI.totalWeight / 2);
				endif;
				isBE := true;
			endif;
		endforeach;

	endforeach;

	if has40 and not has20 then
		if isBE then
			_locnMaxWeight := 0;
		else
			_locnMaxWeight := getMaxWeightLimit(false); // 40s Only
		endif;
	else
		_locnMaxWeight := getMaxWeightLimit(true);
	endif;
	
epilog
	delete theTIs;
end;</source>
        <Parameter name="_tisWeight" type="Real" usage="output"/>
        <Parameter name="_locnMaxWeight" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getWeightKilosTIs" id="31f1b70c-d0be-4203-9bc3-a609089082bc">
        <source>getWeightKilosTIs(_mode : Integer; _clear : Boolean) : Real;
/*
Purpose:			
Date		Who		Reason
28 June 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	theTI : CM_TrackedItem;
	weight : Real;
	theTIs : CM_TIArray;
begin
	create theTIs transient;
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if not slotDefn.isAvailable then
			continue;
		endif;
		
		slotDefn.CM_ROROSlotDefnVoyage.mySlotController.getTIs(theTIs, _mode, _clear);
		foreach theTI in theTIs discreteLock do
			if theTI.myPrimaryActualLocation = slotDefn.CM_ROROSlotDefnVoyage.mySlotController then // ignore back ends
				weight := weight + theTI.totalWeight;
			endif;
		endforeach;

	endforeach;

	return weight;

epilog
	delete theTIs;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getWeightsForLocn" id="ea21d04f-b50e-4969-840f-cc437f34809e">
        <source>getWeightsForLocn(_mode : Integer; _clear : Boolean; _tisWeight, _locnMaxWeight : Real output) : Boolean;
/*
Purpose:			
Date		Who		Reason
28 June 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	theTI : CM_TrackedItem;
	weight : Real;
	theTIs : CM_TIArray;
	has20, has40, isBE : Boolean;
begin
	create theTIs transient;
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if not slotDefn.isAvailable then
			continue;
		endif;
		
		slotDefn.CM_ROROSlotDefnVoyage.mySlotController.getTIs(theTIs, _mode, _clear);
		foreach theTI in theTIs discreteLock do
			if theTI.is20 then
				has20 := true;
			else
				has40 := true;
			endif;
			
			 // ignore back ends
			if (_mode = REAL_MODE and theTI.myPrimaryActualLocation = slotDefn.CM_ROROSlotDefnVoyage.mySlotController)
			or (_mode = PLANNING_MODE and theTI.myPrimaryPlannedLocation = slotDefn.CM_ROROSlotDefnVoyage.mySlotController) // PAR 28401
			or (_mode = QUEUE_MODE and theTI.myPrimaryQueuedLocation = slotDefn.CM_ROROSlotDefnVoyage.mySlotController) then // PAR 28401
				if theTI.is20 then
					_tisWeight := _tisWeight + theTI.totalWeight;
				else
					if has20 then
						_tisWeight := _tisWeight + (theTI.totalWeight / 2);
					else
						_tisWeight := _tisWeight + theTI.totalWeight;
					endif;
				endif;
			else
				if has20 then
					_tisWeight := _tisWeight + (theTI.totalWeight / 2);
				endif;
				isBE := true;
			endif;
		endforeach;

	endforeach;

	if has40 and not has20 then
		if isBE then
			_locnMaxWeight := 0;
		else
			_locnMaxWeight := getMaxWeightLimit(false); // 40s Only
		endif;
	else
		_locnMaxWeight := getMaxWeightLimit(true);
	endif;
	return (has20 and has40); // return if mxed 20s and 40s
epilog
	delete theTIs;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_tisWeight" type="Real" usage="output"/>
        <Parameter name="_locnMaxWeight" type="Real" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleAllWLEsComplete" id="006c0cbc-e14e-4e4b-a0b1-bd266ef3956d">
        <source>handleAllWLEsComplete(_isLoad : Boolean) : Boolean;
/*
Purpose:		PAR 30656	Are ALL the WLES on this location completed?
Date				Who			Reason
November 2012		CNWAB1		Initial creation
*/


vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	theReq : CM_RORORequest;
	found: Boolean;
	voy : CM_Voyage;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC = null then
			continue;
		endif;
		
		if _isLoad then
			theReq := slotLC.myRORORequestLoad;
		else
			theReq := slotLC.myRORORequestDischarge;
		endif;
		if theReq &lt;&gt; null then
			found := true;
			
			if not theReq.isComplete then
				return false;
			endif;
		endif;
	endforeach;
	
	if found then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasAlreadyCovered" id="dc6886b5-1f78-4b0d-aeb4-bba5db844a53">
        <source>hasAlreadyCovered(_isLoad : Boolean; _layoutType : Integer) : Boolean;
/*
Purpose:			
Date		Who		Reason
07 September 2012	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	slotReq : CM_RORORequest;
	slotLayout : CM_RORORequestLayout;
begin

//	return false;
	
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if _isLoad then
				slotReq := slotLC.myRORORequestLoad;
			else
				slotReq := slotLC.myRORORequestDischarge;
			endif;
			
			if slotReq = null then
				continue;
			endif;
		
			slotLayout := slotReq.myLayout;
			
			if slotLayout.isCovering(_layoutType) then
				return true;
			endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_layoutType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasBeenFortyFootPlanned" id="b58d7328-5a71-474e-8f50-4da06b47a7b4">
        <source>hasBeenFortyFootPlanned() : Boolean;
/*

...or 45 foot, or 53 foot; and is the front end of the planned container!


Date		    Who			Reason
23 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	slotDefn 		: CM_ROROSlotDefn;
	slotController 	: CM_ROROSlotController;
	req				: CM_RORORequest;
	tmpTI			: CM_TrackedItem;
	is40 : Boolean;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal do
		slotController := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotController &lt;&gt; null then
			req := slotController.myRORORequestDischarge;
			if req = null then
				req := slotController.myRORORequestLoad;
			endif;		
			
			if req &lt;&gt; null 
			and (not req.isBackEndRequest) 
			and req.getAttrIsNOT20() then // PAR 30253
				// PAR 30253(req.getAttrIs40() or req.getAttrIs45() or req.getAttrIs53()) then

					return true;
			else
				////////////////////////
				tmpTI := slotController.allTrackedItems.first();
				if tmpTI &lt;&gt; null and (tmpTI.isForty() or tmpTI.is45() or tmpTI.is30() or tmpTI.is53()) then
					if tmpTI.myPrimaryActualLocation &lt;&gt; slotController then
						return true;
					endif;
				endif;
				////////////////////////
			endif;
			
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasBeenFortyFootPlannedAft" id="85f820af-8a62-4e22-bf4c-b644b283c2f9">
        <source>hasBeenFortyFootPlannedAft() : Boolean;
/*
Date		    Who			Reason
24 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	slotDefn 		: CM_ROROSlotDefn;
	slotController 	: CM_ROROSlotController;
	req				: CM_RORORequest;
	tmpTI			: CM_TrackedItem;
	
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal do
		slotController := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotController &lt;&gt; null then
			req := slotController.myRORORequestDischarge;
			if req = null then
				req := slotController.myRORORequestLoad;
			endif;		
			
			if req &lt;&gt; null and 
				(req.isBackEndRequest) 
				and req.getAttrIsNOT20() then // PAR 30253
				// PAR 30253 (req.getAttrIs40() or req.getAttrIs45() or req.getAttrIs53()) then
					return true;
			else
				
				tmpTI := slotController.allTrackedItems.first();
				if tmpTI &lt;&gt; null and (tmpTI.isForty() or tmpTI.is45() or tmpTI.is30() or tmpTI.is53()) then
					if tmpTI.myPrimaryActualLocation = slotController then
						return true;
					endif;
				endif;
				
			endif;
			
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasColourCoding" id="1f4a53c3-b68c-4a8c-b722-253cc389a690">
        <source>hasColourCoding(_type: Integer): CM_RORORequest;
/*
Purpose:			
Date		Who		Reason
27 September 2011	cnwab1	Initial creation
*/

vars

	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	obj : Object;
	has40s : Boolean;
	aTI : CM_TrackedItem;
begin
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		
		if slotLC &lt;&gt; null then
			if _type = LOAD_MOVETYPE then
				if slotLC.myRORORequestLoad &lt;&gt; null 
				and not slotLC.myRORORequestLoad.allAllocations.isEmpty() then // PAR 32121 cannot erase. 
					return slotLC.myRORORequestLoad;
				endif;
			elseif _type = DISCHARGE_MOVETYPE then
				if slotLC.myRORORequestDischarge &lt;&gt; null 
				and not slotLC.myRORORequestDischarge.allAllocations.isEmpty() then // PAR 32121 cannot erase. When a load rotated area is moved to ACTUAL layer we create dummy discharge CC with no allocations
					return slotLC.myRORORequestDischarge;
				endif;
			endif;
		endif;
	endforeach;

	
	return inheritMethod(_type);

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="hasCompletedWLE" id="20b9f507-aa33-42b9-83f6-2e53a941a50b">
        <source>hasCompletedWLE(_isLoad : Boolean) : Boolean;
/*
Purpose:			 // PAR 29807
Date		Who		Reason
24 June 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	req : CM_RORORequest;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if _isLoad then
			req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad;
		else
			req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge;
		endif;
		
		if req &lt;&gt; null then
			if req.getAttrIsBackend() then  // 40 back end
				req := req.getFwdSlotReq().CM_RORORequest;
			endif;
			
			if req.isComplete then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasDischargeCCIsRotatedLoad" id="5c707cde-0205-4f95-a085-823d05609b0c">
        <source>hasDischargeCCIsRotatedLoad(): Boolean;
/*
Purpose:			 // PAR 32246
Date				Who			Reason
JANUARY 2014		CNWAB1		Initial creation
*/

vars

	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
begin
	if not self.hasBeenRotatedForLoad then
		return false;
	endif;

	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		
		if slotLC &lt;&gt; null then
			if slotLC.myRORORequestDischarge &lt;&gt; null  then 
				return true;
			endif;
		endif;
	endforeach;

	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
