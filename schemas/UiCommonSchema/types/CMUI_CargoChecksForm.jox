        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnComplete_click" id="533b52a1-ffa6-4add-a0ca-1edc204f6d4c">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnComplete_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076
01 Feb 2024	jlizm1	TFS 62142 Perform checks from voyage ops live

*/

vars

begin

	if self.doVerifyChecksComplete then
		if not self.saveCheckItemSelections() then
			return;
		endif;
	endif;
	
	if self.isVoyageOpsContext and not self.isCheckingMainCargo then
		self.tblCargoChecks.clear();
		self.setupChildSelectTable();
		return;
	endif;

	self.unloadForm();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
