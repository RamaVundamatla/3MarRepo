    <JadeMethod name="setControlsForAddEdit" id="522ff24b-4af9-4b42-91a3-eaaf9d6dee14">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

begin
	
	self.tblInput1.userInputEnabled	:= true;
	
	if self.mode = self.Mode_Add then
		self.tblInput1.clearValues;
		self.cmbCarrier.listIndex := -1;
		self.resetMeasurementRows(self.tblInput1);																	
		self.loadMeasurementTypes(self.tblInput1, self.tblInput1.myEntTableDef.name, self.tblInput1.myEntTableDef.allEntTableRows, true);
		self.setConvertedDisplayValue( self.tblInput1, ETRow_TareKilos, 0.0, self.weightType );
		self.setConvertedDisplayValue( self.tblInput1, ETRow_MaxGrossLadenWeight, 0.0, self.weightType );
		self.tblInput1.row := 1;
		self.tblInput1.column := 2;
	else
		
	endif;

epilog

end;</source>
    </JadeMethod>
