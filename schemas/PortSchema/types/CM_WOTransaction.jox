    <JadeMethod name="getTotalQuantity" id="6f2f88db-73f2-42e3-9472-a1f17829ae92">
        <source>getTotalQuantity():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	totalQuantity : Integer;
	ti 			  : CM_TrackedItem;
begin
	
	if not self.hasCargoWorkOrderDetails  then
		return null;
	endif;
	
	foreach ti in self.myWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs do			///08.02.2023 navma1 #56457:[56458]
		totalQuantity := totalQuantity + ti.totalQuantity;
	endforeach;
	
	return totalQuantity;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
