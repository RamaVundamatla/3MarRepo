    <JadeMethod name="cmbCommodity_gotFocus" id="482c9461-147b-494f-bae5-34108d3c19aa">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCommodity_gotFocus(combobox: ComboBox input) updating;
/*
Purpose:	

Date		Who		Reason
07 August 2024	navab1	CR 65331 TASK 65332
*/

vars
	theTable: Table;
	obj : Object;
begin
	theTable := self.tblLines;
	self.currentLineRow := theTable.row;
	
	obj := theTable.accessCell(self.currentLineRow, 3).itemObject;
	if combobox.findObject(obj) &gt; 0 then
		combobox.listObject := obj;
	else	
		combobox.listObject := null; // ### TFS BUG 66001 19SEP2024 NAVAB1
	endif;

	if combobox.listObject = null then
		combobox.listIndex := 1;
	endif;



epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
