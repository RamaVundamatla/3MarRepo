    <JadeMethod name="getVvrDetailsStringForAttrib" id="0cda7f81-276a-4405-94bd-de4944ae47a6">
        <source>getVvrDetailsStringForAttrib( _attrName: String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2021	navndl1	Initial creation	TFS 51809

*/

vars

	type : Integer;
	localColl : CM_VehicleVisitDetailByTime;
	iter : Iterator;
	vvrd : CM_VehicleVisitRecordDetail;
	outputString : String;
	addComma : Boolean;

begin

	if _attrName = ETRow_VvrdBoomInward then
		type := VisitRecord_InwardGateBoom;
	elseif _attrName = ETRow_VvrdBoomOutward then
		type := VisitRecord_OutwardGateBoom;
	elseif _attrName = ETRow_VvrdBulkIn then
		type := VisitRecord_Bulk_In;
	elseif _attrName = ETRow_VvrdBulkOut then
		type := VisitRecord_Bulk_Out;
	elseif _attrName = ETRow_VvrdCargoPlaced then
		type := VisitRecord_CargoPlaced;
	elseif _attrName = ETRow_VvrdCargoRemoved then
		type := VisitRecord_CargoRemoved;
	elseif _attrName = ETRow_VvrdCreation then
		type := VisitRecord_Create;
	elseif _attrName = ETRow_VvrdDeAssignRFID then
		type := VisitRecord_DeassignRFIDTag;
	elseif _attrName = ETRow_VvrdDeleted then
		type := VisitRecord_Deleted_Entry;
	elseif _attrName = ETRow_VvrdDiscrepancy then
		type := VisitRecord_CargoDiscrepancy;
	elseif _attrName = ETRow_VvrdGrossWeightIn then
		type := VisitRecord_TruckGrsWeightIn;
	elseif _attrName = ETRow_VvrdGrossWeightOut then
		type := VisitRecord_TruckGrsWeightOut;
	elseif _attrName = ETRow_VvrdSwapRelease then
		type := VisitRecord_SwapReleaseCargo;
	elseif _attrName = ETRow_VvrdTrouble then
		type := VisitRecord_Trouble;
	elseif _attrName = ETRow_VvrdTurnAround then
		type := VisitRecord_Turnaround;
	elseif _attrName = ETRow_VvrdWayBillPrint then
		type := VisitRecord_WayBillPrint;
	elseif _attrName = ETRow_VvrdWeighBridge then
		type := VisitRecord_WeighBridge;
	elseif _attrName = ETRow_VvrdWeighBridgeIn then
		type := VisitRecord_WeighBridgeIn;
	elseif _attrName = ETRow_VvrdWeighBridgeOut then
		type := VisitRecord_WeighBridgeOut;
	elseif _attrName = ETRow_VvrdYardLocation then
		type := VisitRecord_Yard;
	else
		type := 0;
	endif;
	
	if type = 0 then
		return null;
	else
		create localColl transient;
		
		iter := self.allVehicleVisitRecordDetails.createIterator;
		while iter.next( vvrd ) do
			if vvrd.recordType = type then
				localColl.addNoDuplicates( vvrd, false );
			endif;
		endwhile;
		delete iter;
		
		if localColl.isEmpty then
			return null;
		endif;
		
		iter := localColl.createIterator;
		while iter.next( vvrd ) do
			if addComma then
				outputString := outputString &amp; ", " &amp; vvrd.getRecordDetailDescription();
			else
				outputString := vvrd.getRecordDetailDescription();
				addComma := true;
			endif;
		endwhile;
		delete iter;
		
	endif;

	return outputString;

epilog

	delete localColl;
	delete iter;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWLEForGateEntity" id="38ef0d5b-5f68-4d23-89ff-e3ca5b5f0653">
