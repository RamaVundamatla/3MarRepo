    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF" id="7655299d-9b8f-427a-8a47-08f07612f845">
        <updating/>
        <source>setPxyFromCMIF(_params: CMIF_EDIDataDetails) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2023	navra1	Initial creation for TFS 59666 - EUP - CallOff fields not available in the column organiser

*/

vars

begin
	inheritMethod(_params);
	self.setVehicleNumber(_params.vehicleNumber);
	self.transportReferenceCustomer := _params.transportReferenceCustomer;
	self.vehicleBookingSlotType := _params.vbSlotType;
epilog

end;</source>
        <Parameter name="_params" type="CMIF_EDIDataDetails"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="d32accbc-d499-4e78-a121-b3b7359ce85a">
        <updating/>
        <source>setStatus(_newStatus: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/07/2023	navdap1		Initial creation TFS 58923 EUP CasllOff EDI Data Type / Data Load
//
vars

begin
	inheritMethod(_newStatus);
	
	if self.myRequestMultiLine &lt;&gt; null then
		self.myRequestMultiLine.setStatus(_newStatus);
	endif;

epilog

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setVehicleNumber" id="8840fa7a-9244-429b-9b30-90736f96e7c5">
        <updating/>
        <source>setVehicleNumber(_vehicleNumber : String) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2023	navra1	Initial creation for TFS 59666 - EUP - CallOff fields not available in the column organiser

*/

vars
	tisOfRequestMultiLine  		: CM_EDITIById;
	found						: Boolean;
	ediTi 						: CM_EDITrackedItem;
	ediTiTransient 						: CM_EDITrackedItem;
begin
	
	if self.myRequestMultiLine = null then
		return;
	endif;
	
	tisOfRequestMultiLine := self.myRequestMultiLine.allEDITrackedItems;
	
	foreach ediTi in tisOfRequestMultiLine do
		if ediTi.isKindOf(CM_EDIRequestHeaderTI) then
			found := true;
			break;
		endif;
	endforeach;
	
	if found then
		ediTi.CM_EDIRequestHeaderTI.regNumber := _vehicleNumber;		
	endif;	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vehicleNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="verifyAll" id="02ac7672-a720-4071-989b-eba1e1752fea">
        <updating/>
        <source>verifyAll() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/06/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
// 29/08/2023	navdap1		TFS 60115 EUP FR CallOff
// 18/10/2023	navdap1		Initial creation TFS 58926 EUP | Calloff Update - Replace/ Create Logic and DB Load
// 19/02/2024	naviv1		CR 61643 - EUP | FR 54084 - Validation to Check Cargo Group Exists for CallOff
// 28/03/2024	naviv1		Bug 63179 - EUP | CallOff - If cargo group wasn't exist it throws error, but still able to DB load and it creates Release Request and Work Order
//
vars
	existingEdiFile : CM_EDIFile;
	terminal : CM_Terminal;
	iter : Iterator;
	release : CM_BulkRelease;
	errorMsg : String;
	newStatus : Integer;
	errorSet : CM_ErrorSet;
	allEDITrackedItems : CM_EDITIById;
	ediTI : CM_EDITrackedItem;
	ediShipTI : CM_EDICargoOnShipTI;
	voyage : CM_Voyage;
	requestDetail : CM_EDIRequestDetailTI;
	cargoGroup : CM_CargoGroup;
begin
	
	app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_VERIFYING); //12.Mar.24 navsp1 TFS 60793
	
	// Do CallOff specific validation first
	terminal := self.getMyTerminal();
	self.myEDIFile.myEDIFileType.findExistingEDIFile(self.myEDIFile.ediClientRef, self.myEDIFile, existingEdiFile);
	
	// For Create or Replace, and no existing call off, is there an existing release request
	if self.statusString.isOneOf(CMIF_JsonHeaderEUP.Status_Create, CMIF_JsonHeaderEUP.Status_Replace) then
		if existingEdiFile = null then
			self.verifyManualReleaseRequest(terminal);
		endif;
	endif;
	
	// For Cancel, is there an existing file that matches to cancel and is it DB Loaded
	if self.statusString = CMIF_JsonHeaderEUP.Status_Cancel then
		self.verifyExistingFileDBLoaded(existingEdiFile);
	endif;
	
	// For Replace or Cancel, check if teh existing file can be replaced or cancelled
	if self.statusString.isOneOf(CMIF_JsonHeaderEUP.Status_Replace, CMIF_JsonHeaderEUP.Status_Cancel) then
		self.verifyCanReplaceCancel(existingEdiFile);
	endif;
	
	// For Create, there can't be an existing work order
	if self.statusString = CMIF_JsonHeaderEUP.Status_Create then
		self.verifyCreateCallOff(existingEdiFile);
	endif;
	
	//Verify Call-Offs													// 19.Sep.2023 navsp1 TFS 57809 &gt;&gt;&gt;&gt;
	allEDITrackedItems := self.myRequestMultiLine.allEDITrackedItems;
	foreach ediTI in allEDITrackedItems do	
		if not ediTI.isKindOf(CM_EDIRequestHeaderTI) then
			continue;
		endif;
		voyage := terminal.lookupVoyage(ediTI.getVoyageCode, null, false);
		if voyage &lt;&gt; null then					
			self.checkEDICutoff(ediTI.getVoyageCode, ediTI.getOperatorCode, ediTI);	
		endif;
	endforeach;															// 19.Sep.2023 navsp1 TFS 57809 &lt;&lt;&lt;&lt;
	
	//Verify Cargo Group												// 19.02.2024 naviv1 #61643
	foreach ediTI in allEDITrackedItems where ediTI.isRequestDetail do		
	requestDetail := ediTI.CM_EDIRequestDetailTI;
	if requestDetail.cargoGroupId &lt;&gt; null then
		cargoGroup := terminal.getCargoGroupItem(requestDetail.cargoGroupId);
		if cargoGroup = null then
			//app.raiseCMException1(Cargo_group_not_found, requestDetail.cargoGroupId, null, null);			//27.03.2024 naviv1 #63179
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Cargo group not found - " &amp; requestDetail.cargoGroupId, LogERROR);		//28.03.2024 naviv1 #63179
			errorMsg := app.getErrorString1(Cargo_group_not_found, requestDetail.cargoGroupId);									//28.03.2024 naviv1 #63179
			app.myPassport.addErrorFull(Cargo_group_not_found, errorMsg, "cargoGroup", null, null);								//28.03.2024 naviv1 #63179
			break;		
		endif;
	endif;
	endforeach;													// 19.02.2024 naviv1 #61643

	// Now verify the actual message data
	create errorSet transient;
	app.myPassport.moveErrorsToSet(errorSet);
	self.myRequestMultiLine.verifyAll();
	app.myPassport.addErrorsFromSet(errorSet);
	
epilog
	if app.myPassport.noErrors and app.myPassport.noWarnings then
		newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
	elseif app.myPassport.hasErrors then						// TFS 60115
		newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;		// TFS 60115
	elseif app.myPassport.hasWarnings then						// TFS 60115
		newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;	// TFS 60115
	endif;
	
	app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, newStatus);
	
	// TFS 58926 update work order / release request status if necessary
	if app.myPassport.hasErrorsOrWarnings then
		app.myPassport.moveErrorsToSet(errorSet);
		app.myTrxUA.trxUpdateWORelReqToPending(self.manifestNumber, app.myPassport);
	endif;
	
	app.myPassport.addErrorsFromSet(errorSet);
	
	delete errorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="verifyCanReplaceCancel" id="59a3cc24-eab1-4c7f-8125-00d1e2e3c4da">
        <source>verifyCanReplaceCancel(_existingEDIFile : CM_EDIFile) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/07/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / Data Load
//
vars
	canBeUpdatedOrCancelled : Boolean;
	errorMsg : String;

begin
	// If there is an ediFile with the same clientRef and it has a edidata and the status of it is DB loaded,
	// check if it can be replaced/deleted
	canBeUpdatedOrCancelled := true;
	if _existingEDIFile &lt;&gt; null and _existingEDIFile.ediData &lt;&gt; null and _existingEDIFile.ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
		canBeUpdatedOrCancelled := _existingEDIFile.canFileBeUpdatedOrCancelled();
	endif;
	
	// If it cannot be updated(ie. some cargo item has been received, or the transport has already come), we cannot update or delete,
	// log error and return
	if not canBeUpdatedOrCancelled then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "EDI item with reference (" &amp; self.myEDIFile.ediClientRef &amp; ") has items cannot be updated/deleted since items/transport has arrived",LogERROR);
		errorMsg := app.getErrorString(Transpo_cargo_already_arrived);
		app.myPassport.addErrorFull(Transpo_cargo_already_arrived, errorMsg, null, null, null);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_existingEDIFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="verifyCreateCallOff" id="5366a99e-a54e-42d6-af0e-ce4186bdefb7">
        <source>verifyCreateCallOff(_existingEDIFile : CM_EDIFile) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/07/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / Data Load
//
vars
	workOrder : CM_WorkOrder;
	errorMsg : String;

begin
	// Check if there is already a WO with our manifestNumber
	workOrder := app.myPassport.myTerminal.allWorkOrders[self.manifestNumber];
	if workOrder &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Work order exists - " &amp; workOrder.id, LogERROR);		
		errorMsg := app.getErrorString1(Work_order_with_name_alrea_exi, workOrder.id);			
		app.myPassport.addErrorFull(Work_order_with_name_alrea_exi, errorMsg, null, null, null);			
	endif;
	
	// If there is an existing file, and it was a Cancel, and it's been DB loaded, this Create cannot proceed
	if _existingEDIFile &lt;&gt; null
	and _existingEDIFile.ediData.CM_EDIDataCallOff.statusString = CMIF_JsonHeaderEUP.Status_Cancel
	and _existingEDIFile.ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Previous EDI file for " &amp; self.manifestNumber &amp; " was a Cancel, and has been DB Loaded", LogINFO);
		errorMsg := app.getErrorString2(Calloff_message_cancelled, _existingEDIFile.ediData.CM_EDIDataCallOff.guid, self.manifestNumber);
		app.myPassport.addErrorFull(Calloff_message_cancelled, errorMsg, null, null, null);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_existingEDIFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="640bac70-681f-498b-95af-4af126b59966">
        <updating/>
        <source>verifyEDIData(): Integer updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/07/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
//
vars

begin
	if self.myRequestMultiLine &lt;&gt; null then
		self.myRequestMultiLine.verifyEDIData();
	endif;
	
	return app.myPassport.allErrors.size();

epilog
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="90a22597-5628-479d-be81-2bfaed0bf5cf">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/06/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
//
vars

begin
	self.myRequestMultiLine.verifyEDIDataTIs(_passport);
	app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, self.myRequestMultiLine.status);
	return app.myPassport.allErrorWarnings.size;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyExistingFileDBLoaded" id="5eacfce1-7047-47d1-b8f6-6e01a95346e8">
        <source>verifyExistingFileDBLoaded(_existingEDIFile : CM_EDIFile) protected;
//
// Purpose:			For Cancel status CallOff messages, check any existing CallOff message for the same manifest numberis not DB Loaded
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/07/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / Data Load
//
vars
	errorMsg : String;

begin
	if _existingEDIFile = null then
		errorMsg := app.getErrorString1(Bulk_Release_Not_Found, self.manifestNumber);
		app.myPassport.addErrorFull(Bulk_Release_Not_Found, errorMsg, app.getErrorString(Release_request), null, null);
		
	// is the existing file DB Loaded? - warning if not
	else
		if not _existingEDIFile.ediData.status.isOneOf(CM_EDIFile.EDI_STATUS_DBLOADED, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL) then
			errorMsg := app.getErrorString1(CallOff_Not_DB_Loaded, self.manifestNumber);
			app.myPassport.addWarningFull(CallOff_Not_DB_Loaded, errorMsg, app.getErrorString(Release_request), null, null);
			
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_existingEDIFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="verifyManualReleaseRequest" id="b880f85a-6d22-4c91-b30e-08b35713fc8c">
        <source>verifyManualReleaseRequest(_terminal : CM_Terminal) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/07/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / Data Load
// 29/08/2023	navdap1		TFS 60115 EUP FR CallOff
//
vars
	iter : Iterator;
	release : CM_BulkRelease;
	errorMsg : String;

begin
	if _terminal = null then
		return;
	endif;
	
	iter := _terminal.allBulkReleasesByCodeDate.createIterator;
	_terminal.allBulkReleasesByCodeDate.startKeyGeq(self.manifestNumber.toUpper, "31/12/2300 23:59".TimeStamp, iter);	// TFS 60115
	while iter.next(release) do
		if release.code &lt;&gt; self.manifestNumber.toUpper then		// TFS 60115
			release := null;
			break;
		endif;
		break;
	endwhile;
	
	if release &lt;&gt; null then
		// found a manual relase request - error
		errorMsg := app.getErrorString2(Rel_req_exists_no_calloff, self.manifestNumber, self.guid);
		app.myPassport.addErrorFull(Rel_req_exists_no_calloff, errorMsg, app.getErrorString(Release_request), null, null);
	endif;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
