    <JadeMethod name="getExtraInfo" id="2f86410b-b6dc-4235-84e2-b6a0952fc192">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;
// ---------------------------------------------------------------------------
// Created:		July 2010 by cnwjre1 for par 24018, show macro details in Rate Table
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)

vars
	maxLen,
	first,
	int,
	count	: Integer;
	cpu : Real;
	caption : String;
	aCT : CM_CalculationType;
	calcType : Integer;
	rateEntry : CM_RateEntry;
	qtyRange  : CM_QuantityRange;
	block : CM_DataContainerBlock;
	dpl : Integer;

begin
	
	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;
	
	foreach rateEntry in self.rateEntries reversed do
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Rate), DC_MoreInfo, 1, rateEntry);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Owner), DC_Label, 1, rateEntry);
		block.addNewItem(self.getListName, DC_Data, 1, self);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(ChangedBy), DC_Label, 1, rateEntry);
		block.addNewItem(rateEntry.userId, DC_Data, 1, rateEntry);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Start_date), DC_Label, 1, rateEntry);
		block.addNewItem(self.systemToLocalTime(rateEntry.startTimestamp).asStringJMT, DC_Data, 1, rateEntry);	// 24/6/2016 cnwmp6 TFS 488 - Multi timezone support

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(ExpiryDate), DC_Label, 1, rateEntry);
		block.addNewItem(self.systemToLocalTime(rateEntry.expiryTimestamp).asStringJMT, DC_Data, 1, rateEntry);	// 24/6/2016 cnwmp6 TFS 488 - Multi timezone support

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Ignore), DC_Label, 1, rateEntry);
		block.addNewItem(app.getYesNo(rateEntry.ignoreThisEntry), DC_Data, 1, rateEntry);

//		block := _dataContainer.addNewBlock;
//		block.addNewItem("Cost per unit", DC_Label, 1, rateEntry);
//		block.addNewItem(rateEntry.costPerUnit.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true), DC_Data, 1, rateEntry);
		
		//18 Sep 2012	NDL	Par 30375
		rateEntry.getExtraInfo(_dataContainer );
		
		if self.service &lt;&gt; null  then
			
			aCT := self.service.myCalculationType;
			if aCT &lt;&gt; null then
				// 24024 rate hook code, show a warning
				if aCT.myHookCodeRate &lt;&gt; null then
					block := _dataContainer.addNewBlock;
					block.addNewItem(app.getErrorString(Has_Rate_hook_code), DC_Label, 1, aCT);
					block.addNewItem(app.getErrorString(This_adjust_rate_used_invoic), DC_Warning, 1, aCT);
				endif;
				/* TFS 39198 moved to CM_RateEntry.getExtraInfo()
				if aCT.isCargoCalcType then
					if calcType = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
						count := 1;
						foreach cpu in rateEntry.allCostPerUnits do
							if count = 1 then
								block.addNewItem(app.getErrorString(Normal_hrs_rate), DC_Label, 1, rateEntry);
							elseif count = 2 then
								block.addNewItem(app.getErrorString(Overtime_hrs_rate), DC_Label, 1, rateEntry);
							else
								block.addNewItem(app.getErrorString(Excluded_hrs_rate), DC_Label, 1, rateEntry);
							endif;
							//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, rateEntry);
							block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, rateEntry); // TFS 36954 MPD 20 Feb 2018
							count := count + 1;
						endforeach;
					endif;
				elseif aCT.isWorkOrderType then // TFS 39198
					calcType := aCT.calculationType;
					if calcType = INV_CALC_TYPE_WO_PERMIT  then 
						count := 1;
						foreach cpu in rateEntry.allCostPerUnits do
							if count = 1 then
								block.addNewItem(app.getErrorString(STR_WO_PERMIT_METMAL), DC_Label, 1, rateEntry);
							elseif count = 2 then
								block.addNewItem(app.getErrorString(STR_WO_PERMIT_CARPEN), DC_Label, 1, rateEntry);
							else
								block.addNewItem(app.getErrorString(STR_WO_PERMIT_CARNOPEN), DC_Label, 1, rateEntry);
							endif;
							block.addNewItem(cpu.asStringJMTWithPrecision(dpl, true), DC_Data, 1, rateEntry); 
							count := count + 1;
						endforeach;
					endif;
				elseif aCT.isVoyageCalcType then
					calcType := aCT.calculationType;
					if calcType = INV_CALC_TYPE_BUSINESS_HRS_QTY then
						count := 1;
						foreach cpu in rateEntry.allCostPerUnits do
							if count = 1 then
								block.addNewItem(app.getErrorString(Included_hrs_rate), DC_Label, 1, rateEntry);
							else
								block.addNewItem(app.getErrorString(Excluded_hrs_rate), DC_Label, 1, rateEntry);
							endif;
							//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, rateEntry);
							block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, rateEntry); // TFS 36954 MPD 20 Feb 2018
							count := count + 1;
						endforeach;
					elseif calcType = INV_CALC_TYPE_BUSHRSVESELVALUE then // PAR 30681
						count := 1;
						foreach cpu in rateEntry.allCostPerUnits do
							if count = 1 then
								block.addNewItem(app.getErrorString(Normal_hrs_rate), DC_Label, 1, rateEntry);
							elseif count = 2 then
								block.addNewItem(app.getErrorString(Overtime_hrs_rate), DC_Label, 1, rateEntry);
							else
								block.addNewItem(app.getErrorString(Excluded_hrs_rate), DC_Label, 1, rateEntry);
							endif;
							//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, rateEntry);
							block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, rateEntry); // TFS 36954 MPD 20 Feb 2018
							count := count + 1;
						endforeach;
					elseif (calcType = INV_CALC_TYPE_VESSEL_TON_RANGE or calcType = INV_CALC_TYPE_VESSEL_TON_QTY1) then 
						first := 1;
						count := 1;
						foreach cpu in rateEntry.allCostPerUnits  do
							int := aCT.integerRange1[count];
							caption := first.String &amp; " - " &amp; int.String;
							block.addNewItem(caption, DC_Label, 1, rateEntry);
							first := int + 1;
							//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, rateEntry);
							block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, rateEntry); // TFS 36954 MPD 20 Feb 2018
							count := count + 1;
						endforeach;
					endif;
				endif;
				*/
				//	CCMS SFW 1279 May 2012 Storage Escalating Charges
				if aCT.allQuantityRanges.size &gt; 0 then
					maxLen := rateEntry.allCostPerUnits.size;
					if maxLen &gt; 0 then	// 29972
						count := 1;
						foreach qtyRange in aCT.allQuantityRanges do
							caption := qtyRange.rangeStart.String &amp; "-" &amp; qtyRange.rangeEnd.String &amp; " " &amp; app.getErrorString(Base);
							block.addNewItem(caption, DC_Label, 1, qtyRange);
							cpu := rateEntry.allCostPerUnits[count];
							//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, qtyRange);
							block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, qtyRange); // TFS 36954 MPD 20 Feb 2018
							count := count + 1;
							if count &gt; maxLen then
								break;
							endif;
							if qtyRange.daysIncrement &gt; 0 then
								caption := qtyRange.getDisplay();
								block.addNewItem(caption, DC_Label, 1, qtyRange);
								cpu := rateEntry.allCostPerUnits[count];
								//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, qtyRange);
								block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, qtyRange); // TFS 36954 MPD 20 Feb 2018
								count := count + 1;
							endif;
							if count &gt; maxLen then
								break;
							endif;
						endforeach;
					endif;
				endif;
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
