    <JadeMethod name="doEnableOptions" id="998eb932-ca6e-4d65-8d93-9bb40829ac96">
        <source>doEnableOptions() protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gate				:CM_Gate;
	isPGate, isTrouble	:Boolean;
begin
	gate := self.myProxyObject.CM_Gate;
	
	if cmbType.listIndex &gt; 0 then
		if cmbType.itemData [cmbType.listIndex] = CM_GateArea.AreaType_P then
			isPGate := true;
		elseif cmbType.itemData [cmbType.listIndex] = CM_GateArea.AreaType_T then
			isTrouble := true;
		endif;
	else
		// no area type selected
		chkIn.value		:= false;
		chkIn.enabled	:= false;
		chkOut.value	:= false;
		chkOut.enabled	:= false;
		chkCreate.value		:= false;
		chkCreate.enabled	:= false;
		chkSelect.value		:= false;
		chkSelect.enabled	:= false;
	endif;	
	// set in/out options
	if gate.isInGate and
		(isPGate or (isTrouble and not gate.hasTroubleGateArea_IN )) then
		chkIn.enabled	:= true;
	else
		chkIn.value 	:= false;
		chkIn.enabled	:= false;
	endif;
	
	if gate.isOutGate and
		(isPGate or 
		(isTrouble and gate.hasPGateAreas_OUT  and 	// does not have trouble out and does have p-check out
			not gate.hasTroubleGateArea_OUT)) then
		chkOut.enabled	:= true;
	else
		chkOut.value 	:= false;
		chkOut.enabled	:= false;
	endif;
	// create/select options
	if not chkIn.value and not chkOut.value then
		chkCreate.value 	:= false;
		chkCreate.enabled	:= false;
		chkSelect.value 	:= false;
		chkSelect.enabled	:= false;
	else
		chkCreate.enabled 	:= true;
		chkSelect.enabled 	:= true;
	endif;
	
	if chkCreate.value then
		grpNew.enabled	:= true;
	else
		txtID.text			:= null;
		txtComment.text		:= null;
		grpNew.enabled		:= false;
	endif;
	
	if chkSelect.value then
		grpSelect.enabled	:= true;
	else
		cmbSelect.listIndex	:= -1;
		grpSelect.enabled	:= false;
	endif;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="42aaf891-d582-4ef0-bc4b-5a98d189b427">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gate	:CM_Gate;
begin
	if not self.doValidate then
		return;
	endif;
	
	gate := self.myProxyObject.CM_Gate;
	
	if chkCreate.value then
		gate.pxyAddNewGateArea (txtID.text.trimBlanks, txtComment.text.trimBlanks, cmbType.itemData [cmbType.listIndex], chkIn.value, chkOut.value);
	elseif chkSelect.value then
		gate.pxyAddGateArea (cmbSelect.listObject.CM_GateArea, chkIn.value, chkOut.value);
	else
	
	endif;
	
	// just add the gate area to th
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidate" id="6ac92d5b-c0dd-4720-bb17-c576d059a11b">
        <source>doValidate():Boolean protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if chkSelect.value and cmbSelect.listObject = null then
		app.msgBox (app.getErrorString (Gate_Error11), app.getErrorString (Error), MsgBox_OK_Only);
		cmbSelect.setFocus;
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadAreaTypeCombo" id="3858cb2b-fc38-4265-939e-ed379f5c9263">
        <source>loadAreaTypeCombo()protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gate	:CM_Gate;
	index	:Integer;
begin
	gate := self.myProxyObject.CM_Gate;
	
	// p-gate always allowed as can have multiple p-gates
	index := cmbType.addItem (app.getErrorString (GateArea_PGate));
	cmbType.itemData[index] := CM_GateArea.AreaType_P;
	// load trouble option if the gate is inward and has no inward trouble OR
	// gate is outward and has no outward trouble and does have outward p-check
	if (gate.isInGate and not gate.hasTroubleGateArea_IN) or
		(gate.isOutGate and gate.hasPGateAreas_OUT and	not gate.hasTroubleGateArea_OUT)  then
		index := cmbType.addItem (app.getErrorString (GateArea_Trouble));
		cmbType.itemData[index] := CM_GateArea.AreaType_T;
	endif;
	
	cmbType.listIndex := 1;	// should not be here if no valid types to add
	
	self.loadGateAreaCombo;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadGateAreaCombo" id="ab13f59b-3b5b-4f38-b965-da473c9bb636">
        <source>loadGateAreaCombo()protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if cmbType.listIndex = -1 then
		cmbSelect.clear;
		return;
	endif;
	
	self.myAssistant.comboBoxTerminalArea_GateArea (cmbSelect, cmbType.itemData[cmbType.listIndex]);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setGateProxy" id="09a94c55-31ee-4334-beeb-fa961d17d2a8">
        <updating/>
        <source>setGateProxy(_gate :CM_Gate)updating;
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	_gate.raiseExceptionIfNotTransient (method);
	
	self.myProxyObject := _gate;
epilog

end;</source>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5972aac7-54bd-407e-8ab5-ec02524e04df">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	chkCreate.transparent := false;
	chkSelect.transparent := false;
	
	self.createMyAssistant(CMUI_Assistant);
	
	self.loadAreaTypeCombo;
	self.doEnableOptions;
	
	btnOk.zOrder(1);
	btnCancel.zOrder (1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3213f929-b6a0-4897-98b8-51549642c821">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011673, locale);
	chkCreate.translateCaption(Xlat_0011674, locale);
	chkIn.translateCaption(Xlat_0011675, locale);
	chkOut.translateCaption(Xlat_0011676, locale);
	chkSelect.translateCaption(Xlat_0011677, locale);
	lblComment.translateCaption(Xlat_0011678, locale);
	lblID.translateCaption(Xlat_0011679, locale);
	lblType.translateCaption(Xlat_0011680, locale);
end;</source>
    </JadeMethod>
</GUIClass>
