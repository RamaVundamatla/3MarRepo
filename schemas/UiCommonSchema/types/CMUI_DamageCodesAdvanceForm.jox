        <source>setSelectedItem(_damage : CM_DamageInstance) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		06 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 06/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars

begin
	self.mySelectedItem := _damage;
epilog
end;</source>
        <Parameter name="_damage" type="CM_DamageInstance"/>
