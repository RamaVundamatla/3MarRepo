    <JadeMethod name="getCargoSubType" id="39397324-1929-46ee-ba2a-defc7c462b5f">
        <source>getCargoSubType(): CM_Product;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// USED IN REPORT DESIGN.  DO NOT DELETE.
// 16/03/2010 	cnwsh3		MES 1019 PAR22675
// Need a way to return the cargo sub type using the request.
//----------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	invalidTI : Boolean;
	ed		: Integer;
begin
	on Exception do app.handleDeletedObject(exception,ti,invalidTI);
	
	if self.trackedItem = null then
		return null;
	endif;
	
	//epr par 34906 16/9/14
	ti:=self.trackedItem;
	ed:= ti.edition;
	if invalidTI then
		return null;
	endif;

	return self.trackedItem.myProduct;
	
	
	return null;
epilog
end;</source>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
