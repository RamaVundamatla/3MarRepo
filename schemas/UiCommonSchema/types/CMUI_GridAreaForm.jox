    <JadeMethod name="setMoveControllerSource" id="569c2831-6a97-40c0-a48e-d11d2204abab">
        <updating/>
        <source>setMoveControllerSource(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	moveController	: CMIF_MoveController;
begin

	create moveController transient;
	
	moveController.setMyTrackedItem(_ti);
	delete app.myMoveController;
	app.myMoveController := moveController;
	moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(self.moveModeForm));	//REAL_MODE));
	moveController.setMoveMode(self.moveModeForm);	
	moveController.isRehandleMove := _ti.isRehandle;
//	moveController.isOverstowMove := _ti.isOverStowed(REAL_MODE);
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMoveControllerTarget" id="d7a41826-bb38-4412-bd61-cfdb6204d483">
        <updating/>
        <source>setMoveControllerTarget(_theLocation : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		April  2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	moveController	: CMIF_MoveController;
begin

	create moveController transient;
	
	delete app.myMoveController;
	app.myMoveController := moveController;
	moveController.setMyToPrimaryLocation(_theLocation);

	moveController.setMoveMode(self.moveModeForm);	
epilog

end;</source>
        <Parameter name="_theLocation" type="CM_LocationsController"/>
    </JadeMethod>
