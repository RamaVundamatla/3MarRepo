    <JadeMethod name="setProxy" id="ed4c72d7-aaad-4292-a9cc-0bbfda9c73aa">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String;
			_myCargoType : CM_CargoType;
			_myProduct : CM_Product;
			_order : Integer;
			_quantity : Integer;
			_volume : Decimal;
			_weight : Decimal
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.code := _code;
	self.description := _description;
	self.order := _order;
	self.quantity := _quantity;
	self.volume := _volume;
	self.weight := _weight;
	
	self.myProduct := _myProduct;
	self.myCargoType := _myCargoType;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_myProduct" type="CM_Product"/>
        <Parameter name="_order" type="Integer"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateAmounts" id="17b23258-d804-4066-849a-05f958c31875">
        <updating/>
        <source>updateAmounts(	_cargoType : CM_CargoType;
				_quantity : Integer;
				_volume : Decimal;
				_weight : Decimal
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	if _cargoType = null then
		//should never happen
		self.quantity := _quantity;
		self.volume := _volume;
		self.weight := _weight;
			
	else
		if _cargoType.isTrackByVolume then
			self.quantity := 0;
			self.volume := _volume;
			self.weight := 0;
		elseif _cargoType.isTrackByWeight then
			self.quantity := 0;
			self.volume := 0;
			self.weight := _weight;
		else
			self.quantity := _quantity;
			self.volume := 0;
			self.weight := 0;
		endif;
		
	endif;

	

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
</Class>
