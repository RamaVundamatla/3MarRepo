        <updating/>
        <source>btn_Save_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doSave() then
		self.unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
