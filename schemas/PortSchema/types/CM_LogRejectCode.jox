<Class name="CM_LogRejectCode" id="a03e2c5d-5a12-4651-8293-4098dd58073b">
    <superclass name="CM_Code"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myRoot" id="72e1f6c2-a62a-4616-b859-19a07402eaef">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allLogRejectCodes"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="7a678140-f8ed-4258-9abf-df011ce1c526">
