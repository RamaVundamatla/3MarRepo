    <JadeMethod name="setForCreateInternal" id="0739c7aa-b0f6-4a2d-bbc0-8de21ba4773f">
        <updating/>
        <source>setForCreateInternal(_myJob: CM_Job; _reqDate: TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Nov 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details

*/

vars

begin
	self.myJob			 	:= _myJob;
	self.requiredByDT 		:= _reqDate;	
	self.userCode			:= app.getMyUserCode;
epilog

end;</source>
        <Parameter name="_myJob" type="CM_Job"/>
        <Parameter name="_reqDate" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateVoyageHoldJob" id="a11f9598-d8fd-4cb3-aa01-92af78c1666e">
        <updating/>
        <source>setForUpdateVoyageHoldJob(_job : CM_VoyageHoldJob) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/02/2017	cnwdap1		Initial creation TFS 3219 LN XVoyage Operations Enhancements
// 23/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
//
vars

begin
	self.isDischarge := _job.isDischarge;
	if self.isDischarge then 
		self.moveType := DISCHARGE_MOVETYPE;  // ### TFS 53105 02JUN2022 NAVAB1 JOB_TYPE_DISCHARGE;
		self.isLoad := false;					// TFS 3489
	else
		self.moveType := LOAD_MOVETYPE;  // ### TFS 53105 02JUN2022 NAVAB1 JOB_TYPE_LOAD;
		self.isLoad := true;					// TFS 3489
	endif;
	self.code := _job.id;
	self.setJob(_job);
	self.sequenced := true;						// TFS 3489
epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateWeightQty" id="b6ac6eed-b803-4478-95a6-659c3767c61f">
        <source>setForUpdateWeightQty( _wle : CM_WorkListEntry input; _newWeight : Decimal; _newQty : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2017	cnwndl1	Initial creation	TFS 4948

*/

vars

	ti : CM_TrackedItem;
	doUpdate : Boolean;
	now : TimeStamp;
	txnParams : CMIF_MoveTransactionController;

begin

	ti := _wle.myTrackedItem;

	if _newWeight &lt;&gt; _wle.weight then
		doUpdate := true;
	endif;
	if _newQty &lt;&gt; _wle.quantity then
		doUpdate := true;
	endif;
	
	if not doUpdate then
		return;
	endif;
	
	now := app.actualTimeServer();

	create txnParams transient;
	txnParams.myTrackedItem := ti;
	txnParams.dateTime := now;
	txnParams.completedDateTime := now;	
	txnParams.mode := PLANNING_MODE;
	txnParams.totalQuantity :=_wle.quantity;
	txnParams.totalWeight := _wle.weight;
	txnParams.myWorkListEntry := _wle;
	txnParams.type := TRANS_TYPE_MOVE;
	txnParams.sourceLocn := _wle.locationTarget;
//	txnParams.targetLocn := _wle.locationTarget;
	txnParams.unplan := true;

	ti.createTransaction(txnParams, app.myPassport);
	
	if _newWeight &lt;&gt; _wle.weight then
		_wle.setWeight( _newWeight );
	endif;
	if _newQty &lt;&gt; _wle.quantity then
		_wle.setQuantity( _newQty );
	endif;
	
	_wle.job.setRemarks(null); //epr TFS 37664 28/3/18 webportal 
	
	txnParams.totalQuantity :=_wle.quantity;
	txnParams.totalWeight := _wle.weight;
	txnParams.totalVolume := _wle.weight * ti.getDensity(); // TFS 7031
	txnParams.sourceLocn := _wle.locationSource;
	txnParams.targetLocn := _wle.locationTarget;
	txnParams.unplan := false;

	ti.createTransaction(txnParams, app.myPassport);

epilog

	delete txnParams;

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_newWeight" type="Decimal"/>
        <Parameter name="_newQty" type="Integer"/>
    </JadeMethod>
