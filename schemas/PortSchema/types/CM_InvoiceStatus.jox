    <JadeMethod name="setForCreate" id="7815c657-d6cd-4696-b51c-11de56fa63d8">
        <updating/>
        <source>setForCreate(_pxyStatus : SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2018	jlgsl4	TFS 39618 - LNX - Initial creation

*/

vars

begin
	self.id := _pxyStatus.id;
	self.priority := _pxyStatus.priority;
	self.setForUpdate(_pxyStatus);
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_pxyStatus" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f242d15f-351c-4e32-a3b8-f7961f36e761">
        <updating/>
        <source>setForUpdate(_pxyStatus : SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2018	jlgsl4	TFS 39618 - LNX - Initial creation
28 Nov 2022 navmv20 TFS CR 55298 TASK 55546 Jade - Write change TRX and unit test to create and update new colour attribute on CM_InvoiceStatus
*/

vars
	template : CM_EmailTemplate;
begin
	self.description := _pxyStatus.description;
	self.myInvoiceProcess := _pxyStatus.myInvoiceProcess;
	self.colour := _pxyStatus.colour; //28 Nov 2022 navmv20 TFS 55546
	self.priority := _pxyStatus.priority;  // ### JIRA 35465 28JUL2025 NAVAB1
	if self.myEmailTemplate = null and _pxyStatus.myEmailTemplate &lt;&gt; null then
		create template persistent;
		template.setMyParent(self);
		template.setForUpdate(_pxyStatus.myEmailTemplate); // ### TFS 52184 20OCT2021 NAVAB1
	endif;
	if self.myEmailTemplate &lt;&gt; null then
 // ### TFS 52184 20OCT2021 NAVAB1		if _pxyStatus.myEmailTemplate = null then				// TFS 37540
 // ### TFS 52184 20OCT2021 NAVAB1			self.myEmailTemplate.erase(NORMAL_ERASE);			// TFS 37540
 // ### TFS 52184 20OCT2021 NAVAB1		else													// TFS 37540
			self.myEmailTemplate.setForUpdate(_pxyStatus.myEmailTemplate);
 // ### TFS 52184 20OCT2021 NAVAB1		endif;													// TFS 37540
	endif;
	
	self.myInvoiceProcess := _pxyStatus.myInvoiceProcess;
	
	// jlgmd1 21/01/2021 8.6.2.100 Cut
	// A bit of a bodge, but handle Statuses being renumbered. (Which they shouldn't be!)
	// eg. LNX 'Approved' went from 10 to 11
	self.id := _pxyStatus.id;
epilog

end;</source>
        <Parameter name="_pxyStatus" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7b2ddc55-ae65-4be7-88a8-997c85d3fa3a">
        <updating/>
        <source>setProxy(_id 	  		: Integer;
		_priority 		: Integer;
		_description 	: String;
		_invoiceProcess : CM_InvoiceProcess;
		_colour 		: Integer; // 28 Nov 2022 navmv20 TFS 55546
		_emailTemplate  : CM_EmailTemplate input
		) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2018	jlgsl4	TFS 39618 - LNX - Initial creation
29 Nov 2022 navmv20 TFS CR 55298 TASK  55546 Jade - Write change TRX and unit test to create and update new colour attribute on CM_InvoiceStatus .
*/

vars

begin
	self.id := _id;
	self.priority := _priority;
	self.description := _description;
	self.myInvoiceProcess := _invoiceProcess;
	self.colour := _colour; // 28 Nov 2022 navmv20 TFS 55546
	if _emailTemplate &lt;&gt; null then // ### TFS 52184 20OCT2021 NAVAB1
		_emailTemplate.setMyParent(self);  // ### TFS 52184 20OCT2021 NAVAB1
	endif;
epilog

end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_priority" type="Integer"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_invoiceProcess" type="CM_InvoiceProcess"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userCanSet" id="be2a1b4c-d250-46de-bb86-7b478965394e">
        <source>userCanSet(_terminal : CM_Terminal) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2019	jlgsl4	TFS 39618
09 Sep 2019	jlgdi1	45803 Added JMTSupport user condition checking
*/

vars
	user : CM_User;
	userTerm : CM_UserTerminal;
begin
	user := app.getMyUser();
	if user = null then
		return false;
	endif;
	
	// 45802
	if user.isJmtSupportUser() then
		return false;
	endif;
	
	userTerm := user.getUserTerminal(_terminal);
	if userTerm = null then
		return false;
	endif;
	
	if userTerm.mySecurityRole = null then
		return false;
	endif;
	
	if not userTerm.mySecurityRole.allInvoiceStatusesMaint.includes(self) then
		return false;
	endif;	

	return true;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f748b49c-77ec-4a62-bba8-d6e48a3fd7a7">
        <source>validateForCreate(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2018	jlgsl4	TFS 39618 - LNX - Initial creation

*/

vars

begin
	if self.myInvoiceProcess.allStatuses[self.id] &lt;&gt; null then
		app.raiseCMException1(Gate_Error16, self.id.String, null, null);
	endif;
	self.validateSelf();
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="32549446-d5a7-41bc-931f-34786a87f918">
        <source>validateForUpdate(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2018	jlgsl4	TFS 39618 - AAT - Initial creation

*/

vars
	invoiceStatus, realStatus : SelfType;
begin
	if self.isTransient then
		realStatus := self.pxyGetRealObject().CM_InvoiceStatus;
	else
		realStatus := self;
	endif;
	if invoiceStatus &lt;&gt; null and invoiceStatus &lt;&gt; realStatus then
		app.raiseCMException1(Gate_Error16, self.id.String, null, null);
	endif;
	self.validateSelf();
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateSelf" id="e624746e-42f6-4941-a831-cfd0942c949a">
        <source>validateSelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2018	jlgsl4	TFS 39618 - LNX - Initial creation

*/

vars

begin
	if self.priority = null then
		app.raiseCMException(No_Priority_entered, "priority", null);
	endif;
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, "description", null);
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
