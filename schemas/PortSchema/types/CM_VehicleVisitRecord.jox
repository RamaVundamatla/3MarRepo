    <JadeMethod name="getAuditText" id="6ad5a8db-e1fb-4a4a-b13e-e5ad32296349">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	txt,
	tmpStr,str	: String;
	vvrd : CM_VehicleVisitRecordDetail;
	type : Integer;
	vvrdTypes : IntegerArray;

begin
	
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	
	
	create vvrdTypes transient;
	foreach vvrd in self.allVehicleVisitRecordDetails do
		type := vvrd.recordType;
		if not vvrdTypes.includes( type ) then
			vvrdTypes.add( type );
		endif;
	endforeach;
	foreach type in vvrdTypes do
		tmpStr := null;
		str := null;
		foreach vvrd in self.allVehicleVisitRecordDetails where vvrd.recordType = type do
			if str = null then
				str := vvrd.recordTypeString;
			endif;
			if tmpStr &lt;&gt; null then
				tmpStr := tmpStr &amp; ", ";
			endif;
			tmpStr := tmpStr &amp; vvrd.getRecordDetailDescription;
		endforeach;
		txt := txt &amp; str &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endforeach;
	
	//jlier1 TFS 57936 24/5/23
	if self.myBarrierCodeIn &lt;&gt; null then
		txt 	:= txt &amp; app.getErrorString(Barrier_code_in)&amp; AuditStringSeparator &amp; self.getBarrierInCode.length.String &amp; AuditStringSeparator &amp; self.getBarrierInCode &amp; AuditStringSeparator;
		txt 	:= txt &amp; app.getEntTableRowTranslation(ETRow_BarrierValidityIn,ETGrp_VisitRecord) &amp; AuditStringSeparator &amp; self.getBarrierValidityIn.length.String &amp; AuditStringSeparator &amp; self.getBarrierValidityIn &amp; AuditStringSeparator;
		txt 	:= txt &amp; app.getEntTableRowTranslation(ETRow_BarrierInTime,ETGrp_VisitRecord) &amp; AuditStringSeparator &amp; self.getBarrierInTime.length.String  &amp; AuditStringSeparator &amp; getBarrierInTime &amp; AuditStringSeparator;
	endif;
	
	if self.myBarrierCodeOut &lt;&gt; null then
		txt 	:= txt &amp; app.getErrorString(Barrier_code_out)&amp; AuditStringSeparator &amp; self.getBarrierOutCode.length.String  &amp; AuditStringSeparator &amp; getBarrierOutCode &amp; AuditStringSeparator;
		txt 	:= txt &amp; app.getEntTableRowTranslation(ETRow_BarrierValidityOut,ETGrp_VisitRecord) &amp; AuditStringSeparator &amp; self.getBarrierValidityOut.length.String  &amp; AuditStringSeparator &amp; getBarrierValidityOut &amp; AuditStringSeparator;
		txt 	:= txt &amp; app.getEntTableRowTranslation(ETRow_BarrierOutTime,ETGrp_VisitRecord) &amp; AuditStringSeparator &amp; self.getBarrierOutTime.length.String  &amp; AuditStringSeparator &amp; getBarrierOutTime &amp; AuditStringSeparator;
	endif;
	
	return txt;

epilog

	delete vvrdTypes;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
