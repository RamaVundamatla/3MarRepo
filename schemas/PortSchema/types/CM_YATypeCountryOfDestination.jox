    <JadeMethod name="getObjects" id="0e9c84eb-c8db-4227-aaba-206110b921c0">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria

*/

vars
	country : CM_Country;
begin
	foreach country in app.myRoot.allCountries do
		objects[country.getYAIdentifier] := country;
	endforeach;

epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
