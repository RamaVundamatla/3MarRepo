<CollClass name="WS_DocumentArray" id="375ceb49-01e2-4395-a31d-76ee4867e9ca">
    <loadFactor>66</loadFactor>
    <memberType name="WS_Document"/>
    <superclass name="ObjectArray"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="setProxyDocuments" id="cc919e32-fe6f-4fbe-9c80-5dcaad37b003">
        <source>setProxyDocuments(_allDocuments : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 September 2021	jlier1	Initial creation 51963
26 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
26 March 2024		navpw1	TFS: 62849 (62927) - Reverted Code to jlizm1 changes

*/

vars
	wsDocument : WS_Document;
	documentHeader : CM_FileData;
	documentContent : CM_FileDataStorageDetail;
	realDocument : CM_FileData;
	pxyDocument : CM_FileData;
	
begin
	foreach wsDocument in self discreteLock do
		if wsDocument.cmObjectId &lt;&gt; "" then
			realDocument := app.myPassport.getObjectOfTypeFromOid(wsDocument.cmObjectId, CM_FileData).CM_FileData;
			if app.myPassport.hasErrors then
				return;
			endif;
			if realDocument &lt;&gt; null then
				pxyDocument := realDocument.pxyCreateUpdateProxy();
				if pxyDocument &lt;&gt; null then
					pxyDocument.setDetails(realDocument.dateTime, wsDocument.description, realDocument.fileName, wsDocument.heading);
					_allDocuments.add(pxyDocument);
				endif;
			endif;
		else
			create documentHeader transient;
			wsDocument.setProxyFileData(documentHeader);
			_allDocuments.add(documentHeader);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_allDocuments" type="ObjectArray" usage="input"/>
    </JadeMethod>
</CollClass>
