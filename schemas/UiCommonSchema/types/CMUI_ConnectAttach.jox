    <JadeMethod name="cmbTIs_click" id="f57af030-465e-4f39-86d2-044edd149d9e">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTIs_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.singleTIMode then
		self.tblData.setValueByControlName(combobox.name,combobox.text);
		self.allTrackedItems.clear;
		self.allTrackedItems.add(combobox.itemObject[combobox.listIndex].CM_TrackedItem);
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTIs_dropDown" id="27d2db01-179a-47e6-a7d4-3aff58db6eef">
        <controlMethod name="CMUI_ComboBox::dropDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTIs_dropDown(combobox: ComboBox input):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	cargoType: CM_CargoType;
	
begin

	if self.cmbCargoType.listIndex &lt; 1 then
		cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	else
		cargoType := self.cmbCargoType.itemObject[self.cmbCargoType.listIndex].CM_CargoType;
	endif;
	
	self.doBuildComboTIs(cargoType);
	
	return true;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
