    <JadeMethod name="btnExtDelGblCnst_click" id="becebdfa-a947-4ff3-a6bc-d6529928fecb">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
