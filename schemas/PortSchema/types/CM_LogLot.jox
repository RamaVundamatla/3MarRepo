        <source>myDischargePort(set: Boolean; _value: CM_Port io) mapping;
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	order : CM_LogStockOrderLine;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	endif;
	if self.allLogStockOrderLines.size &gt; 0 then
