    <JadeMethod name="translateForm" id="bf10eb09-1eb8-42f3-a75b-5e98cb4ce5cd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 June 2016 14:05:00.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021271, locale);
	btnExportCSV_SU.translateCaption(Xlat_0021272, locale);
	btnRefresh.translateBubbleHelp(Xlat_0021273, locale);
	btnRefresh.translateCaption(Xlat_0021274, locale);
	mnuCloneItem.translateCaption(Xlat_0021275, locale);
	mnuLocalContext.translateCaption(Xlat_0021276, locale);
	shtSpace.translateCaption(Xlat_0021277, locale);
end;</source>
    </JadeMethod>
