    <JadeMethod name="userNotify" id="93ba3d18-135f-4ef3-8cbc-e1d79804ce2a">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpEvent	: Integer;
	tmpTerminal	: CM_Terminal;
begin

	if self.displayType = DISPLAY_BOTH or self.displayType = DISPLAY_SYSTEM then
		if eventType = EventSystemAlertAdd then
			self.handleAlertAdd(userInfo.CM_SystemAlert);
		elseif eventType = EventSystemAlertDelete then
			self.handleAlertDelete(userInfo.CM_SystemAlert);
		endif;
	endif;
	if self.displayType = DISPLAY_BOTH or self.displayType = DISPLAY_TERMINAL then
		tmpTerminal := self.myTerminal;
		tmpEvent := tmpTerminal.getEventFromTerminalEvent(eventType);
		
		if tmpEvent = EventTerminalAlertAdd then
			self.handleAlertAdd(userInfo.CM_SystemAlert);
		elseif tmpEvent = EventTerminalAlertDelete then
			self.handleAlertDelete(userInfo.CM_SystemAlert);
		endif;
	endif;
	
	inheritMethod(eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
