    <JadeMethod name="removeAvailable" id="1705f6d8-3d3e-45b6-a735-2f662c7cdf6f">
        <source>removeAvailable( _obj : Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2016	cnwndl1	Initial creation	TFS 2918 / 2419

*/

vars

	rowIndex : Integer;

begin

	if self.tblAvail.rows &lt; 2 then
		return;
	endif;

	foreach rowIndex in 1 to self.tblAvail.rows reversed do
		if self.tblAvail.accessRow( rowIndex ).itemObject = _obj then
			self.tblAvail.removeItem( rowIndex );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
