    <JadeMethod name="validateReeferTransactions" id="d2816885-3110-42ed-ac70-7e7ab1fd316c">
        <source>validateReeferTransactions(_ti : CM_TrackedItem; _vesselDateUsed : Boolean);

vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_ReeferDaily) then
			transCount := transCount + 1;
			invCount := 0;
			foreach invLine in trans.allInvoiceLines do
				invCount := invCount + 1;
				if invCount = 1 then
					self.assertEqualMsg(invLine.quantity, 7.Real, "Cargo invoice line 1 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore1", "Cargo invoice line 1 ILD");
				elseif invCount = 2 then
					self.assertEqualMsg(invLine.quantity, 7.Real, "Cargo invoice line 2 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore2", "Cargo invoice line 2 ILD");
				elseif invCount = 3 then
					self.assertEqualMsg(invLine.quantity, 7.Real, "Cargo invoice line 3 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore3", "Cargo invoice line 3 ILD");
				elseif invCount = 4 then
					if _vesselDateUsed then
						self.assertEqualMsg(invLine.quantity, 51.Real, "Cargo invoice line 4 quantity"); // based on vessel date
					else
						self.assertEqualMsg(invLine.quantity, 32.Real, "Cargo invoice line 4 quantity"); // based on connect/disconnect dates
					endif;
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore4", "Cargo invoice line 4 ILD");
				endif;
			endforeach;
			self.assertEqualMsg(invCount, 4, "Cargo reefer daily invoice lines");
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 1, "Cargo reefer daily transactions");
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_vesselDateUsed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReeferTransactions2" id="dd7172b4-994b-4a49-bb1f-f47c8521a7c1">
        <source>validateReeferTransactions2(_ti : CM_TrackedItem);
// 

vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach invLine in _ti.invoiceLines do
		invCount := invCount + 1;
		trans := invLine.myTransactionTI;
		if trans.isKindOf(CM_ReeferDaily) then
			transCount := transCount + 1;
			self.assertEqualMsg(invLine.quantity, 10.Real, "Reefer daily invoice line quantity");
		elseif trans.isKindOf(CM_DisconnectPower) then
			self.assertEqualMsg(invLine.quantity, 1.Real, "Disconnect invoice line quantity");
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 3, "Cargo reefer invoice lines");
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateSTWOInvoiceFiles" id="3b7b4b47-563a-4dda-9a3b-b7534418d9df">
        <source>validateSTWOInvoiceFiles(_invoice : CM_Invoice);
/*
Purpose:			
Date		Who		Reason

*/
vars
	now 			: TimeStamp;
	ioFin 			: CM_STWRInterface;
	oArray 			: ObjectArray;
	path,
	line,
	expectedLine	: String;
	file 			: File;
	idx			    : Integer;
	invLine 		: CM_InvoiceLine;
	strArr          : HugeStringArray;
	chargeStr       : String;
	voyage          : CM_Voyage;
	idex            : Integer;
	cntSubType      : Integer;
begin
	
	create strArr transient;
	create oArray transient;
	CM_STWRInterface.allInstances(oArray, 0, false);
	ioFin := oArray[1].CM_STWRInterface;
	voyage := ioFin.getVoyage(_invoice);
	
	foreach invLine in _invoice.invoiceLines  do 
		
		chargeStr := ioFin.getChargeXML(invLine.charges.first,voyage);
		strArr.add(chargeStr);
		
	endforeach;
	
	foreach chargeStr in strArr do
		if chargeStr.cnContains ("&lt;Consignor&gt;") and 
			chargeStr.cnContains ("&lt;BillOfLading&gt;")  and  
			chargeStr.cnContains ("&lt;CargoDescription&gt;")  and  
			chargeStr.cnContains ("&lt;CargoDescription&gt;")  and 
			chargeStr.cnContains ("&lt;Location&gt;") and   
			chargeStr.cnContains ("&lt;IMEX&gt;") 	then
			idex := idex +1 ;
		endif;
		
		if  chargeStr.cnContains ("&lt;CargoSubtype&gt;") then
			cntSubType := cntSubType + 1;
		endif;
	endforeach;
	
	self.assertEqual (idex,4);
	self.assertEqual (cntSubType,2);
epilog
	delete oArray;
	if file &lt;&gt; null then
		if file.isOpen then
			file.close();
		endif;
	endif;
	delete file;
	delete strArr;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="validateSingleStorageTrans" id="5fc9b9f8-950b-49d2-97c7-2598e698a118">
        <source>validateSingleStorageTrans(_trans : CM_Storage; _quantity : Real; _invLineDesc : String; _count : Integer);
// validation where a CM_Storage transaction with a single invoice line is expected
vars
	invCount	: Integer;
	invLine	: CM_InvoiceLine;
begin
	foreach invLine in _trans.allInvoiceLines do
		invCount := invCount + 1;
		self.assertEqualMsg(invLine.quantity, _quantity, "Storage " &amp; _count.String &amp; "invoice quantity");
		self.assertEqualMsg(invLine.invoiceLineDesc.narration, _invLineDesc, "Storage " &amp; _count.String &amp; "invoice ILD");
	endforeach;
	self.assertEqualMsg(invCount, 1, "Storage " &amp; _count.String &amp; " invoice line");
end;
</source>
        <Parameter name="_trans" type="CM_Storage"/>
        <Parameter name="_quantity" type="Real"/>
        <Parameter name="_invLineDesc" type="String"/>
        <Parameter name="_count" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateStorageTransactions1" id="c1ced785-7237-4e18-8655-bbf8be726089">
        <source>validateStorageTransactions1(_ti : CM_TrackedItem);

vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			invCount := 0;
			foreach invLine in trans.allInvoiceLines do
				invCount := invCount + 1;
				if transCount = 1 then
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 5.Real, "Cargo 1 tr 1 inv 1 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore1", "Cargo 1 tr 1 inv 1 ILD");
					elseif invCount = 2 then
						self.assertEqualMsg(invLine.quantity, 4.Real, "Cargo 1 tr 1 inv 2 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore2", "Cargo 1 tr 1 inv 2 ILD");
					endif;
				elseif transCount = 2 then
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 5.Real, "Cargo 1 tr 2 inv 1 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore3", "Cargo 1 tr 2 inv 1 ILD");
					endif;
				elseif transCount = 3 then
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 1.Real, "Cargo 1 tr 3 inv 1 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore3", "Cargo 1 tr 3 inv 1 ILD");
					elseif invCount = 2 then
						self.assertEqualMsg(invLine.quantity, 7.Real, "Cargo 1 tr 3 inv 2 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore4", "Cargo 1 tr 3 inv 2 ILD");
					endif;
				endif;
			endforeach;
			if transCount = 1 then
				self.assertEqualMsg(invCount, 2, "Cargo 1 first storage invoice lines");
			elseif transCount = 2 then
				self.assertEqualMsg(invCount, 1, "Cargo 1 second storage invoice lines");
			elseif transCount = 3 then
				self.assertEqualMsg(invCount, 2, "Cargo 1 third storage invoice lines");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 3, "Cargo 1 storage transactions");
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateStorageTransactions10" id="ab1edd2c-2c7c-4efa-951b-5421261b76ca">
        <source>validateStorageTransactions10(_ti : CM_TrackedItem);
// Created:     Oct 2010 by cnwjre1
// 15 days old, rate = 16.00, 7 days at base rate of 10, 7 more at next week rate of 20 and 1 day at 30, total 240 div 15
vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			invCount := 0;
			foreach invLine in trans.allInvoiceLines do
				invCount := invCount + 1;
				if transCount = 1 then
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 1.Real, "Cargo 4 tr 1 inv 1 quantity");
						self.assertEqualMsg(invLine.lineTotal, 16.00.Decimal, "Cargo 4 tr 1 inv 1 total");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreE", "Cargo 4 tr 1 inv 1 ILD");
					endif;
				endif;
			endforeach;
			if transCount = 1 then
				self.assertEqualMsg(invCount, 1, "Cargo 4 storage invoice lines");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 1, "Cargo 4 storage transactions");
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
