    <JadeMethod name="baseErrorNum" id="6dea212e-08e2-4397-9f89-17d5953e599a">
        <methodInvocation>mapping</methodInvocation>
        <source>baseErrorNum(set : Boolean; _value : Integer io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 October 2025		navmd1	Initial creation DOMTN-285

*/

constants
	USER_EXCEPTION_START	: Integer = 64000;
vars

