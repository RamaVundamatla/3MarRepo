    <JadeMethod name="statusString" id="fef1de1f-8040-4d67-a241-2dac72c4ce02">
        <source>statusString(): String;
// ---------------------------------------------------------------------------
// Created:		22 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
begin
    if self.status = CAM_IDLESTATUS then
        return "Idle";
    elseif self.status = CAM_EXTRACTSTATUS then
        return "Extract";
    elseif self.status = CAM_SENDSTATUS then
        return "Send";
    elseif self.status = CAM_COMPLETESTATUS then
        return "Complete";
    elseif self.status = CAM_RESENDSTATUS then
        return "Resend";
    elseif self.status = CAM_HOLDSTATUS then
        return "Hold";
    elseif self.status = CAM_ERRORSTATUS then
        return "ERROR";
    else
        return self.status.String;
    endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="subElementSeparator" id="fa9be78d-8c06-438c-aa84-64b3484a3829">
        <methodInvocation>mapping</methodInvocation>
        <source>subElementSeparator(set : Boolean; _value : Character io) mapping;
/*
Purpose:		Use default value if property blank

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
20 Feb 2015 cnwma1  PAR #35322 CAM Protocol default separator characters are not correct for X12
*/
vars

begin
	if not set then
		if _value = null then
			if self.isX12 then				//20/02/2015 cnwma1 PAR # 35322
				_value := null;
			else
				_value := self.Default_SubElementSeperator;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Character" usage="io"/>
    </JadeMethod>
    <JadeMethod name="useContainerOperator_In_NAD_CF" id="0e6d6fa1-fdc6-4ca8-b311-0047a92326cc">
        <source>useContainerOperator_In_NAD_CF() : Boolean;

/*
Purpose:		Returns true if self (CamProtocol) specialField17 is set.
				This flag means use the translated Container Operator in the NAD+CF record
				rather than the Cam Group Shippers code.
Date			Who		Reason
06 July 2009	cnwrl1	Initial creation as part of PAR 20192 - CCMS 1818
*/
	
vars
	
begin
	return self.useContainerOperator_NAD_CF;
	
epilog
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="useVoyageOp" id="d62cb7a9-b123-4382-a18a-adfba8cc5af1">
        <source>useVoyageOp(): Boolean;

vars

begin
	
	if self.sendType = self.IGNORE_GRP_USE_VOY_OP then
		return false;
	endif;
	
	if self.camGroup &lt;&gt; null then
		return self.camGroup.useVoyageOperator;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="43119867-2381-4b7e-b441-5a0cbb994a95">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	if self.terminal.camProtocols[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
