<Class name="CM_QIntegerProperty" id="5abad7e1-695a-4ffe-b303-1e5e904181e3">
    <superclass name="CM_QueryProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="ca0b1581-2283-4ee8-8530-4fdf1cbd4e0b">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oper	: CM_QueryOperator;
	
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QIntegerEquals persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerGreaterThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLessThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLessThanEquals persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerGreaterEquals persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="e9216434-8ef9-4abb-9cdd-f89214fc54d6">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//return 10;	//	what it was
	return (Max_Integer * -1).String.length;  
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
