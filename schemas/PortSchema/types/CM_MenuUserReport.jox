    <JadeMethod name="moveToSaved" id="027580ae-adce-47b0-a47a-2bdd04ebc1ba">
        <updating/>
        <source>moveToSaved() updating;

// cnwth2 31 October 2002 

vars
	menuRoot		: CM_MenuRootUserBackgroundReps;
	
begin
	if not self.myMenuRoot.isKindOf(CM_MenuRootUserBackgroundReps) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'BGP Report exists with incorrect menu root type');
		return;
	endif;
	
	menuRoot := self.myMenuRoot.CM_MenuRootUserBackgroundReps;
	self.myMenuRoot	:= menuRoot.myUser.myMenuRootBGRSaved;
	
end;</source>
    </JadeMethod>
