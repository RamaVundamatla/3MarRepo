    <JadeMethod name="comboBoxYardInternalMove" id="493d3c27-5e8c-4401-8f65-6c247eda8321">
        <source>comboBoxYardInternalMove(pTbl : CM_EntryTable input; pAttrName : String; _type : Integer);
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	row : Integer;
	str	: String;
	combo : ComboBox;
begin
	
	str := Plan_On_Pickup_Str &amp; Depot_Request_Str &amp; Tab &amp; Controller_Strip_Str ;		  //cnwrd1 par 26734 CCMS 2014 plan on pickup  

	row := pTbl.getRow(pAttrName);

	
	pTbl.setComboValues(row, str);

//	combo := pTbl.accessCell(row, pTbl.ColumnValue).cellControl.ComboBox;
		
//	combo.addItem(Depot_Request.String);
//	combo.addItem(Controller_Strip.String);
//	combo.itemData[1] := Depot_Request;
//	combo.itemData[2] := Controller_Strip;
	
	if _type = Depot_Request then
		pTbl.setValue(row, Depot_Request_Str);
//		pTbl.accessCell(row, pTbl.ColumnValue).text := ;	
//		combo.listIndex := 1;
	elseif _type = Controller_Strip then
		pTbl.setValue(row, Controller_Strip_Str);
//		pTbl.accessCell(row, pTbl.ColumnValue).text := $Move_Request;		
//		combo.listIndex := 2;
	elseif _type = Plan_On_Pickup then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		pTbl.setValue(row, Plan_On_Pickup_Str);
	endif;

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
