    <JadeMethod name="tblDiffMethods_click" id="64cec29f-d7ad-4248-8d5d-d6e1ee7801d0">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDiffMethods_click(table: Table input) updating;
/*
Purpose:	

Date		Who		Reason
23 October 2025	navab1	JIRA 36455
*/

vars
	currentClass	: DEV_Class;
	cm_Method		: DEV_Method;
	level 			: Integer;
	
begin
	if table.row = table.fixedRows then
		return;
	endif;
	
	cm_Method := table.accessRow(table.row).itemObject.DEV_Method;
	
	self.loadedMethod := cm_Method;
	self.compareMethod(cm_Method);
	table.setFocus();
	
	if self.isWinMergeAvailable then
		self.btnOpenInWinMerge.visible := true;
	endif;
	
	if self.isNppAvailable then
		self.btnOpenInNPP.visible := true;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDiffMethods_contextMenu" id="67bfa126-31a5-49ab-a5f4-ef3978fbd899">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDiffMethods_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Purpose:	// ### JIRA 36455 23OCT2026 NAVAB1

Date		Who		Reason
23 October 2025	navab1
*/

vars
   x1 : Real;
    y1 : Real;
	devEnt	: DEV_SchemaObjectEntity;
begin
    x1 := x;
    y1 := y;
	
    table.windowToScreen(x1, y1);
    self.screenToWindow(x1, y1);   // convert x, y relative to form
    
	self.mnuUnresolve.visible := true;
	self.mnuUnresolve.enabled := false;
	self.mnuTableViewDiff.visible := true;  // ### 23OCT2025 NAVAB1
	
	/*
	if listbox.listIndex &gt;= 1 then
		devEnt := listbox.itemObject[listbox.listIndex].DEV_SchemaObjectEntity;
		if devEnt &lt;&gt; null and devEnt.resolvedBy &lt;&gt; null then
			self.mnuUnresolve.enabled := true;
		endif;
	endif;
	*/
	self.mnuLBContext.userObject := table;
	self.popupMenu(self.mnuLBContext, x1.Integer, y1.Integer);
    
	return false;                  // cancel further processing

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblDiffMethods_dblClick" id="0a61e7a5-cbcd-40b8-a054-f4523ecc5c55">
