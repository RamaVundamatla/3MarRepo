    <JadeMethod name="dumpKeys" id="e86ff080-4265-4514-bda4-13bcc014ab75">
        <source>dumpKeys();
// ---------------------------------------------------------------------------
// Created:     02 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter	:Iterator;
	obj		:Object;
	int		:Integer;
	str		:String;
	error	:Boolean;
begin
	on Exception do self.handleError1314(exception, error);
	
	iter := self.createIterator;
	write 'Keys';
	while iter.next (obj) do
		int 	:= 0;
		str 	:= null;
		error 	:= false;
		
		while true do
			int := int + 1;
			
			if str &lt;&gt; null then
				str := str &amp; ',';
			endif;
			
			str := str &amp; iter.getCurrentKey(int).String;
			
			if error then
				break;	// end of keys
			endif;
		endwhile;
		write str;
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
