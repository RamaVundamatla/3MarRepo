    <JadeMethod name="matchOnForeignCode" id="d8776be1-847d-4498-9b55-0186c33f3b51">
        <source>matchOnForeignCode(_foreignCode : String; _foundMatch :Boolean output; _params: ParamListType) : String;
/*
Purpose:			Return system code from foreign code
Parameters:			_foreignCode	- Foreign code from input
					_foundMatch		- set to true if xlation found
					_params			- for Commodity contains temperature
									- for MT Grade contains temperature and optional text
Return Value:		Matching System code from translation, if there is one

Date		Who		Reason
Sep 2006	cnwrs1	par 12528 
15 Oct 2010	cnwkpd1	PAR #25810 - EDI File load performance
					Rewritten using the assumption that the Foreign codes stored in the translation
					table are all uppercased at creation time, so the number of dictionary accesses 
					can be vastly reduced, for performance
24/08/2012 	cnwmh5	Change to handle disabled
07/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - include _foundMatch in method signatures.  add criteria checking
28/03/20129	jlgzm1	TFS 44011 edi xlations not working when foreign in code more than 30 chars
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/

vars
	foreignCode		: String;
	systemCode		: String;
	xlation 		: CM_Xlation_In;
	iter			: Iterator;
	score, 
	bestMatch		:Integer;
begin
	foreignCode := _foreignCode.trimBlanks().toUpper();

	// it is possible to have a foreign code &gt; 30 character in length so all we can do is
	// attempt a match on the first 30 characters
	/* 15.11.2018 cnwma1
	if foreignCode.length &gt; 30 then
		foreignCode := foreignCode[1:30].trimBlanks;
	endif;
	*/
	//tfs44011
	if app.myRoot.getConfig(EdiXlationTruncateLimit).Boolean then
		foreignCode := foreignCode[1:50];								//21.11.2022 navma1 #55424
	else	
		foreignCode := foreignCode[1:30];								//21.11.2022 navma1 #55424
	endif;
	// first look for the default one or if there is only one then use that
	iter := self.allInwardTranslations.createIterator;

	self.allInwardTranslations.startKeyGeq(foreignCode, iter);
	
	bestMatch := -1;
	
	while iter.next (xlation) do
		if xlation.foreignCode &lt;&gt; foreignCode then
			break;
		endif;
		
		if xlation.isDisabled then
			// only happens in unit tests
			continue;
		endif;
		
		if xlation.canHaveCriteria then
			if not xlation.isCriteriaMatch(score, _params) then
				continue;
			endif;
	
			if score &gt; bestMatch then
				// found a better match
				systemCode 	:= xlation.systemCode;
				bestMatch	:= score;
			endif;
		else
			systemCode := xlation.systemCode;
			break;
		endif;
	endwhile;
	
	// the following match was added for par 12528 when foreign code was changed from length 20 to 30
	// to make sure as could still match on 20 character codes like "Waste and Scrap of P" which is the first
	// 20 character of "Waste and Scrap of Paper"
	// this has been removed as it was a temporary measure.
	
	// No suitable matches, so return original input (trimmed)
	if systemCode = null then
		systemCode := _foreignCode.trimBlanks();
	else
		_foundMatch	:= true;		// par 31259 Marchh 2013
	endif;
	
	return systemCode;
epilog
	delete iter;	
end;
</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <Parameter name="_params" type="ParamListType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="matchOnSystemCode" id="6945cbfd-cfea-4a63-b6b4-d2d338ae8fc8">
        <source>matchOnSystemCode(_systemCode : String; _foundMatch :Boolean output) : String;
// par 12528 cnwrs1 sept 2006
// return foreign code from system code
/*

Date		Who		Reason
18 Oct 2010	cnwkpd1	PAR #25810 - EDI performance.  Added break if more than one
					match found
24/08/2012 	cnwmh5	Change to handle disabled
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/

vars
	xlation 		: CM_Xlation_Out;
	foreignCode 	: String;
begin
	foreach xlation in self.allOutwardTranslations where xlation.systemCode = _systemCode do
		if xlation.isDisabled then
			// just for unit tests
			continue;
		endif;
	
		foreignCode := xlation.foreignCode;
		
		// we only expect one
		break;
	endforeach;
	
	if foreignCode = null then
		foreignCode := _systemCode;
	else
		_foundMatch	:= true;	// par 31259 March 2013
	endif;
	
	return foreignCode;
end;

</source>
        <Parameter name="_systemCode" type="String"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="61db30ec-dca9-4cd2-bf9a-54e028abeb78">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Date		Who		Reason
20 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
vars
	proxy	:SelfType;
	ok		:Boolean;
begin
	proxy := inheritMethod();
	
	proxy.myOperator			:= self.myOperator;
	proxy.myOperatorTerminal	:= self.myOperatorTerminal;
	proxy.myRoot				:= self.myRoot;
	proxy.myCargoType := self.myCargoType;
	proxy.myTerminal := self.myTerminal;  //epr TFS 42095 22/11/18
	ok := true;		
	
	return proxy;
epilog
	if not ok then			
		delete proxy;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresSystemObj" id="042461de-8750-44ef-9318-9d781f445f64">
        <source>requiresSystemObj() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 Feb 2023		jlizm1	Initial creation TFS 56604 CSV Import of translation terms - improve error messages
08 Jun 2023		jlika1	TFS 58320 58319 | Jade work for Translations
12 June 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
08 Nov 2023		jlika1	TFS 61129 61013 CUX | Cargo Priority - EDI Translation
*/

vars
	theType : Integer;
	
begin

	theType := self.type;
	
	if theType = XLATION_TYPE_CUSTPRIORITY_BYOP or
	   theType = XLATION_TYPE_CARGOSUBTYPE_BYOP or
	   theType = XLATION_TYPE_CARGOTYPE_BYOP or
	   theType = XLATION_TYPE_CARRIER_BYOP or
	   theType = XLATION_TYPE_COMMODITY_BYOP or
	   theType = XLATION_TYPE_CONSIGNEE_BYOP or
	   theType = XLATION_TYPE_CUSTOMSAGENT or
	   theType = XLATION_TYPE_ISOTYPE_BYOP or
	   theType = XLATION_TYPE_INSTRUCTTERMINAL or
	   theType = XLATION_TYPE_MTGRADE_BYOP or
	   theType = XLATION_TYPE_OPERATOR or
	   theType = XLATION_TYPE_OPERATOR_BYOP or
	   theType = XLATION_TYPE_PORT_BYOP or
	   theType = XLATION_TYPE_SHIPPINGLINE or
	   theType = XLATION_TYPE_TERMINAL_BYOP or
	   theType = XLATION_TYPE_TRAILER_TYPE or
	   theType = XLATION_TYPE_VESSEL or
	   theType = XLATION_TYPE_VESSEL_TYPE or	//11 Sep 2018	NDL	TFS 40778
	   theType = XLATION_TYPE_VESSEL_BYOP or
	   theType = XLATION_TYPE_VOYAGETERMINAL or
	   theType = XLATION_TYPE_SHIPINGAGENT_BYOP or
	   theType = XLATION_TYPE_SHIPPINGLINE_BYOP
	   then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="87df7d70-413d-4ce4-842c-74c380346887">
        <updating/>
        <source>setForCreate(_proxy : CM_XlationTable) updating;
// 19/03/2013	cnwcs5	CCMS POL 2097 / PAR 31259
//19 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
vars
	opTerm	: CM_OperatorTerminal;
begin
	self.myRoot := _proxy.myRoot;

	opTerm := _proxy.myOperatorTerminal;
	
	if opTerm &lt;&gt; null then
		if not opTerm.isTransient then
			self.myOperatorTerminal := opTerm;
		endif;
	else
		self.myOperator := _proxy.myOperator;
	endif;
	
	self.myCargoType := _proxy.myCargoType;
	self.myTerminal := _proxy.myTerminal; //epr TFS 42095 22/11/18
	// note this must be done last
	self.type := _proxy.type;
end;
</source>
        <Parameter name="_proxy" type="CM_XlationTable"/>
    </JadeMethod>
