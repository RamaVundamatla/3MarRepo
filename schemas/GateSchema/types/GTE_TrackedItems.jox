    <JadeMethod name="cmbISOType_lostFocus" id="35d36f20-9dc1-4ba6-a8bb-2cfc16e0c68b">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbISOType_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16/12/2009	cnwmh5		PAR #21921 - add loading of ISO Group combo based on 
//							what is in ISO Type
// ---------------------------------------------------------------------------

vars
	isoTypeGroup 	: CM_ISOTypeGroup;
begin

	self.tblInput.setValueByControlName(combobox.name, combobox.text);
	self.myISOType := combobox.listObject.CM_ISOType;
	
	// 16/12/2009 cnwmh5 #21921 - Start
	if self.myISOType &lt;&gt; null and self.chkUseFilter.value then 
		self.myAssistant.comboBoxISOTypeGroupFilter(self.cmbISOGroup, self.myISOType.myISOTypeGroup);
	else
		self.myAssistant.comboBoxISOTypeGroup(cmbISOGroup, self.myISOGroup); //have to refill ISO group here as it may have been limited from the ISO type selection in below mode. // cnwrd1 par 22789 15/3/2010
	endif;
		
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
