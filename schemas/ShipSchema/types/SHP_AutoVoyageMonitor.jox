    <JadeMethod name="doBuildCmbOperator" id="3ec272ed-1e69-45f4-b057-aa70226a58c0">
        <source>doBuildCmbOperator();
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars
	operator : CM_Operator;
begin
	self.cmbOperator.clear();
	self.cmbOperator.sorted := true;
	
	
	foreach operator in app.myRoot.allOperators discreteLock do
	self.cmbOperator.addItemObject(operator.code &amp; " - " &amp; operator.description, operator);
	
	endforeach;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbStatus" id="6b81a995-ff76-4e62-b16c-ef74486e83e6">
        <source>doBuildCmbStatus();
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars

begin
	self.cmbStatus.clear();
	self.cmbStatus.sorted := true;
	
	self.cmbStatus.addItemWithData(CM_VoyageStage@getStatusDesc(CM_VoyageStage.STATUS_SUCCESS), CM_VoyageStage.STATUS_SUCCESS);
	self.cmbStatus.addItemWithData(CM_VoyageStage@getStatusDesc(CM_VoyageStage.STATUS_FAILED), CM_VoyageStage.STATUS_FAILED);
	self.cmbStatus.addItemWithData(CM_VoyageStage@getStatusDesc(CM_VoyageStage.STATUS_WAITING), CM_VoyageStage.STATUS_WAITING);
	self.cmbStatus.addItemWithData(CM_VoyageStage@getStatusDesc(CM_VoyageStage.STATUS_UNKNOWN), CM_VoyageStage.STATUS_UNKNOWN);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doClear" id="a262d089-7fa7-4ef3-97e2-8be94b2e9c20">
        <source>doClear();
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars

begin
	self.cmbOperator.listIndex := -1;
	self.cmbStatus.listIndex := -1;
	
	//navra1 - MTN-33017 - 11th Oct 2024 - start
	/*
	self.mskStart.setDate(self.myCurrentVoyage.arrivedDT.addDays(-1).date);
	self.mskStartTime.setTime(self.myCurrentVoyage.arrivedDT.time);

	if self.myCurrentVoyage.departedDT.isValid() then
		self.mskEnd.setDate(self.myCurrentVoyage.departedDT.addDays(1).date);
		self.mskEndTime.setTime(self.myCurrentVoyage.departedDT.time);
	
	else
		self.mskEnd.setDate(null);
		self.mskEndTime.setTime(null);
	endif;
	*/
	
	self.mskEnd.setDate(null);
	self.mskEndTime.setTime(null);
	self.mskStart.setDate(null);
	self.mskStartTime.setTime(null);
	//navra1 - MTN-33017 - 11th Oct 2024 - end
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="01154c53-81af-4f35-ace6-547b14b3ea32">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*
Purpose - 	
Who - NAVAB1
Date - 18JUL2024
ADO - CR 64612 TASK 64659
*/

vars
	stage : CM_VoyageStage;
	event : Integer;
	idx : Integer;
	theDataLine : String;
	backclr : Integer;									//navra1 - TFS 65376 - 31st July 2024 - 1
	voyage : CM_Voyage;									//navra1 - MTN-34347/MTN-34395 - 19th Mar 2025
	pxyVoyageProgress : CM_VoyageProgress;				//navra1 - MTN-34347/MTN-34395 - 19th Mar 2025
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if userInfo.isKindOf(CM_VoyageStage) then
		stage := userInfo.CM_VoyageStage;
	elseif theObject.isKindOf(CM_VoyageStage) then
		stage := theObject.CM_VoyageStage;
	elseif theObject.isKindOf(CM_Voyage) then				//navra1 - MTN-34347/MTN-34395 - 19th Mar 2025			
		voyage := theObject.CM_Voyage;						//navra1 - MTN-34347MTN-34395 - 19th Mar 2025
	endif;
	
	if event = Event_VoyageStageCreate then
		if stage &lt;&gt; null then	
			if self.doIncludeObject(stage) then
				self.addRowToTable(stage);
			endif;
		endif;
	elseif event = Event_VoyageStageUpdate then
		if stage &lt;&gt; null then
			self.tblData.findObjectInRow(stage,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := stage.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
				//navra1 - TFS 65376 - 31st July 2024 - 1 - start
				if stage &lt;&gt; null then
					if self.chkShowColours.value then
						backclr :=  self.getColourForStatus(stage.status);
						self.tblData.accessRow(idx).backColor := backclr;
						self.tblData.accessedRow.foreColor := backclr.getInverseColour();
					endif;
				endif;
				//navra1 - TFS 65376 - 31st July 2024 - 1 - end
			endif;
		endif;
	elseif event = Event_VoyageStageDelete then
		self.tblData.removeItemObject(stage);
		self.doNotableClear(stage);
	//navra1 - MTN-34347/MTN-34395 - 19th Mar 2025 - start
	elseif event = Voyage_Update_Event then
		if self.myCurrentVoyage = voyage then			
			if voyage.status &lt;&gt; Voyage_Status_Autoff_Auto and self.chkPauseAutoProcess.value = true then			//navra1 - MTN-34516 - 3rd Apr 2025
				//if the current voyage status is anything but PAUSED(actual status &lt;&gt; PAUSED)  - ie. it is unpaused currently, but the progress screen says it is PAUSED
				self.chkPauseAutoProcess.value := false;				
				
				pxyVoyageProgress := app.createUpdateProxy(self.myCurrentVoyage.myVoyageProgress).CM_VoyageProgress;
				
				if voyage.myVoyageProgress.pauseProgress &lt;&gt; self.chkPauseAutoProcess.value then				//navra1 - MTN-34516 - 3rd Apr 2025
					if process.isInTransactionState() then
						app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, self.chkPauseAutoProcess.value, app.myPassport);
					else
						app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, self.chkPauseAutoProcess.value, app.myPassport);
					endif;
				endif;																						//navra1 - MTN-34516 - 3rd Apr 2025
				
			elseif voyage.status = Voyage_Status_Autoff_Auto and self.chkPauseAutoProcess.value = false then		//navra1 - MTN-34516 - 3rd Apr 2025
				//if the current voyage status is PAUSED(actual status = PAUSED) - ie. it is paused currently, but the progress screen says it is NOT PAUSED
				self.chkPauseAutoProcess.value := true;
				
				pxyVoyageProgress := app.createUpdateProxy(self.myCurrentVoyage.myVoyageProgress).CM_VoyageProgress;
				
				if voyage.myVoyageProgress.pauseProgress &lt;&gt; self.chkPauseAutoProcess.value then				//navra1 - MTN-34516 - 3rd Apr 2025
					if process.isInTransactionState() then
						app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, self.chkPauseAutoProcess.value, app.myPassport);
					else
						app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, self.chkPauseAutoProcess.value, app.myPassport);
					endif;
				endif;																						//navra1 - MTN-34516 - 3rd Apr 2025
				
			endif;
		endif;
	//navra1 - MTN-34347/MTN-34395 - 19th Mar 2025 - end
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete pxyVoyageProgress;				//navra1 - MTN-34347/MTN-34395 - 19th Mar 2025
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doIncludeObject" id="529e1255-39d4-497f-9db4-70f7d3756d6f">
        <source>doIncludeObject(_stage : CM_VoyageStage) : Boolean;
/*
Purpose:	

Date		Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	operator : CM_Operator;
	status : Integer;
	
	startTS, endTS : TimeStamp;
begin
	startTS.setDate(self.mskStart.getDate()); 
	endTS.setDate(self.mskEnd.getDate()); 
	startTS.setTime(self.mskStartTime.getTime()); 
	endTS.setTime(self.mskEndTime.getTime()); 
	
	operator := self.cmbOperator.listObject.CM_Operator;
	status := self.cmbStatus.listData;
	
		if operator &lt;&gt; null
		and operator.code &lt;&gt; _stage.operatorCode then
			return false;
		endif;
	
		if status &lt;&gt; 0
		and status &lt;&gt; _stage.status then
			return false;
		endif;
	
		if startTS.isValid() 
		and _stage.dateTime &lt; startTS then
			return false;
		endif;
	
		if endTS.isValid() 
		and _stage.dateTime &gt; endTS then
			return false;
		endif;

		return true;
epilog

end;</source>
        <Parameter name="_stage" type="CM_VoyageStage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
