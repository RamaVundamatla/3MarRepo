    <JadeMethod name="displayEntryOperator" id="a7309a6d-7213-4a7d-b89e-b2f1f94425a7">
        <source>displayEntryOperator(pOperator : CM_Operator) : String;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
// ---------------------------------------------------------------------------
vars

	 failedDAC  :CM_DataAccessController;

begin

	if pOperator = null then
		return null;
	endif;

	if (not pOperator.canUserAccessSelf(null, failedDAC,  app.myPassport)) then
		return null;
	endif;

	if pOperator.isNotAvailableForEntry then
		return null;
	endif;	
	
	if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
		return pOperator.description &amp; Tab &amp; pOperator.code;	// TFS 53362
	else														// TFS 53362
		return pOperator.code &amp; Tab &amp; pOperator.description;
	endif;														// TFS 53362
	
end;</source>
        <Parameter name="pOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryOperatorAll" id="fb4377f3-5b0c-48d1-97be-42437d2d1488">
        <source>displayEntryOperatorAll(pOperator : CM_Operator) : String;
// ---------------------------------------------------------------------------
// Created:     12 October 2005 by cnwhjg
//
// Purpose:     include not available for entry objects. this is only used in 
//				certian places where we want not available for entry objects to
//				be displayed. 
// Parameters:  None
//
// Returns:     Nothing
//
// ----------   ----------  --------------------------------------------------
// 27/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
// ---------------------------------------------------------------------------
vars

	 failedDAC  :CM_DataAccessController;

begin

	if pOperator = null then
		return null;
	endif;

	if (not pOperator.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;

//	if pOperator.isNotAvailableForEntry then
//		return null;
//	endif;	
	
	if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
		return pOperator.description &amp; Tab &amp; pOperator.code;	// TFS 53362
	else														// TFS 53362
		return pOperator.code &amp; Tab &amp; pOperator.description;
	endif;														// TFS 53362
	
end;</source>
        <Parameter name="pOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
