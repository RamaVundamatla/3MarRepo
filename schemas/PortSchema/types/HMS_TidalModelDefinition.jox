    <JadeMethod name="setForUpdate" id="bd142a29-9660-4ca2-b368-f1f1db53ef3b">
        <updating/>
        <source>setForUpdate(_pxyTidalModel : HMS_TidalModelDefinition; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	preExistingTidalData,
	pxyTidalData,
	newTidalData			: HMS_TidalData;
	tidalDataClass			: Class;
	theDate,
	nextDate				: Date;
begin
	self.raiseExceptionIfTransient(method);
	
	self.code 		:= _pxyTidalModel.code;
	self.description:= _pxyTidalModel.description;
	self.dataType 	:= _pxyTidalModel.dataType;
	self.dataSource := _pxyTidalModel.dataSource;
	self.myRoot 	:= _pxyTidalModel.myRoot;
	self.highestValue := _pxyTidalModel.highestValue;
	self.lowestValue := _pxyTidalModel.lowestValue;
	
	//self.chartDatum := _pxyTidalModel.chartDatum;
	self.declaredDepth := _pxyTidalModel.declaredDepth;
	self.underKeelClearance := _pxyTidalModel.underKeelClearance;
	//self.allHMSTidalData.purge();
	//this is set on the proxy during validation
	self.hasGaps := _pxyTidalModel.hasGaps;
	
	foreach pxyTidalData in _pxyTidalModel.allHMSTidalData do
		//th2 tidal data can only be added or over-written - so delete if existing data with this timestamp
		delete self.allHMSTidalData[pxyTidalData.ts];
		
		create newTidalData as pxyTidalData.class persistent;
		newTidalData.setForUpdate(pxyTidalData, _passport);
		newTidalData.setMyTidalModelDefinition(self);
	endforeach;
	self.getTideFileName := _pxyTidalModel.getTideFileName; //CCMS1640 cnwrs1 jan 2009 
end;


</source>
        <Parameter name="_pxyTidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ccfbac5e-8056-43dc-a315-7e494dd86eff">
        <updating/>
        <source>setProxy(_code,
		_description 	: String;
		_dataType		: Integer;
		_dataSource 	: String;
		_highestValue,
		_lowestValue,
		_declaredDepth,
		_underKeelClearance : Real;
		_hasGaps		: Boolean;
		_root 			: CM_Root;
		_getTideFileName : String) updating; //CCMS1640 cnwrs1 Jan 2009
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.code 			:= _code.trimBlanks.toUpper;
	self.description 	:= _description.trimBlanks;
	self.dataType 		:= _dataType;
	self.dataSource		:= _dataSource.trimBlanks;
	self.highestValue	:= _highestValue;
	self.lowestValue	:= _lowestValue;
	//self.chartDatum		:= _chartDatum;
	self.myRoot 		:= _root;
	self.declaredDepth := _declaredDepth;
	self.underKeelClearance := _underKeelClearance;
	self.getTideFileName := _getTideFileName; //cnwrs1 Jan 2009
end;


</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_dataSource" type="String"/>
        <Parameter name="_highestValue" type="Real"/>
        <Parameter name="_lowestValue" type="Real"/>
        <Parameter name="_declaredDepth" type="Real"/>
        <Parameter name="_underKeelClearance" type="Real"/>
        <Parameter name="_hasGaps" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_getTideFileName" type="String"/>
