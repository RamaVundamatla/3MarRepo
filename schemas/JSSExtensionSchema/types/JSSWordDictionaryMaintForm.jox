    <JadeMethod name="cmbDictionary_sysNotify" id="5be9d87f-4c38-4a7e-ad0b-af8a7e9b2e21">
        <controlMethod name="ComboBox::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDictionary_sysNotify(combobox: ComboBox input; eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		10 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if cmbDictionary.listIndex = JSS_NULL_INDEX then
		cmbDictionary.listIndex	:=	cmbDictionary.findStringExact(1, JSSWordDictionary.DEFAULT_NAME);
		self.setStartRow(null);
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
