    <JadeMethod name="create" id="5cea1246-92d8-48b2-ba2e-791d34663fbc">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.name := EDIFileName_UserDummy;
	self.type	:= EDIFileType_UserDefined;
	self.createConfig();// cnwrd1 ccms 1660 8.8.2008
end;</source>
    </JadeMethod>
    <JadeMethod name="createCSVFile" id="5fa228c8-d62a-4f67-8a14-58c3e09b0db6">
        <source>createCSVFile(_ediData : CM_EDIData; _fileName : String);
//
// 16 Jan 2012	MSL CCMS 1009 PAR 29024
//
vars
	ediTI : CM_EDITrackedItem;
	fieldMappingType : CM_EDIFieldMappingType;
	fieldMapping : CM_EDIFieldMapping;
	value : Any;
	str : String;
	file : File;
	aClass : Class;
begin
	create file transient;
	file.fileName := _fileName;
	file.mode := File.Mode_Output;
	file.open;
	foreach ediTI in _ediData.allEDITrackedItems do
		str := null;
		foreach fieldMappingType in self.allEDIFieldMappingTypes do
			aClass := _ediData.getEDITIType(fieldMappingType.ediDataType);
			if aClass = ediTI.class then
				foreach fieldMapping in fieldMappingType.allEDIFieldMappings do
					value := null;
					value := ediTI.getValueSpecial(fieldMapping.propName, self.myXlationOperator); 
					if value = null and 
					   self.controlColumn = fieldMapping.fieldNum then
						value := fieldMappingType.controlValue;
					endif;
					if str = null then
						str := value.String;
					else
						str := str &amp; self.delimiter &amp; value.String;
					endif;
				endforeach;
			endif;
		endforeach;
		if str &lt;&gt; null then
			file.writeLine(str);
		endif;
	endforeach;
epilog
	file.close;
	delete file;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createConfig" id="33fd940b-c142-40e4-906b-c5fe4bf9c879">
        <updating/>
        <source>createConfig() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2008	cnwrd1	Initial creation

*/

vars

begin
	if self.myEDIFileConfig = null then
		if self.isTransient then
			// setting the proxy
			create self.myEDIFileConfig transient;
		else
			// updating the persistent object so must be transaction state already
			create self.myEDIFileConfig persistent;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createEDITI" id="3e2dfa90-6c1d-4bc5-90b8-5bcad4362710">
        <source>createEDITI(_ediData : CM_EDIData; _ediDataType : Integer) : CM_EDITrackedItem;
/*
----------   ----------  --------------------------------------------------
Created:	01 March 2007 By cnwth2

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ediTI		: CM_EDITrackedItem;
	ediTIClass	: Class;
begin
	if _ediData.getEDITIType(_ediDataType)&lt;&gt; null then			//navsaa30
		ediTIClass := _ediData.getEDITIType(_ediDataType).firstNonAbstractSubclass();
	endif;
	
	if ediTIClass = null or ediTIClass = CM_EDITrackedItem then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI TI type to create invalid for type (' &amp; _ediData.String &amp; ')');
		return null;
	endif;
	
	create ediTI as ediTIClass persistent;
	
	return ediTI;
end;


</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doAutoProcessVoyageLookup" id="575b23e1-db2b-42c8-a49f-63d89c1848c1">
        <source>doAutoProcessVoyageLookup(_ediTI : CM_EDITrackedItem io; _voyageCodeOnFile, _lloydsCode : String; _ediFile : CM_EDIFile; _allStripChars : CharacterArray; _xlationOperator, _ediDataXlationOperator : CM_Operator);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19 Jul 2024	navdap1		Initial creation CR 64619/Task 64654 NSW - EDI Ops Comparison List Type and Choose Voyage
//										and  ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code
//
vars
	terminal : CM_Terminal;
	voy, tryVoy, voyageDetermined : CM_Voyage;
	vessel : CM_Vessel;
	loadListType : String;

begin
	terminal := app.myPassport.myTerminal;
	
	// store off the raw voyage code on the EDI TI for later (we use this in validation to see if there's a mix of Load and Discharge in the file)
	_ediTI.saveRawVoyageCode(_voyageCodeOnFile);
	
	// check if the ediTI has a valid voyage code
	// use the voyage code on file only if it corresponds to a voyage on the terminal, otherwise we will try to fill it up later
	voy := terminal.allVoyagesByCode.getAtKeyGeq(_voyageCodeOnFile, null);	
	if voy = null or voy.code &lt;&gt; _voyageCodeOnFile or _ediTI.myEDIData.CM_EDIDataLoadList.listType = '' then											//navra1 - TFS 65482 - 5th August 2024
		// the voyage on file does not correspond to a voyage on the terminal, so you havent filled it up yet, try now
		// find the vessel for the IMO Code
		vessel := app.myRoot.allVesselsByLloydsNumber[_lloydsCode];
		
		if vessel &lt;&gt; null then
			// use the inwards code and external reference dictionaries to try to find a voyage with a matching vessel
			tryVoy := terminal.allVoyagesByInwardCodeAuto[_voyageCodeOnFile, vessel.code];
			if tryVoy &lt;&gt; null then
				loadListType := "D";
				voyageDetermined := tryVoy;
			else
				tryVoy := terminal.allVoyagesByInwardCode[_voyageCodeOnFile];
				if tryVoy &lt;&gt; null then
					loadListType := "D";
					voyageDetermined := tryVoy;
				endif;
			endif;
			// if we didn't find a match on inwards code, but the inwards code matches the voyage code,
			// this is a discharge (the inwards codes collections aren't populated if the inwards code matches the voyage code)
			if voy &lt;&gt; null and voy.inwardCodeAuto = voy.code and voyageDetermined = null then
				loadListType := "D";
				voyageDetermined := voy;
			endif;
			
			// still not found? try external code
			if voyageDetermined = null then
				tryVoy := terminal.allVoyagesByExtCodeAuto[_voyageCodeOnFile, vessel.code];
				if tryVoy &lt;&gt; null then
					loadListType := "L";
					voyageDetermined := tryVoy;
				else
					tryVoy := terminal.allVoyagesByExternalCode[_voyageCodeOnFile];
					if tryVoy &lt;&gt; null then
						loadListType := "L";
						voyageDetermined := tryVoy;
					endif;
				endif;
			endif;
			// if we didn't find a match on external code, but the external code matches the voyage code,
			// this is a load (the external codes collections aren't populated if the external code matches the voyage code)
			if voy &lt;&gt; null and voy.voyageCodeExternalAuto = voy.code and voyageDetermined = null then
				loadListType := "L";
				voyageDetermined := voy;
			endif;
			
			// if we found a voyage, update the ediTI with the voyage code and the load list type
			if voyageDetermined &lt;&gt; null and voyageDetermined.isAutomaticProcess() then
				_ediTI.setEDITIProperty(ETRow_VoyageCode, voyageDetermined.code, _ediFile, _allStripChars, _xlationOperator, _ediDataXlationOperator);
				_ediTI.myEDIData.CM_EDIDataLoadList.setVoyageCode(voyageDetermined.code);
				_ediTI.myEDIData.CM_EDIDataLoadList.setListType(loadListType);
				_ediTI.myEDIData.CM_EDIDataLoadList.setVesselName(vessel.code);		// Keep this for later to use in Load / Discharge validation as well
			endif;
		else
			// didn't find a vessel? Oh well
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="io"/>
        <Parameter name="_voyageCodeOnFile" type="String"/>
        <Parameter name="_lloydsCode" type="String"/>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_allStripChars" type="CharacterArray"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_ediDataXlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="exportMyCollectionsXML" id="bee8582b-0aed-4aeb-9a8a-bc2801be76e1">
        <source>exportMyCollectionsXML(_file: File; _objArray: ObjectArray io);
/*
----------   ----------  --------------------------------------------------
Created:	05 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars
	fieldMappingType : CM_EDIFieldMappingType;
begin
	_file.writeLine('&lt;'&amp;CM_EDIFileTypeUser::allEDIFieldMappingTypes.name&amp;'&gt;');
	foreach fieldMappingType in self.allEDIFieldMappingTypes do
		fieldMappingType.exportMeXML(_file, _objArray, true, true);
	endforeach;
	_file.writeLine('&lt;/'&amp;CM_EDIFileTypeUser::allEDIFieldMappingTypes.name&amp;'&gt;');
	
	// 3.4.09 cnwrd1 par 19188 //ccms1008 messina  cnwrs1 Sept 2009
//	_file.writeLine('&lt;'&amp;CM_EDIFileTypeUser::allEDIFieldHookCodes.name&amp;'&gt;');
//	foreach hookCode in self.allEDIFieldHookCodes do
//		hookCode.exportMeXML(_file, _objArray, true, true);
//	endforeach;
//	_file.writeLine('&lt;/'&amp;CM_EDIFileTypeUser::allEDIFieldHookCodes.name&amp;'&gt;');
end;


</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="exportMyReferencesXML" id="8eaa4240-e325-4a14-99e7-f2ec19297635">
        <source>exportMyReferencesXML(_file: File; _objArray: ObjectArray io);
/*
----------   ----------  --------------------------------------------------
Created:	05 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	fileType : CM_EDIFileTypeUser;

begin
	if self.myXlationOperator &lt;&gt; null then
		_file.writeLine(app.formatAsXML('myXlationOperator', self.myXlationOperator.code));
	endif;

	// 3.4.09 cnwrd1 par 19188
	if self.myIncludeLineHookCode &lt;&gt; null then
		_file.writeLine('&lt;'&amp;CM_EDIFileTypeUser::myIncludeLineHookCode.name&amp;'&gt;');
		self.myIncludeLineHookCode.exportMeXML(_file, _objArray, true, true);
		_file.writeLine('&lt;/'&amp;CM_EDIFileTypeUser::myIncludeLineHookCode.name&amp;'&gt;');
	endif;
	
	// 3.4.09 cnwrd1 par 19188
	/*
	if self.myIncludeLineHookLink &lt;&gt; null then
		_file.writeLine('&lt;'&amp;CM_EDIFileTypeUser::myIncludeLineHookLink.name&amp;'&gt;');
		self.myIncludeLineHookLink.exportMeXML(_file, _objArray, true, true);
		_file.writeLine('&lt;/'&amp;CM_EDIFileTypeUser::myIncludeLineHookLink.name&amp;'&gt;');
	endif;
	*/
	
	//03 Jan 2019	NDL	TFS 42303
	fileType := self;
	if self.dataType = EDIDataType_LoadList then
		if fileType.getConfig(GeneratePins).Boolean then
			_file.writeLine('&lt;' &amp; GeneratePins &amp; '&gt;true&lt;/' &amp; GeneratePins &amp; '&gt;');
		endif;
		
	elseif self.dataType = EDIDataType_Prenote then
		if fileType.getConfig(GeneratePins).Boolean then
			_file.writeLine('&lt;' &amp; GeneratePins &amp; '&gt;true&lt;/' &amp; GeneratePins &amp; '&gt;');
		endif;
		if fileType.getConfig(SkipDuplicates).Boolean then
			_file.writeLine('&lt;' &amp; SkipDuplicates &amp; '&gt;true&lt;/' &amp; SkipDuplicates &amp; '&gt;');
		endif;
		if fileType.getConfig(CreateBookings).Boolean then
			_file.writeLine('&lt;' &amp; CreateBookings &amp; '&gt;true&lt;/' &amp; CreateBookings &amp; '&gt;');
		endif;
		if fileType.getConfig(InvalidVoyageDefaultNull).Boolean then
			_file.writeLine('&lt;' &amp; InvalidVoyageDefaultNull &amp; '&gt;true&lt;/' &amp; InvalidVoyageDefaultNull &amp; '&gt;');
		endif;
		
	endif;
end;


</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="extractFile" id="9efd27c2-0189-4be9-b320-12b27b3f59cc">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
//
// 16 Jan 2012	MSL CCMS 1009 PAR 29024
//
//10 Dec 2012	cnwrs1	Par 30873	EDI RORO Deck Plan extract in location order
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	ediData : CM_EDIData;
	ediTI : CM_EDITrackedItem;
	fieldMappingType : CM_EDIFieldMappingType;
	fieldMapping : CM_EDIFieldMapping;
	value : Any;
	str : String;
	aClass : Class;
	objArray : CM_ObjectArray;
	obj : Object;
	lineStr : String;
begin
	ediData := _ediFile.ediData;
	if (not CM_EDIDataDeckPlan.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;
	create objArray transient;
	ediData.getAllEDITrackedItems(objArray);
	foreach obj in objArray do
//	foreach ediTI in ediData.allEDITrackedItems do
		ediTI := obj.CM_EDITrackedItem;
		str := null;
		foreach fieldMappingType in self.allEDIFieldMappingTypes do
			aClass := ediData.getEDITIType(fieldMappingType.ediDataType);
			if aClass = ediTI.class then
				foreach fieldMapping in fieldMappingType.allEDIFieldMappings do
					value := null;
					value := ediTI.getValueSpecial(fieldMapping.propName, self.myXlationOperator); 
					if value = null and 
					   self.controlColumn = fieldMapping.fieldNum then
						value := fieldMappingType.controlValue;
					endif;
//write(class.name&amp;'::'&amp;method.name&amp;' '&amp;fieldMapping.propName&amp;' '&amp;value.String.removeCrLfs);
					if str = null then
						str := value.String.removeCrLfs;
					else
						str := str &amp; self.delimiter &amp; value.String.removeCrLfs;
					endif;
				endforeach;
			endif;
		endforeach;
		if str &lt;&gt; null then
			lineStr := lineStr &amp; str &amp; CrLf;
		endif;
	endforeach;
	_ediFile.setRawDataString(lineStr);
	_ediFile.writeFile();
epilog
	delete objArray;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="b53677cd-1ac7-4a77-9c3c-db610e7feaec">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
/*
----------   ----------  --------------------------------------------------
Created:	01 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	_dataType := self.dataType;
	_ediDataClass := app.myRoot.myEdiConfig.getEDIDataClassForType(self.dataType);	
//	if _ediDataClass = CM_EDIDataBookingRef then //par 24875 cnwrs1 5/7/2010
//		_ediDataClass := CM_EDIDataBooking;	//cnwrs1 CCMS 1882 03 June 2010
//	endif;
	_fileTypeCode := self.type;
	
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getConfig" id="ba1d5b35-1205-4f72-b8f5-7c2892bb2cff">
        <updating/>
        <source>getConfig(_key : String) : Any updating;	

vars

begin
	if myEDIFileConfig = null then
		return null;
	endif;
	return myEDIFileConfig.getConfig(_key);
end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getConfigWarningsToIgnore" id="46a215f4-8b93-46f9-a7b6-0893048bfda3">
        <updating/>
        <source>getConfigWarningsToIgnore(_errorList : ObjectArray io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2008	cnwrd1	Initial creation

*/

vars
	interestedError		: CM_InterestedWarning;
	errorObj			: XLAT_Translation;
	dict				: XLAT_TranslationByCatAndNumber;
begin
	dict := app.myRoot.allLocales['0000'].allXlatTranslationsByCatNumber;
		
	if self.myEDIFileConfig &lt;&gt; null then
		foreach interestedError in self.myEDIFileConfig.allWarningsToIgnore  do
			errorObj := dict[XLAT_Exceptions, interestedError.errorCode];
			if errorObj &lt;&gt; null then
				_errorList.add(errorObj);
			endif;
		endforeach;
	endif;		
epilog

end;</source>
