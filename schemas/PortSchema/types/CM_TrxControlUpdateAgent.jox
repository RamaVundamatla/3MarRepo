        <updating/>
        <source>trxUpdateVehicleRegNumber(	_vehicle : CM_Vehicle input;
							_regNumber, _state : String;
							_passport : CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 August 2006	cnwer1	Initial creation - PAR#xxxx
16 October 2009	cnwdap1	PAR #21320 Allow change of State with Reg Number
*/
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	beginTransaction;
	app.myUtilityUA.utlUpdateVehicleRegNumber(_vehicle,_regNumber,_state,_passport);
	if _passport.noErrors then
		app.myEventManager.createSingleObjInfoNoteEvt(_vehicle, _vehicle.CM_Vehicle.myTerminal.getTerminalEvent(Vehicle_Update_Event), _vehicle);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
