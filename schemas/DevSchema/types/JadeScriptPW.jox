    <JadeMethod name="tfs55834" id="ca344021-57ed-4db4-a610-e2c59a770c88">
        <source>tfs55834();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2023	navpw1	Initial creation TFS: 55834

*/

vars
	theXML, theXMLValue : String;
	keyValue : String;
	//selected : ObjectArray;
	row,
	entTableRow : EntTableRow;
	assocDict : DynaDictionary;
	lastPos : Integer;
	userWindow	: CM_UserWindow;
	entDefAll : EntTableDef;
	array : CM_ObjectArray;
	obj : Object;
	objectSet : CM_ObjectSet;
	timeslot : CM_VehicleBookingTimeSlot;
	str : String;
	alertDesc,
	toAddress,
	ccAddress,
	bccAddress,
	fromAddress,
	sendSubject,
	sendMessage			: String;
	blob			: Binary;
	blobFileName	: String;
	
begin
	app.initialize;
	app.createMyController(CMUI_Controller);
	userWindow := app.getUserWindow(CMUI_VBSEmailConfigure.name, false);
	
	if userWindow = null then
		//use all ent rows
	else
		theXML := userWindow.xmlInfo;
	endif;
	
	//Dev code
	theXML := "&lt;showCaptions&gt;false&lt;/showCaptions&gt;
&lt;showEnhanced&gt;false&lt;/showEnhanced&gt;
&lt;listTablemulSelectEmailLayout&gt;
&lt;selectedValue&gt;Carrier&lt;/selectedValue&gt;
&lt;selectedValue&gt;Vehicle Booking Id&lt;/selectedValue&gt;
&lt;selectedValue&gt;Sub Carrier&lt;/selectedValue&gt;
&lt;selectedValue&gt;Pre Gate Out Check&lt;/selectedValue&gt;
&lt;selectedValue&gt;End Time&lt;/selectedValue&gt;
&lt;/listTablemulSelectEmailLayout&gt;
";
	
	create assocDict transient;
	assocDict.setMembership(EntTableRow);
	assocDict.addMemberKey(EntTableRow::heading.name,false,false);
	assocDict.endKeys(false);
	
	assocDict.clear;
	
	entDefAll := app.myController.getEntTableDef(ETDef_VBSEmail);
	
	foreach row in entDefAll.allEntTableRows do
		assocDict.add(row);
	endforeach;
	
	create array transient;
	
	theXMLValue := theXML.cnEcGetTagValueOfName((CMUI_MultiSelectGroupBox.XMLTag_ListTable &amp; CMUI_VBSEmailConfigure::mulSelectEmailLayout.name));
	if theXMLValue &lt;&gt; null then
 		theXMLValue := theXMLValue.trimCharacters(CrLf);
	endif;
	
	//Get all selected rows into a dictionary
	while true do
		keyValue := theXMLValue.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
		
		if keyValue = null then
			break;
		endif;
		
		entTableRow := assocDict.getAtKey(keyValue).EntTableRow;
		if entTableRow &lt;&gt; null then
			array.add(entTableRow);
		endif;
		
		if lastPos = 0 then
			break;
		endif;	
	endwhile;

	array.inspectModal;
	
	create objectSet transient;
	
	objectSet.add("12096.1188729".asOid);
	
	str := "";
	
	foreach obj in objectSet do
		timeslot := obj.CM_VehicleBookingTimeSlot;
		
		foreach row in array as EntTableRow do
			str &amp;= timeslot.getDisplayStringForAttribute(row.name, false);
			str &amp;= ",";
		endforeach;
		
	endforeach;
	
	str := str.stripTrailingChar(",");
	
	//write str;
	
	write str.compressToBinary(Binary.Compression_ZLib);
	
	blob := str.compressToBinary(Binary.Compression_ZLib);
	blobFileName := "test.csv";
	
	alertDesc := "Vehicle Booking Slots Email";
	toAddress := "phillip.wells@navis.com";
	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	sendSubject := "Test";
	sendMessage := "This is a test mail";
	
	app.myTrxCA.trxCreateEmailSendRequest(alertDesc,
											toAddress,
											fromAddress,
											ccAddress,
											bccAddress,
											sendSubject,
											sendMessage,
											null,
											null,
											blob,
											blobFileName,
											null,
											null,
											app.myPassport);

	if not app.myPassport.trxCompletedOK then
		write app.getErrorString2(FailureWithError, app.getErrorString(Email_Request), app.myPassport.returnCode.String);
	endif;
	
epilog
	delete array;
	delete assocDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="zAssertEqualMsg" id="e540cf5d-7cd8-4e66-b8b7-8f11d57450fa">
        <source>zAssertEqualMsg(actual: Any; expected: Any; message : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2025	navpw1	Initial creation

*/

vars

begin
	self.zAssertTrueMsg(actual = expected, "Actual:      " 			 &amp; 
					   actual.String.removeTabCrLfs 	  			 &amp; CrLf &amp; 
					   "Expected: " &amp; expected.String.removeTabCrLfs &amp; CrLf &amp; message);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="actual" type="Any"/>
        <Parameter name="expected" type="Any"/>
        <Parameter name="message" type="String"/>
    </JadeMethod>
    <JadeMethod name="zAssertNotNullMsg" id="a64b824b-129f-460d-b827-6b7b9ba7b698">
        <source>zAssertNotNullMsg(_value: Any; _name: String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2025	navpw1	Initial creation

*/

vars

begin
	self.zAssertTrueMsg(_value &lt;&gt; null, _name &amp; " is null");
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="zAssertTrueMsg" id="0aacf40d-03f2-416d-995c-51d477a06b67">
        <source>zAssertTrueMsg(value : Boolean ; message : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2025	navpw1	Initial creation

*/

vars
	
begin
	if value &lt;&gt; true then
		write message;
		return;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="value" type="Boolean"/>
        <Parameter name="message" type="String"/>
    </JadeMethod>
    <JadeMethod name="zGetXlatedForeignCode" id="50f10042-1363-4c64-bb19-e2fbf2834145">
        <source>zGetXlatedForeignCode(_operatorCode : String; _code : String io; _codeType : Integer; _terminal: CM_Terminal) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2025	navpw1	Initial creation

*/

vars
	operator 		: CM_Operator;
	foreignCode 	: String;
	matchFound 		: Boolean;
	
begin
	if _code.trimBlanks &lt;&gt; null then
		operator := app.myRoot.allOperators[_operatorCode];
		
		if operator &lt;&gt; null then
			foreignCode := operator.getXlationForeignCode (_code, _codeType, matchFound);	// par 31259
		else //par15042 oct 2007 cnwrs1
			foreignCode := _code.trimBlanks;
		endif;
	endif;
	
	return foreignCode;

end;</source>
        <access>protected</access>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_code" type="String" usage="io"/>
        <Parameter name="_codeType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zLogMessage" id="20d167ee-dba8-4a33-be03-236c4eb33388">
        <source>zLogMessage(_message : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2025	navpw1	Initial creation

*/

begin
	write _message;
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
</Class>
