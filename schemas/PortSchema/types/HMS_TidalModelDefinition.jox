    <JadeMethod name="getDisplayStringForAttribute" id="509634c9-34e8-4848-b39b-e43e803a4678">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _attrName = ETRow_AllCheckpoints then
		return self.getCheckpointsDescr();
	elseif _attrName = ETRow_DataType then
		return self.getDataTypeDescr();
	elseif _attrName = ETRow_EarliestDate then
		return self.getEarliestDateDescr();
	elseif _attrName = ETRow_LatestDate then
		return self.getLatestDateDescr();
	elseif _attrName = ETRow_GetTideFileName then
		if self.dataSource &lt;&gt; HMS_TidalDataSourceGetTideFile then //CCMS1640 cnwrs1 Jan 2009
			return "N/A";
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);


end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDraftAtTimeWithData" id="7a87060b-9409-43e6-b9dd-fb7fd4598bd9">
        <source>getDraftAtTimeWithData(_draftAtTime : TimeStamp; _ts1 : TimeStamp; _height1 : Decimal;
					_ts2 : TimeStamp; _height2 : Decimal) : Decimal;
// ---------------------------------------------------------------------------
// Created:     22 February 2008 by cnwrs2
//
// Purpose:     
/*

Date		Who		Reason
11 Apr 2008	cnwrs2	PAR  16520 - round to 2 decimal places
02 May 2008	cnwkpd1	PAR #16642 - signature change to use a Decimal, to correct issues with
					Real imprecision

*/

vars
	totDiffMins,
	diffMins		: Integer;
	diffPerMin		: Real;

begin
	if _draftAtTime = _ts1 then
		return _height1;		// .roundedTo(2);
	elseif _draftAtTime = _ts2 then
		return _height2;		// .roundedTo(2);
	elseif _draftAtTime &lt; _ts1 or _draftAtTime &gt; _ts2 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Time ' &amp; _draftAtTime.asStringJMT &amp; 
				' is not between ' &amp; _ts1.asStringJMT &amp; ' and ' &amp; _ts2.asStringJMT);
		return 0;
	endif;

	totDiffMins := _ts1.getDifferenceInMinutes(_ts2);
	diffPerMin := (_height2 - _height1).Real / totDiffMins;				// PAR #16442
	
	diffMins := _ts1.getDifferenceInMinutes(_draftAtTime);
	
	return (_height1 + (diffMins * diffPerMin)).Decimal.roundedTo(2);	// PAR #16642
	
end;</source>
        <Parameter name="_draftAtTime" type="TimeStamp"/>
        <Parameter name="_ts1" type="TimeStamp"/>
        <Parameter name="_height1" type="Decimal"/>
        <Parameter name="_ts2" type="TimeStamp"/>
        <Parameter name="_height2" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getEarliestDateDescr" id="42c5c2ba-223c-4d0b-9da2-f22dc74a074e">
        <source>getEarliestDateDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tidalData			: HMS_TidalData;
begin
	tidalData := self.allHMSTidalData.first;
	if tidalData &lt;&gt; null then
		return tidalData.ts.date.shortFormatJMT();
	else
		return 'N/A';
	endif;
	
	return null;

end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
