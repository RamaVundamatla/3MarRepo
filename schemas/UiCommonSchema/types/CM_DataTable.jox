    <JadeMethod name="refreshPaginated" id="34b21028-f3c8-49c8-bf41-1bb96a3dcef2">
        <updating/>
        <source>refreshPaginated() updating;
/*

Purpose:				Force table to refresh its display when using pagination. 
						For cases where there is a need to rerun display row pre/post processing for all rows

Parameters:			

Return Value:		

Date					Who		Reason
13 November 2025		jlizm1	Initial creation MTN 35927 Filter Issues on paginated forms

*/

vars

begin
	if self.isPaginated then
		self.resortForPagination(null);
	endif;
	
