    <JadeMethod name="addToolbarControls" id="40954e0d-56d1-49e8-be9d-3d4d56b0ce5d">
        <updating/>
        <source>addToolbarControls() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	toolbar : CMUI_Toolbar;

begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEventAlloc, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShipDelays, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShipDelaysEnq, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCheckList, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEventTrans, CMUI_Toolbar.Control_Alignment_Left); // TFS 3548
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addWLE" id="faafe4ef-748a-4e76-80f8-8577bf9b95d0">
        <updating/>
        <source>addWLE(_wle : CM_WorkListEntry) updating;
/*

Purpose:			Refresh table to add newly created wle

Parameters:			

Return Value:		

Date				Who		Reason
22 August 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail

*/

vars
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject( exception, _wle, invalidObject );
	
	if _wle &lt;&gt; null then
		if allDisplayedWLEs.includes(_wle) then
			return;
		endif;
		if _wle.job = self.myCurrentJob then
			self.loadJobDetails(self.myCurrentJob);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
