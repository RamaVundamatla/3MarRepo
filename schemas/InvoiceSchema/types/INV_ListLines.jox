    <JadeMethod name="doCmbInvoiceBuild" id="aa1e82ff-7100-461c-b5e0-83dea026e0a4">
        <source>doCmbInvoiceBuild(_debtor : CM_Debtor);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 21 November 2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
// ---------------------------------------------------------------------------

vars
	theCombo : CMUI_ComboBox;
	anInvoice : CM_Invoice;
	idx : Integer;
	error : Boolean;
begin
	theCombo := self.cmbInvoice;
	theCombo.clear;
	theCombo.sorted := true;
	
	if _debtor = null then
		foreach anInvoice in self.myCurrentBank.allInvoices discreteLock, reversed 
			where anInvoice.status = CM_Invoice.INVOICE_OPEN 
			or anInvoice.status = CM_Invoice.INVOICE_PENDING 
			or anInvoice.status = CM_Invoice.INVOICE_DISPUTED   //21.11.2018 cnwma1 TFS #41945 TFS 42084?
			or anInvoice.status = CM_Invoice.INVOICE_SUSPENSE 	//Par17895. Sep 2008
		do 
			if idx &gt;= 32000 then
				error := true;
				break;
			endif;

			theCombo.addItemObject(anInvoice.sequenceNum.String, anInvoice);	
			idx := idx + 1;
		endforeach;
	
	else
		foreach anInvoice in _debtor.allInvoices discreteLock, reversed 
			where anInvoice.status = CM_Invoice.INVOICE_OPEN 
			or anInvoice.status = CM_Invoice.INVOICE_PENDING
			or anInvoice.status = CM_Invoice.INVOICE_DISPUTED   //21.11.2018 cnwma1 TFS #41945 TFS 42084?
			or anInvoice.status = CM_Invoice.INVOICE_SUSPENSE 	//Par17895. Sep 2008
		do 
			if idx &gt;= 32000 then
				error := true;
				break;
			endif;

			theCombo.addItemObject(anInvoice.sequenceNum.String, anInvoice);	
			idx := idx + 1;
		endforeach;
	endif;
	
	if error then
		app.msgBox("You have more than 32,000 invoices with a status of OPEN or PENDING." &amp; Cr 
					&amp; "It is recommended that you set the pending invoices to CLOSED", "Invoice Status Problem", MsgBox_Exclamation_Mark_Icon);
	endif;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
