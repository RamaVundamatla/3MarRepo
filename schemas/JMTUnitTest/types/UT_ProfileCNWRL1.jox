<Class name="UT_ProfileCNWRL1" id="116bcaaa-5f8c-448c-835e-d9c3f34186c7">
    <superclass name="UT_Profile"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="initialize" id="41afe573-bc7e-4998-85f6-3e8e1bf4b21d">
        <source>initialize();


constants
	Profile_USER				= 'CNWRL1';
	Profile_TERMINAL			= 'T01';
	Profile_CARGO_TYPE			= 'ISO Container';
	Profile_OPERATOR			= 'UTOP';
	Profile_CARRIER				= 'DOUG';
	Profile_SHIPPING_LINE		= 'UTSL';
	Profile_TRADE				= 'Unit Test Trade';
	Profile_WAREHOUSE			= 'UTWH1';
	
vars
	
begin
	inheritMethod();		// defaults
	
	// what I really want!
	self.settings.addAssociation( UT_Profile.P_USER, Profile_USER );
	self.settings.addAssociation( UT_Profile.P_TERMINAL, Profile_TERMINAL );
	self.settings.addAssociation( UT_Profile.P_CARGO_TYPE, Profile_CARGO_TYPE );
	self.settings.addAssociation( UT_Profile.P_OPERATOR, Profile_OPERATOR );
	self.settings.addAssociation( UT_Profile.P_CARRIER, Profile_CARRIER );
	self.settings.addAssociation( UT_Profile.P_SHIPPING_LINE, Profile_SHIPPING_LINE );
	self.settings.addAssociation( UT_Profile.P_TRADE, Profile_TRADE );
	self.settings.addAssociation( UT_Profile.P_WAREHOUSE, Profile_WAREHOUSE );
	
epilog

end;
</source>
    </JadeMethod>
</Class>
