    <JadeMethod name="isCurrentObjectInSelection" id="1674a383-e0ec-4981-b0bc-076b4e468493">
        <source>isCurrentObjectInSelection() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2013	cnwmc5	Initial creation		PAR 31612

*/

vars
	obj 		: Object;
begin
	if self.myCurrentObject = null then
		return false;
	endif;
	
	foreach obj in self.tblData.allSelectedObjects do
		obj := self.useDiffObjInTblData(obj);
		
		if obj = self.myCurrentObject then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
