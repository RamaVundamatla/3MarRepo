    <JadeMethod name="getDefaultBaseEndpoint" id="47fd9b4d-b3d3-4268-a973-297fe9037eaf">
        <source>getDefaultBaseEndpoint(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	wsc				: IPN1_InaportnetServiceP1ControllerService;
	pos				: Integer;
	defaultEndpoint	: String;
	
begin
	create wsc transient;
	defaultEndpoint := wsc.getEndpointURL();
	
	pos := defaultEndpoint.pos("/inaportnet-service-p1", 1);
	if pos = 0 then
		return defaultEndpoint;
	else
		return defaultEndpoint[1:pos];
	endif;
	
epilog
	delete wsc;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
