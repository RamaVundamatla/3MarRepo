    <JadeMethod name="getAdjustedIncrement" id="cf1cc2c6-6539-486a-85c5-5370b04fd6eb">
        <source>getAdjustedIncrement(_increment : Integer; _daysToSkip : BooleanArray) : Integer;
// invoice contract prototype - adjust increment for non-charged days (weekends etc)
vars
	date			: Date;
	newIncrement	: Integer;
	dow,
	max,
	int				: Integer;
begin
	newIncrement := _increment;
	if _daysToSkip = null or
	   _daysToSkip.size  &lt; 7 or
	   _increment &lt; 1 then
		return newIncrement;
	endif;
	
	max := _increment;
	foreach int in 1 to max do
		date := self + int;
		dow := date.dayOfWeek();
		if _daysToSkip[dow] then
			newIncrement := newIncrement + 1;
		endif;
	endforeach;
	
	return newIncrement;
end;
</source>
        <Parameter name="_increment" type="Integer"/>
        <Parameter name="_daysToSkip" type="BooleanArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCentury" id="232719cf-46c7-4490-b865-af754d42d0e8">
        <source>getCentury():Integer;
//----------------------------------------------------------------
