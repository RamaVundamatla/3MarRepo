    <JadeMethod name="doBtnToolBarHATCHBAY" id="68f2265b-6db4-4eb8-afb4-8f443594e17b">
        <updating/>
        <source>doBtnToolBarHATCHBAY() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	bayFrame : CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	idx, ordinal : Integer;
	aHatchLid : CM_HatchLid; //Vessel;
	theBayDefns: CM_BaySet;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	// the lid points are part of the on deck bay area
	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		aHatchLid := bayFrame.myGridArea.SHP_BayArea.getSelectedHatchLid().CM_HatchLid; //Vessel;
	endif;
	if aHatchLid = null then
		return;
	endif;

	self.anythingChanged := true;
	create theBayDefns transient;
	self.tblComboHatchBay.allSelectedObjects.rebuild;
	
	if self.tblComboHatchBay.allSelectedObjects.size &gt; 0 then
		self.tblComboHatchBay.allSelectedObjects.copy(theBayDefns);
	endif;
//	if self.tblComboBays.allSelectedObjects.size &gt; 0 then
//		self.tblComboBays.allSelectedObjects.copy(theBayDefns);
//	endif;
	aHatchLid.setProxyBays(theBayDefns);
	global.beep;
epilog
	if theBayDefns &lt;&gt; null then
		delete theBayDefns;
	endif;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarHATCHCREATE" id="dd847944-ab45-4fb7-ab82-dd89ad506c95">
        <updating/>
        <source>doBtnToolBarHATCHCREATE() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwmh5		#30582 - Change the way that it works out what columns are covered by a hatch lid.  Currently if you don't 
//							select any under deck slots when defining the hatch lid location it incorrectly works out which under deck 
//							slots are covered by the hatch lid.  It now works out the left and right most point and checks both on deck
//							and under deck slots to see whether they fall within these values
// ---------------------------------------------------------------------------

vars
	aLidPoint : SHP_LidPoint;
	bayFrameOD,bayFrameUD : CMUI_GridAreaFrame;
	aBayCol			: SHP_BayColumn;
	cellUDEnd,cellUDStart,cellODEnd,cellODStart : Object;
	cellUDEndColumn,cellUDStartColumn,cellODEndColumn,cellODStartColumn : Integer;
	aPoint : CMUI_GridPoint;
	thePoints : ObjectArray;
	anObject : Object;
	theLidTier,theLidColumn : Integer;
	aProxyHatchLid : CM_HatchLid; //Vessel;
	aBaySet : CM_BaySet;
	hasLid : Boolean;
	
	xPoint					: Real;											// 07/11/2012 cnwmh5 #30582
	yPoint					: Real;											// 07/11/2012 cnwmh5 #30582
	rowLabel				: String;										// 07/11/2012 cnwmh5 #30582
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	// ####################################
	// ON DECK - work out the first and last cell (column)
	bayFrameOD := self.frmGridArea.getControl(ONDECK);
	if bayFrameOD = null then
		return;
	endif;
	
	self.anythingChanged := true;
	// we have selected Points, we want columns
	// So go through all of the selected points and collect their columns
	hasLid := false;
	xPoint := 9999999999.99;												// 07/11/2012 cnwmh5 #30582
	yPoint := 0.00;															// 07/11/2012 cnwmh5 #30582
	
	bayFrameOD.myGridArea.getSelectedStartXEndYPoints(xPoint, yPoint);		// 07/11/2012 cnwmh5 #30582
	
	if bayFrameOD.myGridArea.allGridColumns.isEmpty then
		theLidTier := 1;
	else
		theLidTier := bayFrameOD.myGridArea.allGridRows.size; // the last row ids for the lids
	endif;
	// ####################################
	// UNDER DECK - work out the first and last cell (column)
	bayFrameUD := self.frmGridArea.getControl(UNDERDECK);
	
	bayFrameUD.myGridArea.getSelectedStartXEndYPoints(xPoint, yPoint);		// 07/11/2012 cnwmh5 #30582

	// 07/11/2012 cnwmh5 #30582
	rowLabel := bayFrameOD.myGridArea.SHP_BayAreaAboveDeck.myBay.getFirstLastTier(true, true, true).id;
	bayFrameOD.myGridArea.getFirstLastColumnsForPoints(rowLabel, xPoint, yPoint, cellODStart, cellODEnd);
	rowLabel := bayFrameUD.myGridArea.SHP_BayAreaBelowDeck.myBay.getFirstLastTier(false, false, true).id;
	bayFrameUD.myGridArea.getFirstLastColumnsForPoints(rowLabel, xPoint, yPoint, cellUDStart, cellUDEnd);
	
	// 08/11/2012 cnwmh5 #30582
	if cellUDStart = null and cellODStart = null then
		return;
	endif;
	
	// 08/11/2012 cnwmh5 #30582
	if cellUDStart = null then
		cellUDStart := cellODEnd;
	endif;
	if cellUDEnd = null then
		cellUDEnd := cellODStart;
	endif;

	// 07/11/2012 cnwmh5 #30582
	cellUDEndColumn := cellUDEnd.SHP_BayColumn.column;
	cellUDStartColumn := cellUDStart.SHP_BayColumn.column;
	cellODEndColumn := cellODEnd.SHP_BayColumn.column;
	cellODStartColumn := cellODStart.SHP_BayColumn.column;	
	
	// #################################
	// CREATE A PROXY HATCH LID
	
	// check to see if we need to create a new lid or whether we are extending it
	aProxyHatchLid := null;
	foreach theLidColumn in cellODStartColumn to cellODEndColumn do
		aPoint := bayFrameOD.myGridArea.allGridPoints[theLidTier,theLidColumn];
		if SHP_LidPoint.hasInstance(aPoint) then
			aLidPoint := aPoint.SHP_LidPoint;
			if aLidPoint.myHatchLid &lt;&gt; null then
				if aLidPoint.endsMidCell = false
				and aLidPoint.startsMidCell = false then
					aProxyHatchLid := aLidPoint.myHatchLid.CM_HatchLid; //Vessel;
					break;
				endif;
			endif;
		endif;
	endforeach;

	if aProxyHatchLid = null then
		create aProxyHatchLid as CM_HatchLidVoyage transient;
		create aBaySet transient;
		aBaySet.add(self.myCurrentBay);
		aProxyHatchLid.setProxy(self.myCurrentBay.ordinalBay,self.myCurrentBay.ordinalBay,
								cellODStartColumn,cellODEndColumn, cellUDStartColumn,cellUDEndColumn,false,false,null,aBaySet);
		aProxyHatchLid.CM_HatchLidVoyage.addBayVoyage(self.myCurrentBay.CM_BayVoyage);

	endif;	
	// #################################
	// create a lid point on screen for each cell (column) this lid is under, attach the proxy lid to each one.
	// although there are lots of cells involved they all have the same X &amp; Ys etc.
	foreach theLidColumn in cellODStartColumn to cellODEndColumn do
		if bayFrameOD.myGridArea.allGridPoints[theLidTier,theLidColumn] = null then
			create aLidPoint transient;
			aLidPoint.setForCreate(theLidColumn,theLidTier,bayFrameOD.myGridArea.SHP_BayArea, cellODStart.SHP_BayColumn,
				cellODEnd.SHP_BayColumn, cellUDStart.SHP_BayColumn, cellUDEnd.SHP_BayColumn, false, false, aProxyHatchLid, aBayCol);		// 07/11/2012 cnwmh5 #30582
		endif;
	endforeach;	

	create thePoints	 transient;
	bayFrameUD.myGridArea.allSelectedPoints.copy(thePoints);
	bayFrameUD.myGridArea.allSelectedPoints.clear;
	foreach anObject in thePoints do
		anObject.CMUI_GridPoint.drawSelf(bayFrameUD);
	endforeach;		
	thePoints.clear;
	bayFrameOD.myGridArea.allSelectedPoints.copy(thePoints);
	bayFrameOD.myGridArea.allSelectedPoints.clear;
	foreach anObject in thePoints do
		anObject.CMUI_GridPoint.drawSelf(bayFrameOD);
	endforeach;		

	bayFrameOD.myGridArea.SHP_BayAreaAboveDeck.drawLidRow();

epilog
	delete thePoints;		// PAR #27874
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarHATCHDELETE" id="08e25eaa-660d-4511-983e-0c3f5d711a0d">
        <updating/>
        <source>doBtnToolBarHATCHDELETE() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aLidPoint : SHP_LidPoint;
	bayFrame : CMUI_GridAreaFrame;
	aColumn : CMUI_GridColumn;
	aBayCol,cellUDEnd,cellUDStart,cellODEnd,cellODStart : SHP_BayColumn;
	theColumns : CMUI_GridColumnsByColumn;
	aPoint : CMUI_GridPoint;
	idx, ordinal : Integer;
	anObject : Object;
	theLidTier, theReturn : Integer;
	aHatchLid : CM_HatchLid;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	// the lid points are part of the on deck bay area
	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		aHatchLid := bayFrame.myGridArea.SHP_BayArea.getSelectedHatchLid().CM_HatchLid; //Vessel;
	endif;
	if aHatchLid = null then
		return;
	endif;
	
	if aHatchLid.pxyIsProxy then
		if aHatchLid.pxyGetRealObject().CM_HatchLid.allVoyageHatchLidJobs.isEmpty = false then
			app.msgBox("This Hatch Lid Cannot Be Deleted. It Has Jobs Associated With It","Hatch Lid Has Jobs",MsgBox_Yes_No + MsgBox_Information_Icon);
			return;
		endif;
	else
		if aHatchLid.allVoyageHatchLidJobs.isEmpty = false then
			app.msgBox("This Hatch Lid Cannot Be Deleted. It Has Jobs Associated With It","Hatch Lid Has Jobs",MsgBox_Yes_No + MsgBox_Information_Icon);
			return;
		endif;
	endif;
	theReturn := app.msgBox("Are You Sure That You Want to Delete This Hatch Lid?","Delete Confirmation",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	if theReturn = MsgBox_Return_No then
		return;
	endif;

	
	self.anythingChanged := true;
	// now go through all the lid points in this area and if they have the same hatch lid object delete them
	foreach aPoint in bayFrame.myGridArea.allGridPoints do
		if aPoint.isKindOf(SHP_LidPoint) then
			if aPoint.SHP_LidPoint.myHatchLid &lt;&gt; null then
				if aPoint.SHP_LidPoint.myHatchLid = aHatchLid then
					delete aPoint;		
				endif;			
			endif;
		endif;
	endforeach;
	bayFrame.myGridArea.allSelectedPoints.rebuild;
	bayFrame.myGridArea.allGridPoints.rebuild;
	delete aHatchLid;
	
	bayFrame.myGridArea.drawSelf();

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarHATCHEND" id="7eec01eb-f074-4f2b-b5b8-5e32372bb0da">
        <updating/>
        <source>doBtnToolBarHATCHEND() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bayFrame : CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	idx, ordinal : Integer;
	aHatchLid : CM_HatchLid; //Vessel;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	// the lid points are part of the on deck bay area
	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		aHatchLid := bayFrame.myGridArea.SHP_BayArea.getSelectedHatchLid().CM_HatchLid; //Vessel;
	endif;
	if aHatchLid = null then
		return;
	endif;
	
	aHatchLid.setProxyMidCell(aHatchLid.startsMidCell,true);
	self.anythingChanged := true;

	foreach aPoint in bayFrame.myGridArea.allGridPoints do
		if aPoint &lt;&gt; null then
			if aPoint.isKindOf(SHP_LidPoint) then
				if aPoint.SHP_LidPoint.myHatchLid = aHatchLid then
					aPoint.SHP_LidPoint.endsMidCell :=  not aPoint.SHP_LidPoint.endsMidCell;
					aPoint.drawSelf(bayFrame);
				endif;
			endif;
		endif;
	endforeach;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarHATCHSTART" id="82d67406-99ed-46d9-bb5d-7e93d1439fe0">
        <updating/>
        <source>doBtnToolBarHATCHSTART() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	bayFrame : CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	idx, ordinal : Integer;
	aHatchLid : CM_HatchLid; //Vessel;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	// the lid points are part of the on deck bay area
	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		aHatchLid := bayFrame.myGridArea.SHP_BayArea.getSelectedHatchLid().CM_HatchLid; //Vessel;
	endif;

	if aHatchLid = null then
		return;
	endif;
	
	aHatchLid.setProxyMidCell(true,aHatchLid.endsMidCell);
	self.anythingChanged := true;


	foreach aPoint in bayFrame.myGridArea.allGridPoints do
		if aPoint &lt;&gt; null then
			if aPoint.isKindOf(SHP_LidPoint) then
				if aPoint.SHP_LidPoint.myHatchLid = aHatchLid then
					aPoint.SHP_LidPoint.startsMidCell :=  not aPoint.SHP_LidPoint.startsMidCell;
					aPoint.drawSelf(bayFrame);
				endif;
			endif;
		endif;
	endforeach;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
