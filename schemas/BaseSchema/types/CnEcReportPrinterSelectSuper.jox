____________________________________________________________________________

This form can be used to select multiple printers for any
reports that require multiple prints to various printers.</text>
    <CompAttribute name="aAllSelectedPrinters" id="42d6e4ac-8ed1-4e1e-8675-8cd0496200ed">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="aIsCancelled" id="9f10b2c9-20d5-490c-a75c-fe4c07c9f658">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="aMyReport" id="c4901598-3cea-4f9d-b0c0-3ae9110d4c01">
        <embedded/>
        <type name="CnEcReportDefinition"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="queryUnload" id="f8858c5e-4b94-46ed-8439-b84e4a7a4416">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;

begin
	if self.aIsCancelled and self.aAllSelectedPrinters.size() &gt; 0 then
		self.aAllSelectedPrinters.clear();
	endif;

	inheritMethod(cancel, reason);
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
</GUIClass>
