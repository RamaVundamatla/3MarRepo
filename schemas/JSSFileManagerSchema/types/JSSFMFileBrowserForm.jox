        <executionLocation>server</executionLocation>
        <source>doFetchDirectoryContentsServer(pPathName:String; pIsUnix:Boolean; pTheContainer:JSSFMFolder input) protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		This method is a wrapper for the doFetchDirectoryContents method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_DB_SERVER	: Boolean = true;
	IS_APP_SERVER	: Boolean = false;
	
begin
	self.doFetchDirectoryContents(	pPathName,
									pTheContainer,
									IS_DB_SERVER,
									IS_APP_SERVER,
									pIsUnix,
									self.aAllPathNamesDbServer);
end;</source>
        <access>protected</access>
        <Parameter name="pPathName" type="String"/>
