    <JadeMethod name="isNegativeAmount" id="79434b75-1ffa-4a59-acff-55541d3387e7">
        <source>isNegativeAmount():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jun 2017 cnwma1 TFS #4549:PAR38683 ADP - Issue in Cash collectiion

*/

vars
	
begin
	if self.totalAmount &lt; 0 then // ### JIRA 35502 18JUL2025 NAVAB1 use totalAmount (Static value)
	
		return true;
