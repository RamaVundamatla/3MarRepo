    <JadeMethod name="createHSegment" id="e1e6c54e-712a-40a3-93d9-33d7fdb597d1">
        <source>createHSegment(_invoice : CM_Invoice; _firstPInvoiceLine : CM_InvoiceLine; _file : File input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Mar 2022	jlier1	Initial creation 53286
26 Apr 2022	jlier1	TFS 53473 
31 May 2022 jlier1 	TFS 53738
*/

vars
	id,
	currencyCode,
	currencyRate,
	customerRef : String; 
	transactionDate, dueDate : String;
	currencyObj : CM_CurrencyType;
	currencyRateObj : CM_CurrencyRate;
	termsOfTradeCode,
	codeI	: String;
	termsOfTradeDays : Integer;
	invoiceLineDesc : CM_InvoiceLineDesc;
begin
	if _invoice = null or _file = null then
		return;
	endif;
	if _invoice.debtor &lt;&gt; null then
		id:=_invoice.debtor.decfinName;
		currencyCode:=_invoice.debtor.additionalInformation1;
		self.getCurrencyDetailsForInvoice(_invoice,currencyObj,currencyRateObj);
		if currencyRateObj &lt;&gt; null then
			currencyRate:=currencyRateObj.rate.String ;
		endif;
		
	endif;

	transactionDate:=_invoice.postedDT.date.format("dd/MM/yyyy");
	termsOfTradeCode :=_invoice.getTermsOfTradeStr(true);
	termsOfTradeDays:=termsOfTradeCode.Integer;
	dueDate:=_invoice.postedDT.date.addDays(termsOfTradeDays).format("dd/MM/yyyy");
	
	customerRef:=_invoice.vesselName &amp; "_" &amp; _invoice.voyageCode;
	//jlier1 TFS 53738 31/5/22
	if _firstPInvoiceLine &lt;&gt; null then
		invoiceLineDesc:=_firstPInvoiceLine.invoiceLineDesc;
		if invoiceLineDesc &lt;&gt; null then
			codeI:=invoiceLineDesc.externalReference1;	
		endif;
	endif;
	
	_file.writeLine(
		"H"          &amp; SemiColon &amp;  // 1LINE_TYPE 
		"OM003L"	 &amp; SemiColon &amp; // 2 COMPNAY
		id &amp;  SemiColon &amp; //  3 IDENTITY 
		self.getInvoiceNo(_invoice) &amp; SemiColon &amp; //4  invoice no
		transactionDate &amp; SemiColon &amp; // 5  transaction date
		"EXTINV" &amp; SemiColon &amp;  //  6 invoice type
		transactionDate &amp; SemiColon &amp; // 7 invoice date
		dueDate	&amp; SemiColon &amp; // 8 due date
		Space   &amp; SemiColon &amp; //  9 pay_term id
		currencyCode &amp; SemiColon  &amp; //  10 currency
		currencyRate &amp; SemiColon &amp; // 11 currency rate
		Space   &amp; SemiColon &amp; //  12 voucher code
		Space   &amp; SemiColon &amp; //  13 text
		Space   &amp; SemiColon &amp; //  14 div factor
		Space   &amp; SemiColon &amp; //  15 creators reference
		Space   &amp; SemiColon &amp; //  16 ncf ref		
		Space   &amp; SemiColon &amp; //  17 pre acc code b	
		Space   &amp; SemiColon &amp; //  18 pre acc code  c
		Space   &amp; SemiColon &amp; //  19 pre acc code  d	
		Space   &amp; SemiColon &amp; //  20 pre acc code  e	
		Space   &amp; SemiColon &amp; //  21 pre acc code  f	
		Space   &amp; SemiColon &amp; //  22 pre acc code  g	
		Space   &amp; SemiColon &amp; //  23 pre acc code  h	
		codeI   &amp; SemiColon &amp; // 24 pre acc code  i	
		Space   &amp; SemiColon &amp; //  25 pre acc code  j	
		Space   &amp; SemiColon &amp; //  26 pre project activity id	
		"F"   &amp; SemiColon &amp; //  27 voucher type
		Space   &amp; SemiColon &amp; //  28 discount date 1	
		Space   &amp; SemiColon &amp; //  29 - discount perc1	
		Space   &amp; SemiColon &amp; //   30 - discount curramount 1	
		Space   &amp; SemiColon &amp; //   31 - discount domaamount 1
		Space   &amp; SemiColon &amp; //  32 - discount date 2
		Space   &amp; SemiColon &amp; //  33 - discount perc 2
		Space   &amp; SemiColon &amp; //   34 - discount curramount 2	
		Space   &amp; SemiColon &amp; //   35 - discount domaamount 2
		Space   &amp; SemiColon &amp; //  36 - discount date 3
		Space   &amp; SemiColon &amp; //  37 - discount perc 3
		Space   &amp; SemiColon &amp; //   38 - discount curramount 3	
		Space   &amp; SemiColon &amp; //   39 - discount domaamount 3
		Space   &amp; SemiColon &amp; //   40 - pay term base date
		Space   &amp; SemiColon &amp; //  41 - advance invoice
		Space   &amp; SemiColon &amp; //   42 - series reference
		Space   &amp; SemiColon &amp; //   43 - number reference
		Space   &amp; SemiColon &amp; //   44 - way pay id
		Space   &amp; SemiColon &amp; //   45 - payment add id
		Space   &amp; SemiColon &amp; //   46 - other payer
		Space   &amp; SemiColon &amp; //   47 - delivery date
		"10"   &amp; SemiColon &amp; //   48 - delivery add id
		customerRef   &amp; SemiColon &amp; //   49 - customer refeence
		Space   &amp; SemiColon &amp; //   50 - affect line postings
		Space   &amp; SemiColon  //   51 - UUID
		);
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_firstPInvoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createISegment" id="4fd6d96d-72dc-4158-b867-02556289fdd6">
        <source>createISegment(_invoiceLines : CM_InvoiceLineSet; _file : File input; _itemID : String);
/*

Purpose:			

Parameters:		should pass in all invoice lines with the same tax code	for the same invoice

Return Value:		

Date		Who		Reason
31 March 2022	jlier1	Initial creation 53286
26 Apr 2022	jlier1	TFS 53477
*/

vars
	invoice : CM_Invoice;
	vatCode : String;
	netCurrAmount,
	vatCurrAmount : Decimal[16,2];
	firstInvoiceLine, invoiceLine : CM_InvoiceLine;
	currencyType : CM_CurrencyType;
	currencyRate : CM_CurrencyRate;
	rate : Decimal[16,6];
	taxCode : CM_TaxCode;
begin
	if _invoiceLines = null or _file = null then
		return;
	endif;
	firstInvoiceLine:=_invoiceLines.first;
	if firstInvoiceLine = null then
		return;
	endif;
	invoice:=firstInvoiceLine.invoice;
	self.getCurrencyDetailsForInvoice(invoice,currencyType,currencyRate);
	if currencyRate &lt;&gt; null then
		rate:=currencyRate.rate;
	else
		rate :=1;
	endif;
	foreach invoiceLine in _invoiceLines discreteLock  do
		netCurrAmount:=netCurrAmount + (invoiceLine.lineTotal * rate).roundedTo(2);
		vatCurrAmount:=vatCurrAmount + (invoiceLine.getTotalTaxAmountForLine() * rate).roundedTo(2);
	endforeach;
	
	taxCode:=self.getTaxCodeForInvoiceLine(firstInvoiceLine);
	if taxCode &lt;&gt; null then
		vatCode:=taxCode.code;
	endif;
		
	_file.writeLine(
		"I"          &amp; SemiColon &amp;  // 1 LINE_TYPE 
		self.getInvoiceNo(invoice)   &amp; SemiColon &amp; // 1 invoice no
		_itemID &amp; SemiColon &amp; // 3 item id
		vatCode &amp; SemiColon &amp; //4 vat code
		netCurrAmount.roundedTo(2).String  &amp; SemiColon &amp; // 5 net curr amount
		Space &amp; SemiColon &amp;  // 6 net dom amount
		vatCurrAmount.roundedTo(2).String  &amp; SemiColon &amp; // 7 vat curr amount
		Space &amp; SemiColon  &amp; // 8 vat dome amount
		Space &amp; SemiColon  &amp; // 9 ref
		Space &amp; SemiColon  &amp; // 10 deliv type id
		"EX" &amp; SemiColon  &amp; // 11 series refence
		Space &amp; SemiColon   &amp;// 12 number refence
		Space &amp; SemiColon   // 13 man tax liability date refence
	);
epilog

end;</source>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineSet"/>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_itemID" type="String"/>
    </JadeMethod>
    <JadeMethod name="createPSegment" id="31ce13bd-5022-4f2b-bc0f-2e378892cda5">
        <source>createPSegment(_invoiceLines : CM_InvoiceLineSet;   _file : File input; _rowID : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2022	jlier1	Initial creation 53286
26 Apr 2022	jlier1	TFS 53477
*/

vars
	codeA,
	codeB,
	codeD,
	codeH,
	codeI  : String;
	quantity,
	 currAmount : Real;
	 text: String;
	invoice : CM_Invoice;
	service : CM_Service;
	invoiceLineDesc : CM_InvoiceLineDesc;
	taxCode : CM_TaxCode;
	itemID : String;
	firstInvoiceLine, invoiceLine : CM_InvoiceLine;
	currencyType : CM_CurrencyType;
	currencyRate : CM_CurrencyRate;
	rate : Decimal[16,6];
begin
	if _invoiceLines  = null or _invoiceLines.first = null then
		return;
	endif;
	firstInvoiceLine:=_invoiceLines.first;
	invoice:=firstInvoiceLine.invoice;
	taxCode:=self.getTaxCodeForInvoiceLine(firstInvoiceLine);
	if taxCode &lt;&gt; null then
		itemID:=taxCode.externalReference1;
	endif;
	
	
	codeA:=firstInvoiceLine.getServiceGLCode();
	invoiceLineDesc:=firstInvoiceLine.invoiceLineDesc;
	if  invoiceLineDesc &lt;&gt; null then
		service:=invoiceLineDesc.services.first;
		codeB:=invoiceLineDesc.printingOrder.asStringJMT;
		codeI:=invoiceLineDesc.externalReference1;
	endif;
	
	if service &lt;&gt; null then
		codeD:=service.externalReference1;
		codeH:=service.externalReference2;
		text:=service.remarks;
	endif;
		//jlier1	TFS 53479 28/4/22
	if invoiceLineDesc &lt;&gt; null and invoiceLineDesc.narration &lt;&gt; null then
		if text &lt;&gt; null then
			text:=text &amp; Hyphen &amp; invoiceLineDesc.narration;
		else
			text:=invoiceLineDesc.narration;
		endif;
	endif;
	
	self.getCurrencyDetailsForInvoice(invoice,currencyType,currencyRate);
	if currencyRate &lt;&gt; null then
		rate:=currencyRate.rate;
	else
		rate :=1;
	endif;
	
	foreach invoiceLine in _invoiceLines  discreteLock do
			quantity:=quantity + invoiceLine.quantity;
			currAmount:=currAmount + (invoiceLine.lineTotal  * rate).roundedTo(2);
	endforeach;
	
	
	if invoice.status = CM_Invoice.INVOICE_POSTED_CREDIT then
		if currAmount.Decimal &lt; 0 then
			currAmount:=(-(currAmount));
		endif;
	else
		currAmount:=(-(currAmount));
	endif;
	
	
	
	_file.writeLine(
		"P"          &amp; SemiColon &amp;  // 1LINE_TYPE 
		self.getInvoiceNo(invoice)	 &amp; SemiColon &amp; // 2 invoice no
		itemID &amp;  SemiColon &amp; //  3 item id 
		_rowID &amp; SemiColon &amp; //4  row no
		codeA &amp; SemiColon &amp; // 5  codeA
		codeB &amp; SemiColon &amp;  //  6 codeB
		Space &amp; SemiColon &amp; // 7 codeC
		codeD	&amp; SemiColon &amp; // 8 code D
		Space   &amp; SemiColon &amp; //  9 code E
		Space &amp; SemiColon  &amp; //  10 code F
		Space &amp; SemiColon &amp; // 11 code G
		codeH   &amp; SemiColon &amp; //  12 codeH
		codeI   &amp; SemiColon &amp; //  13 code I
		Space   &amp; SemiColon &amp; //  14 code J
		quantity.roundedTo(2).String   &amp; SemiColon &amp; //  15 quantity
		currAmount.roundedTo(2).String   &amp; SemiColon &amp; //  16 curr amount		
		Space   &amp; SemiColon &amp; //  17 dom amount
		Space   &amp; SemiColon &amp; //  18 auto po sting proc code
		Space   &amp; SemiColon &amp; //  19 optional code	
		text   &amp; SemiColon &amp; //  20 text 	
		Space   &amp; SemiColon  //  21 project activity	
	);
epilog

end;</source>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineSet"/>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_rowID" type="String"/>
    </JadeMethod>
    <JadeMethod name="createTSegment" id="8836b976-743d-42f2-9c23-9ed4a1f550ba">
        <source>createTSegment(_invoiceLines : CM_InvoiceLineSet; _file : File input; _itemID : String);
/*

Purpose:			

Parameters:		should pass in all invoice lines with the same tax code	for the same invoice

Return Value:		

Date		Who		Reason
31 March 2022	jlier1	Initial creation 53286
26 Apr 2022 	jlier1 TFS 53482
*/

vars
	invoice : CM_Invoice;
	taxID : String;
	taxCurrAmount : Decimal[16,2];
	firstInvoiceLine, invoiceLine : CM_InvoiceLine;
	currencyType : CM_CurrencyType;
	currencyRate : CM_CurrencyRate;
	rate : Decimal[16,6];
	taxCode : CM_TaxCode;
	taxRate : CM_TaxRate;
	taxRatePerCent : Decimal[16,2];
begin
	if _invoiceLines = null or _file = null then
		return;
	endif;
	firstInvoiceLine:=_invoiceLines.first;
	if firstInvoiceLine = null then
		return;
	endif;
	invoice:=firstInvoiceLine.invoice;
	self.getCurrencyDetailsForInvoice(invoice,currencyType,currencyRate);
	if currencyRate &lt;&gt; null then
		rate:=currencyRate.rate;
	else
		rate:=1;
	endif;
	
	
	
	foreach invoiceLine in _invoiceLines discreteLock do
		taxCurrAmount:=taxCurrAmount + (invoiceLine.getTotalTaxAmountForLine() * rate);
	endforeach;
	taxCode:=self.getTaxCodeForInvoiceLine(firstInvoiceLine);
	if taxCode &lt;&gt; null then
		taxID:=taxCode.code;
		taxRate:=taxCode.getTimeRate(invoice.postedDT);
		if taxRate &lt;&gt; null then
			taxRatePerCent:=taxRate.rate;
		endif;
	endif;
	
	
	_file.writeLine(
		"T"          &amp; SemiColon &amp;  // 1 LINE_TYPE 
		self.getInvoiceNo(invoice) &amp; SemiColon &amp; // 1 invoice no
		_itemID &amp; SemiColon &amp; // 3 item id
		taxID &amp; SemiColon &amp; //4 tax
		taxRatePerCent.roundedTo(2).String &amp; SemiColon &amp; // 5 net curr amount
		taxCurrAmount.roundedTo(2).String &amp; SemiColon &amp;  // 6 tax curr Amount
		Space &amp; SemiColon &amp; // 7 tax dom amount
		Space &amp; SemiColon  // 8 fee code		
	);
epilog

end;</source>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineSet"/>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_itemID" type="String"/>
    </JadeMethod>
    <JadeMethod name="export" id="7e4a558b-3d9e-4f20-9a8b-c28d5f8a9a2a">
        <updating/>
        <source>export(invoice: CM_Invoice input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2022	jlier1	Initial creation 53286

*/

vars
	file,
	tmpFile   : File;
	path  : String;
	
begin

	path := self.getExportFileNameBase(not app.isJMTUnitTest);
	if path[path.length:1] &lt;&gt; '\' then
		path := path &amp; "\";
	endif;
	
	create file;
	file.mode      := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.fileName:= path &amp; self.getExportFileName(invoice,app.actualTimeAppServer);	
	
	self.writeInvoiceToFile(invoice,  file );	

	invoice.incrementExportCount(false);		
epilog

	if file &lt;&gt; null and file.isOpen then
		file.close;
	endif;
	
	delete file;
	
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportBulk" id="8da576df-26ce-43ac-9cb7-dbdc8c775c04">
        <source>exportBulk(_invoices : CM_InvoiceSet input; startDT : TimeStamp) : String;
/*

Purpose:			

Parameters:			

Return Value:		if successful return the fileName - needed for emailing

Date		Who		Reason
06 April 2022	jlier1	Initial creation 53286

*/

vars
	file : File;
	path ,fileName  : String;
	firstInvoice, invoice  : CM_Invoice;
	iter : Iterator;
begin
	

	path  := self.getExportFileNameBase(true);
	if path[path.length:1] &lt;&gt; '\' then
		path := path &amp; "\";
	endif;
	firstInvoice:=_invoices.first;
	if firstInvoice = null then
		return null;
	endif;
	
	fileName:=self.getExportFileName(firstInvoice,startDT);
	
	create file;
	file.mode      := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.fileName:= path &amp; fileName;

	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	iter:=_invoices.createIterator;
	while iter.next(invoice) do
		self.validateInvoiceToExport(firstInvoice.status, invoice);
		if app.myPassport.hasErrors then
			return null;
		endif;
		self.writeInvoiceToFile(invoice,file);
	endwhile;
	
	if not app.myPassport.hasErrors then
		//bulk set those invoices export count
		app.myTrxUA.trxIncrementInvoicesExported(_invoices,true,app.myPassport);
	endif;

	
	return file.fileName;
epilog
	if app.myPassport.hasErrors then
		if  file &lt;&gt; null and file.isAvailable then
			file.purge();
		endif;
	endif;
	if file &lt;&gt; null and file.isOpen then
		file.close;
	endif;

	delete file;
	delete iter;
end;</source>
        <Parameter name="_invoices" type="CM_InvoiceSet" usage="input"/>
        <Parameter name="startDT" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="exportToFile" id="28f39380-2cbf-42de-a049-2fc1c0a1faa2">
        <source>exportToFile(invoice: CM_Invoice input; fileNameBase: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2022	jlier1	Initial creation 53286

*/

vars
	file	: File;
begin
	
	create file;
	file.allowReplace := true;
	file.fileName     := fileNameBase; 
	file.mode         := File.Mode_Output;

	self.writeInvoiceToFile(invoice,file);

	invoice.incrementExportCount(false);

epilog
	if file &lt;&gt; null and file.isOpen then
		file.close;
	endif;
	delete file;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="exportToFileBulk" id="e6c0cabb-ed3d-4695-bdc4-b979f822a3df">
        <source>exportToFileBulk(_invoices : CM_InvoiceSet input; fileNameBase: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2022	jlier1	Initial creation 53286

*/

vars
	file	: File;
	iter : Iterator;
	invoice,firstInvoice : CM_Invoice;
begin
	
	firstInvoice:=_invoices.first;
	if firstInvoice = null then
		return;
	endif;
	
	create file;
	file.allowReplace := true;
	file.fileName     := fileNameBase; 
	file.mode         := File.Mode_Output;

	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	iter:=_invoices.createIterator;
	while iter.next(invoice) do
		self.validateInvoiceToExport(firstInvoice.status, invoice);
		if app.myPassport.hasErrors then
			return;
		endif;
		self.writeInvoiceToFile(invoice,file);
	endwhile;
	
	if not app.myPassport.hasErrors then
		//bulk set those invoices export count
		app.myTrxUA.trxIncrementInvoicesExported(_invoices,true,app.myPassport);
	endif;
	

epilog
	if app.myPassport.hasErrors then
		if  file &lt;&gt; null and file.isAvailable then
			file.purge();
		endif;
	endif;
	if file &lt;&gt; null and file.isOpen then
		file.close;
	endif;
	delete file;
	delete iter;
	delete invoice;
end;</source>
        <Parameter name="_invoices" type="CM_InvoiceSet" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrencyDetailsForInvoice" id="a0f89b5a-92be-467f-af54-3479da221a25">
        <source>getCurrencyDetailsForInvoice(	_invoice : CM_Invoice;
								_currency : CM_CurrencyType output;
								_currencyRate : CM_CurrencyRate output) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2022	jlier1	Initial creation 53286

*/

vars
	currencyCode : String;
begin
	if _invoice = null or _invoice.debtor = null then
		return;
	endif;
	
		
	currencyCode:=_invoice.debtor.additionalInformation1;
	if currencyCode &lt;&gt; null then
		_currency:=app.myRoot.allCurrencyTypes[currencyCode];
		if _currency &lt;&gt; null then
			_currencyRate:=_currency.getRate(_invoice.postedDT);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_currency" type="CM_CurrencyType" usage="output"/>
        <Parameter name="_currencyRate" type="CM_CurrencyRate" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getExportFileName" id="90830b31-f6a1-4923-88a8-99d81cf0372e">
        <source>getExportFileName(_invoice: CM_Invoice; _startDT : TimeStamp): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2022	jlier1	Initial creation 53286

*/

vars
	invoiceType, bankCode : String;
	bank : CM_Bank;
begin

	if _invoice = null then
		return null;
	endif;
	
	bank:=_invoice.getBank;
	if bank &lt;&gt; null then
		bankCode:=bank.code;
	endif;
	
	invoiceType:=self.getInvoiceTypeCode(_invoice.status);
	
	return  "MTN_" &amp; app.myRoot.getSystemModeShortDesc &amp; bankCode &amp;  "_" &amp; invoiceType &amp;"_IFS10_" &amp; _startDT.time.format("HH_mm_ss") &amp; _startDT.date.format("ddMMyy") &amp; ".csv";

epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceNo" id="2d63a3e5-f0d9-4527-83fb-02b4df913adf">
        <source>getInvoiceNo(_invoice : CM_Invoice )  : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2022	jlier1	Initial creation

*/

vars
	invoiceNo : String;
begin	
	if _invoice = null then
		return null;
	endif;
	if _invoice.invoiceType &lt;&gt; null then
		invoiceNo:=_invoice.invoiceType.externalReference;
	endif;
	invoiceNo:=invoiceNo&amp; _invoice.sequenceNum.String.padLeadingZeros(6);
	return invoiceNo;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceTypeCode" id="7158d663-604b-4ab7-97aa-7579a9e6b99b">
        <source>getInvoiceTypeCode(_status : Integer ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2022	jlier1	Initial creation

*/

vars

begin
	if _status = CM_Invoice.INVOICE_POSTED or
		_status = CM_Invoice.INVOICE_POSTED_REVERSE then
		return "INV";
	elseif _status = CM_Invoice.INVOICE_POSTED_CREDIT then
		return "CRN";
	endif;
	
	//raise ale
	return null;
	
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
