    <JadeMethod name="addMinMaxToTerminalArea" id="dfa34135-d142-4ca2-940d-715a8de225ca">
        <source>addMinMaxToTerminalArea(	_tam : CM_TerminalAreaMaster input;
							_cargoType : CM_CargoType;
							_cargoSubType : CM_Product;
							_minVol	: Decimal;
							_minWeight : Integer; 
							_maxVol		: Decimal;
							_maxWeight : Integer;
							_maxQuantity : Integer
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2016	cnwndl1	Initial creation	TFS 2172

*/

vars

	proxyTAM : CM_TerminalAreaMaster;
	proxyMinMax : CM_TerminalAreaProductMinMax;
	load : Boolean;

begin

	app.cmsBeginLoad(load);
	proxyTAM := _tam.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	create proxyMinMax transient;
	proxyMinMax.setupProxy(	null,_cargoType,
							_cargoSubType,
							proxyTAM,
							_minVol,
							_minWeight,
							_maxVol,
							_maxWeight,
							_maxQuantity
							);

	app.myTrxUA.trxUpdateTerminalArea(proxyTAM, app.myPassport);

epilog

	app.cmsEndLoad(load);
	delete proxyMinMax;
	delete proxyTAM;

end;</source>
