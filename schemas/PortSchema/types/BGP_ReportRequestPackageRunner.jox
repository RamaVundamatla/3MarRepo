<Class name="BGP_ReportRequestPackageRunner" id="c6d80010-a55b-47c0-92a3-30bb42f46b9e">
    <superclass name="BGP_ReportRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Package Runner&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ExplicitInverseRef name="allAttachedFiles" id="3e7737d2-9088-43fb-8dd5-ce2444c39fc4">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_FileDataStorageHdrSet"/>
        <access>readonly</access>
        <Inverse name="CM_FileDataStorageHeader::myBGPRequestPackageRunner"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allReportRequests" id="7fd8703a-390b-4918-85ff-83388053049b">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="BGP_RequestSet"/>
        <access>readonly</access>
        <Inverse name="BGP_ReportRequestPackage::myPackageRunner"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myPackage" id="a3ab43ca-3979-4fbe-9cf7-967ac55e8352">
        <embedded/>
