    <JadeMethod name="tblLocks_contextMenu" id="33c83022-7635-4edd-96ae-76b2884ceeb4">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocks_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1, y1	: Real;

begin

	self.mnuTblLocksPrintAll.visible := false;
	self.mnuTblLocksPrintSelect.visible := false;
	self.mnuTblNodesSendReq.visible := false;
	self.mnuTblNodesShowScreen.visible := false;//par14598
	
	// Don't show these options on the locks table
	self.mnuSetLogLevel.visible := false;
	self.mnuSetLogLvlApp.visible := false;

	if self.isDeveloper or app.isDevelopmentSystem or app.isSpecial() then
		self.mnuTblLocksPrintAll.visible := true;
		self.mnuTblLocksPrintSelect.visible := true;
	endif;

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
//	self.mnuTblLocksPrintAll.visible := true;
//	self.mnuTblLocksPrintSelect.visible := true;
//	self.mnuTblNodesSendReq.visible := false;
	
	popupMenu(mnuTblNodesContext, x1.Integer, y1.Integer);
	
	return false;

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblLocks_dblClick" id="52314922-4153-4980-b524-090e3d05077e">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocks_dblClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rowIdx	: Integer;
	theRow	: JadeTableRow;
	obj		: Object;
begin

	rowIdx := table.row;
	
	if rowIdx = 1 then
		table.resortTableByColumn(table.column);
	else
		if app.isAllowedToInspect then
			theRow := table.accessRow(rowIdx);
			obj := theRow.itemObject;
			if obj &lt;&gt; null then
				obj.inspect;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblNodes_click" id="94e5112d-c180-473c-bf25-7c8e99b7f9dc">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblNodes_click(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;
	
	if table.row = 1 then
		table.resortTableByColumn(table.column);
		self.doHighLights();
	endif;
/*	self.tblNodes.sortColumn[1] := table.column;    
	self.tblNodes.sortAsc[1]    := self.sortAscending;
	self.sortAscending := not self.sortAscending;
	self.tblNodes.sortCased[1]  := false;
	self.tblNodes.resort;*/
/*
	self.tblNodes.sortColumn[2] := 2;    
	self.tblNodes.sortAsc[2]    := true;
	self.tblNodes.sortCased[2]  := false;
	self.tblNodes.sortColumn[3] := 3;    
	self.tblNodes.sortAsc[3]    := true;
	self.tblNodes.sortCased[3]  := false;
*/
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblNodes_contextMenu" id="5092e6a0-2fa8-4a5a-b841-3a9c7a0ee3eb">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblNodes_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1, y1	: Real;
	rowIndex : Integer;
	processObj : Process;
	schema : Schema;
	portSchema : Schema;
	superSchema : Schema;
	canChangeLogLevel : Boolean;

begin
	self.mnuTblLocksPrintAll.visible := false;
	self.mnuTblLocksPrintSelect.visible := false;
	self.mnuTblNodesSendReq.visible := false;
	self.mnuSetLogLevel.visible := false;	//26 Nov 2019	NDL	TFS 47053
	self.mnuSetLogLvlApp.visible := false;	//27 Jan 2020 jlgmd1 TFS 48270
	
	self.mnuTblNodesShowScreen.visible := true;//par14598
	
	if self.isDeveloper or app.isDevelopmentSystem or app.isSpecial() then
		self.mnuTblNodesSendReq.visible := true;
	endif;
	
	//26 Nov 2019	NDL	TFS 47053
	if app.isSpecial() or app.getMyUser.isSuperUser or app.getMyUser.isJmtSupportUser then
		rowIndex := self.tblNodes.row;
		if rowIndex &gt; self.tblNodes.fixedRows and  rowIndex &lt;= self.tblNodes.rows then
			processObj := self.tblNodes.accessRow( rowIndex ).itemObject.Process;
			if processObj &lt;&gt; null then
				self.mnuSetLogLevel.visible := true;
				self.mnuSetLogLevel.enabled := false;
				self.mnuSetLogLvlApp.visible := true;		//27 Jan 2020 jlgmd1 TFS 48270
				self.mnuSetLogLvlApp.enabled := false;		//27 Jan 2020 jlgmd1 TFS 48270
				portSchema := rootSchema.getSchema( "PortSchema" );
				schema := rootSchema.getSchema( processObj.schema.name );
				if portSchema &lt;&gt; null and schema &lt;&gt; null then
					superSchema := schema;
					while true do
						if superSchema = portSchema then
							canChangeLogLevel := true;
							break;
						elseif superSchema = null or superSchema = rootSchema then
							canChangeLogLevel := false;
							break;
						endif;
						superSchema := superSchema.superschema;
					endwhile;
				endif;
				if canChangeLogLevel then
					self.mnuSetLogLevel.userObject := processObj;
					self.mnuSetLogLevel.enabled := true;
					
					//27 Jan 2020 jlgmd1 TFS 48270
					if processObj.persistentApp.name &lt;&gt; "JMTerminal" then
						self.mnuSetLogLvlApp.userObject := processObj;
						self.mnuSetLogLvlApp.enabled := true;
					endif;
				endif;
			endif;
		endif;	
	endif;

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if tblNodes.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := tblNodes.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form

//	self.mnuTblLocksPrintAll.visible := false;
//	self.mnuTblLocksPrintSelect.visible := false;
//	self.mnuTblNodesSendReq.visible := true;

	self.mnuColumnOrganiser.userObject := self.tblNodes;	//18/09/2023 navmd1 TFS 60524
	
	popupMenu(mnuTblNodesContext, x1.Integer, y1.Integer);
	
	return false;

epilog
	
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
