    <JadeMethod name="showMultiSelectForm" id="f9479b2c-2350-4263-a874-9842820d90ff">
        <source>showMultiSelectForm(_multi : CMUI_MultiSelectGroupBox input; _queue : CM_RadioTelemetryQueue; _isFrom, _isInit : Boolean) protected;

// Created by cnwdvb1 on 30 July 2007
/* This method controls the locations controllers that end up 
in the group boxes for selection based on the terminal areas selected. */
// 25/02/2010	cnwcs5	removed VTA reference
vars

	array1,
	arrayAvailable	: ObjectArray;
	obj				: Object;
	ta				: CM_TerminalArea;
	aController		: CM_LocationsController;
	idx,
	totRows			: Integer;
	lcArray,
	tmpArray,
	lcSelected		: CM_LCArray;
	isEnabled		: Boolean;

begin

	// If using init then the group box is populated from the queue otherwise
	// it gets the selected from the group box itself.
	if not _isInit then
		create tmpArray transient;
		lcArray := tmpArray;
		if _isFrom then
			self.grpFrmLocations.getSelected(lcArray);
		else
			self.grpToLocations.getSelected(lcArray);
		endif;
	else	
		if _isFrom then
			lcArray := _queue.CM_SubQueue.moveFromLocnControllers;
		else
			lcArray := _queue.CM_SubQueue.moveToLocnControllers;
		endif;
	endif;
	
	
	create lcSelected transient;
	create array1 transient;
	
	// Get selected terminal areas.
	_multi.getSelected(array1);
	
	create arrayAvailable transient;
	lcSelected.clear();
		
	// Process each selected area.	
	foreach obj in array1 where (obj.isKindOf(CM_GridArea)) do	// 25/02/2010  cnwcs5 - removed VTA reference
		ta := obj.CM_TerminalArea;
		
		// Go through locations controllers and put appropriate locations into the group box. 
		foreach aController in ta.allLocationsControllers do
			if aController.isKindOf(CM_GridController) or aController.isKindOf(CM_BlockController) then
				arrayAvailable.add(aController);
			endif;
		endforeach;
		
		// Work out if the select list is still valid.
		foreach aController in lcArray do
			if aController.isKindOf(CM_GridController) or aController.isKindOf(CM_BlockController) and
				aController.myTerminalArea = ta then
				lcSelected.add(aController);
			endif;
		endforeach;
				
	endforeach;
	
	// Rebuild the location group boxes.
	if _isFrom then
		self.grpFrmLocations.setAvailable(arrayAvailable, true);
		self.grpFrmLocations.setSelected(lcSelected);
	else
		self.grpToLocations.setAvailable(arrayAvailable, true);
		self.grpToLocations.setSelected(lcSelected);
	endif;
	
epilog
	delete array1;
	delete arrayAvailable;
	delete tmpArray;
	delete lcSelected;	
end;</source>
        <access>protected</access>
        <Parameter name="_multi" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_isFrom" type="Boolean"/>
        <Parameter name="_isInit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="8808505b-fe52-4221-a169-14c3d643268b">
        <updating/>
        <source>showThumbnailData(obj: CM_RadioTelemetryQueue) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/10/2009	cnwcs5		par 21285 - fixed exception
// 01/10/2025	jlizm1		MTN 35861 RTQueue configuration - cargo attribute criteria
// ---------------------------------------------------------------------------

vars
	theQueue				: CM_SubQueue;
	theVQueue				: CM_VoyageQueue;
	theVCQueue				: CM_VoyageCraneQueue;
	theWPQueue				: CM_VoyageWorkPointQueue;
	idx						: Integer;
	fromAreaStr,
	toAreaStr				: String;
	
begin
	
	// DVB changed 11/08/06
	self.shtFromAreas.visible := false;
	self.shtToAreas.visible := false;
	self.shtMachineTypes.visible := false;
	self.btnEditCTA.visible:=false;
	self.btnEditCTA.enabled:=true;
	self.cmbType.setIndexForItemData(obj.queueType);
	self.cmbType.click(self.cmbType);	
	
	self.tblMain.setValueByName(ETRow_Id,obj.id);
	idx := self.cmbParent.findObject(obj.myParentQueue);
	if idx &gt; 0 then
		self.cmbParent.listIndex := idx;
		self.cmbParent.click(self.cmbParent);
	endif;
	
	self.tblMain.setValueByControlName(self.cmbParent.name,self.cmbParent.text.trimBlanks);
	
	if obj.queueType = QTYPE_SUBQUEUE or obj.queueType = QTYPE_VOYAGEYARD  then
		theQueue := obj.CM_SubQueue;
		fromAreaStr := theQueue.allMoveFromTAMasters.getAreaAsString();
		toAreaStr := theQueue.allMoveToTAMasters.getAreaAsString();
		
		self.tblMain.setValueByName(ETRow_FromAreas, fromAreaStr);	
		// Do area1 options.
		if not theQueue.isUnidirectional then
			self.tblMain.showRowByName(ETRow_Area1Opts,false);
			if theQueue.lookForFromAreaMove then
				self.optGetSame1.value := true;
				self.optGetSame1.click(self.optGetSame1);
			else
				self.optGetNext1.value := true;
				self.optGetNext1.click(self.optGetNext1);
			endif;
		endif;
			
		self.tblMain.setValueByName(ETRow_ToAreas, toAreaStr);
		
		// Do area2 options.
			
		if not theQueue.isUnidirectional then
			self.tblMain.showRowByName(ETRow_Area2Opts,false);
			if theQueue.lookForToAreaMove then
				self.optGetSame2.value := true;
				self.optGetSame2.click(self.optGetSame2);
			else
				self.optGetNext2.value := true;
				self.optGetNext2.click(self.optGetNext2);
			endif;
		endif;
		
		self.grpAreasCovered1.multiClear();
		self.grpAreasCovered2.multiClear();
		
		self.doDisplayMachineTypeGrps(theQueue);
			
		if not theQueue.isUnidirectional then
			self.cmbDirectional.listIndex := 1;
		else
			self.cmbDirectional.listIndex := 2;
		endif;
		self.tblMain.setValueByControlName(self.cmbDirectional.name,self.cmbDirectional.text.trimBlanks);
		
		self.doDisplayGroupLocations(theQueue);
		//jlier1 TFS 51260 8/11/21
		if obj.queueType = QTYPE_VOYAGEYARD then
			self.cmbVoyage.setIndexFromObject(obj.CM_SubQueue.myVoyage);
			self.tblMain.setValueByControlName(self.cmbVoyage.name,self.cmbVoyage.text.trimBlanks);
			self.cmbVoyageJobType.setIndexForItemData(obj.CM_SubQueue.voyageJobType);
			self.tblMain.setValueByControlName(cmbVoyageJobType.name,cmbVoyageJobType.text);
		endif;
		
		
	elseif obj.queueType = QTYPE_RTGSUBQUEUE then

	elseif obj.queueType = QTYPE_RTG or obj.queueType = QTYPE_RMG then
		theQueue := obj.CM_SubQueue;
		fromAreaStr := theQueue.allMoveFromTAMasters.getAreaAsString();
		self.tblMain.setValueByName(ETRow_FromAreas, fromAreaStr);
		self.doDisplayGroupLocations(theQueue);
	elseif obj.queueType = QTYPE_VOYAGE then
		theVQueue := obj.CM_VoyageQueue;
		
		// VOYAGE
		idx := self.cmbVoyage.findObject(theVQueue.myVoyage);
		self.cmbVoyage.listIndex := idx;
		
		self.tblMain.setValueByControlName(self.cmbVoyage.name,self.cmbVoyage.text.trimBlanks);
		

	elseif obj.queueType = QTYPE_CRANE then
		theVCQueue := obj.CM_VoyageCraneQueue;
		
		self.cmbCranes.setObject(theVCQueue.crane);
		self.tblMain.setValueByName(ETRow_Cranes,self.cmbCranes.text);
		
		self.cmbDiscMachMode.setIndexForItemData(theVCQueue.dischargeMachinesMode);
		self.tblMain.setValueByName(ETRow_DischargeMachineHandover,self.cmbDiscMachMode.text);
		
		self.cmbLoadMachMode.setIndexForItemData(theVCQueue.loadMachinesMode);
		self.tblMain.setValueByName(ETRow_LoadMachineHandover,self.cmbLoadMachMode.text);
		self.btnEditCTA.visible:=true; //epr par 32902 8/11/13

	elseif obj.queueType = QTYPE_WORKPOINT then
		//CCMS 1033 21/7/11
		theWPQueue := obj.CM_VoyageWorkPointQueue;
		idx := self.cmbWorkPoint.findObject(theWPQueue.myWorkPoint);
	
		self.cmbWorkPoint.listIndex:= idx;
		self.tblMain.setValueByName(ETRow_WorkPoint,self.cmbWorkPoint.text);
		
		self.cmbDiscMachMode.setIndexForItemData(theWPQueue.dischargeMachinesMode);
		self.tblMain.setValueByName(ETRow_DischargeMachineHandover,self.cmbDiscMachMode.text);
		
		self.cmbLoadMachMode.setIndexForItemData(theWPQueue.loadMachinesMode);
		self.tblMain.setValueByName(ETRow_LoadMachineHandover,self.cmbLoadMachMode.text);
	
	endif;
	
	self.setAllCriteria(self.myCurrentObject.CM_RadioTelemetryQueue);
	self.displayCriteriaDesc();
	self.tblMain.optimiseTableHeight;
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditCTA.enabled:= false;
	endif;
end;</source>
        <Parameter name="obj" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
