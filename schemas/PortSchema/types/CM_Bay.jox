    <JadeMethod name="exportAsXMLInverseRef" id="6a911733-4500-4445-926e-10f0a6d00e42">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	if _property = CM_Bay::allCellsOnDeck then
		return ExportAsParent;
	elseif _property = CM_Bay::allTiersOnDeck then
		return ExportAsParent;
	elseif _property = CM_Bay::allCellsUnderDeck then
		return ExportAsParent;
	elseif _property = CM_Bay::allTiersUnderDeck then
		return ExportAsParent;
	elseif _property = CM_Bay::allSlotsByOrdinal then
		return ExportAsParent;
	elseif _property = CM_Bay::myAftBay then
		return ExportAsChild;
	elseif _property = CM_Bay::myForwardBay then
		return ExportAsChild;
	elseif _property = CM_Bay::myHold then
		return ExportAsChild;
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
