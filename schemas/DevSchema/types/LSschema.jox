    <JadeMethod name="delete" id="aec6ae93-7b4c-49b6-b495-d2ab105e01b0">
        <updating/>
        <source>delete() updating;

/*

Purpose:		

Date			Who		Reason
16/03/2015		cnwmh5	Initial creation

*/

vars
	
begin

	self.allClasses.purge();
	self.allConstants.purge();
	self.allGlbConstantsToDelete.purge();
	self.allTranslatableStrings.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getLSclass" id="f4bdd3f6-d8f0-4fbb-a5e8-d687c9807feb">
        <source>getLSclass(className:String):LSclass;

vars
	lscls : LSclass;
	tmpClass	: Class;
begin
	lscls := allClasses[className];
	if lscls = null then
		tmpClass := self.mySchema.getClass(className);
		if tmpClass = null then
			return null;
		endif;
		
		create lscls transient;
		lscls.myClass := tmpClass;
		lscls.name := lscls.myClass.name;	// this way round gets 1090 if name is mis-spelled
		lscls.mySchema := self;
	endif;
	return lscls;
end;</source>
        <Parameter name="className" type="String"/>
        <ReturnType type="LSclass"/>
    </JadeMethod>
    <JadeMethod name="produceJCFForDelXlatGlbCnst" id="77e37c9f-862c-4aad-988e-d03bd813a81a">
        <source>produceJCFForDelXlatGlbCnst(folder : FileFolder): ObjectArray;

/*

Purpose:	Produce a JCF for PortSchema to delete unused global constants		

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwmh5	Initial creation

*/


vars

	file		: File;
	constantObj	: Constant;
	logMsg		: String;
	allMethodRefs	: MethodSet;
	constantsToDelete : ObjectArray;
begin
	
	create file transient;
	create constantsToDelete transient;
	file.usePresentationFileSystem := folder.usePresentationFileSystem;
	file.openOutput(folder.fileName &amp; '\' &amp; mySchema.name &amp; '-DeleteGlobalConstants.jcf');

	self.myAgent.log('Creating jcf: ' &amp; file.fileName, false);	
	
	file.writeLine(self.zJCFHeader());
		
	create allMethodRefs transient;
	foreach constantObj in rootSchema.getSchema(PortSchemaName).getCategory(XLAT_FormCaptions).getConstants do
		allMethodRefs.clear();
		constantObj.getMethodRefs(allMethodRefs);
		if allMethodRefs.size = 0 then
			file.writeLine("Delete GlobalConstant PortSchema::" &amp; constantObj.name);
			constantsToDelete.add(constantObj);
		endif;	
	endforeach;
	
	self.myAgent.log('	Complete: ' &amp; file.fileLength.String &amp; ' bytes', false);
	
	logMsg := "*** Warning - JCF for Global Constants to delete has been created";
	self.myAgent.log(logMsg, true);
	app.createAlert(logMsg, true);
		
	return constantsToDelete;
		
epilog
	delete file;
	delete allMethodRefs;
end;</source>
        <Parameter name="folder" type="FileFolder"/>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="produceScmFileForXlatablStrngs" id="8f2151bb-c159-4a69-9575-fbc26c561330">
        <source>produceScmFileForXlatablStrngs(file : File; nextValue : Integer io);

vars
	lsTs 		: LStranslatableString;
	stringName	: String;
	locale		: Locale;	// 5129 = NZ English
	proxy		: XLAT_TranslationsAndGCProxy;
	category	: XLAT_Category;
	message		: String;
	
begin
	self.myAgent.log('Creating scm: ' &amp; file.fileName, false);	
	
	create proxy transient;	// reuse

	category := myAgent.root.allXLAT_Categories[XLAT_Exceptions];
	foreach lsTs in allTranslatableStrings do
		nextValue := nextValue + 1;
		
		if lsTs.validate(message) = false then
			app.writeStatement( 'Error: ' &amp; message);
			continue;
		endif;
				
		proxy.initialiseForXlatableStringScm(lsTs.sourceNewFormat, null, myAgent.root, category);	// message text (NZ English)

		file.writeLine(
						Tab&amp;Tab&amp;										// padding
						lsTs.name &amp;':'&amp;Tab&amp;Tab&amp;Tab&amp;						// Glb Constant name
						'Integer = ' &amp; nextValue.String &amp;';' &amp;CrLf &amp;	// Glb Constant type &amp; value
						'	documentationText' &amp;CrLf &amp;
						'`' &amp; proxy.buildXml &amp; '`');					// default locale text
	endforeach;
	
	self.myAgent.log('	Complete: ' &amp; file.fileLength.String &amp; ' bytes', false);
epilog
	delete proxy;
end;</source>
        <Parameter name="file" type="File"/>
        <Parameter name="nextValue" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="produceScmFile_FormXLATGlbTfr" id="ddaf7d58-c93c-436b-909d-3e83d2e0811b">
        <source>produceScmFile_FormXLATGlbTfr(folder : FileFolder; allSchemas : LSschemaByName);

/*

Purpose:		produce a PortSchema partial schema file to load global constants required for translation of form text
				(captions, bubbleHelp)
				This is for the transfer of constants between Development Environment and system double patching in

Date			Who		Reason
04/11/2015		cnwmh5	Initial creation

*/

vars
	file	: File;
	constantCategory : ConstantCategory;
	lsSchema : LSschema;
	lsClass : LSclass;
	lsConstant : LSconstant;
	text : String;
	constantNumberOut : Integer;
	
begin
	create file transient;
	file.usePresentationFileSystem := folder.usePresentationFileSystem;
	file.openOutput(folder.fileName &amp; '\' &amp; mySchema.name &amp; '-FormCaptions-partial.scm');

	self.myAgent.log('Creating scm: ' &amp; file.fileName, false);	
	
	file.writeLine(zScmHeader);
	
	constantCategory := rootSchema.getSchema(PortSchemaName).getConstantCategory(XLAT_FormCaptions);
	file.writeLine('constantDefinitions');

	// constant category
	file.writeLine(Tab &amp; 'categoryDefinition ' &amp; constantCategory.name);
	file.writeLine(Tab &amp; 'documentationText');
	file.writeLine('`' &amp; XML_Version &amp; 'TranslationClass ClassName="' &amp; XLAT_FormCaption.name &amp; '"&gt;');
	file.writeLine('&lt;/TranslationClass&gt;`');

	foreach lsSchema in allSchemas do
		foreach lsClass in lsSchema.allClasses do
			foreach lsConstant in lsClass.allConstants do
			
				app.writeLog(method.qualifiedName() &amp; Tab &amp; lsClass.myClass.name &amp; Tab &amp; lsConstant.schemaName &amp; Tab &amp; 
					lsConstant.formName &amp; Tab &amp; lsConstant.controlName &amp; Tab &amp; lsConstant.controlProperty, LogINFO);
		
				// now write the constant definition to the scm file	
				file.writeLine(Tab &amp; Tab &amp; lsConstant.name &amp; ':	Integer = ' &amp; lsConstant.number.String &amp; ';');
				file.writeLine(Tab &amp; 'documentationText');
				file.writeLine('`' &amp; XML_Version &amp; XMLTag_Header &amp; ' ' &amp;
								XML_Tag_SchemaName &amp; '="' &amp; lsConstant.schemaName &amp; '" ' &amp;
								XML_Tag_FormClass &amp; '="' &amp; lsConstant.formName &amp; '" ' &amp;
								XML_Tag_ControlName &amp; '="' &amp; lsConstant.controlName &amp; '" ' &amp;
								XML_Tag_ControlProperty &amp; '="' &amp; lsConstant.controlProperty &amp; '"&gt;');
				file.writeLine('&lt;' &amp; XMLTag_LocaleMsg &amp; ' ' &amp; XMLTag_LocaleName &amp; '="' &amp; StandardTextLocaleStr &amp; '"&gt;');
				file.writeLine('&lt;' &amp; XMLTag_Msg &amp; '&gt;' &amp; lsConstant.text.xmlReplaceReservedChars(true) &amp; '&lt;/' &amp; XMLTag_Msg &amp; '&gt;');
				file.writeLine('&lt;/' &amp; XMLTag_LocaleMsg &amp; '&gt;');
				file.writeLine('&lt;/' &amp; XMLTag_Header &amp; '&gt;`');
		
			endforeach;
		endforeach;
	endforeach;

	self.myAgent.log('	Complete: ' &amp; file.fileLength.String &amp; ' bytes', false);
epilog
	delete file;
end;</source>
        <Parameter name="folder" type="FileFolder"/>
        <Parameter name="allSchemas" type="LSschemaByName"/>
    </JadeMethod>
    <JadeMethod name="produceScmFile_FormXlatGlbCnst" id="a1c9eb75-1700-4cf4-b67e-37fc1a4074da">
        <source>produceScmFile_FormXlatGlbCnst(folder : FileFolder; allSchemas : LSschemaByName; highestConstantNumber : Integer);

// produce a PortSchema partial schema file to load global constants required for translation of form text
// (captions, bubbleHelp)

vars
	file	: File;
	constantCategory : ConstantCategory;
	constantNumber : Integer;
	lsSchema : LSschema;
	lsClass : LSclass;
	lsConstant : LSconstant;
	text : String;
	constantNumberOut : Integer;
	transAgent : FormCaptionsAgentXLATGenerate;
begin
	create file transient;
	file.usePresentationFileSystem := folder.usePresentationFileSystem;
	file.openOutput(folder.fileName &amp; '\' &amp; mySchema.name &amp; '-FormCaptions-partial.scm');

	self.myAgent.log('Creating scm: ' &amp; file.fileName, false);	
	
	file.writeLine(zScmHeader);
	
	constantCategory := rootSchema.getSchema(PortSchemaName).getConstantCategory(XLAT_FormCaptions);
	file.writeLine('constantDefinitions');

	// constant category
	file.writeLine(Tab &amp; 'categoryDefinition ' &amp; constantCategory.name);
	file.writeLine(Tab &amp; 'documentationText');
	file.writeLine('`' &amp; XML_Version &amp; 'TranslationClass ClassName="' &amp; XLAT_FormCaption.name &amp; '"&gt;');
	file.writeLine('&lt;/TranslationClass&gt;`');

	// this is the constant's unique key
	constantNumber := highestConstantNumber;
	
	create transAgent transient;
	
	foreach lsSchema in allSchemas do
		foreach lsClass in lsSchema.allClasses do
			foreach lsConstant in lsClass.allConstants do
			
				if lsConstant.dontGenerate then							// 24/09/2015 cnwmh5
					continue;
				endif;
		
				// increment constant value
				if lsConstant.number &gt; 0 then
					constantNumberOut := lsConstant.number;
				else
					constantNumber := constantNumber + 1;
					constantNumberOut := constantNumber;
				endif;
				
			//	 transAgent.makeConstantName(lsConstant,constantNumberOut);
				
		
				// Text for default locale is the caption/bubbleHelp text as defined by the developer in Painter.
				//text := lsConstant.myControl.getPropertyValue(lsConstant.controlProperty).String;
				text := lsConstant.text;
		
				// now write the constant definition to the scm file	
				file.writeLine(Tab &amp; Tab &amp; lsConstant.name &amp; ':	Integer = ' &amp; constantNumberOut.String &amp; ';');
				file.writeLine(Tab &amp; 'documentationText');
				file.writeLine('`' &amp; XML_Version &amp; XMLTag_Header &amp; ' ' &amp;
								XML_Tag_SchemaName &amp; '="' &amp; lsConstant.schemaName &amp; '" ' &amp;
								XML_Tag_FormClass &amp; '="' &amp; lsConstant.formName &amp; '" ' &amp;
								XML_Tag_ControlName &amp; '="' &amp; lsConstant.controlName &amp; '" ' &amp;
								XML_Tag_ControlProperty &amp; '="' &amp; lsConstant.controlProperty &amp; '"&gt;');
				file.writeLine('&lt;' &amp; XMLTag_LocaleMsg &amp; ' ' &amp; XMLTag_LocaleName &amp; '="' &amp; StandardTextLocaleStr &amp; '"&gt;');
				file.writeLine('&lt;' &amp; XMLTag_Msg &amp; '&gt;' &amp; text.xmlReplaceReservedChars(true) &amp; '&lt;/' &amp; XMLTag_Msg &amp; '&gt;');
				file.writeLine('&lt;/' &amp; XMLTag_LocaleMsg &amp; '&gt;');
				file.writeLine('&lt;/' &amp; XMLTag_Header &amp; '&gt;`');
		
			endforeach;
		endforeach;
	endforeach;

	/*
	foreach lsConstant in self.allConstants do
		// Text for default locale is the caption/bubbleHelp text as defined by the developer in Painter.
		//text := lsConstant.myControl.getPropertyValue(lsConstant.controlProperty).String;
		text := lsConstant.text;

		// now write the constant definition to the scm file	
		file.writeLine(Tab &amp; Tab &amp; lsConstant.name &amp; ':	Integer = ' &amp; lsConstant.number.String &amp; ';');
		file.writeLine(Tab &amp; 'documentationText');
		file.writeLine('`' &amp; XML_Version &amp; XMLTag_Header &amp; ' ' &amp;
						XML_Tag_SchemaName &amp; '="' &amp; lsConstant.schemaName &amp; '" ' &amp;
						XML_Tag_FormClass &amp; '="' &amp; lsConstant.formName &amp; '" ' &amp;
						XML_Tag_ControlName &amp; '="' &amp; lsConstant.controlName &amp; '" ' &amp;
						XML_Tag_ControlProperty &amp; '="' &amp; lsConstant.controlProperty &amp; '"&gt;');
		file.writeLine('&lt;' &amp; XMLTag_LocaleMsg &amp; ' ' &amp; XMLTag_LocaleName &amp; '="' &amp; StandardTextLocaleStr &amp; '"&gt;');
		file.writeLine('&lt;' &amp; XMLTag_Msg &amp; '&gt;' &amp; text.xmlReplaceReservedChars(true) &amp; '&lt;/' &amp; XMLTag_Msg &amp; '&gt;');
		file.writeLine('&lt;/' &amp; XMLTag_LocaleMsg &amp; '&gt;');
		file.writeLine('&lt;/' &amp; XMLTag_Header &amp; '&gt;`');
	endforeach;
	*/
	
	self.myAgent.log('	Complete: ' &amp; file.fileLength.String &amp; ' bytes', false);
epilog
	delete file;
	delete transAgent;
end;</source>
        <Parameter name="folder" type="FileFolder"/>
        <Parameter name="allSchemas" type="LSschemaByName"/>
        <Parameter name="highestConstantNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="produceScmFile_FormXlatMethods" id="bbaeedf1-d91d-4e19-aba0-140f3bd00bd4">
        <source>produceScmFile_FormXlatMethods(folder : FileFolder);

/*

Date		Who		Reason
05 Jun 2008	cnwkpd1	JADE PAR #48105 - fix jadeMethodDefinitions section to have correct header on translateForm
					methods
09/06/2011	cnwmh5	#27657 - update details getting written out
*/

vars
	lsClass : LSclass;
	file : File ;
ts			: TimeStamp;
begin
	create file transient;
	file.usePresentationFileSystem := folder.usePresentationFileSystem;
	file.openOutput(folder.fileName &amp; '\' &amp; mySchema.name &amp; '-FormCaptions-partial.scm');
	self.myAgent.log("Creating scm: " &amp; file.fileName, true);

	file.writeLine(zScmHeader);

	file.writeLine("typeDefinitions");
	//foreach lsClass in allClasses where lsClass.allConstants.size &gt; 0 do
	foreach lsClass in allClasses where lsClass.allConstants.size &gt; 0 or lsClass.allConstForMethFix.size &gt; 0 do
		file.writeLine(lsClass.name &amp; " partialDefinition");
		file.writeLine(Tab &amp; "(");
		file.writeLine(Tab &amp; "jadeMethodDefinitions");
		file.writeLine(Tab &amp; Tab &amp;  CM_BaseForm::translateForm.makeHeader &amp; " updating;");	// cnwkpd1 05/06/2008
		file.writeLine(Tab &amp; Tab &amp; 'setModifiedTimeStamp "cnwmh5" "16.0.02" ' &amp;  currentSchema.patchVersion.String &amp; ' ' &amp; 
			ts.date.year.String &amp; ":" &amp; ts.date.month.padLeadingWith("0", 2) &amp; ":" &amp; ts.date.day.padLeadingWith("0", 2) &amp; ":" &amp; 
			ts.time.hour.padLeadingWith("0", 2) &amp; ":" &amp; ts.time.minute.padLeadingWith("0", 2) &amp; ":" &amp; 
			ts.time.second.padLeadingWith("0", 2) &amp; "." &amp; ts.time.milliSecond.String &amp; ";");
		file.writeLine(Tab &amp; ")");
	endforeach;
	
	file.writeLine("typeSources");
	//foreach lsClass in allClasses where lsClass.allConstants.size &gt; 0 do
	foreach lsClass in allClasses do
		if lsClass.allConstants.size &gt; 0 or lsClass.allConstForMethFix.size &gt; 0 then
			file.writeLine(lsClass.zScmTypeSource);
		endif;
	endforeach;

	self.myAgent.log('	Complete: ' &amp; file.fileLength.String &amp; ' bytes', false);
epilog
	delete file;
end;</source>
        <Parameter name="folder" type="FileFolder"/>
    </JadeMethod>
    <JadeMethod name="produceScmFile_Translations" id="08dc2cc9-7e18-4146-8df1-8178619abca2">
        <source>produceScmFile_Translations(folder : FileFolder);

vars
	file			: File;
	lsClass			: LSclass;
	lsConstant		: LSconstant;
	
	str 			: String;
	date			: Date;
	
begin
	
	create file transient;
	file.usePresentationFileSystem := true;
	file.openOutput(folder.fileName &amp; '\PortSchema-FormCaptions-JadeScriptTranslations.scm');
	self.myAgent.log("Creating scm: " &amp; file.fileName, true);

	str := 'jadeVersionNumber "' &amp; app.getSystemVersion &amp; '";' &amp; CrLf &amp; 
		"schemaDefinition" &amp; CrLf &amp;
		"PortSchema subschemaOf BaseSchema partialDefinition;" &amp; 
		"typeDefinitions" &amp; CrLf &amp;
		Tab &amp; "JadeScript partialDefinition" &amp; CrLf &amp;
		Tab &amp; "(" &amp; CrLf &amp;
		Tab &amp; "jadeMethodDefinitions" &amp; CrLf &amp;
		Tab &amp; Tab &amp; "loadSpecificTranslation2();" &amp; CrLf &amp;
		Tab &amp; ")" &amp; CrLf &amp;
		"typeSources" &amp; CrLf &amp; 
		Tab &amp; "JadeScript" &amp; CrLf &amp; Tab &amp; "(" &amp; CrLf &amp;
		Tab &amp; "jadeMethodSources" &amp; CrLf &amp;
		"loadSpecificTranslation2" &amp; CrLf &amp;
		"{" &amp; CrLf;
	
	str := str &amp; "loadSpecificTranslation2();" &amp; CrLf &amp;
	   Tab &amp; "//----------------------------------------------------------------------" &amp; CrLf &amp;
	   Tab &amp; "//" &amp; CrLf &amp;
	   Tab &amp; "//  Created by cnwsh3" &amp; CrLf &amp;
	   Tab &amp; "//" &amp; CrLf &amp;
	   Tab &amp; "//	Date 04 May 2007" &amp; CrLf &amp;
	   Tab &amp; "//" &amp; CrLf &amp;
	   Tab &amp; "//Adds a specific error message to a system." &amp; CrLf &amp;
	   Tab &amp; "//" &amp; CrLf &amp;
	   Tab &amp; "// Usage: 	1. Ensure the new error message has been loaded in the patch definition" &amp; CrLf &amp;
	   Tab &amp; "//			2. Add the global constant as a string" &amp; CrLf &amp;
	   Tab &amp; "//" &amp; CrLf &amp;
	   Tab &amp; "// Designed to add the error message as per global constant and include it in all" &amp; CrLf &amp;
	   Tab &amp; "// the locales that exist on the system." &amp; CrLf &amp;
	   Tab &amp; "//----------------------------------------------------------------------" &amp; CrLf &amp;
	   Tab &amp; "// Created on " &amp; date.String &amp; "." &amp; CrLf &amp;
	   "vars" &amp; CrLf &amp;
	   Tab &amp; "transAgent : CM_TranslationAgent;" &amp; CrLf &amp;
	   Tab &amp; "sa : StringArray;" &amp; CrLf &amp;
	   "begin" &amp; CrLf &amp;
	   Tab &amp; "app.initialize;" &amp; CrLf &amp;
	   Tab &amp; "create transAgent transient;" &amp; CrLf &amp;
	   Tab &amp; "create sa transient;" &amp; CrLf;
	   	   
	file.writeLine(str);
	
	str := null; 
	foreach lsClass in allClasses do
		// add each constant to the array
		foreach lsConstant in self.allConstants do
			if lsConstant.dontGenerate then							// 24/09/2015 ncwmh5
				continue;
			endif;
			str := str &amp; Tab &amp; 'sa.add("' &amp; lsConstant.name &amp; '");' &amp; CrLf;
		endforeach;
	endforeach;
	
	str := str &amp; CrLf &amp; 
		Tab &amp; 'app.writeLog("sa.size: " &amp; sa.size.String, LogINFO);' &amp; CrLf &amp; 
		Tab &amp; 'transAgent.trxLoadSpecificTranslations(sa);' &amp; CrLf &amp;
		Tab &amp; "app.finalize;" &amp; CrLf &amp;
		"epilog" &amp; CrLf &amp;
		Tab &amp; "delete transAgent;" &amp; CrLf &amp;
		Tab &amp; "delete sa;" &amp; CrLf &amp;
		"end;" &amp; CrLf &amp;
		  "}" &amp; CrLf &amp;
		 Tab &amp; ")";
	file.writeLine(str);
	file.close();
	
	self.myAgent.log('	Complete: ' &amp; file.fileLength.String &amp; ' bytes', false);
	
epilog

	delete file;

end;</source>
        <Parameter name="folder" type="FileFolder"/>
    </JadeMethod>
    <JadeMethod name="produceScm_XlatblStrngMthRefs" id="702d26ba-fc24-4cd4-8f2d-362b1bb186e0">
        <source>produceScm_XlatblStrngMthRefs(_path : String);

vars
	lsClass : LSclass;
	file : File ;
	restore : File;

begin
	create file transient;
	file.usePresentationFileSystem := true;
	file.openOutput(_path &amp; "\" &amp; mySchema.name &amp; "-XlatStringRefs-partial.scm");

	create restore transient;
	restore.usePresentationFileSystem := true;
	restore.openOutput(_path &amp; "\" &amp; mySchema.name &amp; "-restore.scm");

	self.myAgent.log("Creating scm: " &amp; file.fileName, false);
	self.myAgent.log("Creating scm: " &amp; restore.fileName, false);

	file.writeLine(zScmHeader);
	restore.writeLine(zScmHeader);

	file.writeLine("typeDefinitions");
	restore.writeLine("typeDefinitions");

	foreach lsClass in allClasses do
		file.writeLine(lsClass.scmHeaderForTSMigration);
		restore.writeLine(lsClass.scmHeaderForTSMigration);
	endforeach;
	
	file.writeLine("typeSources");
	restore.writeLine("typeSources");

	foreach lsClass in allClasses do
		file.writeLine(lsClass.scmTypeSourceForTSMigration);
		restore.writeLine(lsClass.scmTypeSourceBeforeTSMigration);
	endforeach;

	self.myAgent.log("	Complete: " &amp; file.fileLength.String &amp; " bytes", false);
epilog
	delete file;
	delete restore;
end;
</source>
        <Parameter name="_path" type="String"/>
    </JadeMethod>
    <JadeMethod name="zJCFHeader" id="465e78f7-2e2c-4c53-9cc8-57f339ea1e72">
        <source>zJCFHeader():String ;
/*

Purpose:	Create the JCF Header		

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwmh5	Initial creation

*/

vars
	str : String;
begin
	str := 'JadeCommandFile' &amp; CrLf;
	str := str &amp; 'JadeVersionNumber ' &amp; app.getSystemVersion &amp; CrLf;
	str := str &amp; "Commands" &amp; CrLf;
	str := str &amp; "AbortOnError False" &amp; CrLf;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zScmHeader" id="1bc75e0e-74fb-4ce5-9483-7cb44256739b">
        <source>zScmHeader():String ;

vars
	str : String;
begin
	str := 'jadeVersionNumber "' &amp; app.getSystemVersion &amp; '";' &amp; CrLf;
	str := str &amp; "schemaDefinition" &amp; CrLf;
	str := str &amp; name &amp; " subschemaOf " &amp; mySchema.superschema.name &amp; " partialDefinition;";

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zScmTrailer" id="5d1e6606-95ab-4f38-9e2f-eaf44b14ea15">
        <source>zScmTrailer():String ;

begin
	return "";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
