<Class name="CM_TcpIpClientAgent" id="a2744607-d064-4fed-b0a7-ae5c6978487e">
    <superclass name="CM_Agent"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="isConnected" id="2d96e717-1a22-4c75-b6c3-dd7e881dedd1">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTcpMsg" id="829e3d76-46b1-4216-97b2-55e80e1f5262">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="RFC_TcpMsg"/>
        <access>readonly</access>
        <Inverse name="RFC_TcpMsg::myTcpIpClientAgent"/>
    </ExplicitInverseRef>
    <PrimAttribute name="numberOfReconnects" id="b2c2e931-ba5f-4ef0-99a8-72c04af6a5da">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="serverName" id="e60b94fb-d981-4de8-aa9d-861d16003143">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="tcpIpPort" id="f59b7678-ac63-4613-acb1-30df63b4787f">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="closeConnect" id="ddb0fdc9-8d11-49e9-94c7-a46efe50973c">
        <source>closeConnect();
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if myTcpMsg &lt;&gt; null then
		myTcpMsg.cnClose(myTcpMsg);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="e19587b3-5304-4156-b69f-8fe557101d0a">
        <updating/>
        <source>delete() updating;

// cnwdvb1 28 April 2003 

vars

begin

	endNotificationForSubscriber(self);
	self.closeConnect();

end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="b1228982-7221-4f3f-a47d-2e5d2d9f2b1b">
        <updating/>
        <source>init(_controller : BGP_TCPClient) updating;

// cnwdvb1 28 April 2003 

vars

begin

//	on NormalException do normalExceptionHandler(exception) global;
	self.tcpIpPort 	:= _controller.tcpIpPort;
	self.serverName	:= _controller.serverName;
	
	//changed to 12mins to slow the handle flooding
	self.beginTimer(720000, Timer_Continuous, 5); //look for re connection if discoonected
		
	self.openConnect();

end;</source>
        <Parameter name="_controller" type="BGP_TCPClient"/>
    </JadeMethod>
    <JadeMethod name="logMonitor" id="add844f7-257b-42de-b568-6d7e49707ae2">
        <source>logMonitor(_msg : String);

// cnwdvb1 28 April 2003 

vars

begin

	app.writeLog(_msg, LogINFO);

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="normalExceptionHandler" id="61cdd192-4943-4d45-921d-f5cd7e25f467">
        <updating/>
        <source>normalExceptionHandler(_exObj : Exception) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
// ---------------------------------------------------------------------------
vars
	errStr	: String;
	msg : String;
begin
	if _exObj.errorCode = 1228 or 
	   _exObj.errorCode = 1295 or 
	   _exObj.errorCode = 3015 or 
	   _exObj.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;_exObj.errorCode.String&amp;' '&amp;_exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		terminate;
	endif;

	//Our exceptions
	if _exObj.isKindOf(CM_Exception) then
	   	abortTransaction;
		errStr := 'Error (' &amp; _exObj.errorCode.String &amp; '). ' &amp; _exObj.extendedErrorText;
		self.logMonitor(errStr);
		return Ex_Resume_Next;
	endif;
	
	//all other exceptions
	abortTransaction;
	app.doDumpStack(_exObj); //rs 7 October 2002
	return Ex_Abort_Action;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="openConnect" id="e23ad96d-0e1a-4008-ae11-4fb5ce92fd15">
        <updating/>
        <source>openConnect() updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Oct 2008	cnwkpd1		PAR #17953 - Rework to ensure connections are not leaked
// ---------------------------------------------------------------------------

vars
	msg			: String;
	
begin
	// PAR #17953 - need to delete current connection before creating a new one
	delete self.myTcpMsg;
	
	create self.myTcpMsg transient;
	self.myTcpMsg.cnOpen(self.serverName, self.tcpIpPort, self.myTcpMsg);
	msg := "Trying to connect to " &amp; self.serverName &amp; " at port " &amp; self.tcpIpPort.String;
	self.logMonitor(msg);

end;</source>
    </JadeMethod>
    <JadeMethod name="processReadData" id="a71c5094-83c5-4459-89fa-5e68938467d2">
        <updating/>
        <source>processReadData(_buf	: Binary) updating;

// cnwdvb1 28 April 2003 

vars

begin

end;</source>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="sendTelegram" id="403e7972-0112-48a3-853f-c237d3af0594">
        <updating/>
        <source>sendTelegram(_telegram : Binary) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myTcpMsg &lt;&gt; null and
	   self.isConnected then
		myTcpMsg.cnWrite(_telegram, myTcpMsg);
	else
		self.logMonitor("Disconnected. Write failed.");
	endif;
end;</source>
        <Parameter name="_telegram" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setIsConnected" id="d1e38fd5-d776-4161-8bbe-9228946063ea">
        <updating/>
        <source>setIsConnected(_isConnected : Boolean) updating;

// cnwdvb1 28 April 2003 

vars

begin

	self.isConnected := _isConnected;
	if self.isConnected then
		self.numberOfReconnects := 0;
	else
		if self.numberOfReconnects &gt; 4 then
			app.remoteErrorWarningToAlert(self.getNiceClassName &amp; " - 5 connection failures.", null, null, null, false, true);
			self.numberOfReconnects := 0;
		endif;
	endif;

end;</source>
        <Parameter name="_isConnected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTcpMsg" id="03fbf8a1-86af-4945-ae6f-7e67ee28f848">
        <updating/>
        <source>setMyTcpMsg(_tcp : RFC_TcpMsg) updating;

// cnwdvb1 28 April 2003 

vars

begin

	self.myTcpMsg := _tcp;

end;</source>
        <Parameter name="_tcp" type="RFC_TcpMsg"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="f6dc3466-8923-4a0c-92ed-043dccfa93b2">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

// cnwdvb1 28 April 2003 

vars

begin
	if eventTag = 5 then
		if not isConnected then
			self.logMonitor("Try to reconnect.");
			self.numberOfReconnects := self.numberOfReconnects + 1;
			self.openConnect();
		endif;
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
