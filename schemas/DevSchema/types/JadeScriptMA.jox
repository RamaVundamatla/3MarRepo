    <JadeMethod name="lnx52795" id="f13c4714-844e-4a1b-b686-166a7b1aea5e">
        <source>lnx52795();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2022		navma1	Initial creation

*/

vars
	voyage : CM_Voyage;
	bay    : CM_BayVoyage;
	slot : CM_SlotRequest;
begin
	voyage:= "4480.2177145".asOid.CM_Voyage;
	
	if voyage = null then
		
		return;
	endif;
	
	foreach bay in voyage.myCellularVoyageStructure.allBayVoyagesById do
		foreach slot in bay.allSlotRequestByMoveType do 
			if slot.getVoyageAllocations.size &gt; 0 then
				write slot.myBay.id &amp;Tab &amp; slot.mySlotController.getFullId &amp; Tab&amp;  slot.getVoyageAllocations.first.CM_VoyageAllocation.getName;
			endif;
		endforeach;
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mA53424" id="a5cf8de9-1bbf-43d7-bd10-19fa14675754">
        <source>mA53424();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2022		navma1	Initial creation

*/

vars
	terminal : CM_Terminal;
	context  : Integer;
	definedText : CM_DefinedText;
	iter		 : Iterator;
begin
	context  := 101002;
	terminal := app.myRoot.allTerminals['MA'];
	
	iter:=terminal.allTerminalDefinedText.createIterator;
	terminal.allTerminalDefinedText.startKeyGeq(context.Integer,null,iter);
	while iter.next(definedText) do
		if definedText.context &lt;&gt; context.Integer then
			break;
		endif;
		
		write definedText.context.String &amp; Tab &amp; definedText.text &amp;Tab &amp; definedText.sortOrder.String;
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
