		lineType := self.cmbLineType.itemData[idx];
	endif;
	
	self.setViewForLineType(lineType);
end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeMasterEntryView" id="0c8dcecd-883b-4027-a297-eefd465ccab5">
        <source>doChangeMasterEntryView();

vars
	transMode,
	idx,
	processOpt			: Integer;	
begin
	idx := self.cmbTransportMode.listIndex; 
	if idx &gt; 0 then
		transMode := self.cmbTransportMode.itemData[idx];
	endif;
	
	idx := self.cmbProcessOpt.listIndex;
	if idx &gt; 0 then
		processOpt := self.cmbProcessOpt.itemData[idx];
	endif;
	
	self.setViewForStockOrder(processOpt, transMode);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCargoTypeLostFocus" id="55aee4c4-7483-4e2a-a70b-88722ea82955">
        <source>doCmbCargoTypeLostFocus() protected;
// ---------------------------------------------------------------------------
// Created:     05 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_EntryTable;
	cmb				: CMUI_ComboBox;
	tmpCargoType	: CM_CargoType;
begin

	cmb 			:= self.cmbCargoType;
	tbl 			:= self.tblDetailEnt;
	tmpCargoType 	:= self.cmbCargoType.listObject.CM_CargoType;
	
	
	if cmb.text = tbl.getValueByName(ETRow_MyCargoType).String then 
	//have already selected the item previously so no need to redo and clear other combos. 
		return;
	endif;

	tbl.setValueByControlName(cmb.name, cmb.text);
	self.myAssistant.comboBoxProduct(self.cmbProduct, tmpCargoType, null, self.cmbProduct.listObject.CM_Product);
	tbl.setValueByName(ETRow_MyProduct, null);
	tbl.setValueByName(ETRow_Id, null);
	
	
	// populate TIs for all TI's of cargo type. if product type selected will be re-populated and procduct combo pre-filled
	
		if tmpCargoType &lt;&gt; null then
			self.myAssistant.comboBoxTrackedItemToPack(self.cmbTI, tmpCargoType.id, TI_STATE_NORMAL, self.cmbTI.text); 	
		else
			self.cmbTI.clear();
		endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbProductLostFocus" id="99775ec5-4f7d-466d-b9db-b7e82d480d74">
        <source>doCmbProductLostFocus() protected;
// ---------------------------------------------------------------------------
// Created:     05 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmb					: CMUI_ComboBox;
	tmpProduct			: CM_Product;
	tmpCargoType		: CM_CargoType;
begin
	cmb := self.cmbProduct;
	self.tblDetailEnt.setValueByControlName(cmb.name, cmb.text);
	
	tmpProduct := cmb.listObject.CM_Product;
	if tmpProduct &lt;&gt; null then
		self.myAssistant.comboBoxTIsByProduct(self.cmbTI, tmpProduct, self.cmbTI.text); 
	else //if no product selected, list all the TIs of the selected cargo type - then
		//when a TI is selected, the product combob will prefill.
		tmpCargoType := self.cmbCargoType.listObject.CM_CargoType;
		if tmpCargoType &lt;&gt; null then
			self.myAssistant.comboBoxTrackedItemToPack(self.cmbTI, tmpCargoType.id, TI_STATE_NORMAL, self.cmbTI.text); 	
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbTILostFocus" id="eaae9663-8938-4f3f-84cc-6ef6dad82dd5">
        <source>doCmbTILostFocus() protected;
// ---------------------------------------------------------------------------
// Created:     05 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmbPro,
	cmb			: CMUI_ComboBox;
	tmpTI		: CM_TrackedItem;
begin
	cmb := self.cmbTI;
	self.tblDetailEnt.setValueByControlName(cmb.name, cmb.text);
	cmbPro := self.cmbProduct;
	tmpTI := cmb.listObject.CM_TrackedItem;
	
	if (tmpTI &lt;&gt; null) then
		if (tmpTI.myProduct &lt;&gt; null) and
	       (cmbPro.listObject &lt;&gt; tmpTI.myProduct) then
			cmbPro.listObject := tmpTI.myProduct;
			self.tblDetailEnt.setValueByControlName(cmbPro.name, cmbPro.text);
		endif;
	endif;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="895becff-20c6-4c3d-a8f8-dfdb7fae9740">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     07 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	stkOrd			: CM_StockOrderHeader;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	stkOrd := self.myCurrentMasterObject.CM_StockOrderHeader;
	
	if stkOrd = null then //zDoDelete should ensure this
		return false;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteStockOrder(stkOrd, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('Deleteing Stock Order', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDetailAdd" id="ea77e1cd-5922-4d41-92d9-11a43adb987f">
        <updating/>
        <source>doDetailAdd() updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	pxyOrderLine,
	orderLine				: CM_StockOrderLine;
	stkOrd					: CM_StockOrderHeaderGeneric;
	tblDetail				: CM_DataTable;
	rowIdx,	
	backColour,
	tmpLineType				: Integer;
	entDef					: EntTableDef;
	newCombo 				: CMUI_ComboBox;
	str 					: String;
	cargoType				: CM_CargoType;
	defaultFromLineAbove	: Boolean;
	product					: CM_Product;
begin

	if self.mode &lt;&gt; self.Mode_Edit
	and self.mode &lt;&gt; self.Mode_New then	
		return;
	endif;

	tblDetail := self.tblDataDetail;
	
	tblDetail.addItemAt(null,tblDetail.rows + 1);
	
//	if rowIdx mod 2 = 0 then
//		backColour := self.colorRow1;
//	else
//		backColour := self.colorRow2;
//	endif;			
//	tblDetail.accessRow(rowIdx).backColor := backColour;	
	
	self.newIndex := self.newIndex + 1;
	rowIdx := tblDetail.rows;

	defaultFromLineAbove := rowIdx &gt; tblDetail.fixedRows + 1;

	//Load cargotype control
	newCombo := self.addControlCmbLineType(rowIdx, newIndex).CMUI_ComboBox;
	self.myAssistant.comboBoxOrderLineType(newCombo, str);
	// if row above then populate combo with what it has selected.
	if defaultFromLineAbove then 
		tmpLineType := self.getTblDataDetailRowLineType(rowIdx - 1);
		str := app.stockOrderLineTypeEnumToString(tmpLineType);
		tblDetail.accessCell(rowIdx, self.colLineType).text := str;
		self.setupColumnQtyIdForLineType(tmpLineType, rowIdx);	
		newCombo.text := str;
	endif;

	newCombo := self.addControlCmbCargoType(rowIdx, self.newIndex).CMUI_ComboBoxCargoTypeForTerm;
	// if row above then populate combo with what it has selected. 	
	if defaultFromLineAbove then 
		cargoType := self.getTblDataDetailCargoType(rowIdx - 1);
		newCombo.CMUI_ComboBoxCargoTypeForTerm.setObject(cargoType);
		tblDetail.accessCell(rowIdx, self.colCargoType).text := newCombo.text;
	endif;
			
	//Load product control
	newCombo := self.addControlCmbProduct(rowIdx, newIndex).CMUI_ComboProduct;

	if defaultFromLineAbove then 
		// this setsup the product combo
		self.setupTblDtlRowForCargoType(rowIdx, tmpLineType, cargoType);
		product := self.getTblDataDetailProduct(rowIdx - 1);
		newCombo.CMUI_ComboProduct.myCargoType := cargoType;
		newCombo.CMUI_ComboProduct.setObject(product);
		tblDetail.accessCell(rowIdx, self.colProduct).text := newCombo.text;
	endif;
	
	self.setTblDataDetailCells(rowIdx);	

	tblDetail.clearAllSelected();
	tblDetail.selectRow(rowIdx, true);
	tblDetail.row := rowIdx;
	if tblDetail.row =(tblDetail.fixedRows + 1) then 
		tblDetail.column := 1; // is first row so start at begining
	else
		tblDetail.column := self.colQuantityId; // has been added so will have defaults from above so start at id column PAR11162
	endif;
	tblDetail.setFocus();
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doEnquiryTI" id="7e5a2e1d-d1da-48d0-8ae9-3c90dd01644a">
