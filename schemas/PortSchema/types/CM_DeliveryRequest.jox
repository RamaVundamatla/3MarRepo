    <JadeMethod name="myTILCType" id="1b74b4f3-f027-4931-97b4-63379cff797b">
        <methodInvocation>mapping</methodInvocation>
        <source>myTILCType(_set : Boolean; _value : CM_TILCType io) mapping;
/*
Date		Who		Reason
06 Dec 2012	cnwcs5	Initial creation - par 30852
*/
vars
	type	:CM_TILCType;
begin
	if not _set  or	
		not self.isTransient or// don't need to bother for transients
		_value = null or				// new trailer type is null
		self.myTILCType = _value then	// not changing trailer type
		return;
	endif;
	
	_value.updateForNonInversedReference;

epilog

end;</source>
