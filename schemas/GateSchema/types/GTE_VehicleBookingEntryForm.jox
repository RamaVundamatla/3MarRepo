    <JadeMethod name="addToolbarControls" id="36128479-df93-4e10-944f-4fd2f72b1316">
        <updating/>
        <source>addToolbarControls() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 22 November 2007
//
//----------------------------------------------------------------------

vars
	toolbar : CMUI_Toolbar;
begin
inheritMethod();
	toolbar := self.frmToolbar;
	
	//LEFT BUTTONS
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNewTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);
	
	//RIGHT BUTTONS
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="fd9582bf-c4f3-49b1-b928-09a5158770d5">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 21 November 2007
//
//----------------------------------------------------------------------

vars

begin
	self.permissionView  := PmGteInOutEntry;
	self.permissionMaint := PmGteInOutEntry;
	
	self.helpFileName := HelpFile_Gate;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblItems" id="b3650ff9-c758-4746-9d40-d4717d2e3671">
        <source>initTblItems();
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 22 November 2007
//
//----------------------------------------------------------------------

vars
	entDef : EntTableDef;
begin
	entDef := app.myController.getEntTableDef(ETDef_ContainerInfo);
	self.tblItems.setTblDataEntRowsFromDef(entDef);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblSearch" id="c46d50ac-4ea6-4581-9998-e082a9985b67">
