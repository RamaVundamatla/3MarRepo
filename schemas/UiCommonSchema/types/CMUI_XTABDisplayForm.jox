    <JadeMethod name="doSummarise" id="936499f7-8803-447f-9747-ca47d761293b">
        <source>doSummarise()protected;
// ---------------------------------------------------------------------------
// Created:     03 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/01/2009	cnwrl1		Changed to use method CMUI_Assistant (CCMS SFW 1047 - Totals Only Lists)
// 16/12/2009	cnwcs5		ccms 1023 - snapshot summaries
// 09/08/2010	CNWCS5		PAR 23706 - smal optimisation
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer	:= Busy;
	
	if self.myProxyOutputFormat.isSnapshotMode then	// cnwcs5 16/12/2009
		// self.myAssistant.showXTABSummaryDefinitionForm( self.getCollectionForDrillDown, false, true, false, true);	// cnwcs5 16/12/2009
		self.myAssistant.showXTABSummaryDefinitionForm( self.myCollectionForDrillDown, false, true, false, true); // 09/08/2010 cnwcs5 par 23706
	else																								
		//self.myAssistant.showXTABSummaryDefinitionForm( self.getCollectionForDrillDown, false, false, false, true);	
		self.myAssistant.showXTABSummaryDefinitionForm( self.myCollectionForDrillDown, false, false, false, true);	// 09/08/2010 cnwcs5 par 23706
	endif;																								
epilog
	app.mousePointer	:= Idle;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCollForSelectedCellObject" id="0336f0c9-929e-4120-bf7f-c2c512162d02">
        <source>getCollForSelectedCellObject(_obj : Object): ObjectSet protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars

begin
	if _obj &lt;&gt; null and _obj.isKindOf (CMIF_OutputField) then
		return _obj.CMIF_OutputField.myParent.allObjects;
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="getCollectionForDrillDown" id="f534de74-111d-4450-91d9-4997e977a8cb">
        <source>getCollectionForDrillDown():ObjectSet protected;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	cnwrl1		Make sure there is at least one valid row in the table
// 22/02/2010	cnwcs5		par 22435 - release summary changes
// 09/08/2010	cnwcs5		par 23706 - handle multi-select for drill down
// ---------------------------------------------------------------------------
vars
	obj			: Object;
	coll, work,
	temp		: ObjectSet;	// 09/08/2010 cnwcs5 par 23706
begin
	// I don't know why I have to do this but I don't get an itemObject if I don't
	tblMain.sheet := tblMain.topSheet;
	
	// cnwrl1 22/06/2009 PAR 19993 - start of coding
	if tblMain.row &lt;= null or tblMain.column &lt;= null then
		return null;
	endif;
	// cnwrl1 22/06/2009 PAR 19993 - end of coding
	
	coll	:= self.myCollectionForDrillDown;	// 09/08/2010 cnwcs5 par 23706
	
	coll.clear;									// 09/08/2010 cnwcs5 par 23706
	
	// 09/08/2010 cnwcs5 par 23706 obj := tblMain.accessCell (tblMain.row, tblMain.column).itemObject; 	
	
	create work transient;						// 09/08/2010 cnwcs5 par 23706
	
	tblMain.getSelectedCellObjects (work);		// 09/08/2010 cnwcs5 par 23706	
	
	foreach obj in work do						// 09/08/2010 cnwcs5 par 23706
		if obj &lt;&gt; null and obj.isKindOf (CMIF_OutputField) then
			temp :=  obj.CMIF_OutputField.getCollectionForDrillDown;	// 09/08/2010 cnwcs5 par 23706 // 22/02/2010 cnwcs5 par 22435 - release summary changes
		
			temp.copyNoDuplicates (coll, false);// 09/08/2010 cnwcs5 par 23706
		endif;
	endforeach;									// 09/08/2010 cnwcs5 par 23706
	
	return coll;								// 09/08/2010 cnwcs5 par 23706	
epilog
	delete work;								// 09/08/2010 cnwcs5 par 23706
end;</source>
        <access>protected</access>
        <ReturnType type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="getFirstTrackedItemInColl" id="5371c0ba-bfcf-4f2b-acda-301f620d7641">
        <source>getFirstTrackedItemInColl(_coll : ObjectSet) : CM_TrackedItem;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	obj : Object;
begin
	foreach obj in _coll discreteLock where obj.isKindOf(CM_TrackedItem) do		
		return obj.CM_TrackedItem;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="ObjectSet"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getSnapshotObjectsFromColl" id="83427635-7f6a-49bf-b17a-d4c9c4dcce15">
        <source>getSnapshotObjectsFromColl(_coll :Collection) protected;
// ---------------------------------------------------------------------------
// Created:     16 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  _coll - _collection containing CM_DynamicObject_Snapshot instances
//				coll - _collection to put tracked items or bookings
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	any		:Any;
	obj 	:Object;
	coll	:CM_ObjectSet;
begin
	coll := self.mySnapshotDrillDownColl;
	
	coll.clear;
	foreach any in _coll do
		foreach any in _coll do
			if not any.isKindOf (CM_DynamicObject_Snapshot) then
				continue;	// expect all to be same type but will check anyway
			endif; 
			foreach obj in any.CM_DynamicObject_Snapshot.allObjects do
				coll.addNoDuplicates (obj, false); 
			endforeach;
		endforeach;		
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="1d3380b7-3871-4117-bf6b-9610a9abb62d">
        <updating/>
        <source>initialise(
	_proxyFormat		: CM_OutputFormat_XTAB;
	_realFormat			: CM_OutputFormat_XTAB;
	_expectedEdition	: Integer;
	_collection			: ObjectSet ) updating;

/*

Purpose:		This method is used to populate the required properties on startup.
Parameters:		
Return Value:	

Date				Who		Reason
29 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
18/08/2010			cnwcs5	par 23706 - set hideRepeatedRowValues
*/
	
vars
	
begin
	// set the format and collection for the form
	self.setMyOutputFormat( _proxyFormat, _realFormat, _expectedEdition );
	self.setCollection( _collection );
	self.setHideRepeatedRowValues (not _proxyFormat.showRepeatedRowValues);
epilog
	
end;
</source>
        <Parameter name="_proxyFormat" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_realFormat" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_collection" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="e933d2be-43f2-4899-a1ea-422e6c1cbeaf">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/* ---------------------------------------------------------------------------
Created:     26 February 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	row, col	: Integer;
	obj			: Object;
begin

	if (not self.doGenerateXTAB()) then
	endif;	

	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1 highlight the specific snap shot for the invoice line
	if self.myInitialSnapshot &lt;&gt; null then
		foreach row in self.tblMain.fixedRows to self.tblMain.rows do
			col := self.tblMain.fixedColumns + 1;
			obj := self.tblMain.accessCell(row, col).itemObject;
			if obj &lt;&gt; null then
				if obj.CMIF_OutputField.myParent.allObjects.first = self.myInitialSnapshot then
					self.tblMain.row := row;
					self.tblMain.accessCell(row, col).selected := true;
					self.tblMain.topRow := row;
					break;
				endif;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
