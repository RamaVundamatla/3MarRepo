    <JadeMethod name="findErrorName" id="e97efaf4-089f-4e37-9ba6-fb966de03e1f">
        <source>findErrorName();
//----------------------------------------------------------------
//	Created:	10 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
//	catName		: String;
	category	: ConstantCategory;
	constant	: Constant;
	value		: Integer;
	
begin
	//find what?
	value := 89528;
	
	category := currentSchema.getCategory(XLAT_Exceptions);		
	
	foreach constant in category.getConstants do
		if constant.valueAsInteger = value then
			write constant.name &amp; CrLf &amp; constant.text;
			//constant.inspect;
			return;
		endif;
	endforeach;
	write "NOTHING";
end;</source>
    </JadeMethod>
