<Class name="CMQF_BOLMonthlyStatistics" id="b595d6eb-b17f-46c1-8800-9ac43477b6a1">
    <superclass name="CMQF_BOL"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterForHaveOperatorTerminal" id="a106b980-50a5-4f8e-86de-2bbfbd5616e7">
        <updating/>
        <source>filterForHaveOperatorTerminal(_opTerm : CM_OperatorTerminal; 
								_collection : Collection input; 
								_passport : CM_Passport) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 September 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	masterTI	: CM_TrackedItem;
	isoType		: CM_ISOType;
	bolColl 	: CM_BOLByTypeNumberDTDict;	
	bol			: CM_BOL;
	iter		: Iterator;
	breakOut	: Boolean;
begin
	bolColl := _opTerm.allBOLByTypeNumber;
	iter := bolColl.createIterator;
	if self.bolType &lt;&gt; null then
		bolColl.startKeyGeq(self.bolType, null, null, iter);
	endif;
	
	while iter.next(bol) do	
		if self.bolType &lt;&gt; null and bol.bolType &lt;&gt; self.bolType then
			break;
		endif;
		
		if checkStatusIncludesObject(bol, _passport, breakOut) and
//		if self.includesObject(bol, _passport, breakOut) and
		   CM_BOLOut.hasInstance(bol) then 
			_collection.add(bol);
			self.numContainers := self.numContainers + 1;
			self.outwardsDockets := self.outwardsDockets + 1;
			self.outwardsTIs := self.outwardsTIs + bol.allTrackedItems.size;
			self.outwardsVolume := outwardsVolume + bol.getTotalTIVolume;
			self.outwardsWeight := outwardsWeight + bol.getTotalTIWeight;
			self.totalPackingCharge := self.totalPackingCharge + bol.CM_BOLOut.getContainerCharge;
			
			masterTI := bol.CM_BOLOut.myMasterTI;
			if masterTI.isContainer() then
//			if CM_Container.hasInstance(masterTI) then
				if (not masterTI.CM_Container.is40) then
					num20ft := num20ft +1;
				else
					num40ft := num40ft + 1;
				endif;
			endif;
			
		else
			self.inwardsDockets := self.inwardsDockets + 1;
			self.inwardsTIs := inwardsTIs + bol.allTrackedItems.size;
			self.inwardsVolume := inwardsVolume + bol.getTotalTIVolume;
			self.inwardsWeight := inwardsWeight + bol.getTotalTIWeight;
		endif;
		
	//	if breakOut then
	//		break;
	//	endif;
	endwhile;
	//convert weight to tonnes for report
	self.outwardsWeight := self.outwardsWeight / 1000;
	self.inwardsWeight := self.inwardsWeight / 1000;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_opTerm" type="CM_OperatorTerminal"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForHaveTerminal" id="535573af-9569-49c7-9444-1f9b35b87c61">
        <updating/>
        <source>filterForHaveTerminal(_terminal : CM_Terminal; 
					_collection : Collection input; 
					_passport : CM_Passport) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 September 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	masterTI	: CM_TrackedItem;
	isoType		: CM_ISOType;
	bolColl 	: CM_BOLByTypeNumberDTDict;	
	bol			: CM_BOL;
	iter		: Iterator;
	breakOut	: Boolean;
begin

	bolColl := _terminal.allBOLsReleasedByTypeNumberDT;
	delete iter;
	iter := bolColl.createIterator;
	bolColl.startKeyGeq(self.bolType, null, null, iter);
	
	while iter.next(bol) do	
		if self.bolType &lt;&gt; null and bol.bolType &lt;&gt; self.bolType then
			break;
		endif;

		if not self.checkStatusIncludesObject(bol, _passport, breakOut) then
//		if (not self.includesObject(bol, _passport, breakOut)) then
//			if breakOut then
//				break;
//			endif;
			
			continue;
		endif;
		
		_collection.add(bol);
		self.numContainers := self.numContainers + 1;
		self.outwardsDockets := self.outwardsDockets + 1;
		self.outwardsTIs := self.outwardsTIs + bol.allTrackedItems.size;
		self.outwardsVolume := outwardsVolume + bol.getTotalTIVolume;
		self.outwardsWeight := outwardsWeight + bol.getTotalTIWeight;
		self.totalPackingCharge := self.totalPackingCharge + bol.CM_BOLOut.getContainerCharge;
		
		masterTI := bol.CM_BOLOut.myMasterTI;
		if CM_Container.hasInstance(masterTI) then
			if (not masterTI.CM_Container.is40) then
				num20ft := num20ft +1;
			else
				num40ft := num40ft + 1;
			endif;
		endif;
		
		if breakOut then
			break;
		endif;
	endwhile;
	
	bolColl := _terminal.allBOLsReceivedByTypeNumberDT;
	delete iter;
	iter := bolColl.createIterator;
	if self.bolType &lt;&gt; null then
		bolColl.startKeyGeq(self.bolType, null, null, iter);
	endif;
	
	//total inwards
	while iter.next(bol) do	
		if self.bolType &lt;&gt; null and bol.bolType &lt;&gt; self.bolType then
			break;
		endif;
		
		if not self.checkStatusIncludesObject(bol, _passport, breakOut) then
//		if (not self.includesObject(bol, _passport, breakOut)) then
//			if breakOut then
//				break;
//			endif;
			
			continue;
		endif;
		
		self.inwardsDockets := self.inwardsDockets + 1;
		self.inwardsTIs := inwardsTIs + bol.allTrackedItems.size;
		self.inwardsVolume := inwardsVolume + bol.getTotalTIVolume;
		self.inwardsWeight := inwardsWeight + bol.getTotalTIWeight;
	endwhile;

	//convert weight to tonnes for report
	self.outwardsWeight := self.outwardsWeight / 1000;
	self.inwardsWeight := self.inwardsWeight / 1000;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="bb14d4ba-14f4-4e2a-8726-4014b03e991d">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars
	op			: CM_Operator;
	opTerm		: CM_OperatorTerminal;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
begin

	op := self.myOperator;

	foreach terminal in self.allTerminals do : terminalLoop
		if op &lt;&gt; null then
			opTerm := op.getOperatorTerminal(terminal, false);
			if opTerm = null then
				continue terminalLoop;
			endif;
			
			self.filterForHaveOperatorTerminal(opTerm, _collection, _passport);
		else
			self.filterForHaveTerminal(terminal, _collection, _passport);
		endif;	
	endforeach;
		
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="1c9c8e9c-ab97-446d-9bbf-78f23932d14a">
        <updating/>
        <source>includesObject(_bol: CM_BOL; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 September 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	rtnValue			: Boolean;
	masterTI			: CM_TrackedItem;
begin
	rtnValue := inheritMethod(_bol, _passport, _breakOut);
	
	if rtnValue then
		if CM_BOLOut.hasInstance(_bol) and
		   _bol.CM_BOLOut.myMasterTI &lt;&gt; null then
			if self.voyageCode &lt;&gt; null and 
			   _bol.CM_BOLOut.myMasterTI.myVoyage.code &lt;&gt; self.voyageCode then
				rtnValue := false;
			endif;
		endif;
	endif;
	
	return rtnValue;
end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
