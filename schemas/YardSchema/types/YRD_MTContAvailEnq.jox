    <JadeMethod name="translateForm" id="b25ce764-7d8a-4802-8d3f-f46c2724e87d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2019 09:20:08.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022887, locale);
	btnHideSearcher.translateCaption(Xlat_0017050, locale);
	btnPrint.translateCaption(Xlat_0017051, locale);
	btnQuery.translateCaption(Xlat_0017052, locale);
	btnRefresh.translateCaption(Xlat_0017053, locale);
	btnResetSearch.translateCaption(Xlat_0017054, locale);
	btnShowSearcher.translateCaption(Xlat_0017055, locale);
	chkConfirmed.translateBubbleHelp(Xlat_0017056, locale);
	chkConfirmed.translateCaption(Xlat_0017057, locale);
	lblISOGroup.translateCaption(Xlat_0017058, locale);
	lblLastUpdated.translateCaption(Xlat_0017059, locale);
	lblMTGrade.translateCaption(Xlat_0017060, locale);
	lblOperator.translateCaption(Xlat_0017061, locale);
	lblReceivalDate.translateCaption(Xlat_0017062, locale);
	lblReleaseDate.translateCaption(Xlat_0017063, locale);
	lblSubTerminal.translateCaption(Xlat_0023731, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0017064, locale);
	mnuContext.translateCaption(Xlat_0017065, locale);
	mnuInspectObj.translateCaption(Xlat_0017066, locale);
	mnuShowCargo.translateCaption(Xlat_0017067, locale);
	mnuShowExtra.translateCaption(Xlat_0017068, locale);
	mnuShowInArea.translateCaption(Xlat_0017069, locale);
	mnuShowRels.translateCaption(Xlat_0017070, locale);
	mnuThreshold.translateCaption(Xlat_0017071, locale);
	shtQuery1.translateCaption(Xlat_0017072, locale);
end;</source>
    </JadeMethod>
