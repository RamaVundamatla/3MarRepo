    </JadeMethod>
    <JadeMethod name="ndlDeleteOldTasks" id="b327acad-e82a-4f89-9848-5e28654b666d">
        <source>ndlDeleteOldTasks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2019	jlgndl1	Initial creation

*/

vars

	term : CM_Terminal;
	q : CM_RadioTelemetryQueue;
	createdBefore : Date;
	entry : CM_RTQueueEntry;
	allOldEntries : CM_RTQueueEntrySet;
	qsToDelete : CM_RTQueueSet;

begin

	term := CM_Root.firstInstance.allTerminals.getAtKey("T4");
	app.myPassport.setMyTerminal( term );
	
	createdBefore := "01 Aug 2019".Date;
	
	create allOldEntries transient;
	create qsToDelete transient;
	
	foreach entry in term.radioTelemetry.masterQueue.allEntries discreteLock do
		if entry.addedDT.Date &gt;= createdBefore then
			continue;
		endif;
		allOldEntries.addNoDuplicates( entry, false );
	endforeach;
	foreach q in term.radioTelemetry.masterQueue.allSubQueuesById discreteLock do
		if q.isVoyageQueue then
			if q.CM_VoyageQueue.myVoyage = null then
				qsToDelete.add( q );
			else
				if not global.isValidObject( q.CM_VoyageQueue.myVoyage ) then
					qsToDelete.add( q );
				elseif q.CM_VoyageQueue.myVoyage.archivedDT.Date.isValid then
					qsToDelete.add( q );
				endif;
			endif;
		endif;
		foreach entry in q.allEntries discreteLock do
			if entry.addedDT.Date &gt;= createdBefore then
				continue;
			endif;
			allOldEntries.addNoDuplicates( entry, false );
		endforeach;
	endforeach;
	
	allOldEntries.inspectModal();
	
	foreach entry in allOldEntries do
		while true do
			app.myTrxDA.trxDeleteQueueEntry( entry, app.myPassport );
			if app.myPassport.trxCompletedOK then
				break;
			elseif app.myPassport.hasErrors then
				write app.myPassport.getErrorsAndWarningsAsString;
				break;
			else
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endwhile;
	endforeach;
	
	qsToDelete.inspectModal();
	
	foreach q in qsToDelete do
		while true do
			app.myTrxDA.trxDeleteQueue( q, app.myPassport );
			if app.myPassport.trxCompletedOK then
				break;
			elseif app.myPassport.hasErrors then
				write app.myPassport.getErrorsAndWarningsAsString;
				break;
			else
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endwhile;
	endforeach;

epilog

	delete allOldEntries;
	delete qsToDelete;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlDeleteOldVehicleVists" id="12158be8-57b2-4f4a-9e44-daf9a2b04ea0">
        <source>ndlDeleteOldVehicleVists();
/*

Purpose:			

