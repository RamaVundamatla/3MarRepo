    <JadeMethod name="selectOpShipLine" id="5c4e6d37-2c6f-4989-b91f-0bf610e5ee42">
        <updating/>
        <source>selectOpShipLine() updating;

vars
	operShippingLine : CM_OperatorShippingLine;
begin
//	_table.CM_DataTable.selectObject(_table.accessRow(_table.row).itemObject, false);
	operShippingLine := tblOperShipLine.accessRow(self.tblOperShipLine.row).itemObject.CM_OperatorShippingLine;
	if operShippingLine &lt;&gt; null then
		cmbOperator.setIndexFromObject(operShippingLine.myOperator);
		cmbShippingLine.setIndexFromObject(operShippingLine.myShippingLine);
		self.populateTableDestDischPort(operShippingLine, operShippingLine.myShippingLine);
	endif;
	self.btnAdd.enabled := false;
	self.btnRemove.enabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlEnable" id="2d137ff0-61ee-4706-8a2a-1990b985c9fb">
        <source>setControlEnable();
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 28 July 2006
//
//----------------------------------------------------------------------

vars

begin

	if self.cmbPortDisch.listIndex &gt; 1 and 
		self.cmbPortDest.listIndex &gt; 1 then
		self.btnAdd.enabled := true;
	else
		self.btnAdd.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="b0fe5bda-26a9-4b02-b3de-3350dec3a358">
        <source>setupControls();

vars
	operator : CM_Operator;
	shippingLine : CM_ShippingLine; 
begin
	if app.myPassport.myUser.canDo(null, PmAdmDestDischPortMaint) and
	   self.cmbOperator.listIndex &gt; 0 and
	   self.cmbShippingLine.listIndex &gt; 0 and
	   self.cmbPortDest.listIndex &gt; 0 and
	   self.cmbPortDisch.listIndex &gt; 0 then
		btnAdd.enabled := true;
	else
		btnAdd.enabled := false;
	endif;
	if app.myPassport.myUser.canDo(null, PmAdmDestDischPortMaint) and
	   self.tblDestDischPort.selectedCount &gt; 0 then
		btnRemove.enabled := true;
	else
		btnRemove.enabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="856d705f-9217-44be-b8a8-918bb4ed509b">
        <updating/>
        <source>setupForm() updating;

vars
	entTableDefData : EntTableDef;
begin

	inheritMethod();
	self.cmbShippingLine.initialise(false);
	self.cmbOperator.initialise(false);
	self.cmbPortDest.enabled := false;
	self.cmbPortDisch.enabled := false;
	self.btnAdd.enabled := false;
	self.btnRemove.enabled := false;
	self.tblDestDischPort.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblDestDischPort.selectMode := CM_BaseTable.SelectMode_WholeRows;//MultiSelect_Simple;
	self.tblOperShipLine.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblOperShipLine.selectMode := CM_BaseTable.SelectMode_WholeRows;//MultiSelect_Simple;

	entTableDefData := app.myController.getEntTableDef(ETDef_OperShipLine);
	if entTableDefData &lt;&gt; null then	
		self.tblOperShipLine.zAddSortColumn(ETRow_Operator, false);
		self.tblOperShipLine.zAddSortColumn(ETRow_ShippingLine, false);
		self.tblOperShipLine.setTblDataEntRowsFromDef(entTableDefData);
	endif;

	entTableDefData := app.myController.getEntTableDef(ETDef_DestDischPort);
	if entTableDefData &lt;&gt; null then	
		self.tblDestDischPort.zAddSortColumn(ETRow_DestPort, false);
		self.tblDestDischPort.setTblDataEntRowsFromDef(entTableDefData);
	endif;
	//self.toolbarStyle := self.ToolbarStyle_None;
//	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
//	self.showToolbar := true;
//	self.btnSaveBase.visible := false;	
//	self.btnCancelBase.visible := true;	
	self.doRefresh();
	
	self.beginClassNotification(CM_OperatorShippingLine, false, Any_System_Event, Response_Continuous, null); // cnwvu1 25/08/2006
	self.beginClassNotification(CM_DestinationToDischargePort, false, Any_System_Event, Response_Continuous, null); // cnwvu1 25/08/2006
	
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="7de0f086-e640-4707-a612-e1f0c9ff604a">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//	created by cnwvu1	19/02/2007

vars
	idx	: Integer;
	theDestToDisch	: CM_DestinationToDischargePort;
	strDestination	: String;
	strDischarge	: String;
	theShipLine		: CM_OperatorShippingLine;
	str				: String;
	s				: String;
begin

	if theObject.isKindOf(CM_DestinationToDischargePort) then
		theDestToDisch	:= theObject.CM_DestinationToDischargePort;
	elseif theObject.isKindOf(CM_OperatorShippingLine) then
		theShipLine := theObject.CM_OperatorShippingLine;	
	endif;

	if eventType = Object_Update_Event then
		//there is no update event in this form
	elseif eventType = Object_Delete_Event then

		if theObject.isKindOf(CM_DestinationToDischargePort) then
			if self.tblDestDischPort.findObjectInRow(theDestToDisch, idx) and (tblOperShipLine.text &lt;&gt; null) 
// we have to add correct IF
//			  and (self.cmbOperator.myObject = theShipLine.myOperator) and (self.cmbShippingLine.myObject = theShipLine.myShippingLine)
			then
				self.tblDestDischPort.removeItem(idx);
			endif;
		elseif theObject.isKindOf(CM_OperatorShippingLine) then
			if self.tblOperShipLine.findObjectInRow(theShipLine, idx) then
				self.tblOperShipLine.removeItem(idx);
			endif;
		endif;

	elseif eventType = Object_Create_Event then

		if theObject.isKindOf(CM_DestinationToDischargePort) then
			if theDestToDisch.myOperatorShippingLine &lt;&gt; null then
				theShipLine := theDestToDisch.myOperatorShippingLine;
			endif;
			if not self.tblDestDischPort.findObjectInRow(theDestToDisch, idx) 
//			  and (self.cmbOperator.myObject = theShipLine.myOperator) and (self.cmbShippingLine.myObject = theShipLine.myShippingLine)
// we have to add correct IF - it does not work for the same shipping Line
			  and (self.cmbOperator.text.String = theShipLine.myOperator.description) and (self.cmbShippingLine.text.String = theShipLine.myShippingLine.description)
			then
				strDestination	:= theDestToDisch.destination.getDisplayFormatted(self.portCmbOrderDescrFirst);
				strDischarge	:= theDestToDisch.dischargePort.getDisplayFormatted(self.portCmbOrderDescrFirst);
				self.tblDestDischPort.addItemObject(theDestToDisch, strDestination &amp; Tab &amp; strDischarge);
			endif;
		elseif theObject.isKindOf(CM_OperatorShippingLine) then
			if not self.tblOperShipLine.findObjectInRow(theShipLine, idx) then
				self.tblOperShipLine.addItemObject(theShipLine, theShipLine.myOperator.getDisplayDetailsOther(false)&amp;Tab&amp;theShipLine.myShippingLine.getDisplayDetailsOther(false));
			endif;
		endif;
		
	endif;
	
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
