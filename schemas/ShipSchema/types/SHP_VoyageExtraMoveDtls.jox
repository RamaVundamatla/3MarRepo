    <JadeMethod name="doSaveExtraMoves" id="33f2ccb3-6efc-40fa-828a-1bc94325ddcb">
        <source>doSaveExtraMoves() protected;
/*

Date		    Who			Reason
18 June 2010	cnwas3	  Initial creation

*/

vars

begin
	self.myExtraMoveDtl.numCageMoves	:= self.txtCageMoves.text.asIntegerJMT();
	self.myExtraMoveDtl.numExtraMoves	:= self.txtExtraMoves.text.asIntegerJMT();
	self.myExtraMoveDtl.numLashingBinMoves	:= self.txtBinMoves.text.asIntegerJMT();
	self.myExtraMoveDtl.numLashings		:= self.txtLashings.text.asIntegerJMT();
	self.myExtraMoveDtl.numUnlashings	:= self.txtUnlashings.text.asIntegerJMT();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init" id="810a0d4d-129d-46ba-825c-54bdbbb6382f">
        <updating/>
        <source>init(_voyage : CM_Voyage) updating;
/*

Date		    Who			Reason
15 June 2010	cnwas3	  ccms 1134

*/

vars

begin
	self.myCurrentVoyage := _voyage;
	
	create self.myExtraMoveDtl transient;
	self.myExtraMoveDtl.setFromVoyage(_voyage);
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="35a11932-e983-4c4b-bc21-20ac0915a108">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/* ---------------------------------------------------------------------------
Created:     01 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	inheritMethod();
	
	self.lblVoyage.caption := app.getErrorString(Lashing_move_details_voyage) &amp; self.myCurrentVoyage.code;
	
	self.txtBinMoves.setTextFromInteger(self.myExtraMoveDtl.numLashingBinMoves);
	self.txtCageMoves.setTextFromInteger(self.myExtraMoveDtl.numCageMoves);
	self.txtExtraMoves.setTextFromInteger(self.myExtraMoveDtl.numExtraMoves);
	self.txtLashings.setTextFromInteger(self.myExtraMoveDtl.numLashings);
	self.txtUnlashings.setTextFromInteger(self.myExtraMoveDtl.numUnlashings);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="cca9e222-bae0-4552-a5f5-a12947bd70bd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015784, locale);
	btnCancel.translateCaption(Xlat_0015785, locale);
	btnSave.translateCaption(Xlat_0015786, locale);
	lblCageMoves.translateCaption(Xlat_0015787, locale);
	lblExtraMoves.translateCaption(Xlat_0015788, locale);
	lblLashBinMoves.translateCaption(Xlat_0015789, locale);
	lblLashings.translateCaption(Xlat_0015790, locale);
	lblUnlashings.translateCaption(Xlat_0015791, locale);
	lblVoyage.translateCaption(Xlat_0015792, locale);
end;</source>
    </JadeMethod>
