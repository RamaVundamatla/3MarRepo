    <JadeMethod name="getProfileByPublicId" id="06e1d687-0edb-468c-b8ce-c41c8a133286">
        <updating/>
        <source>getProfileByPublicId(_profilePublicId,
				 	 _profileSecretId	: String io; 
					 _authToken         : String io;
					 _timeoutOccurred   : Boolean io): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)

*/

vars
	errorMessage,
	httpHeader,
	logMessage,
	url,
	jsonPostData,
	jsonResponse   		: String;
	xml					: JadeXMLDocument;
	jsonHelper			: CMIF_JsonHelper;
	resultCode          : Integer;
	xmlHelper		    : CM_XmlHelperAgent;
	xmlElement		   : JadeXMLElement;
begin
	
	if _authToken = null then
		return false;
	endif;
	
	
	create xml transient;
	create xmlHelper transient;
	create jsonHelper transient;
	
	xml.outputDeclaration := false;
	xml.addElement("root");
	xml.rootElement.addElement("profilePublicId").setText(_profilePublicId);
	jsonPostData := jsonHelper.convertXMLToJson(xml.writeToString());

	url 		:= self.baseEndpoint &amp; '/getProfileByPublicId' &amp; '?' &amp;'profilePublicId=' &amp; _profilePublicId;
	httpHeader  := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer "  &amp; _authToken;
	
	
	// Send the request
	jsonResponse := self.doSendHTTPRequest(url,
										   "GET",
										   httpHeader,
										   jsonPostData,
										   resultCode);
	
	if resultCode &lt;&gt; HttpResponseOK then
		if resultCode = null then
			logMessage := logMessage &amp; " - response timeout";
		else
			logMessage := logMessage &amp; " - error " &amp; resultCode.String;
		endif;
		return false;
	endif;
	

	self.updateActivityHistory(true); 	
	
	

	
	xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	
	if resultCode = HttpResponseOK then
		xmlElement := xml.findElementByTagName("profileSecretId");
		if xmlElement &lt;&gt; null then
			_profileSecretId := xmlElement.text();
			return true;
		else
			_profileSecretId := null;
			return false;
		endif;
	else
		return false;
	endif;
	
	return true;
epilog
	app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	delete xml;
	delete xmlHelper;
	delete jsonHelper;
end;</source>
        <Parameter name="_profilePublicId" type="String" usage="io"/>
        <Parameter name="_profileSecretId" type="String" usage="io"/>
        <Parameter name="_authToken" type="String" usage="io"/>
        <Parameter name="_timeoutOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="postCargoEvent" id="1a41028b-311d-4af7-aadf-b88b1959fce3">
        <updating/>
        <source>postCargoEvent(_cargo: CM_TrackedItem; _authToken, _secretId: String): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Jul 2019	jlgmp6	Initial creation	TFS45230
07 Jul 2020 cnwma1	Bug 49649: MTN - Cargo Chain Support - Data Fields
*/

vars
	xml				: JadeXMLDocument;
	xmlEvents,
	xmlProperty		: JadeXMLElement;
	httpHeader,
	url				: String;
	cargoJSON 		: String;
	jsonHelper		: CMIF_JsonHelper;
	jsonResponse	: String;
	resultCode		: Integer;
	weight			: Decimal[14, 4];
	subType,
	bol,
	vessel,
	voyage,
	contentsStatus,
	imexStatus,
	commodity,
	hazards,
	consignee,
	consignor,
	forwarder,
	carrier,
	operator,
	description,
	remarks			: String;
	isWeightCert,
	isHazardous		: Boolean;
	terminal		: CM_Terminal;

begin
	terminal := _cargo.getMyTerminal();

	create jsonHelper transient;
	create xml transient;
	xml.outputDeclaration := false;
	xml.addElement("root");

	xml.rootElement.addElement("profileSecretId").setText(_secretId);

	xmlEvents := xml.rootElement.addElement("events");
	xmlEvents.addElement("eventType").setText("MasterTerminalCargo");
	xmlEvents.addElement("visibility").setText("public");

	if _cargo.isContainer() then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("packingType");
		xmlProperty.addElement("dataType").setText("packingtype");
		xmlProperty.addElement("value").setText("container");

		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("isoType");
		xmlProperty.addElement("dataType").setText("isotype");
		xmlProperty.addElement("value").setText(_cargo.getISOType());

		contentsStatus := _cargo.getContentsStatusDesc(false);
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("Status");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(contentsStatus);

	elseif _cargo.isBulkCargo() then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("trackingType");
		xmlProperty.addElement("dataType").setText("cargotype");
		xmlProperty.addElement("value").setText("Bulk");

	else
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("trackingType");
		xmlProperty.addElement("dataType").setText("cargotype");
		xmlProperty.addElement("value").setText("Breakbulk");

		if _cargo.totalQuantity &gt; 0 then
			xmlProperty := xmlEvents.addElement("properties");
			xmlProperty.addElement("name").setText("Quantity");
			xmlProperty.addElement("dataType").setText("integer");
			xmlProperty.addElement("value").setText(_cargo.totalQuantity.String);
		endif;
	endif;

	if _cargo.myCargoType &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("cargoType");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(_cargo.myCargoType.description);
	endif;

	subType := _cargo.getCargoSubTypeDescr();
	if subType &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("cargoSubtype");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(subType);
	endif;

	if _cargo.loadPort &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("PortofLan");
		xmlProperty.addElement("dataType").setText("locode");
		xmlProperty.addElement("value").setText(_cargo.loadPort);
	endif;

	if _cargo.dischargePort &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("PortofDis");
		xmlProperty.addElement("dataType").setText("locode");
		xmlProperty.addElement("value").setText(_cargo.dischargePort);
	endif;

	if _cargo.destinationPort &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("Destination");
		xmlProperty.addElement("dataType").setText("locode");
		xmlProperty.addElement("value").setText(_cargo.destinationPort);
	endif;

	if terminal &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("Location");
		xmlProperty.addElement("dataType").setText("locode");
		xmlProperty.addElement("value").setText(terminal.getConfig(PortDestCode).String);
	endif;

	bol := _cargo.billOfLading;
	if bol &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("BOL");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(bol);
	endif;

	vessel := _cargo.vesselName;
	if vessel &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("Vessel");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(vessel);
	endif;

	voyage := _cargo.voyageCode;
	if voyage &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("VoyageNum");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(voyage);
	endif;

	imexStatus := _cargo.getImExStatusStringDesc(true);
	xmlProperty := xmlEvents.addElement("properties");
	xmlProperty.addElement("name").setText("IMEX");
	xmlProperty.addElement("dataType").setText("text");
	xmlProperty.addElement("value").setText(imexStatus);

	commodity := _cargo.getCommodityDesc();
	if commodity &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("commodity");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(commodity);
	endif;

	weight := _cargo.getTareWeight();
	if weight &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("TareWeight");
		xmlProperty.addElement("dataType").setText("mass");
		xmlProperty.addElement("value").setText(weight.String &amp; "kg");
	endif;

	weight := _cargo.weightCargo;
	if weight &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("CargoWeight");
		xmlProperty.addElement("dataType").setText("mass");
		xmlProperty.addElement("value").setText(weight.String &amp; "kg");
	endif;

	isWeightCert := _cargo.isWeightCertified;
	xmlProperty := xmlEvents.addElement("properties");
	xmlProperty.addElement("name").setText("WeightCertified");
	xmlProperty.addElement("dataType").setText("boolean");
	xmlProperty.addElement("value").setText(isWeightCert.asStringJMT());

	isHazardous := _cargo.isHazardous;
	xmlProperty := xmlEvents.addElement("properties");
	xmlProperty.addElement("name").setText("Hazardous");
	xmlProperty.addElement("dataType").setText("boolean");
	xmlProperty.addElement("value").setText(isHazardous.asStringJMT());

	hazards := _cargo.getHazardsAsString();
	if hazards &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("HazardDetail");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(hazards);
	endif;

	consignee := _cargo.getConsigneeDesc();
	if consignee &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("consignee");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(consignee);
	endif;

	consignor := _cargo.getConsignorDesc();
	if consignor &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("consignor");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(consignor);
	endif;

	if _cargo.myFreightForwarder &lt;&gt; null then
		forwarder := _cargo.myFreightForwarder.description;
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("FreightFor");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(forwarder);
	endif;

	carrier := _cargo.getCarrierDescription();
	if carrier &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("Carrier");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(carrier);
	endif;

	operator := _cargo.operatorDescription;
	if operator &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("Operator");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(operator);
	endif;
	
	//07.07.2020 cnwma1 #49649
	description := _cargo.description;
	if description &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("Description");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(description);
	endif;
	
	//07.07.2020 cnwma1 #49649
	remarks := _cargo.remarks;
	if remarks &lt;&gt; null then
		xmlProperty := xmlEvents.addElement("properties");
		xmlProperty.addElement("name").setText("Remarks");
		xmlProperty.addElement("dataType").setText("text");
		xmlProperty.addElement("value").setText(remarks);
	endif;
	
	
	cargoJSON := jsonHelper.convertXMLToJson(xml.writeToString());

	url := self.baseEndpoint &amp; '/addEvents';

	httpHeader := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer " &amp; _authToken;
	
	app.writeLog(method.qualifiedName() &amp; Space &amp;  "Send HTTP Request", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	// Send the request
	jsonResponse := self.doSendHTTPRequest(url,
										   "POST",
										   httpHeader,
										   cargoJSON,
										   resultCode);
	return resultCode;
epilog
	delete xml;
	delete jsonHelper;
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_authToken" type="String"/>
        <Parameter name="_secretId" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="postMetadata" id="7bba7ac8-9315-48b5-a9c8-d75ff9986914">
        <updating/>
        <source>postMetadata(_cargo: CM_TrackedItem; _authToken, _secret,_eventHash: String): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)

*/

vars
	jsonResponse,
	url,
	httpHeader,
	cargoJSON 		: String;
	resultCode		: Integer;
	terminal		: CM_Terminal;

begin
	terminal := _cargo.getMyTerminal();

	

	if _eventHash &lt;&gt; null then
		cargoJSON :=CN_LEFT_BRACKET  &amp; CrLf &amp;
					CN_LEFT_BRACE    &amp; CrLf &amp;
					CN_DOUBLE_QUOTE  &amp; "profileSecretId"  &amp; CN_DOUBLE_QUOTE &amp; CN_COLON &amp; CN_DOUBLE_QUOTE &amp; _secret              	&amp; CN_DOUBLE_QUOTE &amp; CN_COMMA &amp; CrLf &amp;
					CN_DOUBLE_QUOTE  &amp; "key"              &amp; CN_DOUBLE_QUOTE &amp; CN_COLON &amp; CN_DOUBLE_QUOTE &amp; "lastProcessedEvent" 	&amp; CN_DOUBLE_QUOTE &amp; CN_COMMA &amp; CrLf &amp;
					CN_DOUBLE_QUOTE  &amp; "value"            &amp; CN_DOUBLE_QUOTE &amp; CN_COLON &amp; CN_DOUBLE_QUOTE &amp; _eventHash           	&amp; CN_DOUBLE_QUOTE  &amp; CrLf &amp;
					CN_RIGHT_BRACE   &amp; CrLf &amp;
					CN_RIGHT_BRACKET;
	
	else
		cargoJSON :=CN_LEFT_BRACKET  &amp; CrLf &amp;
					CN_LEFT_BRACE 	 &amp; CrLf &amp;
					CN_DOUBLE_QUOTE  &amp; "profileSecretId"  &amp; CN_DOUBLE_QUOTE &amp; CN_COLON &amp; CN_DOUBLE_QUOTE &amp; _secret              	&amp; CN_DOUBLE_QUOTE &amp; CN_COMMA &amp; CrLf &amp;
					CN_DOUBLE_QUOTE  &amp; "key"              &amp; CN_DOUBLE_QUOTE &amp; CN_COLON &amp; CN_DOUBLE_QUOTE &amp; "oid" 					&amp; CN_DOUBLE_QUOTE &amp; CN_COMMA &amp; CrLf &amp;
					CN_DOUBLE_QUOTE  &amp; "value"            &amp; CN_DOUBLE_QUOTE &amp; CN_COLON &amp; CN_DOUBLE_QUOTE &amp; _cargo.getOidAsString()  &amp; CN_DOUBLE_QUOTE  &amp; CrLf &amp;
					CN_RIGHT_BRACE 	 &amp; Comma              &amp; CrLf &amp;
					CN_LEFT_BRACE 	 &amp; CrLf 			  &amp;
					CN_DOUBLE_QUOTE  &amp; "profileSecretId"  &amp; CN_DOUBLE_QUOTE &amp; CN_COLON &amp; CN_DOUBLE_QUOTE &amp; _secret              	&amp; CN_DOUBLE_QUOTE &amp; CN_COMMA &amp; CrLf &amp;
					CN_DOUBLE_QUOTE  &amp; "key"              &amp; CN_DOUBLE_QUOTE &amp; CN_COLON &amp; CN_DOUBLE_QUOTE &amp; "TerminalCode" 			&amp; CN_DOUBLE_QUOTE &amp; CN_COMMA &amp; CrLf &amp;
					CN_DOUBLE_QUOTE  &amp; "value"            &amp; CN_DOUBLE_QUOTE &amp; CN_COLON &amp; CN_DOUBLE_QUOTE &amp; terminal.code           	&amp; CN_DOUBLE_QUOTE  &amp; CrLf &amp;
					CN_RIGHT_BRACE 	 &amp; CrLf &amp;
					CN_RIGHT_BRACKET;
	endif;
	
	url 	   := self.baseEndpoint &amp; '/setMetadata';
	httpHeader := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer " &amp; _authToken;

	jsonResponse := self.doSendHTTPRequest(url, "POST", httpHeader, cargoJSON, resultCode);

	return resultCode;
epilog
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_authToken" type="String"/>
        <Parameter name="_secret" type="String"/>
        <Parameter name="_eventHash" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="postRegisterHook" id="e7a900e3-e140-4903-95ed-430db8f11b62">
        <updating/>
        <source>postRegisterHook(_authToken, _secretId: String): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Jul 2019	jlgmp6	Initial creation	TFS45230
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)
*/
constants
	Nonsense			: String = "Nonsense";
	Placeholder			: String = "Placeholder";

vars
	resultCode			: Integer;
	iniFile,
	webServiceURL,
	restWSApplication	: String;
	xml					: JadeXMLDocument;
	httpHeader,
	url,
	cargoJSON	 		: String;
	jsonHelper			: CMIF_JsonHelper;
	jsonResponse,
	eventTypes,
	callback			: String;
	ccem				: CM_CargoChainEventMapping;

begin
	/*
	iniFile := app.getIniFileName();
	if app.getProfileString(iniFile, CargoChainSection, WebServiceURL, Nonsense) = Nonsense and app.getProfileString(iniFile, CargoChainSection, RestWSApplication, Nonsense) = Nonsense then
		// ini file section doesn't exist, create it
		if not self.createCargoChainIniSection() then
			return 0;
		endif;
	endif;

	webServiceURL := app.getProfileString(iniFile, CargoChainSection, WebServiceURL, null);
	restWSApplication := app.getProfileString(iniFile, CargoChainSection, RestWSApplication, null);
    */

	create jsonHelper transient;

	url 	   := self.baseEndpoint &amp; '/registerProfileHook';
	httpHeader := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer " &amp; _authToken;
	callback   := self.callBackUrl;         							 // 13.07.2020 cnwma1 #49243
	
	foreach ccem in self.allCargoChainEventMappings do
		eventTypes := DoubleQuote &amp; ccem.eventName &amp; DoubleQuote;
		//callback := webServiceURL &amp; Forward_Slash &amp; app.ccFunctionEnumToName(ccem.cargoChainFunction) &amp; QuestionMark &amp; restWSApplication;  //11.11.2019 cnwma1 TFS #45285
		//callback := webServiceURL &amp; Forward_Slash &amp;  "CargoChainEvent" &amp; QuestionMark &amp; restWSApplication;                                 //11.11.2019 cnwma1 TFS #45285   // 13.07.2020 cnwma1 #49243
		
		create xml transient;
		xml.outputDeclaration := false;
		xml.addElement("root");

		xml.rootElement.addElement("eventTypes").setText(Placeholder);
		xml.rootElement.addElement("uri").setText(callback);
		xml.rootElement.addElement("profileSecretId").setText(_secretId);

		cargoJSON := jsonHelper.convertXMLToJson(xml.writeToString()).replace(DoubleQuote &amp; Placeholder &amp; DoubleQuote, CN_LEFT_BRACKET &amp; eventTypes &amp; CN_RIGHT_BRACKET);

		// Send the request
		jsonResponse := self.doSendHTTPRequest(url,
											   "POST",
											   httpHeader,
											   cargoJSON,
											   resultCode);
		if resultCode &lt;&gt; HttpResponseOK then
			break;
		endif;

		delete xml;
	endforeach;

	return resultCode;
epilog
	delete xml;
	delete jsonHelper;
end;</source>
        <Parameter name="_authToken" type="String"/>
        <Parameter name="_secretId" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMetaData" id="9c4e210d-d5a6-4a2f-9c2d-dc494832f860">
        <updating/>
        <source>setMetaData(_profileSecretId 	: String ;
			_key                : String;
			_value              : String;
			_authToken 			: String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)

*/

vars
	url,
	jsonPostData,
	httpHeader,
	jsonResponse     	: String;
	xml					: JadeXMLDocument;
	jsonHelper			: CMIF_JsonHelper;
	resultCode          : Integer;
	xmlHelper		    : CM_XmlHelperAgent;
begin
	if _authToken = null then
		return false;
	endif;
	
	create xml transient;
	create xmlHelper transient;
	create jsonHelper transient;

	
	xml.outputDeclaration := false;
	xml.addElement("root");
	xml.rootElement.addElement("profileSecretId").setText(_profileSecretId);
	xml.rootElement.addElement("key").setText(_key);
	xml.rootElement.addElement("value").setText(_value);
	
	jsonPostData := jsonHelper.convertXMLToJson(xml.writeToString());
	
	url 		:= self.baseEndpoint &amp; '/setMetaData';
	httpHeader  := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer " &amp; _authToken;
	
	// Send the request
	jsonResponse := self.doSendHTTPRequest(url,
										   "POST",
										   httpHeader,
										   jsonPostData,
										   resultCode);

	xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	if resultCode = HttpResponseOK then
		

		return true;
	else
		return false;
	endif;
epilog
	delete xml;
	delete xmlHelper;
	delete jsonHelper;
end;</source>
        <Parameter name="_profileSecretId" type="String"/>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_authToken" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupFromWebServiceDefinition" id="d39a52c9-e71a-49ec-b432-2732be7cbb12">
        <updating/>
        <source>setupFromWebServiceDefinition(_definition: CM_CargoChainServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Nov 2018	jlger1	Initial creation
13 Jul 2020 cnwma1  Bug 49243: MTN - Cargo Chain Web Service Callback INI value
*/

vars

begin
	inheritMethod(_definition);
	self.authProviderUrl :=_definition.authProviderUrl;
	self.clientID 		 :=_definition.clientID;
	self.clientSecret    :=_definition.clientSecret;
	self.runAsKey 		 := _definition.runAsKey;									// 3/7/19 MAP TFS45230
	self.callBackUrl     := _definition.callBackUrl;                                // 13.07.2020 cnwma1 #49243
	_definition.allCargoChainEventMappings.copy(self.allCargoChainEventMappings);	// 18/7/19 MAP TFS45230
epilog

end;</source>
        <Parameter name="_definition" type="CM_CargoChainServiceDef"/>
    </JadeMethod>
</Class>
