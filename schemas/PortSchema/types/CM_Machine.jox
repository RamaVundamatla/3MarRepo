        <source>addMoveToHistoryTask(aTask: CM_RTQueueTask) : CM_MachineMoveHistory updating;

/*

Date		Who		Reason
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed as part of refactoring methods

*/

vars
	histEntry:   CM_MachineMoveHistory;	
	tmpUser	: CM_User;
begin

	create histEntry persistent;
	tmpUser := self.user;
	if tmpUser = null then
		histEntry.completedTask(aTask, CM_MachineHistory.Unknown_Value, self);
	else
		histEntry.completedTask(aTask, tmpUser.code, self);
	endif;
	return histEntry; //ccms 1416 feb 2006 cnwrs1
end;</source>
        <Parameter name="aTask" type="CM_RTQueueTask"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
