    <JadeMethod name="quantityCARGObyMeasurement" id="cef24cfc-0623-4fce-97e2-a90a1fd5f13f">
        <source>quantityCARGObyMeasurement(_tran : CM_TITransaction; chargeByUnits : Integer) : Real;
// ---------------------------------------------------------------------------
// Created:     June 2017 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // TFS 4709
// 23 Oct 2024		navlw1			JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------

vars
	blockUnit : Integer;
	amount : Real;
	value : Real;
	calcType : CM_CalculationType;
	convRate : Real;
begin
	// ### CALCULATION TYPE
	calcType := self.myCalculationType;
	if calcType &lt;&gt; null then
		blockUnit := calcType.theCalcTypeUnit;
	else
		blockUnit := INV_CALC_TYPE_UNITY; // value of 1
	endif;
	
	// ### MEASUREMENT TYPE
	if calcType.myMeasurementType &lt;&gt; null then
		convRate := calcType.myMeasurementType.conversionRate;
	else
		convRate := 1;
	endif;
			
	// ### AMOUNT
	if chargeByUnits = INV_CALC_TYPE_CARGOWEIGHTCONVT then 
		if calcType.isUseCargoWeight() then
			amount := _tran.cargoWeight; //02/10/2025	navkc1 JIRA 36149
		else
			amount := _tran.totalWeight; // KG
		endif;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOVOLUMECONVT then 
		amount := _tran.totalVolume;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOLENGTHCONVT then 
		amount := _tran.totalLength; // CM
	else
		amount := 1;
	endif;

	// ### CONVERT
	value := self.getQuantityForTranCargoByType(_tran, blockUnit) * (amount / convRate);
	app.invLog(method.qualifiedName &amp; " blockUnit=" &amp; blockUnit.String &amp; " amount=" &amp; amount.String 
							&amp; " convRate=" &amp; convRate.String &amp; ", convValue=" &amp; (amount / convRate).String &amp; ", rangeValue=" &amp; value.String, LogINFO.String);
	
	return value;

epilog

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <Parameter name="chargeByUnits" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityVoyageBlockUnits" id="0170efbd-bc39-41ff-a9aa-0e3a8f9cd7cf">
        <source>quantityVoyageBlockUnits(_blockUnit : Integer; _hmsData : HMS_VoyageData; _voyage : CM_Voyage; _resourceUsed : HMS_ResourceUsed) : Real protected;
/*

Purpose:			added as part of  TFS 39237, refactoring 'getQuantityForTransactionVTMIS'

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2018	jlgab1	Initial creation

*/

vars
	value	: Real;
	towingHMSData : HMS_VoyageData;
	towingVoyage : CM_Voyage;

begin
	if _hmsData= null then
		return 1;
	endif;
	
	if _blockUnit = INV_CALC_TYPE_UNITY then
		value := 1;
	elseif _blockUnit = INV_CALC_TYPE_RESOURCE_QTY then
		if _resourceUsed&lt;&gt; null then
			value := _resourceUsed.unitsUsed;
		endif;
	elseif _blockUnit = INV_CALC_TYPE_UNIT_GRT then
		value := _hmsData.dim_GrossRegTonnes; 
	elseif _blockUnit = INV_CALC_TYPE_UNIT_NRT then
		value := _hmsData.dim_NetRegTonnes;
	elseif _blockUnit = INV_CALC_TYPE_UNIT_LENGTH then
		value := _hmsData.dim_LengthOverall; 
	elseif _blockUnit = INV_CALC_TYPE_UNIT_BEAM then
		value := _hmsData.dim_Beam; 
	elseif _blockUnit = INV_CALC_TYPE_UNIT_DEADWEIGHT then
		value := _hmsData.dim_DeadWeight;
	elseif _blockUnit = INV_CALC_TYPE_UNIT_DRAFT_MID then
		value := _voyage.draftMid;
	else // DEFAULT
		value := _hmsData.dim_GrossRegTonnes; 
	endif;

	// TFS 39198 include the towing voyage's value
	/* TFS 42161 SAURABH SAID TO REMOVE ALL OF THIS
	towingVoyage := _hmsData.myTowingVoyage;
	if towingVoyage &lt;&gt; null then
		towingHMSData :=towingVoyage.myHMSVoyageData;
		if towingHMSData&lt;&gt; null then
			if  _blockUnit = INV_CALC_TYPE_UNIT_GRT then
				value := value + towingHMSData.dim_GrossRegTonnes; 
			elseif _blockUnit = INV_CALC_TYPE_UNIT_NRT then
				value := value + towingHMSData.dim_NetRegTonnes;
			elseif _blockUnit = INV_CALC_TYPE_UNIT_LENGTH then
				value := value + towingHMSData.dim_LengthOverall; 
			elseif _blockUnit = INV_CALC_TYPE_UNIT_BEAM then
				value := value + towingHMSData.dim_Beam; 
			elseif _blockUnit = INV_CALC_TYPE_UNIT_DEADWEIGHT then
				value := value + towingHMSData.dim_DeadWeight;
			elseif _blockUnit = INV_CALC_TYPE_UNIT_DRAFT_MID then
				value := value + towingVoyage.draftMid;
			else // DEFAULT
				value := value + towingHMSData.dim_GrossRegTonnes;
			endif;
		endif;
	endif;
	*/
	
	if value = 0 then
		value := 1;
	endif;
	
	return value;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_blockUnit" type="Integer"/>
        <Parameter name="_hmsData" type="HMS_VoyageData"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_resourceUsed" type="HMS_ResourceUsed"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="replaceInvoiceLineTypes" id="06578cf0-46de-458c-bc4d-986034febb4c">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count	: Integer;
	qrm,qrmSub		: CM_QuantityRangeMap;
begin
	foreach qrm in self.allQuantityRanges do
		if qrm.myChildQuantityMap &lt;&gt; null then
			foreach qrmSub in qrm.myChildQuantityMap.allQuantityRanges do 
				count := count + qrmSub.replaceInvoiceLineTypes(_oldILD, _newILD);
			endforeach;
		else
			count := count + qrm.replaceInvoiceLineTypes(_oldILD, _newILD);
		endif;
	endforeach;

	return count;
end;
</source>
        <Parameter name="_oldILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_newILD" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
