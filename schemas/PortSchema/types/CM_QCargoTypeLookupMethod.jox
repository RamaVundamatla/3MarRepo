    <JadeMethod name="getControlNameForOperator" id="5dcaaa10-204a-465e-9746-bd4821c9688a">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	if CM_QIntegerLookupEqual.hasInstance(_operator) or
	   CM_QIntegerLookupNotEqual.hasInstance(_operator) then
		return 'cmbCargoType';
	endif;


end;</source>
