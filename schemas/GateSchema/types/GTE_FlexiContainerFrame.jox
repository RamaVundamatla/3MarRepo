vars

begin
	
	self.backColor := self.selectedBackColor;
	
	self.myFlexiTruckLayoutFrame.selectContainer(self);	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCaption" id="7ee807ef-e53c-42df-9168-6e34a4807ad9">
        <updating/>
        <source>setCaption() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lenStr	: String;

begin

	if self.length &lt;&gt; 0 then
		lenStr := self.length.String &amp; "ft";
	else
		lenStr := '&lt;unknown size&gt;';
	endif;

	//self.caption 	:= self.id &amp; CrLf &amp; lenStr;
	self.caption 	:= self.id &amp; " " &amp; lenStr;//cnwas3
	self.bubbleHelp	:= self.id &amp; CrLf &amp; 'Length : ' &amp; lenStr;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDetails" id="08ba6c88-14dd-4470-ae32-ec43361d1819">
        <updating/>
        <source>setDetails(pId : String; pDoors : Boolean; _container : CMGTE_Entity) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.id		 := pId;

	self.setHasDoors(pDoors);
	self.myContainer := _container.getGateEntity(_container.jobQueueNum);
	if not _container.isTransient then
		self.myContainer:=_container;
	endif;
//	self.id:=self.myContainer.getID;
	if self.myContainer.isKindOf(CMGTE_Container) then
		self.myFlexiDoorsDirBtn.doorsRight := not(self.myContainer.CMGTE_Container.doorsDirection=TI_DOORSDIRN_FWD);
	else
		self.myFlexiDoorsDirBtn.doorsRight := not(self.myContainer.CMGTE_Release.doorsDirection=TI_DOORSDIRN_FWD);
	endif;//cnwas3
	
	self.setLengthFromIsoType();
	self.setCaption();
	
	self.visible := true;

end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pDoors" type="Boolean"/>
        <Parameter name="_container" type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="setHasDoors" id="29014439-559e-455f-840a-6dd5e630a3fe">
        <updating/>
        <source>setHasDoors(pValue: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.hasDoors := pValue;
	
	if self.myFlexiTruckLayoutFrame.myDoorsCheckBox.value then
		// doors dir is used
		if pValue then
			self.myFlexiDoorsDirBtn.visible := true;
		else
			self.myFlexiDoorsDirBtn.visible := false;
		endif;
	else
		// doors btn is probably not visible anyway 
		self.myFlexiDoorsDirBtn.visible := false;
	endif;
	
	
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setId" id="a7021331-ba83-4110-9615-36889cd3211a">
        <updating/>
        <source>setId(pId : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.id		 := pId;
	
	self.setCaption();
	
end;</source>
        <Parameter name="pId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLength" id="4f027288-0b79-41a2-8e79-2d7dbaa904c8">
        <updating/>
        <source>setLength(pLength : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.length = pLength then
		return;
	endif;
	
	self.length := pLength;
	
	self.setCaption();
	
	self.myFlexiTruckLayoutFrame.displayContainers();

end;</source>
        <Parameter name="pLength" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setLengthFromIsoType" id="d93e2b55-1268-4a52-ab49-b41d5181d0cb">
        <updating/>
        <source>setLengthFromIsoType() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2009	cnwas3	Initial creation

*/

vars
	container : CMGTE_Entity;
	isoType	: CM_ISOType;

begin	
	container:=self.myContainer;
	if container.isContainer() then
		isoType := app.myRoot.allISOTypes[container.getIsoType()];		
		if isoType &lt;&gt; null then
			if isoType.is40ftLong then
				self.length := 40;
			elseif isoType.is45ftLong then
				self.length := 45;
			elseif isoType.is20ftLong then
				self.length := 20;
			else
				self.length := 0;
			endif;
		else
			self.length := 0;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setWidth" id="1ee50ac2-03c8-4bf4-bb41-dbd61a71e325">
        <updating/>
        <source>setWidth(p10, p20, p40 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.length = 40 then
		self.width := p40;
	elseif self.length = 20 then
		self.width := p20;
	else
		self.width := p20;	// p10 - make 20 the default;
	endif;

	self.positionDoorsDirBtn();

end;</source>
        <Parameter name="p10" type="Integer"/>
        <Parameter name="p20" type="Integer"/>
        <Parameter name="p40" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showDoorsDirBtn" id="2ecfccb3-307a-421b-b455-ae697c056958">
        <source>showDoorsDirBtn();
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.hasDoors then
		self.myFlexiDoorsDirBtn.visible := true;
	else
		self.myFlexiDoorsDirBtn.visible := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="02a0dfb7-2bdb-4b55-b1f9-561575ff88d1">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	//cnwsh3 21/04/2006 - The selected container was not being highlighted with new skin layout.  Set the control to ignore the skin.
	self.ignoreSkin := true;
	
	self.buildSelf();
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <DevControlTypes name="GTE_FlexiContainerFrame">
        <bitmap></bitmap>
        <windowClass>AlFrame</windowClass>
        <DevControlProperties name="alignChildren">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Width</value>
                <value>2 - All</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="alignContainer">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Top</value>
                <value>2 - Align Bottom</value>
                <value>3 - Align Width</value>
                <value>4 - Stretch to next control below</value>
                <value>5 - Align Container</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="alignment">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - Left  justify - TOP</value>
                <value>1 - Left  justify - MIDDLE</value>
                <value>2 - Left  justify - BOTTOM</value>
                <value>3 - Right justify - TOP</value>
                <value>4 - Right justify - MIDDLE</value>
                <value>5 - Right justify - BOTTOM</value>
                <value>6 - Center - TOP</value>
                <value>7 - Center - MIDDLE</value>
                <value>8 - Center - BOTTOM</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="allowDocking">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrush">
            <cntrlType>picture</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrushStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - tile</value>
                <value>1 - stretch</value>
                <value>2 - center</value>
                <value>3 - stretch proportional</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="backColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelInner">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Inset</value>
                <value>2 - Raised</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="bevelInnerWidth">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelOuter">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Inset</value>
                <value>2 - Raised</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="bevelOuterWidth">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelShadowColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderColorSingle">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Fixed single</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="boundaryBrush">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - Solid Brush</value>
                <value>1 - Dotted Brush</value>
            </optionsList>
        </DevControlProperties>
