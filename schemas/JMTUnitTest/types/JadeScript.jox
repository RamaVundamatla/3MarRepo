    <JadeMethod name="mdhTestLinkScript1" id="51711087-a60a-4cba-bd05-76193999e034">
        <source>mdhTestLinkScript1();

/*

Purpose:		Check against Testlink to see which forms covered by unit test.

Date			Who		Reason
23/01/2014		cnwmh5	Initial creation

*/

vars

	file								: File;
	
	tlFormsArray						: StringArray;
	devFormsArray						: StringArray;
	tokensArray							: StringArray;
	tokens								: StringArray;
	
	line								: String;
	firstTime							: Boolean;
	tokenSize							: Integer;
	index								: Integer;
	str									: String;

begin

	// get the deatils from testlink
	
	create tlFormsArray transient;
	create tokensArray transient;
	create tokens transient;
	
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version	
	file.fileName := "C:\temp\testLink_methods_details.csv";
	
	firstTime := true;
	
	while not file.endOfFile do
	
		if firstTime then
			line := file.readLine();
			firstTime := false;
		endif;
	
		line := file.readLine();
		
		tokens.clear();
		tokens := line.cnGetTokens(",");
		
		if tokens.size &gt; 0 then
			index := 1;
			while index &lt;= tokens.size do	
				if not tlFormsArray.includes(tokens[index].trimBlanks()) then
					tlFormsArray.add(tokens[index].trimBlanks());
				endif;
				index := index + 1;
			endwhile;
		endif;
		
	endwhile;
	file.close();
	delete file;
		
	create devFormsArray transient;
	
	// read thru the details from the system where have a form and also a unit test
	create file transient;
	file.fileName := "C:\temp\trxDisplayMethodsCalledByFormsWithUnitTests.csv";
	
	while not file.endOfFile do
	
		line := file.readLine();
		
		tokens.clear();
		tokens := line.cnGetTokens(Tab);
	
		index := 4;
		foreach index in 4 to tokens.size step 1 do
			if not devFormsArray.includes(tokens[index].trimBlanks()) then
				devFormsArray.add(tokens[index].trimBlanks());
			endif;
		endforeach;
	
	endwhile;
	
	foreach line in tlFormsArray do
		str := line;
		if devFormsArray.includes(line) then
			str := str &amp; " has a trx covered by a unit test"; 
		else
			str := str &amp; " doesn't have a trx covered by a unit test" &amp; Tab &amp; Tab &amp; "********";			
		endif;
		write str;
	endforeach;
	
epilog

	delete file;
	delete tlFormsArray;
	delete tokensArray;
	delete tokens;
	delete devFormsArray;
	
end;</source>
    </JadeMethod>
