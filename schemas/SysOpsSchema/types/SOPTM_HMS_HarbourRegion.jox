    <JadeMethod name="setupThumbnailDetails" id="952f571a-9943-4aa5-ac27-6faf9d698d54">
        <source>setupThumbnailDetails();
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	objSet		: ObjectSet;
	theForm		: SOP_HMS_TableMaintForm;
	defName		: String;

begin
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_HMSTblDataWayPoint);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	
	defName := self.getDefNameTblInput();
	
	if defName = null then //saftey net
		defName := ETDef_HMSTblInput;
	endif;
	
	theForm.initTblInput(theForm.tblInput1, defName);
	theForm.shtTblInput1.visible := true;

	create objSet transient;
	
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.shtMultiSelect1.caption := 'Berth Details';
	theForm.mulSelect1.formDisplayEntryMethodName := SOP_TableMaintForm::displayEntryBerth.name;
	theForm.mulSelect1.availableHeading := 'Berths Available';
	theForm.mulSelect1.selectedHeading  := 'Berths in this Region';


	theForm.myHarbour.getBerthsUnassignedToRegion(objSet);
	theForm.mulSelect1.setAvailable(objSet, true);

	
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkCurrent, HMS_ChkPointType_Current, null);
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkHeight, HMS_ChkPointType_Draft, null);
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkHiLo, HMS_ChkPointType_HiLo, null);
	//self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkTideRange, HMS_ChkPointType_TideRange, null); // jlgka1 TFS 45620
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkDay, HMS_ChkPointType_TimeGap, null);
	//self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkShipsDepar, HMS_ChkPointType_ShipsDepart, null); // jlgka1 TFS 45620
	//self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkUserHook, HMS_ChkPointType_UserHookCode, null);  // jlgka1 TFS 45620
	//self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkTideState, HMS_ChkPointType_TideState, null); //epr par 16884 5/608  // jlgka1 TFS 45620
	
	theForm.cmbChkTideRange.automaticCellControl	:=	true;
	
	theForm.tblData.userInputEnabled := false;	// 26/03/2008 cnwar2 #16267
epilog
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="cd97bed8-e9ea-4f2d-8c16-4a5e57791df5">
        <updating/>
        <source>showThumbnail(pObj: HMS_HarbourRegion) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	objSet		: ObjectSet;
	theForm		: SOP_HMS_TableMaintForm;
	regionObj	: HMS_HarbourRegion;
	
begin
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setTableFromObject(pObj, null);
	
	theForm.myAssistant.comboBoxHMSHarbour(theForm.cmbHarbour, pObj.getHarbourReal());
	theForm.myAssistant.comboBoxTerminal(theForm.cmbTerminal, pObj.getTerminal(), null);
	theForm.myAssistant.comboBoxHMSBerthForRegion(theForm.cmbPrefBerth,pObj,pObj.myPreferredBerth);
	//theForm.cmbPrefBerth.listCollection(pObj.allBerthsInRegion, false, 0);
	
	//if pObj.myPreferredBerth &lt;&gt; null then
	//	theForm.cmbPrefBerth.listIndex := theForm.cmbPrefBerth.findObject(pObj.myPreferredBerth);
	//endif;
	
	theForm.cmbHarbour.lostFocus(theForm.cmbHarbour);
	theForm.cmbTerminal.lostFocus(theForm.cmbTerminal);
	theForm.cmbPrefBerth.lostFocus(theForm.cmbPrefBerth);
	
	create objSet transient;
	
	// lorcan harbour may not now exist
	if pObj.getHarbourReal &lt;&gt; null then
		theForm.shtMultiSelect1.enabled := true;
		pObj.getHarbourReal.getBerthsUnassignedToRegion(objSet);
		pObj.allBerthsInRegion.copy(objSet);
		theForm.mulSelect1.setAvailable(objSet, true);
		theForm.mulSelect1.setSelected(pObj.allBerthsInRegion);
	else
		theForm.shtMultiSelect1.enabled := false;

		// Still need to do following so that when we do the update
		// these things get copied over
		pObj.allBerthsInRegion.copy(objSet);
		theForm.mulSelect1.setAvailable(objSet, true);
		theForm.mulSelect1.setSelected(pObj.allBerthsInRegion);
	endif;
	
	//th2 - no longer collection - replaced by four references
	//objSet.clear;
	//app.myRoot.getCheckPtsUnassignedToRegion(objSet);
	//pObj.allCheckpoints.copy(objSet);
	//theForm.mulSelect2.setAvailable(objSet, true);
	//theForm.mulSelect2.setSelected(pObj.allCheckpoints);
	
	regionObj	:=	theForm.myCurrentObject.HMS_HarbourRegion;
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkCurrent, HMS_ChkPointType_Current, regionObj);
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkHeight, HMS_ChkPointType_Draft, regionObj);
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkHiLo, HMS_ChkPointType_HiLo, regionObj);
	//self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkShipsDepar, HMS_ChkPointType_ShipsDepart, regionObj); jlgka1 TFS 45620
	//self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkTideRange, HMS_ChkPointType_TideRange, regionObj); jlgka1 TFS 45620
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkDay, HMS_ChkPointType_TimeGap, regionObj);
	//self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkUserHook, HMS_ChkPointType_UserHookCode, regionObj); //jlgka1 TFS 45620
	//self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSCheckPoint(theForm.cmbChkTideState, HMS_ChkPointType_TideState, regionObj); //epr par 16884 5/6/08 //jlgka1 TFS 45620
	
	if pObj.myCurrentCheckpoint &lt;&gt; null then
		theForm.cmbChkCurrent.listIndex := theForm.cmbChkCurrent.findObject(pObj.myCurrentCheckpoint);
		theForm.tblInput1.setValueByName(ETRow_CheckpointCurrent, pObj.myCurrentCheckpoint.description);
	endif;
	
	if pObj.myHeightCheckpoint &lt;&gt; null then
		theForm.cmbChkHeight.listIndex := theForm.cmbChkHeight.findObject(pObj.myHeightCheckpoint);
		theForm.tblInput1.setValueByName(ETRow_CheckpointHeight, pObj.myHeightCheckpoint.description);
	endif;
	
	if pObj.myHiLoCheckpoint &lt;&gt; null then
		theForm.cmbChkHiLo.listIndex := theForm.cmbChkHiLo.findObject(pObj.myHiLoCheckpoint);
		theForm.tblInput1.setValueByName(ETRow_CheckpointHiLo, pObj.myHiLoCheckpoint.description);
	endif;
	
	//jlgka1 TFS 45620 --&gt;
	/*if pObj.myShipsDepartCheckpoint() &lt;&gt; null then
		theForm.cmbChkShipsDepar.listIndex := theForm.cmbChkShipsDepar.findObject(pObj.myShipsDepartCheckpoint);
		theForm.tblInput1.setValueByName(ETRow_CheckpointShipsDepart, pObj.myShipsDepartCheckpoint.description);
	endif;
		
	if pObj.myTideRangeCheckPoint &lt;&gt; null then
		theForm.cmbChkTideRange.listIndex	:=	theForm.cmbChkTideRange.findObject(pObj.myTideRangeCheckPoint);
		theForm.tblInput1.setValueByName(ETRow_CheckpointTideRange, pObj.myTideRangeCheckPoint.description);
	endif;*/
	//jlgka1 TFS 45620 &lt;--
	
	if pObj.myTimeGapCheckpoint &lt;&gt; null then
		theForm.cmbChkDay.listIndex := theForm.cmbChkDay.findObject(pObj.myTimeGapCheckpoint);
		theForm.tblInput1.setValueByName(ETRow_CheckpointTimeGap, pObj.myTimeGapCheckpoint.description);
	endif;

	//jlgka1 TFS 45620 --&gt;
	/*if pObj.myUserHookCodeChkPoint &lt;&gt; null then
		theForm.cmbChkUserHook.listIndex := theForm.cmbChkUserHook.findObject(pObj.myUserHookCodeChkPoint);
		theForm.tblInput1.setValueByName(ETRow_CheckpointUserHook, pObj.myUserHookCodeChkPoint.description);
	endif;
	
	//epr par 16884 5/6/08
	if pObj.myTideStateCheckpoint() &lt;&gt; null then
		theForm.cmbChkTideState.listIndex := theForm.cmbChkTideState.findObject(pObj.myTideStateCheckpoint);
		theForm.tblInput1.setValueByName(ETRow_CheckpointTideState, pObj.myTideStateCheckpoint.description);
	endif;*/
	//jlgka1 TFS 45620 &lt;--
epilog
	delete objSet;
end;</source>
        <Parameter name="pObj" type="HMS_HarbourRegion"/>
    </JadeMethod>
</Class>
