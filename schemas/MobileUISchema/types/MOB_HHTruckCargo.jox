    <JadeMethod name="btnDocActions_click" id="71ab2459-f6d4-47f0-a271-f9d2f9fe38d7">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDocActions_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2016	cnwndl1	Initial creation	2921 / 2419

*/

vars

	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;

begin

	if self.isMOB_HHCargoDisplay then
		return;
	endif;

	create resDetailSet transient;
	create bookingItemSet transient;
	
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.hasDocumentActions( resDetailSet, bookingItemSet ) then
	
		self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
		self.myMobileGenericAgent.setAllBookingRefItems( bookingItemSet );
		self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
		self.gotoForm( MOB_HHDocumentActions, false );
		
	endif;

epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="changeQuantity" id="7aa24b3b-cd62-40ab-970d-e148b526ad65">
        <source>changeQuantity() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2013	cnwndl1	Initial creation	Par 32368
12 July 2017	jlgrh7 TFS #39817  STWO - Change of quantity in handheld does not change total weight

*/

vars

	row : Integer;
	dataString : String;
	quantity : Integer;
	weightMeasureType : CM_MeasurementType;
	productWeightMeasureType : CM_MeasurementType;				//+TFS39817
	volumeMeasureType : CM_MeasurementType;
	productVolumeMeasureTYpe : CM_MeasurementType;				//+TFS39817
	weightRowString : String;
	volumeRowString : String;
	weightRowIndex : Integer;
	volumeRowIndex : Integer;
	totWeight : Decimal [14,4];
	totVolume : Decimal [16,4];
	measureTbl : CMUI_MeasurementTable;
	product : CM_Product;
	
begin

	product := self.getProductForMeasurementType();

	row := tblCargo.getRow(ETRow_NumItems);
	if row &gt; 0 then
		dataString := tblCargo.getCellText(row,2).trimBlanks.toUpper;
		if dataString = null or dataString.isInteger then
			quantity := dataString.Integer;
			if self.myTrackedItem = null or not self.myTrackedItem.canMergeBreakBulk then
				return;
			endif;
			
			if self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
				return;
			endif;
			
			//weightMeasureType := self.getDefaultMeasurementForType(product, Type_Weight); 					//-TFS39911
			productWeightMeasureType := self.getDefaultMeasurementForType(product, Type_Weight); 		//+TFS39911
			weightMeasureType := app.getDefaultMeasurementForType(Type_Weight);											//+TFS39911
			weightRowString := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; weightMeasureType.shortName;
			weightRowIndex := self.tblCargo.getRow( weightRowString );
			
			//volumeMeasureType := self.getDefaultMeasurementForType(product, Type_Volume);						//-TFS39911
			productVolumeMeasureTYpe := self.getDefaultMeasurementForType(product, Type_Volume);			//+TFS39911
			volumeMeasureType :=app.getDefaultMeasurementForType(Type_Volume);												//+TFS39911
			volumeRowString := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; volumeMeasureType.shortName;
			volumeRowIndex := self.tblCargo.getRow( volumeRowString );
			
			if weightRowIndex = 0 and volumeRowIndex = 0 then
				return;
			endif;
			
			if quantity &lt; 1 /*or quantity &gt; self.myTrackedItem.totalQuantity*/ then
				quantity := self.myTrackedItem.totalQuantity;
			endif;
			if quantity = self.myTrackedItem.totalQuantity then
				totWeight := self.myTrackedItem.totalWeight;
				totVolume := self.myTrackedItem.totalVolume;
			else
				totWeight := self.myTrackedItem.totalWeight * ( quantity / self.myTrackedItem.totalQuantity );
				totVolume := self.myTrackedItem.totalVolume * ( quantity / self.myTrackedItem.totalQuantity );
			endif;
			
			if weightRowIndex &gt; 0 and weightRowIndex &lt;= self.tblCargo.rows then
				measureTbl := self.allMeasurementControls[weightRowString].CMUI_MeasurementTable;
				//measureTbl.setValues( app.convertMeasurementForDisplay(weightMeasureType.shortName, totWeight) &amp; Space &amp; weightMeasureType.shortName);									//-TFS39911
				measureTbl.setValues( app.convertMeasurementForDisplay(productWeightMeasureType.shortName, totWeight) &amp; Space &amp; productWeightMeasureType.shortName);	//+TFS39911
				measureTbl.lostFocus( measureTbl );
			endif;
			if volumeRowIndex &gt; 0 and volumeRowIndex &lt;= self.tblCargo.rows then
				measureTbl := self.allMeasurementControls[volumeRowString].CMUI_MeasurementTable;
				//measureTbl.setValues( app.convertMeasurementForDisplay(volumeMeasureType.shortName, totVolume) &amp; Space &amp; volumeMeasureType.shortName);									//-TFS39911
				measureTbl.setValues( app.convertMeasurementForDisplay(productVolumeMeasureTYpe.shortName, totVolume) &amp; Space &amp; productVolumeMeasureTYpe.shortName);	//+TFS39911
				measureTbl.lostFocus( measureTbl );
			endif;
			
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkIfLockedDown" id="2b0fa0af-38e6-4023-9162-1a576d1c8237">
        <source>checkIfLockedDown();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	row : Integer;
	
begin

	if self.tblCargo.column &lt;&gt; 2 then	//02 Sep 2013	NDL	Par 32368
		return;
	endif;

	if self.lockedDown then
		row := tblCargo.row;
		if row &gt; 0 and row &lt;&gt; tblCargo.getRow(ETRow_Location) then
			self.msgBox( app.getErrorString1(No_Handheld_Chg_allowed, tblCargo.getCellText(row,1)) ,app.getErrorString(Warning) ,MsgBox_OK_Only, true );
			self.setErrorPostionFor(ETRow_Location);
			self.setComboValues;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
