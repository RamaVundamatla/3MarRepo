    <JadeMethod name="setControlsForAddEdit" id="46dd150c-e72f-4e29-a1db-4a19fa8de184">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
begin
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;	


	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		
		if theForm.mulSelect1.visible then
			theForm.mulSelect1.setSelected(null);										
		endif;
		theForm.tblInput1.moveFirst();	
	
		if theForm.mulSelect1.isMySheetVisible then
			theForm.mulSelect1.setFocus;
		else
			theForm.tblInput1.setFocus;
		endif;	
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.HMS_Object);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);

	endif;

	

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="bc6205da-1bca-4133-8145-c91635c2e45c">
        <updating/>
        <source>setCtrlsForView() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput2.userInputEnabled := false;
	theForm.tblInput3.userInputEnabled := false;
	theForm.mulSelect2.userInputEnabled := false;
	theForm.mulSelect1.userInputEnabled := false;
	theForm.mulSelect3.userInputEnabled := false;
	theForm.mulSelect41.userInputEnabled := false;		
	theForm.mulSelect42.userInputEnabled := false;	      

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="6f21699f-b92d-4dd3-8008-60ecc0d594b7">
        <updating/>
        <source>setupThumbnailDetails() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	defName	: String;
	theForm : SOP_TableMaintForm;
begin
 
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_HMSTblData);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	
	defName := self.getDefNameTblInput();
	
	if defName = null then //saftey net
		defName := ETDef_HMSTblInput;
	endif;
	
	theForm.initTblInput(theForm.tblInput1, defName);
	theForm.shtTblInput1.visible := true;


end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="68b1bf59-76c7-4c51-9db5-3806ce5abceb">
        <updating/>
        <source>showThumbnail(pObj: HMS_Object) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setTableFromObject(pObj, 'setTableFromObjectSpecial');

end;</source>
        <Parameter name="pObj" type="HMS_Object"/>
    </JadeMethod>
</Class>
