<Class name="CM_LoggingOrganisation" id="847c2523-a6ca-4886-bd58-a7cee7247541">
    <superclass name="CM_Code"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myRoot" id="955108c2-cd77-442d-955b-1809287f614c">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>protected</access>
        <Inverse name="CM_Root::allLoggingOrganisations"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="445861f2-b9ff-49eb-aade-7c09db0fe750">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.isCodeGroupNOTRequired := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="205a8a5e-b3f5-49ec-8b58-3eb454982690">
        <updating/>
        <source>setForCreate(_proxy: CM_Code) updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="_proxy" type="CM_Code"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="48bbc053-31e5-4f0d-bd81-418ccb94aa93">
        <updating/>
        <source>setProxy(pCode, pDescription:String; _notAvailableForEntry:Boolean)updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.setSuperClassDetailsForProxy(pCode, pDescription,_notAvailableForEntry, null);
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="0459c95a-ff90-4442-a352-822f45beb742">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allLoggingOrganisations.includesKey(self.code) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	inheritMethod();
end;</source>
    </JadeMethod>
</Class>
