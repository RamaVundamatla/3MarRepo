    <JadeMethod name="populateFromBOL" id="5afd1cf2-22a7-45e4-94a7-5e6cb7d837e0">
        <source>populateFromBOL(_bol: CM_BOL; _bolItem: CM_BOLDtl);

vars
	consignee: CM_ConsigneeConsignor;
begin
	if _bol &lt;&gt; null then
		if _bol.loadPortCode &lt;&gt; null then
			self.cmbPOL.setObjectFromCode(_bol.loadPortCode);
		endif;
		if _bol.destinationPort &lt;&gt; null then
			self.cmbPOD.setObjectFromCode(_bol.dischargePort);  // PAR 32924
		endif;
	endif;
	
	if _bolItem &lt;&gt; null then
		if  _bolItem.consigneeCode &lt;&gt; null then
			consignee := app.myRoot.allConsigneeConsignors[_bolItem.consigneeCode];
			self.cmbConsignee.setIndexFromObject(consignee);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_bolItem" type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="populateFromDutyDocItem" id="cca603fd-4c20-4d89-bdf4-76101792477a">
        <updating/>
        <source>populateFromDutyDocItem(  ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901
20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)

*/

vars
	hsCode : String;
	hsCodeObj : CM_DutyDocHSCode;
	consignee : CM_ConsigneeConsignor;
	agent: CM_DutyDocAgent;
	dpl : Integer;
begin
	create agent transient;
	dpl := self.getRateEntryDecimalPlaces; // TFS 36954 MPD 20 Feb 2018
	
	self.txtID.text := self.myDutyDocItem.cargoId;
	self.txtID.enabled := false;	
	self.txtCargoDetail.text := self.myDutyDocItem.cargoDetails;
	self.txtOperator.text:=self.myDutyDocItem.operator;
	self.txtAgent.text:=self.myDutyDocItem.agent;
	self.txtVoyage.text:=self.myDutyDocItem.voyageDetails;
	
	hsCodeObj:= self.myDutyDocItem.getMyHSCode();
	
	if hsCodeObj &lt;&gt; null then
		self.cmbHSCodeCode.setIndexFromObject(hsCodeObj);
		self.setHSCodeDesc();
	endif;
	
	self.cmbConsignee.setIndexFromObject( self.myDutyDocItem.getMyConsignee);
	self.cmbPOD.setObjectFromCode(self.myDutyDocItem.pod);

	self.cmbPOL.setObjectFromCode(self.myDutyDocItem.pol);
	self.myAssistant.comboBoxBOLInsForVoyage(self.cmbBOL,self.myDutyDocItem.getMyVoyage,self.myDutyDocItem.getMyBOL.CM_BOLIn);
	//11 Mar 2013	NDL	Par 31273
	if self.cmbBOL.listIndex &lt; 1 and self.myDutyDocItem.bol.trimBlanks &lt;&gt; null then
		self.cmbBOL.text := self.myDutyDocItem.bol.trimBlanks;
	endif;
	self.txtDO.text:=self.myDutyDocItem.deliveryOrder;
	self.txtDOExp.setDate(self.myDutyDocItem.deliveryOrderExpiryDate);
	
	self.cmbPacking.listIndex := self.cmbPacking.findStringExact(1, agent.getPackingText(self.myDutyDocItem.packing));
	
	//self.txtOrigin.text := self.myDutyDocItem.origin;
	self.setCmbOrigin(self.myDutyDocItem.origin);	//08 Aug 2013	NDL	Par 32305
	self.txtQuantity.text := self.myDutyDocItem.quantity.String;
	self.txtVolume.text := self.myDutyDocItem.volume.asStringJMTWithPrecision(2,false);
	self.txtGrossWeight.text := self.myDutyDocItem.grossWeight.asStringWeightJMT;
	self.txtNetWeight.text := self.myDutyDocItem.netWeight.asStringWeightJMT;
	self.cmbCurrency.listIndex := self.cmbCurrency.findStringExact(1,self.myDutyDocItem.currency);
	//self.txtForeignValue.text := self.myDutyDocItem.foreignValue.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces,false);
	self.txtForeignValue.text := self.myDutyDocItem.foreignValue.asStringJMTWithPrecision(dpl,false);	// TFS 36954 MPD 20 Feb 2018
	self.txtLocalValue.text := self.myDutyDocItem.localValue.asCurrencyJMT;
	//self.txtLocalFreight.text := self.myDutyDocItem.freight.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces,false);
	self.txtLocalFreight.text := self.myDutyDocItem.freight.asStringJMTWithPrecision(dpl,false);	// TFS 36954 MPD 20 Feb 2018
	self.txtLocalIns.text := self.myDutyDocItem.insurance.asCurrencyJMT;
	self.txtNetValue.text := ( self.myDutyDocItem.localValue + self.myDutyDocItem.freight + self.myDutyDocItem.insurance).asCurrencyJMT;
	self.txtRatePercent.text := self.myDutyDocItem.dutyRate.asStringJMTWithPrecision(2,false);
	self.txtDutyCode.text := self.myDutyDocItem.dutyCode;
	self.txtDuty.text := self.myDutyDocItem.duty.asCurrencyJMT;

	self.grpCar.visible := self.myDutyDocItem.isCar;
	if self.myDutyDocItem.isCar then
		self.txtVCCNum.text := self.myDutyDocItem.CM_DutyDocCarItem.vccNo;
		self.txtVccDate.setDate( self.myDutyDocItem.CM_DutyDocCarItem.vccDate );
		self.cmbVehType.text := self.myDutyDocItem.CM_DutyDocCarItem.vehicleType;
		self.cmbVehMake.text := self.myDutyDocItem.CM_DutyDocCarItem.vehicleMake;
		self.cmbVehModel.text := self.myDutyDocItem.CM_DutyDocCarItem.vehicleModel;
		self.txtChassis.text := self.myDutyDocItem.CM_DutyDocCarItem.chassisNo;
		self.txtEngine.text := self.myDutyDocItem.CM_DutyDocCarItem.engineNo;
		self.cmbVehColour.text := self.myDutyDocItem.CM_DutyDocCarItem.color;
		self.txtNumPlate.text := self.myDutyDocItem.CM_DutyDocCarItem.numberPlate;
	endif;
	
	if self.myDutyDocItem.exemptDutyCode &lt;&gt; null or self.myDutyDocItem.exemptSource &lt;&gt; null or self.myDutyDocItem.exemptBenefit &lt;&gt; null then
		self.chkDutyExempt.value := true;
	else
		self.chkDutyExempt.value := false;
	endif;
	self.grpExempt.visible := self.chkDutyExempt.value;      // 34042

	self.txtDutyExempt.text := self.myDutyDocItem.exemptDutyCode;
	self.txtExemptSource.text := self.myDutyDocItem.exemptSource;
	self.txtExemptBenefit.text := self.myDutyDocItem.exemptBenefit;

epilog
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateFromTrackedItem" id="b1c06453-8aa2-412b-a90e-b78d21eec0a9">
        <updating/>
        <source>populateFromTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901
02/09/204			cnwma1  PAR# 34046 Consignee duplicates
*/

vars
	operator : CM_Operator;
	freightForwarder : CM_ConsigneeConsignor;
	voyage		: CM_Voyage;
	isoProdDesc : String;
begin

	self.myTrackedItem := _ti;

	self.txtID.text := _ti.id;

	self.txtCargoDetail.text := _ti.cargoTypeDescr; 
	isoProdDesc:= _ti.getProductOrISODescr;
	if isoProdDesc &lt;&gt; null then
		self.txtCargoDetail.text :=self.txtCargoDetail.text &amp; " - " &amp;isoProdDesc;
	endif;
	self.txtOperator.text:=_ti.operatorCode;
	voyage:=_ti.myVoyage;
	
	if voyage &lt;&gt; null then
		self.txtVoyage.text:=_ti.vesselCode &amp; " " &amp; voyage.code &amp; " " &amp; voyage.arrivedDT.asStringJMT;
	endif;
	operator:=_ti.myOperator;
	
	if operator &lt;&gt; null then
		freightForwarder:=operator.allFFsForBookRefUpdate.first;
		if freightForwarder &lt;&gt; null then
			self.txtAgent.text:=freightForwarder.code;
		endif;
	endif;
	
	if not self.isSaveNext then
		if self.myDutyDoc &lt;&gt; null then // 02/09/2014  cnwma1 PAR#34046
			self.cmbConsignee.setIndexFromObject(self.myDutyDoc.getMyConsignee);
		else
			self.cmbConsignee.setIndexFromObject( _ti.myConsignee);
		endif;
		
		self.cmbPOD.setObjectFromCode(_ti.dischargePort);  // PAR 32924
		self.cmbPOL.setObjectFromCode(_ti.loadPort);
		
		self.myAssistant.comboBoxBOLInsForVoyage(self.cmbBOL,_ti.myVoyage,_ti.myReceivalBOL);
		self.populateFromBOL(_ti.myReceivalBOL, _ti.myBOLDtl);
		
		self.cmbPacking.listIndex := -1;
		//self.txtOrigin.text := null;
		self.cmbOrigin.listIndex := -1;	//08 Aug 2013	NDL	Par 32305
		self.txtQuantity.text := null;
		self.txtVolume.text := null;
		self.txtGrossWeight.text := null;
		self.txtNetWeight.text := null;
		self.cmbCurrency.listIndex := -1;
		self.txtForeignValue.text := null;
		self.txtLocalValue.text := null;
		self.txtLocalFreight.text := null;
		self.txtLocalIns.text := null;
		self.txtNetValue.text := null;
		self.txtRatePercent.text := null;
		self.txtDutyCode.text := null;
		self.txtDuty.text := null;
	
		self.grpCar.visible := _ti.isCar;
		self.txtVCCNum.text := null;
		self.txtVccDate.setDate( null );
		self.cmbVehType.listIndex := -1;
		self.cmbVehMake.listIndex := -1;
		self.cmbVehModel.listIndex := -1;
		self.txtChassis.text := null;
		self.txtEngine.text := null;
		self.cmbVehColour.listIndex := -1;
		self.txtNumPlate.text := null;
		
		self.chkDutyExempt.value := false;
		self.txtDutyExempt.text := null;
		self.txtExemptSource.text := null;
		self.txtExemptBenefit.text := null;
		
		self.doClickDutyExempt();
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="populateTextBoxDecimals" id="76c2160e-20d4-4ba3-a1c2-35485fa05d53">
        <source>populateTextBoxDecimals();
/*

Purpose:			

