    <JadeMethod name="displayMeasurementFields" id="9bfed560-78f1-4f33-bc51-4dd2ae62c168">
        <updating/>
        <source>displayMeasurementFields() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2013	cnwndl1	Initial creation	Paer 32172

*/

vars

begin

	self.weightType := app.getDefaultMeasurementForType(Type_Weight);
	self.widthType := app.getDefaultMeasurementForType(Type_Width);
	self.heightType := app.getDefaultMeasurementForType(Type_Height);
	self.lengthType := app.getDefaultMeasurementForType(Type_Length);
	
	self.tblIHeight.setup(Type_Height, self.backColor);
	self.tblIHeight.tabKey := J_key_Tab;
	self.tblIHeight.visible := true;
	
	self.tblILength.setup(Type_Length, self.backColor);
	self.tblILength.tabKey := J_key_Tab;
	self.tblILength.visible := true;
	
	self.tblIWidth.setup(Type_Width, self.backColor);
	self.tblIWidth.tabKey := J_key_Tab;
	self.tblIWidth.visible := true;
	
	self.tblOHeight.setup(Type_Height, self.backColor);
	self.tblOHeight.tabKey := J_key_Tab;
	self.tblOHeight.visible := true;
	
	self.tblOLength.setup(Type_Length, self.backColor);
	self.tblOLength.tabKey := J_key_Tab;
	self.tblOLength.visible := true;
	
	self.tblOWidth.setup(Type_Width, self.backColor);
	self.tblOWidth.tabKey := J_key_Tab;
	self.tblOWidth.visible := true;
	
	self.tblDeckHeight.setup(Type_Height, self.backColor);
	self.tblDeckHeight.tabKey := J_key_Tab;
	self.tblDeckHeight.visible := true;
	
	self.tblMaxCHeight.setup(Type_Height, self.backColor);
	self.tblMaxCHeight.tabKey := J_key_Tab;
	self.tblMaxCHeight.visible := true;
	
	self.tblTotHeight.setup(Type_Height, self.backColor);
	self.tblTotHeight.tabKey := J_key_Tab;
	self.tblTotHeight.visible := true;
	self.tblTotHeight.enabled := true;
	
	self.tblMaxCWeight.setup(Type_Weight, self.backColor);
	self.tblMaxCWeight.tabKey := J_key_Tab;
	self.tblMaxCWeight.visible := true;
	
	self.tblTare.setup(Type_Weight, self.backColor);
	self.tblTare.tabKey := J_key_Tab;
	self.tblTare.visible := true;
	
	self.tblTotWeight.setup(Type_Weight, self.backColor);
	self.tblTotWeight.tabKey := J_key_Tab;
	self.tblTotWeight.visible := true;
	self.tblTotWeight.enabled := true;

epilog

end;</source>
