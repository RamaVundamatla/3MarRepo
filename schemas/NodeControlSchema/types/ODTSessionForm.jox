begin
	parent.currentForm:=self;
end;</source>
    </JadeMethod>
    <JadeMethod name="addFile" id="0e9f9f4a-f480-4eaf-805d-d530c4dc537e">
        <updating/>
        <source>addFile(inFileName:String; clear:Boolean) updating;

begin
	if inFileName = null then
		return;
	endif;
	monitorFileName:=inFileName;
	if clear then
		listBox.clear;
	endif;
	doingWinZip:=false;
	doingJdbutil:=false;
	file.usePresentationFileSystem:=false;  // look on server first
	file.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	file.fileName:=inFileName;
	if not file.isAvailable then
		global.beep;
		addLine("file "&amp;file.fileName&amp;" not found");
		file.fileName:=null;
	endif;
	setCaption;
	prevFileLength:=0;
	if inFileName="immediate" then
		return;
	endif;
	if file.fileLength&gt;1 then
		if file.fileLength&gt;400000 then
			file.seek(file.fileLength-400000);
			file.readLine;  // skip partial line
		endif;
	
		addLinesFromFile(0);
	endif;
	findFileNumber;
	
	refreshNow;
	addLine(null);
	listBox.removeItem(listBox.listIndex);
	scrollToBottom;
end;</source>
        <Parameter name="inFileName" type="String"/>
        <Parameter name="clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addLine" id="1409caae-fdf6-471f-b96d-0f1cc277d36d">
        <source>addLine(s:String);

vars
	i,j:Integer;
	t,oid:String;
begin
	if listBox.listCount&gt;7000 then
		listBox.removeItem(1);
		listBox.topIndex:=listBox.topIndex-1;
	endif;
	t:=s;
/*	i:=t.pos("TDB:", 1);
	if i &lt;&gt; 0 then
		i:=i+8;
		j:=i;
		oid:=t.scanUntil(":",j).asOid.String;
		if oid &lt;&gt; "Object/0.0" then
			t:=s[1:i-1]&amp;oid&amp;s[j:end];
		endif;
	endif; /**/
	listBox.addItem(t);
/*	if s.cnContains(": Exception")
	then
		app.playSound("C:\WINDOWS\Media\chord.wav");
//		listBox.itemSelected[listBox.listCount]:=true;
		listBox.itemBackColor[listBox.listCount]:=Red;
	endif;
	if s.cnContains("Locked by")
	then
		app.playSound("C:\WINDOWS\Media\Windows Feed Discovered.wav");
//		listBox.itemSelected[listBox.listCount]:=true;
		listBox.itemBackColor[listBox.listCount]:=Yellow;
	endif;
/*	if alarmTrigger&lt;&gt;null and s.cnContains(alarmTrigger) then
		if alarmAction="highlight" then
			listBox.itemSelected[listBox.listCount]:=true;
		elseif alarmAction="beep" then
			global.beep;
		endif;
	endif;
	if doingWinZip and (s.cnContains("Warning:") or s.cnContains("Error:")) then
		listBox.itemSelected[listBox.listCount]:=true;
		global.beep;
	endif; */
	scrollToBottom;
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="addLinesFromFile" id="56309e0e-15a6-48d9-984b-6d35461799b4">
        <updating/>
        <source>addLinesFromFile(delay:Integer) updating;

vars
	i:Integer;
	s:String;
begin
	prevFileLength:=file.fileLength;
	while not file.endOfFile and file.currentOffset&lt;prevFileLength do
		s:=file.readLine;
		if s&lt;&gt;null then
//			write s.Binary.display;
			if doingJdbutil and s.length&gt;50 and s[25:25]=Cr&amp;"Backup and Compress file" then
				i:=s.pos("backup complete",50);
				i:=s[1:i].reversePos(Cr);
				s:=s[1:24]&amp;s[i+4:end];
//				continue;
			endif;
			addLine(s);
			if delay&gt;0 and prevFileLength-file.currentOffset&lt;200 then
				refreshNow;
			endif;
		endif;
	endwhile;
	file.close;
	setCaption;
end;</source>
        <Parameter name="delay" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToFileNames" id="5aee6cd3-c4c9-4524-8f98-e8a267ce947b">
        <updating/>
        <source>addToFileNames(item:String io) updating;

vars
	drive:String;
	i,j,k:Integer;
begin
	// build file name list into array, first array item is original folder that was backed up
	i:=item.pos("Zip file: ",1);
	if i&lt;&gt;0 then
		if item[i+10]="d" then
			drive:="e:\";
		else
			drive:="d:\";
		endif;
		k:=item.pos("_",14)+1;  // envName follows the _ eg 20020411_SkiSbs.zip
		j:=1;
		fileNames.add(drive&amp;item[k:end].scanUntil(".",j));
	endif;
	if item.toLower.cnContains("error:") then
		addLine(item);
	endif;
	k:=item.pos(":",1)+1;
	if k&lt;&gt;1 and item[k]&lt;&gt;"\" and item[k]&lt;&gt;" " then
		item.scanWhile("0123456789 ",k);
		item.replaceChar("/","\");
		if item[item.length]&lt;&gt;"\" then
			fileNames.add(drive&amp;item[k:end].trimRight.toLower);
		endif;
	endif;
end;</source>
        <Parameter name="item" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="bHide_click" id="0992a337-b6d5-4703-b90d-5d7d7a3ac096">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bHide_click(btn: Button input) updating;

begin
	listBox.top:=0;
	listBox.height:=clientHeight-3;
	listBox.zOrder(1);
	listBox.setFocus;
	resize;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bRun_click" id="69d2177f-cef6-4d15-8fee-4d9bad15d937">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bRun_click(btn:Button input) updating;

begin
	if oEnv.value then
		cbEnv.setFocus;
		/*if cbAction.text=Start_Env then
			logMessage("now monitoring and logging transaction start/stop notifications");
			beginNotification(system, 778, Response_Continuous, 0);
			beginNotification(system, 779, Response_Continuous, 0);
			app.logMessage("now monitoring and logging transaction start/stop notifications");
			return;
		endif;
		if cbAction.text=Stop_Env then
			logMessage("no longer monitoring and logging transaction start/stop notifications");
			endNotification(system, 778);
			endNotification(system, 779);
			app.doWindowEvents(2000);
			missingFiles.purge;
			app.logMessage("no longer monitoring and logging transaction start/stop notifications");
			return;
		endif;/**/
		if cbEnv.listIndex&lt;1 and cbAction.text&lt;&gt;Backup and cbAction.text&lt;&gt;Show_Databases and cbAction.text&lt;&gt;Show_All_Nodes then
			logMessage("please select an environment");
			global.beep;
			return;
		endif;
		setEnv(cbEnv.text);

		if     cbAction.text=Backup then			runBackup;
		elseif cbAction.text=Schema_Extract then	runSchemaExtracts;
		elseif cbAction.text=Load_Hotfix then		runHotfix;
		elseif cbAction.text=Load_Schemas then		runLoadSchemas;
		elseif cbAction.text=Load_Licence then		runJadReg;
		elseif cbAction.text=Show_Jade_Version then	runVersionInfo;
		elseif cbAction.text=Stop_Fat_Clients then	runKiller("fat");
		elseif cbAction.text=Stop_All_Clients then	runKiller("all");
		elseif cbAction.text=Start_Env then			runStartEnv;
		elseif cbAction.text=Stop_Env then			runStopEnv;
		elseif cbAction.text=Show_Nodes then		runPV("jad* -l*\"&amp;envName&amp;"\*");
		elseif cbAction.text=Show_All_Nodes then	runPV("*jad* -l");
		elseif cbAction.text=Show_Databases then	runPV("jadrap* -e");
		elseif cbAction.text=Start_Monitor then		runThinClient("JadeMonitorSchema","JadeMonitor");
		elseif cbAction.text=Start_Jade_Dev then	runThinClient("JadeSchema","Jade");
		else
			logMessage("please select an action");
			global.beep;
			return;
		endif;

	elseif oRun.value then
		cmdLine:=tCmdLine.text.trimBlanks;
		if cmdLine[1:7]="verify " then				backupVerify;
		elseif cmdLine[1:3]="pd " then				runPd;
		else										runCmdLine(tCmdLine.text.trimBlanks);
		endif;
		tCmdLine.setFocus;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="backupEnv" id="b9a78421-16b0-4850-9348-83d2b6635a15">
        <updating/>
        <source>backupEnv() updating;
//	backs up the given environment (eg "d:\actax") using WinZip to the other drive
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	i,result,retCode:Integer;
	path,exe,backupLoc,zipFile,zipFile2,zipFile3:String;
	f:File;
begin
	doingWinZip:=true;
	logMessage("");
	logMessage(app.computerName.toLower&amp;"&gt;"&amp;"backup "&amp;env);

	if env[1]="s" then
		backupLoc:="r:\zip\";
	else
		backupLoc:="s:\zip\";
	endif;
	if env.cnContains("\schemas\backup") then
		backupLoc:=backupLoc&amp;"schemas/";
	endif;
	
	create f;
	f.usePresentationFileSystem:=false;

	if envName="SkiSbs_Lobj_1" then  // second part of SkiSbs, Lobj_xxx9n structures only
		zipFile2:=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end]&amp;"_Lobj_1.zip";  // must split up SkiSbs// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		f.fileName:=zipFile2;
		if f.isAvailable then f.purge; endif;
		cmdLine:="c:\winnt\wzzip -ef -r -P -b"&amp;backupLoc[1:backupLoc.length-1]&amp;" "
				&amp;" -x*\c_system_old\* "&amp;zipFile2&amp;" "
				&amp;env&amp;"\server\c_system\Lobj_???9?.dat "
				&amp;env&amp;"\server\c_system\_control.dat ";  // include a known file in case there aren't any Lobjs
		logMessage("cmd2="&amp;cmdLine);
		setupCP;
		app.startApplicationWithParameter(currentSchema.name,"CommandProcessor",cp);

	elseif envName="SkiSbs_Lobj_2" then
		// third part of SkiSbs - remaining Lobj structures
		zipFile3:=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end]&amp;"_Lobj_2.zip";  // must split up SkiSbs// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		f.fileName:=zipFile3;
		if f.isAvailable then f.purge; endif;
		cmdLine:="c:\winnt\wzzip -ef -r -P -b"&amp;backupLoc[1:backupLoc.length-1]&amp;" "
				&amp;"-xLobj_???9?.dat -x*\c_system_old\* "&amp;zipFile3&amp;" "
				&amp;env&amp;"\server\c_system\Lobj*.dat "
				&amp;env&amp;"\server\c_system\_control.dat ";  // include a known file in case there aren't any Lobjs
		logMessage("cmd3="&amp;cmdLine);
		setupCP;
		app.startApplicationWithParameter(currentSchema.name,"CommandProcessor",cp);
		
	elseif envName="HmlHML_Lobj" then
		// second part of HmlHML - Lobj structures
		zipFile2:=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end]&amp;"_Lobj.zip";  // must split up HmlHML// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		f.fileName:=zipFile2;
		if f.isAvailable then f.purge; endif;
		cmdLine:="c:\winnt\wzzip -ef -r -P -b"&amp;backupLoc[1:backupLoc.length-1]&amp;" "
				&amp;" -x*\c_system_old\* "&amp;zipFile2&amp;" "
				&amp;env&amp;"\server\c_system\Lobj*.dat "
				&amp;env&amp;"\server\c_system\_control.dat ";  // include a known file in case there aren't any Lobjs
		logMessage("cmd3="&amp;cmdLine);
		setupCP;
		app.startApplicationWithParameter(currentSchema.name,"CommandProcessor",cp);
		

	else  // normal environment
		// delete old zip file if any
		zipFile :=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end]&amp;".zip";// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		zipFile.replaceChar("\","_");
		zipFile[3]:="\"; zipFile[7]:="\";
		f.fileName:=zipFile;
		if f.isAvailable then f.purge; endif;
	
		// do the zip
		cmdLine:="c:\winnt\wzzip -ef -r -P -b"&amp;backupLoc[1:backupLoc.length-1];
		if env="t:\SkiHis" then
							
		elseif env="r:\TsbProd" then
			cmdLine:=cmdLine&amp;" -x*\c_system\O_*.dat -x*\c_system\C_*.dat"; 	// exclude all user data
							
		elseif env="r:\HmlHML" then
			cmdLine:=cmdLine&amp;" -x*\Lobj*.dat -x*\Coll*.dat";  // exclude Lobj for first bit
							
		elseif env="u:\HmlPPrint" or env="u:\HmlPPrnt2" then  // jhp 20060301
			cmdLine:=cmdLine&amp;" -x*\c_misc\ro\*";  // exclude numerous print files
																	
		elseif env="t:\SkiSbs" then
			cmdLine:=cmdLine&amp;" -x*\Lobj*.dat -x*\Global*.dat";  // exclude Lobj for first bit
		endif;
		cmdLine:=cmdLine&amp;" -x*\c_system_old\* "&amp;zipFile;
/*		if env="t:\SkiSbs" then
			cmdLine:=cmdLine&amp;" "&amp;env&amp;"B\doc\*.*";
		endif; */  // jhp 20050314 removed SkiSbsB from backup
		cmdLine:=cmdLine&amp;" "&amp;env&amp;"\*.*";
		logMessage("cmd="&amp;cmdLine);
		setupCP;
		if app.name="SchemaBackup" or app.name="EnvBackup" then  // jhp 20050314
			beginTransientTransaction;
			cp.reportWhenFinished:=true;
			commitTransientTransaction;
			cp.run;
			beginTransientTransaction;
			delete cp;
			commitTransientTransaction;
		else
			app.startApplicationWithParameter(currentSchema.name,"CommandProcessor",cp);
		endif;
	endif;
epilog
	delete f;
end;</source>
    </JadeMethod>
    <JadeMethod name="backupMixed" id="32d24575-9973-47ef-8170-9714ba4a7167">
        <updating/>
        <source>backupMixed() updating;
//	back up an environment, some files (listed below) with jdbutilb, the rest with wzzip
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	i:Integer;
	backupLoc,backupDir,zipFile:String;
	hugeFiles:StringArray;
begin
	doingJdbutil:=true;
	logMessage("");
	logMessage(app.computerName.toLower&amp;"&gt;"&amp;"jdbutil backup (partial) "&amp;env);
	create hugeFiles transient;

	//all  backup to "s:\zip\"
	backupLoc:="s:\zip\";	
	
	// exclusion list
	if env="t:\SkiHis" then
		hugeFiles.add("Global_Inv96");
		hugeFiles.add("Global_Mor97");
		hugeFiles.add("Lobj_Inv96");
		hugeFiles.add("Lobj_Mor97");
		
	elseif env="r:\TsbProd" then
		hugeFiles.add("O_AllEvents");
		hugeFiles.add("C_AllEvents");
		hugeFiles.add("O_Accounts");
		hugeFiles.add("C_Accounts");
			
	elseif envName="Creator" then
		hugeFiles.add("_userscm");
		hugeFiles.add("_userxrf");
	endif;

	// set up backup directory
	backupDir:=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end];// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	zipFile:=backupDir&amp;"\"&amp;env[4:end]&amp;".zip";
	app.makePathIfPossible(zipFile,false);

	if hugeFiles.size&gt;0 then
		// use jdbutilb for any huge files (&gt;4gb)
		cmdLine:=env&amp;"\server\c_bin\jdbutilb.exe"
				&amp;" path="&amp;env&amp;"\server\c_system"
				&amp;" ini="&amp;env&amp;"\server\c_bin\"&amp;env[4:end]&amp;".ini"
				&amp;" backup";
		foreach i in 1 to hugeFiles.size do
			cmdLine:=cmdLine&amp;" "&amp;hugeFiles[i];
		endforeach;
		cmdLine:=cmdLine&amp;" backupDir="&amp;backupDir
						&amp;" compress overwrite";
		logMessage("cmd="&amp;cmdLine);
		setupCP;
		app.startApplicationWithParameter(currentSchema.name,"CommandProcessor",cp);
	endif;
epilog
	delete hugeFiles;
end;</source>
    </JadeMethod>
    <JadeMethod name="backupVerify" id="ddab42d8-dbbb-4d11-962d-5154cad1953b">
        <updating/>
        <source>backupVerify() updating;

vars
	s,zipFileName:String;
begin
	doingWinZip:=true;
	if processLogFileName&lt;&gt;null then
		listBox.clear;
	endif;
	processLogFileName:=null;
	fileNames.clear;
	missingFiles.clear;
	addFile("immediate", true);
	zipFileName:=tCmdLine.text.trimBlanks[8:end];
	cmdLine:="c:\winnt\wzzip -vb "&amp;zipFileName;
	if setupCP=false then
		tCmdLine.setFocus;
		return;
	endif;
	
	addLine("");
	addLine("immediate&gt;"&amp;tCmdLine.text);
	app.startApplicationWithParameter(currentSchema.name,"CommandProcessor",cp);
	waitForCPInit;
	doingBackupVerify:=true;
	getResults;  // show the resutls as they arrive in stdOut
	doingBackupVerify:=false;
	
//	foreach s in fileNames do
//		addLine(s.display);
//	endforeach;
	addLine((fileNames.size-1).integerFormat&amp;" files found in "&amp;zipFileName);

	if fileNames.size&gt;0 then
		s:=fileNames[1];
		fileNames.removeAt(1);
	endif;
	addLine("verifying against "&amp;s);
	findMissingFiles(s);
	if missingFiles.size=0 then
		addLine("no missing files");
	else
		addLine("");
		addLine(missingFiles.size.integerFormat&amp;" Missing Files:");
		foreach s in missingFiles do
			addLine(s.display);
		endforeach;
		addLine("");
	endif;
	if fileNames.size=0 then
		addLine("no extra files");
	else
		addLine("");
		addLine(fileNames.size.integerFormat&amp;" Extra Files:");
		foreach s in fileNames do
			addLine(s.display);
		endforeach;
		addLine("");
	endif;
	
	addLine("result="&amp;cp.result.String&amp;","&amp;cp.exitCode.String);
	tCmdLine.setFocus;
	scrollToBottom;
	sendFinishMsg;
	doingWinZip:=false;
end;</source>
    </JadeMethod>
    <JadeMethod name="cbEnv_keyPress" id="12c5deae-f9f2-42ca-9bdb-bef1f980394b">
        <controlMethod name="ComboBox::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cbEnv_keyPress(combobox:ComboBox input; keyCharCode:Integer io) updating;

begin
	if keyCharCode=58 or keyCharCode=92 then  // colon or backslash
		combobox.style:=0;
	endif;
	if combobox.text="" then  // default to selection from text
		combobox.style:=3;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkForNewFile" id="268740c9-09a2-43b5-9033-926ce30d5502">
        <updating/>
        <source>checkForNewFile() updating;

vars
	f:File;
begin
	create f;
	f.usePresentationFileSystem:=file.usePresentationFileSystem;
	f.fileName:=fileStem&amp;(fileNumber+1).String&amp;fileSuffix;
	if f.isAvailable then
		addLine('&gt;&gt;&gt; opening file '&amp;f.fileName&amp;' &lt;&lt;&lt;');
		addFile(f.fileName, false);
	endif;
epilog
	delete f;
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="02aa1d43-b9d5-4ae2-874d-1226d6ad1e17">
        <updating/>
        <source>create() updating;

begin
	create file;
	file.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	file.mode:=File.Mode_Input;
	file.maxRecordSize:=16000;
	file.usePresentationFileSystem:=false;

	create processLogFile;
	processLogFile.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version
	processLogFile.mode:=File.Mode_Append;
	processLogFile.usePresentationFileSystem:=false;

	create fileNames;
	create missingFiles;
	create adm;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayFolder" id="bff4ce4e-381a-43ca-8ccc-f20ac9ed9eeb">
        <updating/>
        <source>displayFolder(dir:String) updating;

vars
	folder:FileFolder;
	fileNode:FileNode;
begin
	create folder;
	folder.fileName:=dir;
	folder.usePresentationFileSystem:=false;
	if folder.isAvailable then
		foreach fileNode in folder.files do
			if fileNode.isKindOf(File) then
				addLine(fileNode.fileName);
			else
//				addLine(fileNode.fileName&amp;"\");
				if not cmdLine.cnContains(":1") then
					displayFolder(fileNode.fileName);
				endif;
			endif;
		endforeach;
	endif;
epilog
	delete folder;
end;</source>
        <Parameter name="dir" type="String"/>
    </JadeMethod>
    <JadeMethod name="doCmd" id="16b11f94-cef1-43c9-8835-fd41c34ce029">
        <updating/>
        <source>doCmd(cmd:String):String updating;

vars
	doCp:CommandProcessor;
	s,myEnv:String;
begin
	myEnv:=envName;
	beginTransientTransaction;
	create doCp sharedTransient;
	doCp.cmdLine:=cmd;
	commitTransientTransaction;

	doCp.run;
	s:=doCp.stdOut;
	while s.length&gt;2 and s[1:2]=CrLf do
		s:=s[3:end];  // chop leading CrLfs
	endwhile;
	while s.length&gt;2 and s[s.length-1:2]=CrLf do
		s:=s[1:s.length-2];  // chop trailing CrLfs
	endwhile;
	return s;
epilog
	setEnv(myEnv);
	beginTransientTransaction;
	delete doCp;
	commitTransientTransaction;
end;</source>
        <Parameter name="cmd" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doFind" id="5151be32-3739-480e-a60d-4c2dd015bd21">
        <updating/>
        <source>doFind(next,backwards:Boolean) updating;

vars
	i,j,ifirst,ilast,istep:Integer;
	found:Boolean;
begin
	ifirst:=listBox.listIndex;
	if backwards then
		ilast:=1;
		istep:=-1;
	else
		ilast:=listBox.listCount;
		istep:=1;
	endif;
	
	if next then
		ifirst:=ifirst+istep;
		foreach i in ifirst to ilast step istep do
			if listBox.itemText[i].toLower.contains(findText) then
				listBox.listIndex:=i;
				found:=true;
				break;
			endif;
		endforeach;
	
	else
		foreach i in ifirst to ilast step istep do
			listBox.itemBackColor[i]:=White;
		endforeach;
		read findText;
		if findText = null then
			return;
		endif;
		findText:=findText.toLower;
		foreach i in ifirst to ilast step istep do
			if listBox.itemText[i].toLower.contains(findText) then
				if not found then
					listBox.listIndex:=i;
				endif;
				listBox.itemBackColor[i]:=LightYellow;
				found:=true;
			endif;
		endforeach;
	endif;
	if not found then
		global.beep;
	endif;
end;</source>
        <Parameter name="next" type="Boolean"/>
        <Parameter name="backwards" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="editCopy" id="c5ed6a90-4d84-43da-af82-7351e52fae79">
        <updating/>
        <source>editCopy() updating;

vars
	i,j:Integer;
	s,t:String;
begin
	foreach i in 1 to listBox.listCount where listBox.itemSelected[i]=true do
		s:=s&amp;listBox.itemText[i]&amp;CrLf;
	endforeach;
	app.copyStringToClipboard(s);
end;</source>
    </JadeMethod>
    <JadeMethod name="extractSchema" id="d171b57a-6e6a-4eb2-bb68-417ce6a981df">
        <updating/>
        <source>extractSchema(schemaName:String) updating;

vars
	path,schemaPath,param:String;
	i,j:Integer;
begin
	if cp.result&lt;&gt;0 or cp.exitCode&lt;&gt;0 then  // error on previous schema
		return;
	endif;
	logMessage(null);
	logMessage("extracting "&amp;schemaName&amp;"...");
	doingSchemaExtract:=true;
	path:=env&amp;"\server\c_bin";
	i:=env[4:end].pos("\",1)+4;
	schemaPath:=env&amp;"\schemas\backup\";
	app.makePathIfPossible(schemaPath,false);

	if adm.versionInfo(envName)[1:1]="5" then
		param:="A, "&amp;schemaPath&amp;schemaName&amp;".scm, "&amp;schemaPath&amp;schemaName&amp;".ddb, "&amp;schemaName;
		cmdLine:=path&amp;"\jadloadb ini="&amp;path&amp;"\"&amp;env[i:end]&amp;".ini"&amp;" path="&amp;env&amp;"\server\c_system"&amp;" server=multiUser"
			&amp;" schema=JadeSchema app=Jade"
			&amp;" executeSchema=JadeSchema executeClass=Schema executeMethod=extractBatch"
			&amp;" executeParam="&amp;'"'&amp;param&amp;'" executeTransient=true';
	else  // use jadclient for Jade 6
		param:=" Single "&amp;schemaPath&amp;schemaName&amp;".scm "&amp;schemaPath&amp;schemaName&amp;".ddb "&amp;schemaName;
		cmdLine:=path&amp;"\jadclient ini="&amp;path&amp;"\"&amp;env[i:end]&amp;".ini"&amp;" path="&amp;env&amp;"\server\c_system"&amp;" server=multiUser"
			&amp;" schema=JadeSchema app=JadeBatchExtract"&amp;" endJade"&amp;param;
	endif;
//	logMessage(cmdLine);
	setupCP;
	
	app.startApplicationWithParameter(currentSchema.name,"CommandProcessor",cp);
	while cp.myCP=null do  // wait for CommandProcessor to initialise
		app.doWindowEvents(250);
	endwhile;
	while global.isValidObject(cp.myCP) do  // wait for it to finish
		app.doWindowEvents(250);
	endwhile;
	doingSchemaExtract:=false;
	if cp.result=0 and cp.exitCode=0 and app.mySpoolerServerJPS.fileExists(schemaPath&amp;schemaName&amp;".scm")=false then
		beginTransientTransaction;
		cp.exitCode:=14;
		commitTransientTransaction;
		logMessage(schemaPath&amp;schemaName&amp;".scm file missing");
	endif;
	if cp.result&lt;&gt;0 or cp.exitCode&lt;&gt;0 then
		if app.myCommandProcessor&lt;&gt;null then  // pass fail back to JCF
			beginTransientTransaction;
			app.myCommandProcessor.result:=cp.result;
			app.myCommandProcessor.exitCode:=cp.exitCode;
			commitTransientTransaction;
		endif;
		logMessage(schemaName&amp;" extract failed");
	else
		logMessage(schemaName&amp;" extract completed");
	endif;
end;</source>
        <Parameter name="schemaName" type="String"/>
    </JadeMethod>
    <JadeMethod name="findFileNumber" id="7b9113f3-4fc1-4a90-bc54-9d85eb721237">
        <updating/>
        <source>findFileNumber() updating;

vars
	i,j,len,pos:Integer; s,t:String;
begin
	fileStem:="";
	fileNumber:=0;
	fileSuffix:="";
	s:=file.fileName;
	len:=s.length;
	if s[len-3:4] &lt;&gt; '.log' then
		return;  // not a versioned log file
	endif;
	
	foreach i in 1 to 255 do
		pos:=len-3-i;
		if not s[pos].isNumeric then
			break;
		endif;
		if pos = 1 then
			return;
		endif;
	endforeach;
	fileStem:=s[1:pos];
	fileNumber:=s[pos+1:i-1].Integer;
	fileSuffix:=s[len-3:4];
end;</source>
    </JadeMethod>
    <JadeMethod name="findLatestFile" id="19c930ed-0138-4ca8-b52b-f54c688f2ae1">
        <updating/>
        <source>findLatestFile(stem,suffix:String; number:Integer):String updating;

vars
	i,j,lowestNum:Integer;
	s,t,highestName:String;
	f:File;
begin
	create f;
	f.usePresentationFileSystem:=false;
	foreach i in 0 to 999 do
		f.fileName:=stem&amp;(number+i).String&amp;suffix;
		if f.isAvailable then
			if lowestNum = 0 then
				lowestNum:=number+i;
			endif;
			highestName:=f.fileName;
		endif;
		if number+i &gt; lowestNum+100 then
			break;
		endif;
	endforeach;
	return highestName;
epilog
	delete f;
end;</source>
        <Parameter name="stem" type="String"/>
        <Parameter name="suffix" type="String"/>
        <Parameter name="number" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findMissingFiles" id="aa878fee-2f83-4f87-bc64-2180e52681e0">
        <updating/>
        <source>findMissingFiles(dir:String) updating;

vars
	folder:FileFolder;
	fileNode:FileNode;
	i,j:Integer;
	s,t:String;
begin
	create folder;
	folder.fileName:=dir;
	folder.usePresentationFileSystem:=false;
	if folder.isAvailable then
		foreach fileNode in folder.files do
			if fileNode.isKindOf(File) then
				s:=fileNode.fileName[4:end].cnEcFindReplace("..","",false).toLower;
				i:=fileNames.indexOf(s);
				if i=0 then
					if s.cnContains("admin") then
						t:=s;
					endif;
					missingFiles.add(s);
				else
					fileNames.removeAt(i);
				endif;
			else
				findMissingFiles(fileNode.fileName);
			endif;
		endforeach;
	endif;
epilog
	delete folder;
end;</source>
        <Parameter name="dir" type="String"/>
    </JadeMethod>
    <JadeMethod name="getResults" id="f3edee25-fdd1-4b2d-bf0a-e0030885aa08">
        <updating/>
        <source>getResults() updating;

vars
	item,s,t,u,v,myStdOut:String;
	len,prevLen,i,j,k,l:Integer;
begin
	while true do
		app.doWindowEvents(250);
		myStdOut:=cp.myCP.stdOut;
		if myStdOut.length&lt;=prevLen then continue; endif;
//		write "length="&amp;(myStdOut.length-prevLen).String;

		s:=s&amp;myStdOut[prevLen+1:end];					// get what we haven't seen before
//		write s.display;
		prevLen:=myStdOut.length;						// remember where to start next time
		s.replaceChar(Cr," ");
		s:=s.cnEcFindReplace(#"08 20 08","",false);		// edit out wzzip stuff
		s:=s.cnEcFindReplace("..","",false);
		len:=s.length;
		i:=1; j:=1;
		while i&gt;0 and i&lt;len do
			item:=s.scanUntil(Lf,i).trimRight;
			if i&gt;0 then
				i:=i+1;
				j:=i;
				if doingBackupVerify then
					addToFileNames(item);
				else
					listBox.addItem(item);
					scrollToBottom;
				endif;
			endif;
		endwhile;
		if s.cnContains(Command_Finished) then break; endif;
		if s.length&gt;j then s:=s[j:end]; else s:=""; endif;			// save off any partial line
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="1234d061-5c0c-4c1f-9718-ef26afa7eb48">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode:Integer io; shift:Integer) updating;

begin
	//write keyCode.String&amp;Tab&amp;shift.String;
	if keyCode=74 and shift=2 then  // Ctrl+J	Run JadeDev
		app.startApplication("JadeSchema", "Jade");
		keyCode:=0;

	elseif keyCode=82 and shift=2 then  // Ctrl+R	Run JCMController
		app.startApplication("JCFViewSchema", "JCMController");
		keyCode:=0;

	elseif keyCode=84 and shift=2 then  // Ctrl+T	monitor transaction contention
//		logMessage("now monitoring and logging transaction start/stop notifications");
		beginNotification(system, 778, Response_Continuous, 0);
		beginNotification(system, 779, Response_Continuous, 0);
		app.logMessage("now monitoring and logging transaction start/stop notifications");
		keyCode:=0;

	elseif keyCode=19 then  // Pause - toggle pause button
		paused:=not paused;
		setCaption;
		keyCode:=0;

	elseif keyCode=32 and shift=2 then	// Ctrl+Spacebar	Select Line
		listBox.itemSelected[listBox.listIndex]:=true;
		keyCode:=0;

	elseif keyCode=38 and shift=2 then	// Ctrl+Up	Scroll Up
		listBox.topIndex:=listBox.topIndex - 1;

	elseif keyCode=40 and shift=2 then	// Ctrl+Down Scroll Down
		listBox.topIndex:=(listBox.topIndex + 1).min(listBox.listCount);

	elseif keyCode=191 then				// Slash Find text
		doFind(false, shift = 1);

	elseif keyCode=114 then				// F3 Find next
		doFind(true, shift = 1);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listBox_keyDown" id="ad77b0c3-fc0e-46ca-abe7-71dc0031ed08">
        <controlMethod name="ListBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>listBox_keyDown(listbox: ListBox input; keyCode: Integer io; shift: Integer) updating;

vars
	i:Integer;
begin
//	write keyCode.String&amp;" "&amp;shift.String;
	if keyCode=37 then  // left
		listBox.scrollHorzPos:=listBox.scrollHorzPos-20;

	elseif keyCode=39 then  // right
		listBox.scrollHorzPos:=listBox.scrollHorzPos+20;

	elseif keyCode=27 then  // esc
		foreach i in 1 to listBox.listCount do
			listBox.itemSelected[i]:=false;
		endforeach;

	elseif keyCode=67 and shift=2       // Ctrl+C
	or     keyCode=45 and shift=2 then  // Ctrl+Insert
		editCopy;
		keyCode:=0;  // required for 6.2
	endif;

	if listBox.scrollHorzPos&lt;0 then
		listBox.scrollHorzPos:=0;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="efbf1ede-8f00-4bb8-affc-7981f827ed01">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
vars
	sa:StringArray;
	s:String;
begin
	create sa transient;
	adm.listEnvs(sa);
	foreach s in sa do
		cbEnv.addItem(s);
		if  s = "SkiSbs" then  // add special extra items, eg split zips
		elseif
			s = "SkiHis" then
		elseif			
		    s = "TsbProd" then
		elseif			
		    s = "HmlHML" then
		endif;			
	endforeach;

	cbAction.addItem(Start_Env);
	cbAction.addItem(Start_Jade_Dev);
	cbAction.addItem(Start_Monitor);
	cbAction.addItem(Show_Nodes);
	cbAction.addItem(Stop_Fat_Clients);
	cbAction.addItem(Stop_All_Clients);
	cbAction.addItem(Stop_Env);
	cbAction.addItem(Backup);
	cbAction.addItem(Load_Schemas);
	cbAction.addItem(Schema_Extract);
	cbAction.addItem(Load_Hotfix);
	cbAction.addItem(Load_Licence);
	cbAction.addItem(Show_Jade_Version);
	cbAction.addItem(Show_All_Nodes);
	cbAction.addItem(Show_Databases);

//	oEnv.change(oEnv);
//	oRun.change(oRun);
	tCmdLine.text:="c:\tools\pv jad* -l*coydapp*";
//	setProcessLogFileName("run");
//	parent.mnuFileSelect_click(null);
	monitorFileName:=app.getProfileStringAppServer(app.getIniFileNameAppServer, "JadeLog", "LogDirectory", "c:\temp")&amp;"\jommsg1.logff";
	cbEnv.setFocus;
	bHide.click(null);
	resize;
epilog
	delete sa;
	beginTimer(1000, Timer_OneShot, Timer_Normal);
end;</source>
    </JadeMethod>
    <JadeMethod name="logFormattedMessage" id="bf7564c4-1658-43d7-84ee-519964902473">
        <updating/>
        <source>logFormattedMessage(s:String) updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	t:String;
begin
	t:=s.replace(CrLf,CrLf&amp;app.actualTimeServer.logFormat&amp;" ");// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	processLogFile.writeLine(app.actualTimeServer.logFormat&amp;" "&amp;t);// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	processLogFile.close;
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="cee3df91-9471-428d-9fb9-a0674a1c3fe6">
        <updating/>
        <source>logMessage(s:String) updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

begin
	processLogFile.writeLine(app.actualTimeServer.logFormat&amp;" "&amp;s);// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	processLogFile.close;
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="oEnv_change" id="710d2ebc-082f-436a-ba8d-43daba593c47">
        <controlMethod name="OptionButton::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>oEnv_change(optionbutton:OptionButton input) updating;

begin
	if optionbutton.value=true then
		setProcessLogFileName("backup");
		cbEnv.enabled:=true;
		cbAction.enabled:=true;
		cbEnv.setFocus;
	else
		setProcessLogFileName("run");
		cbEnv.enabled:=false;
		cbAction.enabled:=false;
	endif;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="oRun_change" id="acea1348-95f1-400f-b2f3-f0f0ae49c861">
        <controlMethod name="OptionButton::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>oRun_change(optionbutton:OptionButton input) updating;

begin
	if optionbutton.value=true then
		setProcessLogFileName("run");
		tCmdLine.enabled:=true;
		tCmdLine.setFocus;
	else
		setProcessLogFileName("backup");
		tCmdLine.enabled:=false;
	endif;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resize" id="68a32bd9-8d2c-436a-a1fb-6a875c4cd38b">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

begin
	lAction.left:=bRun.left/2;
	cbAction.left:=lAction.left+lAction.width+6;
	cbAction.width:=bRun.left-cbAction.left-6;
	cbEnv.width:=lAction.left-cbEnv.left-12;
	tCmdLine.width:=bRun.left-tCmdLine.left-6;
	//tCmdLine.height:=60;
	listBox.move(0,listBox.top,clientWidth,clientHeight-listBox.top-2);
	scrollToBottom;
end;</source>
    </JadeMethod>
    <JadeMethod name="runBackup" id="d4dbf034-394d-448c-9cb1-1d5ee690ce41">
        <updating/>
        <source>runBackup() updating;

vars
	s:String;
begin
	setProcessLogFileName("backup");
	doingWinZip:=false;
	doingJdbutil:=false;
	envName:=cbEnv.text;
	if envName.cnContains(":") then  // adhoc folder backup
		env:=envName;
	else							 // it's a named Jade environment
		if envName[1:7]="SkiSbs_"
		or envName[1:7]="SkiHis_"
		or envName[1:7]="HmlHML_"	then
			adm.envName:=envName[1:6];
		elseif envName[1:8] = "TsbProd_" then
			adm.envName:=envName[1:7];			
		else
			adm.envName:=envName;
		endif;
		adm.envInfo;
		env:=adm.env;
	endif;
	if not adm.backupCheckInuse(env) then
		return;
	endif;
/*	if envName="SkiSbs" and not adm.backupCheckInuse(env&amp;"B\doc") then  // SkiSbsB\doc included in that zip
		return;
	endif; */  // jhp 20050314 removed SkiSbsB from backup

	if envName="SkiHis_Lobj" then
		backupMixed;
	elseif envName = 'TsbProd_Events' then
		backupMixed;
	else
		backupEnv;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="runCmdLine" id="5e601ca1-6173-46f1-b0c0-b3f4b17a7a17">
        <updating/>
        <source>runCmdLine(s:String) updating;

begin
	// set runLogFileName:=null to use stdOut instead of a file
	doingWinZip:=true;
	setProcessLogFileName("run");
	//cmdLine:=tCmdLine.text.trimBlanks;
	cmdLine:=s;
	if setupCP=false then
		tCmdLine.setFocus;
		return;
	endif;
	
	logMessage("");
	logMessage(app.computerName.toLower&amp;"&gt;"&amp;cp.cmdLine);
	app.startApplicationWithParameter(currentSchema.name,"CommandProcessor",cp);
	if processLogFileName=null then
		waitForCPInit;
		getResults;  // show the results as they arrive in stdOut
		
	//	write cp.myCP.stdOut.Binary.display;
	/*	s:=cp.myCP.stdOut;
		s:=s.cnEcFindReplace(#"08 20 08","",false);
		s:=s.cnEcFindReplace("..","",false);
		write s.display; /* */
		logMessage("result="&amp;cp.result.String&amp;","&amp;cp.exitCode.String);
		tCmdLine.setFocus;
		scrollToBottom;
		sendFinishMsg;
	endif;
	doingWinZip:=false;
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="runHotfix" id="8e8242d8-fb30-409d-a3e1-d9f0e8fb4e8c">
        <updating/>
        <source>runHotfix() updating;

begin
	tCmdLine.text:=env&amp;"\server\c_bin\jadloadb.exe path="&amp;env&amp;"\server\c_system"
	              &amp;" ini="&amp;env&amp;"\server\c_bin\"&amp;envName&amp;".ini"
	              &amp;' schemaFile="'&amp;env&amp;"\server\c_bin\"&amp;'hotfix.scm"';
	oRun.value:=true;
	oRun_change(oRun);
	tCmdLine.selStart:=tCmdLine.text.length-5;
	tCmdLine.height:=38;
	listBox.move(0,tCmdLine.top+tCmdLine.height+6,clientWidth,clientHeight-listBox.top-2);
	scrollToBottom;
	global.beep;
end;</source>
    </JadeMethod>
    <JadeMethod name="runJadReg" id="0df4c615-dced-43ca-919d-bab3fbdb45a0">
        <updating/>
        <source>runJadReg() updating;

begin
	tCmdLine.text:=env&amp;"\server\c_bin\jadregb.exe path="&amp;env&amp;"\server\c_system"
	              &amp;' name="" key=';
	oRun.value:=true;
	oRun_change(oRun);
	tCmdLine.selStart:=tCmdLine.text.length;
	tCmdLine.height:=38;
	listBox.move(0,tCmdLine.top+tCmdLine.height+6,clientWidth,clientHeight-listBox.top-2);
	scrollToBottom;
	global.beep;
end;</source>
    </JadeMethod>
    <JadeMethod name="runKiller" id="21d1cfdc-017d-40c9-83a1-d1bff982d633">
        <updating/>
        <source>runKiller(option:String) updating;

begin
	setProcessLogFileName("run");
	logMessage(null);
	logMessage("killing clients in "&amp;envName&amp;"...");
	if envName="HmlCEN" then
		logMessage("not supported in "&amp;envName&amp;"...");
	else
		adm.killUsers(envName,option);
		logMessage(envName&amp;" client killer started");
	endif;
end;</source>
        <Parameter name="option" type="String"/>
    </JadeMethod>
    <JadeMethod name="runLoadSchemas" id="966e42ce-8eca-4a66-94e3-13d0ad60812c">
        <updating/>
        <source>runLoadSchemas() updating;

vars
	i,j:Integer;
	s,t,path,ddb,scm:String;
	sfb:FrmServerFileBrowser;
	ff:FileFolder; fn:FileNode; f:File;
begin
	path:=env&amp;"\server\c_bin";
	i:=env[4:end].pos("\",1)+4;
	setProcessLogFileName("run");

	create sfb;
	sfb.myParentForm:=self;
	sfb.selectedItem:=schemasFolderName;
	sfb.init("Browse for Folder on " &amp; app.dbServerComputerName, "Select Folder with Schemas", null);
	sfb.showModal;
	if sfb.selectedItem = null then
		return;
	endif;
	schemasFolderName:=sfb.selectedItem;

	create f;
	f.usePresentationFileSystem:=false;
	create ff;
	ff.fileName:=schemasFolderName;
	ff.usePresentationFileSystem:=false;
	foreach fn in ff.files 
	where fn.isKindOf(File) 
	and (fn.name.cnContains(".jcf") or fn.name.cnContains(".scm") or fn.name.cnContains(".cls") or fn.name.cnContains(".mth")) do
		ddb:="";
		if fn.name.cnContains(".jcf") then
			scm:=' commandFile="'&amp;fn.fileName&amp;'"';
		else
			scm:=' schemaFile="'&amp;fn.fileName&amp;'"';
			if fn.name.cnContains(".scm") then
				f.fileName:=fn.fileName.replace(".scm", ".ddb");
				if f.isAvailable then
					ddb:=' ddbFile="'&amp;f.fileName&amp;'"';
				endif;
			endif;
		endif;
		cmdLine:=path&amp;"\jadloadb ini="&amp;path&amp;"\"&amp;env[i:end]&amp;".ini"&amp;" path="&amp;env&amp;"\server\c_system"
			&amp;scm&amp;ddb
			&amp;" clearRestart=true deleteIfAbsent=true displayTimes=true";
		logMessage(cmdLine);
		
		setupCP;
		logMessage("");
		logMessage(app.computerName.toLower&amp;"&gt;"&amp;cp.cmdLine);
		app.startApplicationWithParameter(currentSchema.name,"CommandProcessor",cp);
		while cp.myCP=null do  // wait for CommandProcessor to initialise
			app.doWindowEvents(250);
		endwhile;
		while global.isValidObject(cp.myCP) do  // wait for it to finish
			app.doWindowEvents(250);
		endwhile;
		//runCmdLine("cmd /c dir '"&amp;ff.fileName&amp;"'");
	endforeach;
	logMessage("Schemas load finished");
epilog
	delete sfb;
	delete ff;
end;
</source>
    </JadeMethod>
    <JadeMethod name="runPV" id="029fb8ae-e095-4f28-b59b-47fe01a7b6a0">
        <updating/>
        <source>runPV(s:String) updating;

begin
	setProcessLogFileName("run");
	tCmdLine.text:="c:\tools\pv "&amp;s;
	runCmdLine(tCmdLine.text.trimBlanks);
	cbEnv.setFocus;
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="runPd" id="60186b8b-7252-47fe-90d1-518f35704394">
        <updating/>
        <source>runPd() updating;

vars
	i,j:Integer;
	s,t,dir:String;
begin
	addLine("ODT&gt;"&amp;cmdLine);
	displayFolder(cmdLine[4:end].replace(":1","").trimBlanks);
	addLine(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="runSchemaExtracts" id="80b44730-b072-47a2-91d8-2d050d0911c6">
        <updating/>
        <source>runSchemaExtracts() updating;

vars
	envSuffix:String;
begin
	setProcessLogFileName("backup");
	cmdLine:=" ";
	setupCP;
	beginTransientTransaction;
	cp.result:=0;
	cp.exitCode:=0;
	commitTransientTransaction;
	logMessage(null);
	logMessage("starting schema extracts for "&amp;envName&amp;"...");

	envSuffix:=envName[envName.length-2:3];
	if envName="coyDapp" then
		extractSchema("BaseSchema");
		extractSchema("NodeControlSchema");
		extractSchema("LincSchema");
		extractSchema("FrameworkSchema");
		extractSchema("JetPlusSchema");
		extractSchema("PrintDBSchema");
		extractSchema("JCFInterfaceSchema");
		extractSchema("JCFModelSchema");
		extractSchema("JCFViewSchema");

	elseif envName="coyDappP" then
		extractSchema("NodeControlSchema");
		extractSchema("JetPlusSchema");

	elseif envSuffix="JCM" then
		extractSchema("JCFInterfaceSchema");
		extractSchema("JCFModelSchema");
		extractSchema("JCFViewSchema");

	elseif envSuffix="JCA" then
		extractSchema("JCFInterfaceSchema");

	elseif envSuffix="PDB" then
		extractSchema("LincRunSchema");
		extractSchema("JetPlusSchema");
		extractSchema("JCFInterfaceSchema");

	elseif envName="PtfJetX" or envName="cnwtjcc" then
		extractSchema("JtdControllerSchema");
		extractSchema("JtdDriverSchema");

	elseif envName="Creator" then
		extractSchema("BenchmarkControlSchema");
		extractSchema("NodeControlSchema");

	elseif envName.cnContains("JetX") then
		extractSchema("JCFInterfaceSchema");
		extractSchema("JCFModelSchema");
		extractSchema("JCFViewSchema");
		extractSchema("JetPlusSchema");
		
	elseif envName="JetLinc2" then
		extractSchema("BaseSchema");
		extractSchema("LincSchema");
		extractSchema("FrameworkSchema");
		extractSchema("JetPlusSchema");
		extractSchema("LincGen");
		
	elseif envName="Selwood" then
		extractSchema("LincSchema");
		extractSchema("JetPlusSchema");
		extractSchema("LCDSDB");
		extractSchema("LFMSDB");
		extractSchema("MAJORDB");
		extractSchema("MARKDB");
		extractSchema("PRINTDB");
		extractSchema("SALEDB");
		
	elseif envName="HmlPPrint" then
		extractSchema("JetPlusSchema");
		extractSchema("DMSSchema");
		extractSchema("PrintDBSchema");

	else  // normal client envs
		if envName[1:3]="Fhc" or envName="CcmlPay" or envName="Shelby" or envName="Smithtown" then
			extractSchema("LincSchema");
		else
			extractSchema("LincRunSchema");
		endif;
		extractSchema("JetPlusSchema");
		extractSchema(adm.appSchema);
	endif;
	if cp.result&lt;&gt;0 or cp.exitCode&lt;&gt;0 then
		logMessage(envName&amp;" schema extracts failed");
	else
		logMessage(envName&amp;" schema extracts completed");
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="runStartEnv" id="f22f6a01-8b11-4f1c-a9ce-b648dd3a80b0">
        <updating/>
        <source>runStartEnv() updating;

vars
	myEnv:String;
begin
	setProcessLogFileName("run");
	myEnv:=envName;
	logMessage(null);
	logMessage("starting "&amp;envName&amp;"...");
	adm.startupEnv(envName);
	setEnv(myEnv);
	logMessage(envName&amp;" startup completed");
end;</source>
    </JadeMethod>
    <JadeMethod name="runStopEnv" id="869a5ffa-d3da-4c48-8814-b588ca8982c7">
        <updating/>
        <source>runStopEnv() updating;

vars
	s,t,u,v,myEnv:String;
begin
	setProcessLogFileName("run");
	myEnv:=envName;
	logMessage("");
	logMessage("NOTE: this will hang if any clients are running (need to ok dialog box on Terminal Services)");
	logMessage(app.computerName.toLower&amp;"&gt;stopping "&amp;envName);
	s:=doCmd("c:\tools\pv jad* -l*\"&amp;envName&amp;"\*").replace(CrLf&amp;CrLf,CrLf);
	logFormattedMessage(s);
	if s.cnContains("No matching processes") then
		return;
	elseif s.cnContains("jade.exe") then
		global.beep;
		logMessage("");
		logMessage("&gt;&gt;&gt;stop fat nodes first&lt;&lt;&lt;");
		return;
	endif;
	if s.cnContains("jadapp") then
		logMessage(app.computerName.toLower&amp;"&gt;stopping jadapp");
		t:=doCmd("c:\tools\pv -c jadapp* -l*\"&amp;envName&amp;"\*").replace(CrLf&amp;CrLf,CrLf);
		app.doWindowEvents(1000);
		setEnv(myEnv);
		t:=doCmd("c:\tools\pv jadapp* -l*\"&amp;envName&amp;"\*").replace(CrLf&amp;CrLf,CrLf);
		if not t.cnContains("No matching processes") then
			logMessage(app.computerName.toLower&amp;"&gt;&gt;&gt;jadapp did not close&lt;&lt;&lt;");
			logFormattedMessage(t);
			return;
		endif;
	endif;
	if s.cnContains("jadrap") then
		logMessage(app.computerName.toLower&amp;"&gt;stopping jadrap");
		t:=doCmd("c:\tools\pv -c jadrap* -l*\"&amp;envName&amp;"\*").replace(CrLf&amp;CrLf,CrLf);
	endif;
	app.doWindowEvents(1000);
	setEnv(myEnv);
	s:=doCmd("c:\tools\pv jad* -l*\"&amp;envName&amp;"\*").replace(CrLf&amp;CrLf,CrLf);
	logFormattedMessage(s);
epilog
	logMessage(envName&amp;" shutdown completed");
//	logMessage(Command_Finished);
end;</source>
    </JadeMethod>
    <JadeMethod name="runThinClient" id="ff22cc73-7cd2-4d18-a15e-a75558b44259">
        <updating/>
        <source>runThinClient(skema,appl:String) updating;

vars
	result,retCode:Integer;
	s,t,u,v,path:String;
	sa:StringArray;
begin
	setProcessLogFileName("run");
	logMessage("");
	logMessage("starting "&amp;appl&amp;" for "&amp;env);
	if app.computerName=app.computerNameAppServer then
		path:="c:\thinbin_host\"&amp;envName;
	else
		path:="c:\thinbin\"&amp;envName;
	endif;
	create sa transient;
	sa[1]:="schema="&amp;skema&amp;" app="&amp;appl;
	sa[2]:="AppServer="&amp;app.computerNameAppServer;
	sa[3]:="AppServerPort="&amp;adm.port.String;
	result:=node.createExternalProcess(path,path&amp;"\jade.exe",sa,null,true,false,retCode);
	if result=0 then
		logMessage("started");
	else
		logMessage("failed (no thinbin?), result="&amp;result.String);
	endif;
epilog
	delete sa;
end;</source>
        <Parameter name="skema" type="String"/>
        <Parameter name="appl" type="String"/>
    </JadeMethod>
    <JadeMethod name="runVersionInfo" id="99fb7f3b-6804-4971-81e7-f81c2afb0481">
        <updating/>
        <source>runVersionInfo() updating;

vars
	result,retCode,i,j:Integer;
	s,path,exe,baseRelease:String;
begin
	setProcessLogFileName("run");
	path:=env&amp;"\server\c_bin\";
	exe:="r:\coyDapp\admin\tools\jverinfo.exe";
	logMessage("");
	logMessage(app.computerName.toLower&amp;"&gt;show executable versions in "&amp;path);
	if app.mySpoolerServerJPS=null then
		create app.mySpoolerServerJPS;
	endif;
	if not app.mySpoolerServerJPS.fileExists(path&amp;"jverinfo.exe") then  // included with release in Jade 6
		app.mySpoolerServerJPS.copy(exe,path&amp;"jverinfo.exe");
	endif;
	retCode:=node.createExternalProcess(path,path&amp;"jverinfo.exe",null,null,false,true,result);
	if retCode&lt;&gt;0 and retCode&lt;&gt;4 then logMessage("jverinfo.exe retCode "&amp;retCode.String); endif;
	
	baseRelease:=adm.versionInfoRead(path);
	foreach s in adm.sa do
		logMessage(s);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="scrollToBottom" id="85031d71-8b83-4102-a985-33b95cc7edbb">
        <source>scrollToBottom();

begin
	if not paused and listBox.listCount&gt;0 then
		listBox.listIndex:=listBox.listCount;
		listBox.topIndex:=listBox.listCount;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="sendFinishMsg" id="86c2fb08-2ec7-4189-86d8-04ae79ab8c94">
        <updating/>
        <source>sendFinishMsg() updating;

begin
	// tell the CommandProcessor we are finished with its stdOut
	beginTransientTransaction;
	cp.myCP.stdOut:=Command_Finished;
	commitTransientTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCaption" id="a91f460c-f281-4c4c-8dc7-89a4231a7241">
        <updating/>
        <source>setCaption() updating;

begin
	caption:=sessionName&amp;" - "&amp;file.fileName.toLower&amp;" ("&amp;file.fileLength.integerFormat&amp;")";
	if paused then
		caption:=caption&amp;" - PAUSED";
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnv" id="65f08b10-b578-4dda-9f54-f3e80604c66f">
        <updating/>
        <source>setEnv(s:String) updating;

begin
	envName:=s;
	adm.envName:=envName;
	adm.envInfo;
	envName:=adm.envName;
	env:=adm.env;
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProcessLogFileName" id="990d914d-41f6-434e-b453-94a40344d3c2">
        <updating/>
        <source>setProcessLogFileName(option:String) updating;

vars
	s:String;
begin
//	s:=app.cnGetServerMiscPath.replace("server\c_misc","admin\logs")&amp;"\"&amp;app.computerName.toLower&amp;"_"&amp;option&amp;"_"&amp;sessionNumber.String&amp;".log";
	s:=app.dbPath.toLower.replace("server\c_system","admin\logs")&amp;"\"&amp;app.computerName.toLower&amp;"_"&amp;option&amp;"_"&amp;sessionNumber.String&amp;".log";
	processLogFile.fileName:=s;
	processLogFileName:=s;
	app.makePathIfPossible(processLogFileName,false);
	processLogFile.open;
	processLogFile.close;
	addFile(processLogFileName, true);
end;</source>
        <Parameter name="option" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupCP" id="226c4e04-8ae8-4878-8235-ea8e2fbd1107">
        <updating/>
        <source>setupCP():Boolean updating;

begin
	if cmdLine="" then
		global.beep;
		return false;
	endif;

	beginTransientTransaction;
	if cp=null then
		create cp sharedTransient;
	endif;
	cp.cmdLine:=cmdLine;
	cp.stdOut:="";
	cp.myCP:=null;
	cp.logFileName:=processLogFileName;
	cp.doingWinZip:=doingWinZip;
	cp.doingSchemaExtract:=doingSchemaExtract;
	cp.doingJdbutil:=doingJdbutil;
	commitTransientTransaction;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="1f75dcf2-dfe9-45dc-9270-bc47b1508f22">
        <updating/>
        <source>timerEvent(tag:Integer) updating;

vars
	i,j,pid,appSequenceId,nod,tot:Integer;
	s,t,u,v:String;
	ia:IntegerArray;
begin
	if tag=Timer_Normal and file.fileName&lt;&gt;null then
		file.kind := File.Kind_Unknown_Text;	// 4/3/16 cnwmp6 PAR 36286 unicode version
		if file.fileLength&gt;prevFileLength then
			file.seek(prevFileLength);
			addLinesFromFile(1);
		endif;
		if fileNumber &gt; 0 and not fileStem.cnContains("_run_") then
			checkForNewFile;
		endif;
		
		/*if missingFiles.size &gt; 0 then
			//addLine(missingFiles.display);
			create ia transient;
			ia.initialise(getInstanceIdForObject(Node.instances.last).Integer);
			foreach s in missingFiles where s &lt;&gt; null do
				//i:=1;   pid:=s.scanUntil(";",i).Integer;
				//i:=i+1; appSequenceId:=s.scanUntil(";",i).Integer;
				//t:=t&amp;appSequenceId.String.rightAlign(4);
				i:=1;   nod:=s.scanUntil(";",i).Integer;
				ia[nod]:=ia[nod]+1;
				//t:=t&amp;(s[i+1:end]&amp;" ").padBlanks(35);
				t:=t&amp;(s&amp;" ").padBlanks(35);
			endforeach;
//			foreach i in ia do
			foreach j in 3 to ia.size do  // skip rap and control appserver
				i:=ia[j];
				tot:=tot+i;
				v:=v&amp;i.String&amp;" ";
			endforeach;
			if t &lt;&gt; null then
				v:=v&amp;tot.String.rightAlign(3)&amp;" ";
				app.logMessage(v&amp;" "&amp;t);
			endif;
		endif; /**/
	endif;
epilog
	beginTimer(1000, Timer_OneShot, Timer_Normal);
	delete ia;
end;</source>
        <Parameter name="tag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="054717b6-baf9-46e9-9b4b-10f431cf524b">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	parent.deleteSession(self);
	endNotificationForSubscriber(self);
	endTimer(Timer_Normal);
	delete file;
	delete processLogFile;
	delete adm;
	delete fileNames;
	delete missingFiles;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="a915c5d6-6995-49f8-89a2-060d8a321103">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(event:Integer; obj:Object; tag:Integer; userInfo:Any) updating;

vars
	i,j,pid,appSequenceId:Integer;
	s,t:String;
begin
	if event = 778 or event = 779 then
		s:=userInfo.String;
		i:=1;   pid:=s.scanUntil(";",i).Integer;
		i:=i+1; appSequenceId:=s.scanUntil(";",i).Integer+1;
	endif;

	if appSequenceId &lt;&gt; 0 then
		if event = 778 then  // start transaction
			missingFiles.atPut(appSequenceId, s);
			app.logMessage("Start trans "&amp;s);
	
		elseif event = 779 then  // end transaction
			missingFiles.atPut(appSequenceId, "");
			app.logMessage("End trans "&amp;s);
		endif;
	endif; /* */
end;</source>
        <Parameter name="event" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="tag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="waitForCPInit" id="1c98fcf3-b56b-45ae-bab4-476cf83c335f">
        <updating/>
        <source>waitForCPInit() updating;

begin
	while cp.myCP=null do  // wait for CommandProcessor to initialise
		app.doWindowEvents(250);
	endwhile;
end;</source>
    </JadeMethod>
</GUIClass>
