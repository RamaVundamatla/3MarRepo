    <JadeMethod name="shouldAuditProperty" id="88344922-1d19-4705-be40-c10a38b9ddb3">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if 	propName = CM_HSCodeSubCode::myHSCode.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="a1676138-27ed-4b21-83f9-6c2ccbed98b9">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	inheritMethod();
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="f18d9fb6-7723-4b63-b400-1a5451416c96">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	realHS,
	exisitngHS : CM_HSCodeSubCode;
	code : CM_HSCodeCode;

begin
	inheritMethod();
	
	if self.id = null then
		app.raiseCMException(Input_required_field_Id, null, null);
		return;
	endif;
	
	if self.id.length &lt;= 6 then
		app.raiseCMException2(Field_length_characters_long, self.id &amp; ": " &amp; app.getErrorString(Id), "&gt; 6", null, null);
	endif;
	
	if self.myHSCode = null then
		code := app.myRoot.allHSCodes[self.id[1:6]];
		if code = null then
			app.raiseCMException2(Related_obj_does_not_exist, app.getErrorString(Code), self.id[1:6], null, null);
		endif;
	endif;
	
	realHS := self.pxyGetRealObject();
	exisitngHS := app.myRoot.allHSSubCodes[self.id];
	
	if exisitngHS &lt;&gt; null and (realHS = null or exisitngHS &lt;&gt; realHS) then
		app.raiseCMException3(ERR_DuplicateItemWith, app.getErrorString(Sub_code), app.getErrorString(Id), self.id, null, null);
		return;
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
