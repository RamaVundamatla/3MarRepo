Return Value:		Usercode if there is a valid default, otherwise null

Date		Who		Reason
07 May 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCredentials" id="000282c8-7ea0-4f7c-aeed-49419769a21b">
        <source>validateCredentials( _functionPermission : Integer ) : Boolean;
/*

Purpose:			Validate the credentials in the receiver and initialise the passport ready
					for the processing to follow.

Parameters:			Web Service the incoming message has been received on

Return Value:		True if the validation succeeds, false otherwise.

Date		Who		Reason
04 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
07 May 2018	jlgkpd1	TFS #37190 - Allow for INI file default usercode to comply
					with INAPORTNET "no authentication rule"
					
*/

vars
	passport		: CM_Passport;
	locale			: CM_Locale;
	usercode		: String;
	jmtUser			: CM_User;
	userTerminal	: CM_UserTerminal;
	usingDefaultUser	: Boolean;
	
begin
	passport := app.myPassport;
	passport.initialiseTransaction();
	
	// Check user value
	usercode := self.user.trimBlanks().toUpper();
	
	// Allow for INI file default if appropriate
	if usercode = null then
		usercode := self.getDefaultUsercode();
		usingDefaultUser := true;
	endif;
	
	// User is mandatory	
	if usercode = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_ExternalRequest::user.name, null, null);
		return false;
	endif;
	
	// Check user is valid
	jmtUser := app.getMyRoot.allUsers[usercode];
	if jmtUser = null then
		app.raiseCMException1(ERR_REST_INV_USER, usercode, null, null);
		return false;
	endif;

	// Check current User status
//	if jmtUser.isSuspended() then
	if jmtUser.isSuspendedOrIsDisabled() then	 //23 Nov 2020	NDL TFS 50378
		app.raiseCMException(ERR_USER_SUSPENDED, null, null);
		return false;
	endif;
	
	// Validate password (unless we're using a default from the INI file)
	if not usingDefaultUser then
		if not jmtUser.isValidPassword(self.password) then
			app.raiseCMException(ERR_INVALID_PASSWORD, null, null);
			return false;
		endif;
	endif;
	
	// All good, so set the passport user
	passport.setMyUser(jmtUser);
	
	// Default the app Terminal to the User's first one
	userTerminal := jmtUser.allUserTerminals.first();
	if userTerminal &lt;&gt; null then
		passport.setMyTerminal(userTerminal.myTerminal);
	else
		passport.setMyTerminal(null);
	endif;
	
	// Set up application locale from current User for each transaction
	app.setLocale(jmtUser.getLocale());
	
	// Ensure "special" is set correctly
	if jmtUser.code = "SUPERUSER" then
		app.setSpecial('31/12/3000'.TimeStamp);
	else
		app.setSpecial(app.actualTimeServer);
	endif;
	
	//18 Apr 2018	NDL	TFS 38135
	if _functionPermission &gt; 0 then
		app.checkCurrentUserHasAccess( _functionPermission );
		if app.myPassport.hasErrors then
			return false;
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_functionPermission" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
