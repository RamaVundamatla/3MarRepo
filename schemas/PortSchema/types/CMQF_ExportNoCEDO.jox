<Class name="CMQF_ExportNoCEDO" id="072a41f9-0f2f-4225-b794-b6bef54d180a">
    <superclass name="CMQF_Export"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmstate"/>
    <JadeMethod name="includesObject" id="995536c3-7092-4e90-804c-ceebecd4755a">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// 01 Oct 2010  cnwrs1      par25912 allow for tranship coastals

vars

begin
	if not inheritMethod(_ti, _passport, _breakOut) then
		return false;
	endif;
	if _ti.customExportEntryNumber &lt;&gt; null then
		return false;
	endif;
	if _ti.isCoastalOutbound() then //par 25912 cnwrs1 1 Oct 2010
		return false;
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
