    <JadeMethod name="doSave" id="65719483-2da6-4875-883c-5f6aed5d2b6f">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newStkOrd		: CM_StockOrderHeader;
	pxyStkOrd		: CM_StockOrderHeaderGeneric;
	passport		: CM_Passport;
	result			: Integer;
	headingStr		: String;
begin

	passport := app.myPassport;
	if (not CM_StockOrderHeaderGeneric.hasInstance(self.myCurrentMasterPxy)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'The current master object is null or of the wrong type');
		return false;
	endif;

	if self.tblDataDetail.fixedRows = self.tblDataDetail.rows then
		app.msgBox('You must add at least one order line to this stock order berfore continuing','No order lines present', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if self.mode = self.Mode_New then 	
		// do stuff to create new proxy details 
		if not self.createDetailObjects() then 
			return false;
		endif;
	elseif self.mode = self.Mode_Edit then 
		if not self.setProxyDetailObjects() then
			return false;
		endif;
	else 
		return false;
	endif;
	
	pxyStkOrd := self.myCurrentMasterPxy.CM_StockOrderHeaderGeneric;
	pxyStkOrd.allStockOrderLines.clear();
	self.allDetailObjects.copy(pxyStkOrd.allStockOrderLines);
	
	if (not self.setPxyHeaderFromTbl(pxyStkOrd)) then
		return false;
	endif;
	
	while true do
		if self.mode = self.Mode_New then
			headingStr := 'Creating Stock Order';
			app.myTrxCA.trxCreateStockOrder(pxyStkOrd, newStkOrd, passport);
		elseif self.mode = self.Mode_Edit then
			headingStr := 'Updating Stock Order';
			app.myTrxUA.trxUpdateStockOrder(pxyStkOrd, passport);
		endif;
		
		if passport.trxCompletedOK then
			self.clearErrorWarnings();
			if self.mode = self.Mode_New then
				self.myCurrentMasterObject := newStkOrd;
			elseif self.mode = self.Mode_Edit then
				self.myCurrentMasterObject := pxyStkOrd.pxyGetRealObject;
			endif;
			return true;
		else
			result := app.showErrorWarningDialog(headingStr, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;
	
		
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDetailDataDblClick" id="72edb299-c281-48b7-8440-f1e522de3df5">
        <updating/>
        <source>doTblDetailDataDblClick(_tbl: CM_DataTable input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	itemObj			: Object;
	ti				: CM_TrackedItem;
begin
	itemObj := _tbl.accessRow(_tbl.row).itemObject;

	if CM_StockOrderTILine.hasInstance(itemObj) then
		ti := itemObj.CM_StockOrderTILine.myTrackedItem;
	endif;

	if ti = null then
		return;
	endif;
	
	self.doEnquiryTI(ti);

end;</source>
