    <JadeMethod name="transportManifestFilter" id="32d17ede-99b1-4e2c-b32f-f0bf6fa81a30">
        <source>transportManifestFilter(ediData : CM_EDIData input) : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	filterMessageType 	: String;
	filterMessageNum 	: String;
	filterAction 		: String;
	filterReceiver 		: String;
	filterSender 		: String;
	filterMessageID		: String;
	returnValue			: Boolean;
begin
	if not ediData.isKindOf(CM_EDIDataTransManifest) then
		return false;
	endif;
	
	filterMessageType	:= self.tblSearch.getValueByName(ETRow_FilterMessageType).String;
	filterAction		:= self.tblSearch.getValueByName(ETRow_FilterAction).String;
	filterMessageNum 	:= self.tblSearch.getValueByName(ETRow_FilterMessageNumber).String;
	filterReceiver		:= self.tblSearch.getValueByName(ETRow_FilterReceiver).String;
	filterSender		:= self.tblSearch.getValueByName(ETRow_FilterSender).String;
	filterMessageID		:= self.tblSearch.getValueByName(ETRow_FilterMessageID).String;
	
    if not filterMessageType.isBlank then
		if ediData.CM_EDIDataTransManifest.myCargoOnSite &lt;&gt; null then
			if filterMessageType.toUpper() = ediData.getMessageType.toUpper() then
				returnValue := false;
			else
				returnValue := true;
			endif;
		elseif ediData.CM_EDIDataTransManifest.myGateDocument &lt;&gt; null then
			if filterMessageType.toUpper() = ediData.getMessageType.toUpper() then
				returnValue := false;
			else
				returnValue := true;
			endif;
		elseif ediData.CM_EDIDataTransManifest.myShipManifest &lt;&gt; null then
			if filterMessageType.toUpper() = ediData.getMessageType.toUpper() then
				returnValue := false;
			else
				returnValue := true;
			endif;
		elseif ediData.CM_EDIDataTransManifest.myTrainConsist &lt;&gt; null then
			if filterMessageType.toUpper() = ediData.getMessageType.toUpper() then
				returnValue := false;
			else
				returnValue := true;
			endif;
		else
			returnValue := true;
		endif;
	endif;		
	
	if not filterMessageNum.isBlank then
		if filterMessageNum.toUpper() = ediData.getMessageNumber().toUpper() and not returnValue then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	if not filterAction.isBlank then
		if filterAction.toUpper() = ediData.getAction().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	if not filterReceiver.isBlank then
		if filterReceiver.toUpper() = ediData.getReceiver().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	if not filterSender.isBlank then
		if filterSender.toUpper() = ediData.getSender().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	if not filterMessageID.isBlank then
		if filterMessageID.toUpper() = ediData.getMessageID().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	return returnValue;
end;</source>
        <Parameter name="ediData" type="CM_EDIData" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="unload" id="fedd403c-9e66-440c-9875-559d2eebce9f">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.endNotificationForSubscriber(self);
	if self.myEDIAgent &lt;&gt; null then
		delete self.myEDIAgent;
	endif;
	
	// TFS 59451 navmd1 24/08/2023
	if self.myEDIUIAgent &lt;&gt; null then
		delete self.myEDIUIAgent;
	endif;
	
	self.setEDIFileInError(null);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateEDIFileIfChanged" id="d2eee9ae-ea02-489b-853e-ab56765833c3">
        <source>updateEDIFileIfChanged();
//----------------------------------------------------------------
//	Created:	20 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	int			: Integer;
//	longString	: CM_LongString;
begin
	foreach int in 1 to self.tblFileLine.rows do
		if self.tblFileLine.accessCell(int, self.COLUMN_CHANGED).text = self.HAS_CHANGED then //par17172 cnwrs1 July 2008
			app.myTrxUA.trxUpdateEDIMessage(self.myEDIFileInError, int, self.tblFileLine.accessCell(int, self.COLUMN_DATA).text, app.myPassport); //par17172
		endif;
	
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateTblData" id="0f63387e-c8a0-4b16-a313-2a62d8f06ad7">
        <updating/>
        <source>updateTblData(_ediData: CM_EDIData) updating;
// ---------------------------------------------------------------------------
// Created:		23 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//05 Feb 2016	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar

vars
	rowIdx			: Integer;
	strDisplay		: String;
	table			: CM_DataTable;
	gotException	: Boolean;
	exOccurred : Boolean;
begin
	on Exception do self.handle14051Error(exception, self.tblData, exOccurred);	//25 Nov 2014	NDL	Par 35248
	on Exception do app.handleDeletedObject (exception, _ediData, gotException);
	
//	if _ediData = null or not _ediData.isKindOf(self.myDataClass) then //27 Oct 2016	NDL 1090 error
	if _ediData = null or self.myDataClass = null or not _ediData.isKindOf(self.myDataClass) then //06 Jul 2017	NDL
		// won't cause an exception if _ediData is an invalid object
		return;
	endif;
	
	table := self.tblData;
	
	// if _ediData is not valid then we will get an exception here
	strDisplay := _ediData.getAttributeStringForDefArray(table.allTblDataEntRows);
	
	if gotException then
		// _ediData is not valid
		return;
	endif;
	if exOccurred then
		return;
	endif;
	
	if not table.findObjectInRow(_ediData, rowIdx) then
		//not in table
		rowIdx := table.addItemObject(_ediData,strDisplay);
	else
		table.setCellText(rowIdx, 1, strDisplay);
		self.showThumbDetail(_ediData);
		
		self.ediTIDataNeedsRefresh := true;
	endif;
	
	if (rowIdx mod 2 = 0) then
		table.accessedRow.backColor := self.colorRow1;
	else
		table.accessedRow.backColor := self.colorRow2;
	endif;
			

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="3dc955af-d71f-4ac0-8bc5-d9e8e4cd7226">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin

	self.handleNotification(eventType, theObject, eventTag, userInfo);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xHandlerFileOpen" id="4266544f-bb81-4bac-bb29-e70aabdac77b">
        <source>xHandlerFileOpen(_exceptionObj:Exception; _errorMsg:String output):Integer protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2009 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_errorMsg	:=	process.getErrorText(_exceptionObj.errorCode);
	
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="Exception"/>
        <Parameter name="_errorMsg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
