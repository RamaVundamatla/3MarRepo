    <JadeMethod name="ediImportUserDefinedDefinition" id="58952da2-e6a8-4c3a-95ed-de25c42a68e3">
        <source>ediImportUserDefinedDefinition(_xml: String; _name: String):CM_EDIFileTypeUser;
//22 December 2008	cnwdw1	
//
vars
	fileType, pxyFileType: CM_EDIFileTypeUser;
begin
	ediDeleteUserDefinedDefinition(_name, EDIFileType_UserDefined);
	create pxyFileType transient;
	pxyFileType.importMeXML(_xml);
	app.myTrxCA.trxCreateEDIFileTypeUser(fileType, pxyFileType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return fileType;	// cnwcs5 18/05/2010
epilog	
	delete pxyFileType;
end;</source>
