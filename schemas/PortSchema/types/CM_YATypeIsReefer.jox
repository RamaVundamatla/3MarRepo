<Class name="CM_YATypeIsReefer" id="a467f22e-2d9b-4a28-a0e4-ceb7a8587cda">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>For free storage days criteria details.</text>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaObjectForTi" id="e2c21e90-abb4-4e32-9522-54897bcc11df">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);

vars

begin
	if _ti.isKindOf(CM_Container) then
		if _ti.CM_Container.isReefer then
			_process := true;
		endif;
	endif;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="535261f8-d83a-42a2-a5e2-9d11b4f53040">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);

vars

begin
	if _ti.isReefer then
		_criteriaValue 	:= CM_YADataBoolean.VALUE_TRUE;
	else
		_criteriaValue 	:= CM_YADataBoolean.VALUE_FALSE;
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="942b76e6-fb65-48cd-a481-b5580febd048">
        <source>getTypeName(): String;

begin
	return "Is Reefer";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isBooleanType" id="19a2ed8f-fe2c-42c9-8f75-08303b11b90e">
        <source>isBooleanType(): Boolean;

vars

begin
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="d5395918-3ad2-477f-ae88-05af31d02995">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
// ** TO BE UPDATED **
vars

begin
	return _cmifAutoPlan.isRequiresPower_Match(_yaData);
end;
</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPrimitiveValue" id="cb81c5c0-4944-4809-844e-ba79065bcc87">
        <source>isPrimitiveValue(): Boolean;

vars

begin
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="aba57636-0a93-4ee5-8254-496e6ff57d57">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars

begin
	//epr TFS 37176 21/2/18
//	return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.isReefer);
	
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch(_tiTrx.myTrackedItem.isReefer);	// is Reefer not kept on the generic transaction
	else
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.isReefer);
	endif;

end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
