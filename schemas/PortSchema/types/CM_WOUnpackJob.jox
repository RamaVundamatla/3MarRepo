    <JadeMethod name="setForCreateInternal" id="3c5c6458-f66e-47ae-aa9b-0d03baab64d6">
        <updating/>
        <source>setForCreateInternal(_cmifJobParam : CMIF_WorkOrderJobParams;_terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
01 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
*/



vars
	req : CM_WOUnpackRequest;
begin

	inheritMethod(_cmifJobParam, _terminal);						//02.06.2023 navma1 #58296

	//---------------
	//Build a Request
	//---------------
	create req;	
	req.setForCreateInternal(self, _cmifJobParam);
	//---------------
	//Build the WLEs' from the request.
	//---------------
	self.createWLEs();
	//self.setJobPlannedLocation();										//02.04.2024 navhl20 #63251
	self.setJobPlannedLocation(false); //26/08/2024	navkc1 CR 63588 Task 63589

end;</source>
        <Parameter name="_cmifJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
