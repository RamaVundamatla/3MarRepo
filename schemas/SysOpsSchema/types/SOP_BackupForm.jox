    <JadeMethod name="setupForm" id="12dad312-40eb-4660-8e20-b3ec9f9df3fa">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDefEntry,
	entTableDefData: EntTableDef;
	term: CM_Terminal;
	date: Date;
begin
	inheritMethod();
	self.myBackup := app.myRoot.myBackup;
	
	entTableDefEntry := app.myController.getEntTableDef(ETDef_BackupMaint);
	self.tblBackup.setEntTableDef(entTableDefEntry, null, 'entTableDefSetupWarning');
	self.tblBackup.userInputEnabled := false;	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.btnSaveBase.visible := true;	
	self.btnCancelBase.visible := true;	

	self.fldBackup.useSheetBackColors := true;
	self.fldBackup.setDefaultSheetBackColors();
	self.fldBackup.initSheetBackColors();

	entTableDefData := app.myController.getEntTableDef(ETDef_BackupDBHistoryMaint);
	if entTableDefData &lt;&gt; null then	
		self.tblDBHistory.zAddSortColumn('dateTime', true);
		self.tblDBHistory.setTblDataEntRowsFromDef(entTableDefData);
	endif;
	entTableDefData := app.myController.getEntTableDef(ETDef_BackupJournalHistMaint);
	if entTableDefData &lt;&gt; null then	
		self.tblJournalHist.zAddSortColumn('journalNumber', true);
		self.tblJournalHist.zAddSortColumn('dateTime', true);
		self.tblJournalHist.setTblDataEntRowsFromDef(entTableDefData);
	endif;
	
	self.tblDBHistory.selectMode := Table.SelectMode_Row;
	self.tblDBHistory.accessMode := Table.AccessMode_Row;
	self.tblDBHistory.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblDBHistory.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblDBHistory.allSelectedObjects.clear;
	self.tblDBHistory.top := 7;
	self.tblDBHistory.left := 5;
	self.tblDBHistory.setDistanceFromRight(5);
	self.tblDBHistory.setDistanceFromBottom(5);
	self.tblDBHistory.stretchHeight := true;
	self.tblDBHistory.stretchWidth := true;
	self.tblDBHistory.userInputEnabled := false;	
	
	self.tblJournalHist.selectMode := Table.SelectMode_Row;
	self.tblJournalHist.accessMode := Table.AccessMode_Row;
	self.tblJournalHist.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblJournalHist.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblJournalHist.allSelectedObjects.clear;
	self.tblJournalHist.top := 7;
	self.tblJournalHist.left := 5;
	self.tblJournalHist.setDistanceFromRight(5);
	self.tblJournalHist.setDistanceFromBottom(5);
	self.tblJournalHist.stretchHeight := true;
	self.tblJournalHist.stretchWidth := true;
	self.tblJournalHist.userInputEnabled := false;	
	
	self.doRefresh();
	self.shtDBHistory.cnEcResizeContents();
	if self.myBackup = null then
		self.btnBackup.enabled := false;
		self.btnReset.enabled := false;
	else
		self.btnBackup.enabled := true;
		self.btnReset.enabled := true;
	endif;
	self.btnAbort.enabled := false;
	self.btnSaveBase.enabled := false;
	self.btnCancelBase.enabled := false;

	self.setNavigatorHeading(self.caption);
	
	self.populateTableBackup;
	self.doRefresh;
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnAbort.enabled := false;
		self.btnBackup.enabled := false;
		self.btnEdit.enabled := false;
		self.btnReset.enabled := false;
		self.btnSaveBase.enabled := false;
		
	endif;
end;</source>
    </JadeMethod>
