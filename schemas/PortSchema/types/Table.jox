    <JadeMethod name="getHeadingsString" id="f498a0aa-de4e-4e68-8a87-a14a45b71bb2">
        <source>getHeadingsString(pDelimiter:String):String;
// --------------------------------------------------------------------------------
// Created:		07 August 2008 by cnwdad1
//
// Purpose:		Returns a delimited string of the receiver's headings.
//
// Parameters:	pDelimiter - The delimiter for the headings.
//
// Returns:		The delimited headings string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	headings	: String;
	colPointer	: Integer;
	colCount	: Integer;
	
begin
	colCount	:=	self.columns;
	
	foreach colPointer in 1 to colCount do
		if colPointer = 1 then
			headings	:=	self.getCellText(1, colPointer);
		else
			headings	:=	headings &amp; pDelimiter &amp; self.getCellText(1, colPointer);
		endif;
	endforeach;
	
	return headings;
end;</source>
        <Parameter name="pDelimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
