C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D2102R,,,,"&amp;ContainerId15&amp;",1,2200,,,,,,,,"&amp;TestOperator&amp;",,,,,,,,,,,,,12589,,,,,"&amp;VoyageName;
/*
C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D2050,,,,"&amp;ContainerId13&amp;",1,4262,,,,,,,,"&amp;TestOperator&amp;",,,,,,,,,,,,,12589,,,,,"&amp;VoyageName&amp;"
C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D2010R,,,,"&amp;ContainerId16&amp;",1,4262,,,,,,,,"&amp;TestOperator&amp;",,,,,,,,,,,,,12589,,,,,"&amp;VoyageName;
*/
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedDeckPlan[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);

//L,D2200O,S,,Yes,1X1

	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg(ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1');
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);

	//****************************************************************************************************************
	//**** extarct the actual and proposed Deck Plan actual should match the input proposed should have ROBs only ****
	//****************************************************************************************************************
	ediControllerAgent.setTerminal(self.getTerminal);
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedDeckPlanNoBOL];
	ediDataParams.operator := voyage.myOperator;

	//now extract the actual and proposed deck plan and compare them - they should be different
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, ACTUAL_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediDataActual := ediData;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);

		// now check the data lines
		unloadArray.clear();
//		write "*************** Actual ******************";
		unloadArray.add("V,A,VOYSHIP30951,Jolly Rosso");
		unloadArray.add("L,D2098,,0.0000,true,2X5");
		unloadArray.add("L,D2100O,S,0.0000,false,");
		unloadArray.add("P,D2100O,1,66.50,-1.20");
		unloadArray.add("P,D2100O,2,72.50,-1.20");
		unloadArray.add("P,D2100O,3,72.50,1.20");
		unloadArray.add("P,D2100O,4,66.50,1.20");
		unloadArray.add("P,D2100O,5,66.50,-1.20");
		unloadArray.add("L,D2101O,S,0.0000,false,");
		unloadArray.add("P,D2101O,1,72.50,-1.20");
		unloadArray.add("P,D2101O,2,78.50,-1.20");
		unloadArray.add("P,D2101O,3,78.50,1.20");
		unloadArray.add("P,D2101O,4,72.50,1.20");
		unloadArray.add("P,D2101O,5,72.50,-1.20");
		unloadArray.add("L,D2110O,S,0.0000,false,");
		unloadArray.add("P,D2110O,1,66.50,-3.60");
		unloadArray.add("P,D2110O,2,72.50,-3.60");
		unloadArray.add("P,D2110O,3,72.50,-1.20");
		unloadArray.add("P,D2110O,4,66.50,-1.20");
		unloadArray.add("P,D2110O,5,66.50,-3.60");
		unloadArray.add("L,D2111O,S,0.0000,false,");
		unloadArray.add("P,D2111O,1,72.50,-3.60");
		unloadArray.add("P,D2111O,2,78.50,-3.60");
		unloadArray.add("P,D2111O,3,78.50,-1.20");
		unloadArray.add("P,D2111O,4,72.50,-1.20");
		unloadArray.add("P,D2111O,5,72.50,-3.60");
		unloadArray.add("L,D2120O,S,0.0000,false,");
		unloadArray.add("P,D2120O,1,66.50,-6.10");
		unloadArray.add("P,D2120O,2,72.50,-6.10");
		unloadArray.add("P,D2120O,3,72.50,-3.60");
		unloadArray.add("P,D2120O,4,66.50,-3.60");
		unloadArray.add("P,D2120O,5,66.50,-6.10");
		unloadArray.add("L,D2121O,S,0.0000,false,");
		unloadArray.add("P,D2121O,1,72.50,-6.10");
		unloadArray.add("P,D2121O,2,78.50,-6.10");
		unloadArray.add("P,D2121O,3,78.50,-3.60");
		unloadArray.add("P,D2121O,4,72.50,-3.60");
		unloadArray.add("P,D2121O,5,72.50,-6.10");
