    <JadeMethod name="isSpecial" id="98ea59a0-5e23-4541-9ff5-921d463e7996">
        <source>isSpecial() : Boolean;
// ---------------------------------------------------------------------------
// Created:     01 June 2004 by cnwrs2
//
// Purpose:     Used to replace SUPERUSER
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
18 Feb 2010	cnwkpd1	PAR #22396 - Changes for performance related to EDI loads

*/

constants
	CheckTimeStamp	: TimeStamp = '01/01/3000'.TimeStamp;
	
vars
//	ts	: TimeStamp;

begin
	return self.theTime &gt; CheckTimeStamp;
	
//	ts := self.getPropertyValue(PortSchema::theTime.name).TimeStamp;
