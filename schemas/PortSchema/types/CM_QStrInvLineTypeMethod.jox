    <JadeMethod name="setComboValues" id="1b0507bb-8e12-4546-8a50-efa010c997ea">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2014	cnwjre1	Initial creation

*/

vars

	terminal : CM_Terminal;
	termCrit			: CM_SelectorCriteriaLine;
	ut					: CM_UserTerminal;
	obj					: Object;
	os					: ObjectSet;
	bank : CM_Bank;
	invLineType	 : CM_InvoiceLineDesc;
	qrl : CM_QReferenceLookup;
	dict : CM_InvoiceLineDescByNarrDict;
begin
	_combo.clear();
	
	create os transient;
	create dict transient;
	// 34364 company and invoice types specific to terminal otherwise companies for terminals the user can see
	foreach termCrit in _params.allCriteriaLines do
		if termCrit.myQueryProperty.propertyName = 'myTerminal' or
		   termCrit.myQueryProperty.propertyName = 'getTerminal' then
			termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
			break;
		endif;
	endforeach;
	if os.isEmpty() then
		foreach ut in app.myPassport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;

	foreach obj in os do
		terminal := obj.CM_Terminal;
		foreach bank in terminal.companies discreteLock where bank.isBusinessUnit do
			foreach invLineType in bank.invoiceLineDescriptors discreteLock where not invLineType.isNotAvailableForEntry do
				if dict[invLineType.narration] = null then
					dict.add(invLineType);
				endif;
				_combo.itemObject[_combo.addItem( self.translateToDisplayValue(invLineType).String ) ] := invLineType;
			endforeach;
		endforeach;
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

epilog
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="784094cf-1a71-4f02-b3d2-1b7664ad5502">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	selectionValue,
	idx 				: Integer;
	array 				: ObjectArray;
	
	terminal 			: CM_Terminal;
	termCrit			: CM_SelectorCriteriaLine;
	ut					: CM_UserTerminal;
	obj					: Object;
	os					: ObjectSet;
	bank 				: CM_Bank;
	invLineType	 		: CM_InvoiceLineDesc;
	qrl 				: CM_QReferenceLookup;
	dict 				: CM_InvoiceLineDescByNarrDict;

begin
	
	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2;
	//_tbl.rows := _tbl.fixedRows;
	array := _tbl.getPropertyValue("allSelectedObjects").ObjectArray;
	array.clear;
	
	create os transient;
	create dict transient;
	// 34364 company and invoice types specific to terminal otherwise companies for terminals the user can see
	foreach termCrit in _params.allCriteriaLines do
		if termCrit.myQueryProperty.propertyName = 'myTerminal' or
		   termCrit.myQueryProperty.propertyName = 'getTerminal' then
			termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
			break;
		endif;
	endforeach;
	if os.isEmpty() then
		foreach ut in app.myPassport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;

	foreach obj in os do
		terminal := obj.CM_Terminal;
		foreach bank in terminal.companies discreteLock where bank.isBusinessUnit do
			foreach invLineType in bank.invoiceLineDescriptors discreteLock where not invLineType.isNotAvailableForEntry do
				selectionValue := 0;
				if _operator &lt;&gt; null and _operator.CM_QStringLookupIsOneOf.allSelectionValues.includes(invLineType.narration) then
					selectionValue := 1;
					array.add(invLineType);
				endif;
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; self.translateToDisplayValue(invLineType).String);
				_tbl.accessRow(idx).itemObject := invLineType;
				_tbl.row := idx;
                _tbl.change(_tbl);
			endforeach;
		endforeach;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="f0642adf-c635-4b1a-9253-e26d665c09f8">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars
	invLineDesc : CM_InvoiceLineDesc;
	str 		: String;
	numRows,
	idx 		: Integer;
	sa 			: StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			invLineDesc := _tbl.accessRow(idx).itemObject.CM_InvoiceLineDesc;
			sa.add(invLineDesc.narration);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="9db0fd23-ec20-4396-8648-82c3edda88cb">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars

	invLineType : CM_InvoiceLineDesc;

begin
	if _value.isKindOf(CM_InvoiceLineDesc) then
		if _value &lt;&gt; null then
			invLineType := _value.CM_InvoiceLineDesc;
			return invLineType.narration &amp; "  [" &amp; invLineType.bank.code &amp; "/" &amp; invLineType.bank.terminal.code &amp; "]";
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="7df07e3d-f606-49bb-a035-4b1d400cbc32">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	invalidObj : Boolean;
	object 	   : CM_InvoiceLineDesc;
	returnVal  : String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_InvoiceLineDesc) then
			object := _value.CM_InvoiceLineDesc;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.narration;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
