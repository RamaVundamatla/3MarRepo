    <JadeMethod name="clearForm" id="024c2533-6fb7-4004-8c3e-4dc810f47887">
        <source>clearForm();
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
19 August 2009	cnwml2	Initial creation
18 March 2010	cnwcs5	par 23241 - various issues
*/
vars

begin
	self.tblExpected.clearAllData();
	self.tblExpectedMacro.rows := 0;
	self.tblExpectedMacro.columns := 0;
	self.tblActual.clearAllData();
	self.tblActualMacro.rows := 0;
	self.tblActualMacro.columns := 0;
	self.tblUnreconciled.clearAllData();
	self.tblUnreconMacro.rows := 0;
	self.tblUnreconMacro.columns := 0;
	self.lblReconDetail.caption := "";
	self.lblActual.caption := app.getString(BOL_Cargo) &amp; " (0)";
	self.lblUnreconciled.caption := app.getErrorString1 (UNRECONCILED_CARGO, 0.asStringJMT);	// par 23241;
	self.chkShowAllCargo.value := false;

	self.optBOL.enabled	 			:= false;	// par 23241
	self.optVoyage.enabled	 		:= false;	// par 23241
	self.optBOL.value				:= true;	// par 23241
	self.btnCompleteRecon.enabled	:= false;	// par 23241
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbBOL_click" id="d9affb00-443f-40a3-9fe5-bb31ce603ece">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBOL_click(combobox: ComboBox input) updating;
//25 January 2010	cnwml2
//18 March 2010		cnwcs5	par 23241

vars

begin
	if self.myBOL &lt;&gt; self.cmbBOL.listObject.CM_BOL then		//+cnwml2 PAR23796
		//clear macros
		self.tblExpectedMacro.rows 		:= 0;
		self.tblExpectedMacro.columns 	:= 0;
		self.tblActualMacro.rows 		:= 0;
		self.tblActualMacro.columns 	:= 0;
		self.tblUnreconMacro.rows 		:= 0;
		self.tblUnreconMacro.columns 	:= 0;
	endif;
	
	self.myBOL 		:= self.cmbBOL.listObject.CM_BOL;
	self.myVoyage 	:= self.myBOL.CM_BOLIn.myVoyage;
	
	self.cmbVoyage.setObject(self.myVoyage);
	self.setCmbBOL();
	self.loadData();
	
	if self.myBOL &lt;&gt; null then
		self.optBOL.enabled	 			:= true;	// par 23241
		self.optVoyage.enabled	 		:= true;	// par 23241
		self.btnCompleteRecon.enabled	:= true;	// par 23241	
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbVoyage_click" id="ad35e8d4-e305-4a57-bd72-8b4e36abc204">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_click(combobox: ComboBox input) updating;
//25 January 2010	cnwml2


vars

begin
	self.myVoyage := combobox.listObject.CM_Voyage;
	self.cmbVoyage.setObject(self.myVoyage);
	self.setCmbBOL();
	self.myBOL := self.cmbBOL.listObject.CM_BOL;
	self.clearForm();
	
	if self.myBOL &lt;&gt; null then
		self.optBOL.enabled	 			:= true;	// par 23241
		self.optVoyage.enabled	 		:= true;	// par 23241
		self.btnCompleteRecon.enabled	:= true;	// par 23241	
	endif;	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDragDrop" id="5f1f8834-7ece-45ca-b48f-95e036bd6128">
        <updating/>
        <source>doDragDrop(_table: Table input; _win: Window; _x: Real; _y: Real) updating;
//06 August 2009	cnwdw1	
//
vars
	sourceTable: CM_DataTable;
	targetRow: Integer;
	targetBOLDtl: CM_BOLDtl;
	sourceTI, targetTI: CM_TrackedItem;
	tis: CM_TISet;
	result, row : Integer;
	obj : Object;
begin
	inheritMethod(_table, _win, _x, _y);
	sourceTable := _win.CM_DataTable;
	
	if _table = self.tblExpected then
		// moving ti to a new booking item
		targetRow := self.tblExpected.dragRow;
		if targetRow &gt; 1 then
			targetBOLDtl := self.tblExpected.accessRow(targetRow).itemObject.CM_BOLDtl;
			self.myCurrentBOLDtl := targetBOLDtl; //+ cnwmd1 Par 21741
			create tis transient;
			sourceTable.allSelectedObjects.copy(tis);
		endif;
	endif;
	if _table = self.tblUnreconciled then
		targetBOLDtl := null;
		create tis transient;
		sourceTable.allSelectedObjects.copy(tis);
		self.allCurrentTrackedItems.clear(); //+ cnwmd1 Par 21741
		tis.copy(self.allCurrentTrackedItems);	//+ cnwmd1 Par 21741
	endif;

	if tis = null then		// PAR 21102
		return;
	endif;
	
	while true do
		if not sourceTable.allSelectedObjects.isEmpty then
			self.myBOLAgent.moveTIsToBOLDtl(tis, self.myBOL, targetBOLDtl);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.tblUnreconMacro.rows := 0;
			self.tblUnreconMacro.columns := 0;
			return;
		endif;
		result := app.showErrorWarningDialog('BOL', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and  result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		return;
	endwhile;
	
epilog
	delete tis;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_win" type="Window"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doEditRecon" id="9a3fb824-46d3-4f6c-9876-b8fa79dcea71">
        <source>					doEditRecon();
//25 January 2010	cnwml2


vars
	form : CMUI_BOLMaintForm;
begin

	form := app.loadForm(CMUI_BOLMaintForm,
									self.myAssistant.class,
									false,
									false,
									false,
									self.myTerminal, null).CMUI_BOLMaintForm;
	
	form.setCaption("View BOL");
	form.setMode(Mode_Update);
	form.setMyCurrentBOL(self.myBOL);
	
	form.setMyBOLType(app.myRoot.allBOLTypes[BOLType_GeneralBillOfLading]);
	
	form.show();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="2dae2cdb-6217-4196-91fe-6b15508faa8a">
        <updating/>
        <source>doRefresh() updating, protected;
//25 January 2010	cnwml2


vars

begin
	inheritMethod();	
	self.loadData();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="064a0d34-4497-4108-8343-1802a80355c8">
        <updating/>
        <source>doSave(): Boolean updating;

//
// Purpose:     
//			 
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//26 January 2010	cnwml2
//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	pxyBOL : CM_BOL;
	result : Integer;
	errObj : CM_Error;
begin
	pxyBOL := app.createUpdateProxy(self.myBOL).CM_BOL;
	
	pxyBOL.setReconDetails(self.localToSystemTime(self.dateComplete.text.asTimeStampJMT), self.txtCompleteReaso.text);
	
	
	while true do
		app.myTrxUA.trxUpdateBOL(pxyBOL, true, null, app.myPassport);

		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.unloadForm();
			return true;
		else
			result := app.showErrorWarningDialog('BOL', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			
			errObj := app.myPassport.allErrorWarnings.first();
			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;
	endwhile;
	
epilog
	delete pxyBOL;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSysNotes" id="0fac2b76-93a0-4d26-957a-13fe2188153b">
        <updating/>
        <source>doSysNotes(eventType: Integer; theObject: Object; userInfo: Any) updating;
//12 August 2009	cnwdw1	
//18 March 2010		cnwcs5	par 23239 - rationalize notifications
vars
	invalidObject	: Boolean;
	ti: CM_TrackedItem;
	idx: Integer;
begin
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);
	if theObject.isKindOf(CM_BOL) then
// par 23239 if eventType = Object_Update_Event then
// par 23239 self.loadData();
		if eventType = Object_Delete_Event then
			if theObject = self.myBOL then	// par 23239
				app.msgBox(app.getErrorString1(DeletedByAnotherUser, self.cmbBOL.text),app.getErrorString(BookingReconciliation), MsgBox_OK_Only);
				self.unloadForm;
			endif;							// par 23239
		endif;
/*	par 23239 elseif theObject.isKindOf(CM_TrackedItem) then
		if self.myBOL &lt;&gt; null then
			ti := theObject.CM_TrackedItem;
			if ti.myBOLDtl = null then
				// No booking item so is unreconciled
				self.loadUnreconciledTable();
			elseif eventType = Object_Update_Event then
				if self.tblUnreconciled.findObjectInRow(theObject, idx) then
					// A Ti that we had in the unreconciled table has changed
				   self.loadUnreconciledTable();
				endif;
			endif;
		endif;*/
	endif;


end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doTblExpMoveTI" id="8f9c48a4-c5f2-4c19-b8ef-3ba19ddb1de6">
        <updating/>
        <source>doTblExpMoveTI(_table: Table input; _win: Window)updating, protected;
//20 August 2009	cnwml2
/*

Date		Who		Reason
30 Aug 2012	cnwkpd1	PAR #28731 - Transient leaks in JMT
	
*/

vars
	sourceTable: CM_DataTable;
	targetRow: Integer;
	targetBOLDtl: CM_BOLDtl;
	sourceTI: CM_TrackedItem;
	tis: CM_TISet;
	result : Integer;
begin
	inheritMethod(_table, _win);
	sourceTable := _win.CM_DataTable;
//	if sourceTable = null or sourceTable.allSelectedObjects.first.isKindOf(CM_TrackedItem) then
		// source must be tracked items
//		return;
//	endif;
	
	if _table = self.tblExpected then
		// moving ti to a new booking item
		targetRow := self.tblExpected.accessedRow.row;
		if targetRow &gt; 1 then
			targetBOLDtl := self.tblExpected.accessRow(targetRow).itemObject.CM_BOLDtl;
			create tis transient;
			sourceTable.allSelectedObjects.copy(tis);
		endif;
	endif;
	if _table = self.tblUnreconciled then
		targetBOLDtl := null;
		create tis transient;
		sourceTable.allSelectedObjects.copy(tis);
	endif;

	while true do
		if not sourceTable.allSelectedObjects.isEmpty then
			self.myBOLAgent.moveTIsToBOLDtl(tis, self.myBOL, targetBOLDtl);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.tblUnreconMacro.rows := 0;
			self.tblUnreconMacro.columns := 0;
			return;
		endif;
		result := app.showErrorWarningDialog('BOL', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and  result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		return;
	endwhile;

epilog
	delete tis;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_win" type="Window"/>
    </JadeMethod>
    <JadeMethod name="doUserNotes" id="bef12598-87fa-4c29-b43f-93a3de39c2b0">
        <updating/>
        <source>doUserNotes(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     18 March 2010 by cnwcs5
// Purpose:     par 23239 - code moved from userNotify method
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	termEvent, 
	row 		: Integer;
	ti			: CM_TrackedItem;
	oldBOL		: CM_BOL;
begin 
	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(_eventType);
	endif;


	if termEvent = Event_BOLUpdate then 
		if _userInfo.Object = self.myBOL then
			self.loadData();
		else
			self.loadUnreconciledTable;
		endif;
	elseif termEvent = EVENT_TI_BOL_RECON then	// par 23239
		ti		:= _object.CM_TrackedItem;
		oldBOL	:= _userInfo.CM_BOL;
		
		if ti.myReceivalBOL = self.myBOL or
			oldBOL = self.myBOL then
			
			self.loadData;
			return;
		endif;
		// if we get to here then change relates to a ti on another bol so no need 
		// to refresh anything other than the unreconciled table
		if self.tblUnreconciled.findObjectInRow(ti, row) then
			// A Ti that we had in the unreconciled table has changed
			self.loadUnreconciledTable();
		else
			// the object was not already in the unreconciled table
			if ti.myReceivalBOL = null then
				// not reconciled
				if optVoyage.value then
					self.loadUnreconciledTable;
				else
					// we are only looking at unreconciled items for the current booking
					// this is handled in the refreshForm above
				endif;
			endif;		
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="3e44273a-653a-4217-bc20-18fc4f93e895">
        <updating/>
        <source>initForm() updating;
//05 August 2009	cnwdw1	
//18 March 2010		cnwcs5	par 23239 - rationalize notifications
vars

begin
	inheritMethod();
	
	self.initNotes();
	
	self.lblExpected.caption := app.getErrorString(BOL_Items);	
	//self.lblActual.caption := app.getErrorString(Cargo_Receivals);	
	//self.lblUnreconciled.caption := app.getErrorString(Unreconciled_Receivals);	
	
	self.btnEditRecon.caption := app.getErrorString(BOL_Edit);
	
	self.optBOL.value := true;

	if self.xmlStrTblExpected &lt;&gt; null then
		self.tblExpected.setTblDataEntRowsArray(app.myController.getEntTableDef(ETDef_DocketTblItems), null, self.xmlStrTblExpected);	
	else	
		self.tblExpected.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_DocketTblItems));
	endif;
	
	if self.xmlStrTblActual &lt;&gt; null then
		self.tblActual.setTblDataEntRowsArray(app.myController.getEntTableDef(ETDef_DefaultCargoEnt), null, self.xmlStrTblActual);	
	else	
		self.tblActual.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_DefaultCargoEnt));
	endif;
	
	if self.xmlStrTblUnreconciled &lt;&gt; null then
		self.tblUnreconciled.setTblDataEntRowsArray(app.myController.getEntTableDef(ETDef_DefaultCargoEnt), null, self.xmlStrTblUnreconciled);	
	else	
		self.tblUnreconciled.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_DefaultCargoEnt));
	endif;
//	-- PAR 	23239
//	self.beginClassNotification(CM_BookingRef, false, self.myTerminal.getTerminalEvent(Event_BOLUpdate), Response_Continuous, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="initNotes" id="aaaf55d0-53a5-4913-9cb4-a6d781086803">
        <source>initNotes();
//12 August 2009	cnwdw1	
//18 March 2010 	cnwcs5	par 23239 - rationalize notifications
vars

begin
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_BOLUpdate), Response_Continuous, 0);		// PAR 23239
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(EVENT_TI_BOL_RECON), Response_Continuous, 0);	// PAR 23239
	self.beginClassNotification (CM_BOLIn, false, Object_Delete_Event, Response_Continuous, 0);	// par 23239
	
/*	self.beginNotification(self.myBOL, Object_Update_Event, Response_Continuous, 0);
	self.beginNotification(self.myBOL, Object_Delete_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, Object_Create_Event, Response_Continuous, 0);
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="inspectObject" id="4dfde20b-075f-4e09-9838-cc5a29a87043">
        <source>inspectObject();
//25 January 2010	cnwml2


vars

	obj 		: Object;
