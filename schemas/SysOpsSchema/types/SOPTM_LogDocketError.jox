    <JadeMethod name="doSave" id="0632f6eb-7bdc-4791-917f-206a8eaefb95">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwas3	Initial creation

*/

vars
	errObj:CM_Error;
	idx:Integer;
	tmpListBox:ListBox;
	ignoreWarnings,rtnValue:Boolean;
	pxyLogDocketError:CM_DocketErrorType;
	lCode,lDescription:String;
	notAvailForEntry	: Boolean;
	theForm : SOP_TableMaintForm;
begin

  	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	notAvailForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DocketErrorType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name,app.getErrorString(Proxy_object_null_update));
			return false;
		endif;
	endif;

	pxyLogDocketError := theForm.myProxyObject.CM_DocketErrorType;
	pxyLogDocketError.setProxy(lCode, lDescription,false, notAvailForEntry,0);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDocketErrorType(pxyLogDocketError, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDocketErrorType(pxyLogDocketError, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
