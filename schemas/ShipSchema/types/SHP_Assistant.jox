    <JadeMethod name="showCCVoyage" id="dcae5391-3b7f-4ab8-a57d-f48da3101b4c">
        <source>showCCVoyage(_parentForm : SHP_VoyageAreaForm2; _voyage : CM_Voyage;_masterMenuAction : CMUI_MenuAction; _description : String; _isExport : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwas3	Initial creation

*/

vars
	theForm				: CMUI_YAMaintVoyForm;
	defaultAlooc	: CM_YardAllocation;
	obj				: Any;
	wagon			: CM_Wagon;
	yas : ObjectArray;
	parentForm : SHP_VoyageAreaForm2;
begin
	parentForm := _parentForm;
	
	theForm := app.loadForm(CMUI_YAMaintVoyForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_YAMaintVoyForm;
	if theForm = null then
		return;
	endif;	
	//theForm.setPosition(10,10);
	defaultAlooc := _voyage.getVoyageAllocation(_description);
	
	if defaultAlooc &lt;&gt; null then
		create yas transient;
		if defaultAlooc &lt;&gt; null then
			yas.add(defaultAlooc);
		endif;
	endif;
	
	//theForm.isModal := false;
	theForm.myVoyage := _voyage;
	theForm.allVoyages.add(_voyage);
	theForm.setYardAllocation(yas);
	theForm.isExport := _isExport;
	theForm.setPosition(10,10);
	//theForm.doCriteriaReset();
	theForm.setFormParent(_parentForm);
	theForm.setParentForm(_parentForm);
	parentForm.setMyCCScreen(theForm);
	//theForm.setPosition(10,10);
	//theForm.setPropertyValue('top',10);
	
	theForm.show();
	theForm.doChangeIMEX(_isExport);	//+cnwas3 par 27507
	theForm.doCriteriaReset();
	
	
epilog

	delete yas;
end;</source>
        <Parameter name="_parentForm" type="SHP_VoyageAreaForm2"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isExport" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCCVoyageRORO" id="10d7f252-bdba-4332-a2bf-6adf5f0c1521">
        <source>showCCVoyageRORO(_parentForm : SHP_ROROPlanningForm; _voyage : CM_Voyage;_masterMenuAction : CMUI_MenuAction; _description : String; _isExport : Boolean);
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/


vars
	theForm				: CMUI_YAMaintVoyForm;
	defaultAlooc	: CM_YardAllocation;
	obj				: Any;
	wagon			: CM_Wagon;
	yas : ObjectArray;
	parentForm : SHP_ROROPlanningForm;
begin
	parentForm := _parentForm;
	
	theForm := app.loadForm(CMUI_YAMaintVoyForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_YAMaintVoyForm;
	if theForm = null then
		return;
	endif;	

	defaultAlooc := _voyage.getVoyageAllocation(_description);
	
	if defaultAlooc &lt;&gt; null then
		create yas transient;
		if defaultAlooc &lt;&gt; null then
			yas.add(defaultAlooc);
		endif;
	endif;
	
	theForm.myVoyage := _voyage;
	theForm.allVoyages.add(_voyage);
	theForm.setYardAllocation(yas);
	theForm.isExport := _isExport;
	theForm.setPosition(10,10);
	theForm.setFormParent(_parentForm);
	theForm.setParentForm(_parentForm);
	parentForm.setMyCCScreen(theForm);
	
	theForm.show();
	theForm.doChangeIMEX(_isExport);	
	theForm.doCriteriaReset();
	
	
epilog

	delete yas;
end;</source>
        <Parameter name="_parentForm" type="SHP_ROROPlanningForm"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isExport" type="Boolean"/>
