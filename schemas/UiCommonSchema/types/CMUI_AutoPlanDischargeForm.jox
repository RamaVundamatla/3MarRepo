    <JadeMethod name="doQueryUnload" id="1f1193e7-25ee-4c6d-9f8f-34b6a8ce3807">
        <source>doQueryUnload(cancel: Integer io; reason: Integer) protected;

// Created by cnwdvb1 on 03 May 2006

vars

begin

	if self.myWleSetOut.isEmpty() then
		return;
	endif;
	
	if app.msgBox('The system will not be able to automatically determine which items to un plan once this window is closed. Are you sure you wish to close this window.', 'Auto Discharge Window Closure', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		cancel := 1;
		return;
	endif;
	
	return;

end;</source>
        <access>protected</access>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
