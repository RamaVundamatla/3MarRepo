    <JadeMethod name="getDisplayStringForAttribute" id="888b1c7f-ce03-43a1-b29d-bacbe2d8fcb1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	resourcePilotLaunch : HMS_ResourceForPilotLaunch;
begin		
	if _attrName = ETRow_MyHarbour then
		if self.myCurrentHarbour &lt;&gt; null then
			return self.myCurrentHarbour.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyArrivalResource then
	resourcePilotLaunch := self.allResourcesForPilotLaunch[self.myCurrentHarbour, self];
		if resourcePilotLaunch &lt;&gt; null and resourcePilotLaunch.myArrivalResource &lt;&gt; null then 
			return (resourcePilotLaunch.myArrivalResource.description);
		else 
			return null;
		endif;
		
	elseif _attrName = ETRow_MyDepartResource then
	resourcePilotLaunch := self.allResourcesForPilotLaunch[self.myCurrentHarbour, self];
		if resourcePilotLaunch &lt;&gt; null and resourcePilotLaunch.myDepartResource &lt;&gt; null then 
			return (resourcePilotLaunch.myDepartResource.description);
		else 
			return null;
		endif;
	elseif _attrName = ETRow_MyShiftResource then
	resourcePilotLaunch := self.allResourcesForPilotLaunch[self.myCurrentHarbour, self];
		if resourcePilotLaunch &lt;&gt; null and resourcePilotLaunch.myShiftResource &lt;&gt; null then 
			return (resourcePilotLaunch.myShiftResource.description);
		else 
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResourceForHarbourMovement" id="a1147d93-efbb-4d8e-9d8f-9181690e3d91">
        <source>getResourceForHarbourMovement(_harbour : HMS_Harbour; _movement : String) : HMS_Resource;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	realResource : HMS_Resource;
	resourceLineComp : HMS_ResourceForPilotLaunch;
begin		
	if _harbour = null then
		return null;
	endif;
	
	resourceLineComp := self.allResourcesForPilotLaunch[_harbour, self];
	if resourceLineComp &lt;&gt; null then
		if _movement = HMSMovementTypeArrival then
			return resourceLineComp.myArrivalResource;
		elseif _movement = HMSMovementTypeDeparture then
			return resourceLineComp.myDepartResource;
		else
			return resourceLineComp.myShiftResource;
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_movement" type="String"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2e833030-bd1e-4966-a8e3-90036691a550">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy	:	HMS_PilotLaunch;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	proxy.myCurrentHarbour := self.myCurrentHarbour;		
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="09c9067c-2364-4345-be8b-52e5aecf8165">
        <updating/>
        <source>setForDelete(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	resourceForPilotLaunch	: HMS_ResourceForPilotLaunch;
begin
	inheritMethod(_passport);
	foreach resourceForPilotLaunch in self.allResourcesForPilotLaunch do
		resourceForPilotLaunch.setForDelete(_passport);
		resourceForPilotLaunch.erase(NORMAL_ERASE);
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e49acc58-eab8-4e8e-8c73-4f2869f496c2">
        <updating/>
        <source>setForUpdate(_pxyPilotLaunch: HMS_PilotLaunch; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
// 03-JUL-2014  cnwma1 CCMS SFW1328 -HMS Not Available For Entry 
//--------------------------------------------------------------
vars
	tmpresoucesForPilotLaunch,
	resoucesForPilotLaunch	: HMS_ResourceForPilotLaunch;
begin
	inheritMethod(_pxyPilotLaunch, _passport);

	self.code 					:= _pxyPilotLaunch.code.toUpper.trimBlanks;
	self.description			:= _pxyPilotLaunch.description;
	self.isNotAvailableForEntry	:= _pxyPilotLaunch.isNotAvailableForEntry; 	//  cnwma1 3/7/2014   CCMS SFW 1328
	self.myCurrentHarbour		:= _pxyPilotLaunch.myCurrentHarbour;
	self.myRoot			:= _pxyPilotLaunch.myRoot;
	
	foreach tmpresoucesForPilotLaunch in self.allResourcesForPilotLaunch do
		tmpresoucesForPilotLaunch.setForDelete(_passport);
	endforeach;
	
	self.allResourcesForPilotLaunch.purge();
	
	foreach tmpresoucesForPilotLaunch in _pxyPilotLaunch.allResourcesForPilotLaunch do
		create resoucesForPilotLaunch persistent;
		resoucesForPilotLaunch.setPilotLaunch(self);
		resoucesForPilotLaunch.setForUpdate(tmpresoucesForPilotLaunch, _passport);
	endforeach;
end;</source>
        <Parameter name="_pxyPilotLaunch" type="HMS_PilotLaunch"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="df946cf5-b904-46cb-a430-b0de9969397b">
        <updating/>
        <source>setProxy(_root : CM_Root; _harbour: HMS_Harbour)updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot := _root;
	self.myCurrentHarbour := _harbour;
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="024f1fda-e7e2-4a15-92f4-18a3d98aa6ba">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars

begin
	inheritMethod(_passport);
	if (not self.allVoyageMovements.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.description, "Voyage Movement", null, null);	
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="fd5752e6-a94f-4dcc-8ae6-cbe918ae63e6">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//----------------------------------------------------------

vars
	tmpPilotLaunch	:	HMS_PilotLaunch;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
//		app.raiseCMException1( REQUIRED_FIELD, 'Code', ETRow_Code, null );
		app.raiseCMException( Input_required_field_code, ETRow_Code, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.description = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Description', ETRow_Description, null );
		app.raiseCMException( Input_required_field_Desc, ETRow_Description, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.myRoot = null then
	//	app.raiseCMException1( REQUIRED_FIELD , 'Harbour Root', null, null );
		app.raiseCMException( Input_required_field_harbRoot, null, null ); // cnwdb2	PAR 35364


	endif;

	if self.myCurrentHarbour = null then
	//	app.raiseCMException1( REQUIRED_FIELD , 'Harbour', null, null );
		app.raiseCMException( Input_required_field_harbour, null, null ); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	tmpPilotLaunch := self.myRoot.allPilotLaunches.getAtKey(self.code);
	if tmpPilotLaunch &lt;&gt; null then
		if self.isTransient and tmpPilotLaunch &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Pilot Launch', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Pilot Launch already exists for %1 : Pilot_launch_already_exists
			app.raiseCMException1(Pilot_launch_already_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;

epilog


end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
