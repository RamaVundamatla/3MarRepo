    </ExplicitInverseRef>
    <JadeMethod name="set" id="36af8b6b-adb1-41d7-aea2-65c7ae7e6974">
        <updating/>
        <source>set(_name : String; _myIniFile : DEV_IniFile) updating;

vars

begin
	self.name := _name;
	self.myIniFile := _myIniFile;
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_myIniFile" type="DEV_IniFile"/>
    </JadeMethod>
</Class>
