<Class name="CM_YATypeGrammage" id="3b6b238d-102f-4980-bfd7-d3c8011a6e1e">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaValueForTi" id="1be4da0a-5331-41f3-8748-2c027c57262d">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 May 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _ti.isKindOf(CM_BreakBulkGeneric) then
		//_criteriaValue := _ti.CM_BreakBulkGeneric.grammage;
		_criteriaValue := _ti.CM_BreakBulkGeneric.getGrammage().Decimal;	// ### TFS 54021 29June2022 NAVPW1
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
