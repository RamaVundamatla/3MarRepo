    <JadeMethod name="initShtMultiSelect" id="41d8272b-efef-4007-be1f-e71f58ae9b9a">
        <source>initShtMultiSelect();
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 01 September 2003
//
//-----------------------------------------------------------------------

vars
	terminology : String;
begin
	
	inheritMethod();
	terminology := app.getTerminologyAlternate(null, null, 'Consignee', CM_TermExpressionPlural, 'Consignees') &amp; '/' &amp;
	app.getTerminologyAlternate(null, null, CM_TerminologyConsignor, CM_TermExpressionPlural, 'Consignors');

	self.setupMultiSelect1(terminology,app.myRoot.allConsigneeConsignors,SOP_TableMaintForm::displayEntryConsignee.name);	
end;</source>
    </JadeMethod>
