    <JadeMethod name="delete" id="8ef55cc3-ab78-4307-8280-6a0f665affd9">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		01 August 2002 by cnwdad1
//
// Purpose:		Passes this event onto the Form Interface class for processing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyFormInterface &lt;&gt; null
	and global.isValidObject(self.aMyFormInterface)
	then
		self.aMyFormInterface.sendMsg("formDelete");
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteSelectedNodes" id="21bc9819-61e0-4735-84f9-1c9a63c56de4">
        <updating/>
        <source>doDeleteSelectedNodes() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		Deletes the selected file/directory nodes.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theContainer	: JSSFMFileNode;
	theNode			: JSSFMFileNode;
	sourcePath		: String;
	theFileAgent	: JSSFMFileAgent;
	
begin
	self.getServiceInterfaceSettings();
	theFileAgent	:=	self.getFileAgent();
	
	// Iterate through the selected files/diectories.
	
	foreach theContainer in self.aAllCutAndPasteObjects do
		foreach theNode in theContainer.JSSFMFolder.allFileNodes do
			sourcePath	:=	theNode.pathName;
			
			// Remove the file/directory node.
			
			if theNode.nodeType = self.LISTBOX_NODE_LOCAL_FOLDER then
				theFileAgent.deleteDirectory(sourcePath, JSSFMFileManagerService.NODE_SOURCE_CLIENT);
				
			elseif theNode.nodeType = self.LISTBOX_NODE_LOCAL_FILE then
				theFileAgent.deleteFile(sourcePath, JSSFMFileManagerService.NODE_SOURCE_CLIENT);
				
			elseif theNode.nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
				theFileAgent.deleteDirectory(sourcePath, JSSFMFileManagerService.NODE_SOURCE_APPSERVER);
				
			elseif theNode.nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
				theFileAgent.deleteFile(sourcePath, JSSFMFileManagerService.NODE_SOURCE_APPSERVER);
				
			elseif theNode.nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
				theFileAgent.deleteDirectory(sourcePath, JSSFMFileManagerService.NODE_SOURCE_DBSERVER);
				
			elseif theNode.nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
				theFileAgent.deleteFile(sourcePath, JSSFMFileManagerService.NODE_SOURCE_DBSERVER);
				
			endif;
			
			self.listRemoveDirectory(lstDirTop, sourcePath);
			self.listRemoveDirectory(lstDirBottom, sourcePath);
			self.tableRemoveFileNode(tblFilesTop, sourcePath);
			self.tableRemoveFileNode(tblFilesBottom, sourcePath);
		endforeach;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFetchDirectoryContents" id="c72313c3-416d-4a81-bf4e-0e63275ffabe">
        <source>doFetchDirectoryContents(	pPathName:String;
							pTheContainer:JSSFMFolder input;
							pIsDbServer:Boolean;
							pIsAppServer:Boolean;
							pIsUnix:Boolean;
							pAllPathNames:HugeStringArray) protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Fetches the subdirectories and files for the specified directory
//				name.  Note: Do not invoke this method directly - there are two
//				wrapper methods for client and server execution which should be
//				called instead.
//
// Parameters:	pPathName - The name of the directory who's nodes to fetch.
//				pTheContainer - The JSSFM file folder object which will be populated
//					with sub-node objects.
//				pIsDbServer - A flag to indicate whether the node is the database
//					Server node.
//				pIsAppServer - A flag to indicate whether the node is the Application
//					Server node.
//				pIsUnix - True if the directory's OS platform is Unix.
//				pAllPathNames - An array of restricted directory names.  If this
//					array is empty, then access will be allowed to all directories,
//					otherwise only the directory names in the array will be accessible.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	diskFolderObj		: FileFolder;
	theDiskNode			: FileNode;
	folderNodeType		: Integer;
	fileNodeType		: Integer;
	isRestricted		: Boolean;
	diskNodeName		: String;
	nodeNameLength		: Integer;
	checkPathName		: String;
	checkNameLength		: Integer;
	isPathAccessible	: Boolean;
	isDriveFound		: Boolean;
	fileSeparator		: String;
	
begin
	create diskFolderObj transient;
	diskFolderObj.usePresentationFileSystem	:=	(not pIsAppServer);
	diskFolderObj.fileName	:=	pPathName;
	
	if pIsDbServer then
		folderNodeType	:=	self.LISTBOX_NODE_DB_SERVER_FOLDER;
		fileNodeType	:=	self.LISTBOX_NODE_DB_SERVER_FILE;
	elseif pIsAppServer then
		folderNodeType	:=	self.LISTBOX_NODE_APP_SERVER_FOLDER;
		fileNodeType	:=	self.LISTBOX_NODE_APP_SERVER_FILE;
	else
		folderNodeType	:=	self.LISTBOX_NODE_LOCAL_FOLDER;
		fileNodeType	:=	self.LISTBOX_NODE_LOCAL_FILE;
	endif;
	
	if pIsUnix then
		fileSeparator	:=	JSS_SEPARATOR_UNIX;
	else
		fileSeparator	:=	JSS_SEPARATOR_WIN;
	endif;
	
	isRestricted	:=	(not pAllPathNames.isEmpty());
	
	foreach theDiskNode in diskFolderObj.files() do
		theDiskNode.usePresentationFileSystem	:=	diskFolderObj.usePresentationFileSystem;
		
		isPathAccessible	:=	true;
		
		if isRestricted then
			diskNodeName		:=	theDiskNode.fileName.toUpper() &amp; fileSeparator;
			nodeNameLength		:=	diskNodeName.length();
			isPathAccessible	:=	false;
			
			foreach checkPathName in pAllPathNames do
				checkNameLength	:=	checkPathName.length();
				
				if checkNameLength = 0 then
					continue;
				elseif diskNodeName[1] = checkPathName[1] then
					isDriveFound	:=	true;
					
					if diskNodeName = checkPathName then
						isPathAccessible	:=	true;
						break;		// This path name can be accessed.
					else
						if nodeNameLength &gt; checkNameLength then
							if diskNodeName[1:checkNameLength] = checkPathName then
								isPathAccessible	:=	true;
								break;		// This path name can be accessed.
							endif;
						elseif checkNameLength &gt; nodeNameLength then
							if checkPathName[1:nodeNameLength] = diskNodeName then
								isPathAccessible	:=	true;
								break;		// This path name can be accessed.
							endif;
						endif;
					endif;
				endif;
			endforeach;
			
			if (not isDriveFound) then
				isPathAccessible	:=	true;
			endif;
		endif;
		
		if isPathAccessible then
			if theDiskNode.isKindOf(FileFolder) then
				pTheContainer.addFolder(theDiskNode.name, theDiskNode.fileName, folderNodeType, pIsUnix);
			else
				pTheContainer.addFile(	theDiskNode.name,
										theDiskNode.fileName,
										fileNodeType,
										pIsUnix,
										theDiskNode.File.fileLengthDec(),
										theDiskNode.File.lastModified(),
										theDiskNode.File.archive,
										theDiskNode.File.hidden,
										theDiskNode.File.readOnly,
										theDiskNode.File.systemFile);
			endif;
		endif;
	endforeach;
epilog
	delete diskFolderObj;
end;</source>
        <access>protected</access>
        <Parameter name="pPathName" type="String"/>
        <Parameter name="pTheContainer" type="JSSFMFolder" usage="input"/>
        <Parameter name="pIsDbServer" type="Boolean"/>
        <Parameter name="pIsAppServer" type="Boolean"/>
        <Parameter name="pIsUnix" type="Boolean"/>
        <Parameter name="pAllPathNames" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="doFetchDirectoryContentsClient" id="aadf7480-1967-416a-9932-414e07740503">
        <executionLocation>client</executionLocation>
        <source>doFetchDirectoryContentsClient(	pPathName:String;
								pTheContainer:JSSFMFolder input;
								pIsAppServer:Boolean;
								pIsUnix:Boolean) protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		This method is a wrapper for the doFetchDirectoryContents method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_DB_SERVER	: Boolean = false;
	
vars
	allPathNames	: HugeStringArray;
	
begin
	create allPathNames transient;
	
	if pIsAppServer then
		self.aAllPathNamesAppServer.copy(allPathNames);
	endif;
	
	self.doFetchDirectoryContents(	pPathName,
									pTheContainer,
									IS_DB_SERVER,
									pIsAppServer,
									pIsUnix,
									allPathNames);
epilog
	delete allPathNames;
end;</source>
        <access>protected</access>
