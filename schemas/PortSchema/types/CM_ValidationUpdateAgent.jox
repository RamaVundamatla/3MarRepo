    <JadeMethod name="valDisassembleLogs" id="bd171ecb-ac20-499e-ae34-febb18852c81">
        <source>valDisassembleLogs(_oldLog : CM_Log; _newLogArray : CMIF_LogRegradeArray; _residualLength, _residualVolume : Real; _reason, _recovery, _user : String);
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newLog 		: CMIF_LogRegrade;
	volume		: Real;
	length		: Real;
		
begin

	foreach newLog in _newLogArray do
		 newLog.validate();
	endforeach;
	
	// Logs cannot be longer than original.
	if _residualLength &lt; 0 then
		app.raiseCMException1(LengthOfNewExceedsOld, null, null,null);
	endif;
	
	self.valRejectTrackedItems(_reason, _recovery, TRANS_TYPE_DISASSEMBLY, null);
	
	// User is a required field. This should be passed through from the form.
	if _user = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User', 'User', null);
		app.raiseCMException(Input_required_field_Usr, 'User', null); // cnwdb2	PAR 35364
	endif;
	
end;</source>
        <Parameter name="_oldLog" type="CM_Log"/>
        <Parameter name="_newLogArray" type="CMIF_LogRegradeArray"/>
        <Parameter name="_residualLength" type="Real"/>
        <Parameter name="_residualVolume" type="Real"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_recovery" type="String"/>
        <Parameter name="_user" type="String"/>
    </JadeMethod>
