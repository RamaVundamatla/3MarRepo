    <JadeMethod name="xPAR31367StatusBarStepB2" id="6fb7cae3-9eb0-4ec3-83cc-4fd5947a83b6">
        <updating/>
        <source>xPAR31367StatusBarStepB2() updating;

/*

Purpose:		Colour code and check that the status bar is correct

Date			Who		Reason
23/03/2013		cnwmh5	Initial creation

*/
vars

	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	locnGCDefnVoyage					: CM_ROROGCDefnVoyage;
	slotDefn 							: CM_ROROSlotDefn;
	slotLC 								: CM_ROROSlotController;
	
	dischargeLocn						: StringArray;
	
	locn								: String;
	
begin

	app.writeLog("STEP B2", LogINFO);
	app.writeLog("Colour code discharge jobs.  Creating dischargeJobs.  Please wait...", LogINFO);
	
	// locations to discharge colour code
	create dischargeLocn transient;
	dischargeLocn.add("D4083");
	dischargeLocn.add("D4082");
	dischargeLocn.add("D4087");
	dischargeLocn.add("D4074");
	dischargeLocn.add("D4070");
	dischargeLocn.add("D4075");
	dischargeLocn.add("D4199");
	
	dischargeLocn.add("D4086");
	dischargeLocn.add("D4085");
	dischargeLocn.add("D4076");
	dischargeLocn.add("D4077");
	dischargeLocn.add("D4064");
	dischargeLocn.add("D4040");
	dischargeLocn.add("D4065");
	
	beginTransaction;
	foreach locn in dischargeLocn do
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			if (locn = "D4040" or locn = "D4064" or locn = "D4199" or locn = "D4065") and 
					slotLC.ordinalSlot &lt;= 3 then
				continue;
			endif;
			slotLC.CM_ROROSlotController.createDefaultDischargeCC(app.myPassport, true);
		endforeach;
	
	endforeach;
	commitTransaction;
	
	// GC Area
	dischargeLocn.clear();
	dischargeLocn.add("D4001G");
	
	beginTransaction;
	foreach locn in dischargeLocn do
		locnGCDefnVoyage := self.myDeck.allROROGCDefnByCode[locn].CM_ROROGCDefnVoyage;
		self.assertNotEqual(locnGCDefnVoyage, null);
		locnGCDefnVoyage.myGCController.createDefaultDischargeCC(app.myPassport, true);
	endforeach;
	commitTransaction;
	
	// OOTL Discharge
	dischargeLocn.clear();
	dischargeLocn.add("D4421OR");
	dischargeLocn.add("D4423OR");
	dischargeLocn.add("D4424OR");
	dischargeLocn.add("D4414O");
	dischargeLocn.add("D4412O");
	dischargeLocn.add("D4411O");
	
	dischargeLocn.add("D4426OR");
	dischargeLocn.add("D4428OR");
	dischargeLocn.add("D4420O");
	dischargeLocn.add("D4418O");
	
	beginTransaction;
	foreach locn in dischargeLocn do
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			slotLC.CM_ROROSlotController.createDefaultDischargeCC(app.myPassport, true);
		endforeach;
	
	endforeach;
	commitTransaction;
	
	/*
	
	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogAlways);
	
	// check that the details of the status bar is correct - Hide Exports
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004 Job: 200");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008 Job: 200");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012 Job: 201");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019 Job: 205");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015 Job: 203");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 4 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018, UT313670015");
	self.locationArray.add("D4021");
	self.statusArray.add("D4021 D4021 | Aft: D4016 | 5 x CONT AUSYD  U40G | UT313670040, UT313670041, UT313670042, UT313670043, UT313670044");
	
	self.locationArray.add("D4060");
	self.statusArray.add("D4060 D4060 | Aft: D4055 | 4 x CONT AUBRI  U20G| 3 x CONT AUSYD  U40G | UT313670059, UT313670060, UT313670045, UT313670046, UT313670047, UT313670057, UT313670058");
	self.locationArray.add("D4040");
	self.statusArray.add("D4040 D4040 | Aft: D4035 | 4 x CONT AUSYD  U40G | UT313670048, UT313670049, UT313670050, UT313670051");
	self.locationArray.add("D4036");
	self.statusArray.add("D4036 D4036 |  Fwd: D4041 | 5 x CONT AUBRI  U20G | UT313670061, UT313670062, UT313670063, UT313670064, UT313670065");
	self.locationArray.add("D4041");
	self.statusArray.add("D4041 D4041 | Aft: D4036  | ");
	self.locationArray.add("D4037");
	self.statusArray.add("D4037 D4037 |  Fwd: D4042 | 5 x CONT AUBRI  U20G | UT313670066, UT313670067, UT313670068, UT313670069, UT313670070");
	self.locationArray.add("D4042");
	self.statusArray.add("D4042 D4042 | Aft: D4037 | 5 x CONT AUBRI  U20G | UT313670071, UT313670072, UT313670073, UT313670074, UT313670075");
	self.locationArray.add("D4043");
