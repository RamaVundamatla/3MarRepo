    <JadeMethod name="doActionTaskKnown" id="5232dd9d-e8f6-439d-8c97-7baf309764e8">
        <updating/>
        <source>doActionTaskKnown(_woActionIF: CMIF_WorkOrderAction; _realJob: CM_Job io; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks

*/

vars

begin
	inheritMethod(_woActionIF, _realJob, _passport);

	if self.allSelectedTIs.first.myPrimaryActualLocation &lt;&gt; self.myUnpackToLocation then
		self.createQueuedMove(self.myUnpackToLocation);
	endif;
	
epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAdvWOTransactionType" id="ea5324dd-bb0e-489e-9c45-fd0cb71da0cb">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TIUNPACK_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TIUNPACK_UPDATED;
	else
		return TRANS_TYPE_WO_TIUNPACK_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="54a4f93f-6df4-4512-b6f3-e75cf686694a">
        <source>getDisplayString(_useShortDesc : Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Aug 2009	cnwmd1	Initial creation
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
06 Mar 2023 navma1 ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	displayStr, 
	locationStr : String;
	typeDesc    : String;
begin
	
	typeDesc := self.getTypeDescription();												  			 //29.09.2021 navma1 #51925
	
	if _useShortDesc then
			displayStr := typeDesc &amp;" Task #" &amp; self.getTaskSequenceNumber().String;				//06.03.2023 navma1 #56457:[56458]															 //29.09.2021 navma1 #51925
	else
		if self.myUnpackToLocation &lt;&gt; null then
			locationStr := self.myUnpackToLocation.getID();
		endif;
		
		displayStr := self.getLongDescription(typeDesc,locationStr);								//29.09.2021 navma1 #51925
	endif;
epilog
	return displayStr.trimBlanks;
end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
