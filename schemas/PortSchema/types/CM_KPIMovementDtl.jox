    <JadeMethod name="getTruckVisit" id="a885d23a-6245-4a10-bbe9-7b8d3570309c">
        <updating/>
        <source>getTruckVisit(truck: String) : CM_VehicleVisitRecord updating;
/*
Purpose: 		

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2012	cnwdw1	Initial creation
*/
vars
	iter: Iterator;
	visits: CM_VehicleVisitsByDTDups;
	visit: CM_VehicleVisitRecord;
	arrival: CM_VehicleVisitRecordDetail;
	token: Integer;
	sentinelDate: TimeStamp;
begin
	
	visits := self.getTerminal.allVehicleVisits;
	iter := visits.createIterator;
	visits.startKeyGtr(self.startTime, iter);
	sentinelDate := self.startTime.subtractHoursAndMinutes(24);

	while iter.back(visit) do
		if visit.timeIn &lt; sentinelDate then
			break;
		endif;
		if visit.vehicle &lt;&gt; null and visit.vehicle.code = truck then
			return visit;
		endif;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="truck" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="isDischarge" id="31a4f59f-f5ae-4980-a43a-eb6a051844c1">
