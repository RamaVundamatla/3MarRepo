    <JadeMethod name="comboBoxVehicleBookingRules" id="54d8cc7a-4902-46bb-bda8-245afa874ee9">
        <source>comboBoxVehicleBookingRules( _cmb : ComboBox input; _value : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2015	cnwndl1	Initial creation	Par 36234

*/

vars

	idx : Integer;

begin

	_cmb.clear();
	_cmb.sorted := false;
	
	idx := _cmb.addItem(CM_VehicleBookings.BVR0);
	idx := _cmb.addItem(CM_VehicleBookings.BVR1);
	
	if _value &lt;&gt; null then
		_cmb.listIndex := _cmb.findStringExact(1,_value);
	endif;
	
	if _cmb.listIndex &lt; 1 then
		_cmb.listIndex := _cmb.findStringExact(1,CM_VehicleBookings.BVR0);
	endif;
	

epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="283438fa-434d-4564-ab2a-25594c93ac8d">
        <updating/>
        <executionLocation>client</executionLocation>
