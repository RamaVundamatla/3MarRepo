    <JadeMethod name="setProxy" id="d5fe7e6d-f237-4ef6-889e-a00ae82a502c">
        <updating/>
        <source>setProxy(	pDesc						: String;
			pShortDesc					: String;
			pSortKey					: Integer;
			pReportDesc					: String;
			pEmptyReportColumn			: Integer;
			_trxTypeOnCompletion		: CM_TransactionType;		 // 22 Feb 2010 RJS - PAR 22099
			_trxTypeOnCreation 			: CM_TransactionType;		 //cnwrs1 CCMS 1826 29 July 2010
			pAllCargoTypes 				: Collection;
			pAllResourceTypes 			: Collection;				//18 Dec 2009	NDL	CCMS MES 1006
			_requiresWorkOrder 			: Boolean;
			_requiredExtraInfo 			: String;
			_selectedTerminals 			: CM_TerminalSet;			//13 Oct 2010	NDL Par 23991
			_selectedSubTerminals 		: CM_SubTerminalByCodeDict;	//13 Oct 2010	NDL Par 23991
			_type 						: Integer;
			_eventComplete 				: CM_EventType;
			_eventCreate				: CM_EventType;				//31/10/2022 navds20 TFS  #56634[54259]
			_doNotBlockRTL				: Boolean) updating;  
			
//31/10/2022 navds20 ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance
//22 May 2023  navmv20 CR 57924 Task 57920: UI - Work Order Trans Types on TO DO Tasks
//11/12/2023	jlizm1	TFS 61654 CUX ToDo Task don't block RTL
vars

	term : CM_Terminal;

begin
	self.raiseExceptionIfNotTransient(method);
	self.description			:=	pDesc;
	self.shortDescription		:=	pShortDesc;
	self.reportDescription		:=	pReportDesc;
	self.type 					:= _type;     			 		 //31/10/2022 navds20 TFS  #56634[54259]

	if self.type = TODO_TYPE_GROUP_TI					 		 // ### TFS  #56634[54259] 21NOV2022 NAVAB1
	or self.type = TODO_TYPE_GROUP_CARGOGROUP then 				 // ### TFS  #56634[54259] 28NOV2022 NAVAB1
		self.emptyReportColumn		:=	pEmptyReportColumn;
	
		//22/05/2023 navmv20 CR 57924 Task 57920 - START
		/*self.myTransactionType      :=  _trxTypeOnCompletion; 	 //cnwrs1 CCMS 1826 29 July 2010
		if self.myTransactionType &lt;&gt; null then
			self.trxTypeOnCompletion := self.myTransactionType.trxType;
		else
			self.trxTypeOnCompletion := null;
		endif;
		
		if _trxTypeOnCreation &lt;&gt; null then //cnwrs1 CCMS 1826 29 July 2010
			self.trxTypeOnCreation := _trxTypeOnCreation.trxType;
		else
			self.trxTypeOnCreation := null;
		endif;*/
		//22/05/2023 navmv20 CR 57924 Task 57920 - END
		self.allCargoTypes.clear();
		pAllCargoTypes.copy(self.allCargoTypes);
		self.requiresWorkOrder		:= _requiresWorkOrder;
		self.setRequiredExtraInfo(_requiredExtraInfo);  //19 Feb 2010	#cnwdz2	par22432 SFW 1071
		self.doNotBlockRTL			:= _doNotBlockRTL;
	
		//13 Oct 2010	NDL Par 23991
		self.allAllowedReleaseTerms.clear();
		if _selectedTerminals &lt;&gt; null and not _selectedTerminals.isEmpty then
			_selectedTerminals.copy( self.allAllowedReleaseTerms );
		endif;
		self.allAllowedEditSubTerms.clear();
		if _selectedSubTerminals &lt;&gt; null and not _selectedSubTerminals.isEmpty then
			_selectedSubTerminals.copy( self.allAllowedEditSubTerms );
		endif;
	else // ### TFS  #56634[54259] 21NOV2022 NAVAB1
		//start 02/11/2022 navds20 TFS  #56634[54259]
		self.myEventType := _eventComplete;
		
		if self.myEventType &lt;&gt; null then
			self.trxTypeOnCompletion := self.myEventType.type;
		else
			self.trxTypeOnCompletion := null;
		endif;
		
		if _eventCreate &lt;&gt; null then
			self.trxTypeOnCreation := _eventCreate.type;
		else
			self.trxTypeOnCreation := null;
		endif;
			//end 02/11/2022 navds20 TFS  #56634[54259]
	endif; // ### TFS  #56634[54259] 21NOV2022 NAVAB1
	
	//22/05/2023 navmv20 CR 57924 Task 57920 - START
	self.myTransactionType      :=  _trxTypeOnCompletion;
	if self.myTransactionType &lt;&gt; null then
		self.trxTypeOnCompletion := self.myTransactionType.trxType;
	elseif self.myEventType = null then
		self.trxTypeOnCompletion := null;
	endif;
		
	if _trxTypeOnCreation &lt;&gt; null then
		self.trxTypeOnCreation := _trxTypeOnCreation.trxType;
	elseif _eventCreate = null then
		self.trxTypeOnCreation := null;
	endif;
	//22/05/2023 navmv20 CR 57924 Task 57920 - END
	
	self.sortKey				:=	pSortKey;
	
	//18 Dec 2009	NDL	CCMS MES 1006
	self.allResourceTypes.clear();
	pAllResourceTypes.copy(self.allResourceTypes);
	
	
epilog

end;</source>
        <Parameter name="pDesc" type="String"/>
        <Parameter name="pShortDesc" type="String"/>
        <Parameter name="pSortKey" type="Integer"/>
        <Parameter name="pReportDesc" type="String"/>
        <Parameter name="pEmptyReportColumn" type="Integer"/>
        <Parameter name="_trxTypeOnCompletion" type="CM_TransactionType"/>
        <Parameter name="_trxTypeOnCreation" type="CM_TransactionType"/>
        <Parameter name="pAllCargoTypes" type="Collection"/>
        <Parameter name="pAllResourceTypes" type="Collection"/>
        <Parameter name="_requiresWorkOrder" type="Boolean"/>
        <Parameter name="_requiredExtraInfo" type="String"/>
        <Parameter name="_selectedTerminals" type="CM_TerminalSet"/>
        <Parameter name="_selectedSubTerminals" type="CM_SubTerminalByCodeDict"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_eventComplete" type="CM_EventType"/>
        <Parameter name="_eventCreate" type="CM_EventType"/>
        <Parameter name="_doNotBlockRTL" type="Boolean"/>
    </JadeMethod>
