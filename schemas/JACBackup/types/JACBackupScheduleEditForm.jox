		btnPathDef.enabled		:=	false;
		tbxPath1.readOnly		:=	true;
		btnPath1.enabled		:=	false;
		tbxPath2.readOnly		:=	true;
		btnPath2.enabled		:=	false;
		tbxPath3.readOnly		:=	true;
		btnPath3.enabled		:=	false;
		tbxPath4.readOnly		:=	true;
		btnPath4.enabled		:=	false;
		tbxPath5.readOnly		:=	true;
		btnPath5.enabled		:=	false;
		tbxPath6.readOnly		:=	true;
		btnPath6.enabled		:=	false;
		tbxPath7.readOnly		:=	true;
		btnPath7.enabled		:=	false;
		tbxPath8.readOnly		:=	true;
		btnPath8.enabled		:=	false;
		tbxPath9.readOnly		:=	true;
		btnPath9.enabled		:=	false;
		btnDone.enabled			:=	false;
	endif;
end;</source>
