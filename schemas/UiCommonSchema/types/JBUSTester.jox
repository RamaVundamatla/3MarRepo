    <JadeMethod name="cmbCommand_click" id="79b4e7a8-e180-4dde-95d4-2396f26242a9">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCommand_click(combobox: ComboBox input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	value : String;
begin

	if combobox.listIndex &lt; 0 then
		return;
	else
		value := combobox.itemText[combobox.listIndex];
		
		if value = self.CMD_READ_TAG then
			self.txtSlave_3.text := charsInTag.String;
		elseif value  = self.CMD_READER_STATUS then
			self.txtSlave_3.text := 1.String;
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbFunc_click" id="c0e6cfb5-d881-466b-b66c-cd09d832d519">
