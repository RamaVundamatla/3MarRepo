/*
Purpose:			
Date		Who		Reason
16 April 2012	cnwab1	Initial creation
*/

vars

begin

	if _isLoad then
		if self.mySlotRequestLoad &lt;&gt; null then
			return self.mySlotRequestLoad.isLinked();
		endif;
	else
		if self.mySlotRequestDischarge  &lt;&gt; null then
			return self.mySlotRequestDischarge.isLinked();
		endif;
	
	endif;
	
	return false;

epilog

end;</source>
