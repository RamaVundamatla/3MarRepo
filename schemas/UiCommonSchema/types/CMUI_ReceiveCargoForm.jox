//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	str 	: String;

begin
	// get codes from list box, display in text box and disappear the list box
	str := self.lstColourList.getSelectedString(CM_VehicleColour::colour.name);
	if str.length &gt; 30 then
		self.txtColourList.text := str[1:29]&amp; '...';
	else
		self.txtColourList.text := str;
	endif;
	self.txtColourList.visible := true;
	self.lstColourList.visible := false;
	self.lstColourList.parent := _fieldFrame;

epilog

end;</source>
