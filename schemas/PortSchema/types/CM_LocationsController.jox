    <JadeMethod name="isBoxcarCont" id="9bdd5887-cf64-4226-a144-bfbd62c35fd8">
        <source>isBoxcarCont(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 March 2013	cnwndl1	Initial creation	Par 31278

*/

