    <JadeMethod name="is40OverGap" id="d2c09028-ba97-47c2-90b4-0676dc506642">
        <source>is40OverGap(pDroppedPosition : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2001 By Andrew Bishop cnwab1
// Note:			Called form DRAG &amp; DROP
// Purpose:		if we are a 40 footer and a target for a move is in a fork lift stack then check whether we are over a gap
//				i.e. 20' stack location, gap, 20' stack location. If this is the case this is not allowed
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ta	: CM_TerminalArea;
	lc	: CM_LocationsController;
	gc	: CM_GapController;
	taString, locnString	: String;
	i, lAccess	: Integer;
begin
	//if not self.is40 then
	if not self.requiresMoreThan1TwentyLC() then  // PAR 16415 CCMS 1029
		return false;
	endif;
	
	foreach i in 1 to pDroppedPosition.length do
		if pDroppedPosition[i:1] = " " then
			taString := pDroppedPosition[1:i].trimBlanks;
			locnString := pDroppedPosition[i:end].trimBlanks;
		endif;
	endforeach;
	
	ta := self.myTerminal.allTerminalAreas[taString];
	
	if ta = null then
//	or not global.isValidObject(ta) then
		return false;
	endif;
	
	// Gaps are only on Fork Lifts, at the moment, so anything else can not be over a gap
	if not ta.isKindOf(CM_ForkLiftStack) then
		return false;
	endif;
	
	lc := ta.CM_ForkLiftStack.allGridControllersByName[locnString];

	if  lc.CM_StackController.myNextController = null then
		return false;	
	endif;
	
	if  lc.CM_StackController.myNextController &lt;&gt; null and lc.CM_StackController.myNextController.isKindOf(CM_GapController) then
		gc := lc.CM_StackController.myNextController.CM_GapController;
		if gc.width = 0 then
			return false;	
		endif;
	endif;

	return true;
	
end;</source>
        <Parameter name="pDroppedPosition" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
