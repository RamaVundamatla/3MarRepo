    <JadeMethod name="getProductTypeString" id="6010b376-83b3-4411-a1ee-55f418471bd9">
        <source>getProductTypeString(_productType: Integer) : String;
begin
	if _productType = ProductType_PieceBreakBulk then
		return ProductType_PieceBreakBulkStr;
	endif;
	if _productType = ProductType_BreakBulk then
		return ProductType_BreakBulkStr;
	endif;
	if _productType = ProductType_Bulk then
		return ProductType_BulkStr;
	endif;
	if _productType = ProductType_Trailer then
		return ProductType_TrailerStr;
	endif;
	if _productType = ProductType_Vehicle then
		return ProductType_VehicleStr;
	endif;
	if _productType = ProductType_CargoGroup then	//27 May 2015	NDL	Par 36338
		return ProductType_CargoGroupStr;
	endif;
	
	return "";		
epilog

end;</source>
        <Parameter name="_productType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSystemProduct" id="a1f62783-18bc-4213-8c13-f7524f0b3d78">
        <updating/>
        <source>getSystemProduct(_checkBoxIsUnticked : Boolean) updating, protected;
/* ---------------------------------------------------------------------------
Created:	25 May 2009	by cnwvu1

Purpose:	CCMS 1080 PAR19704. Creates proxy system dummy product for
			a user defined cargo type
			_checkBoxIsUnticked = true - means forced creation pxySystemProductType
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoType 			: CM_CargoType;
	systemProduct		: CM_Product;
	//tmpPxySystemProduct	: CM_Product;
	requiresSystemProductType	: Boolean;
	loadStateSet			: Boolean;
	
begin

	// All user-defined cargo types, that don't require subcargo types (product types), 
	// have one system dummy product,
	// which is editable on Cargo Types Maintenance. PAR 19704, CCMS 1080 May 2009
	if self.pxySystemProductType &lt;&gt; null then
		delete self.pxySystemProductType;	//just in case, if it not deleted yet.
	endif;

	if self.mode = Mode_Add then
		create self.pxySystemProductType transient;
		//setting default values for dummy product
		self.pxySystemProductType.setAsSystemForCargoTypeUserDef();
		self.pxySystemProductType.setProductDefaults(self.myProxyObject.CM_CargoType);
		
	elseif self.mode = Mode_Update then
		
		cargoType := self.myCurrentObject.CM_CargoType;
		
		if _checkBoxIsUnticked then
			requiresSystemProductType := true;	// when clicking on the "Sub Cargo Required" checkbox
		else
			requiresSystemProductType := cargoType.requiresSystemProductType();
		endif;
		
		//setting values from the existing dummy product 
		if not cargoType.isSystemCargoBOLType and requiresSystemProductType then
			if cargoType.mySystemProductType = null then
				create self.pxySystemProductType transient;
				//setting default values for dummy product
				self.pxySystemProductType.setAsSystemForCargoTypeUserDef();
				self.pxySystemProductType.setProductDefaults(self.myProxyObject.CM_CargoType);
			else
				systemProduct := cargoType.mySystemProductType;	// HERE !!!!!!!!!!!!! 
				app.cmsBeginLoad(loadStateSet);
				self.pxySystemProductType := systemProduct.pxyCreateUpdateProxy();
				app.cmsEndLoad(loadStateSet);
				self.pxySystemProductType.createProductAttributes();	//creating proxies for attributes
				self.pxySystemProductType.setForUpdate(systemProduct);
			endif;
		endif;
	
	endif;

epilog
	app.cmsEndLoad(loadStateSet);

end;</source>
        <access>protected</access>
        <Parameter name="_checkBoxIsUnticked" type="Boolean"/>
    </JadeMethod>
