<Class name="CM_Association">
    <JadeMethod name="asStringWithoutFailures" id="eda54132-a253-4ff2-a81c-345cda3d1428">
        <source>asStringWithoutFailures() : String;

/*

Purpose:		Return the details without the failures details	

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwmh5	Initial creation

*/

vars

	pos				: Integer;
	pos1			: Integer;
	returnValue		: String;
	
begin
	
	pos := 1;
	pos := self.stringValue.pos("====================", pos);
	
	if pos = 0 then
		returnValue := self.stringValue;
	else
		pos := pos + "====================".length + 1;
		pos := self.stringValue.pos("====================", pos);
		if pos &gt; 0 then
			pos := pos + "====================".length + 1;
			pos1 := pos;
			pos := self.stringValue.pos("FAIL", pos);
			if pos &gt; 0 then
				returnValue := self.stringValue[pos:end];
			else
				returnValue := self.stringValue[pos1:end];
			endif;
		endif;
	endif;
	
	returnValue := app.formatFailureDetails(returnValue);			// 06/09/2011 cnwmh5
	
	return returnValue;	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
