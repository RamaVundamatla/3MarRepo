	self.setupInvStatusEmailDefault(PINEmail_InvProcAPIOffset + CM_Invoice.INVOICE_SUSPENSE,
									app.invoiceStatusEnumToString(CM_InvoiceProcessInvoiceAPI.firstInstance, CM_Invoice.INVOICE_SUSPENSE),
									'Invoice', sa);
									
	self.setupInvStatusEmailDefault(PINEmail_InvProcAPIOffset + CM_Invoice.INVOICE_POSTED_REVERSE,
									app.invoiceStatusEnumToString(CM_InvoiceProcessInvoiceAPI.firstInstance, CM_Invoice.INVOICE_POSTED_REVERSE),
									'Invoice', sa);
	
	self.setupInvStatusEmailDefault(PINEmail_InvProcAPIOffset + CM_Invoice.INVOICE_POSTED_CREDIT,
									app.invoiceStatusEnumToString(CM_InvoiceProcessInvoiceAPI.firstInstance, CM_Invoice.INVOICE_POSTED_CREDIT),
									'Invoice', sa);						
	//navra1 - TFS 54090 - CR - 61386, Task - 61564 - 29th Nov 2023
	
	self.setupInvStatusEmailDefault(PINEmail_InvProcAPIOffset + CM_Invoice.INVOICE_POSTED_CREDIT_PENDING,
