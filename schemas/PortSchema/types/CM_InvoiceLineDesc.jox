    <JadeMethod name="setForCreate" id="61c81a57-47bf-4e64-8dab-ba809ba6e579">
        <updating/>
        <source>setForCreate(pProxyInvoiceLineDesc : CM_InvoiceLineDesc) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	pProxyInvoiceLineDesc.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.setForUpdate(pProxyInvoiceLineDesc);

	self.bank := pProxyInvoiceLineDesc.bank;

	if self.printingOrder  = 0 then // PAR 13340
		self.printingOrder := self.bank.invoiceLineDescriptors.size;
	endif;
end;</source>
        <Parameter name="pProxyInvoiceLineDesc" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e20d13f1-c816-4c03-aa46-17fdad3fac93">
        <updating/>
        <source>setForUpdate(pProxyInvoiceLineDesc : CM_InvoiceLineDesc) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 28/10/2021	navma1 		ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
// 31 Jan 2023 	navvt20  TFS 56132 Task 56134: UI - Invoice Line Type - UOM
vars
	 calcTypeChange : Boolean;
begin

	pProxyInvoiceLineDesc.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	calcTypeChange 					   := (self.myCalculationType &lt;&gt; pProxyInvoiceLineDesc.myCalculationType);
	self.bOneLinePerFinancialPeriod    := pProxyInvoiceLineDesc.bOneLinePerFinancialPeriod;
	self.bPrintTrackedItems 		   := pProxyInvoiceLineDesc.bPrintTrackedItems;
	self.myDebtorType 				   := pProxyInvoiceLineDesc.myDebtorType; 		// CentrePort CCMS 1047 Par 16666
	self.myCalculationType			   := pProxyInvoiceLineDesc.myCalculationType;	// 24024
	self.invoiceType 				   := pProxyInvoiceLineDesc.invoiceType;
	self.narration 					   := pProxyInvoiceLineDesc.narration ; //[1:60];         //28.10.2021 navma1 #52163
	self.remarks 					   := pProxyInvoiceLineDesc.remarks[1:601];
	self.unitNarration			 	   := pProxyInvoiceLineDesc.unitNarration[1:10];
	self.printingOrder 				   := pProxyInvoiceLineDesc.printingOrder;
	self.isNotAvailableForEntry		   := pProxyInvoiceLineDesc.isNotAvailableForEntry;
	self.currencyConversionNotRequired := pProxyInvoiceLineDesc.currencyConversionNotRequired; // TFS 41484
	self.taxAlwaysCharged 			   := pProxyInvoiceLineDesc.taxAlwaysCharged;	 		   //07 May 2019	NDL	TFS 44651
	self.services.clear;
	pProxyInvoiceLineDesc.services.copy(self.services);
	
	self.minimumChargeAmount 		   := pProxyInvoiceLineDesc.minimumChargeAmount;			// PAR #36909
	self.minimumChargeGroupBy 		   := pProxyInvoiceLineDesc.minimumChargeGroupBy;			// PAR #36909
	self.minimumChargeInvoiceLineType  := pProxyInvoiceLineDesc.minimumChargeInvoiceLineType;	// PAR #36909
	self.externalReference1 		   := pProxyInvoiceLineDesc.externalReference1; //30/3/22 jlier1	TFS 53286
	self.myUOM		      			   :=pProxyInvoiceLineDesc.myUOM;	// 31 Jan 2023 navvt20 TFS 56134
	// CCMS 1264 Apr 2012 update invoice line quantity (no longer dynamic) from change of calc type
	if calcTypeChange then
		self.updateInvoiceLineQuantity();
	endif;
end;</source>
        <Parameter name="pProxyInvoiceLineDesc" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
