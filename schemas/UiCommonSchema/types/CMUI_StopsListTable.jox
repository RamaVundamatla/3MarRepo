    <JadeMethod name="addSelectedStops" id="803c51a5-0f64-4a72-8350-6d5a9e1d52f6">
        <updating/>
        <source>addSelectedStops( _stops : CM_Stops ) updating;

/*
Date				Who		Reason
21 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	index		: Integer;
	
begin
	if _stops = null then
		return;
	endif;
	
	if self.allSelectedStops.includesKey( _stops.id ) then
		return;
	endif;
	
	// add it to the collection and check the appropriate row if in the displayed part of the table.
	self.allSelectedStops.add( _stops );
	if self.findObjectInRow( _stops, index ) then
		self.accessCell( index, self.chkBoxColumn ).text	:= TableCheckBox_Selected;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_stops" type="CM_Stops"/>
    </JadeMethod>
    <JadeMethod name="adjustColumns" id="1768d637-e4ae-4a42-b376-a79ee2ffb0f6">
        <updating/>
        <source>adjustColumns() updating;

/*
Purpose:	Make sure the StopsListTable is displayed in the space available nicely!

Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	colWidth	: Integer;
	
begin
	self.accessColumn( self.chkBoxColumn ).width	:= 25;
	self.accessColumn( self.dateInputColumn ).width	:= 75;
	
	
	colWidth	:=	self.width.Integer -
					self.accessColumn( self.chkBoxColumn ).width -
					self.accessColumn( self.dateInputColumn ).width -
					25;						// allow for the vertical scroll bar
	
	if colWidth &lt;= null then
		self.accessColumn( self.headingColumn ).width	:= 50;
	else
		self.accessColumn( self.headingColumn ).width	:= colWidth;
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="change" id="fcadfd12-bfcb-4b9d-b93c-3f96fe5b004d">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>change( _table : Table input ) updating, clientExecution;

/*
Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	bStopsIncluded	: Boolean;
	tempStr			: String;
	tempDate		: Date;
	stopsTable		: CM_StopsTable;
	stops			: CM_Stops;
	
begin
	inheritMethod( _table );
	
	if _table.row &lt;= _table.fixedRows or _table.row &gt; _table.rows then
		return;
	endif;
	
	stopsTable	:= _table.accessRow( _table.row ).itemObject.CM_StopsTable;
	
	// cnwrl1 18/01/2010 PAR 21889 - start of coding
	if self.rowChecked( _table.row ) then
		// reset the expiry date to null
		_table.setCellText( _table.row, self.dateInputColumn, null );
	endif;
	// cnwrl1 18/01/2010 PAR 21889 - end of coding
	
	// now make a proxy stops out of this stopsTable object.
	create stops transient;
	tempStr	:= _table.accessCell( _table.row, self.dateInputColumn ).text;
	// if a date is entered then the edit mask should stop it being invalid but just in case.
	if tempStr.Date.isValid then
		tempDate	:= tempStr.Date;
	else
		tempDate	:= null;
	endif;
	
	stops.id	:= stopsTable.id;
	stops.setClearanceExpiryDate( tempDate );
	
	// make sure it is in the appropriate collections,
	// first remove it
	bStopsIncluded	:= self.allSelectedStops.includesKey( stops.id );
	if bStopsIncluded then
		self.allSelectedStops.removeKey( stops.id );
	endif;
	
	bStopsIncluded	:= self.allStopsToBeUpdated.includesKey( stops.id );
	if bStopsIncluded then
		self.allStopsToBeUpdated.removeKey( stops.id );
	endif;
	
	// now add it to the collection it should be in, do it in this order to make
	// sure it only goes into the appropriate collection correctly only.
	if stops.clearanceExpiryDate &lt;&gt; null then
		self.allStopsToBeUpdated.add( stops );
	elseif self.rowChecked( _table.row ) then
		self.allSelectedStops.add( stops );
	else
		delete stops;			// avoids transient leaks.
	endif;
	
	// now reset the access and colour as required
	self.setExpiryDateAccessAndColour( stopsTable, self.row );
	
epilog
	// cnwrl1 01/02/2010 PAR 21889 - start of coding
	// possible transient leaks
	if stops &lt;&gt; null then
		if not self.allStopsToBeUpdated.includes( stops ) and not self.allSelectedStops.includes( stops ) then
			delete stops;
		endif;
	endif;
	// cnwrl1 01/02/2010 PAR 21889 - end of coding
	
end;
</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearSelected" id="a7aa5fa5-c7c6-47e8-bdd6-9474b0776744">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>clearSelected() updating, clientExecution;

/*
Purpose:	To clear the collections and selected table entries.

Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	index			: Integer;
	startRow		: Integer;
	maxRows			: Integer;
	
begin
	if not self.allExistingStops.isEmpty then
		// get rid of the transients CM_Stops;
		self.allExistingStops.purge;
	endif;
	self.allExistingStops.clear;
	
	if not self.allSelectedStops.isEmpty then
		// get rid of the transients CM_Stops;
		self.allSelectedStops.purge;
	endif;
	self.allSelectedStops.clear;
	
	if not self.allStopsToBeUpdated.isEmpty then
		// get rid of the transients CM_Stops;
		self.allStopsToBeUpdated.purge;
	endif;
	self.allStopsToBeUpdated.clear;
	
	startRow	:= self.fixedRows + 1;
	maxRows		:= self.rows;
	
	foreach index in startRow to maxRows do
		self.accessCell( index, self.chkBoxColumn ).text	:= TableCheckBox_NotSelected;
		self.accessRow( index ).selected					:= false;
	endforeach;
	
	if maxRows &gt;= startRow then
		self.row	:= startRow;
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="click" id="06d94875-5121-4f63-82c0-cf7c36da4f32">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click( _table : Table input ) updating, clientExecution;

/*
Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	tableCell	: JadeTableCell;
	theRow		: Integer;
	
begin
	if _table.readOnly then
		return;
	endif;
	
	theRow := _table.row;
	
	if _table.userInputEnabled and theRow &gt; _table.fixedRows and theRow &lt;= _table.rows then
		if self.doManually then
			// the click did not occured in the checkBox column so we
			// will need to change the value of the checkbox manually
			tableCell := _table.accessCell( theRow, self.chkBoxColumn );
			if tableCell.text = TableCheckBox_NotSelected then
				tableCell.text	:= TableCheckBox_Selected;
			else
				tableCell.text	:= TableCheckBox_NotSelected;
			endif;
			self.doManually	:= false;
			// and now call the change method with this new setting.
			_table.change( _table );
		endif;
	endif;
	
	inheritMethod( _table );

	if theRow &gt; _table.fixedRows and theRow &lt;= _table.rows then
		self.highlightRow( theRow );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="681da837-90e7-47a4-bcb8-8f5cc26bcc22">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;

/*
Purpose:	Setup what the Stops List Table looks like when first painted.
			See method windowCreated for each time the form loads.

Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	
begin
	self.fixedRows			:= 1;
	self.fixedColumns		:= 0;
	self.rows				:= self.fixedRows;
	self.columns			:= self.fixedColumns + 3;
	self.gridLines			:= true;
	self.fixed3D			:= false;
	self.userInputEnabled	:= true;
	self.selectMode			:= Table.SelectMode_Row;
	self.gridColor			:= CM_BaseForm.Color_GrayText;
	self.scrollBars			:= Table.ScrollBars_Both;
	self.autoSize			:= Table.AutoSize_ColumnMinimum;
	self.chkBoxColumn		:= self.fixedColumns + 1;
	self.headingColumn		:= self.fixedColumns + 2;
	self.dateInputColumn	:= self.columns;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="findObjectInRow" id="dc5cf47a-0cd0-450c-bd40-54cc3025db50">
        <updating/>
        <source>findObjectInRow( _obj : Object; _rowIdx : Integer io ) : Boolean updating;

/*
Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	index		: Integer;
	startRow	: Integer;
	numRows		: Integer;
	found		: Boolean;
	stopsTable	: CM_StopsTable;
	
begin
	if _obj = null then
		return found;
	endif;
	
	numRows	:= self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	
	startRow	:= (self.fixedRows + 1).max(_rowIdx);
	if startRow &gt; numRows then
		return found;
	endif;
	
	stopsTable	:= _obj.CM_Stops.myStopsTable;		// do this once outside loop.
	foreach index in startRow to numRows do
		if self.accessRow( index ).itemObject = stopsTable then
			found	:= true;
			_rowIdx	:= index;
			break;
		endif;
	endforeach;
	
	return found;
	
epilog
	
end;
</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringOfStops" id="408a17d4-af9a-48ce-b75e-fb1a5292d84f">
        <source>getDisplayStringOfStops() : String;

/*
Purpose:		Returns a string of all the stops both those selected and those with an expiry date.
				This method is used during lost focus to populate the stops table entry row.

Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	stops		: CM_Stops;
	terminal	: CM_Terminal;
	user		: CM_User;
	returnStr	: String;
	
begin
	if self.allSelectedStops.isEmpty and self.allStopsToBeUpdated.isEmpty then
		return returnStr;
	endif;
	
	// get the constant data once.
	user		:= app.getMyUser;
	terminal	:= self.getMyTerminalFromForm;
	if user = null or terminal = null then
		// if these do not exist have real problems!
		return returnStr;
	endif;
	
	// first those selected as being set.
	foreach stops in self.allSelectedStops do : stops_loop1
		// make sure the user has access to this StopsTable
		if not user.canViewStop( terminal, stops.myStopsTable ) then
			continue stops_loop1;
		endif;
		if returnStr &lt;&gt; null then
			returnStr	:= returnStr &amp; Comma_And_Space;
		endif;
		returnStr		:= returnStr &amp; stops.myStopsTable.heading;
		if not stops.isStopActiveAsAtDate( null ) then			// null means as at today
			returnStr	:= returnStr &amp; Space &amp; Left_Round_Bracket &amp; stops.clearanceExpiryDate.asStringJMT &amp; Right_Round_Bracket;
		endif;
	endforeach stops_loop1;
	
	// now those which are marked with an expiry date.
	foreach stops in self.allStopsToBeUpdated do : stops_loop2
		// make sure the user has access to this StopsTable
		if not user.canViewStop( terminal, stops.myStopsTable ) then
			continue stops_loop2;
		endif;
		if returnStr &lt;&gt; null then
			returnStr	:= returnStr &amp; Comma_And_Space;
		endif;
		returnStr		:= returnStr &amp; stops.myStopsTable.heading;
		if not stops.isStopActiveAsAtDate( null ) then			// null means as at today
			returnStr	:= returnStr &amp; Space &amp; Left_Round_Bracket &amp; stops.clearanceExpiryDate.asStringJMT &amp; Right_Round_Bracket;
		endif;
	endforeach stops_loop2;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="highlightRow" id="96fbae01-1b79-4e19-84a8-c5f39ef5a684">
        <updating/>
        <source>highlightRow( _row : Integer ) updating, protected;

/*
Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	
begin
	// highlight ie colour the row selected.
	if _row &lt;= self.fixedRows or _row &gt; self.rows then
		return;
	endif;
	
	self.accessRow( _row ).selected :=	self.accessCell( _row, self.chkBoxColumn ).text = TableCheckBox_Selected;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadAllStopsTables" id="f5481076-123f-4a49-a1d3-e74508148606">
        <updating/>
        <source>loadAllStopsTables(_terminal :CM_Terminal; _assistant :CMUI_Assistant )updating;

/*
Purpose:	Load all of the stopsTable instances allowed to be maintained by this user for this terminal.

Date				Who		Reason
22 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
15/06/2010			cnwcs5	par 24343 - changed method so as not be be so tightly couple with the container enquiry form
*/
	
vars
	
begin
	_assistant.listTableStopsTable2(self, _terminal, true );
epilog
	
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_assistant" type="CMUI_Assistant"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="73133081-b231-4f15-b917-d520ff6a4abc">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown( _table : Table input; _button : Integer; _shift : Integer; _x : Real; _y : Real ) updating, clientExecution;

/*
Date				Who		Reason
18 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	
begin
	inheritMethod( _table, _button, _shift, _x, _y );
	
	self.rowColumnChg( _table );
	
epilog
	
end;
</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_shift" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="rowChecked" id="391b442d-f38b-4896-962e-143ab04c043b">
        <updating/>
        <source>rowChecked( _row : Integer ) : Boolean updating, protected;

/*
Purpose:	This method returns true if the row accessed has the checkbox checked.

Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	
begin
	if _row &gt; self.fixedRows and _row &lt;= self.rows then
		if self.accessCell( _row, self.chkBoxColumn ).text = TableCheckBox_Selected then
			return true;
		endif;
	endif;
	
	return false;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="d68e4c1a-1e9c-4d77-a20b-c25389a563df">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>rowColumnChg( _table : Table input ) updating, clientExecution;

/*
Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	
begin
	inheritMethod( _table );
	
	if _table.column = self.dateInputColumn then
		if _table.accessCell( _table.row, self.dateInputColumn ).inputType = Table.InputType_None then
			// Only set the column to the checkBox column if the expiry date column is not input allowed,
			// this allows the spacebar to be used to set/unset the checkbox.
			self.doManually	:= true;
			_table.column	:= self.chkBoxColumn;
		endif;
	elseif _table.column = self.chkBoxColumn then
		self.doManually	:= false;
	else
		// if the input date column is not enterable then set the column to the
		// checkBox column so that the spacebar can be used to set/unset the checkbox.
		if _table.accessCell( _table.row, self.dateInputColumn ).inputType = Table.InputType_None then
			_table.column	:= self.chkBoxColumn;
			self.doManually	:= true;
		else
			self.doManually	:= false;
		endif;
	endif;
	
	// now do the click event on "this" column and row.
	self.click( _table );
	
epilog
	
end;
</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setExpiryDateAccessAndColour" id="e14f70b1-d47b-4771-949f-54b3016a6143">
        <updating/>
        <source>setExpiryDateAccessAndColour(
	_stopsTable	: CM_StopsTable;
	_theRow		: Integer ) updating;

/*
Purpose:	To reapply the required access and colours for expiry date column.

Date				Who		Reason
23 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	tableCell		: JadeTableCell;
	
begin
	// Set up the default colour and input type for the expiry date cells.
	tableCell			:= self.accessCell( _theRow, self.dateInputColumn );
	tableCell.inputType	:= Table.InputType_None;
	tableCell.backColor	:= CM_EntryTable.ReadOnlyRowColour;	// disabled colour = 13421823 = RGB of 255, 204, 204
	
	if not _stopsTable.allowClearanceExpiryDate then
		return;
	endif;
	
	tableCell.inputType	:= Table.InputType_TextBox;
	tableCell.backColor	:= CM_ContainerEnqForm.TXN_RELATED_COLOUR;	// enabled colour = 13434879 = RGB of 255, 255, 204
	
epilog
	
end;
</source>
        <Parameter name="_stopsTable" type="CM_StopsTable"/>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setExpiryDateJadeEditMask" id="9e1a8bff-a8af-4b2b-86d1-a12e54fe6a06">
        <updating/>
        <source>setExpiryDateJadeEditMask( _form : CM_BaseForm ) updating;

/*
Purpose:	To make sure the listbox expiry date has a Jade Date Edit Mask on it.

Date				Who		Reason
22 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	tableColumn			: JadeTableColumn;
	containerEnqForm	: CM_ContainerEnqForm;
	
begin
	tableColumn				:= self.accessColumn( self.dateInputColumn );
	tableColumn.inputType	:= Table.InputType_None;
	
	// currently only used on this form.
	if _form.isKindOf( CM_ContainerEnqForm ) then
		containerEnqForm								:= _form.CM_ContainerEnqForm;
		tableColumn.cellControl							:= containerEnqForm.txtExpiryDate;	// a subclass of JadeEditMask
		tableColumn.cellControl.automaticCellControl	:= true;
	endif;
	
	// reset the headings row.
	self.accessRow( self.fixedRows ).inputType	:= Table.InputType_None;
	
epilog
	
end;
</source>
        <Parameter name="_form" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="e667d89c-4846-40d6-a6af-431becf88682">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated( _cntrl : Control input; _persistCntrl : Control ) updating, clientExecution;

/*
Date				Who		Reason
17 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	tempstr			: String;
	index			: Integer;
	tableColumn		: JadeTableColumn;
	
begin
	// Setup how we what the Stops List Table to look like and behave.
	inheritMethod( _cntrl, _persistCntrl );
	
	self.fixedRows			:= 1;
	self.fixedColumns		:= 0;
	self.rows				:= self.fixedRows;
	self.columns			:= self.fixedColumns + 3;
	self.gridLines			:= true;
	self.fixed3D			:= false;
	self.userInputEnabled	:= true;
	self.selectMode			:= Table.SelectMode_Row;
	self.gridColor			:= CM_BaseForm.Color_GrayText;
	self.scrollBars			:= Table.ScrollBars_Both;
	self.autoSize			:= Table.AutoSize_ColumnMinimum;
	self.chkBoxColumn		:= self.fixedColumns + 1;
	self.headingColumn		:= self.fixedColumns + 2;
	self.dateInputColumn	:= self.columns;
	
	foreach index in 1 to self.columns do
		tableColumn	:= self.accessColumn( index );
		if index = self.chkBoxColumn then
			// setup the checkbox column
			tableColumn.inputType	:= Table.InputType_CheckBox;
		elseif index = self.dateInputColumn then
			// setup the Expiry Date column
			tableColumn.inputType	:= Table.InputType_None;
		else
			// setup the text column
			tableColumn.inputType				:= Table.InputType_None;
			tableColumn.partialTextIndication	:= true;
		endif;
	endforeach;
	
	if self.isInPainter then
		// do not set the header and load the data if in painter!
		return;
	endif;
	
	// set the required headings depending on translations.
	self.accessRow( self.fixedRows ).inputType	:= Table.InputType_None;
	tempstr	:=	app.getString( CheckBox_Include ) &amp; Tab &amp;
				app.getString( Description ) &amp; Tab &amp;
				app.getString( ExpiryDate );
	self.accessCell( self.fixedRows, 1 ).text	:= tempstr;
	self.adjustColumns;
	
epilog
	
end;
</source>
