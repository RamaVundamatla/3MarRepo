        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuTxnResources_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006
24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
05 Jul 2024 navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client
*/

vars
	
	obj : Object;
	titxn : CM_TITransaction; //24/05/2023  navmv20 CR 57925 Task 57921
	proxyUsageSet : CM_ResourceTypeUsageSet;
	trans : CM_Transaction; //24/05/2023  navmv20 CR 57925 Task 57921
	objString : String; //24/05/2023  navmv20 CR 57925 Task 57921
begin

	obj := menuItem.userObject;
	
	if obj &lt;&gt; null then
		//24/05/2023  navmv20 CR 57925 Task 57921 - START
		if obj.isKindOf(CM_TITransaction) then
			titxn := menuItem.userObject.CM_TITransaction;
			if titxn &lt;&gt; null then
				self.myAssistant.showResourceTypeUsageForTxn(titxn, self.myMasterMenuAction, null, null, proxyUsageSet, false, null);		// 11/01/2011 cnwar2 #26691  //05 Jul 2024 navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client
			endif;
		elseif obj.isKindOf(CM_Transaction) then
			trans := menuItem.userObject.CM_Transaction;
			if trans &lt;&gt; null then
				self.myAssistant.showResourceUsageToDoTxn(trans, null, null,proxyUsageSet, false, objString);
			endif;
		
		endif;
		//24/05/2023  navmv20 CR 57925 Task 57921 - END
	endif;
	

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
