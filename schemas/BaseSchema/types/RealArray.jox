<CollClass name="RealArray">
    <JadeMethod name="cnEcDoSort" id="c44cf448-ab00-4bd1-ab23-edbe812e1fb9">
        <lockReceiver/>
        <updating/>
        <source>cnEcDoSort(pSorterObj : CnEcSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	realValue		: Real;
	sortKeyObj		: Object;

begin
	foreach realValue in self do
		pSorterObj.addKey(realValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.allKeys do
		self.add(sortKeyObj.CnEcSortKey.getKey().Real);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="CnEcSorter"/>
    </JadeMethod>
</CollClass>
