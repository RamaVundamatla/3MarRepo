    <JadeMethod name="showSplitBreakBulkForm" id="aa6b681a-48d3-4eda-afa6-d59b667dc842">
        <source>showSplitBreakBulkForm( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	form : CMUI_SplitBreakBulkForm;
	msg : String;

begin

	if _ti = null then
		msg := app.getErrorString(No_Cargo_selected);
	elseif not _ti.canSplitTotalQuantity then
		msg := app.getErrorString(No_split_cargo_not_BB);
//	14 Jul 2015	NDL	Par 36550
//	elseif not _ti.isOnSite then	//14 Jun 2013	NDL	Par 31826
//		msg := app.getErrorString1(ERR_TI_NOT_ONSITE,_ti.id);
	endif;
	if msg &lt;&gt; null then
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	form := app.loadForm(CMUI_SplitBreakBulkForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_SplitBreakBulkForm;
	if form = null then
		return;
	endif;	
	
	if form.setMyTrackedItem(_ti) then
		form.showModal();
	endif;

epilog

end;</source>
