    <JadeMethod name="setEDIAttributes" id="9d355722-512b-4d11-b4e4-2932882b0977">
        <updating/>
        <source>setEDIAttributes(_fileName, _fileVersion, _operatorCode : String; _numItems : Integer) updating;
// -------------------------------------------
// Created 31 March 2004 by cnwdvb1
// -------------------------------------------
//04 Jul 2012	cnwrs1	- dont make up descriptionmj if none provided
vars

begin

/*	if self.description = null then	//04 Jul 2012	cnwrs1
		self.setDescription(app.getErrorString2(Successfully_Loaded_EDI_Data, _operatorCode, _fileVersion));
	endif;
*/	
	self.fileName 		:= _fileName[1:30];
	self.fileVersion	:= _fileVersion[1:30];
	self.operatorCode	:= _operatorCode[1:4];
	self.numItems		:= _numItems;
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_fileVersion" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_numItems" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="165f9d63-7fc3-4bda-a7d0-4ec25a1a803c">
        <updating/>
        <source>setForCreate(_proxy: CM_ActivityHistoryEDI) updating;
// -------------------------------------------
// Created 31 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_proxy);
	self.fileName 		:= _proxy.fileName;
	self.fileVersion	:= _proxy.fileVersion;
	self.numItems		:= _proxy.numItems;
	self.operatorCode	:= _proxy.operatorCode;


end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistoryEDI"/>
    </JadeMethod>
