    <JadeMethod name="mnuLstJobHideCompleted_click" id="41e684f7-0837-472c-bdb3-8a9155c9389c">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuLstJobHideCompleted_click(menuItem: MenuItem input) updating;
//--------------------------------------------------
// Created:	01 October 2003 By: cnwgd1
// 15 Oct 2012		PJS		PAr #30438
//--------------------------------------------------
vars

begin
	if self.mnuLstJobHideCompleted.checked then
		self.mnuLstJobHideCompleted.checked := false;
	else
		self.mnuLstJobHideCompleted.checked := true;	
	endif;
		
	self.hideCompletedJobs := self.mnuLstJobHideCompleted.checked;
	self.lstJobsSaveSelected();
	//self.loadListJobsAll();
	handleListJobsLoad;		//30438
	setListAndSelectorHeights(true);
	self.lstJobsSetSelectedObject();
		
end;</source>
