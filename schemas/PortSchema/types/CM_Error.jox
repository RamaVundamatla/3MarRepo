/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwndl1	Initial creation

*/

vars

begin

	if app.isJMTUnitTest then
		if app.verboseLogging then
			app.writeCurrentStack();
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDetailsAsString" id="da365e70-9329-4ff7-bae8-fc8c8d0d2896">
        <source>getDetailsAsString() : String;
// ---------------------------------------------------------------------------
// Created:     14 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	//return self.errorCode.String &amp; '::' &amp; self.text;
	// Was getting duplicate code; DVB 12/01/06
	return self.text;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailsAsStringNoCode" id="380316e9-8816-468f-abc3-7caae9c2ab84">
        <source>getDetailsAsStringNoCode() : String;

/*

Purpose:			Return the error message text without the "Code :&lt;number&gt;. " preamble

Parameters:			None

Return Value:		Clean error text


Date		Who		Reason
17 Nov 2008	cnwkpd1	PAR #18374 - Remove Code number of error messages in TCP application

*/

vars
	pos				: Integer;	
	codeStr,
	message			: String;
	
begin
	// Set up default preamble to search for
	codeStr := ":" &amp; self.errorCode.String &amp; ". ";
	message := self.text;
	pos := message.pos(codeStr, 1);
	
	// If it doesn't appear, then just return raw text
	if pos = 0 then
		return message;
	endif;
	
	// Otherwise return text following preamble
	return message[pos + codeStr.length:end];
	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailsForTableDisplay" id="21568e7e-a8c3-4d27-9d95-2f0f1968f4f1">
        <source>getDetailsForTableDisplay():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2009	cnwndl1	Initial creation Par 21325

*/

vars

	retValue : String;
	invalid : Boolean;
	
begin

	on Exception do app.handleDeletedObject( exception, self.mySubject, invalid );
	
	if self.mySubject &lt;&gt; null then
		retValue := self.mySubject.getNiceName &amp; " : ";
	endif;
	
	retValue := retValue &amp; self.text;
	
	if self.fieldName &lt;&gt; null then
		retValue := retValue &amp; " [" &amp; self.fieldName &amp; "]";
	endif;
	
	return retValue;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullDetailsAsString" id="40ee22f5-effb-4a7e-a6fd-e3b797899896">
        <source>getFullDetailsAsString() : String;
// ---------------------------------------------------------------------------
// Created:     14 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	dump: String;
begin

	//return self.errorCode.String &amp; '::' &amp; self.text;
	// Was getting duplicate code; DVB 12/01/06
	if self.allDumpDetails.size &gt; 0 then
		dump := CrLf &amp; self.allDumpDetails.display;
	endif;
	return self.text &amp; dump;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeFromPassport" id="9a19d2e1-ff01-4683-8c35-ea594fee368e">
        <updating/>
        <source>removeFromPassport() updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myErrorPassport := null;
	self.myWarningPassport := null;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="set" id="e30344ca-7745-4d55-928a-8840964a87ee">
        <updating/>
        <source>set(pErrorCode : Integer; pText : String; pWarning : Boolean; pField : String; pObject : Object; _subject : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.errorCode		:= pErrorCode;
	self.text			:= pText;
	self.warningOnly	:= pWarning;
	self.fieldName		:= pField[1:30];
	self.myUserObject	:= pObject;
	self.mySubject 		:= _subject;

	if app.isJMTUnitTest then
		if app.verboseLogging then
			app.writeStatement("CM_ERROR " &amp; self.getDetailsAsString);
		endif;
	endif;

end;</source>
        <Parameter name="pErrorCode" type="Integer"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pWarning" type="Boolean"/>
        <Parameter name="pField" type="String"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="_subject" type="CM_Object"/>
    </JadeMethod>
