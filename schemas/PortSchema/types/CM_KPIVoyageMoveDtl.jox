    <JadeMethod name="setDetailValues" id="f0909f57-ce13-4cc7-9b5d-85935ef91fa2">
        <updating/>
        <source>setDetailValues(_tran : CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 04/08/2011		cnwcs5			CCMS MES 1033 - RORO KPI
// ---------------------------------------------------------------------------

vars
	ti 		: CM_TrackedItem;
	isTwinLift 	: Boolean;
begin
	self.allTransactions.add(_tran);
	
	ti := _tran.myTrackedItem;

	if ti.isReefer then
		self.numReefer := self.numReefer + 1;
	endif;
	
	self.numTIs := self.numTIs + 1;
epilog

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setKeyValues" id="aaa75795-992a-4870-9976-492efb72adec">
        <updating/>
        <source>setKeyValues(_cargoType :CM_CargoType; _cargoSubType :CM_Product; _moveType, _len, _contents : Integer; _isTranship : Boolean; _kpiEntity : CM_KPIVoyageEntity) updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 22/06/2010		cnwas3			par 24585 Shortening the key desc string to avoid a 1035 exception
// 04/08/2011		cnwcs5			CCMS MES 1033 - RORO KPI
// ---------------------------------------------------------------------------

vars
	
begin
	self.myCargoType		:= _cargoType;
	self.myCargoSubType		:= _cargoSubType;
	self.voyageMoveType 	:= _moveType;
	self.isTranship 		:= _isTranship;
	
	self.myKPIVoyageEntity	:= _kpiEntity;
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_len" type="Integer"/>
        <Parameter name="_contents" type="Integer"/>
        <Parameter name="_isTranship" type="Boolean"/>
        <Parameter name="_kpiEntity" type="CM_KPIVoyageEntity"/>
    </JadeMethod>
</Class>
