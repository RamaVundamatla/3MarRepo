    <JadeMethod name="loadRateTable" id="58a664da-761b-43ac-92d1-93f81c7e7de3">
        <source>loadRateTable(_company:CM_Bank; _level:Integer; _rateTable:Table io; _row:Integer io; _timeStamp:TimeStamp; _progress:CMS_Progress io);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 Feb 2018	jlgmd1		TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)
// ---------------------------------------------------------------------------

vars
	shipPortGroup : CM_ShipPortGroup;
	lineGroupDebtor : CM_LineGroupDebtor;
	service : CM_Service;
	i,j : Integer;
	rate : CM_RateEntry;
	dpl : Integer;
	symbol : Character;

begin

	// TFS 36954 MPD 20 Feb 2018
	if self.getMyTerminal &lt;&gt; null then
		dpl := self.getMyTerminal.getConfig(FinancialRateDPlaces).Integer;
	else
		dpl := $CM_RateMoney.decimalPlaces;
	endif;
	symbol := app.myRoot.getInvoiceCurrencySymbol.Character;

	foreach shipPortGroup in shipPortGroups do
		foreach lineGroupDebtor in shipPortGroup.lineGroupDebtors do
			_rateTable.row := _row;
			_rateTable.column := 1;
			_rateTable.text := lineGroupDebtor.code;
			_rateTable.itemObject := lineGroupDebtor;
			j := 1;
			_progress.setAction("Getting rates for Line Group Debtor: " &amp; lineGroupDebtor.code);
			_progress.progress.partsDone := _row - 1;
			app.doWindowEvents(0);

			foreach service in _company.services do
				j := j + 1;
				_rateTable.column := j;
				rate := lineGroupDebtor.getServiceTimeRate(_company, service, _timeStamp);
				if rate &lt;&gt; null then
					//_rateTable.text := rate.getDerivedCostPerUnit(_timeStamp).userCurrencyFormat($CM_RateMoney);
					_rateTable.text := symbol &amp; rate.getDerivedCostPerUnit(_timeStamp).asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
					if rate.rate.isKindOf(CM_LineGroupDebtorRate) then
						if rate.rate.CM_LineGroupDebtorRate.lineGroupDebtor = lineGroupDebtor then
							_rateTable.fontBold := true;
						else
							_rateTable.fontBold := false;
						endif;
					else
						_rateTable.fontBold := false;
					endif;
				endif;
			endforeach;
			_row := _row + 1;

		endforeach;
	endforeach;

end;</source>
        <Parameter name="_company" type="CM_Bank"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_rateTable" type="Table" usage="io"/>
        <Parameter name="_row" type="Integer" usage="io"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadRateTableByRow" id="4baf385a-18fc-45d2-bf1d-6310318fa46b">
        <source>loadRateTableByRow(_company:CM_Bank; _level:Integer; _rateTable:Table io; _row:Integer io; _timeStamp:TimeStamp; _progress:CMS_Progress io);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 Feb 2018	jlgmd1		TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)
// ---------------------------------------------------------------------------

vars
	shipPortGroup : CM_ShipPortGroup;
	lineGroupDebtor : CM_LineGroupDebtor;
	service : CM_Service;
	i,j : Integer;
	rateEntry : CM_RateEntry;
	dpl : Integer;
	symbol : Character;

begin

	// TFS 36954 MPD 20 Feb 2018
	if self.getMyTerminal &lt;&gt; null then
		dpl := self.getMyTerminal.getConfig(FinancialRateDPlaces).Integer;
	else
		dpl := $CM_RateMoney.decimalPlaces;
	endif;
	symbol := app.myRoot.getInvoiceCurrencySymbol.Character;

	foreach shipPortGroup in shipPortGroups do
		foreach lineGroupDebtor in shipPortGroup.lineGroupDebtors do
			_rateTable.row := _row;
			_rateTable.column := 1;
			_rateTable.text := lineGroupDebtor.code;
			_rateTable.itemObject := lineGroupDebtor;
			j := 1;
			_progress.setAction("Getting rates for Line Group Debtor: " &amp; lineGroupDebtor.code);
			_progress.progress.partsDone := _row - 1;
			app.doWindowEvents(0);

			foreach service in _company.services do
				j := j + 1;
				_rateTable.column := j;
				rateEntry := lineGroupDebtor.getServiceTimeRate(_company, service, _timeStamp);
				if rateEntry &lt;&gt; null then
					//_rateTable.text := rateEntry.getDerivedCostPerUnit(_timeStamp).userCurrencyFormat($CM_RateMoney);
					_rateTable.text := symbol &amp; rateEntry.getDerivedCostPerUnit(_timeStamp).asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
					if rateEntry.rate.isKindOf(CM_LineGroupDebtorRate) then
						if rateEntry.rate.CM_LineGroupDebtorRate.lineGroupDebtor = lineGroupDebtor then
							_rateTable.fontBold := true;
						else
							_rateTable.fontBold := false;
						endif;
					else
						_rateTable.fontBold := false;
					endif;
				endif;
			endforeach;
			_row := _row + 1;

		endforeach;
	endforeach;

end;</source>
        <Parameter name="_company" type="CM_Bank"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_rateTable" type="Table" usage="io"/>
        <Parameter name="_row" type="Integer" usage="io"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6e637ff3-c3ab-44b6-a16b-b064011c6131">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	07 April 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
//14 Aug 2023 	navhl20 	ChangeRequest 56642: MTN - Invoicing Shipping Line / Debtor Link
vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	proxy.myDebtor := self.myDebtor; 						//14.8.2023 navhl20 #56642
	self.allContacts.copy(proxy.allContacts);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDebtor" id="2ae66d1e-994e-45a6-b50e-73e7d31291c4">
