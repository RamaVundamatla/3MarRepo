    <JadeMethod name="setupForm" id="2498f848-78ce-4d2b-a7d7-57eda813cfb4">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
06 November 2023	navmv20	CR 60425 Task 60986: Jade - Cust Doc Permissions
27 Feb 2024 navrv30 Bug 61880: EUP | FR 53715 - Customs Enquiry screen - Query Issues
*/

vars

begin
	inheritMethod();
	
	// ### TFS BUG 59633 31AUG2023 NAVAB1 self.handleMenusForModalDisplay();

	self.initTblCustDocEnquiry(ETDef_CustDocEnq);
	self.getXMLSettingsForSetup();

	setCaption(self.caption);
	self.startNotifications();
	
	self.buildCombDocType();
	self.buildCombLicense();
	self.buildCombAgent();
	self.buildCombHSCodes();
	self.buildCombCargoGroups();
	self.setCargoType();
	self.setCargoSubType();
	self.setCommodities();
	
	self.btnFind.default := true;
	
	//06/11/2023	navmv20	CR 60425 Task 60986- start
	/*if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAdd.enabled := false;
		self.btnRemove.enabled := false;
// ### TFS CR 60424 TASK 60549 28SEP2023 NAVAB1		self.btnUpdate.enabled := false;
		self.btnApprove.enabled := false;
	endif;*/
	self.doPermissions();
	//06/11/2023	navmv20	CR 60425 Task 60986 - end
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startNotifications" id="6921f3f4-4e85-4460-a7e1-ae0f324857b3">
