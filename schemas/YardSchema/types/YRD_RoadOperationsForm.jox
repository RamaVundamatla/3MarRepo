    <JadeMethod name="mnuVoyWleDel_click" id="87389dad-7cc7-4e73-8c46-186239aae9ae">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuVoyWleDel_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2016	cnwndl1	Initial creation	TFS 2032

*/

vars

	voyageWle : CM_VoyageWLE;
	voyageJob : CM_VoyageJob;
	result : Integer;
	obj : CM_Object;
	proxyVoyJob : CM_VoyageJob;
	loadState : Boolean;

begin

	voyageWle := menuItem.userObject.CM_VoyageWLE;
	
	if voyageWle &lt;&gt; null then
		voyageJob := voyageWle.job.CM_VoyageJob;
		if voyageJob &lt;&gt; null and voyageJob.workListEntries.size = 1 then
			//The only wle in a ship discharge job, ( that is already on the truck.... kill the job whihc will delete the wle so we can gate it out. )
			
			if voyageJob.isLoadedToOperations then
				app.cmsBeginLoad(loadState);
				proxyVoyJob := voyageJob.pxyCreateUpdateProxy();
				app.cmsEndLoad(loadState);
				
				while true do
					app.myTrxUA.trxUpdateVoyageJobLoadUnload(proxyVoyJob, false, app.myPassport);
					if app.myPassport.trxCompletedOK then
						self.clearErrorWarnings();
						break;
					else
						result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
						if result = IDOK then
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
					endif;
					return;
				endwhile;
			
			endif;
			
			
			while true do
				app.myTrxDA.trxDeleteVoyageJob(voyageJob, app.myPassport);
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					break;
				else
					result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
					if result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				return;
			endwhile;
			
		else
			//we only have the lone wle or the job has other wles, so leave it alone.
			obj := voyageWle;
			while true do
				app.myTrxDA.trxDeleteCMObject(obj, app.myPassport);
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					break;
				else
					result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
					if result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				return;
			endwhile;
			
		endif;	
	endif;

epilog

	self.mnuVoyWleDel.visible := false;	
	app.cmsEndLoad(loadState);
	delete proxyVoyJob;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
