    <JadeMethod name="processRefNumbers" id="c8b8efed-68b0-4217-ad3f-cd69ea849096">
        <source>processRefNumbers(	_xmlElementRefNum : JadeXMLElement;
					_ediFile: CM_EDIFile input;
					_ediPreNote : CM_EDIPrenoteTI input
					):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 August 2016		cnwndl1	Initial creation	TFS 2276 / 2565

*/
vars

	xmlSubElement : JadeXMLElement;
	str : String;

begin

	xmlSubElement := null;
	xmlSubElement := _xmlElementRefNum.getElementByTagName(self.TagShippingLineBooking);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.bookingRef := str;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementRefNum.getElementByTagName(self.TagExportClearanceNumber);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.customExportEntryNumber := str;
		endif;
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementRefNum.getElementByTagName(self.TagShipperCargoReference);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.clientRef := str[1:30];	//21 Jan 2021	NDL	TFS 50636
		endif;
		
	endif;
	
	
	
	
	return true;

epilog

end;</source>
        <access>protected</access>
