    <JadeMethod name="doTblUserNotify" id="bf073798-d7dc-453d-a67f-b8eac374ce56">
        <updating/>
        <source>doTblUserNotify(_shift : CM_ShiftEntity; eventType : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	tmpEvent : Integer;
	tmpTerminal : CM_Terminal;
begin
	tmpTerminal := self.myTerminal;
	tmpEvent := tmpTerminal.getEventFromTerminalEvent(eventType);

	if _shift.isKindOf(CM_Shift) then
		if tmpEvent = Event_Shift_Add then
			self.displayShiftsDays();
		elseif tmpEvent = Event_Shift_Update then
			self.displayShiftsDays();
		elseif tmpEvent = Event_Shift_Delete then
			self.displayShiftsDays();
		endif;
	else
		if tmpEvent = Event_Shift_Add then
			self.displayShiftsStandard();
		elseif tmpEvent = Event_Shift_Update then
			self.displayShiftsStandard();
		elseif tmpEvent = Event_Shift_Delete then
			self.displayShiftsStandard();
		endif;
	endif;
end;
</source>
        <Parameter name="_shift" type="CM_ShiftEntity"/>
        <Parameter name="eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="27c442a4-06a8-4341-8770-e0add036aeb8">
