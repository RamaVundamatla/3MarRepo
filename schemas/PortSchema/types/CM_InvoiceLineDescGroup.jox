    <JadeMethod name="getAuditText" id="ee285d8c-1499-4f80-9637-ca5de125f1e2">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
	txt,
	tmpInvLine,tmpStr	: String;
	tmpInvLineDesc 	: CM_InvoiceLineDesc;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	

	if self.lineDescriptions.size &gt; 0 then
		foreach tmpInvLineDesc in self.lineDescriptions do
			if tmpInvLineDesc &lt;&gt; null then
				tmpStr :=tmpInvLineDesc.narration&amp;" "&amp; tmpStr ;
			endif;
		endforeach;
			txt := txt &amp; 'Invoice Lines' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	tmpStr := null;
	
	return txt;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="e8e422f2-dd5f-4595-8239-f7f7b9674ccf">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.description[1:10];
	else
		return self.description;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5bd6ba82-0fbc-40c8-bd0e-bb9befe59a61">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//////////////////////////////////////////////
//  coded by cnwyl1 15 05 2006 for PAR 11590
//
/////////////////////////////////////////////
vars

begin
	if _attrName = ETRow_Description  then
		return self.description;
	elseif _attrName = ETRow_InvLineDesc  then
		return self.getInvLineDesc();
	elseif _attrName = ETRow_MinimumChargeAmount then
		return self.minimumChargeAmount.asStringJMTWithPrecision(2, false);
	elseif _attrName = ETRow_MinimumChargeLineType then
		return self.getMiniumumChargeLineTypeDesc();
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvLineDesc" id="112bf3d2-2601-4968-a79c-6515603f1591">
        <source>getInvLineDesc() : String;
///////////////////////////////////////
//
//          coded by cnwyl1 
//            15 05 2006
//
/////////PAR 11590////////////////////
vars
	aStr : String;
	aLines : CM_InvoiceLineDesc;
begin
	foreach aLines in self.lineDescriptions do
		if aStr = null then
			aStr := aLines.narration;
		else
			aStr := aStr &amp; ", " &amp; aLines.narration;	// TFS 2066 change delimiter (was Cr) so it shows more and can be extracted
		endif;
	endforeach;
	return aStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMiniumumChargeLineTypeDesc" id="94055d6f-fb3a-497b-a11e-89526f97ff64">
        <source>getMiniumumChargeLineTypeDesc() : String;
/*

Date		Who		Reason
17 January 2017	cnwer1	Initial creation TFS 2903

*/

vars
	invalid : Boolean;
	desc : String;
begin
	on Exception do app.handleDeletedObject(exception,self.myMinimumChargeInvoiceLineType,invalid);
	
	if self.myMinimumChargeInvoiceLineType = null then
		return null;
	endif;
	
	desc:= self.myMinimumChargeInvoiceLineType.narration;
	
	if invalid then
		return null;
	endif;
	
	return desc;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2a0d8101-bedf-4899-8466-d24d75927116">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Date		Who		Reason
17 January 2017	cnwer1	Initial creation TFS 2903

*/

vars
	proxy : CM_InvoiceLineDescGroup;
	completedOK : Boolean;
begin
	proxy:= inheritMethod();
	proxy.myMinimumChargeInvoiceLineType := self.myMinimumChargeInvoiceLineType;
	
	completedOK := true;
	return proxy;

epilog
	if not completedOK then
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="467fad00-ad0a-468e-a207-d8b72640c179">
        <updating/>
        <source>setForCreate(_theController : CMIF_InvoiceLineDescGroup) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	proxyInvoiceLineDesc : CM_InvoiceLineDescGroup;

begin
	
	self.bank := _theController.myBank;
	self.setForUpdate(_theController);
end;</source>
        <Parameter name="_theController" type="CMIF_InvoiceLineDescGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8fc7021e-1bd8-4d0a-b59d-027edee2c73d">
        <updating/>
        <source>setForUpdate(_theController : CMIF_InvoiceLineDescGroup) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aLine : CM_InvoiceLineDesc;
begin
	self.description := _theController.myPxyLineDescGroup.description[1:30];
	//epr TFS 2903 20/1/17
	self.minimumChargeAmount := _theController.myPxyLineDescGroup.minimumChargeAmount;
	self.myMinimumChargeInvoiceLineType :=_theController.myPxyLineDescGroup.myMinimumChargeInvoiceLineType;
	foreach aLine in 	self.lineDescriptions do
		aLine.setMyGroup(null);
	endforeach;
	
	foreach aLine in 	_theController.allInvoiceLineDesc do
		aLine.setMyGroup(self);
	endforeach;


end;</source>
        <Parameter name="_theController" type="CMIF_InvoiceLineDescGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ca691fc8-5408-42c4-8fd2-e6815319a7bc">
        <updating/>
        <source>setProxy(_desc : String;
		_minimumCharge : Decimal;
		_minimumChargeLineType : CM_InvoiceLineDesc) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aLine : CM_InvoiceLineDesc;
begin
	self.description := _desc[1:30];
	//epr TFS 2903 20/1/16
	self.minimumChargeAmount :=_minimumCharge;
	self.myMinimumChargeInvoiceLineType :=_minimumChargeLineType;
end;</source>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_minimumCharge" type="Decimal"/>
        <Parameter name="_minimumChargeLineType" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="ba985191-6eaa-4212-b7b7-d6a791e07bde">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_InvoiceLineDescGroup::myChildQuantityMap.name 
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
