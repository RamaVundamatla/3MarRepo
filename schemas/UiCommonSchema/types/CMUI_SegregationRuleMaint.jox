    <JadeMethod name="translateForm" id="4117c3c0-9e66-4b25-bec3-b0303e06e131">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 March 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008072, locale);
	btnCancelMatrix.translateBubbleHelp(Xlat_0004933, locale);
	btnCancelMatrix.translateCaption(Xlat_0004934, locale);
	btnCancelRule.translateBubbleHelp(Xlat_0004935, locale);
	btnCancelRule.translateCaption(Xlat_0004936, locale);
	btnDeleteRule.translateCaption(Xlat_0004937, locale);
	btnEditMatrix.translateBubbleHelp(Xlat_0004938, locale);
	btnEditMatrix.translateCaption(Xlat_0004939, locale);
	btnEditRule.translateBubbleHelp(Xlat_0004940, locale);
	btnEditRule.translateCaption(Xlat_0004941, locale);
	btnExportMatrix.translateBubbleHelp(Xlat_0005185, locale);
	btnExportMatrix.translateCaption(Xlat_0005186, locale);
	btnImportMatrix.translateBubbleHelp(Xlat_0005187, locale);
	btnImportMatrix.translateCaption(Xlat_0005188, locale);
	btnNewRule.translateBubbleHelp(Xlat_0004942, locale);
	btnNewRule.translateCaption(Xlat_0004943, locale);
	btnSaveMatrix.translateBubbleHelp(Xlat_0004944, locale);
	btnSaveMatrix.translateCaption(Xlat_0004945, locale);
	grpConditions.translateCaption(Xlat_0004946, locale);
	grpRuleMatrix.translateCaption(Xlat_0004947, locale);
	lblRuleMode.translateCaption(Xlat_0004948, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="550b313b-0074-418e-8fe3-5d3ec3a81610">
        <controlMethod name="Form::unload"/>
