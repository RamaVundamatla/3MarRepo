    <JadeMethod name="addBRToTable" id="f31bf5af-d694-415f-ab3a-4a6acc6d5c68">
        <source>addBRToTable(_tbl : CM_MobTable io; _br :CM_BookingRef);
// ---------------------------------------------------------------------------
// Created:     29 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	row : Integer;
begin
	row := _tbl.addItem(getBRDisplay(_br));
	_tbl.accessRow(row).itemObject := _br;
end;</source>
        <Parameter name="_tbl" type="CM_MobTable" usage="io"/>
        <Parameter name="_br" type="CM_BookingRef"/>
    </JadeMethod>
