    <JadeMethod name="addLocationToAgent" id="7dc41962-37d0-4d90-994d-a97063787ee9">
        <updating/>
        <source>addLocationToAgent(_location : CM_LocationsController; _type : Integer) updating;
// -------------------------------------------
// Created 29 March 2005 by cnwdvb1
// -------------------------------------------
/* If the checking secondary flag is set then we don't add it to arrays. If it is checking
secondary and it's never then we have to remove back end location. */
vars

begin

	if _type = Locations_Found then
		if not self.myCurrentCMIFYAAutoPlan.allFoundLCs.includes(_location) then

			//self.myCurrentCMIFYAAutoPlan.allFoundLCs.add(_location);
			if not self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.includes(_location) then //cnwrd1 par 29269 14.3.2012 only add if we are a true good location not one with LOB restrictions
				self.addLogEntry(AP_Log_YA_Default,'Suitable location found - ' &amp; _location.getFullId(), true);
				self.myCurrentCMIFYAAutoPlan.addToFoundLocations(_location);
			else
				self.addLogEntry(AP_Log_YA_Default,'Suitable location found With Restriction- ' &amp; _location.getFullId(), true);//cnwrd1 par 29269 14.3.2012 
			endif;
		endif;
	elseif _type = YAOverlap_Sometimes then
		// Gets done later. If everything is ok
	elseif _type = YAOverlap_LastResort and not self.checkingSecondary then
		if not self.myCurrentCMIFYAAutoPlan.allLCsLastResort.includes(_location) then
			self.addLogEntry(AP_Log_YA_Default,'Adding location - ' &amp; _location.getFullId() &amp; ' to last resort list for later evaluation', true);
			self.myCurrentCMIFYAAutoPlan.allLCsLastResort.add(_location);
		endif;
	elseif _type =YAOverlap_Never then
		
		if self.myCurrentCMIFYAAutoPlan.allLCsLastResort.includes(_location) then
			self.myCurrentCMIFYAAutoPlan.allLCsLastResort.remove(_location);
		endif;
	elseif _type = Temp_LastResort then
		if not self.myCurrentCMIFYAAutoPlan.allLCsTempLastResort.includes(_location) then
			self.myCurrentCMIFYAAutoPlan.allLCsTempLastResort.add(_location);
		endif;
	else
		// Ok
	endif;
	
	// Just slips through. Valid for checking secondary stuff.

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addLogEntry" id="ab4ec1e2-2faf-4f39-9d75-03cc386db842">
        <updating/>
        <source>addLogEntry(_logIndexLevel : Integer; _logEntry : String; _isVerbose : Boolean) updating;
// -------------------------------------------
// Created 29 March 2005 by cnwdvb1
// New version includes _logIndexLevel, which is used in the display tree for multi cargo test planning.
// -------------------------------------------
vars

	str							: String;
	isVeboseLoggingEnabled		: Boolean;
	callingMethod: String;
	isBadCMIFYAAutoPlan 		: Boolean;
	cmifAutoPlan				: CMIF_YAAutoPlan;
begin
	
	on Exception do app.handleDeletedObject(exception, cmifAutoPlan, isBadCMIFYAAutoPlan); 

	cmifAutoPlan := self.myCurrentCMIFYAAutoPlan;
	

	
	
	if _logEntry = null or _logEntry.isBlank then
		str := (_logIndexLevel.String &amp; ", Null logEntry call stack: " &amp; app.getMethodStack(0) ).String[1:512];
	else
		str := (_logIndexLevel.String &amp; "," &amp; _logEntry).String[1:512];
	endif;
//	str := _logEntry[1:512];
//	if self.extraLogDetail then
		
//	endif;
	
	if app.myLoggingForm &lt;&gt; null then
		app.doFormLogging( method, str, null );
	endif;	
	
	if cmifAutoPlan = null then
		return;
	endif;
	
	if not _isVerbose then
		cmifAutoPlan.allLogging.add(str);	
	endif;
	
	
	cmifAutoPlan.allVerboseLogging.add(str);
	


end;</source>
        <Parameter name="_logIndexLevel" type="Integer"/>
        <Parameter name="_logEntry" type="String"/>
        <Parameter name="_isVerbose" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToFailedLocations" id="a2b66cd9-dee7-48e4-9625-6120ca1b6783">
        <source>addToFailedLocations(_failedLocation : CM_LocationsController);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwer1	Initial creation

*/

vars

begin
	if not self.myCurrentCMIFYAAutoPlan.allFailedLocations.includes(_failedLocation) then
		self.myCurrentCMIFYAAutoPlan.allFailedLocations.add(_failedLocation);
	endif;
	
	//cnwrd1 par 29269 14.4.2012 LOB queueing
	if self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.includes(_failedLocation) then
		self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.remove(_failedLocation);
	endif;
	
epilog

end;</source>
        <Parameter name="_failedLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="addToPassedWithRestrictionLoc" id="1b8c3a85-6e81-4c29-9a7a-72d4ca4ed240">
        <source>addToPassedWithRestrictionLoc(_passedResrtictLocation : CM_LocationsController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2012	cnwrd1	Initial creation
//cnwrd1 par 29269 14.3.2012
*/

vars

begin
	//cnwrd1 par 29269 14.4.2012 LOB queueing
	if not self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.includes(_passedResrtictLocation) then
		self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.add(_passedResrtictLocation);
	endif;
	
epilog

end;</source>
        <Parameter name="_passedResrtictLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="addYATestLocation" id="6293567d-7434-4883-bd55-58860eabc83e">
        <updating/>
        <source>addYATestLocation( _yaCont : CM_LocationsController; _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2013	cnwndl1	Initial creation	Par 32049
13 jan 	2016 	cnwer1	PAR 37319
20 Oct 2022		jlier1  TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location
*/

vars
	previousTestLocation : CM_YATestLocation;
	location : CM_LocationsController;
	locationTA : CM_TerminalArea;
	nextLocation : CM_YardController;
	startOffset : Integer;
	endOffset : Integer;

begin

	location := _yaCont;
	
	self.allYATestLocations.addData( location, _ti,0 );
	
	
	locationTA := location.myTerminalArea;
	if locationTA.isKindOf(CM_GridArea)  then
		if location.isKindOf(CM_GridController) and location.CM_GridController.myPreviousController &lt;&gt; null then
			previousTestLocation:=self.allYATestLocations[location.CM_GridController.myPreviousController];
			//epr par 37319
			if previousTestLocation &lt;&gt; null then
				startOffset:=previousTestLocation.endOffset;
			endif;
		endif;
		
		if _ti.is30 or _ti.isForty or _ti.is45 or _ti.is53 then
			nextLocation := location.getNextControllerOfType(location.class).CM_YardController;
			if nextLocation &lt;&gt; null then
				endOffset:=0;
				//epr par 37319
				if _ti.is30 then
					endOffset:=((startOffset + _ti.getActualLength()) mod 20).Integer;
				endif;
				self.allYATestLocations.addData( nextLocation, _ti,endOffset );
				if _ti.is53 or _ti.is45 then
					
					location := nextLocation;
					nextLocation := location.getNextControllerOfType(location.class).CM_YardController;
					if nextLocation &lt;&gt; null then
						startOffset:=0;
						//epr par 37319
						endOffset:=((startOffset + _ti.getActualLength()) mod 20).Integer;	
						self.allYATestLocations.addData( nextLocation, _ti,  endOffset  );
					endif;
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_yaCont" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="autoPlanForDischarge" id="39bb57af-c34a-4b2e-8c08-c896d141c012">
        <updating/>
        <source>autoPlanForDischarge(_terminal : CM_Terminal; _voyage : CM_Voyage; _wleSetOut : CM_WLESet input) updating;

// Created by cnwdvb1 on 01 May 2006

vars

	job				: CM_Job;
	wle				: CM_WorkListEntry;
	ti				: CM_TrackedItem;
	tmpLocn			: CM_LocationsController;
	passport		: CM_Passport;
	wleSet 			: CM_WLESet;
	jobSheet		: CM_JobSheet;

begin

	// Need a voyage.
	if _voyage = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, 'voyage has not been specified', null, null);
		return;
	endif;
	
	// Store the wles we want to auto plan here.
	create wleSet transient;

	// Dont clear the out set because this is keeping state.
	passport := app.myPassport;
	
	// Plan discharge jobs on job sheets that haven't been planned or queued already and aren't complete.
	foreach jobSheet in _voyage.allJobSheets discreteLock do
		foreach job in jobSheet.allJobsByOrder discreteLock do
			if job.jobType = JOB_TYPE_DISCHARGE and job.CM_VoyageJob.isLoadedToOperations then
				foreach wle in job.workListEntries discreteLock do
					if wle.status = WLE_COMPLETED or  wle.isQueued() or wle.myFutureMove &lt;&gt; null then
						continue;
					endif;
					ti := wle.myTrackedItem;
					if ti = null then
						continue;
					endif;
					
					if not wleSet.includes(wle) then
						wleSet.add(wle);
					endif;
				endforeach;
			endif;
		endforeach;
	endforeach;
	
	// Call trx with any wles
	if not wleSet.isEmpty() then
		app.myTrxUA.trxAutoPlanMultipleTis(wleSet, _wleSetOut, PLANNING_MODE, passport);
	endif;

	return;
epilog
	delete wleSet;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_wleSetOut" type="CM_WLESet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTandemTiYA" id="2ce7924d-c5a3-4c62-98c8-302704865f6c">
        <updating/>
        <source>autoPlanTandemTiYA(	_terminal 			: CM_Terminal;
					_terminalArea 		: CM_TerminalArea; 					
					_ti, _tandemTi  	: CM_TrackedItem;
					_tiLocation, 
					_tandemTiLocation 	: CM_LocationsController output) updating;
					
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 09 January 2019
TFS#		: 41806
Function	: This function copy the behavior of the test auto plan form.

*** Changes ***
Date			Name		TFS#		Description
20 Oct 2022		jlier1  TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location

****************************************************/
vars
	tiArray 			: ObjectArray;
	agent				: CM_YAAutoplanAgent;
	location			: CM_LocationsController;
	obj					: Object;
	ti, cloneTI			: CM_TrackedItem;
	passport			: CM_Passport;
	primeYardAllocation : CM_YardAllocation;
	usedYardAllocation	: CM_YardAllocation;
	log					: StringArray512;
	cmifYAPlanScenario  : CMIF_YAAutoPlanSenario;
	splitLocations		: String;
	index				: Integer;
begin	
	if _ti = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, 'tracked item has not been specified', null, null);		
		return;
	endif;
	if _tandemTi = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, 'Tandem tracked item has not been specified', null, null);
		return;
	endif;
	create tiArray transient;
	
	tiArray.addExclusive(_ti);
	tiArray.addExclusive(_tandemTi);
	
	agent := self;
	passport := app.myPassport;
	passport.setMyTerminal(_terminal);
	
	foreach obj in tiArray do
		index := index + 1;
		
		agent.initialiseForTrxStart();
		agent.clearForMulti();
		cmifYAPlanScenario:=null;
		if obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_TrackedItem;
			
			if ti.myTerminal &lt;&gt; _terminal then				
				cloneTI :=ti.cloneForInterTerminalPreNote(_terminal,true);
				agent.autoPlanTiYA(_terminal, _terminalArea, null, null, cloneTI, null);
			else
				agent.autoPlanTiYA(_terminal, _terminalArea, null, null, ti, null);
			endif;
		endif;
		
		splitLocations := null;
		location := agent.getFoundLocation();
		if location = null then
			splitLocations := agent.getSplitLocsString();
		endif;
		usedYardAllocation := agent.getYardAllocationUsed();
		
		if index = 1 then
			_tiLocation := location;
		else
			_tandemTiLocation := location;
		endif;
		
		primeYardAllocation := self.getPrimeYardAllocation;
		
		log := self.getLoggingArray(true);
		
		if location &lt;&gt; null then
			agent.addYATestLocation( location, ti ); //jlier1 TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location
		endif;
		
		if cloneTI &lt;&gt; null then
			delete cloneTI;
		endif;
	endforeach;
	
epilog
	delete tiArray;
	
	if cloneTI &lt;&gt; null then
		delete cloneTI;
	endif;
	if agent &lt;&gt; null then
		agent.resetTestLocations();	
	endif;
	
	if _ti &lt;&gt; null then
		self.unlock(_ti);
	endif;
	
	if _tandemTi &lt;&gt; null then
		self.unlock(_tandemTi);
	endif;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tandemTi" type="CM_TrackedItem"/>
        <Parameter name="_tiLocation" type="CM_LocationsController" usage="output"/>
        <Parameter name="_tandemTiLocation" type="CM_LocationsController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTiToRail" id="a106bfc8-9faf-4917-ae88-6546c839aaeb">
        <updating/>
        <source>autoPlanTiToRail(	_moveMode 	: Integer;
					_terminal 	: CM_Terminal; // last option
					_railArea	: CM_Rail;//looked for third option
					_train 		: CM_Train;//looked for second
					_wagon		: CM_Wagon;// first option
					_ti 		: CM_TrackedItem
					) : CM_WagonController updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2013	cnwndl1	Initial creation	Par 31692
 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
*/

vars

	cmifAutoPlan : CMIF_YAAutoPlanNormal;
	wagonController : CM_WagonController;
	taDict : CM_TAByTypeIdDict;
	iter : Iterator;
	loopTA : CM_TerminalArea;
	taTypeKey : Integer;
	taIdKey : String;
	rail : CM_Rail;

begin

	if _ti = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, app.getErrorString(No_Cargo_selected), null, null);
		return null;
	endif;
	
	if _wagon = null and _train = null and _railArea = null and _terminal = null then
		app.raiseCMException2(AutoPlanningYAError, _ti.id, app.getErrorString(No_Associated_Target_Range), null, null);
		return null;
	endif;
	
	self.initialise();
	self.isFindLocationForBox := true;
	self.myFirstYAFailure := null;
	self.myCurrentJob := null;
	
	self.myCurrentTerminal := _terminal;
	
	create cmifAutoPlan transient;
	self.setYAAutoPlan(cmifAutoPlan);
	self.setCurrentYAAutoPlan(cmifAutoPlan);
	
	self.sharedLock(_ti);
	
	cmifAutoPlan.attachTI(_ti);
	
	self.addLogEntry(AP_Log_YA_Global, app.getErrorString1(Attempting_auto_plan, _ti.id), true);

	if _wagon &lt;&gt; null then
		self.addLogEntry(AP_Log_YA_Default, app.getErrorString1(Using_specified_wagon, _wagon.id), true);
		wagonController := _wagon.getAutoPlanLocationFor(_ti, self, cmifAutoPlan, _moveMode );
		if wagonController &lt;&gt; null then
			return wagonController;
		endif;
		
	elseif _train &lt;&gt; null then
		wagonController := _train.getAutoPlanLocationFor(_ti, self, cmifAutoPlan, _moveMode );
		if wagonController &lt;&gt; null then
			return wagonController;
		endif;
		
	elseif _railArea &lt;&gt; null then
		wagonController := _railArea.getAutoPlanLocationFor(_ti, self, cmifAutoPlan, _moveMode, true );
		if wagonController &lt;&gt; null then
			return wagonController;
		endif;
		
	elseif _terminal &lt;&gt; null then
		//search all rail areas in terminal
	
		self.addLogEntry(AP_Log_YA_Default, app.getErrorString(Using_rail_areas), false);
		taDict := _terminal.allTerminalAreasByTypeId;
		iter := taDict.createIterator();
		taDict.startKeyGeq(TA_TYPE_RAILWAY_TRACK, null, iter);
		while iter.next(loopTA) do
			iter.getCurrentKeys(taTypeKey,taIdKey); //MTN-35226
			if taTypeKey &lt;&gt; TA_TYPE_RAILWAY_TRACK then
				break;
			endif;
			rail := loopTA.CM_Rail;
			wagonController := rail.getAutoPlanLocationFor(_ti, self, cmifAutoPlan, _moveMode, false );
			if wagonController &lt;&gt; null then
				return wagonController;
			endif;
			
		endwhile;
	
	endif;
	
	self.setHadError(true);
	return null;

epilog

	delete iter;
	
	self.createLoggingAlert();
	self.agentUsage := self.Normal_Usage;
	
	if _ti &lt;&gt; null then
		self.unlock(_ti);
	endif;

end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTiVerbose" id="46eb01c9-e0e5-4343-91dc-58112568efe4">
        <updating/>
        <source>autoPlanTiVerbose(_terminal : CM_Terminal; _terminalArea : CM_TerminalArea; _yaCMIF : CMIF_YAAutoPlanSenario) : Boolean updating;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
// This method should be called from the Portschema method autoPlanSenario
begin

	self.setIsSenarioTesting(false, true);

	if _yaCMIF = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, 'CMIF Senario  has not been specified', null, null);
		return false;
	endif;
	
	self.initialiseForSenario(_yaCMIF, _terminal, _terminalArea);
	
	return self.searchAllocationIn(_terminal, _terminalArea, null);

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_yaCMIF" type="CMIF_YAAutoPlanSenario"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTiYA" id="f6d85c39-e751-4b92-87b7-be4c7125123d">
        <updating/>
        <source>autoPlanTiYA(	_terminal : CM_Terminal;
				_terminalArea : CM_TerminalArea; 
				_gridRow 		: CM_GridRow;
				_gridColumn		: CM_GridColumn;
				_ti : CM_TrackedItem; 
				_job : CM_Job) : Boolean updating;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
// This method should be called from the Portschema method autoPlanTiYA or autoPlanTiYATest
vars

	yaCMIF			: CMIF_YAAutoPlan;

begin

	if _ti = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, 'tracked item has not been specified', null, null);
		return false;
	endif;
	
	self.initialiseSearchForAutoPlan(_ti, _terminal, _terminalArea,_gridRow,_gridColumn);
	
	yaCMIF := self.myCMIFYAAutoPlan;
	
	self.sharedLock(_ti);
	
	yaCMIF.attachTI(_ti);

	return self.searchAllocationIn(_terminal, _terminalArea, _job);
		
epilog

	if _ti &lt;&gt; null then
		self.unlock(_ti);
	endif;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_gridRow" type="CM_GridRow"/>
        <Parameter name="_gridColumn" type="CM_GridColumn"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTwinTi" id="e3c30e71-2cfa-4bb2-b79e-fdd39d4e1a6a">
        <updating/>
        <source>autoPlanTwinTi(_terminal : CM_Terminal; _terminalArea : CM_TerminalArea; _ti,_twinTi : CM_TrackedItem ) : Boolean updating;
/*

Purpose:	auto plan to 2x 20 ft containers to the yard next to each other

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2008	cnwer1	Initial creation

*/

vars
	yaCMIF: CMIF_YAAutoPlan;

begin

	if not self.validateTwins( _ti, _twinTi) then	//13 Sep 2011	NDL	Par 28112
		return false;
	endif;

	//validation code below migrated into "validateTwins" so it can be called separately	13 Sep 2011	NDL	Par 28112
		
/*	//do some basic checks before we start the overhead of auto planning
	if _ti = null or _twinTi = null then
		// Raise exception.
		app.raiseCMException(AutoPlanningYAError_NULL, null, null);//11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	//check both tis iso types are twin lift capable
	if not _ti.isTwinLiftCapable then
		// Raise exception.
		app.raiseCMException1(ERR_Failed_Autoplan_ISOType, _ti.id, null, null);//11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	if not _twinTi.isTwinLiftCapable then
		app.raiseCMException1(ERR_Failed_Autoplan_ISOType, _twinTi.id, null, null);//11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	//check if one is overDimension then can not be twin lifted
	
	if _ti.isOverDimensions  then
		app.raiseCMException1(ERR_Failed_Autoplan_Dimension, _ti.id, null, null); //11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	if _twinTi.isOverDimensions  then
		app.raiseCMException1(ERR_Failed_Autoplan_Dimension, _twinTi.id, null, null); //11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	//check the physical height PAR 19140
	
	if _ti.getActualHeight &lt;&gt; _twinTi.getActualHeight then
		app.raiseCMException2(ERR_Failed_Autoplan_Height, _ti.id, _twinTi.id, null, null); //11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	
	//check the hazardous details
	
	//we can assume that if one of the containers have haz that are required to be in a seperate ta to the other then return
	
	//like wise if both have any seperation defined then abort since they will be next to each other
	
	if not _ti.valHazSegregation(_twinTi,Segregation_Type_Yard,1,1,0,true,true,true) then
		app.raiseCMException2(ERR_Failed_Autoplan_Hazardous, _ti.id, _twinTi.id, null, null); //11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	*/
	
	self.initSearchForTwinAutoPlan(_ti,_twinTi, _terminal, _terminalArea);
	
	
	self.sharedLock(_ti);
	self.sharedLock(_twinTi);
	
	self.myCMIFYAAutoPlan.attachTI(_ti);
	self.myLinkedYAAutoPlan.attachTI(_twinTi);

	return self.searchAllocationIn(_terminal, _terminalArea, null);
		
epilog

	if _ti &lt;&gt; null then
		self.unlock(_ti);
	endif;
	if _twinTi &lt;&gt; null then
		self.unlock(_twinTi);
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_twinTi" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="bestPickReleaseTIs" id="b508ecb2-dc26-4c0a-9ae1-7fb0ba72d434">
        <updating/>
        <source>bestPickReleaseTIs(_request : CM_DeliveryRequest) : CM_TrackedItem updating;
//19 May 2010	cnwml2; modified 28 May cnwjre1 to fix unit test failures
//+cnwml2 PAR23848

vars
	saveTi,
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	found : Boolean;
	dynaDict : DynaDictionary;
	iter : Iterator;
begin
	self.lastOverstowLevel := 99999;
	if _request.myOriginatingBulkRelease &lt;&gt; null then
		//jlier1 1/10/25 MTN-35633
		self.addLogEntry(AP_Log_YA_Global,'Checking Best Pick for assigned cargo for Release ' &amp; _request.myOriginatingBulkRelease.code, true);
		
		//jlier1 MTN-35637 17/9/25
		create dynaDict transient;
		dynaDict.setMembership(CM_TrackedItem);
		dynaDict.addMemberKey(CM_TrackedItem::numOverstows.name,false,false);
		dynaDict.addMemberKey(CM_TrackedItem::bestPickDT.name,false,false);			
		dynaDict.endKeys(true);
		
		_request.myOriginatingBulkRelease.allTrackedItemsAssigned.copy(dynaDict);
		
		iter:=dynaDict.createIterator;	
		dynaDict.startKeyGeq(null,null,iter);
	
		while iter.next(ti) do
			// handle releasing several TIs in same transaction - second+ time around skip the TIs just assigned
			found := false;
			foreach wle in ti.allWorklistEntries discreteLock do
				if wle.status = WLE_COMPLETED then   // PAR 26481
					continue;
				endif;
				if wle.myTrackedItem = ti then
					found := true;
					break;
				endif;
			endforeach;
			if found then
				continue;
			endif;
			//jlier1 1/10/25 MTN-35633
			self.addLogEntry(AP_Log_YA_Global,ti.id &amp; ", Best Pick Date/Time " &amp; ti.bestPickDT.asStringJMT &amp; " using " &amp; ti.getBestPickDTReason &amp; ", Overstows " &amp; ti.numOverstows.asStringJMT  , false);
			//jlier1 MTN-35637 17/9/25
			if _request.allTerminalAreas.first &lt;&gt; null then
				if not _request.allTerminalAreas.includes(ti.myTerminalArea) then
					//jlier1 1/10/25 MTN-35633
					self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " not located in a request terminal area", false);
					continue;
				endif;
			endif;
			
			if not ti.myPrimaryActualLocation.isKindOf(CM_YardController) then
				//jlier1 1/10/25 MTN-35633
				self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " not in a Yard Location", false);
				continue;
			endif;			
			//get all used cargo for terminal area
			if ti.myTerminalArea &lt;&gt; null  then
				if ti.myTerminalArea.isTIAllocatedInDirectorTask(ti,_request) then
					//jlier1 1/10/25 MTN-35633
					self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " is already allocated to Director Task", false);
					continue;
				endif;
			endif;
			
			//don't need to do the overstow stuff because it is now ordered by the least overstowe
			self.myCurrentCMIFYAAutoPlan.allFoundTis.add(ti);
			self.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.add(ti);
			saveTi := ti;
			break;
		endwhile;
	endif;
	
	if saveTi = null and
	   self.bestPickOverstowedTI &lt;&gt; null then
		self.addLocationToAgent(self.bestPickOverstowedTI.allLocations.first, CM_YAAutoplanAgent.Locations_Found);
		self.myCurrentCMIFYAAutoPlan.allFoundTis.add(self.bestPickOverstowedTI);
		self.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.add(self.bestPickOverstowedTI);
		saveTi := self.bestPickOverstowedTI;
	endif;
	
	if saveTi &lt;&gt; null then			// 23676 for logging
		self.addLogEntry(AP_Log_YA_Default,'Located item (' &amp; saveTi.id &amp; ') in source location ' &amp; saveTi.locationId, false);
	else
		self.addLogEntry(AP_Log_YA_Default,'Search for best pick in BOL found nothing', true);	
		self.createLoggingAlert();		// PAR 26771 
	endif;
	return saveTi;
epilog
	delete iter;
	delete dynaDict;
end;</source>
        <Parameter name="_request" type="CM_DeliveryRequest"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="canOverstow" id="db1b7866-886b-4b62-a693-84a214dcef15">
        <updating/>
        <source>canOverstow(_location : CM_YardController) : Boolean updating;
// -------------------------------------------
// Created 16 September 2005 by cnwdvb1
// -------------------------------------------
vars

	rule	: CM_YAOverstowRule;
	imex	: CM_IMEXStatus;
	ti		: CM_TrackedItem;

begin

	// Normal autoplan.
	ti := self.getMyCurrentTrackedItem();
	
	if self.myCurrentAllocation &lt;&gt; null then
		// Don't have to specify a rule.
		if self.myCurrentAllocation.myYAOverstowRule &lt;&gt; null then
			self.addLogEntry(AP_Log_YA_Default,'Using overstow rule from allocation...', true);
			rule := self.myCurrentAllocation.myYAOverstowRule;
		endif;
	else
	// Check out imex status default rule.
		if ti = null then
			return false;
		endif;
		imex := ti.getImExStatusObject();
		if imex = null then
			return false;
		endif;
		self.addLogEntry(AP_Log_YA_Default,'Using overstow rule from IMEX...', true);
		rule := imex.getYAOverstowRuleForTerminal(self.myCurrentTerminal);
	endif;
	
	if rule = null then
		self.addLogEntry(AP_Log_YA_Default,'No overstow rule continuing...', true);
		return true;
	endif;
	
	self.addLogEntry(AP_Log_YA_Default,'Using overstow rule - ' &amp; rule.code, true);
		
	return rule.canOverstow(_location, ti, self);

end;</source>
        <Parameter name="_location" type="CM_YardController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canTerminalAreaHaveEmpties" id="f07db0cb-e20a-4f4c-a3de-3f3d14d1d940">
        <source>canTerminalAreaHaveEmpties(_ta: CM_TerminalArea): Boolean;
//17 September 2010	cnwdw1	
// Answer true if the area can be used to find empties 
vars

begin
	if _ta = null or _ta.isTransferArea then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForNestedAllocations" id="337b5476-f037-40da-9154-b665ad0d2cf5">
        <updating/>
        <source>checkForNestedAllocations(_yardController : CM_YardController; _yardAllocation : CM_YardAllocation) : Integer updating;
// -------------------------------------------
// Created 14 April 2005 by cnwdvb1
// -------------------------------------------
vars
	
	type	: Integer;

begin

	if self.checkingSecondary then
		self.addLogEntry(AP_Log_YA_Default,'Comparing back end against yard allocation - ' &amp; _yardAllocation.code, true);
	else
		self.addLogEntry(AP_Log_YA_Default,'Comparing primary controller against yard allocation - ' &amp; _yardAllocation.code, true);
	endif;
	
	type := _yardAllocation.allowOthersOption;
	
	if  type = YAOverlap_Sometimes then
		// We need to know if we fit or not. If we don't then only use as
		// last resort otherwise it's perfect.
		if not _yardAllocation.compareCriteriaToCMIF(self, self.myCurrentCMIFYAAutoPlan) then
			self.addLogEntry(AP_Log_YA_Default,'Did not compare against yard allocation - ' &amp; _yardAllocation.code &amp; ' changing to last resort', true);
			type := YAOverlap_LastResort;
		endif;
	endif;
	
	// Add location. Don't add back end. Just checking if it is ok.
	if not self.checkingSecondary then
		self.addLocationToAgent(_yardController, type);
	endif;
	return type;
	
	
end;</source>
        <Parameter name="_yardController" type="CM_YardController"/>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkMarkDictSpecial" id="2d3bbb7e-c2fa-413f-8b8c-962af9367c61">
        <updating/>
        <source>checkMarkDictSpecial(_mark : String; _imexStatus : Integer; _terminal : CM_Terminal) : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/03/2021	navdap1		Initial creation TFS 50889 PRP Yard Allocation Performance Improvement
//
vars
	termIter : Iterator;
	tiMark, markKey, yaKey : String;
	yardAllocation : CM_YardAllocation;
	crit : CM_YACriteria;
	imexObj : CM_IMEXStatus;

begin
	tiMark := _mark.trimBlanks[1:100];
	imexObj := app.myRoot.allImexStatuses[_imexStatus];
	termIter := _terminal.allYAsByMark.createIterator;
	_terminal.allYAsByMark.startKeyGeq(tiMark, null, termIter);
	while termIter.next(yardAllocation) do
		termIter.getCurrentKeys(markKey, yaKey);
		if markKey &lt;&gt; tiMark then
			break;
		endif;
		if markKey = tiMark and yardAllocation.allCriteria.size = 2 then
			crit := yardAllocation.allCriteriaByType[YACriteriaType_ImexStatus];
			if crit &lt;&gt; null and crit.myYAData.CM_YADataObjects.allObjects.includes(imexObj) then
				// success - use this yard allocation
				self.addLogEntry(AP_Log_YA_Match, "Using " &amp; yardAllocation.code&amp; " from Mark criteria search", false);
				self.myCurrentCMIFYAAutoPlan.allFoundLCs.add(yardAllocation.allYardControllers.first);
				return true;
			endif;
		endif;
	endwhile;
	
	return false;
epilog
	delete termIter;
end;</source>
        <Parameter name="_mark" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearForMulti" id="26e90784-54ec-4900-9444-525dcd90038f">
        <source>clearForMulti();

// Created by cnwdvb1 on 20 June 2007

vars
	
	invalid : Boolean;

begin

	if self.myCurrentCMIFYAAutoPlan &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myCurrentCMIFYAAutoPlan, invalid );	//01 Mar 2012	NDL	Par 29195
		self.myCurrentCMIFYAAutoPlan.clearForMulti();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="b4dae1ee-f4dd-4e6f-9524-edbf9133b4c0">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
vars

	terminal	: CM_Terminal;
	iter		: Iterator;

begin

	if app.isWebApp then
		return;
	endif;
	
	iter := app.myRoot.allTerminals.createIterator();
	while iter.next(terminal) do
		if not terminal.isAutoPlanningEnabled() then   //SFW1030 04/08/2008
			continue;
		endif;
		
		// Only load up terminals with autoplanning enabled. We 
		// don't take notice of the ya autoplanning flag because
		// users should still be able to do senario autoplanning.
		if not terminal.isAutoPlanningEnabled() then   //SFW1030 04/08/2008
			continue;
		endif;
		
		self.beginNotification(terminal, terminal.getTerminalEvent(EVENT_YA_CP_UPDATE), Response_Continuous, 1);
	endwhile;
	
	// Put begin notes stuff here

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="createAutomaticYardAllocation" id="c77d37d5-c030-4258-a8ad-b5c36d84f0de">
        <updating/>
        <source>createAutomaticYardAllocation(_terminalArea : CM_TerminalArea; _ti : CM_TrackedItem) : Boolean updating;
// -------------------------------------------
// Created 19 September 2005 by cnwdvb1
// -------------------------------------------
/* Attributes that need to be created based on old criteria
GENERAL 	- Operator
CONTAINER	- ISO group or if not available then ISO type
			- Availability grade
			- Washed
			- Rehandles only
LOG			-  Not sure as yet
WAREHOUSE	- Product */
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/07/2014	cnwdap1		PAR #34488 Rejig code to create proxy allocation before calling parserObj.parseLocations, as a 
//							method furher down the stack (CM_IrregularBlockArea::yaBuildBlocks) depends on having an allocation
// 10/03/2021	navdap1		TFS 50889 PRP Yard Allocation Performance Improvement
// 20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
vars
	aTA						: CM_TerminalArea;
	realAllocation			: CM_YardAllocation;
	allocationObj			: CM_YardAllocation;
	parserObj				: CM_YAParser;
	allBlocksInObj			: CM_YABlockArray;
	allBlocksOutObj			: CM_YABlockArray;
	allGroupsInObj			: CM_YABlockGroupArray;
	allGroupsOutObj			: CM_YABlockGroupArray;
	groupObj				: CM_YABlockGroup;
	tmpDescription			: String;
	targetLocation			: String;
	allCriteria				: CMIF_Array;
	tmpObjectSet			: ObjectSet;
	transientObj			: CMIF_YACriteriaPriority;
	cmifObject				: CMIF_Object;
//	realCriteriaPriority	: CM_YACriteriaPriority;
	proxyObj				: CM_YACriteriaPriority;
	priorityValue			: Real;
	fillOption				: Integer;
	sortValue				: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
//	yaCMIF					: CMIF_YAAutoPlan;
	terminal				: CM_Terminal;
	isFound					: Boolean;
	iter					: Iterator;
	tmpTotal				: Real;
	rule					: CM_YAOverstowRule;
	imex					: CM_IMEXStatus;
	block					: CM_YABlock;						// PAR #34488

begin
	terminal := _terminalArea.myTerminal;
	
	create parserObj transient;
	create allBlocksInObj transient;
	create allBlocksOutObj transient;
	
	create allCriteria transient;
	create tmpObjectSet transient;
	
	_ti.setYardAllocationCriteriaAuto(allCriteria, tmpObjectSet);
	
	foreach cmifObject in allCriteria reversed do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		if transientObj.isDeleted then
			continue;
		endif;
		
		proxyObj		:=	transientObj.myProxy;
		priorityValue	:=	2^sortValue;
		proxyObj.setPriorityValue(priorityValue);
		sortValue		:=	sortValue + 1;
		
		if tmpDescription = null then
			tmpDescription := transientObj.getListDisplay();
		else
			tmpDescription := transientObj.getListDisplay() &amp; ', ' &amp; tmpDescription;
		endif;
		
		tmpTotal	:=	tmpTotal + transientObj.myProxy.CM_YACriteria.calculatePriority();
	endforeach;
	
	iter := terminal.allYardAllocations.createIterator();
	//realAllocation  := self.getYardAllocation(terminal, null, tmpTotal);
	//iter.startAtObject(realAllocation);
	terminal.allYardAllocations.startKeyGeq(tmpTotal, iter);     // CCMS 20441
	self.exclusiveLock( terminal.allYardAllocations );	// 17 Mar 2011	NDL	Par 27205 - 
	
	while iter.next(realAllocation) do
		self.sharedLock(realAllocation);
		if realAllocation.priorityValue &lt;&gt; tmpTotal then
			// not found
			break;
		endif;
		
		// CCMS 1013
//		if realAllocation.isDisabled then
		if realAllocation.isDisabled or not realAllocation.includeInYardDisplays() then
			continue;
		endif;
		
		// do new compare here
		if realAllocation.isSameAs(allCriteria) then
			isFound := true;
			break;
		endif;
		
		self.unlock(realAllocation);
	endwhile;
	
	if isFound and realAllocation &lt;&gt; null then
		allocationObj := app.createUpdateProxy(realAllocation).CM_YardAllocation;
		allocationObj.allYABlocksIn.copy(allBlocksInObj);
		allocationObj.allYABlocksOut.copy(allBlocksOutObj);
		parserObj.loadBlocks(allBlocksInObj, allBlocksOutObj);
	else
		// PAR #34488 create the proxy allocation at this stage, so parserObj.parseLocatinos (and subsequent methods)
		// have an allocation to operate against
		create allocationObj transient;
		if _terminalArea.autoPlanTest.testFirstInFirstOut then
			fillOption := YAFillOption_FIFO;
		else
			fillOption := YAFillOption_InOrder;
		endif;
		// Check out imex status default rule.
		imex := _ti.getImExStatusObject();
		if imex &lt;&gt; null then
			rule := imex.getYAOverstowRuleForTerminal(terminal);
		endif;
		allocationObj.setProxy(	'Auto Allocation - ' &amp; _terminalArea.id &amp; ' (' &amp; _ti.id &amp; ')',
								tmpDescription,
								'Allocation based on the state of ' &amp; _ti.cargoTypeDescr &amp; ' ' &amp; _ti.id,
								fillOption,
								fillOption,
								YAExpiryType_Never,
								null,
								0,
								null,
								YAOverlap_Always,
								YANoLocation_Continue,
								rule,
								0,
								false,
								false,
								null,
								null,
								true,
								_terminalArea.myTerminal	);
		allocationObj.setProxyGroupBlocks(allBlocksInObj, allBlocksOutObj);
	endif;
	
	// Ok, now parse the location string.
	targetLocation := _terminalArea.id;
	
	if parserObj.parseLocations(allocationObj, targetLocation) then
		allBlocksInObj.clear();
		allBlocksOutObj.clear();
	//	parserObj.allYABlocksIn.copy(allBlocksInObj);
	//04 Apr 2016	NDL	TFS 1716
		foreach block in parserObj.allYABlocksIn do
			allBlocksInObj.addExclusive(block);
		endforeach;
	//	parserObj.allYABlocksOut.copy(allBlocksOutObj);
	//04 Apr 2016	NDL	TFS 1716
		foreach block in parserObj.allYABlocksOut do
			allBlocksOutObj.addExclusive(block);
		endforeach;
	else
	//	app.msgBox(parserObj.errorMessage, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	if isFound and realAllocation &lt;&gt; null then
		allocationObj.setNewBlocks(allBlocksInObj, allBlocksOutObj);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realAllocation, true);
			// ### NOTES
		terminal.causeEvent(terminal.getTerminalEvent(Event_YardAllocationUpdate),false,realAllocation);
		
		foreach aTA in realAllocation.allTerminalAreas do
			aTA.causeEvent(terminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,null);
		endforeach;
		
		realAllocation.terminalMarkDictRemove(allocationObj, allCriteria);			// TFS 50889
		realAllocation.setForUpdate(allocationObj);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realAllocation, false);
	else
		//create allocationObj transient;								// PAR #34488
		create allGroupsInObj transient;
		create allGroupsOutObj transient;
		create groupObj transient;
		
		//allBlocksInObj.copy(groupObj.allYABlocksIn);
		//allBlocksOutObj.copy(groupObj.allYABlocksOut);
		foreach block in allBlocksInObj do
			if block.myYABlockGroupIn &lt;&gt; null then	//08 July 2014	NDL	- 1090 during testing Par 34526, no-one knows any better until Bish/Dave return....
				if block.myYABlockGroupIn.allYABlocksIn.includes(block) then
					block.myYABlockGroupIn.allYABlocksIn.remove(block);
				endif;
			endif;
			groupObj.allYABlocksIn.add(block);
		endforeach;
		foreach block in allBlocksOutObj do
			if block.myYABlockGroupOut &lt;&gt; null then	//08 July 2014	NDL	- 1090 during testing Par 34526, no-one knows any better until Bish/Dave return....
			//	if block.myYABlockGroupOut.allYABlocksIn.includes(block) then
				if block.myYABlockGroupOut.allYABlocksOut.includes(block) then	//04 Feb 2015	NDL	Par 35617
					block.myYABlockGroupOut.allYABlocksOut.remove(block);
				endif;
			endif;
			groupObj.allYABlocksOut.add(block);
		endforeach;
		allGroupsInObj.add(groupObj);
		allGroupsOutObj.add(groupObj);
		
		allocationObj.setGroupBlocks(allGroupsInObj, allGroupsOutObj);	// PAR #34488
		//if _terminalArea.autoPlanTest.testFirstInFirstOut then		// PAR #34488
		//	fillOption := YAFillOption_FIFO;							// PAR #34488
		//else															// PAR #34488
		//	fillOption := YAFillOption_InOrder;							// PAR #34488
		//endif;														// PAR #34488
		
		// Check out imex status default rule.							// PAR #34488
		//imex := _ti.getImExStatusObject();							// PAR #34488
		//if imex &lt;&gt; null then											// PAR #34488
		//	rule := imex.getYAOverstowRuleForTerminal(terminal);		// PAR #34488
		//endif;														// PAR #34488
		
		//allocationObj.setProxy(	'Auto Allocation - ' &amp; _terminalArea.id &amp; ' (' &amp; _ti.id &amp; ')',			// PAR #34488
		//						tmpDescription,																// PAR #34488
		//						'Allocation based on the state of ' &amp; _ti.cargoTypeDescr &amp; ' ' &amp; _ti.id,	// PAR #34488
//		//						'Automatically Created By System',											// PAR #34488
		//						fillOption,																	// PAR #34488
		//						fillOption,																	// PAR #34488
		//						YAExpiryType_Never,															// PAR #34488
		//						null,																		// PAR #34488
		//						0,																			// PAR #34488
		//						null,  //cnwjo3 par 24145													// PAR #34488
		//						YAOverlap_Always,															// PAR #34488
		//						YANoLocation_Continue,														// PAR #34488
		//						rule,																		// PAR #34488
		//						0,																			// PAR #34488
		//						false,																		// PAR #34488
		//						false,																		// PAR #34488
		//						allGroupsInObj,																// PAR #34488
		//						allGroupsOutObj,															// PAR #34488
		//						true,																		// PAR #34488
		//						_terminalArea.myTerminal);													// PAR #34488
		
		// Already in transaction state.
		app.myUtilityCA.utlCreateYardAllocation(allocationObj, allCriteria, realAllocation, app.myPassport);
	endif;
	
	if app.myPassport.noErrors then						// TFS 50889
		realAllocation.terminalMarkDictAdd();			// TFS 50889
	endif;												// TFS 50889
	
	return true;
epilog
	if realAllocation &lt;&gt; null then
		self.unlock(realAllocation);
	endif;
	
	delete iter;
	delete allocationObj;
	delete allBlocksInObj;
	delete allBlocksOutObj;
	delete allGroupsInObj;
	delete allGroupsOutObj;
	delete parserObj;
	
	if allCriteria &lt;&gt; null then
		allCriteria.purge();
	endif;
	
	delete allCriteria;
	delete tmpObjectSet;
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createLoggingAlert" id="2dc13acf-c2ac-400e-a6bd-375d79b5f171">
        <updating/>
        <source>createLoggingAlert() protected, updating;
// -------------------------------------------
// Created 05 May 2005 by cnwdvb1
// -------------------------------------------
vars

	str			: String;
	isFirst		: Boolean;
	cmifYAAutoPlanAgent: CMIF_YAAutoPlan;
begin

	// We only create logging alerts when in Normal Usage.
	if not self.isSingleProcessing() then
		return;
	endif;
	
	//16 Jun 2015	NDL	Par 36338
	if self.isReserveSelectionTest then
		return;
	endif;
	
	if app.isSpecial then					// PAR 28770
		self.alertOverride := true;
		app.verboseLogging := true;
	endif;

	// We don't bother creating duplicate alerts.
	if app.myPassport.warningsAcknowledged and not self.alertOverride then
		return;
	endif;

	cmifYAAutoPlanAgent := self.myCMIFYAAutoPlan;
	if cmifYAAutoPlanAgent = null then
		cmifYAAutoPlanAgent := self.myCurrentCMIFYAAutoPlan;
	endif;
	if cmifYAAutoPlanAgent = null then
		return;
	endif;
	
	isFirst	:= true;
	// If verbose logging is on or auto plan had an error then
	// we want all the detail.
	if	app.verboseLogging or 
		(self.hadError and not self.agentUsage = self.TestSingleTI) then
		
		//epr par 19693 15/5/09
		cmifYAAutoPlanAgent.setMyTerminal(self.myCurrentTerminal); 
		app.alertManager.addLogAlertYAFromLogging(cmifYAAutoPlanAgent,true,self.hadError);
		
		if self.myLinkedYAAutoPlan &lt;&gt; null then
			self.myLinkedYAAutoPlan.setMyTerminal(self.myCurrentTerminal);
			app.alertManager.addLogAlertYAFromLogging(self.myLinkedYAAutoPlan,true,self.hadError);
		endif;

		
	// We aren't logging so stop.
	elseif not self.myCurrentTerminal.isAutoPlanAllowLogging() then		// SFW1030 04/08/2008
		return;
		
	// We are just creating basic logging after successful auto planning.
	elseif not self.isFindLocationForBox then
		return;

	endif;
	
	// If we aren't in transaction state we will need to commit this alert manually.
	if  not process.isInTransactionState then
		app.commitAlert();	
	endif;

epilog
	self.alertOverride := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createSplitMoveCMIFs" id="f9eb55af-2dbc-404d-a4b9-a08281830937">
        <updating/>
        <source>createSplitMoveCMIFs():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/06/2016	cnwndl1	Initial creation	TFS 2172
26/08/2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	ti : CM_TrackedItem;
	errorMsg : String;
	errorNum : Integer;
	location : CM_LocationsController;
	availableQuantity : Integer;
	availableWeight : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
	availableVolume : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
	cargoType : CM_CargoType;
	remQuantity : Integer;
	remWeight : Decimal [16,4];
	remVolume : Decimal [16,4];
	moveController : CMIF_MoveController;
	locStr : String;
	unit  : String;
	amount : String;
	doBreak : Boolean;
	multiLocs : StringArray;
	splitMsg : String;

begin

	self.allMultiRangeCMIFs.clear();

	if self.myCMIFYAAutoPlan = null or self.myCMIFYAAutoPlan.allLocationsForSplit.isEmpty then
		return false;
	endif;
	
	ti := self.myCMIFYAAutoPlan.getMyTrackedItem;
	
	if ti = null or not ti.canSplitTotalQuantity then
		return false;
	endif;
	
	cargoType := ti.myCargoType;
	
	if cargoType.isTrackByWeight then
		remWeight := ti.totalWeight;
	elseif cargoType.isTrackByVolume then
		if ti.getDensity = 0 then
			self.addLogEntry(AP_Log_YA_Global,"Failed to Auto Plan over Multi Locations for Track by Volume cargo because it has no density. '" &amp; ti.id &amp; "'", false);
			return false;
		endif;
		remVolume := ti.totalVolume;
	else
		remQuantity := ti.totalQuantity;
	endif;
	
	create multiLocs transient;
	
	foreach location in self.myCMIFYAAutoPlan.allLocationsForSplit do
		location.checkControllerFullTAMax(ti,null,null,errorMsg,errorNum,availableQuantity,availableWeight,availableVolume);
		locStr := null;
		if cargoType.isTrackByWeight then
			if availableWeight &gt; 0 then
				create moveController transient;
				self.allMultiRangeCMIFs.add(moveController);
				moveController.isMultiRangeMove := true;	//27 July 2020	NDL	TFS 49775
				moveController.setMyTrackedItem(ti);
				moveController.setMyToPrimaryLocation(location);
				if location.isKindOf(CM_GeneralCargoAllocGroup) then												// TFS 49453
					moveController.setMyToPrimaryLocation(location.CM_GeneralCargoAllocGroup.allLocations.first);	// TFS 49453
				endif;																								// TFS 49453
				if availableWeight &lt; remWeight then
					moveController.setWeight(availableWeight); //epr TFS 8220 6/12/17 
					remWeight := remWeight - availableWeight;
				else
					moveController.setWeight( remWeight);
					remWeight := 0;
					doBreak := true;
				endif;
				unit := cargoType.myWeightMeasurementType.shortName;
				amount := app.convertMeasurementForDisplay(unit, moveController.weight);
				locStr := location.getFullId &amp; "(" &amp; amount &amp; Space &amp; unit &amp; ")";
			endif;
		elseif cargoType.isTrackByVolume then
			if availableVolume &gt; 0 then
				create moveController transient;
				self.allMultiRangeCMIFs.add(moveController);
				moveController.isMultiRangeMove := true;	//27 July 2020	NDL	TFS 49775
				moveController.setMyTrackedItem(ti);
				moveController.setMyToPrimaryLocation(location);
				if location.isKindOf(CM_GeneralCargoAllocGroup) then												// TFS 49453
					moveController.setMyToPrimaryLocation(location.CM_GeneralCargoAllocGroup.allLocations.first);	// TFS 49453
				endif;																								// TFS 49453
				unit := cargoType.myVolumeMeasurementType.shortName;
				if availableVolume &lt; remVolume then
					moveController.setWeight( availableVolume / ti.getDensity);
					remVolume := remVolume - availableVolume;
					amount := app.convertMeasurementForDisplay(unit, availableVolume);
				else
					moveController.setWeight( remVolume / ti.getDensity);
					remVolume := 0;
					amount := app.convertMeasurementForDisplay(unit, remVolume);
					doBreak := true;
				endif;
				locStr := location.getFullId &amp; "(" &amp; amount &amp; Space &amp; unit &amp; ")";
			endif;
		else
			if availableQuantity &gt; 0 then
				create moveController transient;
				self.allMultiRangeCMIFs.add(moveController);
				moveController.isMultiRangeMove := true;	//27 July 2020	NDL	TFS 49775
				moveController.setMyTrackedItem(ti);
				moveController.setMyToPrimaryLocation(location);
				if location.isKindOf(CM_GeneralCargoAllocGroup) then												// TFS 49453
					moveController.setMyToPrimaryLocation(location.CM_GeneralCargoAllocGroup.allLocations.first);	// TFS 49453
				endif;																								// TFS 49453
				if availableQuantity &lt; remQuantity then
					moveController.setQuantity( availableQuantity);
					locStr := location.getFullId &amp; "(" &amp; availableQuantity.String &amp; ")";
					remQuantity := remQuantity - availableQuantity;
				else
					moveController.setQuantity( remQuantity);
					
					doBreak := true;
					locStr := location.getFullId &amp; "(" &amp; remQuantity.String &amp; ")";
					remQuantity := 0;
				endif;
				
			endif;
		endif;
		if locStr &lt;&gt; null then
			multiLocs.add(locStr);
		endif;
		if doBreak then
			break;
		endif;
	endforeach;
	
	if cargoType.isTrackByWeight then
		if remWeight &gt; 0 then
			self.addLogEntry(AP_Log_YA_Global,"Failed to fully Auto Plan over Multi Locations for '" &amp; ti.id &amp; "'", false);
			return false;
		endif;
	elseif cargoType.isTrackByVolume then
		if remVolume &gt; 0 then
			self.addLogEntry(AP_Log_YA_Global,"Failed to fully Auto Plan over Multi Locations for '" &amp; ti.id &amp; "'", false);
			return false;
		endif;
	else
		if remQuantity &gt; 0 then
			self.addLogEntry(AP_Log_YA_Global,"Failed to fully Auto Plan over Multi Locations for '" &amp; ti.id &amp; "'", false);
			return false;
		endif;
	endif;
	
	if not multiLocs.isEmpty then
		foreach locStr in multiLocs do
			if splitMsg &lt;&gt; null then
				splitMsg := splitMsg &amp; ", ";
			endif;
			splitMsg := splitMsg &amp; locStr;
		endforeach;
		self.addLogEntry(AP_Log_YA_Global,"Auto Plan using Multi Locations for '" &amp; ti.id &amp; "' : " &amp; splitMsg, false);
	endif;
	
	return true;

epilog

	delete multiLocs;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="9c05f1aa-5363-4f58-be40-f2f2aea974dd">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 01 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allCMIFTerminals.purge();
	if global.isValidObject(self.myCMIFYAAutoPlan) then
		delete self.myCMIFYAAutoPlan;
	endif;
	
	if global.isValidObject(self.myCMIFValidateMove) then
		delete self.myCMIFValidateMove;
	endif;

	if global.isValidObject(self.myLinkedYAAutoPlan) then
		delete self.myLinkedYAAutoPlan;
	endif;
	
	if global.isValidObject(self.myCurrentCMIFYAAutoPlan) then
		delete self.myCurrentCMIFYAAutoPlan;
	endif;

	self.endNotificationForSubscriber(self);			// KPD 23/07/2010
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doAutoPlanOfTwinTI" id="18dab744-562a-4134-ad23-b24078d2c934">
        <updating/>
        <source>doAutoPlanOfTwinTI(	_foundAllocation : CM_YardAllocation io ; 
					_allLogging,
					_allVerboseLogging : StringArray512 input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 March 2009	cnwer1	Initial creation PAR 19133 

*/

vars
	twinTI : CM_TrackedItem;
	twinCMIFAutoplan : CMIF_YAAutoPlan;
	twinAutoplanAgent : CM_YAAutoplanAgent;
begin

	twinCMIFAutoplan:=self.myLinkedYAAutoPlan;
	twinTI:= twinCMIFAutoplan.getMyTrackedItem;
	
	create twinAutoplanAgent transient;
	twinAutoplanAgent.useOverstowRules:=self.useOverstowRules;
	
	twinAutoplanAgent.initialiseSearchForAutoPlan(twinTI,self.myCurrentTerminal,self.myCurrentSpecificTA,self.myCurrentSpecificRow,self.myCurrentSpecificColumn);
	twinAutoplanAgent.myCMIFYAAutoPlan.attachTI(twinTI);
	//i need to make sure that the allocation returned has more than one location available
	//by making this scenario it will add all locations possible that it finds for the allocation
	twinAutoplanAgent.agentUsage := self.Scenario_Twin;
	
	//can not just return this method as verbose does not return true;
	 twinAutoplanAgent.searchAllocationIn(twinAutoplanAgent.myCurrentTerminal, twinAutoplanAgent.myCurrentSpecificTA, null);

	//return the allocation if the numberOfLocations found is &gt; 1
	if  twinAutoplanAgent.numberOfLocationsFound = 1 then
		if twinAutoplanAgent.myCMIFYAAutoPlan.allFoundLCs.size = 1 then
			if twinAutoplanAgent.myCMIFYAAutoPlan.allFoundLCs.first.isKindOf(CM_BlockController) then
				_foundAllocation:=twinAutoplanAgent.myCurrentAllocation;
			else
				_foundAllocation:=null;
			endif;
		endif;
	elseif twinAutoplanAgent.numberOfLocationsFound	&gt; 1 then
		_foundAllocation:=twinAutoplanAgent.myCurrentAllocation;
	else
		_foundAllocation:=null;
	endif;
epilog
	//copy over the logging about which allocation it found to the twin container
	twinAutoplanAgent.myCMIFYAAutoPlan.allLogging.copy(_allLogging);
	twinAutoplanAgent.myCMIFYAAutoPlan.allVerboseLogging.copy(_allVerboseLogging);
	delete twinAutoplanAgent;
end;</source>
        <Parameter name="_foundAllocation" type="CM_YardAllocation" usage="io"/>
        <Parameter name="_allLogging" type="StringArray512" usage="input"/>
        <Parameter name="_allVerboseLogging" type="StringArray512" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterTIMatchesRequest" id="a9b13747-fd10-4702-a9a8-122894e14e0e">
        <source>filterTIMatchesRequest(_ti : CM_TrackedItem; _request : CM_DeliveryRequest) : Boolean protected;
// for best-pick
vars

begin
	if _request.operatorCode &lt;&gt; null then
		if _ti.operatorCode &lt;&gt; null and 
		   _ti.operatorCode &lt;&gt; _request.operatorCode then
			return false;
		endif;
	endif;

	if _request.myCargoType &lt;&gt; null then
		if _ti.cargoType &lt;&gt; _request.myCargoType.id then
			return false;
		endif;
		if _request.myCargoType.id = TI_CargoType_Container then
			if _request.isoGroup &lt;&gt; null then
				if _ti.isoTypeGroup &lt;&gt; _request.isoGroup then
					return false;
				endif;
			endif;
			if _request.isoType &lt;&gt; null then
				if _ti.getISOType() &lt;&gt; _request.isoType then
					return false;
				endif;
			endif;
		endif;
	endif;
	if _request.mySubTerminalSource &lt;&gt; null then
		if _ti.mySubTerminal &lt;&gt; null and
		   _ti.mySubTerminal &lt;&gt; _request.mySubTerminalSource then
			return false;
		endif;
	endif;
	if 	_request.ids &lt;&gt; null then
		if not _request.ids.compareIDStrings(_ti.id) then
			return false;
		endif;
	endif;

	if _ti.isKindOf(CM_Container) then
		if _ti.CM_Container.isClean &lt;&gt; _request.clean then
			return false;
		endif;
		if _ti.CM_Container.isHeavyDuty &lt;&gt; _request.heavyRated then
			return false;
		endif;		
	endif;

	if _request.allAvailabilityGrades.size &gt; 0 and _ti.canSetAvailabilityGrade then
		if not _request.allAvailabilityGrades.includes(_ti.getAvailabilityGrade) then
			return false;
		endif;
	endif;
	
	if _request.voyageCode &lt;&gt; null then
		if _ti.voyageCode &lt;&gt; null and
		   _ti.voyageCode &lt;&gt; _request.voyageCode then
			return false;
		endif;
	endif;
	if _request.billOfLading &lt;&gt; null then
		if _ti.billOfLading &lt;&gt; null and
		   _ti.billOfLading &lt;&gt; _request.billOfLading then
			return false;
		endif;
	endif;
	if _request.consignee &lt;&gt; null then
		if _ti.consignee &lt;&gt; null and
		   _ti.consignee &lt;&gt; _request.consignee then
			return false;
		endif;
	endif;
	if _request.commodity &lt;&gt; null then
		if _ti.commodity &lt;&gt; null and
		   _ti.commodity &lt;&gt; _request.commodity then
			return false;
		endif;
	endif;
	
	// the tracked item is being found so it can be assigned to this request.
	// exclude any which are already assigned to other releases
	if (not _ti.allBulkReleasesAssigned.isEmpty()) and
	   (not _ti.allBulkReleasesAssigned.includes(_request.myOriginatingBulkRelease)) then
		return false;
	endif;

	// match
	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_request" type="CM_DeliveryRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findYardAllocation" id="3c3e25e0-c5c9-43a5-b023-1c9393ec17b4">
        <source>findYardAllocation(_ti : CM_TrackedItem; _yardAllocations : CM_ObjectSet io; _tiCriteria : String output);
// -------------------------------------------
// Created November 2007 cnwrs1 CCMS 1547
// -------------------------------------------
// find all yard allocations that will match this conatiner

vars
	yardAllocation			: CM_YardAllocation;
	allCriteria				: CMIF_Array;
	tmpObjectSet			: ObjectSet;
	transientObj			: CMIF_YACriteriaPriority;
	cmifObject				: CMIF_Object;
	terminal				: CM_Terminal;
	isFound					: Boolean;
	iter					: Iterator;
	tmpTotal				: Real;
begin
	terminal := app.getMyTerminalDO_NOT_USE;
	
	create allCriteria transient;
	create tmpObjectSet transient;
	
	_ti.setYardAllocationCriteriaAll(allCriteria, tmpObjectSet);

	foreach cmifObject in allCriteria reversed do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		if transientObj.isDeleted then
			continue;
		endif;
		
		if _tiCriteria = null then
			_tiCriteria := transientObj.getListDisplay();
		else
			_tiCriteria := transientObj.getListDisplay() &amp; ', ' &amp; _tiCriteria;
		endif;
		
		tmpTotal := tmpTotal + transientObj.myProxy.CM_YACriteria.calculatePriority();
	endforeach;
	
	yardAllocation  := self.getYardAllocation(terminal, null, tmpTotal);
	iter := terminal.allYardAllocations.createIterator();
//	iter.startAtObject(yardAllocation);

	while iter.next(yardAllocation) do

//		if yardAllocation.priorityValue &gt; tmpTotal then
			// not found
//			break;
//		endif;
		
		if yardAllocation.isDisabled or not yardAllocation.includeInYardDisplays() then
			continue;
		endif;

		// do similar compare here
		if yardAllocation.isSimilarTo(allCriteria) then
			isFound := true;
			_yardAllocations.add(yardAllocation);
		endif;
	endwhile;
epilog
	delete iter;
	
	if allCriteria &lt;&gt; null then
		allCriteria.purge();
	endif;
	
	delete allCriteria;
	delete tmpObjectSet;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_yardAllocations" type="CM_ObjectSet" usage="io"/>
        <Parameter name="_tiCriteria" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCMIFTermWrapper" id="1030b3a6-4254-40ff-8542-acf8d14c518d">
        <source>getCMIFTermWrapper(_terminal : CM_Terminal) : CMIF_YATerminal protected;
// -------------------------------------------
// Created 16 May 2005 by cnwdvb1
// -------------------------------------------
vars

	cmifYATerminal : CMIF_YATerminal;

begin

	
	cmifYATerminal := self.getCMIFTerminal(_terminal);
	
	if cmifYATerminal = null then
		return self.initTerminal(_terminal);
	endif;

	return cmifYATerminal;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CMIF_YATerminal"/>
    </JadeMethod>
    <JadeMethod name="getCMIFTerminal" id="2b790bf2-f498-47d9-bee4-3a5325766173">
        <source>getCMIFTerminal(_terminal : CM_Terminal) : CMIF_YATerminal protected;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
vars

	cmifYATerminal : CMIF_YATerminal;

begin

	foreach cmifYATerminal in self.allCMIFTerminals do
		if cmifYATerminal.myTerminal = _terminal then
			break;
		endif;
		cmifYATerminal := null;
	endforeach;
	
	return cmifYATerminal;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CMIF_YATerminal"/>
    </JadeMethod>
    <JadeMethod name="getFoundLocation" id="ba91cbb9-07ec-4434-b986-866f229742c1">
        <source>getFoundLocation() : CM_LocationsController;
// -------------------------------------------
// Created 06 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myCurrentCMIFYAAutoPlan = null then
		return null;
	endif;
	
	return self.myCurrentCMIFYAAutoPlan.getFoundLocation;


end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getFoundLocationDesc" id="50124c44-6534-490e-8214-99980963bf5a">
        <source>getFoundLocationDesc() : String protected;
// -------------------------------------------
// Created 06 May 2005 by cnwdvb1
// -------------------------------------------
vars

	str	: String;
	lc	: CM_LocationsController;

begin

	lc := self.getFoundLocation();
	
	if lc &lt;&gt; null then
		str := lc.getFullId() &amp; ' ';
	endif;
	
	if not self.myCurrentCMIFYAAutoPlan.allFoundTis.isEmpty() then
		str := str &amp; self.myCurrentCMIFYAAutoPlan.allFoundTis.first.id; 
	endif;

	return str;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLoggingArray" id="1da1ed87-3157-4a7f-acd5-99a559ffe0e5">
        <source>getLoggingArray(_verbose : Boolean) : StringArray512;
// -------------------------------------------
// Created 12 May 2005 by cnwdvb1
// -------------------------------------------
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	invalidObject	: Boolean;
	ed	: Integer;
	currentCMIFYAAutoPlan : CMIF_YAAutoPlan;
begin
	on Exception do app.handleDeletedObject(exception, currentCMIFYAAutoPlan, invalidObject);
	
	//epr par 19478 17/4/09
	currentCMIFYAAutoPlan := self.myCurrentCMIFYAAutoPlan;
	if currentCMIFYAAutoPlan = null then
		return null;
	endif;
	// can get invalid myCurrentCMIFYAAutoPlan, trigger exception handler
	ed := currentCMIFYAAutoPlan.edition;
	if invalidObject then
		return null;
	endif;
	
	if	_verbose then
		return currentCMIFYAAutoPlan.allVerboseLogging;
	else
		return currentCMIFYAAutoPlan.allLogging;
	endif;


end;</source>
        <Parameter name="_verbose" type="Boolean"/>
        <ReturnType type="StringArray512"/>
    </JadeMethod>
    <JadeMethod name="getLoggingString" id="86b3cdec-af1b-4a06-a5f6-dfee796e3475">
        <source>getLoggingString(): String;
//18 May 2009	cnwdw1	
//
vars
	line: String;
	str: String;
begin
	foreach line in self.getLoggingArray(true) do
		str := str &amp; line &amp; CrLf;
	endforeach;
	return str;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyCurrentTrackedItem" id="ebf97335-b699-48c3-b61f-7fbf6d4f3e39">
