/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

