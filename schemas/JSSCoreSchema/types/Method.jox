<Class name="Method">
    <JadeMethod name="jssGetParameters" id="82afbb31-d4d7-4f2b-aeac-9e9d51921d51">
        <source>jssGetParameters():ParameterColl;
// --------------------------------------------------------------------------------
// Created:		24 April 2003 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's collection of parameters.
//
// Parameters:	None
//
// Returns:		A reference to the parameters collection.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.parameters;
end;</source>
        <ReturnType type="ParameterColl"/>
    </JadeMethod>
</Class>
