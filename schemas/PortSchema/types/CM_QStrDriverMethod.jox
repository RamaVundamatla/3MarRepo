<Class name="CM_QStrDriverMethod" id="79c1d8b1-df95-4068-8f39-c63dc65565cc">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="setComboValues" id="52dca923-9381-4ed0-b85d-cf72daa82136">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 May 2023			navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2
18 June 2024		jlizm1	TFS 63908 Allow duplicate driver names

*/

vars
	driver			: CM_DriverDetails;
	selectStr		: String;
	storeIdx		: Integer;
	idx				: Integer;
	selectedDriver	: CM_DriverDetails;
	term 			: CM_Terminal;
	driverStr		: String;
	
begin
	_combo.clear();
	_combo.sorted := true;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	term := _passport.myTerminal;
	if term = null then
		return;
	endif;
	
	foreach driver in term.allDriversbyName discreteLock do
		driverStr := driver.name &amp; Space &amp; Hyphen &amp; Space &amp; driver.code;
		
		idx := _combo.addItem(driverStr);
		_combo.itemObject[idx] := driver;
		
		if driver.code = selectStr then
			selectedDriver := driver;
		endif;
		
	endforeach;
	
	storeIdx  := _combo.findObject(selectedDriver);
	if storeIdx &gt; 0 and storeIdx &lt;= _combo.listCount then
		_combo.listIndex := storeIdx;
	endif;
	
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="35b77cd3-fa14-4b4b-80b9-b364d9f483a9">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2023	navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2

*/

vars
	numRows,
	idx					: Integer;
	str 				: String;
	driver 				: CM_DriverDetails;
	driverStrArray		: StringArray; 
begin
	create driverStrArray transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			driver := _tbl.accessRow(idx).itemObject.CM_DriverDetails;
			driverStrArray.add(driver.name);
		endif;
	endforeach;
	
	_op.setSearchValue(driverStrArray);

epilog
	delete driverStrArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="6e39f836-1274-4fb9-9bed-9caa02e278e6">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 May 2023			navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2
18 June 2024		jlizm1	TFS 63908 Allow duplicate driver names

*/

vars
	driver : CM_DriverDetails;
begin
	if _value.isKindOf (CM_DriverDetails) then	
		if _value &lt;&gt; null then
			driver := _value.CM_DriverDetails;
			return driver.code;
		else
			return null;
		endif;
	endif;
	
	return _value.String;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="321f709f-d9ab-4906-949e-31ae589eaaec">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 May 2023			navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2
18 June 2024		jlizm1	TFS 63908 Allow duplicate driver names

*/

vars
	invalidObj 		: Boolean;
	driver			: CM_DriverDetails;
	returnVal		: String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		elseif _value.isKindOf(CM_DriverDetails) then
			driver := _value.CM_DriverDetails;
		elseif _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if driver &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, driver, invalidObj);
		returnVal := driver.code;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
