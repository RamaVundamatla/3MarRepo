    <JadeMethod name="trxDeleteEDIData" id="625e7f47-de98-46fe-bd61-1f81bae1b745">
        <updating/>
        <source>trxDeleteEDIData(_ediData : CM_EDIData io; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
// 08/08/2012	cnwcs5	par 30136 - change of signature for utl method
// 16 Aug 2016	cnwrs1	TFS 2534 Par 38135 - dead locking between edidata process and edidata deletion
vars
	terminal	: CM_Terminal;
	ediConfig	: CM_EDIConfig;
	auditConfig	: CM_AuditConfig;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// Start the transaction
	terminal := _ediData.getMyTerminal();
	if terminal &lt;&gt; null then
		ediConfig := terminal.myEdiConfig;
		if ediConfig &lt;&gt; null then
			self.exclusiveLock(ediConfig);
		endif;
	endif;
	// 36185 get deadlocks between create and delete of EDI data -  the create updates CM_EDIConfig collections and then audits, updating CM_AuditConfig collection.
	//	The delete audits, updating CM_AuditConfig collection, then deletes, updating CM_EDIConfig collections.
	// Lock both in the same sequence in the add and delete code before beginTransaction.
	//  CM_EDIConfig is for the terminal, CM_AuditConfig is for the CM_EDIData class.
	if app.myAA.getAuditConfigForClass( _ediData, _ediData.class, auditConfig) then
		if auditConfig &lt;&gt; null then
			self.exclusiveLock(auditConfig);
		endif;
	endif;
	
	beginTransaction;

	app.myUtilityDA.utlDeleteEDIData(_ediData, _passport);

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteEDIDatas" id="7dc3bdaf-82b8-40ef-82f3-04dd087d0f0d">
        <updating/>
        <source>trxDeleteEDIDatas(_ediDatas : CM_EDIDataByNumberDict; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: August 2002	By: cnwgd1
//
//Updated: July 2004	By: JC		Reason: Now multi-transactional
//--------------------------------------------------------------
// 08/08/2012	cnwcs5	par 30136 - rework to delete &gt; 1 edi data in single transaction
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 16 Aug 2016	cnwrs1	TFS 2534 Par 38135 - dead locking between edidata process and edidata deletion
// 05/02/2018	jlgdap1	TFS 36953 Create system activity history so users know what's going on with deletes
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
constants
	MAX_TRX_TIME = 1;	// par 30136 Aug 2012
	
vars
//	terminal	: CM_Terminal;
//	ediConfig	: CM_EDIConfig;
	auditConfig	: CM_AuditConfig;

	ediData			: CM_EDIData;
	gotException	: Boolean;
	nextCommitTS	: TimeStamp;
	msg				: String;
	trxCount, delCount, count		: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	on Exception do app.handleDeletedObject(exception, ediData, gotException);	// cnwdad1 11/06/2010 - PAR #22153.

	if app.isBackGroundApp then
		msg := _ediDatas.size.String &amp; ' EDI Data records to be deleted.';
		
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	else
		// if deleting using JMT (not BGP) then there could be errors
		foreach ediData in _ediDatas do
			app.myValDA.valEDIData(ediData);
		
			if gotException then
				// just carry on with next one - who cares
				gotException	:=	false;
				continue;
			endif;
		endforeach;
	
		if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
			return;
		endif;
	endif;
	
	// Start the transaction
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
//	ediData := _ediDatas.first;
//	if ediData &lt;&gt; null then
// 06 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//		terminal := ediData.getMyTerminal();
//		if terminal &lt;&gt; null then
//			ediConfig := terminal.myEdiConfig;
//			if ediConfig &lt;&gt; null then
//				self.exclusiveLock(ediConfig);
//			endif;
//		endif;
	// 36185 get deadlocks between create and delete of EDI data -  the create updates CM_EDIConfig collections and then audits, updating CM_AuditConfig collection.
	//	The delete audits, updating CM_AuditConfig collection, then deletes, updating CM_EDIConfig collections.
	// Lock both in the same sequence in the add and delete code before beginTransaction.
	//  CM_EDIConfig is for the terminal, CM_AuditConfig is for the CM_EDIData class.
	// Although this method deletes multiple CM_EDIData instances, they are have the same edi config as this method is called for a single terminal,
	//	and all have the same audit config as there is one such for all CM_EDIData sub-classes.
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
//		if app.myAA.getAuditConfigForClass(ediData.class, auditConfig) then
//			if auditConfig &lt;&gt; null then
//				self.exclusiveLock(auditConfig);
//			endif;
//		endif;
//	endif;
	beginTransaction;

	trxCount := trxCount + 1;
	// if we get a JMT error we want to be able to ignore the edi data that caused it and carry on
	// if we don't set this to true the exception handler will abort the transaction :-(	
	app.setContinueCMExceptions(true);
		
	nextCommitTS	:=	app.actualTimeServer().addSeconds (MAX_TRX_TIME);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	foreach ediData in _ediDatas do
		if app.actualTimeServer &gt; nextCommitTS then// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			// time to commit this transaction and start a new one	
			app.cmsCommitTransaction(_passport);
// 06 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//			terminal := ediData.getMyTerminal();
//			if terminal &lt;&gt; null then
//				ediConfig := terminal.myEdiConfig;
//				if ediConfig &lt;&gt; null then
//					self.exclusiveLock(ediConfig);
//				endif;
//			endif;
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
			// 36185 for the next transaction - do before getting the next commit time 
//			if app.myAA.getAuditConfigForClass(ediData.class, auditConfig) then
//				if auditConfig &lt;&gt; null then
//					self.exclusiveLock(auditConfig);
//				endif;
//			endif;
			
			nextCommitTS := app.actualTimeServer().addSeconds (MAX_TRX_TIME);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			// update number of items deleted
			delCount	:= delCount + count;
			// reset count of deletes for current transaction
			count		:= 0;
			
			beginTransaction;	
			// increment # of transactions
			trxCount 	:= trxCount + 1;
		endif;
		// exclusive lock the edi data before we delete it
		if not self.tryLock (ediData, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
			// maybe we did not get the lock or maybe the edi data is deleted already
			continue;
		endif;
		// lock this sub-object to avoid a deadlock in the
		// refresh of the screen where we access this to get the size
		// and Jade puts a lock on it.		
		if not self.tryLock (ediData.allEDITrackedItems, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
			// maybe we did not get the lock or maybe the edi data is deleted already
			continue;
		endif;
		// par 30136 - use utl method for delete - incorporates validation and auditing as well
		app.myUtilityDA.utlDeleteEDIData (ediData, _passport);
		
		if _passport.hasErrors then
			// got errors trying to process this edi data
			if app.isBackGroundApp then			
				// write entry to log and continue with next one
				msg := ediData.String &amp; ' could not be deleted ' &amp; _passport.getAllErrorsWarningsAsString;

				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				// need to clear these for next time we check the passport
				_passport.clearErrorsWarnings;
				// if the last trx was aborted then begin transaction again
				if not process.isInTransactionState then
					// the current transaction was aborted - log the number of deleted that were rolled back
					msg := count.String &amp; ' deletes were rolled back in same transaction.';
					
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053

					beginTransaction;
					// don't increase of transactions
					// reset running count of deletes for current transaction
					count := 0;
				endif;
				// carry on - there will be others to deleted
				continue;
			else
				// bail out on first error
				break;
			endif;
		endif;
		// update running count of deletes for this transaction
		count := count + 1;
	endforeach;
	
	// update number of items deleted
	delCount := delCount + count;
	
	if _passport.noErrors() and (not process.isInTransactionState()) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
	
	if app.isBackGroundApp then
		msg := 'A total of ' &amp; delCount.String &amp; ' edi data records deleted in ' &amp; trxCount.String &amp; ' transactions.';
		
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.createActivityHistory(ActivityHistoryGeneralSys, _passport.myTerminal, null, msg, false, false);	// TFS 36953
	endif;
end;</source>
        <Parameter name="_ediDatas" type="CM_EDIDataByNumberDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
