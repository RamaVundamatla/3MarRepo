begin
	self.myOwnershipChange := self.tblData.accessRow(table.row).itemObject.CM_OwnershipChange;
	
	//30/11/2023	navkc1 ChangeRequest 58254 Task 61099
	self.btnApprove.enabled := app.myCurrentUserCan(self.getMyTerminal(), PmInvOwnershipChangeApprove);
	self.btnRemove.enabled := app.myCurrentUserCan(self.getMyTerminal(), PmInvOwnershipChangeRemove);
	
	if self.myOwnershipChange &lt;&gt; null then
		if self.myOwnershipChange.isApproved() then // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
