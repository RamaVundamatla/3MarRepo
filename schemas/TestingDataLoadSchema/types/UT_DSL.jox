    <JadeMethod name="moveQueued" id="b36a1d6b-7bd7-4af0-b575-b366d9e6ba0c">
        <source>moveQueued(_ti: CM_TrackedItem; _destination: Any);
//02 September 2008	cnwdw1	
// 02/08/2011	cnwmh5	Change so isForced can be passed via opts, change to use assertNoTrxErrorsOrWarnings
vars
	moveController	: CMIF_MoveController;
	dest: CM_LocationsController;
begin
	if _destination.isKindOf(CM_LocationsController) then
		dest := _destination.CM_LocationsController;
	elseif _destination.isKindOf(CM_TerminalArea) then
		dest := _destination.CM_TerminalArea.getLocationsController();
	endif;
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(dest);
	moveController.setMoveMode(QUEUE_MODE);
	if self.opts.includesKey("IsForcedMove") then					// 02/08/2011 cnwmh5
		moveController.isForcedMove := self.opts.bool("IsForcedMove");
	else
		moveController.isForcedMove := true;
	endif;
	
	if self.opts.includesKey("TotalQuantity") then			
		moveController.setQuantity(self.opts.int("TotalQuantity"));
	endif;
	
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();								// 02/08/2011 cnwmh5 

epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_destination" type="Any"/>
    </JadeMethod>
    <JadeMethod name="moveQueuedCargo" id="7cbc5c61-cc24-440d-be7e-3e89eaa16533">
        <source>moveQueuedCargo( _wle : CM_WorkListEntry );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	cnwndl1	Initial creation
02/08/2011	cnwmh5	Change so isForced can be passed via opts, change to use assertNoTrxErrorsOrWarnings
*/

vars
	moveController	: CMIF_MoveController;
	ti: CM_TrackedItem;
	dest: CM_LocationsController;
	destination: Any;
begin
	self.assertNotNull(_wle);
	
	ti := _wle.myTrackedItem;
	self.assertNotNull(ti);
	
	destination := ti.myPrimaryQueuedLocation;
	self.assertNotNull(destination);

	if destination.isKindOf(CM_LocationsController) then
		dest := destination.CM_LocationsController;
	elseif destination.isKindOf(CM_TerminalArea) then
		dest := destination.CM_TerminalArea.getLocationsController();
	endif;
	create moveController transient;
	moveController.setMyTrackedItem(ti);
	moveController.setMyToPrimaryLocation(dest);
	moveController.setMoveMode(REAL_MODE);
	if self.opts.includesKey("IsForcedMove") then					// 02/08/2011 cnwmh5
		moveController.isForcedMove := self.opts.bool("IsForcedMove");
	endif;
	moveController.setMyWorkListEntry(_wle);
	
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();								// 02/08/2011 cnwmh5 
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="moveRTTask" id="97352efe-8515-49f0-90e3-10f3948df129">
        <source>moveRTTask(_task: CM_RTQueueEntry input; _queue: CM_RadioTelemetryQueue);
//22 October 2009	cnwdw1	
//
vars

begin
	app.myTrxUA.trxUpdateQueueEntryPosition(_task, _queue, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
end;</source>
        <Parameter name="_task" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="moveToGroundUsingHH" id="b87d11b6-2eb7-4ae7-a3fb-5ddf9c1ea6a4">
        <source>moveToGroundUsingHH(_ti : CM_TrackedItem io; _voyageJob : CM_VoyageJob; _crane : CM_Crane);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwmh5	Initial creation

*/

vars

	lanes			: CM_LCArray;

begin

	create lanes transient;
	_crane.getLanes(lanes);
	
	app.myTrxUA.trxLanderDischargeToGround(GroundComplete, _ti, lanes.first, _voyageJob, _ti.allWorklistEntries.first, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.checkTIForTxnOfType(_ti, TRANS_TYPE_REC_SHIP);		// 16/08/2012 cnwmh5
	self.checkTIForTxnOfType(_ti, TRANS_TYPE_WHARFAGE);

epilog
	
	delete lanes;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_crane" type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="moveToShipUsingHatchman" id="b5763900-d123-418c-b6b4-e458bf9f7f36">
        <source>moveToShipUsingHatchman(_ti: CM_TrackedItem; _job: CM_VoyageJob input; _slot: CM_SlotController);
//27 August 2010	cnwdw1	
//
vars
	tis: CM_TIArray;
	slots: CM_LCArray;
begin
	create tis transient;
	tis.add(_ti);
	create slots transient;
	slots.add(_slot);
	app.myTrxUA.trxMoveTrackedItemsToShip(tis, _job, slots, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIForTxnOfType(_ti, TRANS_TYPE_REL_SHIP);		// 16/08/2012 cnwmh5
	self.checkTIForTxnOfType(_ti, TRANS_TYPE_WHARFAGE);
epilog
	delete tis;
	delete slots;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_slot" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="moveVehicleToLane" id="c653479b-c46f-4755-bfe7-355def90bbf2">
        <source>moveVehicleToLane(_vehicle: CM_Vehicle input; _gateArea: CM_GateArea; _lane: Integer);
//17 August 2009	cnwdw1	
// Move the vehicle to the lane in the gate area. If the lane is 0, then move to the in transit location
vars
	lane : CM_YardController;
begin
	lane := getGateLane(_gateArea, _lane);
	app.myTrxUA.trxMoveVehicle(_vehicle, lane, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <Parameter name="_gateArea" type="CM_GateArea"/>
        <Parameter name="_lane" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveVehicleToYard" id="bec2354b-a499-46c7-a682-4e5f0139fc52">
        <source>moveVehicleToYard(_vehicle: CM_Vehicle input);
//17 August 2009	cnwdw1	
//
vars
	location: CM_YardController;
begin
	if _vehicle.getCurrentVisit.getGateIn &lt;&gt; null then
		location := _vehicle.getCurrentVisit.getGateIn.getDefaultYardLocation_IN (_vehicle); 	//getDefaultYardLane;
	else		
		location := getTerminal.myRoadJobSheet.myInTerminalUnknownLC;
	endif;
	app.myTrxUA.trxMoveVehicle(_vehicle, location, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
    </JadeMethod>
    <JadeMethod name="moveWLE" id="03fabb7d-80a0-47b3-b758-2c2531c841b8">
        <source>moveWLE(_wle :CM_WorkListEntry);
/*
Date		Who		Reason
01 May 2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
*/
vars
	wleArray,
	wlesWithWarnings	: CM_WLEArray;
begin
	create wleArray transient;
	create wlesWithWarnings transient;
	wleArray.add(_wle);

	app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, REAL_MODE, false,  null, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete wleArray;
	delete wlesWithWarnings;
end;
</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="ndlDeleteTerminalNotComplete" id="0113028c-3cf2-4ff9-802b-6ef00f2180d5">
        <source>ndlDeleteTerminalNotComplete();
/*

Purpose:			

Parameters:			**************THIS IS WORK IN PROGRESS****************

Return Value:		

Date		Who		Reason
16 January 2013	cnwndl1	Initial creation

*/

vars

	bgpDirCont : BGP_DirectoryController;

	term : CM_Terminal;
	voyage : CM_Voyage;
	yardAllocation : CM_YardAllocation;
	yaTemplate : CM_YATemplate;
	yaOverstowRule : CM_YAOverstowRule;
	mediator : CM_RTConnectMediator;
	batNum : CM_BatNumber;
	bol : CM_BOL;
	bulkRelease : CM_BulkRelease;
	cargoCheck : CM_CargoCheck;
	dataDumpDef : CM_DataDumpExtractDef;
	driverDetail : CM_DriverDetails;
	gateEntity : CMGTE_Entity;
	auditObj : CM_AuditObject;
	gate : CM_Gate;
	interTermMove : CM_InterTerminalMove;
	interTermTarget : CM_InterTermTargetTermInfo;
	activityHist : CM_ActivityHistory;
	kpi : CM_KPI;
	keySeries : CM_KeySeries;
	layoutGraphic : CM_Graphic;
	ti : CM_TrackedItem;
	pinObjDefEmail : CM_ObjectEmail;
	segRule : CM_SegregationRule;
	segCondYard : CM_SegregationCondition;
	stateObject : CM_StateObject;
	systemAlert : CM_SystemAlert;
	queue : CM_RadioTelemetryQueue;
	vessTerm : CM_VesselTerminalData;
	vvr : CM_VehicleVisitRecord;
	vehicle : CM_Vehicle;
	train : CM_Train;
	//termScenario : CM_TerminalScenario; // jlgka1 TFS 45614 
	termAreaView : CM_TerminalAreaView;
	termArea : CM_TerminalAreaMaster;
	bank : CM_Bank;
	operTerm : CM_OperatorTerminal;
	userTerm : CM_UserTerminal;
	termAreaGrp : CM_TerminalAreaGroup;
	machine : CM_Machine;
	bgpListenCont : BGP_RFIDListenController;
	bgpRequest : BGP_Request;
	bgpSpecificReportRequest : BGP_SpecificReportRequest;
	bgpTCPClient : BGP_TCPClient;
	actHistory : CM_ActivityHistory;
	attributeArea : CM_AttributeArea;
	autoTask : CM_AutoTask;
	objArray : ObjectArray;
	obj : Object;
	iter : Iterator;
	discrepancy : CM_Discrepancy;
	dutyDocTerminalRoot : CM_DutyDocTerminalRoot;
	ediBOLOutLogTI : CM_EDIBOLOutLogTI;
	ediDataBOLOutLog : CM_EDIDataBOLOutLog;
	formConfigForm : CM_FormConfigForm;
	futureMove : CM_FutureMove;
	invoice : CM_Invoice;
	objUpgraderCAMSTrx : CM_ObjectUpgraderCAMSTrx;
	job : CM_Job;
	packageSailing : CM_PackageSailing;
	rtQueueArbiter : CM_RTQueueArbiter;
	remoteDataManager : CM_RemoteDataManager;
	terminalRef : CM_Terminal;
	terminalTIsByBR : CM_TerminalTIsByBR;
	testDataRTDevice : CM_TestDataRTDevice;
	stockOrderHeaderGeneric : CM_StockOrderHeaderGeneric;
	xmlSession : CM_XMLSession;
	yaConfig : CM_YAConfig;
	yardRequest : CM_YardRequest;
	harbour : HMS_Harbour;
	booking : CM_BookingRef;
	boom : CM_Boom;
	ccTerminal : CM_ConsigneeConsignorTerminal;
	hookLink : CM_HookLink;
	drTerm : CM_DebtorTerminal;
	txn : CM_TITransaction;
	evtxn : CM_EventTransaction;
	faultResponse : CM_FaultResponse;
	fault : CM_Fault;
	hmstxn : HMS_Transaction;
	interDef : CM_InterfaceDefinition;
	rfidReader : CM_RFIDTagReader;
	rfid : CM_RFIDTag;
	rtqMulti : CM_RTQueueMultiRule;
	machTypeConfig : CM_RTTermMachTypeConfig;
	receivalDef : CM_ReceivalCutoffTermDef;
	shift : CM_Shift;
	snap : CM_SnapshotData;
	stopTemp : CM_StopTableTemplate;
	workOrder : CM_WorkOrder;
	workPoint : CM_WorkPoint;
	camGrp : CM_CamGroup;
	camPro : CM_CamProtocol;
	calendar : CM_Calendar;
	wagon : CM_Wagon;
	discrepancyArray : CM_DiscrepancyArray;
	region : HMS_HarbourRegion;
	movePath : HMS_MovementPath;
	rtqMultiMast : CM_RTQueueMultiRuleTAMaster;
	shiftStd : CM_ShiftStd;
	wharf : HMS_Wharf;
	termName : String;
	defVoyage : CM_Voyage;
	bolOutHeader : CM_BOLOutHeader;
	bulkTITransactionAudit : CM_BulkTITransactionAudit;
	delay : CM_Delay;
	delayColl : CM_DelayByStartDTDict;
	ediParty : CM_EDIParty;
	eventRequestNotification : CM_EventRequestNotification;
	eventRequestStops : CM_EventRequestStops;
	hmsSavedConflictReport : HMS_SavedConflictReport;
	interTerminalConfig : CM_InterTerminalConfig;
	jobPriority : CM_JobPriority;
	kiosk : CM_Kiosk;
	logCheckScaleHdr : CM_LogCheckScaleHdr;
	logScalingHdr : CM_LogScalingHdr;
	pinNo : CM_PinNo;
	emptyTis : CM_TISet;
	sOHFixupHdr : CM_SOHFixupHdr;
	stockOrderHeader : CM_StockOrderHeader;
	subTerminal : CM_SubTerminal;
	terminologyHdr : CM_TerminologyHdr;
	timeSlot : CM_TimeSlot;
	timeSlotStd : CM_TimeSlotStd;
	toDoTemplate : CM_ToDoTemplate;
	voyagePlanningCode : CM_VoyagePlanningCode;
	logDocketData : CM_LogDocketData;
	moveMap : CM_MoveMap;
	mTThreshold : CM_MTThreshold;
	fromUnitTestMethod : Boolean;
	hookCode : CM_HookCode;
	cmqfFilterRpts : CMQF_FilterReports;							// 23/05/2016
	
begin

	fromUnitTestMethod := self.opts.bool("FromUnitTestMethod");

	if not fromUnitTestMethod then 
		if not app.dbPath.toUpper.pos("CNWDMAST",1) &gt; 0 then
			// to prevent accidental use in DMAST until its going properly
			return;
		endif;
	endif;
	
	process.isNDLref;

	app.isGarbageCollectionProcess := true;
		
	//term := '2351.397'.asOid.CM_Terminal;	//Terminal BLAH
	
	if self.opts.includesKey("TerminalToDelete") then
		term := app.myRoot.allTerminals[self.opts.str("TerminalToDelete")];
	endif;
	
	if term = null and not fromUnitTestMethod then
		app.msgBox(termName &amp; "No terminal selected.", "Bugger", MsgBox_OK_Only);
	endif;
	
	if term = null then
		return;
	endif;
	
	app.myPassport.setMyTerminal(term); 
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", term.code);
	
	/*
	Collections to consider
	
	***No inverse
	allRTAllocationCriteriaTypes
	allTerminalsForRelease
	allTerminalsForVoyageInland
	allVoyagesNew
	chilledTIsOffPower
	consigneePriorities
	currentRTSessionsRunning
	discrepancies
	keySeries
	selectionMacros
	
	***Peer-to-Peer 
	
	allBOLOutUnmatched
	allCalendarDates
	allCargoBOLTypes
	allDataDumpExtractDefs
	allDriversBySecondaryCode
	allDriversbyName
	allGateEntityByDateTranNum
	allGateEntityByTranNumDate
	allHarbourRegions
	allLogBOLsUnmatched
	allStkOrdByProcessFulfillStat
	allUnscaledLogsByIdCargoType

	***Child collections - that should take care of themselves!!
	allBOLOutHeadersUnmatched
	allBOLTermsByTypeNum
	allBOLTermsByTypeOpNum
	allBOLsReleasedByTypeNumberDT
	allBOLsReleasedByTypeStatDTNum
	allCustomsMessByDispCodeDTDup
	allCustomsMessbyDTDispCodeDup
	allDebtorTerminals
	allDelays
	allDeletedTIsByCargoTypeId
	allDeletedTIsByCargoTypeIdRev
	allDeletedTIsByIdCargoType
	allDeletedTIsByIdCargoTypeRev
	allEventRequestNotifyByCargoID
	allEventRequestStopsByCargoID
	allEventRequestsNotify
	allEventRequestsStops
	allOperatorTerminals
	allRTQueueMultiRuleTAMasters
	allStateObjects
	allTbaTIsByCargoTypeId
	allTbaTIsByCargoTypeIdRev
	allTbaTIsByIdCargoType
	allTbaTIsByIdCargoTypeRev
	allVoyageStatistics
	allVoyagesArchived
	allVoyagesByArrivalDTCode
	allVoyagesByCode
	allVoyagesByDepartDTCode
	allVoyagesByInwardCode
	allVoyagesByVesselCodeArrivDT
	allVoyagesSet
	
	*/
	
	//Lets start by deleting all known voyages.
	/*
	this should clear out
	allVoyagesArchived
	allVoyagesByArrivalDTCode
	allVoyagesByCode
	allVoyagesByDepartDTCode
	allVoyagesByInwardCode
	allVoyagesByVesselCodeArrivDT
	allVoyagesSet 
	*/
	
	//kill off all the stops being generated.
	//allStopTableTemplates
	foreach stopTemp in term.allStopTableTemplates do
		beginTransaction;
		delete stopTemp;
		commitTransaction;
	endforeach;
	
	defVoyage := term.getConfig(DefVoyage).CM_Voyage;
	
/*	if defVoyage = null then
		app.msgBox(termName &amp; "Terminal needsd a default voyage before it can be deleted.", "Bugger",MsgBox_OK_Only);
		return;
	endif;*/
	
	foreach voyage in term.allVoyagesArchived do
		if defVoyage &lt;&gt; null and voyage = defVoyage then
			continue;
		endif;
		self.deleteVoyage( voyage.code );
	endforeach;
	foreach voyage in term.allVoyagesByCode do
		if defVoyage &lt;&gt; null and voyage = defVoyage then
			continue;
		endif;
		self.deleteVoyage( voyage.code );
	endforeach;
	
	beginTransaction;
	term.setConfig(DefVoyage,null);
	commitTransaction;
	
	if defVoyage &lt;&gt; null then
		self.deleteVoyage(defVoyage.code);
	endif;
	
	//Now Yard Allocations
	/*
	allYardAllocations
	allYardAllocatonsByCode
	
	allYAPriorities
	allYATemplates
	
	allYAOverstowRules
	*/
	
	foreach yardAllocation in term.allYardAllocatonsByCode do
		self.deleteYA( yardAllocation.code );
	endforeach;
	
	foreach yaTemplate in term.allYATemplates do
		self.deleteYATemplate( yaTemplate.code );
	endforeach;
	
	foreach yaOverstowRule in term.allYAOverstowRules do
		app.myTrxDA.trxDeleteOverstowRule(yaOverstowRule, app.myPassport);
	endforeach;
	
	self.deleteYAPriorities();
	
	yaConfig := term.myYAConfig;
	if yaConfig &lt;&gt; null then
		app.myTrxDA.trxDeleteHookCode(yaConfig.myYAOverstowHookCode, app.myPassport);     // 13/04/2016 cnwmh5
		self.assertNoTrxErrorsOrWarnings();
		///beginTransaction;
		///delete yaConfig;
		///commitTransaction;
		app.myTrxDA.trxDeleteYAConfig(yaConfig, app.myPassport);						// 15/09/2016 cnwmh5
		self.assertNoTrxErrorsOrWarnings();
	endif;

	
	//allActiveMediators
	foreach mediator in term.allActiveMediators do
		beginTransaction;
		delete mediator;
		commitTransaction;
	endforeach;
	
	//allAllowedReleaseAvailGrades
	//allAllowedReleaseToDoTasks
	beginTransaction;
	term.allAllowedReleaseAvailGrades.clear();
	term.allAllowedReleaseToDoTasks.clear();
	commitTransaction;
	
	//allBatNumbersInUse
	foreach batNum in term.allBatNumbersInUse do
		beginTransaction;
		delete batNum;
		commitTransaction;
	endforeach;
	beginTransaction;
	term.batNumbers.clear();
	commitTransaction;
	
	//allBOLsReceivedByDTType
	//allBOLsReceivedByTypeNumberDT
	foreach bol in term.allBOLsReceivedByDTType  do
		self.deleteBOL(null,bol);
	endforeach;
	
	//allBOLOutHeadersUnmatched
	foreach bolOutHeader in term.allBOLOutHeadersUnmatched do
		beginTransaction;
		delete bolOutHeader;
		commitTransaction;
	endforeach;
	
	//allBulkReleaseByTypeByStByCd
	//allBulkReleasesByCodeDate
	//allBulkReleasesByDelRelNo
	foreach bulkRelease in term.allBulkReleasesByCodeDate  do
		self.deleteReleaseRequest( bulkRelease.code );
	endforeach;
	
	//allCargoChecks
	foreach cargoCheck in term.allCargoChecks  do
		beginTransaction;
		delete cargoCheck;
		commitTransaction;
	endforeach;
	
	//allDataDumpExtractDefs
	foreach dataDumpDef in term.allDataDumpExtractDefs  do
		beginTransaction;
		delete dataDumpDef;
		commitTransaction;
	endforeach;
	
	//allDriversByCode
	foreach driverDetail in term.allDriversByCode  do
		self.deleteDriverDetails( driverDetail.code );
	endforeach;
	
	//allActivityHistory
	foreach activityHist in term.allActivityHistory do
		beginTransaction;
		delete activityHist;
		commitTransaction;
	endforeach;
	
	
	//allGateEntityByDateTranNum
	//allGateEntityByTranNumDate
	foreach gateEntity in term.allGateEntityByDateTranNum do
		beginTransaction;
		delete gateEntity;
		commitTransaction;
	endforeach;
	
	
	
	//allInterTerminalMovesIn
	foreach interTermMove in term.allInterTerminalMovesIn do
		beginTransaction;
		delete interTermMove;
		commitTransaction;
	endforeach;
	
	//allInterTerminalMovesOut
	foreach interTermMove in term.allInterTerminalMovesOut do
		beginTransaction;
		delete interTermMove;
		commitTransaction;
	endforeach;
	
	
	//allInterTerminalTargetTermInfo	
	foreach interTermTarget in term.allInterTerminalTargetTermInfo do
		beginTransaction;
		delete interTermTarget;
		commitTransaction;
	endforeach;
	
	
	//allGates
	foreach gate in term.allGates do
		self.deleteGate(gate);
	endforeach;
	
	//allKPICargo
	foreach kpi in term.allKPICargo do
		beginTransaction;
		delete kpi;
		commitTransaction;
	endforeach;

	//machines
	foreach machine in term.machines do
		self.deleteMachine( machine.id);
	endforeach;
	
	//allKeySeriesByCode
	foreach keySeries in term.allKeySeriesByCode do
		beginTransaction;
		delete keySeries;
		commitTransaction;
	endforeach;
	
	//allPINObjectEmailDefaults
	foreach pinObjDefEmail in term.allPINObjectEmailDefaults do
		beginTransaction;
		delete pinObjDefEmail;
		commitTransaction;
	endforeach;
	
	//allLayoutGraphics
	beginTransaction;
	term.allLayoutGraphics.purge();
	commitTransaction;
	
	
	//allOffsiteTIsByCargoTypeId
	//allOffsiteTIsByCargoTypeIdRev
	//allOffsiteTIsByIdCargoType
	//allOffsiteTIsByIdCargoTypeRev
	foreach ti in term.allOffsiteTIsByCargoTypeId do
		self.deleteTrackedItem(ti,false);
	endforeach;
	
	
	//allNotifiedTIsByCargoTypeId
	//allNotifiedTIsByCargoTypeIdRev
	//allNotifiedTIsByIdCargoType
	//allNotifiedTIsByIdCargoTypeRev
	foreach ti in term.allNotifiedTIsByCargoTypeId do
		self.deleteTrackedItem(ti,false);
	endforeach;
	
	
	//allOnsiteTIsByBookingRef
	//allOnsiteTIsByCargoTypeId
	//allOnsiteTIsByCargoTypeIdRev
	//allOnsiteTIsByIdCargoType
	//allOnsiteTIsByIdCargoTypeRev
	//allOnsiteTIsByIntendedRelMode
	foreach ti in term.allOnsiteTIsByCargoTypeId do
		self.deleteTrackedItem(ti,false);
	endforeach;
	
	
	//allSegRulesByEntity1Entity2
	//allSegRulesByTypeCode
	//allSegregationRules
	foreach segRule in term.allSegregationRules do
		beginTransaction;
		delete segRule;
		commitTransaction;
	endforeach;

	//allSegregationConditions
	foreach segCondYard in term.allSegregationConditions do
		beginTransaction;
		delete segCondYard;
		commitTransaction;
	endforeach;
	
	//allSystemAlertsByDateTime
	//allSystemAlertsBySeverityDate
	foreach systemAlert in term.allSystemAlertsByDateTime do
		beginTransaction;
		delete systemAlert;
		commitTransaction;
	endforeach;
	
	//allCargoBOLTypes
	beginTransaction;
	term.allCargoBOLTypes.clear();
	commitTransaction;
	
	//queues
	foreach queue in term.queues do
		self.deleteQueue( queue.id );
	endforeach;
	
		
	//allVesselTerminals
	foreach vessTerm in term.allVesselTerminals do
		beginTransaction;
		delete vessTerm;
		commitTransaction;
	endforeach;
	
	//allVehicleVisits
	//allVehicleVisitsByNumDT
	foreach vvr in term.allVehicleVisits do
		self.deleteVVR( vvr );
	endforeach;
	
	//vehicles
	foreach vehicle in term.vehicles do
		self.deleteVehicle( vehicle.regNumber );
	endforeach;
	
	//allWagons
	foreach wagon in term.allWagons do
		self.deleteWagonAndAssociatedObjs(wagon);
	endforeach;
	
	
	//allWagonsDeparted
	foreach wagon in term.allWagonsDeparted do
		self.deleteWagonAndAssociatedObjs(wagon);
	endforeach;	
	
	//get the null train first
	train := term.getNullTrain;
	if train &lt;&gt; null then
		beginTransaction;
		delete train;
		commitTransaction;
	endif;

	
	//allTrainsOnTerminal
	foreach train in term.allTrainsOnTerminal do
		self.deleteTrain( null, train );
	endforeach;

	//allTrainsArrival
	foreach train in term.allTrainsArrival do
		self.deleteTrain( null, train );
	endforeach;
	
	//allTrainsDeparted
	//allTrainsDepartedReversed
	foreach train in term.allTrainsDeparted do
		self.deleteTrain( null, train );
	endforeach;
	
	//allDepartedTrainsByArrivalDT
	foreach train in term.allDepartedTrainsByArrivalDT do
		self.deleteTrain( null, train );
	endforeach;
	
	//allTerminalScenarios
	/*foreach termScenario in term.allTerminalScenarios do
		beginTransaction;
		delete termScenario;
		commitTransaction;
	endforeach;*/
	
	//allTerminalAreaViews
	foreach termAreaView in term.allTerminalAreaViews do
		beginTransaction;
		delete termAreaView;
		commitTransaction;
	endforeach;
	
	//allTerminalAreaGroups
	//allTerminalAreaMastersById
	//allTerminalAreas
	//allTerminalAreasByTypeId
	
	beginTransaction;
	term.setConfig(DefRailOpsArea,null);
	commitTransaction;
	
	foreach termArea in term.allTerminalAreas where termArea.isKindOf(CM_SubBlockStack) do
		self.deleteTerminalArea(termArea.id);
	endforeach;
	foreach termArea in term.allTerminalAreas do
		self.deleteTerminalArea(termArea.id);
	endforeach;
	foreach termAreaGrp in term.allTerminalAreaGroups do
		beginTransaction;
		foreach rtqMultiMast in termAreaGrp.allRTQueueMultiRulesFrom do
			delete rtqMultiMast;
		endforeach;
		foreach rtqMultiMast in termAreaGrp.allRTQueueMultiRulesTo do
			delete rtqMultiMast;
		endforeach;
		delete termAreaGrp;
		commitTransaction;
	endforeach;
	
	//companies
	foreach bank in term.companies do
		self.deleteBank( bank );
	endforeach;
	
	//allOperatorTerminals
	foreach operTerm in term.allOperatorTerminals do
		beginTransaction;
