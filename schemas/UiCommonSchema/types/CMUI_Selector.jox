    <JadeMethod name="clearSheets" id="94db9387-a648-4a54-9b66-6c42f553d5b8">
        <source>clearSheets() protected;
// ---------------------------------------------------------------------------
// Created:     23 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numSheets,
	idx					: Integer;
	tbl					: CM_DataTable;
	tblSheet			: JadeTableSheet;
	criteriaHolder		: CM_QueryCriteriaLineHolder;
begin
	tbl := self.tblCriteria;
	numSheets := tbl.sheets;
	foreach idx in numSheets to 1 step -1 do
		tblSheet := tbl.accessSheet(idx);
		delete tblSheet.itemObject;
		if idx &gt; 1 then	//cmwrs1 aug 2005 canned delete all sheets in Jade 6.1
			delete tblSheet;
		endif;
	endforeach;
	
	tbl.clear();
	tbl.rows := tbl.fixedRows;
	
	tblSheet := tbl.accessSheet(1);
	tblSheet.columns := 1;
	tblSheet.rows := 0;
	tblSheet.caption := self.SHEET_ONE_NAME;
	create criteriaHolder transient;
	tblSheet.itemObject := criteriaHolder;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clickArgShowAllSelected" id="6c51461e-f0b1-4ce6-ab1f-7437e961b130">
        <source>clickArgShowAllSelected( optionbutton: OptionButton input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars

	tbl : CMUI_ListTable;
	checkBoxColumn : Integer;
	rowIndex : Integer;

begin

	tbl:= self.tblArgument;
	checkBoxColumn := tbl.getChkBoxColumn;

	if optionbutton = self.optAll and self.optAll.value
	or optionbutton = self.optSelected and not self.optSelected.value
	then
		//show all
		foreach rowIndex in 1 to tbl.rows do
			tbl.accessRow( rowIndex ).visible := true;
		endforeach;
	else
		//show only selected
		foreach rowIndex in 1 to tbl.rows do
			tbl.accessRow( rowIndex ).visible := tbl.accessCell( rowIndex, checkBoxColumn ).text = '1';
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
