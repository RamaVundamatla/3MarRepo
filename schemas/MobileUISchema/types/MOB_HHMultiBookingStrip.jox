    <JadeMethod name="setChildTopSheetByCaption" id="325e201d-8ecd-477a-a473-10852b49ab0a">
        <source>setChildTopSheetByCaption( _previousCaption : String ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2016	cnwndl1	Initial creation

*/

vars

	sheet : MOB_Sheet;
	size : Integer;
	index : Integer;

begin

	if self.shtExChild.caption = _previousCaption then
		self.fldChildren.topSheet := self.shtExChild;
	else
		size := self.allSelectedConts.size;
		if size = 0 then
			sheet := self.shtChildTemp.getControl(1).MOB_Sheet;
		else
			if _previousCaption &lt;&gt; null then
				foreach index in 1 to size do
					sheet := self.shtChildTemp.getControl(index).MOB_Sheet;
					if sheet &lt;&gt; null then
						if sheet.caption = _previousCaption then
							break;
						endif;
						sheet := null;
					endif;
				endforeach;
			endif;
		endif;
		
		if sheet = null then
			sheet := self.shtChildTemp.getControl( 1 ).MOB_Sheet;
		endif;
		
		if sheet &lt;&gt; null then
			self.fldChildren.topSheet := sheet;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_previousCaption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="ea65f3ff-85e6-4a61-ae19-8b84a2bd9bb1">
        <updating/>
        <source>setupControls()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

	selectedTi : CM_TrackedItem;
	btn : MOB_Button;
	index : Integer;
	previousCaption : String;

begin

	self.populateContainers();

	self.doResizeControls(true);
	
	self.txtContFind.text := self.lblContFind.caption.toUpper;	//02 Dec 2016	NDL	TFS 3034/2549
	
	self.populateCmbSortBy();
	self.cmbSortBy.listIndex := 1;
	self.populateLblBookings();
	
	//01 Dec 2016	NDL TFS 3034 / 2549 
	if self.showAvailableSheet then
		self.fldContainers.topSheet := self.shtContAvail;
	endif;
	
	//if we are returning from Doc Actions or Pack Complete or refreshing becuase of a notification
	//- reset the screen to how it was (as much as we can) 
	if not self.myMobileGenericAgent.allConfirmedTis.isEmpty then
	
		self.myMobileGenericAgent.setAllReserveDetails( null );
		self.myMobileGenericAgent.setAllBookingRefItems( null );
		self.myMobileGenericAgent.setMyNextTiToAction( null );
		
		self.chkByCont.value := self.myMobileGenericAgent.inward;
		self.myMobileGenericAgent.setInward( false );
		
		self.cmbSortBy.listIndex := self.myMobileGenericAgent.decimalField1.Integer;
		self.myMobileGenericAgent.setDecimalField1( 0 );
		
		if availButtonCount &gt; 0 then
			foreach selectedTi in self.myMobileGenericAgent.allConfirmedTis do
				index := 0;
				foreach index in 1 to availButtonCount do
					btn := self.btnAvailTemp.getControl( index ).MOB_Button;
					if btn &lt;&gt; null and btn.userObject = selectedTi then
						self.allSelectedConts.add( selectedTi );
						break;
					endif;
				endforeach;
			endforeach;
		endif;
		self.myMobileGenericAgent.allConfirmedTis.clear();
		
		self.populateContainers();
		self.doResizeControls(false);	//03 Mar 2017	NDL	TFS 3299
		
		//01 Dec 2016	NDL	TFS 3034 / 2549 
		if self.showAvailableSheet then
			if not self.allSelectedConts.isEmpty then
				self.fldContainers.topSheet := self.shtContSel;
			endif;
		endif;
		
		if self.myMobileGenericAgent.stringField1 &lt;&gt; null then
			previousCaption := self.myMobileGenericAgent.stringField1;	
			self.myMobileGenericAgent.setStringField1( null );
			self.setChildTopSheetByCaption( previousCaption );
		endif;
			
	endif;
	
	//19 Dec 2016	NDL	TFS 3000
	if self.fldContainers.topSheet = self.shtContSel then
		self.txtContFind.setFocus();
	endif;
		

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFldChildren" id="d20fdae3-5d08-4c2b-8ec8-ffc9e6a2602d">
        <updating/>
        <source>setupFldChildren( initialSetup : Boolean )protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

	index : Integer;
	size : Integer;
	
	clonedSheet : MOB_Sheet;
	clonedFrame : MOB_Frame;
	clonedScroll : VScroll;
	cloneMenuButton : MOB_Button;
	cloneLabel : MOB_Label;
			
	listByContainer : Boolean;
	arrayIndex : Integer;
	ti : CM_TrackedItem;
	btnCount : Integer;
	buttonIndex : Integer;
	menuButton : MOB_Button;
	
	tabIndex : Integer;
	previousCaption : String;
	changed: Boolean;

begin

	self.setupForNotifications(false, null);
	self.allNotableObjects.clear();
	self.docActsToDisplay2.clear;	//03 Mar 2017	NDL	TFS 3299
	self.btnDocActions2.visible := false;	//03 Mar 2017	NDL	TFS 3299

	tabIndex := self.localTabIndex;
	if self.fldChildren.topSheet &lt;&gt; null then
		previousCaption := self.fldChildren.topSheet.caption;
	endif;

	//clear all cloned sheets 'Packed Child' sheets
	btnCount := self.childButtonCount;
	if btnCount &gt; 0 then
		foreach buttonIndex in 1 to btnCount do
			menuButton := self.btnChildTemp.getControl( buttonIndex ).MOB_Button;
			if menuButton &lt;&gt; null then
				delete menuButton;
			endif;
		endforeach;
	endif;
	
	size := self.availButtonCount + self.selectedButtonCount;  // to allow for nulti moving done in setupControls 
	foreach index in 1 to size reversed do
	
		clonedSheet := self.shtChildTemp.getControl( index ).MOB_Sheet;
		clonedFrame := self.frmChildTemp.getControl( index ).MOB_Frame;
		clonedScroll := self.scrChildTemp.getControl( index ).VScroll;
		cloneLabel := self.lblNoChild.getControl( index ).MOB_Label;
	
		if cloneLabel &lt;&gt; null then
			delete cloneLabel;
		endif;
		
		if clonedScroll &lt;&gt; null then
			delete clonedScroll;
		endif;
		
		if clonedFrame &lt;&gt; null then
			delete clonedFrame;
		endif;
		
		if clonedSheet &lt;&gt; null then
			delete clonedSheet;
		endif;
		
	endforeach;

	
	btnCount := 0;
	childButtonCountArray.clear;
	self.childButtonCount := 0;
	self.shtChildTemp.visible := false; // this is the template one.

	if self.allSelectedConts.isEmpty then
		self.fldChildren.visible := false;
		return;
	endif;
	
	self.fldChildren.visible := true;
	
	listByContainer := self.chkByCont.value;
	if listByContainer then
		foreach ti in self.allSelectedConts discreteLock do
			arrayIndex := self.allSelectedConts.indexOf( ti );
			self.setupShtContChildren( arrayIndex, ti, tabIndex );
		endforeach;
	else
		self.setupShtContChildren( 1, null, tabIndex );
	endif;
	
	self.setupShtExChild( initialSetup, tabIndex );
	
	//03 Mar 2017	NDL	TFS 3299
	self.btnDocActions2.visible := not self.docActsToDisplay2.isEmpty;
	if self.btnDocActions2.visible then
		if self.fldChildren.top + self.fldChildren.height &gt; self.btnDocActions2.top then
			self.fldChildren.height := self.btnDocActions2.top - ( self.fldChildren.top + self.resizedMargin );
			changed := true;
		endif;
	else
		if self.fldChildren.top + self.fldChildren.height &lt; self.btnDocActions2.top then
			self.fldChildren.height := ( self.btnDocActions2.top + self.btnDocActions2.height ) - self.fldChildren.top;
			changed := true;
		endif;
	endif;
	if changed then
		self.frmExChild.height := self.shtExChild.height - self.resizedMargin;
		self.getButtonWidthSetScrollBar( self.exChildButtonCount, self.frmExChild, self.btnExChildTemp.height, self.scrExChild );
		if listByContainer then
			foreach ti in self.allSelectedConts discreteLock do
				arrayIndex := self.allSelectedConts.indexOf( ti );
				clonedFrame := self.frmChildTemp.getControl( arrayIndex ).MOB_Frame;
				clonedSheet := self.shtChildTemp.getControl( arrayIndex ).MOB_Sheet;
				clonedScroll := self.scrChildTemp.getControl( arrayIndex ).VScroll;
				btnCount := self.childButtonCountArray[arrayIndex];
				clonedFrame.height := clonedSheet.height - self.resizedMargin;
				self.getButtonWidthSetScrollBar(btnCount, clonedFrame, self.btnChildTemp.height, clonedScroll );
			endforeach;
		else
			arrayIndex := 1;
			clonedFrame := self.frmChildTemp.getControl( arrayIndex ).MOB_Frame;
			clonedSheet := self.shtChildTemp.getControl( arrayIndex ).MOB_Sheet;
			clonedScroll := self.scrChildTemp.getControl( arrayIndex ).VScroll;
			btnCount := self.childButtonCountArray[arrayIndex];
			clonedFrame.height := clonedSheet.height - self.resizedMargin;
			self.getButtonWidthSetScrollBar(btnCount, clonedFrame, self.btnChildTemp.height, clonedScroll );
		endif;
	endif;
	
		
	self.setChildTopSheetByCaption( previousCaption );
	
	self.setupForNotifications(true, null);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupFldContainers" id="3987d1d1-8ea0-4a95-af02-8e8569de4367">
        <updating/>
        <source>setupFldContainers( initialSetup : Boolean; _tabIndex : Integer io )protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

	cTop : Real;
	cWidth : Real;
	cLeft : Real;
	cHeight : Real;
	buttonHeight : Integer;
	buttonWidth : Real;
	buttonTop : Integer;
	index : Integer;
	menuButton : MOB_Button;
	stdHeight : Real;

begin

	stdHeight := self.getStdControlHeight;

	if initialSetup then
		self.shtContAvail.setAndIncrementTabIndex( _tabIndex );
//		self.shtContAvail.visible := true;
		self.frmContAvail.setAndIncrementTabIndex( _tabIndex );
		self.frmContAvail.visible := true;
		self.scrContAvail.setAndIncrementTabIndex( _tabIndex );
		self.scrContAvail.visible := true;
		self.shtContSel.setAndIncrementTabIndex( _tabIndex );
		self.shtContSel.visible := true;
		self.frmContSel.setAndIncrementTabIndex( _tabIndex );
		self.frmContSel.visible := true;
		self.scrContSel.setAndIncrementTabIndex( _tabIndex );
		self.scrContSel.visible := true;
	endif;
	
	buttonHeight := self.getScrollingButtonHeight();
	
	self.frmContAvail.move(	self.resizedMargin / 2,
							self.resizedMargin / 2,
							self.shtContAvail.width - self.resizedMargin,
							self.shtContAvail.height - self.resizedMargin
							);
							
	//01 Dec 2016	NDL	TFS 3034 / 2549 
	self.shtContAvail.visible := self.showAvailableSheet;
	
	cTop := self.resizedMargin;
	cLeft := self.resizedMargin;
	cWidth := self.shtContSel.width - stdHeight - (self.resizedMargin * 3);
	self.txtContFind.move(	cLeft, 
							cTop, 
							cWidth, 
							stdHeight);
	
	cWidth := stdHeight;
	cLeft := self.txtContFind.left + self.txtContFind.width + self.resizedMargin;
	self.btnContFind.move(	cLeft, 
							cTop, 
							cWidth, 
							stdHeight);
							
	cTop := self.txtContFind.top + self.txtContFind.height + self.resizedMargin;
	cHeight := self.frmContAvail.height - cTop;
	self.frmContSel.move(	self.frmContAvail.left, 
							cTop, 
							self.frmContAvail.width, 
							cHeight);
							
	self.lblNoContAvail.move(	self.resizedMargin,
								self.resizedMargin,
								self.frmContAvail.width - ( self.resizedMargin * 2 ),
								buttonHeight - ( self.resizedMargin * 2 )
								);
								
	self.lblNoContSel.move(	self.resizedMargin,
							self.resizedMargin,
							self.frmContSel.width - ( self.resizedMargin * 2 ),
							buttonHeight - ( self.resizedMargin * 2 )
							);
								
	if self.availButtonCount &gt; 0 then
		buttonWidth := getButtonWidthSetScrollBar( self.availButtonCount, self.frmContAvail, self.btnAvailTemp.height, self.scrContAvail );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.availButtonCount do
			menuButton := self.btnAvailTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnAvailTemp.fontSize;	
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	else
		buttonWidth := getButtonWidthSetScrollBar( self.availButtonCount, self.frmContAvail, self.btnAvailTemp.height, self.scrContAvail );
	endif;
	
	if self.selectedButtonCount &gt; 0 then
		buttonWidth := getButtonWidthSetScrollBar( self.selectedButtonCount, self.frmContSel, self.btnSelectedTemp.height, self.scrContSel );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.selectedButtonCount do
			menuButton := self.btnSelectedTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnSelectedTemp.fontSize;
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	else
		buttonWidth := getButtonWidthSetScrollBar( self.selectedButtonCount, self.frmContSel, self.btnSelectedTemp.height, self.scrContSel );
	endif;
							
epilog

end;</source>
        <access>protected</access>
        <Parameter name="initialSetup" type="Boolean"/>
        <Parameter name="_tabIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForNotifications" id="49a95188-4119-4ee0-9dc6-874375aa8dc9">
        <source>setupForNotifications( _begin : Boolean; _oneObject : Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2016	cnwndl1	Initial creation

*/

vars

	obj : Object;
	
begin

	if _begin then
	
		if _oneObject &lt;&gt; null then
		
			self.beginNotification( _oneObject, Any_System_Event, Response_Continuous, 0 );
		
		else
	
			foreach obj in self.allSelectedConts do
				self.beginNotification( obj, Any_System_Event, Response_Continuous, 0 );
			endforeach;
			foreach obj in self.allNotableObjects do
				self.beginNotification( obj, Any_System_Event, Response_Continuous, 0 );
			endforeach;
		
		endif;
	
	else
	
		if _oneObject &lt;&gt; null then
		
			self.endNotification( _oneObject, Any_System_Event );
		
		else
	
			self.endNotifications();
		
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_begin" type="Boolean"/>
        <Parameter name="_oneObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="09f90ab3-6146-4c70-ad87-773a1327cb0b">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	
	inheritMethod();
	
	//01 Dec 2016	NDL	TFS 3034 / 2549 - At the moment STW don't want to see this sheet.  If they change their mind again, make sure they pay $$$
	self.showAvailableSheet := app.isDevelopmentSystem and process.isNDLref;
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupShtContChildren" id="b11315ad-ce00-437f-ac3f-d0130916c576">
        <updating/>
        <source>setupShtContChildren( _arrayIndex : Integer; _ti : CM_TrackedItem; _tabIndex : Integer io )updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation

*/

vars

	clonedSheet : MOB_Sheet;
	clonedFrame : MOB_Frame;
	clonedScroll : VScroll;
	cloneMenuButton : MOB_Button;
	cloneLabel : MOB_Label;

	buttonHeight : Integer;
	buttonWidth : Real;
	buttonTop : Integer;
	index : Integer;
	
	ti : CM_TrackedItem;
	btnCount : Integer;
	buttonOffset : Integer;
	
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	
	dynaDict : DynaDictionary;
	obj : Object;
	sortOrder : Integer;
	firstBtnAdded : Integer;
	lastBtnAdded : Integer;
	reason : String;
	
	cargoTypeAndSubType : String;
	colourStr : String;

begin

	//The entire 'Container Children' sheet is cloned from the template version.
	//This because we optionally want one per selected container and don't know how many until run-time. 
	
	//Clone the sheet and controls and set onto the folder.
	clonedSheet := self.shtChildTemp.loadControl( _arrayIndex ).MOB_Sheet;
	clonedFrame := self.frmChildTemp.loadControl( _arrayIndex ).MOB_Frame;
	clonedScroll := self.scrChildTemp.loadControl( _arrayIndex ).VScroll;
	cloneLabel := self.lblNoChild.loadControl( _arrayIndex ).MOB_Label;

	clonedSheet.parent := self.fldChildren;
	clonedSheet.setAndIncrementTabIndex( _tabIndex );
	clonedSheet.visible := true;
	
	clonedFrame.parent := clonedSheet;
	clonedFrame.setAndIncrementTabIndex( _tabIndex );
	clonedFrame.visible := true;
	
	clonedScroll.parent := clonedFrame;
	clonedScroll.setAndIncrementTabIndex( _tabIndex );
	clonedScroll.visible := true;
	
	cloneLabel.parent := clonedSheet;
	
	buttonHeight := self.getScrollingButtonHeight();
	
	clonedFrame.move(	self.resizedMargin / 2,
						self.resizedMargin / 2,
						clonedSheet.width - self.resizedMargin,
						clonedSheet.height - self.resizedMargin
						);
												
	cloneLabel.move(	self.resizedMargin,
							self.resizedMargin,
							clonedFrame.width - ( self.resizedMargin * 2 ),
							buttonHeight - ( self.resizedMargin * 2 )
							);
	
	create dynaDict transient;
	dynaDict.setMembership( CM_TrackedItem );
	if self.cmbSortBy.listIndex &gt; 0 then
		sortOrder := self.cmbSortBy.itemData[ self.cmbSortBy.listIndex ];
	endif;
	
	if sortOrder = 1 then	//"Sort By: Cargo Id"
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	elseif sortOrder = 2 then	//"Sort By: Cargo Type / Sub Type"
		dynaDict.addMemberKey(CM_TrackedItem::cargoTypeDescr.name, false, false);
		dynaDict.addMemberKey(CM_TrackedItem::productCode.name, false, false);
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	elseif sortOrder = 3 then	//"Sort By: Cargo Group Id / Cargo Id"
		dynaDict.addMemberKey(CM_TrackedItem::myCargoGroup.name, false, false);
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	else
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	endif;
	dynaDict.endKeys(true);
	
	
	if _ti &lt;&gt; null then
		_ti.allChildren.copy( dynaDict );
		clonedSheet.caption := app.getErrorString(Child_Cargo) &amp; _ti.id;
	else
		foreach ti in self.allSelectedConts do
			ti.allChildren.copy( dynaDict );
		endforeach;
		clonedSheet.caption := app.getErrorString(Child_Cargo) &amp; app.getErrorString(All_Containers);
	endif;
	
	firstBtnAdded := self.childButtonCount + 1;
	
	if not dynaDict.isEmpty then
		foreach obj in dynaDict discreteLock do
		
			ti := obj.CM_TrackedItem;
		
			if  ti.myBookingRefItem &lt;&gt; null then
				docActions := ti.myBookingRefItem.myBookingRefItemActions;
			else
				docActions := null;
			endif;
			
			btnCount := btnCount + 1;
			self.childButtonCount := self.childButtonCount + 1;
			cloneMenuButton := self.btnChildTemp.loadControl( self.childButtonCount ).MOB_Button;
			cloneMenuButton.parent := clonedFrame;
			cloneMenuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
			
			cloneMenuButton.userObject := ti;
			
			 //23 Nov 2016	NDL	TFS 2549 - add  cargo sub type, color and carg group id.
			cargoTypeAndSubType := ti.cargoTypeDescr;
			if ti.getCargoSubTypeCode &lt;&gt; null then
				cargoTypeAndSubType := cargoTypeAndSubType &amp; "/" &amp; ti.getCargoSubTypeCode;
			endif;
			cargoTypeAndSubType := cargoTypeAndSubType &amp; " - ";
			if ti.getMyCargoGroupId &lt;&gt; null then
				cargoTypeAndSubType := cargoTypeAndSubType &amp; ti.getMyCargoGroupId &amp; " ";
			endif;
			cargoTypeAndSubType := cargoTypeAndSubType &amp; ti.id;
			colourStr := ti.getColour;
			
			if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
				cloneMenuButton.caption := cargoTypeAndSubType &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
											&amp; CrLf &amp; colourStr &amp; " " &amp; ti.myPrimaryActualLocation.getFullId;
			elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
				cloneMenuButton.caption := cargoTypeAndSubType &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
											&amp; CrLf &amp; colourStr &amp; " " &amp; ti.myPrimaryActualLocation.getFullId;
			else
				cloneMenuButton.caption := cargoTypeAndSubType &amp; CrLf &amp; colourStr &amp; " " &amp; ti.myPrimaryActualLocation.getFullId;
			endif;
			
			if docActions &lt;&gt; null then
				taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
				if taskAndStopStr &lt;&gt; null then
					cloneMenuButton.caption := cloneMenuButton.caption &amp; " " &amp; taskAndStopStr;
					self.docActsToDisplay2.addExclusive( docActions );	//03 Mar 2017	NDL	TFS 3299
				endif;
			endif;
			
			self.addHazDetailsToButton( cloneMenuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
		
			self.allNotableObjects.add(ti);
			cloneMenuButton.enabled := true;
			
			buttonOffset := buttonOffset + buttonHeight-2;
			_tabIndex := _tabIndex + 1;
			cloneMenuButton.tabIndex := _tabIndex;
			
		endforeach;
	endif;
	
	lastBtnAdded := self.childButtonCount;
	self.childButtonCountArray[_arrayIndex] := btnCount;
	
	clonedFrame.caption := null;
	cloneLabel.visible := (btnCount = 0);
								
	if btnCount &gt; 0 then
		buttonWidth := getButtonWidthSetScrollBar( btnCount, clonedFrame, self.btnChildTemp.height, clonedScroll );
		buttonTop := self.resizedMargin - 1;
		
		foreach index in firstBtnAdded to lastBtnAdded do
			cloneMenuButton := self.btnChildTemp.getControl( index ).MOB_Button;
			if cloneMenuButton &lt;&gt; null then
				cloneMenuButton.width := buttonWidth;
				cloneMenuButton.height := buttonHeight;
				cloneMenuButton.top := buttonTop;
				cloneMenuButton.fontSize := self.btnChildTemp.fontSize;	
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	else
		buttonWidth := getButtonWidthSetScrollBar( btnCount, clonedFrame, self.btnChildTemp.height, clonedScroll );
	endif;

epilog

	delete dynaDict;

end;</source>
        <access>protected</access>
        <Parameter name="_arrayIndex" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tabIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupShtExChild" id="8e64bea6-cf12-420f-9e3d-6b26b2b820ce">
        <updating/>
        <source>setupShtExChild( initialSetup : Boolean; _tabIndex : Integer io )protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation

*/

vars

	buttonHeight : Integer;
	buttonWidth : Real;
	buttonTop : Integer;
	index : Integer;
	menuButton : MOB_Button;
	
	ti : CM_TrackedItem;
	unpackedTi : CM_TrackedItem;
	tiSet : CM_TISet;
	btnCount : Integer;
	buttonOffset : Integer;
	
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	
	dynaDict : DynaDictionary;
	obj : Object;
	sortOrder : Integer;
	
	buttonIndex : Integer;
	reason : String;
	
	cargoTypeAndSubType : String;
	colourStr : String;

begin
	
	//clear any previous cloned buttons of this type
	btnCount := self.exChildButtonCount;
	if btnCount &gt; 0 then
		foreach buttonIndex in 1 to btnCount do
			menuButton := self.btnExChildTemp.getControl( buttonIndex ).MOB_Button;
			if menuButton &lt;&gt; null then
				delete menuButton;
			endif;
		endforeach;
	endif;
	
	btnCount := 0;
	self.exChildButtonCount := 0;
	
	//set up teh folder, frame, label and scroll bar
	self.shtExChild.setAndIncrementTabIndex( _tabIndex );
	self.shtExChild.visible := true;
	self.frmExChild.setAndIncrementTabIndex( _tabIndex );
	self.frmExChild.visible := true;
	self.scrExChild.setAndIncrementTabIndex( _tabIndex );
	self.scrExChild.visible := true;
	
	buttonHeight := self.getScrollingButtonHeight();
	
	self.frmExChild.move(	self.resizedMargin / 2,
							self.resizedMargin / 2,
							self.shtExChild.width - self.resizedMargin,
							self.shtExChild.height - self.resizedMargin
							);
							
							
	self.lblNoExChild.move(	self.resizedMargin,
							self.resizedMargin,
							self.frmExChild.width - ( self.resizedMargin * 2 ),
							buttonHeight - ( self.resizedMargin * 2 )
							);
	
	//Find all the cargo to siplay and put in order
	create dynaDict transient;
	dynaDict.setMembership( CM_TrackedItem );
	if self.cmbSortBy.listIndex &gt; 0 then
		sortOrder := self.cmbSortBy.itemData[ self.cmbSortBy.listIndex ];
	endif;
	
	if sortOrder = 1 then	//"Sort By: Cargo Id"
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	elseif sortOrder = 2 then	//"Sort By: Cargo Type / Sub Type"
		dynaDict.addMemberKey(CM_TrackedItem::cargoTypeDescr.name, false, false);
		dynaDict.addMemberKey(CM_TrackedItem::productCode.name, false, false);
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	elseif sortOrder = 3 then	//"Sort By: Cargo Group Id / Cargo Id"
		dynaDict.addMemberKey(CM_TrackedItem::myCargoGroup.name, false, false);
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	else
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	endif;
	dynaDict.endKeys(true);
	
	create tiSet transient;
	foreach ti in self.allSelectedConts do
		tiSet.clear();
		ti.getAllUnpackedChildren( tiSet );
		foreach unpackedTi in tiSet do
			if unpackedTi.isChild then
				continue;
			endif;
			if not dynaDict.includes(unpackedTi) then
				dynaDict.add( unpackedTi );
			endif;
		endforeach;
	endforeach;
	
	// create the buttons (clone them from the template, one per cargo item) to display
	if not dynaDict.isEmpty then
		foreach obj in dynaDict discreteLock do
		
			ti := obj.CM_TrackedItem;
			if not ti.isOnSite then
				continue;
			endif;
			if ti.hasBeenMerged then
				continue;
			endif;
		
			if  ti.myBookingRefItem &lt;&gt; null then
				docActions := ti.myBookingRefItem.myBookingRefItemActions;
			else
				docActions := null;
			endif;
			
			btnCount := btnCount + 1;
			menuButton := self.btnExChildTemp.loadControl( btnCount ).MOB_Button;
			menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
			
			menuButton.userObject := ti;
			
			 //23 Nov 2016	NDL	TFS 2549 - add  cargo sub type, color and carg group id.
			cargoTypeAndSubType := ti.cargoTypeDescr;
			if ti.getCargoSubTypeCode &lt;&gt; null then
				cargoTypeAndSubType := cargoTypeAndSubType &amp; "/" &amp; ti.getCargoSubTypeCode;
			endif;
			cargoTypeAndSubType := cargoTypeAndSubType &amp; " - ";
			if ti.getMyCargoGroupId &lt;&gt; null then
				cargoTypeAndSubType := cargoTypeAndSubType &amp; ti.getMyCargoGroupId &amp; " ";
			endif;
			cargoTypeAndSubType := cargoTypeAndSubType &amp; ti.id;
			colourStr := ti.getColour;
			
			if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
				menuButton.caption := cargoTypeAndSubType &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
											&amp; CrLf &amp; colourStr &amp; " " &amp; ti.myPrimaryActualLocation.getFullId;
			elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
				menuButton.caption := cargoTypeAndSubType &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
											&amp; CrLf &amp; colourStr &amp; " " &amp; ti.myPrimaryActualLocation.getFullId;
			else
				menuButton.caption := cargoTypeAndSubType &amp; CrLf &amp; colourStr &amp; " " &amp; ti.myPrimaryActualLocation.getFullId;
			endif;
			
			if docActions &lt;&gt; null then
				taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
				if taskAndStopStr &lt;&gt; null then
					menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
					self.docActsToDisplay2.addExclusive( docActions );	//03 Mar 2017	NDL	TFS 3299
				endif;
			endif;
			
			self.addHazDetailsToButton( menuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
		
			self.allNotableObjects.add(ti);
			menuButton.enabled := true;
			
			buttonOffset := buttonOffset + buttonHeight-2;
			_tabIndex := _tabIndex + 1;
			menuButton.tabIndex := _tabIndex;
			
		endforeach;
	endif;
	
	// set the counter on the form
	self.exChildButtonCount := btnCount;
	
	// resize the buttons and scroll bar
	if btnCount &gt; 0 then
		buttonWidth := getButtonWidthSetScrollBar( self.exChildButtonCount, self.frmExChild, self.btnExChildTemp.height, self.scrExChild );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.exChildButtonCount do
			menuButton := self.btnExChildTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnExChildTemp.fontSize;	
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	else
		buttonWidth := getButtonWidthSetScrollBar( self.exChildButtonCount, self.frmExChild, self.btnExChildTemp.height, self.scrExChild );
	endif;
	
	self.lblNoExChild.visible := (btnCount = 0);
	self.btnExChildTemp.visible := false;

epilog

	delete tiSet;
	delete dynaDict;

end;</source>
        <access>protected</access>
        <Parameter name="initialSetup" type="Boolean"/>
        <Parameter name="_tabIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="a64845d2-bd8f-46f7-b7fb-2df269b5686c">
