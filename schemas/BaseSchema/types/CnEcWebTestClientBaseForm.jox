    <JadeMethod name="doDisplayMessage" id="e21cf3c7-2d05-470d-99f0-61e92bb5dc35">
        <source>doDisplayMessage(pMessage:String) protected;
// --------------------------------------------------------------------------------
// Created:		14 June 2000 by cnwdad1
//
// Purpose:		Displays an informational/activity message on this form.  The
//				message will be appended to any existing message text on the form.
//
// Parameters:	pMessage - The message to be displayed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	messageText	: String;
	timestamp	: TimeStamp;

begin
	messageText	:=	txtDisplay.text;

	if messageText = null then
		messageText		:=	timestamp.String &amp; ": " &amp; pMessage;
	else
		messageText	:=	messageText &amp; CrLf &amp; timestamp.String &amp; ": " &amp; pMessage;
	endif;

	txtDisplay.text	:=	messageText;
	txtDisplay.refreshNow();
end;</source>
        <access>protected</access>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="152d1bdf-7c25-4076-90e5-e77b4f96864d">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 June 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not self.isValidClient()) then
		app.msgBox("The Remote Test Client can only be run as a Thin Client.", "Client Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		terminate;
	endif;

	self.doRegisterNotifications();
	self.setCaption();
	self.doDisplayMessage("Standing by...");
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRegisterNotifications" id="71d44ecd-ece8-4160-9127-d845567b4850">
        <source>doRegisterNotifications() protected;
// --------------------------------------------------------------------------------
// Created:		16 June 2000 by cnwdad1
//
// Purpose:		Registers the receiver for notifications from the controller node.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginNotification(global, CNEC_WEBTEST_SLAVE_SPAWN_FAT, Response_Continuous, 0);
	beginNotification(global, CNEC_WEBTEST_SLAVE_SPAWN_THIN, Response_Continuous, 0);
	beginNotification(global, CNEC_WEBTEST_CLIENT_CLOSE, Response_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStartClientFat" id="7b6506d7-49e3-49d6-adb7-25f8e2acdc01">
        <source>doStartClientFat(pPathBinaries:String; pPathIniFile:String) protected;
// --------------------------------------------------------------------------------
// Created:		14 June 2000 by cnwdad1
//
// Purpose:		Initiates a copy of the application, as a Standard (fat) Client.
//				The application will run in a new copy of Jade.exe.
//
// Parameters:	pPathBinaries - The directory name for the location of the JADE binaries.
//				pPathIniFile - The directory name for the location of the JADE INI file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	result			: Integer;
	processName		: String;
	processResult	: Integer;

begin
	// Wait a random time before cloning - reduce impact on the Server.
	process.sleep(self.getSleepTime());

	processName		:=	pPathBinaries &amp; "\jade.exe path=" &amp; app.dbPath;
	processName		:=	processName &amp; " schema=" &amp; currentSchema.name &amp; " app=BaseWebTestSlave";
	processName		:=	processName &amp; " ini=" &amp; pPathIniFile &amp; " server=multiUser";
	self.doDisplayMessage("Starting: " &amp; processName);
	processResult	:=	node.createExternalProcess(null, processName, null, null, true, false, result);
epilog
	if processResult = node.ExternalProcess_Failed then
		self.doDisplayMessage("External Process failed for: " &amp; processName);
	elseif processResult = node.ExternalProcess_InitiateFailed then
		self.doDisplayMessage("Failed to initiate: " &amp; processName);
	elseif processResult = node.ExternalProcess_InitiateOK then
		self.doDisplayMessage("Successfully initiated: " &amp; processName);
	elseif processResult = node.ExternalProcess_InvalidParam then
		self.doDisplayMessage("FAILED - Invalid parameter for: " &amp; processName);
	elseif processResult = node.ExternalProcess_Successful then
		self.doDisplayMessage("Successfully started: " &amp; processName);
	else
		self.doDisplayMessage("Unexpected return code for: " &amp; processName);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pPathBinaries" type="String"/>
        <Parameter name="pPathIniFile" type="String"/>
    </JadeMethod>
    <JadeMethod name="doStartClientThin" id="2623da85-2a38-4bfe-9cf2-bd6eb7b02fd4">
        <source>doStartClientThin(pAppServerPort:String) protected;
// --------------------------------------------------------------------------------
// Created:		14 June 2000 by cnwdad1
//
// Purpose:		Initiates a copy of the application, as a Thin Client.
//				The application will run in a new copy of Jade.exe.
//
// Parameters:	pAppServerPort - The port number of the JADE Application Server.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	result			: Integer;
	processName		: String;
	processResult	: Integer;
	appServerInfo	: String;

begin
	// Wait a random time before cloning - reduce impact on the Server.
	process.sleep(self.getSleepTime());

	appServerInfo	:=	"AppServer=" &amp; app.computerNameAppServer() &amp; " AppServerPort=" &amp; pAppServerPort;

	processName		:=	app.getJadeInstallDir() &amp; "\jade.exe " &amp; appServerInfo; 
	processName		:=	processName &amp; " schema=" &amp; currentSchema.name &amp; " app=BaseWebTestSlave";
	processName		:=	processName &amp; " ini=" &amp; app.getIniFileName();
	self.doDisplayMessage("Starting: [" &amp; processName &amp; "]");
	processResult	:=	node.createExternalProcess(null, processName, null, null, true, false, result);
epilog
	if processResult = node.ExternalProcess_Failed then
		self.doDisplayMessage("External Process failed for: " &amp; processName);
	elseif processResult = node.ExternalProcess_InitiateFailed then
		self.doDisplayMessage("Failed to initiate: " &amp; processName);
	elseif processResult = node.ExternalProcess_InitiateOK then
		self.doDisplayMessage("Successfully initiated: " &amp; processName);
	elseif processResult = node.ExternalProcess_InvalidParam then
		self.doDisplayMessage("FAILED - Invalid parameter for: " &amp; processName);
	elseif processResult = node.ExternalProcess_Successful then
		self.doDisplayMessage("Successfully started: " &amp; processName);
	else
		self.doDisplayMessage("Unexpected return code for: " &amp; processName);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pAppServerPort" type="String"/>
    </JadeMethod>
    <JadeMethod name="getSleepTime" id="8c1abb06-3395-43eb-a290-c4efda1e95a2">
        <source>getSleepTime():Integer protected;
// --------------------------------------------------------------------------------
// Created:		14 June 2000 by cnwdad1
//
// Purpose:		Returns a random period of time (of 60 seconds or within).
//
// Parameters:	None
//
// Returns:		Integer - The random period of time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MOD_TIME			: Integer = 60000;    // Wait up to 60 seconds.

vars
	sleepTime			: Integer;
	randomTime			: Integer;
	relativeMachineTime	: Decimal[20];
	stringTime			: String;

begin
	relativeMachineTime	:=	app.relativeMachineTime();
	stringTime			:=	relativeMachineTime.String;
	randomTime			:=	stringTime[(stringTime.length() - 5):end].Integer;
	sleepTime			:=	(process.number * MOD_TIME) mod ((randomTime mod MOD_TIME).Integer + 1);
	return sleepTime;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSpawnInfoFat" id="b1100a48-081c-401f-95ae-9d910cf49f6c">
        <source>getSpawnInfoFat(pUserInfo:Binary; pCopies:Integer io; pPathBinaries:String io; pPathIni:String io) protected;
// --------------------------------------------------------------------------------
// Created:		07 July 2000 by cnwdad1
//
// Purpose:		Extracts the "parameters" required when spawning a new web test via
//				Standard (fat) Client.  The parameters are fixed-length "fields"
//				within a binary image, specified by the the pUserInfo parameter.
//
// Parameters:	pUserInfo - A binary image containing the fixed-length parameter fields.
//				pCopies - The number of clients to spawn.
//				pPathBinaries - The directory name where the JADE binaries are located.
//				pPathIni - The directory name where the JADE INI file is located.
//
// Returns:		The application parameters are returned in the method's IO parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	spawnData	: Binary[513];

begin
	spawnData		:=	pUserInfo;
	pCopies			:=	spawnData.String[1:3].Integer;
	pPathBinaries	:=	spawnData.String[4:255].trimBlanks();
	pPathIni		:=	spawnData.String[259:255].trimBlanks();
end;</source>
        <access>protected</access>
        <Parameter name="pUserInfo" type="Binary"/>
        <Parameter name="pCopies" type="Integer" usage="io"/>
        <Parameter name="pPathBinaries" type="String" usage="io"/>
        <Parameter name="pPathIni" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSpawnInfoThin" id="42908435-a2ae-40a4-9a2f-45fa92e4b5aa">
        <source>getSpawnInfoThin(pUserInfo:Binary; pCopies:Integer io; pAppServerPort:String io) protected;
// --------------------------------------------------------------------------------
// Created:		07 July 2000 by cnwdad1
//
// Purpose:		Extracts the "parameters" required when spawning a new web test via
//				Thin Client.  The parameters are fixed-length "fields" within a binary
//				image, specified by the the pUserInfo parameter.
//
// Parameters:	pUserInfo - A binary image containing the fixed-length parameter fields.
//				pCopies - The number of clients to spawn.
//				pAppServerPort - The port number for the client's Application Server.
//
// Returns:		The application parameters are returned in the method's IO parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	spawnData	: Binary[8];

begin
	spawnData		:=	pUserInfo;
	pCopies			:=	spawnData.String[1:3].Integer;
	pAppServerPort	:=	spawnData.String[4:5].trimBlanks();
end;</source>
        <access>protected</access>
        <Parameter name="pUserInfo" type="Binary"/>
        <Parameter name="pCopies" type="Integer" usage="io"/>
        <Parameter name="pAppServerPort" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isValidClient" id="9a08a700-3c65-4aba-88aa-12c152e90180">
        <source>isValidClient():Boolean;
// --------------------------------------------------------------------------------
// Created:		18 June 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the executing client is
//				a valid Thin Client.
//
// Parameters:	None
//
// Returns:		True if the client is a valid Thin Client, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return process.isUsingThinClient;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="02a7f181-6eeb-403c-bf22-68e87f805faa">
        <updating/>
        <source>setCaption() updating;
// --------------------------------------------------------------------------------
// Created:		11 July 2000 by cnwdad1
//
// Purpose:		Sets the receiver's form caption.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.caption	:=	self.caption &amp; ": " &amp; app.computerName();
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="9a5ba571-ca73-4c62-ac51-6df7acc9c417">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		15 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	endNotificationForSubscriber(self);
	inheritMethod;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="004fa6dd-8577-4785-a4eb-bd506d3dfedd">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	copyIndex		: Integer;
	copiesToSpawn	: Integer;
	appServerPort	: String;
	pathBinaries	: String;
	pathIniFile		: String;
	delimiterPos	: Integer;
	userInfoBinary	: Binary;
begin
	app.mousePointer	:=	Busy;

	// 9/3/16  cnwns1 PAR 36286 unicode version
	if userInfo.isKindOf(String) then
		userInfoBinary := userInfo.String.asANSI(0);
	else
		userInfoBinary := userInfo.Binary;
	endif;
	
	
	if eventType = CNEC_WEBTEST_SLAVE_SPAWN_FAT then
		// The "userInfo" (Integer) contains the number of copies to spawn.

		self.getSpawnInfoFat(userInfoBinary, copiesToSpawn, pathBinaries, pathIniFile);

		if copiesToSpawn &gt; 0 then
			self.doDisplayMessage("I've been requested to spawn " &amp; copiesToSpawn.String &amp; " FAT copies...");

			foreach copyIndex in 1 to copiesToSpawn do
				self.doDisplayMessage("Spawning copy #" &amp; copyIndex.String &amp; "...");
				self.doStartClientFat(pathBinaries, pathIniFile);
			endforeach;
		endif;

	elseif eventType = CNEC_WEBTEST_SLAVE_SPAWN_THIN then
		// The "userInfo" (String) contains the number of copies to spawn,
		// and the Application Server Port number, delimited by a "Tab".

		self.getSpawnInfoThin(userInfoBinary, copiesToSpawn, appServerPort);

		if copiesToSpawn = 0 then
			self.doDisplayMessage("Cannot spawn Thin Clients - The number of copies to spawn is missing!");
			return;
		endif;

		if appServerPort = null then
			self.doDisplayMessage("Cannot spawn Thin Clients - The App Server Port is missing!");
			return;
		endif;

		self.doDisplayMessage("I've been requested to spawn " &amp; copiesToSpawn.String &amp; " THIN copies...");

		foreach copyIndex in 1 to copiesToSpawn do
			self.doDisplayMessage("Spawning copy #" &amp; copyIndex.String &amp; "...");
			self.doStartClientThin(appServerPort);
		endforeach;

	elseif eventType = CNEC_WEBTEST_CLIENT_CLOSE then
		self.doDisplayMessage("I've been requested to close down, TTFN...");
		terminate;

	else
		cnEcMonitor("Unexpected notification message: EventType='" &amp; eventType.String &amp; "'  EventTag='" &amp; eventTag.String &amp; "'  TheObject='" &amp; theObject.String &amp; "'  UserInfo='" &amp; userInfo.String &amp; "'");

	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
