        <source>showDutyDocExtraChargesForm(_debtor: CM_Debtor; _invoice: CM_Invoice; _dutyDoc: CM_DutyDoc);

vars
	invoiceForm : INV_DutyDocExtraChargesForm;

begin
	
	create invoiceForm transient;

	// from 36280 check for no form because of security issue
	if invoiceForm = null then
		return;
	endif;
	invoiceForm.myDebtor := _debtor;
	invoiceForm.myInvoice := _invoice;
	invoiceForm.myDutyDoc := _dutyDoc;
	invoiceForm.createMyAssistant(INV_Assistant);
	invoiceForm.setMyTerminal(self.myTerminal);
	invoiceForm.show();

end;
</source>
