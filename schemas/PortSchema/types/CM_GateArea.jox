    <JadeMethod name="getFirstEntryGate" id="707e39f9-54d6-4615-8c26-4c4a0b4c6cde">
        <source>getFirstEntryGate():CM_Gate;
/*
Date		Who		Reason
05 September 2011	cnwcs5	Initial creation - CCMS POL1862
*/
vars
	usage	:CM_GateAreaUsage;
begin
	usage := self.allGates_IN.first;
	
