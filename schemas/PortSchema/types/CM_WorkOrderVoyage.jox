    <JadeMethod name="addLengthOfTimeToDT" id="bc962a1a-f296-4e05-ad6e-f638d9b44a5a">
        <source>addLengthOfTimeToDT( _ts : TimeStamp ) : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2018	jlgndl1	Initial creation	TFS 39248

*/

vars

	ts : TimeStamp;

begin

	if self.lengthOfTime &gt; 0 then
		ts := _ts + self.lengthOfTime.daysAsTimeStampInterval();
	else
		ts := _ts;
	endif;
	
	return ts;

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItem" id="68346b83-0036-46a7-b4f8-67b8336bfa05">
        <source>addTrackedItem( _ti : CM_TrackedItem ;_task : CM_WorkOrderDtl);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2018	jlgndl1	Initial creation	TFS 39246
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]

*/

vars

begin
	if self.taskStatus = WO_STATUS_COMPLETE
		or self.taskStatus = WO_STATUS_CANCELLED 
		or self.taskStatus = WO_STATUS_NOTAPPROVED then
		return; // dont want to add cargo to a complete or canceled work order.
	endif;	

	if  _ti = null then
		return;
	endif;
	
	if not self.allTIs.includes( _ti ) then
		self.allTIs.add( _ti );
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_task" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="canAccessOnWeb" id="ec70c5aa-b10f-4eaa-a7f4-3a9a30451a77">
        <source>canAccessOnWeb(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jan2020	jlger1	Initial creation 48179
24 Jan 2023	navma1 	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	failedDAC	    : CM_DataAccessController;
	operator        : CM_Operator;
	user			: CM_User;
	passport		: CM_Passport;
	voyage			: CM_Voyage;
begin
	
	passport	:=	 app.myPassport;	//24.01.2023 navma1 #56141 Task#56147
	user 		:= app.getMyUser();		//24.01.2023 navma1 #56141 Task#56147

	if not user.canDo(self.myTerminal, PmWebWorkOrdersVoyView)  then			
		return false;
	endif;
	
	voyage := self.myVoyage;			//24.01.2023 navma1 #56141 Task#56147
	
	if voyage &lt;&gt; null then
		if not voyage.canUserAccessSelf(user, failedDAC, passport) then 
			return false;
		endif;
	endif;
	if self.isWorkOrderForPermit() then
		operator := self.allWoDtls.first.CM_WodPermitRequest.myOperator;
		if operator &lt;&gt; null then
			if not operator.canUserAccessSelf(user, failedDAC, passport) then 
				return false;
			endif;
		endif;
	endif;
	
	return inheritMethod;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canArchive" id="6b5b871f-ec2a-4f70-9a4f-fd6287a1c205">
        <source>canArchive(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	isEuPProcess	 	: Boolean;
	voyageProcess   	: CM_VoyageProcess;
begin
	
	voyageProcess	:= self.myTerminal.getDefaultVoyageProcess();						
	
	if voyageProcess &lt;&gt; null then
		isEuPProcess := voyageProcess.isEUPDefaultProcess();							
	endif;
	
	if isEuPProcess and self.taskStatus = WO_STATUS_NOTAPPROVED then
		return true;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="3fbfd84f-ea72-4c08-85a7-011657267534">
        <source>canCancel(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2018	jlger1	Initial creation

*/

vars
	wodDtl : CM_WorkOrderVoyageDtl;
begin
		if self.taskStatus = WO_STATUS_CANCELLED then
				return false;
		endif;
		
		
		wodDtl :=self.allWoDtls.first.CM_WorkOrderVoyageDtl;
		
		if wodDtl = null then
			return inheritMethod;
		else
			return wodDtl.canCancel;
		endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCreateCashReceipt" id="e8409799-8360-48e2-acb1-7fc85a3ed684">
        <source>canCreateCashReceipt() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/08/2018	jlgab1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
12/09/2018	jlgdap1	TFS 40202 PEL1 Estimation SAP Integration	
24/10/2018  cnwma1	Bug 41536: PEL1 - SAP - Marine Service Work Order Edit - Regeneration of Cash receipts
23 Oct 2024 navlw1 	JIRA-33107: Invoice Logging Use Levels
*/

vars
	cashRec : CM_CashReceipt;
begin
	
	// TFS 41026 no estimates for departure marine services request
	if self.isWorkOrderForDMSR() then 
		app.invLog("DMSR - No Estimations for DMSR", LogINFO.String);// JLGAB1 15MAY19 added during testing
		return false;
	endif;
	
	// TFS 41536 Stop Regeneration of Cash receipts  24.10.2018 cnwma1 
	if self.isWorkOrderForIMSR then
		foreach cashRec in self.allCashReceipts do
			if not cashRec.allSapRequests.isEmpty  then
				app.invLog("IMSR - Already have done SAP, not re processing work order estimation", LogTRACE.String);// JLGAB1 15MAY19 added during testing
				return false;
			endif;
			
			if cashRec.paymentStatus= CM_CashReceipt.CREDIT_CHECK_APPROVED or
			   cashRec.paymentStatus= CM_CashReceipt.CREDIT_CHECK_REJECTED then
				app.invLog("IMSR - Payment status is approved or rejected, not re processing work order estimation", LogTRACE.String);// JLGAB1 15MAY19 added during testing
			   return false;
			endif;
		endforeach;
	endif;
	
	if self.isWorkOrderForPermit() then // TFS 42161
		return true;
	endif;
	
	if self.taskStatus = WO_STATUS_USERENTRY or self.taskStatus = WO_STATUS_PENDING then
		return true;
	endif;
	
	return false;	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertId" id="0e142e6b-5dc4-4566-9b32-5b99efc200c2">
        <updating/>
        <source>convertId( woVoyageNumberGenerator : CM_AutoIdVoyWOIdGen input; _voyage : CM_Voyage )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2018	jlgndl1	Initial creation	TFS 40249

*/

vars

	oldId : String;
	newId : String;
	
	woDtl : CM_WorkOrderDtl;
	
	oldTaskId : String;
	newTaskId : String;

begin

	oldId := self.id;
	newId := woVoyageNumberGenerator.getNextIdForVoyageWO( _voyage, self );
	self.id := newId;

	foreach woDtl in self.allWoDtls do
		if not woDtl.isWorkOrderVoyageDtl then
			continue;
		endif;
		oldTaskId := woDtl.taskID;
		newTaskId := oldTaskId.replaceString( oldId, newId );
		woDtl.setPropertyValue( "taskID", newTaskId );	
	endforeach;

epilog

end;</source>
        <Parameter name="woVoyageNumberGenerator" type="CM_AutoIdVoyWOIdGen" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="creatPxyTisForProFormaWO" id="08e9492f-8965-46b1-9835-118a81ec9d3f">
        <source>creatPxyTisForProFormaWO( );
/*

Purpose:			

Parameters:			Callers responsibility to purge the transient contents after use,

Return Value:		

Date		Who		Reason
27 June 2018	jlgndl1	Initial creation	TFS 39246

*/

vars

	
	wodCargoRequest : CM_WodCargoRequest;

begin

	if self.allWoDtls.first = null then
		return;
	endif;
	
	self.allWoDtls.first.creatPxyTisForProFormaWO;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProxyWorkOrderTasks" id="74827bb2-dcf0-4d23-a443-70793b4b3d84">
        <source>createProxyWorkOrderTasks(_detailType: Integer; _reqByDT: TimeStamp; _startDT: TimeStamp; _toDoTask: CM_ToDoTaskDesc);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Oct 2018	jlger1	Initial creation 41310
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	pxyWODtl 			: CM_WorkOrderDtl;
	wodClass   		    : Class;
	workOrderDetailType	: CM_WorkOrderDetailType;
begin
	
	workOrderDetailType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Voyage,_detailType];
	if workOrderDetailType &lt;&gt; null then
		
		wodClass := workOrderDetailType.getWodClass(WorkOrderMode_Voyage);
		
		create pxyWODtl as wodClass transient;
		self.setProxyWorkOrderTask( pxyWODtl, _reqByDT, _startDT, false,_detailType, _toDoTask);		//24.01.2023 navma1 #56141 Task#56147
	endif;
	
epilog

end;</source>
        <Parameter name="_detailType" type="Integer"/>
        <Parameter name="_reqByDT" type="TimeStamp"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_toDoTask" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
