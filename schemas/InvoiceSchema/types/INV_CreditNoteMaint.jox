    <JadeMethod name="doSave" id="db0bf3cf-6bdd-406e-a72e-a91434ce3d8b">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone	
*/

