    <JadeMethod name="createTestObject" id="ecf21474-bf26-47ee-aaaa-468d84f6b802">
        <source>createTestObject() : CM_TrxTestObject protected;
// ---------------------------------------------------------------------------
// Created:     03 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	testObj	: CM_TrxTestObject;
begin

	// create a dummy test object to update
	beginTransaction;
	create testObj persistent;
	commitTransaction;
	
	return testObj;

end;</source>
        <access>protected</access>
        <ReturnType type="CM_TrxTestObject"/>
    </JadeMethod>
    <JadeMethod name="deleteTestObject" id="47840a7f-0716-4eb7-8499-d71edc195e25">
        <source>deleteTestObject(_testObj : CM_TrxTestObject io) protected;
// ---------------------------------------------------------------------------
// Created:     03 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not global.isValidObject(_testObj)) then
		return;
	endif;

	beginTransaction;
	delete _testObj;
	commitTransaction;

end;</source>
        <access>protected</access>
        <Parameter name="_testObj" type="CM_TrxTestObject" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doAddAck" id="c49a176f-debe-4cac-b83c-0ba5a3d5ba27">
        <updating/>
        <source>doAddAck() updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	: Integer;
	pxyObj,
	realObj	: CM_TrxTestObject;

begin

	app.mousePointer := MousePointer_HourGlass;

	self.setTrxTest();
	
	create pxyObj transient;

	// ==========  Sample code ==========
	
	app.myPassport.warningsAcknowledged	:= chkWarningsAck.value;

	while true do
		app.myTrxCA.aTrxSample(pxyObj, realObj, self.myTrxTest, app.myPassport);
		if app.myPassport.trxCompletedOK then
	
			// reset the Warnings Acknowledged checkbox
			chkWarningsAck.enabled 	:= false;
			chkWarningsAck.value	:= false;
	
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
	
			app.msgBox('Data saved', 'Info', MsgBox_OK_Only);
		else
			result := app.showErrorWarningDialog('Trx Test', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			if app.myPassport.hasWarningsToAcknowledge then
				self.chkWarningsAck.enabled := true;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

	//		app.showAllErrors('Errors', MsgBox_OK_Only);		// shows errors in a msgbox
	//		app.showErrors();			// msg box - "Errors/Warnings found.  You must correct before saving"
	//		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);	// shows errors in a msgbox
	//		app.showErrorWarnings();	// Dialog window with table of errors/warnings &amp; OK button
	//		app.showWarnings();			// Dialog similar showErrorWarnings but with Review and Cancel button
		endif;
		
		break;

	endwhile;

	// ==========  End of Sample code ==========

epilog	
	delete pxyObj;
	self.deleteTestObject(realObj);
	app.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddSimple" id="3090feb0-b010-41d1-9634-07f7288db5ff">
        <updating/>
        <source>doAddSimple() updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	: Integer;
	pxyObj,
	realObj	: CM_TrxTestObject;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	app.mousePointer := MousePointer_HourGlass;

	self.setTrxTest();
	create pxyObj transient;

	// ==========  Sample code ==========
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.aTrxSample(pxyObj, realObj, self.myTrxTest, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Test Create', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

	// ==========  End of Sample code ==========

epilog
	delete pxyObj;
	self.deleteTestObject(realObj);
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteAck" id="9239c48f-152d-4c5d-a8ee-88d74cc68935">
        <updating/>
        <source>doDeleteAck() updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	: Integer;
	realObj	: CM_TrxTestObject;

begin

	app.mousePointer := MousePointer_HourGlass;

	self.setTrxTest();
	realObj := self.createTestObject();
	
	// ==========  Sample code ==========
	
	app.myPassport.warningsAcknowledged	:= chkWarningsAck.value;

	while true do
		app.myTrxDA.aTrxSample(realObj, self.myTrxTest, app.myPassport);
		if app.myPassport.trxCompletedOK then
	
			// reset the Warnings Acknowledged checkbox
			chkWarningsAck.enabled 	:= false;
			chkWarningsAck.value	:= false;
	
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
	
			app.msgBox('Object deleted', 'Info', MsgBox_OK_Only);
		else
			result := app.showErrorWarningDialog('Test Delete', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			if app.myPassport.hasWarningsToAcknowledge then
				self.chkWarningsAck.enabled := true;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

	//		app.showAllErrors('Errors', MsgBox_OK_Only);		// shows errors in a msgbox
	//		app.showErrors();			// msg box - "Errors/Warnings found.  You must correct before saving"
	//		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);	// shows errors in a msgbox
	//		app.showErrorWarnings();	// Dialog window with table of errors/warnings &amp; OK button
	//		app.showWarnings();			// Dialog similar showErrorWarnings but with Review and Cancel button
		endif;
		
		break;

	endwhile;

	// ==========  End of Sample code ==========

epilog	
	self.deleteTestObject(realObj);
	app.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteSimple" id="8971b5b8-cd6b-4955-ae6f-2c3f849f1f3d">
        <updating/>
        <source>doDeleteSimple() updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	: Integer;
	testObj	: CM_TrxTestObject;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	app.mousePointer := MousePointer_HourGlass;

	self.setTrxTest();
	testObj := self.createTestObject();

	// ==========  Sample code ==========

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.aTrxSample(testObj, self.myTrxTest, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Test Delete', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	// ==========  End of Sample code ==========

epilog	
	self.deleteTestObject(testObj);
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveBackground" id="6fa41c08-7a38-4a8d-ad57-e4deeb5c6aac">
        <updating/>
        <source>doSaveBackground() updating;

// cnwdvb1 18 November 2002 

vars

	manager : CM_RemoteDataManagerInternal;
	cmif	: CMIF_Remote;

begin

	
	self.setTrxTest();
	app.myPassport.warningsAcknowledged	:= chkWarningsAck.value;
	create cmif transient;
	create manager transient;
	cmif.transactionType := 'TrxTest';
	cmif.myTrxTestObject := self.myTrxTest;
	cmif.terminal := 'T1';
	manager.processInternal(cmif, app.myPassport);	

	if app.myPassport.trxCompletedOK then

		// reset the Warnings Acknowledged checkbox
		chkWarningsAck.enabled 	:= false;
		chkWarningsAck.value	:= false;

		// Clear errors/warnings from form and err/warnings window
		self.clearErrorWarnings();

		app.msgBox('Data saved', 'Info', MsgBox_OK_Only);
	else
		if app.myPassport.hasWarningsToAcknowledge then
			self.chkWarningsAck.enabled := true;
		endif;

		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

	endif;
epilog
	delete cmif;
	delete manager;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSavePreTrxVal" id="3e4cd8ff-3790-41db-bd90-d6c265430429">
        <updating/>
        <source>doSavePreTrxVal() updating;
// ---------------------------------------------------------------------------
// Created:     04 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.mousePointer := MousePointer_HourGlass;

	self.setTrxTest();

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	self.myTrxTest.doValidation();

	if (not app.myPassport.noErrors) then
		app.showErrorWarningDialog('Pre-Trx Test', app.myPassport, ErrWarnMode_Add);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return;
	endif;
	on CM_Exception do null;	// disarm the validation ex handler

	// now do the actual update
	self.doUpdateSimple();

epilog	
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateAck" id="7be48661-56c7-4c30-8a11-bb2ffe77e9e2">
        <updating/>
        <source>doUpdateAck() updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	: Integer;
	pxyObj,
	realObj	: CM_TrxTestObject;

begin

	app.mousePointer := MousePointer_HourGlass;

	self.setTrxTest();
	realObj := self.createTestObject();
	
	pxyObj := app.createUpdateProxy(realObj).CM_TrxTestObject;

	// ==========  Sample code ==========
	
	app.myPassport.warningsAcknowledged	:= chkWarningsAck.value;

	while true do
		app.myTrxUA.aTrxSample(pxyObj, self.myTrxTest, app.myPassport);
		if app.myPassport.trxCompletedOK then
			app.myPassport.dumpDetails('After update - OK');
	
			// reset the Warnings Acknowledged checkbox
			chkWarningsAck.enabled 	:= false;
			chkWarningsAck.value	:= false;
	
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
	
			app.msgBox('Data saved', 'Info', MsgBox_OK_Only);
		else
			app.myPassport.dumpDetails('After update - fail');
			result := app.showErrorWarningDialog('Trx Test', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			if app.myPassport.hasWarningsToAcknowledge then
				self.chkWarningsAck.enabled := true;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

	//		app.showAllErrors('Errors', MsgBox_OK_Only);		// shows errors in a msgbox
	//		app.showErrors();			// msg box - "Errors/Warnings found.  You must correct before saving"
	//		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);	// shows errors in a msgbox
	//		app.showErrorWarnings();	// Dialog window with table of errors/warnings &amp; OK button
	//		app.showWarnings();			// Dialog similar showErrorWarnings but with Review and Cancel button
		endif;
		
		break;

	endwhile;

	// ==========  End of Sample code ==========

epilog	
	delete pxyObj;
	self.deleteTestObject(realObj);
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateSimple" id="a597637f-8c50-4673-ac1b-0f07eaf3a248">
        <updating/>
        <source>doUpdateSimple() updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	: Integer;
	pxyObj,
	realObj	: CM_TrxTestObject;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	app.mousePointer := MousePointer_HourGlass;

	self.setTrxTest();
	realObj := self.createTestObject();
	
	pxyObj := app.createUpdateProxy(realObj).CM_TrxTestObject;

	// ==========  Sample code ==========

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.aTrxSample(pxyObj, self.myTrxTest, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			app.msgBox('Data Updated OK', 'Info', MsgBox_OK_Only);
			break;
		else
			theResult := app.showErrorWarningDialog('Test Update', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	// ==========  End of Sample code ==========

epilog	
	delete pxyObj;
	self.deleteTestObject(realObj);
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="getLockObjects" id="214b1691-eaf3-4dd1-8db9-16159c497c75">
        <updating/>
        <source>getLockObjects() updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	testLockObj	: CM_TrxTestObject;

begin

	self.myTestLockObjectA := CM_TrxTestObject.firstInstance;
	if self.myTestLockObjectA = null then
		beginTransaction;
		create self.myTestLockObjectA persistent;
		self.myTestLockObjectA.code := 'A';
		commitTransaction;
	endif;

	self.myTestLockObjectB := CM_TrxTestObject.lastInstance;
	if self.myTestLockObjectB = null or
	   self.myTestLockObjectB = self.myTestLockObjectA then
		beginTransaction;
		create self.myTestLockObjectB persistent;
		self.myTestLockObjectB.code := 'B';
		commitTransaction;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="bbf0ceea-6c7c-449c-aa83-9f1e45910506">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     12 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod();

	self.setPassBackExceptions();
	
	chkWarningsAck.enabled 	:= false;

	self.getLockObjects;

	create self.myTrxTest transient;

	self.myTrxTest.myTestLockObjectA	:= self.myTestLockObjectA;
	self.myTrxTest.myTestLockObjectB	:= self.myTestLockObjectB;

	//self.initPassport();

end;</source>
    </JadeMethod>
    <JadeMethod name="lockObject" id="17146b88-4f5b-42da-a0f1-1fe4c71ea3ed">
