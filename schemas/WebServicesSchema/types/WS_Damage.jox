    <JadeMethod name="delete" id="a4c1b287-7a21-4048-bb1c-53c57de14b1d">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2015	cnwmc5	Initial creation

*/

vars

begin
	delete self.myDamageCode;
	delete self.myDamagePosition;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="68f71d3a-83e9-4f76-a610-dffacf7dd3f3">
        <updating/>
        <source>setProxyFromObject(_object: CM_DamageInstance) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2015	cnwmc5	Initial creation
10 Nov 2017		jlghl1	Extending class for new web portal
24 June 2022 	navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
06 Dec 2024		navsck1	Initial creation for MTN-33610 Create a new webservice to handle multiple damages and images
*/

vars
	
begin
	inheritMethod(_object);
	
	self.quantity := _object.quantity;
	//self.severity := _object.severity;		//24 June 2022 navhl20 TFS 53862
	if _object.myDamageSeverity &lt;&gt; null then
		self.severity := _object.myDamageSeverity.level;		//24 June 2022 navhl20 TFS 53862
		create self.myDamageSeverity transient;
		self.myDamageSeverity.setProxyFromObject(_object.myDamageSeverity);		//06.12.2024 navsck1 JIRA #33610
	endif;
	
	if _object.myDamagePosition &lt;&gt; null then
		create self.myDamagePosition transient;
		self.myDamagePosition.setProxyFromObject(_object.myDamagePosition);
	endif;
	if _object.myDamageDefinition &lt;&gt; null then
		create self.myDamageCode transient;
		self.myDamageCode.setProxyFromObject(_object.myDamageDefinition);
	endif;
	
	self.isRepaired := _object.repaired;
	self.isNewDamage := _object.isNewDamage;
	self.remarks := _object.remarks;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_DamageInstance"/>
    </JadeMethod>
</Class>
