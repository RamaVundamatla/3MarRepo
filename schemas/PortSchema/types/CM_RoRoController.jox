    <JadeMethod name="executePostUndoMove" id="0d3f5f44-b5db-4b81-854e-cb40b5b116b3">
        <updating/>
        <source>executePostUndoMove(control: CMIF_MoveController; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwjk3	Initial creation

*/

vars

begin
	inheritMethod(control, _passport);
	
	if (control.moveMode = PLANNING_MODE or control.moveMode = QUEUE_MODE) and control.isUndoMove then
		self.reCalcUsedLength(control, true);
	endif;
epilog

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="83901b2b-bc73-41a4-bce9-2f250f349454">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwjk3	Initial creation

*/

vars

begin
	if _attrName = ETRow_Id or _attrName = ETRow_Code then  //cnwjo3 ccms 1018
		return self.id;
	elseif _attrName = ETRow_Length then
		//return self.length.String;			// cnwjk3 PAR 23909 16/03/2010
		return self.length.asStringJMT();		// cnwjk3 PAR 23909 16/03/2010
	elseif _attrName = ETRow_Width then
		//return self.width.String;				// cnwjk3 PAR 23909 16/03/2010
		return self.width.asStringJMT();		// cnwjk3 PAR 23909 16/03/2010
	elseif _attrName = ETRow_StartOffset then
		//return self.startOffset.String;		// cnwjk3 PAR 23909 16/03/2010
		return self.startOffset.asStringJMT();	// cnwjk3 PAR 23909 16/03/2010
	elseif _attrName = ETRow_NumberingDirection then
		return self.numberingDirectionToString();
	elseif _attrName = ETRow_ParkDirection then
		return self.parkingDirectionToString();
	elseif _attrName = ETRow_AccessDirection then
		return self.accessDirectionToString();
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGLVDrawLengthInPixels" id="e1d73da5-73d8-401a-a5d7-040821a0132a">
