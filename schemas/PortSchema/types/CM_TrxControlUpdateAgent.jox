    <JadeMethod name="trxRebuildTerminalBRXref" id="29b8f042-6f09-4548-8e88-3779868e48ff">
        <updating/>
        <source>trxRebuildTerminalBRXref(_terminal : CM_Terminal;
						_passport : CM_Passport input) updating;

/*

Purpose:			Create/Rebuild a Booking reference cross reference for the passed in Terminal

Parameters:			Terminal to attach the cross reference to

Return Value:		None


Date		Who		Reason
28 Aug 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars
	lockedXref,
	brXref			: CM_TerminalTIsByBR;
		
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_terminal, "Terminal");
	
	// Start the transaction
	beginTransaction;
	
	// Reserve lock on CM_Terminal to single thread through the check for an existing
	// cross reference
	reserveLock(_terminal);
	brXref := _terminal.getBookingRefXref();
	
	// If the Booking Reference cross ref doesn't exist, then create it
	if _passport.noErrors() and brXref = null then
		// Create a new cross reference
		app.myUtilityCA.utlCreateTerminalBRXref(_terminal, brXref, _passport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	// Firstly take a Session Duration reserve lock on the xref parent to stop other users
	// from trying to initiate a rebuild
	self.lock(brXref, Reserve_Lock, Session_Duration, LockTimeout_Server_Defined);
	if _passport.hasErrors then
		return;
	endif;
	lockedXref := brXref;

	// Rebuild the cross reference
	self.doRebuildTerminalBRXref(_terminal, brXref, _passport);
	
	
epilog
	self.finaliseActivityWithPassport(_passport);

	// If we got the session lock, then we need to unconditionally release it AFTER the
	// transaction is committed
	if lockedXref &lt;&gt; null then
		self.unlock(lockedXref);
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxReceiveFromShip" id="efa3d882-665f-4ed8-9d6f-69dd26504307">
        <updating/>
        <source>trxReceiveFromShip(_tiSet : CM_TISet; _toLocn : CM_LocationsController input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	app.writeLog('Receive from ship - start:  ' &amp; _tiSet.size.String &amp; ' TIs', LogINFO);

	beginTransaction;
	app.myUtilityUA.utlReceiveFromShip(_tiSet, _toLocn, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
	app.writeLog('Receive from ship - complete', LogINFO);

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_toLocn" type="CM_LocationsController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxReconcileLogDockets" id="a8f44526-e496-4373-b5b6-d3e4a6ae0043">
        <updating/>
        <source>trxReconcileLogDockets(_passport : CM_Passport input;
					   _cmifMonitor : CMIF_Monitor input) updating;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	logScaleHdr	: CM_LogScalingHdr;
	scaleHdrs	: CM_LogScalingHdrsByNumDTDict;
	tmpMsg		: String;
	partsDone,
	partsInJob 	: Integer;
	terminal	: CM_Terminal;
	logDocket	: CM_BOLIn;
	extMatch 	: CM_BOLExtLogIn;	
	isMatched	: Boolean;
	errorSet	: CM_ErrorSet;
	error		: CM_Error;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	create errorSet transient;

	//beginTransaction;
	//app.myUtilityUA.utlReconcileLogDockets(_passport, _cmifMonitor);
	
	terminal := _passport.myTerminal;
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Terminal, contact developer.');
		return;
	endif;

	app.writeLog('Reconciling Dockets - start', LogINFO);

	scaleHdrs	:= terminal.allLogScalingHdrsUnmatched;
	
	if _cmifMonitor &lt;&gt; null then
		partsInJob 	:= scaleHdrs.size;
		tmpMsg 		:= _cmifMonitor.message;
	endif;
		
	foreach logScaleHdr in scaleHdrs do
		// need to reset these each time as they
		// get set back to false in doDeferredUpdates()
		
		_passport.useTITransactionDeferUpdate := true;
		_passport.useTIDictDeferUpdate := true;
		exclusiveLock(logScaleHdr);
		if (not _cmifMonitor.updateProgress(tmpMsg &amp; ' ' &amp; logScaleHdr.bolNumber, partsInJob, partsDone)) then
			return;
		endif;
		beginLoad;
		logDocket := logScaleHdr.getMatchingBOL();
		endLoad;

		beginTransaction;

		isMatched := logScaleHdr.attemptMatch(logDocket,true, _passport);   //epr TFS 3769 3/4/17 from clicking the match button
		if isMatched and _passport.noErrors then
			// this means that the match was sucessful
			extMatch := logDocket.myExtension.CM_BOLExtLogIn;
			extMatch.completeRoadInProcessForBOL(_passport);
		endif;
		
		if _passport.hasErrors then
			app.cmsAbortTransaction;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();	
			continue;
		endif;
		
		_passport.doDeferredUpdates();

		// fix for dup logs error par #18747 5.2.09 cnwrd1
		
		if (not _passport.isOkToCommit(false)) then
			app.cmsAbortTransaction;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();	
			continue;
		endif;

		app.cmsCommitTransaction(_passport);

		partsDone := partsDone + 1;
	endforeach;

	_passport.addErrorsFromSet(errorSet);
		
	if _passport.noErrors and (not process.isInTransactionState) then
		// done so finaliseActivityWithPassport will set trxComplete correctly
		beginTransaction;
	endif;


epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
	app.writeLog('Reconciling Dockets - complete', LogINFO);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRegradeLog" id="74c0a472-ef71-42b9-9aa0-88bd249a5375">
        <updating/>
        <source>trxRegradeLog(_logRegrade : CMIF_LogRegrade input; _userCode : String; _location : CM_LocationsController; 
		_isMove : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     Takes a set of CM_TrackedItems (which should be reals) and rejects.
//
// Parameters:  The set of tracked items.
//
// Returns:     True if successful.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr,
	prodCode	: String;
	pxyProduct,
	realProduct	: CM_ProductLog;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	app.writeLog('Regrade Logs - start: ' &amp; _logRegrade.allTrackedItems.size.String &amp; ' TIs', LogINFO);
	
	if _logRegrade.myOperator = null then
		tmpStr := app.getTerminologyAlternate(null, _passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, 'operator', null);
		app.raiseCMException1(Input_required_field_Required, tmpStr, 'operator', null); // cnwdb2	PAR 35364
		return;
	endif;

	if _logRegrade.myRegradeCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Regrade Reason', 'Regrade Reason', null);
		app.raiseCMException1(Input_required_field_Required, 'Regrade Reason', 'Regrade Reason', null); // cnwdb2	PAR 35364
		return;
	endif;	
	/*
	// Check if a product with this code exists and create if required
	tmpProduct := _logRegrade.getProduct(_passport).CM_ProductLog;
	if _passport.hasErrors then
		return;
	endif;
	*/
	
	// Ensure that the new product code exists before start
	prodCode := app.buildLogProductCode(_logRegrade.species, _logRegrade.gradeCode, _logRegrade.type, _logRegrade.treatment, _logRegrade.length);
	create pxyProduct transient;
	
	// This will also raise an exception if the codes are not valid
	pxyProduct.setProxyLogProductFromCodes(prodCode, _logRegrade.myOperator, 
					_logRegrade.species, _logRegrade.gradeCode, _logRegrade.type, 
					_logRegrade.treatment, _logRegrade.length, _passport, null);
	if _passport.hasErrors then
		return;
	endif;
		
	realProduct := _logRegrade.myOperator.allProducts[TI_CargoType_Log, prodCode].CM_ProductLog;
	if realProduct = null and _passport.noErrors then
		// need to create the real product
		beginTransaction;
		create realProduct persistent;
		realProduct.setForCreate(pxyProduct);
		
		if _passport.hasErrors then
			return;
		endif;
		commitTransaction;
	endif;
	
	_logRegrade.myProduct := realProduct;

	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;
	
	beginTransaction;
	app.myUtilityUA.utlRegradeLog(_logRegrade, _userCode, _location, _isMove, _passport);

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	delete pxyProduct;
	app.writeLog('Regrade Logs - complete', LogINFO);
	
end;</source>
        <Parameter name="_logRegrade" type="CMIF_LogRegrade" usage="input"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_isMove" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
