    <JadeMethod name="enableSaveButtons" id="c7210912-ce7f-4588-8231-8e0b5389feaa">
        <source>enableSaveButtons(_enable : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions

*/

vars

begin
	if _enable then
		self.btnOk.enabled := true;
		self.btnNext.enabled := true;
	else
