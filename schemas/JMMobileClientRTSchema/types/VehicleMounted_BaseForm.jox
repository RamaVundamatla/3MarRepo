    <JadeMethod name="checkErrors" id="9c977644-72f2-4386-a244-5f7573355a02">
        <source>checkErrors(): Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	errorMsg		: MobileHandHeldThin::DTO_HandHeldGateError;
begin

	if allErrorMsgs.size &gt; 0 then
		foreach errorMsg in allErrorMsgs do
				txtWrongData.text:=errorMsg.errorDescr &amp; CrLf;
				shtError.setFocus;
		endforeach;
		return true;
	endif;	

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearErrors" id="0c2e3193-bb2c-452e-b7ff-15655b5da51b">
