// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.validateForUpdate;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="49bd5eed-c5f2-4fb6-8666-791394b4dc8b">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     12 June 2002 by cnwsb1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/03/2010	cnwcs5		par 22762 - check can be deleted flag
// 11/04/2019 	JLGNS1		Bug 44243: PEL1 add inverses to prevent deleting consigniees if used in a WODCargoRequest
// ---------------------------------------------------------------------------
vars
	entries 			: Integer;
	map : CM_TranMapInvoiceLineMapping;
begin
	// ### TFS CR 65336 TASK 65337 08AUG2024 NAVAB1
	map :=  self.allTMInvoiceLineMappings.first;
	if map &lt;&gt; null then
		app.raiseCMWarning2(Cargo_subty_used_invoi_mappi_s, self.code,map.getTranMapBreadCrumb(),null,null, self);
	endif;

	if not self.hasNoNonInversedUsages then												// 04/03/2010 cnwcs5 par 22762 
		// can't be deleted - check this first
		
		//par 23669.  Only want to stop the delete if the product is not a system product type
		//if its a system product type we can delete it since it will never have been assigned to a TI
		if not self.isSystemProductType then
			app.raiseCMException1(ERR_CannotDeleteProduct, self.description, null, null);	// 04/03/2010 cnwcs5 par 22762 
			return;																			// 04/03/2010 cnwcs5 par 22762 
		endif;
	endif;
		
	//check SOH's
	entries := self.allSOHLocations.size;
	
	if entries &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, entries.String, app.getErrorString(Product), null);
	endif;
	
	entries := self.allProductMaps.size;

	if entries &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, entries.String, app.getErrorString(Invoice_cargo_subtype_maps), null);
	endif;
	
	
	entries := self.allWodCargoRequests.size;																			//Bug 44243
																														//Bug 44243
	if entries &gt; 0 then																									//Bug 44243
		app.raiseCMException2(ObjectStillHasEntries, self.code, entries.String, app.getErrorString(Work_order), null);	//Bug 44243
	endif;																												//Bug 44243													
	
	
	
	// 07/03/2012 cnwar2 #28974
	if not self.allProductMaps.isEmpty then
		app.raiseCMException1(CannotDeleteTransMap, self.code, null, null);
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="9d85fe5c-cc32-4e27-b407-e6c3470ab2d0">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18 Jun 2008	cnwkpd1		PAR #17014 - Make description mandatory in EDI load
// 19 Mar 2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements 
// 20/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
//28/06/2022 navds20 TFS 53760 MTN - DuplicateItem not Translatable
// ---------------------------------------------------------------------------
vars
	realObjForProxy	: CM_Product;
	realObjFound	: CM_Product;
	tmpStr,
	operatorStr		: String;
	prodAttrsViewable : StringArray;
	prodAttr		: String;
	
begin
	if self.myCargoType = null then
		if self.code &lt;&gt; SystemProductCode then	//CCMS 1080, PAR 19704. There is special system product for user-defined cargot type with no subcargo types. cargoType.mySystemProductType - not inversed.
		//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', ETRow_CargoType, null);
			app.raiseCMException(Input_required_field_cargoType, ETRow_CargoType, null);// cnwdb2	PAR 35364
			return;
		endif;
	endif;
	
//	prodAttrsViewable := self.myCargoType.allAttributesOnProduct;
	
	if self.myHandlingType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Handling Type', ETRow_HandlingType, null);
		app.raiseCMException(Input_required_field_handType, ETRow_HandlingType, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	// PAR #17014 - Ensure description is mandatory
	//PAR #17238
	if self.description = null and (not CM_ProductLog.hasInstance(self)) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_ProductDescription, null);
		app.raiseCMException(Input_required_field_Desc, ETRow_ProductDescription, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	/* WAS... No longer required field as per Richard Smith email dated 11/05/2006 13:00
	if self.myOperator = null then
		tmpStr := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
		app.raiseCMException1(REQUIRED_FIELD, tmpStr, ETRow_Operator, null);
		return;
	endif;
	*/
	
	//par 19029, different height,length and width will cause all kind of calculation and precision issues.  should
	//all be the same
	if self.getMyHeightMultiplier() &lt;&gt; self.getMyLengthMultiplier() or self.getMyHeightMultiplier() &lt;&gt; self.getMyWidthMultiplier() then
		app.raiseCMException(ERR_PRODUCTMULTIPLIER_MISMATCH, null, null);
	endif;
	
	// PAR #31155 height, length and width must have the same measurement type
	//if self.myHeight.myMeasurementType &lt;&gt; self.myLength.myMeasurementType or self.myHeight.myMeasurementType &lt;&gt; self.myWidth.myMeasurementType then
		//app.raiseCMException(HeightLengthWidth_MeasureTypes, null, null);
	//endif;
	
	// Checks that require an operator
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Cargo_subtype_code), ETRow_ProductCode, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Cargo_subtype_code), ETRow_ProductCode, null); // cnwdb2	PAR 35364


	elseif self.myOperator &lt;&gt; null then //No longer required field as per Richard Smith email dated 11/05/2006 13:00
		// Check that the product code is unique for the operator.
		// Works for creates and updates.
		realObjFound	:= self.myOperator.allProducts[self.cargoType, self.code];
		realObjForProxy	:= self.pxyGetRealObject;
		if realObjFound &lt;&gt; null and realObjFound &lt;&gt; realObjForProxy then
			tmpStr := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
			operatorStr := self.myOperator.code;
			//app.raiseCMException2(DuplicateItem, app.getErrorString(Product) &amp;" " &amp; self.code, tmpStr  &amp; " " &amp; operatorStr, null, null);  //28/06/2022 navds20 TFS 53760
			//Cargo Subtype %1 already exists for %2 : Cargo_subtype_already_exists
			app.raiseCMException2(Cargo_subtype_already_exists,  self.code, tmpStr  &amp; " " &amp; operatorStr, null, null); //28/06/2022 navds20 TFS 53760
		endif;
	else
		// Check only one product with null operator (in this case null = "All Operator")
		// As per Richard Smith email dated 11/05/2006 13:00
		if self.code &lt;&gt; SystemProductCode then	//CCMS 1080, PAR 19704. There is special system product for user-defined cargot type with no subcargo types. cargoType.mySystemProductType - not inversed.
			realObjFound	:= self.myCargoType.allProducts[null, self.code];
			realObjForProxy	:= self.pxyGetRealObject;
			if realObjFound &lt;&gt; null 
			and realObjFound &lt;&gt; realObjForProxy then
				//app.raiseCMException2(DuplicateItem, app.getErrorString(Product), self.code, null, null); //28/06/2022 navds20 TFS 53760
				//Cargo Subtype already exists for %1 : Cargo_subtype_alread_exists
				app.raiseCMException1(Cargo_subtype_alread_exists, self.code, null, null); //28/06/2022 navds20 TFS 53760
			endif;	
		endif;
		
	endif;
	
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366

	self.myWidthString.validateForUpdate();
	self.myHeightString.validateForUpdate();
	self.myLengthString.validateForUpdate();

	self.myWidth.validateForUpdate();
	self.myHeight.validateForUpdate();
	self.myLength.validateForUpdate();

	self.myQuantity.validateForUpdate();
	self.myVolume.validateForUpdate();
	self.myDensityDec.validateForUpdate();		// ### TFS 52193 22Nov2021 NAVPW1
	self.myWeight.validateForUpdate();

	self.myType.validateForUpdate();
	
	// PAR #33606 Bulk - if my cargo type is track by volume, and I don't have a density, raise an error	// PAR #33606
	if self.myCargoType &lt;&gt; null then
		//epr par 36005 9/4/15 
	if  self.myCargoType.isBulkByVolume then							// PAR #33606
		if self.myDensityDec.value = null then																// PAR #33606 // ### TFS 52193 22Nov2021 NAVPW1
			app.raiseCMException(Density_Rqd_Tracked_By_Volume, null, null);								// PAR #33606
		endif;																								// PAR #33606
	endif;
	endif;
	
	//10 Jun 2016	NDL	TFS 241
	if self.autoVolumeCalculate then
		// cargo type doesn't allow this.
		if self.myCargoType = null then
			app.raiseCMException2(AllowAutoVolumeCalc_No, "Null", self.code, null, null);
		elseif not self.myCargoType.allowAutoVolumeCalc then
			app.raiseCMException2(AllowAutoVolumeCalc_No, self.myCargoType.description, self.code, null, null);
		endif;
		
		//volume must be non zero
		if self.myVolume = null or self.myVolume.value = 0 then
			app.raiseCMException2( Must_greater_than, app.getErrorString(Volume_value), "0", null, null );
		endif;
		//quantity must be non zero
		if self.myQuantity = null or self.myQuantity.value = 0 then
			app.raiseCMException2( Must_greater_than, app.getErrorString(Quantity_value), "0", null, null );
		endif;
	endif;
	
end;</source>
    </JadeMethod>
