    <JadeMethod name="txtEndDate_lostFocus" id="177dbd7b-a33f-4208-a211-a13a71b7bbfb">
        <controlMethod name="CnEcDateBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtEndDate_lostFocus(textbox: CnEcDateBox input) updating;

/*

Purpose:			

Date			Who		Reason
01/05/2012		cnwmh5	Initial creation

*/

vars

begin
	
	if not textbox.text.Date.isValid() then
		textbox.setFocus();
		return;
	endif;

	self.endTimeStamp.setDate(textbox.text.Date);
	
	if self.endTimeStamp &lt; self.startTimeStamp then
		textbox.setFocus();
		return;
	endif;
	
	self.populateDateCombo();								// 16/07/2015 cnwmh5
		
epilog

end;</source>
