    <JadeMethod name="setMyHeader" id="444f9545-115f-4268-955d-52f5014c86f7">
        <updating/>
        <source>setMyHeader(_header : CM_BulkRelease input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.packType = self.PackType_Child then
		//if previously in the wrong collection, then remove - can onlt be in one or the other
		if _header.allReserveDetails.includes(self) then
			_header.allReserveDetails.remove(self);
		endif;
		if (not _header.allReservePackingChildren.includes(self)) then
			_header.allReservePackingChildren.add(self);
		endif;
		
	else
		//if previously in the wrong collection, then remove - can only be in one or the other
		if _header.allReservePackingChildren.includes(self) then
			_header.allReservePackingChildren.remove(self);
		endif;
		if (not _header.allReserveDetails.includes(self)) then
			_header.allReserveDetails.add(self);
		endif;
	endif;
	
	//13 Dec 2017	NDL	TFS 8091
	if _header &lt;&gt; null and not _header.isTransient then
		self.updateObjectEdition( _header );	
	endif;

end;</source>
        <Parameter name="_header" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
