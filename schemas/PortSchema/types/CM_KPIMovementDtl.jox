/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2012	cnwdw1	Initial creation
*/
vars

begin
	self.allMovementLegs.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayString" id="70867d9f-142c-4b05-9f31-756b3bf0596c">
        <source>displayString() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2012	cnwdw1	Initial creation
*/
vars

begin
	return "Cargo: " &amp; self.cargoId &amp; " Source: " &amp; self.sourceType &amp; " " &amp; self.source &amp; " To: " &amp; self.targetType &amp; " " &amp; self.target &amp;  
		" Start: " &amp; self.startTime.asStringForWebInterface &amp; " Finish: " &amp; self.finishTime.asStringForWebInterface &amp; " Duration: " &amp; self.duration.String &amp; " TEU: " &amp; self.teu.String &amp;
		" WorkPoint: " &amp; self.workPointId;
		

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPrimeSource" id="1fef1ab6-eecb-4999-9973-bc69f35cec57">
        <source>getPrimeSource() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2012	cnwdw1	Initial creation
*/
vars
	sta: StringArray;
begin
	create sta transient;
	self.source.asStringArrayByDelimiter(sta, " ");
	if sta.size &gt; 0 then
		return sta.first;
	endif;
	
	return "";
epilog
	delete sta;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
