    <JadeMethod name="autoVoyageMoveConfig" id="688d9693-3e19-4b51-b6fd-0b3791f9c9ad">
        <source>autoVoyageMoveConfig(_offset : Integer;_voyDateType : Integer) : CM_EDIAutoMovements;
/*
Purpose:			

Date		Who		Reason
// ### TFS BUG 65730 22AUG2024 NAVAB1
*/

vars
	pxyAM, realAM : CM_EDIAutoMovements;
	term : CM_Terminal;
	bs : CM_BlockStack;
	voyStatus : CM_VoyageStatus;
	voyProcess : CM_VoyageProcess;
begin
	term := self.getTerminal();
	
	if term.myEDIAutoMove &lt;&gt; null then
		app.myTrxDA.trxDeleteEDIAutoMove(term.myEDIAutoMove, app.myPassport);
		self.assertTrueTrxOKShowPassport("Delete Auto Movement Config");
	endif;
	
	bs := self.addBlockStack("voyAM", 99999, null);
	self.assertTrueMsg(bs &lt;&gt; null, "BS is null");
	
	voyProcess := app.myRoot.allVoyageProcesses["AUTO"];
	self.assertTrueMsg(voyProcess &lt;&gt; null, "voyProcess is null");
	
	voyStatus := voyProcess.allStatusesById[Voyage_Status_Closed_Auto];
	self.assertTrueMsg(voyStatus &lt;&gt; null, "voyStatus is null");
	
	
	create pxyAM transient;
	pxyAM.setProxy(term, _offset, _voyDateType, bs.myLocationsController, voyStatus);
	
	app.myTrxCA.trxCreateEDIAutoMove(pxyAM, realAM, app.myPassport);
	
	return realAM;
	
epilog
	delete pxyAM;
end;</source>
        <Parameter name="_offset" type="Integer"/>
        <Parameter name="_voyDateType" type="Integer"/>
        <ReturnType type="CM_EDIAutoMovements"/>
    </JadeMethod>
    <JadeMethod name="deleteAllVoyageStages" id="af20122c-287b-4190-b844-75f090bf8cf5">
        <source>deleteAllVoyageStages(_progress : CM_VoyageProgress);
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars
	 realStage : CM_VoyageStage;

begin
	foreach realStage in _progress.allStages discreteLock do
		app.myTrxDA.trxDeleteVoyageStage(realStage, app.myPassport);
	
	endforeach;
epilog

end;</source>
        <Parameter name="_progress" type="CM_VoyageProgress"/>
    </JadeMethod>
