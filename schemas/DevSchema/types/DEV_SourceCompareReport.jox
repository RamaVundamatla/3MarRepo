				attributesDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if attributesDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing Attributes Count: " &amp; attributesDifferentCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devConstant in devClass.allConstants where devConstant.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if not wroteHeaderLine then
