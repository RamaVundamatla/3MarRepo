    <JadeMethod name="showConfigLocator" id="4cd6682d-33d1-408e-89ef-13f4e7f2f6c3">
        <source>showConfigLocator();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2012	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	formClass : Class;
	form : CM_BaseForm;

begin

	schema := currentSchema.getSchema("SysOpsSchema");
	formClass := schema.getClass("SOP_UserConfigLocator");
	form := app.getForm(formClass.name).CM_BaseForm;
	if form = null then
		form := app.loadForm(formClass, CMUI_Assistant, false, false, false, self.myTerminal, null).CM_BaseForm;
	endif;
	if form &lt;&gt; null then
		form.show;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showConflictsReport" id="15fb406a-3d78-4ed1-aa22-6e08898f5ad1">
        <source>showConflictsReport(_conflictManager : CMIF_HMS_ConflictsManager input; _terminal : CM_Terminal; _harbour : HMS_Harbour);
//--------------------------------------------------------------
//Created: June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	formCls			: Class;
	assistCls		: Class;
	conflictsFrm	: CM_BaseForm;
	menuAction		: CMUI_MenuAction;
	subSys			: CMUI_SubSystem;
	term			: CM_Terminal;	
	
begin
// cnwdad1 27/06/2008 - PAR #17135.
	if _harbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		return;
	endif;
	
	subSys := app.myController.allSubSystems['HmsSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('HMS_ConflictReportForm', formCls, assistCls);
	endif;

	term := _terminal;
	
	if term = null then
		if _harbour &lt;&gt; null then
			term := _harbour.allTerminalsByCode.first();
		endif;
		
		if term = null then
			term := app.getMyTerminalDO_NOT_USE();
		endif;
	endif;

	if term &lt;&gt; null then
		conflictsFrm := app.loadForm(formCls, assistCls, false, false, false, term, null).CM_BaseForm;
	else
		// No Terminal for system items e.g. Vessel Definition window
		create conflictsFrm as formCls transient;
		conflictsFrm.createMyAssistant(assistCls);
	endif;
	
	if conflictsFrm = null then
		return;
	endif;

	conflictsFrm.showWithObjectMode(_conflictManager, null);
end;</source>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="showCraneRateForm" id="80a056d7-a99c-4ab3-b81a-b5ad597f4372">
        <source>showCraneRateForm(	_obj : CM_Object;
					_menuAction : CMUI_MenuAction);
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	form 		: CMUI_CraneRates;
	result 		: Integer;
	menuAction : CMUI_MenuAction;
begin
	if _obj = null then
		return;
	endif;

	form := app.loadForm(CMUI_CraneRates, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_CraneRates;	
	
	if form = null then
		return;
	endif;
	
	
//	form := app.loadForm(CMUI_CraneRates, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_CraneRates;	
	
	//if form = null then
	//	return;
	//endif;
	form.setMyObject(_obj);

	if currentSchema.name = 'JtdDriverSchema' then  // jhp 20061221
		form.show;
		form.zOrder(1);
	else
		form.showModal;
	endif;

epilog
	delete form;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showCritieriaMaintForm" id="870ef98d-961c-449a-9125-35861a9dc6cd">
        <source>showCritieriaMaintForm(	_parentForm : CM_BaseForm;
						_terminal : CM_Terminal;
						_context : Integer;
						_allTemplateCriteria : CMIF_Array input ) : Boolean;
/*

Date		Who		Reason
13 May 2016	cnwer1	Initial creation TFS 1882

*/

vars
	theForm 		: CMUI_YACriteriaMaintForm;
begin
	theForm := app.loadForm(CMUI_YACriteriaMaintForm, CMUI_Assistant, false, false, true, _terminal, null).CMUI_YACriteriaMaintForm;
	if theForm = null then
		return false;
	endif;
	
	theForm.setTemplateCriteria(_allTemplateCriteria);
	theForm.setContext(_context);
	theForm.setParentForm(_parentForm);
	theForm.showModal();
	
	if theForm.modalResult = IDOK then
		_allTemplateCriteria.purge();
		theForm.getTemplateCriteria(_allTemplateCriteria );
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_allTemplateCriteria" type="CMIF_Array" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCustomsReferencesForm_TI" id="a7007b55-b479-400d-95f1-c6b0eb769fd9">
        <source>showCustomsReferencesForm_TI(_ti :CM_TrackedItem; _mode : Integer) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 November 2022	navpw1	Initial creation TFS: 55215
02 April 	2024	navlw1 	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable
08 April 	2024	navlw1 	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode
*/

vars
	frm					: CMUI_CustomsReferencesForm_TI;
	menuAction 			: CMUI_MenuAction;
	
begin
	if _ti = null then
		app.msgBox(	app.getString( CannotUpdateStopNothingSelectd ),
					app.getString( Please_Select_Cargo_Items ),
					MsgBox_Stop_Icon + MsgBox_OK_Only );
		return IDCANCEL;
	endif;
	
	frm := app.loadForm(CMUI_CustomsReferencesForm_TI, CMUI_Assistant, false, false, false, self.myTerminal, menuAction).CMUI_CustomsReferencesForm_TI;
	
	if frm = null then
		// should not happen
		return IDCANCEL;
	endif;
	
	// navwlw #63566
	frm.mode := _mode;
	
	// set references on form being displayed for tracked items for which stops are to be maintained
	frm.setMyTerminal(self.myTerminal);	

	frm.myTrackedItem	:= _ti;
	
	frm.showModal;
	
	return frm.modalResult;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showCustomsStatusEnquiryForm" id="44cd81b1-4384-4d75-83bb-58066b7ea7f7">
