    <JadeMethod name="deleteProduct" id="7939185c-5665-4808-ad0e-179fd6067a43">
        <source>deleteProduct(_product: Any; _operator: CM_Operator; _cargoType: CM_CargoType);
//29 August 2008	cnwdw1	
// 26/06/2014		cnwmh5	Update to pass either product or product.code through

vars
	product: CM_Product;
	cargoType: CM_CargoType;
begin
	
	if _product.isKindOf(String) then
		product := _cargoType.allProducts[_operator.code, _product.String];
	elseif _product.isKindOf(CM_Product) then
		product := _product.CM_Product;
	endif;
	
	if product &lt;&gt; null then
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		beginTransaction;
		product.allSOHLocations.purge();
		product.setPropertyValue(CM_Product::hasNoNonInversedUsages.name, true);
		commitTransaction;
		app.myTrxDA.trxDeleteProduct(product, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
	
epilog
	abortTransaction;
end;
</source>
        <Parameter name="_product" type="Any"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
