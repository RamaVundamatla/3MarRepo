    <JadeMethod name="ccms1061_setProxy" id="aafbf239-a607-42ce-a9c2-d5357f1b6601">
        <updating/>
        <source>ccms1061_setProxy(_area :CM_TerminalArea input) updating;
// ---------------------------------------------------------------------------
// Created:     16 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	// create default lane for terminal area - in by default
	if not self.pxyHasLanesDefined then
		self.pxyCreateNewLane (true);
	endif;

	self.setProxyInterchangeArea (_area.id, _area.comment, _area.myTerminal, TA_TYPE_YARD_INTERCHANGE, 0,  _area.actAsReleasePoint.Boolean, _area.hideFromOverView, self.Access_VehicleMachines, null,  null); 
epilog

end;</source>
        <Parameter name="_area" type="CM_TerminalArea" usage="input"/>
    </JadeMethod>
