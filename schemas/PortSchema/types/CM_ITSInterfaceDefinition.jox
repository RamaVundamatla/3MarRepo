    <JadeMethod name="allocateResponseMessageNumber" id="1aea604f-3550-453e-9d39-77d1fe030257">
        <updating/>
        <source>allocateResponseMessageNumber() : Integer updating;

/*

Purpose:			Allocate next message number for Responses

Parameters:			None

Return Value:		Response message number


Date		Who		Reason
24 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.lastResponseMessageNumber := self.lastResponseMessageNumber + 1;
	
	if self.lastResponseMessageNumber &gt; 999999999 then
		self.lastResponseMessageNumber := 1;
	endif;
	
	return self.lastResponseMessageNumber;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="91a745d0-ed9f-46d8-a9ef-0662af45aaac">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	callStack    : ProcessStackArray;
	methCallDesc : MethodCallDesc;

begin
	executeWhen JMTDevelopmentEnvironment;

	app.writeLog(method.qualifiedName, LogERROR);	//26 Nov 2019	NDL	TFS 47053
	
	create callStack transient;
	// get the stack for the current process
	process.currentStack(callStack);
	// iterate through the process stack array and display each MethodCallDesc
	foreach methCallDesc in callStack do
		app.writeLog(methCallDesc.display, LogERROR);	//26 Nov 2019	NDL	TFS 47053
	endforeach;

	endExecuteWhen;
	
	
epilog
	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;
	
end;		
</source>
    </JadeMethod>
