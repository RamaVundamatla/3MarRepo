    <JadeMethod name="createDamageInstance" id="eee582c4-e935-4732-b7dd-9b7e9ea48252">
        <source>createDamageInstance(_damageCmb, _severityCmb : ComboBox; 
					 _damageInstanceDict : MobileHandHeldThin::CM_DamageInstanceByDmgePos input) protected;
					 //_damageInstanceDict : MobileHandHeldThin::CM_DamageInstanceByLocDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On	Changed By  Reason
26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details - changed method signature to use damage position object dicts.
01/07/2022  navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details	
----------   ----------  --------------------------------------------------
*/
vars
	damageDefCode			: MobileHandHeldThin::CM_DamageDefinitionCode;
	damageInstance			: MobileHandHeldThin::CM_DamageInstance;
	damagePosition			: MobileHandHeldThin::CM_DamagePosition;
	remarks					: String;
	quantity				: Integer;
	isNewDamage,
	isRepaired				: Boolean;
begin
	damageDefCode := _damageCmb.listObject.MobileHandHeldThin::CM_DamageDefinitionCode;
	
	if damageDefCode = null then
		return;
	endif;
	
	create damageInstance transient;

	damageInstance.setProxy(null, 
							null,
							damageDefCode,
							damagePosition,//_damageCmb.tag.Integer,
							remarks,
							isNewDamage,
							quantity,
							//_severityCmb.text.Integer			//July 1, 2022 navak20 TFS 53862
							//isRepaired,						//July 1, 2022 navak20 TFS 53862
							//null	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593		//July 1, 2022 navak20 TFS 53862
							null,	// 11.07.2022 navak20 TFS 53862
							null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
							null, null, null, null, null, null, null, null, null	//July 1, 2022 navak20 TFS 53862
							);
	_damageInstanceDict.add(damageInstance);
end;


</source>
        <access>protected</access>
        <Parameter name="_damageCmb" type="ComboBox"/>
        <Parameter name="_severityCmb" type="ComboBox"/>
        <Parameter name="_damageInstanceDict" type="MobileHandHeldThin::CM_DamageInstanceByDmgePos" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doApplyErrors" id="48b910b9-ab06-4e56-a351-4ab18e4b8503">
        <updating/>
        <source>doApplyErrors(_errorMsgs : MobileHandHeldThin::DTO_HandHeldGateErrorDict) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	mess : String;
	errorMsg		: MobileHandHeldThin::DTO_HandHeldGateError;
	str				: String;
begin
	
	foreach errorMsg in _errorMsgs do
		if (errorMsg.errorNo = 75837 or  errorMsg.errorNo = 70005) 
		and self.txtVehicle.text &lt;&gt; null then
			mess := "Car  '" &amp; self.txtVehicle.text &amp; "' is not on the manifest for voyage '" &amp; self.txtVoyage.text &amp; "'." &amp; Cr 
								&amp; Cr &amp; "MOVED TO HOLDING AREA";
			app.msgBox(mess, "MOVE TO HOLDING AREA", MsgBox_OK_Only);
			self.doSendAlertTXTToControl(mess);
			self.txtAltID.text := null;
			self.txtVehicle.text := null;
			self.txtLocation.text := null;
			return;
		else
			str := str &amp; errorMsg.errorDescr &amp; '.' &amp; CrLf;
		endif;
	endforeach;
	self.txtWrongData.text := str;

end;


</source>
        <access>protected</access>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict"/>
    </JadeMethod>
    <JadeMethod name="doClearErrors" id="5530f9bc-ca38-455d-8c12-749af9c135c2">
        <source>doClearErrors() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.txtWrongData.text := null;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbRemarksClick" id="64e31c82-4896-46e7-94e3-d75ff0f839bc">
        <source>doCmbRemarksClick() protected;
/*
----------   ----------  --------------------------------------------------
Created:	21 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	remark			: MobileHandHeldThin::CM_PredefinedRemark;
begin
	remark := self.cmbRemarks.listObject.MobileHandHeldThin::CM_PredefinedRemark;
	if remark = null then
		return;
	endif;
	
	self.txtWrongData.text := remark.description;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmDamage" id="13b20350-4345-4a0a-8ac7-c6bf9504a02b">
        <updating/>
        <source>doConfirmDamage() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	damageRemarks,
	altID, carID, errors			: String;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//damageDict			: MobileHandHeldThin::CM_DamageInstanceByLocDict; 
	damageDict			: MobileHandHeldThin::CM_DamageInstanceByDmgePos;
	pxyDamageInstance	: MobileHandHeldThin::CM_DamageInstance;
	errorMsgs			: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
begin
	carID := self.txtVehicle.text.trimBlanks.toUpper();
	altID := self.txtAltID.text.trimBlanks.toUpper();
	
	if carID = null and altID = null then
		app.msgBox("You must enter a value for the Car's VIN",'Error: No car VIN specified',MsgBox_Exclamation_Mark_Icon);
	endif;
		
	
	create damageDict transient;
	create errorMsgs transient;
	
	self.tblDamage.setProxyFromTable(damageDict, null, errors);
	
	if errors &lt;&gt; null then
		if app.msgBox(errors &amp; CrLf &amp; 'Continue?', 'Entry Warnings - Continue?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	damageRemarks := self.txtDamage.text.trimBlanks;
	
	app.myHandHeldCarGuiAgent.doConfirmDamageCar(damageRemarks,damageDict,	errorMsgs);
	
	
	if (not errorMsgs.isEmpty) then
		app.msgBox('Errors occured when applying damage details. They will now be displayed','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	else
		self.doShowFrmMain();
	endif;

epilog
	
	if damageDict &lt;&gt; null then
		damageDict.purge();
	endif;
	delete damageDict;

	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	delete errorMsgs;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmLocation" id="90e0f22f-10fa-4311-a6aa-eee5af4114d0">
        <updating/>
        <source>doConfirmLocation() updating;
// ---------------------------------------------------------------------------
// Created:		24 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error			: DTO_HandHeldGateError;
	locationID		: String;
begin
	create errorMsgs transient;
	
	locationID := self.txtLocation.text.trimBlanks.toUpper();
	
	if locationID = null then
		return;
	endif;
	
	app.myHandHeldCarGuiAgent.doConfirmLocation(locationID, 	errorMsgs);
	if not errorMsgs.isEmpty then
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	endif;
	
epilog
	delete errorMsgs;


end;</source>
    </JadeMethod>
    <JadeMethod name="doConfirmVoyage" id="2b72fdd9-9a4b-4af3-9567-d92f42b1d360">
        <updating/>
        <source>doConfirmVoyage() updating;
// ---------------------------------------------------------------------------
// Created:		24 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error			: DTO_HandHeldGateError;
	voyageID		: String;
begin
	create errorMsgs transient;
	self.doClearErrors();
	
	voyageID := self.txtVoyage.text.trimBlanks.toUpper();
	
	if voyageID = null then
		return;
	endif;
	
	app.myHandHeldCarGuiAgent.doConfirmVoyage(voyageID, 	errorMsgs);
	
	if not errorMsgs.isEmpty then
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	endif;
	
epilog
	delete errorMsgs;


end;</source>
    </JadeMethod>
