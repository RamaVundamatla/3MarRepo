    <JadeMethod name="getDisplayStringForAttribute" id="d78022d6-df8d-4502-8a51-a4a233d8c62b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/01/2013	cnwdap1		PAR #30860 CCMS QNS 2236 New exterrnal invoice number field
// July 2015	cnwjre1		Some internal invoices with null invoice type
// 14 June 2016	cnwns1		TFS 488 - Multi Timezone Support
// 16/06/2017	cnwdap1		TFS 4894 Voyage exteranl Code in Invoice List
// 17 Jan 2018  cnwma1		TFS #Bug 36575: JMT - External Invoice Number Issue
// 27 Sep 2018  cnwma1	    ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes
// 14 Nov 2018  jlgrh7 		TFS41530  STWO - Sort on amount columns in Invoice list and invoice line list screens
// 22 July 2019	cnwma1		ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 14 Oct 2019  cnwma1		Bug 47007: JMT - Invoice for BOLs in Invoice List
// 03 Jun 2020  cnwma1 		ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 02 Oct 2020  cnwma1		ChangeRequest 50112: ASPA - GCI Stevedores
// 11 Mar 2021  cnwma1      ChangeRequest 50925: ASPA - New Total Column in Invoice Form
// 16 Dec 2021  navma1		ChangeRequest 52580: SAL - Work Order and Invoicing link
// 01 June 2022	navak20		ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 29 Jun 2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
// 18 Aug 2022	navpw1		TFS: 54564 (54381)(54383) - EUP - Inv Config - Debtor Currencies and Countries
// 23 Sep 2022	navpw1		TFS: 54564 (54384) - EUP - Inv Config - Invoice Surcharges
// 7 Nov 2022 	navrk21 	Bug 55204: MTN - Accural Type for Debtor is incorrect
// 01 Dec 2022 navtnr20		TFS CR 55308 TASK 55552: UI - Add new attribute to Invoice List columns
//21 Feb 2023 navtnr20		TFS CR 55648 Task 55663: UI - Contract Id
// 14/08/2023	navkc1		Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
// 18 Aug 2023  navlc30     ChangeRequest 59481: EUP | New Scope 54831 [15] - Total Tax Display on Invoice List Screen
// 05/09/2023 navcs2	Bug 59959: EUP | TAS Invoicing - Invoice API doesn't match whats defined in API spec
// 13/02/2024	navra1		CR 61910/Task 62303 - EUP | API Create default package to run on invoice updating status to POSTED
// ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1 - from this point these fields are calculated when the invoice is updated, as each invoice line is created. 
//																			An upgrade script might have taken many hours to convert all existing invoices, lines etc. 
//																			So this change will use a value if it is not null else it will derive the value, as it always has done.
vars
	dit					: CM_DebtorInvType;
	packageNames		: String;
	package				: CM_Package;
	statusChangeAudit 	: CM_Audit;
	ts 				  	: TimeStamp;
	roundDecimalOpt   	: Integer;
	invLine		  		: CM_InvoiceLine;
	stevedoreCode	  	: String;				// TFS 53362
	stevedoreObj	  	: CM_Stevedore;			// TFS 53362
	debtorAltAddress	: CM_Address;			// ### TFS 54564 (54381) 01Sep2022 NAVPW1
	debtorCurrencyType 	: CM_CurrencyType;		// ### TFS 54564 (54382) 01Sep2022 NAVPW1
	localBank			: CM_Bank; 				//02/04/2025	navkc1 JIRA Bug MTN-34085
begin
	localBank := self.bank; //02/04/2025	navkc1 JIRA Bug MTN-34085
	
	if _attrName = ETRow_AccuralType  then
		if self.invoiceType = null then
			return null;
		else
			//return  invoiceType.getAccrualTypeDescription();				// 07.11.2022 navrk21 TFS 55204
			return  invoiceType.getAccrualTypeDescDebtor(self.debtor);		// 07.11.2022 navrk21 TFS 55204
		endif;
	
	elseif _attrName = ETRow_MergedInto  then // ### TFS CR 58085 TASK 61347 11JAN2024 NAVAB1
		if self.myMergeInvoice &lt;&gt; null then
			return self.myMergeInvoice.sequenceNum.String;
		endif;
		return null;
	elseif _attrName = ETRow_MergedInvoices  then // ### TFS CR 58085 TASK 61347 11JAN2024 NAVAB1
		return self.getAllMergeInvoicesSql();
	elseif _attrName = ETRow_InvoiceTotalAmount  then // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
		return self.totalAmount.asStringJMTWithPrecision(2,true);// ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
	elseif _attrName = ETRow_AuditsQual  then
		return  qualifiedAudits.size.String.padLeftBlanks(10);
	elseif _attrName = ETRow_AuditsUnQual  then
		return unqualifiedAudits.size.String.padLeftBlanks(10);
	elseif _attrName = ETRow_Bank  then
		//02/04/2025	navkc1 JIRA Bug MTN-34085
		if localBank &lt;&gt; null then
			return  localBank.code;
		endif;
		
		return null;
	elseif _attrName = ETRow_DebtorCode  then
		return debtor.name;
	elseif _attrName = ETRow_InvoiceProcess  then // TFS 39168
		return self.getMyInvoiceProcess.description;
	elseif _attrName = ETRow_Exported  or
		   _attrName = ETRow_Export then
		return app.getYesBlank(self.exportedCount &lt;&gt; 0);
	elseif _attrName = ETRow_GlYearPeriod  then
		if decfinGLYear &lt;&gt; null // AKB 02Feb2001 PAR 3869
		and decfinGLPeroid &lt;&gt; null then
			return decfinGLYear.String &amp; "/" &amp; decfinGLPeroid.String.padZeros(2) ;
		else
			return null;
		endif;
	elseif _attrName = ETRow_InvoiceTypeCode  then
		if self.invoiceType = null then
			return null;
		else
			return self.invoiceType.getInvoiceString(self);
		endif;
	elseif _attrName = ETRow_Items  then
		return (self.invoiceLines.size + self.allCashPayments.size).String.padLeftBlanks(10);
	elseif _attrName = ETRow_Period  then
		if self.invoiceType &lt;&gt; null then		
			if self.invoiceType.myFinancialPeriodEnd &lt;&gt; null then
				return self.invoiceType.myFinancialPeriodEnd.description;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_Status  then
		return self.getStatusDescription(self.status);
	elseif _attrName = ETRow_Terms  then
			return self.termsOfTradeCode ;
	elseif _attrName = ETRow_Terminal  then
		return  self.myTerminal.code;
	elseif _attrName = ETRow_FromDT  then
		if fromDT.isValid then
			return self.systemToLocalTime(fromDT).String;// 14 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
	elseif 	_attrName = ETRow_Voyage or
			_attrName = ETRow_VoyageGeneral // 10/11/2023	navkc1 Bug 61004
			then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;
		endif;
		return null;
	elseif _attrName = ETRow_ToDT  then
	
		if toDT.isValid then
			return self.systemToLocalTime(toDT).String;// 14 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
	elseif _attrName = ETRow_PostedDT  then
	
		if postedDT.isValid then
			return self.systemToLocalTime(postedDT).String;// 14 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_Details  then	//Par 17895
		/*if self.detailCode &lt;&gt; null then // ### TFS 51219 25MAY2021 NAVAB1
			return self.detailCode; // ### TFS 51219 25MAY2021 NAVAB1
		endif;
		
		if self.invoiceType = null then
			return null;
		endif;
		if self.invoiceType.isVoyageSpecific() then
			if self.myVoyage &lt;&gt; null then
				return self.myVoyage.code;
			endif;
		elseif self.invoiceType.isVoyageGroupSpecific() then // ### TFS 51219 25MAY2021 NAVAB1
			if self.myVoyage &lt;&gt; null then // ### TFS 51219 25MAY2021 NAVAB1
				return self.myVoyage.voyageGroupCode; // ### TFS 51219 25MAY2021 NAVAB1
			endif;
		elseif self.invoiceType.isCargoItemSpecific() then
			if self.myTrackedItem &lt;&gt; null then
				return self.myTrackedItem.getDisplayDetails(true);
			endif;
		elseif self.invoiceType.isBOLSpecific() then
			if self.myBOL &lt;&gt; null then
				return self.myBOL.number;

			endif;
		endif;
		return null;*/
		return self.getInvoiceTypeSpecifics(); // ### TFS 54565 (54384) 21Sep2022 NAVPW1
		
	elseif _attrName = ETRow_ExternalInvoiceNumber
	    or _attrName = ETRow_InvoiceNumber	then	
		return self.getExternalInvoiceNumber;
	elseif _attrName = ETRow_TotalAmount then																
		return self.getTotalAmount().asStringJMTWithPrecision(2, true);
	elseif _attrName = ETRow_SequenceNum then
		return self.sequenceNum.asStringJMT;
	elseif _attrName = ETRow_IsZeroRated then
		return self.isZeroRatedTax.asStringJMT;
	elseif _attrName = ETRow_Export then
		return true.asStringJMT;
	elseif _attrName = ETRow_Packages then
		dit := self.debtor.allDebtorInvTypes[self.invoiceType];
		if dit &lt;&gt; null then
			foreach package in dit.allPackageInvoices do
				if packageNames = null then
					packageNames := package.code;
				else
					packageNames := packageNames &amp; ", " &amp; package.code;
				endif;
			endforeach;
			
		endif;
		if packageNames = null then																	//navra1 - CR 61910/Task 62303 - 13th Feb 2024
			if localBank &lt;&gt; null then																//navra1 - CR 61910/Task 62303 - 13th Feb 2024
				if localBank.myDefaultPackage &lt;&gt; null then											//navra1 - CR 61910/Task 62303 - 13th Feb 2024
					packageNames := localBank.myDefaultPackage.code &amp; '(DEFAULT PACKAGE)';			//navra1 - CR 61910/Task 62303 - 13th Feb 2024
				endif;																				//navra1 - CR 61910/Task 62303 - 13th Feb 2024
			endif;																					//navra1 - CR 61910/Task 62303 - 13th Feb 2024
		endif;																						//navra1 - CR 61910/Task 62303 - 13th Feb 2024
		return packageNames;
	 // ### JIRA 35466 31JUL2025 NAVAB1
	elseif _attrName = ETRow_StartDate then
		if self.fromDT.isValid then
			return self.systemToLocalTime(self.fromDT).date.asStringJMT;
		else
			return null;
		endif;
	elseif _attrName = ETRow_EndDate then
		if self.toDT.isValid then
			return self.systemToLocalTime(self.toDT).date.asStringJMT;// 14 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
	elseif _attrName = ETRow_RunPackage then
		return null;
	elseif _attrName = ETRow_StatusChangeReason then
		statusChangeAudit:=self.getLastStatusChangeAudit;
		if statusChangeAudit &lt;&gt; null then
			return statusChangeAudit.clearingRemarks;
		endif;
		return null;
	elseif _attrName = ETRow_StatusChangeReasonCode then
		statusChangeAudit:=self.getLastStatusChangeAudit;
		if statusChangeAudit &lt;&gt; null then
			return statusChangeAudit.statusChangeReasonCode;
		endif;
		return null;
		
	elseif _attrName = ETRow_VoyageExternalCode then		// TFS 4894
		if self.myVoyage &lt;&gt; null then						// TFS 4894
			return self.myVoyage.voyageCodeExternal;		// TFS 4894
		else												// TFS 4894
			return null;									// TFS 4894
		endif;												// TFS 4894
		
	//01 Sep 2017	NDL	TFS 6759
	elseif _attrName = ETRow_PostedCreditInv then
		if self.myPostedCreditInvoice &lt;&gt; null then
			return self.myPostedCreditInvoice.sequenceNum.String;
		endif;
		return null;
	
	//01 Sep 2017	NDL	TFS 6759
	elseif _attrName = ETRow_PostedPendingInv then
		if self.myPostedPendingInvoice &lt;&gt; null then
			return self.myPostedPendingInvoice.sequenceNum.String;
		endif;
		return null;
	
	//01 Sep 2017	NDL	TFS 6759
	elseif _attrName = ETRow_ReversedCreditInv then
		if self.myReversedCreditInvoice &lt;&gt; null then
			return self.myReversedCreditInvoice.sequenceNum.String;
		endif;
		return null;
	
	//01 Sep 2017	NDL	TFS 6759
	elseif _attrName = ETRow_ReversedPendingInv then
		if self.myReversedPendingInvoice &lt;&gt; null then
			return self.myReversedPendingInvoice.sequenceNum.String;
		endif;
		return null;
	elseif _attrName = ETRow_DebtorPaymentType then              // 27 Sep 2018  cnwma1	    ChangeRequest 41132
		return app.paymentTypeEnumToString(self.paymentType);
	elseif _attrName = ETRow_PaymentStatus then                 // 27 Sep 2018  cnwma1	    ChangeRequest 41132
		return self.getPaymentStatusStr();
	elseif _attrName = ETRow_SapCustCode then	//21 Nov 2018	NDL	TFS 42116
		return debtor.code;
	elseif _attrName = ETRow_SapCustName then	//21 Nov 2018	NDL	TFS 42116
		return debtor.name;
	elseif _attrName = ETRow_SapVoyCode then	//21 Nov 2018	NDL	TFS 42116
		if self.myVoyage &lt;&gt; null then	
			return self.myVoyage.code;
		else				
			return null;	
		endif;	
	elseif _attrName = ETRow_SapVessName or _attrName = ETRow_VesselName then		//21 Nov 2018	NDL	TFS 42116 
		if self.myVoyage &lt;&gt; null and self.myVoyage.getMyVessel &lt;&gt; null then	        //03/06/2020 cnwma1 Tfs #49400
			return self.myVoyage.getMyVessel.name;
		else				
			return null;	
		endif;
	elseif _attrName = ETRow_VesselCode then	                                   //03/06/2020 cnwma1 Tfs #49400
		if self.myVoyage &lt;&gt; null and self.myVoyage.getMyVessel &lt;&gt; null then	       
			return self.myVoyage.getMyVessel.code;
		else				
			return null;	
		endif;
	elseif _attrName = ETRow_SapAmount then							//21 Nov 2018	NDL	TFS 42116
		return self.getTotalAmountPlusPelindoTax().asStringJMT;
	elseif _attrName = ETRow_SapPreInvNo then						//21 Nov 2018	NDL	TFS 42116

		if self.myPostedPendingInvoice &lt;&gt; null then
			//return self.myPostedPendingInvoice.externalFinancialId;
			return self.myPostedPendingInvoice.getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
		else
			return null;
		endif;
	elseif _attrName = ETRow_SapInvNo or							//21 Nov 2018	NDL	TFS 42116
			_attrName = ETRow_ExternalFinancialID then				//08/12/2025	navkc1 JIRA 36262
		//return self.externalFinancialId;
		return self.getExternalFinancialId();						//08/12/2025	navkc1 JIRA 36262
	elseif _attrName = ETRow_SapInvType then						//21 Nov 2018	NDL	TFS 42116
		if self.invoiceType &lt;&gt; null then
			return self.invoiceType.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_SapTrxDate then	//21 Nov 2018	NDL	TFS 42116
		ts := self.getSapTransactionDTLocalTZ();
		if ts &lt;&gt; null then
			return ts.asStringJMT;
		else
			return null;
		endif;
	elseif _attrName = ETRow_SapVessCargo then		//21 Nov 2018	NDL	TFS 42116
		return self.getSapVesselCargo();
	elseif _attrName = ETRow_SapRPKOPPPKBno then	//21 Nov 2018	NDL	TFS 42116
		return self.getSapRPKOPPPKBNo();
	elseif _attrName = ETRow_SapProdStat then		//21 Nov 2018	NDL	TFS 42116
		return self.getSapProdStatus().asStringJMT;
	elseif _attrName = ETRow_SapSapAmount then		//21 Nov 2018	NDL	TFS 42116
		return self.getSapAmount().asStringJMT;
	elseif _attrName = ETRow_SapRefIdSap then		//21 Nov 2018	NDL	TFS 42116
		return self.getSapRefIdSap;
	elseif _attrName = ETRow_SapSapInvStat then		//21 Nov 2018	NDL	TFS 42116
		return self.getSapInvoiceStaus;
	elseif _attrName = ETRow_SapPerfStat then		//21 Nov 2018	NDL	TFS 42116
		return self.getSapPerformanceStatus();
	elseif _attrName = ETRow_Debtor then 			// TFS 39618
		return debtor.name; 						// TFS 39618
	elseif _attrName = ETRow_BusinessUnit then
		//02/04/2025	navkc1 JIRA Bug MTN-34085
		if localBank &lt;&gt; null then
			return localBank.code;
		endif;
		return null;
	elseif _attrName = ETRow_VoyageOperatorCode then // TFS 39618
		if self.myVoyage &lt;&gt; null and  self.myVoyage.myOperator &lt;&gt; null then
			return self.myVoyage.myOperator.code;
		endif;
		return "";
	elseif _attrName = ETRow_VoyageOperatorDesc then // TFS 39618
		if self.myVoyage &lt;&gt; null and self.myVoyage.myOperator &lt;&gt; null then
			return self.myVoyage.myOperator.description;
		endif;
		return "";
	elseif _attrName = ETRow_VoyageCode then // TFS 39618
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;
		endif;
		return "";
	elseif _attrName = ETRow_VesselName then // TFS 39618
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.vesselCode;
		endif;
		return "";
	elseif _attrName = ETRow_VoyageArrivalDate then 	// TFS 39618
		if self.myVoyage &lt;&gt; null then
			if self.myVoyage.arrivedDT.isValid() then
				return self.systemToLocalTime(self.myVoyage.arrivedDT).asStringJMT;
			endif;
		endif;
		return "";
	elseif _attrName = ETRow_VoyageDepartureDate then 	// TFS 39618
		if self.myVoyage &lt;&gt; null then
			if self.myVoyage.departedDT.isValid() then
				return self.systemToLocalTime(self.myVoyage.departedDT).asStringJMT;
			endif;
		endif;
		return "";
	elseif _attrName = ETRow_DebtorAddInfo1 then 		// TFS 39618
		return self.debtor.additionalInformation1;
	elseif _attrName = ETRow_DebtorAddInfo2 then 		// TFS 39618
		return self.debtor.additionalInformation2;
	elseif _attrName = ETRow_DebtorAccount then 		// TFS 39618
		return self.debtor.decfinName;
	elseif _attrName = ETRow_DebtorLong then 			// TFS 39618
		return self.debtor.longName;
	elseif _attrName = ETRow_DebtorActualCode then 		// TFS 39618
		return self.debtor.code;
	elseif _attrName = ETRow_BillingAddress  then 		//22.07.2019 cnwma1 TFS #45577
		if self.myBillingAddress &lt;&gt; null then
			return self.myBillingAddress.code;
		endif;
	elseif _attrName = ETRow_DebtorAddress then         //22.07.2019 cnwma1 TFS #45577
		if self.myBillingAddress &lt;&gt; null then
			return self.myBillingAddress.description;
		elseif self.debtor.getDefaultDebtorAddress &lt;&gt; null then
			return  self.debtor.getDefaultDebtorAddress.description;
		endif;
	// ### TFS 54564 (54381) 19Aug2022 NAVPW1
	elseif _attrName = ETRow_AlternativeAddress then
		debtorAltAddress := self.debtor.getDebtorAlternativeAddress;
		
		if self.myAlternativeAddress &lt;&gt; null then
			return self.myAlternativeAddress.description;
			
		elseif debtorAltAddress &lt;&gt; null then
			return debtorAltAddress.description;
			
		endif;
	// ### TFS 54564 (54381) 19Aug2022 NAVPW1
	// ### TFS 54564 (54382) 22Aug2022 NAVPW1
	elseif _attrName = ETRow_CurrencyType then
		debtorCurrencyType := self.debtor.getDebtorCurrencyType();
		
		if self.myCurrencyType &lt;&gt; null then
			return self.myCurrencyType.code;
			
		elseif debtorCurrencyType &lt;&gt; null then
			return debtorCurrencyType.code;
			
		endif;
	// ### TFS 54564 (54382) 22Aug2022 NAVPW1
	elseif _attrName = ETRow_ExportCount then			//22.07.2019 cnwma1 TFS #45577
		return self.exportedCount.String;
	elseif _attrName = ETRow_VoyageGroupCode then		//03/06/2020 cnwma1 Bug #49400
		return self.voyageGroupCode; 
	elseif _attrName = ETRow_ReceiveStevedore then     //02.10.2020 cnwma1 TFS #50112
		// TFS 53362 start
		stevedoreCode := self.getStevedoreCode();
		if app.myRoot.getConfig(ComboByNameStevedore).Boolean and stevedoreCode &lt;&gt; null then
			stevedoreObj := app.myRoot.allStevedores[stevedoreCode];
			if stevedoreObj &lt;&gt; null then
				return stevedoreObj.description;
			endif;
		endif;
		//return self.getStevedoreCode();
		return stevedoreCode;
		// TFS 53362 end
	elseif _attrName = ETRow_TotalAmountRounded then   //11.03.2021 cnwma1 TFS #50925
		if self.myTerminal &lt;&gt; null then
			roundDecimalOpt := self.myTerminal.getConfig(InvoiceRoundLineTotal).Integer;
		endif;
		return self.getTotalAmount().asStringJMTWithPrecision(roundDecimalOpt, true);
	elseif _attrName = ETRow_WorkOrders then 			//16.12.2021 navma1 #52580
		return self.allWorkOrders.listString(Comma,CM_WorkOrder::id.name);
	elseif _attrName = ETRow_InvoiceNoteNotes then 			// ### TFS 52752 04Feb2022 NAVPW1
		if self.myInvoiceNote &lt;&gt; null then
			return self.myInvoiceNote.note.formatWithEllipsis(1, 100, true);
		endif;
	elseif _attrName = ETRow_InvoiceNoteInternal then 		// ### TFS 52752 04Feb2022 NAVPW1
		if self.myInvoiceNote &lt;&gt; null then
			return self.myInvoiceNote.internalOnly.String;
		endif;
	elseif _attrName = ETRow_CargoShippingLineCode then 	// Jun 1, 2022 navak20 TFS 53204
		foreach invLine in self.invoiceLines where invLine.trackedItem &lt;&gt; null do
			return invLine.getDisplayStringForAttribute(_attrName, _short);
		endforeach;
	elseif _attrName = ETRow_CargoShippingLineDesc then		// // Jun 1, 2022 navak20 TFS 53204
		foreach invLine in self.invoiceLines where invLine.trackedItem &lt;&gt; null do
			return invLine.getDisplayStringForAttribute(_attrName, _short);  
		endforeach;
	// ### TFS 54564 (54383) 31Aug2022 NAVPW1
	elseif _attrName = ETRow_Locale then
		if self.myLocale &lt;&gt; null then
			return self.myLocale.localeDescription;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Currency then
		if self.myCurrencyType &lt;&gt; null then
			return self.myCurrencyType.code;
		else
			return null;
		endif;
	// ### TFS 54564 (54383) 31Aug2022 NAVPW1
	//01.12.2022 navtnr20  TFS 55552
	elseif _attrName = ETRow_Category then
		return self.getCategory();
	elseif _attrName = ETRow_HasAttachments then
		return self.hasAttachment().asStringJMT;
	elseif	_attrName = ETRow_OtherInvoices then
		return self.otherInvoices();
	elseif	_attrName = ETRow_OtherInvoicesExternal then
		return self.getOtherInvoicesExternal();
	elseif _attrName = ETRow_ExternalNumber then
		return self.getExternalNumber();
	//01.12.2022 navtnr20 TFS 55552
	elseif _attrName = ETRow_InvoiceContractId then//21.02.2023 navtnr20 TFS CR 55648 Task 55663
		return self.contractIds;
	elseif _attrName = ETRow_ExternalInterfaceStatus then //jlier1 TFS 56856 3/4/23
		return self.externalIntefaceStatus;
	elseif _attrName = ETRow_CreditNoteStartDate then //14/08/2023	navkc1	Bug 59803
		if self.isCreditNote() then
			return app.systemToLocalTime(fromDT).date().asStringJMT();
		else
			return null;
		endif;
	elseif _attrName = ETRow_CreditNoteStartTime then //14/08/2023	navkc1	Bug 59803
		if self.isCreditNote() then
			return app.systemToLocalTime(fromDT).time().asStringJMT();
		else
			return null;
		endif;
	elseif _attrName = ETRow_CreditNoteEndDate then //14/08/2023	navkc1	Bug 59803
		if self.isCreditNote() then
			return app.systemToLocalTime(toDT).date().asStringJMT();
		else
			return null;
		endif;
	elseif _attrName = ETRow_StatusInvoiceManual then //14/08/2023	navkc1	Bug 59803
		if self.isCreditNote() then
			return self.getStatusDescriptionForSelf();
		else
			return null;
		endif;
	elseif _attrName = ETRow_TaxCodeStatic then // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
		return self.taxCodes;
	elseif _attrName = ETRow_TaxDescriptionStatic then // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1 
		return self.taxDescriptions;
	elseif _attrName = ETRow_TaxRateStatic then // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
		return self.taxRates;
	elseif _attrName = ETRow_TaxValueStatic then	// ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
		return self.taxValue.asStringJMTWithPrecision(2,true);
	elseif _attrName = ETRow_TaxCode then				//18.8.2023 navlc30 #59481
		return self.getTaxCodesDescAsString(false);
	elseif _attrName = ETRow_TaxDescription then		//18.8.2023 navlc30 #59481
		return self.getTaxCodesDescAsString(true);
	elseif _attrName = ETRow_TaxRate then				//18.8.2023 navlc30 #59481
		return self.getTaxRatesAsString();
	elseif _attrName = ETRow_TaxValue then				//18.8.2023 navlc30 #59481
		return self.getTotalTaxValueAsString();
	elseif _attrName = ETRow_InvoiceNarration then		// 05/09/2023 navcs2	Bug 59959
		return self.narration;							// 05/09/2023 navcs2	Bug 59959
	elseif _attrName = ETRow_InvoicesCopiedFrom then //09/08/2024	navkc1 CR 64894 Task 64895
		return self.getInvoiceCopiedFromStr();
	elseif _attrName = ETRow_InvoicesCopiedTo then //09/08/2024	navkc1 CR 64894 Task 64895
		return self.getInvoicesCopiedToStr();
	elseif _attrName = ETRow_CNotesCopiedFrom then //09/08/2024	navkc1 CR 64894 Task 64895
		return self.getCNotesCopiedFromStr();
	elseif _attrName = ETRow_CNotesCopiedTo then //09/08/2024	navkc1 CR 64894 Task 64895
		return self.getCNotesCopiedToStr();
	elseif _attrName = ETRow_InvoicesCopiedFromExt then //09/08/2024	navkc1 CR 64894 Task 64895
		return self.getInvoiceCopiedFromExtStr();
	elseif _attrName = ETRow_InvoicesCopiedToExt then //09/08/2024	navkc1 CR 64894 Task 64895
		return self.getInvoicesCopiedToExtStr();
	elseif _attrName = ETRow_CNotesCopiedFromExt then //09/08/2024	navkc1 CR 64894 Task 64895
		return self.getCNotesCopiedFromExtStr();
	elseif _attrName = ETRow_CNotesCopiedToExt then //09/08/2024	navkc1 CR 64894 Task 64895
		return self.getCNotesCopiedToExtStr();
	elseif _attrName = ETRow_MergedIntoExt then //16/10/2024	navkc1	JIRA Bug MTN-12545
		if self.myMergeInvoice &lt;&gt; null then
			return self.myMergeInvoice.externalNumber.asStringJMT();
		endif;
		return null;
	elseif _attrName = ETRow_MergedInvoicesExt then //16/10/2024	navkc1	JIRA Bug MTN-12545
		return self.getAllMergeInvoicesExtSql();
	elseif _attrName = ETRow_ExternalTaxNumber then 
		return self.externalTaxNumber; //08/12/2025	navkc1 JIRA 36262
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
