/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023		navma1	Initial creation

*/

vars

begin
	if _status = CM_VehicleBookingTimeSlot.AvailableNotBookedInt then
		return CM_VehicleBookingTimeSlot.AvailableNotBooked;
	elseif _status =  CM_VehicleBookingTimeSlot.BookedNotYetDueInt then
		return  CM_VehicleBookingTimeSlot.BookedNotYetDue;
	elseif _status =  CM_VehicleBookingTimeSlot.BookedOverdueInt then
		return  CM_VehicleBookingTimeSlot.BookedOverdue;
	elseif _status =  CM_VehicleBookingTimeSlot.BookedCurrentInt then
		return  CM_VehicleBookingTimeSlot.BookedCurrent;
	elseif _status =  CM_VehicleBookingTimeSlot.BookedArrivedEarlyInt then
		return CM_VehicleBookingTimeSlot.BookedArrivedEarly;
	elseif _status =  CM_VehicleBookingTimeSlot.BookedArrivedLateInt then
		return CM_VehicleBookingTimeSlot.BookedArrivedLate;
	elseif _status =  CM_VehicleBookingTimeSlot.BookedArrivedOntimeInt then
		return CM_VehicleBookingTimeSlot.BookedArrivedOntime;
	elseif _status =  CM_VehicleBookingTimeSlot.NoLongerAvailInt then
		return CM_VehicleBookingTimeSlot.NoLongerAvail;
	else
		return null;
	endif;
epilog

end;</source>
