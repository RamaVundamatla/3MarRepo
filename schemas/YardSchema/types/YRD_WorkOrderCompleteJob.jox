    <JadeMethod name="isCargoTodoWOJob" id="0fb33247-d8cb-4dd0-94ab-e21c93b004c4">
        <source>isCargoTodoWOJob():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2024	navbs1	Initial creation Bug MTN-33403: EUP - New To Do Complete form is not available for non-cargo To Do Task jobs

*/

vars
	todoJob :CM_WOToDoTaskJob;
begin
	if not self.myJob.isKindOf(CM_WOToDoTaskJob) then 
		return false;
	endif;
	
	todoJob := self.myJob.CM_WOToDoTaskJob;
		
