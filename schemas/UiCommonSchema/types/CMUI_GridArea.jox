    <JadeMethod name="getSelectedStartXEndYPoints" id="40642087-5a77-4bde-ae37-9a3adb8a6564">
        <source>getSelectedStartXEndYPoints(_xPoint, _yPoint : Real io);

/*

Purpose:		Get the left most selected position and the right most selected point	

Date			Who		Reason
07/11/2012		cnwmh5	Initial creation

*/

vars
	gridPoint 					: CMUI_GridPoint;
begin

	foreach gridPoint in self.allSelectedPoints do
		if gridPoint.myGridColumn &lt;&gt; null then
			_xPoint := _xPoint.min(gridPoint.x1);
			_yPoint := _yPoint.max(gridPoint.x2);
		endif;	
	endforeach;

epilog

end;</source>
        <Parameter name="_xPoint" type="Real" usage="io"/>
        <Parameter name="_yPoint" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXsYs" id="2cd0f5f0-75c4-4442-81b9-c0669310ced8">
        <source>getXsYs(_x1 : Integer output;_x2 : Integer output;_y1 : Integer output;_y2 : Integer output);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_x2 := self.mySDF.allColumnEndPositions[self.column].Integer;
	if self.column = 1 then
		_x1 := 0;
	else
		_x1 := self.mySDF.allColumnEndPositions[self.column  - 1].Integer;
	endif;
//	_x1 := _x2 - self.mySDF.getColumnWidth(self.column).Integer;
	_y2 := self.mySDF.allRowEndPositions[self.row].Integer;
	if self.row = 1 then
		_y1 := 0;
	else
		_y1 := self.mySDF.allRowEndPositions[self.row - 1].Integer;
	endif;
//	_y1 := _y2 - self.mySDF.getRowHeight(self.row).Integer;
end;</source>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="gridXMLcreate" id="b08b3377-e9b7-4f19-a2bd-822ce873300f">
        <source>gridXMLcreate();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
