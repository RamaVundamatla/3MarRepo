	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	create slots transient;
	create tiArray transient;
	
	// set up the areas and containers on the voyage
	if voyage.myROROStructure &lt;&gt; null then
		voyageDeck := voyage.myROROStructure.allDecksByCode[DeckName];
		///if voyageDeck &lt;&gt; null then
			
			
			// setup and check OOTL 20'
			///voyageDeck.myVoyageStructure.createQuickCargoOOTL(null, false, 12, 0, voyageDeck, 2); // 2 X 20
			///self.assertNoTrxErrorsOrWarnings();
			//locnDefnVoyage := voyageDeck.allROROLocnDefnByCode["D4339O"].CM_ROROLocnDefnVoyage;
			//tiArray.clear();
			//locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
