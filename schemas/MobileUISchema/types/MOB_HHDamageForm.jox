    <JadeMethod name="handleBtnTwo" id="0e05c06b-5eb1-477a-ab57-ebe3d3dab63b">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*
Date		Who		Reason
28 January 2009	cnwcp2	Initial creation
16 Martch 2009	cnwcp2	Now re-display the table completly. Prevents extra blank lines
*/

vars

begin

	// 37244 from to-do completion this is the Back button
	if self.myToDoTaskDesc = null then
		self.displayDamages();
	else
		self.getSessionAgent.setMyProxy(null);		// delete any proxy TI
		self.unloadForm();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleWarnings" id="9a66fc31-5d7f-46d0-8249-7a68dcfbd666">
        <source>handleWarnings(_exObj : Exception; _passport : CM_Passport input) : Integer protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/10/2016	cnwdap1		Initial creation TFS 2788
//
vars

begin
	if _passport = null then
		return Ex_Pass_Back;
	endif;

	if _exObj.isKindOf(CM_Exception) and _exObj.CM_Exception.isWarning then
		_passport.addWarningFull(_exObj.errorCode, _exObj.extendedErrorText, _exObj.CM_Exception.userString, _exObj.CM_Exception.myUserObject, _exObj.CM_Exception.mySubject);
		return Ex_Continue;
	endif;
	
	return Ex_Pass_Back;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
