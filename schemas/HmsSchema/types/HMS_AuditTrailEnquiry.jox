Return Value:		


Date		Who		Reason
01 Apr 2008	cnwkpd1	PAR #16374 - Add extract table option

*/

vars

begin
	self.doExportCSV();
	
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
