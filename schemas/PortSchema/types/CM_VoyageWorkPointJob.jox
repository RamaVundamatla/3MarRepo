    <JadeMethod name="getType" id="c6cc22c1-eca5-4ef9-9e41-d119c5198267">
        <source>getType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds

*/

vars
	wod 	 : CM_WorkOrderTIDtl;
	transStr : String;
begin
	wod := self.myWODtl;
	
	if wod = null then
		return null;
	endif;
	
	if wod.isKindOf(CM_WodReceive) then
		transStr := app.transportModeENumToString(wod.CM_WodReceive.transport);
		return 'Unload' &amp; Space &amp; transStr;
	elseif wod.isKindOf(CM_WodRelease) then
		transStr := app.transportModeENumToString(wod.CM_WodRelease.transport);
		return 'Load' &amp; Space &amp; transStr;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageHold" id="4025950c-ce6e-49a4-944c-7dec9e07cbc6">
        <source>getVoyageHold():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jan 2023 navhl20 Defect 61894: EUP - Ship Operations - Voyage Hold entered on the Add Jobs Details form is not saving the details correctly.
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	req	: CM_HoldRequest;
begin
	req := self.allRequests.first.CM_HoldRequest;
	if req &lt;&gt; null then
		if req.myHoldControllerDischarge &lt;&gt; null then
			return req.myHoldControllerDischarge.getFullId();
		endif;
		if req.myHoldControllerLoad &lt;&gt; null then
			return req.myHoldControllerLoad.getFullId();
		endif;
	endif;
	if self.myWorkOrderReceiveJob &lt;&gt; null then
		return self.myWorkOrderReceiveJob.getHolds();
	endif;
	if self.myWorkOrderReleaseJob &lt;&gt; null then
		return self.myWorkOrderReleaseJob.getHolds();
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
