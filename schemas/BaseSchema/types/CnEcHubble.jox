    <JadeMethod name="updateMe" id="20b0e3c4-feac-43f5-ab28-e3c98f0dded8">
        <updating/>
        <source>updateMe(	pErrorFileName:String;
			pInputFileName:String;
			pLogFileName:String;
			pOutputFileName:String;
			pMyOidTableRoot:CnEcOidTable;
			pAllExportObjects:Collection) updating;

begin
	if self.errorFileName &lt;&gt; pErrorFileName then
		self.errorFileName := pErrorFileName;
	endif;
	
	if self.inputFileName &lt;&gt; pInputFileName then
		self.inputFileName := pInputFileName;
	endif;
	
	if self.logFileName &lt;&gt; pLogFileName then 
		self.logFileName := pLogFileName;
	endif;
	
	if self.outputFileName &lt;&gt; pOutputFileName then
		self.outputFileName := pOutputFileName;
	endif;
	
	if self.myOidTable &lt;&gt; pMyOidTableRoot then
		self.myOidTable := pMyOidTableRoot;
	endif;
	
	if self.allExportObjects &lt;&gt; pAllExportObjects then
		self.allExportObjects := pAllExportObjects;
	endif;				
end;</source>
        <Parameter name="pErrorFileName" type="String"/>
        <Parameter name="pInputFileName" type="String"/>
        <Parameter name="pLogFileName" type="String"/>
        <Parameter name="pOutputFileName" type="String"/>
        <Parameter name="pMyOidTableRoot" type="CnEcOidTable"/>
        <Parameter name="pAllExportObjects" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="writeSingletonErrorFile" id="7d6de74e-84ba-4e4e-8ad1-702cf04bca70">
        <source>writeSingletonErrorFile(pLogFile : File io) protected;
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	hubble		: CnEcHubble;
	outputFile	: String;
	oidTable	: CnEcOidTable;
	pMsg		: CnEcXmlStructureInstance;
	iter		: Iterator;
	object		: Object;
	file 		: File; 
	
begin
	if self.allRejectedMessages.size() &gt; 0 then
   		create file;
   		file.fileName := self.errorFileName; 
   		logMessage(pLogFile, "Creating Error file. - " &amp; self.errorFileName &amp; " - " &amp; app.actualTimeServer().String);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

   		foreach pMsg in self.allRejectedMessages do
   			file.writeLine(pMsg.errorFormat());
			self.allRejectedMessages.remove(pMsg);
   			delete pMsg;	
   		endforeach;	
	endif;
epilog
	delete file;		 
end;</source>
        <access>protected</access>
        <Parameter name="pLogFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xmlParse" id="46902bbd-ae32-4bca-9ae9-104a93048284">
        <updating/>
        <source>xmlParse(pTagData : String; pMsgInst : CnEcXmlGroupInstance io ) : Integer updating, protected;

vars
//	xmlParser	: CnEcXMLParser;
	index		: Integer;
	tagData		: String;
	
begin
//	create xmlParser transient;
	index := 1;
    tagData := pTagData;
//	return xmlParser.parseRecursive(tagData, pMsgInst, index);
	return self.myParser.parseRecursive(tagData, pMsgInst, index);
epilog
//	delete xmlParser;
end;</source>
        <access>protected</access>
        <Parameter name="pTagData" type="String"/>
        <Parameter name="pMsgInst" type="CnEcXmlGroupInstance" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
