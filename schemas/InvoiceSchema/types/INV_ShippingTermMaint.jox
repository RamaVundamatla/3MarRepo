        <source>setBusinessUnit() updating;
/*
Purpose:			

Date		Who		Reason

*/

vars
	shipTerm : CM_InvoiceShipTermMapping;
begin
	self.endNotificationForSubscriber(self.myCurrentBank);

	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvShipMappingCreate), Response_Continuous, null);
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvShipMappingUpdate), Response_Continuous, null);
