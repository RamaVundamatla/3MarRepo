    <JadeMethod name="mpdGetAllFormsForName" id="95ebc95a-e1de-4063-b145-ecfb503a0ae2">
        <source>mpdGetAllFormsForName();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 May 2022	navmd1	Initial creation

*/

constants
	FORM_NAME	: String = "CM_ContainerEnqForm";
vars
	oa : ObjectArray;
	form : Form;
begin
	create oa transient;
	Form.allInstances(oa, 0, true);
	
	foreach form in oa as Form do
