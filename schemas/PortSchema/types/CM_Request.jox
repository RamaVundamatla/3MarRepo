    <JadeMethod name="createBulkReleaseFromSelf" id="9c8a50b7-eab2-4437-a776-0a35d378093b">
        <updating/>
        <source>createBulkReleaseFromSelf(_passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
vars
begin

	if self.myTerminal.getConfig(DoNotCreateBulkRelease).Boolean then
		// Par 8380
		return;
	endif;
		
	if self.myOriginatingBulkRelease &lt;&gt; null then
		// Already has a bulk release	
		return;
	endif;
	
	if (not self.isReleaseType()) then
		// Don't create bulk release for receipt jobs.	
		return;
	endif;

	//epr par 12720 11/10/06
	if self.myJob = null then
		return;
	endif;
	
	// Par 8380	- Now
	self.setMyOriginatingBulkRelease(self.createBulkRelease(_passport));
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
