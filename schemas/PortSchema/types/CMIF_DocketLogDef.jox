    <JadeMethod name="init" id="dd15c451-a648-4c41-9cef-ea7187a44757">
        <updating/>
        <source>init(_locationsController	: CM_LocationsController;
	 _operator 				: CM_Operator;
	 _species,
	 _grade,
	 _type,
	 _treatment,
	 _length				: String;
	 _isNoNumber			: Boolean;
	 _numberOfLogs			: Integer;
	 _volume				: Real;
	  _bol					: CM_BOL) updating;

vars

begin

	self.myLocationsController	:= _locationsController;
	self.id					:= self.myLocationsController.getID();
	self.myOperator			:= _operator;
	self.species			:= _species;
	self.grade				:= _grade;
	self.type				:= _type;
	self.treatment			:= _treatment;
	self.length				:= _length;
	self.isNoNumber			:= _isNoNumber;
	self.numberOfLogs		:= _numberOfLogs;
	self.volume				:= _volume;
	self.myBol				:= _bol;

end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_species" type="String"/>
        <Parameter name="_grade" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_treatment" type="String"/>
        <Parameter name="_length" type="String"/>
        <Parameter name="_isNoNumber" type="Boolean"/>
        <Parameter name="_numberOfLogs" type="Integer"/>
        <Parameter name="_volume" type="Real"/>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
</Class>
