    <JadeMethod name="setProxyVesselFromXML" id="eb1d6527-27a1-4ff1-abcd-1cfc43269ea4">
        <updating/>
        <source>setProxyVesselFromXML(_theXML : String) updating;
//--------------------------------------------------
// Created:	07 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	pos : Integer;
	tmpCode,
	tmpStr : String;
	tmpShipLine : CM_ShippingLine;
	tmpHarbour : HMS_Harbour;
	tmpRoot : CM_Root;
	pxyVDH : HMS_VesselDataHarbour;
begin
	
	if _theXML = null then
		return;
	endif;
	
	tmpRoot := app.myRoot;
	
	self.coastalServiceVessel := _theXML.cnEcGetTagValueOfName('csv').Integer.Boolean;
	self.countryCode := _theXML.cnEcGetTagValueOfName('ccd');

	self.dim_Beam := _theXML.cnEcGetTagValueOfName('db').Integer;
	self.dim_DeadWeight := _theXML.cnEcGetTagValueOfName('dw').Integer;
	self.dim_DraftAft := _theXML.cnEcGetTagValueOfName('da').Integer;
	self.dim_DraftFore := _theXML.cnEcGetTagValueOfName('df').Integer;
	self.dim_GrossRegTonnes := _theXML.cnEcGetTagValueOfName('dg').Integer;
	self.dim_NetRegTonnes := _theXML.cnEcGetTagValueOfName('dn').Integer;		// QNS 2178
	self.dim_LengthOverall := _theXML.cnEcGetTagValueOfName('dl').Integer;

	self.dist_BowToFwdContainer := _theXML.cnEcGetTagValueOfName('bf').Integer;
	self.dist_BridgeToBow := _theXML.cnEcGetTagValueOfName('bb').Integer;
	self.dist_BridgeToStern := _theXML.cnEcGetTagValueOfName('bs').Integer;
	self.dist_SternToAftContainer := _theXML.cnEcGetTagValueOfName('sa').Integer;
	self.dist_SternToBunker := _theXML.cnEcGetTagValueOfName('sb').Integer;

	self.hasBowThrust := _theXML.cnEcGetTagValueOfName('hb').Integer.Boolean;
	self.hasFixedProp := _theXML.cnEcGetTagValueOfName('hf').Integer.Boolean;
	self.hasHoldTanks := _theXML.cnEcGetTagValueOfName('ht').Integer.Boolean;
	self.hasRamp := _theXML.cnEcGetTagValueOfName('hr').Integer.Boolean;
	self.hasSternThrust := _theXML.cnEcGetTagValueOfName('hs').Integer.Boolean;

	self.remarksGeneral := _theXML.cnEcGetTagValueOfName('rg');
	self.requiresTow := _theXML.cnEcGetTagValueOfName('rt').Integer.Boolean;	//21 Aug 2018	NDL	TFS 40347
	self.isTramper := _theXML.cnEcGetTagValueOfName('tr').Integer.Boolean;		//11 Sep 2018	NDL	TFS 40778
	
	tmpCode := _theXML.cnEcGetTagValueOfName('sl');
	if tmpCode &lt;&gt; null then
		self.myDefaultShippingLine := tmpRoot.allShippingLines[tmpCode];
	endif;

	tmpCode := _theXML.cnEcGetTagValueOfName('st');
	if tmpCode &lt;&gt; null then	
		self.myVesselType := tmpRoot.allVesselTypes[tmpCode];
	endif;

	if tmpRoot.allHarbours.isEmpty() then
		// no harbour
		return;
	endif;

	// create vessel data for harbour	
	pos := 1;
	while (pos &gt; 0) do
		tmpStr := _theXML.cnEcGetNextTagValueOfName("VDH", pos); 
		if tmpStr = null then
			break;
		endif;
		
		tmpCode := tmpStr.cnEcGetTagValueOfName("mh");
		if tmpCode &lt;&gt; null then
			tmpHarbour := tmpRoot.allHarbours[tmpCode];
		endif;
		if tmpHarbour = null then
			continue;
		endif;
		
		if self.allVesselDataForHarbour[tmpHarbour] &lt;&gt; null then
			// one already exists for this harbour
			continue;
		endif;
		
		create pxyVDH transient;
		pxyVDH.setProxyVDHFromXML(tmpStr, tmpHarbour);
		self.allVesselDataForHarbour.add(pxyVDH);
	endwhile;
	
end;</source>
        <Parameter name="_theXML" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageHMSData" id="f1c6d04c-22a4-4f68-b6bb-6cdc4f37f163">
        <source>setProxyVoyageHMSData(	_pxyVoyageHMSData : HMS_VoyageData input;
						_defaultBerthFromTerminal : Boolean;
						_terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/03/2018	jlger1	Initial creation  tfs 37663 web portal create
23/11/2018	jlgdap1	Initial creation TFS 41949 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyagevars
31/12/2025	navpw1	JIRA: MTN-36175 - Fixed berth preference already exists error message as this is an automated process when changing the voyage vessel.
										So therefore we now check if it already exists before creating the transient

*/

vars
	vesselHarbourDetails	: HMS_VesselDataHarbour;
	berth					: HMS_Berth;
	
	berthPriority			: Integer;
	shippingAgent			: CM_ShippingAgent;
	estTieUpTime,
	numLCrewLetGo,
	numLCrewTieUp,
	numTugsIn,
	numTugsOut				: Integer;
	pxyPref					: HMS_BerthPreferenceVoyageData; 
	berthPref,
	existingBerthPref		: HMS_BerthPreference;
	tidalClassArrive,
	tidalClassDepart		: HMS_TidalClass;
	
begin
	if _pxyVoyageHMSData = null then
		return;
	endif;
	
	vesselHarbourDetails:= self.allVesselDataForHarbour[_terminal.myHarbour];
	
	if vesselHarbourDetails &lt;&gt; null then
		berth:= vesselHarbourDetails.getDefaultBerth();
		berthPriority:= vesselHarbourDetails.berthPriority;
		shippingAgent:=vesselHarbourDetails.myShippingAgent;
		estTieUpTime := vesselHarbourDetails.estTieUpTime;
		tidalClassArrive:=vesselHarbourDetails.myTidalClassArrival;
		tidalClassDepart:=vesselHarbourDetails.myTidalClassDeparture;
	else
	
		if not self.allVesselDataForHarbour.isEmpty then	//19 Apr 2018	NDL	TFS 38135
			tidalClassArrive := self.allVesselDataForHarbour.first.myTidalClassArrival;	
			tidalClassDepart := self.allVesselDataForHarbour.first.myTidalClassDeparture;	
		endif;
	endif;
	//jlier1 TFS 52194 21/10/21
	if _defaultBerthFromTerminal then
		berth:=null;
	endif;
	if berth = null then
		berth:=_terminal.myHarbour.getDefaultBerthForMoveType(HMSMovementTypeArrival);
	endif;
	
	_pxyVoyageHMSData.setProxy(self.coastalServiceVessel,
							false,
							self.hasBowThrust,
							self.hasFixedProp,						
							self.hasHoldTanks,
							self.hasRamp,
							self.hasSternThrust,
							false, //pilot exempt
							null, //pilot
							null, //master
							self.remarksGeneral,
							null, //remarks pilot
							self.remarksPreviousNames,
							self.countryCode,
							null, //from port
							null, //to port
							null, //remarks voyage
							self.dim_Beam,
							self.dim_DraftAft,
							self.dim_DraftFore,
							self.dim_LengthOverall,
							self.dim_DeadWeight,
							self.dim_GrossRegTonnes,
							self.dim_NetRegTonnes,
							dist_BowToFwdContainer,
							dist_BridgeToBow,
							dist_BridgeToStern,
							dist_SternToAftContainer,
							dist_SternToBunker,
							estTieUpTime,
							numLCrewLetGo,
							numLCrewTieUp,
							numTugsIn,
							numTugsOut,
							null,//_pxyVoyageData.voyageStatus,
							berthPriority, //berthPriority,
							berth, //berth,
							_terminal.myHarbour, //tmpHarbour,
							self.myDefaultLineCompany,
							self.myDefaultShippingLine,
							shippingAgent, //self.cmbShippingAgent.listObject.CM_ShippingAgent,
							self.myVesselCategoryIn,
							self.myVesselCategoryOut,
							self.myVesselType, //self.cmbShipType.listObject.HMS_VesselType,
							tidalClassArrive,
							tidalClassDepart,
							null, //self.cmbVisitType.listObject.HMS_VisitType);
							self.requiresTow,	//requiresTow : Boolean;
							false,	//is ZeroRatedTax : Boolean 12 Jun 2018	NDL	TFS 39141
							false	//isZeroRatedCargo : Boolean		// TFS 41949
							);
							
	if vesselHarbourDetails &lt;&gt; null then						
		foreach berthPref in vesselHarbourDetails.allBerthPrefByOrder do :outerLoop
			// ### JIRA: MTN-36175 31Dec2025 NAVPW1
			//Add check to see if berthPref already exists on voyage. If it does then skip generating a transient
			foreach existingBerthPref in _pxyVoyageHMSData.allBerthPreferencesArray do :innerLoop
				if berthPref.berthName = existingBerthPref.berthName then //We don't want to add a berth that has already been added to the voyage
					continue outerLoop;
				endif;
			endforeach;
			// ### JIRA: MTN-36175 31Dec2025 NAVPW1
			
			create pxyPref transient;
			pxyPref.setProxy(berthPref.defaultBowMark,
									 berthPref.defaultBridgeMark, 
									 berthPref.defaultSternMark, 
									 berthPref.orientation, 
									 berthPref.getMyBerth, 									 
									 app.myPassport);
									 
					
			_pxyVoyageHMSData.allBerthPreferencesArray.add(pxyPref);
		endforeach;	
		
		vesselHarbourDetails.setProxyResourceType(_pxyVoyageHMSData,HMSMovementTypeArrival);
		vesselHarbourDetails.setProxyResourceType(_pxyVoyageHMSData,HMSMovementTypeShift);
		vesselHarbourDetails.setProxyResourceType(_pxyVoyageHMSData,HMSMovementTypeDeparture);
		
	
	endif;
	//jlier1 TFS 51963 8/10/21
	if _pxyVoyageHMSData.allVoyageMovements.isEmpty then
		_pxyVoyageHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
	endif;
epilog

end;</source>
        <Parameter name="_pxyVoyageHMSData" type="HMS_VoyageData" usage="input"/>
        <Parameter name="_defaultBerthFromTerminal" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setPxyMyRoot" id="9dfdb0d7-542c-48a3-8895-7b8d2b91d961">
        <updating/>
        <source>setPxyMyRoot(_root : CM_Root) updating;
//-----------------------------------------
// Created: December 2004 By: cnwgd1
