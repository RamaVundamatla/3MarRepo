    <JadeMethod name="canResize" id="718b2001-1789-4230-ab57-d1abdcf7b943">
        <updating/>
        <source>canResize(_xOffset, _yOffset : Integer; _minWidth, _minHeight : Integer output): Boolean updating;
//28 September 2009	cnwdw1	
//
vars

begin
	return true;
end;</source>
        <Parameter name="_xOffset" type="Integer"/>
        <Parameter name="_yOffset" type="Integer"/>
        <Parameter name="_minWidth" type="Integer" usage="output"/>
        <Parameter name="_minHeight" type="Integer" usage="output"/>
