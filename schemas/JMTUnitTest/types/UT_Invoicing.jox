    <JadeMethod name="tMultipleQuantityWeightRange" id="af2b75b4-d852-4fd7-850f-c887e5fb86d2">
        <updating/>
        <source>tMultipleQuantityWeightRange() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:    June 2014

Purpose:    Replace manual test for multiple quantity range using cargo weight.
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	date	: Date;
	ts		: TimeStamp;
	count	: Integer;
	cargoMap	: CM_TranMap;
	service1,
	service2,
	service3	: CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
  	invLineType2,
	invLineType3	: CM_InvoiceLineDesc;
	invoice		: CM_Invoice;
	invoiceLine	: CM_InvoiceLine;
	services : CM_ServiceByNameDict;
	operator	: CM_Operator;
	bs: CM_BlockStack;
	termArea	: CM_TerminalArea;
	loc		: CM_LocationsController;
	grid : CM_GridController;
	voy : CM_Voyage;
	cargo1,
	cargo2,
	cargo3	: CM_TrackedItem;
	aPort : CM_Port;
	trans : CM_TransactionSet;
	tran : CM_TITransaction;
begin

	self.deleteTransactionMaps();

	// block stack
	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteInvoiceTransactionMap(1, 'UT_CargoMultiWeight');
	self.deleteInvoiceType("UT_InvTypeWeight");
	self.deleteInvoiceService("UT_ServiceWeight1", FORCED_ERASE);
	self.deleteInvoiceService("UT_ServiceWeight2", FORCED_ERASE);
	self.deleteInvoiceService("UT_ServiceWeight3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight3", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Types
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeWeight", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeWeight not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT04'];
	self.assertNotNullMsg(calType1, "Calculation type CCT04 not found");
	
	service1 := self.createInvoiceService("UT_ServiceWeight1","weight1", calType1, null);
	self.assertNotNullMsg(service1, "UT_ServiceWeight1 not created");
 	services.add(service1);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeWeight1", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeWeight1 not created");

	service2 := self.createInvoiceService("UT_ServiceWeight2","weight2", calType1, null);
	self.assertNotNullMsg(service2, "UT_ServiceWeight2 not created");
	services.clear();
 	services.add(service2);
	
	invLineType2 := self.createInvoiceLineType("UT_LineTypeWeight2", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeWeight2 not created");

	service3 := self.createInvoiceService("UT_ServiceWeight3","weight3", calType1, null);
	self.assertNotNullMsg(service3, "UT_ServiceWeight3 not created");
	services.clear();
 	services.add(service3);
	
	invLineType3 := self.createInvoiceLineType("UT_LineTypeWeight3", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeWeight3 not created");

	// Need to map to above invoice line types
	self.tranMapLoadMultiCargoWeight();
	
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	cargo1 := self.addContainerAtLocation("UACU7894561", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs);
	// this has weight of 2100
	self.opts.addAssoc("TotalWeight", "2100");
	self.updateTrackedItem(cargo1);

	cargo2 := self.addContainerAtLocation("UACU7894562", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs);
	self.opts.addAssoc("TotalWeight", "4000");
	self.updateTrackedItem(cargo2);
	
	cargo3 := self.addContainerAtLocation("UACU7894563", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs);
	self.opts.addAssoc("TotalWeight", "6000");
	self.updateTrackedItem(cargo3);
	
	count := 0;
	foreach invoiceLine in cargo1.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight1", "First cargo invoice line type");
	endforeach;
	self.assertEqualMsg(count, 1, "First cargo invoice line count");
	
	count := 0;
	foreach invoiceLine in cargo2.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight2", "Second cargo invoice line type");
	endforeach;
	self.assertEqualMsg(count, 1, "Second cargo invoice line count");
	
	count := 0;
	foreach invoiceLine in cargo3.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight3", "Third cargo invoice line type");
	endforeach;
	self.assertEqualMsg(count, 1, "Third cargo invoice line count");
	
epilog
	delete trans;
	delete services;
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'UT_CargoMultiWeight');
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
end;</source>
    </JadeMethod>
    <JadeMethod name="tMultipleStorage" id="debb11f5-f072-49e5-a53e-9be759bd5078">
        <source>tMultipleStorage();
// cnwma1
// cnwjre1 check how multiple storage transactions interact
//	Four containers all arrive 01/04
//	First has storage at 04, 05, 06, 07 and 08
//	Second has storage at 04, 06 and 08
//	Third has storage at 04 and 08
//	Last has storage only at 08

//	The sum of the storage invoice lines for each should be the same, as the overall storage period is the same for all containers
vars
	quantityTotal	: Integer;
	storageConfig	: CM_StorageConfig;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	zeroTime		: Time;
	triggers	: CM_StorageTriggerByType;
	includeFirstDay,
	includeLastDay	: Boolean;

	ti1,
	ti2,
	ti3,
	ti4 : CM_TrackedItem;
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	now		: Date;
	tranTime	: Time;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	operator	: CM_Operator;
	invLine		: CM_InvoiceLine;
	calType1 : CM_CalculationType;
	invLineDesc1 : CM_InvoiceLineDesc;
	bank 		: CM_Bank;
begin
	self.deleteStorageConfig( false );
	
	// set up the storage config with include first and last days, all else default
	zeroTime := "00:00".Time;
	firstDayTimeCutoff := zeroTime;
	lastDayTimeCutoff := zeroTime;
	includeFirstDay := true;
	includeLastDay := true;
	create criteriaTypes transient;
	create triggers transient;

	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, firstDayTimeCutoff, includeFirstDay, includeLastDay,
											  lastDayTimeCutoff, 0, 0, null,null, null, -1, -1, -1);
	terminal := self.getTerminal();
	operator := app.myRoot.allOperators["MSC"];
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;

	self.deleteContainer("HJCU8141306");
	self.deleteContainer("HJCU8141307");
	self.deleteContainer("HJCU8141308");
	self.deleteContainer("HJCU8141309");

	ti1 := self.addContainerOpts("HJCU8141306", "2200", "GENL", operator);
	ti2 := self.addContainerOpts("HJCU8141307", "2200", "GENL", operator);
	ti3 := self.addContainerOpts("HJCU8141308", "2200", "GENL", operator);
	ti4 := self.addContainerOpts("HJCU8141309", "2200", "GENL", operator);
	beginTransaction;
	ti1.setPropertyValue( "totalWeight", "23100".Decimal );
	ti2.setPropertyValue( "totalWeight", "23100".Decimal );
	ti3.setPropertyValue( "totalWeight", "23100".Decimal );
	ti4.setPropertyValue( "totalWeight", "23100".Decimal );
	commitTransaction;
	
	self.move(ti1, self.getLocationsController(blockStack.allLocationsControllers.first));
	self.move(ti2, self.getLocationsController(blockStack.allLocationsControllers.first));
	self.move(ti3, self.getLocationsController(blockStack.allLocationsControllers.first));
	self.move(ti4, self.getLocationsController(blockStack.allLocationsControllers.first));

	tranDate.setDate(1,4,2016);
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti1, tranTS);
	self.resetTransactionDate(ti2, tranTS);
	self.resetTransactionDate(ti3, tranTS);
	self.resetTransactionDate(ti4, tranTS);

	tranDate.setDate(1,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedTransaction(ti1, tranTS, TRANS_TYPE_REC_SHIP);
	self.createDatedTransaction(ti2, tranTS, TRANS_TYPE_REC_SHIP);
	self.createDatedTransaction(ti3, tranTS, TRANS_TYPE_REC_SHIP);
	self.createDatedTransaction(ti4, tranTS, TRANS_TYPE_REC_SHIP);
	
	// delete the CM_Receive (is replaced with CM_ReceiveRoad)
	beginTransaction;
	foreach tran in ti1.allTransactions do
		if tran.class.name = CM_Receive.name then
			delete tran;
		endif;
	endforeach;
	foreach tran in ti2.allTransactions do
		if tran.class.name = CM_Receive.name then
			delete tran;
		endif;
	endforeach;
	foreach tran in ti3.allTransactions do
		if tran.class.name = CM_Receive.name then
			delete tran;
		endif;
	endforeach;
	foreach tran in ti4.allTransactions do
		if tran.class.name = CM_Receive.name then
			delete tran;
		endif;
	endforeach;
	commitTransaction;

	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	// uses days since receival
	self.tranMapLoadSimpleStorage();
	
	
	// cnwma1 
	
	
	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	bank := self.myBank;
	
	invLineDesc1 := bank.invoiceLineDescriptors["UT_LineTypeStore1"];
	if invLineDesc1 &lt;&gt; null then
		beginTransaction;
			invLineDesc1.setPropertyValue("myCalculationType",calType1);
		commitTransaction;
	endif;

	
	
	tranDate.setDate(4,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti1, tranTS, TRANS_TYPE_STORAGE, true);
	tranDate.setDate(5,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti1, tranTS, TRANS_TYPE_STORAGE, true);
	tranDate.setDate(6,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti1, tranTS, TRANS_TYPE_STORAGE, true);
	tranDate.setDate(7,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti1, tranTS, TRANS_TYPE_STORAGE, true);
	tranDate.setDate(8,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti1, tranTS, TRANS_TYPE_STORAGE, true);
	
	foreach tran in ti1.allTransactions do
		foreach invLine in tran.allInvoiceLines do
			quantityTotal := quantityTotal + invLine.quantity.Integer;
		endforeach;
	endforeach;
	self.assertEqualMsg(quantityTotal, 8, "First storage quantity total");

	tranDate.setDate(4,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti2, tranTS, TRANS_TYPE_STORAGE, true);
	tranDate.setDate(6,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti2, tranTS, TRANS_TYPE_STORAGE, true);
	tranDate.setDate(8,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti2, tranTS, TRANS_TYPE_STORAGE, true);

	quantityTotal := 0;
	foreach tran in ti2.allTransactions do
		foreach invLine in tran.allInvoiceLines do
			quantityTotal := quantityTotal + invLine.quantity.Integer;
		endforeach;
	endforeach;
	self.assertEqualMsg(quantityTotal, 8, "Second storage quantity total");

	tranDate.setDate(4,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti3, tranTS, TRANS_TYPE_STORAGE, true);
	tranDate.setDate(8,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti3, tranTS, TRANS_TYPE_STORAGE, true);

	quantityTotal := 0;
	foreach tran in ti3.allTransactions do
		foreach invLine in tran.allInvoiceLines do
			quantityTotal := quantityTotal + invLine.quantity.Integer;
		endforeach;
	endforeach;
	self.assertEqualMsg(quantityTotal, 8, "Third storage quantity total");
	
	tranDate.setDate(8,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(ti4, tranTS, TRANS_TYPE_STORAGE, true);

	quantityTotal := 0;
	foreach tran in ti4.allTransactions do
		foreach invLine in tran.allInvoiceLines do
			quantityTotal := quantityTotal + invLine.quantity.Integer;
		endforeach;
	endforeach;
	self.assertEqualMsg(quantityTotal, 8, "Fourth storage quantity total");
	// Result is 8 for all 4 cases, as it should be
epilog

	abortTransaction;

	self.resetDefaultTranMap();
	self.deleteStorageConfig( true );

	delete criteriaTypes;
	delete triggers;
	delete transParams;
end;</source>
    </JadeMethod>
