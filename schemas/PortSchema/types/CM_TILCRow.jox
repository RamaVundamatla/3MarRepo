        <source>setMyVehicle(_vehicle : CM_Vehicle) updating;
/*

Date		Who		Reason
23 August 2013	cnwer1	Initial creation PAR 32261

*/

vars

begin
	self.myVehicle:=_vehicle;
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="fd1cee74-8435-429f-816c-cb04d5339a2a">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/*

Date		Who		Reason
23 August 2013	cnwer1	Initial creation PAR 32261

*/

vars

begin
	if self.myVehicle = null then	
		inheritMethod(_control);
	else
		if _control.moveMode = REAL_MODE and _control.myToPrimaryLocation = self then
			//raise exception // nothing should be moved here just dummy for stuff to be queued &amp; planned while the chassis is unknown
			//app.raiseCMException(Cant_move_to_unknown_trailer,null,null);
	
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
