    <JadeMethod name="getDisplayDetails" id="9082b5be-e8ac-4214-9924-e7781eb61b0d">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.description;
	endif;
	end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="acb984f9-fcdb-4393-8cf1-cb4f9655ee11">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2010	cnwmh5	Initial creation #24264
*/

vars
	str	: String;
begin

	if _attrName = ETRow_Debtor then
		// display full debtor name not truncated 10 characters
		if self.debtor &lt;&gt; null then
			str := self.debtor.getDisplayDetails(false);
		endif;
		return str;
	// 31448 address fields
	elseif _attrName = ETRow_AddressLine1 then
		return self.getAddress1();
	elseif _attrName = ETRow_AddressLine2 then
		return self.getAddress2();
	elseif _attrName = ETRow_AddressLine3 then
		return self.getAddress3();
	elseif _attrName = ETRow_AddressPostCode then
		return self.getAddressPostCode();
	elseif _attrName = ETRow_AddressRegion then
		return self.getAddressRegion();
	elseif _attrName = ETRow_AddressCountry then
		return self.getAddressCountryName(); 	
	elseif _attrName = ETRow_FinancialId then	//04.Mar.24 navsp1 TFS 57177
		if self.debtor &lt;&gt; null then
			return self.debtor.code;
		endif;
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
