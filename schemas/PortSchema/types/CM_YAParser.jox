    <JadeMethod name="buildBlocks" id="bae48642-ea2f-4112-be4a-6730b59c7e23">
        <source>buildBlocks():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		20 April 2005 by cnwdad1
//
// Purpose:		Builds/updates Yard Allocation Blocks for the Terminal Areas and
//				Locations Controllers that have been parsed.
//
// Parameters:	None
//
// Returns:		True if the Blocks were successfully assembled, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockAreaObj	: CM_YABlockArea;
	blockObj		: CM_YABlock;
	
begin
	foreach blockAreaObj in self.allBlockAreas do
		if not blockAreaObj.buildBlock(self.myYardAllocation, self.allYABlocksIn, self.allYABlocksOut) then
			return false;
		endif;
	endforeach;

	// Creation of decking options now done here - earliest point we have all LC's on all blocks.
	
	foreach blockObj in self.allYABlocksIn do
		if blockObj.myDeckingOptions &lt;&gt; null then
			// Not a new block - redo location cells.
			blockObj.updateProxyDeckingOptions();
			continue;
		endif;
		
		blockObj.setProxyDeckingOptions();
	endforeach;	

	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDecking" id="9618e256-8261-40df-af56-49b87ec36ae1">
        <source>copyDecking(_proxyYA : CM_YardAllocation);
/*
Purpose:			When adding a new range to a yard allocation on the satellite view, the proxy blocks
					created for the existing blocks have default decking rules created for them.  
					Prior to PAR #28002, these default decking options ended up being persisted, thus over-writing
					any customised decking options.
					This method replaces the default decking options with proxies created from the actual blocks.

Parameters:			_proxtYA - the proxy of the yard allocation we are updating

Return Value:		None

Date		Who		Reason
17/08/2011	cnwdap1	Initial creation PARC #28002 Copy existing decking options to proxy blocks
*/
vars
	block, existingBlock	: CM_YABlock;
	group, proxyGroup		: CM_YABlockGroup;
	proxyBlocks				: CM_YABlockArray;
	deckingOptions			: CM_YADeckingOptionsBlock;

begin
	create proxyBlocks transient;
	_proxyYA.allYABlocksIn.copy(proxyBlocks);
	
	foreach proxyGroup in _proxyYA.allYABlockGroupsIn do
		// get the persistent group
		group := proxyGroup.pxyGetRealObject();
		if group = null then
			continue;
		endif;
		// get the matching proxy block for each persistent block
		// (the persistent blocks will have the current decking options)
		foreach block in group.allYABlocksIn do
			existingBlock := self.findMatchingBlock(proxyBlocks, block);
			// if a new block is being added, an existing one won't be found - the added block will haveth default decking options from the terminal area
			if existingBlock &lt;&gt; null then
				// delete the (possibly) incorrect proxy decking (has default decking options)
				deckingOptions := existingBlock.myDeckingOptions;
				delete deckingOptions;
				// create new proxy decking from the actual decking options
				deckingOptions := app.createUpdateProxy(block.myDeckingOptions).CM_YADeckingOptionsBlock;
				// attach the new proxy decking options to the block
				deckingOptions.setMyBlock(existingBlock);
			endif;
		endforeach;
	endforeach;
	
epilog
	delete proxyBlocks;
end;</source>
        <Parameter name="_proxyYA" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="createBlocks" id="7535c850-9f0c-4221-a73a-1a33f1dc884f">
        <updating/>
        <source>createBlocks(_ya: CM_YardAllocation; _blocks: ObjectArray) updating;
//09 September 2008	cnwdw1	
//
vars
	blockArea: CM_YABlockArea;
	block: Object;
begin
	self.myYardAllocation := _ya;
	foreach block in _blocks where block.isKindOf(CM_LCArray) and block.CM_LCArray.size &gt; 0 do
		// Add a block area, it will auotmatically be added to allBlockAreas 
		create blockArea transient;
		blockArea.populateFromLocations(self, block.CM_LCArray);
	endforeach;
	self.buildBlocks();
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_blocks" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="delete" id="8d4b9402-ac7e-45c4-ad12-59d8760b7860">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		20 April 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allBlockAreas.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findMatchingBlock" id="5065d767-88be-4256-8398-12d9496c3c63">
        <source>findMatchingBlock(_blocks: CM_YABlockArray; _block: CM_YABlock): CM_YABlock protected;
//04 March 2009	cnwdw1	
//
vars
	block: CM_YABlock;
begin
	foreach block in _blocks do
		if block.getYAMDisplay(false) = _block.getYAMDisplay(false) then
			return block;
		endif;
	endforeach;
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_blocks" type="CM_YABlockArray"/>
        <Parameter name="_block" type="CM_YABlock"/>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="5cbcb917-bfee-4c72-8f2a-3fb7f41bb9c8">
        <updating/>
        <source>initializeMe() updating, protected;
// --------------------------------------------------------------------------------
// Created:		11 April 2005 by cnwdad1
//
// Purpose:		Initializes the receiver ready for parsing the locations string and
//				creating the YA Block(s).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj	: CM_Terminal;
	
begin
	self.errorMessage	:=	null;
	
	terminalObj	:=	app.getMyTerminalDO_NOT_USE();
	
	if terminalObj = null and app.isDevelopmentSystem() then
		terminalObj	:=	CM_Terminal.firstInstance();
	endif;
	
	terminalObj.getAllTerminalAreasForYA(self.allTerminalAreas);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadBlocks" id="cbf1aa76-4cbf-4404-a54b-c1164d53f79f">
        <source>loadBlocks(pAllBlocksInObj:CM_YABlockArray; pAllBlocksOutObj:CM_YABlockArray);
// --------------------------------------------------------------------------------
// Created:		13 April 2005 by cnwdad1
//
// Purpose:		Populates the receiver's array of YA Blocks.
//
// Parameters:	pAllBlocksInObj - A reference to an array of "In" YA Blocks.
//				pAllBlocksOutObj - A reference to an array of "Out" YA Blocks.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllBlocksInObj.copy(self.allYABlocksIn);
	pAllBlocksOutObj.copy(self.allYABlocksOut);
end;</source>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray"/>
    </JadeMethod>
    <JadeMethod name="orderBlocks" id="bce4d253-535c-4d93-b1e7-9aea2f42ce0e">
        <source>orderBlocks(_proxyYA: CM_YardAllocation);
//04 March 2009	cnwdw1	
// Sort the yablocks (ranges) in the proxyYA so they match the order of the
// real YA. New ranges are added to the end
vars
	block, existingBlock: CM_YABlock;
	group, proxyGroup: CM_YABlockGroup;
	proxyBlocks: CM_YABlockArray;
begin
	create proxyBlocks transient;
	_proxyYA.allYABlocksIn.copy(proxyBlocks);
	
	// Group order is unchanged so can use the proxy 
	foreach proxyGroup in _proxyYA.allYABlockGroupsIn do
		proxyGroup.allYABlocksIn.clear();
		proxyGroup.allYABlocksOut.clear();
		group := proxyGroup.pxyGetRealObject();
		if group = null then
			continue;
		endif;
		foreach block in group.allYABlocksIn do
			existingBlock := self.findMatchingBlock(proxyBlocks, block);
			if existingBlock &lt;&gt; null then
				proxyGroup.allYABlocksIn.add(existingBlock);
				proxyGroup.allYABlocksOut.add(existingBlock);
				proxyBlocks.remove(existingBlock);
			endif;	
		endforeach;
	endforeach;

	// If there were new blocks add them at end of last group
	if proxyBlocks.size &lt;&gt; 0 then
		proxyGroup := _proxyYA.allYABlockGroupsIn.last;
		proxyBlocks.copy(proxyGroup.allYABlocksIn);
		proxyBlocks.copy(proxyGroup.allYABlocksOut);
	endif;
	
epilog
	delete proxyBlocks;
end;</source>
        <Parameter name="_proxyYA" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="parseAreaString" id="5f49beb4-e8e5-4edd-8cbe-01b039ff0714">
        <updating/>
        <source>parseAreaString(pAreaString:String):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 April 2005 by cnwdad1
//
// Purpose:		Derives the Area from the location string, then passes the rest of
//				the string to a method to parse the locations within the area.
//
// Parameters:	pAreaString - Contains the Area location ID, and a list/range of rows/columns.
//
// Returns:		True if the locations were successfully parsed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	terminalAreaObj		: CM_TerminalArea;
	blockAreaObj		: CM_YABlockArea;
	charPos				: Integer;
	tokenValue			: String;
	workString			: String;
	
begin
	workString	:=	pAreaString.trimBlanks();
	
	if workString = null then
		self.errorMessage	:=	"The Area ID cannot be empty.";
		return false;
	endif;
	
	// Get the first token, which is the Area ID.
	
	charPos		:=	1;
	tokenValue	:=	workString.scanUntil(J_key_Space.Character, charPos).trimBlanks();
	
	if tokenValue = null then
		self.errorMessage	:=	"No Area has been specified for the location.";
		return false;
	endif;
	
	terminalAreaObj	:=	self.allTerminalAreas[tokenValue];
	
	if terminalAreaObj = null then
		self.errorMessage	:=	"The Terminal Area was not found: " &amp; tokenValue.trimBlanks();
		return false;
	endif;
	
	if charPos = 0 then
		// There's no more of the work string to parse, so the user has not
		// specified any locations within the Terminal Area.
		create blockAreaObj transient;
		blockAreaObj.populateForWholeArea(self, terminalAreaObj, self.errorMessage);
		return true;
	endif;
	
	// Get the row/column values/ranges.
	
	charPos	:=	charPos + 1;
	
	if charPos &lt;= workString.length() then
		tokenValue	:=	workString[charPos:end].trimBlanks();
		
		create blockAreaObj transient;
		
		if blockAreaObj.parseAreaRowString(	self,
											terminalAreaObj,
											tokenValue,
											self.errorMessage)
		then
			return true;
		else
			delete blockAreaObj;
			return false;
		endif;
	endif;
	
	// We should never get to this point!!
	
	self.errorMessage	:=	"There were no Area locatons to process.";
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pAreaString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="parseLocations" id="e78bd401-738c-495a-a67e-0e657b9bd146">
        <updating/>
        <source>parseLocations(pYardAllocationObj:CM_YardAllocation; pLocationsString:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		20 April 2005 by cnwdad1
//
// Purpose:		Parses the Yard Allocation location identifiers, one area at a time.
//
//				Individual Locations will be separated by a semi-colon.
//
// Parameters:	pYardAllocationObj - A reference to the Yard Allocation which the
//					locations will belong to.
//				pLocationsString - A string of location Ids to parse.
//
// Returns:		True if the locations were successfully parsed, otherwise false.
//				If successful, the allYABlocks array on the receiver will have
//				been populated with the resulting YA Blocks.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myYardAllocation	:=	pYardAllocationObj;
	
	if pLocationsString = null then
		self.allYABlocksIn.clear;
		self.allYABlocksOut.clear;
		return true;
	endif;
	
	if self.parseLocationsString(pLocationsString) then
		return self.buildBlocks();
	else
		return false;
	endif;
end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pLocationsString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="parseLocationsString" id="437a42cf-e580-44a8-aaa6-9c3091e6c6b5">
        <updating/>
        <source>parseLocationsString(pLocationsString:String):Boolean updating, protected;
// -----------------------------------------------------------------------------
// Created:		07 April 2005 by cnwdad2
//
// Purpose:		Parses the Yard Allocation location identifiers, one area at a time.
//
//				Individual Locations will be separated by a semi-colon.
//
// Parameters:	pLocationsString - A string of location Ids to parse.
//
// Returns:		True if the locations were successfully parsed, otherwise false.
//				If successful, the allYABlocks array on the receiver will have
//				been populated with the resulting YA Blocks.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	charPos			: Integer;
	workString		: String;
	locationId		: String;
	
begin
	//workString	:=	pLocationsString.trimBlanks().toUpper();
	
	// Par 13522 Don't toupper as labels and idents can be lower case;
	workString	:=	pLocationsString.trimBlanks();
	
	// First, validate the locations string.
	
	if not self.validateStringToParse(workString) then
		return false;
	endif;
	
	// Now start parsing the work string.
	
	charPos	:=	0;
	
	while true do
		charPos		:=	charPos + 1;
		
		if charPos &gt; workString.length() then
			break;
		endif;
		
		locationId	:=	workString.scanUntil(J_key_SemiColon.Character, charPos);
		
		if not self.parseAreaString(locationId) then
			break;
		endif;
		
		if charPos = 0 then
			break;
		endif;
	endwhile;
	
	return (self.errorMessage = null);
end;</source>
        <access>protected</access>
        <Parameter name="pLocationsString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateStringToParse" id="f5af7e8a-f74b-4fff-a957-4432c3445f90">
        <updating/>
        <source>validateStringToParse(pWorkString:String io):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 April 2005 by cnwdad1
//
// Purpose:		Validates the locations string, and strips uneccessary characters,
//				such as duplicate delimiters.
//
// Parameters:	pWorkString - The locations string to validate.
//
// Returns:		True of the locations string is valid, otherwise false.  The updated
//				string will be returned in the IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	charPos			: Integer;
	workString		: String;
	workLength		: Integer;
	testChar		: Character;
	findString		: String;
	invalidChars	: String;
	
begin
	workString	:=	pWorkString.trimBlanks().toUpper();
	
	if workString = null then
		self.errorMessage	:=	"No locations were entered.";
		return false;
	endif;
	
	self.initializeMe();
	
	// Check that the string contains no invalid characters.
	
	charPos				:=	1;
	workLength			:=	workString.length();
	invalidChars		:=	null;
	
	foreach charPos in 1 to workLength do
		testChar	:=	workString[charPos];
		
		if self.VALID_CHARS.pos(testChar, 1) = 0 then
			if invalidChars = null then
				invalidChars	:=	testChar;
			else
				invalidChars	:=	invalidChars &amp; testChar;
			endif;
		endif;
	endforeach;
	
	if invalidChars &lt;&gt; null then
		self.errorMessage	:=	"The Location name(s) contains invalid characters (" &amp; invalidChars &amp; ").";
		return false;
	endif;
	
	// Now strip of any extraneous characters on the end.
	
	if workString[workLength:1] = J_key_SemiColon.Character then
		workString	:=	workString[workLength:1];
		workLength	:=	workString.length();
	endif;
	
	// Next, eliminate any duplicate delimiters.
	
	findString	:=	J_key_SemiColon.Character &amp; J_key_SemiColon.Character;
	workString	:=	workString.cnEcFindReplace(findString, J_key_SemiColon.Character, false);
	findString	:=	J_key_Comma.Character &amp; J_key_Comma.Character;
	workString	:=	workString.cnEcFindReplace(findString, J_key_Comma.Character, false);
	findString	:=	J_key_Hyphen.Character &amp; J_key_Hyphen.Character;
	workString	:=	workString.cnEcFindReplace(findString, J_key_Hyphen.Character, false);
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pWorkString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
