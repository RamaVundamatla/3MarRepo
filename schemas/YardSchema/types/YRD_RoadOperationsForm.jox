    <JadeMethod name="doRemarksUpdate" id="bbc7f414-5986-4027-884a-674b344f4eff">
        <updating/>
        <source>doRemarksUpdate(_obj : CM_Object input) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
//nds TFS 2867 17/01/17 PKT - Bulk Process
// 14/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes
// 31 Aug 2023 	navhl20 	Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
// ---------------------------------------------------------------------------

vars
	wleArray : CM_WLEArray;
	table : CM_DataTable;
	obj : CMIF_RoadOpObject;
	flexiType : Integer;
	gteEntity : CMGTE_Entity;
begin
	
	if _obj = null then
		return;
	endif;
	
	// cnwrd1 par 31069 22.2.2013
	create wleArray transient;
	self.getAllWLEsInTableSelected(wleArray, self.myCurrentTable,true );	//nds TFS 2867 17/01/17 PKT - Bulk Process
	
	// Mar 2011 cnwjre1 27097 call consolidated request edit form for delivery request; call the existing one for others
	//epr par 34254 6/6/14
	if _obj.isKindOf(CM_DeliveryRequest) then
		self.myAssistant.showRequestEditForm(_obj.CM_DeliveryRequest,wleArray,self.myCurrentWLE);
		gteEntity:=_obj.CM_YardRequest.myGateEntity;
		if global.cnwer1 and gteEntity &lt;&gt; null and gteEntity.isReEditable then
			
			if _obj.CM_DeliveryRequest.isMTs then
				flexiType:=CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY;
			elseif not _obj.CM_DeliveryRequest.myCargoType.isContainer then
				flexiType:=CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL;
			else
				flexiType:=CMUI_FlexiCargoForm.FLEXI_CARGO_FULL;
			endif;
			self.myAssistant.showCargoReleaseFromFlexiGate(self,false,flexiType,2, 200, null,false,_obj.CM_YardRequest.myGateEntity,null,null,null,null, null,self.myCurrentRoadJob.myVehicleVisit, null, null);	//31.8.2023 navhl20 #60183
		endif;
	else
		self.myAssistant.showRemarksForm(self.myCurrentWLE); //epr par 34880 18/9/14
	endif;

epilog
	delete wleArray;
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResetDoorDirection" id="99fcc47b-d053-4c9d-9be0-d67e0e1bc946">
        <updating/>
        <source>doResetDoorDirection() updating, protected;
/*
Date		Who		Reason
11 August 2011	cnwndl1	Initial creation	Par 27582
//22/11/2017 	cnwma1  TFS #7828 QNS - System buffering
*/

vars
	wle : CM_WorkListEntry;
	req	: CM_YardRequest;
	newDoorsForwardValue : Boolean;
begin

	// Toggles the 'doorsForward' setting on the associated Release request
	// only valid if the container is not already on the truck.
	
	wle := self.mnuDoorsForward.userObject.CM_WorkListEntry;
	if wle = null or wle.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;
	
	req := wle.myRequest.CM_YardRequest;
	if req = null or req.isReceivalType then
		return;
	endif;
	
	newDoorsForwardValue := not req.doorsForward;
	
	app.myTrxUA.trxUpdateYardRequestDoorsDir( req, newDoorsForwardValue, app.myPassport );
	
	self.myRoadOpController.handleUserNotification(WLE_Update_Event,wle);
	
	if self.dkbMacro.visible then     		 //22/11/2017 cnwma1 TFS #7828
		self.displayExtraInfoForObj(wle);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
