    </JadeMethod>
    <JadeMethod name="tblItems_dblClick" id="129ca5e6-5204-4208-9a6d-3812e57aadca">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblItems_dblClick(table: Table input) updating;
//15 January 2010	cnwml2


vars
	bolDtl : CM_BOLDtl;
begin
	if not self.btnEdit.enabled then		// 26/04/2010 cnwmh5 par 23821
		return;								// 26/04/2010 cnwmh5 par 23821
	endif;
	if self.tblItems.allSelectedObjects.size &gt; 0 then
		bolDtl := self.tblItems.accessRow(self.tblItems.row).itemObject.CM_BOLDtl;

		self.doAddEditBOLItem(bolDtl, false);
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f08b77e6-c564-4fa5-8e0c-d0aefd8e5f9d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 July 2022 08:59:57.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013396, locale);
	btnAdd.translateCaption(Xlat_0013397, locale);
	btnAddRow.translateCaption(Xlat_0024969, locale);
	btnCancel.translateCaption(Xlat_0013398, locale);
	btnClear.translateCaption(Xlat_0013399, locale);
	btnDelRow.translateCaption(Xlat_0024970, locale);
	btnDelete.translateCaption(Xlat_0013400, locale);
	btnEdit.translateCaption(Xlat_0013401, locale);
	btnSave.translateCaption(Xlat_0013402, locale);
	chkDirDel.translateCaption(Xlat_0018618, locale);
	grpItems.translateCaption(Xlat_0013403, locale);
	lblBOL.translateCaption(Xlat_0013404, locale);
	lblDestination.translateCaption(Xlat_0014269, locale);
	lblDischargePort.translateCaption(Xlat_0014270, locale);
	lblGenLandDate.translateCaption(Xlat_0022018, locale);
	lblLoadPort.translateCaption(Xlat_0014271, locale);
	lblNotifyParty.translateCaption(Xlat_0013405, locale);
	lblOperator.translateCaption(Xlat_0013406, locale);
	lblPO.translateCaption(Xlat_0019348, locale);
	lblServiceOrder.translateCaption(Xlat_0019349, locale);
	lblVoyage.translateCaption(Xlat_0013407, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0014089, locale);
	mnuContextMenu.translateCaption(Xlat_0014090, locale);
	mnuReceived.translateCaption(Xlat_0014091, locale);
	mnuTblInspectObject.translateCaption(Xlat_0014092, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="3983c841-50b4-40b6-9bc2-714ad194ee2a">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Dec 2024	navbs1	Initial Creation Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created

*/

vars
	
	scm				: Schema;
	frmClass		: Class;
begin
	scm 			:= rootSchema.getSchema('YardSchema');
	frmClass 		:= scm.getClass('YRD_WorkOrder');
	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(frmClass) then 
		self.myParentForm.sendMsgWithParams("setBOL",self.myCurrentBOL);
	endif;
	return inheritMethod();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
