    <JadeMethod name="trxGetNextSystemTrainNumber" id="b8fe6368-e4c5-4458-bde3-6cb06b81a566">
        <updating/>
        <source>trxGetNextSystemTrainNumber(_terminal : CM_Terminal; _code : String output; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2009	cnwrd1	Initial creation

*/

vars
	tmpCode : String;
	codeFound : Boolean;
	train : CM_Train;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	codeFound := true; 
	while codeFound do
		tmpCode := _terminal.getNextTrainCode();
//		codeFound := _terminal.allTrainsOnTerminal[tmpCode,null] &lt;&gt; null;
		train := _terminal.allTrainsOnTerminal.getAtKeyGeq(tmpCode,null);
		codeFound := ((train &lt;&gt; null) and (tmpCode  = train.code));
	endwhile;
	

epilog
	_code := tmpCode;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
