    <JadeMethod name="auditId" id="692fa401-2bb9-41a8-a8f3-cdb1da4f5ddb">
        <source>auditId(): String;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	auditIdStr : String;
begin
	
	auditIdStr := self.myBusinessUnit.code &amp; "/" &amp; self.myContractByVolume.auditId();
	
	if self.myVessel &lt;&gt; null then
		auditIdStr := auditIdStr &amp; "/" &amp; self.myVessel.code;
	endif;
	
	if self.myVoyage &lt;&gt; null then
		auditIdStr := auditIdStr &amp; "/" &amp; self.myVoyage.code;
	endif;

	auditIdStr := auditIdStr &amp; "/" &amp; self.createdDateTime.asStringJMT();
	
	return auditIdStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
