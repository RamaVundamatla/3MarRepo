    <JadeMethod name="addClonedControls" id="5dada1c9-519d-4735-a19b-0d2c267cbc6b">
        <updating/>
        <source>addClonedControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwndl1	Initial creation

*/

vars

	newGrpTop : Real;
	cloneIndex : Integer;
	controlName : String;
	grpRake : CMUI_GroupBox;
	lblRake : CMUI_Label;
	txtRakeLeft : CMUI_TextBox;
	txtRakeRight : CMUI_TextBox;
	txtRakeWagons : CMUI_TextBox;
	rakeWagonsArray : ObjectArray;
	baseTabOrder : Integer;
	
begin

	grpRake1.visible := false;
	baseTabOrder := txtRakeLeft1.tabIndex;

//	create rakeWagonsArray transient;		// PAR #27874

	newGrpTop := 41;
	if self.cloneSize &gt; 0 then
		foreach cloneIndex in 1 to self.cloneSize do
			// group box first;
			newGrpTop := newGrpTop + 30;
			grpRake := grpRake1.loadControl(cloneIndex).CMUI_GroupBox;
			grpRake.parent := self.grpAllRakes;
			grpRake.top := newGrpTop;
			grpRake.visible := true;
			//then label
			lblRake := lblRake1.loadControl(cloneIndex).CMUI_Label;
			lblRake.parent := grpRake;
			//then left order textbox
			txtRakeLeft := txtRakeLeft1.loadControl(cloneIndex).CMUI_TextBox;
			txtRakeLeft.parent := grpRake;
			txtRakeLeft.text := cloneIndex.String;
			txtRakeLeft.tabIndex := baseTabOrder + 2 + (cloneIndex * 10);
			//then wagons list textbox
			txtRakeWagons := txtWagons1.loadControl(cloneIndex).CMUI_TextBox;
			txtRakeWagons.parent := grpRake;
			//then right order textbox
			txtRakeRight := txtRakeRight1.loadControl(cloneIndex).CMUI_TextBox;
			txtRakeRight.parent := grpRake;
			txtRakeRight.tabIndex := baseTabOrder + 4 + (cloneIndex * 10);
			
			create rakeWagonsArray transient;
			allRakesWagonsArrays.add(rakeWagonsArray); // for position 'cloneIndex'
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearSameValue" id="55f6c87a-a04d-4284-a68b-d97465632f2d">
        <updating/>
        <source>clearSameValue( textBox : TextBox input) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars

	pos : Integer;
	control : Control;
	valueInt : Integer;
	
begin

	valueInt := textBox.text.Integer;
	foreach pos in 1 to self.controlCount do
		control := self.controls(pos);
		if control.isKindOf(TextBox) then
			if textBox &lt;&gt; control then
				if control.TextBox.text.trimBlanks.Integer = valueInt then
					control.TextBox.text := null;
				endif;
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="textBox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="3ed28032-647a-4c5a-9410-a65cc42ad155">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars

begin
	self.permissionView		:= PmAdmRailopsView;
	self.permissionMaint	:= PmAdmRailopsMaint;	
