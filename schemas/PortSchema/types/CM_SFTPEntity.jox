    <JadeMethod name="setProxy" id="1451c330-4519-4784-85bc-35728a7a3719">
        <updating/>
        <source>setProxy(_destinationDirectory: String; _id: String; _password: String; _serverName: String; _sourceDirectory: String; _userId: String; _isPassive: Boolean; _useProxy: Boolean; _mode: Integer; _serverGMTBias: Integer; _serverType: Integer; _port: Integer; _timeOut: Integer; _singleFileCopy: Boolean; _saveUndeletedFilesList: Boolean; _passPhrase: String; _privateKey: String; _publicKey: String) updating;
//
// 17 Sep 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//
vars

begin
	inheritMethod(_destinationDirectory, _id, _password, _serverName, _sourceDirectory, _userId, _isPassive, _useProxy, _mode, _serverGMTBias, _serverType, _port, _timeOut, _singleFileCopy, _saveUndeletedFilesList, _passPhrase, _privateKey, _publicKey);
	self.passPhrase := _passPhrase;
	self.privateKey := _privateKey;
	self.publicKey := _publicKey;
	self.port := _port;
	self.timeOut := _timeOut;
epilog

end;</source>
