<Class name="CM_RemoteCheckScalingExtra" id="7da66dcc-f2d1-4211-8c30-bdb1575f3f3e">
    <superclass name="CM_RemoteDataExtra"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <PrimAttribute name="conditionCode" id="e265e541-cfd2-40bc-813f-768efcc643c3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="id" id="7cc4be9e-de07-49b2-9b2f-bbf7190d411d">
        <length>36</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="maxSED" id="0c4103b7-5ba7-45a3-a760-cad1861410fc">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="minSED" id="9efe8f37-e8eb-4694-9041-d5bb0cb2eee0">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doCheckScale" id="b32fd9be-ad63-482b-84e1-36f43c09d334">
        <source>doCheckScale(_checkScaleHdr : CM_LogCheckScaleHdr);

// cnwdvb1 14 May 2003 

vars

	checkScaleDtl	: CM_LogCheckScaleDtl;
	error			: Integer;

begin

	create checkScaleDtl transient;
	checkScaleDtl.setProxy(_checkScaleHdr, self.id, self.conditionCode, self.minSED, self.maxSED);

end;</source>
        <Parameter name="_checkScaleHdr" type="CM_LogCheckScaleHdr"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="e1be2c73-ce91-4be7-988a-7464feb7b943">
        <source>getDescription(): String;

// cnwdvb1 03 June 2003 

vars

begin
	return 'Check scaling extra detail';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="0b670624-1fc9-41b7-a9e9-5adcca91c1c8">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns: Integer) updating;

// cnwdvb1 07 April 2003 

vars

begin
	self.id				:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;
	self.conditionCode	:= _table.accessCell(3,_entryTableColumns).text.trimBlanks;
	self.minSED			:= _table.accessCell(4,_entryTableColumns).text.Integer;
	self.maxSED			:= _table.accessCell(5,_entryTableColumns).text.Integer;
	

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="45cdf576-3757-486e-9de8-b646451c88bb">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteCheckScalingExtra; _remoteDataDtl: CM_RemoteDataDtl) updating;

// cnwdvb1 07 April 2003 

vars

begin

	self.conditionCode 		:= _proxy.conditionCode;
	self.id					:= _proxy.id;
	self.maxSED				:= _proxy.maxSED;
	self.minSED				:= _proxy.minSED;	
	inheritMethod(_proxy, _remoteDataDtl);

end;</source>
        <Parameter name="_proxy" type="CM_RemoteCheckScalingExtra"/>
        <Parameter name="_remoteDataDtl" type="CM_RemoteDataDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCheckScalingExtra" id="8fdc8208-fbeb-4d8f-963d-064f77eb4bbb">
        <updating/>
        <source>setProxyForCheckScalingExtra(_remoteDtl : CM_RemoteDataDtl; _id, _conditionCode : String; _minSED, _maxSED : Integer) updating;

// cnwdvb1 07 April 2003 

vars

begin

	self.conditionCode	:= _conditionCode;
	self.id				:= _id;
	self.maxSED			:= _maxSED;
	self.minSED			:= _minSED;
	
	self.setProxy(_remoteDtl);

end;</source>
        <Parameter name="_remoteDtl" type="CM_RemoteDataDtl"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_conditionCode" type="String"/>
        <Parameter name="_minSED" type="Integer"/>
        <Parameter name="_maxSED" type="Integer"/>
    </JadeMethod>
</Class>
