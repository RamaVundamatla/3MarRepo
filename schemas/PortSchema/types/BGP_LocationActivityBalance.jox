<Class name="BGP_LocationActivityBalance" id="51f27290-fadc-4fa1-b3cd-14c9968170f4">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Location Activity Balance Calculation&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="recalculateOnly" id="019ae944-9d91-46e3-8b83-b26b80d64fd4">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="action" id="3cfe33fa-3237-4ff4-8361-d40aaeb4e1c1">
        <updating/>
        <source>action(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	errCode	: Integer;
	errTxt	: String;
	agent : CM_LocationActivityAgent;

begin

	on Exception do app.alertExceptionHandler(exception, null,  self.getErrorDesc(),errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);

	create agent transient;
	
	agent.setBaseDataFromBGP( self );
						
	agent.doProcess();
	
epilog

	delete agent;
	
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		app.createActivityHistory(ActivityHistoryGeneral, null, null, "Location Activity Balance, run was successfull.", false, false);
	endif;
	inheritMethod();
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="4fc11aea-438c-4265-bc7d-b1e9d9cada95">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2021	navndl1	Initial creation	TFS 50906

*/

vars
	detail : String;

begin
	detail := inheritMethod();
	
	if self.recalculateOnly then
		return detail &amp; Tab &amp; app.getErrorString( Locatio_activit_balance_recalc );
	else
		return detail &amp; Tab &amp; app.getErrorString( Locati_activi_daily_balanc_cal );
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="769260c0-0f71-4300-bcf7-c479aff1f4b7">
        <updating/>
        <source>initRequestFromTask( _task: CM_AutoTaskLocationActivityBal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin
	inheritMethod(_task);
	
	self.recalculateOnly := _task.recalculateOnly;

epilog

end;</source>
        <Parameter name="_task" type="CM_AutoTaskLocationActivityBal"/>
    </JadeMethod>
</Class>
