    <JadeMethod name="getRowColour" id="002a7df2-85f5-4ed0-b1a5-7a8bfb45e74d">
        <source>getRowColour(_foreColour: Integer output; _backColour: Integer output);
//--------------------------------------------------------------
//Created: 07 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	isExport	: Boolean; 
begin

	if self.status = JOB_COMPLETE then
		if isRelease then
			_backColour := CM_Job.Colour_ReleaseComplete;
		else
			_backColour := CM_Job.Colour_ReceiptComplete;		
		endif;
		_foreColour := White;				
	elseif self.isLoadedToOperations then
		_foreColour := Black;
		isExport := (not self.isDischarge) and (self.jobType &lt;&gt; JOB_TYPE_SOB);// allSOBTrackedItems.isEmpty;
		if isExport
		and (not self.isFullyPlanned) then
			_backColour := Colour_JobLoaded;
		else
			_backColour := Colour_JobLoadedPlanned;
		endif;
	elseif not self.isLoadedToOperations then
		_foreColour := Black;
		_backColour := Colour_JobNotLoaded;		
	elseif self.myVoyageJobSheet = null then
		_foreColour := Black;
		_backColour := Colour_JobUnallocated;
	else
		inheritMethod(_foreColour, _backColour);
	endif;
	
end;</source>
        <Parameter name="_foreColour" type="Integer" usage="output"/>
        <Parameter name="_backColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSeqSheetNextLidJobRemarks" id="a195b565-77a6-4458-8ed8-ef3e726fd472">
        <source>getSeqSheetNextLidJobRemarks( _voyageJob : CM_VoyageJob ) : String;
//-------------------------------------------------------------------------
// created by cnwvu1 on 01/02/2007
//
// Purpose: we are looking for next jobs.
// 		if they are Hatch Lid jobs, we will form list of them using remarks.
//		They will be printed on a ShipSeqReport
//
// Parameters: 
// Output text as following:
// 		NEXT 2 JOBS ARE HATCH LID JOBS:
// 
//		REPLACE LIDS PCS BYA 17
//		REMOVE HATCH LID C BAY 01
//-------------------------------------------------------------------------

vars
	str		: String;
	jobsArray					: CM_JobArray;
	jobsArraySize				: Integer;
	nextVoyageJob				: CM_VoyageJob;
	jobIdx, countHatchLid		: Integer;
	
begin

	str := null;

	if _voyageJob.myJobSheet = null then // PAR 26945
		return null;
	endif;
	
	jobsArray := _voyageJob.myJobSheet.allJobsByOrder;
	jobsArraySize := jobsArray.size;
	jobIdx := jobsArray.indexOf( _voyageJob );
	countHatchLid := 0;

	while jobIdx &lt; jobsArraySize do
		jobIdx := jobIdx + 1;
		nextVoyageJob := jobsArray[jobIdx].CM_VoyageJob;
		if nextVoyageJob.isHatchLidJob() then
			countHatchLid := countHatchLid + 1;
			str	:= str &amp; CrLf &amp; "' " &amp; nextVoyageJob.getRemarks()  &amp; " BAY " &amp; nextVoyageJob.bayId &amp; " '";	//13864 - bayId added
		else
			break;
		endif;
	endwhile;
	
	if countHatchLid &gt; 0 then
		if countHatchLid = 1 then
			str := 'NEXT JOB IS A HATCH LID JOB:' &amp; CrLf &amp; str;
		else
			str := 'NEXT ' &amp; countHatchLid.String &amp; ' JOBS ARE HATCH LID JOBS:'	&amp; CrLf	&amp; str;
		endif;
	endif;

	return str;
	
end;
</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSequenceSortedWLEs" id="bd8df1cd-fe6c-406e-a12f-dd277137e461">
        <source>getSequenceSortedWLEs(array : CM_WLEArray input);
//Returns the wle's on this job in sorted order.
vars
	vIsStarBoard		: Boolean;
	wle				: CM_WorkListEntry;
	vWLE			: CM_VoyageWLE;

begin

	if array = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'array', null, null);
		return;
	endif;
	vIsStarBoard	:= self.myVoyage.starboardBerthed;
	if self.isTwinLift then
		array.addAndSortTwinSequences(vIsStarBoard, self.workListEntries);
	else
		array.addAndSortSingleSequences(vIsStarBoard, self.workListEntries);
	endif;
end;</source>
        <Parameter name="array" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStartEndFromWLEs" id="e409f29b-5003-4052-9025-037a6968e924">
        <source>getStartEndFromWLEs(_start, 
					_end : TimeStamp io);

vars
	max, min : TimeStamp;
	wle : CM_WorkListEntry;
begin
	max:=null;
	min:=null;
	foreach wle in self.workListEntries do
		if max = null then
			max:=wle.completedDate;
		else
			if wle.completedDate &gt; max then
				max:=wle.completedDate;
			endif;
		endif;
	
		if min = null then
			min:=wle.completedDate;
		else
			if wle.completedDate &lt; min then
				min:=wle.completedDate;
			endif;
		endif;
	endforeach;
	
	_start :=min;
	_end:=max;
end;
</source>
        <Parameter name="_start" type="TimeStamp" usage="io"/>
        <Parameter name="_end" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTotalLifts" id="49681dcc-91c0-4846-b203-4ecc52f58cae">
        <source>getTotalLifts() : Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	lifts : Real;
	wle : CM_WorkListEntry;
begin

	//count number of lifts
	foreach wle in self.workListEntries do
		if wle.CM_VoyageWLE.isSOBLoad() then // PAR 15440 
			continue; // PAR 15440 
		endif; // PAR 15440 
		if wle.CM_VoyageWLE.isTwinLift then
			lifts := lifts + 0.5;	//each wle twin counts for half
		else
			lifts := lifts + 1;
		endif;
	endforeach;


	return lifts.roundedUp;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
