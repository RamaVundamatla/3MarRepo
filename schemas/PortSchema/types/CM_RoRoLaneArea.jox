    <JadeMethod name="getLongestLaneDrawExtent" id="74cbada6-8f61-4bb5-971c-7d9c96b60fd2">
        <source>getLongestLaneDrawExtent() : Real protected;

/*

Purpose:			
	Helps with measurement/drawing code

Parameters:			

Return Value:		
	largest lane (+ startOffset) length in metres 

Date		Who		Reason
25 November 2009	cnwjk3	ccms 1018



*/

vars
	len,
	maxLen	: Real;
	lane	: CM_RoRoController;
begin
	foreach lane in self.allLanesByLaneNumber do
		//len := lane.length + lane.startOffset;
		len := lane.length;
		if len &gt; maxLen then 
			maxLen := len;
		endif;
	endforeach;
	return maxLen;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getMaxRowLabel" id="649d18e0-c30c-40f1-81cc-3fc3aae5e8bd">
        <source>getMaxRowLabel() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.laneCount &gt; 0 then
		return self.allLanesByLaneNumber.last().id;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxRowRangeString" id="6925ab6a-16f9-417b-b248-db3d7c39e8eb">
        <source>getMaxRowRangeString( _maxRowRange : String output) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwjk3	Initial creation

*/

vars

begin
	_maxRowRange := "";
	if self.laneCount &gt; 0 then
		_maxRowRange := _maxRowRange &amp; self.getMinRowLabel();
		_maxRowRange := _maxRowRange &amp; "-";
		_maxRowRange := _maxRowRange &amp; self.getMaxRowLabel();
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="_maxRowRange" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
