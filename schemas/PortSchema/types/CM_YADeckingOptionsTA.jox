    <JadeMethod name="pxyCreateUpdateProxy" id="d45871ad-0db6-422a-982e-225c15cbe4d3">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyOptions		: CM_YADeckingOptionsTA;
	completedOK		: Boolean;
begin
	pxyOptions := inheritMethod();
	pxyOptions.myTerminalArea := self.myTerminalArea;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyOptions;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyOptions;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ef6aad70-35c9-4a79-adf1-c0f868e9a7f1">
        <updating/>
        <source>setForCreate(_pxyDeckingOpts: CM_YADeckingOptionsTA) updating;
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.myTerminalArea := _pxyDeckingOpts.myTerminalArea;
	inheritMethod(_pxyDeckingOpts);

end;</source>
        <Parameter name="_pxyDeckingOpts" type="CM_YADeckingOptionsTA"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a8239409-746c-40a0-901e-bbbdcd6b9a8f">
        <updating/>
        <source>setForUpdate(_pxyDeckingOpts: CM_YADeckingOptions; _updateToLevel: Integer) updating;
//----------------------------------------------------------------
//	Created:	10 June 2005	by Jason Chapman  (cnwjc2)
//
//	When a row is updated the decking order might flow through to the rows and blocks
//
//----------------------------------------------------------------
/*

Date		Who		Reason
20 Mar 2009	cnwkpd1	PAR #18994 - prevent incorrect error message when increasing height
					of a Gridded Area

*/

vars
	pxyRowDO	: CM_YADeckingOptionsRow;
	termArea	: CM_GridArea;
	gridRow		: CM_GridRow;
	
begin
	inheritMethod(_pxyDeckingOpts, _updateToLevel);
	
	termArea := self.getGridArea();

	if termArea = null then
		return;
	endif;

	if termArea.type = TA_TYPE_FORK_LIFT_STACK then
		if _updateToLevel &gt; self.myDeckingLevel then
		//	self.updateBlocksForNoRowArea(termArea, _updateToLevel);
		endif;
		return;
	endif;
	//NO FORKLIFT STACKS PAST THIS POINT
	
	// PAR #18994 - ONLY update new rows at this point
	//check for new rows before returning
	//all rows should be updated incase extra locations have been added
	foreach gridRow in termArea.allGridRows do
		if gridRow.myDeckingOptions = null then
			//must have added a row
			//should create here if null
			create pxyRowDO transient;
			pxyRowDO.setProxy(false, true, gridRow);
			pxyRowDO.copyInRules(self);
			pxyRowDO.copyOutRules(self);

			app.myUtilityUA.utlUpdateDeckOptionsApplyRules(pxyRowDO, _updateToLevel, app.myPassport);
		
			//epr par 24724 5/7/10 can be sure the pxy is not deleted somewhere else 
			delete pxyRowDO;
			
		
			if app.myPassport.hasErrors then
				return;
			endif;
		endif;
	endforeach;
	
	if _updateToLevel &lt;= self.myDeckingLevel then
		return;
	endif;

	foreach gridRow in termArea.allGridRows do
		if gridRow.myDeckingOptions = null then
			//must have added a row
			//should create here if null
			create pxyRowDO transient;
			pxyRowDO.setProxy(false, true, gridRow);
		else	
			pxyRowDO := gridRow.myDeckingOptions.pxyCreateUpdateProxy();
		endif;

		pxyRowDO.allDeckingRulesIn.purge;
		pxyRowDO.allDeckingRulesOut.purge;

		pxyRowDO.copyInRules(self);
		pxyRowDO.copyOutRules(self);
		
		app.myUtilityUA.utlUpdateDeckOptionsApplyRules(pxyRowDO, _updateToLevel, app.myPassport);
		
		
		//epr par 24724 5/7/10 	
		delete pxyRowDO;
		
		
		if app.myPassport.hasErrors then
			return;
		endif;	
		
	endforeach;

epilog
	if global.isValidObject(pxyRowDO) then
		delete pxyRowDO;	
	endif;
end;</source>
        <Parameter name="_pxyDeckingOpts" type="CM_YADeckingOptions"/>
        <Parameter name="_updateToLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setHeightsForNewArea" id="00710b80-67fe-4575-b749-8ef5ba0e7846">
        <source>setHeightsForNewArea();
//----------------------------------------------------------------
//	Created:	02 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rule		: CM_YADeckingRule;
	stackHeight	: Integer;
begin
	
	stackHeight := self.myTerminalArea.getHeightOfStack();
	
	//on create there's only one rule
	rule := self.allDeckingRulesIn.first;
	if rule.heightTo &lt;&gt; stackHeight then
		rule.setHeights(1, stackHeight);	
	endif;
	
	rule := self.allDeckingRulesOut.first;
	if rule.heightTo &lt;&gt; stackHeight then
		rule.setHeights(1, stackHeight);	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9133af6e-cc0c-439e-825c-c73a8eed5022">
        <updating/>
        <source>setProxy(_showHeights, _outUsesReverseIn: Boolean; _areaObject: CM_Object) updating;
//----------------------------------------------------------------
//	Created:	11 April 2005	by Jason Chapman  (cnwjc2)
// 26 Nov 2014  cnwma1 PAR #35296  Error: 1048 While updating RORO Lane  Area
//----------------------------------------------------------------

vars
	yaDeckingOption : CM_YADeckingOptionsTA;
begin
	inheritMethod(_showHeights, _outUsesReverseIn, _areaObject);

	if _areaObject &lt;&gt; null then
		/*yaDeckingOption:=_areaObject.CM_TerminalArea.myYADeckingOptions;    26/11/2014 cnwma1 PAR #35296
		if yaDeckingOption  &lt;&gt; null then
			yaDeckingOption.myTerminalArea:=null;
		endif;*/
		self.myTerminalArea := _areaObject.CM_TerminalArea;
	endif;
end;</source>
        <Parameter name="_showHeights" type="Boolean"/>
        <Parameter name="_outUsesReverseIn" type="Boolean"/>
        <Parameter name="_areaObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="updateBlocksForNoRowArea" id="855a0756-a878-4e31-94cb-09fbdcfe10af">
        <source>updateBlocksForNoRowArea(_terminalArea: CM_TerminalArea; _updateToLevel: Integer);
//----------------------------------------------------------------
//	Created:	10 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	allocation		: CM_YardAllocation;
	yaBlock			: CM_YABlock;
	pxyBlockDO		: CM_YADeckingOptions;
begin

	foreach allocation in _terminalArea.allYardAllocations do

		foreach yaBlock in allocation.allYABlocksIn do

			pxyBlockDO := yaBlock.myDeckingOptions.pxyCreateUpdateProxy();
			pxyBlockDO.allDeckingRulesIn.purge;
			pxyBlockDO.allDeckingRulesOut.purge;
	
			pxyBlockDO.copyInRules(self);
			pxyBlockDO.copyOutRules(self);
			
			app.myUtilityUA.utlUpdateDeckOptionsApplyRules(pxyBlockDO, _updateToLevel, app.myPassport);
			
			if app.myPassport.hasErrors then
				return;
			endif;	
			
			//delete pxyBlockDO;
		endforeach;
	endforeach;

epilog
	if global.isValidObject(pxyBlockDO) then
		delete pxyBlockDO;	
	endif;
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_updateToLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateCellPositions" id="b4cff634-e62e-4035-bfc6-2aba7620d066">
        <source>validateCellPositions(_forIn: Boolean; _locnCellArray: CM_YALocationCellArray);
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locnCtrl	: CM_LocationsController;
begin

	if _forIn then
		foreach locnCtrl in self.myTerminalArea.allLocationsControllers do
			locnCtrl.CM_YardController.validateLocnCellsAscInArray(_locnCellArray);
		endforeach;
	else
		foreach locnCtrl in self.myTerminalArea.allLocationsControllers do
			locnCtrl.CM_YardController.validateLocnCellsDescInArray(_locnCellArray);
		endforeach;
	endif;

end;</source>
        <Parameter name="_forIn" type="Boolean"/>
        <Parameter name="_locnCellArray" type="CM_YALocationCellArray"/>
    </JadeMethod>
</Class>
