    </JadeMethod>
    <JadeMethod name="txtTargetLoc_lostFocus" id="2d3334d1-e21e-4873-8b14-95837bc7120f">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTargetLoc_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

begin

	if self.txtTargetLoc.text.trimBlanks = null then
		self.txtTargetLoc.text := self.lblTargetLoc.caption.toUpper;
		self.txtTargetLoc.userObject := null;
	else
		if self.txtTargetLoc.userObject &lt;&gt; null then
			if self.txtTargetLoc.text &lt;&gt; self.txtTargetLoc.userObject.CM_LocationsController.getFullId then
				self.txtTargetLoc.userObject := null;
			endif;
		endif;
	endif;
	
	self.txtTargetLoc.selStart := 0;
	self.txtTargetLoc.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
