    <JadeMethod name="getName" id="7b235a93-f652-4665-bf97-d5b2e2d340c8">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:=	inheritMethod() &amp; Tab &amp;
					'id ' &amp; self.id.display;
	
//	/*
	if app.myRoot = null then
		// need for mapping method on self.myStopsTable
		app.setPropertyValue( PortSchema::myRoot.name, CM_Root.firstInstance );
	endif;
	
	if self.myStopsTable &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myStopsTable.heading.display;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; myTrackedItem.id.padBlanks( 20 );
	endif;
	
	if self.clearanceExpiryDate &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.clearanceExpiryDate.asStringJMT;
	endif;
	
	returnStr	:= returnStr &amp; Tab &amp; creationTime.cnEcShortFullFormat;
//	*/
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStopOverrideReason" id="50880814-2d2b-4c7a-84ac-7014e1817149">
        <source>getStopOverrideReason():CM_StopOverridenReason;
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by cnwcs5 PAR 23697
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter	:Iterator;
	reason	:CM_StopOverridenReason;
	trx		:CM_TITransaction;
begin
	if self.myStopOverrideTxn &lt;&gt; null then
		if self.isTransient then
			return self.myStopOverrideTxn.myStopOverrideReason;
		endif;
		
		// *** check there are no subsequent updates
		iter 	:= self.myTrackedItem.allTransactions.createIterator;
	
		while iter.back (trx) do
			if trx = self.myStopOverrideTxn then
				// no updates
				return self.myStopOverrideTxn.myStopOverrideReason;
			endif;
			if not trx.isKindOf (CM_StopUpdate) then
				continue;
			endif;
			if trx.CM_StopUpdate.stopId &lt;&gt; self.id then
				continue;
			endif;
			if trx.CM_StopUpdate.myStopOverrideReason = null then
				continue;	
			endif;
			return trx.CM_StopUpdate.myStopOverrideReason; 
		endwhile;
	endif;
	return null;
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_StopOverridenReason"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="cdc983bc-32d8-4e46-9e3c-acf73f6e601e">
        <source>getYADisplay(): String;
// --------------------------------------------------------------------------------
// Created:		08 March 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.id.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSplitStopCustDocsDetails" id="56d478c0-cc79-437e-b1e9-90eaa1d332f0">
        <updating/>
        <source>handleSplitStopCustDocsDetails(_custDoc : CM_CustomDocument) updating;
/*
Purpose:			

Date		Who		Reason
13 September 2023	navab1	CR 59942 TASK 59943 
*/

vars
	stopTran : CM_TITransaction;
begin
	if  _custDoc &lt;&gt; null then
		self.custDocCode := _custDoc.code;
		if  _custDoc.myCustomLicense&lt;&gt; null then
			self.custDocLicense := _custDoc.myCustomLicense.code;
		endif;
		self.custDocSequence := _custDoc.sequence.String;
		self.custDocType := _custDoc.myCustomDocumentType.code &amp; " " &amp; CM_CustomDocumentType@getDirectStrFromInt(_custDoc.direction);
		
		if self.myTransaction &lt;&gt; null 
		and self.myTrackedItem &lt;&gt; null then
			stopTran:= self.myTrackedItem.getLastTransOfType(self.myTransaction.type);
			stopTran.setCustDocFromTI(self.myTrackedItem);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_custDoc" type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="isOverridden" id="c0c8009a-0423-4886-a1dc-789eb03131d3">
        <source>isOverridden() : Boolean;
// ---------------------------------------------------------------------------
// Created:     20 September 2010 by cnwcs5 PAR 23697
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myStopOverrideTxn &lt;&gt; null;
	
epilog

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopActiveAsAtDate" id="89d858c6-3e69-458b-898a-7282c906a05c">
        <source>isStopActiveAsAtDate( _asAtDate : Date ) : Boolean;

/*
Purpose:	This method will return true if this stop is active as at the date provided.
			Active means:
			1) the clearanceExpiryDate is null or
			2) the clearanceExpiryDate &lt; as at date.
			If no as at date is supplied (or invalid) then will default to today.
			
			Active is the opposite of cleared.

Date				Who		Reason
14 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
27/08/2010			cnwrl1	PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
	
vars
	asAtDate	: Date;
	ti : CM_TrackedItem;
	
begin
	// ### TFS CR 60424 TASK 60549 29SEP2023 NAVAB1
	if self.myStopsTable.requiresInfoForCustoms() then
		ti := self.myTrackedItem;
		if ti &lt;&gt; null then
			if ti.allCustomDocuments.isNotEmpty() then
				// put the stop back on if the release amount &gt;= to the cleared amount
				 return not ti.hasCustDocClearedForActiveStop(self.id); // ### TFS BUG 62185 16FEB2024 NAVAB1
			
			endif;
		endif;
	endif;
	
	// A stop is considered to be cleared for a particular TrackedItem
	// if no stop exists or the clearanceExpiryDate is today or in the future
	// otherwise it is active for that TrackedItem.
	if _asAtDate = null or not _asAtDate.isValid then
		asAtDate	:= app.actualTimeServer.date;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		asAtDate	:= _asAtDate;
	endif;
	
	// cnwrl1 20/09/2010 PAR 23697 - start of coding
	// A stop can now be marked as being overridden in which case it is treated as if it is deactive.
	if self.isOverridden() then
		return false;
	endif;

	
	// cnwrl1 20/09/2010 PAR 23697 - end of coding
	return self.clearanceExpiryDate = null or self.clearanceExpiryDate &lt; asAtDate;
	
epilog
	
end;
</source>
        <Parameter name="_asAtDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myStopsTable" id="0c3e2df7-59a8-48a2-829d-a8196434e6c1">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myStopsTable(set: Boolean; _value: CM_StopsTable io)updating,  mapping;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		self.myStopsTable := _value;
		return;
	endif;

	_value := app.myRoot.allStopsTable[self.id];
end;</source>
        <text>Remove after v7</text>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_StopsTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyIsCancelStop" id="eb73ab46-4d93-4f79-92bc-a3cc63671e74">
        <source>pxyIsCancelStop():Boolean;
// ---------------------------------------------------------------------------
// Created:     11 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	if self.action = self.Action_Cancel then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
