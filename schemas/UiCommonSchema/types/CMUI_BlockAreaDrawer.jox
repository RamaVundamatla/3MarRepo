    <JadeMethod name="getSelectedYardAllocation" id="f41afb7f-4bd7-4053-92d3-3e3af4eb1478">
        <source>getSelectedYardAllocation() : CM_YardAllocation;
//29 May 2008	cnwdw1	
// 10/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
//						Change location of handler
vars
	invalidObject : Boolean;
	selectedYardAllocation : CM_YardAllocation;
begin
	selectedYardAllocation := self.mySelectedYardAllocation;
	if selectedYardAllocation = null then
		return selectedYardAllocation;
	endif;
	on Exception do app.handleDeletedObject(exception, selectedYardAllocation, invalidObject);
	selectedYardAllocation.isTransient;	// force a check for valid object
	if invalidObject then
		selectedYardAllocation := null;
	endif;
	return selectedYardAllocation;
end;</source>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
