        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="33b29ccb-6c31-4210-a7c0-b22ae5dd3cb2">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _srcLocn : CM_SourceSubSubLocation; lstIndex: Integer): String updating, clientExecution;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	
	if _srcLocn = null then
		return null;
	endif;

	if _srcLocn.notAvailableForEntry then
		if self.myObject &lt;&gt; _srcLocn then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
			
	return _srcLocn.code.String &amp; Tab &amp; _srcLocn.description;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_srcLocn" type="CM_SourceSubSubLocation"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="7c6bbdfb-8cab-498a-b760-052460a2622b">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpCodeGroup : CM_CodesByCodeDict;
begin
	if self.mySubSourceLocation &lt;&gt; null then
		tmpCodeGroup := self.mySubSourceLocation.allSubSubLocations;
	endif;

	return tmpCodeGroup;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="init" id="706d28c1-50f7-48b4-a94b-0cb9ea6e8498">
        <updating/>
        <source>init() updating, protected;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll		: Collection;
	idx, 
	token		: Integer;
	saveText,
	code,
	tmpStr		: String;
	obj			: Object;
	tmpObj		: CM_SourceSubSubLocation;
	isDeleted	: Boolean;
	
begin
	coll := self.getCollectionJMT();
	if coll = null then
		self.amInitialised := false;
		return;
	endif;
	isDeleted := true;
	
	// save the current text as calling listCollection
	// clears the current text
	if self.text &lt;&gt; null then
		token 		:= 1;
		saveText 	:= self.text;
		code 		:= self.text.getNextToken(token);
	endif;
	
	foreach obj in coll.CM_CodesByCodeDict do
		if obj.CM_SourceSubSubLocation.code = code then
			isDeleted := false;
		endif;
		
		self.addItem(obj.CM_SourceSubSubLocation.code &amp; Tab &amp; obj.CM_SourceSubSubLocation.description);
	endforeach;

	if isDeleted and code &lt;&gt; null then
		self.addItem(code &amp; Tab &amp; "Deleted");
	endif;
	
	self.selLength := 1000;			
	idx := self.findString(1, saveText);

	if idx &gt; 0 then
		self.listIndex := idx;
		self.setEntryTableCell();
		self.text := saveText;
	else
		self.text := null;
	endif;
		
	self.amInitialised := true;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setObjectAndSrcSubLocation" id="929b6fa7-ed4e-41ee-87a2-bd937f94b0bf">
        <updating/>
        <source>setObjectAndSrcSubLocation(_obj : CM_SourceSubSubLocation; _srcSubLocation : CM_SourceSubLocation) updating;
// -------------------------------------------
// Created 29 september 2005 by cnwhjg1
// -------------------------------------------
vars

begin
	if self.mySubSourceLocation &lt;&gt; _srcSubLocation  or _obj &lt;&gt; self.myObject then
		self.mySubSourceLocation := _srcSubLocation;

		if _obj = null then
			self.text := null;
			self.amInitialised := false;
		// want collection to reset itslef which does not happen if obj is null. 
			self.myObject := _obj;
			self.zInit();
			
			if self.findObject(_obj) &gt; 0 then
				self.listObject := _obj;
			else
				self.clear();
			endif;	
			return;
		endif;
		
		
	endif;
	// Forces a clear because we want new .
	self.amInitialised := false;
	
	self.setObject(_obj);
	

end;</source>
        <Parameter name="_obj" type="CM_SourceSubSubLocation"/>
        <Parameter name="_srcSubLocation" type="CM_SourceSubLocation"/>
    </JadeMethod>
    <JadeMethod name="setTextForDisplayCollection" id="ff70664b-5360-445b-b4cb-120638b90858">
        <updating/>
        <source>setTextForDisplayCollection(_text: String) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_text);
	
	if (not self.amInitialised) and
		self.mySubSourceLocation = null and 
		_text &lt;&gt; null then
		// init call in inheritMethod failed
		self.clear;
		self.addItem(_text);
		self.text := _text;
	endif;

end;
</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
