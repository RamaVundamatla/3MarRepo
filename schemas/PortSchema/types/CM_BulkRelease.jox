    <JadeMethod name="cleanUpReserveDetails" id="5df5820a-2da4-431b-815b-fd69f5a06856">
        <source>cleanUpReserveDetails();

/*

Purpose:			If user changes the release from one type to another (eg a release by type to a release by id)
					Make sure the correct reserve details remain.
					Refer to par 25953

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2010	cnwmd1	Initial creation

*/

vars
	rd : CM_ReserveDetail;
	wrongClass : Class;
begin
	if self.releaseByType then
		wrongClass := CM_ReserveTI;
	else
		wrongClass := CM_ReserveSelection;
	endif;
	
	foreach rd in self.allReserveDetails do
		if rd.class = wrongClass then
			delete rd;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cloneForRoll" id="c065039f-7ed2-4159-b860-00c84572ceb5">
        <source>cloneForRoll(_newBookingRef :CM_BookingRef) :CM_BulkRelease;
/* Changes

Date		Name	TFS#		Description
============================================================================
13/05/2016	cnwns1	TFS 488		Multi Timezone Support
24/01/2019	jlgka1	41708		Add myBOLIn.
============================================================================*/
vars
	newBulkRelease	: CM_BulkRelease;
	cloneReserve,
	realReserve		: CM_ReserveDetail;
	bookingRefItem	: CM_BookingRefItem;
begin
	newBulkRelease := self.copySelf(true).CM_BulkRelease; //creat pxy for create later for audit cnwrd1 12.2.09 par #17936

	newBulkRelease.setRequestDate(app.actualTimeServer);	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	newBulkRelease.myCargoType				:= self.myCargoType;
	newBulkRelease.myLoadPort				:= self.myLoadPort;
	newBulkRelease.myDestinationPort		:= self.myDestinationPort;	// 04 Nov 2009	NDL	Par 21519
	newBulkRelease.myAssignedTrain			:= self.myAssignedTrain;	// 04 Nov 2009	NDL	Par 21519

	if _newBookingRef.dischargePort &lt;&gt; null then
		newBulkRelease.myDischargePort := app.myRoot.allPorts[_newBookingRef.dischargePort];
	else
		newBulkRelease.myDischargePort	:= null;
	endif;
	
	newBulkRelease.myDischargePort			:= self.myDischargePort;
	newBulkRelease.myOperator				:= self.myOperator;
	newBulkRelease.myOperatorGroup			:= self.myOperatorGroup;
	newBulkRelease.myTerminal				:= self.myTerminal;
	newBulkRelease.myTransferToTerminal		:= self.myTransferToTerminal;
	newBulkRelease.myISOGroup				:= self.myISOGroup;
	newBulkRelease.myVoyage					:= _newBookingRef.myVoyage;
	newBulkRelease.myBusinessUnit			:= self.myBusinessUnit;
	newBulkRelease.myBOLIn					:= self.myBOLIn; //jlgka1 TFS 41708
	
	/* should not copy over attached TIs */
	foreach realReserve in self.allReserveDetails do
		cloneReserve := realReserve.cloneSelf(true); //creat pxy for create later for audit cnwrd1 12.2.09 par #17936

		realReserve.cloneReferences(cloneReserve, true); //creat pxy for create later for audit cnwrd1 12.2.09 par #17936
		
		if realReserve.myBookingRefItem &lt;&gt; null then
			bookingRefItem	:= realReserve.myBookingRefItem.cloneForRoll;
			bookingRefItem.setMyReserveDetail(cloneReserve);
			bookingRefItem.setMyBookingRef(_newBookingRef);
		endif;
		
		cloneReserve.setMyHeader(newBulkRelease);
	endforeach;
		
	return newBulkRelease;
end;
</source>
        <Parameter name="_newBookingRef" type="CM_BookingRef"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="7f7437ec-e516-4a8b-abf4-26734abee129">
        <source>cloneReferences(_clone : SelfType input; bTransient : Boolean);
/*
----------   ----------  --------------------------------------------------
Created:	08 October 2007 By cnwth2

Purpose:	At the time of development, this will be specifically be called from 
			the "Next" button in the release requests screen. We want to clone
			all but the code field (cleared by the caller). That is why pxyCreateUpdateProxy 
			cannot be used in this instance, as the link to the original persistent
			object is unwanted

/* Changes

Date		Name	TFS#	Description
============================================================================
24/10/2012	cnwmh5	#30539	Change to only copies reserve detail if Release By Type or Release By Id and waybill
24/01/2019	jlgka1	41708	Add myBOLIn.	
============================================================================*/
vars
	
	persistentReq,
	cloneReq						: CM_Request;
	cloneReserve,
	realReserve						: CM_ReserveDetail;	
	
begin
	_clone.myCargoType				:= self.myCargoType;
	//_clone.myFreightForwarderTerminal:= self.myFreightForwarderTerminal;			// removed for PAR 20646
	_clone.myLoadPort				:= self.myLoadPort;
	_clone.myDischargePort			:= self.myDischargePort;
	_clone.myDestinationPort		:= self.myDestinationPort;	// 04 Nov 2009	NDL	Par 21519
	_clone.myAssignedTrain			:= self.myAssignedTrain;	// 04 Nov 2009	NDL	Par 21519
	_clone.myOperator				:= self.myOperator;
	_clone.myOperatorGroup			:= self.myOperatorGroup;
	_clone.myTerminal				:= self.myTerminal;
	_clone.myTransferToTerminal		:= self.myTransferToTerminal;
	_clone.myISOGroup				:= self.myISOGroup;
	_clone.myVoyage					:= self.myVoyage;
	_clone.myBusinessUnit			:= self.myBusinessUnit;
	_clone.mySubTerminal			:= self.mySubTerminal; //11/01/2010 cnwdz2 22086
	_clone.mySubTerminalTarget		:= self.mySubTerminalTarget; // cnwrd1 par 23219 17.3.2010
	_clone.myBOLIn					:= self.myBOLIn; //jlgka1 TFS 41708
	
	/*should not copy over attached TIs	*/
	if self.releaseByType or (not self.releaseByType and self.isWaybill) then						// 24/10/2012 cnwmh5 #30539
		foreach realReserve in self.allReserveDetails do
			cloneReserve := realReserve.cloneSelf(bTransient);
			realReserve.cloneReferences(cloneReserve, bTransient);
			cloneReserve.setMyHeader(_clone);
		endforeach;
	endif;
	
	foreach realReserve in self.allReservePackingChildren do
		cloneReserve := realReserve.cloneSelf(bTransient);
		realReserve.cloneReferences(cloneReserve, bTransient);
		cloneReserve.setMyHeader(_clone);
	endforeach;
end;


</source>
        <Parameter name="_clone" type="SelfType" usage="input"/>
        <Parameter name="bTransient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="209321d6-0fa8-4e98-92b4-a4f30ccd1844">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setStatus(BR_NOTSET, false, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="createAssignedTransaction" id="8e8c9e37-238e-4340-b9f1-703b42322124">
        <source>createAssignedTransaction(_ti : CM_TrackedItem input; _unassign : Boolean);
/*
Date		Who		Reason
27 Feb 2009	cnwar2	Initial creation	#17320
29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
17 Aug 2016	NDL		TFS 2559 STW use Road and Packing Releases with the same code, so we now store and check release type too.
10/07/2018 	jlgns1	Bug 39350: POL - [Fwd: ##RE-8138## : FW: Emailing: Rail Release error in Test June 2018 ##8138##]
*/

vars
	txnParams : CMIF_TITransactionController;
	otherTrx,
	trx  : CM_TITransaction; 
	
	//11 Jan 2016	NDL	TFS 3189/2876
	assignTrxToRestoreFrom : CM_RelRequestAssign;
	yardWle : CM_YardWLE;
	req : CM_Request;
	resSel : CM_ReserveSelection;
	rrpForRailTi: CM_TrackedItem;
	terminal : CM_Terminal;		//	Bug 39350

begin

	create txnParams transient;
	if _unassign then
		txnParams.type := TRANS_TYPE_REL_REQ_UNASSIGN;
	else
		txnParams.type := TRANS_TYPE_REL_REQ_ASSIGN;
	endif;
	txnParams.myTrackedItem := _ti;
	txnParams.myBulkRelease := self;
	
	// if called from setForUpdate then self.myTerminal may still be null 
	if self.myTerminal &lt;&gt; null then					//	Bug 39350
		terminal := self.myTerminal;				//	Bug 39350
	elseif _ti.myTerminal &lt;&gt; null then				//	Bug 39350
		terminal := _ti.myTerminal;					//	Bug 39350
	else											//	Bug 39350
		terminal := app.myPassport.myTerminal;		//	Bug 39350
	endif;											//	Bug 39350
		
	//epr TFS 2329 26/7/16 already has the trx don't create another one
	trx := _ti.allTransactions.getLastTransOfType(txnParams.type, self);	// 7/11/16 cnwmp6 TFS 2891
	if trx &lt;&gt; null then
		if _unassign then
		//	if trx.CM_RelRequestUnassign.myBulkReleaseCode = self.code then
			if trx.CM_RelRequestUnassign.myBulkReleaseCode = self.code and trx.context = self.type then	//17 Aug 2016	NDL	TFS 2559
				otherTrx:=_ti.allTransactions.getLastTransOfType(TRANS_TYPE_REL_REQ_ASSIGN, self);	// 7/11/16 cnwmp6 TFS 2891
				//if there no assign or the assign is before the unassign return 
				if otherTrx = null
				or (otherTrx.CM_RelRequestAssign.myBulkReleaseCode &lt;&gt; self.code)
				or (otherTrx.CM_RelRequestAssign.context &lt;&gt; self.type)	//17 Aug 2016	NDL	TFS 2559
				or (otherTrx.CM_RelRequestAssign.myBulkReleaseCode = self.code and otherTrx .dateTime &lt; trx.dateTime )
				then
					return;
				endif;
			endif;
		else
		//	if trx.CM_RelRequestAssign.myBulkReleaseCode = self.code then
			if trx.CM_RelRequestAssign.myBulkReleaseCode = self.code and trx.context = self.type then	//17 Aug 2016	NDL	TFS 2559
				otherTrx:=_ti.allTransactions.getLastTransOfType(TRANS_TYPE_REL_REQ_UNASSIGN, self);	// 7/11/16 cnwmp6 TFS 2891
				//if there no unassign or the unassign is before the assign return
				if otherTrx = null
				or (otherTrx.CM_RelRequestUnassign.myBulkReleaseCode &lt;&gt; self.code)
				or (otherTrx.CM_RelRequestUnassign.context &lt;&gt; self.type)	//17 Aug 2016	NDL	TFS 2559
				or (otherTrx.CM_RelRequestUnassign.myBulkReleaseCode = self.code and trx .dateTime &gt; otherTrx.dateTime )
				then
					return;
				endif;
			endif;		
		endif;
	endif;
	
	_ti.createTransaction(txnParams, app.myPassport);
	
	
	//11 Jan 2016	NDL	TFS 3189/2876 - When unassigning for ship releases for STWR reset voyage,
	//									dischargePort and IMEX to values that were in place as at
	//                                  the time of originally assigning it.
	if _unassign then
		if self.isShipType and terminal.getConfig( UnassignResetsPrevVals ).Boolean then				//	Bug 39350
			assignTrxToRestoreFrom := _ti.allTransactions.getLastTransOfType( TRANS_TYPE_REL_REQ_ASSIGN, self ).CM_RelRequestAssign;
			if assignTrxToRestoreFrom &lt;&gt; null then
				_ti.restorePreAssignValues( assignTrxToRestoreFrom );
			endif;
			
		elseif self.isRailType and terminal.getConfig( UnassignResetsPrevVals ).Boolean then			//	Bug 39350
			//12 Jan 2016	NDL	TFS 3192/2877 - When unassigning cargo from Rail requests, if the
			//								cargo is unactioned AND assigned to a WLE that is targetting a wagon
			//                              disassociate the cargo and replace with a 'tba'
			if _ti &lt;&gt; null and not _ti.isRRPforRail then
				yardWle := self.getWagonLoadWleFor( _ti );
				if yardWle &lt;&gt; null then
					req := yardWle.myRequest;
					if req &lt;&gt; null and req.myReserveDetail &lt;&gt; null and req.myReserveDetail.isKindOf( CM_ReserveSelection ) then
						resSel := req.myReserveDetail.CM_ReserveSelection;
						if resSel &lt;&gt; null then
							rrpForRailTi := resSel.createPlanningTrackedItem(null, null, false);
						endif;
					endif;
					yardWle.setMyTrackedItem( rrpForRailTi );
					if rrpForRailTi &lt;&gt; null then
						req.setBulkReleaseTI( rrpForRailTi );
						yardWle.job.updateTICollections(rrpForRailTi, yardWle);
						if resSel.allTrackedItems.includes( rrpForRailTi ) then
							resSel.allTrackedItems.remove( rrpForRailTi);
							//13 Dec 2017	NDL	TFS 8091
							if not resSel.isTransient then
								self.updateObjectEdition( resSel );
							endif;
						endif;
						if rrpForRailTi.allBulkReleasesAssigned.includes( self ) then
							rrpForRailTi.allBulkReleasesAssigned.remove( self);
						endif;
					endif;
					yardWle.causeEvent(terminal.getTerminalEvent(WLE_Update_Event), false, yardWle);	//	Bug 39350
				endif;
			endif;
		endif;
	endif;
	
	_ti.updateObjectEdition(_ti);  // par 30292 //+ cnwmd1 Par 23108
	
epilog
	delete txnParams;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_unassign" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createEmailFromType" id="25c2544f-13d4-4b51-be27-c0a386f68557">
        <source>createEmailFromType(_defaultEmailType : Integer) : CM_PINObjectDefaultEmail protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwer1	Initial creation PAR 28625

*/

vars
	defEmail,
	carrierEmail		: CM_PINObjectDefaultEmail;
	emailController		: CMIF_EmailTemplateController;
	carrier				: CM_Carrier;
	consignee			: CM_ConsigneeConsignor;
begin
	defEmail	:= self.myTerminal.getEmailDefaultsSettings( _defaultEmailType );
	// cnwrl1 24/07/2009 PAR 20349 - end of coding
	
	if defEmail = null then
		return null;
	endif;
	
	if self.myEmailTemplate &lt;&gt; null then	// there is persistent email info set on the bulk release
		create carrierEmail transient;
		create emailController transient;
		carrierEmail.setEmailController(emailController);
		carrierEmail.setFromEmailTemplate(self.myEmailTemplate);		
		carrierEmail.setSubjectFieldsFromEmailDefau(defEmail);
		
	else	// creating default email
		carrierEmail 		:= defEmail.cloneSelf(true);
		carrier 			:= self.getCarrier();
		consignee			:= self.getConsignee();
		carrierEmail.setAddresses( self.myTerminal, carrier, consignee, _defaultEmailType );
	endif;
	
	return carrierEmail;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_defaultEmailType" type="Integer"/>
        <ReturnType type="CM_PINObjectDefaultEmail"/>
    </JadeMethod>
    <JadeMethod name="createPlanningTrackedItem" id="870adb73-2605-40fd-aeb4-f21629954ca6">
        <source>createPlanningTrackedItem(slotPosition : String) : CM_TrackedItem;
// 08/06/2010 cnwmh5 #20661 - Add passing of slot controller
// 30/11/2010 cnwdap1 PAR #26426 CCMS MES 1102 add boolean "_transient" parameter
vars

begin
	if self.allReserveDetails.size = 0 then
		return null;
	endif;
	
	return self.allReserveDetails.first.CM_ReserveSelection.createPlanningTrackedItem(slotPosition, null, true);
end;
</source>
        <Parameter name="slotPosition" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createPxyEmailTemplate" id="15c6539f-0aae-41ae-bac1-95bd81b42b3d">
        <updating/>
        <source>createPxyEmailTemplate() : CM_EmailTemplate updating;
/* ---------------------------------------------------------------------------
Created:	17 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	pxyEmailTemplate	: CM_EmailTemplate;
	
begin

	self.raiseExceptionIfNotTransient(method);

	create pxyEmailTemplate transient;
	//self.setMyEmailTemplate(pxyEmailTemplate);
	pxyEmailTemplate.setMyParent(self);
	return pxyEmailTemplate;

end;</source>
        <ReturnType type="CM_EmailTemplate"/>
    </JadeMethod>
    <JadeMethod name="createRequests" id="a26e3be3-c142-4750-af51-374bd6b4d845">
        <source>createRequests() : CM_DeliveryRequest;
// 25/09/2012	cnwcs5	par 30390 - removed CM_ReserveDetail::voyageCode property
vars
	pxyDeliveryRequest		: CM_DeliveryRequest;
	reserveDetail			: CM_ReserveDetail;
	operatorCode,
	remarks,
	releaseNum 				: String;
	totalRequested			: Integer;
	consigneeString			: String;
	idMask 					: String;
	array					: StringArray;
	tas						: CM_TerminalAreaArray;
	colour, mark			: String;
begin
	reserveDetail := self.allReserveDetails.first;
	
	if reserveDetail = null then
		return null;
	endif;
	
	if self.type = BR_TYPE_BOL then
		releaseNum := self.code;
	endif;
	
	if self.myOperator &lt;&gt; null then
		operatorCode := self.myOperator.code;
	endif;
	
	if CM_ReserveSelection.hasInstance(reserveDetail) then
		totalRequested := reserveDetail.totalRequested;
		colour := reserveDetail.CM_ReserveSelection.colour;
		mark := reserveDetail.CM_ReserveSelection.markSelection;
	else
		totalRequested := 1;
	endif;
	//th2 PAR 14496 - Remarks missing from Road Ops
	if self.releaseByType then
		remarks := reserveDetail.remarks;
	else
		remarks := self.cargoRemarks;
	endif;
	// this has to be the code otherwise we will get a string to long exception unless we also have a consignee desc on deliveryRequest
	if self.consigneeCode = null then			// dh 5/9/2008 for APM changes
		consigneeString := null;
	else										
		consigneeString := self.consigneeCode;	
	endif;										
	
	create pxyDeliveryRequest transient;

	pxyDeliveryRequest.set(	consigneeString,		// 
							self.consignorVoyageCode,
							releaseNum,	// deliveryNumber, 
							null,			// eirNumber,
							reserveDetail.getISOTypeCode(),
							operatorCode,
							self.myOperatorGroup, //tmpOperatorGroup,
							reserveDetail.getCargoType,
							reserveDetail.getClean(),
							reserveDetail.getDoISOGroupCheck,	// RDD 8/8/2001 Xpose 1231/POT 147
							TI_DOORSDIRN_NULL,
							reserveDetail.getHeavyRated,
							false,
							null,//needCOU
							null, //need generator
							false, // TFS 2686 reserveDetail.getRemoveStops,
							totalRequested,
							self.deliveryReasonCode,
							self.getAllAvailabilityGrades, 
							self.deliveryReasonDescr,
							remarks,
							null,	//Ids
							null,	// pinNo
							self.myTransferToTerminal,
							null,
							self.mySubTerminal,						// cnwdad1 02/07/2009 - CCMS 1735.
							self.getISOGroupCode,					// MES1008 JMH 29/9/09 Add iso group
							0,
							colour,
							mark,
							reserveDetail.getBOLNumber //18 Feb 2014	NDL	Par 33524
							);
	
	pxyDeliveryRequest.voyageCode := reserveDetail.getVoyageCode;	// par 30390 Spet 2012
	
	idMask := self.getMaskIdString;  								// dh 25/1/2008 par 15489 added back in
	
	if idMask &lt;&gt; null then		
		create array transient;
		idMask.convertToDelimitedArray(",", array);
		if array &lt;&gt; null then
			pxyDeliveryRequest.setIds(array);
		endif;
	endif;													// dh end of change
	
	if CM_ReserveSelection.hasInstance(reserveDetail) then
		create tas transient;
		reserveDetail.CM_ReserveSelection.allTerminalAreas.copy(tas);
		pxyDeliveryRequest.setNominatedTAs(tas, null);
	endif;
	
	pxyDeliveryRequest.setBulkRelease(self);
	
	return pxyDeliveryRequest;
epilog
	delete array;
	delete tas;
end;</source>
        <ReturnType type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="createWOFromBulkRelease" id="9dc31157-5158-4113-b5c2-411545ff83f8">
        <source>createWOFromBulkRelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2023 navmv20 CR 58410 Task 58413: UI - Cargo Review - Create Work Order
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
24 Jul 2023 navma1	Bug 59259: MTN - Error when actioning work order created by cargo review Screen
27 May 2025	navpw1	JIRA: MTN-34975 - Added a variable for customerReference so that we can check if the reserveDtl is a reserve selection before we attempt to read customerReference
12 Jun 2025	navah1	Bug 34978: MTN - Cargo Review - Cannot Create Release Request by Id Raises a 91758
*/

vars
	pxyWoDtl, 
	woDtl 		   : CM_WorkOrderDtl;
	reserveDtl	   : CM_ReserveDetail;
	bookingRef 	   : CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
	pxyWO		   : CM_WorkOrder;
	emails         : CM_EmailEntityByTypeNameDict;
	realWO         : CM_WorkOrder;
	voyage         : CM_Voyage;
	train          : CM_Train;
	woDtlSet 	   : CM_WorkOrderDtlSet;
	bookingRefStr  : String;
	requiredByDT,
	now            : TimeStamp;
	customerReference	: String; 
begin
	
	if self.type = BR_TYPE_RAIL then
		train := self.myAssignedTrain;
	elseif self.type = BR_TYPE_SHIP then
		voyage := self.myVoyage;
	endif;
	
	create woDtlSet transient;
	
	foreach reserveDtl in self.allReserveDetails do
		create pxyWoDtl as CM_WodRelease transient;
		bookingRefItem := reserveDtl.myBookingRefItem;
		if bookingRefItem &lt;&gt; null then	
			bookingRef := bookingRefItem.myBookingReference;
			if bookingRef &lt;&gt; null then
				bookingRefStr := bookingRef.bookingReference;
			endif;
		endif;
		pxyWoDtl.CM_WodRelease.setProxyWodRelease(self , 
												  self.type , 
												  voyage, 
												  train,
												  bookingRef,							//04.07.2023 navma1 #58952
												  bookingRefItem,						//04.07.2023 navma1 #58952
												  reserveDtl);
		woDtlSet.add(pxyWoDtl);
		if not self.releaseByType then			//12.06.2025 navah1 #34978  
			break;
		endif;
	endforeach;
	
	create pxyWO as CM_WorkOrderTI transient;
	create emails transient;
	
	reserveDtl := self.allReserveDetails.first;
	
	now := app.actualTimeServer;
	
	if self.dateRequested.isValid() then
		requiredByDT := self.dateRequested;
	elseif self.dateEstimatedRequired.isValid() then
		requiredByDT := self.dateEstimatedRequired;
	else
		requiredByDT := now;
	endif;
	
	// ### JIRA: MTN-34975 27May2025 NAVPW1
	if reserveDtl.isReserveSelection then
		customerReference := reserveDtl.CM_ReserveSelection.customerReference;
	endif;
	// ### JIRA: MTN-34975 27May2025 NAVPW1
	pxyWO.setProxy(	
			emails,
			customerReference,					// ### JIRA: MTN-34975 27May2025 NAVPW1
			false, 								//_emailNotification
			now, 								//_enteredByDT
			app.getMyUser(), 					//_enteredByUser 
			'',									//_approvedBy
			app.getMyUser().myOrganisation, 	// _myOrganisation
			app.myPassport.myTerminal, 			//_myTerminal
			self.remarksAdditional1,  			//_remarks
			requiredByDT,						//_requiredByDT
			null, 								//_startAtDT
			WO_STATUS_USERENTRY					//_taskStatus    WO_STATUS_USERENTRY
			);
	
	foreach woDtl in woDtlSet do
		pxyWO.setProxyWorkOrderTask( woDtl, requiredByDT, null, false,null, null);	//24.07.2023 navma1 #59259
		if woDtl.isKindOf(CM_WodRelease) and not self.releaseByType then			//12.06.2025 navah1 #34978  
			self.allTrackedItemsAssigned.tryCopy(woDtl.CM_WodRelease.allSelectedTIs); 
		endif;
	endforeach;
	
	app.myUtilityCA.utlCreateWorkOrder(pxyWO, realWO, app.myPassport);
epilog
	// ### TFS CR 60922 TASK 60980 30OCT2023 NAVAB1
	delete pxyWO;
	woDtlSet.purge;
	delete woDtlSet;
	delete emails;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="e7e3187e-45f4-4f81-ba50-cd89b0b32d29">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     13 March 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/09/2008	concms1		par 16130 - 
// 25/02/2013	cnwcs5		CCMS PNL 2243 / par 31185
// ---------------------------------------------------------------------------
vars
	
	ti				: CM_TrackedItem;
	gotException	: Boolean;
	tisToDelete  	: CM_TISet;
begin

	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152

	self.auditLogs.purge;
	
	//CCMS 1616 - deletting the pin after the bulk release has been deletd.
	if self.myPinNo &lt;&gt; null then
		self.myPinNo.removeItem(self, true);	// par 16130
	endif;
	
	// self.requests will be deleted by parent/child relationship
	
	// par 31185 -  EDI creates proxy tracked items which need to be deleted 
	// this used to be done in loadDb but this is the correct place
	if self.isTransient then
		on Exception do app.handleDeletedObject (exception, ti, gotException);
		//epr clean up transients tfs 2606
		create tisToDelete transient;
		foreach ti in self.allTrackedItemsAssigned do
			if ti.isTransient then 
				tisToDelete.add(ti);
			endif;
		endforeach;
		
		tisToDelete.purge;
	endif;
	
epilog
	delete tisToDelete;
end;</source>
    </JadeMethod>
    <JadeMethod name="detachUnusedTIs" id="ed435535-6031-4ced-87ce-8af432b3234c">
        <updating/>
        <source>detachUnusedTIs()updating, protected;
//--------------------------------------------------
// Created:	22 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	ti 				: CM_TrackedItem;
	iter 			: Iterator;
	reserveDetail	: CM_ReserveDetail;
	
begin
	//Only detach if complete/archived
	if self.status &lt;&gt; BR_COMPLETE
	and self.status &lt;&gt; BR_ARCHIVE then
		return;
	endif;
	
	foreach ti in self.allTrackedItemsAssigned do
		self.removeTIAssigned(ti);
		// moved transaction create to above method (PAR 23115)
		//self.createAssignedTransaction(ti, true);	// 20/07/2009 cnwar2 #20227
	endforeach;

epilog
	delete iter;		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCompleteIfLastItem" id="5df21181-9b7d-4d08-bba8-3abf73b1f1ca">
        <updating/>
        <source>doCompleteIfLastItem()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2015	cnwndl1	Initial creation	Par 37288
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	resDetail : CM_ReserveDetail;
	assocTi : CM_TrackedItem;
	packCompleteCount : Integer;
	packCompleteWeight : Decimal[16,4];
	invalidObj : Boolean;
	allTis		: CM_TISet;
begin

	if not self.isPackingType then
		//Only touch packing requests
		return;
	endif;
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	if self.status &lt;&gt; BR_ACTIVE then
		//Only consider active ones.
		return;
	endif;
	
	if self.allReserveDetails.isEmpty and self.allReservePackingChildren.isEmpty then
		// No parents or children, leave it alone, can't be populated yet
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, resDetail, invalidObj );
	
	// OK, so if all amounts requested have been satisfied, 
	// and all children are packed, and all Parents are marked as 'Pack Complete'
	// then the Packing Request, should be marked as 'Complete' .
	
	//Parents first
	foreach resDetail in self.allReserveDetails do
		packCompleteCount := 0;
		resDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach assocTi in resDetail.allTrackedItems do
		foreach assocTi in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			//Parent Tracked item
			if not assocTi.isPackingComplete then
				return;
			endif;
			packCompleteCount := packCompleteCount + assocTi.totalQuantity.max(1);
		endforeach;
		foreach assocTi in resDetail.allTrackedItemsReleased do
			packCompleteCount := packCompleteCount + assocTi.totalQuantity.max(1);
		endforeach;
		if resDetail.totalRequested &gt; packCompleteCount then
			// not enough  on the parent detail yet.
			return;
		endif;
	endforeach;
	
	if invalidObj then
		//somethings up, bail, don't change it.
		return;
	endif;
	
	//Now children
	foreach resDetail in self.allReservePackingChildren do
		packCompleteCount := 0;
		packCompleteWeight := 0;
		resDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach assocTi in resDetail.allTrackedItems do
		foreach assocTi in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			//Make sure cargo selected to be packed as been.
			if not assocTi.isChild then
				return;
			endif;
			packCompleteCount := packCompleteCount + assocTi.totalQuantity.max(1);
			packCompleteWeight := packCompleteWeight + assocTi.totalWeight;
		endforeach;
		foreach assocTi in resDetail.allTrackedItemsReleased do
			packCompleteCount := packCompleteCount + assocTi.totalQuantity.max(1);
			packCompleteWeight := packCompleteWeight + assocTi.totalWeight;
		endforeach;
		if resDetail.weightRequested &gt; 0 then
			// pack by weight or volume
			if resDetail.weightRequested &gt; packCompleteWeight then
				// not enough of this sort of children packed yet.
				return;
			endif;
		elseif resDetail.totalRequested &gt; packCompleteCount then
			// not enough of this sort of children packed yet.
			return;
		endif;
	endforeach;
	
	if invalidObj then
		//somethings up, bail, don't change it.
		return;
	endif;
	
	//All nominated children packed, and all parents 'pack complete' and requested amount for everything has been met.
	self.setStatus( BR_COMPLETE, false, false );

epilog
	delete allTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="emailNotify" id="1240c4df-943d-4398-bfb3-4e81b1458c07">
        <source>emailNotify(_carrierEmail: CM_PINObjectDefaultEmail; _isDelete: Boolean; _pin: CM_PinNo input);
//----------------------------------------------------------------
//	Created:	20 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	transToDelete,
	carrierEmail		: CM_PINObjectDefaultEmail;
	emailController		: CMIF_EmailTemplateController;
	defaultEmailType	: Integer;
	
begin
	if _carrierEmail = null then
		// cnwrl1 30/07/2009 PAR 20349 - start of coding
		if _isDelete then
			defaultEmailType	:= PINEmail_ReleaseRequestDelete;
		else
			defaultEmailType	:= PINEmail_ReleaseRequest;
		endif;
		
		carrierEmail := self.createEmailFromType(defaultEmailType);	
		transToDelete := carrierEmail;
	else
		carrierEmail := _carrierEmail;
	endif;
	
	//epr par 28625 1/3/12
	if carrierEmail.myEmailController.freeTxtToAddesses = null then
		 carrierEmail.myEmailController.freeTxtToAddesses:= carrierEmail.myEmailController.freeTxtCcAddesses;
		  carrierEmail.myEmailController.freeTxtCcAddesses := null;
	endif;
	
	if not carrierEmail.okToSend() or app.isUnitTestGarbageCollect then
		return;
	endif;
	
	inheritMethod(carrierEmail, _isDelete, _pin);

	if _pin &lt;&gt; null then	//Par 19408. ccms 1769 April 2009
		_pin.addRecipientEmails(carrierEmail, true);
	endif;
	
epilog
	delete transToDelete;
end;</source>
        <Parameter name="_carrierEmail" type="CM_PINObjectDefaultEmail"/>
        <Parameter name="_isDelete" type="Boolean"/>
        <Parameter name="_pin" type="CM_PinNo" usage="input"/>
    </JadeMethod>
    <JadeMethod name="emailNotifyForStatusChanged" id="ee00f7dc-3df8-49f9-90ac-5b1e905d4999">
        <source>emailNotifyForStatusChanged(_oldStatus, _newStatus : Integer) protected;
/* ---------------------------------------------------------------------------
Created:	16 April 2009	by cnwvu1

Purpose:	Par 19408. CCMS 1769 - emailng carriers when status of bulk release
			changed:
			Pending	--&gt; Active or 
			Active	--&gt; Pending.
   
Change Date		Who		Reason
04/09/2017		cnwma1	TFS # 6670 PEN - RE: Ticket 5132 - Cargo IDs in a continuous loop issue continues to cause Cargo Enquiry to fail and a file lock.
------------------------------------------------------------------------------*/
vars
	carrierEmail,
	defEmail			: CM_PINObjectDefaultEmail;
	defaultEmailType	: Integer;
begin
	
	// cnwrl1 24/07/2009 PAR 20349 - start of coding to replace code above
	if self.myTerminal = null then
		return;	// do nothing
	endif;
	// If the status of the Release Requests changes from "Active" to "Pending" or
	// from any other status to "Active" then an email will be sent to configurable email recipient(s).
	if _oldStatus = BR_ACTIVE and _newStatus = BR_PENDING then
		// type 8 = "Release Request Status Changed To Pending"
		defaultEmailType	:= PINEmail_ReleaseStatusPending;
		
	elseif _newStatus = BR_ACTIVE and _oldStatus &lt;&gt; BR_ACTIVE then
		// type 9 = "Release Request Status Changed To Active"
		defaultEmailType	:= PINEmail_ReleaseStatusActive;
	else
		return;	// do nothing
	endif;
	
	//04/09/2017 cnwma1 TFS #6670
	
	defEmail	:= self.myTerminal.getEmailDefaultsSettings( defaultEmailType );
	if defEmail &lt;&gt; null then
		if not defEmail.enabled then
			return ;
		endif;
	endif;
	//epr par 28625
	carrierEmail:=self.createEmailFromType(defaultEmailType);
	
	self.emailNotify(carrierEmail, false, null);
	
epilog
	delete carrierEmail;
	
end;</source>
        <access>protected</access>
        <Parameter name="_oldStatus" type="Integer"/>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="embargoPIN" id="eed19ffb-ade4-4074-883c-b9888b5ac6a1">
        <source>embargoPIN(_carrierEmail : CM_PINObjectDefaultEmail);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 May 2009	cnwar2	Initial creation

*/

vars

begin
	if self.myPinNo = null then
		return;
	endif;
	
	exclusiveLock(self);
	
	self.myPinNo.isEmbargoed := true;
	self.myPinNo.embargoedTS := app.serverTimestampAtTrxStart;

	self.emailNotify(_carrierEmail, true, self.myPinNo);
	self.myPinNo.allItems.remove(self);
end;</source>
        <Parameter name="_carrierEmail" type="CM_PINObjectDefaultEmail"/>
    </JadeMethod>
    <JadeMethod name="erase" id="d4b51204-930d-4fb2-812e-6c70ab6dd8aa">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/05/2025	naviv1		MTN-34693 - EUP FR | 54084 - CallOff - 1090 Error when accessing Vehicle Booking after cancelling release request

vars
	iter : Iterator;
	request : CM_Request;
	timeSlot : CM_VehicleBookingTimeSlot;
	vbsItem : CM_VehicleBookingTimeSlotItem;
begin

	auditLogs.purge;	
	
	iter := requests.createIterator;

	while iter.next(request) do
		request.erase(_eraseLevel);
	endwhile;
	
	//MTN-34693 -- Clear invalid references to deleted bulk release and reserve selection
	delete iter;
	
	iter := allVBTimeslotsById.createIterator;
	
	while iter.next(timeSlot) do
		foreach vbsItem in timeSlot.allVehicleBookingItems do
			if vbsItem.myBulkRelease = self then
				vbsItem.setMyBulkReleaseToNull();
				if vbsItem.myReserveDetails &lt;&gt; null then
					vbsItem.setMyReserveDetailToNull();
				endif;
			endif;
		endforeach;
	endwhile;
	//MTN-34693 -- End

	inheritMethod(_eraseLevel);

epilog
	delete iter;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="generatePinNo" id="3061cad3-5615-4dd0-ac67-13aeb9922850">
        <updating/>
        <source>generatePinNo(_isEmailChanged : Boolean) : Boolean updating;
//--------------------------------------------------
// Created:	09 January 2006 By: cnwgd1
//--------------------------------------------------
// 13/02/2012	cnwcs5	par 28756 - changed methode signature (noPINforHazardousODProcess)
vars
	updateOK	: Boolean;
begin
	if self.status &lt;&gt; BR_ACTIVE or self.type &lt;&gt; BR_TYPE_ROAD then
		return false;
	endif;
	
	// if PIN exists, it will be deleted when hazardous or OD cargo is attached.
	if self.noPINforHazardousODProcess(self.myPinNo, app.myPassport) then
		// the release request has haz/od cargo so cannot generate PIN		// Par 19432 Feb 2009 (ccms 1676 Par 18864)
		return false;
	endif;
	
	if _isEmailChanged = false or self.myPinNo = null then
		updateOK := app.generatePinNo(self.myPinNo, self.getDescription(true), self.myTerminal);
	endif;
	
	if updateOK and self.myPinNo &lt;&gt; null then
		// send an email out with the PIN
		self.emailNotify(null, false, self.myPinNo);
	endif;
	
	return updateOK;
end;</source>
        <Parameter name="_isEmailChanged" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAgGatewayExtraData" id="b9301e47-d3c1-4136-a24e-97401f9b24e8">
        <source>getAgGatewayExtraData(_key : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2025	navnk30	JIRA 36229: Yara New Discoveries | Special Instructions &amp; BOL Segment in OrderCreate Request XML

*/

vars
	value : String;
begin
	global.getExtraData(self.allExtraData, _key, value);
	return value;
epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllAvailabilityGrades" id="e548b85a-0a7a-4d5c-953b-5fbfae970ae6">
        <source>getAllAvailabilityGrades() : IntegerArray;
/*
----------   ----------  --------------------------------------------------
Created:	28 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	reserve			: CM_ReserveDetail;
begin
	if self.releaseByType then
		if not self.allReserveDetails.isEmpty() then //added by cnwyl1 for par 14885
			return self.allReserveDetails.first.getAllAvailabilityGrades;
		endif;
	else
		return self.allAvailabilityGrades;
	endif;
end;


</source>
        <ReturnType type="IntegerArray"/>
