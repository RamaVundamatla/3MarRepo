    <JadeMethod name="windowCreated" id="5ae2d00c-f71b-465c-bdd8-697670bfe8e8">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: CMUI_RowFrame input; persistCntrl: Control) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     02 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	cntrl.buildSelf();
	cntrl.setCntrlDefaults();
	
	if self.frmInput &lt;&gt; null then
		self.height := self.frmInput.height;
	endif;

end;</source>
        <Parameter name="cntrl" type="CMUI_RowFrame" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
