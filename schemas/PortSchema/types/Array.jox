<CollClass name="Array">
    <JadeMethod name="moveElement" id="d9e0729b-d6c8-4114-b72b-2099fafaf2e0">
        <lockReceiver/>
        <updating/>
        <source>moveElement(pElement:Any; pIsMoveUp:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		14 March 2005 by cnwdad1
//
// Purpose:		Moves the specified array element up or down one (1) position in the
//				receiver.
//
// Parameters:	pElement - A reference to the array element to move.
//				pIsMoveUp - True if the member object is to be moved up one element,
//					otherwise the member will be moved down one element.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementIndex	: Integer;
	
begin
	if pElement = null then
		self.raiseMoveError("The array element to move is null.");
	endif;
	
	if self.size() = 1 then
		return;
	endif;
	
	elementIndex	:=	self.indexOf(pElement);
	
	if elementIndex = 0 then
		self.raiseMoveError("The array element to move (" &amp; pElement.String &amp; ") is not a member of the array.");
	else
		if pIsMoveUp then
			if elementIndex = 1 then
				return;
			endif;
			
			elementIndex	:=	elementIndex - 1;
		else
			if elementIndex = self.size() then
				return;
			endif;
			
			elementIndex	:=	elementIndex + 1;
		endif;
		
		self.remove(pElement);
		self.insert(elementIndex, pElement);
	endif;
end;</source>
        <Parameter name="pElement" type="Any"/>
        <Parameter name="pIsMoveUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="raiseMoveError" id="f5bfa966-7418-40b4-ba98-4d147527e8a9">
        <source>raiseMoveError(pErrorMessage:String) protected;
// --------------------------------------------------------------------------------
// Created:		14 March 2005 by cnwdad1
//
// Purpose:		Raises an exception with the specified error message.
//
// Parameters:	pErrorMessage - An error message to raise the exception with.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08 Jan 2026 navma1 MTN-36897 PEN - Transient File Growth in PEN Production Environment 
// --------------------------------------------------------------------------------
vars
	callStackArray	: ProcessStackArray;
	methodCallObj	: MethodCallDesc;
	methodObj		: Method;
	classObj		: Class;
	
begin
	create callStackArray transient;
	self.cnEcGetPreviousMethods(callStackArray);
	methodCallObj	:=	callStackArray[3];
	methodObj		:=	methodCallObj.method;
	classObj		:=	methodCallObj.getReceiver().class;
	
	app.raiseUnexpectedProgramError(classObj.name, methodObj.name, pErrorMessage);
epilog
	if callStackArray &lt;&gt; null then
		callStackArray.purge();		//08.01.2026 navma1 #MTN-36897
		delete callStackArray;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
</CollClass>
