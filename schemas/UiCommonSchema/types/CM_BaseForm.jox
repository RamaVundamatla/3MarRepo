    <JadeMethod name="openInTiledView" id="df95d23c-a4a7-47bf-854c-a8cbbb25549e">
        <source>openInTiledView() : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theMdiFrame	: Form;

begin

	theMdiFrame := self.getMdiFrame;
	if theMdiFrame &lt;&gt; null and theMdiFrame.isKindOf(CMUI_SuperAppForm2) then
		if app.useTiledView then
			self.move(app.tiledFormLeftPos, 0,
					  theMdiFrame.clientWidth - app.tiledFormLeftPos,
					  theMdiFrame.CMUI_SuperAppForm2.clientWindowHeight);
			return true;
		endif;
	endif;

	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="openWithSavedSettings" id="dfff3698-4856-4f4a-b15c-4e53b3925800">
        <updating/>
        <source>openWithSavedSettings() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	userWindow	: CM_UserWindow;

begin

	if app.getMyUser &lt;&gt; null then
		userWindow := self.myUserWindow;
		if userWindow = null then
			userWindow := app.getUserWindow(self.name, false);
		endif;
		if userWindow &lt;&gt; null then
			self.initFromUserWindow(userWindow);
			return true;
		endif;
	endif;
	
	// only gets to here when no user values to be applied
	self.setRawDefaultSize();	// 14 Sep 2009	NDL Par 20641

	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
