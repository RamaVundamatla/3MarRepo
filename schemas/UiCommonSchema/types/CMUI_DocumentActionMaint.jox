    <JadeMethod name="addInCompleteTableItem" id="c80aae2d-fe4a-400a-9360-828ce9afe99e">
        <source>addInCompleteTableItem(	stop : CM_StopsTable;
				task : CM_ToDoTaskDesc;
				ti : CM_TrackedItem;
				_disableItem : Boolean;
				_remark : String
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation

*/

vars

	totalApplied : Real;
	totCompleted : Real;
	remaining : Real;
	rowIndex : Integer;
	objId : String;
	obj : CM_Object;

begin

	self.myRealDocumentAction.getTotalsForTi( stop, task, ti, totalApplied, totCompleted, remaining );
	if remaining &gt; 0 then
		if stop &lt;&gt; null then
			objId := stop.shortHeading;
			obj := stop;
		elseif task &lt;&gt; null then
			objId := task.shortDescription;
			obj := task;
		endif;
		if _disableItem then
			rowIndex := self.tblCargoIDs.addItem( objId &amp; Tab &amp; "0" &amp; Tab &amp; ti.getMyCargoGroupId &amp; Tab &amp; ti.id &amp; Tab &amp; " " &amp; Tab &amp; remaining.String &amp; Tab &amp; _remark);
			self.tblCargoIDs.accessCell( rowIndex, 2 ).inputType := Table.InputType_CheckBox;
			self.tblCargoIDs.accessRow( rowIndex ).backColor := LightGray;
			self.tblCargoIDs.accessRow( rowIndex ).enabled := false;
		else
			rowIndex := self.tblCargoIDs.addItem( objId &amp; Tab &amp; "1" &amp; Tab &amp; ti.getMyCargoGroupId &amp; Tab &amp; ti.id &amp; Tab &amp; remaining.String &amp; Tab &amp; remaining.String &amp; Tab &amp; _remark);
			self.tblCargoIDs.accessCell( rowIndex, 2 ).inputType := Table.InputType_CheckBox;
			self.tblCargoIDs.accessCell( rowIndex, 3 ).inputType := Table.InputType_None;
			self.tblCargoIDs.accessCell( rowIndex, 3 ).enabled := false;
			self.tblCargoIDs.accessCell( rowIndex, 4 ).inputType := Table.InputType_None;
			self.tblCargoIDs.accessCell( rowIndex, 4 ).enabled := false;
			self.tblCargoIDs.accessCell( rowIndex, 5 ).inputType := Table.InputType_TextNumeric;
			self.tblCargoIDs.accessCell( rowIndex, 6 ).enabled := false;
			self.tblCargoIDs.accessCell( rowIndex, 6 ).itemObject := obj;
			self.tblCargoIDs.accessCell( rowIndex, 7 ).inputType := Table.InputType_None;
			self.tblCargoIDs.accessRow( rowIndex ).itemObject := ti;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="stop" type="CM_StopsTable"/>
        <Parameter name="task" type="CM_ToDoTaskDesc"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="_disableItem" type="Boolean"/>
        <Parameter name="_remark" type="String"/>
    </JadeMethod>
    <JadeMethod name="clickOpts" id="cc93faf6-00ce-4942-b777-9149b72e64d0">
        <source>clickOpts( _initial : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation

*/

vars

begin

	self.cmbStops.enabled := false;
	self.cmbTasks.enabled := false;

	if self.optStops.value then
		self.cmbStops.enabled := true;
	elseif self.optTasks.value then
		self.cmbTasks.enabled := true;
	endif;
	
	self.populateTblCargoIds();
	
	if _initial and self.tblCargoIDs.rows = 1 then
		//no stops need processing, show the tasks
		if self.optStops.value then
			self.optTasks.value := true;
			self.cmbStops.enabled := false;
			self.cmbTasks.enabled := true;
		elseif self.optTasks.value then
			self.optStops.value := true;
			self.cmbTasks.enabled := false;
			self.cmbStops.enabled := true;
		endif;
		clickOpts( false );
	endif;

epilog

	app.mousePointer := Idle;

end;</source>
        <Parameter name="_initial" type="Boolean"/>
    </JadeMethod>
