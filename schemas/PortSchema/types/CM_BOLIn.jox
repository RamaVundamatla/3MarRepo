    <JadeMethod name="hasUnscaledLogs" id="3837ff92-95c9-4b9b-ba53-5e987a6610e4">
        <source>hasUnscaledLogs() : Boolean;
//--------------------------------------------------------------
//Created: 20 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	log : CM_Log;
begin
	if self.bolType &lt;&gt; BOLType_Log then
		return false;
	endif;
	if not self.allTrackedItems.isEmpty then
		log := self.allTrackedItems.last.CM_Log;
		if log.isUnscaled then
			return true;
		else
			return false;
		endif;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importMyCollectionsXML" id="bae3e52e-0cff-4416-b4a4-012ac721b1d8">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	terminal		: CM_Terminal;
	ti				: CM_TrackedItem;
	blockLength,
	pos				: Integer;
	tiId,
	tiBlock			: String;
	foundCargoType,
	cargoType		: CM_CargoType;
	cargoTypeDict	: CM_CargoTypesByIdDict;
begin
	terminal := app.myRoot.allTerminals['POE'];
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminal POE could not be found');
		return;
	endif;
	
	cargoTypeDict := app.myRoot.allCargoTypesById;
	foreach cargoType in cargoTypeDict do
		if cargoType.abbreviation = 'BMLT' then
			foundCargoType := cargoType;
			break;
		endif;
	endforeach;
	
	if foundCargoType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Cargo type "BMLT" not found');
		return;
	endif;
	
	tiBlock := _collectionsBlock.cnEcGetTagValueOfName('allTrackedItems');
	blockLength := tiBlock.length;
	pos := 1;
	while pos &lt;= blockLength do
		tiId := tiBlock.cnEcGetNextTagValueOfName('id', pos);
		if pos &lt; 1 then
			break;
		endif;
		if tiId[1:3] = "220" then
			write tiId;
		endif;
		ti := terminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(tiId, cargoType.id);
//not checking key - I've added some debug code here  JC
		if ti = null then
			ti := terminal.allOffsiteTIsByIdCargoType.getAtKeyGeq(tiId, cargoType.id, null);
			if tiId[1:3] = "220" then
				app.writeStatement(Tab &amp; "offsite");
			endif;
		else
			if tiId[1:3] = "220" then
				app.writeStatement( Tab &amp; "onsite");
			endif;
		
		endif;
		if CM_BreakBulkGeneric.hasInstance(ti) then
			ti.setPropertyValue('myReceivalBOL', self);
		endif;
	endwhile;

end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="eeea482c-e762-49d7-bbd7-c1d9c9db98c4">
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables);
/*
Purpose: OPSVIEW			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars
	opsviewtable : CMIF_CrgBillsOfLading;
	consigneenor : CM_ConsigneeConsignor;
	bolItem 	 : CM_BOLDtl;
begin
	opsviewtable := _opsViewTable.CMIF_CrgBillsOfLading;
	
	opsviewtable.gkey := opsviewtable.generateFullGKey(self, "");
	opsviewtable.client_id := app.myRoot.companyCode;						//05.06.2025 navma1 #MTN-34114
	opsviewtable.nbr := self.number;
	opsviewtable.category := "IMPORT";
	opsviewtable.complex_gkey := opsviewtable.generateCpxGKey();
	opsviewtable.line_gkey := opsviewtable.generateFullGKey(self.myOperator, "");
	
	consigneenor := self.getConsignee();
	if consigneenor &lt;&gt; null then
		opsviewtable.consignee_name := consigneenor.description;
		opsviewtable.consignee_gkey := opsviewtable.generateFullGKey(consigneenor, "");
	endif;
	consigneenor := self.getConsignor();
	if consigneenor &lt;&gt; null then
		opsviewtable.shipper_name := consigneenor.description;
		opsviewtable.shipper_gkey := opsviewtable.generateFullGKey(consigneenor, "");
	endif;
	
	opsviewtable.cv_gkey := opsviewtable.generateFullGKey(self.myVoyage, "");
	opsviewtable.origin := self.loadPortCode;
	opsviewtable.destination := self.dischargePort;
	opsviewtable.notes := self.getRemarks();
	opsviewtable.manifested_qty := self.getBOLQuantityForInvoice();
	opsviewtable.is_direct := self.directDelivery;
	opsviewtable.bl_type := "MASTER";
	opsviewtable.docType := "BILLOFLADING";
	
	bolItem := self.allBOLDtls.first;
	if bolItem &lt;&gt; null then
		if bolItem.myCargoType &lt;&gt; null then
			opsviewtable.cargoSuperType := bolItem.myCargoType.getProductTypeString();
			
		endif;
	endif;
	
	opsviewtable.gid := 0;
	opsviewtable.pin := "";
	opsviewtable.agent_gkey := 0;
	
	
	
end;
</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
