    <JadeMethod name="doProfileMethod" id="5a495c8e-579d-40bd-b34e-e73c0022bff2">
        <source>doProfileMethod() protected;

constants
	DefaultDriverProfileName = "Default";
	
vars
	dpDict : JtdDriverProfileNameDict;
	d : ObjectByStringExtKeyDict;
	mpa : JtdMethodProfileArray;
	drvProfileName : String;
	pd : ProcessDescriptor;
	f : ProfileMethodForm;
	dp : JtdDriverProfile;
	mp : JtdMethodProfile;
	mth : Method;
	scm : Schema;
	
begin
	// assumes this is called from a top-level event method, so if we run
	// into any unexpected exceptions, we'll just cut back to an idle state
	on Exception do app.abortActionExHandler(exception);
	
	if self.mySelectedCmdTarget = null or (not Process.hasInstance(self.mySelectedCmdTarget)) then
		// this command can be sent only to an individual process
		return;
	endif;

	pd := app.mySession.allProcessDescsByProcess[self.mySelectedCmdTarget.Process];

	if pd = null then
		// belts and braces - we haven't got a descriptor for this process!
		return;
	endif;
	
	scm := pd.getProcessSchema;
	
	if scm = null then
		// belts and braces - we can't find the schema the process is running from!
		return;
	endif;

	create mpa transient;

	// get the profile definitions from the process schema
	mth := scm.getProfileTextMethod;

	if mth = null or
	   pd.profileName = null or pd.profileName.toLower = DefaultDriverProfileName.toLower
	then
		// the process schema has no profile definitions or the process is using
		// the default profile, so find all transaction generator methods in the
		// schema from which the process is running
		scm.getTrxGenMethodProfiles(mpa);
		drvProfileName := DefaultDriverProfileName;
	else
		// build descriptions for the profiles defined in the process schema
		create dpDict transient;
		app.createDriverProfilesFromMethod(mth, dpDict, true);
		// can we find a description for the profile the process is using?
		dp := dpDict[pd.profileName];
		if dp &lt;&gt; null then
			// yes, so copy its method profiles
			dp.jtdAllPrologProfiles.copy(mpa);
			dp.jtdAllMethodProfiles.copy(mpa);
			dp.jtdAllEpilogProfiles.copy(mpa);
			drvProfileName := pd.profileName;
		else
			// no, so assume the default and find all transaction generator
			// methods in the schema from which the process is running
			scm.getTrxGenMethodProfiles(mpa);
			drvProfileName := DefaultDriverProfileName;
		endif;
	endif;

	if mpa = null or mpa.size &lt; 1 then
		// can't find anything to profile!
		app.msgBox("The selected process is running from schema " &amp; scm.name &amp; '.' &amp;
			CrLf &amp; CrLf &amp; "The selected process is using the " &amp; drvProfileName &amp;
			" profile." &amp; CrLf &amp; CrLf &amp; "There are no methods available for profiling.",
			"No Methods Available", MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;

	create f transient;
	f.lblProfileName.caption := drvProfileName;
	
	create d transient; // need this to filter duplicate method names
		
	foreach mp in mpa do
		// filter duplicates - add each method name to the listbox only once
		if d[mp.jtdMethodName] = null then
			f.lstMethods.addItem(mp.jtdMethodName);
			d.putAtKey(mp.jtdMethodName, self);
		endif;
	endforeach;
	
	if f.showModal &lt;&gt; 0 or f.selectedMethodName = null or f.outputFileName = null then
		// the user cancelled or didn't select anything
		return;
	endif;

	// request the selected method be profiled
	app.mySession.doCmdProfileMethod(self.mySelectedCmdTarget, f.selectedMethodName, f.outputFileName);
	
epilog
	// purge our method profile array first so that if we've copied references
	// from a driver profile, inverse maintenance will clean up driver profile
	// inverse references (when we purge mpa) before we purge dpDict
	if mpa &lt;&gt; null then
		mpa.purge;
		delete mpa;
	endif;

	if dpDict &lt;&gt; null then
		dpDict.purge;
		delete dpDict;
	endif;

	delete d;
	delete f;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="e4102d2b-9bbf-468b-88fb-cd72d6ff1a7c">
        <updating/>
        <source>doSave(asHTML,onClient:Boolean) updating, protected;

constants
	ColumnGap = 3;
	
vars
	s, ss, txt, totalTimeStr, latestTimeStr : String;
	msf : MachineSummaryForm;
	ts : TimeStamp;
	i, n : Integer;
	t, r, u : Real;
	f : File;
	
begin
	self.lastSaveFileType := 0;
	
	app.mySession.getTotalAndLatestTimeStrings(totalTimeStr, latestTimeStr);

	// Heading ----------------------------------------------------------------------------------------

	if asHTML then
		txt := "&lt;html&gt;" &amp; CrLf &amp; "&lt;head&gt;&lt;title&gt;Benchmark Summary&lt;/title&gt;&lt;/head&gt;" &amp; CrLf &amp;
			'&lt;a name="top" id="top"&gt;&lt;/a&gt;' &amp; CrLf &amp; "&lt;h1&gt;Benchmark Summary&lt;/h1&gt;" &amp; CrLf;
	else
		txt := "Benchmark Summary".withUnderline(true) &amp; CrLf &amp; CrLf;
	endif;
	
	if self.lastSaveFileName &lt;&gt; null then
		if asHTML then
			txt := txt &amp; "File - " &amp; self.lastSaveFileName.withHTMLEntitiesReplaced;
		else
			txt := txt &amp; "File - " &amp; self.lastSaveFileName;
		endif;
		txt := txt.withLineBreaks(2, asHTML);
	endif;

	txt := txt &amp; "Summary created on " &amp; ts.date.String &amp; " at " &amp; ts.time.String &amp;
		'.'.String.withLineBreaks(2, asHTML);

	if asHTML then
		txt := txt &amp; CrLf &amp;
					 "&lt;ul&gt;" &amp; CrLf &amp;
					 '&lt;li&gt;&lt;a href="#results"&gt;Result Summary&lt;/a&gt;&lt;/li&gt;&lt;br /&gt;' &amp; CrLf &amp;
					 '&lt;li&gt;&lt;a href="#drivers"&gt;Driver Summary&lt;/a&gt;&lt;/li&gt;&lt;br /&gt;' &amp; CrLf &amp;
					 '&lt;li&gt;&lt;a href="#transactions"&gt;Transaction Summary&lt;/a&gt;&lt;/li&gt;&lt;br /&gt;' &amp; CrLf &amp;
					 '&lt;li&gt;&lt;a href="#stats"&gt;Statistics&lt;/a&gt;&lt;/li&gt;&lt;br /&gt;' &amp; CrLf &amp;
					 '&lt;li&gt;&lt;a href="#profiles"&gt;Profile Summary&lt;/a&gt;&lt;/li&gt;&lt;br /&gt;' &amp; CrLf &amp;
					 '&lt;li&gt;&lt;a href="#machines"&gt;Machine Summary&lt;/a&gt;&lt;/li&gt;' &amp; CrLf &amp;
					 "&lt;/ul&gt;" &amp; CrLf;
	endif;
	
	// Result Summary ---------------------------------------------------------------------------------

	if asHTML then
		txt := txt &amp; '&lt;a name="results" id="results"&gt;&lt;/a&gt;' &amp; CrLf &amp; "&lt;hr /&gt;&lt;h2&gt;" &amp; CrLf;
	endif;

	txt := txt &amp; "Result Summary".withUnderline(not asHTML).withLineBreaks(2, asHTML);

	if asHTML then
		txt := txt &amp; "&lt;/h2&gt;" &amp; CrLf;
	endif;

	app.mySession.getAllRoundedTPS(t, r, u);
	
	txt := txt &amp; "Total TPS: " &amp; t.String.withLineBreaks(1, asHTML) &amp; "Read TPS: " &amp;
		r.String.withLineBreaks(1, asHTML) &amp; "Update TPS: " &amp; u.String.withLineBreaks(1, asHTML) &amp;
		"Total Time: " &amp; totalTimeStr.withLineBreaks(1, asHTML) &amp; "Driver Processes: " &amp;
		app.mySession.allProcessDescsByName.size.String.withLineBreaks(2, asHTML);

	if asHTML then
		txt := txt &amp; CrLf &amp; '&lt;br /&gt;&lt;a href="#top"&gt;&lt;i&gt;Back To Top&lt;/i&gt;&lt;/a&gt;&lt;br /&gt;&lt;br /&gt;' &amp; CrLf;
	endif;

	// Driver Summary ---------------------------------------------------------------------------------

	if asHTML then
		txt := txt &amp; '&lt;a name="drivers" id="drivers"&gt;&lt;/a&gt;' &amp; CrLf &amp; "&lt;hr /&gt;&lt;h2&gt;" &amp; CrLf;
	endif;

	txt := txt &amp; "Driver Summary".withUnderline(not asHTML).withLineBreaks(2, asHTML);

	if asHTML then
		txt := txt &amp; "&lt;/h2&gt;" &amp; CrLf;
	endif;

	if asHTML then
		txt := txt &amp; "From an initial state where no driver processes are running, a " &amp;
			"&lt;i&gt;benchmark run&lt;/i&gt; is the period of time between the first driver process " &amp;
			"starting and the last driver process stopping.";
	else
		txt := txt &amp; "From an initial state where no driver processes are running, a benchmark " &amp;
			"run is the period of time between the first driver process starting and the last " &amp;
			"driver process stopping.";
	endif;
	txt := txt.withLineBreaks(2, asHTML);

	txt := txt &amp; "Total benchmark run time: " &amp; totalTimeStr.withLineBreaks(1, asHTML) &amp;
		"Most recent benchmark run time: " &amp; latestTimeStr.withLineBreaks(2, asHTML);

	if asHTML then
		txt := txt &amp; "&lt;i&gt;Free MB&lt;/i&gt; and &lt;i&gt;Free %&lt;/i&gt; refer to available physical memory.&lt;br /&gt;&lt;br /&gt;"
			&amp; CrLf &amp; "&lt;pre&gt;" &amp; CrLf;
	else
		txt := txt &amp; "'Free MB' and 'Free %' refer to available physical memory." &amp; CrLf &amp; CrLf;
	endif;

	txt := txt &amp; self.tblDrivers.asString(self.tblDrivers.fixedRows, ColumnGap, null) &amp; CrLf &amp; CrLf;
	
	if asHTML then
		txt := txt &amp; "&lt;/pre&gt;" &amp; CrLf &amp; '&lt;a href="#top"&gt;&lt;i&gt;Back To Top&lt;/i&gt;&lt;/a&gt;&lt;br /&gt;&lt;br /&gt;' &amp; CrLf;
	endif;

	// Tranaction Summary- ----------------------------------------------------------------------------

	if asHTML then
		txt := txt &amp; '&lt;a name="transactions" id="transactions"&gt;&lt;/a&gt;' &amp; CrLf &amp; "&lt;hr/&gt;&lt;h2&gt;" &amp; CrLf;
	endif;

	txt := txt &amp; "Transaction Summary".withUnderline(not asHTML).withLineBreaks(2, asHTML);

	if asHTML then
		txt := txt &amp; "&lt;/h2&gt;" &amp; CrLf;
	endif;

	if self.tblTrans.rows &gt; self.tblTrans.fixedRows then
		if asHTML then
			txt := txt &amp; "&lt;pre&gt;" &amp; CrLf;
		endif;
		txt := txt &amp; self.tblTrans.asString(self.tblTrans.fixedRows, ColumnGap, null) &amp; CrLf &amp; CrLf;
		if asHTML then
			txt := txt &amp; "&lt;/pre&gt;" &amp; CrLf;
		endif;
	else
		txt := txt &amp; "Nothing to report.".withLineBreaks(2, asHTML);
		if asHTML then
			txt := txt &amp; "&lt;br /&gt;";
		endif;
	endif;
	
	if asHTML then
		txt := txt &amp; CrLf &amp; '&lt;a href="#top"&gt;&lt;i&gt;Back To Top&lt;/i&gt;&lt;/a&gt;&lt;br /&gt;&lt;br /&gt;' &amp; CrLf;
	endif;
	
	// Statistics -------------------------------------------------------------------------------------

	if asHTML then
		txt := txt &amp; '&lt;a name="stats" id="stats"&gt;&lt;/a&gt;' &amp; CrLf &amp; "&lt;hr /&gt;&lt;h2&gt;" &amp; CrLf;
	endif;

	txt := txt &amp; "Statistics".withUnderline(not asHTML).withLineBreaks(2, asHTML);
	
	if asHTML then
		txt := txt &amp; "&lt;/h2&gt;" &amp; CrLf;
	endif;

	if asHTML then
		txt := txt &amp; "The &lt;i&gt;Total&lt;/i&gt; column " &amp;
			"shows statistics for the entire controller session.&lt;br /&gt;" &amp; CrLf &amp;
			"The &lt;i&gt;Sample&lt;/i&gt; column shows statistics for the most recent sample only (started on " &amp;
			self.sampleStartTimeStamp.date.String &amp; " at " &amp; self.sampleStartTimeStamp.time.String &amp;
			").&lt;br /&gt;&lt;br /&gt;" &amp; CrLf &amp; "&lt;pre&gt;" &amp; CrLf;
	else
		txt := txt &amp; "The 'Total' column " &amp;
			"shows statistics for the entire controller session." &amp; CrLf &amp;
			"The 'Sample' column shows statistics for the most recent sample only (started on " &amp;
			self.sampleStartTimeStamp.date.String &amp; " at " &amp; self.sampleStartTimeStamp.time.String &amp;
			")." &amp; CrLf &amp; CrLf;
	endif;

	txt := txt &amp; self.tblStats.asString(1, ColumnGap, null) &amp; CrLf &amp; CrLf;
	
	if asHTML then
		txt := txt &amp; "&lt;/pre&gt;" &amp; CrLf &amp; '&lt;a href="#top"&gt;&lt;i&gt;Back To Top&lt;/i&gt;&lt;/a&gt;&lt;br /&gt;&lt;br /&gt;' &amp; CrLf;
	endif;

	// Profile Summary --------------------------------------------------------------------------------

	if asHTML then
		txt := txt &amp; '&lt;a name="profiles" id="profiles"&gt;&lt;/a&gt;' &amp; CrLf &amp; "&lt;hr /&gt;&lt;h2&gt;" &amp; CrLf;
	endif;

	txt := txt &amp; "Profile Summary".withUnderline(not asHTML).withLineBreaks(2, asHTML);

	if asHTML then
		txt := txt &amp; "&lt;/h2&gt;" &amp; CrLf;
	endif;

	s := app.mySession.getProfileSummaryString(ColumnGap, n);
	
	if n = 1 then
		ss := "1 Profile, ";
	else
		ss := n.String &amp; " Profiles, ";
	endif;
	
	i := app.mySession.allProcessDescsByName.size;
	
	if i = 1 then
		ss := ss &amp; "1 Process.";
	else
		ss := ss &amp; i.String &amp; " Processes.";
	endif;

	txt := txt &amp; ss.withLineBreaks(2, asHTML);
	
	if n &gt; 0 then
		if asHTML then
			txt := txt &amp; "&lt;pre&gt;" &amp; CrLf;
		endif;
		txt := txt &amp; s &amp; CrLf &amp; CrLf;
		if asHTML then
			txt := txt &amp; "&lt;/pre&gt;" &amp; CrLf &amp; '&lt;a href="#top"&gt;&lt;i&gt;Back To Top&lt;/i&gt;&lt;/a&gt;&lt;br /&gt;&lt;br /&gt;' &amp; CrLf;
		endif;
	endif;	
	
	// Machine Summary --------------------------------------------------------------------------------

	if asHTML then
		txt := txt &amp; '&lt;a name="machines" id="machines"&gt;&lt;/a&gt;' &amp; CrLf &amp; "&lt;hr /&gt;&lt;h2&gt;" &amp; CrLf;
	endif;

	txt := txt &amp; "Machine Summary".withUnderline(not asHTML).withLineBreaks(2, asHTML);
	
	if asHTML then
		txt := txt &amp; "&lt;/h2&gt;" &amp; CrLf;
	endif;

	if app.mySession.myDbServerMachineDescriptor = null then
		txt := txt &amp; "DB Server Machine: *** unknown ***".withLineBreaks(1, asHTML);
	else
		if asHTML then
			txt := txt &amp; "DB Server Machine: " &amp;
				app.mySession.myDbServerMachineDescriptor.name.withHTMLEntitiesReplaced;
		else
			txt := txt &amp; "DB Server Machine: " &amp; app.mySession.myDbServerMachineDescriptor.name;
		endif;
		txt := txt.withLineBreaks(1, asHTML);
	endif;

	if asHTML then
		txt := txt &amp; "Database Path: " &amp; app.dbPath.withHTMLEntitiesReplaced;
	else
		txt := txt &amp; "Database Path: " &amp; app.dbPath;
	endif;
	txt := txt.withLineBreaks(1, asHTML);
	
	txt := txt &amp; "Free Disk On Database Drive: " &amp;
		app.mySession.dbServerFreeDisk.asMegabytes.roundedTo(2).String &amp;
		" MB".withLineBreaks(2, asHTML);

	if asHTML then
		txt := txt &amp;
			"&lt;i&gt;Total(MB)&lt;/i&gt; refers to total physical memory.&lt;br /&gt;" &amp; CrLf &amp;
			"&lt;i&gt;Free(MB)&lt;/i&gt; and &lt;i&gt;Free(%)&lt;/i&gt; refer to available physical memory.&lt;br /&gt;" &amp; CrLf &amp;
			"&lt;i&gt;CPU&lt;/i&gt; refers to the processor type and speed (in MHz).&lt;br /&gt;&lt;br /&gt;" &amp; CrLf &amp;
			"&lt;pre&gt;" &amp; CrLf;
	else
		txt := txt &amp;
			"'Total(MB)' refers to total physical memory." &amp; CrLf &amp;
			"'Free(MB)' and 'Free(%)' refer to available physical memory." &amp; CrLf &amp;
			"'CPU' refers to the processor type and speed (in MHz)." &amp; CrLf &amp; CrLf;
	endif;

	// bit of a quick and dirty: create an invisible MachineSummaryForm (ie: we never show
	// it) and ask it to give us the machine summary details from its table as a string
	create msf transient;
	txt := txt &amp; msf.getTableAsString(ColumnGap) &amp; CrLf &amp; CrLf;

	if asHTML then
		txt := txt &amp; "&lt;/pre&gt;" &amp; CrLf &amp; '&lt;a href="#top"&gt;&lt;i&gt;Back To Top&lt;/i&gt;&lt;/a&gt;&lt;br /&gt;&lt;br /&gt;' &amp; CrLf;
	endif;

	// Output File ------------------------------------------------------------------------------------

	if asHTML then
		txt := txt &amp; "&lt;/html&gt;" &amp; CrLf;
	endif;
	
	create f transient;
	f.allowCreate := true;
	f.allowReplace := true;
	f.mode := File.Mode_Output;
	f.shareMode := File.Share_Exclusive;
	f.fileName := self.lastSaveFileName;
	f.usePresentationFileSystem:=onClient;
	
	f.writeString(txt);
	f.close;
	
	if asHTML then
		self.lastSaveFileType := self.FileTypeHTML;
	else
		self.lastSaveFileType := self.FileTypeText;
	endif;

epilog
	delete msf;
	delete f;
end;</source>
        <access>protected</access>
        <Parameter name="asHTML" type="Boolean"/>
        <Parameter name="onClient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTableAsText" id="ba2a604c-d510-4ed1-a742-2425ce8fe7b7">
        <source>doSaveTableAsText(tbl : Table input; startRow : Integer; fileName : String) protected;

vars
	f : File;
	
begin
	create f transient;
	
	f.allowCreate := true;
	f.allowReplace := true;
	f.mode := File.Mode_Output;
	f.shareMode := File.Share_Exclusive;
	f.fileName := fileName;
	
	f.writeString(tbl.asStringTabDelimited(startRow));

	f.close;

epilog
	delete f;
end;</source>
        <access>protected</access>
        <Parameter name="tbl" type="Table" usage="input"/>
        <Parameter name="startRow" type="Integer"/>
        <Parameter name="fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doSaveToLogs" id="3fee1f30-7081-4539-a792-0f96e2ec11b5">
        <updating/>
        <source>doSaveToLogs() updating;

begin
	lastSaveFileName:=app.getProfileStringAppServer(app.getIniFileNameAppServer, "JadeLog", "LogDirectory", "")&amp;"\Results.txt";
	lastSaveFileType:=FileTypeText;
	doSave(false, false);
	lastSaveFileName:=app.getProfileStringAppServer(app.getIniFileNameAppServer, "JadeLog", "LogDirectory", "")&amp;"\Results.htm";
	lastSaveFileType:=FileTypeHTML;
	doSave(true, false);
	setCaption(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectProfile" id="6df4a561-5dd2-4d50-a608-c81bcf7358ec">
        <source>doSelectProfile() protected;

vars
	f : SelectDriverProfileForm;
	obj : Object;
	
begin
	create f transient;
	
	if f.showModal = 0 and f.returnedProfileName &lt;&gt; null then
		obj := self.mySelectedCmdTarget;
		app.mySession.doCmdSetProfile(obj, f.returnedProfileName);
	endif;

epilog
	delete f;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectProfile_Bulk" id="3dcb5e62-18d5-49df-b738-53e8925fde9a">
        <source>doSelectProfile_Bulk() protected;

vars
	f : SelectDriverProfileBulkForm;
	spareDrivers : ProcessDescriptorSet ;
	index : Integer ;
	pd	: ProcessDescriptor;
	nd	: NodeDescriptor;
	count : Integer ;
begin
	create f transient;
	
	if f.showModal = 0 then
		create spareDrivers transient ;
		foreach nd in app.mySession.allNodeDescriptorsByName do
			foreach pd in nd.allProcessDescriptors do
				index := f.allSelectedProfileNames.indexOf( pd.profileName );
				if f.allSelectedProfileCounts[ index ] &gt; 0 then
					f.allSelectedProfileCounts[ index ] := f.allSelectedProfileCounts[ index ] - 1 ;
				else
					spareDrivers.add( pd );
				endif;
			endforeach;
		endforeach;

		foreach index in 1 to f.allSelectedProfileCounts.size do
			foreach count in 1 to f.allSelectedProfileCounts[ index ] do
				pd := spareDrivers.first ;
				if pd &lt;&gt; null then
					app.mySession.doCmdSetProfile(pd.getCommandTarget, f.allSelectedProfileNames[ index ]);
					spareDrivers.remove( pd );
				endif;
			endforeach;
		endforeach;
	endif;

epilog
	delete f;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetSaveFileName" id="1dd0625b-8a20-4912-9784-f085c4c5c51f">
        <updating/>
        <source>doSetSaveFileName(fileType : Integer) : Boolean updating, protected;

vars
	dlg : CMDFileSave;
	
begin
	create dlg transient;
	
	dlg.createPrompt := false;
	dlg.fileMustExist := false;
	dlg.hideReadOnly := true;
	dlg.noReadOnlyReturn := true;
	dlg.overwritePrompt := true;
	dlg.pathMustExist := true;
	dlg.resetCurrentPath:=false;
	dlg.validate := true;
	dlg.fileName:="Results";
	dlg.initDir:=app.getProfileStringAppServer(app.getIniFileNameAppServer, "JadeLog", "LogDirectory", "");

	dlg.filter := "All Files|*.*";
	if fileType = self.FileTypeHTML then	
		dlg.filter := "HTML Documents (*.htm, *.html)|*.htm;*.html|" &amp; dlg.filter;
		dlg.defaultExt := self.ExtensionHTML;
	elseif fileType = self.FileTypeText then
		dlg.filter := "Text Files (*.txt)|*.txt|" &amp; dlg.filter;
		dlg.defaultExt := self.ExtensionText;
	else
		dlg.defaultExt := null;
	endif;
	
	if dlg.open &lt;&gt; 0 then
		return false;
	endif;
	
	self.lastSaveFileName := dlg.fileName.trimBlanks;
	self.lastSaveFileType := fileType;
		
	self.setCaption(false);
	
	return true;

epilog
	delete dlg;
end;</source>
        <access>protected</access>
        <Parameter name="fileType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowGraph" id="4a6f6423-083f-4b1c-b68a-b8c8af879973">
        <updating/>
        <source>doShowGraph(menuItem : MenuItem input; pic : Picture input;
	showIt : Boolean) updating, protected;

begin
	pic.parent.visible := showIt;
	pic.visible := showIt;
	menuItem.checked := showIt;
	self.resizeTheLot;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
        <Parameter name="pic" type="Picture" usage="input"/>
        <Parameter name="showIt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doViewSysNodesProcsChange" id="612a26b8-5e8c-404d-8074-8ae8a8ef7d26">
        <updating/>
        <source>doViewSysNodesProcsChange(mnuItem : MenuItem input) updating, protected;

begin
	if mnuItem = null or mnuItem.checked then
		return;
	endif;
	
	self.mnuViewSysNodesOnly.checked := false;
	self.mnuViewSysNodesProcs.checked := false;
	self.mnuViewSysOnly.checked := false;
	
	mnuItem.checked := true;
	
	self.refreshDriversTable;
end;</source>
        <access>protected</access>
        <Parameter name="mnuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enableOpenLastSavedMenuItem" id="e8215e08-843c-4193-8124-7c5e59bf0d84">
        <source>enableOpenLastSavedMenuItem() protected;

vars
	n : Integer;
	s : String;
	
begin
	self.mnuFileOpenCurrent.enabled := self.lastSaveFileName &lt;&gt; null and
		self.isLastSaveFileTypeValid;
		
	if not self.mnuFileOpenCurrent.enabled then
		return;
	endif;

	// extract just the filename
	s := self.lastSaveFileName;
	n := s.reversePos('\');
	if n &lt; 1 then
		n := s.reversePos('/');
	endif;
	if n &gt; 0 and n &lt; s.length then
		s := s[n + 1 : end].trimBlanks;
	else
		s := null;
	endif;

	if s &lt;&gt; null then		
		self.mnuFileOpenCurrent.caption := "&amp;Open " &amp; s;
	else
		self.mnuFileOpenCurrent.caption := "&amp;Open Current File";
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="evtMnuDrvCloneFixedClick" id="37e7862c-7319-405a-b3b9-8ec2b6a35ad8">
        <updating/>
        <source>evtMnuDrvCloneFixedClick(menuItem: MenuItem input) updating;

vars
	n, len : Integer;
	s : String;
	
begin
	if menuItem = null then
		return;
	endif;

	s := menuItem.name;
	len := s.length;
	
	if s = null or len &lt; 1 then
		return;
	endif;
		
	n := s.pos("Clone", 1);
	
	if n &lt; 1 then
		return;
	endif;

	n := n + 5; // move past "Clone"
	
	if n &gt; len then
		return;
	endif;
	
	n := s[n : end].Integer;
	
	if n &gt; 0 and n &lt;= MaxClones then
		app.mySession.doCmdClone(self.mySelectedCmdTarget, n);
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="evtMnuDrvCloneSpecifyClick" id="9aad292f-12d0-4e82-b2bc-f4bba2c78ea2">
        <updating/>
        <source>evtMnuDrvCloneSpecifyClick(menuItem: MenuItem input) updating;

begin
	app.mySession.doCmdCloneSpecify(self.mySelectedCmdTarget);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="evtMnuDrvPingClick" id="dc50fba8-ae4d-46df-8a46-36f3a1060d76">
        <updating/>
        <source>evtMnuDrvPingClick(menuItem: MenuItem input) updating;

begin
	app.mySession.doCmdPing(self.mySelectedCmdTarget);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="evtMnuDrvProfDefaultClick" id="7ae72cb1-1284-4a5d-bb15-66f1e12d4a54">
        <updating/>
        <source>evtMnuDrvProfDefaultClick(menuItem: MenuItem input) updating;

vars
	obj : Object;
	
begin
	obj := self.mySelectedCmdTarget;
	app.mySession.doCmdSetProfile(obj, null);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="evtMnuDrvProfSelectClick" id="ff9b677d-9cfc-4587-9c8a-bd94493cce3f">
        <updating/>
        <source>evtMnuDrvProfSelectClick(menuItem: MenuItem input) updating;

begin
	self.doSelectProfile;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="evtMnuDrvSetAutoPingClick" id="663b3442-7c76-4677-807c-0d530aa30df4">
        <updating/>
        <source>evtMnuDrvSetAutoPingClick(menuItem: MenuItem input) updating;

begin
	app.mySession.doCmdSetAutoPing(self.mySelectedCmdTarget);
end;</source>
