		formPermission.id := PmHHCargoRepair;
		response.allFormPermissions.add(formPermission);
	endif;
	
	//jlier1 TFS 54703 27/9/22
	if app.myCurrentUserCan(term,PmHHMAFILoadUnload) then
		create formPermission transient;
		formPermission.id := PmHHMAFILoadUnload;
		response.allFormPermissions.add(formPermission);
	endif;
	
	if app.myCurrentUserCan(term,PmAdmDamageCodeAdvancedMaint) then    //18.10.2022 navma1 #53880
		create formPermission transient;
		formPermission.id := PmAdmDamageCodeAdvancedMaint;
		response.allFormPermissions.add(formPermission);
	endif;
	
	if app.myCurrentUserCan(term,PmAdmDamageCodeAdvancedView) then     //18.10.2022 navma1 #53880
		create formPermission transient;
		formPermission.id := PmAdmDamageCodeAdvancedView;
		response.allFormPermissions.add(formPermission);
	endif;
	
	//jlier1 TFS 55404 28/11/22
	if app.myCurrentUserCan(null,Sub_WarehouseApps)and  app.myCurrentUserCan(term,PmHHWarehouseMultiMove) then
		create formPermission transient;
		formPermission.id := PmHHWarehouseMultiMove;
		response.allFormPermissions.add(formPermission);
	endif;
	
	if app.myCurrentUserCan(term, PmAdmTIRepairMaint ) then   //08.03.2023 navlw1 #53880
		create formPermission transient;
		formPermission.id := PmAdmTIRepairMaint ;
		response.allFormPermissions.add(formPermission);
	endif;
	
	if app.myCurrentUserCan(term, PmAdmTIRepairView) then   //08.03.2023 navlw1 #53880
		create formPermission transient;
		formPermission.id := PmAdmTIRepairView;
		response.allFormPermissions.add(formPermission);
	endif;
	
	if app.myCurrentUserCan(term, PmMobScanningApp) then // 29.03.2023 navlw1 #55987
		create formPermission transient;
		formPermission.id := PmMobScanningApp;
		response.allFormPermissions.add(formPermission);
	endif;
	
	if app.myCurrentUserCan(term, PmMobDeliveryDispatchApp) then // 20.09.2023 navsck1 #60470
		create formPermission transient;
		formPermission.id := PmMobDeliveryDispatchApp;
		response.allFormPermissions.add(formPermission);
	endif;
	
	if app.myCurrentUserCan(term, PmMobDeliveryDispatchAppOnly) then // 19.04.2024 navmj1 #63668
		create formPermission transient;
		formPermission.id := PmMobDeliveryDispatchAppOnly;
		response.allFormPermissions.add(formPermission);
	endif;
	
	// TFS 62642 If not licensed for VAS Work orders, don't add permission for the todo App
	if app.myCurrentUserCan(null, Sub_VASWorkOrder) then
		if app.myCurrentUserCan(term, PmHHTodoApp) then
			create formPermission transient;
			formPermission.id := PmHHTodoApp;
			response.allFormPermissions.add(formPermission);
		endif;
	endif;
	
	//09-Dec-2025 navtr3  MTN-36835
	if app.myCurrentUserCan(term, PmHHHeaderDisplaySettings) then
		create formPermission transient;
		formPermission.id := PmHHHeaderDisplaySettings;
		response.allFormPermissions.add(formPermission);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
		delete formPermission;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_FormPermissionResponse"/>
    </JadeWebServicesMethod>
