    <JadeMethod name="setStatus" id="a0d198c2-a0fe-4d29-a4c5-91eadfc2022c">
        <updating/>
        <source>setStatus(_value : Integer) updating;
/*

Purpose:		Created because i wanted a singled point to send a note when the status is updated to completed	


Return Value:		


Date		Who		Reason
25 Sep 2006	cnwer1	Initial creation - PAR#xxxx
15 May 2013	cnwpjs1 PAr # 31294
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
*/
vars
	ti  		   : CM_TrackedItem;
	request 	   : CM_Request;
	transferToTerm : CM_Terminal;
begin
	
	if self.status &lt;&gt; _value then	
		ti 			:= self.myTrackedItem;					  //06.06.2023 navma1 #58339
		request     := self.myRequest;						  //06.06.2023 navma1 #58339
		self.status := _value;
		
		self.setCompletedDate(app.serverTimestampAtTrxStart); //epr par 25573 7/2/2011
		
		if self.status = WLE_COMPLETED then
			/*
			//02.06.2023 navma1 #58296
			Complete Work Order Wle 
			*/
		
			/*
			02.06.2023 navma1 #58296
			if self.myWorkOrderWLE &lt;&gt; null then
				self.myWorkOrderWLE.setStatus(WLE_COMPLETED);										
			endif;
			app.myEventManager.createSingleObjInfoNoteEvt(self, EVENT_WLE_COMPLETE, self);
			self.setWorkOrderComplete();
			*/
		
			/*
			06.06.2023 navma1 #58339
			Changing Work Order Status Wle
			*/
			self.doCompleteWorkOrder();
			
			
			if request &lt;&gt; null then 			//epr par 33221 3/3/14
				request.handleAllWLEsComplete();// PAR 27749
			endif;
			
			if request &lt;&gt; null and ti &lt;&gt; null then
				//03 Sep 2013	NDL	Par 32397
				if request.isKindOf(CM_YardRequest) then
					transferToTerm := request.CM_YardRequest.myTransferToTerminal;
					if transferToTerm &lt;&gt; null then
						if ti.destinationTerminal &lt;&gt; transferToTerm.code then
							ti.setDestinationTerminal(transferToTerm.code);
						endif;
					endif;
				endif;
				
				request.unallocateTrackedItem(ti);
			endif;
		endif;
		//epr par 36908 22/9/15
		app.myEventManager.createSingleObjInfoNoteEvt(self, self.getMyTerminal.getTerminalEvent(WLE_Status_Event), self);
		/*
		Generate Ops View 
		*/
		self.generateOpsView(_value);			//06.06.2023 navma1 #58339											
	endif;

	//epr par 25573 7/2/2011
	if self.job &lt;&gt; null then
		self.job.updateStatus();
		/*
		06.06.2023 navma1 #58339
		Update Work Order Status 
		*/
		self.updateWOJobStatus();
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
