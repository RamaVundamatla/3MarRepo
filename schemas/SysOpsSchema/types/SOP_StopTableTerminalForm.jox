    <JadeMethod name="copyColToArray" id="45a05ddf-a8c5-41de-8c21-6b418f02cce4">
        <source>copyColToArray(_objectArray : ObjectArray; _intArray : IntegerArray io);
//ccms1824 cnwrs1 may 2009
// 29/06/2010	cnwcs5	par 24341 - add tranship option
//15 May 2013	cnwrs1	par31549 stop removal of unused options
//16 Aug 2022   navds20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
//19/12/2024    navsaa30 MTN-33636 TPT | Stops Configuration for Standard Damage
vars
	obj		: Object;
	string : String;	
begin
	_intArray.clear();
	
	foreach obj in _objectArray do
		string:=obj.CM_String.string;
		if string = StopApplyExportStr then
			_intArray.add(StopApplyExport);			
		elseif string = StopApplyImportStr then
			_intArray.add(StopApplyImport);
		elseif string = StopApplyPackCompleteStr then
			_intArray.add(StopApplyPackComplete);
		elseif string = StopApplyUnpackCompleteStr then
			_intArray.add(StopApplyUnpackComplete);
		elseif string = StopPreventDeliveryRequestStr then
			_intArray.add(StopPreventDeliveryRequest);
		elseif string = StopPreventExportStr then
			_intArray.add(StopPreventExport);
		elseif string = StopPreventImportStr then
			_intArray.add(StopPreventImport);
		elseif string = StopPreventGateOutStr then	//03 Jul 2015	NDL	Par 36543
			_intArray.add(StopPreventGateOut);
		elseif string = StopPreventTruckUnloadStr then	//03 Jul 2015	NDL	Par 36543
			_intArray.add(StopPreventTruckUnload);
		elseif string = StopPreventRTQueuingStr then
			_intArray.add(StopPreventRTQueuing);
		elseif string = StopPreventReceiptStr then
			_intArray.add(StopPreventReceipt);
		elseif string = StopPreventReleaseRequestStr then
			_intArray.add(StopPreventReleaseRequest);
		elseif string = StopPreventSubTerminalEditStr then
			_intArray.add(StopPreventSubTerminalEdit);
		elseif string = StopPreventVoyagePlanningStr then
			_intArray.add(StopPreventVoyagePlanning);
		elseif string = StopPreventYardMoveStr then
			_intArray.add(StopPreventYardMove);
		elseif string = StopPreventStorageChargesStr then		// 23/08/2016 cnwjre1 TFS 2570
			_intArray.add(StopPreventStorageCharges);
		elseif string = StopProcessCustomsInspectStr then
			_intArray.add(StopProcessCustomsInspect);
		elseif string = StopProcessCustomsScanInsptStr then
			_intArray.add(StopProcessCustomsScanInspect);
		elseif string = StopProcessEDICustomExportStr then
			_intArray.add(StopProcessEDICustomExport);
		elseif string = StopProcessEDICustomImportStr then
			_intArray.add(StopProcessEDICustomImport);
//		elseif string = Stop_Process_EDI_Customs_Str then
//			_intArray.add(Stop_Process_EDI_Customs);
//		elseif string = StopProcessEDIOperatorStr then
//			_intArray.add(StopProcessEDIOperator);
		elseif string = StopProcessEmptyImportStr then
			_intArray.add(StopProcessEmptyImport);
		elseif string = StopProcessRemoveWhenChildStr then
			_intArray.add(StopProcessRemoveWhenChild);
		elseif string = StopProcessRemoveOnCoastalStr then
			_intArray.add(StopProcessRemoveOnCoastal);
		elseif string = StopProcessOpExpReleaseNoStr then //cnwrd1 4.11.08 CCMS JMT 1743/1764 
			_intArray.add(StopProcessOpExpReleaseNo);					//cnwrd1 4.11.08 CCMS JMT 1743/1764 
		elseif string = StopProcessOpImpReleasePINStr then//cnwrd1 4.11.08 CCMS JMT 1743/1764 
			_intArray.add(StopProcessOpImpReleasePIN);					//cnwrd1 4.11.08 CCMS JMT 1743/1764 
		elseif string = StopProcessOpImpDeliverRelStr then//cnwrs1 Aug 2009 CCMS1845
			_intArray.add(StopProcessOpImpDeliverRel);					//cnwrs1 Aug 2009 CCMS1845 
		elseif string = StopProcessCopyToChildStr then  // CCMS 1696
			_intArray.add(StopProcessCopyToChild);
		elseif string = StopProcessImportStorageStr then  // PAR 19166 28.5.09 cnwgb1 
			_intArray.add(StopProcessImportStorage);
		elseif string = StopProcessVoyagePlanningStr then
			_intArray.add(StopProcessVoyagePlanning);					//CCMS1884 - 22207 cnwsh3 27/01/2010
		elseif string = StopApplyTranshipStr then			// par 24341
			_intArray.add (StopApplyTranship)	;						// par 24341
		elseif string = StopApplyBOLStr then				// cnwmc5 - 14 April 2014 - CCMS 2352
			_intArray.add(StopApplyBOL);								// cnwmc5 - 14 April 2014 - CCMS 2352
		elseif string = StopApplySOLASVGMStr then //epr TFS 14946 24/5/16
			_intArray.add(StopApplySOLASVGM);
		elseif string = StopProcessTransLoadSameCtyStr then	// 21/7/17 MAP TFS4916
			_intArray.add(StopProcessTransLoadSameCty);
		// 16.08.2022 navds20 TFS 53862
		elseif string = StopPreventRelReqDamRefusedStr then
			_intArray.add(StopPreventRelReqDamRefused);
		elseif string = StopApplyDamagedNotRefusedStr then
			_intArray.add(StopApplyDamagedNotRefused);
		elseif string = StopApplyDamagedAndRefusedStr then
			_intArray.add(StopApplyDamagedAndRefused);
		elseif string = StopApplyDamagedStr then			//19/12/24 navsaa30 #33636
			_intArray.add(StopApplyDamaged);
		// 16.08.2022 navds20 TFS 53862
		//22/08/2023	navkc1	CR 59610 Task 59611 --&gt;
		elseif string = StopPreventTrainLoadStr then
			_intArray.add(StopPreventTrainLoad);
		elseif string = StopPreventTruckLoadStr then
			_intArray.add(StopPreventTruckLoad);
		elseif string = StopPreventTruckGateInStr then
			_intArray.add(StopPreventTruckGateIn);
		elseif string = StopPreventVoyageDepartureStr then
			_intArray.add(StopPreventVoyageDeparture);
		elseif string = StopPreventTrainDepartureStr then
			_intArray.add(StopPreventTrainDeparture);
		elseif string = StopPreventTrainUnloadStr then
			_intArray.add(StopPreventTrainUnload);
		elseif string = StopPreventReleaseFromTranStr then //jlier1 TFS 64478 24/6/24
			_intArray.add(StopPreventReleaseFromTranArea);
		/*
		================================
		04/06/2025	navkc1 JIRA MTN 35025
		Leave this license check at the bottom
		================================
		*/
		// ### JIRA 34756 27MAY2025 NAVAB1
		elseif app.myPassport.myUser.canDo(null, Sub_CustomDocuments) then
			if string = StopPreventRelReqAssignStr then
				_intArray.add(StopPreventRelReqAssign);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_objectArray" type="ObjectArray"/>
        <Parameter name="_intArray" type="IntegerArray" usage="io"/>
    </JadeMethod>
