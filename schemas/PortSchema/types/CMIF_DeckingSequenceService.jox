    <JadeMethod name="setRules" id="19f1e663-1639-4c7d-ad40-6e6b1b830b38">
        <updating/>
        <source>setRules(_stackRule, _rowRule, _patternRule: Integer) updating;
//17 December 2008	cnwdw1	
//
vars

begin
	if self.areaRule = DeckingRule_ByStack or self.areaRule = DeckingRule_ByStackFill then
		self.stackRule := _stackRule;
		self.rowRule := _rowRule;
	else
		self.stackRule := _rowRule;
		self.rowRule := _stackRule;
	endif;
	self.patternRule := _patternRule;

end;</source>
        <Parameter name="_stackRule" type="Integer"/>
        <Parameter name="_rowRule" type="Integer"/>
        <Parameter name="_patternRule" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStartRowStack" id="9737f56e-94bb-4c4a-b7d1-eb5102dafafc">
        <updating/>
        <source>setStartRowStack(_startStack,
				 _startRow : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2010	cnwer1	Initial creation

*/

vars

begin

	self.startRow:=0;
	self.startStack:=0;
	if self.areaRule = DeckingRule_ByStack or self.areaRule = DeckingRule_ByStackFill then
		if _startStack &lt;&gt; 0 then
			self.startStack:=_startStack;
		endif;
		if _startRow &lt;&gt; 0 then
			self.startRow:=_startRow;
		endif;
	else
		if _startRow &lt;&gt; 0 then
			self.startStack:=_startRow;
		endif;
		if  _startStack &lt;&gt; 0 then
			self.startRow:=_startStack;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_startStack" type="Integer"/>
        <Parameter name="_startRow" type="Integer"/>
    </JadeMethod>
</Class>
