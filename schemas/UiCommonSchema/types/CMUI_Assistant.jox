    <JadeMethod name="listTableToDoTasksSysUser" id="744c3a00-283e-4157-babe-f581029b4c2e">
        <source>listTableToDoTasksSysUser( _lstTable : CMUI_ListTable input; _cargoType : CM_CargoType; _allToDoTasksForUser : CM_ToDoTaskDescByCode input );
/* ---------------------------------------------------------------------------
Created:	19 August 2008	by cnwvu1

Purpose:	all to do tasks that are available for a user from all terminals
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	taskDict	: CM_ToDoTaskDescByCode;
	ut			: CM_UserTerminal;
	user		: CM_User;
	task		: CM_ToDoTaskDesc;
	
begin

	user		:= app.getMyUser();
	_lstTable.clear();
	

	
	foreach ut in user.allUserTerminals do
		
		delete taskDict;
		create taskDict transient;
		app.myPassport.myUser.getToDoTasksAddRemoveForTerm(ut.myTerminal, taskDict);
		
		foreach task in taskDict do
			if not _allToDoTasksForUser.includes(task) then
				if _cargoType.allToDoTaskDescs.includes(task) then
					_allToDoTasksForUser.add(task);
				endif;
			endif;
		endforeach;
		
	endforeach;
	
	
	_lstTable.displayCollection( _allToDoTasksForUser, false, Table.DisplayCollection_Forward, null );

epilog
	delete taskDict;

end;</source>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_allToDoTasksForUser" type="CM_ToDoTaskDescByCode" usage="input"/>
    </JadeMethod>
