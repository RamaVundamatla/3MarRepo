    <JadeMethod name="doPostSelectorSearch" id="46266121-cb88-4c70-af58-be32dc86d723">
        <source>doPostSelectorSearch(removedCritLines, tempLines : ObjectSet input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlger1	Initial creation 47132

*/

vars
	obj : Object;
begin
	if removedCritLines &lt;&gt; null then
		foreach obj in removedCritLines do
			obj.CM_SelectorCriteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
		endforeach;
	endif;
	if tempLines &lt;&gt; null then
		foreach obj in tempLines do
			obj.CM_SelectorCriteriaLine.setMyCriteriaLineHolder(null);
		endforeach;
		tempLines.purge;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="removedCritLines" type="ObjectSet" usage="input"/>
        <Parameter name="tempLines" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPreEditValidation" id="71b1cf8b-6b31-4300-86fe-26d1c2c2abfb">
        <updating/>
        <source>doPreEditValidation(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2004	cnwth2
//
// Purpose:     Checks that child cargo is not selected if bulkEditing (causes problems
//				when we create child proxies, and then try to create anothre proxy for the same
//				object if it also happens to be selected in the table
//
//				If ths happens here we give the option of removing the child cargo and continuing
//				or cancelling completely
// 31 Oct 2023	navma1 		ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
// ----------   ----------  --------------------------------------------------
vars
	obj				: Object;
	itemsToRemove	: CM_TISet;
	tbl				: CM_DataTable;
	tiSet			: CM_TISet;
	ti				: CM_TrackedItem;
	
begin

	if not self.doingMultiEdit then	// single edit mode
		if not self.doPreEditValidationLog(null) then	// average scaled log is not editable. PAR 21688 Nov 2009
			return false;
		endif;
		return true;
	endif;

	// bulk edit mode
	tbl := self.tblData;
	create tiSet transient;
	create itemsToRemove transient;

	//05 Jun 2015	NDL	Par 36338
	if app.isCargoGroupEnabled then
		if self.includesCargoGroupAnCargoItems(tbl) then
			return false;
		endif;
	endif;
	
	//construct tiSet - all selected TIs
	/*
	31.10.2023 navma1 #60920
	foreach obj in tbl.allSelectedObjects do					
		tiSet.add(obj.CM_TrackedItem);
	endforeach;
	*/
	tbl.allSelectedObjects.copy(tiSet);								//31.10.2023 navma1 #60920
	
	// average scaled log is not editable
	if not self.doPreEditValidationLog(tiSet) then
		return false;
	endif;
	
	foreach ti in tiSet where (CM_TrackedItem.hasInstance(ti)) do
		if ti.myParent &lt;&gt; null and
		   tbl.allSelectedObjects.includes(ti.myParent) then
			itemsToRemove.add(ti);
		endif;
	endforeach;

	if itemsToRemove.isEmpty then
		return true;
	endif;
	
	if app.msgBox(app.getErrorString(BulkEditParentChildrenSelected),
					app.getErrorString(BulkEditParentChildrenContinue), 
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Cancel) &lt;&gt; MB_OK then
		return false;
	endif;
	
	foreach obj in itemsToRemove do
		tbl.allSelectedObjects.remove(obj);
	endforeach;
	
	
	if self.myCurrentObject = null then //we may have just blown it away
		self.myCurrentObject := tblData.allSelectedObjects.last.Object;
	endif;
	
	return true;
	
epilog
	delete itemsToRemove;
	delete tiSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPreEditValidationLog" id="66073f2b-411e-4fb9-a774-d6afa2ab7323">
        <source>doPreEditValidationLog(_tiSet : CM_TISet): Boolean;
/* ---------------------------------------------------------------------------
Created:	25 November 2009	by cnwvu1

Purpose:	PAR 21688. Gives false when a log isAverageScaled = true
   
Change Date		Who		Reason
31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
------------------------------------------------------------------------------*/
vars
	ti				: CM_TrackedItem;
	log				: CM_Log;
	averageLogFound	: Boolean;
	user			: CM_User;
	canDoLogs		: Boolean;
begin

	user := app.getMyUser;
	if user &lt;&gt; null and user.canDo(self.myTerminal, Mod_Logs) then //31.10.2023 navma1 #60920
		canDoLogs := true;
	endif;
	
	if not canDoLogs then					//31.10.2023 navma1 #60920
		return true;
	endif;
	// average scaled log is not editable. PAR 21688 Nov 2009

	if _tiSet = null then	// single edit mode
		ti := self.myCurrentObject.CM_TrackedItem;
		if ti &lt;&gt; null and ti.isKindOf(CM_Log) and ti.CM_Log.isAverageScaled then
			log				:= ti.CM_Log;
			averageLogFound	:= true;
		endif;
		
	else		// multi select edit mode
		foreach ti in _tiSet do
			if ti.isKindOf(CM_Log) and ti.CM_Log.isAverageScaled then
				log				:= ti.CM_Log;
				averageLogFound	:= true;
				break;
			endif;
		endforeach;
		
	endif;
	
	if averageLogFound then
		app.msgBox(app.getErrorString1(AverageScaledLogNotEditable, log.id), null, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
		
	return true;

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPreSelectorSearch" id="8a22496f-b532-4682-9c79-3faaa153deb7">
        <updating/>
        <source>doPreSelectorSearch(removedCritLines, tempLines : ObjectSet input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlger1	Initial creation 47132

*/

vars

	idCrit,
	cargoTypeCrit,
	crit : CM_SelectorCriteriaLine;
	obj : Object;
	cargoTypeObj : CM_CargoType;
	cargoType  : Integer;
begin
	
	foreach crit in self.myCriteriaLineHolder.allCriteriaLines do
		if crit.myQueryProperty.propertyName = CM_TrackedItem::myTerminal.name then		
			continue;
		endif;

		
		if (crit.myQueryOperator.isKindOf(CM_QTimeRange) or crit.myQueryOperator.isKindOf(CM_QDateRange) or crit.myQueryOperator.isKindOf(CM_QDateDayRange) ) then
			if crit.myQueryOperator.getSearchValueStr(crit.myQueryProperty) = null then
				removedCritLines.add(crit);
			endif;
			continue;
		endif;
		
				
		if  ( crit.myQueryOperator.getSearchValue = null)	then
			removedCritLines.add(crit);
			continue;
		endif;
		
	endforeach;
	
	
	

	if self.cmbSelector.listObject = null then
		cargoTypeCrit:=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::cargoType.name);
		if cargoTypeCrit &lt;&gt; null then
			cargoTypeObj:=app.myRoot.allCargoTypesById[cargoTypeCrit.myQueryOperator.getSearchValue.Integer];
			//jlier1 TFS 53423 26/5/22
			if cargoTypeObj &lt;&gt; null and cargoTypeObj.isLog then
				crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::getTAType.name);
				if crit &lt;&gt; null then
					removedCritLines.addNoDuplicates(crit,false);
				endif;
			endif;
			
		endif;
		idCrit :=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);
		if idCrit &lt;&gt; null then	
			self.splitFilterID(idCrit.myQueryOperator.getSearchValue.String);
			if not self.myFilterIDList.isEmpty then	//08 June 2020	NDL	TFS 49484
				idCrit.myQueryOperator.setSearchValue( self.myFilterIDList.first );
			endif;
		endif;
		
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::state.name);
		if crit &lt;&gt; null then
			if crit.myQueryOperator.getSearchValue.Integer = TI_STATE_TRANSFER_FROM or
				crit.myQueryOperator.getSearchValue.Integer = TI_STATE_TRANSFER_TO then
				//remove the site 
				crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::site.name);
				if crit &lt;&gt; null then
					removedCritLines.addNoDuplicates(crit,false);
				endif;
			endif;
		endif;
		
		if self.myEnqController.isKindOf(CM_EnqControllerBOL) then

			if cargoTypeCrit &lt;&gt; null then
				cargoType := cargoTypeCrit.myQueryOperator.getSearchValue.Integer;
				cargoTypeCrit.setMyCriteriaLineHolder(null);
				removedCritLines.add(cargoTypeCrit);
			endif;
			if cargoType &lt;&gt; null then
				
				crit:=self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.BOL_Query_Type,cargoType], self.myCriteriaLineHolder, CM_BOL::bolType.name, CM_QueryOperator.Operator_Equal, cargoType);
				if crit &lt;&gt; null then
					tempLines.add(crit);
				endif;
				crit:=self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.BOL_Query_Type,cargoType], self.myCriteriaLineHolder, CM_BOL::isInward.name, CM_QueryOperator.Operator_Equal, true.getYesNo);	
				if crit &lt;&gt; null then
					tempLines.add(crit);
				endif;
			endif;
			crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::getTAType.name);
			if crit &lt;&gt; null then
				removedCritLines.addNoDuplicates(crit,false);
			endif;
			//jlier TFS 53454 27/5/22
		endif;
	endif;
	
	foreach obj in removedCritLines do
		obj.CM_SelectorCriteriaLine.setMyCriteriaLineHolder(null);
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="removedCritLines" type="ObjectSet" usage="input"/>
        <Parameter name="tempLines" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="f0aefb1d-0525-443c-8335-508122a566c1">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:     May 2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tiReport	: CM_TIEnquiryOutput;
	progress	: CMS_Progress;
	now			: TimeStamp;
	ti 			: CM_TrackedItem;
	tmpReport	: JadeReport;
	tp			: CM_GenericTablePrint;
	bol			: CM_BOL;
begin
	
	app.mousePointer := MP_HOURGLASS;
	now := self.systemToLocalTime(app.actualTimeServer());	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
	create tmpReport transient;
	app.printer.close;
	//app.printer.setMargins(Print_Portrait,5,5,10,10);					//-cnwml2 PAR25134
	app.printer.setMargins(app.printer.orientation, 5, 5, 10, 10);		//+cnwml2 PAR25134
	app.printer.topOfPage := 1;
	app.printer.bottomOfPage := 1;
	app.printer.setReport(tmpReport);	//Capture for print preview.

	create tiReport transient;
	//+cnwml2 PAR25134
	if app.printer.orientation = Print_Portrait then
		tiReport.initReport;
	elseif app.printer.orientation = Print_Landscape then
		tiReport.initReportForLandscape();	
	endif;
	app.printer.setHeader(tiReport.frHeader);
	app.printer.setFooter(null);
	tiReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.String;
	
	if CM_TrackedItem.hasInstance(self.myCurrentObject) then
		ti := self.myCurrentObject.CM_TrackedItem;
		tmpReport.description := "Cargo Enquiry " &amp; ti.id;
		// setup header information
		tiReport.lblCargoTypeLbl.visible := true;
		tiReport.lblTIID.visible := true;
		tiReport.portteclogo.picture := app.getPicLogoProduct();		//+cnwml2 PAR25134
		tiReport.picLogo.picture := app.getPicLogoPort; // The bitmap called rptlogo.bmp in reports/formats
		tiReport.lblCargoType.caption := ti.isoTypeDesc.trimBlanks; //ti.isoTypeDesc;
		tiReport.lblTIID.caption := ti.id;
	
	elseif CM_BOL.hasInstance(self.myCurrentObject) then
		bol := self.myCurrentObject.CM_BOL;
		tmpReport.description := "Cargo Enquiry " &amp; bol.number;
		// setup header information
		tiReport.lblCargoTypeLbl.visible := true;
		tiReport.lblTIID.visible := true;
		tiReport.portteclogo.picture := app.getPicLogoProduct();			//+cnwml2 PAR25134
		tiReport.picLogo.picture := app.getPicLogoPort; // The bitmap called rptlogo.bmp in reports/formats
		
		tiReport.lblTIID.caption := bol.number;
	
	else
		app.msgBox('The print function for this item type is not currently handled', 'Type not handled', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
		
	//cnwrd1 par 19525 - cannot assume shtEdit1 is current and correctly refreshed before printing so refresh.
	self.showThumbnailDataForSheet(self.shtEdit1, true);
	
	if self.isShowingAlphabetised then
		self.printTableIfVisible(tiReport, self.shtEdit1, self.tblAlpha);
	else
		self.printTableIfVisible(tiReport, self.shtEdit1, self.tblEdit1);
	endif;
	//th2 PAR 14510 - Only previously clicked sheets were printing here
	//This was because fields on a sheet are only loaded when you click on them, not when you select the container.
	//self.showThumbnailDataForSheet(self.shtEdit1, true);  //cnwrd1 par 19525 moved to before printing this sheet
	self.showThumbnailDataForSheet(self.shtEdit2, true);
	self.showThumbnailDataForSheet(self.shtEdit3, true);
	self.showThumbnailDataForSheet(self.shtEdit4, true);
	self.showThumbnailDataForSheet(self.shtEdit5, true);
	self.showThumbnailDataForSheet(self.shtEdit6, true);
	self.showThumbnailDataForSheet(self.shtEdit7, true);
	self.showThumbnailDataForSheet(self.shtEdit8, true);
	self.showThumbnailDataForSheet(self.shtEdit9, true);
	self.showThumbnailDataForSheet(self.shtEdit10, true);
	
	
	self.printTableIfVisible(tiReport, self.shtEdit2, self.tblEdit2);
	self.printTableIfVisible(tiReport, self.shtEdit3, self.tblEdit3);
	self.printTableIfVisible(tiReport, self.shtEdit4, self.tblEdit4);
	self.printTableIfVisible(tiReport, self.shtEdit5, self.tblEdit5);
	self.printTableIfVisible(tiReport, self.shtEdit6, self.tblEdit6);
	self.printTableIfVisible(tiReport, self.shtEdit7, self.tblEdit7);
	self.printTableIfVisible(tiReport, self.shtEdit8, self.tblEdit8);
	self.printTableIfVisible(tiReport, self.shtEdit9, self.tblEdit9);
	self.printTableIfVisible(tiReport, self.shtEdit10, self.tblEdit10);

	app.printPreview(tmpReport, true);
	
epilog
	app.printer.close;
	delete progress;
	delete tp;
	delete tiReport;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintList" id="1d020b13-62bc-4a0a-a576-d051d41d6bd2">
        <source>doPrintList();
// ---------------------------------------------------------------------------
// Created:     23 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.tblData.rows &lt;= self.tblData.fixedRows then
		app.msgBox('No items are currently listed', 'Nothing to print', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.tblData.printTable('Cargo Listing');
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueueCargoOffMAFI" id="a9e6f752-29e0-45f9-bf37-140a58f79b5b">
        <updating/>
        <source>doQueueCargoOffMAFI() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	jlizm1	Initial creation TFS 54702 CUX MAFI Auto Queueing
02 May 2024			jlizm1	TFS 63887 Check mafi and onboard cargo voyage match for RTL

*/

vars
	obj 	: Object;
	ti 		: CM_TrackedItem;
	tiSet 	: CM_TISet;
	params 	: CMIF_AutoplanParams;
	result 	: Integer;
	str		: String;
	mafi 	: CM_TILC;
	
begin
	
	create tiSet transient;
	
	if self.tblData.allSelectedObjects.isEmpty then
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_TrackedItem) then
			tiSet.add(self.myCurrentObject.CM_TrackedItem);
		endif;
	else
		foreach obj in self.tblData.allSelectedObjects do
			if CM_TrackedItem.hasInstance( obj ) then
				ti := obj.CM_TrackedItem;
				if not ti.isOnMAFI then
					continue;
				endif;
				mafi := ti.getCurrentTrailer();
				if mafi.myVoyage &lt;&gt; ti.myVoyage or mafi.dischargePort &lt;&gt; ti.dischargePort then
					tiSet.addNoDuplicates( ti, false );
				endif;
			endif;
		endforeach;
	endif;

	create params transient;
	
	if tiSet.size &gt; 0 then
		if not app.msgBox(app.getErrorString(Queue_cargo_off_mafi), app.getErrorString(QueueSelectedCargo), MsgBox_OK_Cancel) = MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	params.moveMode := QUEUE_MODE;
	params.showWarningWhenNoPlan := true;
	tiSet.copy(params.allTrackedItems);
	
	while true do
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	

epilog

	delete params;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="1761d010-3173-48a8-97b7-46adb4c3a1b1">
        <updating/>
        <source>doRefresh() updating, protected;
/* ---------------------------------------------------------------------------
// Created:     21 October 2003	cnwth2
//
// Purpose:     Table view form will re-show the thumbnail data - here we will also
//				clear out all the combos to force them to be repopulated
//			 
// ----------   ----------  --------------------------------------------------
   29/06/2010	cnwdap1		PAR #24516 Clear new Tranship combos
   03/07/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
   31/08/17		jlgns1		6735 POL - [Fwd: ##5431## : 8.5.1.090 Not saving VGM authorised details]
   02 Oct 2020  cnwma1		ChangeRequest 50112: ASPA - GCI Stevedores
   19/12/2022	jlika1		TFS 55584 HS Code Combobox Usage
   22/02/2023	jlika1		TFS 56496 CUX - Add attribute to cargo (to allow for conversions of MAFI types)
   12/06/2023	navpw1		TFS: 57812 (58439) - Added sorting method combo box
   14 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
   10 Nov 2023	jlika1	TFS 61130 61013 CUX | Cargo Priority - Cargo Maintenance
*/
vars

begin

	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		if self.allColumnFilters.includesFiltersFor( self.tblData ) then
			self.allColumnFilters.replaceAllFiltersForTable( self.tblData, null );
			self.applyColumnFilter( self.tblData );
		endif;
	endif;
	
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;
	
	self.cmbCarrier.clear();
	self.cmbComGroup.clear();
	self.cmbCommodity.clear();
	self.cmbConsignee.clear();
	self.cmbReceiveStevedore.clear();  //02.10.2020 cnwma1 TFS #50112
	self.cmbReleaseStevedore.clear();  //02.10.2020 cnwma1 TFS #50112
	self.cmbConsignor.clear();
	self.cmbFrghtFwdr.clear(); // 
	self.cmbContents.clear();
	self.cmbDestPort.clear();
	self.cmbDisPort.clear();
	self.cmbTranship.clear();
	self.cmbHasRadio.clear();
	self.cmbImExStatus.clear();
	self.cmbISOType.clear();
	self.cmbSpecialStow.clear(); //+ cnwmd1 Par 22167
	self.cmbLoadPort.clear();
	self.cmbOrigPort.clear();
	self.cmbMTGrade.clear();
	self.cmbOperator.clear();
	self.cmbRelCarrier.clear();
	self.cmbRelWagon.clear();
	self.cmbScalerCode.clear();
	self.cmbState.clear();
	self.cmbVoyage.clear();
	self.cmbWagon.clear();
	self.cmbWagonClass.clear();	//12 May 2014	NDL	Par 33615
	self.cmbBRItem.clear();
	self.cmbGenSetType.clear();
	self.cmbSubTerminal.clear();
	self.cmbIntendRelease.clear(); 	//+ cnwmd1, CCMS 1067, Par 19710
	self.cmbTrainAssigned.clear();	//+ cnwmd1, CCMS 1067, Par 19710
	self.cmbExpTshipVoy.clear();	// PAR #24516 cnwdap1
	self.cmbExpTshipDisch.clear();	// PAR #24516 cnwdap1
	self.cmbExpTshipDest.clear();	// PAR #24516 cnwdap1
	self.cmbHsCode.clear();
	self.cmbFloorType.clear();
	self.cmbCargoType4Cntnts.clear(); //02/10/2025	navkc1 JIRA 36144 
	//TFS 6735 jlgns1 31/08/2017 
	//	self.cmbAuthName.clear();				// TFS 4492
	//	self.cmbCertName.clear();				// TFS 4492
	
	self.cmbSortingMethod.clear();	// ### TFS 57812 (58439) 12Jun2023 NAVPW1
	self.cmbCustPriority.clear();
	
	inheritMethod();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRememberQuery" id="ff59dd28-1ebe-407f-af0e-3158deb66d65">
        <source>doRememberQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2019	jlger1	Initial creation

*/

vars
 idx : Integer;
	 obj, newObj : Object;
begin
    global.cnwer1;

	newObj:=self.cmbSelector.listObject;
	

	obj:=self.mnuRememberQuery.userObject;
	if obj &lt;&gt; null then
		idx:=self.cmbSelector.findObject(obj);
		if idx &gt; 0 then
			self.cmbSelector.setIndexFromObject(obj);
			if self.cmbSelector.listIndex &gt; 0 then
				self.cmbSelector.itemText[self.cmbSelector.listIndex]:=obj.CM_MenuUserQuery.heading;				
			endif;
		endif;
	endif;
	if  newObj &lt;&gt; null then
		self.cmbSelector.setIndexFromObject(newObj);
	else
		self.cmbSelector.listIndex:=1;
	endif;
	if self.cmbSelector.listIndex &gt; 1 then
		self.cmbSelector.itemText[self.cmbSelector.listIndex]:="*" &amp;newObj.CM_MenuUserQuery.heading;	
	endif;

		
	mnuRememberQuery.userObject:=newObj;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="01143f5d-248b-4997-aa8c-f08ff1631956">
        <updating/>
        <source>doResize() updating;
// 15/06/2010			cnwcs5	par 24342 - no longer using CMUI_StopsListTable
vars
	tbl			: CM_ThumbnailTable;
begin
	inheritMethod;

	if self.useTblThumb then
		tbl := self.tblThumb;
		//PAR#5304  - so end column extends out
		tbl.accessColumn(2).width := tbl.width.Integer;
	endif;
	
	self.setupMoveModeCtrl();	//25 Aug 2011	NDL Par 28035

	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="b54fd542-8859-422b-a660-8dccfb3a7593">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 June 2002 by cnwth2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	defVoyage	: CM_Voyage;
	idx			: Integer;
	
begin
	if not self.mode = Mode_Update then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Form not in update mode');
		return false;
	endif;
	
	if (not CM_TrackedItem.hasInstance(self.myProxyObject)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is either null, or not of Tracked Item type');
		return false;
	endif;

	if self.cmbVoyage.listObject = null 
	and (self.cmbVoyage.listCount &gt; 0)
	//and tblEdit1.getValueByName(ETRow_MyVoyage) = null then		// 17/03/2009 cnwar2 #18965
	and self.getValueFromTables(ETRow_MyVoyage) = null
	then
		defVoyage := self.myTerminal.getConfig(DefVoyage).CM_Voyage;
		idx := self.cmbVoyage.findObject(defVoyage);
		if idx &gt; 0 then
			self.cmbVoyage.listObject := defVoyage;
			self.cmbVoyage.lostFocus(self.cmbVoyage);
		endif;
	endif;
	
	if self.doingMultiEdit then
		return self.doSaveBulkEdit();
	else
		return self.doSaveSingleTI();
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveBulkEdit" id="0bef9329-3b59-439b-87a9-fb3e52513eea">
        <updating/>
        <source>doSaveBulkEdit(): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 20/07/2010	cnwdap1		PAR #25021 include Tranship tab in comparisons if displayed
// 26/06/2012	cnwdap1		PAR #29735 New parameter for CM_TrackedItem::setBookingRefAndItem
//							From here, if the user has selected a particular booking item,
//							we'll stick with it
//02 Oct 2012	cnwrs1	Par 30468 check the cargo/tare weight
//14 Jan 2015   cnwma1      PAR #35511 BBulk to cars
//06 Nov 2015   cnwma1	 	PAR #36719 Bulk Edit "only if original value matches" 
//11/12/2015   	cnwma1      PAR #37301 Comparison Error
//07/02/2023	navkc1 		CR 61168 Task 62372: Jade - TI Update Stop Criteria Check
//09/04/2024	navdap1		TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
//21 Oct 2024	navbs1  	Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue
// 05/11/20024	jlier1		MTN-33112
//20 Feb 2025	navhl20 	Bug MTN-34042: POL - Can't Bulk Edit Customs Export Delivery Order on Tracked Items
vars
	updateController		: CMIF_TIUpdateController;
	tbl						: CM_EntryTable;
	idx						: Integer;
	result					: Integer;
	numDefs					: Integer;
	pxyTI					: CM_TrackedItem;
	propDict				: PropertyNDict;
	rowObj					: Object;
	theClass				: Class;
	prop					: Property;
	somethingChanged		: Boolean; //PAR 17591
	updateAlphaOrFF			: Boolean;
	entRowTrans				: EntTableRowTransient;
	extraParams				: CMIF_TIUpdateExtraParams;
	editObject				: CMIF_EditObject;	
	obj						: Object;
	ti						: CM_TrackedItem;
	cbType					: CM_CargoBOLType;
	notMatch				: Boolean;
	firstTi					: CM_TrackedItem;
	prof     				: JadeProfiler;
	clock					: String;
	folder					: String;
	doProgressive			: Boolean;			// TFS 63307
	fieldChanged			: CMIF_EditObject;							//navra1 - TFS 64033 - 28th May 2024
	allSimpleFields			: Boolean;									//navra1 - TFS 64033 - 28th May 2024
	changedFieldsDict		: CMIF_EditObjectByAttrNameDict;			//navra1 - TFS 64033 - 28th May 2024
	simpleFieldsArray		: StringArray;								//navra1 - TFS 64033 - 28th May 2024
	simpleUpdateAgent 		: CMIF_TIBulkUpdateAgent;					//navra1 - TFS 64033 - 28th May 2024
	tiSet					: CM_TISet;									//navra1 - TFS 64033 - 28th May 2024
	masterTI				: CM_TrackedItem;							//navra1 - TFS 64033 - 28th May 2024	
	tmpStops				: IntegerArray;								//20.02.2025 navhl20 #34042
begin
	
	if process.isMohamed or process.isRam() then
		clock  := app.clock.String;
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 20;
		prof.fileName := folder&amp;"\MA" &amp; '\'  &amp;" - doSaveBulkEdit - " &amp;app.getMyUserCode &amp; ' - ' &amp; clock &amp;".txt";		
		prof.clearMethodCache();
		prof.start;
	endif;
	updateAlphaOrFF := (self.isShowingAlphabetised or (not self.canUpdate and self.canChangeFreightForwarder)); // PAR 16564

	pxyTI := self.myProxyObject.CM_TrackedItem;	
	
	updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
	self.myBulkEditController.myMasterTI := pxyTI;
	self.myBulkEditController.updateOption := self.cmbBulkEditOpt.itemData[self.cmbBulkEditOpt.listIndex];
	self.myBulkEditController.myMasterTIBeforeUpdate := self.myBulkEditController.myMasterTI.cloneSelf(true);
	self.addDebtorTypesToProxy(self.myBulkEditController.myMasterTIBeforeUpdate); //PAR 17591 cnwgb1 29 July 2008
	//self.addOperatorToProxy(self.myBulkEditController.myMasterTIBeforeUpdate);    // 06/11/2015 cnwma1 PAR #36719
	//self.myProxyObject.CM_TrackedItem.cloneReferences(self.myBulkEditController.myMasterTI, updateController, app.myPassport);
	self.myBulkEditController.myMasterTIBeforeUpdate.cloneReferences(self.myProxyObject.CM_TrackedItem, updateController, app.myPassport);	//10 Nov 2015	NDL	Par 36719
	
	
	theClass := self.myProxyObject.class;
	create propDict transient;
	numDefs := self.numberOfSheets;
	
	if updateAlphaOrFF then
		numDefs := 1;
	endif;
	
	//05 Jun 2015	NDL	Par 36338
	if app.isCargoGroupEnabled then
		if self.includesCargoGroupAnCargoItems(self.tblData) then
			return false;
		endif;
	endif;
	
	firstTi := self.tblData.allSelectedObjects.first.CM_TrackedItem;
	foreach obj in self.tblData.allSelectedObjects do
		if firstTi.myCargoType &lt;&gt; obj.CM_TrackedItem.myCargoType then
			notMatch := true;
			break;
		endif;
	endforeach;
	
	// 28823 Mar 2012 include change of cargo type (in a different table from all the other changes)
	if self.myProxyObject.CM_TrackedItem.myCargoType &lt;&gt; self.myCurrentCargoBOLType   and not notMatch  then
		//jlier1 MTN-33112 just create edit objects don't go through all the ent table rows 
		create editObject transient;
		editObject.myBulkEditController := self.myBulkEditController;
		editObject.attrName := ETRow_CargoTypeEntry;
	endif;


	foreach idx in 1 to numDefs do
		if updateAlphaOrFF then
			tbl := self.tblAlpha;
		else
			tbl := self.getEditTableForIndex(idx);
		endif;
		
		//par 19029 cnwjo3
		self.setVolumeFromHLW(tbl,null,null,null);
		
		propDict.clear();
		somethingChanged := false; //PAR 17591 cnwgb1 23 July 2008
		foreach rowObj in tbl.allEntRowTransients do
			entRowTrans := rowObj.EntTableRowTransient;
			if entRowTrans.hasChanged then
				// TFS 2115 07/2016 bulk-edit of seals doesn't make sense and gives errors in the update, just skip them by turning off the row changed flag
				if entRowTrans.name.length &gt; 6 and
				   entRowTrans.name[1:6] = "StRow_" then
					entRowTrans.hasChanged := false;
					continue;
				endif;
				somethingChanged := true; 		//PAR 17591 cnwgb1 23 July 2008
				prop := theClass.getPropertyInHTree(entRowTrans.name);
				if prop = null then
					// Debtor types are not stored as properties but are in a dictionary
					if entRowTrans.name[1:6] &lt;&gt; "DtRow_" and	  //PAR 17591 cnwgb1 24 July 2008
					   entRowTrans.name[1:6] &lt;&gt; "StRow_"  then		// Dt for debtor types, St for seals
						app.writeLog('Cargo Enquiry property entRowName not found in HTree ' &amp; entRowTrans.name, LogINFO);
					endif;
					continue;//th2 added - can't add null to collection
				endif;
					
				propDict.add(prop);
			endif;
		endforeach;
		
		if somethingChanged then //PAR 17591 cnwgb1 23 July 2008
			tbl.setObjectFromTableWithProps(pxyTI, CM_ContainerEnqForm::setTIFromTableSpecial.name, true, propDict);
		endif;
		
		//+cnwml2 PAR25920
		foreach prop in propDict do
			//jlier1 MTN-33112 create edit objects for anything that is changed and does not already have one (like hazards)
			if self.myBulkEditController.allEditObjectsByAttrName[prop.name] = null then
				create editObject transient;  //hazards other stuff not updated in setTIFromTableSpecial need an bulk edit object
				editObject.myBulkEditController := self.myBulkEditController;
				editObject.attrName := prop.name;
			endif;
		
			if prop.name = ETRow_MyVoyage then
				foreach obj in self.allProxyObjects do
					ti := obj.CM_TrackedItem;
					if ti.isTranshipItem and ti.state = TI_STATE_NORMAL then			//is a tranship item and onsite
						ti.setTranshipExportVoyage(ti.myVoyage.code, app.myPassport);
					endif;
				endforeach;
				break;
			endif;
		endforeach;
		
	endforeach;
	//02 Oct 2012	cnwrs1	Par 30468
	foreach obj in self.allProxyObjects do
		ti := obj.CM_TrackedItem;
		cbType := self.getCargoBOLTypeOfObject(ti);
		self.setCargoTareWeight(ti, cbType);
	endforeach;
	
	// cnwrd 25.5.09 ccms 1804
	create extraParams;
	
	if self.myTerminal.getConfig(UsePackSubTerminalDtl).Boolean then		// cnwdad1 15/01/2010 - PAR #22121.
		if not self.doMTChangeSubTerminalPackInfo(extraParams) then
			return false;
		endif;
	endif;
	
	// cnwrd1 par 20545 28.8.09 start
	if extraParams.doUpdateVoyageDetails then	
		pxyTI.setMyVoyage (extraParams.myVoyage, app.myPassport) ;
		create editObject transient;  // par 21318, bit of a hack, add some editObjects for bulk edit to copy changes to other cargo.
		editObject.myBulkEditController := self.myBulkEditController;
		editObject.attrName := ETRow_MyVoyage;
		
		pxyTI.setDestinationPort(extraParams.destinationPort);
		create editObject transient;
		editObject.myBulkEditController := self.myBulkEditController;
		editObject.attrName := ETRow_DestinationPort;
				
		
		pxyTI.setDischargePort(extraParams.dischargePort);			
		create editObject transient;
		editObject.myBulkEditController := self.myBulkEditController;
		editObject.attrName := ETRow_DischargePort;
	endif;
	
	if extraParams.myBookingRefItem &lt;&gt; null then
		//pxyTI.setBookingRefAndItem(extraParams.myBookingReference,extraParams.myBookingRefItem, app.myPassport);			// PAR #29735
		pxyTI.setBookingRefAndItem(extraParams.myBookingReference,extraParams.myBookingRefItem, true, app.myPassport);		// PAR #29735
		create editObject transient;
		editObject.myBulkEditController := self.myBulkEditController;
		editObject.attrName := ETRow_MyBookingRef;
		
		create editObject transient;
		editObject.myBulkEditController := self.myBulkEditController;
		editObject.attrName := ETRow_MyBookingRefItem;		
	endif;
	// cnwrd1 par 20545 28.8.09 end
	
	
	//26 Jan 2018 NDL	TFS 36697
	if app.myRoot.getConfig(DoValLogicalWeights).Boolean then
		if not pxyTI.validateLogicalWeights() then
			app.msgBox( app.getErrorString(Total_weigh_must_equal_cargo_w), app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
	endif;
	
	//if nothing is changed return even before you show the progress
	if self.myBulkEditController.allEditObjectsByAttrName.size() = 0 then				//navra1 - DEFECT 64428 - 2nd June 2024
		app.writeLog("No fields were changed, returning!", LogINFO);					//navra1 - DEFECT 64428 - 2nd June 2024
		return true;																	//navra1 - DEFECT 64428 - 2nd June 2024
	endif;
	
	self.displayMonitorForBulkEditing();

	app.myPassport.setContext(Context_Pass_OPS_TI_Update);  // ### TFS 53105 16JUN2022 NAVAB1		//21.10.2024  navbs1  #14791
	doProgressive := self.getMyTerminal.getConfig(AllowProgressiveUpdates).Boolean;			// TFS 63307
	
	//navra1 - TFS 64033 - 28th May 2025 - start - call simple update trx for simple fields update
	create simpleFieldsArray transient;
	simpleFieldsArray.add(ETRow_Mark);	
	simpleFieldsArray.add(ETRow_MarkNumber);
	simpleFieldsArray.add(ETRow_Colour);
	simpleFieldsArray.add(ETRow_Remarks);
	simpleFieldsArray.add(ETRow_PurchaseOrder);
	simpleFieldsArray.add(ETRow_ServiceOrder);
	simpleFieldsArray.add(ETRow_InvoiceContractId);										//navra1 - TFS 64368/Task 64370 - 31st May 2024
	simpleFieldsArray.add(ETRow_SpecialStow);											//navra1 - TFS 64368/Task 64379 - 4th June 2024
	masterTI := self.myBulkEditController.myMasterTI;									//20.02.2025 navhl20 #34042
	if masterTI.customExportEntryNumber = null then										//20.02.2025 navhl20 #34042
		create tmpStops transient;															
		masterTI.getStopsToBeProcessedRemove(StopProcessEDICustomExport, tmpStops);
		if tmpStops.isEmpty then
			simpleFieldsArray.add(ETRow_CustomExportEntryNumber);
		endif;
	else
		simpleFieldsArray.add(ETRow_CustomExportEntryNumber);							//navra1 - TFS 64368/Task 64378 - 4th May 2024	
	endif;
	//masterTI := self.myBulkEditController.myMasterTI;									//20.02.2025 navhl20 #34042
	changedFieldsDict := self.myBulkEditController.allEditObjectsByAttrName;
	allSimpleFields := true;					//assume all are simple fields
	
	//create the property value dictionary for the agent as you check
	foreach fieldChanged in changedFieldsDict do
		if not simpleFieldsArray.includes(fieldChanged.attrName) then
			allSimpleFields := false;			
			break;
		endif;
	endforeach;
	
	if allSimpleFields then				//if all are simple fields do the simple trx and return		
		//create agent to pass to the trx
		create simpleUpdateAgent transient;		
		simpleUpdateAgent.setupAgentForSimpleUpdate(changedFieldsDict, masterTI, self.allProxyObjects);		
		
		while true do
			app.myPassport.allowProgressiveUpdates := doProgressive;							// TFS 63307			
			
			app.myTrxUA.trxUpdateTIsForBulkEditSimple(simpleUpdateAgent, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				self.allTITxnControllers.purge();
				self.allTITxnControllers.clear();
				return true;
			else
				self.isBulkEditingCompleted := true;
				result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;

				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			return false;
		endwhile;
	endif;
	//navra1 - TFS 64033 - 28th May 2025 - end - call simple update trx for simple fields update
	
	// PAR 24336 - move setting of other proxies to before go into trx state
	//_bulkEditController.setProxiesForUpdate( _pxySet, _allStopsToAdd, _allStopsToRemove, _allStopsToUpdate, _extraParams, _passport );
	self.myBulkEditController.setProxiesForUpdate(self.allProxyObjects, self.allStopsToAdd, self.allStopsToRemove, self.allStopsToUpdate, extraParams, app.myPassport);
	extraParams.useSelectedBookingItem :=true;    //11/12/2015 cnwma1 PAR #37301
	
	//07/02/2023	navkc1 CR 61168 Task 62372
	self.checkProxyStopApplicable();
	
	while true do
		// set this as transaction does multi-transactions
		//self.addUpdateTransactionComplete := true;//added by cnwyl1 for Par 12276 and Par 12183
		app.myPassport.allowProgressiveUpdates := doProgressive;							// TFS 63307
		
		app.myTrxUA.trxUpdateTIsForBulkEdit(	self.allProxyObjects,
												self.myBulkEditController,
												TI_UPDMODE_NORMAL,
												self.allTasksToAdd,
												self.allTasksToComplete,
												self.allTasksToRemove,
												self.allStopsToAdd,
												self.allStopsToRemove,
												self.allStopsToUpdate,			// cnwrl1 18/01/2010 PAR 21889
												self.hasEditedToDoTasks,
												extraParams, //cnwrd1 ccms 1804 29.5.09
												app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.allTITxnControllers.purge();
			self.allTITxnControllers.clear();
			return true;
		else
			self.isBulkEditingCompleted := true;
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;
	
epilog
	delete tiSet;								//navra1 - TFS 64033 - 28th May 2024
	delete simpleUpdateAgent;					//navra1 - TFS 64033 - 28th May 2024
	delete simpleFieldsArray;					//navra1 - TFS 64033 - 28th May 2024
	delete extraParams;
	delete updateController;
	delete propDict;
	delete app.myPassport.myCMIFMonitor;

	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;
	app.mousePointer := MousePointer_Default;
	
	if self.myBulkEditController &lt;&gt; null then
		self.myBulkEditController.reset();	
	endif;
	
	if prof &lt;&gt; null then
		prof.report;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSingleTI" id="ffb67ba0-415e-449a-8b02-92c4d880c886">
        <updating/>
        <source>doSaveSingleTI() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwdap1		CCMS MES 1007 - add Reefer Ent Def to allow non-container reefer maintenance
// 29/03/2010	cnwdap1		PAR #23224 Expand reefer check to include chekcing commodity
// 06/06/2010	cnwrs2		PAR 24336 - add call to hook code
// 29/06/2010	cnwdap1		PAR #24516 add Tranship edit tab for tranships
// 26/06/2012	cnwdap1		PAR #29735 New parameter for CM_TrackedItem::setBookingRefAndItem
//							From here, if the user has selected a particular booking item,
//							we'll stick with it
//02 Oct 2012	cnwrs1	Par 30468 check the cargo/tare weight
// 29/05/2014	cnwdap1		PAR #34256 Don't clear the myReceivalBOLIn reference if we're a Log
//							(logs have a myReceivalBOLIn but their billOfLading attribute is blank)
// 11/12/2015   cnwma1      PAR #37301 Comparison Error
// 12/01/2018	jlgmd1		TFS #36406 - Editing Prenote doesn't change the Wagon Number
// 08 August 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// 07/02/2023	navkc1 		CR 61168 Task 62372: Jade - TI Update Stop Criteria Check
//21 Oct 2024	navbs1  	Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue

vars
	cbType					: CM_CargoBOLType;
	tbl						: CM_EntryTable;
	idx						: Integer;
	pxyTI					: CM_TrackedItem;
	txnControllerDict		: CMIF_TITxnContrlrByTypeDTDict;
	numDefs					: Integer;
	result					: Integer;
	extraParams				: CMIF_TIUpdateExtraParams;
	tmpDefArray				: StringArray;
	lashingToDoDesc 		: CM_ToDoTaskDesc;
	displayCompleteToDo	: Boolean;
	tiUpdateCntrl			: CMIF_TIUpdateController;
begin
	//if focus has gone straight from a cell control to the save button, the table WON'T pick up
	//a changed field value automatically, so we must call it explicitly
	tbl := self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);
	
	//par 19029 cnwjo3
	self.setVolumeFromHLW(tbl,null,null,null);
	
	tbl.doChangedComparison(tbl.row);
	pxyTI := self.myProxyObject.CM_TrackedItem;
	
//	cbType := self.getCargoBOLTypeOfObject(self.myProxyObject.CM_TrackedItem);				//+cnwml2 PAR21056	// cnwrl1 05/11/2010 PAR 26170 - what it was
	cbType := self.getCargoBOLTypeOfObject(pxyTI);						//+cnwml2 PAR21056
	if cbType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'CargoBOLType is null');
		return false;
	endif;
	
	if self.isShowingAlphabetised or (not self.canUpdate and self.canChangeFreightForwarder) then
		self.tblAlpha.setObjectFromTable(pxyTI, CM_ContainerEnqForm::setTIFromTableSpecial.name, false);
	elseif pxyTI.isKindOf(CM_CargoGroup) and app.isCargoGroupEnabled then	//03 Jun 2015	NDL	Par 36338
		self.tblEdit1.setObjectFromTable(pxyTI, CM_ContainerEnqForm::setTIFromTableSpecial.name, false);
	else
		numDefs := self.numberOfSheets;
				
		foreach idx in 1 to numDefs do
			tbl := self.getEditTableForIndex(idx);
			if (not self.allInitializedSheets.includes(idx)) then
				continue;
			endif;
		
			tbl.setObjectFromTable(pxyTI, CM_ContainerEnqForm::setTIFromTableSpecial.name, false);
		endforeach;
	endif;
	
	if pxyTI.billOfLading = null and not pxyTI.isKindOf(CM_Log) then				// PAR #34256
	//if pxyTI.billOfLading = null then		//cnwmc5 - 1 May 2014 - PAR 34074		// PAR #34256
		pxyTI.setMyReceivalBOL(null);		//cnwmc5 - 1 May 2014 - PAR 34074
		pxyTI.setBOLDtl(null);				//cnwmc5 - 1 May 2014 - PAR 34074
	endif;									//cnwmc5 - 1 May 2014 - PAR 34074
	
	// after setFromTable now check to see if cargo/tare weights need resetting
	self.setCargoTareWeight(pxyTI, cbType);	//02 Oct 2012	cnwrs1	Par 30468

	create extraParams;
	
	// cnwrd 25.5.09 ccms 1804
	if self.myTerminal.getConfig(UsePackSubTerminalDtl).Boolean then		// cnwdad1 15/01/2010 - PAR #22121.
		if not self.doMTChangeSubTerminalPackInfo(extraParams) then
			return false;
		endif;
	endif;
	
	// cnwrd1 par 20545 28.8.09 start
	if extraParams.doUpdateVoyageDetails then	
		pxyTI.setMyVoyage (extraParams.myVoyage, app.myPassport);
		pxyTI.setDestinationPort(extraParams.destinationPort);
		pxyTI.setDischargePort(extraParams.dischargePort);			
	endif;
	
	if extraParams.myBookingRefItem &lt;&gt; null then
		//pxyTI.setBookingRefAndItem(extraParams.myBookingReference,extraParams.myBookingRefItem, app.myPassport);			// PAR #29735
		pxyTI.setBookingRefAndItem(extraParams.myBookingReference,extraParams.myBookingRefItem, true, app.myPassport);		// PAR #29735
	endif;
	extraParams.useSelectedBookingItem := true;
	pxyTI.setCargoType(cbType.id);
	pxyTI.setMyProduct(self.myProxyObject.CM_TrackedItem.myProduct);
	
	if pxyTI.isRotatableContainer() then
		pxyTI.setCargoTypeForContents(self.myProxyObject.CM_TrackedItem.getCargoTypeForContents()); //02/10/2025	navkc1 JIRA 36144
	else 
		pxyTI.setCargoTypeForContents(null);
	endif;
	
	// cnwrd1 par 20545 28.8.09 end
	// CCMS 1071 BOLDtl
	pxyTI.setBOLDtl(self.myProxyObject.CM_TrackedItem.myBOLDtl);

	//+cnwml2 PAR25920
	if pxyTI.isTranshipItem and pxyTI.state = TI_STATE_NORMAL then			//is a tranship item and onsite
		pxyTI.setTranshipExportVoyage(pxyTI.myVoyage.code, app.myPassport);
	endif;
	
	//TFS 36406
	if pxyTI.isPreNote then
		extraParams.doWagonMove := true;
	endif;
	
	// PAR 24336 RJS - move setting of other proxies to before go into trx state
	app.myHookAgent.runHookLinkPublic(HookType_CargoEdit, self.myTerminal, pxyTI, extraParams);
	
	//26 Jan 2018 NDL	TFS 36697
	if app.myRoot.getConfig(DoValLogicalWeights).Boolean then
		if not pxyTI.validateLogicalWeights() then
			app.msgBox(app.getErrorString(Total_weigh_must_equal_cargo_w), app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	//Start 08.08.2022 navak20 TFS 53862
	if pxyTI.amIDamaged then				// 17/07/23 navcs2 Bug 59045
		pxyTI.setDamagedDT(true);
	else
		pxyTI.setDamagedDT(false);
	endif;
	//End 08.08.2022 navak20 TFS 53862
	
	//jlier1 TFS 54700 7/9/22
	if pxyTI.isChassis and pxyTI.CM_TILC.contentsStatus &lt;&gt; self.myCurrentObject.CM_TILC.contentsStatus and
		(pxyTI.CM_TILC.contentsStatus = TI_CONTENTS_STATUS_FULLLASHED or pxyTI.CM_TILC.contentsStatus = TI_CONTENTS_STATUS_PRTLOADLASH) then
		//check config
		lashingToDoDesc:=self.myTerminal.getConfig(ToDoTaskMAFILashing).CM_ToDoTaskDesc;
		if lashingToDoDesc &lt;&gt; null then
			//check if already completed this task??
			if self.myCurrentObject.CM_TrackedItem.getToDoTaskCompletedDT(lashingToDoDesc.code) = null then
				//has not already been completed 
				//check if it is added 
				if self.myCurrentObject.CM_TrackedItem.getToDoTaskToDoWithCode(lashingToDoDesc.code) = null then
					//add the to do task
					if not self.allTasksToAdd.includes(lashingToDoDesc.code) then
						self.allTasksToAdd.add(lashingToDoDesc.code);
						self.hasEditedToDoTasks:=true;
					endif;
				endif;
				
				if lashingToDoDesc.allResourceTypes.first = null then
					self.allTasksToComplete.add(lashingToDoDesc.code);
					self.hasEditedToDoTasks:=true;
				else
					displayCompleteToDo:=true;
				endif;
			
			endif;
		endif;
	endif;
	
	//07/02/2023	navkc1 CR 61168 Task 62372
	self.checkProxyStopApplicable();
	
	while true do
		delete txnControllerDict;
		create txnControllerDict transient;
		self.allTITxnControllers.copy(txnControllerDict);
		
		if self.hasEditedToDoTasks then //cnwrd1 ccms 1804 27.5.09
			self.allTasksToAdd.copy(extraParams.allTasksToAdd);
			self.allTasksToComplete.copy(extraParams.allTasksToComplete);
			self.allTasksToRemove.copy(extraParams.allTasksToRemove);
			extraParams.hasEditedToDoTasks := self.hasEditedToDoTasks;
		endif;
		
		app.myPassport.setContext(Context_Pass_OPS_TI_Update); // ### TFS 52925 21FEB2022 NAVAB1	//21.10.2024  navbs1  #14791
		
		app.myTrxUA.trxUpdateTIandExtraInfo(pxyTI, 
											TI_UPDMODE_NORMAL, 
											extraParams,
											txnControllerDict, 
											null, //comment field
											app.myPassport);			
				
		if app.myPassport.trxCompletedOK() then
			self.clearErrorWarnings();
			self.allTITxnControllers.purge();
			self.allTITxnControllers.clear();	
			
			//jlier1 TFS 54700 15/9/22
			if displayCompleteToDo then			
				self.doCompleteMAFILashingToDo(lashingToDoDesc);
			endif;
			
			return true;
		else
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return false;
	endwhile;
	
		
epilog
		
	app.myPassport.setContext(Context_Pass_Null); // ### TFS 52925 21FEB2022 NAVAB1			//21.10.2024  navbs1  #14791

	delete txnControllerDict;
	delete extraParams;
	delete tmpDefArray;		// CCMS 1007
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearchUsingSelector" id="b31a2d70-fc56-4ffe-8a47-227193287cca">
        <updating/>
        <source>doSearchUsingSelector( _tiID : String; _numItems: Integer io; _tiSet : CM_TISet io ):Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2014	cnwndl1	Initial creation TESTING
15 October 2015 cnwma1  PAR #36601 Cargo Enquiry Log Search by Terminal Area + Yard Location returns nothing
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
08 Jul    2018	cnwma1	Bug 39512: C3 - [Bug] - Cargo Enquiry Search Criteria
*/

vars

	isoType : CM_ISOType;
	cargoType : CM_CargoType;
	imexCode : CM_IMEXStatus;
	product : CM_Product;
	filtTrailerTypeCode : String;
	ta : CM_TerminalArea;
	taType : CM_TerminalAreaType;
	
	comboSiteText : String;
	tiSite : Integer;
	tiState : Integer;
	
	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerTI;
	iter : Iterator;
	ti : CM_TrackedItem;
	
	startObject : CM_CargoGroup;
	tiLength : Integer;
begin

	//establish the correct query definition to use
	cargoType := self.cmbFiltTiType.listObject.CM_CargoType;
	if self.filterISOType &lt;&gt; null then
		isoType := app.myRoot.allISOTypes[self.filterISOType];
		if isoType &lt;&gt; null and cargoType = null then
			cargoType := app.myRoot.allCargoTypesById[ TI_CargoType_Container ];
		endif;
	endif;
	
	if cargoType = app.myRoot.allCargoTypesById[ TI_CargoType_Container ] then
		qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container];
	else
		qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	endif;
	
	
	//create the selector query object.
	create myEnqController;
	create myEnqController.allObjects as  CM_TISet transient;
	create criteriaHolder transient;
	myEnqController.myTerminal := self.myTerminal;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	myEnqController.searchReversed := true;
	myEnqController.containerEnqSearch := true;
	myEnqController.searchArchivedVoyages := self.includeArchivedVoyages;
write method.qualifiedName &amp; " self.includeArchivedVoyages " &amp; self.includeArchivedVoyages.String;	
	//create the individual criteria query lines
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
	
	if self.filterAltId &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::alternativeId.name, CM_QueryOperator.Operator_StartsWith, self.filterAltId);
	endif;
	
	if self.filterBOL &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::billOfLading.name, CM_QueryOperator.Operator_Equal, self.filterBOL);
	endif;
	
	if self.filterBookingRef &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_Equal, self.filterBookingRef);
	endif;
	
	if cargoType &lt;&gt; null then // already derived from self.cmbFiltTiType / filterCargoTypeId
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
	endif;
	
	if self.filterCustomsReference &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::customsReference.name, CM_QueryOperator.Operator_StartsWith, self.filterCustomsReference);
	endif;
	
	
	if self.filterIMEXStatus &lt;&gt; null then
		imexCode := app.myRoot.allImexStatuses[ self.filterIMEXStatus ];
		if imexCode &lt;&gt; null then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::imexStatus.name, CM_QueryOperator.Operator_Equal, imexCode);
		endif;
	endif;
	
	if isoType &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Container::isoType.name, CM_QueryOperator.Operator_Equal, isoType);
	endif;
	
	if _tiID &lt;&gt; null then // Use passed in value because can be called multiple times for multi cargo entry from form
		//self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith, _tiID);
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith, _tiID[1:30]); //21 Apr 2016	NDL	TFS 1885
	endif;
	
	if self.filterOperator &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, self.filterOperator);
	endif;
	
	if self.filterProduct &lt;&gt; null then
		product := self.cmbFiltProd.listObject.CM_Product;
		if product &lt;&gt; null then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_Equal, product);
		endif;
	endif;

	if self.cmbFiltSite.listIndex &gt; 0 then
		comboSiteText := self.cmbFiltSite.itemText[ self.cmbFiltSite.listIndex ];
	endif;
	if comboSiteText = ANYSITE_STRING
	or comboSiteText.trimBlanks = null
	then
		tiSite := 0;
		tiState := 0;	
	elseif comboSiteText = ONSITE_STRING then
		tiSite := TI_SITE_ONSITE;
		tiState := TI_STATE_NORMAL;	
	elseif comboSiteText = OFFSITE_STRING then
		tiSite := TI_SITE_OFFSITE;
		tiState := TI_STATE_OFFSITE;	
	elseif comboSiteText = ONSHIP_STRING then
		tiSite := TI_SITE_ONSHIP;
		tiState := TI_STATE_ONSHIP;	
	elseif comboSiteText = OFFLOADED_STRING then
		tiSite := 0;
		tiState := TI_STATE_OFFLOADED;	
	elseif comboSiteText = NOTIFIED_STRING then
		tiSite := TI_SITE_TBA;
		tiState := TI_STATE_NOTIFIED;	
	elseif comboSiteText = DELETED_STRING then
		tiSite := 0;
		tiState := TI_STATE_DELETED;	
	elseif comboSiteText = TRANSFER_STRING_FROM then
		tiSite := 0;
		tiState := TI_STATE_TRANSFER_FROM;	
	elseif comboSiteText = TRANSFER_STRING_TO then
		tiSite := 0;
		tiState := TI_STATE_TRANSFER_TO;	
	endif;
	if tiSite &gt; 0 then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::site.name, CM_QueryOperator. Operator_Equal, tiSite);
	endif;
	if tiState &gt; 0
	and ( cargoType = null or cargoType.productType &lt;&gt; ProductType_CargoGroup )	//02 Jun 2015	NDL	Par 36338
	then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, tiState);
	endif;
			
	if self.filterSubTerminal &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::mySubTerminal.name, CM_QueryOperator.Operator_Equal, self.filterSubTerminal);
	endif;
	
	if self.filterTerminalArea &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::myTerminalArea.name, CM_QueryOperator.Operator_Equal, self.filterTerminalArea);
	endif;
	
	if self.filterUnpackedFrom &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::getMyUnpackedFromContainerId.name, CM_QueryOperator.Operator_Equal, self.filterUnpackedFrom);
	endif;
	
	//29 Aug 2019	NDL	TFS 46118
	if self.filterMark &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::mark.name, CM_QueryOperator.Operator_Equal, self.filterMark);
	endif;
	
	if self.filterVoyage &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, self.filterVoyage);
	endif;
	
	if self.filterYardLocation &lt;&gt; null then
		if self.myCurrentCargoBOLType &lt;&gt; null then						// 15/10/2015 cnwma1 PAR #36601 
			if self.myCurrentCargoBOLType.id &lt;&gt; TI_CargoType_Log then 	// 15/10/2015 cnwma1 PAR #36601 
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_StartsWith, self.filterYardLocation.getFullId);// cnwrd1 par 34211 changed to stars with for racking searches.
			else
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_StartsWith,self.filterYardLocation.getID); 	 // 15/10/2015 cnwma1 PAR #36601 
			endif;
		//08.07.2018 cnwma1	TFS #39512
		else 
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_StartsWith, self.filterYardLocation.getFullId);
		endif;
	endif;	
	
	//epr CCMS 1409 par 35553 22/1/15
	if self.filetEIR &lt;&gt; null then
		self.doCreateCriteriaLine(qDef,criteriaHolder,CM_TrackedItem::eirNumber.name, CM_QueryOperator.Operator_Equal,self.filetEIR);
	endif;
	
	// call the query
	myEnqController.myContext := self;	//24 July 2014	NDL	Par 34625
	myEnqController.doQuery( qDef );
	
	// Have to add each individually to the _ti collection as can do multiple passes which may identify duplicates
	// also additional filtering may be required after the selector has done its stuff.
	if self.filterTrailerType &lt;&gt; null then
		filtTrailerTypeCode := self.filterTrailerType.code;
	endif;
	iter := myEnqController.allObjects.CM_TISet.createIterator;

	while iter.next(ti) do

		if filtTrailerTypeCode &lt;&gt; null and ti.getTrailerType &lt;&gt; filtTrailerTypeCode then
			//self.filterTrailerType
			continue;
		endif;
		if self.filterTAType &lt;&gt; null then
			//self.filterTAType
			ta := ti.myTerminalArea;
			if ta &lt;&gt; null then
				taType := ta.myType;
			else
				taType := null;
			endif;
			if self.filterTAType &lt;&gt; taType then
				continue;
			endif;
		endif;
		
		_tiSet.addNoDuplicates( ti, false );
		
	endwhile;
	delete iter;
	
	//04 Jun 2015	NDL	Par 36388
	if app.isCargoGroupEnabled and cargoType = null then
		//wants to look at cargo groups and cargo together...
		if _tiID &lt;&gt; null then
			tiLength := _tiID.length;
			iter := self.myTerminal.allCargoGroupsByIdCargoType.createIterator;
			startObject := self.myTerminal.allCargoGroupsByIdCargoType.getAtKeyGeq(_tiID,null).CM_CargoGroup;
			if startObject &lt;&gt; null then
				iter.startAtObject( startObject );
				while iter.next( ti ) do
					if ti.id.length &lt; tiLength then
						break;
					endif;
					if ti.id[1:tiLength] &lt;&gt; _tiID then
						break;
					endif;
					if self.filterOperator &lt;&gt; null then
						if ti.myOperator &lt;&gt; self.filterOperator then
							continue;
						endif;
					endif;
					_tiSet.addNoDuplicates( ti, false );
				endwhile;
			endif;
			delete iter;
		endif;
	endif;
	
	if app.isCargoGroupEnabled and cargoType &lt;&gt; null and cargoType.isCargoGroup then
		if _tiID &lt;&gt; null then
			tiLength := _tiID.length;	
			iter := self.myTerminal.allCargoGroupsByAlternativeID.createIterator;
			startObject := self.myTerminal.allCargoGroupsByAlternativeID.getAtKeyGeq(_tiID).CM_CargoGroup;
			if startObject &lt;&gt; null then
				iter.startAtObject( startObject );
				while iter.next( ti ) do
					if ti.alternativeId.length &lt; tiLength then
						break;
					endif;
					if ti.alternativeId[1:tiLength] &lt;&gt; _tiID then
						break;
					endif;
					if self.filterOperator &lt;&gt; null then
						if ti.myOperator &lt;&gt; self.filterOperator then
							continue;
						endif;
					endif;
					_tiSet.addNoDuplicates( ti, false );
				endwhile;
			endif;
			delete iter;
			
		endif;
	endif;
		
	return true;
	
epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_tiID" type="String"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectorSearch" id="05e4b35e-7e24-407c-ac13-63c09e8729bc">
        <updating/>
        <source>doSelectorSearch(numItems : Integer io;  breakOut : Boolean io) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2019	jlger1	Initial creation 47132
04 April 2024   annamth     CR 61540: MTN - [POC - Phase 1] - Enhancing Query Performance through Multi-Process
27 May 20205	navnk30		JIRA 34771: MTN - Implement Pagination in the Cargo Enquiry Form
30 Jun 2025 jlier1	MTN-347771 - changed to using display collection
*/

vars

	ti : CM_TrackedItem;
	obj : Object;
	iter : Iterator;
	critCargoType : CM_SelectorCriteriaLine;
	idCrit,
	critOperator : CM_SelectorCriteriaLine;
	removedCritLine : ObjectSet;
	tempLines : ObjectSet;
	cargoTypeInt : Integer;
	cargoTypeObj : CM_CargoType;
	startObject : CM_CargoGroup;
	tiID : String;
	originalMultiID : String;
	form : CM_BaseForm;
begin
	self.myFilterIDList.clear;
	self.myEnqController.reset;
	self.myEnqController.allObjects.clear;

	if self.myEnqController.isKindOf(CM_EnqControllerTI) then
		self.myEnqController.CM_EnqControllerTI.myTerminal := self.myTerminal;
	endif;
			
	create removedCritLine transient;
	create tempLines transient;
	self.doPreSelectorSearch(removedCritLine,tempLines);
	
	
	self.myEnqController.myContext:=self;
	self.myEnqController.myCriteriaLineHolder :=   self.myCriteriaLineHolder;
	
	if self.myFilterIDList.size &gt; 1 then
		idCrit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);
		originalMultiID:=self.myFilterIDList.concatenate(' ');
		if idCrit &lt;&gt; null then
			foreach tiID in self.myFilterIDList do
				idCrit.myQueryOperator.setSearchValue(tiID);
				self.myEnqController.doQuery(  null);
			endforeach;		
		endif;
	else
		if app.isCargoGroupEnabled then	//06 Mar 2020 TFS 48776 - testing ( a search for a single Cargo Group without a cargo type fails)
			idCrit :=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);
		endif;
		self.myEnqController.doQuery(  null);
	endif;
	
	/* The totalNumOfAsyncProcesses is the number of processes that are present for all users in a node (application server). These should not exceed the
	value specified in the config value MaxAsyncProcesses. MaxWorkersPerUser is the number of worker processes that can be created for user.	
	Example: MaxAsyncProcesses is 30
	User1 is performing a search. System creates 10(assuming MaxWorkersPerUser is 8) worker processes.
	User2 is performing a search. System creates 10(assuming MaxWorkersPerUser is 8) worker processes. 
	User3 is performing a search. System creates 10(assuming MaxWorkersPerUser is 8) worker processes.
	User4 is also performing the search, then 32 is greater than the configured value of 30...at this point the search for User4 defaults to the synchronous search.
	*/
	
	//navra1 - TFS 63751/Task 63752 - 13th May 2024	- start
	form := self;
	/*													27.05.2025 navnk30 JIRA 34771 START
	self.tblData.getDataAndDisplayRowsMultith(self.myEnqController.allObjects, true, form, true);	
	numItems := self.tblData.rows - self.tblData.fixedRows;	//set numItems to the total rows you filled up on the table		//navra1 - DEFECT 64188 - 20th May 2024
	*/
	self.tblData.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, self.myEnqController.allObjects, true);
	numItems := self.myEnqController.allObjects.size();	//27.05.2025 navnk30 JIRA 34771 END
	
	
	//navra1 - TFS 63751/Task 63752 - 13th May 2024	- end
	
	if app.isCargoGroupEnabled and  idCrit &lt;&gt; null then
		
		//29 Apr 2020	NDL	TFS 49192
		critCargoType := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::cargoType.name);
		if critCargoType &lt;&gt; null and critCargoType.myQueryOperator.isKindOf(CM_QIntegerLookupEqual) then
			cargoTypeInt := critCargoType.myQueryOperator.getSearchValue().Integer;
			if cargoTypeInt &gt; 0 then
				cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey( cargoTypeInt ).CM_CargoType;
			endif;
		endif;
	
		foreach tiID in self.myFilterIDList do
			idCrit.myQueryOperator.setSearchValue(tiID);
			if cargoTypeObj = null then
				iter := self.myTerminal.allCargoGroupsByIdCargoType.createIterator;
				startObject := self.myTerminal.allCargoGroupsByIdCargoType.getAtKeyGeq(tiID,null).CM_CargoGroup;
			else
				iter := self.myTerminal.allCargoGroupsByAlternativeID.createIterator;
				startObject := self.myTerminal.allCargoGroupsByAlternativeID.getAtKeyGeq(tiID).CM_CargoGroup;
			endif;
			critOperator:=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::operatorCode.name);
			if startObject &lt;&gt; null then
				iter.startAtObject( startObject );
				while iter.next( ti ) do
					if iter.getCurrentKey(1).String &lt;&gt; tiID then
						break;
					endif;
					if critOperator &lt;&gt; null and critOperator.myQueryOperator.getSearchValue &lt;&gt; null then
						if  not ti.qrySelectorCriteria(critOperator) then
							continue;
						endif;
					endif;
					self.addObjectToTable(ti, numItems, breakOut);	
				endwhile;
			endif;
			delete iter;

		endforeach;
	endif;
	
	if originalMultiID &lt;&gt; null and idCrit &lt;&gt; null  then
		idCrit.myQueryOperator.setSearchValue(originalMultiID);
	endif;
	
epilog
	self.doPostSelectorSearch(removedCritLine,tempLines);
	
	delete removedCritLine;
	delete tempLines;
	delete iter;
	delete self.tblData.allTblDataObjDict;
	
end;</source>
        <access>protected</access>
        <Parameter name="numItems" type="Integer" usage="io"/>
        <Parameter name="breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doShowCustomsStatusEnquiryForm" id="8d2653c5-b66a-4eee-b6a5-9e0501e7c72d">
        <source>doShowCustomsStatusEnquiryForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2014	cnwmc5	Initial creation	CCMS 2353

*/

vars
	realBOL : CM_BOLIn;
	
begin
	if (not self.myCurrentObject.isKindOf(CM_BOLIn) or not CM_BOLIn.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	
	realBOL	:= self.myCurrentObject.CM_BOLIn;
	
	self.myAssistant.showCustomsStatusEnquiryForm(self.myTerminal, realBOL);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowDamageEntriesForCargoEnq" id="479f374d-2d2e-42d5-971b-f2dab9e43e14">
        <source>doShowDamageEntriesForCargoEnq(_pxyTI : CM_TrackedItem);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 13/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 27 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//----------------------------------------------------------------------
vars
	tbl : CM_EntryTable;
begin
	tbl := self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);
	tbl.setValueByName(ETRow_DamageDetail, _pxyTI.getDisplayStringForAttribute(ETRow_DamageDetail, false));
	
	//Start 27.07.2022 navak20 TFS 53862
	if _pxyTI.allDamageInstancesByPos.size &gt; 0 then		
		tbl.hideRowByName(ETRow_HasNewDamage,false);
		tbl.setValueByName(ETRow_HasNewDamage,false);
	endif;
	//End 27.07.2022 navak20 TFS 53862
epilog
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doShowDamageInstancesForm" id="387c34e4-cc26-4846-8d05-95e7f4ea19dd">
        <updating/>
        <source>doShowDamageInstancesForm() updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 24 July 2009
//
// Implemented version: 7.7.3
// 30/09/2022	navkc1	ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
// 02/08/2023	navcs2	ChangeRequest 59569: EUP - Damage | Cargo Saving and Discrepancy order
//----------------------------------------------------------------------
vars
	existingForm	: Boolean;
	ti,
	realTi : CM_TrackedItem;
	form : CMUI_DamageCodesAdvanceForm;
	mode : Integer;
begin
	/*- Par 23522  Allow to view damages
	//epr par 21065 17/3/10
	if self.mode = Mode_View then
		return;
	endif;
	*/
	
	ti := self.myProxyObject.CM_TrackedItem;
	realTi := self.myCurrentObject.CM_TrackedItem;
	
	// Inverse the mode essentially
	// 01/08/2023 navcs2 ChangeRequest 59569
	if self.mode = self.Mode_Update then
		mode := self.Mode_View;
	elseif self.mode = self.Mode_View then
		mode := self.Mode_Update;
	endif;
	
	self.myAssistant.showDamageEntryForm(self, mode, self.myTerminal, ti, realTi, null, null, false);	// 30/09/2022	navkc1	#54463  // 01/08/2023 navcs2 ChangeRequest 59569
	
	/*	//30/09/2022	navkc1	#54463
	// from 29944 only have one open at once; also keep a reference so can close on edit
	if self.myDamageCodesForm &lt;&gt; null then
		form := self.myDamageCodesForm;
		if not app.isValidObject(form) then		// form closed
			form := null;
		else
			existingForm := true;
		endif;
	endif;
	if form = null then
	//form := app.loadForm (CMUI_DamageCodesForm, CMUI_Assistant, false, false, true , self.myTerminal, null).CMUI_DamageCodesForm; //- cnwmd1 Par 23522
		form := app.loadForm (CMUI_DamageCodesAdvanceForm, CMUI_Assistant, false, false, mode = Mode_Add or mode = Mode_Update , self.myTerminal, null).CMUI_DamageCodesAdvanceForm; //+ cnwmd1 Par 23522
	endif;
	
	if form = null then
		return;
	endif;
	
	if self.mode = Mode_Add then
		form.mode := Mode_Add;
	elseif self.mode = Mode_Update then
		form.mode := Mode_Update;
		form.isParentFormUpdate := true;
	else
		form.mode := Mode_View;
	endif;
		
	form.setMyMasterItems(ti, realTi);
	form.setParentForm(self);

	form.centreWindow();
	if self.mode = Mode_View then //+ cnwmd1 Par 23522
		// from 29944 limit the number of view forms
		self.myDamageCodesForm := form;
		if existingForm then	// in case cargo item has changed since last form display
			form.initDamageTable();
			form.loadDamageItems();
		endif;
		form.show;
	else
		form.showModal();
	endif;
	*/
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowDataSpecial" id="396c2e38-f079-4636-89b7-641f56cd49c1">
        <source>doShowDataSpecial(_tbl : CM_DataTable input; _row : Integer; _obj : Object);
/*

Purpose:			
		This method is created to show any special data to the table
Parameters:			

Return Value:		

Date		Who		Reason
19 April 2023	navkc1	Initial creation
1  Jul 2025	jlier1  JIRA - 34771
*/

vars
	theCell : JadeTableCell;
	drwAtt	: CM_DrawingAttribute;
	col		: Integer;
	text	: String;
begin
	if _obj.isKindOf(CM_TrackedItem) then
		// we used to save off the column in which RT was displayed but it was not being updated consistently
		// so we will look it up here instead
		col := _tbl.getColumnByRowName(ETRow_RadioTelemetryState);	// 28/02/2011 cnwcs5 par 14050
		
		if col &gt; 0 and _row &gt; 0 then													// 28/02/2011 cnwcs5 par 14050
			// ### NOW AKB2004AUG the new Q and P icons had no Q or P in them so use Letters and colour the font
			theCell 			:= _tbl.accessCell(_row, col);
			text				:= _obj.CM_TrackedItem.getRTLetter(); 	// returns Q, P, or RT
			//theCell.text 		:= text;								// 28/02/2011 cnwcs5 par 14050
			theCell.fontBold 	:= false;
			
			// 01/03/2011 cnwcs5 par 14050 - next block rewritten to be more efficient and reflect result from getRTLetter
			if text = "P" then
				theCell.foreColor := Green;
			elseif text = "Q" then
				theCell.foreColor := Red;
			else // value of RT
				theCell.foreColor := Blue;
			endif;				
			// 01/03/2011 cnwcs5 par 14050 - end
		endif;
		
		col := _tbl.getColumnByRowName(ETRow_CustomExportStop);		// 28/02/2011 cnwcs5 par 14050
		
		if col &gt; 0  and _row &gt; 0  then													// 28/02/2011 cnwcs5 par 14050 // 26/05/2010 cnwmh5 #23880
			theCell := _tbl.accessCell(_row, col);				// 28/02/2011 cnwcs5 par 14050
			if theCell.text &lt;&gt; null then
				drwAtt := app.myRoot.allDrawingAttributes[PicTICustomHold];
				
				if drwAtt &lt;&gt; null then
					theCell.text 		:= drwAtt.fontCharacter.Character;	
					theCell.foreColor 	:= drwAtt.colour;
					theCell.fontName 	:= drwAtt.fontName;
				endif;
			endif;
		endif;		
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doShowDktForTicket" id="ee0283df-314e-484d-baa3-e17cab8c3cc0">
        <updating/>
        <source>doShowDktForTicket()updating;
//--------------------------------------------------------------
//Created: 05 June 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 04/04/2022	navdap1		TFS 53304 C3L Show Docket for Cargo returns 1086 Error
vars
	bol : CM_BOL;
	theTI : CM_TrackedItem;
	crit : CM_SelectorCriteriaLine;		// TFS 53304
begin
	if self.myCurrentObject = null or not self.myCurrentObject.isKindOf(CM_TrackedItem) then
		return;
	endif;
	theTI := self.myCurrentObject.CM_TrackedItem;
	bol := theTI.myReceivalBOL;
	if bol &lt;&gt; null then
		self.myCurrentCargoBOLType := bol.getMyBOLType;
		self.myAssistant.comboBoxCargoBolType(self.cmbFiltTiType, bol.bolType, true, true, true, true);
		self.cmbFiltTiType.click(self.cmbFiltTiType);
		self.cmbFiltTiType.lostFocus(self.cmbFiltTiType); //12/01/2010 cnwdz2 21836
		if cmbFiltTiType.listObject.CM_CargoBOLType.mainFormFilterView = 'LogBOL' then
			self.tblSearch.setValueByName(ETRow_DocketNumber, bol.number);	
		else
			self.tblSearch.setValueByName(ETRow_FilterBOL, bol.number);		
		endif;//par 13899
		self.createDefaultCritLineHolder(bol.getMyBOLType, bol);					// TFS 53304
		self.setupTblSearcherForCargoType(bol.bolType);								// TFS 53304
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_BOL::number.name);	// TFS 53304
		if crit &lt;&gt; null then														// TFS 53304
			crit.myQueryOperator.setSearchValue(bol.number);						// TFS 53304
		endif;																		// TFS 53304
		//self.tblSearch.setValueByName(ETRow_FilterBOL, bol.number);
		self.zDoSearch();
		self.setTblSearchFromSelector();											// TFS 53304
		self.setEditEnabledDisabled(self.myCurrentCargoBOLType.id);		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowDktsInLocation" id="66ab9a64-e80d-4e4f-bc47-0c714995c32c">
        <updating/>
        <source>doShowDktsInLocation()updating;
//--------------------------------------------------------------
//Created: 05 June 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 04/04/2022	navdap1		TFS 53304 C3L Show Docket for Cargo returns 1086 Error
vars
	location : CM_LocationsController;
	theTI : CM_TrackedItem;
	crit : CM_SelectorCriteriaLine;			// TFS 53304
begin
	if self.myCurrentObject = null or not self.myCurrentObject.isKindOf(CM_TrackedItem) then
		return;
	endif;

	theTI := self.myCurrentObject.CM_TrackedItem;
	if theTI.myReceivalBOL = null then
		return;
	endif;
	location := theTI.getPrimaryLocation(REAL_MODE);

//	if location &lt;&gt; null then
//		self.myCurrentCargoBOLType := theTI.myReceivalBOL.getMyBOLType;
//		self.myAssistant.comboBoxCargoBolType(self.cmbFiltTiType, theTI.myReceivalBOL.bolType, true, true, true, true);
//		self.cmbFiltTiType.click(self.cmbFiltTiType);	
//		self.tblSearch.setValueByControlName(self.cmbFiltYardLocn.name, location.displayEntry);	
//		self.zDoSearch();
//		self.setEditEnabledDisabled(0);		
//	endif;
	if location &lt;&gt; null then
		self.myCurrentCargoBOLType := theTI.myReceivalBOL.getMyBOLType;
		self.myAssistant.comboBoxCargoBolType(self.cmbFiltTiType, theTI.myReceivalBOL.bolType, true, true, true, true);
		self.cmbFiltTiType.click(self.cmbFiltTiType);	
//par 11124	 rs1 dec 2005
		self.tblSearch.setValueByName(ETRow_FilterId, null);
		self.tblSearch.setValueByName(ETRow_FilterBOL, null);
		self.tblSearch.setValueByControlName(cmbFiltYardLocn.name, null);
		self.tblSearch.setValueByControlName(cmbFiltVoyage.name, null);
		self.createDefaultCritLineHolder(theTI.myReceivalBOL.getMyBOLType, theTI.myReceivalBOL);					// TFS 53304
		self.setupTblSearcherForCargoType(theTI.myReceivalBOL.bolType);												// TFS 53304
		if location.myTerminalArea &lt;&gt; null then
			self.myAssistant.comboBoxTAType(cmbFiltTAType, location.myTerminalArea.myType, false);	
			tblSearch.setValueByControlName(cmbFiltTAType.name, cmbFiltTAType.text);
		
			self.myAssistant.comboBoxTerminalArea(cmbFiltTermArea, location.myTerminalArea.myType.type, location.myTerminalArea);	
				
			self.cmbFiltTermArea.lostFocus(cmbFiltTermArea);
			self.setFilterTerminalArea(location.myTerminalArea);
		
			self.myAssistant.comboBoxLocationControllers(cmbFiltYardLocn, self.filterTerminalArea.getLCsCollectionForDisplay(), false);
			self.tblSearch.setValueByControlName(cmbFiltYardLocn.name, location.displayEntry());
			cmbFiltYardLocn.listObject := location;
			self.filterYardLocation := location;
			crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myTerminalArea.name);				// TFS 53304
			if crit &lt;&gt; null then																					// TFS 53304
				crit.myQueryOperator.setSearchValue(location.myTerminalArea);										// TFS 53304
			endif;																									// TFS 53304
			crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myPrimaryActualLocation.name);		// TFS 53304
			if crit &lt;&gt; null then																					// TFS 53304
				crit.myQueryOperator.setSearchValue(location);														// TFS 53304
			endif;																									// TFS 53304
		elseif location.isKindOf(CM_LogVoyageController) then	//par 11124	 rs1 dec 2005
//			self.tblSearch.setValueByControlName(cmbFiltVoyage.name, location.CM_LogVoyageController.myLogVoyage.displayEntry());
			self.tblSearch.setValueByControlName(cmbFiltVoyage.name, location.CM_LogVoyageController.myVoyage.displayEntry());
//			cmbFiltVoyage.listObject := location.CM_LogVoyageController.myLogVoyage;
			cmbFiltVoyage.listObject := location.CM_LogVoyageController.myVoyage;
//			self.filterVoyage := location.CM_LogVoyageController.myLogVoyage;
			self.filterVoyage := location.CM_LogVoyageController.myVoyage;
			crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myVoyage.name);					// TFS 53304
			if crit &lt;&gt; null then																					// TFS 53304
				crit.myQueryOperator.setSearchValue(location.CM_LogVoyageController.myVoyage.code);					// TFS 53304
			endif;																									// TFS 53304
		else
			//don't do the search if it's not one of the above
			return;
		endif;
		self.zDoSearch();
		self.setTblSearchFromSelector();											// TFS 53304
		self.setEditEnabledDisabled(0);		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowDocketCargo" id="f50a66e8-3255-4f53-9ff5-4c29fae0b12f">
        <updating/>
        <source>doShowDocketCargo() protected, updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bol				: CM_BOL;
	objArray		: CM_ObjectArray;
	cargoType		: Integer;
	id				: String;
	masterTI		: CM_TrackedItem;
	cargoEnqForm 	: CM_ContainerEnqForm;
begin
	if (not CM_BOL.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	
	bol := self.myCurrentObject.CM_BOL;
	if bol.allTrackedItems.isEmpty then
		app.msgBox('There is no cargo associated with this docket','No attachments', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create objArray transient;
	bol.allTrackedItems.copy(objArray);

	if self.tblView2.row &gt; 0 then
		//try to get the selected log to display on the new form
		cargoType := bol.allTrackedItems.first.cargoType;
		id := self.tblView2.accessCell(self.tblView2.row, 1).text;
		masterTI := bol.allTrackedItemsOrig[cargoType,id];
	endif;
	
	if masterTI = null then
		masterTI := bol.allTrackedItems.first;
	endif;
	
	cargoEnqForm := self.myAssistant.showCargoEnquiryForTIs(masterTI,
											objArray,
											self.myMasterMenuAction,
											false);
		
	if cargoEnqForm = null then
		return;
	endif;
		
	cargoEnqForm.tblData.clearAllSelected();
	cargoEnqForm.tblData.selectObject(masterTI, true);

epilog
	delete objArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowHSCodeSearcherForm" id="48c494b2-f2a8-46ce-a22d-bbc6faead8d1">
        <source>doShowHSCodeSearcherForm() : CM_HarmonizedSystem;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 20 December 2022
TFS#		: 55584
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	return self.myAssistant.showHSCodeSearchForm(self, true);
end;</source>
        <ReturnType type="CM_HarmonizedSystem"/>
    </JadeMethod>
    <JadeMethod name="doShowInTerminalArea" id="cfeae34c-8383-45c2-9f49-4a94473fdc66">
        <source>doShowInTerminalArea();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2012	cnwdw1	Initial creation
*/
vars
	cm_ObjectArray	: CM_ObjectArray;
	objectSet : ObjectSet;
	ti: CM_TrackedItem;
	ta: CM_TerminalArea;
begin
	ti := self.myCurrentObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;
	
	create cm_ObjectArray transient;
	ta := ti.myTerminalArea;
	if ta = null then
		return;
	endif;
	
	if ta.isGridArea then
		self.myAssistant.findLocationsFromObject( ta, cm_ObjectArray );
		self.myAssistant.showYardGridAreasForm(	cm_ObjectArray,	0, self.myMasterMenuAction,	0);
	else
		create objectSet transient;
		ta.getAllLocationsTrackedItems(objectSet);
		objectSet.copy(cm_ObjectArray);
		self.myAssistant.showCargoEnquiryForTIs(ti,	cm_ObjectArray, self.myMasterMenuAction,	false);
    endif;		
epilog
	delete cm_ObjectArray;
	delete objectSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowLogsInLocation" id="642e0ad1-4c30-4505-aacf-831070c31389">
