    <JadeMethod name="getAmountForCurrencyCode" id="7a0a621f-72b6-46aa-9b4c-c51138fc95d0">
        <updating/>
        <source>getAmountForCurrencyCode(_typeCode: String; _asAtDateTime: TimeStamp): Decimal updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2018	jlgma1	Bug 42218: PEL1 - International Tariff - Currency Conversion

*/


vars
	cashValue   : Decimal[23,6];
	proFormaDetail : CM_ProformaDetails;
	currRate       : Decimal[16,8];
    convertedRate  : Real;
begin

	if self.getBank.code.toUpper.cnContains("DOM") then 
		return self.cashValue;
	
	else
		currRate := self.getExRateForCurrencyCode(_typeCode);
		foreach proFormaDetail in self.allProformaDetails do
	
			convertedRate := proFormaDetail.rate;
			if proFormaDetail.myInvoiceLineType = null then
				convertedRate := proFormaDetail.rate;
			endif;
			if proFormaDetail.myInvoiceLineType &lt;&gt; null and proFormaDetail.myInvoiceLineType.currencyConversionNotRequired then
				convertedRate := proFormaDetail.rate;
			else
			
				convertedRate := proFormaDetail.getConvertedRate(currRate);
			endif;
			
			cashValue := cashValue + (convertedRate * proFormaDetail.quantity) ;
		endforeach;
	endif;
	
	return cashValue;
epilog

end;</source>
        <Parameter name="_typeCode" type="String"/>
        <Parameter name="_asAtDateTime" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="057d2d7b-b1d2-4c5c-a6fa-dde37efa6116">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/02/2018  cnwma1	Bug 43452: PEL1 - SAP Web Service (1081 Deadlock) issue

*/

vars
	txt,
	tmpStr	: String;

begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr :=  app.paymentStatusCashEnumToString(self.paymentStatus);
	txt := txt &amp; app.getErrorString(Credit_check_status) &amp; 
	AuditStringSeparator &amp; tmpStr.length.String &amp; 
	AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;

	// TFS 46032
	if self.myDebtorTerminal &lt;&gt; null then
		tmpStr := self.myDebtorTerminal.myDebtor.name;
		txt := txt &amp; 'Debtor' &amp; AuditStringSeparator 
			   &amp; tmpStr.length.String &amp; AuditStringSeparator 
			   &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBOL" id="62931c8d-beac-47bf-b021-b5ff7ff78a44">
        <source>getBOL() : CM_BOL;
// for 36704 Ghana cash receipt
vars
	ti	: CM_TrackedItem;
	bol	: CM_BOL;
	localTiArray : CM_TIArray;		//30 Mar 2016	NDL	TFS 1726
begin

	create localTiArray transient;	//30 Mar 2016	NDL	TFS 1726
	self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
		
	//foreach ti in self.allTrackedItems do
	foreach ti in localTiArray do		//30 Mar 2016	NDL	TFS 1726
		bol := ti.myReceivalBOL;
		if bol &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	return bol;
	
epilog

	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726
	
end;
</source>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
