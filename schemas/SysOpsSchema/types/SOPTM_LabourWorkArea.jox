    <JadeMethod name="setControlsForAddEdit" id="08a0cbef-927e-4e87-a19e-04cb9454b411">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	theForm : SOP_TableMaintForm;
	modalresult : Integer;
	
begin

	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		modalresult := self.showForm( null );
	
	else

		modalresult := self.showForm( self.getSelectedLabourWorkArea );
		
	endif;
	
	self.doEnableControls(false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="50d89247-cc89-4d3d-84ce-2d8a044542e8">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	theForm : SOP_TableMaintForm;

begin

	inheritMethod();
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	self.doEnableControls(true);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDefaults" id="0602ae89-9285-4734-91ca-c27486c1116b">
        <source>setupThumbnailDefaults();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

begin

	inheritMethod();
	
	self.myForm.btnNewWc.visible := true;
	self.myForm.btnNewWc.bubbleHelp := self.myForm.btnNewTV.caption;
	self.myForm.btnEditWc.visible := true;
	self.myForm.btnEditWc.bubbleHelp := self.myForm.btnEditTV.caption;
	
	self.myForm.btnNewTV.visible := false; // TFS 2198
	self.myForm.btnEditTV.visible := false; // TFS 2198
	
	self.myForm.frmToolbar.positionToolbarControls();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="c960a9c8-6bd8-405a-9ae3-ea4dad450b0b">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	theForm : SOP_TableMaintForm;

begin
	
	theForm := self.myForm;
	theForm.useProxyObject := false;
	theForm.setTblDataEntRows(ETDef_LabourWorkArea);
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_LabourWorkArea);	
	theForm.shtTblInput1.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showForm" id="431e826b-2cdb-4a13-81ee-1582b3d00000">
        <source>showForm( labourWorkArea : CM_LabourWorkArea ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	form : SOP_LOBWorkAreaMaintForm;
	
begin

	create form;
	form.setMyTerminal(self.myForm.myTerminal);
	form.setMyCurrentWorkArea(labourWorkArea);
	
	return form.showModal();
	
epilog

end;</source>
        <Parameter name="labourWorkArea" type="CM_LabourWorkArea"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="9dd26d88-39b3-4ae4-99b0-612cf933d893">
        <updating/>
        <source>showThumbnail(pObj: CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	theForm : SOP_TableMaintForm;
	labourWorkArea : CM_LabourWorkArea;

begin

	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	if pObj &lt;&gt; null and pObj.isKindOf( CM_LabourWorkArea ) then
		labourWorkArea := pObj.CM_LabourWorkArea;
	else
		labourWorkArea := self.getSelectedLabourWorkArea();
	endif;
	
	if labourWorkArea = null then
		theForm.tblInput1.setValueByName(ETRow_Code, null);
		theForm.tblInput1.setValueByName(ETRow_Description, null);
		theForm.tblInput1.setValueByName(ETRow_NotAvailable, false.String);
		theForm.tblInput1.setValueByName(ETRow_TermAreas, null);
		theForm.tblInput1.setValueByName(ETRow_SubAreas, null);
		theForm.tblInput1.setValueByName(ETRow_SubSubAreas, null);
	else
		theForm.tblInput1.setValueByName(ETRow_Code, labourWorkArea.code);
		theForm.tblInput1.setValueByName(ETRow_Description, labourWorkArea.description);
		theForm.tblInput1.setValueByName(ETRow_NotAvailable, labourWorkArea.notAvailableForEntry.String);
		theForm.tblInput1.setValueByName(ETRow_TermAreas, labourWorkArea.getTerminalAreasString);
		theForm.tblInput1.setValueByName(ETRow_SubAreas, labourWorkArea.getSubAreasString);
		theForm.tblInput1.setValueByName(ETRow_SubSubAreas, labourWorkArea.getSubSubAreasString);
	endif;

	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		theForm.btnNewWc.enabled:= false;
		theForm.btnEditWc.enabled:= false;
	endif;

epilog

end;</source>
        <Parameter name="pObj" type="CM_Object"/>
    </JadeMethod>
</Class>
