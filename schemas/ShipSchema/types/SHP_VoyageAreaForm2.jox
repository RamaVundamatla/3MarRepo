	endif;
	/*
	self.btnPenVoltage.fontCharacter	:= 86;
	self.btnPenVoltage.fontColour		:= Red;
	self.btnPenVoltage.fontName		:= "Verdana";
*/
	drawAttr := atttDict[PicTIHalfHeight];
	if drawAttr &lt;&gt; null then
		self.btnPenHalfHeight.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIHazard];
	if drawAttr &lt;&gt; null then
		self.btnPenHazard.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIHiCube];
