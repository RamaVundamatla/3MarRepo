    <JadeMethod name="populateCombos" id="ccc264f9-e5b3-45fb-a2ba-d7ff67dcbd17">
        <source>populateCombos();
// ---------------------------------------------------------------------------
// Created:     27 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

	iter			: Iterator;
	ta				: CM_TerminalArea;
	isAllLocations	: Boolean;
	coll			: Collection;
	op				: CM_Operator;
	cargoType		: CM_CargoBOLType;
	cargoTypesColl	: CM_CargoBOLTypeArray;
	taType			: CM_TerminalAreaType;
	tmpCargoTypeDict : CM_CargoTypesByIdDict;
begin	
	// Setup operator combo box.
	coll := app.myRoot.allOperators;
	if coll.size &gt; 0 then
		cmbOperator.listCollection(coll, true, 0);
		op := coll.first.CM_Operator;
		if app.myCurrentOperator = null then
			cmbOperator.listObject := op;
			app.setMyCurrentOperator(op);
		else
			cmbOperator.listIndex := cmbOperator.findObject(app.myCurrentOperator);
		endif;
	endif;

	create tmpCargoTypeDict transient;
	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType, null);
	
	self.populateTIsByCargoType;
	
epilog
	delete tmpCargoTypeDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateDocketsByOperator" id="3a976884-cbdc-4b96-a2e5-d54f8288e40f">
        <source>populateDocketsByOperator();
// ---------------------------------------------------------------------------
// Created:     19 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	op			: CM_Operator;
	bol			: CM_BOL;
	bolTerminal	: CM_BOLTerminal;
	iter		: Iterator;
begin
	self.allBOLs.clear();
	self.cmbDocket.clear();
	
	op := self.cmbOperator.listObject.CM_Operator;
	if op = null then
		return;
	endif;
	
	iter := self.myTerminal.allBOLTermsByTypeOpNum.createIterator;
	self.myTerminal.allBOLTermsByTypeOpNum.startKeyGeq(BOLType_GeneralDocket, op, null, iter);
		
	while iter.next(bolTerminal) do
		bol := bolTerminal.myBOL;
		if bol.bolType &lt;&gt; BOLType_GeneralDocket or
		   bol.myOperator &lt;&gt; op then
			break;
		endif;
		
		if bol.isKindOf(CM_BOLIn) then
			self.allBOLs.add(bol);
		endif;
	endwhile;
	
	iter.reset;
	self.myTerminal.allBOLTermsByTypeOpNum.startKeyGeq(BOLType_GeneralBillOfLading, op, null, iter);
	while iter.next(bolTerminal) do
		bol := bolTerminal.myBOL;
		if bol.bolType &lt;&gt; BOLType_GeneralBillOfLading or
		   bol.myOperator &lt;&gt; op then
			break;
		endif;
		
		if bol.isKindOf(CM_BOLIn) then
			self.allBOLs.add(bol);
		endif;
	endwhile;
	
	self.cmbDocket.listCollection(self.allBOLs, false, 0);
	

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTIsByCargoType" id="4fdad572-b018-42a5-88df-dcb3f2fa5828">
        <source>populateTIsByCargoType();
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jan 2011	cnwkpd1		PAR #26678 - Tidy up transient leaks
// 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
// ---------------------------------------------------------------------------
vars
	
	cargoTypeId			: Integer;
	tiDict 				: CM_TIByCargoTypeIdDict;
	iter				: Iterator;
	operator			: CM_Operator;
	opTerm				: CM_OperatorTerminal;
	ti					: CM_TrackedItem;
	idStr				: String;
	cargoTypeObj 		: CM_CargoType;
	loadStateSet		: Boolean;
	
begin
	cargoTypeObj := cmbCargoType.listObject.CM_CargoType;
	cmbTI.clear;
	operator := self.zGetOperator();
	if operator &lt;&gt; null then
		opTerm := operator.allOperatorTerminals[self.myTerminal];
	endif;
	if (cargoTypeObj = null) or
	   (opTerm = null) or
		(operator = null) then
		cmbTI.addItem('!ERROR! - No operator or cargo type found');
		return;
	endif;
	
	cargoTypeId := cargoTypeObj.id;
	tiDict := opTerm.allOnsiteTIsByCargoTypeId;
	
	if tiDict &lt;&gt; null then
		app.cmsBeginLoad(loadStateSet);
		iter := tiDict.createIterator();
		tiDict.startKeyGeq(cargoTypeId, null, iter);
		
		while iter.next(ti) do
			if ti.cargoType &lt;&gt; cargoTypeId then
				break;
			endif;
			
			iter.getCurrentKeys(cargoTypeId, idStr);	//MTN-35226
			cmbTI.addItem(idStr);
		endwhile;
	endif;
		
epilog
	app.cmsEndLoad(loadStateSet);
	delete iter;		// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="saveTrackedItems" id="0021efdc-146e-45c4-9a2f-7725b3576f06">
