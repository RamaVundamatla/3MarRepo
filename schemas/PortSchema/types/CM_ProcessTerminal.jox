    <JadeMethod name="validateForCreate" id="a65f6ae0-ff88-40e8-8d0c-90c62476c0cf">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation
01 Oct	2021	jlier1 TFS 51963
*/

vars
	processTerminal : CM_ProcessTerminal;
begin
	if self.myDepotVoyage &lt;&gt; null then

		if self.myVoyageProcess  &lt;&gt; null and not self.myVoyageProcess.isDefaultProcessJMT  then
			processTerminal := self.myVoyageProcess.allProcessTerminals.getAtKey( self.myVoyageProcess, self.myTerminal );
			if processTerminal &lt;&gt; null then
				if processTerminal.myDepotVoyage = self.myDepotVoyage then
					app.raiseCMException2(ERR_Duplicate_DepotVoyage, self.myDepotVoyage.code, self.myVoyageProcess.description,null,null);
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="13b55dd9-9385-4e03-834c-66a9bb1a2be7">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation
12 Feb  2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal
01 Oct	2021	jlier1 TFS 51963
*/

vars
	processTerminal : CM_ProcessTerminal;
begin
	if self.myDepotVoyage &lt;&gt; null then
		if self.myVoyageProcess  &lt;&gt; null and not self.myVoyageProcess.isDefaultProcessJMT  then
			processTerminal := self.myVoyageProcess.allProcessTerminals.getAtKey( self.myVoyageProcess, self.myTerminal );
			if processTerminal &lt;&gt; null then
				if processTerminal.myDepotVoyage = self.myDepotVoyage then
					app.raiseCMException2(ERR_Duplicate_DepotVoyage, self.myDepotVoyage.code, self.myVoyageProcess.description,null,null);
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
