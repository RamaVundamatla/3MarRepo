    <JadeMethod name="canUserRunReport" id="8037f184-32c2-4bf5-9767-13454d6a2eac">
        <source>canUserRunReport(_user: CM_User): Class;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	class : Class;

begin
	
	class := inheritMethod(_user);
	if class &lt;&gt; null then
		return class;
	endif;
	
	if not _user.canUserAccessObj(app.myRoot.allCarriers[self.carrierCode], CM_Carrier) then
		return CM_Carrier;
	endif;

	return null;


end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="abf3b6a5-9e19-403f-95b4-2749cbf4746b">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     04 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	terminal		: CM_Terminal;
	endTS			: TimeStamp;
begin
	//self.endDate := self.endDate + 1;
	endTS := self.endDate.TimeStamp;
	endTS.setTime('23:59:59:999'.Time);
	foreach terminal in self.allTerminals do
		terminal.getTITxnsForTypeAdvanced(	self.transType, 
											self.startDate.TimeStamp,
											endTS, 
											'checkStatusIncludesObject', 
											self,
											_collection);
	endforeach;	

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
