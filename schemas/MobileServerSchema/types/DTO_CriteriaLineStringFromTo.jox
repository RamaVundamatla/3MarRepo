<Class name="DTO_CriteriaLineStringFromTo" id="940075de-f9e8-4c8e-bd54-96ac53e973c8">
    <superclass name="DTO_CriteriaLineString"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mobileServer"/>
    <PrimAttribute name="searchValueB" id="b21b737b-4d79-4506-a1bd-6aaac8b6dcd1">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="putSearchingValue" id="0e7b972c-8a8e-4714-b579-3cdb19bf19f3">
        <source>putSearchingValue(_criteriaLine: CM_SelectorCriteriaLine input; _strDateArray: StringArray );
// ---------------------------------------------------------------------------
// Created:     June 2008		cnwvu1	
// ---------------------------------------------------------------------------
vars
	dateArray : DateArray;
	valueTranslatedFrom,
	valueTranslatedTo : Any;

begin
	
	create dateArray transient;
	
	valueTranslatedFrom	:= _criteriaLine.myQueryProperty.translateStringToSearchValue( _strDateArray[1], _criteriaLine );
	valueTranslatedTo	:= _criteriaLine.myQueryProperty.translateStringToSearchValue( _strDateArray[2], _criteriaLine );

	dateArray.add( valueTranslatedFrom.Date );
	dateArray.add( valueTranslatedTo.Date );
	
	_criteriaLine.myQueryOperator.setSearchValue( dateArray );
	
epilog
	delete dateArray;

end;</source>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine" usage="input"/>
        <Parameter name="_strDateArray" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="putSearchingValuesFromRT" id="b25caeac-7b22-4496-8f82-36b98a5d0e0c">
        <source>putSearchingValuesFromRT( _criteriaLine : CM_SelectorCriteriaLine input );
// ----------------------------------------------------------------------
// Created 08 may 2008 by cnwvu1
//
// Purpose:	Puts searching values from DTO criteriaLine (RT screen)
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	dateArray : StringArray;
	
begin
	
	create dateArray transient;
	
	dateArray.add( self.searchValueA );
	dateArray.add( self.searchValueB );
	
	self.putSearchingValue( _criteriaLine, dateArray );		//Par 17084	cnwvu1 June 2008

epilog
	delete dateArray;
	
end;
</source>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7bd9fbde-fbd5-4248-91bd-b786002f8ce9">
        <updating/>
        <source>setForCreate( 	_labelCriteria, 
				_searchValueA, _searchValueB : String; _searchValueBoolean : Boolean;
				_myQueryCriteriaLineHolderRT : DTO_QueryCriteriaLineHolderRT;
				_propClassName, _propName, _queryOperatorOid : String ) updating;
// ----------------------------------------------------------------------------------
// Created 07 may 2008 by cnwvu1
// ----------------------------------------------------------------------------------

vars

begin

	inheritMethod(_labelCriteria, _searchValueA, _searchValueB, _searchValueBoolean, _myQueryCriteriaLineHolderRT, _propClassName, _propName, _queryOperatorOid);

	self.searchValueB := _searchValueB;
	
end;
</source>
        <Parameter name="_labelCriteria" type="String"/>
        <Parameter name="_searchValueA" type="String"/>
        <Parameter name="_searchValueB" type="String"/>
        <Parameter name="_searchValueBoolean" type="Boolean"/>
        <Parameter name="_myQueryCriteriaLineHolderRT" type="DTO_QueryCriteriaLineHolderRT"/>
        <Parameter name="_propClassName" type="String"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_queryOperatorOid" type="String"/>
    </JadeMethod>
