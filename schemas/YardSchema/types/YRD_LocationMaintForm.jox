    <JadeMethod name="doUpdateGridArea" id="e24031ca-ab3d-4162-af7b-1f685aae4a4c">
        <source>doUpdateGridArea(_theLCS : CM_LCArray);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aLocation : CM_LocationsController;
	aPoint : YRD_PadPoint;
	a,b : TimeStamp;
begin
	self.modalDialogUpdateInfo("Updating Graphic...");	
	if self.myCurrentTerminalArea.isRestrictionBlockStack() then 
		return;
	endif;
	foreach aLocation in _theLCS do
		aPoint := self.mySDF.getPointFromLC(aLocation).YRD_PadPoint;
		
		if aPoint &lt;&gt; null then
			aPoint.setForUpdatePad(aLocation.CM_GridController);
		endif;
	endforeach;
	self.frmGridArea.myGridArea.editMode := false;
	self.frmGridArea.myGridArea.clearAllSelectedItems();
	self.frmGridArea.myGridArea.YRD_PadArea.doLockAll(false);
	self.modalDialogUpdateInfo("Drawing Graphic...");	
	self.mySDF.drawSelf(); // use this as it draws the labels
end;</source>
        <Parameter name="_theLCS" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="doUpdateGridAreaNote" id="ba9033ca-e5d3-42f4-9b9b-4f417d033865">
        <source>doUpdateGridAreaNote(_anObject : Object; _theLCS : CM_LCArray);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 18/05/2021	navdap1		TFS 49899 MTN Labour on Block for New GC Areas
vars
	aLocation : CM_LocationsController;
	aPoint : YRD_PadPoint;
	aGPoint : CMUI_GridPoint;
	theArea : CMUI_GridArea;

begin
	self.modalDialogUpdateInfo("Updating Graphic...");	
	if self.myCurrentTerminalArea.isRestrictionBlockStack() then 
		return;
	endif;

	theArea := self.frmGridArea.myGridArea;
	
	theArea.removeInvalidObjectLabel(); // if an object has been deleted it will be in the label dict
	
	foreach aGPoint in theArea.allGridPoints do
		aPoint := aGPoint.YRD_PadPoint;
		aPoint.doUpdateNull(_anObject);
	endforeach;
	foreach aLocation in _theLCS do
		aPoint := self.mySDF.getPointFromLC(aLocation).YRD_PadPoint;
		
		if aPoint &lt;&gt; null then
		// TFS 3422 add general cargo area
			if aLocation.isKindOf(CM_GridController) then
				aPoint.setForUpdatePad(aLocation.CM_GridController);
			elseif aLocation.isKindOf(CM_IrregularBlockController) then
				aPoint.setForUpdatePadGC(aLocation.CM_IrregularBlockController);
			elseif aLocation.isKindOf(CM_GeneralCargoAllocGroup) then						// TFS 49899
				aPoint.setForUpdatePadGCAlloc(aLocation.CM_GeneralCargoAllocGroup);			// TFS 49899
			endif;
		endif;
	endforeach;
	theArea.editMode := false;
	theArea.clearAllSelectedItems();
	theArea.YRD_PadArea.doLockAll(false);
	self.modalDialogUpdateInfo("Drawing Graphic...");	
	self.mySDF.drawSelf(); // use this as it draws the labels
end;</source>
        <Parameter name="_anObject" type="Object"/>
        <Parameter name="_theLCS" type="CM_LCArray"/>
    </JadeMethod>
