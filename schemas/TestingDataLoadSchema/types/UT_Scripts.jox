    <JadeMethod name="resetData_44070" id="57304fa7-0fc7-462a-bae5-d5a90854204f">
        <source>resetData_44070();
/*

Purpose:	Reset 37392		

Date		Who		Reason
23/08/2022	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	passportTerm 			: CM_Terminal;
	tiMaster				: CM_TIMasterContainer;
		
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	foreach tiMaster in CM_TIMasterContainer.instances discreteLock do
	
		if tiMaster.id &lt;&gt; "JLG44070A01" then
			continue;
		endif;
		
		beginTransaction;
		delete tiMaster;
		commitTransaction;
	
	endforeach;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_44072" id="ff0d4d2e-e2c7-4b6b-97c7-906e5b9a25b8">
        <source>resetData_44072();
/*

Purpose:	Reset 37392		

Date		Who		Reason
16/03/2022	navmh5	Initial creation

*/

vars
	
	terminal				: CM_Terminal;
	passportTerm 			: CM_Terminal;
	vvr 					: CM_VehicleVisitRecord;
	
	found					: Boolean;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	foreach vvr in CM_VehicleVisitRecord.instances discreteLock where vvr.regNumber = "44072" and vvr.timeOut = null do
			found := true;
			break;
		endforeach;
	
		if found then
			self.ignoreTrxWarnings(true); 
			app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_44073" id="75d29fea-7648-4b17-b6b3-c5361e6d3551">
        <source>resetData_44073();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/10/2021	navmh5	Initial creation

*/

vars

	user						: CM_User;
	terminal					: CM_Terminal;
	userTerminal				: CM_UserTerminal;
	passportTerm				: CM_Terminal;
	ediParty 					: CM_EDIParty;
	ediPartyRules				: CM_EDIPartyRules;
	ediFactRule					: CM_EDIEDIFactRule;
	obj							: CM_Object;
	pxyItem						: CM_EDIEDIFactRule;
	
	ediPartyArray				: StringArray512;
	ediCoparnDetailsArray		: StringArray512;
	ediRulesSet					: CM_EDIRulesSet;
	
	bookingBGMFound				: Boolean;
	releaseRBMGFound			: Boolean;
	
begin

	app.initialize();
	
	passportTerm := app.myPassport.myTerminal;
	
	// Retreive the user so we know which terminals that we need to run against
	user := app.myRoot.allUsers["USERDWAT"];
	if user = null then
		return;
	endif;
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("USERDWAT");
	
	create ediPartyArray transient;
	
	create ediCoparnDetailsArray transient;
	ediCoparnDetailsArray.add("44073^BGM1.1^11^Booking");
	ediCoparnDetailsArray.add("44073^BGM1.1^12^Release Request");
	
	foreach userTerminal in user.allUserTerminals do
	
		terminal := userTerminal.getMyTerminal();
		if (not global.isValidObject(terminal) or terminal = null) then
			continue;
		endif;
		
		app.myPassport.setMyTerminal(terminal);
		
		beginTransaction;
		terminal.setConfig(EdiUseOldCoparn, false);
		commitTransaction;
		
		ediPartyArray.clear();
		ediPartyArray.add("44073");
		bookingBGMFound := false;
		releaseRBMGFound := false;
		foreach ediParty in terminal.allEDIParties discreteLock do
			if (not ediPartyArray.includes(ediParty.name)) then
				continue;
			endif;
						
			foreach ediPartyRules in ediParty.allEDIPartyRules where ediPartyRules.isKindOf(CM_EDIPartyCoparnRules) do
							
				foreach obj in ediPartyRules.allEDIPartyRules discreteLock do
				
					ediFactRule := obj.CM_EDIEDIFactRule;
					
					if ediCoparnDetailsArray.includes(ediParty.name &amp; "^" &amp; ediFactRule.getItem() &amp; "^" &amp; ediFactRule.getValue() &amp; "^" &amp; ediFactRule.getFunctionDescription()) then
						if ediFactRule.getFunctionDescription() = "Booking" then
							bookingBGMFound := true;
						endif;
						if ediFactRule.getFunctionDescription() = "Release Request" then
							releaseRBMGFound := true;
						endif;
					endif;
				
				endforeach;
								
			endforeach;
			
			beginTransaction;
			if not bookingBGMFound then
				create pxyItem persistent;
				pxyItem.setMyEDIPartyRules(ediPartyRules);
				pxyItem.setPropertyValue("item", CM_EDIEDIFactRule.Item_BGM_1_1);
				pxyItem.setPropertyValue("value", "11");
				pxyItem.setPropertyValue("function", CM_EDIEDIFactRule.Function_BGM_1_1_Booking);					
			endif;
				
			if not releaseRBMGFound then
				create pxyItem persistent;
				pxyItem.setMyEDIPartyRules(ediPartyRules);
				pxyItem.setPropertyValue("item", CM_EDIEDIFactRule.Item_BGM_1_1);
				pxyItem.setPropertyValue("value", "12");
				pxyItem.setPropertyValue("function", CM_EDIEDIFactRule.Function_BGM_1_1_Release);
			endif;
			commitTransaction;
			
		endforeach;
					
	endforeach;
		
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
	delete ediPartyArray;
	delete ediCoparnDetailsArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_44105" id="9dd9c620-3de4-48d2-9770-7449c4c549d3">
        <source>resetData_44105();
/*

Purpose:	Reset 37392		

Date		Who		Reason
16/03/2022	navmh5	Initial creation

*/

vars
	
	terminal				: CM_Terminal;
	passportTerm 			: CM_Terminal;
	vvr 					: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	
	found					: Boolean;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["CASH"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	vehicle := self.getVehicle("44105");
	if vehicle = null then
		app.writeLog("Unable to find vehicle 44105", LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_44130" id="87ac35c2-5e8a-4b68-92a3-add2fc6c7bf7">
        <source>resetData_44130();

/*

Purpose:			

Parameters:			

Return Value:		

   Date		     Who		Reason
04 April 2022	navmp4	Initial creation

*/

constants

	VoyageId					: String = "VOY44130";
	VesselCode				    : String = "JDIAM";
	CraneId						: String = "CRN1";

vars
	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	voyageLoadJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	operator					: CM_Operator;
	bs						    : CM_BlockStack;
	
	slotsFrom					: CM_SlotControllerArray;
	tisToDelete					: StringArray;
	
begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	// delete the tracked item
	create tisToDelete transient;
	tisToDelete.add("JLG44130A01");
		
	self.deleteTIResetScript(tisToDelete, terminal);
	
	//DELETE THE VOYAGE
	self.deleteVoyage(VoyageId);
	
	// create the voyage
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselCode, "MSK", "AZL"); 
	self.assertNotNull(voyage);
	
	operator := app.myRoot.allOperators["MSK"];
	self.assertNotNull(operator);

	// add cargo on voyage		
	self.opts.purge();
	opts.addAssoc(UTTI_VoyageCode, "VOY44130");
	opts.addAssoc(UTTI_DischargePort, "NZAKL");
	
	bs := self.getTerminalArea("MKBS07").CM_BlockStack;
	self.assertNotNull(bs);
	
	ti := self.addContainerAtLocation("JLG44130A01", operator, "2200", "GEN", TI_IMEX_STATUS_EXPORT, bs);
	self.assertNotNull(ti);

	
	
	// colour code the load slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "25", DeckOnDeck, 1, 3, 1, slotsFrom);
	self.markSlotsAsLoadJob(slotsFrom,tmpLoadCC);
	self.markSlotsAsLoadCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "25", DeckOnDeck, 1, 3, 1, slotsFrom);
	
	voyageLoadJob := self.addVoyageJob(voyage, CraneId, slotsFrom, false);
	self.assertNotNull(voyageLoadJob);
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	delete slotsFrom;
	delete tmpLoadCC;
end;


</source>
    </JadeMethod>
    <JadeMethod name="resetData_44201" id="e08a5cb7-dc3e-4623-8ab8-8a4a9290b152">
        <source>resetData_44201();
/*

Purpose:	Reset 44201		

Date		Who		Reason
12/04/2019	jlgmk3	Initial creation

*/

vars
	terminal				: CM_Terminal;
	voyage					: CM_Voyage;
	iMove					: CM_InterTerminalMove;
	iConfig					: CM_InterTerminalConfig;
	ti						: Object;
	passportTerm			: CM_Terminal;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId, bolNumber			: String;
begin
	//app.initialize();
	
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	
	// delete the logs
	create tisToDelete transient;
	tisToDelete.add("LOG0");
	tisToDelete.add("LOG1");
	tisToDelete.add("LOG2");
	tisToDelete.add("LOG3");
	tisToDelete.add("LOG4");
	tisToDelete.add("LOG5");
	tisToDelete.add("LOG6");
	tisToDelete.add("LOG7");
	tisToDelete.add("LOG8");
	tisToDelete.add("LOG9");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	// delete BOL
	bolNumber := "BOL44201";
	self.deleteBOL(bolNumber, null);
	
	// delete voyage
	//voyage := terminal.allVoyagesByCode.getAtKeyGeq("VOY44201", null);
	voyage := self.getVoyage("VOY44201");
	if (voyage &lt;&gt; null and voyage.code = "VOY44201") then
		self.deleteVoyage(voyage.code);
	endif;

	self.deleteVehicle("44201");	// 14/07/2020 jlgmh5 - added so warning message appear on Gate In/Out Save
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tisToDelete;
	delete tiSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_44210" id="5b395f2b-d37d-4ee8-a022-f88daab3b21d">
        <source>resetData_44210();
/*

Purpose:		Reset the data for Test Case 44210	

Parameters:			

Return Value:		

Date		Who		Reason
06/07/2020	jlgmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	//dsl						: UT_DSL;
	ti						: Object;
	bs						: CM_BlockStack;
	operator				: CM_Operator;
	cont					: CM_TrackedItem;
	txn						: CM_TITransaction;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	//app.initialize();
	
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	app.myPassport.setMyTerminal(terminal);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG44210013");
	tisToDelete.add("JLG4421001");
	tisToDelete.add("JLG44210");
	tisToDelete.add("JLGF4421001");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	// Create cargo on site
	bs := self.getTerminalArea("MKBS01").CM_BlockStack;
	if bs = null then
		app.writeLog(method.qualifiedName() &amp; " - Unable to find Block Stack - MKBS03.  Exiting Reset Script...", LogINFO);
		write method.qualifiedName() &amp; " - Unable to find Block Stack - MKBS03.  Exiting Reset Script...";
		app.automatedOutputFile.writeLine(method.qualifiedName() &amp; " - Unable to find Block Stack - MKBS03.  Exiting Reset Script...");
		return;
	endif;
	
	operator := app.myRoot.allOperators["O439"];
	if operator = null then
		app.writeLog(method.qualifiedName() &amp; " - Unable to find Operator - O439.  Exiting JadeScript...", LogINFO);
		write method.qualifiedName() &amp; " - Unable to find Operator - O439.  Exiting JadeScript...";
		app.automatedOutputFile.writeLine(method.qualifiedName() &amp; " - Unable to find Operator - O439.  Exiting Reset Script...");
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, "MSCK000002");
	self.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	self.opts.addAssoc("ReceivedDate", "02/04/2019 04:10:00");
	self.opts.addAssoc("RecTransportMode", 1);
	self.opts.addAssoc("CamsDate", "02/04/2019 04:10:00");
	cont := self.addContainerAtLocation("JLG44210013", operator, "FLTP", "GEN", 1, bs);
	self.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseRoad), "02/04/2019 04:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveRoad) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 04:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 04:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, "MSCK000002");
	self.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	self.opts.addAssoc("ReceivedDate", "02/04/2019 05:10:00");
	self.opts.addAssoc("RecTransportMode", 1);
	self.opts.addAssoc("CamsDate", "02/04/2019 05:10:00");
	cont := self.addContainerAtLocation("JLG4421001", operator, "FLTP", "GEN", 1, bs);
	self.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseRoad), "02/04/2019 05:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveRoad) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 05:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 05:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, "MSCK000002");
	self.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	self.opts.addAssoc("ReceivedDate", "02/04/2019 06:10:00");
	self.opts.addAssoc("RecTransportMode", 1);
	self.opts.addAssoc("CamsDate", "02/04/2019 06:10:00");
	cont := self.addContainerAtLocation("JLG44210", operator, "TRAI", "GEN", 1, bs);
	self.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseRoad), "02/04/2019 06:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveRoad) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 06:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 06:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, "MSCK000002");
	self.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	self.opts.addAssoc("ReceivedDate", "02/04/2019 07:10:00");
	self.opts.addAssoc("RecTransportMode", 1);
	self.opts.addAssoc("CamsDate", "02/04/2019 07:10:00");
	cont := self.addContainerAtLocation("JLGF4421001", operator, "2200", "GEN", 1, bs);
	self.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseRoad), "02/04/2019 07:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveRoad) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 07:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 07:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;

epilog

	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_44225" id="0023fc8e-9422-4570-b324-e1f890338c06">
        <source>resetData_44225();

/*

Purpose:	Reset 43587		

Date		Who		Reason
14/10/2021	navmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	dsl						: UT_DSL;
	ti						: Object;
	vvr 					: CM_VehicleVisitRecord;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
	
begin

	
	app.initialize();
	
	create dsl transient;
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG44225A01");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			dsl.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	foreach vvr in CM_VehicleVisitRecord.instances discreteLock where vvr.regNumber = "44225" and vvr.timeOut = null do
		break;
	endforeach;
	
	if vvr &lt;&gt; null then
		self.ignoreTrxWarnings(true); 
		app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

	app.myPassport.setMyTerminal(passportTerm);

	delete dsl;
	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
