<Class name="CM_YATypeHSCode" id="f5390766-822d-4f5a-bdb4-f52b44bfbe7a">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaValueForTi" id="1ae26be2-7e8f-48c3-9c07-4c2e79595180">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 January 2023
TFS#		: 55588
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	_criteriaValue := _ti.getHSCode();
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="0bc350dd-f8a0-4909-9fa0-a51117b20ce6">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
