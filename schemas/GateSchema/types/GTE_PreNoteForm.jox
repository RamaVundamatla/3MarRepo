    <JadeMethod name="includeObject" id="449d1a94-e6af-4232-8d2c-f3aa452b54cd">
        <updating/>
        <source>includeObject(_ti : CM_TrackedItem; _passport : CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2003	cnwth2	Initial creation
23 May 2019 cnwma1	Bug 44836: JMT - Pre-note search does not work with out a created from date
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
23 May 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
04 Oct 2024 navsp1  JIRA 20762 EUP | General Testing - Search on Client Ref on User Screens
*/
vars
	tmpTransMode	: Integer;
    transMode		: String;
	failedDAC		: CM_DataAccessController;
	filterFromLocal,
	filterToLocal,
	filterFromSystem,
	filterToSystem	: TimeStamp;

begin
	if _ti.state &lt;&gt; TI_STATE_NOTIFIED then
		return false;
	endif;
	
	if _ti.isChild then //cnwrd1 par 24440 17.6.2010
		return false;
	endif;
	
	transMode 	:= self.viewTransportMode;
	tmpTransMode := _ti.receiptTransportMode;

 	if (transMode = app.getErrorString(Road_rail) ) 

 	or (transMode = BR_TYPE_ROAD_STR and tmpTransMode = TI_TRANSMODE_ROAD) // cnwrd1 par 18519 6.3.09							// PAR #27972
 	or (transMode = BR_TYPE_RAIL_STR and tmpTransMode = TI_TRANSMODE_RAIL) then													// PAR #27972

		if _ti.isChild then //cnwrd1 par 24440 17.6.2010
			return false;
		endif;
		
		if self.isDataFiltered then
			// data is filtered
			filterFromLocal.setDate(self.filtStartDate);
			filterFromLocal.setTime("0:00:00".Time);
			//filterToLocal.setDate(self.filtEndDate +1);		// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
			filterToLocal.setDate(self.filtEndDate);			// 23.05.2019 cnwma1 Bug #44836
			filterToLocal.setTime("23:59:59".Time);             // 23.05.2019 cnwma1 Bug #44836
			filterFromSystem := self.localToSystemTime(filterFromLocal);
			filterToSystem := self.localToSystemTime(filterToLocal);

//			if (self.filtStartDate.isValid and _ti.createdTime.date &lt; self.filtStartDate)
			if (filterFromSystem.isValid() and _ti.createdTime &lt; filterFromSystem)		//	5/5/16 cnwmp6 TFS 488 - Multi timezone support
//			or (self.filtEndDate.isValid and _ti.createdTime.date &gt; self.filtEndDate)then
			or (filterToSystem.isValid() and _ti.createdTime &gt;= filterToSystem) then
				return false;
			//elseif self.filterId &lt;&gt; null and not _ti.id.startsWith(self.filterId) then
			elseif self.filterId &lt;&gt; null and not _ti.id.startsWith(self.filterId) and not _ti.id.endsWith(self.filterId) then	// 18/05/2010 cnwmh5 #23339
			   	return false;
			elseif self.filterOperatorCode &lt;&gt; null and self.filterOperatorCode &lt;&gt; _ti.operatorCode then
			   	return false;
			elseif self.filterBookingReference &lt;&gt; null and (not _ti.bookingReference.startsWith(self.filterBookingReference)) then
			   	return false;
			elseif self.filtConsigneeCode &lt;&gt; null and self.filtConsigneeCode &lt;&gt; _ti.consignee.trimBlanks then
				return false;
			elseif self.filterStevedoreCode &lt;&gt; null and self.filterStevedoreCode &lt;&gt; _ti.stevedoreCodeRecieve.trimBlanks then  //02.10.2020 cnwma1 TFS #50112
				return false;
			elseif self.filtConsignorCode &lt;&gt; null and self.filtConsignorCode &lt;&gt; _ti.consignor.trimBlanks then			
				return false;

			elseif (self.filtIMEXStatus &lt;&gt; null and _ti.getImExStatus() &lt;&gt; self.filtIMEXStatus) then
				return false;
			elseif ( (transMode = BR_TYPE_RAIL_STR and tmpTransMode = TI_TRANSMODE_RAIL) and self.cmbFilterTrain.listObject &lt;&gt; null // PAR 22766	// PAR #27972
						and _ti.getMyNotifiedTrain &lt;&gt; self.cmbFilterTrain.listObject) then
				return false;
				
			elseif self.filtShippingLine &lt;&gt; null and _ti.getShippingLineCode() &lt;&gt; self.filtShippingLine then		// 23/05/2022 navak20 TFS 53204
				return false;
			elseif self.filtCountryOfOrigin &lt;&gt; null and _ti.getCountryOfOriginCode() &lt;&gt; self.filtCountryOfOrigin then		//17.08.2022 navtnr20 54441
				return false;
			elseif self.filtClientRef &lt;&gt; null and not _ti.clientRef.toUpper.startsWith(self.filtClientRef.toUpper) then					//JIRA 20762
				return false;																											//JIRA 20762
			endif;																														//JIRA 20762
			
		endif;
		
		return _ti.canUserViewMe(null, _passport, true, true, false, true, false, failedDAC);
		

	endif;

	return false;
	

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="c41b7eb1-4a15-45e9-9a16-f4e00c40707a">
