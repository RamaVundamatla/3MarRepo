    <JadeMethod name="setupThumbnailDetails" id="3bedf252-0148-48dc-83ff-c793b5b4c305">
        <updating/>
        <source>setupThumbnailDetails()updating;

vars
	table	: CM_DataTable;
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ConsignMaintTbl);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput( theForm.tblInput1, ETDef_ConsignMaint);
	theForm.shtTblInput1.visible := true;
		
	
	if theForm.allowDelete then
		theForm.btnAction01.visible	:= true;
	endif;

	theForm.fldInput.topSheet :=  theForm.shtTblInput1;
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);		
	
	theForm.txtName.visible := true;
	theForm.btnAddNew.visible := true;
	
 	// 31448 add Address maintenance
	theForm.shtViewTable1.caption := 'Address';
	// Note: SOPTM_Carrier also uses tblData4 but it sets it up each usage, so we can change it here
	table := self.myForm.tblData4;
	// SOPTM_Carrier sets sort columns, clear them here
	table.allTblDataSortColumns.clear();
	table.allTblDataSortDescending.clear();
	table.clearSort();
	table.fixedRows := 0;
	table.rows := 0;
	table.columns := 2;
	table.fixedColumns := 1;
	table.enabled := true;
	table.visible := true;
	// enable tabbing between rows, colour the table like the others on the form
	table.tabKey := Tab.Integer;
	table.backColor := theForm.backColor;
	table.accessColumn(CM_EntryTable.ColumnHeading).backColor := theForm.colorHeadingColumn;
	table.accessColumn(CM_EntryTable.ColumnValue).backColor := theForm.colorValueColumn;

	table.addItem(app.getErrorString(Address1) &amp; Tab &amp; "");
	table.addItem(app.getErrorString(Address2) &amp; Tab &amp; "");
	table.addItem(app.getErrorString(Address3) &amp; Tab &amp; "");
	table.addItem(app.getErrorString(PostCode) &amp; Tab &amp; "");
	table.addItem(app.getErrorString(Region) &amp; Tab &amp; "");
	table.addItem(app.getErrorString(Country) &amp; Tab &amp; "");
	
	table.accessCell(1,2).inputType := Table.InputType_TextBox;
	table.accessCell(2,2).inputType := Table.InputType_TextBox;
	table.accessCell(3,2).inputType := Table.InputType_TextBox;
	table.accessCell(4,2).inputType := Table.InputType_TextBox;
	table.accessCell(5,2).inputType := Table.InputType_TextBox;
	table.accessCell(6,2).cellControl := theForm.cmbCountry;
	theForm.cmbCountry.setObject(null);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="3707cfe9-2cb6-461b-81bb-f15f36f61ce5">
        <updating/>
        <source>showThumbnail(pConsigneeConsignor : CM_ConsigneeConsignor) updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
// 03 Aug 2017	cnwma1		TFS #5209:PEN - Release Request Stop
vars
	address1	: String;
	address2	: String;
	address3	: String;
	postCode	: String;
	region		: String;
	countryName	: String;
	country		: CM_Country;
	addressObj	: CM_Address;
	table		: CM_DataTable;
	theForm		: SOP_TableMaintForm;

begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.btnImport.visible := true;
	theForm.tblInput1.setValueByName(ETRow_Code, pConsigneeConsignor.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pConsigneeConsignor.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry,	pConsigneeConsignor.isNotAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_SecureExportPartner,	pConsigneeConsignor.secureExportPartner);
	theForm.tblInput1.setValueByName(ETRow_ShowOOWRemarks,	pConsigneeConsignor.showOOWRemarks);

	theForm.tblInput1.setValueByName(ETRow_Colour,pConsigneeConsignor.colour);
	theForm.tblInput1.setValueByName(ETRow_DerogationNumber,pConsigneeConsignor.derogationNumber);
	theForm.tblInput1.setValueByName(ETRow_EmailAddress,pConsigneeConsignor.emailAddress);
	
	//par#12903 3/11/2006
	theForm.tblInput1.setValueByName(ETRow_IsConsignor,pConsigneeConsignor.isConsignor);
	theForm.tblInput1.setValueByName(ETRow_IsConsignee,pConsigneeConsignor.isConsignee);
	theForm.tblInput1.setValueByName(ETRow_IsFreightFwdr,pConsigneeConsignor.isFreightFwdr);
	
	//cnwmc5 - 20/12/2012 - HAT 2198
	theForm.tblInput1.setValueByName(ETRow_License,pConsigneeConsignor.license);
	theForm.tblInput1.setValueByName(ETRow_LicenseExpiryDate,pConsigneeConsignor.licenseExpiryDate);
	
	// 3.8.2017 cnwma1 TFS #5209
	theForm.tblInput1.setValueByName(ETRow_IsRestricted,pConsigneeConsignor.isRestricted); 
	
	theForm.tblInput1.setValueByName(ETRow_IsUsedForPacking, pConsigneeConsignor.isUsedForPacking);		// PAR #35895
	
	theForm.tblInput1.setValueByName(ETRow_IsInternal,pConsigneeConsignor.isInternal); //jlier1 TFS 57087 27/6/23
	if not pConsigneeConsignor.isFreightFwdr then
		theForm.tblInput1.hideRowByName(ETRow_IsInternal,false);
	else
		theForm.tblInput1.showRowByName(ETRow_IsInternal,false);
	endif;
	
	if pConsigneeConsignor.myConsignGroup &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_MyConsignGroup, pConsigneeConsignor.myConsignGroup.code &amp; "      " &amp; pConsigneeConsignor.myConsignGroup.description);
	endif;
	if pConsigneeConsignor.debtor &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_MyDebtor, pConsigneeConsignor.debtor.name);
		theForm.tblInput1.setValueByName(ETRow_FinancialId, pConsigneeConsignor.debtor.code);	//04.Mar.24 navsp1 TFS 57177
    endif;
	theForm.myAssistant.comboBoxConsignGroup(theForm.cmbConsignGroup, pConsigneeConsignor.myConsignGroup);

    theForm.cmbDebtor.setObject(pConsigneeConsignor.debtor);
	
	theForm.shtMultiSelect1.caption := 'PIN Advice Email Addresses ' &amp; pConsigneeConsignor.allPINNotifyEmailAddresses.size.String ;
	theForm.mulSelect1.setSelected(pConsigneeConsignor.allPINNotifyEmailAddresses);
 
 	// 31448 add Address maintenance
	if pConsigneeConsignor.myAddress &lt;&gt; null then
		addressObj := pConsigneeConsignor.myAddress;
		address1 := addressObj.addr1;
		address2 := addressObj.addr2;
		address3 := addressObj.addr3;
		postCode := addressObj.postCode;
		region := addressObj.region;
		countryName := addressObj.countryName;
		country := addressObj.getCountry();
	endif;

	table := self.myForm.tblData4;
	table.userInputEnabled := false;	
	table.accessCell(1,2).text := address1;
	table.accessCell(2,2).text := address2;
	table.accessCell(3,2).text := address3;
	table.accessCell(4,2).text := postCode;
	table.accessCell(5,2).text := region;
	table.accessCell(6,2).text := countryName;
	if theForm.mode = theForm.Mode_Update then
		theForm.cmbCountry.setObject(country);
		table.userInputEnabled := true;	
	endif;
	/*if theForm.btnImport.visible then
		if not app.myCurrentUserCan(null, self.permissionMaint) then
			theForm.btnImport.enabled := false;
		else
			theForm.btnImport.enabled := true;
		endif;
	endif;
	*/
end;</source>
        <Parameter name="pConsigneeConsignor" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="0bc7228f-7f46-45b8-b384-41857d948d44">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars

	lConsigneeConsignor:CM_ConsigneeConsignor;
	cell : JadeTableCell;
begin

	lConsigneeConsignor := _obj.CM_ConsigneeConsignor;
	if(_idxRow &lt;&gt; 1) then
		if self.colourColumn &gt; 0 then	
		    cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;		    
			cell.backColor := lConsigneeConsignor.colour;
		endif;
	endif;

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
