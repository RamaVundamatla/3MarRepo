    <JadeMethod name="isIncluded" id="9992da16-19ca-4ee7-8993-fddb6e1fab01">
        <source>isIncluded() : Boolean;
/*
Purpose: If I am a sub detail and my parent detail is not included then I am not included.			

Date		Who		Reason
14 September 2023	navab1	CR 59942 TASK 59943 
*/

vars

begin
	if self.myParentCustomDocumentDetail &lt;&gt; null then
		if not self.myParentCustomDocumentDetail .included then
			return false;
		endif;
	endif;

	return self.included;


end;</source>
