    <JadeMethod name="doCOOApproval" id="03737fb5-7646-44d5-93bd-ab3e2b9a063d">
        <updating/>
        <source>doCOOApproval(_cmifAgent	: CMIF_COOAgent) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email
*/

vars
	now, freeStoExpTS				: TimeStamp;
	cargoGroup : CM_CargoGroup;
	ti				: CM_TrackedItem;
	subDetails,
	details			: CM_OwnershipChangeDetail;
	debtor			: CM_Debtor;
	bank			: CM_Bank;
	cargoGroups 	: CM_TISet;
	txnParams		: CMIF_BBDiscrepancyController;
	aTITrans		: CM_TITransaction;
	invLine			: CM_InvoiceLine;
	invoice			: CM_Invoice;
	invProcess		: CM_InvoiceProcess;
	email 			: CM_InvProcessDefaultEmail;
	emailController	: CMIF_EmailTemplateController;
	cooFinancial 	: CM_OwnershipChangeFinancial;
	freeStoExp : CM_StorageExpiryDetail;
	oldOpExtDays : Integer;
begin
	self.dateTimeApproved := now;
	self.userCodeApproved := app.getMyUserCode();
	
	create cargoGroups transient;
	
	foreach details in self.allDetails where details.included do
		ti := details.myTrackedItem;
		if ti.isCargoGroupItem() then
			cargoGroup := ti.CM_CargoGroup; // ### JIRA 33701 14JAN2025 NAVAB1
			foreach subDetails in details.allSubDetails where subDetails.isIncluded() do
				subDetails.doCOOApproval(_cmifAgent);
			endforeach;
		else
			cargoGroup := ti.myCargoGroup;
			details.doCOOApproval(_cmifAgent);
		endif;
		
		// Create post action to refresh the Cargo Group's operator collection
		if cargoGroup &lt;&gt; null then
			CMIF_TrxActionCargoGroupUpdOp@createAction(null, cargoGroup.CM_CargoGroup, app.myPassport);
			cargoGroups.addNoDuplicates(cargoGroup, false);
		endif;
		
	endforeach;
	
	foreach cargoGroup in cargoGroups as CM_CargoGroup do // ### JIRA 33701 14JAN2025 NAVAB1
		delete txnParams;
		create txnParams transient;
		txnParams.type := TRANS_TYPE_OWNERSHIP_CHANGED;
		aTITrans := cargoGroup.createTransaction(txnParams, app.myPassport);
		// ### JIRA 33701 19DEC2024 NAVAB1
		if app.myPassport.hasErrorsOrWarnings() then
			return;
		endif;
		aTITrans.CM_OwnershipChanged.setDetailsFromCOO(null, self, null);
		
		// ### JIRA 33801 14JAN2025 NAVAB1
		cargoGroup.doRefreshAllOperators();
	endforeach;
	
	//08/12/2023	navkc1 ChangeRequest 58261 Task 58260
	if self.allFinancialIssues.isNotEmpty() then
		// Get the invoice process from the fist invoice line;
		cooFinancial := self.allFinancialIssues.first();
		invLine := cooFinancial.myInvoiceLine;
		invoice := invLine.invoice;
		debtor := invoice.debtor;
		bank := invoice.bank;
		invProcess := invoice.getMyInvoiceProcess();
		
		if invProcess &lt;&gt; null and invProcess.myEmailTemplate &lt;&gt; null then
			create email transient;
			create emailController transient;
			
			email.setEmailController(emailController);
			email.setFromEmailTemplate(invProcess.myEmailTemplate);
			
			self.emailNotify(email, false, self); //19/08/2024	navkc1 CR 65246  Task 65697
		endif;
	endif;
	
epilog
	delete cargoGroups;
	delete txnParams;
	delete email;
end;</source>
        <Parameter name="_cmifAgent" type="CMIF_COOAgent"/>
    </JadeMethod>
    <JadeMethod name="doCreateCMIFAgent" id="145276c2-b5a1-41be-b516-c6e89d58e033">
        <source>doCreateCMIFAgent(_cmifAgent : CMIF_COOAgent io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	cooSubDetail,
	cooDetail		: CM_OwnershipChangeDetail;
	subTi,
	ti				: CM_TrackedItem;
	cg				: CM_CargoGroup;
	transferQty		: Integer;
	transferWgtVol	: Decimal[23,4];
	doSplit			: Boolean;
	cmifDetail		: CMIF_COODetails;
begin
	
	foreach cooDetail in self.allDetails where cooDetail.isIncluded() do
		doSplit := false;
		ti := cooDetail.myTrackedItem;
		
		if ti.isCargoGroupItem() then
			cg := ti.CM_CargoGroup;
			
			foreach cooSubDetail in cooDetail.allSubDetails where cooSubDetail.isIncluded() do
				doSplit := false;
				subTi := cooSubDetail.myTrackedItem;
				
				if subTi.isBulkByVolume() then
					transferWgtVol := cooSubDetail.transferredVolume;
					doSplit := transferWgtVol &lt; subTi.totalVolume;
				
				elseif subTi.isBulkByWeight() then
					transferWgtVol := cooSubDetail.transferredWeight;
					doSplit := transferWgtVol &lt; subTi.totalWeight;
															 
				else
					transferQty := cooSubDetail.transferredQuantity;
					doSplit := transferQty &lt; subTi.totalQuantity;
													   
				endif;
				
				if doSplit then
					create cmifDetail transient;
					cmifDetail.myOwnershipChangeDetail := cooSubDetail;
					cmifDetail.myCmifAgent := _cmifAgent;
				endif;
				
			endforeach;
			
		else
			if ti.isBulkByVolume() then
				transferWgtVol := cooDetail.transferredVolume;
				doSplit := transferWgtVol &lt; ti.totalVolume;
			elseif ti.isBulkByWeight() then
				transferWgtVol := cooDetail.transferredWeight;
				doSplit := transferWgtVol &lt; ti.totalWeight;
														 
			else
				transferQty := cooDetail.transferredQuantity;
				doSplit := transferQty &lt; ti.totalQuantity;
												   
			endif;
			
			if doSplit then
				create cmifDetail transient;
				cmifDetail.myOwnershipChangeDetail := cooDetail;
				cmifDetail.myCmifAgent := _cmifAgent;
			endif;
			
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_cmifAgent" type="CMIF_COOAgent" usage="io"/>
    </JadeMethod>
    <JadeMethod name="emailNotify" id="d11f16c8-9113-4499-a0dc-75987dfbfe64">
        <source>emailNotify(_objectEmail : CM_ObjectEmail;_isDelete: Boolean; _object: CM_Object input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email
19/08/2024	navkc1 CR 65246  Task 65697: Jade _ COO Derive Email Body

*/

vars
	
	fromAddress,
	blobFileName			: String;
	blob 					: Binary;
	fileData 				: CM_FileData;
	invoice					: CM_Invoice;
	cooFinancial			: CM_OwnershipChangeFinancial;
	invLine					: CM_InvoiceLine;
	header 					: CM_FileDataStorageHeader;
	headerSet 				: CM_FileDataStorageHdrSet;

begin

	if _objectEmail = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'object email is null');
		return;
	endif;

	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	create headerSet transient; // ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1
	
	foreach cooFinancial in self.allFinancialIssues do
		invLine := cooFinancial.myInvoiceLine;
		invoice := invLine.invoice;
		
		if _objectEmail.CM_InvProcessDefaultEmail.attachFiles then
		// ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1			create headerSet transient;
			
			foreach fileData in invoice.allFiles where fileData.getInvoiceExternalOnly() do
				blob := fileData.getDataAsBinary();
				blobFileName:= fileData.fileName;
				
				if blob &lt;&gt; null  then
					header := app.convertBlobForRequest(blob, blobFileName, false, 0);
					if header &lt;&gt; null then
						headerSet.add(header);
					endif;
				endif;
			endforeach;
		endif;
	endforeach;
	
	app.myUtilityCA.utlCreateEmailSendRequest(	true, 
												_objectEmail.name, 
												_objectEmail.getToAddresses(),
												fromAddress,
												_objectEmail.getCcAddresses(),
												_objectEmail.getBccAddresses(),
												self.getObjectEmailSubject(_objectEmail),
												self.getObjectEmailBody(_objectEmail), 
												null,
												headerSet,
												null,
												null,
												EmailSource_Invoice,
												null,
												app.myPassport);
	
epilog
	delete headerSet;
end;</source>
        <Parameter name="_objectEmail" type="CM_ObjectEmail"/>
        <Parameter name="_isDelete" type="Boolean"/>
        <Parameter name="_object" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllDetailsAmtAndValidate" id="56f42cef-94f7-4f33-bfa8-641fdca9991b">
        <source>getAllDetailsAmtAndValidate(_cargoGroups : ObjectArray io; _qtyAvail, _qtyRel, _qtyTransfer : IntegerArray io; _volAvail, _volRel, _volTransfer, _wgtAvail, _wgtRel, _wgtTransfer : DecimalArray io; _validate : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/05/2024	navkc1 Bug 64182: MTN - COO Release by Type Validation Issue
18/09/2024  navrv30 Bug 65897: TPT | Cargo Review Issues
*/

vars
	ti				: CM_TrackedItem;
	cg				: CM_CargoGroup;
	cargoType		: CM_CargoType;
	detail			: CM_OwnershipChangeDetail;
	
	max,
	index,	
	qtyAvail,
	qtyTransfer,
	qtyReserve		: Integer;
	
	weightAvail,
	weightTransfer,
	weightReserve,
	volAvail,
	volTransfer,
	volReserve		: Decimal[16,4];
	
	reserveDetails	: CM_ReserveDetail;
	
	reason			: String;
begin
	
	// Go through all subdetails
	foreach detail in self.allDetails discreteLock where detail.isIncluded() do
		
		ti := detail.myTrackedItem;
		// Get the Cargo Group
		if ti.isCargoGroupItem() then
			cg := ti.CM_CargoGroup;
		else
			cg := ti.myCargoGroup;
		endif;
		
		if cg = null then
			continue;
		endif;
		
		// Get Cargo Type
		cargoType := ti.myCargoType;
		
		// Add Cargo group to array and get Index
		index := _cargoGroups.indexOf(cg);
		if index = null then
			_cargoGroups.addExclusive(cg);
			index := _cargoGroups.indexOf(cg);
			_volAvail.atPut(index, 0);
			_volRel.atPut(index, 0);
			_volTransfer.atPut(index, 0);
			_wgtAvail.atPut(index, 0);
			_wgtRel.atPut(index, 0);
			_wgtTransfer.atPut(index, 0);
			_qtyAvail.atPut(index, 0);
			_qtyRel.atPut(index, 0);
			_qtyTransfer.atPut(index, 0);
		endif;
		
		// We only want to check the cargo that has matching release requests
		foreach reserveDetails in cg.allReserveDetailAssigned discreteLock do
			if reserveDetails.isReserveSelection() then
				if not ti.testAgainstReserveSelection(reserveDetails.CM_ReserveSelection, reason, false, null) then
					continue;
				endif;
				
				// Get the Total amount available &amp; Total amount reserved &amp; Total amount in COO of TI/CargoGroup
				if cargoType.isBulk() then
					if cargoType.isBulkByVolume() then
						volAvail := cg.totalVolume; //ti.totalVolume;  //18 September 2024 navrv30 Bug 65897
						volReserve := ti.getReservedVolume(null);
						
						if volReserve = null and cg &lt;&gt; null then
							volReserve := cg.getReservedVolume(null);
						endif;
						
						volTransfer := ti.getOwnershipChangeVolume(null);
						
						//_volAvail[index] += volAvail;
						_volAvail.atPut(index, volAvail);		//18 September 2024 navrv30 Bug 65897
						// For Reserve amount, we always check the cargo group, and we shouldn't accumulate
						_volRel.atPut(index, volReserve);
						_volTransfer[index] += volTransfer;
						
					else
						weightAvail := cg.totalWeight; // ti.totalWeight;   //18 September 2024 navrv30 Bug 65897
						weightReserve := ti.getReservedWeight(null);
						
						if weightReserve = null and cg &lt;&gt; null then
							weightReserve := cg.getReservedWeight(null);
						endif;
						
						weightTransfer := ti.getOwnershipChangeWeight(null);
						
						//_wgtAvail[index] += weightAvail;
						_wgtAvail.atPut(index, weightAvail);        //18 September 2024 navrv30 Bug 65897
						// For Reserve amount, we always check the cargo group, and we shouldn't accumulate
						_wgtRel.atPut(index, weightReserve);
						_wgtTransfer[index] += weightTransfer;
					endif;
				else
					qtyAvail := cg.totalQuantity; //ti.totalQuantity;   //18 September 2024 navrv30 Bug 65897
					qtyReserve := ti.getReserveQuantity(null);
					
					if qtyReserve = null and cg &lt;&gt; null then
						qtyReserve := cg.getReserveQuantity(null);
					endif;
					
					qtyTransfer := ti.getOwnershipChangeQuantity(null);
					
					//_qtyAvail[index] += qtyAvail;
					_qtyAvail.atPut(index, qtyAvail);            //18 September 2024 navrv30 Bug 65897
					// For Reserve amount, we always check the cargo group, and we shouldn't accumulate
					_qtyRel.atPut(index, qtyReserve);
					_qtyTransfer[index] += qtyTransfer;
				endif;
			else
				continue;
			endif;
		endforeach;
		
		
	endforeach;
	
	if _validate then
		max := _cargoGroups.size();
		foreach index in 1 to max do
			if 	_volTransfer[index] &gt; _volAvail[index] - _volRel[index] then
				app.raiseCMException3(This_owner_chang_have_amoun_re, _volRel[index].String, _volTransfer[index].String, (_volAvail[index] - _volRel[index]).String,null,null);
			elseif _wgtTransfer[index] &gt; _wgtAvail[index] - _wgtRel[index] then
				app.raiseCMException3(This_owner_chang_have_amoun_re, _wgtRel[index].String, _wgtTransfer[index].String, (_wgtAvail[index] - _wgtRel[index]).String,null,null);
			elseif _qtyTransfer[index] &gt; _qtyAvail[index] - _qtyRel[index] then
				app.raiseCMException3(This_owner_chang_have_amoun_re, _qtyRel[index].String, _qtyTransfer[index].String, (_qtyAvail[index] - _qtyRel[index]).String,null,null);
			endif;
		endforeach;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_cargoGroups" type="ObjectArray" usage="io"/>
        <Parameter name="_qtyAvail" type="IntegerArray" usage="io"/>
        <Parameter name="_qtyRel" type="IntegerArray" usage="io"/>
        <Parameter name="_qtyTransfer" type="IntegerArray" usage="io"/>
        <Parameter name="_volAvail" type="DecimalArray" usage="io"/>
        <Parameter name="_volRel" type="DecimalArray" usage="io"/>
        <Parameter name="_volTransfer" type="DecimalArray" usage="io"/>
        <Parameter name="_wgtAvail" type="DecimalArray" usage="io"/>
        <Parameter name="_wgtRel" type="DecimalArray" usage="io"/>
        <Parameter name="_wgtTransfer" type="DecimalArray" usage="io"/>
        <Parameter name="_validate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="31f5565c-80b5-4162-8372-13f79dc3e850">
        <source>getAuditText(): String;
/*
Purpose:			

Date		Who		Reason
21 July 2023	navab1	// ### TFS CR 58246 TASK 58249 21JUL2023 NAVAB1
*/

vars
	txt,
	tmpStr	: String;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	// Start 6.3.2023 navmk20 TFS 56944
	if self.myIncoterm &lt;&gt; null then
		tmpStr := self.myIncoterm.code;
		if tmpStr &lt;&gt; null then
			txt := txt &amp;'Incoterm'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		endif;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCOOOperator" id="6e61e5fd-58b6-4053-8c1b-6ff496e49510">
        <source>getCOOOperator(_oprSet: CM_OperatorSet io; _operatorType: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2023	navma1	ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1

*/

vars
	coo 				: CM_OwnershipChange;
	isOrginalOperator	: Boolean;
	isNewOperator		: Boolean;
	isOldOperator		: Boolean;
begin
	
	isOrginalOperator	:= _operatorType = CM_OwnershipChange::myOperatorOrig.name;
	isNewOperator 		:= _operatorType = CM_OwnershipChange::myOperatorNew.name;
	isOldOperator 		:= _operatorType = CM_OwnershipChange::myOperatorOld.name;
	
	if isOrginalOperator then
		_oprSet.tryAddIfNotNull(self.myOperatorOrig);
	elseif isOldOperator then
		_oprSet.tryAddIfNotNull(self.myOperatorOld);
	elseif isNewOperator then
		_oprSet.tryAddIfNotNull(self.myOperatorNew);
	endif;
	
	
epilog

end;</source>
        <Parameter name="_oprSet" type="CM_OperatorSet" usage="io"/>
        <Parameter name="_operatorType" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoSubTypeCode" id="2700f149-4127-4ecf-bf6c-a188dc1ca5cc">
        <source>getCargoSubTypeCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
*/

vars
	ownershipChangeDetail      : CM_OwnershipChangeDetail;
	displayStr, returnStr : String;
	ti : CM_TrackedItem;
begin
	foreach ownershipChangeDetail in self.allDetails do
		ti := ownershipChangeDetail.myTrackedItem;
		if ti = null then
			continue;
		endif;
		displayStr := ti.productCode;
		/*
		if displayStr &lt;&gt; null then
			if returnStr.pos(displayStr,1) = 0 then
				if returnStr = null then
					returnStr := displayStr;
				else
					returnStr := returnStr &amp; ", " &amp; displayStr;
				endif;
			endif;
		endif;
		*/
		
		returnStr.addStringToList(displayStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return returnStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
