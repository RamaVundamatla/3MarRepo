    <JadeMethod name="setFilterAttributes" id="66652c23-55b2-46eb-bbdd-1c9656e267f7">
        <updating/>
        <source>setFilterAttributes() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2008	cnwer1	Initial creation

*/

vars

begin
	self.myOperator:=self.cmbOperator.listObject.CM_Operator;
	self.myVoyage:=self.cmbVoyage.listObject.CM_Voyage;
	self.myIMEXStatus:=self.cmbImEx.listObject.CM_IMEXStatus;
	if self.myIMEXStatus &lt;&gt; null and self.myIMEXStatus.code = 0 then
		self.myIMEXStatus:=null;
	endif;
	self.myCargoType:=self.cmbTiType.listObject.CM_CargoType;
	self.myFiltConsignee:=self.cmbConsignee.listObject.CM_ConsigneeConsignor;
	self.myFiltDestination:=self.cmbDestination.listObject.CM_Port;
	self.myFiltFreightFwdr:=self.cmbFreightFwdr.listObject.CM_ConsigneeConsignor;
	self.myISOType:=self.cmbISOType.listObject.CM_ISOType;
	self.myIsoTypeGroup := self.cmbIsoTypeGroup.listObject.CM_ISOTypeGroup;
epilog

end;</source>
    </JadeMethod>
