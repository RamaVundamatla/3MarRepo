    <JadeMethod name="importPLXMLReference" id="aa6af7eb-173f-4bfc-98f5-0342ee391e97">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_XlationTable::myRoot.name then
		return app.myRoot;
	elseif _name = CM_XlationTable::myOperator.name then
		return app.myRoot.allOperators[_theCode];
	elseif _name = CM_XlationTable::myOperatorTerminal.name then
//		return app.getMyTerminal().allOperatorTerminals[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="theKey" id="a24bef7a-a788-4b20-8e34-61121f6a18c0">
        <source>theKey(): String;

vars
	msg : String;
begin
	msg := self.type.String&amp;':';
	if self.myOperator = null then
		msg := msg&amp;':';
	else
		msg := msg&amp;self.myOperator.code&amp;':';
	endif;
	if self.myOperatorTerminal = null then
		msg := msg&amp;':';
	else
		msg := msg&amp;self.myOperatorTerminal.theKey&amp;':';
	endif;
	return msg;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
