    <JadeMethod name="doNotableAdd" id="a7ffd993-837a-4f12-9b8f-8eef8fcf3ac2">
        <source>doNotableAdd(_anObject : Object);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	invalid : Boolean;
	ed : Integer;
begin
	if _anObject = null then
		return;
	endif;
	
	/*if not global.isValidObject(_anObject) then
		return;
	endif;*/
	
	//cnwjo3, par 21915
	on Exception do app.handleDeletedObject(exception,_anObject,invalid);
	ed := _anObject.edition;
	if invalid then
		return;
	endif;
	
	if not self.allNotableObjects.includes(_anObject) then
		if CM_TerminalArea.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED), Response_Continuous, null);
		elseif CM_Voyage.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED), Response_Continuous, null);
			beginNotification(_anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED), Response_Continuous, null);
			beginNotification(_anObject, self.myTerminal.getTerminalEvent(TIEvent_Transit_Status_Update), Response_Continuous, null);
			
		elseif CM_Invoice.hasInstance(_anObject) then
			if not self.allNotableObjects.includes(_anObject) then
				self.allNotableObjects.add(_anObject);
				beginNotification(_anObject, self.myTerminal.getTerminalEvent(Event_InvoiceUpdate), Response_Continuous, null);
			endif;
		elseif CM_InvoiceLine.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, self.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), Response_Continuous, null);
		elseif _anObject.isKindOf(CM_CashPayment) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, self.myTerminal.getTerminalEvent(Event_CashPaymentUpdate), Response_Continuous, null);
		elseif CM_TrackedItem.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);
		elseif CM_VoyageWLE.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);			
		elseif CM_VoyageJob.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);						
		elseif HMS_ResourceUsed.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginClassNotification(HMS_ResourceUsed,false,Object_Create_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);						
		elseif HMS_VoyageMovement.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);
		//cnwjo3, used in YRD_EasyGateEnquiry::addRowToTable form, par 21915
		elseif CM_InterTerminalMove.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);
		//cnwjo3, used in YRD_LoadList::doQuery, par 21915
		elseif CM_Train.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);
		//cnwjo3, used in YRD_WorkOrderEnquiry::addRowToTable, par 21915
		elseif CM_WorkOrder.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);
		//cnwjo3, used in YRD_WorkOrderEnquiry::addRowToTable, par 21915
		elseif CM_WorkOrderDtl.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);
		endif;		
	endif;
	
end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="0da48aad-fbc6-4c98-8ca5-a1d61b58890b">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_TerminalArea) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED));
			removedNotification := removedNotification + 1; //cnwjo3 par 21915
		elseif anObject.isKindOf(CM_Voyage) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED));
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED));
			removedNotification := removedNotification + 1; //cnwjo3 par 21915
		elseif anObject.isKindOf(CM_TrackedItem) then
			endNotification(anObject, Object_Update_Event);
			removedNotification := removedNotification + 1; //cnwjo3 par 21915
		endif;
	endforeach;

	//cnwjo3 par 21915
	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="ebbf6d6b-922f-4d25-859a-9962d877e239">
        <source>doNotableRemove(_anObject : Object);
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if _anObject = null then
		return;
	endif;
	if not global.isValidObject(_anObject) then
		return;
	endif;
	if  self.allNotableObjects.includes(_anObject) then
		if _anObject.isKindOf(CM_TerminalArea) then
			self.allNotableObjects.remove(_anObject);
			endNotification(_anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED));
		elseif _anObject.isKindOf(CM_TrackedItem) then
			self.allNotableObjects.remove(_anObject);
			endNotification(_anObject, Object_Update_Event);
		elseif CM_Invoice.hasInstance(_anObject) then
			if not self.allNotableObjects.includes(_anObject) then
				self.allNotableObjects.remove(_anObject);
				endNotification(_anObject, self.myTerminal.getTerminalEvent(Event_InvoiceUpdate));
			endif;
		elseif CM_InvoiceLine.hasInstance(_anObject) then
			if not self.allNotableObjects.includes(_anObject) then
				self.allNotableObjects.remove(_anObject);
				endNotification(_anObject, self.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate));
			endif;
		elseif _anObject.isKindOf(CM_CashPayment) then
			if not self.allNotableObjects.includes(_anObject) then
				self.allNotableObjects.remove(_anObject);
				endNotification(_anObject, self.myTerminal.getTerminalEvent(Event_CashPaymentUpdate));
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
