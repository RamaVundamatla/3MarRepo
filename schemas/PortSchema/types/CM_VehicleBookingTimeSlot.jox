    <JadeMethod name="addSlotItem" id="88980d01-fd81-40ab-a6fc-04093fef842f">
        <updating/>
        <source>addSlotItem(_slotItem : CM_VehicleBookingTimeSlotItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars

begin
	self.allVehicleBookingItems.addNoDuplicates(_slotItem, false);
	
	if _slotItem.direction = DIRECTION_DELIVERY then
		self.includesDelivery := true;
	elseif _slotItem.direction = DIRECTION_PICKUP then
		self.includesPickUp := true;
	endif;

end;</source>
        <Parameter name="_slotItem" type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
    <JadeMethod name="auditClass" id="0ac376c6-0e70-43f0-bebd-1a38ba6051ff">
        <options>4</options>
        <source>auditClass(): Class typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navlw1	ChangeRequest 59132:[59133] EUP | VBS Audits

*/

vars

begin
	return CM_VehicleBookingTimeSlot;
epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="canBeCopied" id="0be94877-e8c5-4844-abee-1cac173d19e4">
        <source>canBeCopied():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navma1	ChangeRequest 59700: FR | 53429 - VBS Slot transfer - Slot status
20 Nov 2023 navlc30 ChangeRequest 61207: EUP | FR | 54329 | VBS - Pending issues - Issue 13

*/

vars
	status : Integer;
begin
	status := self.getStatusInteger();
	
	if status = CM_VehicleBookingTimeSlot.AvailableNotBookedInt  or 	 // 1 - Available - Not booked				//20.11.2023 navlc30 #61207
	   status = CM_VehicleBookingTimeSlot.BookedNotYetDueInt     or 	 // 2 - Booked - Not yet due
	   status = CM_VehicleBookingTimeSlot.BookedCurrentInt       or      // 4 - "Booked - Current"
	   status = CM_VehicleBookingTimeSlot.BookedArrivedEarlyInt  or      // 5 - Booked - Arrived early
	   status = CM_VehicleBookingTimeSlot.BookedArrivedLateInt   or		 // 6 - Booked - Arrived late
	   status = CM_VehicleBookingTimeSlot.BookedArrivedOntimeInt then	 // 7 - Booked - Arrived on time
	   return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeTransfered" id="12000683-1416-4554-8eea-c685e8c78745">
        <source>canBeTransfered():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navma1	ChangeRequest 59700: FR | 53429 - VBS Slot transfer - Slot status

*/

vars

begin

	if self.getStatusString = CM_VehicleBookingTimeSlot.BookedOverdue or 
	   self.getStatusString = CM_VehicleBookingTimeSlot.BookedCurrent or 
	   self.getStatusString = CM_VehicleBookingTimeSlot.BookedNotYetDue then
	   
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
