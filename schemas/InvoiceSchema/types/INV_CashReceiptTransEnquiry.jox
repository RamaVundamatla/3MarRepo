    <JadeMethod name="displayChangeStatusMnu" id="e96bfffa-3088-4b99-b521-f2fa370d6b50">
        <source>displayChangeStatusMnu(_cashReceipt : CM_CashReceipt) : Boolean;
/*

Purpose:			This method decides whether we should display the context menu for user to change the cash receipt status

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/

vars

begin
	
	if not app.isSpecial() then
		return false;
	endif;
	
	// Only allow user to change status when it's in HOLD status
	if	_cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
