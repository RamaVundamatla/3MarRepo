    <JadeMethod name="mnuViewBooking_click" id="53dbe683-baf5-4d2e-a6a1-f899c550798e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuViewBooking_click(menuItem: MenuItem input) updating;
//10 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars

begin
	if menuItem.userObject.isKindOf(CM_BookingRef) then
		if menuItem.userObject.CM_BookingRef.bookingReference = self.myProxyBookingItem.myBookingReference.bookingReference then
			//move current booking to front
			self.myParentForm.zOrder(1);
		else
			self.myAssistant.showBookingForm(menuItem.userObject.CM_BookingRef, self.myMasterMenuAction, self.myTerminal);
		endif;
	else
		if menuItem.userObject.CM_BookingRefItem.myBookingReference = self.myProxyBooking then
			//move current booking to front
			self.myParentForm.zOrder(1);
		else
			self.myAssistant.showBookingForm(menuItem.userObject.CM_BookingRefItem.myBookingReference, self.myMasterMenuAction, self.myTerminal);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
