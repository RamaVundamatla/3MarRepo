    <JadeMethod name="shouldAuditProperty" id="1e5576fc-13a4-4984-b843-5b91d548f63a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation

*/

vars

	propName	: String;
	
begin

	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TranMapBOL::myChildQuantityMap.name or
		propName = CM_TranMapBOL::myBank.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ecfafcb1-f8e3-40a9-957f-d20689b1fbcc">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFs 47100

*/

vars

begin

	if self.myBank &lt;&gt; null then
		if self.myBank.allBOLTranMaps[self.name] &lt;&gt; null then
			app.raiseCMException1(TransactionMap_already_exists,self.name,null,null); 
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="68fe3b5d-2b55-4145-a1f2-0423ed93cc8a">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	if self.myBank.myCurrentTranMapBOL = self then
		app.raiseCMException(ERR_TRANSMAP_ACTIVE, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
