<Class name="CMIF_SAPPreBillCheckLimitReq" id="71235a52-0c8d-4bf7-ad98-815449fb5db1">
    <superclass name="CMIF_SAPWSRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>37189.002 Perform Credit Check for Pre-Billing Customer
WSDL 1.4: Pre-Billing - Credit Limit + Billing Payment Process
PaymentType_PrePay</text>
    <PrimAttribute name="amount" id="cc6e967f-cd72-49e0-b028-46d981cb5457">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="amountEstmtOpen" id="6cd89470-d1c1-4803-8402-2e305a7f6f47">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="currency" id="17e8b57b-9f33-40e0-889f-4111d6862b55">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="customerNo" id="25bc91b8-ee35-470d-a4b5-9852bc009a2c">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myBillInfo" id="cd6f59f1-4774-4736-9191-081bcf0f72eb">
        <embedded/>
        <type name="CMIF_SAPPreBillCheckLimBilling"/>
    </ImplicitInverseRef>
    <PrimAttribute name="paymentCode" id="17d45bd7-d827-494c-b76b-328ba84afc66">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="preInvoiceID" id="f48e4ab6-0975-4bed-b105-e67c6168acd5">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="copyToRealWSObject" id="83551d76-f3a5-4db1-a8ab-fcdf0551703a">
        <source>copyToRealWSObject(_realRequest: SAP14_PreBillCheckLimitReq_DT input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.amount := self.amount;
	_realRequest.amountEstmtOpen := self.amountEstmtOpen;
	
	// manual population of billingInfo required
	create _realRequest.billingInfo transient;
	_createdObjects.add(_realRequest.billingInfo);
	if self.myBillInfo &lt;&gt; null then
		self.myBillInfo.copyToRealWSObject(_realRequest.billingInfo, _createdObjects);
	endif;
	
	_realRequest.currency := self.currency;
	_realRequest.customerNo := self.customerNo;
	_realRequest.paymentCode := self.paymentCode;
	_realRequest.preInvoiceID := self.preInvoiceID;

epilog

end;</source>
        <Parameter name="_realRequest" type="SAP14_PreBillCheckLimitReq_DT" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyToSAPPreBillCheckLimitReq" id="2459ca1b-ec63-4ec7-83af-d4cf37b0cfdb">
        <updating/>
        <source>copyToSAPPreBillCheckLimitReq(_invoice : CM_Invoice) updating;
/*
Purpose:			
	37189.002 Perform Credit Check for Pre-Billing Customer
	WSDL 1.4: Pre-Billing - Credit Limit + Billing Payment Process
	PaymentType_PrePay
Return Value:		

Date		Who		Reason
12 Jul 2018	jlgrs1	ChangeRequest 38630: PEL1 - SAP Credit Check Interfaces
23 Jan 2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
29 Jan 2019 cnwma1	Bug 43124: PEL1 - Container Services - SAP SIT issues
*/
vars
	billingInfo  : CMIF_SAPPreBillCheckLimBilling;
begin
	
	self.preInvoiceID 	 := self.sapHelper(_invoice,"preInvoiceID");
	self.customerNo      := self.sapHelper(_invoice,"customerNo");
	self.amount 	  	 := self.sapHelper(_invoice,"getTotalAmtDocCurAR");  								 //23.01.2019 cnwma1 #42942
	self.paymentCode  	 := self.sapHelper(_invoice,"paymentCode");
	self.currency		 := self.sapHelper(_invoice,"currency");
	self.amountEstmtOpen := _invoice.debtor.getEstimateOpenAmount(PaymentType_PrePay).String; //29.01.2019 cnwma1 #43214
	
	create billingInfo transient ;
	billingInfo.bINF01	:= self.sapHelper(_invoice,"billingInfo.bINF01");  //debtor.name
	billingInfo.bINF02  := self.sapHelper(_invoice,"billingInfo.bINF02");  //debtor.additionalInformation1
	billingInfo.bINF03  := self.sapHelper(_invoice,"getTotalAmtDocCurAR"); //23.01.2019 cnwma1 TFS #42942
	billingInfo.bINF04  := self.sapHelper(_invoice,"billingInfo.bINF04");  //invoice.exportCurrencyCode
	billingInfo.bINF05  := self.sapHelper(_invoice,"billingInfo.bINF05");  //voyage.myVessel.name
	billingInfo.bINF06  := self.sapHelper(_invoice,"billingInfo.bINF06");  //invoice.invoiceType.description
	self.myBillInfo := billingInfo;	
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a8705362-acff-4d6e-b8df-f647d7cd0bfa">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	delete self.myBillInfo;
	
epilog

end;</source>
    </JadeMethod>
