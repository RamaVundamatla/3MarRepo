    <JadeMethod name="tAddDamagePosition" id="7d60a3b7-be88-4280-a347-7d5dbe66475c">
        <source>tAddDamagePosition();
// cnwrs1
//  Created by cnwsh3
//	Date 23 July 2009
//
// Implemented version: 7.7.3
//----------------------------------------------------------------------
vars
	damagePos	: CM_DamagePosition;
	cargoTypes 		: CM_ObjectSet;
	machineTypes 	: CM_ObjectSet;
begin
	self.deleteDamagePosition('zDontUse');
	
	create cargoTypes transient;
	create machineTypes transient;
	
	self.addDamagePosition('zDontUse', 'UnitTest - DO NOT EDIT OR USE', cargoTypes, machineTypes);
	
	
	self.deleteDamagePosition('zDontUse1');
	
	

	
	self.addDamagePosition('zDontUse1', 'UnitTest Damage code ', cargoTypes, machineTypes);
	damagePos := app.myRoot.allDamagePositionsByCode["zDontUse1"];
	self.assertNotNull(damagePos);
	
	// Update damage Position 
	self.updateDamagePosition(damagePos);
	self.assertEqual(damagePos.description,"UnitTest Damage code UP");
	
	
epilog
	
	delete cargoTypes;
	delete machineTypes;
end;</source>
    </JadeMethod>
