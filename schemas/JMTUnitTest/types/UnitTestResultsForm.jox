    <JadeMethod name="checkUnitTestRunnerRunning" id="1db0fb13-6f52-494a-b04e-d2eaa2f533ac">
        <source>checkUnitTestRunnerRunning() : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2024	navpw1	Initial creation

*/

vars
	jadeNodes		: NodeDict;
	jadeNode		: Node;
	allProcesses	: ProcessDict;
	jadeProcess 	: Process;
	invalidJadeNode	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, jadeNode, invalidJadeNode);
	create jadeNodes transient;
	create allProcesses transient;
	
	system.nodes.copy(jadeNodes);
	
	if jadeNodes.isEmpty then
		return null;
	endif;
	
	foreach jadeNode in jadeNodes do :nodeLoop
		allProcesses.clear();
		if invalidJadeNode then
			invalidJadeNode := false;
			continue;
		endif;
		
		jadeNode.processes.copy(allProcesses);
		
		if allProcesses.isEmpty then
			continue nodeLoop;
		endif;
		
		foreach jadeProcess in allProcesses do
			if not jadeProcess.adminInfo.startsWith("JMTUnitTestRunner") then
				continue;
				
			endif;
			
			return true;
			
		endforeach;
		
	endforeach;
	
	return false;
	
epilog
	delete jadeNodes;
	delete allProcesses;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
