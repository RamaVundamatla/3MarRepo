<CollClass name="CMIF_CustomSequenceObjectArray" id="8c63248e-43ea-44d7-8169-37f7932d9cf3">
    <loadFactor>66</loadFactor>
    <memberType name="CMIF_CustomSequenceObject"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getSeqObjFromSlotReq" id="61169d0d-53d8-4ab7-aa9a-6960cae173ae">
        <source>getSeqObjFromSlotReq(_sr : CM_SlotRequest) : CMIF_CustomSequenceObject;
// ---------------------------------------------------------------------------
// Created:		04 September 2008 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 17814
//
// ---------------------------------------------------------------------------
vars
	tmp : CMIF_CustomSequenceObject;
begin
	foreach tmp in self discreteLock do
		if tmp.myRequest = _sr then
			return tmp;
		endif;
	endforeach;
	
	return tmp;
end;</source>
        <Parameter name="_sr" type="CM_SlotRequest"/>
        <ReturnType type="CMIF_CustomSequenceObject"/>
    </JadeMethod>
</CollClass>
