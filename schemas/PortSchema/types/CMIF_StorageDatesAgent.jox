<Class name="CMIF_StorageDatesAgent" id="14345828-8371-43ac-84f1-951d1aba2741">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="allStorageDates" id="9adbbfc3-df1e-46c5-b409-9c772f3a6d96">
        <memberTypeInverse/>
        <type name="CMIF_StorageDatesByDate"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allStorageTransactions" id="5602fd58-758e-415b-bd52-9d89b47bc9c2">
        <memberTypeInverse/>
        <type name="CM_TITransactionByDateDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="23c0b2bc-8882-4dd3-9b08-3e066faaff9d">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <JadeMethod name="addDate" id="bbfb2e82-9b05-443c-a014-ed2c4ac39452">
        <source>addDate(_dateTime : TimeStamp; _noCharge : Boolean; _opCode : String);
/*
Purpose:			

Date		Who		Reason
17 January 2024	navab1	CR 58263 TASK 58264
*/

vars
	date : CMIF_StorageDates;
	tran : CM_TITransaction;
	date1, date2 : Date;
begin

	// ### TFS BUG 64177 30MAY2024 NAVAB1 - if COO the chargeable date for the previous operator 
	//																will be on the  same date as the free storage expiry of the new operator.
	// only 1 storage transaction per day per operator
	foreach tran in self.allStorageTransactions do
		if tran.dateTime.date = _dateTime.date 
		and tran.operatorCode = _opCode then // ### TFS BUG 64177
			return;
		endif;
	endforeach;

	
	// only 1 storage tran per day
	foreach date in self.allStorageDates do
		date1 := date.dateTime.date;
		date2 := _dateTime.date;
		
		if date1 = date2 
		and date.operatorCode = _opCode  then // ### TFS BUG 64177
			return;
		endif;
	endforeach;

	
	create date transient;
	date.dateTime := _dateTime;
	date.noCharge := _noCharge;
	date.operatorCode := _opCode;
	
	self.allStorageDates.add(date);

epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_opCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="416b64e6-8c9a-4b23-a312-346b307e1a31">
        <updating/>
        <source>initialise(_ti : CM_TrackedItem) updating;
/*
Purpose:			

Date		Who		Reason
19 January 2024	navab1	CR 58263 TASK 58264
*/

vars
	tran : CM_TITransaction;
	trans : CM_TITransactionSet;
begin
	self.myTrackedItem := _ti;
	
	trans := self.myTrackedItem.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	trans.copy(self.allStorageTransactions);
	
	/* actually do not do this, instead, else where, check if configured for zero free days
	// need to include the receive date. If TI has no configured free days then there must not be a CM_Storage 'no charge' on the same day as receival. 
	// Adding the recieve transaction will stop storage trans with the same date being created
	tran := self.myTrackedItem.allTransactions.findFirstReceivalTrans();
	if tran &lt;&gt; null then
		self.allStorageTransactions.add(tran);
	endif;
	*/
epilog
	delete trans;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
