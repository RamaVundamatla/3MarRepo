    <JadeMethod name="handleBtnTwo" id="d787fa67-c398-423d-a829-f61ae8beaa04">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278
*/
vars
	context : Integer;
	quantity : Integer;
	weight : Decimal [16,4];

begin
	//user clicked checks - show cargo checks form
	if self.myTrackedItem = null then
		return;
	endif;
	
	// do we have any checks to perform?
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
		context := CARGO_CHECK_CONTEXT_RAIL_REC;
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
		context := CARGO_CHECK_CONTEXT_RAIL_REL;
	else
		return;
	endif;
	
	if self.myTerminal.hasNoCargoCheckItemsFor(context) then	
		return;
	endif;
	
	self.myMobileGenericAgent.setMyNextTiToAction(self.myTrackedItem);
	self.myMobileGenericAgent.setMyWle(self.myWorkListEntry);
	self.myMobileGenericAgent.setDisplayIdOnCheckForm(true);
	
	if self.txtLocation.text.trimBlanks &lt;&gt; null then
		app.myMobileCargoFindAgent.setStringField1(self.txtLocation.text.trimBlanks);
	endif;
	if self.txtQuantity.visible then
		app.myMobileCargoFindAgent.setStringField2(self.txtQuantity.text.trimBlanks);	//01 Aug 2013	NDL	Par 32140
	else
		app.myMobileCargoFindAgent.setStringField2(null);
	endif;
	//02 Apr 2014	NDL	CCMS 1366
	if self.tblWeightVolume.visible then
		weight := self.tblWeightVolume.getConvertedValue();
		app.myMobileCargoFindAgent.setDecimalField1(weight);
	else
		weight := 0;
		app.myMobileCargoFindAgent.setDecimalField1(0.00);
	endif;
	
	//28 May 2013	CCMS 2274 Break-bulk
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
		self.myMobileGenericAgent.setSplitValues( quantity, weight, null );
	endif;

	self.gotoForm(MOB_HHGateCheckCargo, false);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTrackedItem" id="f017bb4e-6e6e-48b3-9966-c0368fad1b5e">
        <updating/>
        <source>populateTrackedItem() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278
*/

vars

	warningMess : String;
	wle : CM_WorkListEntry;
	location: String;
	lc: CM_LocationsController;
	job : CM_Job;
	otherWle : CM_WorkListEntry;
	allowAddCargo : Boolean;
	desc1 : String;
	desc2 : String;
	weightStr : String;
	volumeStr : String;
	measureType : CM_MeasurementType;
	
begin

	self.btnAddCargo.visible := self.addCargoVisibility;
	self.lblQuantity.visible := false;
	self.txtQuantity.visible := false;
	self.tblWeightVolume.visible := false;
	
	if self.myTrackedItem = null then
		self.txtCargoId.text := lblCargoId.caption.toUpper;
		self.txtCargoId.setFocus();
		self.lblCargoType.caption := null;
		self.lblCargoDesc.caption := null;	//02 Aug 2013	NDL	Par 32156
		self.txtLocation.visible := true;
		self.resetLocationDisplay();
		
	else	
		self.txtCargoId.text := self.myTrackedItem.id;
		self.myTrackedItem.getShortDescriptions( desc1, desc2 );	//02 Aug 2013	NDL	Par 32156
		self.lblCargoType.caption := desc1;	//02 Aug 2013	NDL	Par 32156
		self.lblCargoDesc.caption := desc2;	//02 Aug 2013	NDL	Par 32156
		self.txtLocation.text := null;
		self.txtQuantity.text := null;
		
		if self.myTrackedItem.isBulkByQuantity and  self.myTrackedItem.canSplitTotalQuantity then
			self.lblQuantity.visible := true;
			self.txtQuantity.visible := true;
			if self.myMobileGenericAgent.splitQuantity &lt;&gt; 0 then
				self.txtQuantity.text := self.myMobileGenericAgent.splitQuantity.String;
			elseif app.myMobileCargoFindAgent.stringField2 &lt;&gt; null then	//03 Oct 2016	NDL	TFS 2765
				self.txtQuantity.text := app.myMobileCargoFindAgent.stringField2;	//03 Oct 2016	NDL	TFS 2765
				app.myMobileCargoFindAgent.setStringField2(null);	//03 Oct 2016	NDL	TFS 2765
			endif;
		elseif self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
			self.txtQuantity.visible := false;
			self.setBulkWeightVolumeFields( self.myTrackedItem, self.tblWeightVolume, self.lblQuantity, self.myMobileGenericAgent.splitWeight );
		endif;
		
		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
			self.getRailJobWLE( job, wle, false );
			self.txtLocation.visible := true;
			
			//03 Oct 2016	NDL	TFS 2765
			if app.myMobileCargoFindAgent.stringField1 &lt;&gt; null then	
				self.txtLocation.text := app.myMobileCargoFindAgent.stringField1;
				app.myMobileCargoFindAgent.setStringField1(null);
				self.findLocationToMoveTo( lc );
				if lc &lt;&gt; null then 
					self.setTxtLocationDetails( lc.getFullId, lc );
				endif;
			endif;
			
			//02 Oct 2014	NDL	- Par 34981 should use the value from the WLE if we have one
			if lc = null and  wle &lt;&gt; null then
				lc := wle.getTargetLocation;
				//if not lc.isWagon or not self.myHandHeldCheckerAgent.myCurrentWagon.allLocationsControllers.includes( lc.CM_WagonController ) then
				if not lc.isWagon or not self.myMobileGenericAgent.myCurrentWagon.allLocationsControllersArray.includes( lc.CM_WagonController ) then	//04 Dec 2014	NDL	Par 35345
					lc := null;
				endif;
			endif;
			if lc = null then
				lc := self.myMobileGenericAgent.myCurrentWagon.getNextFreeWagonControllerPN( self.myTrackedItem, REAL_MODE );
			endif;
			location := lc.getFullId;
			self.setTxtLocationDetails( location, lc );	
							
			
		elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
			
			if self.myTrackedItem.directDelivery then
				wle := self.myTrackedItem.getVoyageWLEUnactioned( false );
				if wle &lt;&gt; null then
					otherWle := self.myTrackedItem.getDirectDeliveryTargetWle( wle );
					if otherWle &lt;&gt; null then
						lc := otherWle.getTargetLocation;
					endif;
				endif;
		
			endif;
			
			//03 Oct 2016	NDL	TFS 2765
			if lc = null then	
				if app.myMobileCargoFindAgent.stringField1 &lt;&gt; null then	
					self.txtLocation.text := app.myMobileCargoFindAgent.stringField1;
					app.myMobileCargoFindAgent.setStringField1(null);
					self.findLocationToMoveTo( lc );
					if lc &lt;&gt; null then 
						self.setTxtLocationDetails( lc.getFullId, lc );
					endif;
				endif;
			endif;
			
			if lc = null then
				if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
					lc := self.myTrackedItem.myPrimaryQueuedLocation;
				elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
					lc := self.myTrackedItem.myPrimaryPlannedLocation ;
				endif;
			endif;
			
			if lc &lt;&gt; null then
				self.setTxtLocationDetails( lc.getFullId, lc );
			endif;	
			
		endif;
				
		if self.txtLocation.text = null then
			self.resetLocationDisplay();
		endif;
		
		app.myMobileCargoFindAgent.clearHistory(true);
		
	endif;
	
	self.setupTblWles();
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="resetLocationDisplay" id="40eafb9f-5a64-4a39-bb6f-fa3551d77ee9">
        <source>resetLocationDisplay();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

begin
	
	self.setTxtLocationDetails( self.lblLocation.caption.toUpper, null );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="96139c83-aece-4068-8885-5c3c2bfc30f3">
        <updating/>
        <source>selectCargoItem( manual : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
	trackedItems : CM_TIArray;	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	onWagonCargoArray : CM_TIArray;
	onWagonCargoDict : CM_TIByIdCargoTypeDict;
	onWagonCargoDictRev : CM_TIByIdCargoTypeDictRev;
	lc : CM_LocationsController;
	
begin

	
	
	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.id &lt;&gt; cargoId then
			self.myMobileGenericAgent.setSplitValues( 0, 0, null );
		endif;
	endif;
	
	self.setMyTrackedItem(	null, null );
	self.lblCargoType.caption := null;
	self.lblCargoDesc.caption := null;	//02 Aug 2013	NDL	Par 32156
	self.txtQuantity.text := null;
//	self.txtNewCargoId.text := null;
	
	term := self.myMobileDataAgent.myTerminal;
	wagon := self.myMobileGenericAgent.myCurrentWagon;
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;	

		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
		
			firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
			if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
				iter := term.allOnsiteTIsByIdCargoType.createIterator;
				iter.startAtObject(firstTi);
				while iter.next( ti ) do
					if ti.id[1:cargoIdLength] &lt;&gt; cargoId then	
						break;
					endif;
					tiArray.addExclusive(ti);
				endwhile;
				delete iter;
			endif;
			
			if tiArray.isEmpty and not term.allOnsiteTIsByIdCargoType.isEmpty then
				create revDict transient;
				term.allOnsiteTIsByIdCargoType.copy( revDict );
				firstTi := revDict.getAtKeyGeq(cargoIdReversed,null);
				if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
					iter := revDict.createIterator;
					iter.startAtObject(firstTi);
					while iter.next( ti ) do
						if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
							break;
						endif;
						tiArray.addExclusive(ti);
					endwhile;
					delete iter;
				endif;
				delete revDict;
			endif;
			
		endif;
		
		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
		
			create onWagonCargoArray transient;
			create onWagonCargoDict transient;
			create onWagonCargoDictRev transient;
			wagon.getAllTrackedItems( true, onWagonCargoArray, false );
			if not onWagonCargoArray.isEmpty then
				onWagonCargoArray.copy( onWagonCargoDict );
				onWagonCargoArray.copy( onWagonCargoDictRev );
			endif;
			
			firstTi := onWagonCargoDict.getAtKeyGeq(cargoId,null);
			if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
				iter := onWagonCargoDict.createIterator;
				iter.startAtObject(firstTi);
				while iter.next( ti ) do
					if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
						break;
					endif;
					tiArray.addExclusive(ti);
				endwhile;
				delete iter;
			endif;
		
			if tiArray.isEmpty then
				firstTi := onWagonCargoDictRev.getAtKeyGeq(cargoIdReversed,null);
				if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
					iter := onWagonCargoDictRev.createIterator;
					iter.startAtObject(firstTi);
					while iter.next( ti ) do
						if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
							break;
						endif;
						tiArray.addExclusive(ti);
					endwhile;
					delete iter;
				endif;
			endif;
			
			delete onWagonCargoDict;
			delete onWagonCargoArray;
			delete onWagonCargoDictRev;
		
		endif;
		
	endif;
		
	if not manual and tiArray.isEmpty then
		return;
		
	elseif tiArray.size = 1 then
		self.setMyTrackedItem(	tiArray.first, null );
		populateTrackedItem();
		return;
		
	else		
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate(true);
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_UNDEFINED);
		
		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
			//lc := wagon.allLocationsControllers.first;
			lc := wagon.allLocationsControllersArray[1];	//04 Dec 2014	NDL	Par 35345
			app.myMobileCargoFindAgent.setMyYardLoc(lc);
		endif;
		
		//02 Apr 2014	NDL	CCMS 1366
		if self.txtQuantity.visible then
			app.myMobileCargoFindAgent.setStringField2(self.txtQuantity.text.trimBlanks);
		else
			app.myMobileCargoFindAgent.setStringField2(null);
		endif;
		if self.tblWeightVolume.visible then
			app.myMobileCargoFindAgent.setDecimalField1(self.tblWeightVolume.getConvertedValue);
		else
			app.myMobileCargoFindAgent.setDecimalField1(0.00);
		endif;
		
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.myMobileGenericAgent.setMyWle(null);
		self.gotoForm( MOB_HHCargoFind, false );
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete trackedItems;
	delete revDict;	
	delete onWagonCargoArray;
	delete onWagonCargoDict;
	delete onWagonCargoDictRev;

end;</source>
        <Parameter name="manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLBLQuantityCaption" id="58c7c1ca-5670-49c9-a389-b966bf48bb64">
        <updating/>
        <source>setLBLQuantityCaption() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2013	cnwndl1	Initial creation

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

	job : CM_Job;
	wle : CM_WorkListEntry;
	quantity : Integer;
	locale	: CM_Locale;

begin

	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.canMergeBreakBulk then
		wle := self.myWorkListEntry;
		if wle = null then
			self.getRailJobWLE( job, wle, false); 
		endif;
		if wle = null then
			quantity := self.myTrackedItem.totalQuantity;
		else
			quantity := wle.quantity;
		endif;
	endif;
	
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
	endif;
	
	if self.myTrackedItem = null
	or ( not self.myTrackedItem.isBulkByWeight and not self.myTrackedItem.isBulkByVolume )
	then
	
		self.lblQuantity.translateCaption(Xlat_0019105, locale);
		
		if quantity &gt; 0 then
			self.lblQuantity.caption := self.lblQuantity.caption &amp; " (" &amp; quantity.String &amp; ")";
		endif;
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="547fea36-2785-4f66-981f-bd4ff564efa1">
