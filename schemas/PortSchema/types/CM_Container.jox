    <JadeMethod name="isAttributeTrue" id="1d8d619d-f061-4e3a-99de-d8ba9b7f383e">
        <source>isAttributeTrue(attribToTest: Integer): Boolean;
/*
 ------------------------------------------------------------------------
Created:			19 October 2001 by cnwdwq1
Purpose:			Generic method on CM_TrackedItem and re-implimented here to return whether
							a property is valid or not. Passed in a constant of type TIAttributeTest to do the work.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------		----------		-----------------------------------------
02/12/2009		cnwdap1			CCMS MES 1007 moved reefer properties up to CM_TrackedItem level
---------------------------------------------------------------------------
*/
vars

begin
	
	// do is40 test first as it is one of the most
	// frequently called ones
	if attribToTest = TI_Attrib_IsForty then
		return self.is40;
	elseif attribToTest = TI_Attrib_IsFortyFive then
		return self.is45();
	elseif attribToTest = TI_Attrib_IsThirty then
		return self.is30();
	elseif attribToTest = TI_Attrib_IsFiftyThree then
		return self.is53();
	elseif attribToTest = TI_Attrib_IsFantainer then
		return self.isFantainer;
	//elseif attribToTest = TI_Attrib_IsChilled then			// CCMS 1007
	//	return self.isChilled;									// CCMS 1007
	//elseif attribToTest = TI_Attrib_RequiresPower then		// CCMS 1007
	//	return self.requiresPower;								// CCMS 1007
	//elseif attribToTest = TI_Attrib_IsReefer then				// CCMS 1007
	//	return self.isReefer;									// CCMS 1007
	elseif attribToTest = TI_Attrib_IsHiCubed then
		return self.isHighCube;
	elseif attribToTest = TI_Attrib_IsHeavyDuty then
		return self.isHeavyDuty;
	elseif attribToTest = TI_Attrib_IsOverStowed then
		return self.isOverStowed(REAL_MODE);
	//elseif attribToTest = TI_Attrib_RequiresTemperature then	// CCMS 1007
	//	return self.requiresTemperature;						// CCMS 1007
	//elseif attribToTest = TI_Attrib_MonitorConnection then	// CCMS 1007
	//	return self.monitorConnection;							// CCMS 1007
	elseif attribToTest = TI_Attrib_IsIntegral then
		return self.isIntegral;
	elseif attribToTest = TI_Attrib_HasCOU then
		return self.hasCOU;
	elseif attribToTest = TI_Attrib_IsClean then
		return self.isClean;
	// no longer an attribute
	//elseif attribToTest = TI_Attrib_IntendedForOffsite then
	//	aStop := self.myTerminal.getConfig(ConfigStopIntendedOffsite).CM_StopsTable; // CCMS 1051 AKB2002AUGUST
	//	return self.isStopSet(aStop.id); // CCMS 1051 AKB2002AUGUST

//		return self.intendedForOffsite;
	//elseif attribToTest = TI_Attrib_IsConnected then			// CCMS 1007
	//	return self.isConnected;								// CCMS 1007
	elseif attribToTest = TI_Attrib_IsEmpty then
		return self.contentsStatus = TI_CONTENTS_STATUS_EMPTY;
	//elseif attribToTest = TI_Attrib_IsPortHole then			// CCMS 1007
	//	return self.isPortHole;									// CCMS 1007
	//elseif attribToTest = TI_Attrib_IsWaterCooled then		// CCMS 1007
	//	return self.getCoolingType = ContainerWaterCooled; 		// CCMS 1007
	elseif attribToTest = TI_Attrib_IsLCL then
		return self.contentsStatus = TI_CONTENTS_STATUS_LCL;
	elseif attribToTest = TI_Attrib_IsFCL then
		return self.contentsStatus = TI_CONTENTS_STATUS_FCL;
	elseif attribToTest = TI_Attrib_IsHalfHeight then
		return (self.sizeAttributes.bitAnd(ISO_HALF_HEIGHT) &lt;&gt; 0 );
	else
		return inheritMethod(attribToTest);
	endif;

end;</source>
        <Parameter name="attribToTest" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvGradeSuitableForRelease" id="21c88b9e-37f1-4fb3-ae44-36e450be2282">
        <source>isAvGradeSuitableForRelease(): Boolean;

/*

Purpose:			For use in Report Writer		

Parameters:			

Return Value:		


Date		Who		Reason
22 March 2012	cnwndl1	Initial creation	Par 29320 / CCMS 2140

*/

vars

	grade : CM_MTGrade;

begin
	
	grade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];
	if grade = null then
		return false;
	endif;
	
	return grade.isSuitableForRelease;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvailable" id="dbc0f756-152b-4cce-8194-698207730d9d">
        <methodInvocation>mapping</methodInvocation>
        <source>isAvailable(set: Boolean; _value: Boolean io) mapping;

vars
	grade 	: CM_MTGrade;
	ti 		: CM_TrackedItem;
	errString	: String;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	// cnwrd1 15.12.2011  par 28810 //cnwrd1 par 28935 19.01.2012
	_value := self.isAvailableForSubTerminal(null,errString, false);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isAvailableForSubTerminal" id="735724a2-88f1-4739-aa13-9f89b4aeb2fa">
        <source>isAvailableForSubTerminal(_subterm: CM_SubTerminal; _errString: String output; _isInternal : Boolean): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2011	cnwrd1	Initial creation
// cnwrd1 15.12.2011  par 28810
*/

vars
	grade 	: CM_MTGrade;
	ti 		: CM_TrackedItem;
	result : Boolean;
begin
	
	if self.isChild then
		//Child is always same availability as parent
		ti := self.getParent;
		result := ti.isAvailableForSubTerminal(_subterm, _errString, _isInternal) ;
		return result;
	endif;
	
	result := inheritMethod(_subterm, _errString, _isInternal);
		
	if not _isInternal then //cnwrd1 par 28935 - only test if we are not on an internal move. The ava grade for intrnal move is tested later.
		if contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			grade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];
			if grade &lt;&gt; null and grade.isSuitableForRelease = false then
				result := false;
				_errString := _errString &amp; '. Grade Not suitable for release';
				return result;
			endif;
		endif;	
	endif;
	
	return result;
epilog

end;</source>
        <Parameter name="_subterm" type="CM_SubTerminal"/>
        <Parameter name="_errString" type="String" usage="output"/>
        <Parameter name="_isInternal" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBoxToBeWeighed" id="7f164fff-79ad-405f-b2b9-64cf01548418">
        <source>isBoxToBeWeighed(_terminal: CM_Terminal): Boolean;

// Created by cnwdvb1 on 11 October 2006

vars

	operatorTerminal : CM_OperatorTerminal;

begin
	if not self.myCargoType.isWeighable then
		return false;
	endif;
	
	if not app.getMyUser.canDo(_terminal, Mod_Weighing) then
		return false;
	endif;

	if self.hasToDoTasksWithTransClass(TRANS_TYPE_WEIGH, false) then	// 04/11/2010 cnwar2 #26198
	//if self.hasToDoTasksWithTransClass(CM_Weighed, false) then
		return true;
	elseif self.weighStatus = WEIGH_STATUS_FORCED then
		return true;
	elseif self.weighStatus = WEIGH_STATUS_WEIGHED then
		return false;
	else
		if self.myOperator &lt;&gt; null and _terminal &lt;&gt; null then
			operatorTerminal := self.myOperator.allOperatorTerminals[_terminal];
		endif;

		// CCMS 1489
		if self.isTranshipItem then
			if operatorTerminal = null or operatorTerminal.weighTranships then
				return true;
			endif;
		elseif self.isExport then
			if (self.contentsStatus = TI_CONTENTS_STATUS_FCL) or self.contentsStatus = TI_CONTENTS_STATUS_LCL then
				if self.myOperator = null or (operatorTerminal &lt;&gt; null and operatorTerminal.weighExports) then
					return true;
				endif;
			elseif self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
				if self.myOperator = null or (operatorTerminal &lt;&gt; null and operatorTerminal.weighMTExports) then
					return true;
				endif;
			endif;
		elseif self.isImport then
			if (self.contentsStatus = TI_CONTENTS_STATUS_FCL or self.contentsStatus = TI_CONTENTS_STATUS_LCL) then
				if self.myOperator = null or (operatorTerminal &lt;&gt; null and operatorTerminal.weighImports) then
					return true;
				endif;
			elseif self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
				if self.myOperator = null or (operatorTerminal &lt;&gt; null and operatorTerminal.weighMTImports) then
					return true;
				endif;
			endif;
		endif;
	endif;

	return false;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
