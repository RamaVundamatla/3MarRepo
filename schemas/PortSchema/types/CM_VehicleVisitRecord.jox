    <JadeMethod name="addAdjCommentToLastUnLoaded" id="201602d3-7086-423d-95fe-018cbcb5e0a6">
        <source>addAdjCommentToLastUnLoaded();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2018	jlgndl1	Initial creation	TFS 41180

*/

vars

	vvrd : CM_VehicleVisitRecordDetail;
	vvrdToAdjust : CM_VehicleVisitRecordDetail;
	str : String;
	
begin
	
	foreach vvrd in self.allVehicleVisitRecordDetails reversed do
		if vvrd.recordType = VisitRecord_CargoRemoved then
			vvrdToAdjust := vvrd;
			break;
		endif;
	endforeach;
	
	if vvrdToAdjust &lt;&gt; null then
		str := app.getErrorString(Hand_held_truck_unload_adjust);
		vvrdToAdjust.addAdjustmentComment( str );
	endif;


epilog

end;</source>
    </JadeMethod>
