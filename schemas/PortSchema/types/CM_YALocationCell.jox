    <JadeMethod name="delete" id="92a80e78-ddd0-4e54-82f7-e602822645c0">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2012	cnwndl1	Initial creation	Par 29604

*/

vars

	deckingOpt : CM_YADeckingOptions;

begin

	if self.allMyDeckingOptions &lt;&gt; null and not self.allMyDeckingOptions.isEmpty then
		foreach deckingOpt in self.allMyDeckingOptions do
			if deckingOpt.allYALocationCellsIn &lt;&gt; null
			and deckingOpt.allYALocationCellsIn.includes( self ) then
				deckingOpt.allYALocationCellsIn.remove( self );
			endif;
			if deckingOpt.allYALocationCellsOut &lt;&gt; null
			and deckingOpt.allYALocationCellsOut.includes( self ) then
				deckingOpt.allYALocationCellsOut.remove( self );
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
