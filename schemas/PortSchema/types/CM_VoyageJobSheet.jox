    <JadeMethod name="createOOWAuto" id="a3bd4987-37c6-45fe-80ad-eec626f28195">
        <source>createOOWAuto(_controller : CMIF_VoyageJobParams input);
// ### passed in CMIF_VoyageJobParams is only used to report back TL changes
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ooc	: CM_OOWCreation;
	oowc : CM_OOWCreationDetail;
	oowd : CM_OOWCreationDetail;
	lastBay, aBay : CM_BayVoyage;
	tmpBay : CM_Bay;
	lastDeck : Integer;
	lastHold, aHold : CM_Hold;
	craneType : Integer;
	aCrane : CM_Crane;
	get40 : Boolean;
	aTerm : CM_Terminal;
	theBays : CM_BayArray;
	sepODUDJobs,craneJnt2040L, craneJnt2040D, makeJob : Boolean;
	isDisch, lastOOWCWasDischarge, craneJntSobDisch : Boolean;
	numItems, minItems : Integer;
	aSR : CM_SlotRequest;
	srSetTmp, srSet : CM_SlotRequestSet;
begin
	
	aTerm := self.myVoyage.myTerminal;
	if aTerm &lt;&gt; null then
		sepODUDJobs := aTerm.getConfig(SeparateOnUnderDeckJobs).Boolean;
	else
		sepODUDJobs := true;
	endif;
	
	if not _controller.isTransientJob then
		self.eraseAllJobs();
	endif;
	
	create theBays transient;
	create srSet transient;
	create srSetTmp transient;
	
	aCrane := self.getMyCrane();
	
	//if aCrane.canTwinLift then
	if aCrane.machineLiftType = TWIN_LIFT then//ccms1595 27/11/07
		craneType := JobTypePriority_Crane2;
	elseif aCrane.machineLiftType = NORMAL_LIFT then
		craneType := JobTypePriority_Crane1;
	endif;

	craneJntSobDisch := self.myVoyage.myCellularVoyageStructure.getOOWSameJobForSOBDisch(craneType);
	
	minItems := aCrane.minItemsForTLJob;
	
	// ### these are how the users have organised the colour coding by bay OD and UD.
	foreach ooc in self.allOOWCreations do
		oowc:=ooc.CM_OOWCreationDetail;
		aBay := oowc.myBay;
		aHold := aBay.myHold;

		
		craneJnt2040L := oowc.doJoint2040Jobs(false);
		craneJnt2040D := oowc.doJoint2040Jobs(true);
		
		if aCrane.machineLiftType = NORMAL_LIFT then//ccms1595 27/11/07
			// PAR 30003
			if oowc.isLoad() then
				if craneJnt2040L then
					// TAKE 2 change to use hold. // makeJob := (lastBay &lt;&gt; aBay  and lastBay &lt;&gt; null );
					makeJob := (lastHold &lt;&gt; null and lastHold &lt;&gt; aHold);
				else
					makeJob := true;
				endif;
			endif;
			if oowc.isDischarge() then
				if craneJnt2040D then
					//makeJob := (lastBay &lt;&gt; aBay  and lastBay &lt;&gt; null );
					makeJob := (lastHold &lt;&gt; null and lastHold &lt;&gt; aHold);
				else
					makeJob := true;
				endif;
			endif;
			// PAR 30003 makeJob := true;
		endif;		

		if not srSet.isEmpty()
		and ((lastHold &lt;&gt; null and lastHold &lt;&gt; aHold) 
			or (sepODUDJobs and (lastDeck &lt;&gt; 0 and oowc.ordinalDeck &lt;&gt; lastDeck))
			or makeJob  
			or (lastOOWCWasDischarge = oowc.isLoad())) then
//######
			// CCMS 1529
			if (numItems &gt; 0 and minItems &gt; 0) 
			and (numItems &lt; minItems) 
			and theBays.size &gt; 1 // 2 bays worth
			and not get40 then // 20s only
				// split into 2 seperate jobs one for each bay
				foreach tmpBay in theBays do
					
					srSetTmp.clear;
					foreach aSR in srSet do
						if aSR.myBay = tmpBay then
							srSetTmp.add(aSR);
						endif;
					endforeach;
					if not srSetTmp.isEmpty then
						isDisch := srSetTmp.first.isDischarge;
						self.createOOWAutoJob(srSetTmp, isDisch, tmpBay, null, null,null,null, null, _controller);
					endif;
				endforeach;
			else	
				isDisch := srSet.first.isDischarge;
				self.createOOWAutoJob(srSet, isDisch, lastBay, null, null,null,null, null, _controller);
			endif;

//######

			
			srSet.clear;
			theBays.clear;
			get40 := false;
			numItems := 0;
		endif;

		if get40 = false then
			get40 := oowc.is40;
		endif;

		oowc.allSlotRequests.copy(srSet);
		if not theBays.includes(aBay) then
			theBays.add(aBay);
		endif;
		
// PAR 30003		craneJnt2040L := oowc.doJoint2040Jobs(false);
// PAR 30003		craneJnt2040D := oowc.doJoint2040Jobs(true);
		
		// CCMS 1529
		if oowc.isLoad() then
			numItems := numItems + oowc.getTotalItems();
		endif;
		
		
		// need to add in here the possible setting of 1 job for OD and UD.
		//cnwmc5 - 25 July 2014 - PAR 34455
		if oowc.isLoad() then
			if not craneJnt2040L then
				makeJob := oowc.makeSeperateJobFor20And40ByBay(aBay);
			endif;
		endif;
		if oowc.isDischarge() then
			if not craneJnt2040D then
				makeJob := oowc.makeSeperateJobFor20And40ByBay(aBay);
			endif;
		endif;
		
		
	/*	 PAR 30003
		//if not aCrane.canTwinLift then
		if aCrane.machineLiftType = NORMAL_LIFT then//ccms1595 27/11/07
			PAR 30003 makeJob := true;
		endif;
		*/
		
	//	if oowc.isLoad() and aCrane.canTwinLift and not craneJnt2040L then // twin lift crane but seperate load jobs//ccms1595 27/11/07
		if oowc.isLoad() and aCrane.machineLiftType = TWIN_LIFT and not craneJnt2040L then // twin lift crane but seperate load jobs
			if not get40 then // this is a load 20 job
				oowd := oowc.getNextOOWC();
				if oowd &lt;&gt; null and oowd.is40 then // next is a 40
					makeJob := true;
				endif;
			else
				makeJob := true;
			endif;
		endif;
		//if oowc.isDischarge() and aCrane.canTwinLift and not craneJnt2040D then // twin lift crane but seperate discharge jobs//ccms1595 27/11/07
		if oowc.isDischarge() and aCrane.machineLiftType = TWIN_LIFT and not craneJnt2040D then // twin lift crane but seperate discharge jobs
			if not get40 then // this is a discharge 20 job
				oowd := oowc.getNextOOWC();
				if oowd &lt;&gt; null and oowd.is40 then // next is a 40
					makeJob := true;
				endif;
			else
				makeJob := true;
			endif;
		endif;

		lastHold := aHold;
		lastBay := aBay;
		lastDeck := oowc.ordinalDeck;
		if craneJntSobDisch then
			lastOOWCWasDischarge := (oowc.isDischarge() or oowc.isSOB());
		else
			lastOOWCWasDischarge := oowc.isDischarge() ;
		endif;
	endforeach;

//######
	// CCMS 1529
	if (numItems &gt; 0 and minItems &gt; 0) 
	and (numItems &lt; minItems) 
	and theBays.size &gt; 1 // 2 bays worth
	and not get40 then // 20s only
		// split into 2 seperate jobs one for each bay
		foreach tmpBay in theBays do
			
			srSetTmp.clear;
			foreach aSR in srSet do
				if aSR.myBay = tmpBay then
					srSetTmp.add(aSR);
				endif;
			endforeach;
			if not srSetTmp.isEmpty then
				isDisch := srSetTmp.first.isDischarge;
				self.createOOWAutoJob(srSetTmp, isDisch, tmpBay, null, null,null,null, null, _controller);
			endif;
		endforeach;
	else	
		if not srSet.isEmpty() then  // PAR 16952
			isDisch := srSet.first.isDischarge;
			self.createOOWAutoJob(srSet,isDisch, lastBay, null, null,null,null, null, _controller);
		endif;
	endif;

//######



epilog
	delete theBays;
	delete srSet;
	delete srSetTmp;
end;</source>
        <Parameter name="_controller" type="CMIF_VoyageJobParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createOOWAutoCraneJobs" id="67edec55-85a2-45d4-bf5a-9c166301d088">
        <source>createOOWAutoCraneJobs();
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	boomBay, lastBay,aBay, bay2 : CM_Bay;
	boomIdx, lastDeck, insIndex : Integer;
	lastHold, aHold, holdBeforeBridge : CM_Hold;
	jobIdx : Integer;
	aCrane : CM_Crane;
	aTerm : CM_Terminal;
	autoBoomUp, autoLid : Boolean;
	boomJob, removeJob, replaceJob, longTravel : CM_JobType;
	hatchCodes, lidCode, jobID, bay1ID, bay2ID : String;
	aJob : CM_Job;
	vJob, lastJob, newJob : CM_VoyageJob;
	underDeckJobd, holdChange, deckChange, boomJobDone : Boolean;
	isTheOowReversed : Boolean;
	tmpJobs : CM_JobArray;
begin
	aTerm := self.myVoyage.myTerminal;
	if aTerm &lt;&gt; null then
		autoBoomUp := aTerm.getConfig(AutoCreateBoomUpJob).Boolean;
		autoLid := aTerm.getConfig(AutoCreateHatchLidJob).Boolean;
	else
		autoBoomUp := true;
		autoLid := true;
	endif;
	
	if not autoBoomUp and not autoLid then
		return;
	endif;
	
	create tmpJobs transient;
	self.allJobsByOrder.copy(tmpJobs);
	
	aCrane := self.getMyCrane();
	
	boomJob := aCrane.allHatchJobTypes[CM_Crane.HatchJobType_BoomUp];
	removeJob := aCrane.allHatchJobTypes[CM_Crane.HatchJobType_LidRemove];
	replaceJob := aCrane.allHatchJobTypes[CM_Crane.HatchJobType_LidReplace];
	longTravel :=  aCrane.allHatchJobTypes[CM_Crane.HatchJobType_LongTravel];  // PAR 20474
	
	isTheOowReversed:=self.isOOWReversed;  //epr par 23024
	holdBeforeBridge := self.myVoyage.myCellularVoyageStructure.getHoldBeforeBridge(); // PAR 14278
	
	foreach aJob in tmpJobs do
		vJob := aJob.CM_VoyageJob;
		
		vJob.getBays(aBay,bay2);
		
		jobID := vJob.jobId;
		if aBay &lt;&gt; null then 	bay1ID := aBay.id; endif;
		if bay2 &lt;&gt; null then bay2ID := bay2.id; endif;
		
		aHold := aBay.myHold;
		
		holdChange := (boomJob &lt;&gt; null	and autoBoomUp and (lastHold &lt;&gt; null and lastHold &lt;&gt; aHold));
		deckChange := (autoLid 
						// the deck has changed OR the first job is under deck
						and ((lastDeck &lt;&gt; 0 and vJob.ordinalDeck &lt;&gt; lastDeck) or (lastDeck = 0 and vJob.ordinalDeck = DeckUnderDeck)));

		if holdChange 
		or deckChange then
			if underDeckJobd then
				
				if holdChange then
					insIndex := self.allJobsByOrder.indexOf(vJob);
					if insIndex &lt; 1 then
						insIndex := 0;
					endif;
				else
					jobIdx := self.allJobsByOrder.indexOf(lastJob);
					insIndex :=  jobIdx + 1;
				endif;


				newJob := self.createOOWAutoJob(null, false, lastBay, replaceJob, null,insIndex,"REPLACE " &amp; hatchCodes &amp; " " &amp; lidCode, hatchCodes, null);
				self.removeJob(newJob);
				self.addJob(newJob, insIndex);
				hatchCodes := null;
				insIndex := insIndex + 1; // keep this incase of a follow up BOOM UP
			endif;
			underDeckJobd := false;

		endif;
		if holdChange
		or deckChange then
			if vJob.ordinalDeck = DeckUnderDeck and aHold.allHatchLids.size &lt;&gt;  0 then //epr 23/4/07 par 13892
			

				if holdChange then
					insIndex := self.allJobsByOrder.indexOf(vJob);
					if insIndex &lt; 1 then
						insIndex := 0;
					endif;
				else
					insIndex := self.allJobsByOrder.indexOf(lastJob) + 1;
				endif;
				hatchCodes := aBay.CM_BayVoyage.getHatchLidCodeForUDJobs();
				if hatchCodes.length = 1 then
					lidCode := "LID";
				else
					lidCode := "LIDS";
				endif;
				newJob := self.createOOWAutoJob(null, false, aBay, removeJob, null,insIndex,"REMOVE " &amp; hatchCodes &amp; " " &amp; lidCode, hatchCodes, null);
				underDeckJobd := true;
				
				self.removeJob(newJob);
				self.addJob(newJob, insIndex);
				insIndex := insIndex + 1; // PAR 13980 keep this incase of a follow up BOOM UP
			endif;		
			
			// ### BOOM
			if holdChange then
				if not boomJobDone // PAR 14278
				and holdBeforeBridge &lt;&gt; null then
					if ((isTheOowReversed) // PAR 15604
					and (holdBeforeBridge.ordinalHold &gt;= aHold.ordinalHold)) // PAR 15604     // PAR 18640 add =
					and (lastHold.ordinalHold &gt; holdBeforeBridge.ordinalHold) then // PAR 16419
						boomIdx := self.myVoyage.myCellularVoyageStructure.allHolds.indexOf(holdBeforeBridge); // PAR 18640  removed '+ 1' after indexOf();
						if boomIdx &lt;= self.myVoyage.myCellularVoyageStructure.allHolds.size then	//Par15788
							boomBay := self.myVoyage.myCellularVoyageStructure.allHolds[boomIdx].allBays.last;
							
							if lastHold.ordinalHold &gt; boomIdx then // PAR 16419
								insIndex := self.allJobsByOrder.indexOf(vJob); // PAR 16419
								if vJob.bayId  = self.allJobsByOrder[insIndex - 1].CM_VoyageJob.bayId then // PAR 18640
									insIndex := insIndex - 1; // PAR 18640
								endif;
							else
								insIndex := self.allJobsByOrder.indexOf(lastJob); // PAR 15411
							endif;
							
							newJob := self.createOOWAutoJob(null, false, boomBay, boomJob, null,insIndex, null, null, null);
							boomJobDone := true; // PAR 14278
							self.removeJob(newJob);
							self.addJob(newJob, insIndex);
						endif;
					elseif ((not isTheOowReversed)// PAR 15604
					and (holdBeforeBridge.ordinalHold &lt; aHold.ordinalHold)  // PAR 14278 PAR 15551 - removed '='
					and (lastHold.ordinalHold &lt;=  holdBeforeBridge.ordinalHold)) then //epr tfs 5151 25/7/17
						boomBay := holdBeforeBridge.allBays.last;
						insIndex := self.allJobsByOrder.indexOf(vJob); // PAR 15411
						if vJob.bayId  = self.allJobsByOrder[insIndex - 1].CM_VoyageJob.bayId then // PAR 18640
							insIndex := insIndex - 1; // PAR 18640
						endif;
						newJob := self.createOOWAutoJob(null, false, boomBay, boomJob, null,insIndex, null, null, null);
						boomJobDone := true; // PAR 14278
						self.removeJob(newJob);
						self.addJob(newJob, insIndex);
					endif;
						
						
				endif;
			endif;
			
		endif;
		
		
		lastHold := aHold;
		lastBay := aBay;
		lastDeck := vJob.ordinalDeck;
		lastJob := vJob;
		holdChange := false;
	endforeach;

	if underDeckJobd then
		insIndex := self.allJobsByOrder.size + 1; // PAR 13883 force this job to be the last.
		newJob := self.createOOWAutoJob(null, false, lastBay, replaceJob, null,insIndex,"REPLACE " &amp; hatchCodes &amp; " " &amp; lidCode, hatchCodes, null);
	endif;

epilog
	delete tmpJobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="createOOWAutoJob" id="45ce53a0-4c52-42a3-88bf-9ccd7e927a3f">
        <source>createOOWAutoJob(_requests : CM_SlotRequestSet; _isDischarge : Boolean; _bay : CM_Bay; 
					_jobType : CM_JobType; _oowcs : CM_OOWCreationByOrdinal; _idx : Integer; _remarks : String; _hatchCodes : String;
					_controller : CMIF_VoyageJobParams input) : CM_VoyageJob;
// ### passed in CMIF_VoyageJobParams is only used to report back TL changes
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theJobParams : CMIF_VoyageJobParams;
	theNewVoyageJob, theProxyVJob : CM_VoyageJob;
	firstJob, newJobID, bayID : String;
	oowc : CM_OOWCreation;
	aReq : CM_SlotRequest;
	idx : Integer;
	tmpTI : CM_TrackedItem;
begin
//	create theProxyVJob transient;
	if _jobType = null 
	and _requests &lt;&gt; null
	and _requests.isEmpty then
		return null;
	endif;

		
	if _idx = 1 and _jobType &lt;&gt; null then // PAR 13883
		// PAR 13883 must be a remove hatch lid and its to be the very first job.
		firstJob := self.allJobsByOrder.first.id;
		if not firstJob.isInteger() then
			newJobID := "00";
		else
			if firstJob.Integer &gt; 1 then
				newJobID := (firstJob.Integer - 1).String &amp; "H"; // PAR 13883
			else
				newJobID := "00";
			endif;
		endif;
	elseif _idx &lt;&gt; null and _jobType &lt;&gt; null then
		newJobID := self.getNextJobNumberSuffix(_idx - 1);
		
	else
		newJobID := self.myVoyage.getNextJobNumber(self, self.getMyWorkPointObject().IF_VoyageWorkPoint).String; // next id
	endif;

	create theJobParams transient;
	theJobParams.useNewMethod 	:= false;// PAR 14420
	theJobParams.isDischarge		:=	_isDischarge;
	theJobParams.craneID			:=	self.crane;
	theJobParams.myVoyage			:=	self.myVoyage;
	theJobParams.myProxyJob		:=	null;
	theJobParams.resquence			:=	true;	
	theJobParams.isSeqForJob		:=	false;
	theJobParams.usedByOOWCreation := true;
	theJobParams.myBay 			:= _bay;
	theJobParams.autoSortIntoOOW	:= true;
	theJobParams.id 				:= newJobID;
	theJobParams.myJobType 		:= _jobType;
	theJobParams.holdNote := true;
	if _controller &lt;&gt; null then
		theJobParams.isTransientJob  := _controller.isTransientJob;
	endif;
	
	theJobParams.myJobSheet := self;
	
	if not _isDischarge then //only for load jobs
		theJobParams.allowOutOfOrderLoading := self.myVoyage.createOutOfSequenceLoadJobs();  //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;

	if _jobType &lt;&gt; null and _jobType.isHatchType then
		theJobParams.remarks 		:= _remarks;
		theJobParams.setHatchLidsFromCode(_hatchCodes);
	endif;
	if _requests &lt;&gt; null then
		if not _requests.isEmpty then
			bayID := _requests.first.CM_SlotRequest.myBay.id;
		endif;
//		_requests.copy(theJobParams.allSlotRequests); // PAR 13904
		// PAR 13904 changed to setting the slot controllers
		foreach aReq in _requests do
			theJobParams.allSlotControllers.add(aReq.mySlotController);
			theJobParams.allObjectEditions.add(aReq.mySlotController);
			
		endforeach;
	endif;
	theJobParams.setRequests(); // PAR 14420
	app.myUtilityCA.utlCreateVoyageJob(theJobParams, theNewVoyageJob, app.myPassport);
	
	if _controller &lt;&gt; null then
		foreach tmpTI in theJobParams.allTIs do
			idx := idx + 1;
			if not _controller.allTIs.includes(tmpTI) then
				_controller.allTIs.add(tmpTI);
				_controller.allReasons.add(theJobParams.allReasons[idx]);
			endif;
		endforeach;
	endif;
	return theNewVoyageJob;
epilog
	delete theJobParams.myProxyJob;
	delete theJobParams;
end;</source>
        <Parameter name="_requests" type="CM_SlotRequestSet"/>
        <Parameter name="_isDischarge" type="Boolean"/>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_jobType" type="CM_JobType"/>
        <Parameter name="_oowcs" type="CM_OOWCreationByOrdinal"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_hatchCodes" type="String"/>
        <Parameter name="_controller" type="CMIF_VoyageJobParams" usage="input"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="createOOWAutoRenumber" id="709f1f4c-bdbe-4721-90aa-db80541106c6">
        <source>createOOWAutoRenumber();

vars
	aJob : CM_Job;
	vJob : CM_VoyageJob;
	idx, increment, thePads, tmpSize, index : Integer;
	tmpArray : IntegerArray;
	workPointObject : CM_Object;
	tmpTerminal	: CM_Terminal;
begin

	tmpTerminal := self.getMyTerminal();
	if tmpTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminal is null for (' &amp; self.String &amp; ')');
		return;
	endif;
	if (not tmpTerminal.getConfig(AutoOOWJobRenumber).Boolean) then
		return;
	endif;

	create tmpArray transient;
	idx := 9999;
	foreach aJob in self.allJobsByOrder do
		index := index + 1;
		if aJob = null then
//			tmpArray.add(index);
			continue;
		endif;
		vJob := aJob.CM_VoyageJob;
		vJob.setJobNum(idx.String);
		idx := idx + 1;
	endforeach;
	
	tmpSize := tmpArray.size;
	if tmpSize &gt; 0 then
		foreach index in 1 to tmpSize reversed do
			self.allJobsByOrder.removeAt(tmpArray[index]);
		endforeach;
	endif;
	
	increment := tmpTerminal.getConfig(ShipJobNumberIncrement).Integer;
	if increment &lt; 1 then
		increment := 1;
	endif;
	
	workPointObject:=self.getMyWorkPointObject();
	if workPointObject = null then
		idx := 1;
	else
		idx := workPointObject.IF_VoyageWorkPoint.getJobSeed;
	endif;
	thePads := idx.String.length;
	foreach aJob in self.allJobsByOrder do
		if aJob = null then
			continue;
		endif;
		
		vJob := aJob.CM_VoyageJob;
		vJob.setJobNum(idx.String.padLeadingZeros(thePads));
		idx := idx + increment;
	endforeach;
epilog
	delete tmpArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="createOOWAutoSetJobs" id="19572d17-3ea9-494a-9b03-4127683b5419">
        <source>createOOWAutoSetJobs();
// ---------------------------------------------------------------------------
// Created:		08 November 2007 By Andrew Bishop cnwab1
//
