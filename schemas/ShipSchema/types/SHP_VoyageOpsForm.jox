    <JadeMethod name="mnuCargoTaskRemove_click" id="3d5f2ec5-247c-4dff-b974-56cafe252d5d">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoTaskRemove_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwndl1	Initial creation	Par 37011

*/

