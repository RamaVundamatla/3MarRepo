        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInfo_dragOver(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating;
//--------------------------------------------------
// Created:	08 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if app.myMoveController &lt;&gt; null then
