//				in the caption "40 Total" according to the Terminal Configuration:
//					53'	: 	Not Included- caption = "40 Total"
//							Own column	- caption = "40/53 Total"
//							Other column- caption = "40/53 Total"
// --------------------------------------------------------------------------------------------

vars
	isOwn	: Boolean;
	
begin
	
	if app.is53IncludedForReportsAsColumn( isOwn ) then	//should "45" be included as part in the caption "40 Total" ?
		return true;	// we have '40/45 Total' column, when 45' is included as Own/Separate column
