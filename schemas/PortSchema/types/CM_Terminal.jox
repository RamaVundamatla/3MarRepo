    <JadeMethod name="hasBOLForType" id="fccc91ea-413f-4452-aac8-f4e812e78ca8">
        <source>hasBOLForType(_bolType : Integer) : Boolean;
/* ---------------------------------------------------------------------------
Created:     19 June 2008 by cnwrs2

Purpose:     Need to check if have any BOL's of a particular type
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpBOL	: CM_BOL;
begin

	tmpBOL := self.allBOLsReceivedByTypeNumberDT.getAtKeyGeq(_bolType, null, null);
	if tmpBOL &lt;&gt; null
	and tmpBOL.bolType = _bolType then
		return true;
	endif;

	
	tmpBOL := self.allBOLsReleasedByTypeNumberDT.getAtKeyGeq(_bolType, null, null);
	if tmpBOL &lt;&gt; null
	and tmpBOL.bolType = _bolType then
		return true;
	endif;

	return false;



epilog

end;</source>
        <Parameter name="_bolType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasDualGateVTA" id="ae8e99c6-5fe2-4a7d-9c85-86fda271d5bb">
        <source>hasDualGateVTA() : Boolean;
/*
Purpose:			
Return Value:	true if  any gates have inward or outward p-gate areas	

Date				Who		Reason
26 September 2006	cnwer1	Initial creation - PAR#xxxx
25/02/2010			cnwcs5	Changed to check gate rather than VTA to see if we have dual gates
*/
vars
	gate	: CM_Gate;
begin 
	foreach gate in self.allGates do
		if gate.hasPGateAreas_IN or
			gate.hasPGateAreas_OUT then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasDuplicateCodeVoyages" id="fc0ff600-759d-4a6e-b62f-8e6a46da3ef0">
        <source>hasDuplicateCodeVoyages( code : String ) : Boolean;
//-----------------------------------------------------------------------
//	Created:	12 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	voyage, lastVoyage			 	: CM_Voyage;
	iter							: Iterator;
begin
	iter := self.allVoyagesNew.createIterator();
	self.allVoyagesNew.startKeyGeq(code, null, iter);
	while iter.next(voyage) do
		if lastVoyage &lt;&gt; null then
			if lastVoyage.code = voyage.code then
				// more than one
				return true;
			else
				// code is unique
				return false;
			endif;
		endif;
		if lastVoyage = null then
			lastVoyage := voyage;
			continue;
		endif;
	endwhile;
	return false;
epilog
	delete iter;
end;</source>
        <Parameter name="code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasLocationActivityFor" id="f4b1f5d9-d160-46ab-8681-656e8ce6d178">
        <source>hasLocationActivityFor( _object : CM_Object ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	cargoType : CM_CargoType;
	operator : CM_Operator;
	locActTypes : IntegerArray;
	type : Integer;
	startObject : CM_EventTransaction;
	eventTrx : CM_EventTransaction;
	locActivity : CMEVT_LocationActivity;
	earliest : TimeStamp;
	iter : Iterator;

begin

	if _object = null then
		return false;
	elseif _object.isKindOf( CM_CargoType ) then
		cargoType := _object.CM_CargoType;
	elseif _object.isKindOf( CM_Operator ) then
		operator := _object.CM_Operator;
	endif;
	
	earliest := app.actualTimeAppServer.cnEcAddDays( ( self.getLocationActivityMaxDays() * -1 ) );
	
	create locActTypes transient;
	locActTypes.add( EVT_LocationBalance );
	locActTypes.add( EVT_LocationDiscrepDecrease );
	locActTypes.add( EVT_LocationDiscrepIncrease );
	locActTypes.add( EVT_LocationMove );
	
	iter := self.allEventsByTypeDateTime.createIterator;
	
	foreach type in locActTypes do
		iter.reset();
		startObject := self.allEventsByTypeDateTime.getAtKeyLss( type + 1, null ); //should be the last on of this type
		if startObject &lt;&gt; null and startObject.type = type then
			iter.startAtObject( startObject );
			while iter.back( eventTrx ) do
				if eventTrx.type &lt;&gt; type then
					break;
				endif;
				locActivity := eventTrx.CMEVT_LocationActivity;
				if locActivity.dateTime &lt; earliest then
					break;
				endif;
				if cargoType &lt;&gt; null then
					if cargoType = locActivity.getCargoType then
						return true;
					endif;
				elseif operator &lt;&gt; null then
					if operator = locActivity.getOperator then
						return true;
					endif;
				endif;
			endwhile;
		endif;
	endforeach;
	
	
	return false;

epilog

	delete iter;
	delete locActTypes;

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasNoCargoCheckItemsFor" id="de613aba-660a-47f6-8e06-d48db5508ad8">
