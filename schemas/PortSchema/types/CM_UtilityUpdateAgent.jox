        <source>utlUpdateSelectorQueryAccess( _pxyQuerySet : CM_SelectorQueryAccess; _queryColl : CM_MenuUserQueryArray input; _passport : CM_Passport input );
// ---------------------------------------------------------------------------
// Created:     15 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	realQuerySet	: CM_SelectorQueryAccess;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();
	
	_pxyQuerySet.pxyGetRealObjectAndEdition( realQuerySet, expectedEdition );

	if realQuerySet = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SelectorQueryAccess.name, null, null );
		return;
	endif;
	
	if realQuerySet.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Query Access Set', null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock( realQuerySet );
	
	realQuerySet.setForUpdate( _pxyQuerySet, _queryColl );

end;</source>
        <Parameter name="_pxyQuerySet" type="CM_SelectorQueryAccess"/>
