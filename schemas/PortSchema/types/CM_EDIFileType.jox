    <JadeMethod name="getName" id="21f4f4cb-5f9f-4f86-97bd-9011406a5886">
        <source>getName() : String;

vars
	returnStr		: String;
	
begin
	returnStr	:=	inheritMethod() &amp; Tab &amp;
					self.name.padBlanks( 25 ) &amp; Tab &amp;
					self.type.display &amp; Tab &amp;
					self.creationTime.cnEcShortFullFormat;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStopsTableFromHeading" id="30116271-798c-4240-86eb-912f24f64904">
        <source>getStopsTableFromHeading(_desc: String): CM_StopsTable;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2015	cnwrd1	Initial creation
Migrated up a class or two NDL Par 36543
*/

vars
	aStopsTable : CM_StopsTable;
	found : Boolean;
begin

	foreach aStopsTable in app.myRoot.allStopsTable
		where aStopsTable.heading.trimBlanks = _desc do
			return aStopsTable;
		break;
	endforeach;

	return null;
	
epilog

end;</source>
