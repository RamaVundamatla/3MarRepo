				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "00000005", "For BOL 5");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "JPHIJ", "For BOL 5");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "AUPKL", "For BOL 5"); 
			endif;
		endif;
    endforeach;
	self.assertEqualMsg(voyage1.allOnshipTIsByIdCargoType.size, 21, "Total number of on ship Tis");
	foreach ti in voyage1.allOnshipTIsByIdCargoType do
		if ti.billOfLading = "00000001" then
			self.assertEqualMsg(ti.cargoTypeDescr, "Motor Vehicle", "For Cargo On Ship 1"); 
			self.assertEqualMsg(ti.CM_Car.make, "HONDA", "For Cargo On Ship 1"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "", "For Cargo On Ship 1"); 
			self.assertEqualMsg(ti.billOfLading, "00000001", "For Cargo On Ship 1");
			self.assertEqualMsg(ti.dischargePort, "AUPKL", "For Cargo On Ship 1"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship 1"); 
			self.assertEqualMsg(ti.destinationPort, "", "For Cargo On Ship 1"); 
			self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship 1"); 
			self.assertEqualMsg(ti.weight.String, "1851.0000", "For Cargo On Ship 1"); 
			self.assertEqualMsg(ti.totalVolume.String, "15.9620", "For Cargo On Ship 1"); 
