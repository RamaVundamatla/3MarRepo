    <JadeMethod name="resetData_50282" id="b98929d4-2a23-4e30-aa7b-7d3bb0c87253">
        <source>resetData_50282();
/*

Purpose:	Reset 50282		

Date		Who		Reason
06/11/2020	jlgmk3	Initial creation

*/
vars
	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	operator				: CM_Operator;
begin
	//app.initialize();
	
	
	/*****************************************************
	 * Terminal - MTNQ
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["MTNQ"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);

	self.deleteOperator("AOPS");
	operator := self.getOperator("AOPS");
	self.assertNull(operator);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_50320" id="84509442-05d6-47b3-b250-9e8f685df5bd">
        <source>resetData_50320();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/11/2020	jlgmh5	Initial creation

*/
constants

	TrackedItemId			: String = "REEFAPP";

vars

	terminal				: CM_Terminal;
	ti						: CM_TrackedItem;
	ti2						: Object;
	gbs						: CM_TerminalArea;
	obj						: Object;
	lc						: CM_LocationsController;
	voyage					: CM_Voyage;
	dischargePort			: CM_Port;
	operator				: CM_Operator;
	trackedItem				: CM_TrackedItem;
	txn						: CM_TITransaction;
	reeferBlock				: CM_ReeferBlock;
	pxyReeferBlock			: CM_ReeferBlock;
	pxyReeferBlockPos		: CM_ReeferBlockPosition;
	reeferJob 				: CM_YardActivity;	
	
	tiSet					: CM_TISet;
	tiObjectSet				: ObjectSet;
	locations				: StringArray;
	connectedArray			: ObjectArray;
	disconnectedArray		: ObjectArray;
	tiArray					: ObjectArray;
	tiConnectedArray		: ObjectArray;
	tiDisconnectedArray		: ObjectArray;
	lcMonitorArray			: ObjectArray;
	lcConnectArray			: ObjectArray;
	lcDisconnectArray		: ObjectArray;
	reeferWalkPositionArray : CM_ReeferBlockPositionArray;
	tiMixedArray			: ObjectArray;
	tiMixedConnectArray		: ObjectArray;
	tiMixedDisconnectArray	: ObjectArray;
	tiMixedAlarmArray		: ObjectArray;
	lcMixedArray			: ObjectArray;

	trackedItemId			: String;
	trackedItemCount		: Integer;
	count					: Integer;	
	location				: String;
	index					: Integer;
	isoType					: String;
	commodity				: String;
	startTS					: TimeStamp;
	endTS					: TimeStamp;
	receivedTS				: TimeStamp;
	randomMinutes			: Integer;
	maxHeight				: Integer;
	tier					: Integer;
	currentLC				: String;
	now						: TimeStamp;
	
begin
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 // **** TODO - RESET TO TT1
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	// delete the tracked items
	create tiObjectSet transient;
	
	gbs := self.getTerminalArea("RAFN20");
	self.assertNotNull(gbs);
	
	gbs.getAllLocationsTrackedItems(tiObjectSet);
	
	// Delete tracked items
	create tiSet transient;
	
	foreach obj in tiObjectSet do
	
		trackedItemId := obj.CM_TrackedItem.id;
		
		if trackedItemId[1:9] &lt;&gt; "REEFAPP01" then
			continue;
		endif;
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti2 := trackedItemId.asOid;
			if ti2 &lt;&gt; null and CM_TrackedItem.hasInstance(ti2) then
				tiSet.add( ti2.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
				
	endforeach;
	
	// delete reefer walk paths
	foreach reeferBlock in gbs.allReeferBlocks do
		if reeferBlock.name[1:6] &lt;&gt; "50320_" then
			continue;
		endif;
		write 'Deleting walk path: ' &amp; reeferBlock.name;
		app.writeLog('Deleting walk path: ' &amp; reeferBlock.name, LogINFO);
		app.myTrxDA.trxDeleteReeferBlock( reeferBlock, app.myPassport );	
	endforeach;
		
	create locations transient;
	locations.add("1601");
	locations.add("1602");
	locations.add("1603");
	locations.add("1604");
	locations.add("1605");
	locations.add("1801");
	locations.add("1802");
	locations.add("1803");
	locations.add("1804");
	locations.add("1805");
	locations.add("2001");
	locations.add("2002");
	locations.add("2003");
	locations.add("2004");
	locations.add("2005");
	
	trackedItemCount := 100;
	count := 1;
	index := 1;
	isoType := "2230";
	commodity := "REEF";
		
	location := locations[index];
	lc := gbs.getLocationsControllerFromId(location);
	self.assertNotNull(lc);
	
	voyage := self.getVoyage("VOYREEFAPP01");
	self.assertNotNull(voyage);
	
	dischargePort := self.getPort("USJAX");
	self.assertNotNull(dischargePort);
	
	tiObjectSet.clear();
	
	receivedTS := app.actualTimeAppServer().addDays(-53);
	receivedTS.setTime("00:00:00".Time);
		
	operator := self.getOperator("MSC");
	self.assertNotNull(operator);
	
	create tiArray transient;
	create tiConnectedArray transient;
	create tiDisconnectedArray transient;
	create tiMixedArray transient;
	create tiMixedConnectArray transient;
	create tiMixedDisconnectArray transient;
	create tiMixedAlarmArray transient;
	
	while (true) do
	
		lc := gbs.getLocationsControllerFromId(location);
		
		trackedItemCount := trackedItemCount + 1;
		trackedItemId := TrackedItemId &amp; trackedItemCount.String.padLeadingZeros(4);
				
		randomMinutes := app.randomRange(0, 4);		
		receivedTS := receivedTS.addMinutes(randomMinutes);
			
		self.opts.clear();
		self.opts.addAssoc("ReceivedDate", receivedTS.String);
		self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
		self.opts.addAssoc(UTTI_TotalWeight, 12500.0000.Decimal);
		ti := self.addContainerAtLocation(trackedItemId, operator, isoType, commodity, TI_IMEX_STATUS_IMPORT, lc);
		self.assertNotNull(ti);
		write "TrackedItem: (" &amp; trackedItemId &amp; ") created......";
		app.writeLog("TrackedItem: (" &amp; trackedItemId &amp; ") created......", LogINFO);
						
		// update transactions
		beginTransaction;
		ti.setPropertyValue("inputDT", ti.receivedDT);
		ti.setPropertyValue("moveDT", ti.receivedDT);
		foreach txn in ti.allTransactions do
			txn.updateDateTime(ti.receivedDT);
		endforeach;
		commitTransaction;
		
		// add ti to the array of ti's so can turn reefer on and off
		tiArray.add(ti);
		
		if location[1:2] = "16" then
			tiConnectedArray.add(ti);
		endif;
		if location[1:2] = "18" then
			tiDisconnectedArray.add(ti);
		endif;
		if location[1:2] = "20" then
			if location[3:2].Integer &gt;= 1 and location[3:2].Integer &lt;= 4 then
				tiMixedConnectArray.add(ti);
			endif;
			if location[3:2].Integer &gt;= 3 and location[3:2].Integer &lt;= 4 then
				tiMixedDisconnectArray.add(ti);
			endif;
			if location[3:2].Integer = 5 then
				tiMixedAlarmArray.add(ti);
			endif;
		endif;
	
		if count = 3 then
			count := 0;
			index := index + 1;
			if (index &gt; locations.size) then
				break;
			endif;
			location := locations[index];
			lc := gbs.getLocationsControllerFromId(location);
			self.assertNotNull(lc);
		endif;
		count := count + 1;
			
	endwhile;
	
	create connectedArray transient;
	create disconnectedArray transient;
	
	// connect row 16 
	self.connectDisconnectReefer(tiConnectedArray, true, 0, connectedArray, 2, 9);
	
	// connect row 18
	self.connectDisconnectReefer(tiDisconnectedArray, true, 0, connectedArray, 11, 17);
	self.connectDisconnectReefer(tiDisconnectedArray, false, 0, disconnectedArray, 20, 25);
	
	// connect row 20
	connectedArray.clear();
	disconnectedArray.clear();
	self.connectDisconnectReefer(tiMixedConnectArray, true, 0, connectedArray, 11, 17);
	self.connectDisconnectReefer(tiMixedDisconnectArray, false, 0, disconnectedArray, 20, 25);
	
	// get items to monitor and create walk path
	write "Creating Walk Path (50320_WALK_MON)......";
	app.writeLog("Creating Walk Path (50320_WALK_MON)......", LogINFO);
	create reeferWalkPositionArray transient;
	create lcMonitorArray transient;
	index := 1;
	while index &lt;= 9 do
		lcMonitorArray.add(tiConnectedArray[index].CM_TrackedItem.myPrimaryActualLocation);
		index := index + 1;
	endwhile;
	
	index := 0;
	currentLC := null;
	while index &lt;= lcMonitorArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcMonitorArray.size then
			break;
		endif;
		lc := lcMonitorArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "50320_WALK_MON", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );	
	
	//create a reefer walk path
	write "Creating Walk Path (50320_WALK_DIS)......";
	app.writeLog("Creating Walk Path (50320_WALK_DIS)......", LogINFO);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	// get items to connect and create walk path
	create lcConnectArray transient;
	index := 4;
	while index &lt;= 12 do
		lcConnectArray.add(tiDisconnectedArray[index].CM_TrackedItem.myPrimaryActualLocation);
		index := index + 1;
	endwhile;
	
	index := 0;
	currentLC := null;
	while index &lt;= lcConnectArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcConnectArray.size then
			break;
		endif;
		lc := lcConnectArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "50320_WALK_DIS", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );	
	
	//create a reefer walk path
	write "Creating Walk Path (50320_WALK_CON)......";
	app.writeLog("Creating Walk Path (50320_WALK_CON)......", LogINFO);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	// get items to disconnect and create walk path
	create lcDisconnectArray transient;
	index := 10;
	while index &lt;= 15 do
		lcDisconnectArray.add(tiConnectedArray[index].CM_TrackedItem.myPrimaryActualLocation);
		index := index + 1;
	endwhile;
	
	index := 0;
	currentLC := null;
	while index &lt;= lcDisconnectArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcDisconnectArray.size then
			break;
		endif;
		lc := lcDisconnectArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "50320_WALK_CON", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );
	
	//create a reefer walk path
	write "Creating Walk Path (50320_WALK_MIX)......";
	app.writeLog("Creating Walk Path (50320_WALK_MIX)......", LogINFO);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	// get items to disconnect and create walk path
	create lcMixedArray transient;
	lcMixedArray.add(gbs.getLocationsControllerFromId("2001"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2002"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2003"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2004"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2005"));
	
	index := 0;
	currentLC := null;
	while index &lt;= lcMixedArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcMixedArray.size then
			break;
		endif;
		lc := lcMixedArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "50320_WALK_MIX", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );
	
	//create a reefer walk path
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	
	
	// create monitor jobs
	write "Creating Monitor Jobs......";
	app.writeLog("Creating Monitor Jobs......", LogINFO);
	now := app.actualTimeAppServer();
	index := 1;
	while index &lt;= 9 do
		reeferJob := self.addReeferJob( tiConnectedArray[index].CM_TrackedItem, CM_YardActivity.ReeferMonitor, now );
		if index &lt; 3 then
			reeferJob := self.addReeferJob( tiMixedConnectArray[index].CM_TrackedItem, CM_YardActivity.ReeferMonitor, now );
		endif;
		index := index + 1;
	endwhile;
	
	// create connnect jobs
	write "Creating Connect Jobs......";
	app.writeLog("Creating Connect Jobs......", LogINFO);
	index := 10;
	while index &lt;= 15 do
		reeferJob := self.addReeferJob( tiConnectedArray[index].CM_TrackedItem, CM_YardActivity.ReeferConnect, now );
		index := index + 1;
	endwhile;
	index := 7;
	while index &lt;= 12 do
		reeferJob := self.addReeferJob( tiMixedConnectArray[index].CM_TrackedItem, CM_YardActivity.ReeferConnect, now );
		index := index + 1;
	endwhile;
	
	// create disconnnect jobs
	write "Creating Disconnect Jobs......";
	app.writeLog("Creating Disconnect Jobs......", LogINFO);
	index := 4;
	while index &lt;= 12 do
		reeferJob := self.addReeferJob( tiDisconnectedArray[index].CM_TrackedItem, CM_YardActivity.ReeferDisconnect, now );
		index := index + 1;
	endwhile;
	index := 4;
	while index &lt;= 6 do
		reeferJob := self.addReeferJob( tiMixedConnectArray[index].CM_TrackedItem, CM_YardActivity.ReeferDisconnect, now );
		index := index + 1;
	endwhile;
	
	// create alarm jobs
	write "Creating Alarm Jobs......";
	app.writeLog("Creating Alarm Jobs......", LogINFO);
	index := 1;
	while index &lt;= tiMixedAlarmArray.size do
		reeferJob := self.addReeferJob( tiMixedAlarmArray[index].CM_TrackedItem, CM_YardActivity.ReeferAlarm, now );
		index := index + 1;
	endwhile;
	
epilog

	delete tiSet;
	delete tiObjectSet;
	delete locations;
	delete connectedArray;
	delete disconnectedArray;
	delete tiArray;
	delete tiConnectedArray;
	delete tiDisconnectedArray;
	delete tiMixedArray;
	delete tiMixedConnectArray;
	delete tiMixedDisconnectArray;
	delete tiMixedAlarmArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_50320A" id="1fe75131-9292-4632-8ff1-e868c12562c3">
        <source>resetData_50320A();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/11/2020	jlgmh5	Initial creation

*/
constants

	TrackedItemId			: String = "REEFAPP";

vars

	terminal				: CM_Terminal;
	ti						: CM_TrackedItem;
	ti2						: Object;
	gbs						: CM_TerminalArea;
	obj						: Object;
	lc						: CM_LocationsController;
	voyage					: CM_Voyage;
	dischargePort			: CM_Port;
	operator				: CM_Operator;
	trackedItem				: CM_TrackedItem;
	txn						: CM_TITransaction;
	reeferBlock				: CM_ReeferBlock;
	pxyReeferBlock			: CM_ReeferBlock;
	pxyReeferBlockPos		: CM_ReeferBlockPosition;
	reeferJob 				: CM_YardActivity;	
	
	tiSet					: CM_TISet;
	tiObjectSet				: ObjectSet;
	locations				: StringArray;
	connectedArray			: ObjectArray;
	disconnectedArray		: ObjectArray;
	tiArray					: ObjectArray;
	tiConnectedArray		: ObjectArray;
	tiDisconnectedArray		: ObjectArray;
	lcMonitorArray			: ObjectArray;
	lcConnectArray			: ObjectArray;
	lcDisconnectArray		: ObjectArray;
	reeferWalkPositionArray : CM_ReeferBlockPositionArray;
	tiMixedArray			: ObjectArray;
	tiMixedConnectArray		: ObjectArray;
	tiMixedDisconnectArray	: ObjectArray;
	tiMixedAlarmArray		: ObjectArray;
	lcMixedArray			: ObjectArray;

	trackedItemId			: String;
	trackedItemCount		: Integer;
	count					: Integer;	
	location				: String;
	index					: Integer;
	isoType					: String;
	commodity				: String;
	startTS					: TimeStamp;
	endTS					: TimeStamp;
	receivedTS				: TimeStamp;
	randomMinutes			: Integer;
	maxHeight				: Integer;
	tier					: Integer;
	currentLC				: String;
	now						: TimeStamp;
	
begin
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 // **** TODO - RESET TO TT1
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	// delete the tracked items
	create tiObjectSet transient;
	
	gbs := self.getTerminalArea("RAFNAA");
	self.assertNotNull(gbs);
	
	gbs.getAllLocationsTrackedItems(tiObjectSet);
	
	// Delete tracked items
	create tiSet transient;
	
	foreach obj in tiObjectSet do
	
		trackedItemId := obj.CM_TrackedItem.id;
		
		if trackedItemId[1:9] &lt;&gt; "REEFAPP01" then
			continue;
		endif;
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti2 := trackedItemId.asOid;
			if ti2 &lt;&gt; null and CM_TrackedItem.hasInstance(ti2) then
				tiSet.add( ti2.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
				
	endforeach;
	
	// delete reefer walk paths
	foreach reeferBlock in gbs.allReeferBlocks do
		if reeferBlock.name[1:6] &lt;&gt; "50320A_" then
			continue;
		endif;
		write 'Deleting walk path: ' &amp; reeferBlock.name;
		app.writeLog('Deleting walk path: ' &amp; reeferBlock.name, LogINFO);
		app.myTrxDA.trxDeleteReeferBlock( reeferBlock, app.myPassport );	
	endforeach;
		
	create locations transient;
	locations.add("1601");
	locations.add("1602");
	locations.add("1603");
	locations.add("1604");
	locations.add("1605");
	locations.add("1801");
	locations.add("1802");
	locations.add("1803");
	locations.add("1804");
	locations.add("1805");
	locations.add("2001");
	locations.add("2002");
	locations.add("2003");
	locations.add("2004");
	locations.add("2005");
	
	trackedItemCount := 200;
	count := 1;
	index := 1;
	isoType := "2230";
	commodity := "REEF";
		
	location := locations[index];
	lc := gbs.getLocationsControllerFromId(location);
	self.assertNotNull(lc);
	
	voyage := self.getVoyage("VOYREEFAPP01");
	self.assertNotNull(voyage);
	
	dischargePort := self.getPort("USJAX");
	self.assertNotNull(dischargePort);
	
	tiObjectSet.clear();
	
	receivedTS := app.actualTimeAppServer().addDays(-53);
	receivedTS.setTime("00:00:00".Time);
		
	operator := self.getOperator("MSC");
	self.assertNotNull(operator);
	
	create tiArray transient;
	create tiConnectedArray transient;
	create tiDisconnectedArray transient;
	create tiMixedArray transient;
	create tiMixedConnectArray transient;
	create tiMixedDisconnectArray transient;
	create tiMixedAlarmArray transient;
	
	while (true) do
	
		lc := gbs.getLocationsControllerFromId(location);
		
		trackedItemCount := trackedItemCount + 1;
		trackedItemId := TrackedItemId &amp; trackedItemCount.String.padLeadingZeros(4);
				
		randomMinutes := app.randomRange(0, 4);		
		receivedTS := receivedTS.addMinutes(randomMinutes);
			
		self.opts.clear();
		self.opts.addAssoc("ReceivedDate", receivedTS.String);
		self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
		self.opts.addAssoc(UTTI_TotalWeight, 12500.0000.Decimal);
		ti := self.addContainerAtLocation(trackedItemId, operator, isoType, commodity, TI_IMEX_STATUS_IMPORT, lc);
		self.assertNotNull(ti);
		write "TrackedItem: (" &amp; trackedItemId &amp; ") created......";
		app.writeLog("TrackedItem: (" &amp; trackedItemId &amp; ") created......", LogINFO);
						
		// update transactions
		beginTransaction;
		ti.setPropertyValue("inputDT", ti.receivedDT);
		ti.setPropertyValue("moveDT", ti.receivedDT);
		foreach txn in ti.allTransactions do
			txn.updateDateTime(ti.receivedDT);
		endforeach;
		commitTransaction;
		
		// add ti to the array of ti's so can turn reefer on and off
		tiArray.add(ti);
		
		if location[1:2] = "16" then
			tiConnectedArray.add(ti);
		endif;
		if location[1:2] = "18" then
			tiDisconnectedArray.add(ti);
		endif;
		if location[1:2] = "20" then
			if location[3:2].Integer &gt;= 1 and location[3:2].Integer &lt;= 4 then
				tiMixedConnectArray.add(ti);
			endif;
			if location[3:2].Integer &gt;= 3 and location[3:2].Integer &lt;= 4 then
				tiMixedDisconnectArray.add(ti);
			endif;
			if location[3:2].Integer = 5 then
				tiMixedAlarmArray.add(ti);
			endif;
		endif;
	
		if count = 3 then
			count := 0;
			index := index + 1;
			if (index &gt; locations.size) then
				break;
			endif;
			location := locations[index];
			lc := gbs.getLocationsControllerFromId(location);
			self.assertNotNull(lc);
		endif;
		count := count + 1;
			
	endwhile;
	
	create connectedArray transient;
	create disconnectedArray transient;
	
	// connect row 16 
	self.connectDisconnectReefer(tiConnectedArray, true, 0, connectedArray, 2, 9);
	
	// connect row 18
	self.connectDisconnectReefer(tiDisconnectedArray, true, 0, connectedArray, 11, 17);
	self.connectDisconnectReefer(tiDisconnectedArray, false, 0, disconnectedArray, 20, 25);
	
	// connect row 20
	connectedArray.clear();
	disconnectedArray.clear();
	self.connectDisconnectReefer(tiMixedConnectArray, true, 0, connectedArray, 11, 17);
	self.connectDisconnectReefer(tiMixedDisconnectArray, false, 0, disconnectedArray, 20, 25);
	
	// get items to monitor and create walk path
	write "Creating Walk Path (50320_WALK_MON1)......";
	app.writeLog("Creating Walk Path (50320_WALK_MON1)......", LogINFO);
	create reeferWalkPositionArray transient;
	create lcMonitorArray transient;
	index := 1;
	while index &lt;= 9 do
		lcMonitorArray.add(tiConnectedArray[index].CM_TrackedItem.myPrimaryActualLocation);
		index := index + 1;
	endwhile;
	
	index := 0;
	currentLC := null;
	while index &lt;= lcMonitorArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcMonitorArray.size then
			break;
		endif;
		lc := lcMonitorArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "50320_WALK_MON1", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );	
	
	//create a reefer walk path
	write "Creating Walk Path (50320_WALK_DIS1)......";
	app.writeLog("Creating Walk Path (50320_WALK_DIS1)......", LogINFO);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	// get items to connect and create walk path
	create lcConnectArray transient;
	index := 4;
	while index &lt;= 12 do
		lcConnectArray.add(tiDisconnectedArray[index].CM_TrackedItem.myPrimaryActualLocation);
		index := index + 1;
	endwhile;
	
	index := 0;
	currentLC := null;
	while index &lt;= lcConnectArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcConnectArray.size then
			break;
		endif;
		lc := lcConnectArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "50320_WALK_DIS1", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );	
	
	//create a reefer walk path
	write "Creating Walk Path (50320_WALK_CON1)......";
	app.writeLog("Creating Walk Path (50320_WALK_CON1)......", LogINFO);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	// get items to disconnect and create walk path
	create lcDisconnectArray transient;
	index := 10;
	while index &lt;= 15 do
		lcDisconnectArray.add(tiConnectedArray[index].CM_TrackedItem.myPrimaryActualLocation);
		index := index + 1;
	endwhile;
	
	index := 0;
	currentLC := null;
	while index &lt;= lcDisconnectArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcDisconnectArray.size then
			break;
		endif;
		lc := lcDisconnectArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "50320_WALK_CON1", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );
	
	//create a reefer walk path
	write "Creating Walk Path (50320_WALK_MIX1)......";
	app.writeLog("Creating Walk Path (50320_WALK_MIX1)......", LogINFO);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	// get items to disconnect and create walk path
	create lcMixedArray transient;
	lcMixedArray.add(gbs.getLocationsControllerFromId("2001"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2002"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2003"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2004"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2005"));
	
	index := 0;
	currentLC := null;
	while index &lt;= lcMixedArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcMixedArray.size then
			break;
		endif;
		lc := lcMixedArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "50320_WALK_MIX", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );
	
	//create a reefer walk path
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	
	
	// create monitor jobs
	write "Creating Monitor Jobs......";
	app.writeLog("Creating Monitor Jobs......", LogINFO);
	now := app.actualTimeAppServer();
	index := 1;
	while index &lt;= 9 do
		reeferJob := self.addReeferJob( tiConnectedArray[index].CM_TrackedItem, CM_YardActivity.ReeferMonitor, now );
		if index &lt; 3 then
			reeferJob := self.addReeferJob( tiMixedConnectArray[index].CM_TrackedItem, CM_YardActivity.ReeferMonitor, now );
		endif;
		index := index + 1;
	endwhile;
	
	// create connnect jobs
	write "Creating Connect Jobs......";
	app.writeLog("Creating Connect Jobs......", LogINFO);
	index := 10;
	while index &lt;= 15 do
		reeferJob := self.addReeferJob( tiConnectedArray[index].CM_TrackedItem, CM_YardActivity.ReeferConnect, now );
		index := index + 1;
	endwhile;
	index := 7;
	while index &lt;= 12 do
		reeferJob := self.addReeferJob( tiMixedConnectArray[index].CM_TrackedItem, CM_YardActivity.ReeferConnect, now );
		index := index + 1;
	endwhile;
	
	// create disconnnect jobs
	write "Creating Disconnect Jobs......";
	app.writeLog("Creating Disconnect Jobs......", LogINFO);
	index := 4;
	while index &lt;= 12 do
		reeferJob := self.addReeferJob( tiDisconnectedArray[index].CM_TrackedItem, CM_YardActivity.ReeferDisconnect, now );
		index := index + 1;
	endwhile;
	index := 4;
	while index &lt;= 6 do
		reeferJob := self.addReeferJob( tiMixedConnectArray[index].CM_TrackedItem, CM_YardActivity.ReeferDisconnect, now );
		index := index + 1;
	endwhile;
	
	// create alarm jobs
	write "Creating Alarm Jobs......";
	app.writeLog("Creating Alarm Jobs......", LogINFO);
	index := 1;
	while index &lt;= tiMixedAlarmArray.size do
		reeferJob := self.addReeferJob( tiMixedAlarmArray[index].CM_TrackedItem, CM_YardActivity.ReeferAlarm, now );
		index := index + 1;
	endwhile;
	
epilog

	delete tiSet;
	delete tiObjectSet;
	delete locations;
	delete connectedArray;
	delete disconnectedArray;
	delete tiArray;
	delete tiConnectedArray;
	delete tiDisconnectedArray;
	delete tiMixedArray;
	delete tiMixedConnectArray;
	delete tiMixedDisconnectArray;
	delete tiMixedAlarmArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_50320B" id="87178c4e-acfb-4b74-9ca6-67f279ee826f">
        <source>resetData_50320B();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/11/2020	jlgmh5	Initial creation

*/
constants

	TrackedItemId			: String = "REEFAPP";

vars

	terminal				: CM_Terminal;
	ti						: CM_TrackedItem;
	ti2						: Object;
	gbs						: CM_TerminalArea;
	obj						: Object;
	lc						: CM_LocationsController;
	voyage					: CM_Voyage;
	dischargePort			: CM_Port;
	operator				: CM_Operator;
	trackedItem				: CM_TrackedItem;
	txn						: CM_TITransaction;
	reeferBlock				: CM_ReeferBlock;
	pxyReeferBlock			: CM_ReeferBlock;
	pxyReeferBlockPos		: CM_ReeferBlockPosition;
	reeferJob 				: CM_YardActivity;	
	
	tiSet					: CM_TISet;
	tiObjectSet				: ObjectSet;
	locations				: StringArray;
	connectedArray			: ObjectArray;
	disconnectedArray		: ObjectArray;
	tiArray					: ObjectArray;
	tiConnectedArray		: ObjectArray;
	tiDisconnectedArray		: ObjectArray;
	lcMonitorArray			: ObjectArray;
	lcConnectArray			: ObjectArray;
	lcDisconnectArray		: ObjectArray;
	reeferWalkPositionArray : CM_ReeferBlockPositionArray;
	tiMixedArray			: ObjectArray;
	tiMixedConnectArray		: ObjectArray;
	tiMixedDisconnectArray	: ObjectArray;
	tiMixedAlarmArray		: ObjectArray;
	lcMixedArray			: ObjectArray;

	trackedItemId			: String;
	trackedItemCount		: Integer;
	count					: Integer;	
	location				: String;
	index					: Integer;
	isoType					: String;
	commodity				: String;
	startTS					: TimeStamp;
	endTS					: TimeStamp;
	receivedTS				: TimeStamp;
	randomMinutes			: Integer;
	maxHeight				: Integer;
	tier					: Integer;
	currentLC				: String;
	now						: TimeStamp;
	
begin
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 // **** TODO - RESET TO TT1
	 
	 terminal := app.myRoot.allTerminals["TT2"];
	 if terminal = null then
		return;
	endif;
	
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	// delete the tracked items
	create tiObjectSet transient;
	
	gbs := self.getTerminalArea("RFAP1");
	self.assertNotNull(gbs);
	
	gbs.getAllLocationsTrackedItems(tiObjectSet);
	
	// Delete tracked items
	create tiSet transient;
	
	foreach obj in tiObjectSet do
	
		trackedItemId := obj.CM_TrackedItem.id;
		
		if trackedItemId[1:9] &lt;&gt; "REEFAPP03" then
			continue;
		endif;
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti2 := trackedItemId.asOid;
			if ti2 &lt;&gt; null and CM_TrackedItem.hasInstance(ti2) then
				tiSet.add( ti2.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
				
	endforeach;
	
	// delete reefer walk paths
	foreach reeferBlock in gbs.allReeferBlocks do
		if reeferBlock.name[1:3] &lt;&gt; "TT2" then
			continue;
		endif;
		write 'Deleting walk path: ' &amp; reeferBlock.name;
		app.writeLog('Deleting walk path: ' &amp; reeferBlock.name, LogINFO);
		app.myTrxDA.trxDeleteReeferBlock( reeferBlock, app.myPassport );	
	endforeach;
		
	create locations transient;
	locations.add("1601");
	locations.add("1602");
	locations.add("1603");
	locations.add("1604");
	locations.add("1605");
	locations.add("1801");
	locations.add("1802");
	locations.add("1803");
	locations.add("1804");
	locations.add("1805");
	locations.add("2001");
	locations.add("2002");
	locations.add("2003");
	locations.add("2004");
	locations.add("2005");
	
	trackedItemCount := 300;
	count := 1;
	index := 1;
	isoType := "2230";
	commodity := "REEF";
		
	location := locations[index];
	lc := gbs.getLocationsControllerFromId(location);
	self.assertNotNull(lc);
	
	voyage := self.getVoyage("VOYREEFAPPTT2A");
	self.assertNotNull(voyage);
	
	dischargePort := self.getPort("USJAX");
	self.assertNotNull(dischargePort);
	
	tiObjectSet.clear();
	
	receivedTS := app.actualTimeAppServer().addDays(-53);
	receivedTS.setTime("00:00:00".Time);
		
	operator := self.getOperator("MSC");
	self.assertNotNull(operator);
	
	create tiArray transient;
	create tiConnectedArray transient;
	create tiDisconnectedArray transient;
	create tiMixedArray transient;
	create tiMixedConnectArray transient;
	create tiMixedDisconnectArray transient;
	create tiMixedAlarmArray transient;
	
	while (true) do
	
		lc := gbs.getLocationsControllerFromId(location);
		
		trackedItemCount := trackedItemCount + 1;
		trackedItemId := TrackedItemId &amp; trackedItemCount.String.padLeadingZeros(4);
				
		randomMinutes := app.randomRange(0, 4);		
		receivedTS := receivedTS.addMinutes(randomMinutes);
			
		self.opts.clear();
		self.opts.addAssoc("ReceivedDate", receivedTS.String);
		self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
		self.opts.addAssoc(UTTI_TotalWeight, 12500.0000.Decimal);
		self.opts.addAssoc("Terminal", terminal.code);
		ti := self.addContainerAtLocation(trackedItemId, operator, isoType, commodity, TI_IMEX_STATUS_IMPORT, lc);
		self.assertNotNull(ti);
		write "TrackedItem: (" &amp; trackedItemId &amp; ") created......";
		app.writeLog("TrackedItem: (" &amp; trackedItemId &amp; ") created......", LogINFO);
						
		// update transactions
		beginTransaction;
		ti.setPropertyValue("inputDT", ti.receivedDT);
		ti.setPropertyValue("moveDT", ti.receivedDT);
		foreach txn in ti.allTransactions do
			txn.updateDateTime(ti.receivedDT);
		endforeach;
		commitTransaction;
		
		// add ti to the array of ti's so can turn reefer on and off
		tiArray.add(ti);
		
		if location[1:2] = "16" then
			tiConnectedArray.add(ti);
		endif;
		if location[1:2] = "18" then
			tiDisconnectedArray.add(ti);
		endif;
		if location[1:2] = "20" then
			if location[3:2].Integer &gt;= 1 and location[3:2].Integer &lt;= 4 then
				tiMixedConnectArray.add(ti);
			endif;
			if location[3:2].Integer &gt;= 3 and location[3:2].Integer &lt;= 4 then
				tiMixedDisconnectArray.add(ti);
			endif;
			if location[3:2].Integer = 5 then
				tiMixedAlarmArray.add(ti);
			endif;
		endif;
	
		if count = 3 then
			count := 0;
			index := index + 1;
			if (index &gt; locations.size) then
				break;
			endif;
			location := locations[index];
			lc := gbs.getLocationsControllerFromId(location);
			self.assertNotNull(lc);
		endif;
		count := count + 1;
			
	endwhile;
	
	create connectedArray transient;
	create disconnectedArray transient;
	
	// connect row 16 
	self.connectDisconnectReefer(tiConnectedArray, true, 0, connectedArray, 2, 9);
	
	// connect row 18
	self.connectDisconnectReefer(tiDisconnectedArray, true, 0, connectedArray, 11, 17);
	self.connectDisconnectReefer(tiDisconnectedArray, false, 0, disconnectedArray, 20, 25);
	
	// connect row 20
	connectedArray.clear();
	disconnectedArray.clear();
	self.connectDisconnectReefer(tiMixedConnectArray, true, 0, connectedArray, 11, 17);
	self.connectDisconnectReefer(tiMixedDisconnectArray, false, 0, disconnectedArray, 20, 25);
	
	// get items to monitor and create walk path
	write "Creating Walk Path (TT2M)......";
	app.writeLog("Creating Walk Path (TT2M)......", LogINFO);
	create reeferWalkPositionArray transient;
	create lcMonitorArray transient;
	index := 1;
	while index &lt;= 9 do
		lcMonitorArray.add(tiConnectedArray[index].CM_TrackedItem.myPrimaryActualLocation);
		index := index + 1;
	endwhile;
	
	index := 0;
	currentLC := null;
	while index &lt;= lcMonitorArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcMonitorArray.size then
			break;
		endif;
		lc := lcMonitorArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "TT2M", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );	
	
	//create a reefer walk path
	write "Creating Walk Path (TT2D)......";
	app.writeLog("Creating Walk Path (TT2D)......", LogINFO);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	// get items to connect and create walk path
	create lcConnectArray transient;
	index := 4;
	while index &lt;= 12 do
		lcConnectArray.add(tiDisconnectedArray[index].CM_TrackedItem.myPrimaryActualLocation);
		index := index + 1;
	endwhile;
	
	index := 0;
	currentLC := null;
	while index &lt;= lcConnectArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcConnectArray.size then
			break;
		endif;
		lc := lcConnectArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "TT2D", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );	
	
	//create a reefer walk path
	write "Creating Walk Path (TT2C)......";
	app.writeLog("Creating Walk Path (TT2C)......", LogINFO);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	// get items to disconnect and create walk path
	create lcDisconnectArray transient;
	index := 10;
	while index &lt;= 15 do
		lcDisconnectArray.add(tiConnectedArray[index].CM_TrackedItem.myPrimaryActualLocation);
		index := index + 1;
	endwhile;
	
	index := 0;
	currentLC := null;
	while index &lt;= lcDisconnectArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcDisconnectArray.size then
			break;
		endif;
		lc := lcDisconnectArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "TT2C", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );
	
	//create a reefer walk path
	write "Creating Walk Path (TT2X)......";
	app.writeLog("Creating Walk Path (TT2X)......", LogINFO);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	// get items to disconnect and create walk path
	create lcMixedArray transient;
	lcMixedArray.add(gbs.getLocationsControllerFromId("2001"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2002"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2003"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2004"));
	lcMixedArray.add(gbs.getLocationsControllerFromId("2005"));
	
	index := 0;
	currentLC := null;
	while index &lt;= lcMixedArray.size do
		count := 0;
		index := index + 1;
		if index &gt; lcMixedArray.size then
			break;
		endif;
		lc := lcMixedArray[index].CM_LocationsController;
		if currentLC = null then
			currentLC := lc.getID();
		elseif currentLC &lt;&gt; null then
			if lc.getID() &lt;&gt; currentLC then
				currentLC := lc.getID();
			else
				continue;
			endif;
		endif;
		currentLC := lc.getID();		
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create pxyReeferBlockPos transient;	
			pxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( pxyReeferBlockPos );
		endforeach;	
	endwhile;
	
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( "TT2X", gbs );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );
	
	//create a reefer walk path
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	
	
	// create monitor jobs
	write "Creating Monitor Jobs......";
	app.writeLog("Creating Monitor Jobs......", LogINFO);
	now := app.actualTimeAppServer();
	index := 1;
	while index &lt;= 9 do
		reeferJob := self.addReeferJob( tiConnectedArray[index].CM_TrackedItem, CM_YardActivity.ReeferMonitor, now );
		if index &lt; 3 then
			reeferJob := self.addReeferJob( tiMixedConnectArray[index].CM_TrackedItem, CM_YardActivity.ReeferMonitor, now );
		endif;
		index := index + 1;
	endwhile;
	
	// create connnect jobs
	write "Creating Connect Jobs......";
	app.writeLog("Creating Connect Jobs......", LogINFO);
	index := 10;
	while index &lt;= 15 do
		reeferJob := self.addReeferJob( tiConnectedArray[index].CM_TrackedItem, CM_YardActivity.ReeferConnect, now );
		index := index + 1;
	endwhile;
	index := 7;
	while index &lt;= 12 do
		reeferJob := self.addReeferJob( tiMixedConnectArray[index].CM_TrackedItem, CM_YardActivity.ReeferConnect, now );
		index := index + 1;
	endwhile;
	
	// create disconnnect jobs
	write "Creating Disconnect Jobs......";
	app.writeLog("Creating Disconnect Jobs......", LogINFO);
	index := 4;
	while index &lt;= 12 do
		reeferJob := self.addReeferJob( tiDisconnectedArray[index].CM_TrackedItem, CM_YardActivity.ReeferDisconnect, now );
		index := index + 1;
	endwhile;
	index := 4;
	while index &lt;= 6 do
		reeferJob := self.addReeferJob( tiMixedConnectArray[index].CM_TrackedItem, CM_YardActivity.ReeferDisconnect, now );
		index := index + 1;
	endwhile;
	
	// create alarm jobs
	write "Creating Alarm Jobs......";
	app.writeLog("Creating Alarm Jobs......", LogINFO);
	index := 1;
	while index &lt;= tiMixedAlarmArray.size do
		reeferJob := self.addReeferJob( tiMixedAlarmArray[index].CM_TrackedItem, CM_YardActivity.ReeferAlarm, now );
		index := index + 1;
	endwhile;
	
epilog

	delete tiSet;
	delete tiObjectSet;
	delete locations;
	delete connectedArray;
	delete disconnectedArray;
	delete tiArray;
	delete tiConnectedArray;
	delete tiDisconnectedArray;
	delete tiMixedArray;
	delete tiMixedConnectArray;
	delete tiMixedDisconnectArray;
	delete tiMixedAlarmArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_51302" id="3a590a1b-057c-49dc-9c8f-57d21711d678">
        <source>resetData_51302();
/*

Purpose:	Reset 37392		

Date		Who		Reason
21/06/2022	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	ti						: Object;
	cargoType				: CM_CargoType;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;
	vehicles				: StringArray;
	
	pos 					: Integer;
	trackedItem				: String;
	vehicleId				: String;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create tisToDelete transient;
	tisToDelete.add("JLG51302A01");
	tisToDelete.add("JLG51302A02");
	tisToDelete.add("JLG51302A03");
	tisToDelete.add("JLG51302A04");
	tisToDelete.add("JLG51302A05");
	tisToDelete.add("JLG51302A06");
	tisToDelete.add("JLG51302A07");
	tisToDelete.add("JLG51302A08");
	tisToDelete.add("JLG51302A09");
	tisToDelete.add("JLG51302A10");
	tisToDelete.add("JLG51302A11");
	tisToDelete.add("JLG51302A12");
	tisToDelete.add("JLG51302A13");
	tisToDelete.add("JLG51302A14");
	tisToDelete.add("JLG51302A15");
	tisToDelete.add("JLG51302A16");
	tisToDelete.add("JLG51302A17");
	tisToDelete.add("JLG51302A18");
	tisToDelete.add("JLG51302A19");
	tisToDelete.add("JLG51302A20");
	
	create tiSet transient;
	
	cargoType := self.getCargoType("METAL");
	self.assertNotNull(cargoType);
	
	foreach trackedItem in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItem, cargoType.id, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItem.pos(".",1) &gt; 0 then
			ti := trackedItem.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	create vehicles transient;
	vehicles.add("51302");
	vehicles.add("51302A");
	vehicles.add("51302B");
	vehicles.add("51302C");
	
	foreach vehicleId in vehicles do
	
		vehicle := self.getVehicle(vehicleId);
		if vehicle = null then
			app.writeLog("Unable to find vehicle " &amp; vehicleId, LogINFO);
			return;
		endif;
		
		foreach vvr in vehicle.visitRecords discreteLock do
			
			if vvr.timeOut &lt;&gt; null then
				continue;
			endif;
			
			self.deleteVVR(vvr);
			
		endforeach;
		
		self.deleteVehicle(vehicleId);
		
	endforeach;

	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tisToDelete;
	delete tiSet;
	delete vehicles;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_51312" id="d79e1d3f-bcc9-4575-ae41-11645a8525bc">
        <source>resetData_51312();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/10/2022	navmk3	Initial creation

*/
constants
	ReleaseNumber			= "RELROAD51312A01";
vars
	terminal, passportTerm			: CM_Terminal;
	release, pxyBulkRelease			: CM_BulkRelease;
	
begin
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	self.deleteReleaseRequest(ReleaseNumber);
	// add release requests
	self.opts.addAssoc("Number", 2);
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Voyage", self.getVoyage("MSCK000010").CM_Voyage);
	self.opts.addAssoc("Operator", app.myRoot.allOperators["MSC"].CM_Operator);
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("Carrier", self.getCarrier("AAUTO"));
	
	release := self.addReleaseByTypeRequestOpts(ReleaseNumber, 1, 1);

	// add Bag of Sand request line
	pxyBulkRelease	:=	app.createUpdateProxy(release).CM_BulkRelease;
	self.opts.addAssoc("NoDelete", true);
	self.opts.addAssoc("ProductStr", "BIGSAND");
	self.addReleaseRequestByTypeLine(ReleaseNumber, app.myRoot.allCargoTypesById[10016].id, null, null, 10, pxyBulkRelease);
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_51807" id="f15e17d4-8e88-42bd-984d-e92496c35fc3">
        <source>resetData_51807();
/*

Purpose:	Reset 51807	

Date		Who		Reason
24/08/2021	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	passportTerm 			: CM_Terminal;
	machine					: CM_Machine;
	
	machines				: StringArray;
	
	machineStr				: String;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create machines transient;
	machines.add("FK23");
	machines.add("FK24");
	machines.add("FK25");
	machines.add("FK26");
	machines.add("FK27");
	machines.add("FK28");
	
	foreach machineStr in machines do
		machine := self.getMachine(machineStr);
		self.assertNotNull(machine);
		self.machineLogOff(machine);
	endforeach;
	
	

	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
	delete machines;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_51817" id="1b179c23-de97-4d4d-a820-751517f515c6">
        <source>resetData_51817();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/05/2022	navmh5	Initial creation

*/


vars

	internalJob					: CM_YardInternalJob;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	

begin

	app.initialize();
		
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	beginTransaction;
	foreach internalJob in CM_YardInternalJob.instances discreteLock do
	
		if internalJob.jobId &lt;&gt; "MPBS01-&gt;Unknown 1" then
			continue;
		endif;
	
		if internalJob.myTerminal = null or internalJob.myTerminal.code &lt;&gt; "TT1" then
			continue;
		endif;
		
		internalJob.erase(NORMAL_ERASE);
	
	endforeach;
	commitTransaction;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
end;






</source>
    </JadeMethod>
    <JadeMethod name="resetData_51940" id="10154363-72b2-4657-8127-ff2ce337bf85">
        <source>resetData_51940();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/11/2021	navmk3	Initial creation

*/

constants

	VehicleID				: String = "51940";
	
vars

	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
begin

	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// delete the vehicle visit
	foreach vvr in CM_VehicleVisitRecord.instances discreteLock where vvr.regNumber = "51940" and vvr.timeOut = null do
		if vvr &lt;&gt; null then
			self.ignoreTrxWarnings(true); 
			app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endforeach;
	
	self.deleteReleaseRequest("JLG51940ROAD001");
	
epilog

end;
</source>
    </JadeMethod>
