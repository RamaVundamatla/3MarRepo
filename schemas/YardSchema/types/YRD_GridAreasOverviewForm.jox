    <JadeMethod name="doShowHideSubMainCol" id="1e28f7ff-7aa7-4784-9b61-1c3574acf549">
        <updating/>
        <source>doShowHideSubMainCol() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	if not self.xmlSelector or not self.xmlLegend then
		if not self.dkcSubMainCol.visible then
			//at least one is trying to be visible
			self.dkcSubMainCol.visible := true;
			
			//Don't be clever and consolidate this, it doesn't work without resetting it twice.
			//(Adds the dock bar back on the wrong side with neither.)
			//(Leaves out the splitter without the second one.)
			self.dkcSubMainCol.alignContainer := JadeDockBar.AlignContainer_Left;
			self.dkcSubMainCol.alignContainer := JadeDockBar.AlignContainer_AllVertical;
		
		endif;
		
	else
		//neither visible
		self.dkcSubMainCol.visible := false;
	endif; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowSectionRequested" id="29cd4ebb-58f3-47a9-939f-78c5d2329c85">
        <source>doShowSectionRequested(
	_row		: Boolean;
	_column		: Boolean;
	_area		: Boolean ) protected;

/*

Purpose:		This will open the YardGridAreasForm for the required section of the Teminal.
Parameters:		The input parameters indicate whether a row, column or area should be opened,
				if no boolean is supplied as true will default to area.
Return Value:	none

Date				Who		Reason
22 April 2009		cnwrl1	Initial creation PAR 19463 - Changes to Satellite View Form

*/
	
vars
	gridArea	: CM_GridArea;
	theObj		: Object;
	objs		: ObjectArray;
	
	
begin
	theObj	:= self.myDrawingFrame.getObjectForPosition( self.saveContextMenuX, self.saveContextMenuY );
	if theObj = null then
		return;
	endif;
	
	if theObj.isKindOf( CM_TrackedItem ) then
		theObj	:= theObj.CM_TrackedItem.myPrimaryActualLocation;
	endif;
	if theObj = null or not theObj.isKindOf( CM_GridController ) then
		return;
	endif;
	
	create objs transient;
	
	if _row then
		objs.add( theObj.CM_GridController.myGridRow.allControllersByColumn.first );
		objs.add( theObj.CM_GridController.myGridRow.allControllersByColumn.last );
	elseif _column then
		objs.add( theObj.CM_GridController.myGridColumn.allControllersByRow.first );
		objs.add( theObj.CM_GridController.myGridColumn.allControllersByRow.last );
	else
		gridArea	:= theObj.CM_GridController.myTerminalArea.CM_GridArea;
		objs.add( gridArea.allGridControllersByRowColumn.first );
		objs.add( gridArea.allGridControllersByRowColumn.last );
	endif;
	
	self.myAssistant.showYardGridAreasForm(	objs,
											self.myCurrentDrawingController.getViewMode(),
											self.myMasterMenuAction,
											0);		// PAR 21532 CCMS SFW 1025 - Added 0 parameter
	
epilog
	delete objs;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_row" type="Boolean"/>
        <Parameter name="_column" type="Boolean"/>
        <Parameter name="_area" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableClick" id="42f7ff6c-162a-4d7b-901d-ee59860c75c4">
        <updating/>
        <source>doTableClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		DO NOT DELETE Call back from CMUI_ColourLegendFrame
//
// ---------------------------------------------------------------------------
vars

