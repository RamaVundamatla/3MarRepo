//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11/03/2010		cnwdap1			PAR #23111 relatedTo should be reefersRelatedto - missed during changes for CCMS MES 1007
// ---------------------------------------------------------------------------

vars

	parent : CM_TrackedItem;
begin
	//parent := self.relatedTo.first();										// PAR #23111
	if self.reefersRelatedTo.first() &lt;&gt; null then							// PAR #23111
		parent := self.reefersRelatedTo.first().myParent.CM_TrackedItem;	// PAR #23111
	endif;																	// PAR #23111
	if parent &lt;&gt; null then
		self.locationId := parent.locationId;
		self.plannedLocnId := parent.plannedLocnId;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyGeneratorType" id="b5976475-ac70-463b-a05b-b7d13e815218">
        <updating/>
        <source>setMyGeneratorType(_generatorType: CM_GeneratorType) updating;
/* ---------------------------------------------------------------------------
Created:	13 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

