    </JadeMethod>
    <JadeMethod name="setFromQuickFind" id="4c12bc08-60f8-4092-a2df-cad03a3d89fd">
        <updating/>
        <source>setFromQuickFind(_obj: CM_Object; _text: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2014	cnwndl1	Initial creation
16/03/2015 			cnwmh5	Transient Leak
*/

vars

	index : Integer;
	role : CM_SecurityRole;
	parentArray : ObjectArray;
	lineRole : CM_SecurityRole;
	size : Integer;
	pos : Integer;

begin

	self.doWindowEvents(1);

	if _obj &lt;&gt; null then
	
		role := _obj.CM_SecurityRole;
		
		create parentArray transient;
		parentArray.add( role );
		lineRole := role;
		while lineRole.myParentRole &lt;&gt; null do
			parentArray.add( lineRole.myParentRole );
			lineRole := lineRole.myParentRole;
		endwhile;
		
		if lineRole.isKindOf( CM_SecurityRoleSystemRoot ) then
			if self.cmbMode.listIndex &lt;&gt; 1 then
				self.cmbMode.listIndex := 1;
				self.cmbMode_click( self.cmbMode );
			endif;
		elseif lineRole.isKindOf( CM_SecurityRoleTerminalRoot ) then
			if self.cmbMode.listIndex &lt;&gt; 2 then
				self.cmbMode.listIndex := 2;
				self.cmbMode_click( self.cmbMode );
			endif;
		endif;
		
		size := parentArray.size;
		if size &gt; 1 then
			foreach pos in 2 to size reversed do
				lineRole := parentArray[pos].CM_SecurityRole;
				index := self.lstData.findObject( lineRole );
				if not self.lstData.itemExpanded[index] then
					self.doPicClick(index);
				endif;
			endforeach;
		endif;
		
		index := self.lstData.findObject( role );
		if index &gt; 0 then
			self.lstData.listIndex := index;
			self.lstData_click( self.lstData );
		endif;
	endif;

epilog
	delete parentArray;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="setIsFiltering" id="da337410-c449-47a0-a2d8-fb6c2e77fcf7">
        <updating/>
        <source>setIsFiltering( _value : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2018	jlger1	Initial creation 36402

*/

vars
	permObj : CM_PermissionObject;
	sht : Integer;
	topSheet,
	sheet : Sheet;
	tmpCntrl : Control;
	permissionsAvailable : Integer;
begin
	self.lblFilterDesc.visible:=false;
	self.isFiltering:=_value;
	self.allFilteredPermissions.clear;
	self.allInvalidFilterPermission.clear;
	if self.isFiltering then
		self.myPermissionAgent.getPermissionsForFilter(self.allFilteredPermissions,self.filterKeyword,self.filterContext);
		if self.allFilteredPermissions.size = 0 then
			app.msgBox( app.getErrorString(UiNo_Results), app.getErrorString(Error), MsgBox_OK_Only);
			self.setIsFiltering(false);
		endif;
		foreach permObj in  self.allFilteredPermissions do
			if self.viewMode = self.ViewSystem then
				if not permObj.isSystemPermission then		
					self.allInvalidFilterPermission.add(app.getErrorString1(Not_system_permission,permObj.description));
				endif;
			else
				if  permObj.isSystemPermission then
					self.allInvalidFilterPermission.add(app.getErrorString1(Not_terminal_permission, permObj.description));
				endif;
			endif;
		endforeach;
	endif;	
	sht:=1;
	
	foreach sht in 1 to self.controlCount do
		tmpCntrl := self.controls(sht);
		if tmpCntrl = self.shtUsers or tmpCntrl = shtRoleDefn then
			continue;
		endif;
		if tmpCntrl.parent = self.fldPermissions and
		   Sheet.hasInstance(tmpCntrl) then
			tmpCntrl.visible:=self.getIsSheetVisible(tmpCntrl.Sheet);
			if not tmpCntrl.visible then
				continue;
			endif;
			self.fldPermissions.topSheet := tmpCntrl.Sheet;
			if isFiltering then
				self.fillTableForCategory(tmpCntrl.Sheet.caption);
				if topSheet = null and tmpCntrl.Sheet.visible then
					topSheet:= tmpCntrl.Sheet;
				endif;
			endif;
		endif;
	endforeach;	
	
	
	if self.isFiltering then
	
	/*	if self.allInvalidFilterPermission.size &gt;= self.allFilteredPermissions.size then
			app.showErrorWarningDialogArray(app.getErrorString(Search), self.allInvalidFilterPermission,null,MsgBox_OK_Only);
			self.setIsFiltering(false);
			return;
		elseif not self.allInvalidFilterPermission.isEmpty then
			app.showErrorWarningDialogArray(app.getErrorString(Search), null,self.allInvalidFilterPermission,MsgBox_OK_Only);
		endif; */
		//05 Feb 2021	NDL	TFS 50757
		if not self.allInvalidFilterPermission.isEmpty then
			if self.viewMode = self.ViewSystem then
				app.msgBox( "'Terminal Roles' contains another " &amp; self.allInvalidFilterPermission.size.String &amp; " matches!", app.getErrorString(Warning), MsgBox_OK_Only);
			else
				app.msgBox( "'System Roles' contains another " &amp; self.allInvalidFilterPermission.size.String &amp; " matches!", app.getErrorString(Warning), MsgBox_OK_Only);
			endif;
		endif;
		
		
		self.lblFilterDesc.visible:=true;
		self.lblFilterDesc.autoSize:=true;
		if self.filterContext = CM_PermissionAgent.FilterHandHeld then
			self.lblFilterDesc.caption:= "Permissions for Hand Held App - " &amp; self.filterKeyword;
		elseif self.filterContext = CM_PermissionAgent.FilterWebservices then
			self.lblFilterDesc.caption:= "Permissions for Webservice - " &amp; self.filterKeyword;
		elseif self.filterContext = CM_PermissionAgent.FilterMobileApps  then
			self.lblFilterDesc.caption:= "Permissions for Mobile App - " &amp; self.filterKeyword;
		elseif self.filterContext = CM_PermissionAgent.FilterText  then	//05 Feb 2021	NDL	TFS 50757
			self.lblFilterDesc.caption:= "Permissions including the text - " &amp; self.filterKeyword;
		endif;
	endif;
	
	if topSheet &lt;&gt; null then
		self.fldPermissions.topSheet:=topSheet;
	endif;
	if self.fldPermissions.topSheet &lt;&gt; null then
		self.fldPermissions.topSheet.click(topSheet);
	endif;
	self.btnResetFilter.visible:=_value;
	//self.btnShowFilter.visible:= not _value;
	self.frmToolbar.positionToolbarControls;
	
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="754e3440-3bc4-42d4-a397-842b52e833ef">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myDataClass := CM_SecurityRole;

end;</source>
    </JadeMethod>
    <JadeMethod name="setSheetsForParentRole" id="431d6b4d-8e0a-492b-8e79-02666bfca944">
        <source>setSheetsForParentRole(_parentRole : CM_SecurityRole; _categories : StringArray) protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2003		cnwth2	
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 21/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 30 Aug 2019	jlgdi1		TFS 45802 Visibility of the Invoice Status Sheet will depend on the 
//							allInvoiceStatusesMaint collection of the parent role
// 23/09/2022   navds20     ChangeRequest 54253: EUP - VAS Work Orders
vars
	currCatNumber 	: Integer;
	currCatName 	: String;
	tmpRole			: CM_SecurityRole;

begin
	tmpRole := _parentRole;

	if self.viewMode = ViewSystem then
		self.shtStopsMaint.visible	:= false;
		self.shtStopsCancel.visible	:= false;		// cnwdad1 03/06/2010 - CCMS 1129.
		self.shtStopsView.visible 	:= false;
		self.shtReports.visible		:= false;
		self.shtToDoTasks.visible	:= false;
		self.shtTransactions.visible:= false;				
		self.shtStatus.visible		:= false;											// TFS 37445
		self.shtInvoiceStatus.visible := false; // TFS 39618	
		self.shtworkOrderStatus.visible := false; //23/09/2022 navds20 TFS 54253
		self.shtVolDiscReasons.visible := false;	// 29/4/19 MAP TFS41707
		self.shtEventTypes.visible	:= false;	//09 Mar 2020	NDL	TFS 48784
	else
		self.shtStopsMaint.visible	:= (not tmpRole.allStopsMaint.isEmpty);
		self.shtStopsCancel.visible	:= (not tmpRole.allStopsCancel.isEmpty);		// cnwdad1 03/06/2010 - CCMS 1129.
		self.shtStopsView.visible 	:= (not tmpRole.allStopsView.isEmpty);
		self.shtReports.visible		:= (not tmpRole.allQryReports.isEmpty);
		self.shtToDoTasks.visible	:= (not tmpRole.allToDoTasksAddRemove.isEmpty) or (not tmpRole.allToDoTasksComplete.isEmpty);
		self.shtTransactions.visible:= (not tmpRole.allTransactionTypesForEvents.isEmpty);
		self.shtStatus.visible		:= (not tmpRole.allVoyageStatusesMaint.isEmpty);	// TFS 37445
		self.shtInvoiceStatus.visible := (not tmpRole.allInvoiceStatusesMaint.isEmpty);	// TFS 45802
		self.shtworkOrderStatus.visible := (not tmpRole.allWorkOrderStatusMaint.isEmpty);	//26/09/2022 navds20 TFS 54253
		self.shtVolDiscReasons.visible := true;	// 29/4/19 MAP TFS41707	
		self.shtworkOrderStatus.visible := true; //23/09/2022 navds20 TFS 54253
		self.shtEventTypes.visible	:= (not tmpRole.allEventTypes.isEmpty);	//09 Mar 2020	NDL	TFS 48784
	endif;
	
	shtMaintRoles.visible := false; shtMaintRoles.enabled := false;	//12 Feb 2018	NDL	TFS 36947

	shtPermCat1.visible  := false; shtPermCat1.enabled  := false;
	shtPermCat2.visible  := false; shtPermCat2.enabled  := false;
	shtPermCat3.visible  := false; shtPermCat3.enabled  := false;
	shtPermCat4.visible  := false; shtPermCat4.enabled  := false;
	shtPermCat5.visible  := false; shtPermCat5.enabled  := false;
	shtPermCat6.visible  := false; shtPermCat6.enabled  := false;
	shtPermCat7.visible  := false; shtPermCat7.enabled  := false;
	shtPermCat8.visible  := false; shtPermCat8.enabled  := false;
	shtPermCat9.visible  := false; shtPermCat9.enabled  := false;
	shtPermCat10.visible := false; shtPermCat10.enabled := false;
	shtPermCat11.visible := false; shtPermCat11.enabled := false;
	shtPermCat12.visible := false; shtPermCat12.enabled := false;
	shtPermCat13.visible := false; shtPermCat13.enabled := false;
	shtPermCat14.visible := false; shtPermCat14.enabled := false;
	shtPermCat15.visible := false; shtPermCat15.enabled := false;

	currCatNumber := 0;

	foreach currCatName in _categories do
		currCatNumber := currCatNumber + 1;

		if currCatNumber = 1 then
			shtPermCat1.caption  := currCatName; shtPermCat1.enabled  := true; shtPermCat1.visible  := true;
		elseif currCatNumber = 2 then
			shtPermCat2.caption  := currCatName; shtPermCat2.enabled  := true; shtPermCat2.visible  := true;
		elseif currCatNumber = 3 then
			shtPermCat3.caption  := currCatName; shtPermCat3.enabled  := true; shtPermCat3.visible  := true;
		elseif currCatNumber = 4 then
			shtPermCat4.caption  := currCatName; shtPermCat4.enabled  := true; shtPermCat4.visible  := true;
		elseif currCatNumber = 5 then
			shtPermCat5.caption  := currCatName; shtPermCat5.enabled  := true; shtPermCat5.visible  := true;
		elseif currCatNumber = 6 then
			shtPermCat6.caption  := currCatName; shtPermCat6.enabled  := true; shtPermCat6.visible  := true;
		elseif currCatNumber = 7 then
			shtPermCat7.caption  := currCatName; shtPermCat7.enabled  := true; shtPermCat7.visible  := true;
		elseif currCatNumber = 8 then
			shtPermCat8.caption  := currCatName; shtPermCat8.enabled  := true; shtPermCat8.visible  := true;
		elseif currCatNumber = 9 then
			shtPermCat9.caption  := currCatName; shtPermCat9.enabled  := true; shtPermCat9.visible  := true;
		elseif currCatNumber = 10 then
			shtPermCat10.caption := currCatName; shtPermCat10.enabled := true; shtPermCat10.visible := true;
		elseif currCatNumber = 11 then
			shtPermCat11.caption := currCatName; shtPermCat11.enabled := true; shtPermCat11.visible := true;
		elseif currCatNumber = 12 then
			shtPermCat12.caption := currCatName; shtPermCat12.enabled := true; shtPermCat12.visible := true;
		elseif currCatNumber = 13 then
			shtPermCat13.caption := currCatName; shtPermCat13.enabled := true; shtPermCat13.visible := true;
		elseif currCatNumber = 14 then
			shtPermCat14.caption := currCatName; shtPermCat14.enabled := true; shtPermCat14.visible := true;
		elseif currCatNumber = 15 then
			shtPermCat15.caption := currCatName; shtPermCat15.enabled := true; shtPermCat15.visible := true;
		else
			// Assume a maximum of 15 permission categories - if there's ever more, we need more sheets
			app.msgBox("Exceeded maximum number of permission categories", "Error", MsgBox_OK_Only);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_parentRole" type="CM_SecurityRole"/>
        <Parameter name="_categories" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setSheetsForPermission" id="921736cc-d8ff-4547-bdb8-1993cbe4a0fa">
        <source>setSheetsForPermission(_role : CM_SecurityRole; _categories : StringArray) protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2003		cnwth2	
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 21/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 30 Aug 2019	jlgdi1		TFS 45802 Visibility of the Invoice Status Sheet will depend on the 
//							allInvoiceStatusesMaint collection of the parent role. 
//							Also corrected the visibility condition of ToDoTasks sheet
// 23/09/2022   navds20     ChangeRequest 54253: EUP - VAS Work Orders
vars
	currCatNumber 	: Integer;
	currCatName 	: String;
	tmpRole			: CM_SecurityRole;

begin
	if self.allRootRoles.includes(_role) or _role.myParentRole = null then
		tmpRole := _role;
	else
		tmpRole := _role.myParentRole;
	endif;

	if self.viewMode = ViewSystem then		// For System Roles
		self.shtStopsMaint.visible	:= false;
		self.shtStopsCancel.visible	:= false;		// cnwdad1 03/06/2010 - CCMS 1129.
		self.shtStopsView.visible 	:= false;
		self.shtReports.visible		:= false;
		self.shtToDoTasks.visible	:= false;
		self.shtTransactions.visible:= false;		
		self.shtStatus.visible		:= false;											// TFS 37445
		self.shtInvoiceStatus.visible := false; // TFS 39618	
		self.shtworkOrderStatus.visible := false; //23/09/2022 navds20 TFS 54253
		self.shtVolDiscReasons.visible := false;	// 29/4/19 MAP TFS41707
		self.shtEventTypes.visible	:= false;	//09 Mar 2020	NDL	TFS 48784
	else									// For Terminal Roles
		self.shtStopsMaint.visible	:= (not tmpRole.allStopsMaint.isEmpty);
		self.shtStopsCancel.visible	:= (not tmpRole.allStopsCancel.isEmpty);		// cnwdad1 03/06/2010 - CCMS 1129.
		self.shtStopsView.visible 	:= (not tmpRole.allStopsView.isEmpty);
		self.shtReports.visible		:= (not tmpRole.allQryReports.isEmpty);
		self.shtToDoTasks.visible	:= (not tmpRole.allToDoTasksAddRemove.isEmpty) or (not tmpRole.allToDoTasksComplete.isEmpty);
		self.shtTransactions.visible:= (not tmpRole.allTransactionTypesForEvents.isEmpty);				
		self.shtStatus.visible		:= (not tmpRole.allVoyageStatusesMaint.isEmpty);	// TFS 37445
		self.shtInvoiceStatus.visible := (not tmpRole.allInvoiceStatusesMaint.isEmpty);	// TFS 45802
		self.shtworkOrderStatus.visible := (not tmpRole.allWorkOrderStatusMaint.isEmpty);	//26/09/2022 navds20 TFS 54253
		self.shtworkOrderStatus.visible := true;	//23/09/2022 navds20 TFS 54253
		self.shtVolDiscReasons.visible := true;		// 29/4/19 MAP TFS41707
		self.shtEventTypes.visible	:= (not tmpRole.allEventTypes.isEmpty);	//09 Mar 2020	NDL	TFS 48784
	endif;

	shtPermCat1.visible  := false; shtPermCat1.enabled  := false;
	shtPermCat2.visible  := false; shtPermCat2.enabled  := false;
	shtPermCat3.visible  := false; shtPermCat3.enabled  := false;
	shtPermCat4.visible  := false; shtPermCat4.enabled  := false;
	shtPermCat5.visible  := false; shtPermCat5.enabled  := false;
	shtPermCat6.visible  := false; shtPermCat6.enabled  := false;
	shtPermCat7.visible  := false; shtPermCat7.enabled  := false;
	shtPermCat8.visible  := false; shtPermCat8.enabled  := false;
	shtPermCat9.visible  := false; shtPermCat9.enabled  := false;
	shtPermCat10.visible := false; shtPermCat10.enabled := false;
	shtPermCat11.visible := false; shtPermCat11.enabled := false;
	shtPermCat12.visible := false; shtPermCat12.enabled := false;
	shtPermCat13.visible := false; shtPermCat13.enabled := false;
	shtPermCat14.visible := false; shtPermCat14.enabled := false;
	shtPermCat15.visible := false; shtPermCat15.enabled := false;

	currCatNumber := 0;

	foreach currCatName in _categories do
		currCatNumber := currCatNumber + 1;

		if currCatNumber = 1 then
			shtPermCat1.caption  := currCatName; shtPermCat1.enabled  := true; shtPermCat1.visible  := true;
		elseif currCatNumber = 2 then
			shtPermCat2.caption  := currCatName; shtPermCat2.enabled  := true; shtPermCat2.visible  := true;
		elseif currCatNumber = 3 then
			shtPermCat3.caption  := currCatName; shtPermCat3.enabled  := true; shtPermCat3.visible  := true;
		elseif currCatNumber = 4 then
			shtPermCat4.caption  := currCatName; shtPermCat4.enabled  := true; shtPermCat4.visible  := true;
		elseif currCatNumber = 5 then
			shtPermCat5.caption  := currCatName; shtPermCat5.enabled  := true; shtPermCat5.visible  := true;
		elseif currCatNumber = 6 then
			shtPermCat6.caption  := currCatName; shtPermCat6.enabled  := true; shtPermCat6.visible  := true;
		elseif currCatNumber = 7 then
			shtPermCat7.caption  := currCatName; shtPermCat7.enabled  := true; shtPermCat7.visible  := true;
		elseif currCatNumber = 8 then
			shtPermCat8.caption  := currCatName; shtPermCat8.enabled  := true; shtPermCat8.visible  := true;
		elseif currCatNumber = 9 then
			shtPermCat9.caption  := currCatName; shtPermCat9.enabled  := true; shtPermCat9.visible  := true;
		elseif currCatNumber = 10 then
			shtPermCat10.caption := currCatName; shtPermCat10.enabled := true; shtPermCat10.visible := true;
		elseif currCatNumber = 11 then
			shtPermCat11.caption := currCatName; shtPermCat11.enabled := true; shtPermCat11.visible := true;
		elseif currCatNumber = 12 then
			shtPermCat12.caption := currCatName; shtPermCat12.enabled := true; shtPermCat12.visible := true;
		elseif currCatNumber = 13 then
			shtPermCat13.caption := currCatName; shtPermCat13.enabled := true; shtPermCat13.visible := true;
		elseif currCatNumber = 14 then
			shtPermCat14.caption := currCatName; shtPermCat14.enabled := true; shtPermCat14.visible := true;
		elseif currCatNumber = 15 then
			shtPermCat15.caption := currCatName; shtPermCat15.enabled := true; shtPermCat15.visible := true;
		else
			// Assume a maximum of 15 permission categories - if there's ever more, we need more sheets
			app.msgBox("Exceeded maximum number of permission categories", "Error", MsgBox_OK_Only);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_role" type="CM_SecurityRole"/>
        <Parameter name="_categories" type="StringArray"/>
    </JadeMethod>
