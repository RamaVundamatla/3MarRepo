    <JadeMethod name="cnEcGetDuplicate" id="780c97bf-058d-4781-85ae-21a9c98c94f2">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	colour : String;
	vColour : CM_VehicleColour;

begin

	colour := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "colour" ).String; 
	
	if colour &lt;&gt; null then
		vColour := app.myDutyDocRoot.allVehicleColours.getAtKey( colour );
	endif;

epilog

	return vColour;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
