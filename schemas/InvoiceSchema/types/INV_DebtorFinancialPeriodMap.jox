    <JadeMethod name="doSave" id="6c871788-0275-476a-8d5e-2d9d0190d69b">
        <updating/>
        <source>doSave() updating;
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 35872 use query bank not app current bank
vars
	pxyMapping, realMapping : CM_DebtorBankInvTypeDtl;
	isUpdate	: Boolean;
	ls : Boolean;
	theReturn : Integer;
begin
	if self.myCurrentDebtor.isKindOf(CM_DebtorGroup) then
		app.msgBox("Cannot set maps for debtor groups.","Mapping Update Error",MsgBox_OK_Only);
		return;
	endif;
	
	realMapping := self.myCurrentBank.allDebtorBankInvTypeDtls[self.myCurrentDebtor.CM_Debtor, self.myCurrentInvType];

	if realMapping &lt;&gt; null then	
		app.cmsBeginLoad(ls);
		pxyMapping := app.createUpdateProxy(realMapping).CM_DebtorBankInvTypeDtl;
		app.cmsEndLoad(ls);
		isUpdate := true;
	else
		create pxyMapping transient;
		isUpdate := false;
	endif;
	
	pxyMapping.setProxy(self.myCurrentBank, self.myCurrentDebtor.CM_Debtor, self.myCurrentFinPeriod, self.myCurrentInvType);

	while true do
		if isUpdate then
			app.myTrxUA.trxUpdateFinancialPeriodMap(pxyMapping, app.myPassport);
		else
			app.myTrxCA.trxCreateFinancialPeriodMap(pxyMapping, realMapping, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Mapping Entry", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyMapping;
end;</source>
    </JadeMethod>
