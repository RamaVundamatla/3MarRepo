<Class name="CM_SlotDefn" id="07605246-a927-43d2-ae5c-e49b2a09a2a0">
    <superclass name="CM_BayItem"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>


One slot defn for each slot location controller.
In the yard the abillities are stored on the locations controller, but on the ship the abilities are stored on a definition object.</text>
    <DbClassMap file="vessel"/>
    <Constant name="VOLTAGE_TYPE_DUAL" id="40aa4f82-d371-4ad7-8536-bc74c5764d45">
