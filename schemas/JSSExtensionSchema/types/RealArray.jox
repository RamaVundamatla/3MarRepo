<CollClass name="RealArray">
    <JadeMethod name="jssDoSort" id="37a7e288-cdcd-4a17-b874-aebd810a0475">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pTheSorter : JSSSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayPointer	: Integer;
	realValue		: Real;
	theSortKey		: Object;
	anyValue		: Any;

begin
	foreach realValue in self do
		pTheSorter.addValue(realValue);
	endforeach;
	
	self.purge();
	
	foreach theSortKey in pTheSorter.mySortColl do
		self.add(theSortKey.JSSSortKey.getValue().Real);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSorter" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
