    <JadeMethod name="vCheckDatFileSizesGTThreshold" id="c90e3324-72d6-4ada-b920-317d07ee009f">
        <source>vCheckDatFileSizesGTThreshold(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Save Dat file size details and check to see if growth over threshold
				
Date			Who		Reason
20/01/2015		cnwmh5	Initial creation
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
*/

vars
	
	unitTestResult 					: UM_UnitTestResult;
	dba								: JadeDatabaseAdmin;
	dbFile							: DbFile;
	root							: UM_Root;
	classMethod						: UM_UnitTestClassMethod;
	testResult						: UM_UnitTestResult;

	dbFiles							: DbFileArray;
	dict							: DynaDictionary;
	tokens							: StringArray;
	errorArray						: HugeStringArray;
	beforeNameArray					: StringArray;
	beforeSizeArray					: RealArray;
	
	iter							: Iterator;
	
	resultDetails					: String;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	logResult						: Boolean;
	tsToStopAt						: TimeStamp;
	threshold						: Real;
	result							: String;
	detailsStr						: String;
	str								: String;
	dbFileName						: String;
	dbFileSize						: Real;
	pos								: Integer;
	days							: Integer;
	percentageChange				: Decimal[5,2];
	indexOf							: Integer;
	
begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	threshold := 10.00;
	result := "FAIL";
	
	methStartTS := app.cnGetServerTime();
	
	create tokens transient;
	create beforeNameArray transient;
	create beforeSizeArray transient;
	create errorArray transient;
	
	root := UM_Root.firstInstance;
	self.assertNotNull(root);

	// Get the unit test record to check against.  Either yesterday or for logResult run the the previous weeks details
	logResult := app.myUMTestRunONight.logResult;
	classMethod := root.allRunnableUTClassesMethods.getAtKey(method.getSchemaType().name, method.name).UM_UnitTestClassMethod;
	tsToStopAt := tsToStopAt.addDays(-8);
	
	// should only be null if this is the 1st day it's run / 1st logResult run
	days := 1;
	if not classMethod = null then
		delete iter;
		iter := classMethod.allUnitTestResults.createIterator;
		while iter.next(testResult) do
			if logResult then
				// logresult but greater than 8 days ago
				if testResult.myTestRun.logResult and testResult.myTestRun.startTS.date &lt; tsToStopAt.date then
					testResult := null;
					break;
				elseif not testResult.myTestRun.logResult then
					continue;
				endif;
				days := 7;
			endif;
			break;	
		endwhile;
	endif;
	
	if testResult &lt;&gt; null then
		detailsStr := testResult.details.uncompressToString();
		pos := 1;
		pos := detailsStr.pos("The following .dat file(s)", pos);
		if pos &gt; 0 then
			detailsStr := detailsStr[1:pos-1].trimBlanks();
		endif;		
		detailsStr := detailsStr.replaceString(CrLf, "+");
		detailsStr := detailsStr.replaceString(Tab, "`");
		detailsStr.getTokensForDelimiter("+", tokens);
		
		foreach detailsStr in tokens do
			pos := 1;
			pos := detailsStr.pos("`", pos);
			if pos = 0 then
				continue;
			endif;
			dbFileName := detailsStr[1:pos-1].trimBlanks();
			dbFileSize := detailsStr[pos+1:end].trimBlanks().Real;
			
			beforeNameArray.add(dbFileName);
			beforeSizeArray.add(dbFileSize);
		endforeach;
	endif;
	
	// check the current files to see if there is any differences &gt; threshold
	create dict transient;
	dict.setMembership(Object);
	dict.addExternalKey(String, 75, false, true);			// Dat file name 
	dict.endKeys(false);
	
	create dba transient;
	create dbFiles transient;
	dba.getDbFiles(DbFile.Kind_User_Data, dbFiles);
	foreach dbFile in dbFiles do
		dict.putAtKey(dbFile.name, dbFile);
	endforeach;
	
	iter := dict.createIterator;
	while iter.next(dbFile) do
		if resultDetails &lt;&gt; null then
			resultDetails := resultDetails &amp; CrLf;
		endif;
		
		indexOf := beforeNameArray.indexOf(dbFile.name);
		if indexOf = 0 then
			resultDetails := resultDetails.trimBlanks() &amp; dbFile.name &amp; Tab &amp; dbFile.getFileLength().String;
			continue;
		endif;
		
		dbFileSize := beforeSizeArray[indexOf];
		percentageChange := 0.00;
		if dbFileSize &gt; 0.00 then
			percentageChange := ((dbFile.getFileLength() - dbFileSize) / dbFileSize) * 100;
		endif;
		
		resultDetails := resultDetails &amp; dbFile.name &amp; Tab &amp; dbFile.getFileLength().String;
		
		if percentageChange &gt; threshold then
			errorArray.add(dbFile.name &amp; " has increased by  " &amp; percentageChange.String &amp; "% from " &amp; 
				dbFileSize.roundedTo(0).String &amp; " to " &amp; dbFile.getFileLength().roundedTo(0).String);
		endif;		
	endwhile;
	
	resultDetails := resultDetails.replaceString(Tab, " ");
	app.writeLog(resultDetails, LogINFO);
	
	if not errorArray.isEmpty() then
		resultDetails :=  CrLf &amp; CrLf &amp; resultDetails &amp; CrLf &amp; 
			"The following .dat file(s) have increased by at least " &amp; threshold.String &amp; "% in the last " &amp; days.String &amp;" day(s):" &amp; CrLf;
		foreach str in errorArray do
			resultDetails := resultDetails &amp; CrLf &amp; str;
		endforeach;
	else
		result := "PASS";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;			
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, resultDetails, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
		
epilog
	
	delete iter;
	delete dba;
	delete dbFiles;
	delete dict;
	delete tokens;
	delete errorArray;
	delete beforeSizeArray;
	delete beforeNameArray;

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCheckForBlameObjects" id="5b386a60-b714-40f2-a10b-4bc7ef5e7f1f">
        <source>vCheckForBlameObjects(_userSummary : CM_AssociationDict io);

/*

Purpose:		Check to see if there are any UM_Blame or UM_BlameItem objects.  If they exist then send to 
				Delete routine and advise admins as needs to check why they are there.

Date			Who		Reason
13/06/2016		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	unitTestResult							: UM_UnitTestResult;
	blame									: UM_Blame;
	root									: UM_Root;
	objToDelete								: UM_ObjectsToDelete;
	
	methStartTS								: TimeStamp;
	methEndTS								: TimeStamp;
	elapsedTime								: TimeStampInterval;
	resultStr								: String;
	blameCount								: Integer;
	newBlameCount							: Integer;
	outputStr								: String;
	
begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;

	methStartTS := app.cnGetServerTime();
	
	beginTransaction;
	foreach blame in UM_Blame.instances discreteLock do
		blameCount := blameCount + 1;
		
		objToDelete := root.allObjectsToDeleteByObject[blame.getOidAsString()];
		if objToDelete &lt;&gt; null then				// exists don't require
			continue;
		endif;
	
		newBlameCount := newBlameCount + 1;
		//create objToDelete persistent;
		//objToDelete.updateDetails(blame, UM_ObjectsToDelete.WhenToDeleteNext);
	endforeach;
	commitTransaction;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	outputStr := null;
	if blameCount &gt; 0 then
		outputStr := blameCount.String &amp; " UM_Blame objects found.  " &amp; newBlameCount.String &amp; " are new.";
		_userSummary.addAssociation("CNWMH5", "Fail " &amp; method.getSchemaType().name &amp; " " &amp; 
			method.name &amp; " ADMIN    " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; outputStr);
		resultStr := 'FAIL ';
	else	
		resultStr := "PASS ";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, outputStr, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;		
	
epilog

end;</source>
        <Parameter name="_userSummary" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCheckForConfigChanges" id="3dd9adb0-736d-49e1-92af-e762982e2cee">
        <source>vCheckForConfigChanges(_userSummaryDict : CM_AssociationDict io; _unitTestRun : UM_UnitTestRun io; _startTime : String);

/*
Purpose:        Check for changes in the config values
Date            Who     Reason
17/06/2015      cnwmh5  Initial creation
26/08/2025      navvk1  Fixed failing UT MTN-34210
01/09/2025      navvk1  Leak / invalid object fix (removed nested begin/finally, safe dictionary usage) MTN-34210
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
15 Oct 2025     navsp1  MTN-34201  MTN - Dump Config before first unit test and last unit test for comparison - Phase2
*/

vars
    object              : Object;
    testRun             : UM_UnitTestRun;
    unitTestResult      : UM_UnitTestResult;
    classMethod         : UM_UnitTestClassMethod;
    root                : UM_Root;
	// navvk1 MTN-34210
    parseArr            : HugeStringArray;   // temporary per-activity
    storeArr            : HugeStringArray;   // retained in dyna
    dyna                : DynaDictionary;
    iter                : Iterator;

    errorStr            : String;
    invalidActivity     : Boolean;
    startTS             : TimeStamp;
    keyStr              : String;
    was                 : String;
    now                 : String;
    pos                 : Integer;
    str                 : String;
    pos2                : Integer;
    methStartTS         : TimeStamp;
    methEndTS           : TimeStamp;
    elapsedTime         : TimeStampInterval;
    resultStr           : String;
    methodName          : String;
	// navvk1 MTN-34210
    cmTerminal          : CM_Terminal;
    cmIter              : Iterator;
    cmActivity          : CM_ActivityHistory;//CM_ActivityHistoryGeneral;    
    splitTS             : TimeStamp;
    thisRunStartTS      : TimeStamp;
    errorStrThisRun     : String;
    prevTestRun         : UM_UnitTestRun;
begin
    methStartTS := app.cnGetServerTime();
	// navvk1 MTN-34210
    cmTerminal := app.myRoot.allTerminals["UT"];
    if cmTerminal = null then
        return;
    endif;
    cmIter := cmTerminal.allActivityHistory.createIterator;

    if _unitTestRun = null then
        testRun := UM_UnitTestRun.lastInstance;
    endif;

    if testRun = null then
        startTS := app.myUMTestRunONight.startTS;
    else
        prevTestRun := testRun.getPreviousTest();       //MTN-34201
        if prevTestRun &lt;&gt; null then                     //MTN-34201
            startTS := prevTestRun.endTS;               //MTN-34201
        elseif testRun.startTS &lt;&gt; null then             //MTN-34201
            startTS := testRun.startTS;
        endif;
    endif;

    create dyna transient;
    dyna.setMembership(HugeStringArray);
    dyna.addExternalKey(String, 32, true, false);
    dyna.endKeys(false);

    on Exception do app.handleDeletedObject(exception, cmActivity, invalidActivity);

    // Reverse iterate activities - navvk1 MTN-34210
    while cmIter.back(cmActivity) do
        if cmActivity.dateTime &lt; startTS then
            break;
        endif;
        if cmActivity.description = null or cmActivity.description.cnContains("NoExportStops") then
            continue;
        endif;
        if cmActivity.myTerminal = null or cmActivity.myTerminal.code &lt;&gt; "UT" then
            continue;
        endif;

        create parseArr transient;

        // Prefer extra detail if available
        if cmActivity.isActivityHistoryGeneral and cmActivity.CM_ActivityHistoryGeneral.allExtraDetail &lt;&gt; null and cmActivity.CM_ActivityHistoryGeneral.allExtraDetail.size &gt; 0 then
            str := cmActivity.CM_ActivityHistoryGeneral.allExtraDetail[1];
            str.getTokensForDelimiterHuge("'", parseArr);
        else
            cmActivity.description.getTokensForDelimiterHuge("'", parseArr);
        endif;

        if parseArr.size &gt;= 4 then
            // Determine key (config name)
            pos := parseArr[1].pos(",", 1);
            if pos &gt; 0 then
                str := parseArr[1][1:pos - 1];
            else
                str := parseArr[1];
            endif;
            pos2 := str.reversePos(" ");
            if pos2 &gt; 0 then
                keyStr := str[pos2 + 1 : str.length - pos2].trimBlanks();
            else
                keyStr := str.trimBlanks();
            endif;

            was := parseArr[2];
            now := parseArr[4];
            if now.cnContains("** initialised **") then
                now := "null";
            endif;

            object := dyna.getAtKey(keyStr);
            if object = null then
                create storeArr transient;
                storeArr.add(was);
                storeArr.add(now);
                storeArr.add(cmActivity.userCode);
                storeArr.add(cmActivity.creationTime.date.format("dd/MM/yyyy"));
                storeArr.add(cmActivity.creationTime.time.String);
                dyna.putAtKey(keyStr, storeArr);
            else
                storeArr := object.HugeStringArray;
                if storeArr.size &gt;= 2 then
                    storeArr[2] := now;
                endif;
            endif;
        endif;

        delete parseArr;   // never stored
    endwhile;

    // Build error summary
    iter := dyna.createIterator;
    while iter.next(object) do
        dyna.getIteratorKeys(keyStr, iter);
        storeArr := object.HugeStringArray;
        if storeArr &lt;&gt; null and storeArr.size &gt;= 2 and storeArr[1] &lt;&gt; storeArr[2] then
            splitTS.setDate(storeArr[4].Date);                                                  //MTN-34201
            splitTS.setTime(storeArr[5].Time);                                                  //MTN-34201
            if _startTime &lt;&gt; null and splitTS &gt; _startTime.TimeStamp then                       //MTN-34201
                 errorStrThisRun &amp;=
                                    keyStr &amp; Tab &amp; "was originally: " &amp; Tab &amp; storeArr[1] &amp; Tab &amp;
                                    " was Changed to: " &amp; Tab &amp; storeArr[2] &amp; " by: " &amp; storeArr[3] &amp;
                                    " on " &amp; storeArr[4] &amp; " at " &amp; storeArr[5] &amp; CrLf;
            else
                        errorStr &amp;=
                                    keyStr &amp; Tab &amp; "was originally: " &amp; Tab &amp; storeArr[1] &amp; Tab &amp;
                                    " was Changed to: " &amp; Tab &amp; storeArr[2] &amp; " by: " &amp; storeArr[3] &amp;
                                    " on " &amp; storeArr[4] &amp; " at " &amp; storeArr[5] &amp; CrLf;
             
             endif;
        endif;
    endwhile;

    if errorStr &lt;&gt; null then                                                                    //MTN-34201
        errorStr := "A configuration has been changed from its previous setting :" &amp; CrLf &amp; errorStr;    
    endif;
   if errorStrThisRun &lt;&gt; null then                                                              //MTN-34201
       errorStr    := errorStr &amp; CrLf &amp; "A configuration change was detected during this unit test run." &amp; CrLf &amp; errorStrThisRun;
    endif;
 

    if not app.isOvernightRun then
        self.assertTrueMsg(errorStr = null, "Failed: " &amp; errorStr);
    endif;

    methEndTS := app.cnGetServerTime();
    elapsedTime := methEndTS - methStartTS;

    resultStr := "PASS";
    if errorStr &lt;&gt; null then
        resultStr := "FAIL";
    endif;

    if app.isOvernightRun then
        beginTransaction;
        create unitTestResult persistent;
        resultStr := resultStr.trimBlanks().toUpper();
        root := UM_Root.firstInstance;
        methodName := method.name &amp; "(Start)";
        classMethod := root.allRunnableUTClassesMethods[method.getSchemaType().name, methodName];
        if classMethod &lt;&gt; null then
            methodName := method.name &amp; "(End)";
        endif;
        unitTestResult.updateDetails(
            method.getSchemaType().name,
            methodName,
            (elapsedTime.getMilliseconds / 1000).String,
            "",
            app.getUTAdminUserCode(),
            resultStr,
            errorStr,
            methStartTS,
            app.myUMTestRunONight, 
			method.text);					//17.10.2025 navbs1  #34979
        unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
        commitTransaction;
    endif;

    // Early cleanup of iterators (also repeated safely in epilog)
    if iter &lt;&gt; null then 
		delete iter; 
	endif;
    if cmIter &lt;&gt; null then 
		delete cmIter; 
	endif;

epilog
    // Delete stored arrays and containers
    foreach object in dyna do
        if object &lt;&gt; null then
            delete object;
        endif;
    endforeach;
    delete dyna;
    if iter &lt;&gt; null then 
		delete iter; 
	endif;
    if cmIter &lt;&gt; null then 
		delete cmIter; 
	endif;
end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
        <Parameter name="_startTime" type="String"/>
    </JadeMethod>
    <JadeMethod name="vCheckForStackDumps" id="ed4da126-a37d-4935-a9af-aa89fc422e5d">
        <source>vCheckForStackDumps(_startTS, _endTS : TimeStamp input; _userSummary : CM_AssociationDict io);

/*

Purpose:		Check to see if there are any stack dumps on CNWCHCS11 between the start and end of the unit test run

Date			Who		Reason
29/11/2013		cnwmh5	Initial creation
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
17 Oct 2025	navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	fileFolder								: FileFolder;
	fileNode								: FileNode;
	unitTestResult							: UM_UnitTestResult;
	
	outputStr								: String;
	methStartTS								: TimeStamp;
	methEndTS								: TimeStamp;
	elapsedTime								: TimeStampInterval;
	resultStr								: String;

begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	methStartTS := app.cnGetServerTime();

	create fileFolder transient;
	fileFolder.fileName := app.getAppServerLogDir() &amp; "\";
	fileFolder.usePresentationFileSystem := false;
	fileFolder.mask := "*dump_*].log";
	
	outputStr := null;
	foreach fileNode in fileFolder.files do
		if fileNode.createdTime &gt;= _startTS and fileNode.createdTime &lt;= _endTS then
			outputStr := outputStr.trimBlanks() &amp; CrLf &amp; fileNode.fileName;
			app.stackDumpCount := app.stackDumpCount + 1;											// 01/05/2014 cnwmh5
		endif;
	endforeach;

	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	if outputStr &lt;&gt; null then
		_userSummary.addAssociation("CNWMH5", "Fail " &amp; method.getSchemaType().name &amp; " " &amp; 
			method.name &amp; " ADMIN    " &amp; _startTS.date.String &amp; " " &amp; _startTS.time.String &amp; CrLf &amp; outputStr);
		resultStr := 'FAIL ';
	else	
		resultStr := "PASS ";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, outputStr, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;		
	
epilog

	delete fileFolder;

end;</source>
        <Parameter name="_startTS" type="TimeStamp" usage="input"/>
        <Parameter name="_endTS" type="TimeStamp" usage="input"/>
        <Parameter name="_userSummary" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCheckForStackDumps_MDH" id="d6182163-50ab-44a5-b0ef-03ebece6a5d5">
        <source>vCheckForStackDumps_MDH(_startTS, _endTS : TimeStamp input; _userSummary : CM_AssociationDict io);

/*

Purpose:		Check to see if there are any stack dumps on CNWCHCS11 between the start and end of the unit test run

Date			Who		Reason
29/11/2013		cnwmh5	Initial creation
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
17/02/2017		cnwmh5	Change to find all stack dumps created rather than cnwchcs11 initiated
						Update to add which test was running at the time and who owns it
*/

vars

	fileFolder								: FileFolder;
	fileNode								: FileNode;
	unitTestResult							: UM_UnitTestResult;
	unitTestRun								: UM_UnitTestRun;
	unitTestResult1							: UM_UnitTestResult;
	root									: UM_Root;
	
	mergeIterator							: MergeIterator;
	
	outputStr								: String;
	methStartTS								: TimeStamp;
	methEndTS								: TimeStamp;
	elapsedTime								: TimeStampInterval;
	resultStr								: String;
	summaryStr								: String;
	testName								: String;

begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	methStartTS := app.cnGetServerTime();
	
	// get the result details for the run
	root := UM_Root.firstInstance;
	self.assertNotNull(root);
	
	unitTestRun := root.allUnitTestRuns.last;
	self.assertNotNull(unitTestRun);
	
	create fileFolder transient;
	fileFolder.fileName := "D:\MISC_Logs\17022017DMAST";
	fileFolder.usePresentationFileSystem := true;
	//fileFolder.fileName := app.getAppServerLogDir() &amp; "\";
	//fileFolder.usePresentationFileSystem := false;
	fileFolder.mask := "*dump_*].log";
	
	outputStr := null;
	foreach fileNode in fileFolder.files do
		if fileNode.createdTime &gt;= _startTS and fileNode.createdTime &lt;= _endTS then
			write Tab &amp; 'fileNode.createdTime: ' &amp; fileNode.createdTime.date.format("dd/MM/yyyy") &amp; Tab &amp;
				fileNode.createdTime.time.String;
			// get the test that caused the stack dump
			unitTestResult1 := unitTestRun.getTestForSpecifiedTime(fileNode.createdTime);
			testName := null;
			if unitTestResult1 &lt;&gt; null then
				write Tab &amp; Tab &amp; unitTestResult1.methodRunStartTS.date.format("dd/MM/yyyy") &amp; Tab &amp; 
					unitTestResult1.methodRunStartTS.time.String;
				testName := unitTestResult1.myClassMethod.returnQualifiedClassMthName();
			endif;
			outputStr := outputStr.trimBlanks() &amp; CrLf &amp; fileNode.fileName &amp; Tab &amp; testName;
			app.stackDumpCount := app.stackDumpCount + 1;											// 01/05/2014 cnwmh5
		endif;
	endforeach;

	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	if outputStr &lt;&gt; null then
		_userSummary.addAssociation("CNWMH5", "Fail " &amp; method.getSchemaType().name &amp; " " &amp; 
			method.name &amp; " ADMIN    " &amp; _startTS.date.String &amp; " " &amp; _startTS.time.String &amp; CrLf &amp; outputStr);
		if summaryStr &lt;&gt; null then
			summaryStr := summaryStr &amp; CrLf;
		endif;
		summaryStr := summaryStr &amp; "Fail " &amp; method.getSchemaType().name &amp; " " &amp; 
			method.name &amp; " ADMIN    " &amp; _startTS.date.String &amp; " " &amp; _startTS.time.String &amp; CrLf &amp; outputStr;
		resultStr := 'FAIL ';
	else	
		resultStr := "PASS ";
	endif;
	
	write method.qualifiedName() &amp; Tab &amp; "result: " &amp; resultStr &amp; Tab &amp; summaryStr;
	
	/*
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, outputStr, methStartTS, app.myUMTestRunONight);
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;		
	*/
	
epilog

	delete fileFolder;
	
end;</source>
        <Parameter name="_startTS" type="TimeStamp" usage="input"/>
        <Parameter name="_endTS" type="TimeStamp" usage="input"/>
        <Parameter name="_userSummary" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCheckForTestMethodChanges" id="7914d254-644e-4f8c-8b33-dc0477dfec0e">
        <source>vCheckForTestMethodChanges(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:			Check to see if any of the autometed tests have change.
					Need to know this for the data load for testing

Date		Who		Reason
07/12/2017	jlgmh5	Initial creation
17 Oct 2025	navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	klass						: Class;
	meth						: Method;
	root						: UM_Root;
	unitTestRun					: UM_UnitTestRun;
	unitTestResult 				: UM_UnitTestResult;
	
	classes						: ClassColl;
	methodsDict					: MethodNDict;
	
	iter						: Iterator;
	
	tempTS						: TimeStamp;
	startFromTS					: TimeStamp;
	lastModifiedBy				: String;
	lastModifiedTS				: TimeStamp;
	methStartTS					: TimeStamp;
	methEndTS					: TimeStamp;
	detailsToOutput				: String;
	elapsedTime					: TimeStampInterval;
	resultStr					: String;

begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);
	
	methStartTS := app.cnGetServerTime();
	detailsToOutput := null;

	// get the end time of the last test run
	root := UM_Root.firstInstance;
	self.assertNotNull(root);
	
	// get the last but one e.g. previous run
	tempTS.setDate("31/12/2999".Date);
	tempTS.setTime("23:59:59".Time);
	iter := root.allUnitTestRuns.createIterator;
	root.allUnitTestRuns.startKeyGeq(tempTS, iter);
	iter.back(unitTestRun);
	iter.back(unitTestRun);
	delete iter;
	
	// get the endTime
	if unitTestRun.startTS &lt;&gt; null and unitTestRun.startTS.isValid() then
		startFromTS := unitTestRun.startTS;
	endif;
	if startFromTS = null then
		startFromTS := app.cnGetServerTime();
		startFromTS := startFromTS.addHours(-12);
	endif;
	
	// get the class
	klass := currentSchema.getClass("UT_DSL");
	assertNotNull(klass);
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	// read through all the class methods source code to see if any of the no nos are found
	foreach klass in classes do
		
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		while iter.next(meth) do
			
			lastModifiedBy := meth.getModifiedBy();
			lastModifiedTS := meth.cnGetModifiedTimeStamp();
			
			if lastModifiedTS &gt; startFromTS then
				write meth.qualifiedName() &amp; ' was last modified by ' &amp; lastModifiedBy &amp; ' on ' &amp; lastModifiedTS.date.format("dd/MM/yyyy") &amp;
					' at ' &amp; lastModifiedTS.time.String;
				detailsToOutput := detailsToOutput.trimBlanks() &amp; CrLf &amp; meth.qualifiedName() &amp; ' was last modified by ' &amp; 
					lastModifiedBy &amp; ' on ' &amp; lastModifiedTS.date.format("dd/MM/yyyy") &amp; ' at ' &amp; lastModifiedTS.time.String;
			endif;
		
		endwhile;
		
	endforeach;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// did it pass or fail
	if detailsToOutput &lt;&gt; null and app.myRoot.getConfig(SystemTitle).String.toUpper().cnContains("WMAST".toUpper()) then
		resultStr := "Fail ";
		detailsToOutput := CrLf &amp; "The following unit test(s) have been change since the last automated run: " &amp; CrLf &amp; detailsToOutput;
	
		// create the email to send to the Admins
		_userSummaryDict.addAssociation(app.getUTAdminUserCode(), resultStr &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
			" ADMIN  " &amp; (elapsedTime.getMilliseconds/1000).String &amp; " secs " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; detailsToOutput);
			
	else	
		resultStr := "Pass ";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, detailsToOutput, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;

epilog

	delete iter;
	delete classes;

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCheckFutureQueuedMoves" id="336474ae-d2ab-435d-b0f9-0ab76cf60b5b">
        <source>vCheckFutureQueuedMoves(_userSummaryDict : CM_AssociationDict io);

// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2011	cnwndl1	Initial creation
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
17 Oct 2025	navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
*/

vars

	fm								: CM_FutureMoveQueued;
	unitTestResult 					: UM_UnitTestResult;
	
	str								: String;
	result							: String;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;

begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	methStartTS := app.cnGetServerTime();
	result := "FAIL";

	foreach fm in CM_FutureMoveQueued.instances do
		if fm.allRTQueueEntries.size = 0 and fm.myTrackedItem &lt;&gt; null then
			
			if fm.myTrackedItem.myPrimaryActualLocation.isKindOf(CM_MachineController) then
		//		str := str &amp;  fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' on machine " &amp; fm.myTrackedItem.myPrimaryActualLocation.CM_MachineController.id &amp; " - " &amp; fm.myTrackedItem.myTerminal.code &amp; CrLf;
				continue;
			endif;
		
			if fm.myTrackedItem.myPrimaryActualLocation = null then
				str := str &amp; fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' null primary location - " &amp; fm.myTrackedItem.myTerminal.code &amp; CrLf;
				continue;
			endif;
			if fm.myTrackedItem.myPrimaryQueuedLocation = null then
				str := str &amp; fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' null queued location - " &amp; fm.myTrackedItem.myTerminal.code &amp; CrLf;
				continue;
			endif;
			
			if fm.myTrackedItem.myTerminal.code = "RJD" then
				continue;
			endif;
			if fm.myTrackedItem.myTerminal.code = "JBL" then
				continue;
			endif;
			
			str := str &amp; fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' future queued move with no RT entry - " &amp; fm.myTrackedItem.myTerminal.code &amp; CrLf;
			
		endif;
	endforeach;
		
	if str.trimBlanks() = null then
		result := "PASS";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;			
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, str, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
epilog

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCheckFutureQueuedMovesMDH" id="0ad93b12-8a7f-4f57-8e59-ef36d467b408">
        <source>vCheckFutureQueuedMovesMDH();

// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2011	cnwndl1	Initial creation
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
*/

vars

	fm								: CM_FutureMoveQueued;
	unitTestResult 					: UM_UnitTestResult;
	
	str								: String;
	result							: String;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	count							: Integer;

begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	methStartTS := app.cnGetServerTime();
	result := "FAIL";

	foreach fm in CM_FutureMoveQueued.instances do
		if fm.allRTQueueEntries.size = 0 and fm.myTrackedItem &lt;&gt; null then
			
			if fm.myTrackedItem.myPrimaryActualLocation.isKindOf(CM_MachineController) then
		//		str := str &amp;  fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' on machine " &amp; fm.myTrackedItem.myPrimaryActualLocation.CM_MachineController.id &amp; " - " &amp; fm.myTrackedItem.myTerminal.code &amp; CrLf;
				continue;
			endif;
		
			if fm.myTrackedItem.myPrimaryActualLocation = null then
				str := str &amp; fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' null primary location - " &amp; fm.myTrackedItem.myTerminal.code &amp; " - " &amp; fm.String &amp; CrLf;
				count := count + 1;
				continue;
			endif;
			if fm.myTrackedItem.myPrimaryQueuedLocation = null then
				str := str &amp; fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' null queued location - " &amp; fm.myTrackedItem.myTerminal.code  &amp; " - " &amp; fm.String &amp; CrLf;
				count := count + 1;
				continue;
			endif;
			
			if fm.myTrackedItem.myTerminal.code = "RJD" then
				continue;
			endif;
			if fm.myTrackedItem.myTerminal.code = "JBL" then
				continue;
			endif;
			
			str := str &amp; fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' future queued move with no RT entry - " &amp; fm.myTrackedItem.myTerminal.code  &amp; " - " &amp; fm.String &amp; CrLf;
			count := count + 1;
			
		endif;
	endforeach;
	
	self.assertEqualMsg(count, 0, str);
	
	/*
	if str.trimBlanks() = null then
		result := "PASS";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;			
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, str, methStartTS, app.myUMTestRunONight);
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	*/
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="vCheckReleaseDocCopied" id="f7ba4fd8-d31f-4148-a05a-1788ae1a0c2c">
        <source>vCheckReleaseDocCopied(_unitTestRun : UM_UnitTestRun io; _userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Check to see that documenation has been copied for the release	

Date			Who		Reason
02/08/2016		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/
constants

	DiffFileName			: String = "DirectoryCompare.txt";
	PsFileName				: String = "CheckDocumentationCopied.ps1";
	CmdFileName				: String = "RunCheckDocumentationCopied.bat";

vars

	psFile					: File;
	diffFile				: File;
	cmdFile					: File;
	fileFolder				: FileFolder;
	unitTestResult			: UM_UnitTestResult;
	
	firstMonday				: Date;
	tempDate				: Date;
	index					: Integer;
	result					: Integer;
	passed					: Boolean;
	methStartTS				: TimeStamp;
	methEndTS				: TimeStamp;
	elapsedTime				: TimeStampInterval;
	resultStr				: String;
	str						: String;

begin

	// check to see that we are in wmast if not then don't need to run this
	str := app.myRoot.getConfig(SystemTitle).String.toUpper();
	if not str.cnContains("WMAST") then
		return;
	endif;

	methStartTS := app.actualTimeAppServer;

	// check that we are on the last sunday before the 1st monday of the month
	///firstMonday := app.actualTimeServer().cnEcGetFirstDayOfMonth().addDays(-1).cnEcGetNextMonday();
	///write sundayB4Release.String;
	
	// check that directory exists
	create fileFolder transient;
	fileFolder.usePresentationFileSystem := true;
	fileFolder.fileName := app.cnGetServerMiscPath() &amp; "\DocumentationCheck";
	if not fileFolder.isAvailable() then
		fileFolder.make();
	endif;
	
	// delete powershell file if exists
	create psFile transient;
	psFile.usePresentationFileSystem := fileFolder.usePresentationFileSystem;
	psFile.fileName := fileFolder.fileName &amp; "\" &amp; PsFileName;
	if psFile.isAvailable() then
		psFile.purge();
	endif;
	
	// delete diff file if exists
	create diffFile transient;
	diffFile.usePresentationFileSystem := fileFolder.usePresentationFileSystem;
	diffFile.fileName := fileFolder.fileName &amp; "\" &amp; DiffFileName;
	if diffFile.isAvailable() then
		diffFile.purge();
	endif;
	
	// create command file to run the powershell script
	create cmdFile transient;
	cmdFile.usePresentationFileSystem := fileFolder.usePresentationFileSystem;
	cmdFile.fileName := fileFolder.fileName &amp; "\" &amp; CmdFileName;
	if cmdFile.isAvailable() then
		cmdFile.purge();
	endif;
	cmdFile.writeLine("powershell.exe -file " &amp; psFile.fileName);
	cmdFile.close();
	
	// create the powershell script to run
	self.xCheckDocumenationCopiedPS(psFile, diffFile);
	
	// run the ps file
	app.writeLog("Checking that release documentation has been copied.  Please wait...", LogINFO);
	node.createExternalProcess(fileFolder.fileName, "cmd /c " &amp; CmdFileName, null, null, false, true, result);
	resultStr := "PASS";
	passed := true;
	if (result &lt;&gt; 0 and result &lt;&gt; 4) then
		resultStr := "FAIL";
		passed := false;
	endif;
	
	// check to see if there were any discrepancies
	if passed then
		fileFolder.mask := DiffFileName;
		if (fileFolder.files.size &gt; 0) then
			resultStr := "FAIL";
			passed := false;
		endif;
	endif;
	
	methEndTS := app.actualTimeAppServer;
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// create the email to send to the Admins
	if not passed then
		_userSummaryDict.addAssociation(app.getUTAdminUserCode(), resultStr &amp; " " &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
			" ADMIN  " &amp; (elapsedTime.getMilliseconds/1000).String &amp; " secs " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; 
			"There are differences between the base release documenation and the release documentation.  Check " &amp; 
			diffFile.fileName &amp; " for details.");	
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, null, methStartTS, _unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;		
			
epilog

	delete fileFolder;
	delete psFile;
	delete diffFile;
	delete cmdFile;
	
end;
</source>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCheckSelectedTestsHaveFailed" id="6999bfb1-43f6-4a79-a278-6e436cdde5ae">
        <source>vCheckSelectedTestsHaveFailed(_startTS, _endTS : TimeStamp input; _userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Check to see if the selected class / method(s) have failed
				It will get a Unit Test result record created so we have a history of the details, along with the file.
				Note: This method is run outside the standard Unit Test Overnight run as the details aren't
					created until the finalize method is called.

Date			Who		Reason
04/12/2013		cnwmh5	Initial creation
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars
	
	unitTestResult 							: UM_UnitTestResult;
	root									: UM_Root;
	classMethod								: UM_UnitTestClassMethod;
	
	userSummaryDict							: CM_AssociationDict;
	
	classNameArray							: StringArray;
	methodNameArray							: StringArray;
	
	iter									: Iterator;

	detailsToOutput							: String;
	resultStr								: String;
	methStartTS								: TimeStamp;
	methEndTS								: TimeStamp;
	elapsedTime								: TimeStampInterval;
	index									: Integer;
	
begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	methStartTS := app.cnGetServerTime();
	
	create classNameArray transient;
	create methodNameArray transient;
	
	// MUST always have class / method combination
	classNameArray.add("UT_JMTLogicalCertify");
	methodNameArray.add("tCheckLocationsController");
	
	root := UM_Root.firstInstance;
	if root = null then
	
		app.writeLog("UM_Root not found.  Aborting", LogINFO);
		return;
	endif;
	
	foreach index in 1 to classNameArray.size do
		classMethod := root.allRunnableUTClassesMethods[classNameArray[index], methodNameArray[index]];
		if classMethod = null then
			classMethod := root.allClassMethodsUsedBy[classNameArray[index], methodNameArray[index]];
			if classMethod = null then
				continue;
			endif;
		endif;
		
		// get the first unit test result
		unitTestResult := classMethod.allUnitTestResults.first;
		
		// check to see if the run dates are the same
		if unitTestResult = null or unitTestResult.getMyTestRunRunDate() &lt;&gt; _startTS.date then
			continue;
		endif;
		
		// check to see if failed
		if unitTestResult.getResultDetails(unitTestResult.result).String = "FAIL" then
			detailsToOutput := detailsToOutput.trimBlankCharacters() &amp; CrLf &amp; classMethod.className &amp; "::" &amp; 
				classMethod.methodName;
		endif;
		
	endforeach;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// did it pass or fail
	if detailsToOutput &lt;&gt; null then
		resultStr := "Fail ";
		detailsToOutput := CrLf &amp; "The following unit test(s) failed and need immediate follow-up:" &amp; CrLf &amp; detailsToOutput;
		
		// create the email to send to the Admins
		_userSummaryDict.addAssociation(app.getUTAdminUserCode(), resultStr &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
		" ADMIN  " &amp; (elapsedTime.getMilliseconds/1000).String &amp; " secs " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; detailsToOutput);
		
	else	
		resultStr := "Pass ";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, detailsToOutput, methStartTS, app.myUMTestRunONight, method.text);				//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
		
epilog

	delete iter;
	delete userSummaryDict;
	delete classNameArray;
	delete methodNameArray;
	
end;</source>
        <Parameter name="_startTS" type="TimeStamp" usage="input"/>
        <Parameter name="_endTS" type="TimeStamp" usage="input"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCheckUncompiledMthdsProdScms" id="ccb67528-4cf9-4453-85a7-69369503cb5c">
        <source>vCheckUncompiledMthdsProdScms(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Check for Uncompiled methods in Production Schemas ONLY	

Date			Who		Reason
15/11/2016		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	uncompiledMethods				: StringArray512;
	unitTestResult 					: UM_UnitTestResult;
	
	type							: Integer;

	result							: String;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	errorDetails					: String;	
	str								: String;

begin

	methStartTS := app.cnGetServerTime();
	result := "FAIL";

	create uncompiledMethods transient;
	
	type := 1;
	app.xCheckForUncompiledMethods(type, uncompiledMethods);
	
	if uncompiledMethods.size = 0 then
		result := "PASS";
	else
		errorDetails := null;
		foreach str in uncompiledMethods do
			if errorDetails &lt;&gt; null then
				errorDetails := errorDetails &amp; CrLf;
			endif;
			errorDetails := errorDetails &amp; str;
		endforeach;
		errorDetails := CrLf &amp; "The following method(s) are uncompiled or in error:" &amp; CrLf &amp; CrLf &amp; errorDetails;
		errorDetails := errorDetails.replaceString("^^", " ");
		_userSummaryDict.addAssoc("CNWMH5", errorDetails);
	endif;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
		
	beginTransaction;
	create unitTestResult persistent;										
	result := result.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, errorDetails, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;

epilog

	delete uncompiledMethods;

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vClearAllBGPRequests" id="af5ab785-26d9-4686-ae6a-cc30e68ebe20">
        <source>vClearAllBGPRequests(_unitTestRun : UM_UnitTestRun io; _userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Clear all BGP Requests, leaving report requests (report template used in invoicing test)

Date			Who		Reason
29/03/2012		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	schema							: Schema;
	klass							: Class;
	obj								: Object;
	unitTestResult 					: UM_UnitTestResult;
	
	subClasses						: ClassColl;
	
	result							: String;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	resultDetails					: String;

begin

	methStartTS := app.cnGetServerTime();
	result := "FAIL";

	// get the schema
	schema := rootSchema.getSchema("PortSchema");
	self.assertNotNullMsg(schema, "Schema PortSchema not found");

	// get the class
	klass := schema.getClass("BGP_Request");
	self.assertNotNullMsg(klass, "Class BGP_Request not found");
	
	// get all the subclasses for the class
	create subClasses transient;
	klass.allLocalSubclasses(subClasses);
	
	foreach klass in subClasses do : errorWarningsFound
		foreach obj in klass.instances do
			if obj.isKindOf(BGP_ReportRequest) then
				continue;
			endif;
			app.myTrxDA.trxDeleteBGPRequest(null, obj.BGP_Request, false, app.myPassport);
			///self.assertNoTrxErrorsOrWarnings();
			if app.myPassport.hasErrorsOrWarnings() then
				break errorWarningsFound;
			endif;
		endforeach;
	endforeach;

	if app.myPassport.hasErrorsOrWarnings() then
		resultDetails := app.myPassport.getAllErrorsAndWarningsAsStr();
	else	
		result := "PASS";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;			
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, resultDetails, methStartTS, _unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
epilog

	delete subClasses;
	
end;</source>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCompactAllDatFiles" id="41b1aef3-541a-4f9a-93a6-960fefe33638">
        <source>vCompactAllDatFiles();

/*

Purpose:		Compact all dat files on the last Saturday of the month

Date			Who		Reason
16/05/2016		cnwmh5	Initial creation

*/

vars

	dba							: JadeDatabaseAdmin;
	dbFile						: DbFile;
	cleanUpDetails				: UM_CleanUpDetailsCompact;
	mapToCompact				: UM_MapFilesToCompact;
	root						: UM_Root;
	
	dbFiles						: DbFileArray;
	
	dbFileName					: String;
	lineLength					: Decimal[21,0];
	startLength					: Decimal[21,0];
	endLength					: Decimal[21,0];
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	lastSaturdayOfMonth			: Date;
	now							: Date;

begin

	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;

	// get the last Saturday of the month
	now := app.actualTimeServer().Date;
	lastSaturdayOfMonth := now.cnEcGetLastDayOfMonth();
	while lastSaturdayOfMonth.dayOfWeek() &lt;&gt; 6 do
		lastSaturdayOfMonth := lastSaturdayOfMonth.addDays(-1);
	endwhile;

	// not last saturday of month then nothing to do
	if now &lt;&gt; lastSaturdayOfMonth then
		return;
	endif;

	// Compact files - setup the files to compact here as we will use this to get the previous size from the file
	lineLength := 0;
		
	beginTransaction;
	create dba transient;
	create dbFiles transient;
	dba.getDbFiles(DbFile.Kind_User_Data, dbFiles);
	foreach dbFile in dbFiles do
		
		// setup variables for logging
		dbFileName := dbFile.name;
		startLength := dbFile.getFileLength();
		startTS := app.cnGetServerTime();
		
		// compact file
		app.writeLog("Compacting " &amp; dbFile.name &amp; ".dat (File size=" &amp; dbFile.getFileLength().String &amp; ").  Please wait...", LogINFO);
		dbFile.compactFile();
		app.writeLog("Finished compacting " &amp; dbFile.name &amp; ".dat (File size=" &amp; dbFile.getFileLength().String &amp; ").", LogINFO);
		
		// write required record to file
		endLength := dbFile.getFileLength();
		endTS := app.cnGetServerTime();
		
		mapToCompact := root.allMapFilesToCompact[dbFile.name];

		if mapToCompact = null then
			create mapToCompact persistent;
			mapToCompact.updateDetails(dbFile.name, UM_MapFilesToCompact.WhenToCompactNull);
		endif;
		
		create cleanUpDetails persistent;
		cleanUpDetails.updateDetailsCompact(dbFile.name, startTS, endTS, startLength, endLength);
		
	endforeach;
	commitTransaction;

epilog

	delete dba;
	delete dbFiles;

end;</source>
    </JadeMethod>
    <JadeMethod name="vCompactDatFiles" id="6e5d2cb8-bcc2-4889-8eb9-b0fe31cfeb33">
        <source>vCompactDatFiles(_whichToCompact : Integer; _userSummaryDict : CM_AssociationDict io; _unitTestRun : UM_UnitTestRun io);

/*

Purpose:		Compact required dat / map files

Date			Who		Reason
17/04/2015		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	root						: UM_Root;
	mapToCompact				: UM_MapFilesToCompact;
	dba							: JadeDatabaseAdmin;
	dbFile						: DbFile;
	cleanUpDetails				: UM_CleanUpDetailsCompact;
	unitTestResult 				: UM_UnitTestResult;
	
	dbFiles						: DbFileArray;
	
	startLength					: Decimal[21,0];
	endLength					: Decimal[21,0];
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	resultStr					: String;
	methStartTS					: TimeStamp;
	methEndTS					: TimeStamp;
	elapsedTime					: TimeStampInterval;
	detailsToOutput				: String;
	
begin

	methStartTS := app.cnGetServerTime();
	
	root := UM_Root.firstInstance;
	if root = null then
		app.msgBox("Unable to find Root.  Exiting Jadescript...", "ERROR", MsgBox_OK_Only);
		return;
	endif;
		
	// get all the user defined db files and compact those required
	beginTransaction;
	create dba transient;
	create dbFiles transient;
	dba.getDbFiles(DbFile.Kind_User_Data, dbFiles);
	foreach dbFile in dbFiles do
	
		mapToCompact := root.allMapFilesToCompact[dbFile.name];
		if mapToCompact = null then
			continue;
		endif;
		
		// not the specified run or next then ignore
		if _whichToCompact = UM_MapFilesToCompact.WhenToCompactNull or 
				(mapToCompact.whenToCompact &lt;&gt; _whichToCompact and mapToCompact.whenToCompact &lt;&gt; UM_MapFilesToCompact.WhenToCompactNext) then
			continue;
		endif;
		
		// setup variables for logging
		startLength := dbFile.getFileLength();
		startTS := app.cnGetServerTime();
		
		// compact file
		app.writeLog("Compacting " &amp; dbFile.name &amp; ".dat (File size=" &amp; dbFile.getFileLength().String &amp; ").  Please wait...", LogINFO);
		dbFile.compactFile();
		app.writeLog("Finished compacting " &amp; dbFile.name &amp; ".dat (File size=" &amp; dbFile.getFileLength().String &amp; ").", LogINFO);
		
		// write required record to file
		endLength := dbFile.getFileLength();
		endTS := app.cnGetServerTime();
		
		if detailsToOutput = null then
			detailsToOutput := "Files compacted:";
		endif;
		detailsToOutput := detailsToOutput &amp; CrLf &amp; mapToCompact.mapFileName &amp; " starting: " &amp; startLength.String &amp; 
			" ending: " &amp; endLength.String;
		
		create cleanUpDetails persistent;
		cleanUpDetails.updateDetailsCompact(dbFile.name, startTS, endTS, startLength, endLength);
		
		// if next then only doing it once so set whenToCompact to null
		if mapToCompact.whenToCompact = UM_MapFilesToCompact.WhenToCompactNext then
			mapToCompact.updateWhenToCompact(UM_MapFilesToCompact.WhenToCompactNull);
		endif;
	
	endforeach;
	commitTransaction;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// check to see if completed ok
	resultStr := "PASS";
	if app.myPassport.hasErrors() then
		resultStr := "FAIL";
		detailsToOutput := detailsToOutput &amp; CrLf &amp; CrLf &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr();
	endif;	
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, detailsToOutput, methStartTS, _unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
epilog

	delete dba;
	delete dbFiles;

end;</source>
        <Parameter name="_whichToCompact" type="Integer"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vDeleteBlameRecords" id="c3055dcb-79a8-42cf-9072-4aac1348b21c">
        <source>vDeleteBlameRecords();
/*

Purpose:			Delete Blame Records	
					Will run for an hour or the specified time

Date		Who		Reason
18/07/2018	jlgmh5	Initial creation

*/

constants

	DurationToRun					: Integer = 120;  		// minutes
	MaxRecsToDeleteInTxn			: Integer = 5000;		// no of records to delete in one txn

vars

	blameItem						: UM_BlameItem;
	blame							: UM_Blame;

	startTS							: TimeStamp;
	endTS							: TimeStamp;
	
	count							: Integer;
	numberDeleted					: Integer;
	timeUp							: Boolean;

begin

	app.initialize();
	
	timeUp := false;
	
	// get the time to stop the run
	startTS := app.actualTimeAppServer();
	endTS := startTS.addMinutes(DurationToRun);
	write method.qualifiedName() &amp; Tab &amp; 'startTS: ' &amp; startTS.String &amp; Tab &amp; 'endTS: ' &amp; endTS.String;
	app.writeLog(method.qualifiedName() &amp; Tab &amp; 'startTS: ' &amp; startTS.String &amp; Tab &amp; 'endTS: ' &amp; endTS.String, LogINFO);
	
	//write "blameItems.size b4: " &amp; UM_BlameItem.instances.size.String;
	write method.qualifiedName() &amp; Tab &amp; "blame.size b4: " &amp; UM_Blame.instances.size.String;
	app.writeLog(method.qualifiedName() &amp; Tab &amp; "blame.size b4: " &amp; UM_Blame.instances.size.String, LogINFO);
	
	beginTransaction;
	
	foreach blameItem in UM_BlameItem.instances discreteLock do
	
		// check to see if it's time to exit
		if app.actualTimeAppServer() &gt; endTS then
			timeUp := true;
			break;
		endif;
	
		// max count hit so commit them to the database
		count := count + 1;
		if count &gt; MaxRecsToDeleteInTxn then
			commitTransaction;
			beginTransaction;
			count := 0;
		endif;
		
		// get the blame object
		blame := blameItem.myBlame;
		
		delete blameItem;
		numberDeleted := numberDeleted + 1;
		
		// delete blame if no more blameitems
		if blame.allBlameItems.isEmpty() then
			numberDeleted := numberDeleted + 1;
			delete blame;
		endif;
	
	endforeach;
	commitTransaction;
	
	// if time up for this run then time to leave
	if timeUp then
		return;
	endif;
	
	// delete any blame objects that don't have blame item 
	count := 0;
	beginTransaction;
	foreach blame in UM_Blame.instances discreteLock do
	
		// check to see if it's time to exit
		if app.actualTimeAppServer() &gt; endTS then
			timeUp := true;
			break;
		endif;
		
		// max count hit so commit them to the database
		count := count + 1;
		if count &gt; MaxRecsToDeleteInTxn then
			commitTransaction;
			beginTransaction;
			count := 0;
		endif;
		
		if blame.allBlameItems = null or blame.allBlameItems.isEmpty then
			numberDeleted := numberDeleted + 1;
			delete blame;
		endif;
	
	endforeach;
	commitTransaction;
	
	
epilog

	abortTransaction;
	
	write method.qualifiedName() &amp; Tab &amp; "numberDeleted: " &amp; numberDeleted.String;
	app.writeLog(method.qualifiedName() &amp; Tab &amp; "numberDeleted: " &amp; numberDeleted.String, LogINFO);
	
	write method.qualifiedName() &amp; Tab &amp; "blame.size af: " &amp; UM_Blame.instances.size.String;
	app.writeLog(method.qualifiedName() &amp; Tab &amp; "blame.size af: " &amp; UM_Blame.instances.size.String, LogINFO);
	
	//write "blameItems.size af: " &amp; UM_BlameItem.instances.size.String;
	//write "blame.size af: " &amp; UM_Blame.instances.size.String;

end;</source>
    </JadeMethod>
    <JadeMethod name="vDeleteRequiredObjects" id="d38cf780-34f2-4054-8381-7266a6146bfb">
        <updating/>
        <source>vDeleteRequiredObjects() updating;

/*

Purpose:		Delete Objects from UM_ObjectsToDelete

				Not going to put this as a test as don't care really if it passes or fails
				only need to know the details of how long it took and how many it deleted.
				
				To add a class to delete you need to reimplement CM_Object::unitTestDeleteObject 
				on class you are deleting and any code that is required to run (e.g. see CM_VoyageAllocation)
								

Date			Who		Reason
02/06/2015		cnwmh5	Initial creation
01/02/2016		cnwmh5	Update so doesn't create and audit record for the delete

*/
constants

	NoMinutesToDeleteFor		: Integer = 90;
	
vars

	root 						: UM_Root;
	objToDelete					: UM_ObjectsToDelete;
	obj							: Object;
	compact						: UM_MapFilesToCompact;
	cleanUpDetails				: UM_CleanUpDetails;
	dsl							: UT_DSL;
	audit						: CM_AuditObject;
	
	objClassNameArray			: StringArray;
	objClassCountArray			: IntegerArray;
	
	iter						: Iterator;
	
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	currentTS					: TimeStamp;
	deleteCount					: Integer;
	sizeStart					: Integer;
	sizeEnd						: Integer;
	mapFileName					: String;
	invalidObj					: Boolean;
	details						: String;
	index						: Integer;
	totalDeleted				: Integer;
	tiId						: String;
	auditDisabled				: Boolean;
	
begin

	///return;
	
	// 31/08/2015 cnwmh5 - Temp remove as need to look into why some things aren't deleting without error
	if app.isUnicode then
		return;
	endif;

	// 01/02/2016 cnwmh5 - Need to disable the AuditAgent
	auditDisabled := app.myAA.auditDisabled;
	app.myAA.setPropertyValue("auditDisabled", true);
	
	on Exception do app.handleDeletedObject(exception, obj, invalidObj);

	root := UM_Root.firstInstance;
	self.assertNotNull(root);
	
	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	
	create objClassCountArray transient;
	create objClassNameArray transient;
		
	self.setActiveProfileMDHONLY();
	
	sizeStart := UM_ObjectsToDelete.instances.size;
	
	startTS := app.cnGetServerTime();
	endTS := startTS.addMinutes(NoMinutesToDeleteFor);
	
	iter := root.allObjectsToDeleteSet.createIterator;
	deleteCount := 0;
	
	app.myPassport.setWarningsIgnored(true);
	
	while iter.next(objToDelete) do
		invalidObj := false;
		currentTS := app.cnGetServerTime();
		if currentTS &gt; endTS then
			break;
		endif;
		
		obj := objToDelete.objectToDelete;
				
		if not invalidObj then
		
			// get the map file that needs compacting
			mapFileName := obj.class.getDbFile().name;
			compact := root.allMapFilesToCompact[mapFileName];
			if compact = null then
				self.addMapToFilesToCompact(mapFileName, UM_MapFilesToCompact.WhenToCompactNext);
			else
				beginTransaction;
				compact.updateWhenToCompact(UM_MapFilesToCompact.WhenToCompactNext);
				commitTransaction;
			endif;		
			
			// delete the objects
			deleteCount := deleteCount + 1;
			
			// update the counters for what is deleted
			index := objClassNameArray.indexOf(obj.getNiceClassName());
			if index = 0 then
				objClassNameArray.add(obj.getNiceClassName());
				objClassCountArray.add(1);
			else
				objClassCountArray[index] := objClassCountArray[index] + 1;
			endif;
			
			obj.CM_Object.unitTestDeleteObject(dsl);
			
		endif;
		
		beginTransaction;
		objToDelete.clearObjectToDelete();
		delete objToDelete;
		commitTransaction;
		
	endwhile;
	
	sizeEnd := UM_ObjectsToDelete.instances.size;
	endTS := app.cnGetServerTime();

	// get the details of what has been deleted
	foreach index in 1 to objClassNameArray.size step 1 do
		if details &lt;&gt; null then
			details := details &amp; CrLf;
		endif;
		details := details &amp; objClassCountArray[index].String &amp; " " &amp; 
			objClassNameArray[index] &amp; " objects deleted.";	
		totalDeleted := totalDeleted + objClassCountArray[index];
	endforeach;
	
	if details &lt;&gt; null then
		details := "The following objects have been deleted: " &amp; CrLf &amp; details &amp; CrLf &amp;
			"Total deleted: " &amp; totalDeleted.String;
	endif;
	
	// setup the clean up details
	beginTransaction;
	create cleanUpDetails persistent;
	cleanUpDetails.updateDetails(startTS, endTS, (sizeStart - sizeEnd), UM_CleanUpDetails.TaskDescriptionDelete, details);
	commitTransaction;
	
	app.writeLog("Starting size: " &amp; sizeStart.String &amp; " Ending size: " &amp; sizeEnd.String &amp; " " &amp; (sizeStart - sizeEnd).String &amp; 
		" records deleted. Started: " &amp; startTS.date.format("dd/MM/yyyy") &amp; " " &amp; startTS.time.String &amp; 
		" Ended: " &amp; endTS.date.format("dd/MM/yyyy") &amp; " " &amp; endTS.time.String , LogINFO);
	write "Starting size: " &amp; sizeStart.String &amp; " Ending size: " &amp; sizeEnd.String &amp; " " &amp; (sizeStart - sizeEnd).String &amp; 
		" records deleted. Started: " &amp; startTS.date.format("dd/MM/yyyy") &amp; " " &amp; startTS.time.String &amp; 
		" Ended: " &amp; endTS.date.format("dd/MM/yyyy") &amp; " " &amp; endTS.time.String;
	
epilog

	// 01/02/2016 cnwmh5- reset to original value
	app.myAA.setPropertyValue("auditDisabled", auditDisabled);

	app.myPassport.setWarningsIgnored(false);

	delete iter;
	delete dsl;
	delete objClassNameArray;
	delete objClassCountArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="vExtractLoadReportConstants" id="c3421568-e6f8-48de-8fe8-2f2abea87e24">
        <source>vExtractLoadReportConstants(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Extract and load the Report Constants

Date			Who		Reason
26/03/2015		cnwmh5	Initial creation - 35754 extract CM_Report global constants with the current report descriptions
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
*/

vars

	file							: File;
	constantCategory 				: ConstantCategory;
	constant						: Constant;
	qryReport						: CM_QryReport;
	xmlParser 						: CnEcXmlParser;
	xmlStruct	 					: CnEcXmlStructureInstance;
	unitTestResult 					: UM_UnitTestResult;
	
	dict							: DynaDictionary;	
	args							: StringArray512;
	
	pos1, pos2						: Integer;
	text 							: String;
	text1, text2					: String;
	reportName						: String;
	found,
	changed,
	new,
	lost							: Integer;
	rtnStr							: String;
	resultStr						: String;
	result							: Integer;	
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	errorDetails					: String;

begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	methStartTS := app.cnGetServerTime();

	create dict transient;
	dict.setMembership(CM_QryReport);
	dict.addExternalKey(String, 60, false, true);
	dict.endKeys(false);
	
	foreach qryReport in CM_QryReportSystem.instances do
		if dict[qryReport.reportName] = null then
			dict.putAtKey(qryReport.reportName, qryReport);
		endif;
	endforeach;

	create file transient;
	file.usePresentationFileSystem := true;
	file.openOutput('c:\temp\PortSchema_ReportConstants.scm');
	if file.isAvailable() then
		file.purge;
	endif;

	file.writeLine('jadeVersionNumber "7.0.08";');
	file.writeLine('schemaDefinition');
	file.writeLine('PortSchema subschemaOf BaseSchema partialDefinition;');
	
	constantCategory := rootSchema.getSchema(PortSchemaName).getConstantCategory("CM_Report");
	file.writeLine('constantDefinitions');

	// constant category
	file.writeLine(Tab &amp; 'categoryDefinition ' &amp; constantCategory.name);
	
	create xmlParser transient;
	foreach constant in constantCategory.getConstants do
		delete xmlStruct;
		create xmlStruct as CnEcXmlGroupInstance transient;
		text := constant.text;
		xmlParser.parseToMsgStructure(text, xmlStruct);
		qryReport := null;
		if xmlStruct.findStructure('reportName') &lt;&gt; null then
			reportName 	:= xmlStruct.findStructure('reportName').tagData;
			qryReport := dict.getAtKey(reportName).CM_QryReport;
			if qryReport = null then
				lost := lost + 1;
			else
				found := found + 1;
			endif;
		endif;
		if qryReport &lt;&gt; null and
		   qryReport.reportDescription &lt;&gt; null then
			pos1 := text.pos("&lt;reportDescription&gt;", 1);
			if pos1 &gt; 0 then			// already a reportDescription etry
				text1 := text[1:pos1+18];
				pos2 := text.pos("&lt;/reportDescription&gt;", pos1);
				if pos2 &gt; 0 then
					text2 := text[pos2:end];
					text := text1 &amp; qryReport.reportDescription &amp; text2;
					changed := changed + 1;
				endif;
			else		// no reportDescription, add it before the end tag ...
				pos1 := text.pos("&lt;/CM_QueryReport&gt;", 1);
				if pos1 &gt; 0 then
					text1 := text[1:pos1-1];
					text := text1 &amp; "&lt;reportDescription&gt;" &amp; qryReport.reportDescription &amp; "&lt;/reportDescription&gt;" &amp; CrLf &amp; "&lt;/CM_QueryReport&gt;";
					new := new + 1;
				endif;
			endif;
		endif;
		// now write the constant definition to the scm file with the updated description
		
		file.writeLine(Tab &amp; Tab &amp; constant.name &amp; ':	' &amp; constant.type.name &amp; ' = ' &amp; constant.getSource() &amp; ';');
		file.writeLine(Tab &amp; 'documentationText');
		file.writeLine('`' &amp; text &amp; '`');
		
	endforeach;
	file.close();
	app.writeLog("found=" &amp; found.String &amp; " lost=" &amp; lost.String &amp; " changed=" &amp; changed.String &amp; " new=" &amp; new.String, LogINFO);
	write "found=" &amp; found.String &amp; " lost=" &amp; lost.String &amp; " changed=" &amp; changed.String &amp; " new=" &amp; new.String;
	
	return;
	create args transient;
	
	// load PortSchema global constants
	rtnStr := "Loading schema file: " &amp; file.fileName;
	//self.doWindowEvents(0);
	args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
	args.add('schemaFile="' &amp; file.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'schemaFile="' &amp; file.fileName &amp; '"';
	args.add('ini="' &amp; app.getIniFileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileName &amp; '"';
	args.add('server=multiuser');
	args.add('loadStyle=onlyStructuralVersioning');
	app.writeLog("rtnStr: " &amp; rtnStr, LogINFO);
	
	rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
				node.createExternalProcess(app.getJadeInstallDir(), 'jadloadb.exe', args, null, false, true, result).String;
	rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; rtnStr, LogINFO);
	
	
	if result &lt;&gt; 0 and result &lt;&gt; 4 then
		resultStr := "FAIL";
		errorDetails := "PortSchema scm failed to load (Report Constants).  Please check the scm file.";
	else	
		resultStr := "PASS";
	endif;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	//write method.getSchemaType().name &amp; Tab &amp; method.name &amp; Tab &amp; (elapsedTime.getMilliseconds/1000).String &amp; Tab &amp;
	//	"" &amp; Tab &amp; "CNWMH5" &amp; Tab &amp; resultStr &amp; Tab &amp; errorDetails &amp; Tab &amp; methStartTS.String;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, errorDetails, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
epilog

	delete file;
	delete xmlParser;
	delete xmlStruct;
	delete dict;
	delete args;

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vGenXLATFormMethod" id="b55d5433-da19-4937-a463-b91bb1302de5">
        <source>vGenXLATFormMethod(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Run the Generate translateForm method in DevSchema

Date			Who		Reason
24/02/2015		cnwmh5	Initial creation
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
01/05/2025		navpw1	JIRA: MTN-34767 - Added an isEmpty check for _userSummaryDict as it should be empty for this to pass
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
*/

vars

	schema							: Schema;
	klass							: Class;
	classObj						: Object;
	unitTestResult 					: UM_UnitTestResult;
	
	errorsArray						: StringArray512;
	tokens							: HugeStringArray;
	userArray						: StringArray;
	userErrorArray					: StringArray;
	
	result							: String;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	errorDetails					: String;

begin

	methStartTS := app.cnGetServerTime();
	result := "FAIL";
	
	schema := rootSchema.getSchema("DevSchema");
	self.assertNotNullMsg(schema, "Schema DevSchema not found");
	
	klass := schema.getClass("DevSchema");
	self.assertNotNullMsg(klass, "Class DevSchema not found");
	
	create tokens transient;
	create errorsArray transient;
	create classObj as klass transient;
	classObj.sendMsgWithIOParams("extractNewXLATFormConstViaUT", errorsArray, _userSummaryDict);
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
		
	errorDetails := null;
	if _userSummaryDict = null or _userSummaryDict.isEmpty then
		result := "PASS";
	else
		errorDetails := _userSummaryDict.str("CNWMH5");
		if errorDetails &lt;&gt; null then
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " | CNWMH5 | Errors: " &amp; CrLf &amp; errorDetails, LogINFO);
		endif;
		errorDetails := _userSummaryDict.str(app.getUTAdminUserCode());
		if errorDetails &lt;&gt; null then
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " | " &amp; app.getUTAdminUserCode() &amp; " | Errors: " &amp; CrLf &amp; errorDetails, LogINFO);
		endif;
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	result := result.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, errorDetails, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;

epilog

	delete classObj;
	delete errorsArray;
	delete tokens;
	delete userArray;
	delete userErrorArray;
	
end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vGenXLATFormMethod_MDH" id="d15b9af1-77c6-477f-9e2d-e9937976e5c8">
        <source>vGenXLATFormMethod_MDH(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Run the Generate translateForm method in DevSchema

Date			Who		Reason
24/02/2015		cnwmh5	Initial creation

*/

vars

	schema							: Schema;
	klass							: Class;
	classObj						: Object;
	unitTestResult 					: UM_UnitTestResult;
	
	errorsArray						: StringArray512;
	tokens							: HugeStringArray;
	userArray						: StringArray;
	userErrorArray					: StringArray;
	
	result							: String;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	errorDetails					: String;

begin

	methStartTS := app.cnGetServerTime();
	result := "FAIL";
	
	schema := rootSchema.getSchema("DevSchema");
	self.assertNotNullMsg(schema, "Schema DevSchema not found");
	
	klass := schema.getClass("DevSchema");
	self.assertNotNullMsg(klass, "Class DevSchema not found");
	
	create tokens transient;
	create errorsArray transient;
	create classObj as klass transient;
	classObj.sendMsgWithIOParams("extractNewXLATFormConstViaUT", errorsArray, _userSummaryDict);
	
	/*
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
		
	errorDetails := null;
	if _userSummaryDict = null then
		result := "PASS";
	else
		errorDetails := _userSummaryDict.str("app.getUTAdminUserCode());
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	result := result.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, errorDetails, methStartTS, _unitTestRun);
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	*/
	
epilog

	delete classObj;
	delete errorsArray;
	delete tokens;
	delete userArray;
	delete userErrorArray;
	
end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vGetRunTransientLeakDetails" id="6a40cc87-0398-430f-91fa-8c32891340bf">
        <source>vGetRunTransientLeakDetails(_startTS, _endTS : TimeStamp);

/*

Purpose:		Gets the transient leak details for the current unit test run (Only for Overnight Run)
				It will get a Unit Test result record created so we have a history of the details, along with the file.
				Note: This method is run outside the standard Unit Test Overnight run as the details aren't
					created until the finalize method is called.

Date			Who		Reason
04/12/2013		cnwmh5	Initial creation
13/06/2016		cnwmh5	Start and End timestamp now passed in
08/05/2025		navhn30 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

constants

	DetailsToCheckFor						: String = "Starting check for undeleted process transients ....";
	//EndDetailsToCheckFor					: String = "Check for undeleted process transients found none, other than normal (expected) singletons.";
	EndDetailsToCheckFor					: String = "Transient checks completed, Elapsed time";
	CheckForClass							: String = "Class ";

vars
	
	file									: File;
	fileToRead								: File;
	fileFolder								: FileFolder;
	fileNode								: FileNode;
	testRunner 								: JMTTestController;
	unitTestResult 							: UM_UnitTestResult;
	unitTestRun								: UM_UnitTestRun;
	root									: UM_Root;
	leakChecker								: UT_LeakChecker;
	
	userSummaryDict							: CM_AssociationDict;
	association								: CM_Association;
	
	iter									: Iterator;

	line									: String;
	posClass								: Integer;
	systemId								: String;
	undeleteLeaksFound						: Boolean;
	detailsToOutput							: String;
	user									: String;
	resultStr								: String;
	methStartTS								: TimeStamp;
	methEndTS								: TimeStamp;
	elapsedTime								: TimeStampInterval;
	className								: String;
	
begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	on FileException do app.handleFileTruncatedRec(exception);

	create leakChecker transient;

	methStartTS := app.cnGetServerTime();
	
	systemId := CM_Version.VERSION;
	systemId := systemId.replaceString(".", "");
	
	// right checking through the logs directory for files with "Starting check for undeleted process transients ...." in
	create fileFolder transient;
	fileFolder.fileName := app.getAppServerLogDir();
	fileFolder.usePresentationFileSystem := false;
	fileFolder.mask := "cn_cnw*mast_log_cnwchcs11_*.log";
	///fileFolder.mask := "cn_851dev0706_cnwmh5a_*.log";
	
	// open the file to append to
	delete file;
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := app.cnGetServerMiscPath() &amp; "\AutomatedRunDetails" &amp; "\" &amp; systemId &amp; "AutomatedRunTransientLeakDetals.log";
	file.usePresentationFileSystem := false;
	file.mode := File.Mode_Append;
		
	// read through the files and find any that have undeleted process transients in it
	foreach fileNode in fileFolder.files do
		// check to see if file is in our date range.  If not then continue
		if fileNode.createdTime &lt; _startTS or fileNode.createdTime &gt; _endTS then
			continue;
		endif;
		
		// read through the file and see if it contains the required details
		delete fileToRead;
		create fileToRead transient;
		fileToRead.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		fileToRead.fileName := fileNode.fileName;
		fileToRead.usePresentationFileSystem := false;
		undeleteLeaksFound := false;
		while not fileToRead.endOfFile do
			line := fileToRead.readLine();
			if not line.cnContains(DetailsToCheckFor) and not undeleteLeaksFound then
				continue;
			endif;
			if not undeleteLeaksFound then
				line := fileToRead.readLine();
				line := fileToRead.readLine();
			endif;
			undeleteLeaksFound := true;
			if line.cnContains(EndDetailsToCheckFor) then
				break;
			endif;
			//if line.cnContains("Class JadeMethod had") then
			//	continue;
			//endif;
			// 24/07/2014 cnwmh5 - Add checking for those that we exclude in leak checking during the run
			if line.cnContains(CheckForClass) then
				posClass := line.pos(CheckForClass, 1);
				if posClass &gt; 0 then
					posClass := posClass + CheckForClass.length;
					className := line.scanUntil(" ", posClass).trimBlanks();
					if self.xKnownLeaks(className) then
						continue;
					endif;
				endif;			
			endif;			
			
			file.writeLine(line);
			detailsToOutput := detailsToOutput.trimBlanks() &amp; CrLf &amp; line;
		endwhile;
		
	endforeach;
	file.close();
	
	// did it pass or fail
	if detailsToOutput &lt;&gt; null then
		resultStr := "Fail ";
	else	
		resultStr := "Pass ";
	endif;
	
	if resultStr = "Fail " then
		// create the email to send to the Admins
		create testRunner transient;
		create userSummaryDict transient;
		testRunner.setSendEmail(true);
		userSummaryDict.addAssociation(app.getUTAdminUserCode(), resultStr &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
			" ADMIN    " &amp; _startTS.date.String &amp; " " &amp; _startTS.time.String &amp; CrLf &amp; detailsToOutput);
		iter := userSummaryDict.createIterator();
		while iter.next(association) do
			userSummaryDict.getIteratorKeys(user, iter);
			app.emailReports(association.asStringWithoutFailures(), "Transient Leaks", 2, testRunner,null,false);
		endwhile;
	endif;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// get the details of the last unit test run details.  If start date / time same then create unitTestResult else ignore
	root := UM_Root.firstInstance;
	if root = null then
		app.writeLog("UM_Root not found.  Aborting", LogINFO);
		return;
	endif;
	/////startTS := startTS.addMonths(-1);
	///unitTestRun := root.allUnitTestRuns.last.UM_UnitTestRun;
	///if unitTestRun.startTS.date &lt;&gt; _startTS.date then
	///	app.writeLog("Unit Test run for " &amp; _startTS.String &amp; " not found.  Aborting", LogAlways);
	///	return;
	///endif;
	
	foreach unitTestRun in root.allUnitTestRuns reversed, discreteLock do
		if unitTestRun.startTS.truncateToSecond() = _startTS.truncateToSecond() then
			break;
		endif;	
	endforeach;
	if unitTestRun = null then
		app.writeLog("Unit Test run for " &amp; _startTS.String &amp; " not found.  Aborting", LogINFO);
		return;
	endif;
	
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, detailsToOutput, methStartTS, unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;		
		
epilog

	delete file;
	delete fileFolder;
	delete fileToRead;
	delete iter;
	delete testRunner;
	delete userSummaryDict;
	delete leakChecker;
	
end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="vGetTIsToDelete" id="73f06a0b-48d3-441b-af64-bb8855170763">
        <source>vGetTIsToDelete();

/*

Purpose:		Get Tracked Items to delete.  Need to get all of those with invalid
				objects before we can delete as need to have all the invalid objects
				set to null or a dummy value

Date			Who		Reason
02/06/2015		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/
constants

	NoToFind					: Integer = 25000;
	
vars

	root						: UM_Root;
	schema						: Schema;
	klass						: Class;
	prop						: Property;
	obj							: Object;
	propObjValue				: Object;
	objToDelete					: UM_ObjectsToDelete;
	currentObj					: Object;
	newTerm						: CM_Terminal;
	operator					: CM_Operator;
	obj2						: Object;
	passport					: CM_Passport;
	cou							: CM_ClipOnUnit;
	unitTestRun					: UM_UnitTestRun;
	unitTestResult				: UM_UnitTestResult;
	compact						: UM_MapFilesToCompact;
	
	classes						: ClassColl;
	tiSet						: CM_TISet;
	dict						: DynaDictionary;
	nullRefsDelObjArray			: StringArray;
	objArray					: ObjectArray;
	
	properties					: PropertyColl;
	
	iter						: Iterator;
	iter2						: Iterator;
	
	objFound					: Boolean;
	countAll					: Integer;
	errorFound					: Boolean;
	nullRefsDelObj				: Boolean;
	oidStr						: String;
	reason						: String;
	propName					: String;
	noTIsToDelete				: Integer;
	errorHasBeenFound			: Boolean;
	methStartTS					: TimeStamp;
	methEndTS					: TimeStamp;
	elapsedTime					: TimeStampInterval;
	resultStr					: String;
	detailsToOutput				: String;
	endTS						: TimeStamp;
	mapFileName					: String;
	
begin

	methStartTS := app.cnGetServerTime();
	endTS := methStartTS.addHours(2);

	root := UM_Root.firstInstance;
	self.assertNotNull(root);
	
	// TO BE REMOVED
	beginTransaction;
	foreach newTerm in app.myRoot.allTerminals do
		self.opts.purge();
		self.opts.addAssoc("Terminal", newTerm.code);
		if newTerm.getConfig("DefVoyage") = null then
			newTerm.setConfig("DefVoyage", newTerm.getNullVoyage());
		endif;
	endforeach;
	commitTransaction;
	
	create objArray transient;
	
	newTerm := app.getTerminalByName("Unit Test") ; 
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// get the classes to look check
	schema := rootSchema.getSchema("PortSchema");
	self.assertNotNull(schema);
	
	klass := schema.getClass("CM_TrackedItem");
	self.assertNotNull(klass);
	
	create nullRefsDelObjArray transient;
	nullRefsDelObjArray.add("myTerminal");
	nullRefsDelObjArray.add("myCargoType");
	nullRefsDelObjArray.add("myVoyage");
		
	create dict transient;
	dict.setMembership(Object);
	dict.addExternalKey(String, 50, false, false);				// reason for fail
	dict.addExternalKey(String, 50, false, false);				// objects oid as string
	dict.addExternalKey(String, 50, false, false);				// field failing
	dict.endKeys(false);
	
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	create tiSet transient;
	create properties transient;
	iter := classes.createIterator;
	while iter.next(klass) do
	
		///if klass.name &lt;&gt; "CM_Container" then
		///	continue;
		///endif;
		
		if app.cnGetServerTime() &gt;= endTS then
			break;
		endif;
	
		objFound := false;
	
		delete iter2;
		iter2 := klass.instances.createIterator;
		while iter2.next(obj) do
		
			///if obj.CM_TrackedItem.id &lt;&gt; "RJD10100604" then
			///	continue;
			///endif;
			
			if app.cnGetServerTime() &gt;= endTS then
				break;
			endif;
			
			app.writeLog(obj.CM_TrackedItem.String &amp; Tab &amp; obj.CM_TrackedItem.id &amp; Tab &amp; obj.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp;
				obj.creationTime.time.String, LogINFO);
			detailsToOutput := detailsToOutput.trimBlanks() &amp; obj.CM_TrackedItem.String &amp; Tab &amp; obj.CM_TrackedItem.id &amp; Tab &amp; 
				obj.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; obj.creationTime.time.String &amp; CrLf;
			
			delete properties;
			properties := obj.class.allProperties();
			
			errorHasBeenFound := false;
			countAll := countAll + 1;
			
			foreach prop in properties do
			
				errorFound := false;
			
				if prop.isKindOf(Reference) and prop.name &lt;&gt; "schema" and prop.name[1:1] &lt;&gt; "_" and
						not prop.virtual then
					
					propObjValue := obj.getPropertyValue(prop.name).Object;
					nullRefsDelObj := nullRefsDelObjArray.includes(prop.name);
					
					if self.xCheckIsDeleted(propObjValue) then
						//write obj.String &amp; Tab &amp; obj.getPropertyValue('id').String &amp; Tab &amp; prop.name &amp; Tab &amp; 
						//	obj.getPropertyValue(prop.name).Object.String &amp; Tab &amp; "**DELETED**";
						////dict.putAtKey(obj.getOidAsString(), "**DELETED**", prop.name, obj);
						if not errorFound then
							errorFound := true;
						endif;
					elseif propObjValue &lt;&gt; null and not global.isValidObject(propObjValue) then
						//write obj.String &amp; Tab &amp; obj.getPropertyValue('id').String &amp; Tab &amp; prop.name &amp; Tab &amp; 
						//	obj.getPropertyValue(prop.name).Object.String &amp; Tab &amp; "**INVALID**";
						////dict.putAtKey(obj.getOidAsString(), "**INVALID**", prop.name, obj);
						if not errorFound then
							errorFound := true;
						endif;
					elseif propObjValue = null then
						if nullRefsDelObjArray.includes(prop.name) then
							//write obj.String &amp; Tab &amp; obj.getPropertyValue('id').String &amp; Tab &amp; prop.name &amp; Tab &amp; 
							//	obj.getPropertyValue(prop.name).Object.String &amp; Tab &amp; "**NULL**";
							////dict.putAtKey(obj.getOidAsString(), "**NULL**", prop.name, obj);
							if not errorFound then
								errorFound := true;
							endif;
						endif;
					endif;
					
				endif;
				
				if not errorFound then
					continue;
				endif;
				
				/*
				// set the known problem fields
				beginTransaction;
				if prop.name = "myCargoType" then
					obj.setPropertyValue("cargoType", "11202");
				elseif prop.name = "myTerminal" then
					obj.setPropertyValue(prop.name, newTerm);
				elseif prop.name = "myOperator" then
					obj.setPropertyValue(prop.name, operator);
				elseif prop.name = "myVoyage" then
					if global.isValidObject(obj.getPropertyValue("myTerminal").CM_Terminal) then
						obj.setPropertyValue(prop.name, obj.getPropertyValue("myTerminal").CM_Terminal.getNullVoyage());
					else
						obj.setPropertyValue(prop.name, null);
					endif;
				else
					obj.setPropertyValue(prop.name, null);
				endif;
				commitTransaction;
				*/
				
				errorHasBeenFound := true;
			
			endforeach;
			
			if not errorHasBeenFound then
				continue;
			endif;
			
			//objToDelete := root.allObjectsToDeleteByObject[obj.getOidAsString()];
			//if objToDelete &lt;&gt; null then
			//	continue;
			//endif;
			
			//beginTransaction;
			
			
			//create objToDelete persistent;
			//objToDelete.updateDetails(obj, UM_ObjectsToDelete.WhenToDeleteNext);
			noTIsToDelete := noTIsToDelete + 1;
			
			/*
			obj.CM_TrackedItem.setPropertyValue("readyToShip", false);
		
			// check that locations are not invalid
			if not global.isValidObject(obj.CM_TrackedItem.myPrimaryActualLocation) then
				obj.CM_TrackedItem.setPropertyValue("myPrimaryActualLocation", null);
			endif;
			if not global.isValidObject(obj.CM_TrackedItem.myPrimaryPlannedLocation) then
				obj.CM_TrackedItem.setPropertyValue("myPrimaryPlannedLocation", null);
			endif;
			if not global.isValidObject(obj.CM_TrackedItem.myPrimaryQueuedLocation) then
				obj.CM_TrackedItem.setPropertyValue("myPrimaryQueuedLocation", null);
			endif;		
			
			if not obj.CM_TrackedItem.allQueuedFutureMoves.isEmpty() or 
					not obj.CM_TrackedItem.allPlannedFutureMoves.isEmpty() then
				objArray.clear();
				obj.CM_TrackedItem.allQueuedFutureMoves.copyNoDups(objArray);
				obj.CM_TrackedItem.allPlannedFutureMoves.copyNoDups(objArray);
			
				foreach obj2 in objArray do
					delete obj2;
				endforeach;
			endif;
			
			// if child then need to detach from parent
			if obj.CM_TrackedItem.isChild() then
				if obj.isKindOf(CM_ClipOnUnit) and obj.CM_TrackedItem.myParent = null then
						obj.CM_ClipOnUnit.setPropertyValue("myParent", obj.CM_ClipOnUnit.myReefer);
					endif;
				obj.CM_TrackedItem.myParent.detachChild(obj.CM_TrackedItem);
			endif;
			
			if obj.CM_TrackedItem.hasChildren then
				obj.CM_TrackedItem.detachChildren();
			endif;
			
			if obj.isKindOf(CM_Container) then
				cou := obj.CM_Container.getCou();
				if cou &lt;&gt; null and cou.myReefer &lt;&gt; null then
					if cou.myParent = null then
						cou.setPropertyValue("myParent", cou.myReefer);
					endif;
					cou.myReefer.detachCOU(passport);
				endif;
			endif;
			*/
			
			app.writeLog(Tab &amp; 'Deleting: ' &amp; obj.CM_TrackedItem.String &amp; Tab &amp; obj.CM_TrackedItem.id &amp; Tab &amp; obj.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp;
				obj.creationTime.time.String &amp; Tab &amp; noTIsToDelete.String, LogINFO);
				
			// get the map file that needs compacting
			mapFileName := obj.class.getDbFile().name;
			compact := root.allMapFilesToCompact[mapFileName];
			if compact = null then
				self.addMapToFilesToCompact(mapFileName, UM_MapFilesToCompact.WhenToCompactNext);
			else
				beginTransaction;
				compact.updateWhenToCompact(UM_MapFilesToCompact.WhenToCompactNext);
				commitTransaction;
			endif;		
			
			beginTransaction;
			obj.CM_Object.erase(FORCED_ERASE);
			commitTransaction;
		
			/*******************************************************************************
			* Anything that needs updating but has begin/commitTransaction
			*******************************************************************************/
			
			/*
			if obj.CM_TrackedItem.isQueued() then
				self.unqueueTI(obj.CM_TrackedItem);
			endif;
			
			if obj.CM_TrackedItem.isPlanned(PLANNING_MODE) then
				self.unplanTI(obj.CM_TrackedItem);
			endif;
			*/
			
			///if obj.CM_TrackedItem.id &lt;&gt; "RJD10100604" then
			///	break;
			///endif;
			
			if noTIsToDelete &gt;= NoToFind then
				break;
			endif;
		
		endwhile;
		
		if noTIsToDelete &gt;= NoToFind then
			break;
		endif;
		
	endwhile;
	
	app.writeLog("No of TI's to Delete = " &amp; noTIsToDelete.String, LogINFO);
	app.writeLog("UM_ObjectsToDelete.instances.size: " &amp; UM_ObjectsToDelete.instances.size.String, LogINFO);
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	unitTestRun := root.allUnitTestRuns.last.UM_UnitTestRun;
	
	resultStr := "PASS";
	if noTIsToDelete &lt; NoToFind then	
		resultStr := "FAIL";
	endif;
		
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, detailsToOutput, methStartTS, unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;		
	
epilog

	delete iter;
	delete iter2;
	delete classes;
	delete tiSet;
	delete properties;
	dict.clear();
	delete dict;
	delete nullRefsDelObjArray;
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="vKillRunningDebugProcesses" id="ad1942e9-32ea-4413-9f78-4293e8beb2ff">
        <source>vKillRunningDebugProcesses(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		This will kill off any currently running debug processes
				so that they don't interfere with the overnight run

Date			Who		Reason
12/12/2016		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars
	
	aNode 						: Node;	
	aProcess 					: Process;
	unitTestResult 				: UM_UnitTestResult;
	
	theNodes 					: NodeDict;
	theProcesses 				: ProcessDict; 
	errorDetailsArray			: StringArray512;
	
	invalidNode 				: Boolean;
	invalidProcess				: Boolean;
	result						: String;
	methStartTS					: TimeStamp;
	methEndTS					: TimeStamp;
	elapsedTime					: TimeStampInterval;
	errorDetails				: String;
	
begin
	
	on Exception do app.handleDeletedObject(exception, aNode, invalidNode);
	on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);
	
	methStartTS := app.cnGetServerTime();
	result := "FAIL";
	
	theNodes := system.nodes.cloneSelf(true);
	
	create errorDetailsArray transient;
	
	foreach aNode in theNodes do
		// Clone the nodes collection of processes
		delete theProcesses;
		theProcesses := aNode.processes.cloneSelf(true);
		
		// If we had an exception accessing the node, then skip it
		if invalidNode then
			continue;
		endif;
		
		foreach aProcess in theProcesses do
		
			if invalidProcess then
				continue;
			endif;
			
			if aProcess.persistentApp.name = "JadeDebugger" then
				app.writeLog("Forcing debug session: " &amp; aNode.name &amp; Tab &amp; aNode.osID.String &amp; Tab &amp; aProcess.cnEcGetTableDisplay(), LogINFO);
				errorDetailsArray.add(aProcess.persistentApp.name &amp; Tab &amp; aProcess.cnEcGetTableDisplay());
				system.forceOffUser(aProcess.node, aProcess);
			endif;
			
		endforeach;
		
	endforeach;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// check tpo see if we have any errors
	if errorDetailsArray.size &gt; 0 then
		errorDetails := CrLf &amp; CrLf &amp; "The following DEBUG sessions have been terminated:" &amp; CrLf &amp; errorDetailsArray.concatenate(CrLf);
		_userSummaryDict.addAssociation(app.getUTAdminUserCode(), result &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
			" ADMIN  " &amp; (elapsedTime.getMilliseconds/1000).String &amp; " secs " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; errorDetails);
	else	
		result := "PASS";	
	endif;
	
	beginTransaction;
	create unitTestResult persistent;										
	result := result.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, errorDetails, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;

epilog

	delete errorDetailsArray;
	delete theProcesses;
	delete theNodes;

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vPostInvoicesForUnitTest" id="d4c7d54d-81b0-483f-9d18-ead97d1dbd57">
        <source>vPostInvoicesForUnitTest(_unitTestRun : UM_UnitTestRun io);

/*

Purpose:		Posts the invoices for the unit test terminal

Date			Who		Reason
14/02/2013		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars
	
	unitTestResult 							: UM_UnitTestResult;
	root									: UM_Root;
	
	terminalArray							: CM_TerminalArray;

	resultStr								: String;
	result									: Boolean;
	methStartTS								: TimeStamp;
	methEndTS								: TimeStamp;
	elapsedTime								: TimeStampInterval;
	
begin

	methStartTS := app.cnGetServerTime();
	
	root := UM_Root.firstInstance;
	if root = null then
		app.writeLog("UM_Root not found.  Aborting", LogINFO);
		return;
	endif;
	
	create terminalArray transient;
	terminalArray.add(self.getTerminal());
	
	self.opts.purge();
	self.opts.addAssoc("TerminalArray", terminalArray);
	result := self.postInvoices();	
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// did it pass or fail
	if not result then
		resultStr := "Fail ";
	else	
		resultStr := "Pass ";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, null, methStartTS, _unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
		
epilog

	if terminalArray &lt;&gt; null then
		delete terminalArray;
	endif;
	
end;</source>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vReportFailingGTThreshold" id="f1f7679f-590e-481d-a23a-866571840254">
        <source>vReportFailingGTThreshold(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Report those unit tests that have been failing for move than 10 consecutive runs
				
Date			Who		Reason
05/12/2013		cnwmh5	Initial creation
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars
	
	unitTestResult 							: UM_UnitTestResult;

	detailsToOutput							: String;
	resultStr								: String;
	methStartTS								: TimeStamp;
	methEndTS								: TimeStamp;
	elapsedTime								: TimeStampInterval;
	failingThreshold						: Integer;
	failingFor								: Integer;
	tmpDate									: Date;
	
begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);
	
	methStartTS := app.cnGetServerTime();
	
	failingThreshold := UM_Blame.DateThreshold;
	detailsToOutput := null;
	
	tmpDate := app.myUMTestRunONight.startTS.date;
	
	// read through all the failing unit tests and flag those that have been failing for more that UM_Blame.DateThreshold
	foreach unitTestResult in app.myUMTestRunONight.allFailed do
	
	
		failingFor := unitTestResult.myClassMethod.getFailingFor(tmpDate);
		
		if failingFor &gt; failingThreshold then
			detailsToOutput := detailsToOutput.trimBlanks() &amp; CrLf &amp; unitTestResult.myClassMethod.className &amp; "::" &amp; 
				unitTestResult.myClassMethod.methodName &amp; " " &amp; unitTestResult.ownerName &amp; " " &amp; 
				unitTestResult.elapsedTime.String &amp; " secs     failingFor: " &amp; failingFor.String &amp; " runs";
		endif;
	
	endforeach;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// did it pass or fail
	if detailsToOutput &lt;&gt; null then
		resultStr := "Fail ";
		detailsToOutput := CrLf &amp; "The following unit test(s) have been failing for more that " &amp; failingThreshold.String &amp; 
			" days and need to be followed-up:" &amp; CrLf &amp; detailsToOutput;
	
		// create the email to send to the Admins
		_userSummaryDict.addAssociation(app.getUTAdminUserCode(), resultStr &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
			" ADMIN  " &amp; (elapsedTime.getMilliseconds/1000).String &amp; " secs " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; detailsToOutput);
			
	else	
		resultStr := "Pass ";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, detailsToOutput, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
		
epilog

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vReportFailingGTThreshold2" id="69034e0b-72b5-4d5f-8389-c79120bdbabb">
        <source>vReportFailingGTThreshold2(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Report those unit tests that have been failing for more than the threshold of consecutive runs
				
Date			Who		Reason
16/11/2017		jlgmh5	Initial creation

*/
constants
	
	FailingForThreshold						: Integer = 4;

vars
	
	unitTestResult 							: UM_UnitTestResult;
	unitTestRun								: UM_UnitTestRun;
	classMethod								: UM_UnitTestClassMethod;
	
	iter									: Iterator;

	detailsToOutput							: String;
	methStartTS								: TimeStamp;
	tempTS									: TimeStamp;
	logResult								: Boolean;
	failingForXConsecutiveRuns				: Integer;
	
begin

	logResult := true;

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);
	
	methStartTS := app.cnGetServerTime();
		
	detailsToOutput := null;
	
	// get the last unit test run as this is the run we need to work out the length of time of failing for
	unitTestRun := UM_UnitTestRun.lastInstance;
	
	// read through all the failing tests and find out how long they have failed for and whether over our threshold
	iter := unitTestRun.allFailed.createIterator;
	while iter.next(unitTestResult) do
	
		classMethod := unitTestResult.myClassMethod;
	
		if classMethod.isVerificationAdminTest() then
			continue;
		endif;
		
		tempTS := unitTestRun.startTS;
		failingForXConsecutiveRuns := classMethod.failingForXConsecutiveRuns(tempTS);
		if failingForXConsecutiveRuns &gt; FailingForThreshold then
			write classMethod.className &amp; Tab &amp; classMethod.methodName &amp; ' has been failing for ' &amp; 
				failingForXConsecutiveRuns.String &amp; ' consecutive runs starting on ' &amp;
				tempTS.date.format("dd/MM/yyyy");
		endif;
		
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vReportLogicalCertErrors" id="df59d131-1999-42df-a508-43d56147ed72">
        <source>vReportLogicalCertErrors(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Report any Logical Certify errors
				
Date			Who		Reason
16/07/2014		cnwmh5	Initial creation
13/06/2016		cnwmh5	Remove reference to UM_UnitTestRun from signature
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
*/

vars
	
	unitTestResult 					: UM_UnitTestResult;
	klass							: Class;

	classes							: ClassColl;
	
	detailsToOutput					: String;
	resultStr						: String;
	methStartTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	className						: String;
	tmpDate							: Date;
	failingFor						: Integer;
	
begin

	app.writeLog("Running " &amp; method.qualifiedName() &amp; ".  Please wait...", LogINFO);

	// find the logical certify class
	klass := currentSchema.getClass("UT_DSL");
		
	// get the class and subclasses to see what categories we have
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	foreach klass in classes do
		if klass.name.cnContains("LogicalCertify") then
			className := klass.name;
			break;
		endif;	
	endforeach;

	detailsToOutput := null;
	tmpDate := app.myUMTestRunONight.startTS.date;
	
	// read through all the failing unit tests and flag those that have been failing for more that UM_Blame.DateThreshold
	foreach unitTestResult in app.myUMTestRunONight.allFailed do
		if unitTestResult.myClassMethod.className = className then
			failingFor := unitTestResult.myClassMethod.getFailingFor(tmpDate);
			detailsToOutput := detailsToOutput.trimBlanks() &amp; CrLf &amp; Tab &amp; unitTestResult.myClassMethod.className &amp; "::" &amp; 
				unitTestResult.myClassMethod.methodName &amp; " " &amp; unitTestResult.ownerName &amp;  " failing for: " &amp; failingFor.String &amp; " run(s)";
		endif;
	endforeach;
	
	// did it pass or fail
	if detailsToOutput &lt;&gt; null then
		resultStr := "Fail ";
		detailsToOutput := CrLf &amp; "The following Logical Certify tests have failed and need attention:" &amp; CrLf &amp; detailsToOutput;
	
		// create the email to send to the Admins
		_userSummaryDict.addAssociation(app.getUTAdminUserCode(), resultStr &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
			" ADMIN  " &amp; (elapsedTime.getMilliseconds/1000).String &amp; " secs " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; detailsToOutput);
			
	else	
		resultStr := "Pass ";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, detailsToOutput, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
		
epilog

	delete classes;

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vSetupAddPatchesToRelease" id="66315ef3-887b-4f39-93fe-f684313f1fb1">
        <source>vSetupAddPatchesToRelease();

/*

Purpose:		Setup the required files for adding new patches to a release cut

Date			Who		Reason
05/09/2017		jlgmd1	Initial creation

*/
constants

	PsFileName				: String = "AddPatchesToRelease.ps1";
	CmdFileName				: String = "RunAddPatchesToRelease.bat";

vars

	fileFolder				: FileFolder;
	psFile					: File;
	cmdFile					: File;
	
	result					: Integer;

begin

	// check that directory exists
	create fileFolder transient;
	fileFolder.usePresentationFileSystem := true;
	fileFolder.fileName := app.cnGetClientMiscPath(true) &amp; "\DocumentationCheck";
	if not fileFolder.isAvailable() then
		fileFolder.make();
	endif;
	
	// delete powershell file if exists
	create psFile transient;
	psFile.usePresentationFileSystem := fileFolder.usePresentationFileSystem;
	psFile.fileName := fileFolder.fileName &amp; "\" &amp; PsFileName;
	if psFile.isAvailable() then
		psFile.purge();
	endif;
	
	// create command file to run the powershell script
	create cmdFile transient;
	cmdFile.usePresentationFileSystem := fileFolder.usePresentationFileSystem;
	cmdFile.fileName := fileFolder.fileName &amp; "\" &amp; CmdFileName;
	if cmdFile.isAvailable() then
		cmdFile.purge();
	endif;
	cmdFile.writeLine('powershell.exe -file "%CD%\' &amp; PsFileName &amp; '"' );
	cmdFile.close();
		
	// create the powershell script to run
	self.xAddPatchesToReleasePS(psFile);
	
	// run the ps file
	app.writeLog("Running AddPatchesToRelease script. Please wait...", LogINFO);
	node.createExternalProcess(fileFolder.fileName, "cmd /c " &amp; CmdFileName, null, null, true, true, result);

	if (result &lt;&gt; 0 and result &lt;&gt; 4) then
		app.writeLog("Script failed. (" &amp; result.String &amp; ")", LogINFO);
	endif;
	

epilog

	delete fileFolder;
	delete psFile;
	delete cmdFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="vSetupJugDeploymentDirectory" id="f0d550a2-473a-4ba3-bb0a-19224f5df171">
        <source>vSetupJugDeploymentDirectory();

/*

Purpose:		Setup the required JugDeployment directory based on selections	

Date			Who		Reason
15/08/2016		cnwmh5	Initial creation
05/09/2017		jlgmd1	Changed powershell execution script path to be generic

*/
constants

	PsFileName				: String = "CopyToJugDeploymentDirectory.ps1";
	CmdFileName				: String = "RunCopyToJugDeployment.bat";

vars

	fileFolder				: FileFolder;
	psFile					: File;
	cmdFile					: File;
	
	result					: Integer;

begin

	// check that directory exists
	create fileFolder transient;
	fileFolder.usePresentationFileSystem := true;
	fileFolder.fileName := app.cnGetClientMiscPath(true) &amp; "\DocumentationCheck";
	if not fileFolder.isAvailable() then
		fileFolder.make();
	endif;
	
	// delete powershell file if exists
	create psFile transient;
	psFile.usePresentationFileSystem := fileFolder.usePresentationFileSystem;
	psFile.fileName := fileFolder.fileName &amp; "\" &amp; PsFileName;
	if psFile.isAvailable() then
		psFile.purge();
	endif;
	
	// create command file to run the powershell script
	create cmdFile transient;
	cmdFile.usePresentationFileSystem := fileFolder.usePresentationFileSystem;
	cmdFile.fileName := fileFolder.fileName &amp; "\" &amp; CmdFileName;
	if cmdFile.isAvailable() then
		cmdFile.purge();
	endif;
	cmdFile.writeLine('powershell.exe -file "%CD%\' &amp; PsFileName &amp; '"' );
	cmdFile.close();
		
	// create the powershell script to run
	self.xCopyToJugDeploymentPS(psFile);
	
	// run the ps file
	app.writeLog("Setting up JugDeployement directories.  Please wait...", LogINFO);
	node.createExternalProcess(fileFolder.fileName, "cmd /c " &amp; CmdFileName, null, null, true, true, result);

	if (result &lt;&gt; 0 and result &lt;&gt; 4) then
		app.writeLog("Setting up of JugDeployment files failed. (" &amp; result.String &amp; ")", LogINFO);
	endif;
	

epilog

	delete fileFolder;
	delete psFile;
	delete cmdFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="vSetupReleaseDocumentationCopy" id="0db802f0-8c10-46e7-a1de-77f0b9a9b1e3">
        <source>vSetupReleaseDocumentationCopy(_testRunner : JMTTestController);

/*

Purpose:		

Date			Who		Reason
06 April 2016	cnwmh5	Initial creation
08/05/2025		navhn30 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1

*/

constants

	FILENAME						: String = "ReleaseDocCopy.ps1";

vars

	fileFolder						: FileFolder;
	
	allFiles						: FileNodeArray;

	directory						: String;
	subject							: String;
	message							: String;

begin

	// if main developement or unicode then don't want this to run
	if app.isDevelopmentSystemMain() or app.isUnicode then
		return;
	endif;

	// initialise transient(s)
	create fileFolder transient;

	// check to see if the powershell script exists in DevelopmentEnvs
	directory := app.getIniFileName();
	directory := directory[1:directory.reversePos("/")-1];
	
	fileFolder.fileName := directory;
	fileFolder.mask := FILENAME;
	fileFolder.usePresentationFileSystem := true;
	allFiles := fileFolder.files();
	
	// if exists then nothing to do
	if not allFiles.isEmpty() then
		return;
	endif;	
	
	// create powershell script
	self.xPowerShellRelDocCopy(directory, FILENAME);
	
	// create schedule task
	self.xPowerShellSetupScheduleTask(directory, FILENAME);
	
	// send email to admins to get 'Run whether user is logged on or not set 
	subject := "Release Documentation Copy Scheduled Task Created";
	message := "The Release Documentation Copy Scheduled Task has been created.  The following details need to be changed:" &amp; CrLf &amp;
		"1. When running the task, use the following user account - Change to use CNW\cnwchcs11" &amp; CrLf &amp;
		"2. Run whether user is logged on or not - Select";
	app.emailReports(message, subject, 2, _testRunner,null,false);

epilog

	delete fileFolder;

end;</source>
        <Parameter name="_testRunner" type="JMTTestController"/>
    </JadeMethod>
    <JadeMethod name="vSourceComparison" id="3294b61c-e23e-47f0-b40d-e7cdb3626ec6">
        <source>vSourceComparison(_unitTestRun : UM_UnitTestRun io; _checkAll : Boolean; _differences: String output);
/*

Purpose:			A Unit test created to compare Source Code from WMast or DMast against the local environment this unit test is run from
					Outputs a list of Missing Global Constant Categories/Global Constants/Classes/Methods and Differing Methods
					Will eventually be extended to compare Missing Class Attributes/References/Constants, 
					Differing Class Attributes/References/Constants, Map Files and Differing Global Constants

Parameters:			_checkAll	Runs the 'doSchemaComparison' method on the DevSourceCompare Agent

Return Value:		

Date		Who		Reason
06 December 2021	navpw1	Initial creation TFS: 52202
21/5/2025 navsaa30 MTN-34812 MTN - Source Compare/Unit Test - Change Email to be a Summary Count by User - Phase1
17 Oct 2025	navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
*/

constants
	SchemaFilePathDMast = "C:\JMTDailyExtracts\schemas"; //S11 Daily Extract path
	ReleasesFolderM24 = "\\cnwchcm24\cnwpod$\Releases\";
	SchemaFilePathWMast = "\Daily\JadeMaster\schemas";	// ReleasesFolderM24 + CM_Root::getVersionString() + SchemaFilePathWMast = \\cnwchcm24\cnwpod$\Releases\20021\Daily\JadeMaster\schemas
	
vars
	devSourceCompareAgent 	: Object;
	scm 					: Schema;
	cls						: Class;
	
	fileNode				: FileNode;
	folder					: FileFolder;
	schemaFilePath			: String;
	logLevel				: Integer;
	
	unitTestResult 			: UM_UnitTestResult;
	methStartTS				: TimeStamp;
	methEndTS				: TimeStamp;
	elapsedTime				: TimeStampInterval;
	resultDetails			: String;
	result					: String;
	
begin
	methStartTS := app.cnGetServerTime();
	logLevel := app.logLevel; //Get original Log Level as we revert it back at the end of this method to stop garbage being printed
	result := "FAIL";
	
	app.changeLogLevel(LogERROR);
	
	if app.myCnKarmaCntrl.environmentId.toUpper = "NAVDMAST" then //ToDO: Look for a better way to get envId
		schemaFilePath := ReleasesFolderM24 &amp; app.myRoot.getVersionString() &amp; SchemaFilePathWMast;
	else
		schemaFilePath := SchemaFilePathDMast;
	endif;
	
	scm := rootSchema.getSchema("DevSchema");
	if scm = null then
		self.logMessage("DevSchema not found exiting...");
		return;
	endif;
	
	cls := scm.getClass("DEV_SourceCompareAgent");
	
	if cls = null then
		self.logMessage("DEV_SourceCompareAgent not found exiting...");
		return;
	endif;

	create devSourceCompareAgent as cls transient;
	create folder transient;
	
	devSourceCompareAgent.sendMsgWithParams("setIsRunningComparison", true);
	
	folder.fileName := schemaFilePath;
	folder.usePresentationFileSystem := true; //Use clients connection
	folder.mask := "*.scm";
	
	if not folder.isAvailable() then
		devSourceCompareAgent.sendMsgWithParams("logMessage", "Folder " &amp; folder.fileName &amp; " not found, exiting", LogFATAL);
		return;
	endif;
	
	foreach fileNode in folder.files do
		if (not fileNode.isKindOf(FileFolder)) then
			if not _checkAll then
				devSourceCompareAgent.sendMsgWithParams("doGetRecentlyModified", fileNode.fileName, fileNode.name.replace(".scm", ""), false, 1);
			else
				devSourceCompareAgent.sendMsgWithParams("doSchemaComparison", fileNode.fileName, fileNode.name.replace(".scm", ""), false, 1);
			endif;
			//break;
		endif;
	endforeach;

	devSourceCompareAgent.sendMsgWithParams("setReportAvailable"); //Makes the Report visible in Source Compare App
	
	if devSourceCompareAgent.getPropertyValue("errorsOccurred").Boolean then
		_differences := devSourceCompareAgent.sendMsgWithParams("getReportUserSummary").asString();		//24/6/25  navsaa30 #34812 		
	endif;
	
	if _differences.length &gt; 0 then
		devSourceCompareAgent.sendMsgWithParams("logMessage", _differences, LogERROR);
	endif;
	
	//self.assertFalse(devSourceCompareAgent.getPropertyValue("errorsOccurred").Boolean);
	
	if not devSourceCompareAgent.getPropertyValue("errorsOccurred").Boolean then
		result := "PASS";
	endif;
	
	app.changeLogLevel(logLevel);
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;			
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := methEndTS - methStartTS;
	
	// Testing to see if this is what gets put in the Test 'Output' field.
	resultDetails := _differences;
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, resultDetails, methStartTS, _unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
	devSourceCompareAgent.sendMsgWithParams("setIsRunningComparison", false);
	
epilog
	delete devSourceCompareAgent;
	delete folder;
	
end;</source>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
        <Parameter name="_checkAll" type="Boolean"/>
        <Parameter name="_differences" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="vTestPermissions" id="5620fbfd-db36-4ead-8479-7059a7f4588e">
        <source>vTestPermissions(_userSummaryDict: CM_AssociationDict io);

/*

Purpose:			To check that view and maint permissions are set up correctly on new forms created

Parameters:			

Return Value:		


Date			Who		Reason
07 October 2016	cnwmk3	Initial creation
26 August 2020	jlgmd1	Added a few more classes to list to ignore
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/
constants
	StrView					= "View";
	StrMaint				= "Maint";
	StrExplanation			= " permission constant does not have any Explanation.";
	StrCheckConstant		= " Please check the permission constant.";
	StrAddPermission		= " Please add Permission for this form.";
	DocLink					= "To address these issues, please refer to the documentation at: https://wiki.cnw.co.nz/JMT-KB-AddAnItemToNavigator";
	BaseClass				= "CM_BaseForm";
	HasBaseClass			= " has CM_Base as parent.";
	NoBaseClass				= " does not have CM_Base as parent.";
	ModifiedBy				= " form modified by ";
	CallInheritMethod		= " does call inheritMethod in the unload event.";
	NotCallInheritMethod	= " does not call inheritMethod in the unload event.";
	IncorrectViewConst		= " have Incorrect view permission constant";
	IncorrectMaintConst		= " have Incorrect Maint permission constant";
	SameViewMaintConstant	= " have same permission constants for View and Maint Permission.";
	NoCreateMethod			= " does not have CREATE method";
	AddCreateMethod			= " Please add a CREATE method and View/Maintenance permissions for this form.";
	HasViewPermission		= " has View Permission";
	NoViewPermission		= " does not have View Permission";
	HasMaintPermission		= " has Maint Permission";
	NoMaintPermission		= " does not have Maint Permission";
	ErrHeading				= "The following Permission issues are found: ";
vars
	form					: Form;
	hasCreateMethod			: Boolean;
	hasViewPermission		: Boolean;
	hasMaintPermission		: Boolean;
	dateStartTesting		: TimeStamp;
	methDict				: MethodNDict;
	meth					: Method;
	methodName				: String;
	className				: String;
	source					: String;
	klass					: Class;
	schemasToCheckArray		: StringArray;
	posCrLf					: Integer;	
	sourceLine				: String;
	str						: String;
	pos1					: Integer;
	constantView			: GlobalConstant;
	constantMaint			: GlobalConstant;
	lhs						: String;
	rhs						: String;
	permObj					: CM_PermissionObject;
	permAgent				: CM_PermissionAgent;
	errorDetails			: String;	
	result					: String;
	methStartTS				: TimeStamp;
	methEndTS				: TimeStamp;
	elapsedTime				: TimeStampInterval;
	unitTestResult 			: UM_UnitTestResult;
	modifiedBy				: String;
	errorDetailsAll			: String;
	schemaName				: String;
	hasUnloadMethod			: Boolean;
	hasInheritMethod		: Boolean;
	root					: UM_Root;
	superClass				: String;
	classSet				: ClassSet;
	klass1					: Class;
	baseParent				: Boolean;
	classesToIgnore			: StringArray;
begin
	create permAgent transient;
	create methDict transient;
	create schemasToCheckArray transient;
	create classesToIgnore transient;
	create classSet transient;
	
	permAgent.populatePermissionDict(true, true, 0);
	dateStartTesting.setDateTime(2016, 10, 01, 00, 00, 00, 00);
	result := "FAIL";
	posCrLf := 0;
	
	schemasToCheckArray.add("BaseSchema");
	schemasToCheckArray.add("JACBackup");
	schemasToCheckArray.add("JMExternalControls");
	schemasToCheckArray.add("PortSchema");
	schemasToCheckArray.add("MobileServerSchema");
	//schemasToCheckArray.add("MobileUISchema");
	schemasToCheckArray.add("UiCommonSchema");
	schemasToCheckArray.add("GateSchema");
	schemasToCheckArray.add("GeneralCargoSchema");
	schemasToCheckArray.add("HmsSchema");
	schemasToCheckArray.add("InvoiceSchema");
	schemasToCheckArray.add("LogSchema");
	schemasToCheckArray.add("LOGAS400LoadSchema");
	schemasToCheckArray.add("ShipSchema");
	schemasToCheckArray.add("SysOpsSchema");
	schemasToCheckArray.add("WebSchema");
	schemasToCheckArray.add("WebExampleSchema");
	schemasToCheckArray.add("WebServicesSchema");
	schemasToCheckArray.add("XMLSchema");
	schemasToCheckArray.add("YardSchema");
	schemasToCheckArray.add("JMMobileClientBaseSchema");
	schemasToCheckArray.add("JMMobileClientRTSchema");
	schemasToCheckArray.add("JSSCoreSchema");
	schemasToCheckArray.add("JSSChangeTrackingSchema");
	schemasToCheckArray.add("JSSFileManagerSchema");
	schemasToCheckArray.add("JSSLicenseKeySchema ");
	
	classesToIgnore.add("SHP_GCHoldLocationDefnForm");
	classesToIgnore.add("INV_InvoiceReturn");
	classesToIgnore.add("SOP_WPRatesCopyForm");
	classesToIgnore.add("CMUI_UserPreferencesForm");
	classesToIgnore.add("CMUI_TroubleResolver");	// PmAdmYardovrView/Maint "disabled" (has no category, so doesn't appear to the agent) - Form no longer in use ?
	classesToIgnore.add("CMUI_YardOverView");		// PmAdmYardovrView/Maint "disabled" (has no category, so doesn't appear to the agent) - Form no longer in use ?
	classesToIgnore.add("CM_MenuEntityList");		// Dev App Usage
	classesToIgnore.add("CM_BlankPicture");			// Dev App Usage
	classesToIgnore.add("CM_MenuEntityIcons");		// Dev App Usage
	classesToIgnore.add("CM_MenuEntityIconList");	// Dev App Usage
	classesToIgnore.add("CM_MenuEntityIconList");	// Dev App Usage
	
	// check all forms
		foreach form in Form.instances do
			methDict.clear;
			classSet.clear;
			hasCreateMethod	:= false;
			hasViewPermission := false;
			hasMaintPermission := false;
			baseParent := false;
			
			className := form.name;																// find class in the schema using form.name
			klass := rootSchema.findClassInSubschema(className);
			schemaName := klass.schema.name;
			klass := rootSchema.getSchema(schemaName).getClass(className);
			superClass := klass.getSuperclass.name;
			klass.cnEcGetAllSuperclasses(classSet);
			
			// proceed only if a new form
			if form.creationTime &gt; dateStartTesting and form.name &lt;&gt; "Test" then
				
				if not schemasToCheckArray.includes(schemaName) then							// ignore if form is in any of schemasToRemoveArray list
					continue;
				endif;
				if classesToIgnore.includes(className) then
					continue;
				endif;
				foreach klass1 in classSet do
					if klass1.name = BaseClass then
						baseParent := true;
					endif;
				endforeach;
				if baseParent then
					//app.writeLog(klass.name &amp; HasBaseClass, LogINFO);
				else
					app.writeLog(schemaName &amp; "::" &amp;  className &amp; NoBaseClass , LogINFO);
					errorDetails := schemaName &amp; "::" &amp;  className &amp; " " &amp; ModifiedBy &amp; modifiedBy &amp; NoBaseClass ;
					errorDetailsAll := errorDetailsAll &amp; CrLf &amp; errorDetails;
				endif;
				
				// if class is found, get all methods
				if klass &lt;&gt; null then
					modifiedBy := klass.getModifiedBy();
					app.writeLog(className &amp; " is a new form in " &amp; schemaName, LogINFO);
					klass.getMethods(methDict);
					hasUnloadMethod := false;
					hasInheritMethod := false;
					
					// iterate through all methods to check that "unload" method calls "inheritMethod" and to find the method "create"
					foreach meth in methDict do
						if meth.name = "unload" then
							hasUnloadMethod := true;
							source := self.removeCommentsFromSource(meth.getSource());
							//length := source.length;
							posCrLf := 1;
							// check that "unload" method calls "inheritMethod"
							if source.pos("inheritMethod", 1) &gt; 0 then
								hasInheritMethod := true;
							endif;
						endif;
						// find the method "create"
						methodName := meth.name;
						if methodName = "create" then
							hasCreateMethod := true;
						endif;
					endforeach;
					
					//	Logging and writing to errorDetails if hasUnloadMethod or hasInheritMethod are false
					if hasUnloadMethod and hasInheritMethod then
						//app.writeLog(meth.name &amp; CallInheritMethod, LogINFO);
					elseif hasUnloadMethod and not hasInheritMethod then
						app.writeLog(schemaName &amp; "::" &amp;  className &amp; NotCallInheritMethod, LogINFO);
						errorDetails := schemaName &amp; "::" &amp;  className &amp; " " &amp; ModifiedBy &amp; modifiedBy &amp; NotCallInheritMethod;
						errorDetailsAll := errorDetailsAll &amp; CrLf &amp; errorDetails;
					endif;
					
					// proceed if "create" method is found to check for View and Maint permissions
					if hasCreateMethod then
						meth := klass.getMethod("create");
						source := self.removeCommentsFromSource(meth.getSource());
						source.replaceChar(Tab, " ");
						source := source.trimBlanks();
						//length := source.length();
						posCrLf := 1;
							
						// continue upto last line of code
						while posCrLf &gt; 0 do
							sourceLine := source.cnEcGetNextLine(posCrLf);
							if posCrLf = 0 then
								break;
							endif;	
							if not sourceLine.cnContains(".permission") then
								continue;
							endif;
							
							pos1 := 1;
							str := sourceLine.trimBlanks();
							str.getLHSandRHS(":=", pos1, lhs, rhs);
							lhs := lhs[6:end].trimBlanks();
							rhs := rhs.scanUntil(";", pos1).trimBlanks();
							//write meth.getSchema().name &amp; Tab &amp; className &amp; Tab &amp; "lhs:" &amp; Tab &amp; lhs &amp; Tab &amp; "rhs: " &amp; Tab &amp; rhs &amp; rhs.length.asStringJMT();
							
							// check to see if there is a View Permission 
							if lhs.cnContains(StrView) then
								hasViewPermission := self.xCheckPermissions(lhs, rhs, StrView, klass, errorDetails, errorDetailsAll, constantView);
							elseif lhs.cnContains(StrMaint) then
								// check to see if there is a Maint Permission
								if rhs.length = 1 and rhs.asIntegerJMT = 0 then
									hasMaintPermission := true;
									continue;
								endif;
								hasMaintPermission := self.xCheckPermissions(lhs, rhs, StrMaint, klass, errorDetails, errorDetailsAll, constantMaint);
							endif;
						endwhile;
						if constantView &lt;&gt; null and constantMaint &lt;&gt; null then
							if constantView = constantMaint then
									app.writeLog(className &amp; " form in " &amp; klass.schema.name &amp; SameViewMaintConstant, LogINFO);
									errorDetails := schemaName &amp; "::" &amp;  className &amp; " " &amp; " form created by "&amp; modifiedBy &amp; SameViewMaintConstant &amp; StrCheckConstant;
									errorDetailsAll := errorDetailsAll &amp; CrLf &amp; errorDetails;
							endif;
						endif;
					else
						app.writeLog(className &amp; " in " &amp; schemaName &amp; NoCreateMethod, LogINFO);
						errorDetails := schemaName &amp; "::" &amp;  className &amp; " created by " &amp; modifiedBy &amp; NoCreateMethod &amp; AddCreateMethod;
						errorDetailsAll := errorDetailsAll &amp; CrLf &amp; errorDetails;
						_userSummaryDict.addAssoc(modifiedBy, errorDetails);
						continue;
					endif;
					if hasViewPermission then
						//app.writeLog(className &amp; " in " &amp; schemaName &amp; HasViewPermission, LogINFO);
					else
						app.writeLog(className &amp; " in " &amp; schemaName &amp; NoViewPermission, LogINFO);
						errorDetails := schemaName &amp; "::" &amp;  className &amp; " created by " &amp; modifiedBy &amp; NoViewPermission &amp; StrAddPermission;
						errorDetailsAll := errorDetailsAll &amp; CrLf &amp; errorDetails;
					endif;
					if hasMaintPermission then
						//app.writeLog(className &amp; " in " &amp; schemaName &amp; HasMaintPermission, LogINFO);
					else
						app.writeLog(className &amp; " in " &amp; schemaName &amp; NoMaintPermission, LogINFO);
						errorDetails := schemaName &amp; "::" &amp;  className &amp; " created by " &amp; modifiedBy &amp; NoMaintPermission &amp; StrAddPermission;
						errorDetailsAll := errorDetailsAll &amp; CrLf &amp; errorDetails;
					endif;
				endif;
				if errorDetails &lt;&gt; null then
					errorDetails := ErrHeading &amp; CrLf &amp; errorDetails &amp; CrLf &amp; CrLf &amp; DocLink;
					_userSummaryDict.addAssoc(modifiedBy, errorDetails);
					errorDetails := null;
				endif;
			endif;
		endforeach;
	if errorDetailsAll &lt;&gt; null then
		errorDetails := method.qualifiedName() &amp; CrLf &amp; ErrHeading &amp; CrLf &amp; errorDetailsAll &amp; CrLf &amp; CrLf &amp; DocLink;
		errorDetailsAll := errorDetails;
		//write errorDetailsAll;
	endif;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
		
	errorDetails := null;
	if _userSummaryDict.first = null then
		result := "PASS";
	else
		_userSummaryDict.addAssoc(app.getUTAdminUserCode(), errorDetailsAll);
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	result := result.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, errorDetailsAll, methStartTS, app.myUMTestRunONight, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
epilog
	delete methDict;
	delete schemasToCheckArray;
	delete permAgent;
	delete classSet;
	delete classesToIgnore;
end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vUTSetTerminalConfig" id="78069c10-c47d-4481-a421-88e49f9adcf5">
        <updating/>
        <source>vUTSetTerminalConfig(_unitTestRun : UM_UnitTestRun io; _userSummaryDict : CM_AssociationDict io) updating;

/*

Purpose:		Set any terminal config's that need to be set to run		

Date			Who		Reason
09/09/2015		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	terminal					: CM_Terminal;
	finIOClass 					: CM_ExtFinanceIO;
	defaultFinIOClass			: CM_ExtFinanceIO;
	unitTestResult 				: UM_UnitTestResult;
	
	methStartTS					: TimeStamp;
	methEndTS					: TimeStamp;
	elapsedTime 				: TimeStampInterval;
	resultStr					: String;
	errorTxt					: String;
	
begin

	methStartTS := app.cnGetServerTime();
	
	self.setActiveProfileMDHONLY();

	foreach terminal in app.myRoot.allTerminals discreteLock do
	
		finIOClass := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIOClass = null then
			beginTransaction;
			self.opts.purge();
			self.opts.addAssoc("Terminal", terminal.code);
			defaultFinIOClass := self.getInvoiceFinancialClass();
			terminal.setConfig("FinancialIOClass", defaultFinIOClass);
			app.writeLog("Updating FinancialIOClass in terminal (" &amp; terminal.code &amp; " " &amp; terminal.name &amp; 
				") to default Master Terminal Default", LogINFO);
			commitTransaction;
		endif;
	
	endforeach;

	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// did it pass or fail
	if errorTxt &lt;&gt; null then
		resultStr := "Fail ";
		errorTxt := CrLf &amp; "The Following Financial Class details for terminal (" &amp; terminal.code &amp; " - " &amp; terminal.name &amp; ") are null. " &amp;
			"They have been set to their default: " &amp; CrLf &amp; errorTxt;
	
		// create the email to send to the Admins
		_userSummaryDict.addAssociation(app.getUTAdminUserCode(), resultStr &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
			" ADMIN  " &amp; (elapsedTime.getMilliseconds/1000).String &amp; " secs " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; errorTxt);
			
	else	
		resultStr := "Pass ";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, errorTxt, methStartTS, _unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
epilog

end;</source>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vUTSubTerminalSetCashNotEnable" id="1d36bcfa-41ee-4045-82a6-e3ea0709545c">
        <updating/>
        <source>vUTSubTerminalSetCashNotEnable(_unitTestRun : UM_UnitTestRun io; _userSummaryDict : CM_AssociationDict io) updating;

/*
Purpose:		Check that unit test terminal that is Sub-Terminals enabled and not null
				Define Sub-Terminal area that has valid sub terminals set
				Check that Cash Enabled isn't set

Date			Who		Reason
11/05/2015		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	terminal				: CM_Terminal;
	depot					: CM_SubTerminal;
	warehouse				: CM_SubTerminal;
	unitTestResult 			: UM_UnitTestResult;

	
	subTEnabled				: Boolean;
	defSubTArea				: Boolean;
	errorTxt				: String;
	methStartTS				: TimeStamp;
	methEndTS				: TimeStamp;
	elapsedTime 			: TimeStampInterval;
	resultStr				: String;

begin

	methStartTS := app.cnGetServerTime();
	
	self.setActiveProfileMDHONLY();

	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	depot := app.myRoot.allSubTerminals["UT_Depot"];
	self.assertNotNull(depot);
	
	warehouse := app.myRoot.allSubTerminals["UT_Warehouse"];
	self.assertNotNull(warehouse);
	
	subTEnabled := terminal.getConfig(IsSubTerminalsOn).Boolean;
	defSubTArea :=  terminal.getConfig(IsSubTerminalAreaDefined).Boolean;
		
	beginTransaction;
	
	// if Define Sub-Terminal Area is set then don't need to do anything
	if defSubTArea then
		// 08/04/2016 cnwmh5 - Default will always be off
		terminal.setConfig(IsSubTerminalAreaDefined, false);
		//return;
	endif;
		
	if terminal.getConfig(MySubTerminalForExportFull).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForExportFull has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForExportFull, depot);
	endif;
	if terminal.getConfig(MySubTerminalForExportMTY).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForExportMTY has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForExportMTY, depot);
	endif;
	if terminal.getConfig(MySubTerminalForImportFull).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForImportFull has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForImportFull, depot);
	endif;
	if terminal.getConfig(MySubTerminalForImportMTY).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForImportMTY has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForImportMTY, depot);
	endif;
	if terminal.getConfig(MySubTerminalForStorageFull).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForStorageFull has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForStorageFull, depot);
	endif;
	if terminal.getConfig(MySubTerminalForStorageMTY).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForStorageMTY has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForStorageMTY, depot);
	endif;
	if terminal.getConfig(MySubTerminalForImportGen).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForImportGen has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForImportGen, depot);
	endif;
	if terminal.getConfig(MySubTerminalForExportGen).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForExportGen has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForExportGen, depot);
	endif;
	if terminal.getConfig(MySubTerminalForStorageGen).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForStorageGen has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForStorageGen, depot);
	endif;
	if terminal.getConfig(MySubTerminalForOther).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForOther has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForOther, depot);
	endif;
	if terminal.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForSourceBulkRoad has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForSourceBulkRoad, depot);
	endif;
	if terminal.getConfig(MySubTerminalForSourceBulkRail).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForSourceBulkRail has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForSourceBulkRail, depot);
	endif;
	if terminal.getConfig(MySubTerminalForSourceBulkShip).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForSourceBulkShip has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForSourceBulkShip, depot);
	endif;
	if terminal.getConfig(MySubTerminalForSourceBulkPack).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForSourceBulkPack has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForSourceBulkPack, depot);
	endif;
	if terminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal &lt;&gt; warehouse then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForTargetBulk has been set to " &amp; warehouse.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForTargetBulk, warehouse);
	endif;
	if terminal.getConfig(MySubTerminalForBOLIn).CM_SubTerminal &lt;&gt; depot then
		errorTxt := errorTxt.trimBlanks() &amp; "MySubTerminalForBOLIn has been set to " &amp; depot.code &amp; CrLf;
		terminal.setConfig(MySubTerminalForBOLIn, depot);
	endif;
		
	// 15/07/2015 cnwmh5
	terminal.setConfig(CashProcessingEnabled, false);
	
	commitTransaction;
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	// did it pass or fail
	if errorTxt &lt;&gt; null then
		resultStr := "Fail ";
		errorTxt := CrLf &amp; "The Following Sub Terminal details for terminal (" &amp; terminal.code &amp; " - " &amp; terminal.name &amp; ") are null. " &amp;
			"They have been set to their default: " &amp; CrLf &amp; errorTxt;
	
		// create the email to send to the Admins
		_userSummaryDict.addAssociation(app.getUTAdminUserCode(), resultStr &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
			" ADMIN  " &amp; (elapsedTime.getMilliseconds/1000).String &amp; " secs " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; errorTxt);
			
	else	
		resultStr := "Pass ";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, errorTxt, methStartTS, _unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
		
	
epilog

end;</source>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vUnitTestStatForLastMonth" id="7f25787c-e3b5-4efe-a348-0a6bf29d0a08">
        <source>vUnitTestStatForLastMonth();
/*

Purpose:			To send Unit Test Stats to Accounts every month

Date		Who		Reason
01 August 2016	cnwmk3	Initial creation
17 Oct 2025	navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/
constants
	ToUser						= "nbach@jadeworld.com";
vars
	file						: File;
	subject						: String;
	message						: String;
	mailer						: CM_ObjectEmail;
	testController				: JMTTestController;
	startTS						: TimeStamp;
	today						: TimeStamp;
	emailSent					: Boolean;
	unitTestRun					: UM_UnitTestRun;
	unitTestResult				: UM_UnitTestResult;
	methStartTS					: TimeStamp;
	methEndTS					: TimeStamp;
	elapsedTime					: TimeStampInterval;
	resultStr					: String;
	detailsToOutput				: String;
	endTS						: TimeStamp;
	root						: UM_Root;
	classMethod					: UM_UnitTestClassMethod;
	testResult					: UM_UnitTestResult;
	runAlready					: Boolean;
begin
	today := app.actualTimeServer();
	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	classMethod := root.allRunnableUTClassesMethods["UT_Verification_Admin", "vUnitTestStatForLastMonth"];
	if classMethod = null then
		return;
	endif;
	testResult := classMethod.allUnitTestResults.first;
	if testResult.myTestRun.endTS.date.month = today.date.month then
		return;
	endif;
	
	today.date.cnEcSetBeginningOfMonth();   
	today := today.addMonths(-1);
	startTS.setDate(today.date);
		
	//	extract Test Stat file
	self.outputForAccts();
	create file transient;
	file.fileName := "C:\Temp\Unit_Test_Details_" &amp; startTS.date().monthName().asStringJMT() &amp; ".csv";
	self.assertNotNull(file);
		
	//	write an email
	subject := "Monthly Unit Test Stat";
	message := "Hi,
	  
Please find the attached Unit Test Stats for " &amp; startTS.date().monthName().asStringJMT() &amp; " " &amp; startTS.date.year.asStringJMT() &amp; " with this email.
		 
Thanks,
JMT Testing
Email : jmttesting@jadeworld.com
		";
		
	// attach the file to email and send the email
	emailSent := self.sendEmail(ToUser, message, subject, file);
		
	// send an email to test team about the success/failure
	if emailSent = true then
		app.writeLog(file.fileName &amp; Tab &amp; file.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp;
			file.creationTime.time.String, LogINFO);
		resultStr := "PASS";	
	else
		resultStr := "FAIL";
	endif;
		
	// create a unit test record
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	unitTestRun := root.allUnitTestRuns.last.UM_UnitTestRun;
		
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", "CNWMK3", resultStr, detailsToOutput, methStartTS, unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
epilog
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="vUpdateLicense" id="41da950c-1ea3-4ba1-bb51-b6e4699764c4">
        <source>vUpdateLicense(_unitTestRun : UM_UnitTestRun io; _userSummaryDict : CM_AssociationDict io);
/*

Purpose:		

Date			Who		Reason
29 June 2015	cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

constants

	ClientName						: String = "clientName=";
	
vars

	inputFile						: File;
	unitTestResult					: UM_UnitTestResult;

	args							: StringArray;
	
	result							: Integer;
	line							: String;
	count							: Integer;
	licenseName						: String;
	licenseKey						: String;
	pos								: Integer;
	productCode						: String;
	clientName						: String;
	resultStr						: String;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;

begin

	methStartTS := app.cnGetServerTime();

	clientName := "JADE Master Terminal";
	
	create args transient;	

	args.clear();
	args.add('appServer=jade1.navdmast.nav.cnw.co.nz');
	args.add('appServerPort=50667');
	args.add('app=DevGetClientLicenseKeys');
	args.add('schema=DevSchema');
	args.add('ini="C:\DevelopmentEnvs\navdmast\navdmast.ini"');
	args.add('endJade');
	args.add(ClientName &amp; clientName);
	
	node.createExternalProcess("C:\DevelopmentEnvs\navdmast\c_bin", '"C:\DevelopmentEnvs\navdmast\c_bin\jade.exe"', args, null, true, true, result);
	self.assertEqual(result, 0);
	
	create inputFile transient;
	inputFile.usePresentationFileSystem := true;
	inputFile.fileName := app.getTempDir() &amp; "getClientLicenseKeys.txt";
	inputFile.kind := File.Kind_Unknown_Text;
	
	productCode := ProductCode_JMT;
	while not inputFile.endOfFile do
		line := inputFile.readLine();
		pos := 1;
		licenseName := line.scanUntil(":", pos);
		licenseKey := line[pos+1:end];
		app.myTrxUA.trxUpdateLicense(CM_Root.firstInstance, licenseName, licenseKey, productCode, CM_Root.firstInstance.edition, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		if productCode = ProductCode_JMT then
			productCode := ProductCode_JMT_EDI;
		else
			break;
		endif;
	endwhile;
	inputFile.close();
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	resultStr := "PASS";
	if app.myPassport.hasErrors() then
		resultStr := "FAIL";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, app.myPassport.getAllErrorsAndWarnsFullAsStr(), methStartTS, _unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	

epilog

	delete args;
	delete inputFile;

end;
</source>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xAddPatchesToReleasePS" id="617c9bf5-18d4-4699-8ac2-a53c731c4e72">
        <source>xAddPatchesToReleasePS(_psFile : File);

/*

Purpose:		Create the ps file to add patches to the current release	

Date			Who		Reason
05/09/2017		jlgmd1	Initial creation

*/

constants

	ReleaseDirectory				: String = "F:\Releases\";		//\\cnwchcm24\cnwpod$
	HotfixDirectory					: String = "\Hotfixes-pending";

vars

	source							: String;
	version							: String;

begin

	// get the version
	version := CM_Version.VERSION;
	version := version.replaceString(".", "");

	source := 'Clear-Host
	
#****************************************************************************************************************
# Change History
# ==============
# 08/08/2017 jlgmd1 Initial Creation
# 21/08/2017 jlgmd1 Patches can now be applied in any order (Not that you would really want to)
#                   or can be done individually (A little more useful)
# 05/09/2017 jlgmd1 Fixed source locations not changing correctly when JMT major version is changed
#
#****************************************************************************************************************

#JMT Versions
$NumberOfReleasesToGet = 3 #+1, so technically 4
$versionNumber = "' &amp; version &amp; '"
$SelectedRelease = $versionNumber+"000"

#Directories
$releaseDirectoryBase = "' &amp; ReleaseDirectory &amp; '"
$releaseDirectory =  $releaseDirectoryBase + $versionNumber
$patchDirectory = $releaseDirectory + "' &amp; HotfixDirectory &amp; '"

#Global arrays
$patchesToBeApplied = @()
$patchesAlreadyApplied = @()
$selectedPatches = @()

#Other global variables
$SelectedRelease = "" #Which release are we looking at
[int]$highestPatchNumber = 200 #Start at 210
$miscFilesToIgnore = @("misc\live_app_upgrade.bat")
[int]$highestPatchAdded = 0 #Keep track of the *last* patch added to this release

#Load Assemblies
[System.Reflection.Assembly]::LoadWithPartialName("System.Windows.Forms") &gt;$null
[System.Reflection.Assembly]::LoadWithPartialName("System.Drawing") &gt;$null

#Groupboxes
$GrpReleaseDirectories = New-Object System.Windows.Forms.GroupBox
$GrpPatches = New-Object System.Windows.Forms.GroupBox
$GrpLog = New-Object System.Windows.Forms.GroupBox

#Labels
$LblReleaseNum = New-Object System.Windows.Forms.Label
$LblPatchLoc = New-Object System.Windows.Forms.Label
$LblReleaseLoc = New-Object System.Windows.Forms.Label
$LblPatchAdd = New-Object System.Windows.Forms.Label
$LblPatchApplied = New-Object System.Windows.Forms.Label

#TextBox
$TxtPatchLoc = New-Object System.Windows.Forms.TextBox
$TxtReleaseLoc = New-Object System.Windows.Forms.TextBox

#MultilineTextBox
$MTxtLog = New-Object System.Windows.Forms.TextBox

#ListBox
$LstbxPatchesToAdd = New-Object System.Windows.Forms.Listbox
$LstbxPatchesAlreadyAdded = New-Object System.Windows.Forms.Listbox

#Buttons
$BtnGo = New-Object System.Windows.Forms.Button

#Combobox
$CbxVersion = New-Object System.Windows.Forms.ComboBox


#Create GroupBoxes
function CreateGroupBox($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentText, $ComponentParent) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    $ComponentObject.Text = $ComponentText
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateLabel($ComponentObject, $LocX, $LocY, $ComponentText, $ComponentParent) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size(100, 15)
    $ComponentObject.Autosize = $true
    $ComponentObject.Text = $ComponentText
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateTextBox($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentText, $ComponentParent) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    $ComponentObject.Text = $ComponentText
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateButton($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentText, $ComponentParent, $ComponentAction) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    $ComponentObject.Text = $ComponentText
    $ComponentObject.Add_Click($ComponentAction)
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateComboBox($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentParent, $ComponentItems, $ComponentAction) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    foreach ($item in $ComponentItems) {
        $ComponentObject.Items.Add($item)
    }
    $ComponentObject.SelectedIndex = 0
    $componentObject.Add_SelectedValueChanged($ComponentAction)
    $componentObject.DropDownStyle = [System.Windows.Forms.ComboBoxStyle]::DropDownList
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateMultilineTextBox($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentText, $ReadOnly, $ComponentParent) {
	$ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
	$ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
	$ComponentObject.Multiline = $True;
	$ComponentObject.ScrollBars = [System.Windows.Forms.ScrollBars]::Vertical
	$ComponentObject.WordWrap = $True;
	$ComponentObject.Text = $ComponentText
	if ($ReadOnly -eq $True) {
		$ComponentObject.ReadOnly = $True
	}
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateListBox($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentParent, $ComponentAction) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
	$ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    $ComponentObject.SelectionMode = [System.Windows.Forms.SelectionMode]::MultiExtended
    #$ComponentObject.Add_Click($ComponentAction)
    $ComponentObject.Add_SelectedIndexChanged($ComponentAction)
    $ComponentParent.Controls.Add($ComponentObject)
}

#Define Form Functions
function GetLast4Releases() {
    #Get Release Directories
    $releaseDirectories = @()
    $releaseDirectories = Get-ChildItem -Directory -Path $releaseDirectoryBase | Sort-Object FullName -Descending
    
    $releaseCount = 0
    $releases = @()
    
    #$releases = New-Object System.Collections.Generic.List[System.Object]
    $Last4Releases = @()

    foreach ($directory in $releaseDirectories) {

        [string]$directoryName = $directory.FullName
        [string]$tempVerionsNumber = $directoryName.Substring($directoryName.Length-$versionNumber.Length, $versionNumber.Length)
       
        if (($releaseCount -eq 0 ) -and ($versionNumber -ne $tempVerionsNumber)) {
            continue
        }
        
        #Test to see if monthly direcotry exists
        $releaseDirectory = $releaseDirectoryBase + $tempVerionsNumber
        if (Test-Path $releaseDirectory"\Monthly")
        {
            $releaseDirectory = $releaseDirectory + "\Monthly"
            $releases = Get-ChildItem -Directory -Path $releaseDirectory | Sort-Object FullName -Descending 
        } else {
            #empty so just add
            $Last4Releases += ($tempVerionsNumber + "000")
            $releaseCount = $Last4Releases.Count
        }

        #Monthly exists so get from there
        foreach ($release in $releases) {

            $directoryPath = $release.FullName
			
			# 04/05/2017 cnwmh5 Fix issue with Interim cut directories not being required
            if ($directoryPath.Contains("Interim")) {
                continue;
            }
            $releaseNumber = $directoryPath.Substring($directoryPath.Length - 3, 3)
            
			#If this is the first release we have found, then just add it.
			#Otherwise, only add the release if we have not superseded it. (ie, we only want 851081, not 851080)
            if (($releaseCount -eq 0) -or (($releaseCount -ge 1) -and 
                    ($Last4Releases[$releaseCount - 1].ToString().Substring(3,2) -ne $releaseNumber.Substring(0,2)))) {
                $Last4Releases += $tempVerionsNumber + $releaseNumber
                $releaseCount = $Last4Releases.Count
            }

            # found the last 4 so time to get out
            $releaseCount = $Last4Releases.Count
            if ($releaseCount -gt $NumberOfReleasesToGet) {
                break
            }
        }
    
        # found the last 4 so time to get out
        $releaseCount = $Last4Releases.Count
        if ($releaseCount -gt $NumberOfReleasesToGet) {
            break
        }

    }
	
	#If we have not found as many releases as we can, then add the base release back in
	if ($releaseCount -ne $NumberOfReleasesToGet) {
		$Last4Releases += ($tempVerionsNumber + "000")
        $releaseCount = $Last4Releases.Count
	}
    
    return $Last4Releases

}

function SourceReleaseChanged($ComponentObject, $recheck = $false) {
    #Bail if there is nothing to check
    if ($ComponentObject.Text -Eq [string]::Empty) { return }

    #Clear out any current data we might have
    $Script:patchesToBeApplied = @()
    $Script:patchesAlreadyApplied = @()
    if (($MTxtLog.Text.Length -Gt 0) -And ($recheck -Eq $false)) {
        WriteToLog "&gt;&gt;&gt;&gt; Cleared &lt;&lt;&lt;&lt;" $true
    }

	$script:SelectedRelease = $ComponentObject.Text
	#There is an assumption that the release is always 6 digits, split into 2 lots of 3 (major/minor)
	$first3Characters = $ComponentObject.Text.SubString(0,3)
	$last3Characters = $ComponentObject.Text.SubString(3,3)
	
	if ($last3Characters -eq "000") {
		$releaseDirectory = $releaseDirectoryBase + $first3Characters 
	} else {
		$releaseDirectory = $releaseDirectoryBase + $first3Characters + "\Monthly\" + $SelectedRelease
	}
	
	$TxtPatchLoc.Text = $releaseDirectoryBase + $first3Characters  + "\Hotfixes-pending"
	$TxtReleaseLoc.Text = $releaseDirectory

	#Tell the user what we are doing as this takes a second or 2
    WriteToLog "Calculating relevant patches..."
	#WriteToLog "    * indicates the patch may have already been applied, or is part of the base release"
	
    if (!(Test-Path $TxtPatchLoc.Text)) {
        WriteToLog "Error: Unable to find Patch Directory"
        return
    }
	
	GetPatchesToAdd
	$ret = GetPatchesAlreadyAdded

    if (!($ret)) {
		WriteToLog "Done."
        return
    }

    $Script:patchesAlreadyApplied = $LstbxPatchesAlreadyAdded.Items
    $Script:patchesToBeApplied = $LstbxPatchesToAdd.Items
    
    #In lieu of disabling a patch entry in the listbox (requires creating a custom control), lets just remove any intersecting patches
    $patchesToRemove = @()
    foreach ($patch in $patchesToBeApplied) {
        if ($patchesAlreadyApplied.Contains($patch)) {
            $patchesToRemove += $patch
        }
    }
    foreach ($patch in $patchesToRemove) {
        $LstbxPatchesToAdd.Items.Remove($patch)
    }

    #Just in case the lists have just been update, lets reassign our tracking variables
    $Script:patchesToBeApplied = $LstbxPatchesToAdd.Items
    $Script:patchesAlreadyApplied = $LstbxPatchesAlreadyAdded.Items

    Write-Host $patchesToBeApplied.Count
    Write-Host $patchesAlreadyApplied.Count

    if ($Script:patchesToBeApplied.Count -Gt 0) {
        WriteToLog "Ready to Apply Patches."
    } else {
        if ($patchesAlreadyApplied.Count -gt 0) {
            WriteToLog "All Patches have been applied. Nothing to do."
            $BtnGo.Enabled = $false

            #And finally, if we think the patch has been applied, but has no base tag, then lets apply one.
            Foreach ($patch in $patchesAlreadyApplied) {
                $path = $patchDirectory + "\" + $patch
                $newName = $patch + "_Base" + $SelectedRelease.Substring(3,3)
                if (Test-Path $path) {
                    Try {
                        Rename-Item -Path "$path" -NewName "$newName" -ErrorAction Stop
                    } Catch {
                        WriteToLog ("    Unable to rename $patch to $newName. This should be done manually.")
                    }
                }
            }
        } else {
            WriteToLog "No Patches found."
        }
    }
        
}

function GetPatchesToAdd() {
	#Reset the patch textbox
    $LstBxPatchesToAdd.Items.Clear()

	$patchFolders = @()
    $patchFolders = Get-ChildItem -Directory -Path $TxtPatchLoc.Text | Sort-Object FullName -Descending
    $base = $SelectedRelease.Substring(3,3)

	foreach ($directory in $patchFolders) {
		#Ignore any patches that are not to be included in any patching
        if (($directory.FullName.ToLower().Contains("_do")) -Or ($directory.FullName.ToLower().Contains("_not"))) {
            continue
        }
		
		#Ignore any patches that not from our base
		$name = $directory.Name
		if ($directory.FullName.Contains("_Base")) {
            #But do a recheck on ones which we may have already included
            #if (!($directory.FullName.Contains("_Base$base"))) {
                continue
            #}
			$name = "*$name"
		}
		
		Write-Host $name
		$LstBxPatchesToAdd.items.Add($name.Replace("_Base$base", ""))
	}
}

function GetPatchesAlreadyAdded() {
	#Reset the patch textbox
	$LstBxPatchesAlreadyAdded.Items.Clear()
	
    $Patches = @()
    $PatchesWithSchemaFiles = @()
	$PatchesWithSchemaFiles = CheckForSchemaPatchesApplied

    if ($PatchesWithSchemaFiles -Eq $false) { return $false }
    
    $PatchesWithBinFiles = @()
    $BinPatchesNotApplied = @()
    CheckForBinPatchesApplied ([ref]$PatchesWithBinFiles) ([ref]$BinPatchesNotApplied)

    $PatchesWithBinFiles | % {
        #Only add the patch to the list if it was successfull
        if (!($BinPatchesNotApplied.Contains($_))) {
            $Patches += $_
        }
    }

    $PatchesWithSchemaFiles | % {
        #Only add the patch to the list if it has not got any bin files not fully applied
        if (!($BinPatchesNotApplied.Contains($_))) {
            #Aonly add the patch to the list if we havent seen it before
            if (!($Patches.Contains($_))) {
                $Patches += $_
            }
        }
    }
    
    #If there are no patches at all, then there is nothing for us to do, so bail
    if (!($Patches.Count -Gt 0)) { return }
    
    #Lets make our order the same as the patches to add
    [array]$Patches = $Patches | Sort-Object -Descending
	Foreach ($patch in $Patches) {
        $LstBxPatchesAlreadyAdded.Items.Add($patch)
    }
    $script:highestPatchAdded = ($Patches[0].split("_"))[0]

    return $true
}

function CheckForSchemaPatchesApplied() {
    #First Check the JMTInstall.txt file for the unencrypted version
	$unEncPatches = @()
	$jmtfileloc = $TxtReleaseLoc.Text + "\JadeMaster\JMTInstall.txt"
	CheckJMTFileForPatches([ref]$unEncPatches) $jmtfileloc
	
	#Second Check the JMTInstall.txt file for the encrypted version
	$encPatches = @()
	$version = $CbxVersion.Text
	$jmtfileloc = $TxtReleaseLoc.Text + "\JMT$version\JMTInstall.txt"
	CheckJMTFileForPatches([ref]$encPatches) $jmtfileloc
	
	#Make sure that the schema patches have been applied to both versions
	if (Compare-Object -ReferenceObject $unEncPatches -DifferenceObject $encPatches) {
		#TODO: Throw warning to user that something is very wrong and automatically applying the patches is not possible
		Write-Host $unEncPatches
		Write-Host $encPatches
        WriteToLog "ERROR! Patches dont match between encrypted/non-encrypted releases. Please check JMTInstall files."
		return $false
	} else {
		#Both are the same, so lets just pick one
		$patches = $encPatches
	}	
    return $patches
}

function CheckJMTFileForPatches([ref]$patches, $jmtfileloc) {
		
	if ( !(Test-Path $jmtfileloc -PathType leaf)) {
		WriteToLog "Error: Unable to read $jmtfileloc"
		return
	}
	$inPatches = $False
	Get-Content $jmtfileloc | % {

        #Skip blank lines outright
        if ($_ -eq [string]::Empty) { return }

		#Only care about lines between *REM::Patches Start HERE* and *REM::Patches Finish HERE*
		if ($_.contains("Patches Start HERE")) {
			$inPatches = $True
			return #This is actually *continue* in the foreach-object loop!
		}
		if ($_.contains("Patches Finish HERE")) {
			$inPatches = $False
			return
		}
		
		if ($inPatches -eq $True) {
			#This contains the renumbered schemas, so we need to *un-renumber* them ;)
			#Split by ::
			$textArr = @()
			$textArr = $_.split(":")
			#Get the Schema name
			$schemaName = $textArr[2]
			$textArr = $schemaName.split("_")
			$patchName = $textArr[2] + "_Par" + $textArr[3]
            #Keep track of the highest schema patch number
            $Script:highestPatchNumber = $schemaName.Substring(0,3)
			
			#Only add this patch if we dont already know about it
			if ( -Not ($patches.value.contains($patchName))) {
				$patches.value += $patchName
			}
		}
	}
}

function CheckForBinPatchesApplied([ref]$patchesApplied, [ref]$patchesNotApplied) {
    $patchFolders = @()
    $patchFolders = Get-ChildItem -Directory -Path $TxtPatchLoc.Text | Sort-Object FullName
    $mismatchedFiles = New-Object System.Collections.ArrayList #Maintain a list of bin files that dont match whats in the patch folder vs whats in the release folder

    $patchesWithBinFiles = @()

    foreach ($directory in $patchFolders) {
        #Ignore any patches which were prior to this base
        $base = $SelectedRelease.Substring(3,3)
        if (($directory.FullName.Contains("_Base")) -And (!($directory.FullName.Contains("_Base$base")))) {
            continue
        }
        #Also ignore patches that are not to be deployed
        if (($directory.FullName.ToLower().Contains("_do")) -Or ($directory.FullName.ToLower().Contains("_not"))) {
            continue
        }

        $hasBinFiles = $false
        #Check all patch folders for any binary files
        #Do a Get-FileHash compare against the release directory
        #Keep in mind, that binary patches will superseed each other, so
        #its not a big deal if a previous patch is overwritten by a newer one.
        if (Test-Path ($directory.FullName+"\JadeMaster\misc")) {
            $hasBinFiles = CompareFiles ($directory.FullName + "\JadeMaster") "misc" $false ([ref]$mismatchedFiles)
        }
        if (Test-Path ($directory.FullName+"\JadeMaster\bin")) {
            $hasBinFiles = CompareFiles ($directory.FullName + "\JadeMaster") "bin" $false ([ref]$mismatchedFiles)
        }

        $patchNum = $directory.Name.split("_")[0]
        if (Test-Path ($directory.FullName+"\$patchNum\misc\*")) {
            $hasBinFiles = CompareFiles ($directory.FullName + "\$patchNum") "misc" $true ([ref]$mismatchedFiles)
        }
        if (Test-Path ($directory.FullName+"\$patchNum\bin")) {
            $hasBinFiles = CompareFiles ($directory.FullName + "\$patchNum") "bin" $true ([ref]$mismatchedFiles)
        }

        if ($hasBinFiles -Eq $true) {
            $patchesWithBinFiles += $directory.Name.Replace("_Base$base", "")
        }

    }

    #Return two lists: 1 of patches with binary files that have been successfully applied, and another with a list of ones not applied and have mismatched files
    if ($mismatchedFiles.Count -Ne 0) {
        $mismatchedPatches = @()
        foreach ($file in $mismatchedFiles) {
            #Work out which patch this is from
            #D:\PatchTesting\851\Hotfixes-pending\090_Par4644\JadeMaster\misc\htdocs\JMT\scripts\api.js
            [string]$patch = $file.Replace("$patchDirectory\", "")
            $patch = $patch.substring(0, $patch.IndexOf("\"))

            if (!($mismatchedPatches.Contains($patch))) {
                $mismatchedPatches += $patch
            }
        }

        $patchesNotApplied.Value = $mismatchedPatches
        $patchesApplied.Value = $patchesWithBinFiles

    } else {
        $patchesApplied.Value = $patchesWithBinFiles
    }
}

function CompareFiles($patchFolder, $resFolder, $Encrypted, [ref]$mismatchedFiles) {
    #Go through all files in the given patch folder
    $patch = "$patchFolder\$resFolder"

    #If we actually check anything, then return true, otherwise return false
    $hasBinFiles = $false

    Get-ChildItem -File -Recurse -Path $patch | % {
        #(has misc)
        #D:\PatchTesting\851\Monthly\851090\JARI_JMT851090\ansi\x64-msoft-win64\server
        #(does not have misc)
        #D:\PatchTesting\851\Monthly\851090\JadeMaster
        #D:\PatchTesting\851\Monthly\851090\JMT851090
        $file = $_.FullName.Replace($patch, "").Substring(1) 
        $file = "$resFolder\" + $file
    
        #Ignore files that we dont care about
        if ($script:miscFilesToIgnore.Contains($file) -Eq $true) { return }
        
        $hasBinFiles = $true
        $h1 = Get-FileHash $_.FullName


        #If we are comparing htdocs, then we need to do something special
        $isInHtdocs = $false
        if ($file.Contains("\htdocs\")) {
            #Workaround for htdocs not being in a useful location in the patch folder structure
            $file = $file.Replace("misc\htdocs\", "web\")
            $isInHtdocs = $true
        }

        if (!($Encrypted)) {
            #1. Check the JadeMaster folder
            $newPath = $releaseDirectory + "\JadeMaster\" + $file
            $pathsToCheck = @($newPath.Replace("\JadeMaster\misc\", "\JadeMaster\"))
        } else {
            #2. Check the JMT folder
            #3. Check the JARI folder
            $newPath = $releaseDirectory + "\JMT$SelectedRelease\" + $file
            $pathsToCheck = @($newPath.Replace("\JMT$SelectedRelease\misc\", "\JMT$SelectedRelease\"))

            if ($isInHtdocs -Eq $true) {
                $newPath = $releaseDirectory + "\JARI_JMT$SelectedRelease\jmt_htdocs\" + $file
                $pathsToCheck += $newPath.Replace("\jmt_htdocs\web\", "\jmt_htdocs\")
            } else {
                 $pathsToCheck += ($releaseDirectory + "\JARI_JMT$SelectedRelease\ansi\x64-msoft-win64\server\" + $file)
                 $pathsToCheck += ($releaseDirectory + "\JARI_JMT$SelectedRelease\unicode\x64-msoft-win64\server\" + $file)
            }
        }


        foreach ($path in $pathsToCheck) {
            if (Test-Path $path) {
                    $h2 = Get-FileHash $path
            } else {
                    #While technically not a *mismatched* file, we still want to report this patch has being in error
                    if (!($mismatchedFiles.Value.Contains($patch))) {
                        #Add to our list of mismatched files if we dont already know about it
                        $mismatchedFiles.Value.Add($patch) &gt;$null
                    }

                    #File does not exist in release directory at all, so chances are the patch was not applied
                    $path = $path.Replace($releaseDirectory,  "")
                    $path = $path.Split("\")[1]

                    $patchNum = $patch.Replace($TxtPatchLoc.Text+"\", "")
                    $patchNum = $patchNum.Substring(0, $patchNum.IndexOf("_"))

                    $str = "[$patchNum] $path" + ": $file Does not exist in the release directory!"
                    WriteToLog $str
                    continue
            }

            if ($h1.Hash -eq $h2.Hash) {
                #The files are the same
                if ($mismatchedFiles.Value.Contains($path)) {
                    $mismatchedFiles.Value.Remove($path) &gt;$null
                }
            } else {
                #The files are different
                if (!($mismatchedFiles.Value.Contains($path))) {
                    #Add to our list of mismatched files if we dont already know about it
                    $mismatchedFiles.Value.Add($path) &gt;$null
                }
            }
        }
    }

    return $hasBinFiles
}

function ApplyPatches() {

    #If the release or patch locations have been manually changed, then use them
    $releaseDirectory = $TxtReleaseLoc.Text
    $patchDirectory = $TxtPatchLoc.Text
    $base = $SelectedRelease.Substring(3, 3)
    $warningShown = $false
    #Apply the patches in reverse order to what we stored them as (ie, lowest patch first!)
    foreach ($patch in ($selectedPatches | Sort-Object)) {
        
        #Show a warning if we are trying to apply a patch out of order
        if ($highestPatchAdded -gt 0) {
            if ((($patch.split("_")[0]) -lt $highestPatchAdded) -and (!($warningShown))) {
                $MsgBox = New-Object -ComObject Wscript.Shell
                $ret = $MsgBox.Popup("$patch is lower than the highest currently applied patch ($highestPatchAdded). " +
                    "Are you sure you want to add this one ?", 0, "Are you sure ?", 0x4)
                if ($ret -ne 6) {
                    WriteToLog "Aborted."
                    return
                } else {
                    $warningShown = $true
                }
            }
        }

        WriteToLog "    Applying patch $patch..."
        
        if (Test-Path ("$patchDirectory\$patch" + "_Base$base")) {
            $patch = $patch + "_Base$base"
        }

        $path = $patchDirectory + "\$patch\JadeMaster\Schemas"
        $patchNum = ([string]$patch).split("_")[0]

    #1 Append the next available schema patch number (if there are any to add)

        #1.a Renumber the PortSchema first, if it exists
        $portSchema = Get-ChildItem -Path $path -Filter "PortSchema_$versionNumber*.scm"
        CopySchemaFiles $portSchema.FullName
        
        #1.b Renumber the rest of the files, if they exist
        Get-ChildItem -Path $path"\*" -Filter "*.scm" -Exclude "PortSchema*" | % {
            CopySchemaFiles $_.FullName
        }

    #2. Update the JMTInstall and 1A_Patches.mul files with the new patch files
        AddPatchToTxtFiles $patch

    #3. Copy any binary files to their correct locations
        $src = $patchDirectory + "\$patch"
        $destSource = $releaseDirectory + "\JadeMaster"
        $destEnc = $releaseDirectory + "\JMT$SelectedRelease"
        $destJARI = $releaseDirectory + "\JARI_JMT$SelectedRelease"

        #3.a Copy the BIN files
        if (Test-Path $src"\JadeMaster\bin\*") {
            Copy-Item $src"\JadeMaster\bin\*" -Destination $destSource"\bin" -Recurse -Force
        }
        if (Test-Path $src"\$patchNum\bin\*") {
            Copy-Item $src"\$patchNum\bin\*" -Destination $destEnc"\bin" -Recurse -Force
            Copy-Item $src"\$patchNum\bin\*" -Destination $destJARI"\ansi\x64-msoft-win64\server\bin" -Recurse -Force
            Copy-Item $src"\$patchNum\bin\*" -Destination $destJARI"\unicode\x64-msoft-win64\server\bin" -Recurse -Force
        }

        #3.b Copy the MISC files
        #As the *miscFilesToIgnore* array contains the folder *misc* at the beginning, we need to stip it to make this work
        $trueMiscFilesToIgnore = @()
        foreach ($file in $miscFilesToIgnore) {
            $trueMiscFilesToIgnore += $file.Replace("misc\", "")
        }

        if (Test-Path $src"\JadeMaster\misc\*" -Exclude $trueMiscFilesToIgnore) {
            Copy-Item $src"\JadeMaster\misc\*" -Destination $destSource -Exclude $trueMiscFilesToIgnore -Recurse -Force
        }
        if (Test-Path $src"\$patchNum\misc\*" -Exclude $trueMiscFilesToIgnore) {
            Copy-Item $src"\$patchNum\misc\*" -Destination $destEnc -Exclude $trueMiscFilesToIgnore -Recurse
            Copy-Item $src"\$patchNum\misc\*" -Destination $destJARI"\ansi\x64-msoft-win64\server\misc" -Exclude $trueMiscFilesToIgnore -Recurse -Force
            Copy-Item $src"\$patchNum\misc\*" -Destination $destJARI"\unicode\x64-msoft-win64\server\misc" -Exclude $trueMiscFilesToIgnore -Recurse -Force
        }

        #3.c Tidyup htdocs (workaround)
        #Due to the htdocs being located in a relatively weird place in the patch folder, we need to rearrange some things
        #Source
        if (Test-Path $destSource"\htdocs") {
            CopyFilesAndCreateFolders $destSource"\htdocs" $destSource"\web"
            Remove-Item -Path $destSource"\htdocs" -Recurse -Force
        }
        #JMT
        if (Test-Path $destEnc"\htdocs") {
            CopyFilesAndCreateFolders $destEnc"\htdocs" $destEnc"\web"
            Remove-Item -Path $destEnc"\htdocs" -Recurse -Force
        }
        #JARI
        if (Test-Path $destJARI"\ansi\x64-msoft-win64\server\misc\htdocs") {
            CopyFilesAndCreateFolders $destJARI"\ansi\x64-msoft-win64\server\misc\htdocs" $destJARI"\jmt_htdocs"
            Remove-Item -Path $destJARI"\ansi\x64-msoft-win64\server\misc\htdocs" -Recurse -Force
            Remove-Item -Path $destJARI"\unicode\x64-msoft-win64\server\misc\htdocs" -Recurse -Force
        }

    #4. The last thing to do is rename the folder (This does not always work)
        if (!($patch.Contains("_Base$base"))) {
            $path = "$patchDirectory\$patch"
            $newName = $patch + "_Base$base"
            Try {
                Rename-Item -Path "$path" -NewName "$newName" -ErrorAction Stop
            } Catch {
                WriteToLog ("    Unable to rename " + $patch.Name + " to $newName. This should be done manually.")
            }
        }
    }

    #Fix the order of the schemas if we have just applied one out of order
    if ($warningShown) {
        WriteToLog "    Fixing schema load order..."
        FixSchemaLoadOrder
    }

    WriteToLog "Done!"
    $BtnGo.Enabled = $false
    SourceReleaseChanged $CbxVersion $true
}

function CopyFilesAndCreateFolders($path, $dest) {
    Get-ChildItem -File $path -Recurse | % {
        $folder = $_.FullName.Replace($path, "").Replace($_.Name, "")
        New-Item "$dest\$folder" -ItemType directory -Force
        Move-Item -Path $_.FullName -Destination "$dest\$folder" -Force
    }
}

function CopySchemaFiles([string]$filePath) {
    # Cant move/copy an empty string
    if ($filePath -eq [string]::Empty) { return }

    if (Test-Path $filePath) {

        #Does this SCM have a DDB files too ?
        $hasDDB = Test-Path $filePath.Replace(".scm", ".ddb")          
        
        #Grab just the file name
        $fullFileName = $filePath.Substring($filePath.LastIndexOf("\") + 1)
        $file = $fullFileName.Substring(0, $fullFileName.Length - 4)
        #and just the extension too
        $extension = $fullFileName.Substring($fullFileName.Length - 4)

        if (Test-Path ($releaseDirectory + "\JadeMaster\Schemas\*$file*") -Filter "*.scm") {
            #If our files already exist, then dont bother copying over new ones, just overwrite the existing ones
            $newNameSCM = (Get-ChildItem ($releaseDirectory + "\JadeMaster\Schemas\*$file*") -Filter "*.scm").Name
            $newNameDDB = $newNameSCM.Replace(".scm", ".ddb")
        } else {
            #Work out what Par/TFS number we are dealing with
            $filePath -Match "par([0-9]+)"
            $par = $matches[1]

            #Increment the highest patch number
            $script:highestPatchNumber = $script:highestPatchNumber + 10

            $newNameSCM = [string]$script:highestPatchNumber + $file + "_$par" + $extension
            $newNameDDB = $newNameSCM.Replace(".scm", ".ddb")
        }
        
        #Source (JadeMaster)
        $releasePath = $releaseDirectory + "\JadeMaster\schemas\"
        Copy-Item $filePath ($releasePath + $newNameSCM)
        if ($hasDDB) {
            Copy-Item $filePath.Replace(".scm", ".ddb") ($releasePath + $newNameDDB)
        }

        #Encrypt (&lt;Patch Number&gt;)
        $scmPath = $filePath.Replace("\JadeMaster\Schemas", "\$patchNum\Schemas")
        #JMT
        $releasePath = $releaseDirectory + "\JMT$selectedRelease\schemas\"
        Copy-Item $scmPath ($releasePath + $newNameSCM)
        if ($hasDDB) {
            Copy-Item $scmPath.Replace(".scm", ".ddb") ($releasePath + $newNameDDB)
        }
        #JARI
        $releasePath = $releaseDirectory + "\JARI_JMT$selectedRelease\SchemaFiles\"
        Copy-Item $scmPath ($releasePath + $newNameSCM)
        if ($hasDDB) {
            Copy-Item $scmPath.Replace(".scm", ".ddb") ($releasePath + $newNameDDB)
        }

    }
}

function AddPatchToTxtFiles($patch) {
    #Work out what lines we need to copy to the master JMTInstall.txt file
    $jmtLinesToCopy = @()
    #Work out what lines we need to copy to the starter 1A_Patches.mul file
    $starterLinesToCopy = @()

    Get-Content $patchDirectory"\$patch\JadeMaster\JMTInstall.txt" | % {
        if (($_.contains("SCM::")) -or $_.contains("SCMDDB::")) {
            $fileNameSplit = $_.split(":")
            $filter = "*" + ($fileNameSplit[2]) + "*.scm"

            $fileName = (Get-ChildItem -Path $releaseDirectory"\JadeMaster\schemas" -Filter $filter).Name
            $fileName = $fileName.Substring(0, ($fileName.Length - 4))

            $jmtLinesToCopy += ($fileNameSplit[0] + "::$fileName::" + $fileNameSplit[4] + "::" + $fileNameSplit[6])
         
         
            if ($fileNameSplit[0] -Eq "SCM") {
                $starterLinesToCopy += ($fileName + ".scm")
            }
            if ($fileNameSplit[0] -Eq "SCMDDB") {
                $starterLinesToCopy += ($fileName + ".scm " + $fileName + ".ddb")
            }
        }
    }

    AddSCMToJMTInstallFile $jmtLinesToCopy
    AddSCMToStarterFile $starterLinesToCopy
}

function AddSCMToJMTInstallFile([array]$linesToCopy) {
    if ($linesToCopy.Count -eq 0) { return }
    
    $JMTFilePath = $releaseDirectory + "\JadeMaster"
    $fileStream = [System.IO.StreamWriter] "$JMTFilePath\JMTInstall.tmp"

    $inPatches = $false
    [int]$patchNumToAdd = ($linesToCopy[0].split(":")[2]).substring(0,3)
    $maxLines = $linesToCopy.Count
    $curLine = 0
    [int]$curPatchNum = 0

    Get-Content "$JMTFilePath\JMTInstall.txt" | % {
        
        if ($_.contains("Patches Finish HERE")) {
            $inPatches = $false

            #Add any new files
            for ($line=$curLine; $line -lt $maxLines; $line++) {
                $fileStream.WriteLine($linesToCopy[$line])
            }
        }

        if ($inPatches) {
            #Only bother doing this if we actually have something to add
            if ($curLine -lt $maxLines) {
                try {
                    $curPatchNum = ($_.split(":")[2]).substring(0,3)
                } catch {
                    #If the current line is a space or a comment, then we dont care
                }

                #Lets make an assumption that the $linesToCopy array is in order
                while ($curPatchNum -gt $patchNumToAdd) {
                    #Dont add duplicate lines
                    if ($_ -ne $linesToCopy[$curLine]) {
                        $fileStream.WriteLine($linesToCopy[$curLine])
                    }
                    $curLine++

                    if ($curLine -lt $maxLines) {
                        $patchNumToAdd = ($linesToCopy[$curLine].split(":")[2]).substring(0,3)
                    } else {
                        $patchNumToAdd = ($_.split(":")[2]).substring(0,3)
                    }
                }
            }
        } else {
            #Start the patch checking on the *next* loop through
            if ($_.contains("Patches Start HERE")) {
            $inPatches = $true
            }
        }
        
        $fileStream.WriteLine($_)
    }

    $fileStream.Close()

    #Copy our new JMTInstall file to the 2 locations needed, overwriting the previous file
    Copy-Item "$JMTFilePath\JMTInstall.tmp" "$releaseDirectory\JadeMaster\JMTInstall.txt"
    Copy-Item "$JMTFilePath\JMTInstall.tmp" "$releaseDirectory\JMT$selectedRelease\JMTInstall.txt"
    
    #And clean up our temp file
    Remove-Item "$JMTFilePath\JMTInstall.tmp"
}

function AddSCMToStarterFile([array]$linesToCopy) {
    if ($linesToCopy.Count -eq 0) { return }
    
    $StarterFilePath = $releaseDirectory + "\JadeMaster\schemas"
    $fileStream = [System.IO.StreamWriter] "$StarterFilePath\StarterSchemaLoad1A_Patches.mul.tmp"
       
    [int]$patchNumToAdd = $linesToCopy[0].substring(0,3)
    $maxLines = $linesToCopy.Count
    $curLine = 0
    [int]$curPatchNum = 0
    Get-Content "$StarterFilePath\StarterSchemaLoad1A_Patches.mul" | % {
        #Only bother doing this if we actually have something to add
        if ($curLine -lt $maxLines) {
            try {
                $curPatchNum = $_.substring(0,3)
            } catch {
                #If the current line is a space or a comment, then we dont care
            }
                        
            #Lets make an assumtion that the $linesToCopy array is in order
            while ($curPatchNum -gt $patchNumToAdd) {
                #Dont add duplicate lines
                if ($_ -ne $linesToCopy[$curLine]) {
                    $fileStream.WriteLine($linesToCopy[$curLine])
                }
                $curLine++
                
                if ($curLine -lt $maxLines) {
                    $patchNumToAdd = $linesToCopy[$curLine].substring(0,3)
                } else {
                    #Exit condition
                    $patchNumToAdd = $_.substring(0,3)
                }
            }
        }

        $fileStream.WriteLine($_)
    }

    #Add any new files
    for ($line=$curLine; $line -lt $maxLines; $line++) {
        $fileStream.WriteLine($linesToCopy[$line])
    }

    $fileStream.Close()

    Copy-Item "$StarterFilePath\StarterSchemaLoad1A_Patches.mul.tmp" "$releaseDirectory\JadeMaster\schemas\StarterSchemaLoad1A_Patches.mul"
    Remove-Item "$StarterFilePath\StarterSchemaLoad1A_Patches.mul.tmp"
}

function WriteToLog ($text, $clear = $false) {
    if ($clear) {
        $MTxtLog.Text = ""
    }

    $date = Get-Date -Format "HH:mm"
    $MTxtLog.AppendText($date + ": $text`r`n")
    Write-Host $text
}

function AddPatchClicked([System.Windows.Forms.ListBox]$ComponentObject) {
    $script:selectedPatches = $ComponentObject.SelectedItems | % { $_.replace("*","") }
	Write-Host $script:selectedPatches
    $BtnGo.Enabled = ($selectedPatches.Count -gt 0)
}

function FixSchemaLoadOrder() {
 #1. Fix load orders of the actual files
    $allSchemaFiles = @()
    #Work out what the order *should* be
    Get-ChildItem -File -Path "$releaseDirectory\JadeMaster\schemas\*" -Filter "*.scm" | % {
        [int]$fileNum = $_.Name.substring(0,3)
        if ($fileNum -lt 210) { return }

        $name = $_.Name
        #Add the patch number to the start to enable sorting
        $name = ($name.Split("_")[2]) + $name
        $allSchemaFiles += $name
    }
    $allSchemaFiles = $allSchemaFiles | Sort-Object

    $schemaPaths = @("$releaseDirectory\JadeMaster\schemas\",
                    "$releaseDirectory\JMT$SelectedRelease\schemas\",
                    "$releaseDirectory\JARI_JMT$SelectedRelease\SchemaFiles\") 
    
    #Rename files based on their patch numbers starting from 210
    $highestPatchNumber = 210
    $srcSCMPath = "$releaseDirectory\JadeMaster\schemas\"
    #Keep track of the original patch folder names
    $allPatches = @()
    foreach ($file in $allSchemaFiles) {

        #Add the original patch to our list
        $patchName = $file.substring(0,3) + "_Par" + ($file.split("_")[3])
        $patchName = $patchName.split(".")[0]
        if (!(Test-Path "$patchDirectory\$patchName")) {
            $patchName += "_Base" + $SelectedRelease.substring(3,3)
        }
        if (!($allPatches.Contains($patchName))) {
            $allPatches += $patchName
        }

        $newFileName = "" + $highestPatchNumber + $file.Substring(6) #Renumber the schema
        $oldName = $srcSCMPath + $file.Substring(3)
        $newName = $srcSCMPath + $newFileName
        $hasDDB = Test-Path $oldName.replace(".scm", ".ddb")
        #And repeat for each type of environment/deploy
        foreach ($path in $schemaPaths) {    
            $oldPath = $oldName.replace($srcSCMPath, $path)
            $newPath = $newName.replace($srcSCMPath, $path)

            Move-Item $oldPath  $newPath
            if ($hasDDB) {
                Move-Item $oldPath.replace(".scm", ".ddb") $newPath.Replace(".scm", ".ddb")
            }
        }
        $highestPatchNumber += 10
    }

 #2. Fix the JMTInstall/1A_Patches.mul files
    ClearTxtFiles
    $allPatches | Sort-Object | % {
        AddPatchToTxtFiles $_ 
    }
}

function ClearTxtFiles() {
    $filesToClear = @("$releaseDirectory\JadeMaster\JMTInstall.txt",
                        "$releaseDirectory\JadeMaster\schemas\StarterSchemaLoad1A_Patches.mul")
    foreach ($file in $filesToClear) {
        if ($file.Contains("JMTInstall.txt")) {
            $fileStream = [System.IO.StreamWriter] ($file.replace("JMTInstall.txt", "JMTInstall.tmp"))
            $inPatches = $false
            #Copy all content except anything between the patches lines
            Get-Content $file | % {
                if (!($inPatches)) {
                    $fileStream.WriteLine($_)

                    if ($_.contains("Patches Start HERE")) {
                        $inPatches = $true
                    }
                } else {
                    if ($_.contains("Patches Finish HERE")) {
                        $inPatches = $false
                        $fileStream.WriteLine($_)
                    }
                }
            }
            $filestream.Close()
            #Lastly overwrite the old file with the new one
            Copy-Item ($file.replace("JMTInstall.txt", "JMTInstall.tmp")) $file
            Copy-Item ($file.replace("JMTInstall.txt", "JMTInstall.tmp")) $file.replace("\JadeMaster\", "\JMT$SelectedRelease\")
            
            #And clean up our temp file
            Remove-Item ($file.replace("JMTInstall.txt", "JMTInstall.tmp"))
        } else {
            #Assume its the mul file
            #Dont bother copying any contents, just replace the entire file with a empty one
            "#MULTIPLE_SCHEMA_EXTRACT" &gt;$file
        }
    }
}

#End Define Functions

#Draw form
$Form = New-Object System.Windows.Forms.Form
$Form.width = 400
$Form.height = 500
$Form.FormBorderStyle = [System.Windows.Forms.FormBorderStyle]::Fixed3D
$Form.Text = "Add patches to release"
$Form.MaximumSize = New-Object System.Drawing.size(400, 500)
$Form.MinimumSize = New-Object System.Drawing.size(400, 500)
$Form.StartPosition = "centerscreen"
$Form.KeyPreview = $true
$Form.Add_KeyDown({if ($_.KeyCode -eq "Enter") {}})
$Form.Add_KeyDown({if ($_.KeyCode -eq "Escape") {$Form.Close()}})

$last4Release = @("")
$last4Release += GetLast4Releases

#JMT Directories section
CreateGroupBox $GrpReleaseDirectories 15 10 350 95 "JMT Directories" $Form
CreateLabel $LblReleaseNum 5 20 "Release:" $GrpReleaseDirectories
CreateComboBox $CbxVersion 220 17 120 20 $GrpReleaseDirectories $last4Release ({ SourceReleaseChanged($CbxVersion) })
CreateLabel $LblPatchLoc 5 45 "Patch Location:" $GrpReleaseDirectories
CreateTextBox $TxtPatchLoc 110 42 230 20 $patchDirectory $GrpReleaseDirectories
CreateLabel $LblReleaseLoc 5 70 "Release Location:" $GrpReleaseDirectories
CreateTextBox $TxtReleaseLoc 110 67 230 20 $releaseDirectory $GrpReleaseDirectories

#Patches section
CreateGroupBox $GrpPatches 15 110 350 200 "Patches" $Form
CreateLabel $LblPatchAdd 40 15 "Patches to Add" $GrpPatches
CreateListBox $LstBxPatchesToAdd 5 32 165 162 $GrpPatches ({ AddPatchClicked($LstbxPatchesToAdd)})
CreateLabel $LblPatchApplied 200 15 "Patches already Applied" $GrpPatches
CreateListBox $LstBxPatchesAlreadyAdded 180 32 165 162 $GrpPatches
$LstBxPatchesAlreadyAdded.ForeColor = [System.Drawing.Color]::Gray
$LstbxPatchesAlreadyAdded.SelectionMode = [System.Windows.Forms.SelectionMode]::None

#Log secion
CreateGroupBox $GrpLog 15 315 350 110 "Log" $Form
CreateMultilineTextBox $MTxtLog 5 15 340 87 "" $True $GrpLog

#Buttons
CreateButton $BtnGo 140 430 100 25 "Add Patches" $Form ({ ApplyPatches })
$BtnGo.Enabled = $false

#Create the form
$Form.Add_Shown({$Form.Activate()})
$Form.ShowDialog()
';

	_psFile.writeString(source);
	_psFile.close();

epilog

end;</source>
        <Parameter name="_psFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="xCheckDocumenationCopiedPS" id="e7497b72-294b-4158-8c70-f634a295bbcf">
        <source>xCheckDocumenationCopiedPS(_psFile, _diffFile : File io);

/*

Purpose:		Create the ps file for checking documentation has been copied	

Date			Who		Reason
02/08/2016		cnwmh5	Initial creation

*/
constants

	ReleaseDirectory				: String = "\\cnwchcm24\cnwpod$\Releases\";				// "D:\Releases\";
	DirectoryBaseRelease			: String = "\BaseRelease";
	DirectoryBaseJARIRelease		: String = "\BaseJARIRelease";
	DirectoryJARIPDF				: String = "\jmt_documentation";
	DirectoryJARIHTML				: String = "\jmt_htdocs\HTML5";
	DirectoryPDF					: String = "\documentation";
	DirectoryHTML					: String = "\web\HTML5";
	DirectoryReleaseJADEMASTER		: String = "\JADEMASTER";
	DirectoryReleaseJMT				: String = "\JMT";
	DirectoryReleaseJARI			: String = "\JARI_JMT";
	DirectoryMonthly				: String = "\Monthly";	

vars

	source							: String;
	version							: String;

begin

	// get the version
	version := CM_Version.VERSION;
	version := version.replaceString(".", "");

	source := '
Clear-Host
	
# Get the release directories to check
$versionNumber = "' &amp; version &amp; '"
$releaseDirectory = "' &amp; ReleaseDirectory &amp; '" + $versionNumber

# Setup the base directories to check against
$baseDirectoryArray = (($releaseDirectory + "' &amp; DirectoryBaseRelease &amp; DirectoryPDF &amp; '"), 
	($releaseDirectory + "' &amp; DirectoryBaseRelease &amp; DirectoryHTML &amp; '"), ($releaseDirectory + "' &amp; DirectoryBaseRelease &amp; DirectoryPDF &amp; '"), 
    ($releaseDirectory + "' &amp; DirectoryBaseRelease &amp; DirectoryHTML &amp; '"), 
	($releaseDirectory + "' &amp; DirectoryBaseJARIRelease &amp; DirectoryJARIPDF &amp; '"), ($releaseDirectory + "' &amp; DirectoryBaseJARIRelease &amp; DirectoryJARIHTML &amp; '"))

# Get the release directories to check
if (Test-Path $releaseDirectory"\Monthly")
{
    $releaseDirectory = $releaseDirectory + "' &amp; DirectoryMonthly &amp; '"
    $releaseNumber = Get-ChildItem -Directory -Path $releaseDirectory | sort CreationTime -desc | select -Last 1
    $releaseDirectory = $releaseDirectory + "\" + $releaseNumber
 
}

$releaseDirectoryArray = ($releaseDirectory + "' &amp; DirectoryReleaseJADEMASTER &amp; DirectoryPDF &amp; '"), 
	($releaseDirectory + "' &amp; DirectoryReleaseJADEMASTER &amp; DirectoryHTML &amp; '"), 
	($releaseDirectory + "' &amp; DirectoryReleaseJMT &amp; '" + $releaseNumber + "' &amp; DirectoryPDF &amp; '"), 
	($releaseDirectory + "' &amp; DirectoryReleaseJMT &amp; '" + $releaseNumber + "' &amp; DirectoryHTML &amp; '"), 
	($releaseDirectory + "' &amp; DirectoryReleaseJARI &amp; '" + $releaseNumber + "' &amp; DirectoryJARIPDF &amp; '"),
	($releaseDirectory + "' &amp; DirectoryReleaseJARI &amp; '" + $releaseNumber + "' &amp; DirectoryJARIHTML &amp; '")

$fileToLogTo = "' &amp; _diffFile.fileName &amp; '"

# get the number of directories to check against
$baseDirectoryCount = $baseDirectoryArray.Count - 1

# read through the directories checking for differences in length and last modified time and append to file
foreach ($index in 0..$baseDirectoryCount)
{

    Write-Host "Comparing " $baseDirectoryArray[$index] "and" $releaseDirectoryArray[$index]".  Please wait..."

	$baseDirectoryFiles = Get-ChildItem -Recurse -File -Path $baseDirectoryArray[$index]
    $releaseDirectoryFiles = Get-ChildItem -Recurse -File -Path $releaseDirectoryArray[$index]

    $comparing = "Comparing " + $baseDirectoryArray[$index] + " and " + $releaseDirectoryArray[$index] 
    $comparing | Out-File $fileToLogTo -append

    Compare-Object -ReferenceObject $baseDirectoryFiles -DifferenceObject $releaseDirectoryFiles -Property Name, Length, LastWriteTime | Out-File $fileToLogTo -append

}

# Check to see if the line count = 6 so we can delete the file
$lineCount = 0
$reader = New-Object IO.StreamReader $fileToLogTo
while($reader.ReadLine() -ne $null){ $lineCount++ }
try {
    $reader.Close() 
}
finally
{

}

if ($lineCount -eq 6) 
{
    Remove-Item $fileToLogTo
}';

	_psFile.writeString(source);
	_psFile.close();

epilog

end;</source>
        <Parameter name="_psFile" type="File" usage="io"/>
        <Parameter name="_diffFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xCheckPermissions" id="4b5f2f33-4628-490f-bccf-5800fbc9d6d1">
        <source>xCheckPermissions(_lhs: String; _rhs: String; _permission: String; _klass: Class; _errorDetails, _errorDetailsAll: String io; _constant: GlobalConstant io): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 October 2016	cnwmk3	Initial creation

*/
constants
	StrExplanation			= " permission constant does not have any Explanation.";
	StrCheckConstant		= " Please check the permission constant.";
	IncorrectConst			= " have Incorrect permission constant for ";
	ModifiedBy				= " form modified by ";
vars
	permObj				: CM_PermissionObject;
	permAgent			: CM_PermissionAgent;
	dateStartTesting	: TimeStamp;
	hasViewPermission	: Boolean;
	hasMaintPermission	: Boolean;
	length				: Integer;
begin
	dateStartTesting.setDateTime(2016, 10, 01, 00, 00, 00, 00);
	create permAgent transient;
	permAgent.populatePermissionDict(true, true, 0);
	hasViewPermission := false;
	hasMaintPermission :=  false;
	permObj := permAgent.allPermissionsByName.getAtKey(_rhs);
	
	// Something is wrong, so log it
	if permObj = null then
		app.writeLog("###### " &amp; _klass.name &amp; " has no " &amp; _permission &amp; " Permission. (_rhs = " &amp; _rhs &amp; ") #####", LogINFO);
		return false;
	endif;
	
	_constant := rootSchema.getSchema("PortSchema").getConstant(permObj.constName);
	// check that Permission constant does have an Explanation
	if (_constant.creationTime &gt; dateStartTesting) then
		if permObj.explanation = null then
			app.writeLog(_constant.name &amp; StrExplanation, LogINFO);
			_errorDetails := _errorDetails &amp; " " &amp; _constant.name &amp; " " &amp; _klass.getModifiedBy() &amp; "" &amp; StrExplanation &amp; StrCheckConstant;
			_errorDetailsAll := _errorDetailsAll &amp; CrLf &amp; _errorDetails;
		endif;
											
		// Check that View Permission is set to a View Constant
		length := _permission.length() - 1;
		if _lhs[_lhs.length - length: end] &lt;&gt; _rhs[_rhs.length - length:end] then
			app.writeLog(_klass.name &amp; " form in " &amp; _klass.schema.name &amp; " " &amp; IncorrectConst &amp; _permission &amp; " Permission" , LogINFO);
			_errorDetails := _klass.schema.name &amp; "::" &amp;  _klass.name &amp; " " &amp; ModifiedBy &amp; _klass.getModifiedBy() &amp; IncorrectConst &amp; _permission &amp; " Permission" &amp; StrCheckConstant;
			_errorDetailsAll := _errorDetailsAll &amp; CrLf &amp; _errorDetails;
		endif;
	endif;
	if _permission = "View" then
		hasViewPermission := true;
		return hasViewPermission;
	endif;
	if _permission = "Maint" then
		hasMaintPermission := true;
		return hasMaintPermission;
	endif;
epilog
	delete permAgent;
end;</source>
        <Parameter name="_lhs" type="String"/>
