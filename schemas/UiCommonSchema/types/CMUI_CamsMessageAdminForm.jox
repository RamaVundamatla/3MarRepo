    <JadeMethod name="getCamsStatusInteger" id="7118dc97-07da-4f00-96cb-f791704057fb">
        <source>getCamsStatusInteger(_statusString: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars

begin
    if _statusString = "Idle" then
        return CAM_IDLESTATUS;
    elseif _statusString = "Extract" then
        return CAM_EXTRACTSTATUS;
    elseif _statusString = "Send" then
        return CAM_SENDSTATUS;
    elseif _statusString = "Complete" then
        return CAM_COMPLETESTATUS;
    elseif _statusString = "Resend" then
        return CAM_RESENDSTATUS;
    elseif _statusString = "Hold" then
        return CAM_HOLDSTATUS;
    elseif _statusString = "ERROR" then
        return CAM_ERRORSTATUS;
    else
        return 0;
    endif;
end;</source>
        <Parameter name="_statusString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCamsStatusString" id="77206569-48b5-4809-a208-26fc0b16fceb">
        <source>getCamsStatusString(_status: Integer): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/
vars

begin
    if _status = CAM_IDLESTATUS then
        return "Idle";
    elseif _status = CAM_EXTRACTSTATUS then
        return "Extract";
    elseif _status = CAM_SENDSTATUS then
        return "Send";
    elseif _status = CAM_COMPLETESTATUS then
        return "Complete";
    elseif _status = CAM_RESENDSTATUS then
        return "Resend";
    elseif _status = CAM_HOLDSTATUS then
        return "Hold";
    elseif _status = CAM_ERRORSTATUS then
        return "ERROR";
    else
        return _status.String;
    endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
