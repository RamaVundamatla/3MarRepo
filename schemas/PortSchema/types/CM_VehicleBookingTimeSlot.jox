    <JadeMethod name="getSentLoadNotification" id="bbb49ffb-483b-43c8-8519-80a696334633">
        <source>getSentLoadNotification() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2023	jlier1	Initial creation 58840
08 May 2025	navcs2	MTN-34632
*/

vars
	activity 		: CM_ExternalWebServiceActivity; 
	endPoint 		: CM_Endpoint;
	pos 			: Integer;
	endpointDesc 	: String;
begin
	
	foreach activity in self.allEWSAPIActivities discreteLock do
		if activity.myExtWebserviceDef = null then
			return null;
		endif;
		
		foreach endPoint in activity.myExtWebserviceDef.allEndpoints do			//08 May 2025	navcs2	MTN-34632
			if ETRow_LoadNotification = endPoint.defName then					//08 May 2025	navcs2	MTN-34632
				return true;													//08 May 2025	navcs2	MTN-34632
			endif;																//08 May 2025	navcs2	MTN-34632
		endforeach;																//08 May 2025	navcs2	MTN-34632
		
	endforeach;

	return false;
epilog


end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
