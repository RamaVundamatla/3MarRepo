    <JadeMethod name="utlUpdateCodeGroup" id="b6eed018-41ae-41d2-ac67-e991558522f1">
        <source>utlUpdateCodeGroup(pProxyCodeGroup:CM_CodeGroup ; _passport : CM_Passport input);
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
