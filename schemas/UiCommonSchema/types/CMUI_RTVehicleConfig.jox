    <JadeMethod name="displayCriteriaDesc" id="fcb3e674-9602-4fd1-b31d-05ce5c7fe2ba">
        <source>displayCriteriaDesc();
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	CCMS MES 1080
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	criteria		: CM_YACriteria;
	template 		: CM_YATemplate;
	text			: String;
	cmifCriteria	: CMIF_Object;
	
begin

	self.lblCriteria.caption := "";
	
	if not self.chkAllowNonRT.value then	// when Driver Initiated Move is not allowed, then there are no criteria to be populated.
		return;
	endif;

	foreach cmifCriteria in self.allCriteria do
		criteria := cmifCriteria.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		text := text &amp; criteria.getListDisplay &amp; " ";
	endforeach;
	
	/*if self.isCriteriaModified then
		self.lblCrit.caption := "(criteria modified) ";
	endif;*/

	self.lblCriteria.caption := text.trimBlanks;

end;</source>
    </JadeMethod>
