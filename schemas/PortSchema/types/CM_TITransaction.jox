			type = TRANS_TYPE_REC_RAIL or
			type = TRANS_TYPE_REC_RAIL_INTER_TERM or
			type = TRANS_TYPE_REC_ROAD or
			type = TRANS_TYPE_REC_ROAD_INTER_TERM or
			type = TRANS_TYPE_REC_SHIP;

end;</source>
