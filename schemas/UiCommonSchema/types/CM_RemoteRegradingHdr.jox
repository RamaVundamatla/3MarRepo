<Class name="CM_RemoteRegradingHdr">
    <JadeMethod name="isProcessAllowedInSystemAllert" id="bdb0f530-d92c-4289-8f72-3cc698f08391">
        <source>isProcessAllowedInSystemAllert(): Boolean;
/* ---------------------------------------------------------------------------
Created:	23 February 2010	by cnwvu1

Purpose:	PAR 21218
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return true;	//PAR 23972 10/05/2010

	/*	commented by PAR 23972 10/05/2010
	// it disables btnProcessT for CMUI_RemoteDataEditForm, that is called from CMUI_SystemAllerts
	// and populates "PLEASE RUN FROM FORM" on the form, see loadRemoteTable()
	return false;	
	*/

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteTable" id="477190be-1102-45b7-812a-7b796d068fdd">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 21 November 2002 

vars

	detail	: CM_RemoteDataDtl;
	count	: Integer;

begin

	//PAR 23972 10/05/2010
	inheritMethod(_table);
	foreach detail in self.allRemoteDataDtl do
		count := count + 1;
		self.addRemoteRow(_table, 'Regrading Detail ' &amp; count.String, Click, detail);
	endforeach;

	/*	commented by PAR 23972 10/05/2010
	_table.setColumnHeadings('Item', 'Value');
	self.addRemoteRow(_table, app.getErrorString(Please_run_from_Form), '*********', null);
	*/

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
