    <JadeMethod name="setForUpdate" id="c8cae38e-cc43-405f-b00e-fa1e1cb19113">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
vars

begin
	inheritMethod(_proxyEDITI);
	self.entryNumber := _proxyEDITI.entryNumber;
	self.vesselName := _proxyEDITI.vesselName;
//	self.voyageCode := _proxyEDITI.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	self.status := _proxyEDITI.status;
	self.freightForwarder := _proxyEDITI.freightForwarder;	//01 Jun 2017	NDL	TFS 4456
	self.expiryDate := _proxyEDITI.expiryDate;	//02 Jun 2017	NDL	TFS 4455
epilog

end;</source>
