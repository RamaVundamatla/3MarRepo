    <JadeMethod name="createStorageTransactions22" id="cf3869b3-8e54-45cf-9656-e54dcc0da97c">
        <source>createStorageTransactions22(_realTI : CM_TrackedItem input; _transDate : Date; _createExtraStorage : Boolean);

vars
	transParams: CMIF_StorageTransController;
	tranTS	: TimeStamp;
	date	: Date;
	time	: Time;
begin

	// create storage transaction for given date and an explicit time (for 'days onsite at')
	time := "12:00".Time;
	create transParams transient;
	transParams.type := TRANS_TYPE_STORAGE;
	transParams.noCharge := false;
	transParams.userId := "CNWUT1";
	transParams.createdByBGP := true;	// to get the dateTime used
	transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs
	
	date := _transDate;
	if _createExtraStorage then
		date := date - 2;
	endif;
	beginTransaction;
	tranTS.setDate(date);
	tranTS.setTime(time);
	transParams.dateTime := tranTS;
	_realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	
	if _createExtraStorage then
		date := _transDate;
		beginTransaction;
		tranTS.setDate(date);
		tranTS.setTime(time);
		transParams.dateTime := tranTS;
		_realTI.createTransaction(transParams, app.myPassport);
		commitTransaction;
	endif;


epilog
	delete transParams;
end;</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_transDate" type="Date"/>
        <Parameter name="_createExtraStorage" type="Boolean"/>
    </JadeMethod>
