<Class name="CM_ITSInterfaceReqResetMach" id="81b30624-3a87-4c7f-9859-0eef6e576a24">
    <superclass name="CM_ITSInterfaceRequestInternal"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Reset ITS Interface for machine.</text>
    <DbClassMap file="jmtinterface"/>
    <JadeMethod name="populateCmifMessage" id="45e63b4b-3755-423f-9b67-69a95935e7e8">
        <source>populateCmifMessage(_cmifMsg: CMIF_ITSInterfaceMsg input; _validateFormat: Boolean);

/*

Purpose:			Get property values that may be stored in xml data.

Parameters:			_validateFormat - if true, an exception will be raised when invalid xml data is encountered.

Return Value:		_cmifMsg will be populated with values from message.


Date		Who		Reason
08 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	inheritMethod(_cmifMsg, _validateFormat);
	
	_cmifMsg.messageType := ITS_MESSAGETYPE_RESETMACH;

epilog

end;</source>
        <Parameter name="_cmifMsg" type="CMIF_ITSInterfaceMsg" usage="input"/>
        <Parameter name="_validateFormat" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set" id="12f810e9-a1e2-40ac-a8b0-15e3d5941e3a">
        <updating/>
        <source>set(	_machine		: CM_Machine;
		_user			: CM_User;
		_interfaceDefn	: CM_ITSInterfaceDefinition	) updating;

/*

Purpose:			Standard method for setting the object's properties.

Parameters:			The machine to be reset and the User who is requesting the reset.

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.createdTS		:= app.actualTimeServer();
	self.priority		:= self.Priority_High;

	self.myUser			:= _user;
	self.myMachine		:= _machine;
	
	self.myITSInterfaceDefinition := _interfaceDefn;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_interfaceDefn" type="CM_ITSInterfaceDefinition"/>
    </JadeMethod>
</Class>
