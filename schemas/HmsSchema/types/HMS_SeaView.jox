    <JadeMethod name="doRefresh" id="8f3fdacf-991a-4909-a3ab-64c32f6ca163">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	22 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	cmifMovement : CMIF_HMS_WorkingMovement;
begin
	inheritMethod();
	if self.tblMovement.row &gt; self.tblMovement.fixedRows then				
		cmifMovement := self.tblMovement.accessRow(self.tblMovement.row).itemObject.CMIF_HMS_WorkingMovement;			
	endif;
	self.buildEntireForeground();
	if cmifMovement &lt;&gt; null
	and global.isValidObject(cmifMovement) then
		self.tblMovement.selectObject(cmifMovement, false);
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="027c2d37-f831-49bf-9353-7f219a610a16">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	23 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.tblMovement.move(0, self.frmToolbar.height, self.clientWidth, self.clientHeight - self.frmToolbar.height);
	self.txtRemarks.top := self.frmMarksToolbar.height;
	self.tblMeterMarks.top := self.frmMarksToolbar.height;			
	//self.picList.move(0, self.frmToolbar.height, self.clientWidth, self.clientHeight - self.frmToolbar.height);
	//self.defaultFrame.move(0, 0, self.picList.width, self.picList.height);
	//self.defaultVoyDetails.move(0, 0, self.defaultFrame.width, self.defaultFrame.height);

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveMarksRemarks" id="2b86fc5b-fdf4-4600-b688-269b703187f3">
        <updating/>
        <source>doSaveMarksRemarks()updating;
//--------------------------------------------------
// Created:	22 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	remarks : String;
	pict : DragPicture;
	pxyMovement : HMS_VoyageMovement;
begin

	if self.txtRemarks.visible then
		if self.myCurrentWorkingMovement &lt;&gt; null then
			// update the remarks
			remarks := self.txtRemarks.text;
			if remarks &lt;&gt; self.myCurrentWorkingMovement.remarks then
				self.myCurrentWorkingMovement.remarks := remarks;
				if self.myCurrentWorkingMovement.myPersistentMovement &lt;&gt; null then
					pxyMovement := app.createUpdateProxy(self.myCurrentWorkingMovement.myPersistentMovement).HMS_VoyageMovement;
					app.myTrxUA.trxUpdateHMSMovementRemarks(pxyMovement, remarks, app.myPassport);						
				endif;
			endif;
		endif;
		self.showHideMarksRemarks(true);				
	elseif self.tblMeterMarks.visible then
		//Update the meter marks
		if self.doAddMovementToGraphicalView(self.myCurrentWorkingMovement) then
			self.myGraphicalViewForm.showSelectedPosDetails();
			self.myGraphicalViewForm.scrollToSelectedSprite(null);				
			self.showHideMarksRemarks(false);
		endif;
	else
		return;
	endif;
	
epilog
	delete pxyMovement;
end;</source>
    </JadeMethod>
    <JadeMethod name="getMovementsToAddToList" id="a2d02ac5-9c47-4af1-a113-84cc10139c54">
        <updating/>
        <source>getMovementsToAddToList() updating;

vars
 	workingVoyage 	:	CMIF_HMS_WorkingVoyage;
	workingMovement,
 	nextMove 		: CMIF_HMS_WorkingMovement;
begin
 	// This method gets all the movements that go to the selected berth (berthForView)

 	// Clear current view
 	self.allVoyDetailControls.purge;
	self.tblMovement.rows := self.tblMovement.fixedRows;

	self.cmbMyBerth.listCollection(self.myGraphicalViewForm.allBerthsInView, false, 0);
	
	if self.currBerthForView = null then
		return;
	endif;

	foreach workingMovement in self.myViewController.allMovementsInViewByDT do	
		if workingMovement.myBerth = self.currBerthForView then
			nextMove := workingMovement.getMovementNext;

			if workingMovement.occursOnDT &gt;= self.myViewController.viewStartDT
			or (nextMove.occursOnDT &lt;= self.myViewController.viewFinishDT
			and nextMove.occursOnDT &gt;= self.myViewController.viewStartDT) then
				self.showMovement(workingMovement);

			elseif workingMovement.occursOnDT &lt; self.myViewController.viewStartDT
			and	nextMove.occursOnDT &gt; self.myViewController.viewFinishDT then
				self.showMovement(workingMovement);					
			endif;
		endif;
	endforeach;	
	
	self.tblMovement.colourRows(self.colorRow1, self.colorRow2);	

end;</source>
    </JadeMethod>
    <JadeMethod name="handleNotificationRefreshView" id="9d9fc3ea-8ec8-4c29-87cd-aff3596ac39e">
        <updating/>
        <source>handleNotificationRefreshView(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

begin

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="3a44754e-ba04-48ff-8d0b-4e27b9608f99">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: CM_Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	23 July 2004 By: cnwgd1
//--------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	cmifMovement : CMIF_HMS_WorkingMovement;
	idx : Integer;
begin
	if eventType = Object_Delete_Event then
		//Berth has been deleted
		if theObject = self.currBerthForView then
			self.allLogicalBerths.clear();
			self.currBerthForView := null;
			self.setCurrBerthForView(BerthDown);
		else
			self.buildEntireForeground();
		endif;
	elseif eventType = Object_Update_Event then
		//Berth has been updated
		if theObject = self.currBerthForView then
			if self.tblMovement.row &gt; self.tblMovement.fixedRows then				
				cmifMovement := self.tblMovement.accessRow(self.tblMovement.row).itemObject.CMIF_HMS_WorkingMovement;			
			endif;
			self.getMovementsToAddToList();
			if cmifMovement &lt;&gt; null then
				self.tblMovement.selectObject(cmifMovement, false);
			endif;
		else
			self.buildEntireForeground();
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="CM_Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
