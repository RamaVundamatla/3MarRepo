    <JadeMethod name="uDeleteVoyageLoadJobs" id="19b21883-dd1c-4ad8-99aa-59541a017319">
        <source>uDeleteVoyageLoadJobs();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars

	voyageJobNum : String;
	voyage : CM_Voyage;
	theSlots : CM_SlotControllerArray;
begin
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(self.getVoyageName, null);
	assertTrue(voyage &lt;&gt; null);
	
	

	self.deleteVoyageJob(voyage,"J10","100");
	create theSlots transient;
	
	self.getJobSlotControllers(self.getVoyageName,"09",DeckOnDeck,1,1,20,theSlots);
	self.unmarkSlotsAsLoadJob(theSlots);
	
epilog
	delete theSlots;

end;</source>
    </JadeMethod>
    <JadeMethod name="uRemoveAllStops" id="f49c3171-94c0-453b-aaa7-9f545a048ea7">
        <source>uRemoveAllStops();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2009	cnwer1	Initial creation

*/

vars
	stradStack : CM_StraddleStack;
	allAssocs: ObjectArray;

begin
	
	create allAssocs transient;
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDA"].CM_StraddleStack;//
	self.getAllContainerDetails(0,0,stradStack,null,null,null,null,null,null,allAssocs);

	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDB"].CM_StraddleStack;//
	self.getAllContainerDetails(allAssocs.size,0,stradStack,null,null,null,null,null,null,allAssocs);

	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDC"].CM_StraddleStack;//
	self.getAllContainerDetails(allAssocs.size,0,stradStack,null,null,null,null,null,null,allAssocs);
	
	
	self.removeAllStopsForAssoc(allAssocs);

epilog
	
	allAssocs.purge;
	delete allAssocs;

end;</source>
    </JadeMethod>
