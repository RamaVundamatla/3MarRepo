    <JadeMethod name="addToTable" id="d0e93024-20d2-4a70-9720-2ebcc554bd77">
        <source>addToTable(_bay : CM_Bay);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2013	cnwer1	Initial creation 31289

*/

vars

	newRow : Integer;
begin
	if _bay = null then
		return;
	endif;
	
	newRow:=self.tblBays.rows+1;
	self.tblBays.rows:=newRow;

	if _bay.myHold &lt;&gt; null then
		if _bay.myHold.ordinalHold mod 2 = 0 then
			self.tblBays.accessRow(newRow).backColor := self.ColourYellowDark;
		else
			self.tblBays.accessRow(newRow).backColor := PaleYellow;
		endif;
	endif;
	
	//self.tblBays.accessRow(newRow).backColor:=LightSkyBlue;

	self.tblBays.accessCell(newRow,1).text:= _bay.id;
	//self.tblBays.accessCell(newRow,2).text:=  _bay.id;
	self.tblBays.accessRow(newRow).itemObject:=_bay;
	
epilog

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
