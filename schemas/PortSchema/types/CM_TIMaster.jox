    <JadeMethod name="validateMe" id="105b9fc6-f1db-414e-82e3-e68ae9b8664e">
        <source>validateMe();
// -------------------------------------------
// Created 25 November 2005 by cnwdvb1
// -------------------------------------------
// cnwrd1 ccms 1034 13.8.2008
// 27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
vars

	tiMaster,
	realTiMaster	: CM_TIMaster;
	ti				: CM_TrackedItem;
	taskDescObj		: CM_ToDoTaskDesc;
	cargoTypeObj	: CM_CargoType;
	stopsTable		: CM_StopsTable;
	criteria 		: CM_YACriteria;	//20 Jul 2022	navsj20	TFS 53862
	
begin

	if self.id = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'ID', null, null);
		app.raiseCMException(Input_required_field_id, null, null); // cnwdb2	PAR 35364
		endif;
	
	if self.myOperatorNew = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Operator), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Operator), null, null); // cnwdb2	PAR 35364
	endif;

	// no cargo type field on the form
	/*
	if self.cargoType = TI_CargoType_Null then
		if not self.isKindOf( CM_TIMasterGenerator ) then	// for generators cargo type isn't visible on the screen
			app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', null, null);
		endif;
	endif;
	*/
	
//	if self.myTiMasterGroup = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Master Item Group', null, null);
//	endif;
	
	if self.myRoot = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Root', null, null);
	endif;
	
	realTiMaster := self.pxyGetRealObject();
	
	tiMaster := self.myRoot.allTiMasters[self.cargoType, self.id];
	
	if tiMaster &lt;&gt; null and tiMaster &lt;&gt; realTiMaster then
		//app.raiseCMException2(DuplicateItem, 'Master TI of cargo type ' &amp; self.cargoType.String &amp; ' and ID of ' &amp; self.id, 'System', null, null); //14.06.2022 navds20 53760
		//Master TI of cargo type %1 already exists for ID of %2 System : Maste_cargo_type_alrea_exist_s
		app.raiseCMException2(Maste_cargo_type_alrea_exist_s, self.cargoType.String , self.id, null, null); //14.06.2022 navds20 53760
	endif;
	
	
	
	cargoTypeObj := self.getCargoTypeObject();
	
	if cargoTypeObj &lt;&gt; null then
	
		foreach taskDescObj in self.allToDoTaskDesc do
			if not taskDescObj.allCargoTypes.includes(cargoTypeObj) then
		//		app.raiseCMException1(ERR_INVALID_TODO_TASK, taskDescObj.description, null, null);
				self.allToDoTaskDesc.remove(taskDescObj);
			endif;
		endforeach;
	
		foreach stopsTable in self.allStopsNew do	//Par 17781
			//if not stopsTable.allCargoTypesNew.includes(cargoTypeObj) then		//20 Jul 2022	navsj20	TFS 53862
			if stopsTable.myStopCriteria &lt;&gt; null then								//20 Jul 2022	navsj20	TFS 53862
				foreach criteria in stopsTable.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType 
					and not criteria.myYAData.CM_YADataObjects.allObjects.includes(cargoTypeObj) do	//27 Jul 2022	navsj20	TFS 53862
					//		app.raiseCMException2(StopCargoTypeMismatch, stopsTable.heading, cargoTypeObj.description, null, null);	
					self.allStopsNew.remove(stopsTable);							//20 Jul 2022	navsj20	TFS 53862
				endforeach;			
			endif;
		endforeach;
		
	endif;
	
	/* - removed, no need to check for an existing Ti - no longer creating one
	if self.id &lt;&gt; null then
		ti := self.myRoot.lookupTrackedItem(self.id, TI_CargoType_Null, TI_STATE_NORMAL, null, false, null, true);
	endif;
	
	if ti &lt;&gt; null and realTiMaster = null then
		app.raiseCMException2(DuplicateItem, 'A tracked item with an id of ' &amp; ti.id, 'System', null, null);
	endif;
	
	// removed some (containers) from container range will not have operator
	if self.myOperatorNew = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Operator), null, null);
	endif;
	*/
	// Probably worth making sure ti is unique for whole system.
	
	//27.02.2018 cnwma1 ChangeRequest #36813
	
	self.validateAttGenerator();
	//27.02.2018 cnwma1 ChangeRequest #36813

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTaskForGenSet" id="7d5b4c0b-0936-41a9-bf6d-0ff2000ba605">
        <source>validateTaskForGenSet( _task : CM_ToDoTaskDesc ) : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	22 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	taskDesc	: CM_ToDoTaskDesc;

begin

	if not _task.isForGenSetAttachDetach() then
		return true;	//we are not interested in all others task types
	endif;
	
	if not self.canHaveGeneratorAttached() then
		return false;
	endif;
	
	//Further validation depends on ti type and generator atached/detached
	foreach taskDesc in self.allToDoTaskDesc do

		if taskDesc.isForGenSetAttachDetach() then
//			found := true;
			if taskDesc &lt;&gt; _task then
				return false;	// there is another of the pair already active
			endif;
		endif;
		
	endforeach;

	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
