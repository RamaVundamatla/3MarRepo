    <JadeMethod name="doRestrictionOpenLabour" id="1285955e-2f2e-40f2-a742-7f4e0ea292fb">
        <source>doRestrictionOpenLabour()protected;
// ---------------------------------------------------------------------------
// Created:     02 June 2005	cnwhjg1
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - replace YRD_LocationMaintForm constants with YRDPadArea Constants
vars
	table		: CM_DataTable;
	row			: Integer;
	ta			: CM_TerminalArea;
	restriction	: CM_LabourRestriction;
	
begin
	table	:= self.tblData;
	row 	:= self.tblData.row;
	
	if row &lt;= table.fixedRows then
		return;
	endif;

	ta := table.accessRow(row).itemObject.CM_TerminalArea;
	
	if ta = null then
		return;
	endif;
	
	restriction := ta.allRestrictionsLabour.first;
	
	self.myAssistant.showRestrictionsForm(ta, YRD_PadArea.AreaMode_Labour, restriction,
											false, false, self.myMasterMenuAction);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRowColumnChange" id="37ae76be-9f60-40a0-8e04-374c99f1ec7e">
        <source>doRowColumnChange(_table : Table input) protected;
// -------------------------------------------
// Created 17 February 2004 by cnwdvb1
// -------------------------------------------
// 01/11/2012	cnwcs5	par 30475 - remove btnRestrictions/mnuRestrictions
vars
	obj		: Object;
begin
	obj := _table.accessRow(_table.row).itemObject;
	
	if (not obj.isKindOf(CM_TerminalArea)) then
		self.showExtraInfo(null);
		return;
	endif;
	
	self.showExtraInfo(obj.CM_TerminalArea);
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="3ff38123-3404-4744-bce3-3b506620f90f">
        <updating/>
        <source>doSearch() updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     Here we are returning a set of terminal areas from the TI's in all the terminal areas
//				of the terminal area types that are selected. As soon as we find a box that matches the 
//				search criteria, we include that area and move onto the next area
// ---------------------------------------------------------------------------
// 09/03/2010	cnwcs5	par 22687
// 01/11/2012	cnwcs5	par 30475 - tidy up translations
// 31/03/2016	cnwdap1	PAR #35843 Make monitor time based rather than object count based
// 08/08/2016   cnwma1  TFS # 2440:Manual Stock Adjustment button enabled for Block stack and gives error
// 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
vars
	theDict			: DynaDictionary;
	taTypeDict		: CM_TATypeByTypeDict;
	taDict			: CM_TAByTerminalIdDict;
	taType			: CM_TerminalAreaType;
	ta				: CM_TerminalArea;
	lc				: CM_LocationsController;
	ti				: CM_TrackedItem;
	taIter			: Iterator;
	terminalKey,
	terminal		: CM_Terminal;
	navHdr,
	taIdKey			: String;
	tasFound,
	tisQueried		: Integer;
	cmifMonitor		: CMIF_Monitor;
	noSearchCriteria	: Boolean;
	lastUpdated		: Decimal [20];								// PAR #35843
begin
	
	app.mousePointer := MousePointer_HourGlass;
	cmifMonitor := self.showMonitorForSearch();
	self.setSearchValues();
	
	noSearchCriteria := (self.allFilterOperators.isEmpty and
							self.filterAvailGrade = null and
							self.filterHasRemarks = null and
							self.filterHeldRail = null and
							self.filterHeldRoad = null and
							self.filterIsClean = null and
							self.filterISOTypeCode = null and
							self.filterISOTypeGroupCode = null and
							self.filterIsPTI = null);
	
	beginLoad;

	theDict := self.tblData.myDynaDict;
	
	theDict.clear();
	
	terminal 	:= self.myTerminal;
	taTypeDict 	:= self.allTATypes;
	
	taTypeDict.clear;
	
	self.tblFloatingList.allSelectedObjects.copy(taTypeDict);
	
	if taTypeDict.isEmpty then//include all
		app.myRoot.allTerminalAreaTypes.copy(taTypeDict);
	endif;

	foreach taType in taTypeDict do : areaTypeLoop
		if not self.includeType (taType) then	// 09/03/2010 cnwcs5 par 22687
			continue;							// 09/03/2010 cnwcs5 par 22687
		endif;									// 09/03/2010 cnwcs5 par 22687
		
		if navHdr = null then
			navHdr := taType.description;
		else
			navHdr := navHdr &amp; ', ' &amp; taType.description;
		endif;
		
		taDict := taType.allTerminalAreasByTerminal;
		
		delete taIter;
		
		taIter := taDict.createIterator;
		
		taDict.startKeyGeq(terminal, null, taIter);
		
		while taIter.next(ta) do : terminalAreaLoop
			taIter.getCurrentKeys(terminalKey, taIdKey);	 //MTN-35226

			if terminalKey &lt;&gt; terminal then
				break terminalAreaLoop;
			endif;
			
			foreach lc in ta.allLocationsControllers do : locationsControllerLoop
				if noSearchCriteria then //include empty terminal areas if there is no criteria specified
					if (not theDict.includes(ta)) then
						tasFound := tasFound + 1;
						theDict.add(ta);
						continue terminalAreaLoop;
					endif;
					
				elseif lc.allTrackedItemsById.isEmpty then //don't include empty areas if search critieria have been specified
				   continue locationsControllerLoop; //rs oct 2005 par 10886 it was giving iup on an area once it found an mt lc
				endif;
				
				foreach ti in lc.allTrackedItemsById do : tiLoop					
					tisQueried := tisQueried + 1;
					//if tisQueried mod 50 = 0 then																// PAR #35843
					if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
						//NB. tasFound and tisQueried don't correspond to size of job and parts done - in this case
						//these numbers are used in a different way (see self.updateProgress)
						cmifMonitor.updateProgress(null, tasFound, tisQueried);
						if cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Return then
							break areaTypeLoop;
						elseif cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Cancel then
							return;
						endif;
						lastUpdated := app.relativeMachineTime;													// PAR #35843
					endif;
					
					if (self.includesTI(ti)) and
					   (not theDict.includes(ta)) then
						tasFound := tasFound + 1;
						theDict.add(ta);
						break locationsControllerLoop;
					endif;
					
				endforeach;
			endforeach;	
		endwhile;
	endforeach;
	
	self.setNavigatorHeading(navHdr);
	self.displayTerminalAreas();
	
	self.btnAdjustStock.enabled := false;        		//08/08/2016 cnwma1 TFS #2440
	if self.tblData.allSelectedObjects.size &gt; 0 then	//08/08/2016 cnwma1 TFS #2440
		if  self.tblData.allSelectedObjects.first.isKindOf(CM_BulkArea) then
			self.btnAdjustStock.enabled := true;
		endif;
	endif;
	
	if theDict.isEmpty then
		endLoad;
		app.msgBox(app.getErrorString (Termi_areas_inclu_conta_that_m), app.getErrorString (No_Matches_found), MsgBox_Exclamation_Mark_Icon);	// par 30475 Nov 2012
		return;
	endif;
	
	self.hideSearcher();
	
epilog
	endLoad;
	delete taIter;
	delete app.myPassport.myCMIFMonitor;

	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetAutoAllocations" id="7e95b18f-3ddc-4eee-a2a7-b4fc6193127c">
        <updating/>
        <source>doSetAutoAllocations() protected, updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// ----------   ----------  --------------------------------------------------
// 01/11/2012	cnwcs5	par 30475 - tidy up translations, renamed from doSetAutoRestrictions
//                                - change from restrictions to allocations
//								  - auto-allocations applies to all TA types not just block stack/sub-block stack
//								  - took out beginLoad/endLoad
vars
	table		: CM_DataTable;
	proxy, ta	: CM_TerminalArea;
	result		: Integer;
	doEnable	: Boolean;
	load : Boolean;
begin
	table	:= self.tblData;
	ta 		:= table.accessRow(table.row).itemObject.CM_TerminalArea;
	
	if ta = null then
		return;
	endif;
	
	app.cmsBeginLoad(load);	//20 Feb 2014	NDL	Par 33377
	proxy 		:= ta.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);	//20 Feb 2014	NDL	Par 33377
	doEnable 	:= (not ta.autoRestrictionsEnabled);

	if doEnable and (not ta.allYardAllocations.isEmpty) then										// par 30475 Nov 2012
		app.msgBox(app.getErrorString (Selec_termi_area_curre_yard_al),								// par 30475 Nov 2012
					self.mnuSetAutoAllocations.caption,												// par 30475 Nov 2012
					MsgBox_Exclamation_Mark_Icon);			
		return;
	endif;
	
	proxy.setAutoRetrictionsEnabled(doEnable);
	
	endLoad;
	
	while true do	
		app.myTrxUA.trxUpdateTaAutoRestrictions(proxy, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return;
		else
			result := app.showErrorWarningDialog(self.mnuSetAutoAllocations.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return;
	endwhile;
	
		
epilog
	app.cmsEndLoad(load);	//20 Feb 2014	NDL	Par 33377
	delete proxy;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowContextMenu" id="607c76b4-0283-470e-a8eb-9960020c912a">
        <updating/>
        <source>doShowContextMenu() protected, updating;
//-----------------------------------------------------------------------
//  Created by: cnwsh3
//
//	Date: 18 September 2003
//-----------------------------------------------------------------------
// 31/10/2012	cnwcs5	par 30475 - translate menu caption
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	ta			: CM_TerminalArea;
	locale		: CM_Locale;		// par 30475 Oct 2012
	table		: CM_DataTable;		// par 30475 Oct 2012
	menuItem	: MenuItem;			// par 30475 Oct 2012
begin	

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuTableContext.visible 	:= false;
		self.mnuFlagLoadFrom.visible 	:= false;
		self.mnuFlagLoadTo.visible 		:= false;
		self.mnuYardAllocations.visible := false;
		self.mnuRemoveLabRestrict.visible := false;
		self.mnuAddLabRestriction.visible := false;
		self.mnuColumnOrg.enabled 		:= true;
		self.mnuColumnOrg.visible 		:= true;
		return;
	endif;

	self.mnuTableContext.enabled 	:= true;
	self.mnuColumnOrg.enabled 		:= true;
	self.mnuColumnOrg.visible 		:= true;
	self.mnuFlagLoadFrom.enabled 	:= true;
	self.mnuFlagLoadTo.enabled 		:= true;
	
	locale	:= app.myCurrentLocale;																		// par 30475 Oct 2012
	table 	:= self.tblData;																			// par 30475 Oct 2012
	ta 		:= table.accessRow(table.row).itemObject.CM_TerminalArea;									// par 30475 Oct 2012
	
	if ta &lt;&gt; null then
		self.doMnuYardAllocBuild(ta);	
		self.doMnuLabourRestrictBuild(ta); 
		self.doMnuRemoveLabourRestrictBuild(ta); 
		
		if ta.isSuitableForLoadFrom then
			self.mnuFlagLoadFrom.caption 	:= app.getErrorString (YRD_TAEnq_Unflag1); 					// par 30475 Oct 2012
			self.mnuFlagLoadTo.enabled 		:= false;
			
		elseif ta.isSuitableForLoadInto then
			self.mnuFlagLoadTo.caption 		:= app.getErrorString (YRD_TAEnq_Unflag2); 					// par 30472 Oct 2012
			self.mnuFlagLoadFrom.enabled 	:= false;
		
		else
			self.mnuFlagLoadTo.translateCaption(Xlat_0008934, locale);				// par 30475 Oct 2012
			self.mnuFlagLoadFrom.translateCaption(Xlat_0008933, locale);				// par 30475 Oct 2012
		endif;
		
		menuItem := self.mnuSetAutoAllocations;														// par 30475 Oct 2012

		if ta.type = TA_TYPE_BLOCK_STACK or ta.type = TA_TYPE_SUBBLOCK_STACK then			
			menuItem.visible := true;
			
			if ta.autoRestrictionsEnabled then
				menuItem.caption := app.getErrorString (YRD_TAEnq_AutoYAOff);							// par 30475 Oct 2012
			else
				menuItem.translateCaption(Xlat_0008938, locale);						// par 30475 Oct 2012
			endif;
		else
			menuItem.visible := false;
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="3901fb8b-88a6-4d1a-9301-1a176b14b052">
        <updating/>
        <source>doUserNotify(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating, protected;
// -------------------------------------------
// Created 19 February 2004 by cnwdvb1
// -------------------------------------------
vars

	termEvent	: Integer;
	terminal	: CM_Terminal;
	area		: CM_TerminalArea;
	row,
	rows,
	fixed,
	selectedRow	: Integer;
	tableRow	: JadeTableRow;
	obj			: Object;
	str			: String;
	tmpTable	: CM_DataTable;
	selectedTA	: CM_TerminalArea;
	objectOid	: String;
	isFound		: Boolean;
	
	invalidObj : Boolean;
	edition : Integer;
begin

	terminal 	:= self.myTerminal;
	termEvent 	:= terminal.getEventFromTerminalEvent(_eventType);
	
	// Yard allocation delete is taken care of by a  EVENT_REFRESH_GRID_AREA note
	if CM_TerminalArea.hasInstance(_theObject) and termEvent = EVENT_REFRESH_GRID_AREA then
		objectOid := _theObject.String;
	else
		return;
	endif;

	tmpTable 	:= self.tblData;
	selectedRow := tmpTable.row;
	rows 		:= tmpTable.rows;
	fixed 		:= tmpTable.fixedRows;
	
	on Exception do app.handleDeletedObject( exception, obj, invalidObj );
	
	foreach row in fixed to rows do
		tableRow 	:= tmpTable.accessRow(row);
		obj 		:= tableRow.itemObject;
		
		//06 Nov 2013	NDL	Par 32050 - User deleted a terminal area that 3 other users were still viewing!!!
		invalidObj := false;
		if obj &lt;&gt; null then
			edition := obj.edition;
		else	//22 Jul 2014	NDL	Par 34606
			continue;
		endif;
		if invalidObj then
			self.doRefresh();
			return;
		endif;
		
		
		if (objectOid &lt;&gt; null and obj.String = objectOid) then// or self.allAreasForNotes.includes(obj.CM_TerminalArea) then
			area := obj.CM_TerminalArea;
			
			tmpTable.removeItem(row);
			
			isFound := true;
			
			if row = selectedRow then
				selectedTA := area;
			endif;
			str := area.getAttributeStringForDefArray(tmpTable.allTblDataEntRows);
		 	tmpTable.addItemAt(str,row);
			tableRow := tmpTable.accessRow(row);
			tableRow.itemObject := area;
			
			break;
		endif;
	endforeach;
	
	if not isFound and global.isValidObject(_theObject) then
		area := _theObject.CM_TerminalArea;
		
		if self.allTATypes.includes(area.myType) then
			str := area.getAttributeStringForDefArray(tmpTable.allTblDataEntRows);
			row := tmpTable.addItem(str);
			
			tmpTable.accessRow(row).itemObject := area;
			tmpTable.resort();
		endif;
	endif;
	
	// Check whether row still exists.
	if selectedRow &lt;= tmpTable.rows then /// par13741 Mohammad
		tmpTable.row := selectedRow;
		tmpTable.accessRow(selectedRow).selected := true;
		
		if selectedTA &lt;&gt; null then
			self.showExtraInfo(selectedTA);
		endif;
	endif;
	
	self.colorRows();	//22 July 2014 NDL	Par 34606 - Just do it once at the end
	
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="e9f291f3-5947-4187-8338-e9f93dfa88fa">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------------------
//Created: 15 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	sptStr,
	xmlStr			: String;
	theDataTable	: CM_DataTable;
	strArray		: StringArray;
	availCode		: Integer;
	searchTbl		: CM_EntryTable;
begin

	xmlStr := inheritMethod();

		
	sptStr := global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' name="sptMain"') &amp;
		   global.formatAsXML(XMLTag_Ratio, self.sptMain.leftToRightRatio.String) &amp;
		   global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' name="sptMain"');

	xmlStr := xmlStr &amp; sptStr &amp; self.tblData.getXmlStrForColumns(true);
	searchTbl := self.tblSearch;
	
	create strArray transient;
	strArray.add('type');
	xmlStr := xmlStr &amp; self.tblFloatingList.getXMLStringForSelected(strArray);
	
	//tblSearch settings
	// CCMS 1235
	if self.cmbAvailGrade.myObject &lt;&gt; null then
		availCode := self.cmbAvailGrade.myObject.CM_MTGrade.code;
	endif;
	
	strArray.clear();
	strArray.add('code');
	xmlStr := xmlStr &amp; self.lstOperators.getXMLStringForSelected(strArray) &amp;
						global.formatAsXML(ETRow_FiltISOGroup, searchTbl.getValueByName(ETRow_FiltISOGroup).String) &amp;
						global.formatAsXML(ETRow_FiltISOType, searchTbl.getValueByName(ETRow_FiltISOType).String) &amp;
						global.formatAsXML(ETRow_FiltIsClean, searchTbl.getValueByName(ETRow_FiltIsClean).String) &amp;
						global.formatAsXML(ETRow_FiltIsPTI, searchTbl.getValueByName(ETRow_FiltIsPTI).String) &amp;
						global.formatAsXML(ETRow_FiltAvailGrade, availCode.String) &amp;
						global.formatAsXML(ETRow_FiltHasRemarks, searchTbl.getValueByName(ETRow_FiltHasRemarks).String) &amp;
						global.formatAsXML(ETRow_FiltHeldRoad, searchTbl.getValueByName(ETRow_FiltHeldRoad).String) &amp;
						global.formatAsXML(ETRow_FiltHeldRail, searchTbl.getValueByName(ETRow_FiltHeldRail).String);
						
	
	
	return xmlStr;
epilog
	delete strArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hideSearcher" id="7e19826f-5c6c-43b2-81d0-caa186c0fc99">
        <updating/>
        <source>hideSearcher() updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.isSearcherVisible := false;
	self.frmSearch.visible := false;

	self.tblData.enabled := true;
	self.btnCancelBase.enabled := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="includeType" id="012926cf-341f-4796-9cee-6227205853da">
        <source>includeType(_type :CM_TerminalAreaType):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     09 March 2010 by cnwcs5
// Purpose:     par 22687 - 
// Parameters:  None
// Returns:     true if _type is terminal area type that should be ioncluded in search
//				false means _type will not be included in the list of terminal area types
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _type.type = TA_TYPE_BUILDING or
	   _type.type = TA_TYPE_SWAP then
		return false;
	endif;
	
	if _type.getIsNotAvailableForEntry() then
		return false;
	endif;
	
	if _type.isGantryLaneAreaType then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="CM_TerminalAreaType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesTI" id="dbad3e7d-15cb-4cee-ae61-82942f5bdcf0">
        <source>includesTI(_ti : CM_TrackedItem) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     15 March 2004	cnwth2
//
// Purpose:     Boolan criteria only match true with true (eg. isClean with isClean)
//			 
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	tmpContainer			: CM_Container;
begin
	if _ti = null then
		return false;
	endif;
	
	if CM_Container.hasInstance(_ti) then
		tmpContainer := _ti.CM_Container;
		if (self.filterIsPTI and not tmpContainer.getPreTripDT.isValid) or
		   (self.filterIsClean and not tmpContainer.isClean) or
   		   (self.filterISOTypeCode &lt;&gt; null and self.filterISOTypeCode &lt;&gt; tmpContainer.isoType) or
   		   (self.filterAvailGrade &lt;&gt; null and self.filterAvailGrade &lt;&gt; tmpContainer.availabilityGrade) then
			return false;
		endif;
	endif;
	
	if (not self.allFilterOperators.isEmpty and not self.allFilterOperators.includesKey(_ti.operatorCode)) or
	   (self.filterISOTypeGroupCode &lt;&gt; null and self.filterISOTypeGroupCode &lt;&gt; _ti.isoTypeGroup) or
	   (self.filterHasRemarks and not _ti.hasRemarks) or
	   (self.filterHeldRoad and not _ti.isHeldForReleaseRoad) or
	   (self.filterHeldRail and not _ti.isHeldForReleaseRail) or
	   (self.filterReceivedFrom &lt;&gt; null and _ti.receivedDT.date &lt; self.filterReceivedFrom) or
	   (self.filterReceivedTo &lt;&gt; null and _ti.receivedDT.date &gt; self.filterReceivedTo) then
		return false;
	endif;	

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="89c1ceb5-9097-4899-bb1b-ab48024c6a82">
        <updating/>
        <source>initDataTable()updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 12 September 2003
//
//-----------------------------------------------------------------------

vars
	theTable	:	CM_DataTable;
	theDef		:	EntTableDef;
	
begin
	
	theDef := app.myController.getEntTableDef(ETDef_TAEnq);
	theTable := self.tblData;
	theTable.wordWrap := true;
	theTable.partialTextIndication := true;
 	theTable.setMyDataClass(CM_TerminalArea);

	theTable.setTblDataEntRowsFromDef(theDef);
	theTable.myDynaDict.addMemberKey('id', false, true);
	theTable.myDynaDict.endKeys(true);
	
	theTable.userInputEnabled := false;
	theTable.selectionType := CM_BaseTable.SelectionType_Row;
	theTable.alignment := Table.Alignment_Left_Top;
	self.setColorsForTable(theTable);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="45ad8e39-b003-40c3-9f4b-0a6802db6b03">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     17 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	str,
	tmpStr	: String;
begin
	inheritMethod(_userWindow);
	
	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_Splitter &amp; ' name="sptMain"');
	if str &lt;&gt; null then
		tmpStr := str.cnEcGetTagValueOfName(XMLTag_Ratio);
		if tmpStr &lt;&gt; null then
			self.sptMain.setLeftToRightRatio(tmpStr.Integer);
		endif;
	endif;
	

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initSearchFrame" id="a7302ee9-856a-4c13-813c-0b5d1ab55761">
        <source>initSearchFrame();
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 01/11/2012	cnwcs5	par 30475 - tidy up translations
vars
	frm					: CMUI_MoveableFrame;
	label				: CMUI_Label;
	entTableDef			: EntTableDef;
	tbl					: CM_EntryTable;
	fld					: CMUI_Folder;
	sht					: CMUI_Sheet;
begin

	frm 			:= self.frmSearch;
	frm.backColor 	:= self.backColor;
	frm.width 		:= 300;
	frm.height 		:= 400;
	
	frm.cnEcResizeContents();
	
	label		:= self.lblSearch;
	label.top 	:= 5;
	label.left 	:= 5;

	tbl 		:= self.tblSearch;
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TASearch];
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Entry table definition not found for search table');
		return;
	endif;
	
	tbl.setTerminologyRelevant(null, self.myTerminal);
	tbl.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	tbl.adjustHeight(200);
	
	sht := self.shtAreaTypes;
	
	self.tblFloatingList.move(5, 20, sht.width - 15, sht.height - 30);
	
	self.fldSearch.top 	:= self.frmToolbarSearch.height;
	frm.visible 		:= true;
	
	frm.centreWindow;
end;</source>
    </JadeMethod>
    <JadeMethod name="initSearchSettingsFromUserWin" id="43336ee7-34de-41fd-8c86-d81ba48b2e84">
        <source>initSearchSettingsFromUserWin() protected;
// ---------------------------------------------------------------------------
// Created:     11 March 2004	cnwth2
//
// Purpose:     Intentionally not re-implementing initFromUserWindow as this (inexplicably) occurs
//				before the setupForm, or first activate when controls have not yet been populated.
//				Called as last method of loadDataForFirstTime
//			 
// ----------   ----------  --------------------------------------------------
vars
	taType			: CM_TerminalAreaType;
	startPos		: Integer;
	tbl				: CMUI_ListTable;
	block,
	selectedValue	: String;
	objArray		: ObjectArray;
	taTypesDict		: CM_TATypeByTypeDict;
	userWindow		: CM_UserWindow;
begin

	userWindow := self.myUserWindow;
	if userWindow = null then
		return;
	endif;
	
	taTypesDict := app.myRoot.allTerminalAreaTypes;
	block := userWindow.xmlInfo.cnEcGetTagValueOfName(CMUI_ListTable.XMLTag_ListTable &amp; self.tblFloatingList.name);
	tbl := self.tblFloatingList;
	create objArray transient;
	startPos := 1;
	
	while startPos &lt;&gt; 0 do
		selectedValue := block.cnEcGetNextTagValueOfName(CMUI_ListTable.XMLTag_SelectedValue, startPos);
		if selectedValue &lt;&gt; null then
			taType := taTypesDict[selectedValue.Integer];
			if taType &lt;&gt; null then
				objArray.add(taType);
			endif;
		endif;
	endwhile;
	
	tbl.setSelected(objArray);

epilog
	delete objArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="b695b9f7-bec6-4411-8f88-7df9d301bb73">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if keyCode = CMUI_Key_F3 then
		self.frmSearch.visible := not self.frmSearch.visible;
		return;
	endif;

	inheritMethod(keyCode, shift);

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="286722a3-6fe7-4521-a3cd-ea1f8e2d6f0b">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 March 2004	cnwth2
//
// ----------   ----------  --------------------------------------------------
// 08/02/2010	cnwmh5		PAR 22377 - Add handleDeletedObject test so if 
//							myUserWindow has been deleted will act as if 
//							opening form for first time.
// 10/03/2011	cnwmh5		PAR #27142 - Change where handleDeletedObject is armed
vars
	userWindow			: CM_UserWindow;
	searchTbl			: CM_EntryTable;
	invalidWindow		: Boolean;
	
begin
	inheritMethod();
	
	self.doLoadAvailabilityGrades();
	self.doLoadISOGroups();
	self.doLoadISOTypes();
	self.doLoadOperators();
	self.doLoadTATypes();
	self.initSearchSettingsFromUserWin();
	
	searchTbl 	:= self.tblSearch;
	userWindow 	:= self.myUserWindow;
	
	if userWindow &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, userWindow, invalidWindow);	// 18/02/2010 cnwmh5 #22377
		searchTbl.setValueByName(ETRow_FiltIsClean, userWindow.xmlInfo.cnEcGetTagValueOfName(ETRow_FiltIsClean));
		searchTbl.setValueByName(ETRow_FiltIsPTI, userWindow.xmlInfo.cnEcGetTagValueOfName(ETRow_FiltIsPTI));
		searchTbl.setValueByName(ETRow_FiltHasRemarks, userWindow.xmlInfo.cnEcGetTagValueOfName(ETRow_FiltHasRemarks));
		searchTbl.setValueByName(ETRow_FiltHeldRail, userWindow.xmlInfo.cnEcGetTagValueOfName(ETRow_FiltHeldRail));
		searchTbl.setValueByName(ETRow_FiltHeldRoad, userWindow.xmlInfo.cnEcGetTagValueOfName(ETRow_FiltHeldRoad));
	endif;

	self.doResetReceivedDates();
	
epilog
	// 18/02/2010 cnwmh5 #22377 - Start
	// If it has been deleted then set to null so acts like 1st time loaded
	if invalidWindow then
		self.myUserWindow := null;
	endif;
	// 18/02/2010 cnwmh5 #22377 - End
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstOperators_lostFocus" id="3f9a4de6-dd84-467f-9203-8a81148d6792">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstOperators_lostFocus(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2004	cnwth2
//
// ----------   ----------  --------------------------------------------------
vars
	tbl : CM_EntryTable;
begin
	//display a list of StopsTable codes	
	tbl := self.tblSearch;
	
	self.myAssistant.listTableLostFocus(tbl, self.saveRowHeight, self.lstOperators, CM_Operator::code.name, false);
	
	tbl.adjustHeight(300);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
