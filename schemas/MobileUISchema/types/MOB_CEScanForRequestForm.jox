    <JadeMethod name="setupCargoIDsTable" id="284a5a61-ba38-42a4-b46b-cd81269cfbad">
        <source>setupCargoIDsTable(tbl : CM_MobTable input; intColumns  :Integer io; strHeader : String io);
// ---------------------------------------------------------------------------
// Created:     17 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	tbl.enabled := true;
	tbl.selectMode := tbl.SelectMode_WholeRows;
	tbl.multiSelect := true;
	tbl.columns := intColumns;
	tbl.fixedColumns := 0;
	tbl.rows := 0;
	tbl.addItem(strHeader);
	tbl.fixedRows := 1;
	tbl.defaultRowHeight := 30;
	tbl.rowHeight[1] := 30;
	tbl.gridLines := true;
	tbl.gridColor := Black;
	tbl.alignment := Table.Alignment_Center_Middle;
	tbl.fixed3D := false;
	tbl.setUseHighlightColours(false);
	tbl.setFixedColours();
end;
</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
        <Parameter name="intColumns" type="Integer" usage="io"/>
        <Parameter name="strHeader" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fecb96cf-20bd-4f95-b254-a353bbf72b57">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	intColumns  :Integer;
	strHeader : String;
begin
	inheritMethod();
	
	self.myCargoTI := self.myMainObject.CM_TrackedItem;
	
	if self.allBulkReleases.size &lt;&gt; 0 then
		self.setupPackingTable(self.tbl_PackingRqst, intColumns, strHeader);
		self.loadPackingReqTbl(self.tbl_PackingRqst);
	else
		self.sht_Request.visible := false;
	endif;
	
	self.setupCargoIDsTable(self.tbl_CargoIDs, intColumns, strHeader);
	self.loadCargoIDsTbl(self.tbl_CargoIDs);
	self.txt_CargoID.case := txt_CargoID.Case_Upper;
	
	self.doEnableControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupPackingTable" id="42f90df4-3e77-4b6a-a8f6-ee9920928088">
        <source>setupPackingTable(tbl : CM_MobTable io; intColumns  :Integer io;strHeader : String io);
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	tbl.enabled := true;
	tbl.selectMode := tbl.SelectMode_CurrentRow;
	tbl.fontSize := 14;
	tbl.columns := intColumns;
	tbl.fixedColumns := 0;
	tbl.rows := 0;
	tbl.addItem(strHeader);
	tbl.fixedRows := 1;
	tbl.defaultRowHeight := 30;
	tbl.gridLines := true;
	tbl.gridColor := Black;
	tbl.alignment := Table.Alignment_Center_Middle;
	tbl.fixed3D := false;
	tbl.setFixedColours();
end;
</source>
        <Parameter name="tbl" type="CM_MobTable" usage="io"/>
        <Parameter name="intColumns" type="Integer" usage="io"/>
        <Parameter name="strHeader" type="String" usage="io"/>
    </JadeMethod>
