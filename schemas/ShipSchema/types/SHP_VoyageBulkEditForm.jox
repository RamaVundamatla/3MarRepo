    <JadeMethod name="addToolbarControls" id="10a92bff-83a1-4be1-a541-54bfb2985c09">
        <updating/>
        <source>addToolbarControls() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars
	toolbar : CMUI_Toolbar;
	showCaptions : Boolean;

begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	showCaptions := toolbar.showCaptions;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnColourLegend, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls;
	toolbar.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
