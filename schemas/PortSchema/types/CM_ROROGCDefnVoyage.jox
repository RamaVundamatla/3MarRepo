    <JadeMethod name="setForCreate" id="f89ff3bd-11cc-48c0-b411-2626d9756704">
        <updating/>
        <source>setForCreate(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
//	tmpVessel : CM_Vessel;
	allStateData : CM_StateDataDict;
	roroDeckLabelPrefix : String;
	theVoyage : CM_Voyage;
	theTerminal : CM_Terminal;
begin


	inheritMethod(_proxyDeckItem, _passport);

	self.myVoyageStructure := _proxyDeckItem.myVoyageStructure;
	
// PAR 30388	theVoyage := self.myVoyageStructure.myVoyage;
	theVoyage := self.myDeck.CM_DeckVoyage.getVoyage();
	theTerminal := theVoyage.myTerminal;

	/*
	tmpVessel := self.myDeck.getVessel();
	
	if tmpVessel  &lt;&gt; null then
		allStateData:= tmpVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	*/
	allStateData := self.myDeck.getAllStateDataObject(); // PAR 28971
	
	global.getExtraData(allStateData,RoRoDeckLabelPrefix,roroDeckLabelPrefix);

	// Prefix location code with deck details
	self.setCode( _proxyDeckItem.code, false ); // this is set from a method that get a unique auto code. //roroDeckLabelPrefix &amp; self.myDeck.code &amp; self.code;

//	self.myDeckLayerLayout.causeEvent(EVENT_RORO_LAYER_UPDATE,false,null);
	
	self.createGCController();

	
	self.myDeckLayerLayout.myDeckLayout.hideContainerPositionsUnderGC(self.myLayout); // PAR 27749
	
	

	app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								self.myGCController);
	
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPointsPolygon" id="5b3a4fa4-2de1-452d-b188-00c09a83d32c">
        <updating/>
        <source>setPointsPolygon(_newPoints: PointArray) updating;
/*
Purpose:			
Date		Who		Reason
29 June 2011	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(_newPoints);

	if self.myGCController &lt;&gt; null and self.myGCController.myRORORequestDischarge &lt;&gt; null then
		self.myGCController.myRORORequestDischarge.myLayout.setPointsPolygon(_newPoints);
	elseif self.myGCController &lt;&gt; null and self.myGCController.myRORORequestLoad &lt;&gt; null then
		self.myLayout.setPointsPolygon(_newPoints);
	endif;

epilog

end;</source>
        <Parameter name="_newPoints" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="698e996c-481b-4d4b-b404-0f3edaca4515">
        <updating/>
        <source>setProxy(_structure: CM_ROROVoyageStructure;
		_code: String; 
		_desc: String; 
		_remarks: String; 
		_deckItemLayout: CM_DeckItemLayout; 
		_deck: CM_Deck; 
		_deckLayerLayout: CM_DeckLayerLayout;
		_xMetres,_yMetres : Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	inheritMethod(_structure, _code,_desc,_remarks,_deckItemLayout,_deck, _deckLayerLayout, _xMetres,_yMetres);

	self.myVoyageStructure:=_structure;
epilog

end;</source>
        <Parameter name="_structure" type="CM_ROROVoyageStructure"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_deckLayerLayout" type="CM_DeckLayerLayout"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="5eda30b7-2590-4805-8426-9a4ff761f336">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	//cnwmc5 - 17 Dec 2013 - PAR 32269 - add validation..
	if self.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
		app.raiseCMException1(Cannot_delete_becaus_colour_co,self.code, null, null);
	endif;
	if self.hasColourCoding(DISCHARGE_MOVETYPE) &lt;&gt; null then
		app.raiseCMException1(Cannot_delete_becaus_colour_co,self.code, null, null);
	endif;
	if self.hasTIs(REAL_MODE) then
		app.raiseCMException1(Cannot_delete_becaus_actual_ca,self.code, null, null);
	endif;
	if self.hasTIs(PLANNING_MODE) then
		app.raiseCMException1(Cannot_delete_becaus_planne_ca,self.code, null, null);
	endif;
	if self.hasTIs(QUEUE_MODE) then
		app.raiseCMException1(Cannot_delete_becaus_queued_ca,self.code, null, null);
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
