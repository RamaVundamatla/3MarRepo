    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="fb596cc8-fa60-4aff-8e65-e169238d37eb">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
15 Jul 2022 navcs2  ChangeRequest 53932: MTN - Jobs Changes
04 Jul 2023 namva1	Bug 58976: MTN - Error 14008 when opening Release Rail Work orders
*/

vars
	block 				: CM_DataContainerBlock;
begin
	inheritMethod(_dataContainer);

	//1.6.2022 navma1 #52351
	if self.myBookingRef &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Booking), DC_Label, 1, null);
		block.addNewItem(self.myBookingRef.bookingReference, DC_Data, 1, null);	
	endif;
	
	// 19/07/2022 navcs2 53932
	if self.getPINNumber &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Pin_no), DC_Label, 1, null);
		block.addNewItem(self.getPINNumber, DC_Data, 1, null);
	endif;
	
	if self.myTrain &lt;&gt; null then											//04.07.2023 navma1 #58976
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Train), DC_Label, 1, null);
		block.addNewItem(self.myTrain.code, DC_Data, 1, self.myTrain);	
	endif;
	
	if self.myVoyage &lt;&gt; null then											//04.07.2023 navma1 #58976
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Voyage), DC_Label, 1, null);
		block.addNewItem(self.myVoyage.code, DC_Data, 1, self.myVoyage);	
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInstructionsForContext" id="c7d81d4b-0540-4d70-a291-6368e66306af">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2023	navma1	ChangeRequest 60066: FR 53127 | EUP - Additional Operational Instructions on the Order (Web)
11 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
*/

vars
	bol			: CM_BOL;
	bookingRef	: CM_BookingRef;
begin
	inheritMethod(_instructions, _passingObject, _context);
	
	bol := self.myBillOfLading;
	bookingRef := self.myBookingRef;
	
	if bol &lt;&gt; null then				//11.10.2023 navnk30 #59946
		bol.getInstructionsForContext(_instructions,self.myBillOfLadingDtl,_context);
	endif;
	
	if bookingRef&lt;&gt; null then				//11.10.2023 navnk30 #59946
		bookingRef.getInstructionsForContext(_instructions, self.myBookingRefItem, _context);
	endif;
	
epilog

end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageObject" id="6f6e131f-c75f-4c9b-8b76-0dc113b8bcee">
        <source>getMyVoyageObject(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2019	jlgndl1	Initial creation	TFS 43019
02 Feb 2024	navma1  Bug 62220: MTN - work order enquiry doesn't seem to search as expected App
*/

vars

	invalid : Boolean;
	edition : Integer;
	voyage	: CM_Voyage;
	booking : CM_BookingRef;
begin
	
	on Exception do app.handleDeletedObject( exception, self.myBookingRef, invalid );
	on Exception do app.handleDeletedObject( exception, self.myVoyage, invalid );
	
	booking := self.myBookingRef ;
	
	if booking &lt;&gt; null then
		edition := booking.edition;
		if not invalid then
			return booking.myVoyage;
		endif;
	endif;
	
	voyage := self.myVoyage;
	
	if voyage &lt;&gt; null then
		edition := voyage.edition;
		if not invalid then	
			return voyage;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
