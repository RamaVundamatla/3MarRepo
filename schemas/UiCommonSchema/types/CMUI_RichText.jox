<GUIClass name="CMUI_RichText" id="2543bf02-01f9-470f-bc08-60f7cc3da61e">
    <superclass name="JadeRichText"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myFindDialog" id="d00046b0-84bb-47f6-8651-b59423c0f9c6">
        <embedded/>
        <type name="Form"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="15357dee-a7b9-4bfd-80da-02907f89c6a6">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		09 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31 Mar 2016	cnwkpd1		Changes for JADE 7.1
// --------------------------------------------------------------------------------
vars
	
begin
	if app.isValidObject(self.myFindDialog) then
		delete self.myFindDialog;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showFindDialogJmt" id="402de9bb-c240-488b-a16b-a3b057ffca2d">
        <updating/>
        <source>showFindDialogJmt(pIsFindOnly, pIsClearSelection:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		09 January 2006 by cnwdad1
//
// Purpose:		Shows the receiver's Find/Replace dialog.
//
// Parameters:	pIsFindOnly - True if "replace" capability is not required.
//				pIsClearSelection - True if current selection should be cleared.  If
//					not then Jade only searches the selected text
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31 Mar 2016	cnwkpd1		Changes for JADE 7.1
// --------------------------------------------------------------------------------
vars
	
begin
	if pIsClearSelection then
		self.selLength := 0;
	endif;

	self.myFindDialog := self.findReplaceDialog(pIsFindOnly, 0, 0);
	self.myFindDialog.centreWindow();

epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pIsFindOnly" type="Boolean"/>
        <Parameter name="pIsClearSelection" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="467f298a-f4f7-44cc-9ab0-6f713ca50d4f">
        <controlMethod name="JadeRichText::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		09 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	self.contextMenuOptions	:=	self.MenuOption_None;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
