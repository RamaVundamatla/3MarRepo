    <JadeMethod name="getDisplay" id="02f69af1-ab6f-45e2-9fcd-78d6ad9f4a43">
        <source>getDisplay(dataObj: Object): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2013	cnwdap1		Initial creation PAR #32215
