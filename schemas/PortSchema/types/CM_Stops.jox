/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2011	#cnwdz2	 27436

*/

vars
	
begin
	if self.myStopsTable &lt;&gt; null then
		return self.myStopsTable.heading;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
