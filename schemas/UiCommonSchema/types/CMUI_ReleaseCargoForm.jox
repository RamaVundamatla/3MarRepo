    <JadeMethod name="cmbType_click" id="de4d99f4-508b-4806-8206-017a156e618c">
        <controlMethod name="Frame::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbType_click(frame: Frame input) updating;
// --------------------------------------------------------------------------------
// Created:		6 April 2010 by cnwjo3
//
// Purpose:		whenever we change the cargo type we'll need to update the list of available TIs
//				par 23536
//
vars

begin
	if self.myBulkRelease &lt;&gt; null then
		if self.myBulkRelease.releaseByType then
			self.setAvailableTIs(self.myBulkRelease);
		endif;
	endif;
end;</source>
