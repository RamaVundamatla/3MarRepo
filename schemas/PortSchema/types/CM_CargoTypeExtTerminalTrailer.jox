<Class name="CM_CargoTypeExtTerminalTrailer" id="78270751-81b6-4782-8bd1-c113c75f7585">
    <superclass name="CM_CargoTypeExtTILC"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="canHaveFlexibleLengths" id="23fd70ca-841b-4b03-a9b2-693a9b0427b1">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isReefer" id="036fd6fc-f8f0-43bb-915f-4ac6ea3e623c">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="maxHeight" id="b0fe4d94-6967-4b2e-8833-5c2a9a8f974b">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="maxWeight" id="3caee5e1-80d7-4212-b11e-502a57f26774">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
        <text>29/12/2008 cnwsh3 - SFW CCMS1060 Changed to Decimal[14,4] to allow for accommodating imperial and metric.</text>
    </PrimAttribute>
    <PrimAttribute name="numberOfLocationControllers" id="f470f334-40e1-4dc2-bc3c-cfb920461074">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Not sure about this attribute. May be able to extrapolate this from number of tis divided by height</text>
    </PrimAttribute>
    <JadeMethod name="createTILCType" id="36fc7149-f2fc-49fc-8708-83ac2e1e484f">
        <source>createTILCType() : CM_TILCType;
// -------------------------------------------
// Created 06 December 2005 by cnwdvb1
// -------------------------------------------
vars

	type	: CM_TILCType;


begin

	type	:= inheritMethod();

	type.updateAttributeOfType(CM_TILCType.Type_CanHaveFlexibleLengths, self.canHaveFlexibleLengths);	
	type.updateAttributeOfType(CM_TILCType.Type_Length, null);	
	type.updateAttributeOfType(CM_TILCType.Type_IsReefer, self.isReefer);	
	type.updateAttributeOfType(CM_TILCType.Type_MaxHeight, self.maxHeight);	
	type.updateAttributeOfType(CM_TILCType.Type_MaxWeight, self.maxWeight);	

	
	return type;

end;</source>
        <ReturnType type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="getAttributeValue" id="16e71a0a-926d-46ab-b307-b1f050df0462">
        <source>getAttributeValue(_attribute: String): Any;
// -------------------------------------------
// Created 24 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _attribute = CM_CargoTypeExtTerminalTrailer::canHaveFlexibleLengths.name then
		return self.canHaveFlexibleLengths;
	elseif _attribute = CM_CargoTypeExtTerminalTrailer::isReefer.name then
		return self.isReefer;
	elseif _attribute = CM_CargoTypeExtTerminalTrailer::maxHeight.name then
		return self.maxHeight;
	elseif _attribute = CM_CargoTypeExtTerminalTrailer::maxWeight.name then
		return self.maxWeight;
	elseif _attribute = CM_CargoTypeExtTerminalTrailer::numControllers.name then
		return self.numControllers;
	endif;
	return inheritMethod(_attribute);


end;</source>
        <Parameter name="_attribute" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getExtraData" id="6ebff697-c8f5-40da-92e3-ae9bbc9c01b0">
        <source>getExtraData(_allData: StringArray input);
// -------------------------------------------
// Created 09 November 2005 by cnwdvb1
// -------------------------------------------
begin

	
	return;
	_allData.add('');
	_allData.add(app.getErrorString(Maximum_Weight) &amp; Tab &amp; self.maxWeight.asStringWeightJMT());
	_allData.add(app.getErrorString(Maximum_Height) &amp; Tab &amp; self.maxHeight.String);
	_allData.add(app.getErrorString(Number_Of_Locations) &amp; Tab &amp; self.numControllers.String);
	_allData.add(app.getErrorString(Can_Have_Flexible_Lengths) &amp; Tab &amp; self.canHaveFlexibleLengths.getYesNo());
	_allData.add(app.getErrorString(Is_A_Reefer) &amp; Tab &amp; self.isReefer.getYesNo());

end;</source>
        <Parameter name="_allData" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraDetailForType" id="67319c5e-0fbc-4c02-9d7d-5a59e4fef2dd">
        <source>getExtraDetailForType(_allData: StringArray input; _type: CM_TILCType);
// -------------------------------------------
// Created 07 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_allData, _type);
	
	_allData.add(app.getErrorString(Maximum_Weight) &amp; Tab &amp; _type.maxWeight.asStringWeightJMT());
	_allData.add(app.getErrorString(Maximum_Height) &amp; Tab &amp; _type.maxHeight.String);
	_allData.add(app.getErrorString(Number_Of_Locations) &amp; Tab &amp; _type.numControllers.String);
	_allData.add(app.getErrorString(Can_Have_Flexible_Lengths) &amp; Tab &amp; _type.canHaveFlexibleLengths.getYesNo());
	_allData.add(app.getErrorString(Is_A_Reefer) &amp; Tab &amp; _type.isReefer.getYesNo());

end;</source>
        <Parameter name="_allData" type="StringArray" usage="input"/>
        <Parameter name="_type" type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0cb0327e-1307-4d25-a44d-e14bf3037c5f">
        <updating/>
        <source>setForUpdate(_pxyExtension: CM_CargoTypeExtTerminalTrailer) updating;
// -------------------------------------------
// Created 25 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.canHaveFlexibleLengths				:= _pxyExtension.canHaveFlexibleLengths;
	self.isReefer							:= _pxyExtension.isReefer;
	self.maxHeight							:= _pxyExtension.maxHeight;
	self.maxWeight							:= _pxyExtension.maxWeight;
	// Only done in set for create.
//	self.numberOfLocationControllers		:= _pxyExtension.numberOfLocationControllers;
	inheritMethod(_pxyExtension);


end;</source>
        <Parameter name="_pxyExtension" type="CM_CargoTypeExtTerminalTrailer"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromCMIF" id="6203cb3d-5bae-437e-8405-349434827a7a">
        <updating/>
        <source>setProxyFromCMIF(_cmif: CMIF_CargoTypeExt) updating;
// -------------------------------------------
// Created 25 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	inheritMethod(_cmif);
	self.canHaveFlexibleLengths			:= _cmif.ttCanHaveFlexibleLengths;
	self.isReefer						:= _cmif.ttIsReefer;
	self.maxHeight						:= _cmif.ttMaxHeight;
	self.maxWeight						:= _cmif.ttMaxWeight;

end;</source>
        <Parameter name="_cmif" type="CMIF_CargoTypeExt"/>
    </JadeMethod>
    <JadeMethod name="setPxyTypeFromCMIF" id="1b386d6f-fc3d-443e-9568-9a28975179c3">
        <updating/>
        <source>setPxyTypeFromCMIF(_type: CM_TILCType input; _cmif: CMIF_CargoTypeExt) updating;
// -------------------------------------------
// Created 08 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	inheritMethod(_type, _cmif);
	_type.updateAttributeOfType(CM_TILCType.Type_CanHaveFlexibleLengths, _cmif.ttCanHaveFlexibleLengths);
	_type.updateAttributeOfType(CM_TILCType.Type_IsReefer, _cmif.ttIsReefer);
//	_type.updateAttributeOfType(CM_TILCType.Type_Length, _cmif.description);
	_type.updateAttributeOfType(CM_TILCType.Type_MaxHeight, _cmif.ttMaxHeight);
	_type.updateAttributeOfType(CM_TILCType.Type_MaxWeight, _cmif.ttMaxWeight);



	


end;</source>
        <Parameter name="_type" type="CM_TILCType" usage="input"/>
        <Parameter name="_cmif" type="CMIF_CargoTypeExt"/>
    </JadeMethod>
    <JadeMethod name="setTrackedItemDtl" id="6809933d-6d19-4a06-9f98-eed793dcee5d">
        <source>setTrackedItemDtl(_ti: CM_TrackedItem input; _type : CM_TILCType);
// -------------------------------------------
// Created 24 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	inheritMethod(_ti, _type);
	self.buildLocationControllers(_ti.CM_TILC, _type.numControllers, CM_TILCRow);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_type" type="CM_TILCType"/>
    </JadeMethod>
</Class>
