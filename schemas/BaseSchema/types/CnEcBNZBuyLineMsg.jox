    <JadeMethod name="checkExpiry" id="0185ad92-5860-4f2f-8dc1-3c2429e2c32c">
        <source>checkExpiry():String;

vars
	errorMessage	: String;
	today			: Date;
	expiryDate		: Date;
	
begin
	if expiryDate.isValid then
		expiryDate := self.expiry;
		expiryDate.setDate(today.day, expiryDate.month, expiryDate.year);
		
		if expiryDate &lt; today then
			errorMessage := "Credit Card Expiry date too old.  ";
		endif;
	else
		errorMessage := "Credit Card Expiry date invalid.  ";
	endif;
epilog
	return errorMessage;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
