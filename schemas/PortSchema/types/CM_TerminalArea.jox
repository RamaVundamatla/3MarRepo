    </JadeMethod>
    <JadeMethod name="archiveEmptyLocations" id="9546fc12-1048-4454-a69e-eeb6c85e7a3d">
        <source>archiveEmptyLocations(_numberOfHours : Integer; _overrideIgnore : Boolean; _errorSet : CM_ErrorSet input);
// ---------------------------------------------------------------------------
// Created:     09 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/* Changes

Date		Name	TFS#		Description
============================================================================
29/04/2013	cnwcs5	par 30652 	remove resynch/resynchObject method calls
30/05/2019	jlgka1	TFS 44953	C3 - Archive Rows - Recent Rows being Archived.
								Add more logging option.
============================================================================*/
vars
	lc			: CM_LocationsController;
	aheadTime, 
	now			: TimeStamp;
	lcSet 		: CM_LCSet;
	//jlgka1 TFS 44953 --&gt;
	msg	 		: String; 
	fromMoveOut : Boolean; 
	//jlgka1 TFS 44953 &lt;--
begin
	now := app.actualTimeServer;	
	
	create lcSet transient;
	foreach lc in self.allLocationsControllers do
		lcSet.add(lc);
	endforeach;
	
	foreach lc in self.CM_LogArea.allEmptyLogControllers do
		lcSet.add(lc);
	endforeach;
	
	//PAR 11693 Yi 08/01/2008
	//The row which status is Empty could not be archived because self.allLocationsControllers does not contain them.
	//The solution is to create a new set to include the rows which status are Open, Close and Empty. 
	//foreach lc in self.allLocationsControllers do //removed
	
	foreach lc in lcSet do		// resynch lc as do not want to lock unless we are going to update
		if lc.ignoreArchiving and not _overrideIgnore then
			continue;
		endif;
		
		// PAR 11693 Lorcan 060427 
		// made sure that archiving is done if the lastMoveOutDateTime is invalid
		//	if lc.numTIs = 0 and lc.lastMoveOutDateTime.isValid then //removed
			
		if lc.numTIs = 0 then
			if lc.lastMoveOutDateTime.isValid then
				aheadTime := lc.lastMoveOutDateTime.cnEcAddHours(_numberOfHours);
				fromMoveOut := true;	
			else
			    // if there was no log movements in the log location, then this must be a new location and need to wait 
				// _numberOfHours before we can remove it.
				aheadTime := lc.createdTime.cnEcAddHours(_numberOfHours); // Lorcan and Mohammad 28/7/2007 par#13950
				fromMoveOut := false;
				//aheadTime := null;
			endif;
			if aheadTime = null or aheadTime &lt; now then
				app.myTrxUA.trxArchiveEmptyLocation(lc, now, app.myPassport);
				if (not app.myPassport.trxCompletedOK) then
					app.writeLog('Archiving empty row ' &amp; lc.getID &amp; ' at ' &amp; now.String &amp; " had errors " &amp; CrLf  &amp; app.myPassport.getErrorsAsString, LogINFO );
					_errorSet.copyErrors(app.myPassport.allErrorWarnings);
				else // jlgka1 TFS 44958 --&gt;					
					msg := 'Archiving row ('  &amp; lc.getLocationSubArea &amp; ' '  &amp; lc.getID &amp; ') at ' &amp; now.asStringJMT;
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
					msg := 'Number of hours parameter value (_numberOfHours) equals ' &amp; _numberOfHours.asStringJMT;
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
					if fromMoveOut then
						msg := 'aHeadTime coming from lastMoveOutDateTime';
					else
						msg := 'aHeadTime coming from createdTime';
					endif;
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
				endif; // jlgka1 TFS 44958 &lt;--
			endif;
		endif;
		
	endforeach;
	
end;</source>
        <Parameter name="_numberOfHours" type="Integer"/>
        <Parameter name="_overrideIgnore" type="Boolean"/>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="autoPlan" id="ca4ce183-dc16-4b59-a8af-0c1a2e8a0434">
