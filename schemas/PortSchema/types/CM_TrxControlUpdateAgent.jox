    <JadeMethod name="trxUpdateDrawingAttrPriority" id="8895ee78-db86-4a2c-9efc-1b08c2804332">
        <updating/>
        <source>trxUpdateDrawingAttrPriority(_objArray:CM_ObjectArray;_reset : Boolean;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2017	jlgma1	Initial creation

*/

vars
	proxyDrawingAttribute  : CM_DrawingAttribute;
	idx : Integer;
	obj : Object;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	foreach  obj in _objArray do 
		if _reset then
			idx := 0;
		else
			idx := _objArray.indexOf(obj);
		endif;
		delete proxyDrawingAttribute;
		proxyDrawingAttribute := app.createUpdateProxy(obj.CM_DrawingAttribute).CM_DrawingAttribute;
		if proxyDrawingAttribute&lt;&gt; null then
			if proxyDrawingAttribute.priority &lt;&gt; idx then
				app.myUtilityUA.utlUpdateDrawingAttrPriority(proxyDrawingAttribute,idx, _passport);
			endif;
		endif;
	endforeach;

epilog
	self.finaliseActivityWithPassport(_passport);
	delete proxyDrawingAttribute;
end;</source>
        <Parameter name="_objArray" type="CM_ObjectArray"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
