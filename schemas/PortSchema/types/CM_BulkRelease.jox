    <JadeMethod name="isForty" id="5ef82a81-5535-4bc4-bf02-732d75a44598">
        <source>isForty():Boolean;
// --------------------------------------------------------------------------------
// Created:		30 November 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is for 40
//				containers.
//
// Parameters:	None
//
// Returns:		True if the receiver is for 40' containers, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	requestObj		: CM_Request;
	isoTypeObj		: CM_ISOType;
	isoTypeCode		: String;
	isoTypeGroupObj	: CM_ISOTypeGroup;
	isoTypeGroupCode: String;
	
begin
	requestObj	:=	self.requests.first();
	
	if requestObj.isKindOf(CM_DeliveryRequest) then
		isoTypeCode	:=	requestObj.CM_DeliveryRequest.isoType;
		isoTypeGroupCode	:=	requestObj.CM_DeliveryRequest.isoGroup;
		
		if isoTypeCode &lt;&gt; null then
			isoTypeObj	:=	app.myRoot.allISOTypes[isoTypeCode];
			
			if isoTypeObj &lt;&gt; null then
				return isoTypeObj.is40ftLong();
			endif;
		endif;
		
		//10 May 2010	NDL Par 24064
		if isoTypeGroupCode &lt;&gt; null then
			isoTypeGroupObj	:=	app.myRoot.allISOTypeGroups[isoTypeGroupCode];
			
			if isoTypeGroupObj &lt;&gt; null then
				return isoTypeGroupObj.is40ftLong();
			endif;
		endif;
		
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInRailOps" id="30afe484-8844-4def-8387-76fb8da4534f">
        <source>isInRailOps() : Boolean;
/*
Purpose:			
	Created:		November 2004 By Andrew Bishop cnwab1
Parameters:			

Return Value:		

Date		Who		Reason
24 Jul 2023	navma1	Bug 59261: MTN - Issues while assigning Release Rail request to work orders

*/
vars
	aReserve : CM_ReserveDetail;
	request  : CM_Request;
begin
	
	if self.type &lt;&gt; BR_TYPE_RAIL then
		return false;
	endif;
	
	foreach aReserve in self.allReserveDetails do
		request := aReserve.getRequest();
		if request &lt;&gt; null and not request.isWorkOrderRequest then	//SFW1035	//24.07.2023 navma1 #59261
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
