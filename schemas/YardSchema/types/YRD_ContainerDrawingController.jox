    <JadeMethod name="setFontDefaults" id="c57f2e34-9b87-470f-bb5b-19a62f919b8a">
        <updating/>
        <source>setFontDefaults() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*
Date		Who		Reason
05 Dec 2008 consw1	SFW1030 - Yard Allocation enhancements (include extra info with zoom)
*/

vars

	iAmPrinting : Boolean;
	lDisplayMode,
	lViewMode 	: Integer;
	lFactor 	: Real;
	theFontName	: String;
	theFontSize	: Real;
	thePrintStyle 	: Integer;

begin

	iAmPrinting := self.amPrinting;
	
	// reset so that the first redraw with frame will set for new font size
//	self.textExtent999 := 0;
	
	lFactor 	 	:= self.scaleFactor;
	lDisplayMode 	:= self.displayMode;
	lViewMode 	 	:= self.viewMode;
	thePrintStyle	:= self.printOutputStyle;

	theFontSize := (self.FontSize * self.scaleFactor.Integer);
	
	if self.tiHeight = Ti_Half_Height then
		if lFactor = 2 then
			theFontSize := theFontSize - 2;
		elseif lFactor = 3 then
			theFontSize := theFontSize - 5;
		elseif lFactor = 4 then
			theFontSize := theFontSize - 5;
		endif;
	endif;
	
	if lFactor = 1 then
		theFontSize := 8;
	elseif lFactor = 1.5 then
		theFontSize := 10;
	endif;	

	self.defaultFontSizeForAttributes	:= theFontSize;

	if self.defaultFontSizeForAttributes &gt; 14 then
		self.defaultFontSizeForAttributes := 14;
	endif;

/*
return;




	if iAmPrinting then
		if thePrintStyle = self.PrintOutput_Large then
			theFontName := Font_Helvetica;
			theFontSize := 6;
		elseif thePrintStyle = self.PrintOutput_Medium then
			theFontName := Font_MicrosoftSansSerif;
			theFontSize := 5.5;
		elseif thePrintStyle = self.PrintOutput_Small then
			theFontName := Font_MicrosoftSansSerif;
			theFontSize := 6;
		endif;
	else
		if lFactor = ScaleFactor_4 then
			theFontName := Font_Helvetica;
			theFontSize := 30;

		elseif lFactor = ScaleFactor_3 then
			theFontName := Font_Helvetica;
			theFontSize := 8;

		elseif lFactor = ScaleFactor_2 then
			theFontName := Font_MicrosoftSansSerif;
			theFontSize := 6;

		elseif lFactor = ScaleFactor_1_5 then
			theFontName := Font_MicrosoftSansSerif;
			theFontSize := 6;

		elseif lFactor = ScaleFactor_1 then
			theFontName := Font_MicrosoftSansSerif;
			theFontSize := 6;
		endif;
	endif;
	
	self.defaultFontName	:= theFontName;
	self.defaultFontSize	:= theFontSize;

*/
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a0cec6fa-d20b-4338-9219-65e18198e85d">
        <updating/>
        <source>setForCreate(_dockBar : YRD_ContainerGridAreaDockBar) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.myDrawingFrame := _dockBar.myDrawingFrame;
