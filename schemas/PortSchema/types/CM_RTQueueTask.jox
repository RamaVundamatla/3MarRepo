    <JadeMethod name="isUPSPWagon" id="2223b31c-fc7f-43aa-a443-11f84640cd12">
        <source>isUPSPWagon(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2017	cnwmp6	Initial creation

*/

vars
	loc: CM_WagonController;

begin
	if self.targetLocation &lt;&gt; null and self.targetLocation.isWagon() then
		loc := self.targetLocation.CM_WagonController;
	
		if loc.myWagon &lt;&gt; null and loc.myWagon.myTerminal &lt;&gt; null and loc.myWagon.myTerminal.getConfig(RailDefaultWCIdFormat).Integer = Rail_UPSP_Int then
			return true;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageLoadToCTA" id="a7176907-1128-4ad6-ada7-4a64ae53fc9d">
        <source>isVoyageLoadToCTA() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19/07/2010	cnwer1	Initial creation
24/06/2019	jlgdap1	TFS 44956 JMT Hold Planning Job Cargo Losing Planned Location on RT Move
								Expand this method to cater for Hold Planning (jobs planned to 
								General Cargo controllers and Ship block stacks)
*/

vars
	voyageCraneQueue : CM_VoyageCraneQueue;
	workPointQueue 	: CM_VoyageWorkPointQueue;
begin
	if self.targetLocation = null then
		return false;
	endif;
	
	if self.targetLocation.isKindOf(CM_SlotController) then
		//epr par 24877 6/7/10 
		voyageCraneQueue:= self.getVoyageCraneQueue;
		if voyageCraneQueue &lt;&gt; null and voyageCraneQueue.loadMachinesMode =CM_VoyageCraneQueue.UseShipLanderApp then
			return true;
		endif;
	endif;
	
	if self.targetLocation.isKindOf(CM_VoyageROROController) then
		workPointQueue:= self.getVoyageWorkPointQueue;
		if workPointQueue &lt;&gt; null and workPointQueue.loadMachinesMode =CM_VoyageCraneQueue.UseShipLanderApp then
			return true;
		endif;
	endif;
	
	//cnwrd1 par 30842 ccms 1303
	if self.targetLocation.isKindOf(CM_CraneLaneController) then
		voyageCraneQueue:= self.getVoyageCraneQueue;
		if voyageCraneQueue &lt;&gt; null and voyageCraneQueue.loadMachinesMode =CM_VoyageCraneQueue.UseShipLanderApp then
			return true;
		endif;
	endif;
	
	if self.targetLocation.isKindOf(CM_YardICAreaLaneController) and not self.targetLocation.isYardLocation then
		workPointQueue:= self.getVoyageWorkPointQueue;
		if workPointQueue &lt;&gt; null and workPointQueue.loadMachinesMode =CM_VoyageCraneQueue.UseShipLanderApp then
			return true;
		endif;
	endif;	
	
	// TFS 44956 start
	if self.targetLocation.isKindOf(CM_GeneralCargoController) then
		workPointQueue := self.getVoyageWorkPointQueue;
		if workPointQueue &lt;&gt; null and workPointQueue.loadMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp then
			return true;
		endif;
	endif;
	if self.targetLocation.isKindOf(CM_ShipBlockController) then
		workPointQueue := self.getVoyageWorkPointQueue;
		if workPointQueue &lt;&gt; null and workPointQueue.loadMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp then
			return true;
		endif;
	endif;
	// TFS 44956 end
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWithinSeparationLimits" id="fcbbae93-54f4-4b5e-b7da-664dd008eb62">
        <source>isWithinSeparationLimits(sourceLocn	:	CM_LocationsController)	:	Boolean;
//Returns TRUE if this task is working within "separation limit" in a straddle
//row to the supplied sourcelocation. Else return FALSE.
//This task is the task currently executing for the machine.
/*
Date		Who		Reason
12 Feb 2010	consw1	PAR #21593 - CCMS MES 1014 RDT ITS Interface - Allow for moves with multiple machines
*/
begin
	//----------------------
	//Dont bother checking the task status, if the machine has the task, then we
	//must assume he may do it (it may only be offered).
	//----------------------
	if not sourceLocn.isKindOf(CM_StackController) then 
		//--------------
		//Not a straddle controller. Ignore
		//--------------
		return false;
	endif;
	
	//epr ccms 1100 10/2/10
		if self.machineTypeGroup = MACHINETYPEGRP_IMV then
			return false;
		endif;
	
	if taskType = TASK_PICKUP then
		
	
		if not self.sourceLocation.getParent().isKindOf(CM_GridArea) then
			//--------------
			//Not a straddle/forklift stack. Ignore
			//--------------
			return false;
		endif;
		if self.sourceLocation.getParent() &lt;&gt; sourceLocn.getParent() then
			//--------------
			//Different area. Ignore
			//--------------
			return false;
		endif;
		//--------------
		//Same area, check for clash
		//--------------
		return self.sourceLocation.CM_GridController.isWithinSeparationLimits(sourceLocn);


	elseif taskType = TASK_SETDOWN then
		//slw ccms mes 1014 12/2/2010
		if self.machineTypeGroup = MACHINETYPEGRP_IMV then
			return false;
		endif;

		if self.targetLocation = null then
			return false;
		endif;
		if not self.targetLocation.getParent().isKindOf(CM_GridArea) then
			//--------------
			//Not a straddle/forklift stack. Ignore
			//--------------
			return false;
		endif;
		if self.targetLocation.getParent() &lt;&gt; sourceLocn.getParent() then
			//--------------
			//Different area. Ignore
			//--------------
			return false;
		endif;
		//--------------
		//Same area, check for clash
		//--------------
		return self.targetLocation.CM_GridController.isWithinSeparationLimits(sourceLocn);

	elseif taskType = TASK_DIRECTOR then
		if self.sourceLocation = null then	//Funny state!
			return false;
		endif;
		if not self.sourceLocation.getParent().isKindOf(CM_GridArea) then
			//--------------
			//Not a straddle/forklift stack. Ignore
			//--------------
			return false;
		endif;
		if self.sourceLocation.getParent() &lt;&gt; sourceLocn.getParent() then
			//--------------
			//Different area. Ignore
			//--------------
			return false;
		endif;
		//--------------
		//Same area, check for clash
		//--------------
		return self.sourceLocation.CM_GridController.isWithinSeparationLimits(sourceLocn);
	elseif taskType = TASK_MOVE then
		if self.targetLocation = null then
			return false;
		endif;
		if not self.targetLocation.getParent().isKindOf(CM_GridArea) then
			//--------------
			//Not a straddle/forklift stack. Ignore
			//--------------
			return false;
		endif;
		
		if self.targetLocation.getParent() &lt;&gt; sourceLocn.getParent() then
			//--------------
			//Different area. Ignore
			//--------------
			return false;
		endif;
		//--------------
		//Same area, check for clash
		//--------------
		return self.targetLocation.CM_GridController.isWithinSeparationLimits(sourceLocn);

	elseif taskType = TASK_BREAKBULK then
		if self.sourceLocation = null then	//Funny state!
			return false;
		endif;
		if not self.sourceLocation.getParent().isKindOf(CM_GridArea) then
			//--------------
			//Not a straddle/forklift stack. Ignore
			//--------------
			return false;
		endif;
		if self.sourceLocation.getParent() &lt;&gt; sourceLocn.getParent() then
			//--------------
			//Different area. Ignore
			//--------------
			return false;
		endif;
		//--------------
		//Same area, check for clash
		//--------------
		return self.sourceLocation.CM_GridController.isWithinSeparationLimits(sourceLocn);
	
	else
		//app.setContinueCMExceptions(false);
		//app.raiseCMException2(ERR_UNKNOWN_TASK, self.taskType.String, "Current", null, null);
		return false;
	endif;
end;</source>
        <Parameter name="sourceLocn" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWorkingOrAccepted" id="c90d5db2-3415-40c4-9237-7d173ef1ddc8">
