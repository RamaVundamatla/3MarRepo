    <JadeMethod name="checkRowHighlighted" id="2df21e25-e1ba-48b1-af28-d5c9b8cae59b">
        <source>checkRowHighlighted();

vars
	currRowBasicDim: 	Integer;
	currRowKeyDist:	Integer;
begin
	// Remember current rows
	currRowBasicDim:=tblBasicDimension.row;
	currRowKeyDist:=tblKeyDistances.row;

	// Is there a row selected in either table?
	if currRowBasicDim=0 and currRowKeyDist=0 then
		// Current row not defined in either table
		// Therefore, highlight first row in tblBasicDimension 
		tblBasicDimension.row:=2;
		tblBasicDimension.column:=1;
		tblBasicDimension.selected:=true;
		tblBasicDimension.column:=3;
		tblBasicDimension.selected:=true;
		tblBasicDimension.column:=2;
		tblBasicDimension.selected:=true;
		tblBasicDimension.setFocus;
		tblBasicDimension.refreshNow;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkTblBasicDimension" id="dc4a1ae3-e955-4ea8-ae76-1b9b78ec665a">
        <updating/>
        <source>checkTblBasicDimension():Boolean updating;

vars
//	term:					CM_HMS_Terminal;
	msgTitle:				String;
	errorMsg:				String;
	checkOK:				Boolean;
	firstRowInError:		Integer;
	currentlySelectedRow: 	Integer;

begin
//	term:=app.thisTerminal.CM_HMS_Terminal;

	// Set default check status to 'true'
	checkOK:=true;

	// Set firstRowInError to no row and set currentlySelectedRow
	firstRowInError:=0;
	currentlySelectedRow:=tblBasicDimension.row;

	// Check 'Length Overall'
	tblBasicDimension.row:=2; 
	if tblBasicDimension.text.Integer&lt;LOA_LowerLimit or tblBasicDimension.text.Integer&gt;LOA_UpperLimit then
		errorMsg:=app.getErrorString(MSGBOX_ShipLOAInvalid) &amp; LOA_LowerLimit.String &amp; " and " &amp; LOA_UpperLimit.String &amp; ".";
		errMsgTblBasicDims(errorMsg);
		checkOK:=false;
		if firstRowInError=0 then
			// firstRowInError is not currently set, point to this row
			firstRowInError:=2;
		endif;
	endif;

	// Check 'Gross Registered Tonnes'
	tblBasicDimension.row:=3; 
	if tblBasicDimension.text.Integer&lt;GRT_LowerLimit or tblBasicDimension.text.Integer&gt;GRT_UpperLimit then
		errorMsg:=app.getErrorString(MSGBOX_ShipGRTInvalid) &amp; GRT_LowerLimit.String &amp; " and " &amp; GRT_UpperLimit.String &amp; ".";
		errMsgTblBasicDims(errorMsg);
		checkOK:=false;
		if firstRowInError=0 then
			// firstRowInError is not currently set, point to this row
			firstRowInError:=3;
		endif;
	endif;

	// Check 'DeadWeight'
	tblBasicDimension.row:=4; 
	if tblBasicDimension.text.Integer&lt;DWT_LowerLimit or tblBasicDimension.text.Integer&gt;DWT_UpperLimit then
		errorMsg:=app.getErrorString(MSGBOX_ShipDWTInvalid) &amp; DWT_LowerLimit.String &amp; " and " &amp; DWT_UpperLimit.String &amp; ".";
		//errorMsg:=term.associatedHarbour.getMsgString(HMS_DWT_OUT_OF_RANGE,DWT_DNLIMIT.String, DWT_UPLIMIT.String,"");
		errMsgTblBasicDims(errorMsg);
		checkOK:=false;
		if firstRowInError=0 then
			// firstRowInError is not currently set, point to this row
			firstRowInError:=4;
		endif;
	endif;

	// Check 'Beam'
	tblBasicDimension.row:=5; 
	//if tblBasicDimension.text.Decimal&lt;BEAM_LowerLimit or tblBasicDimension.text.Decimal&gt;BEAM_UpperLimit then
	if tblBasicDimension.text.asDecimalJMT() &lt; BEAM_LowerLimit or tblBasicDimension.text.asDecimalJMT() &gt; BEAM_UpperLimit then	// 01 APR 2010	NDL	Par 23356
		errorMsg:=app.getErrorString(MSGBOX_ShipBEAMInvalid) &amp; BEAM_LowerLimit.String &amp; " and " &amp; BEAM_UpperLimit.String &amp; ".";
		errMsgTblBasicDims(errorMsg);
		checkOK:=false;
		if firstRowInError=0 then
			// firstRowInError is not currently set, point to this row
			firstRowInError:=5;
		endif;
	endif;

	// Check 'Fore Draft'
	tblBasicDimension.row:=6; 
	//if tblBasicDimension.text.Decimal&lt;DRAFT_LowerLimit or tblBasicDimension.text.Decimal&gt;DRAFT_UpperLimit then
	if tblBasicDimension.text.asDecimalJMT() &lt; DRAFT_LowerLimit or tblBasicDimension.text.asDecimalJMT() &gt; DRAFT_UpperLimit then	// 01 APR 2010	NDL	Par 23556
		errorMsg:=app.getErrorString(MSGBOX_ShipDftForeInvalid) &amp; DRAFT_LowerLimit.Decimal.String &amp; " and " &amp; DRAFT_UpperLimit.Decimal.String &amp; ".";
		errMsgTblBasicDims(errorMsg);
		checkOK:=false;
		if firstRowInError=0 then
			// firstRowInError is not currently set, point to this row
			firstRowInError:=6;
		endif;
	endif;

	 // Check 'Aft Draft'
	tblBasicDimension.row:=7; 
	//if tblBasicDimension.text.Decimal&lt;DRAFT_LowerLimit or tblBasicDimension.text.Decimal&gt;DRAFT_UpperLimit then
	if tblBasicDimension.text.asDecimalJMT() &lt; DRAFT_LowerLimit or tblBasicDimension.text.asDecimalJMT() &gt; DRAFT_UpperLimit then	// 01 APR 2010	NDL	Par 23556
		errorMsg:=app.getErrorString(MSGBOX_ShipDftAftInvalid) &amp; DRAFT_LowerLimit.Decimal.String &amp; " and " &amp; DRAFT_UpperLimit.Decimal.String &amp; ".";
		errMsgTblBasicDims(errorMsg);
		checkOK:=false;
		if firstRowInError=0 then
			// firstRowInError is not currently set, point to this row
			firstRowInError:=7;
		endif;
	endif; 

	if firstRowInError&gt;0 then
		// set row pointer to first row in error
		tblBasicDimension.row:=firstRowInError;
		// highlight this row
		tblBasicDimension.rowColumnChg(tblBasicDimension);
	else
		// return pointer to currently selected row
		tblBasicDimension.row:=currentlySelectedRow;
	endif;


	if checkOK=false then
		return false;	
	else
		return true;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTblKeyDistances" id="ca51b279-1e9a-4a1e-85d7-071b66df5f70">
        <updating/>
        <source>checkTblKeyDistances():Boolean updating;

vars
//	term:					CM_HMS_Terminal;
	checkOK:				Boolean;
	firstRowInError:		Integer;
	currentlySelectedRow: 	Integer;
	count:					Integer;

begin
//	term:=app.thisTerminal.CM_HMS_Terminal;

	// Set default check status to 'true'
	checkOK:=true;

	// Set firstRowInError to no row and set currentlySelectedRow
	firstRowInError:=0;
	currentlySelectedRow:=tblKeyDistances.row;

	// Check 'Key Distances'
	count:=2;
	while count&lt;=tblKeyDistances.rows do
		tblKeyDistances.row:=count; 
		if tblKeyDistances.text.Integer&lt;Distance_LowerLimit or tblKeyDistances.text.Integer&gt;Distance_UpperLimit then
			errMsgTblKeyDistances;
			checkOK:=false;
			if firstRowInError=0 then
				// firstRowInError is not currently set, point to this row
				firstRowInError:=count;
			endif;
		endif;
		count:=count+1;
	endwhile;


	if firstRowInError&gt;0 then
		// set row pointer to first row in error
		tblKeyDistances.row:=firstRowInError;
		// highlight this row
		tblKeyDistances.rowColumnChg(tblKeyDistances);
	else
		// return pointer to currently selected row
		tblKeyDistances.row:=currentlySelectedRow;
	endif;


	if checkOK=false then
		return false;	
	else
		return true;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
