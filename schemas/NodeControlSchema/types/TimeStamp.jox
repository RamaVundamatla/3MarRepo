<PrimType name="TimeStamp">
    <JadeMethod name="logFormat" id="c606ecd1-3cc0-4cfc-af71-dc7c3490da76">
        <source>logFormat():String;

vars
	s:String;
begin
	if self.time.milliSecond=0 then  // fix literalFormat bug!
		s:=".000";
	endif;
	return self.date.format("yyy/MM/dd ")&amp;self.literalFormat[12:end]&amp;s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
