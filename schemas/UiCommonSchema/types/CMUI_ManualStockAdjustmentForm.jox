    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="3b38996c-1b7d-4b62-bba5-7d5dac600e12">
        <updating/>
        <source>doBaseFormSave() updating, protected;

// Created by cnwdvb1 on 26 October 2006
vars
	product				: CM_Product;
	adjustedVolume		: Real;
	newVolume			: Real;
	adjustedWeight		: Decimal[14,4];
	newWeight			: Decimal[14,4];
	adjustedQuantity	: Integer;
	newQuantity			: Integer;
	result				: Integer;
	proxyTrackedItem	: CM_TrackedItem;
	comment				: String;
	
begin
	inheritMethod();
	
	product := self.cmbProduct.myObject.CM_Product;
	
	if product = null then
		return;
	endif;
	
	//self.myTrackedItem := self.myLocationsController.getMatchingTrackedItem(product);
	
	if self.myTrackedItem = null then
		if not self.createNewTrackedItem(product) then
			// Need to create tracked item if we don't have one already.
			return;
		endif;
	endif;
	
	// NEED TO CONVERT STRING INTO VALUE USING PRODUCT METHODS.
	if self.showVolume then
		newVolume	:= self.fieldNewV.getString().Real;
		adjustedVolume := product.myVolume.divideValue(newVolume);
	endif;
	
	if self.showQuantity then
		newQuantity	:= self.fieldNewQ.getString().Integer;
		adjustedQuantity := product.myQuantity.divideValue(newQuantity).Integer;
	endif;
	
	if self.showWeight then
		newWeight	:= self.fieldNewW.getString().Integer;
		adjustedWeight := product.getWeightValueFromDisplay(newWeight).Integer;  //myWeight.divideValue(newWeight).Integer; //30.1.09 cnwrd1 par #18821 ++
	endif;
	
	comment := self.fieldComment.getString();
	
	proxyTrackedItem := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;
	proxyTrackedItem.setQVW(adjustedQuantity, adjustedVolume, adjustedWeight);
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem(proxyTrackedItem, comment, TI_UPDMODE_NORMAL, null, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.unloadForm();		// cnwdad1 28/03/2008 - Close the form after a successful update.
		else
			result := app.showErrorWarningDialog('Adjust Stock', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
// cnwdad1 28/03/2008 - There's no point doing this since the form now closes after a successful update.
//	self.setCurrentValues(product);
epilog
	delete proxyTrackedItem;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fieldCargoType_doAlignCtrls" id="398ee9db-aed2-4db4-81be-b51aa50288ad">
        <controlMethod name="CMUI_FieldGeneric::doAlignCtrls"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fieldCargoType_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;

// Created by cnwdvb1 on 09 November 2006

vars
	controlWidth	: Real;
	controlLeft		: Real;
	listboxObj		: CMUI_ComboCargoGeneral;
	
begin
	listboxObj		:=	self.cmbCargoType;
	controlLeft		:=	_fieldGeneric.myLabel.left + _fieldGeneric.myLabel.width + CMUI_FieldFrame.HORIZONTAL_SPACING;
	controlWidth	:=	_fieldGeneric.clientWidth() - controlLeft;
	listboxObj.move(controlLeft, 0, listboxObj.width, _fieldGeneric.height);
	listboxObj.visible	:=	true;
end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
