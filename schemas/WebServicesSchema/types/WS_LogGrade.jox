        <access>readonly</access>
    </CompAttribute>
    <ImplicitInverseRef name="allLogLengths" id="f3a0d07e-7a14-452d-b628-9ec8b88de46b">
        <memberTypeInverse/>
        <type name="WS_LogLengthArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
