    <JadeMethod name="click" id="38e1b39f-faac-42cc-bdb2-e80e8a4a7f99">
        <updating/>
        <source>click(listbox: ListBox input) updating;

// cnwdvb1 16 January 2003 

vars

begin

	if self.myMultiSelectGroupBox &lt;&gt; null then
		self.myMultiSelectGroupBox.handleListBoxClick(listbox.CM_MultiSelectListBox);
	endif;
	if listbox.itemSelected[listbox.listIndex] = false then
		listbox.listIndex := -1;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="6d1f5c85-3886-42a6-abd6-d59b6877e4db">
        <updating/>
        <source>dblClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		10 December 2002 By Jason Chapman cnwjc2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myMultiSelectGroupBox &lt;&gt; null then
		self.myMultiSelectGroupBox.handleListBoxDblClick(listbox.CM_MultiSelectListBox);
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayEntry" id="9d4202ea-d49a-4cac-9532-6bc54d809d46">
        <updating/>
        <source>displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer): String updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	if self.formDisplayEntryMethodName &lt;&gt; null then
		// the available and selected can display different data
		return self.form.sendMsgWithParams(self.formDisplayEntryMethodName, obj).String;	
	else
		return self.myMultiSelectGroupBox.displayEntry(obj);
	endif;
		
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="7a745b16-4570-4dc0-9c95-584d78b0e361">
        <updating/>
        <source>dragDrop(listbox: ListBox input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:	
//
// Date			Who		Reason
// 28 Aug 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
//
// ---------------------------------------------------------------------------

vars
	targetIdx : Integer;
	str : String;
begin
	inheritMethod(listbox, win, x, y);
	self.myMultiSelectGroupBox.doDragDropFromListBox(listbox,win,x,y);

	if self.allowDragDrop
	and self.myDragObject &lt;&gt; null then
		
		targetIdx := self.dragListIndex();
		if targetIdx = self.origIndex
		or targetIdx &lt; 1 then
			// drop to original position, nothing to do
			return;
		endif;
		
		//cnwrd1 3.11.08 par #17630
		if self.origIndex &gt; self.itemText.size then
			//some reason origIndex fallen of the end of the itemText array
			return;
		endif;
	
		// re-position object at new target
		str := self.itemText[self.origIndex];
		self.removeItem(self.origIndex);
		self.addItemAt(str, targetIdx);
		self.itemObject[targetIdx] := self.myDragObject;
		
		self.myMultiSelectGroupBox.doDragComplete(self);		//28.07.2024 navnk30 #64536 Task 64537
	endif;

epilog
	self.origIndex := null;
	self.origXPos := null;
	self.origYPos := null;
	self.myDragObject := null;
	self.dragMode := DragMode_None;		
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="d7a6e299-40f2-4456-8027-e87b4f56e8ea">
        <controlMethod name="ListBox::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragOver(listbox: ListBox input; win: Window input; x: Real; y: Real; state: Integer) updating, clientExecution;
//--------------------------------------------------
// Created:	09 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(listbox, win, x, y, state);
	
	if self.allowDragDrop then
		if self.dragListIndex &gt; 0 then
			self.listIndex := self.dragListIndex;		
		endif;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="ce086263-50d6-4040-bcc5-99ee21265e26">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//--------------------------------------------------
// Created:	09 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	selectFrom,
	selectTo,
	idx,
	currentIdx,
	initRow		: Integer;
begin
	inheritMethod(listbox, button, shift, x, y);

	self.dragMode := DragMode_None;
	self.myDragObject := null;	

	if self.allowDragDrop 		
	and button = Window.MouseButton_Left then
		self.origXPos := x;
		self.origYPos := y;
		self.origIndex := self.listIndex;		
		self.myDragObject := self.listObject;
	endif;

	if self.multiSelect = MultiSelect_None then
		return;
	endif;
	
	currentIdx := self.listIndex;

	if shift.bitAnd(1) = 0 then
		self.origIndex := currentIdx;
		return;
	endif;

	self.clearAllSelected();	
	initRow := self.origIndex;
	if initRow &gt; self.listCount then
		return;
	endif;

	selectFrom := initRow.min(currentIdx);
	selectTo := initRow.max(currentIdx);

	foreach idx in selectFrom to selectTo do
		self.itemSelected[idx] := true;
	endforeach;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="4f06d596-de15-4238-952c-a961b32233d4">
        <controlMethod name="ListBox::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//--------------------------------------------------
// Created:	09 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(listbox, button, shift, x, y);

	if (not self.allowDragDrop) 		// &lt;-- dragDrop not allowed
	or button &lt;&gt; 1						// &lt;-- not dragging
	or self.myDragObject = null then	// &lt;-- nothing selected
		return;
	endif;

	if app.dragDetected(x, y, self.origXPos, self.origYPos) then		
		self.dragMode := DragMode_Drag;
		self.dragCursor := self.dragCursor;	
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="refreshSelf" id="e48bc57d-287b-4113-89b6-96d24dcb51bc">
        <updating/>
        <source>refreshSelf() updating;
/*

Purpose:	Refreshes the text for items in the listbox		

Parameters:			

Return Value:		


Date		Who		Reason
5 Feb 2013	cnwjre1	Initial creation

*/

vars
	i	: Integer;
	obj	: Object;
begin

	foreach i in 1 to self.listCount do
		obj := self.itemObject[i];
		self.itemText[i] := self.displayEntry(self, obj, null);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="a5011651-37ed-4533-b434-c3e25f11588b">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     03 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	cntrl.show3D := Show3D_Use3D;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
