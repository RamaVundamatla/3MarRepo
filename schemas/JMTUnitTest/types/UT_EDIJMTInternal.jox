    <JadeMethod name="tTransManifestCargoOnSiteInt" id="9a4410b9-48a4-43ac-9cb5-ecf13e4d727a">
        <source>tTransManifestCargoOnSiteInt();
//
//18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//14 Apr 2025	navdap1	MTN-14781 CPL| Increase BOL Field Length
//
constants
	VoyageName = 'VOY002BOL';
	ShipName = 'Ship001';
	TestOperator = 'MSK';
	USER_DEF_NAME : String = "JMTInternalCargoOnSite";
	CONTAINER01 : String = "UTCL0111";
	CONTAINER02 : String = "UTCL0121";
	CONTAINER03 : String = "UTCL0131";
	CONTAINER04 : String = "UTCL0141";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiCargoByAllowPartial, true);
	self.deleteContainer(CONTAINER01);
	self.deleteContainer(CONTAINER02);
	self.deleteContainer(CONTAINER03);
	self.deleteContainer(CONTAINER04);
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(ShipName);
	vessel := self.getVessel(ShipName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(ShipName, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage	:= self.addVoyageWithContainerStructur(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	passportObj	:=	app.myPassport;
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTransManifest xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTransManifest.xsd"&gt;
	&lt;AllDataTransManifest&gt;
	&lt;DataTransManifest&gt;
		&lt;statusString&gt;Create&lt;/statusString&gt;
		&lt;guid&gt;"bd32cfne-24eb-495e-98d2-df19db66dd9&lt;/guid&gt;
		&lt;type&gt;CargoOnSite&lt;/type&gt;
		&lt;manifestNumber&gt;Mannumber12345&lt;/manifestNumber&gt;
		&lt;receiver&gt;EBTA&lt;/receiver&gt;
		&lt;sender&gt;Sarge&lt;/sender&gt;
	&lt;AllCargoOnSite&gt;
		&lt;CargoOnSite&gt;
			&lt;weight&gt;2000.0000&lt;/weight&gt;
			&lt;site&gt;1&lt;/site&gt;
			&lt;bol&gt;BOL01&lt;/bol&gt;
			&lt;bookingRef&gt;BK01&lt;/bookingRef&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;commodity&gt;MT&lt;/commodity&gt;
			&lt;companyCode&gt;DFBU&lt;/companyCode&gt;
			&lt;destinationPort&gt;AUMEL&lt;/destinationPort&gt;
			&lt;dischargePort&gt;JPADO&lt;/dischargePort&gt;
			&lt;id&gt;'&amp;CONTAINER03&amp;'&lt;/id&gt;
			&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
			&lt;isoType&gt;2200&lt;/isoType&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;locationId&gt;UTCL 000102 1&lt;/locationId&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;UTOP&lt;/operatorCode&gt;
			&lt;remarks&gt;Rem01&lt;/remarks&gt;
			&lt;sealCustoms&gt;CUSTSEAL3&lt;/sealCustoms&gt;
			&lt;sealTerminalOperator&gt;TermOpSeal3&lt;/sealTerminalOperator&gt;
			&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;receiveDate&gt;01 January 2010, 12:45:00&lt;/receiveDate&gt;
			&lt;consignorCode&gt;BOB&lt;/consignorCode&gt;
			&lt;salesOrderNbr&gt;12345&lt;/salesOrderNbr&gt;
			&lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
			&lt;AllSealDetails&gt;
				&lt;SealDetails&gt;
					&lt;sealEDIType&gt;SH&lt;/sealEDIType&gt;
					&lt;sealEDINum&gt;SHSEAL1&lt;/sealEDINum&gt;
					&lt;/SealDetails&gt;
					&lt;SealDetails&gt;
					&lt;sealEDIType&gt;SHIP&lt;/sealEDIType&gt;
					&lt;sealEDINum&gt;SHSEAL2&lt;/sealEDINum&gt;
				&lt;/SealDetails&gt;
			&lt;/AllSealDetails&gt;
		&lt;/CargoOnSite&gt;
	&lt;/AllCargoOnSite&gt;
	&lt;/DataTransManifest&gt;
	&lt;/AllDataTransManifest&gt;
&lt;/JMTInternalTransManifest&gt;
';
//&lt;id&gt;UTCL0131&lt;/id&gt;

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;'1'&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
//	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.CM_EDIDataTransManifest.myCargoOnSite.allEDITrackedItems.size, 5, "incorrect number of EDI trackedItems");
	ti := self.getTrackedItem(CONTAINER03);
	self.assertNotNull(ti);
	self.assertTrueMsg( ti.clientRef = "12345", "clientRef should be '12345'");
//	self.assertTrueMsg(ti.isHazardous = true, "isHazardous should be 'true'");
	self.assertEqualMsg(ti.getSealNumShipper(), "SHSEAL1,SHSEAL2", "Incorrect Shipper Seal");

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTransManifest xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTransManifest.xsd"&gt;
	&lt;AllDataTransManifest&gt;
	&lt;DataTransManifest&gt;
		&lt;statusString&gt;Create&lt;/statusString&gt;
		&lt;guid&gt;"bd32cfne-24eb-495e-98d2-df19db66dd8&lt;/guid&gt;
		&lt;type&gt;CargoOnSite&lt;/type&gt;
		&lt;manifestNumber&gt;Mannumber12345&lt;/manifestNumber&gt;
		&lt;receiver&gt;EBTA&lt;/receiver&gt;
		&lt;sender&gt;Sarge&lt;/sender&gt;
	&lt;AllCargoOnSite&gt;
		&lt;CargoOnSite&gt;
			&lt;weight&gt;25000.0000&lt;/weight&gt;
			&lt;parentCargoTypeCode&gt;1&lt;/parentCargoTypeCode&gt;
			&lt;site&gt;1&lt;/site&gt;
			&lt;bol&gt;BOL01&lt;/bol&gt;
			&lt;bookingRef&gt;BK01&lt;/bookingRef&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
