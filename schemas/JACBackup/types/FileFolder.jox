<Class name="FileFolder">
    <JadeMethod name="copy" id="6c8692e8-830f-47fb-91a5-db69bd4915db">
        <updating/>
        <source>copy(_target: String; _ignoreErrors: Boolean) : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		Nov 2004 cnwrs1
//
// Purpose:		Copies the receiver's file directory to the specified file name.
//				The entire contents of the directory will also be copied.
//
// Parameters:	pTarget - The name of the direcory to copy the receiver to.
//
// Returns:		True if the copy was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// July 2009    cnwrs1      to replace the data being copied par 20382
// -----------------------------------------------------------------------------
vars
	folderObj: FileFolder;
	fileNodeObj: FileNode;
	allFiles: FileNodeArray;
	isSuccessful, result: Boolean;
	kc : CnKarmaCntrl;
begin
	result := false;
	create folderObj transient;
	folderObj.fileName := _target;
	folderObj.make();
	kc := app.myCnKarmaCntrl;
	if folderObj.isAvailable() then
		allFiles := self.files();
		foreach fileNodeObj in allFiles do
			isSuccessful := kc.copyFile(fileNodeObj.fileName, _target &amp; global.cnEcGetFileSeparator() &amp; fileNodeObj.name, false); //cnwrs1 par 20382 july 2009
//			isSuccessful := fileNodeObj.cnEcCopy(_target &amp; global.cnEcGetFileSeparator() &amp; fileNodeObj.name);
			if (not _ignoreErrors) and
			   (not isSuccessful) then
				result := isSuccessful;
				return result;
			endif;
		endforeach;
	endif;
	result := true;
epilog
	delete folderObj;
	return result;
end;</source>
        <Parameter name="_target" type="String"/>
        <Parameter name="_ignoreErrors" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
