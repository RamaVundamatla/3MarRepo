    <JadeMethod name="vehicleVisitRolloverEnumToStr" id="2a406700-8cb7-4a1e-9798-02c6a2ab7abc">
        <source>vehicleVisitRolloverEnumToStr(_rollover : Integer): String;

/*
Date			Who		Reason
20 August 2009	cnwar2	Initial creation

*/
vars

begin
	if _rollover = VEHICLE_VISIT_ROLLOVER_DAY then
		return app.getErrorString(Day);
	elseif _rollover = VEHICLE_VISIT_ROLLOVER_YEAR then
		return app.getErrorString(Year);
	elseif _rollover = VEHICLE_VISIT_ROLLOVER_MAX_NUM then
		return app.getErrorString(Maximum_number);
	else
		return app.getErrorString(Unknown);
	endif;
end;</source>
        <Parameter name="_rollover" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="vehicleVisitRolloverStrToEnum" id="00a070fd-4e5a-4c3c-99b1-7389373c9760">
        <source>vehicleVisitRolloverStrToEnum(_rollover : String): Integer;

/*
Date			Who		Reason
20 August 2009	cnwar2	Initial creation

*/
vars
	tmpStr : String;
begin
	tmpStr := _rollover.toUpper;

	if tmpStr = app.getErrorString(Day).toUpper then
		return VEHICLE_VISIT_ROLLOVER_DAY;
	elseif tmpStr = app.getErrorString(Year).toUpper then
		return VEHICLE_VISIT_ROLLOVER_YEAR;
	elseif tmpStr = app.getErrorString(Maximum_number).toUpper then
		return VEHICLE_VISIT_ROLLOVER_MAX_NUM;
	else
		return 0;
	endif;
end;</source>
        <Parameter name="_rollover" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="vesselAccessTypeEnumToStr" id="7f0209c7-1899-47eb-aade-634088c4ee45">
        <source>vesselAccessTypeEnumToStr(_vesselType : Integer) : String;
//--------------------------------------------------
// Created:	29 March 2006 By: cnwgd1
//--------------------------------------------------
vars

	voyTfrType : CM_VoyageJobTransferType;

begin

	//12 Mar 2018	NDL	 TFS 37444
	voyTfrType := app.myRoot.allVoyageJobTransferTypes.getAtKey( _vesselType );
	if voyTfrType &lt;&gt; null then
		return voyTfrType.description;
	endif;
	
	if _vesselType = VESSEL_TYPE_LOLO then
		return VESSEL_TYPE_LOLO_DESCR;
	elseif _vesselType = VESSEL_TYPE_RORO then
		return VESSEL_TYPE_RORO_DESCR;
	else
		return app.getErrorString(Unknown);
	endif;

end;</source>
        <Parameter name="_vesselType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="vesselAccessTypeStrToEnum" id="53e4acc1-bcfb-469d-b5fb-15f48e6b7818">
        <source>vesselAccessTypeStrToEnum(_vesselType : String) : Integer;
//--------------------------------------------------
// Created:	29 March 2006 By: cnwgd1
//--------------------------------------------------
vars

	tmpVal	: String;
	iter : Iterator;
	voyTfrType : CM_VoyageJobTransferType;

begin

	tmpVal := _vesselType.toUpper();
	
	//12 Mar 2018	NDL	 TFS 37444
	iter := app.myRoot.allVoyageJobTransferTypes.createIterator;
	while iter.next( voyTfrType ) do
		if tmpVal = voyTfrType.description.toUpper then
			return voyTfrType.id;
		endif;
	endwhile;

	if tmpVal = VESSEL_TYPE_LOLO_DESCR.toUpper() then
		return VESSEL_TYPE_LOLO;
	elseif tmpVal = VESSEL_TYPE_RORO_DESCR.toUpper() then
		return VESSEL_TYPE_RORO;
	else
		return null;
	endif;

epilog

	delete iter;
	
end;</source>
        <Parameter name="_vesselType" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
