    <JadeMethod name="doListBoxOperatorBuild" id="f7793be8-6555-4f9e-94a7-7422e3681494">
        <updating/>
        <source>doListBoxOperatorBuild() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	aOperator : CM_Operator;
	idx : Integer;
	ls : Boolean;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	passport : CM_Passport;
	opDict : CM_OperatorByCodeDict;
	failedDAC  :CM_DataAccessController;
begin
	passport := app.myPassport;
	self.lstOperators.zOrder(1);
	self.lstOperators.rows := 0;
	
	app.cmsBeginLoad(ls);
	foreach aOperator in app.myRoot.allOperators do
		if aOperator.canUserAccessSelf(null, failedDAC, passport) then
			idx := self.lstOperators.addItemObject(aOperator.code &amp; " - " &amp; aOperator.description,aOperator);
		endif;
	endforeach;
	app.cmsEndLoad(ls);
	
	self.lstOperators.userInputEnabled := true;
epilog
	endLoad;

end;</source>
    </JadeMethod>
    <JadeMethod name="doListBoxPortBuild" id="7d6fe463-ab09-41d5-acef-331d3d9c40e0">
        <updating/>
        <source>doListBoxPortBuild() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	aPort : CM_Port;
	idx : Integer;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	theUser : CM_User;
	portDict : CM_PortByCodeDict;
	ls : Boolean;
	portCmbOrderDescrFirst : Boolean;
begin
	theUser := app.myPassport.myUser;
	self.lstPorts.zOrder(1);
	self.lstPorts.rows := 0;
	create portDict transient;
//	if self.myCurrentVoyage &lt;&gt; null then
//		self.myCurrentVoyage.allPorts.copy(portDict);
//	else
		app.myRoot.allActivePorts.copy(portDict);
//	endif;
	
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	app.cmsBeginLoad(ls);
	foreach aPort in portDict do
		self.lstPorts.addItemObject(aPort.getDisplayFormatted(portCmbOrderDescrFirst), aPort);
	endforeach;
	app.cmsEndLoad(ls);
	
	self.lstPorts.sortColumn[1] := 2;
	self.lstPorts.resort();

//	self.lstPorts.addItemAt("" &amp; Tab &amp; "ALL Destinations",1);
//	self.lstPorts.accessCell(1, 1).text := TableCheckBox_Selected;

	
epilog
	delete portDict;
	endLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="doListBoxTermAreaBuild" id="78f6f02e-e896-4561-b72e-3c83cc9a4bde">
        <updating/>
        <source>doListBoxTermAreaBuild() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
============================================================================*/
vars

	aTerminalAreaMaster : CM_TerminalAreaMaster;
	idx : Integer;
	ls : Boolean;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	passport : CM_Passport;
	failedDAC  :CM_DataAccessController;
begin
	passport := app.myPassport;
	self.lstTermArea.zOrder(1);
	self.lstTermArea.rows := 0;
//	idx := self.lstTermArea.addItemObject("ALL Areas",null);
	
	app.cmsBeginLoad(ls);
	foreach aTerminalAreaMaster in self.myTerminal.allTerminalAreaMastersById 
				where aTerminalAreaMaster.type  = TA_TYPE_STRADDLE_STACK
				or aTerminalAreaMaster.type = TA_TYPE_FORK_LIFT_STACK
				or aTerminalAreaMaster.type = TA_TYPE_RTG 
				or aTerminalAreaMaster.type = TA_TYPE_RMG
				or aTerminalAreaMaster.type = TA_TYPE_BLOCK_STACK   //26/02/2015  cnwma1 PAR #33352
				or aTerminalAreaMaster.type = TA_TYPE_RORO_LANE_AREA	//20 Jul 2021	NDL	TFS 51518	
				or aTerminalAreaMaster.type = TA_TYPE_IRREGULAR_BLOCK_AREA	//20 Jul 2021	NDL	TFS 51518
				or aTerminalAreaMaster.type = TA_TYPE_MAFI
				do
		if aTerminalAreaMaster.canUserAccessSelf(null, failedDAC, passport) then
			idx := self.lstTermArea.addItemObject(aTerminalAreaMaster.getID() &amp; " - " &amp; aTerminalAreaMaster.typeString,aTerminalAreaMaster);
			self.lstTermArea.accessRow(idx).backColor := White;
			self.lstTermArea.accessRow(idx).foreColor := Black;
		endif;
	endforeach;
	app.cmsEndLoad(ls);
//	self.lstTermArea.accessCell(1, 1).text := TableCheckBox_Selected;

	
	self.lstTermArea.userInputEnabled := true;
epilog
	endLoad;

end;</source>
    </JadeMethod>
    <JadeMethod name="doListBoxVoyageBuild" id="c71665fb-40a3-48d5-84c5-93aec4cb9c8e">
        <updating/>
        <source>doListBoxVoyageBuild() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	aVoyage : CM_Voyage;
	idx : Integer;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	anArray : ObjectArray;
	theVoyages : CM_VoyageSet;
begin
	self.lstVoyages.rows := 0;
	self.lstVoyages.zOrder(1);
	
	create theVoyages transient;
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages,false, false);
	
	foreach aVoyage in theVoyages do
		self.lstVoyages.addItemObject(aVoyage.code &amp; " - " &amp; aVoyage.vesselName,aVoyage);
	endforeach;
	
	self.lstVoyages.sortColumn[1] := 2;
	self.lstVoyages.resort();
epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuHideClick" id="31099e76-e876-488d-8b80-a1e32a738b9f">
        <source>doMnuHideClick(_menuItem :MenuItem input);
// ---------------------------------------------------------------------------
// Created:		03 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _menuItem.caption = self.MNU_MACRO_HIDE then
		_menuItem.caption := self.MNU_MACRO_SHOW;
		self.splMain.hideRightControl(true);
		self.splYA.hideRightControl(true);
		self.splHaz.hideRightControl(true);
	else
		_menuItem.caption := self.MNU_MACRO_HIDE;
		self.splMain.showRightControl(30, true);
		self.splYA.showRightControl(30, true);
		self.splHaz.showRightControl(30, true);
		self.frmPopupInfo.visible := false;
	endif;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="36e0cf45-6ed2-4826-980e-b9dd8e3604af">
        <source>doMnuInspectObject();
// ---------------------------------------------------------------------------
// Created:		08 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	anObject : Object;
begin
	if self.fldMain.topSheet = self.shtSpace then
		idx :=  self.tblData.row;
		if idx &gt; self.tblData.fixedRows then
			anObject := self.tblData.accessRow(idx).itemObject;
			if anObject &lt;&gt; null then
				anObject.inspect;
			endif;
		endif;
	else
		inheritMethod();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuTIEdit" id="c407b11c-c31b-4b91-8d3f-2e08b8171c5e">
        <updating/>
        <source>doMnuTIEdit(_menuItem: MenuItem input) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj : Object;
	ti : CM_TrackedItem;
	objArray : ObjectArray;
begin
	create objArray transient;
	obj := _menuItem.userObject;
	
	if self.fldMain.topSheet = self.shtHaz then
		self.tblHaz.allSelectedObjects.copy(objArray);
	elseif self.fldMain.topSheet = self.shtYA then
		self.tblYA.allSelectedObjects.copy(objArray);
	else
		return;
	endif;
	
	
	if objArray.isEmpty then
		global.beep;
		app.msgBox("Please select some cargo to enquire on","Edit",MsgBox_Exclamation_Mark_Icon);
	else
		ti := objArray.first.CM_TrackedItem;
		self.myAssistant.showCargoEnquiryForTIs(ti, objArray, self.myMasterMenuAction, true);
	endif;
epilog
	delete objArray;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTIEnquire" id="8329ce86-221c-4553-bdf1-b23ad3a8e0b1">
        <updating/>
