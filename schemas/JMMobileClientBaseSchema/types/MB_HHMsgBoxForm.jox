    <JadeMethod name="checkAccelerator" id="e6311934-fa41-43e9-a3d4-c7894fb635b3">
        <source>checkAccelerator(_buttonObj: Button; _searchFor: Integer): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Purpose:		Returns true if btn is visible and its caption contains "&amp;" followed
//				by the character represented by searchFor.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	charPos	: Integer;
	
begin
    if not _buttonObj.visible or _buttonObj.caption = null or _searchFor = 0 then
    	return false;
    else
    	charPos	:=	_buttonObj.caption.pos("&amp;",1);
    	return charPos &lt;&gt; null and charPos &lt; _buttonObj.caption.length and _buttonObj.caption[charPos+1:1].toUpper = _searchFor.Character;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_buttonObj" type="Button"/>
        <Parameter name="_searchFor" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="ffc38719-324c-43b8-af9a-90883735440b">
        <updating/>
        <source>doResize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Purpose:		Resizes the receiver's contents to the desired dimensions.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	Width = 240;
	Dummy = "Dummy";
vars
	iconFlag	: Integer;
	textHeightForWidth,
	textHeight : Integer;	
	vlft,vtop,vwidth,vheight : Integer;
	lblHeight, frmHeight : Integer;
begin
	self.width:=Width;	
	textHeightForWidth := self.getTextHeightForWidth(self.aMessage,Width);
	textHeight:= self.lblText.getTextHeight(Dummy);
	lblHeight:=(textHeightForWidth + (textHeight * 2));
	frmHeight:=lblHeight +  btnDialog1.clientHeight + 20;
	fraMain.height:=frmHeight;
	self.height:=frmHeight + 25; //add room for control box

	
	/*iconFlag	:=	self.aFlags.bitAnd(MsgBox_Stop_Icon + MsgBox_Question_Mark_Icon + MsgBox_Information_Icon);

	if iconFlag = MsgBox_Stop_Icon
	or iconFlag = MsgBox_Question_Mark_Icon
	or iconFlag = MsgBox_Exclamation_Mark_Icon
	or iconFlag = MsgBox_Information_Icon
	then
		lblText.width	:=	self.width -64;
	else
		// No icon, so move the message to the left, and make it wider.	
		lblText.left	:=	4;
		lblText.width	:=	self.width -22;
	endif;
	*/
//	lblText.height	:=	self.height - 83;
	//lblText.height	:=	self.clientHeight - btnDialog1.height - 30; //- 115;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="b0503ad7-cdb2-48ab-a76a-d778e1863d7f">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(keyCode, shift);
	
	if not self.aIsKeyStrokeReceived then
		btnDialog1.setFocus();
		self.aIsKeyStrokeReceived	:=	true; 
		
		if keyCode = 13 and shift = 0 then
			if btnDialog1.default then
				btnDialog1_click(btnDialog1);
			elseif btnDialog2.default then
				btnDialog2_click(btnDialog2);
			elseif btnDialog3.default then
				btnDialog3_click(btnDialog3);
			endif;
		endif;
	endif;

	if self.checkAccelerator(btnDialog1, keyCode) then
		btnDialog1.click(btnDialog1);
	elseif self.checkAccelerator(btnDialog2, keyCode) then
		btnDialog2.click(btnDialog2);
	elseif self.checkAccelerator(btnDialog3, keyCode) then
		btnDialog3.click(btnDialog3);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="repositionControls" id="e3eae3c6-6824-465d-a2d7-2f815026a130">
        <source>repositionControls() protected;
// --------------------------------------------------------------------------------
// Created:		15 February 2006 by cnwdad1
//
// Purpose:		Horizontally centers the remaining visible buttons at the bottom of
//				the form, and vertically centers the visible icon picture.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	button1Obj		: Button;
	button2Obj		: Button;
	button3Obj		: Button;
	pictureObj		: Picture;
	allButtonsObj	: ObjectArray;
	visibleCount	: Integer;
	leftPos			: Real;
	topPos			: Real;
	
begin
	create allButtonsObj transient;
	
	if btnDialog1.visible then
		allButtonsObj.add(btnDialog1);
	endif;
	
	if btnDialog2.visible then
		allButtonsObj.add(btnDialog2);
	endif;
	
	if btnDialog3.visible then
		allButtonsObj.add(btnDialog3);
	endif;
	
	visibleCount	:=	allButtonsObj.size();
	
	if visibleCount = 1 then
		button1Obj	:=	allButtonsObj[1].Button;
		leftPos		:=	(self.clientWidth / 2) - (button1Obj.width / 2);
		button1Obj.move(leftPos, button1Obj.top, button1Obj.width, button1Obj.height);
		
	elseif visibleCount = 2 then
		button1Obj	:=	allButtonsObj[1].Button;
		leftPos		:=	(self.width / 2) - button1Obj.width - 3;
		button1Obj.move(leftPos, button1Obj.top, button1Obj.width, button1Obj.height);
		
		button2Obj	:=	allButtonsObj[2].Button;
		leftPos		:=	(self.width / 2) + 3;
		button2Obj.move(leftPos, button2Obj.top, button2Obj.width, button2Obj.height);
		
	elseif visibleCount = 3 then
		button2Obj	:=	allButtonsObj[2].Button;
		leftPos		:=	(self.width / 2) - (button2Obj.width / 2);
		button2Obj.move(leftPos, button2Obj.top, button2Obj.width, button2Obj.height);
		
		button1Obj	:=	allButtonsObj[1].Button;
		leftPos		:=	button2Obj.left - button1Obj.width - 6;
		button1Obj.move(leftPos, button1Obj.top, button1Obj.width, button1Obj.height);
		
		button3Obj	:=	allButtonsObj[3].Button;
		leftPos		:=	button2Obj.left + button2Obj.width + 6;
		button3Obj.move(leftPos, button3Obj.top, button3Obj.width, button3Obj.height);
	endif;
	
epilog
	delete allButtonsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="162893be-0d81-4f5c-8322-3e7ba3533a15">
