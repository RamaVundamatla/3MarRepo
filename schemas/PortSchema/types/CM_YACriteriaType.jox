    <JadeMethod name="isCMIFDataMatch" id="122af4a5-3972-4b8a-a8f3-5215543045f6">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData : CM_YAData) : Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _cmifAutoPlan.isKindOf(CMIF_YARequest) then
	// We return true by default because many attributes aren't important to a delivery request.
		return true;
	endif;
	
	return false;

end;</source>
