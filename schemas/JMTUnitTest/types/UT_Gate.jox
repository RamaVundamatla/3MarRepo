    <JadeMethod name="tReceiveGCWithDensityDec" id="b533bd7e-1c7e-4a23-923c-5a90f2cc3c3e">
        <updating/>
        <source>tReceiveGCWithDensityDec() updating;
/*

Purpose:			Tests that Density Decimal works as expected

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2021	navpw1	Initial creation TFS: 52193

*/

constants
	Ref						: String	= UT_DSL.TFS52193;
	TrackedItemId 			: String	= "UTSAND" &amp; Ref;
	CargoType 				: String	= "SAND";
	SubCargoType			: String	= "UT_DSAND";
	CargoTypeCommodity		: String	= "SAND";
	BookingId 				: String 	= "UT_BOOKING";
	CargoVolume 			: Decimal	= 233.00;
	
vars
	vvr				: CM_VehicleVisitRecord;
	truck, driver	: String;
	booking			: CM_BookingRef;
	ti				: CM_TrackedItem;
	agent			: CM_MobileAgent;
	wle				: CM_WorkListEntry;
	cargoType		: CM_CargoType;
	
	flexiController	: CMIF_FlexiGateController;
	pxyGateEntity	: CMGTE_Receival;
	gateEntity		: CMGTE_Entity;

begin
	//Clean up our unit test data
	self.deleteCargo(TrackedItemId, CargoType);
	self.deleteBooking(BookingId);
	
	cargoType := getRoot.getCargoTypeFromAbbrevOrDescr(CargoType);
	self.assertNotNull(cargoType);
	
	self.opts.addAssoc("TotalVolume", CargoVolume);
	self.opts.addAssoc("TotalWeight", 0);
	
	booking := self.addBookingForGnlCargoByVolume(BookingId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.voyage, "NZAKL", cargoType, SubCargoType, CargoTypeCommodity);
	
	self.assertNotNull(booking);
	
	//Check Booking TotalVolume, TotalWeight, Volume, Density is correct as weight and volume can be calculated
	self.assertEqual(booking.allBookingRefItems.first.weight.Decimal, 287.8482.Decimal);
	self.assertEqual(booking.allBookingRefItems.first.volume.Decimal, 233.0000.Decimal);
	self.assertEqual(booking.allBookingRefItems.first.productVolume.Decimal, 1.0000.Decimal);
	self.assertEqual(booking.allBookingRefItems.first.density.Decimal, 1.2354.Decimal);
	
	ti := self.addPrenotedBulk(booking.allBookingRefItems.first, TrackedItemId);

	self.assertNotNull(ti);
	
	//Check Ti TotalVolume, TotalWeight, Volume, Density is correct as weight and volume can be calculated
	self.assertEqual(ti.totalWeight.Decimal, 287.8482.Decimal);
	self.assertEqual(ti.totalVolume.Decimal, 233.0000.Decimal);
	self.assertEqual(ti.volume.Decimal, 1.0000.Decimal);
	self.assertEqual(ti.density.Decimal, 1.2354.Decimal);
	
	/*truck	:= self.getTruckName();
	driver	:= self.getDriverName();
	
	self.deleteVehicle(truck);

	self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	
	vvr := self.gateInGC(truck, "", driver, TrackedItemId, CargoType, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
					CargoTypeCommodity, self.dualGate, 1);
					
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	self.assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	self.assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
	self.assertTrue(vvr.vehicle.allRoadJobs.first.workListEntries.first.myRequest.isKindOf(CM_ReceivalRequest));
	self.assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.myRequest.CM_ReceivalRequest.allReceivalInfo.size, 1);
	
	vvr.inspectModal();
		
	self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	if vvr.myTerminal.getConfig (GateTransitIntoYard).Boolean then
		self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.yic.myInTransitToLocation);
	else
		self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.yic.getDefaultLane);
	endif;
	
	create agent transient;
	wle := vvr.vehicle.allRoadJobs.first.workListEntries.first;
	
	create flexiController transient;
	flexiController.id 						:= ti.id;
	flexiController.cargoType 				:= ti.myCargoType.id;
	flexiController.commodity 				:= ti.commodity;
	flexiController.myTerminal 				:= ti.myTerminal;							
	flexiController.isoTypeCode 			:= ti.getISOType();							
	flexiController.operatorCode 			:= ti.operatorCode;						
	flexiController.allowableTimeOffPower 	:= ti.getAllowableTimeOffPower();	
	flexiController.coolingType 			:= ti.getCoolingType();				
	flexiController.voltageType 			:= ti.getVoltageType();
	flexiController.curtainsIn 				:= ti.getCurtainsIn();
	flexiController.setCarbonDioxide( ti.getCarbonDioxide );					
	flexiController.setOxygen( ti.getOxygen );								
	flexiController.setHumidity( ti.getHumidity );							
	flexiController.ventilation 			:= ti.getVentilation();
	flexiController.weightTotal 			:= ti.totalWeight;
	pxyGateEntity := flexiController.createCMGTE_ReceivalProxy(ti.myCargoType);
	pxyGateEntity.setMoveToTruckOnly(true);	//04 Jun 2010	NDl	Par 23903
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateAndActionGateEntity(vvr, pxyGateEntity, wle.myRequest.CM_ReceivalRequest.allReceivalInfo.first, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	app.myPassport.setWarningsIgnored(false);
	
	//agent.moveTI(ti, "", bs.getLocationsController, wle, true, 0, 0);
	//self.assertNoTrxErrorsOrWarnings;
	*/
epilog
	
	app.myPassport.setWarningsIgnored(false);

	// 10/11/2014 cnwmh5
	delete agent;
	delete flexiController;
	delete pxyGateEntity;

end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveMTIntoRTGArea" id="c6878367-a07f-466e-b8c5-ffbb0a0dc6a4">
        <source>tReceiveMTIntoRTGArea();
// cnwdap1
// cnwdw1
constants
	RTG_AREA	= 'UT_RTG';
	CONTAINER 	= 'UT01234567';
	VEHICLE 	= 'UT_TRUCK';
	YA			= "UT_RTG";
vars
	rtgArea: CM_RTGArea;
	vvr: CM_VehicleVisitRecord;
	ti: CM_TrackedItem;
	ya: CM_YardAllocation;
	icArea: CM_InterchangeArea;
	queue: CM_SubQueue;
begin
	deleteQueue(RTG_AREA&amp;"_Q");
	deleteTerminalArea(RTG_AREA);
	deleteContainer(CONTAINER);
	deleteVehicle(VEHICLE);

	//rtgArea := self.getTerminalArea("CMS_RTG").CM_RTGArea;

	rtgArea := addRTGArea(RTG_AREA,  4, 3, 3);

	queue := self.addQueueToTA(RTG_AREA&amp;"_Q", rtgArea);

	self.deleteYA(YA);
	ya := self.addYA1(YA, YACriteriaType_ID, CONTAINER, rtgArea.allLocationsControllers.first);
	self.updateYAPriority(ya, 11);

	vvr := gateInContainer(VEHICLE, CONTAINER, "2200", operator.code, "MT", dualGate);
	
		ti := self.getTrackedItem(CONTAINER);
		
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
//		assertEqual(pGateIn.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);

return;
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, vvr.getGateIn.getDefaultYardLane);
return;		
	self.workVehicle(vvr);
		assertNotNull(ti.getPrimaryLocation(REAL_MODE));
		assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		assertEqual(vvr.vehicle.myPrimaryActualLocation, vvr.getGateIn.getDefaultYardLane);
		

	
	self.moveVehicleToLane(vvr.vehicle, pout, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pout, 1));
		
	self.roadExit(vvr);
		assertNull(vvr.myRoadJob);
		assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveMTIntoYard" id="449d49e1-4f33-4251-ab5c-8c72c7cbc76e">
        <source>tReceiveMTIntoYard();
// cnwdap1
//30 July 2009	cnwdw1	
// gate In comtainer thru to yard, and truck road exit
vars
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	
begin
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");

	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "MT", dualGate);
		ti := self.getTrackedItem("UUT12345678");
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	self.workVehicle(vvr);
		assertNotNull(ti.getPrimaryLocation(REAL_MODE));
		assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
return;		
	self.moveVehicleToLane(vvr.vehicle, pout, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pout, 1));
		
	self.roadExit(vvr);
		assertNull(vvr.myRoadJob);
		assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
		assertNull(vvr.vehicle.myPrimaryActualLocation);
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveMTStorage" id="aef95f20-b310-4b83-b03e-412feb396755">
        <source>tReceiveMTStorage();
// cnwmp6
// CNWJRE1
/*23 September 2010	cnwas3	  par25562
*/

vars

begin
