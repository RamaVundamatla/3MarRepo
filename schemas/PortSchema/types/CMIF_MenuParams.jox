    <JadeMethod name="setForCreate" id="04ebf268-a21b-4ba9-983c-d954cc59b15f">
        <updating/>
        <source>setForCreate(_int1, _int2 : Integer; _obj1, _obj2 : Object;_str1, _str2 : String) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.integer1 := _int1;
	self.integer2 := _int2;
	self.object1 := _obj1;
	self.object2 := _obj2;
	self.string1 := _str1;
	self.string2 := _str2;
end;</source>
        <Parameter name="_int1" type="Integer"/>
        <Parameter name="_int2" type="Integer"/>
        <Parameter name="_obj1" type="Object"/>
        <Parameter name="_obj2" type="Object"/>
