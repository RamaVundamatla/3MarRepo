    <JadeMethod name="isCMIFDataMatch" id="d221ae2e-5b87-4e96-aa90-4447e2cb7cf7">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria

*/

vars

begin
	
	return _cmifAutoPlan.isCountryOfDestRegion_Match(_yaData);

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="3dae347c-8421-4cbe-b5cd-500592e37f99">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria

*/

vars
	obj		: Object;
	yaData  : CM_YAData;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	yaData := _criteria.myYAData;							
	
	foreach obj in yaData.CM_YADataObjects.allObjects do
		if obj.CM_CountryRegion.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
