    <JadeMethod name="tblMain_resizeColumn" id="0bceca4a-ef9a-4044-9729-944a46471ab9">
        <controlMethod name="CM_EntryTable::resizeColumn"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_resizeColumn(table: Table input; column: Integer input; previousWidth: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:     08 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	extraTbl	: CM_EntryTable;
	sheet		: GTE_Sheet;
	
begin

	sheet := self.topSheet;
	
	if sheet = null then
		return;
	endif;
	
	extraTbl := sheet.myTblExtra;
	
	if extraTbl &lt;&gt; null then
		extraTbl.accessColumn(column).width := table.accessColumn(column).width;
		extraTbl.setValueColumnWidth();
	endif;

end;</source>
