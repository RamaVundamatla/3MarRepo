    <DbClassMap file="base"/>
    <PrimAttribute name="defaultValue" id="f9638333-c60f-44f2-ba12-0f16296af09f">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="keyName" id="9b714659-1a6d-44dc-a1db-9ed32b1a9f15">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="keyValue" id="b0b462b0-f7ea-4068-85a0-1828e33b6c74">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myIniSection" id="6d71c81b-ff27-468a-8f22-d23d3c27bebd">
        <kind>child</kind>
        <embedded/>
        <type name="CnEcIniSection"/>
        <access>readonly</access>
        <Inverse name="CnEcIniSection::allIniKeys"/>
    </ExplicitInverseRef>
    <JadeMethod name="getFileName" id="bb063713-f124-4a84-b3a0-54de84fb56bb">
        <source>getFileName():String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Get the name of the initialization file.
//
// Parameters:	None
//
// Returns:		The name of the initialization file.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myIniSection.getFileName();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getListDisplay" id="8d91dc9f-e09b-4afa-b90a-fdb43a2be30f">
        <source>getListDisplay():String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Get the display value for the receiver.
//
// Parameters:	None
//
// Returns:		Thw receiver's display value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.keyName &amp; " = " &amp; self.keyValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="041d43c9-40b0-4df7-a30d-ebced2b28823">
        <updating/>
        <source>set(pKeyName:String;
	pKeyValue:String;
	pDefaultValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Sets the receiver's propery values.
//
// Parameters:	pKeyName - The name of the key.
//				pKeyValue - The value of the key.
//				pDefaultValue - The default value for the key.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.keyName &lt;&gt; pKeyName then
		self.keyName	:=	pKeyName;
	endif;

	if self.keyValue &lt;&gt; pKeyValue then
		self.keyValue	:=	pKeyValue;
	endif;

	if self.defaultValue &lt;&gt; pDefaultValue then
		self.defaultValue	:=	pDefaultValue;
	endif;
end;</source>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pKeyValue" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setIniSection" id="fd2c6348-4b18-48d1-a698-ea780d35097c">
        <updating/>
        <source>setIniSection(pIniSectionObj:CnEcIniSection) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Set a reference to the key's initialization file section.
//
// Parameters:	pIniSectionObj - The section object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myIniSection &lt;&gt; pIniSectionObj then
		self.myIniSection	:=	pIniSectionObj;
	endif;
end;</source>
        <Parameter name="pIniSectionObj" type="CnEcIniSection"/>
    </JadeMethod>
    <JadeMethod name="setKeyValue" id="c11d46d5-68a2-4350-bc57-d9835e0a2a14">
        <updating/>
        <source>setKeyValue(pElementValue:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Set the value of the receiver key.
//
// Parameters:	pElementValue - The key value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.keyValue &lt;&gt; pElementValue then
		if app.setProfileString(self.getFileName(), self.myIniSection.sectionName, self.keyName, pElementValue) then
			self.keyValue	:=	pElementValue;
			return true;
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="pElementValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
