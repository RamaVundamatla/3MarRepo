	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsShow, method.qualifiedName, 2);
	
	// check that the details of the status bar is correct - Load
	app.writeLog("Checking Status Bar (LOAD) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
