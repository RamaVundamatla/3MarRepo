    <JadeMethod name="processDeleteForWO" id="32d3b22c-1d4e-4737-abc5-725256471dd7">
        <source>processDeleteForWO();
/*

Purpose:	to update the work order (if exists ) and its request on delete of the request		

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwrd1	Initial creation

*/

vars
	isRBT 	: Boolean;
	wle 	: CM_WorkListEntry;
	incompleteCount : Integer;
	incompleteTISet : CM_TISet;
	ti			: CM_TrackedItem;
begin

	create incompleteTISet transient;
	// here we need to see if we are a Work order job
	if self.myJob.myWODtl &lt;&gt; null then
	
	// figure out if we are from a RBT
	isRBT := ( self.myWORequestByType &lt;&gt; null);
	
		foreach wle in self.allWorkListEntries do
			// if wle not complete then we need to update some work order detail stats &amp; cargo id's
			if wle.status &lt;&gt; WLE_COMPLETED then
				incompleteCount := incompleteCount +1;
				if wle.myTrackedItem &lt;&gt; null then
					incompleteTISet.add(wle.myTrackedItem );
				endif;
			endif;	
		endforeach;
		
		if incompleteCount &gt; 0 then
		// now have work to do on the wod/requets		
			if isRBT then
			// TI's are not assigned to the WOD untill the WLE is compelte so we can ignore the incompleteTISet
			// incompleteCount needs to update the request
			self.myWORequestByType.setTotalActioned( self.myWORequestByType.totalActioned - incompleteCount  );
			else
			//we need to update the WOD allocated count 			
			self.myJob.myWODtl.setTotalActioned( self.myJob.myWODtl.totalActioned - incompleteCount);
			self.myJob.myWODtl.setTotalUnactioned( self.myJob.myWODtl.totalUnactioned + incompleteCount);
			// and unaction the cargo on the WOD
				foreach ti in incompleteTISet do
					self.myJob.myWODtl.setTIUnactioned( ti, false);
				endforeach;
			endif;
		
		endif;
	endif;	

epilog
	delete incompleteTISet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c85be715-e434-4c3b-b332-78042a6cbade">
        <updating/>
        <source>setForCreate(_proxyRequest: CM_ToDoRequest) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwrd1	Initial creation

*/

vars

begin

	self.totalRequested := _proxyRequest.CM_TiToDoRequest.totalRequested;
	inheritMethod(_proxyRequest);

epilog

end;</source>
        <Parameter name="_proxyRequest" type="CM_ToDoRequest"/>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="a9ca408d-d466-487f-a14f-45b8c502d99c">
        <updating/>
        <source>setForCreateInternal(_myJob : CM_ToDoJob; _toDoInternalJobParam : CMIF_WorkOrderJobParams) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwrd1	Initial creation

*/


/*
 ------------------------------------------------------------------------
Created:			26 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin

	self.myJob := _myJob;
	self.totalRequested := _toDoInternalJobParam.numberToQueue;
	self.requiredBtDT := _toDoInternalJobParam.requiredByDT;
	self.myWORequestByType := _toDoInternalJobParam.myWORequestbyType;
	
end;</source>
        <Parameter name="_myJob" type="CM_ToDoJob"/>
        <Parameter name="_toDoInternalJobParam" type="CMIF_WorkOrderJobParams"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2a64b634-0186-4f09-80e4-13ab55dda210">
        <updating/>
        <source>setProxy(_ti : CM_TrackedItem; _requestType : CM_ToDoRequestType; _userCode : String; _job : CM_Job) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setProxyForToDoRequest(_requestType, _userCode, _job);
	
	self.myTrackedItem := _ti;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_requestType" type="CM_ToDoRequestType"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
