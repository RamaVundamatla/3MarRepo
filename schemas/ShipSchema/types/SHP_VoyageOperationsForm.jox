//--------------------------------------------------
// Created:	01 October 2003 By: cnwgd1
//--------------------------------------------------
vars
begin
	//argh really annoying how double-clicking when there are no jobs selected closes the selector
	if self.allSelectedVoyageJobsArray.size = 0 and self.myInitJob = null then
