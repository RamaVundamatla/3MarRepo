    <JadeMethod name="tAddInterTermConfig" id="0fdb72d4-c251-4a53-b406-2ef57f390e13">
        <source>tAddInterTermConfig();
// cnwndl1
/* cnwrd1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwrd1	Initial creation

*/

vars
	itc : CM_InterTerminalConfig;
	gate       : CM_Gate;
	laneController : CM_YardController;
	sourceTerm : CM_Terminal ; 
	ta : CM_TerminalArea;
	autoIn, autoOut : Boolean; 
	destTerm : CM_Terminal;
	consignee : CM_ConsigneeConsignor;
	voyCode : String;
	voyage : CM_Voyage;
	delReasonID : Integer;
	delReason : String;
	subTerm : CM_SubTerminal;
	delreason : CM_DeliveryReleaseReason;
	adminGate: CM_GateArea;
begin


	sourceTerm := self.getTerminal();
	self.deleteTerminalArea('ITCBS1');
	ta := self.addBlockStack('ITCBS1', 20 , null);
	gate := sourceTerm.getDefaultGate_OUT();
	
	adminGate := gate.getFirstAGate_IN();		
	if adminGate &lt;&gt; null then
			laneController := adminGate.getLaneByNumber(1);
	endif;

	autoIn := true;  
	autoOut := true;
	
	destTerm := app.myRoot.allTerminals['DP1'];	
	self.assertNotNull(destTerm);						// 10/11/2016 cnwmh5
	
	consignee := app.myRoot.allConsigneeConsignors.first;
	voyCode := '';
	
	delreason := app.myRoot.allDeliveryReasonselReasons.first;
	
	delReasonID := delreason.id;
	delReason := delreason.description;	
	subTerm := sourceTerm.getDefaultSubTerminalForRel(BR_TYPE_ROAD);
	
	
	self.deleteInterTermConfig('RJDUTCONF');

	itc := self.addInterTermConfig('RJDUTCONF',
									gate,
									laneController,
									sourceTerm,
									ta,
									autoIn, 
									autoOut,
									destTerm,
									consignee,
									voyCode,
									voyage,
									delReasonID,
									delReason,
									subTerm
									);

	self.assertNotNull( itc);
	self.assertEqual(itc.myGate , gate);
	self.assertEqual(itc.myLaneController , laneController);
	self.assertEqual(itc.mySourceTerminal , sourceTerm);
	self.assertEqual(itc.allSourceAreas.first , ta);
	self.assertEqual(itc.autoAssignCargoOnMoveIn , autoIn);
	self.assertEqual(itc.autoUnassignCargoOnMoveOut , autoOut);
	self.assertNotNull( itc.allInterTermTargetTermInfo.first);	
	self.assertEqual(itc.allInterTermTargetTermInfo.first.myTargetTerminal , destTerm);
	self.assertEqual(itc.allInterTermTargetTermInfo.first.autoPlanAtDestTerminal , true);
	
					
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tChkErrorsWhenIDExistsTfrTerm" id="e6c2ec5c-c5a8-403a-b2a9-afd53e5d094f">
        <updating/>
        <source>tChkErrorsWhenIDExistsTfrTerm() updating;
/* cnwmh5

Purpose:	For an inter terminal transfers check that returns an error if id already exists.

Date		Who		Reason
04/07/2011	cnwmh5	Initial creation
16/07/2012	cnwmh5	Change to that after is clears app.opts it sets myPassport's myTerminal to the correct terminal.
					Because we are using multiple terminals there is an issue when deleting the prenote as it updates
					the passport's myTerminal with the ti's myTerminal.  In the normal running of things this shouldn't
					be an issue but it is for the unit tests
*/
constants
	VehicleID 			: String = 'UTMDH1';
	TiID1				: String = 'UTMDH000007';
	DriverID 			: String = 'UTMDHDRIVER';
	BlockStackName 		: String = "UTMDHBS7";
	DestTerminalName	: String = "Michael's UT Terminal";
	DestTerminalCode	: String = "MH1";
	InterTermConfig		: String = "UTMDHITCONF";
	CarrierID			: String = "UTMDHCAR";
	CarrierDesc			: String = "Michael's Carrier";
	ConsigneeID			: String = "UTMHF";
	ConsigneeDesc		: String = "Michael's UT Consignee/Consignor";
	DestBS				: String = "UTMDHBS5";
	BookingID			: String = "UTMDHBook1";
	VoyageID			: String = "UTMDHVOY1";
	VesselID			: String = "UTMDHVES1";
vars

	itc 				: CM_InterTerminalConfig;
	gate       			: CM_Gate;
	laneController 		: CM_YardController;
	sourceTerm 			: CM_Terminal ; 
	ta 					: CM_TerminalArea;
	bsDT				: CM_TerminalArea;
	autoIn, autoOut 	: Boolean; 
	destTerm 			: CM_Terminal;
	consignee 			: CM_ConsigneeConsignor;
	voyage 				: CM_Voyage;
	subTerm 			: CM_SubTerminal;
	delreason 			: CM_DeliveryReleaseReason;
	vehicle 			: CM_Vehicle;
	ti			 		: CM_TrackedItem;
	itj 				: CM_InterTermVehicleJob;
	itm 				: CM_InterTerminalMove;
	egc 				: CMIF_EasyGateController;
	adminGate			: CM_GateArea;
	booking 			: CM_BookingRef;
	vessel				: CM_Vessel;
	carrier				: CM_Carrier;
	
	allCarriers			: CM_CarrierByCodeDict;
	allVehicleMachines 	: CM_VehicleSet; 
	pinEmailAddresses	: CM_EmailEntityByTypeNameDict;
	
	voyCode 			: String;
	delReasonID 		: Integer;
	delReason	 		: String;
	etaEtdMandatory		: Boolean;
	
begin

	// set terminal configs
	etaEtdMandatory	:= self.getTerminalConfig("EtaEtdMandatory").Boolean;
	self.setTerminalConfig("EtaEtdMandatory", false);

	// delete the vehicles from source / destination terminals
	self.deleteVehicle(VehicleID);
	self.opts.purge;
	self.opts.addAssoc("Terminal", DestTerminalCode);
	self.deleteVehicle(VehicleID);
	
	// create the carrier
	self.deleteCarrier(CarrierID);
	create pinEmailAddresses transient;
	carrier := self.addCarrier(CarrierID, CarrierDesc, pinEmailAddresses, false, true, true, null);
	self.assertNotNull(carrier);
	
	// create the consignee
	self.deleteConsigneeConsignor(ConsigneeID);
	consignee := self.addConsigneeConsignor(ConsigneeID, ConsigneeDesc, true, true, true);
	self.assertNotNull(consignee);

	// setup destination terminal stuff
	destTerm := self.getTerminal();
	
	// create voyage
	self.deleteVoyage(VoyageID);
	self.deleteVessel(VesselID);
	vessel := addVesselCellular(VesselID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	voyage := addVoyageWithContainerStructur(VoyageID, VesselID, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage);
	
	self.deleteTerminalArea(DestBS);
	bsDT := self.addBlockStack(DestBS, 50, null);
	self.assertNotNull(bsDT);
	
	// need vehicle	 in source and target terminal
	self.deleteVehicle(VehicleID);
	vehicle := self.addVehicle( VehicleID, carrier, destTerm);
	self.assertNotNull(vehicle);
	
	// create a prenote
	self.deleteContainer(TiID1);
	self.deleteBooking(BookingID);
	booking := self.addBookingForContainer(BookingID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 
		voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first, TiID1);
	self.assertNotNull(ti);
	
	self.opts.purge;
	
	app.myPassport.setMyTerminal(self.getTerminal);			// 16/07/2012 cnwmh5
		
	// setup source terminal details
	sourceTerm := self.getTerminal();
	subTerm := sourceTerm.getDefaultSubTerminalForRel(BR_TYPE_ROAD);
	
	// setup source bs
	self.deleteTerminalArea(BlockStackName);
	ta := self.addBlockStack(BlockStackName, 50, null);
	self.assertNotNull(ta);
	
	// get the gate details
	gate := sourceTerm.getDefaultGate_OUT();
	adminGate := gate.getFirstAGate_IN();
	if adminGate = null then
		laneController := adminGate.getLaneByNumber(1);
	endif;
	autoIn := true;
	autoOut := true;
	
	// create the vehicle in each terminal
	self.deleteVehicle(VehicleID);
	vehicle := self.addVehicle( VehicleID, carrier, sourceTerm);
	self.assertNotNull(vehicle);
	
	consignee := app.myRoot.allConsigneeConsignors[ConsigneeID];
	voyCode := "";
	delreason := app.myRoot.allDeliveryReasonselReasons.first;
	delReasonID := delreason.id;
	delReason := delreason.description;	
	
	// create inter terminal config
	self.deleteInterTermConfig(InterTermConfig);
	itc := self.addInterTermConfig(InterTermConfig,
									gate,
									laneController,
									sourceTerm,
									ta,
									autoIn, 
									autoOut,
									destTerm,
									consignee,
									voyCode,
									voyage,
									delReasonID,
									delReason,
									subTerm
									);
	
	ti := self.addContainer(TiID1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	
	// need cargo item assigned to the release (moved to ITCBS1 should do it)
	self.move( ti, ta);  //should allocate it to the BR
	
	self.assertTrue(itc.myRelease.allTrackedItemsAssigned.includes(ti) );
	
	// ok now in a position to shift the cargo
	// need an inter terminal vehicle job
	itj := app.myRoot.allInterTerminalVehicleJobs.getAtKey( VehicleID,'' );
	
	if itj = null then
		itj := self.addInterTermVehicleJob( vehicle );
	endif;
	
	// should now have an inter terminal job.
	self.assertNotNull(itj);
	
	// then an inter terminal move
	itm := self.addInterTerminalMove( ti , sourceTerm, destTerm , vehicle , itj);
	self.assertNotNull(itm);
	
	// create driver details
	self.deleteDriverDetails(DriverID);
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(vehicle);
	self.createDriverDetails(DriverID, allCarriers, allVehicleMachines);
	
	// then set up the controller to do the gate out
	create egc transient;
		
	egc.myTerminal := sourceTerm;
	egc.driver     := DriverID;
	
	egc.myInterTermVehicleJob := itj;	
	egc.allMovesForLoading.add( itm );
	
	//gate out
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateEasyGateOut(egc, app.myPassport); 
	
	///  Needs to check here for newly created error
	self.assertTrxError(ERR_PRENOTE_ID_EXISTS_DEST);
	
	delete egc;
	
epilog
	self.setTerminalConfig("EtaEtdMandatory", etaEtdMandatory);
	
	delete allVehicleMachines;
	delete allCarriers;
	delete pinEmailAddresses;
	delete egc;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToTermWithAvailGradeAndToDo" id="2e4b7a52-ac9b-44c1-a66a-1e3ee8910387">
        <source>tToTermWithAvailGradeAndToDo();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2010	cnwndl1	Initial creation - copy of tTransferCargo, enhanced to specifically
										test the Todo Task and Availability Grade changes from 
										CCMS 1895 / Par 23991.
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
02/11/2022 	navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
16 Apr 2024	jlirs1	TFS 9999 - Fixing unitTests
19/6/2025   jlier1 MTN-34221 refactoring validation so is before trx - means all errors and warnings shown at once - so changed to check for just errors
*/

constants

	VehicleID : String = "UT_TrukZ";
	TiID : String = "SUBT0001002";
	AvailGradeCode : String = "UT_AvailZ";
	ToDoTaskCode : String = "UT_ToDoZ";
	IntTermConfigID : String = "UT_INTTERMCONFIGZ";
	TermAreaID : String = "ITCBS1";
	DriverID : String = 'UTDRIVER';
	DestTermID : String = "DP1";
vars

	itc : CM_InterTerminalConfig;
	gate       : CM_Gate;
	laneController : CM_YardController;
	sourceTerm : CM_Terminal ; 
	ta : CM_TerminalArea;
	autoIn, autoOut : Boolean; 
	destTerm : CM_Terminal;
	consignee : CM_ConsigneeConsignor;
	voyCode : String;
	voyage : CM_Voyage;
	delReasonID : Integer;
	delReason : String;
	subTerm : CM_SubTerminal;
	delreason : CM_DeliveryReleaseReason;
	vehicle : CM_Vehicle;
	ti, targetTi : CM_TrackedItem;
	itj : CM_InterTermVehicleJob;
	itm : CM_InterTerminalMove;
	egc : CMIF_EasyGateController;
	lc : CM_LocationsController;
	tmpFoundHeight : Integer;
	adminGate: CM_GateArea;
	
	pxyTI : CM_TrackedItem;
	toDoTaskDesc : CM_ToDoTaskDesc;
	availGrade : CM_MTGrade;
	tiTask : CM_ToDoTask;
	pxyToDo : CM_ToDoTaskDesc;
	allowedTerminals : CM_TerminalSet;
	error : CM_Error;
	pxyGrade : CM_MTGrade;
	allEditSubTerms : CM_SubTerminalByCodeDict;
	carrier : CM_Carrier;
	str	: String;
	
begin

	self.deleteVehicle(VehicleID);

	sourceTerm := self.getTerminal();
	self.deleteTerminalArea(TermAreaID);
	ta := self.addBlockStack(TermAreaID, 20 , null);
	gate := sourceTerm.getDefaultGate_OUT();
	adminGate := gate.getFirstAGate_IN();		
	if adminGate &lt;&gt; null then
		laneController := adminGate.getLaneByNumber(1);
	endif;

	autoIn := true;  
	autoOut := true;
	destTerm := app.myRoot.allTerminals[DestTermID];	
	create allEditSubTerms transient;
	sourceTerm.allSubTerminals.copy( allEditSubTerms );
	foreach subTerm in  destTerm.allSubTerminals do
		allEditSubTerms.add(subTerm);
	endforeach;
	consignee := app.myRoot.allConsigneeConsignors.getAtKey("UTCC1");
	self.assertTrueMsg(consignee &lt;&gt; null, "Consignee 'UTCC1' not found.");
	self.assertTrueMsg(consignee.isConsignee, "Consignee 'UTCC1' not set as a 'consignee'.");
	voyCode := '';
	delreason := app.myRoot.allDeliveryReasonselReasons.first;
	self.assertTrueMsg(delreason &lt;&gt; null, "No delivery reason found.");
	delReasonID := delreason.id;
	delReason := delreason.description;	
	subTerm := sourceTerm.getDefaultSubTerminalForRel(BR_TYPE_ROAD);
	
	//setup new todo task desc with all sub terms of source and dest term available.
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey( ToDoTaskCode );
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription( toDoTaskDesc );
		self.assertTrueMsg( app.myPassport.trxCompletedOK(), "Unable to delete old ToDo Task Desc during set up. " &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr() );
	endif;
	
	toDoTaskDesc := self.createToDoTaskDesc( ToDoTaskCode );
	self.assertTrueMsg( app.myPassport.trxCompletedOK(), "Unable create ToDo Task Desc during set up. " &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr() );
	
	beginTransaction;
	toDoTaskDesc.setAllAllowedEditSubTerms(allEditSubTerms);
	commitTransaction;
	//setup new availability grade with all sub terms of source and dest term available.
	availGrade := self.createAvailabilityGrade( AvailGradeCode );
	beginTransaction;
	availGrade.setAllAllowedEditSubTerms(allEditSubTerms);
	commitTransaction;
	
	self.deleteInterTermConfig(IntTermConfigID);
	
	itc := self.addInterTermConfig(IntTermConfigID,
									gate,
									laneController,
									sourceTerm,
									ta,
									autoIn, 
									autoOut,
									destTerm,
									consignee,
									voyCode,
									voyage,
									delReasonID,
									delReason,
									subTerm
									);
	// check we have the truck set up in both terminals.
	carrier := app.myRoot.allCarriers.getAtKey("DOUG"); //app.myRoot.allCarriers.first
	vehicle := destTerm.vehicles[VehicleID,""];
	self.opts.addAssoc("Terminal", DestTermID);
	self.deleteVehicle( vehicle);
	self.opts.purge;
	vehicle := destTerm.vehicles[VehicleID,""];
	if vehicle = null then
		vehicle := self.addVehicle( VehicleID, carrier , destTerm);
	endif;									
	self.assertNotNull(vehicle);
	
	
	vehicle := null;
	vehicle := sourceTerm.vehicles[VehicleID,""];
	if vehicle = null then
		vehicle := self.addVehicle( VehicleID, carrier , sourceTerm);
	endif;
	self.assertNotNull(vehicle);
	
	// delete the ti from the source and the target, if it alreday exists.
	self.deleteContainer(TiID);
	ti := destTerm.lookupTrackedItem(TiID, TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false); // AKB added false
	endif;

	// create the tracked item in the source terminal.
	ti := self.addContainer(TiID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	//set the availability grade on the new ti, to one that is not allowed to be released
	pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	pxyTI.setPxyFromFieldValue(CM_EDICargoFieldUpdateTI.F_AvailabilityGrade, availGrade.code.String, null, app.myPassport);
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyTI;
	
	//add a todo task to the new ti.
	beginTransaction;
	tiTask := ti.addToDoTask( toDoTaskDesc.description.trimBlanks , app.myPassport );
	commitTransaction;
	self.assertTrueMsg(tiTask &lt;&gt; null, "Task '" &amp; toDoTaskDesc.description.trimBlanks &amp; "' not created for '" &amp; TiID &amp; "'.");
	
	// need cargo item assigned to the release (moved to ITCBS1 should do it)
	self.move( ti, ta);  //should allocate it to the BR
	self.assertTrue(itc.myRelease.allTrackedItemsAssigned.includes(ti) );
	
	// ok now in a position to shift the cargo
	// need an inter terminal vehicle job
	
	itj := app.myRoot.allInterTerminalVehicleJobs.getAtKey( VehicleID,'' );
	if itj = null then
		itj := self.addInterTermVehicleJob( vehicle );
	endif;
	// should now have an inter terminal job.
	self.assertNotNull(itj);

	
	// then an inter terminal move
	itm := self.addInterTerminalMove( ti , sourceTerm, destTerm , vehicle , itj);
	self.assertNotNull(itm);
	
	// then set up the controller to do the gate out
	create egc transient;	
	egc.myTerminal := sourceTerm;
	egc.driver     := DriverID;
	egc.myInterTermVehicleJob := itj;	
	egc.allMovesForLoading.add( itm );
		
	//attempt the gate out - should be rejected due to the to do task not having the dest term included in the allowed 'release terminals'
	app.myTrxCA.trxCreateEasyGateOut( egc, app.myPassport );
	
	error := app.myPassport.getFirstErrorNonWarning();
	self.assertTrueMsg(error &lt;&gt; null and error.errorCode = 86566, "Release 1. Not the error we expected.  Got a '" &amp; error.errorCode.String &amp; "' instead of a '86566'");
	self.assertTrueMsg(error &lt;&gt; null, "Release attempt 1. No error raised against releasing a ti to a sub terminal when the ti has a todo task set and sub term not selected as releases allowed on ToDo Description.");
	error := null;
	app.myPassport.clearErrorsWarnings;
	
	//set the todo task so JMT is allowed to release cargo to the dest term that includes this todo task set on them.
	create allowedTerminals transient;
	allowedTerminals.add( destTerm );
	pxyToDo := app.createUpdateProxy(toDoTaskDesc).CM_ToDoTaskDesc;
	pxyToDo.setProxy(	toDoTaskDesc.description,	//pDesc:String;
						toDoTaskDesc.shortDescription,	//pShortDesc:String;
						toDoTaskDesc.sortKey,	//pSortKey:Integer;
						toDoTaskDesc.reportDescription,	//pReportDesc:String;
						toDoTaskDesc.emptyReportColumn,	//pEmptyReportColumn: Integer;
						null,	//_trxTypeOnCompletion : CM_TransactionType;			// 22 Feb 2010 RJS - PAR 22099
						null,	//_trxTypeOnCreation : CM_TransactionType; //cnwrs1 CCMS 1826 29 July 2010
						toDoTaskDesc.allCargoTypes,	//pAllCargoTypes : Collection;
						toDoTaskDesc.allResourceTypes,	//pAllResourceTypes : Collection;//18 Dec 2009	NDL	CCMS MES 1006
						toDoTaskDesc.requiresWorkOrder,	//_requiresWorkOrder : Boolean;
						toDoTaskDesc.requiredExtraInfo,	//_requiredExtraInfo : String;
						allowedTerminals,	//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
						toDoTaskDesc.allAllowedEditSubTerms,	//_selectedSubTerminals : CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
						TODO_TYPE_GROUP_TI,	//02/11/2022 navds20 TFS #56635[54261]
						null,				//02/11/2022 navds20 TFS #56635[54261]	
						null,				//02/11/2022 navds20 TFS #56635[54261]
						toDoTaskDesc.doNotBlockRTL //11/12/2023 jlizm1 TFS 61654
						);
	app.myTrxUA.trxUpdateToDoTaskDesc(pxyToDo, app.myPassport);
	self.assertTrueMsg(app.myPassport.hasErrors = false, "Update to allow release of ToDo failed - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	
	// now try gate out again - should fail again with the same type of error against the availability grade
	app.myPassport.clearErrorsWarnings;
	app.myTrxCA.trxCreateEasyGateOut( egc, app.myPassport );
	error := app.myPassport.getFirstErrorNonWarning();
	self.assertTrueMsg(error &lt;&gt; null and error.errorCode = 86567, "Release 2. Not the error we expected.  Got a '" &amp; error.errorCode.String &amp; "' instead of a '86567'");
	self.assertTrueMsg(error &lt;&gt; null, "Release attempt 2. No error raised against releasing a ti to a sub terminal wthen the ti has a non releasable availability and sub term not selected as releases allowed on Availability Grade.");
	error := null;
	app.myPassport.clearErrorsWarnings;
	
	//now set the availability grade so JMT is allowed to release cargo with this grade to the dest term.
	pxyGrade := app.createUpdateProxy(availGrade).CM_MTGrade;
	pxyGrade.setProxy(	availGrade.code,	//pCode:Integer;
						availGrade.description,	//pDescription:String;
						availGrade.isSuitableForRelease,	//pIsSuitableForRelease : Boolean;
						availGrade.isNotAvailableForEntry,	//_isNotAvailableForEntry : Boolean;
						availGrade.colour,	//_colour : Integer;
						allowedTerminals,	//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
						availGrade.allAllowedEditSubTerms	//_selectedSubTerminals : CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
						);
	app.myTrxUA.trxUpdateAvailabilityGrade(pxyGrade, app.myPassport);
	self.assertTrueMsg(app.myPassport.hasErrors = false, "Update to allow release of Availability Grade failed - " &amp; app.myPassport.getErrorsAndWarningsAsString);

	// now try gate out again - should work this time.
	app.myPassport.clearErrorsWarnings;
	
	while true do
		app.myTrxCA.trxCreateEasyGateOut( egc, app.myPassport );
		if app.myPassport.trxCompletedOK then

			app.myPassport.clearErrorsWarnings();
			break;
		else
			if app.myPassport.noErrors then

				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		error := app.myPassport.getFirstErrorNonWarning();
		self.assertTrueMsg(error = null, "Gating out interterminal release.  '" &amp; error.text &amp; "'");
		break;
	endwhile;
	
	app.myPassport.clearErrorsWarnings;
	delete egc;
	
	
	//now setup controller to do gate in
	
	destTerm.findLocationFromString('BS1', true, lc, tmpFoundHeight);
	self.assertNotNull(lc);
	self.updateInterTermMove( itm, itm.status, lc );
	
	create egc transient;
	egc.myTerminal := destTerm;
	egc.driver     := DriverID;
	
	egc.myInterTermVehicleJob := itj;	
	egc.allMovesForOffloading.add( itm );

	
	// gate in at the dest term
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(false);
	
	while true do
		app.myTrxCA.trxCreateEasyGateIn( egc, app.myPassport );
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
		else
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

		endif;
		error := app.myPassport.getFirstErrorNonWarning();
		self.assertTrueMsg(error = null, "Gating in interterminal release.  '" &amp; error.text &amp; "'");
		break;
	endwhile;
	
	targetTi := destTerm.lookupTrackedItem(TiID, TI_CargoType_Container, TI_STATE_NORMAL, null, false);
	
	self.assertNotNull( targetTi );
	//targetTi.inspect;
	self.assertTrue( targetTi.isOnSite());
	self.assertFalse( ti.isOnSite());
	
	self.assertTrueMsg(not targetTi.allToDoTasksToDo.isEmpty, "To do tasks were not created on the Cargo in the Target terminal.");
	tiTask := targetTi.allToDoTasksToDo.first;
	self.assertTrueMsg(tiTask.toDoTaskDesc = toDoTaskDesc,"Created a to do task, on the ti in the traget terminal, but not the one we were expecting.");
	
	// 10/09/2015 cnwmh5
	beginTransaction;
	ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	targetTi.setRemarks(self.createdByUnitTest(null), true);
	commitTransaction;
	
epilog

	delete egc;
	delete pxyTI;
	delete pxyToDo;
	delete pxyGrade;
	delete allowedTerminals;
	delete allEditSubTerms;
	
	// delete the new todo task
	self.deleteToDoTaskDescription( toDoTaskDesc );
	
	// delete the new availability grade
	self.deleteAvailabilityGrade( availGrade );
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTransferCargo" id="584b185c-a0c7-4fef-a24c-9074b4f382b5">
        <source>tTransferCargo();
// cnwndl1
/* cnwrd1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwrd1	Initial creation
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/
constants
	VehicleID : String = 'RJDUTV2';
	TiID : String = 'UUT11111114';
	DriverID : String = 'RJDDRIVER';
	DestTermID : String = "JBL";
vars

	itc : CM_InterTerminalConfig;
	gate       : CM_Gate;
	laneController : CM_YardController;
	sourceTerm : CM_Terminal ; 
	ta : CM_TerminalArea;
	autoIn, autoOut : Boolean; 
	destTerm : CM_Terminal;
	consignee : CM_ConsigneeConsignor;
	voyCode : String;
	voyage : CM_Voyage;
	delReasonID : Integer;
	delReason : String;
	subTerm : CM_SubTerminal;
	delreason : CM_DeliveryReleaseReason;
	vehicle : CM_Vehicle;
	ti, targetTi : CM_TrackedItem;
	itj : CM_InterTermVehicleJob;
	itm : CM_InterTerminalMove;
	egc : CMIF_EasyGateController;
	lc : CM_LocationsController;
	tmpFoundHeight : Integer;
	adminGate: CM_GateArea;
begin

	self.deleteVehicle(VehicleID);
	
	self.deleteContainer(TiID);
		
	sourceTerm := self.getTerminal();
	//app.myRoot.allTerminals['RJD'];	
	self.deleteTerminalArea('ITCBS1');
	ta := self.addBlockStack('ITCBS1', 60 , null);
	gate := sourceTerm.getDefaultGate_OUT();
	adminGate := gate.getFirstAGate_IN();		
	if adminGate &lt;&gt; null then
		laneController := adminGate.getLaneByNumber(1);
	endif;


	autoIn := true;  
	autoOut := true;
	
	destTerm := app.myRoot.allTerminals[DestTermID];	
	self.opts.addAssoc("Terminal", DestTermID);
	self.deleteVehicle(VehicleID);
	opts.purge();
	
	consignee := app.myRoot.allConsigneeConsignors['ROB'];
	voyCode := '';
	
	delreason := app.myRoot.allDeliveryReasonselReasons.first;
	
	delReasonID := delreason.id;
	delReason := delreason.description;	
	subTerm := sourceTerm.getDefaultSubTerminalForRel(BR_TYPE_ROAD);
	
	
	self.deleteInterTermConfig('RJDUTCONF');

	itc := self.addInterTermConfig('RJDUTCONF',
									gate,
									laneController,
									sourceTerm,
									ta,
									autoIn, 
									autoOut,
									destTerm,
									consignee,
									voyCode,
									voyage,
									delReasonID,
									delReason,
									subTerm
									);
	//now target
	vehicle := destTerm.vehicles[VehicleID,""];
	//self.deleteVehicle( vehicle);
	if vehicle = null then
		vehicle := self.addVehicle( VehicleID, app.myRoot.allCarriers['RJDC'] , destTerm);
	endif;
										
	self.assertNotNull(vehicle);
	vehicle := null;
	
	// need vehicle	 in source and target terminal
	vehicle := sourceTerm.vehicles[VehicleID,""];
//	self.deleteVehicle( vehicle);
	if vehicle = null then
		vehicle := self.addVehicle( VehicleID, app.myRoot.allCarriers['RJDC'] , sourceTerm);
	endif;
	
	self.assertNotNull(vehicle);
		
	self.deleteContainer(TiID);
	// and delete it from the target
	
	ti := destTerm.lookupTrackedItem(TiID, TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false); // AKB added false
	endif;

	
	ti := self.addContainer(TiID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	
	// need cargo item assigned to the release (moved to ITCBS1 should do it)
	self.move( ti, ta);  //should allocate it to the BR
	
	self.assertTrue(itc.myRelease.allTrackedItemsAssigned.includes(ti) );
	
	// ok now in a position to shift the cargo
	
	// need an inter terminal vehicle job
	
	itj := app.myRoot.allInterTerminalVehicleJobs.getAtKey( VehicleID,'' );
	
	if itj = null then
		itj := self.addInterTermVehicleJob( vehicle );
	endif;
	
	// should now have an inter terminal job.
	self.assertNotNull(itj);

	
	// then an inter terminal move
	itm := self.addInterTerminalMove( ti , sourceTerm, destTerm , vehicle , itj);
	self.assertNotNull(itm);
	
	// then set up the controller to do the gate out
	
	create egc transient;
		
	egc.myTerminal := sourceTerm;
	egc.driver     := DriverID;
	
	egc.myInterTermVehicleJob := itj;	
	egc.allMovesForLoading.add( itm );
	//gate out
	self.doEasyGateOut(egc);	
	
	
	delete egc;
	
	
	//now setup controller to do gate in
	
	destTerm.findLocationFromString('BS1', true, lc, tmpFoundHeight);
	self.assertNotNull(lc);
	
	self.updateInterTermMove( itm, itm.status, lc );
	
	create egc transient;
	
	egc.myTerminal := destTerm;
	egc.driver     := DriverID;
	
	// probably need to update the itm with a location to offload to 

	
	egc.myInterTermVehicleJob := itj;	
	egc.allMovesForOffloading.add( itm );
	// gate in
	app.myPassport.warningsAcknowledged	:= true;
	app.myPassport.setWarningsIgnored(true);
	self.doEasyGateIn(egc);	
	

	targetTi := destTerm.lookupTrackedItem(TiID, TI_CargoType_Container, TI_STATE_NORMAL, null, false);
	self.assertNotNull( targetTi );
	//targetTi.inspect;
	self.assertTrue( targetTi.isOnSite());
	self.assertFalse( ti.isOnSite());

	// 10/09/2015 cnwmh5
	beginTransaction;
	ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	targetTi.setRemarks(self.createdByUnitTest(null), true);
	commitTransaction;
	
epilog
	app.myPassport.setWarningsIgnored(false);
	delete egc;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTransferCargoRail" id="5b797162-6dac-465b-b49a-38a159c4e56e">
        <updating/>
        <source>tTransferCargoRail() updating;
/* jlgmd1

Purpose:	Create an inter terminal rail transfer

Date		Who		Reason
02/02/2017	cnwrs1	Initial creation
09/10/2017	jlgmd1	Finish implementation and added cargo restriction as part of TFS 7040
28/08/2018	jlgmd1	Work around 'weird' situation when cleaning up previous TIs would create new ones
23/04/2024	navpw1	Added terminal config reset for PrenoteUniqBooking in epilog

*/
constants
	TiID1				: String = 'UTMDH000001';
	TiID2				: String = 'UTMDH000002';
	TiID3				: String = 'UTMDH000003';
	TiID4				: String = 'UTMDH000004';
	ISOType				: String = "2200";
	TiCommodity			: String = "GB1";
	InterTermConfig		: String = "UTMDHITCONF";
	ConsigneeID			: String = "UTMHF";
	ConsigneeDesc		: String = "Michael's UT Consignee/Consignor";
	BookingID			: String = "UTMDHBook1";
	WagonClassID		: String = "ZZ";
	WagonID				: String = "ZZ12345678";
	TrainID				: String = "UT-TRAIN5";
	RailAreaID 			: String = "UT_RA46";
	DestTermID			: String = "JBL";
vars

	itc 				: CM_InterTerminalConfig;
	destTerm 			: CM_Terminal;
	consignee 			: CM_ConsigneeConsignor;
	subTerm 			: CM_SubTerminal;
	delreason 			: CM_DeliveryReleaseReason;
	ti					: CM_TrackedItem;
	ti1, ti2, ti3, ti4	: CM_TrackedItem;	
	wagonClass			: CM_WagonClass;
	wagonMaster			: CM_WagonMaster;
	wagon				: CM_Wagon;
	railArea			: CM_Rail;
	terminal			: CM_Terminal;
	railLine			: CM_RailLine;
	train				: CM_Train;
	proxyCriteria		: CM_YACriteria;
	pxyCargoRestrict	: CM_CargoRestrictionCriteria;
	cargoRestrict		: CM_ObjectMatchCriteria;
	rake				: CMIF_RakeRegion;
	cmifCriteria 		: CMIF_YACriteriaPriority;
	moveController		: CMIF_MoveController;
	

	pinEmailAddresses	: CM_EmailEntityByTypeNameDict;
	allTransientCriteriaObj	: CMIF_Array;
	tiArray				: CM_TIArray;
	
	voyCode 			: String;
	delReasonID,
	count				: Integer;
	delReason,
	trainCode			: String;
	objSet				: ObjectSet;
	subTerminalsEnabled,
	prenoteUniqBooking	: Boolean;
	
begin
	// Keep a reference to the UT terminal
	terminal := app.myPassport.myTerminal;
	prenoteUniqBooking := self.setTerminalConfig(PrenoteUniqBooking, false).Boolean;
	destTerm := app.myRoot.allTerminals[DestTermID];
	beginTransaction;
	destTerm.setConfig(PrenoteUniqBooking, false);
	commitTransaction;

	subTerminalsEnabled := self.getTerminalConfig(IsSubTerminalsOn).Boolean;
	self.setTerminalConfig(IsSubTerminalsOn, true);
	self.assertTrueMsg(app.isSubTerminalsLicensed, "Not licensed for sub terminals!");
	self.assertTrueMsg(app.isSubTerminalsOn(terminal), terminal.name &amp; " not set up for sub terminals!");
	
	// ********************
	// ***** Clean Up *****
	// ********************
	wagonClass := app.myRoot.allWagonClasses[WagonClassID];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	railArea := terminal.allTerminalAreasByTypeId.getAtKey(TA_TYPE_RAILWAY_TRACK,RailAreaID).CM_Rail;
	if railArea &lt;&gt; null then
		self.deleteRailArea(RailAreaID);
	endif;
	
	// Ensure we have no WagonMasters for our wagons
	wagonMaster := app.myRoot.allWagonMasters[WagonID];
	self.deleteWagonMasterAndWagons( wagonMaster ); // in case it was already there.
	
	// Delete the train if it exists
	self.deleteTrain(TrainID, null);
	
	// Delete the Consignee if it exists
	self.deleteConsigneeConsignor(ConsigneeID);
	
	self.deleteInterTermConfig(InterTermConfig);
	
	// Remove any cargo/prenotes that might already exist at the destination terminal
	self.opts.addAssoc("Terminal", DestTermID);
	self.deleteContainer(TiID1);
	self.deleteContainer(TiID2);
	self.deleteContainer(TiID3);
	self.deleteContainer(TiID4);
	self.opts.purge(); // Make sure getTerminal returns 'this' terminal, rather than our destination.
	
	// Remove any cargo that might already exist at the source terminal
	self.deleteContainer(TiID1);
	self.deleteContainer(TiID2);
	self.deleteContainer(TiID3);
	self.deleteContainer(TiID4);
	
	// Sometimes (Usually if we bail part way through this - or a similar - test) the TIs/Prenotes get messed up
	// and end up being created again in the destination terminal as part of the delete in the source terminal!
	// (Still have no idea why, but I think it has something to do with the testing framework)
	self.opts.addAssoc("Terminal", DestTermID);
	self.deleteContainer(TiID1);
	self.deleteContainer(TiID2);
	self.deleteContainer(TiID3);
	self.deleteContainer(TiID4);
	self.opts.purge(); // Make sure getTerminal returns 'this' terminal, rather than our destination.
	
	// ******************
	// ***** Set Up *****
	// ******************
	
	// create the consignee
	consignee := self.addConsigneeConsignor(ConsigneeID, ConsigneeDesc, true, true, true);
	self.assertNotNull(consignee);

	// create rail area
	railArea := self.addRailArea(RailAreaID, 4, 4);
	self.assertNotNull(railArea);
	
	// create train
	train := self.addTrain(TrainID, null);
	self.assertNotNull(train);

	// create wagon class
	wagonClass := self.addWagonClass(WagonClassID);
	self.assertNotNull(wagonClass);
	
	// create wagons
	//self.ignoreTrxWarnings(true);
	wagon := self.addWagonToTrainOption3( train, WagonID, wagonClass, null, true, false);
	self.assertNotNull(wagon);
	
	// get wagon master
	wagonMaster := wagon.myWagonMaster;
	
	// get the rail line
	railLine := railArea.allRailLinesByIndex.first;
	
	// create inter terminal config
	delreason := app.myRoot.allDeliveryReasonselReasons.first;
	delReasonID := delreason.id;
	delReason := delreason.description;	
	destTerm := app.myRoot.allTerminals[DestTermID];
	subTerm := terminal.getDefaultSubTerminalForRel(BR_TYPE_RAIL);
	
	self.assertNotNull(destTerm);
	self.assertNotNull(subTerm);
	
	itc := self.addInterTermConfig(InterTermConfig,
									null,				// gate : CM_Gate
									null,				// laneController : CM_YardController
									terminal,
									railArea,
									true, 				// autoIn
									true,				// autoOut
									destTerm,
									consignee,
									"",					// voyCode : String
									null,				// voyage : CM_Voyage
									delReasonID,
									delReason,
									subTerm
									);
	
	// set up container options
	self.opts.purge();
	opts.addAssoc("IMEX", TI_IMEX_STATUS_REMAINONBOARD);
	opts.addAssoc("Wagon", WagonID);
	opts.addAssoc("IntendedReleaseMode",TI_IntendedReleaseMode_RAIL);
	opts.addAssoc(UTTI_DestinationTerminal, DestTermID);
	opts.addAssoc(UTTI_State, 0 );
	
	//create containers
	ti1 := self.addContainerOpts(TiID1, ISOType, TiCommodity, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti2 := self.addContainerOpts(TiID2, ISOType, TiCommodity, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti3 := self.addContainerOpts(TiID3, ISOType, TiCommodity, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti4 := self.addContainerOpts(TiID4, ISOType, TiCommodity, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNull(ti1);
	self.assertNotNull(ti2);
	self.assertNotNull(ti3);
	self.assertNotNull(ti4);
	
	create tiArray transient;
	tiArray.add(ti1);
	tiArray.add(ti2);
	tiArray.add(ti3);
	tiArray.add(ti4);
	
	// ********************
	// ***** Do Stuff *****
	// ********************
	
	// Add cargo restrictions to wagon
	create allTransientCriteriaObj transient;
	
	// Create Consignor criteria
	create objSet transient;
	objSet.add(consignee);
	create proxyCriteria transient;
	proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_Consignor], objSet, null);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(false, true, false);
	allTransientCriteriaObj.add(cmifCriteria);
	
	// Add all criteria to the wagon
	create pxyCargoRestrict transient;
	pxyCargoRestrict.setProxy( allTransientCriteriaObj, 1);
	pxyCargoRestrict.setProxyBaseData( Red, wagonMaster, terminal);
	
	app.myTrxCA.trxCreateObjMatchCrit( pxyCargoRestrict, cargoRestrict, app.myPassport );
	self.assertTrueMsg( cargoRestrict &lt;&gt; null, "Cargo restriction Not created : " &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertTrueMsg( not wagonMaster.allCargoRestrictionCriteria.isEmpty, "Cargo restriction Not associated with Wagon Master" );
	
	// Add cargo to the wagon
	create moveController transient;
	count := 1;
	foreach ti in tiArray do
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(wagon.allLocationsControllersArray[count]);
		moveController.setMoveMode(REAL_MODE);
		moveController.isForcedMove := true;
		
		app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		
		//check that the tis are on the specified wagon controllers
		self.assertTrueMsg(ti.myPrimaryActualLocation = wagon.allLocationsControllersArray[count], ti.id &amp; " container not associated with its wagon location controller.");
		
		count := count + 2;
	endforeach;
	
	// Move wagons to a rake
	railLine.switchPositions(wagon, 01);
	
	// confirm train in
	//self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	trainCode := train.getCodeDate();
	//check that the cargo is all on site now.
	foreach ti in tiArray do
		self.assertTrueMsg(ti.site = TI_SITE_ONSITE, ti.id &amp; " should be onsite after arrival!");
		self.assertTrueMsg(ti.getReceiveTrainCode() = trainCode, ti.id &amp; " receive train");
		self.checkTIForTxnOfType(ti, TRANS_TYPE_REC_RAIL);
	endforeach;
	
	// confirm train out
	//self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// Clear rake
	create rake transient;
	rake.myTrain := train;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateRailClearRake(rake, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// check the cargo is offsite
	foreach ti in tiArray do
		self.assertTrueMsg(ti.site = TI_SITE_OFFSITE, ti.id &amp; " should be offsite after departure!");
		self.assertTrueMsg(ti.getReleaseTrainCode() = trainCode, ti.id &amp; " release train");
		self.checkTIForTxnOfType(ti, TRANS_TYPE_REL_RAIL_INTER_TERM);
	endforeach;
	
	// check the cargo got pre notes created at the destination
	self.opts.addAssoc("Terminal", DestTermID);
	self.opts.addAssoc("Verify", true);
	
	foreach ti in tiArray do
		self.addPrenoted(ti.id);
		self.assertTrxErrorMsg(ERR_PRENOTE_ID_EXISTS, "Prenote [" &amp; ti.id &amp; "] does not exist in destination terminal");
	endforeach;	
	
	//finished clean up
	wagonClass := app.myRoot.allWagonClasses[WagonClassID];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	railArea := terminal.allTerminalAreasByTypeId.getAtKey(TA_TYPE_RAILWAY_TRACK,RailAreaID).CM_Rail;
	if railArea &lt;&gt; null then
		self.deleteRailArea(RailAreaID);
	endif;
	wagonMaster := app.myRoot.allWagonMasters[WagonID];
	self.deleteWagonMasterAndWagons( wagonMaster ); 
	self.deleteTrain(TrainID, null);
	self.deleteInterTermConfig(InterTermConfig);
	
epilog
	self.setTerminalConfig(PrenoteUniqBooking, prenoteUniqBooking);
	destTerm := app.myRoot.allTerminals[DestTermID];
	beginTransaction;
	destTerm.setConfig(PrenoteUniqBooking, false);
	commitTransaction;
	delete allTransientCriteriaObj;
	delete pxyCargoRestrict;

	if proxyCriteria &lt;&gt; null then
		delete proxyCriteria;
	endif;
	
	if objSet &lt;&gt; null then
		delete objSet;
	endif;
	
	if cmifCriteria &lt;&gt; null then
		delete cmifCriteria;
	endif;
	
	delete tiArray;
	delete moveController;
	delete rake;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTransferCargoRoad" id="c0ceafe5-ec4b-4a83-91ba-169534428bbe">
        <updating/>
        <source>tTransferCargoRoad() updating;
/* cnwmh5

Purpose:	Create an inter terminal road transfer

Date		Who		Reason
17/08/2012	cnwmh5	Initial creation

*/
constants
	VehicleID 			: String = 'UTMDH1';
	TiID1				: String = 'UTMDH000007';
	DriverID 			: String = 'UTMDHDRIVER';
	BlockStackName 		: String = "UTMDHBS7";
//	DestTerminalName	: String = "Michael's UT Terminal";
	DestTerminalCode	: String = "JBL";
	InterTermConfig		: String = "UTMDHITCONF";
	CarrierID			: String = "UTMDHCAR";
	CarrierDesc			: String = "Michael's Carrier";
	ConsigneeID			: String = "UTMHF";
	ConsigneeDesc		: String = "Michael's UT Consignee/Consignor";
	DestBS				: String = "UTMDHBS5";
	BookingID			: String = "UTMDHBook1";
	VoyageID			: String = "UTMDHVOY1";
	VesselID			: String = "UTMDHVES1";
vars

	itc 				: CM_InterTerminalConfig;
	gate       			: CM_Gate;
	laneController 		: CM_YardController;
	sourceTerm 			: CM_Terminal ; 
	ta 					: CM_TerminalArea;
	bsDT				: CM_TerminalArea;
	autoIn, autoOut 	: Boolean; 
	destTerm 			: CM_Terminal;
	consignee 			: CM_ConsigneeConsignor;
	voyage 				: CM_Voyage;
	subTerm 			: CM_SubTerminal;
	delreason 			: CM_DeliveryReleaseReason;
	vehicle 			: CM_Vehicle;
	ti			 		: CM_TrackedItem;
	itj 				: CM_InterTermVehicleJob;
	itm 				: CM_InterTerminalMove;
	egc 				: CMIF_EasyGateController;
	adminGate			: CM_GateArea;
	booking 			: CM_BookingRef;
	vessel				: CM_Vessel;
	carrier				: CM_Carrier;
	
	allCarriers			: CM_CarrierByCodeDict;
	allVehicleMachines 	: CM_VehicleSet; 
	pinEmailAddresses	: CM_EmailEntityByTypeNameDict;
	
	voyCode 			: String;
	delReasonID 		: Integer;
	delReason	 		: String;
	etaEtdMandatory		: Boolean;
	
	shipCutoffError		: Boolean;
	
begin
	
	// set terminal configs
	etaEtdMandatory	:= self.getTerminalConfig("EtaEtdMandatory").Boolean;
	self.setTerminalConfig("EtaEtdMandatory", false);

	// delete the vehicles from source / destination terminals
	self.deleteVehicle(VehicleID);
	self.opts.purge;
	self.opts.addAssoc("Terminal", DestTerminalCode);
	self.deleteVehicle(VehicleID);
	
	// create the carrier
	self.deleteCarrier(CarrierID);
	create pinEmailAddresses transient;
	carrier := self.addCarrier(CarrierID, CarrierDesc, pinEmailAddresses, false, true, true, null);
	self.assertNotNull(carrier);
	
	// create the consignee
	self.deleteConsigneeConsignor(ConsigneeID);
	consignee := self.addConsigneeConsignor(ConsigneeID, ConsigneeDesc, true, true, true);
	self.assertNotNull(consignee);

	// setup destination terminal stuff
	destTerm := self.getTerminal();
	shipCutoffError := destTerm.getConfig(ShipCutoffsShowError).Boolean;
	beginTransaction;
	destTerm.setConfig(ShipCutoffsShowError, false);
	commitTransaction;
	
	// create voyage
	self.deleteVoyage(VoyageID);
	self.deleteVessel(VesselID);
	vessel := addVesselCellular(VesselID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	self.opts.addAssoc( "dateArrival", app.actualTimeServer.date.cnEcAddDays( -2 ) );
	voyage := addVoyageWithContainerStructur(VoyageID, VesselID, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage);
	//self.opts.purge;
	
	self.deleteTerminalArea(DestBS);
	bsDT := self.addBlockStack(DestBS, 50, null);
	self.assertNotNull(bsDT);
	
	// need vehicle	 in source and target terminal
	self.deleteVehicle(VehicleID);
	vehicle := self.addVehicle( VehicleID, carrier, destTerm);
	self.assertNotNull(vehicle);
	
	// create a prenote
	self.deleteContainer(TiID1);
	self.deleteBooking(BookingID);
	booking := self.addBookingForContainer(BookingID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 
		voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first, TiID1);
	self.assertNotNull(ti);
	
	self.opts.purge;
	
	app.myPassport.setMyTerminal(self.getTerminal);			// 16/07/2012 cnwmh5
		
	// setup source terminal details
	sourceTerm := self.getTerminal();
	subTerm := sourceTerm.getDefaultSubTerminalForRel(BR_TYPE_RAIL);
	
	// setup source bs
	self.deleteTerminalArea(BlockStackName);
	ta := self.addBlockStack(BlockStackName, 50, null);
	self.assertNotNull(ta);
	
	// get the gate details
	gate := sourceTerm.getDefaultGate_OUT();
	adminGate := gate.getFirstAGate_IN();
	if adminGate = null then
		laneController := adminGate.getLaneByNumber(1);
	endif;
	autoIn := true;
	autoOut := true;
	
	// create the vehicle in each terminal
	self.deleteVehicle(VehicleID);
	vehicle := self.addVehicle( VehicleID, carrier, sourceTerm);
	self.assertNotNull(vehicle);
	
	consignee := app.myRoot.allConsigneeConsignors[ConsigneeID];
	voyCode := "";
	delreason := app.myRoot.allDeliveryReasonselReasons.first;
	delReasonID := delreason.id;
	delReason := delreason.description;	
	
	// create inter terminal config
	self.deleteInterTermConfig(InterTermConfig);
	itc := self.addInterTermConfig(InterTermConfig,
									gate,
									laneController,
									sourceTerm,
									ta,
									autoIn, 
									autoOut,
									destTerm,
									consignee,
									voyCode,
									voyage,
									delReasonID,
									delReason,
									subTerm
									);
	
	ti := self.addContainer(TiID1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	
	// need cargo item assigned to the release (moved to ITCBS1 should do it)
	self.move( ti, ta);  //should allocate it to the BR
	
	self.assertTrue(itc.myRelease.allTrackedItemsAssigned.includes(ti) );
	
	// ok now in a position to shift the cargo
	// need an inter terminal vehicle job
	itj := app.myRoot.allInterTerminalVehicleJobs.getAtKey( VehicleID,'' );
	
	if itj = null then
		itj := self.addInterTermVehicleJob( vehicle );
	endif;
	
	// should now have an inter terminal job.
	self.assertNotNull(itj);
	
	// then an inter terminal move
	itm := self.addInterTerminalMove( ti , sourceTerm, destTerm , vehicle , itj);
	self.assertNotNull(itm);
	
	// create driver details
	self.deleteDriverDetails(DriverID);
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(vehicle);
	self.createDriverDetails(DriverID, allCarriers, allVehicleMachines);
	
	// then set up the controller to do the gate out
	create egc transient;
		
	egc.myTerminal := sourceTerm;
	egc.driver     := DriverID;
	
	egc.myInterTermVehicleJob := itj;	
	egc.allMovesForLoading.add( itm );
	
	//gate out
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateEasyGateOut(egc, app.myPassport); 
	
	///  Needs to check here for newly created error
	self.assertTrxError(ERR_PRENOTE_ID_EXISTS_DEST);
	
	delete egc;
	
epilog
	self.setTerminalConfig("EtaEtdMandatory", etaEtdMandatory);
	if destTerm &lt;&gt; null then
		beginTransaction;
		destTerm.setConfig(ShipCutoffsShowError, shipCutoffError);
		commitTransaction;
	endif;

	delete allVehicleMachines;
	delete allCarriers;
	delete pinEmailAddresses;
	delete egc;
end;</source>
    </JadeMethod>
</Class>
