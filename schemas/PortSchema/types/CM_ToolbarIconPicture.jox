<GUIClass name="CM_ToolbarIconPicture" id="459245c0-7448-4f52-91d1-6b8b338e8e6c">
    <superclass name="Picture"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="savePictureToDatabase" id="e273e329-b8ff-4743-86b5-f73a6cc6e226">
        <source>savePictureToDatabase(_icon, _enabled, _disabled : String; _root : CM_Root);
// ---------------------------------------------------------------------------
// Created:     28 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin

	if _icon &lt;&gt; null then
		_root.setConfig(_icon, self.pictureDown, false);
	endif;
	if _enabled &lt;&gt; null then
		_root.setConfig(_enabled, self.picture, false);
	endif;
	if _disabled &lt;&gt; null then
		_root.setConfig(_disabled, self.pictureDisabled, false);
	endif;

end;</source>
        <Parameter name="_icon" type="String"/>
        <Parameter name="_enabled" type="String"/>
        <Parameter name="_disabled" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <DevControlTypes name="CM_ToolbarIconPicture">
