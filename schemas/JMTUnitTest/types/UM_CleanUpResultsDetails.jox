    <JadeMethod name="createRecord" id="63c82d0b-05ea-490c-b4f1-d02ad359294b">
        <updating/>
        <source>createRecord(_startTS, _endTS : TimeStamp; _numberDone : Integer; _taskDescription : String; _startingSize, _endingSize : Decimal) updating;

/*

Purpose:		update the details

Date			Who		Reason
19/11/2013		cnwmh5	Initial creation

