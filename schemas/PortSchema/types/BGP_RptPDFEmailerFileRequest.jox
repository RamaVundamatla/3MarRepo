<Class name="BGP_RptPDFEmailerFileRequest" id="d7c3f00a-f185-443d-a1cd-65bad208f808">
    <superclass name="BGP_ReportPDFEmailerRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
&lt;display&gt;Report PDF and/or File Emailer&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ExplicitInverseRef name="allAttachedFiles" id="fa0b431d-9bba-4f30-8fff-c5df63175502">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_FileDataStorageHdrSet"/>
        <access>readonly</access>
        <Inverse name="CM_FileDataStorageHeader::myRptPDFEmailerFileRequest"/>
    </ExplicitInverseRef>
    <JadeMethod name="action" id="71eb9e4d-5979-4add-8334-9b40422dce0c">
        <updating/>
        <source>action(): Boolean updating;
// -------------------------------------------
// Created 01 September 2004 by cnwdvb1
// -------------------------------------------
vars

	errCode		: Integer;
	errTxt,
	userCode,
	reportName	: String;

begin
	
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	self.doPrintAndEmailAndSendFilesPDF();
	
epilog

	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		if self.myUser &lt;&gt; null then
			userCode := app.getErrorString(For_User) &amp; self.getUserCode;
		endif;
		
		// Change activity details.
		app.createActivityHistory(ActivityHistoryGeneral, null, null, app.getErrorString1(Background_Report, self.reportName &amp; userCode), false, false);
	endif;
	return (errCode = null);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintAndEmailAndSendFilesPDF" id="d3f12f46-ad55-4424-9c69-42edf688c581">
        <source>doPrintAndEmailAndSendFilesPDF() protected;
// -------------------------------------------
// Created 22 November 2005 by cnwdvb1
// -------------------------------------------
vars
	binary 			: Binary;
	printer			: CM_PrinterDef;
	reportTemplate	: CM_ReportTemplate;
	user			: CM_User;
begin

	user := app.getMyUser();
	if user = null then
		//app.raiseCMException1(Full_Replacement_Message, 'Unable to send email as user not found.', null, null); //- cnwmd1, Par 20524
		app.raiseCMException(Unable_email_user_not_found, null, null); //+ cnwmd1, Par 20524
		return;
	endif;

	if self.myJadeReport &lt;&gt; null then
		// User want to send PDF report		
	//	if (not user.canDo(self.myTerminal, PmPDFBackground)) then
			//app.raiseCMException1(Full_Replacement_Message, 'Unable to email PDF report as user (' &amp; user.code &amp; ') does not have permission.', null, null); //- cnwmd1, Par 20524
	//		app.raiseCMException1(No_email_pdf_permission, user.code, null, null); //+ cnwmd1, Par 20524
	//		return;
	//	endif;
		
		printer := self.getPrinter(null);
		
		if printer = null then
			//app.raiseCMException1(Full_Replacement_Message, 'PDF Printer Required', null, null); //- cnwmd1, Par 20524
			app.raiseCMException(PDF_Printer_required, null, null); //+ cnwmd1, Par 20524
			return;
		endif;
	
		create reportTemplate transient;
		binary := self.doPrintPDF(printer, self.myJadeReport, reportTemplate, true);
	endif;

	app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString1(Background_Report, self.reportName),
										  self.myEmailTemplate.getAllToAddressesOrNames(false),
										  self.myEmailTemplate.getFromAddress(),
										  self.myEmailTemplate.getAllCCAddressesOrNames(false),
										  self.myEmailTemplate.getAllBCCAddressesOrNames(false),
										  self.myEmailTemplate.subject,
										  self.myEmailTemplate.body,
										  self.myEmailTemplate.allAttachedFilePaths,
										  self.allAttachedFiles,
										  binary,
										  self.reportName &amp; BGP_EmailSendRequest.PDF,
										  EmailSource_Reports,
										  null,
										  app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		app.remoteErrorWarningToAlert('Could not send email', null, app.myPassport.allErrors, null, false, true);
	endif;
	
epilog
	delete reportTemplate;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initPDFEmailerFile" id="f00c7a77-881c-422f-a1b9-9fa976115a63">
        <updating/>
        <source>initPDFEmailerFile(	_user			: CM_User;
					_terminal		: CM_Terminal;
					_reportName 	: String;
					_jadeReport 	: JadeReport;
					_emailTemplate	: CM_EmailTemplate;
					_allFilePaths	: HugeStringArray input) updating;
// -------------------------------------------
// Created 22 November 2005 by cnwdvb1
// -------------------------------------------
vars

	filePath	: String;
	header		: CM_FileDataStorageHeader;

begin

	// Simply provided the path to the files we want to attach. 
	if _allFilePaths &lt;&gt; null then
		foreach filePath in _allFilePaths do		
			header := app.writeFileToBinary(filePath, false, false, null,true);
			if header &lt;&gt; null then
				self.allAttachedFiles.add(header);
			endif;
		endforeach;
	endif;
	
	self.initPDFEmail(_user, _terminal, _reportName, _jadeReport, _emailTemplate);


end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_reportName" type="String"/>
        <Parameter name="_jadeReport" type="JadeReport"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
        <Parameter name="_allFilePaths" type="HugeStringArray" usage="input"/>
    </JadeMethod>
</Class>
