    <JadeMethod name="sendRealisasiPandu" id="f74e7f65-fa48-45e1-964f-2851d6deb2e5">
        <updating/>
        <source>sendRealisasiPandu(_request : CMIF_IPNSendRealPanduReq) : CMIF_IPNSendRealPanduResp updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	response		: CMIF_IPNSendRealPanduResp;
	realRequest		: IPN1_SendRealisasiPandu;
	realResponse	: IPN1_SendRealisasiPanduResponse;
	createdObjects	: ObjectSet;
	soapFault		: Boolean;
	
begin
	create createdObjects transient;
	create realRequest transient;
	createdObjects.add(realRequest);
	
	_request.copyToRealWSObject(realRequest, createdObjects);
	
	realResponse := self.doSendWebServiceRequest(self.myIPNConsumer,
												 method.name,
												 realRequest,
												 soapFault).IPN1_SendRealisasiPanduResponse;
												 
	if realResponse &lt;&gt; null then
		create response transient;
		if app.isDevelopmentSystem then
			response.statusCode :="01";
			response.statusMessage:= "Success";
		else
			if realResponse.sendRealisasiPanduResult &lt;&gt; null then
				if realResponse.sendRealisasiPanduResult.zreturn &lt;&gt; null then
					response.setFromRealWSObject(realResponse.sendRealisasiPanduResult.zreturn);
				endif;
			endif;
		endif;
	elseif soapFault then
		create response transient;
		response.setValuesForSOAPFault();
	endif;
	
	if app.isDevelopmentSystem and response = null then
		create response transient;
		response.statusCode :="01";
		response.statusMessage:= "Success";
	endif;
	
	return response;
	
epilog
	if createdObjects &lt;&gt; null then
		createdObjects.purge();
		delete createdObjects;
	endif;
	
end;</source>
        <Parameter name="_request" type="CMIF_IPNSendRealPanduReq"/>
        <ReturnType type="CMIF_IPNSendRealPanduResp"/>
    </JadeMethod>
    <JadeMethod name="sendRealisasiTambat" id="812e5f27-e48f-458b-b772-ba2c94ae9031">
        <updating/>
        <source>sendRealisasiTambat(_request : CMIF_IPNSendRealTambatReq) : CMIF_IPNSendRealTambatResp  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	response		: CMIF_IPNSendRealTambatResp;
	realRequest		: IPN1_SendRealisasiTambat;
