    <JadeMethod name="utlCreateMachineDelayHistory" id="101c9497-3911-433e-917c-de2efced69d1">
        <updating/>
        <source>utlCreateMachineDelayHistory(_machine : CM_Machine;
							 _currentDelayHist : CM_MachineHistory;
							 _newDelayHist : CM_MachineHistory output;
							 _mins : Integer;
							 _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/10/2022	navds21	TFS 50083 MTN - Machine Delay Idle Time


*/

vars
	rtConfig : CM_RTVehicleConfig;
	alert    : CM_SystemAlert;
begin
	rtConfig   := _machine.myTerminal.getRTVehicleConfigForObject(_machine);  
	
	if rtConfig = null then                                                   
		return;
	endif;
	
	// create a machine history entry if configured to do so, and we don't already have one
	if rtConfig.idleTimeRecordInHistory and _currentDelayHist = null then
		app.writeLog("Created an Delay History for machine " &amp; _machine.code, LogINFO);
		_newDelayHist := _machine.addSetDownDelayedHistory(); 
		_machine.updateObjectEdition(_machine);
	endif;
	
	// create an alert if configured to do so, and we've exceeded the configured time
	if rtConfig.delayTimeUntilAlert &lt;&gt; null and _mins &gt; rtConfig.delayTimeUntilAlert then
		app.writeLog("Machine "  &amp; _machine.code &amp; " has been delay for " &amp; _mins.asStringJMT &amp; " minutes, alert time is " &amp; rtConfig.delayTimeUntilAlert.asStringJMT &amp; " minutes - create an alert", LogINFO);
		alert := _passport.createAlert(	SEVERE_ERROR, 
									app.getErrorString2(Machine_delay_alert, _machine.code, _mins.asStringJMT),
									EVENT_AT_MachineDelayAlert,
									null	);
		if alert &lt;&gt; null then
			alert.myTerminal := _machine.myTerminal;
		endif;
		app.commitAlert();
	endif;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_currentDelayHist" type="CM_MachineHistory"/>
