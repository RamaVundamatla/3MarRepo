    <JadeMethod name="addToolbarControls" id="6b2a0b8d-9ea4-4391-854e-0e6e76e99dbf">
        <updating/>
        <source>addToolbarControls() updating, protected;
//-----------------------------------------
// Created: 01 October 2003 By: cnwgd1
// 10 Oct 12 	PJS	Par #30438 - Voyage Rationlisation
//-----------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnShowSelector, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
	
	toolbar.addButton(self.btnMoveIt, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
			
	toolbar.addButton(self.btnRefreshTbl, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCheckList, CMUI_Toolbar.Control_Alignment_Left); // TFS 3217
	toolbar.addButton(self.btnEventTrans, CMUI_Toolbar.Control_Alignment_Left); // TFS 3548
	
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
	toolbar.addFrame(self.frmAllNone, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	toolbar := self.frmSelectToolbar;
	toolbar.addButton(self.btnSelect, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnResetSelector, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCloseSelector, CMUI_Toolbar.Control_Alignment_Left);
	//toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	//toolbar.addFrame(self.frmLabel, CMUI_Toolbar.Control_Alignment_Left);
	
	//22 February 2022	navsp1	TFS#52896
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnRefreshSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	// 30438
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addFrame(self.frmVoyage, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;

	

	toolbar := self.frmToolbar2;
	toolbar.addFrame(self.frmEffectiveDate, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	self.frmEffectiveDate.visible := true;
	toolbar.visible := false;
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addWLEForTable" id="5f65314d-f064-48f7-bfb7-3f4fde19b1b0">
        <source>addWLEForTable(_table : CM_DataTable input; _wle : CM_WorkListEntry) : Integer protected;

// Created by cnwdvb1 on 26 February 2007

vars

	str 	: String;
	rowIdx	: Integer;

begin
	if (_wle.myRequest.isSOB and _wle.myRequest.getAttrIsLoad) then
		return -1;
	endif;
	self.allTablesByWle.putAtKey(_wle, _table);
	if _wle.myTrackedItem &lt;&gt; null then
		self.doNotableAdd(_wle.myTrackedItem);
	endif;
	str := self.displayRowForDataTable(_wle, _table);
	rowIdx := _table.addItem(str);
	
	_table.accessRow(rowIdx).itemObject := _wle;
	
	return rowIdx;

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="assignTIToReleaseRequest" id="41f42723-e6fa-4eed-9db8-41f0a44126d0">
        <updating/>
        <source>assignTIToReleaseRequest(_wle : CM_WorkListEntry)updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//
//Date			Who		Reason
//04/09/2019	jlgzm1	TFS 42878 Direct Release Between Road and Voyage
//
//-----------------------------------------
vars
	result : Integer;
	moveController : CMIF_MoveController;
	drWLE : CM_WorkListEntry;
begin

	if app.myMoveController = null then
		return;
	endif;
	if _wle = null then
		return;
	else
		sharedLock(_wle);
	endif;
	moveController := app.myMoveController;
	drWLE := moveController.myWorkListEntry; // TFS 42878
	//epr par 31167 18/2/2013
	moveController.setMyToPrimaryLocation(_wle.myRequest.getLC);
	moveController.setMyWorkListEntry(_wle);
	moveController.setJobForMove(_wle.job);
	
	if drWLE &lt;&gt; null then	// TFS 42878
		moveController.isDirectReleaseMove := true;		// TFS 42878
		if moveController.myTrackedItem &lt;&gt; null then	// TFS 42878
			if moveController.myTrackedItem.canMergeBreakBulk then	// TFS 42878
				if not self.myAssistant.showMoveAmountForm( moveController ) then // TFS 42878
					return;	// TFS 42878
				endif;
			endif;
		endif;
	endif;
	
	// TFS 4435 CNWAB1 MAY17
	if moveController.myToPrimaryLocation &lt;&gt; null then
	//	moveController.transferType := moveController.myToPrimaryLocation.getTransferType();
		moveController.setTransferTypeFromJob( _wle.job, moveController.myToPrimaryLocation.getTransferType() );	//12 Mar 2018	NDL	TFS 37444
	endif;

	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Assign To Release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	if _wle &lt;&gt; null then
		unlock(_wle);
	endif;
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;		
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="btnCheckList_click" id="ab04414f-fd85-4618-8011-157ee4a59bf7">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCheckList_click(btn: Button input) updating;
/*
Purpose:			
Date		Who		Reason
10 February 2017	cnwab1	Initial creation
*/

vars

	form 		: SHP_VoyageEventCheckList;
	effectiveTS : TimeStamp;

begin
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage),app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only);
		return;
	endif;
	form := app.loadForm(SHP_VoyageEventCheckList, SHP_Assistant, false, false, true, self.myTerminal, null).SHP_VoyageEventCheckList;	
	
	if form = null then
		return;
	endif;	
	
	
	form.setParentForm(self);
	form.myCurrentVoyage := self.myCurrentVoyage;
	form.myCurrentJob := self.myCurrentJob;
	form.effectiveTS := effectiveTS;

	form.show;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
