    <JadeMethod name="canViewDetail" id="12dc1d26-dbec-4fec-a43e-7a84f5310ec2">
        <source>canViewDetail(): Boolean;
/*
Date		Who		Reason
28 January 2011	cnwrd1	Initial creation

*/

vars

	user	: CM_User;
	
begin
	user := app.getMyUser();

	//cnwrd1 28.1.11 par 26837
	return  user.canDo(self.myTerminal, PmAdmEdiopersView);

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doXmlInfoDataTruncationForAAT" id="5861d34a-899c-444c-adf4-208004a4c87b">
        <updating/>
        <source>doXmlInfoDataTruncationForAAT():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2021	navndl1	Initial creation	TFS 51718 - example code to set up a new 'archived Text' with the first two xml data values, and biffing the rest. 

*/

vars

	infoLines : StringArray512;
	truncatedInfo : StringArray512;
	xmlTruncatedString : String;

begin

	if self.xmlInfo = null then
		//nothing to truncate
		return false;
	endif;
	
	if archivedText &lt;&gt; null then
		//already been truncated
		return false;
	endif;

	create infoLines transient;
	create truncatedInfo transient;

	self.getInformationLines( infoLines );
	if infoLines.size &gt; 1 then
		truncatedInfo[1] := infoLines[1];
		truncatedInfo[2] := infoLines[2];
		xmlTruncatedString := truncatedInfo.asXmlString(CM_InfoEDISent.InfoHeaderTag, CM_InfoEDISent.InfoDetailTag);
		self.archivedText := xmlTruncatedString;
		self.xmlInfo := null;
	endif;
	
	return true;

epilog

	delete infoLines;
	delete truncatedInfo;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCamSeqNumber" id="c4314140-b823-49ab-8458-f906873d74c8">
        <source>getCamSeqNumber():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2020	jlgndl1	Initial creation	TFS 49876 - for the unit test

*/

vars

	infoLines : StringArray512;
	firstLine : String;
	protoStr : String;
	protoPos : Integer;
	protoLength : Integer;
	seqPos : Integer;
	workString : String;

begin

	create infoLines transient;
	self.getInformationLines(infoLines);
	
	if infoLines.isEmpty then
		return 0;
	endif;
	
	firstLine := infoLines.first;
	protoStr := "Protocol: " &amp; self.myCamProtocol.code;
	protoPos := firstLine.pos( protoStr, 1);
	if protoPos = 1 then
		protoLength := protoStr.length;
		seqPos := firstLine.pos( "seq ", protoLength );
		if seqPos &gt; 1 then
			workString := firstLine[ seqPos + 4 : end ].trimBlanks;
			if workString.isInteger then
				return workString.Integer;
			endif;
		endif;
	endif;
	
	return 0;

epilog

	delete infoLines;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8a2a71a1-3757-4a0c-a411-d0de93ff855a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		Who		Reason
23/08/2010	cnwdad1	CCMS 1903 (PAR #24065).
05/02/2013	cnwcs5	CCMS SFW 1294 /par 30855
*/
vars
	protocol	:CM_CamProtocol;
begin
	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			protocol := self.myCamProtocol;
			
			if protocol = null or protocol.isUserDefinedReport then
				return app.getString(CAM_Protocol) &amp; ' double-click to view details...';
			else
				// we are creating CM_InfoEDISent instead of CM_Information for non-user defined
				// Keep details consistent with what was shown for CM_Information
				return CAMSDetails &amp; ' double-click to view details...';
			endif;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="18925a35-e3d8-44d0-a30b-108f18aee043">
        <source>getEnquiryRow(): String;
// --------------------------------------------------------------------------------
// Created:		26 August 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	str	: String;
	
begin
	str := inheritMethod();
	
	return str &amp; app.getString(EDI_Info_Sent) &amp; ' double-click to view details...';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRowFullInfo" id="5532051d-78b7-4d0d-81db-f6176442ec81">
        <source>getEnquiryRowFullInfo(_dataContainer: CM_DataContainer io);
// --------------------------------------------------------------------------------
// Created:		26 August 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	_dataContainer - A reference to the extra info container object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20 Mar 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size
// --------------------------------------------------------------------------------
vars
	block		: CM_DataContainerBlock;
	str			: String;
	theTI		: CM_TrackedItem;
	idx			: Integer;
	infoLines	: StringArray512;
	
begin
	theTI := self.myTrackedItem;
	
	if theTI = null then
		return;
	endif;
	
	create _dataContainer transient;
	block := _dataContainer.addNewBlock;
	
	// PAR #29165 - Change to use method to handle possible XML storage option
	create infoLines transient;
	self.getInformationLines(infoLines);
	
	foreach str in infoLines do
		idx:= idx + 1;
		block.addNewItem(idx.String &amp; ' ', DC_Label, 1, null);
		block.addNewItem(str, DC_Data, 1, null);
	endforeach;
	
epilog
	delete infoLines;
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getInformationLines" id="19f4c004-ea35-4de7-a1f0-3fe015eb0510">
        <source>getInformationLines(_infoLines : StringArray512 input);
/*

Purpose:			Get the information lines for the receiver into the passed in array, converting
					from the stored XML if required

Parameters:			Array to populate with information lines

Return Value:		Array cleared and populated as required

Date		Who		Reason
28 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

vars
	
begin
	_infoLines.clear();
	
	//03 Sep 2021	NDl	TFS 51718 - Truncated via Garbage Collect will only have this sucker set.
	if self.archivedText &lt;&gt; null then
		_infoLines.setFromXmlString(self.archivedText, self.InfoHeaderTag, self.InfoDetailTag);
		return;
	endif;
	
	// New objects (i.e. post Feb 2012) have xmlInfo populated, so check this first
	if self.xmlInfo &lt;&gt; null then
		_infoLines.setFromXmlString(self.xmlInfo, self.InfoHeaderTag, self.InfoDetailTag);
		return;
	endif;
	
	// Otherwise, info will be stored in the array
	if self.allInformationLines.isEmpty() then
		return;
	endif;
	
	// Data is stored raw in the array, so just copy it out
	self.allInformationLines.copy(_infoLines);
		
epilog

end;</source>
        <Parameter name="_infoLines" type="StringArray512" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyCamProtocolName" id="e9e7b715-9454-46e4-9015-39e535afe721">
        <source>getMyCamProtocolName():String;
// --------------------------------------------------------------------------------
// Created:		23 August 2010 by cnwdad1
//
// Purpose:		Returns the name of the receiver's CAMS Protocol.
//
// Returns:		The name of the receiver's CAMS Protocol, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 05 Feb 2013	cnwcs5		CCMS SFW 1294 /par 30855
// --------------------------------------------------------------------------------
vars
	protocol	:CM_CamProtocol;
begin
	protocol := self.myCamProtocol;
	
	if protocol &lt;&gt; null then
		return protocol.code;
	endif;
	
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyOtherTransaction" id="994c6110-63b6-40ee-a30b-7789b027c624">
        <source>getMyOtherTransaction() : CM_TITransaction;

// 04 Feb 2013	cnwcs5	Initial Creation - CCMS SFW 1294 /par 30855

vars
	isInvalid 	: Boolean;
	trx 		: CM_TITransaction;
begin
	trx := self.myOtherTransaction;
	
	if trx = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, trx, isInvalid);
	
	if trx.class &lt;&gt; null then	// always true
		return trx;
	endif;
	
	// must be invalid
	return null;
end;
</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="isChargeable" id="c377210f-7f34-45c0-9f10-c48e287db8b8">
        <source>isChargeable(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors

*/

vars

begin
	
	if app.myRoot.isClientEuroPorts then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isExtraDetailRequired" id="7309aa8e-ef0a-43cc-a2f9-ba6d441b9b8d">
        <source>isExtraDetailRequired(_dataContainer: CM_DataContainer output): Boolean;
// --------------------------------------------------------------------------------
// Created:		26 August 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver has any extra
//				details to display.
//
// Parameters:	_dataContainer - A reference to the extra info container object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	
	//cnwrd1 28.1.11 par 26837
	//this should realy be somewhere else but putting it here will make sure the permission is checked

	if not self.canViewDetail() then
		return false;
	endif;

	self.getEnquiryRowFullInfo(_dataContainer);
	
	return _dataContainer &lt;&gt; null;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCamProtocol" id="4ea5028a-310b-46bb-a639-eb75580e29de">
