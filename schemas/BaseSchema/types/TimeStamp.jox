	endif;

	return false;
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsLessThanOrEqual" id="cd6a0116-b63d-4a56-a315-27d3e448ba27">
        <source>cnEcIsLessThanOrEqual(pTimeStamp:TimeStamp):Boolean;
// --------------------------------------------------------------------------------
// Created:		13 November 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is less-
//				than or equal-to the specified timestamp.
//
// Parameters:	pTimeStamp - The tmestamp to compare the receiver to.
//
// Returns:		True if the receiver is less-than or equal-to the specified timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date &lt; pTimeStamp.date then
		return true;
	elseif self.date = pTimeStamp.date and self.time &lt;= pTimeStamp.time then
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMax" id="bb2d10cd-a340-45da-8015-b62551cb9d87">
        <source>cnEcMax(pTimestamp:TimeStamp):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns which ever is the latest timestamp between the receiver and
//				the parameter.
//
// Parameters:	pTimestamp - The timestamp to compare the receiver to.
//
// Returns:		The latest timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &gt; pTimestamp then
		return self;
	else
		return pTimestamp;
	endif;
end;</source>
        <Parameter name="pTimestamp" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcMidPoint" id="11b87e89-6852-499a-818a-cefc5e00a802">
        <source>cnEcMidPoint(pTimeStamp:TimeStamp):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		21 September 2006 by cnwdad1
//
// Purpose:		Returns a timestamp that is the mid point between the receiver and
//				the specified parameter.
//
// Parameters:	pTimeStamp - The timestamp to compare the receiver to.
//
// Returns:		The mid point between the two timestamps.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	midPoint	: Integer;
	startPoint	: TimeStamp;
	endPoint	: TimeStamp;
	isSameDate	: Boolean;
	
begin
	if not self.isValid() or not pTimeStamp.isValid() then
		return null;
	endif;
	
	isSameDate	:=	false;
	
	if pTimeStamp.date() = self.date() then
		// Both have the same date.
		
		if pTimeStamp.time() = self.time() then
			// Both have the same time, and hence the same mid point.
			return self;
		elseif pTimeStamp.time() &gt; self.time() then
			startPoint	:=	self;
			endPoint	:=	pTimeStamp;
		else
			startPoint	:=	pTimeStamp;
			endPoint	:=	self;
		endif;
		
	elseif pTimeStamp.date() &gt; self.date() then
		startPoint	:=	self;
		endPoint	:=	pTimeStamp;
	else
		startPoint	:=	pTimeStamp;
		endPoint	:=	self;
	endif;
	
	midPoint	:=	(self.cnEcDiff(pTimeStamp) / 2000).Integer;
	
	return startPoint.cnEcAddSeconds(midPoint);
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcMillisecondsSince" id="78de1a60-dc30-4603-9e40-4163be51d055">
        <source>cnEcMillisecondsSince(pStart:TimeStamp):Decimal;
// --------------------------------------------------------------------------------
// Created:		27 February 2003 by cnwdad1
//
// Purpose:		Returns the number of milliseconds since the specified timestamp.
//
// Parameters:	pStart - The timestamp from which to measure the milliseconds.
//
// Returns:		The number of milliseconds.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	12/4/16		cnwmp6		TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
vars
	difference  : Decimal[23,0];
	
begin
	difference	:=	(self.Date - pStart.Date) * CNEC_HOURS_IN_DAY * CNEC_MINUTES_IN_HOUR * CNEC_SECONDS_IN_MINUTE * CNEC_MILLISECONDS_IN_SECOND;
	difference	:=	difference + (self.Time - pStart.Time);
	
	return difference;
end;</source>
        <Parameter name="pStart" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcMin" id="199c6f4f-c2cf-4e59-8b2c-e4080b6e8291">
        <source>cnEcMin(pTimestamp:TimeStamp):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns which ever is the earliest timestamp between the receiver
//				and the parameter.
//
// Parameters:	pTimestamp - The timestamp to compare the receiver to.
//
// Returns:		The earliest timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &lt; pTimestamp then
		return self;
	else
		return pTimestamp;
	endif;
end;</source>
        <Parameter name="pTimestamp" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetDateAndTime" id="bd44833c-087f-4063-80b1-dc301c16f3a3">
        <updating/>
        <source>cnEcSetDateAndTime(pDate:Date; pTime:Time) updating;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Updates the Date and Time properties of the TimeStamp.
//
// Parameters:	pDate (Date) - The new date value.
//				pTime (Time) - The new time value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date &lt;&gt; pDate then
		self.setDate(pDate);
	endif;
	
	if self.time &lt;&gt; pTime then
		self.setTime(pTime);
	endif;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pTime" type="Time"/>
    </JadeMethod>
    <JadeMethod name="cnEcShortFullFormat" id="08a4a75c-8988-4de3-bb4f-14b775c80041">
        <source>cnEcShortFullFormat():String;
// -----------------------------------------------------------------------------
// Created:		07 January 2002 by cnwdad1
//
// Purpose:		Returns the receiver in a short and full format, i.e. dd/MM/yyyy, hh:mm.
//
// Parameters:	None
//
// Returns:		The short-formated timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return	self.date.userFormat($CNEC_DATE_SHORT_FULL) &amp;
			", " &amp; self.time.userFormat($CNEC_TIME_HHMM_24);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcShortPartFormat" id="4facf014-df40-4bb5-b006-0e21dae4e98f">
        <source>cnEcShortPartFormat():String;
// -----------------------------------------------------------------------------
// Created:		07 January 2002 by cnwdad1
//
// Purpose:		Returns the receiver in a short and full format, i.e. d/M/yy, hh:mm.
//
// Parameters:	None
//
// Returns:		The short-formated timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return	self.date.userFormat($CNEC_DATE_SHORT_PART) &amp;
			", " &amp; self.time.userFormat($CNEC_TIME_HHMM_24);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
