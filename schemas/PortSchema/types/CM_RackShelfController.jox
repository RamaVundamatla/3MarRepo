    <JadeMethod name="testIsControllerFullTAMaxYA" id="605dca13-cab3-40e7-abc3-362ec07e7bc3">
        <source>testIsControllerFullTAMaxYA(_yaAgent: CM_YAAutoplanAgent input; _hasSomeCap : Boolean output): Boolean;
/*
Purpose:	// TFS 43424		
Date				Who			Reason
FEBRUARY 2019		CNWAB1		Initial creation
*/


vars
	ti : CM_TrackedItem;
	errorMsg : String;
	errorNum : Integer;
	availableQuantity : Integer;
	availableWeight : Decimal [16,4];
	availableVolume : Decimal [16,4];
begin
	ti:=_yaAgent.myCMIFYAAutoPlan.getMyTrackedItem();
	
	if ti = null then
		_hasSomeCap := false;
		return false;
	endif;
	
	_yaAgent.addLogEntry(AP_Log_YA_Default,errorMsg,true);
	_hasSomeCap := true;
	return false;
epilog
	
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_hasSomeCap" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="valMoveToForHazTIAutoplan" id="3efb9fc3-cc80-4597-8833-84320a91d2dd">
        <source>valMoveToForHazTIAutoplan(_tiBeingMoved: CM_TrackedItem; _yaAgent: CM_YAAutoplanAgent input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36660

*/

vars

	hazTiToCheck		: CM_TrackedItem;

begin
	
	if not _tiBeingMoved.isHazardous then
		return true;
	endif;
	
	// ACTUAL
	foreach hazTiToCheck in self.myLocation.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistAtLocAutoplan(hazTiToCheck, hazTiToCheck.myPrimaryActualLocation, self, Segregation_Type_Warehouse) then 
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " Hazardous conflict with cargo " &amp; hazTiToCheck.id, true);
			return false;
		endif;
	endforeach;
	// QUEUED
	foreach hazTiToCheck in self.myLocation.allHazardousTIsQueued where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistAtLocAutoplan(hazTiToCheck, self, hazTiToCheck.myPrimaryQueuedLocation, Segregation_Type_Warehouse) then 
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " Hazardous conflict with QUEUED cargo " &amp; hazTiToCheck.id, true);
			return false;
		endif;
	endforeach;
	// PLANNED
	foreach hazTiToCheck in self.myLocation.allHazardousTIsPlanned where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistAtLocAutoplan(hazTiToCheck, self,hazTiToCheck.myPrimaryPlannedLocation,  Segregation_Type_Warehouse) then 
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " Hazardous conflict with PLANNED cargo " &amp; hazTiToCheck.id, true);
			return false;
		endif;
	endforeach;
	
	return true;
	
epilog

	
end;</source>
        <Parameter name="_tiBeingMoved" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="53a6c874-ad4d-4b78-86a1-af9e68cfcafd">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/*
Purpose:			
Date		Who		Reason
20 September 2013	cnwab1	Initial creation
*/

vars
	tis : CM_TIArray;
	ti : CM_TrackedItem;
	totWeight, weightTot : Real;
	totWeightStr : String;	//14 Mar 2017	NDL	TFS 3723
	measureType : CM_MeasurementType;	//14 Mar 2017	NDL	TFS 3723
begin
	inheritMethod(_control);
	
	//07 Oct 2013	NDL	Par 32715
	if self.maximumWeight = 0 then
		return;
	endif;

	create tis transient;
	self.getTIs(tis,_control.moveMode, true);
	foreach ti in tis discreteLock do
		totWeight := totWeight + ti.totalWeight;
	endforeach;
	
	//14 Mar 2017	NDL	TFS 3723
	if totWeight = 0 then
		measureType := app.getDefaultMeasurementForType(Type_Weight);
		totWeightStr := " 0";
		if measureType &lt;&gt; null then
			totWeightStr := totWeightStr &amp; measureType.shortName;
		endif;
		totWeightStr := totWeightStr &amp; " ";
	else
		totWeightStr := app.getWeightForDefaultDisplay(totWeight);
	endif;
	
	weightTot := _control.myTrackedItem.totalWeight + totWeight;
	
	if weightTot &gt; self.maximumWeight then
		app.raiseCMWarning6(Locat_maxim_weigh_curre_total_, self.getFullId(), app.getWeightForDefaultDisplay(self.maximumWeight), totWeightStr,
			_control.myTrackedItem.id, self.getFullId(),app.getWeightForDefaultDisplay(weightTot), null, null, self);
	endif;
epilog
	delete tis;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToForHazTI" id="677b3941-6390-4663-83db-5bc70db12f0f">
        <source>validateMoveToForHazTI(_tiBeingMoved: CM_TrackedItem; _detailedErrMsg: Boolean; _allErrorWarnings: CM_ErrorSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36660

*/

vars

	hazTiToCheck		: CM_TrackedItem;

begin
	
	// ACTUAL 
	foreach hazTiToCheck in self.myLocation.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		_tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self, hazTiToCheck.myPrimaryActualLocation, Segregation_Type_Warehouse, _detailedErrMsg, _allErrorWarnings);
	endforeach;
	// QUEUED 
	foreach hazTiToCheck in self.myLocation.allHazardousTIsQueued where hazTiToCheck &lt;&gt; _tiBeingMoved do
		_tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self, hazTiToCheck.myPrimaryQueuedLocation, Segregation_Type_Warehouse, _detailedErrMsg, _allErrorWarnings);
	endforeach;
	// PLANNED 
	foreach hazTiToCheck in self.myLocation.allHazardousTIsPlanned where hazTiToCheck &lt;&gt; _tiBeingMoved do
		_tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self, hazTiToCheck.myPrimaryPlannedLocation, Segregation_Type_Warehouse, _detailedErrMsg, _allErrorWarnings);
	endforeach;
	
epilog


end;

</source>
        <Parameter name="_tiBeingMoved" type="CM_TrackedItem"/>
        <Parameter name="_detailedErrMsg" type="Boolean"/>
        <Parameter name="_allErrorWarnings" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToForHazTIGetTI" id="0911f581-7987-4b64-b597-8564c404d0d4">
        <source>validateMoveToForHazTIGetTI(_tiBeingMoved: CM_TrackedItem; _clashTIs: CM_TIByIdDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36660

*/

vars

	hazTiToCheck		: CM_TrackedItem;
	allErrorWarnings 	: CM_ErrorSet;

begin
	
	create allErrorWarnings transient;
	
	// ACTUAL
	foreach hazTiToCheck in self.myLocation.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self,hazTiToCheck.myPrimaryActualLocation, Segregation_Type_Warehouse, false, allErrorWarnings) then
			_clashTIs.addNoDuplicates(hazTiToCheck, false);
		endif;
	endforeach;
	// QUEUED
	foreach hazTiToCheck in self.myLocation.allHazardousTIsQueued where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self,hazTiToCheck.myPrimaryQueuedLocation, Segregation_Type_Warehouse, false, allErrorWarnings) then
			_clashTIs.addNoDuplicates(hazTiToCheck, false);
		endif;
	endforeach;
	// PLANNED
	foreach hazTiToCheck in self.myLocation.allHazardousTIsPlanned where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self,hazTiToCheck.myPrimaryPlannedLocation, Segregation_Type_Warehouse, false, allErrorWarnings) then
			_clashTIs.addNoDuplicates(hazTiToCheck, false);
		endif;
	endforeach;
	
epilog

	delete allErrorWarnings;
end;
</source>
        <Parameter name="_tiBeingMoved" type="CM_TrackedItem"/>
        <Parameter name="_clashTIs" type="CM_TIByIdDict" usage="input"/>
    </JadeMethod>
</Class>
