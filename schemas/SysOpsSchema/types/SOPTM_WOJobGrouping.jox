    <JadeMethod name="setControlsForAddEdit" id="c2584acc-70ed-4ba5-850d-65bff5076787">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	theForm : SOP_TableMaintForm;
	tbl		: CM_EntryTable;
begin
	theForm := self.myForm;
	tbl     := theForm.tblInput1;
	
	tbl.userInputEnabled  := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.loadLstWODtlType(null);
		
	if theForm.mode = theForm.Mode_Add then 
		tbl.clearValues;
		tbl.enableRowByName(ETRow_Code);
		tbl.enableRowByName(ETRow_Description);
		tbl.enableRowByName(ETRow_IsNotAvailForEntry);
		tbl.setFocus;
		tbl.moveFirst();
		tbl.gotFocus(tbl);		
		
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);
	else
		self.showThumbnail(theForm.myCurrentObject.CM_WorkOrderJobGroupMethod);
		tbl.disableRowByName(ETRow_Code);
		tbl.enableRowByName(ETRow_Description);
		tbl.enableRowByName(ETRow_IsNotAvailForEntry);
	endif;
	
    tbl.cnEcResizeContents;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="5cc1d5ef-fca5-48f6-b3da-cf9e68f9858c">
        <updating/>
