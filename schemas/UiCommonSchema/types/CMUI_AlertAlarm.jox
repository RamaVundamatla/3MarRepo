    <JadeMethod name="doEditRemarks" id="005587f8-d655-4bdf-b06a-bc0bfde1b348">
        <updating/>
        <source>doEditRemarks() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
09 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	selectedAlert:=self.tblData.accessRow(self.tblData.row).itemObject.CM_SystemAlert;
	if selectedAlert = null then
		return;
	endif;
	frmRemarks.centreWindow;
	txtRemarks.text:=selectedAlert.remarks;
	frmRemarks.visible:=true;

epilog

end;</source>
