    <JadeMethod name="lstJobsSaveSelected" id="d5c486d7-46e2-4388-867a-f12810eee4f8">
        <updating/>
        <source>lstJobsSaveSelected() protected, updating;
// ---------------------------------------------------------------------------
// Created:      16 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if self.lstJobs.listIndex &lt; 1 then
		self.selectedListObject := null;
		self.selectedExpanded := null;
		self.topIndex := null;
		self.topObject := null;
		return;
	endif;
	
	self.selectedListObject := self.myCurrentListObject;
	self.selectedExpanded := self.lstJobs.itemExpanded[self.lstJobs.listIndex];
	self.topIndex := self.lstJobs.topIndex;
	self.topObject := self.lstJobs.itemObject[self.topIndex].CM_Object;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstJobsSetBelowLevelAllJobs" id="af934d4b-2684-41c0-89f6-5e86f9f3bec1">
        <source>lstJobsSetBelowLevelAllJobs(_allJobs : CM_JobSet; _jobIndex, _level : Integer);
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	job		: CM_Job;
	str  	: String;
	jobIndex: Integer;
begin

	if _allJobs.isEmpty then
		return;
	endif;

	jobIndex := (_jobIndex + 1);
	
	foreach job in _allJobs do
		str := job.getTreeDescription();
		self.lstJobs.addItemAt(str, jobIndex);
		self.lstJobs.itemObject[jobIndex] := job;
		self.lstJobs.itemLevel[jobIndex] := _level;

		if job.status = JOB_COMPLETE then
			self.lstJobs.itemPicture[jobIndex] := self.picJobComp.picture;
		elseif job.status = JOB_PART_COMPLETE then
			self.lstJobs.itemPicture[jobIndex] := self.picJobPartComp.picture;		
		else //Unactioned
			self.lstJobs.itemPicture[jobIndex] := self.picJobWLEs.picture;
		endif;	
	endforeach;

	if global.isValidObject(self.selectedListObject) then
	endif;
	
end;</source>
        <Parameter name="_allJobs" type="CM_JobSet"/>
        <Parameter name="_jobIndex" type="Integer"/>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstJobsSetSelectedObject" id="5a857005-6e56-47f0-94b2-0ed8acf5c506">
        <updating/>
        <source>lstJobsSetSelectedObject()updating;
//--------------------------------------------------------------
//Created: 03 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
begin
	self.lstJobs.clearAllSelected();
	
	if self.selectedListObject = null then
		self.setMyCurrentListObjects(null);
		if self.lstJobs.listCount &gt; 0 then
			self.lstJobs.listIndex := 1;
			self.lstJobs.listObject := lstJobs.itemObject[1];
			self.lstJobs.itemSelected[1] := true;
			self.lstJobsChange(self.lstJobs.listObject.CM_Object);
		endif;
		if self.topIndex &gt; 0 then
			self.lstJobs.topIndex := self.topIndex;
		endif;		
	elseif global.isValidObject(self.selectedListObject) then
		idx := self.lstJobs.findObject(self.selectedListObject);
		if idx &lt; 0 then
			self.selectedListObject := self.getDefaultObjectToSelect();
			idx := self.lstJobs.findObject(self.selectedListObject);			
		endif;
		if idx &gt; 0 then
			self.lstJobs.listObject := self.selectedListObject;
			self.lstJobs.itemSelected[idx] := true;	
			// unconditionally expand so that the parent items are expanded
			// and then contract if selected item is not expanded
			self.lstJobs.itemExpanded[idx] := true;
			if not self.selectedExpanded then
				self.lstJobs.itemExpanded[idx] := false;
			endif;
			self.lstJobsChange(self.selectedListObject);
		endif;
		if self.topObject &lt;&gt; null then
			idx := self.lstJobs.findObject(self.topObject);
			if idx &gt; 0 then
				self.lstJobs.topIndex := idx;
			endif;
		elseif self.topIndex &gt; 0 then
			self.lstJobs.topIndex := self.topIndex;
		else
			self.lstJobs.topIndex := self.lstJobs.findObject(self.selectedListObject);
		endif;
	else
		self.loadListJobsAll();
		/*if self.lstJobs.itemExpanded[1] &lt;&gt; true then
			self.lstJobs.expandItem(1);
		endif;*/
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="lstJobsUpdateJob" id="11d63747-16ad-4f8f-b70d-2ea8366351a2">
        <updating/>
        <source>lstJobsUpdateJob(_job : CM_Job; _mode, _jobIdx, _level : Integer; pExpanded : Boolean)updating;
//--------------------------------------------------------------
//Created: April By: cnwgd1
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	idx			: Integer;
	str			: String;
	wle			: CM_WorkListEntry;
	
begin
	if _mode = self.Mode_Delete then
		return;
	endif;
	
	if self.viewMode = self.ViewMode_Transport then
		return;
	endif;

	if _jobIdx &lt; 1 then //or _jobIdx &gt;= self.lstTransport.listCount then
		return;
	endif;
	
	if _job = null then
		return;
	endif;
	
	if self.selectedListObject = null then
		self.selectedListObject := _job;
	endif;
	
	idx := _jobIdx;
	
	str := _job.getTreeDescription();

	if _mode = self.Mode_Update then
		self.lstJobs.itemText[idx] := str;
		/*self.lstJobs.removeItem(self.lstJobs.findObject(_job));
		if self.lstJobs.listCount &lt; idx then
			idx := self.lstJobs.addItem(str);
		else
			self.lstJobs.addItemAt(str, idx);
		endif;*/
	elseif _mode = self.Mode_Add then
		if self.lstJobs.listCount &lt; idx then
			idx := self.lstJobs.addItem(str);
		else
			self.lstJobs.addItemAt(str, idx);
		endif;
	endif;
	
	self.lstJobs.itemObject[idx] := _job;
	self.lstJobs.itemLevel[idx] := _level;

//	if _job.isRoadJob and _job.CM_RoadJob.allWorkingDeviceIDs.cnEcIsNotEmpty() then
//		// If this is a Road Job, and a device (Forklift etc) is still working it, show as part-complete.
//		self.lstJobs.itemPicture[idx] := self.picJobPartComp.picture;
//	else
		if _job.status = JOB_COMPLETE then
			self.lstJobs.itemPicture[idx] := self.picJobComp.picture;
		elseif _job.status = JOB_PART_COMPLETE then
			self.lstJobs.itemPicture[idx] := self.picJobPartComp.picture;
		else //Unactioned
			self.lstJobs.itemPicture[idx] := self.picJobWLEs.picture;
		endif;
//	endif;

	// Expand
	//self.lstJobsSetSelectedObject;
	//self.lstJobs.itemExpanded[idx] := pExpanded;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_jobIdx" type="Integer"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="pExpanded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstJobs_click" id="30ee7904-68ba-46c8-a67f-088a3d128aad">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstJobs_click(listbox: ListBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	obj			: CM_Object;
begin
	obj := listbox.listObject.CM_Object;
		
	if self.myCurrentListObject &lt;&gt; obj then
		//clean up
		//if shift.bitAnd(1) &lt;&gt; 0 then
			self.updateSelectedJobs(obj, null);			
			self.lstJobsChange(obj);			
		//else
		//	self.updateSelectedJobs(obj, shift);						
		//	self.lstJobsChange(obj);
		//endif;			
	endif;

end;


</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstJobs_contextMenu" id="f37412bd-ab0f-4ee4-90a1-63e7a92386fc">
        <controlMethod name="ListBox::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstJobs_contextMenu(cntrl: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	lLeft 	: Real;
	tTop 	: Real;
begin
	lLeft := x;
	tTop := y;

	conwin.windowToScreen(lLeft, tTop);
	self.screenToWindow(lLeft, tTop);   // convert x, y relative to form
	
	self.lstJobsContextMenu(lLeft.Integer, tTop.Integer);	
		
	return false;

end;</source>
        <Parameter name="cntrl" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
