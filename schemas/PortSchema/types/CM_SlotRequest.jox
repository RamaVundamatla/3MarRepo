    <JadeMethod name="getVoyageAllocationGroupCode" id="b1ed3819-294f-49a6-b54a-6a0be0369840">
        <source>getVoyageAllocationGroupCode() : String;
/*
Purpose:			
Date		Who		Reason
20 May 2014	cnwab1	Initial creation
*/

vars



	isGen			: Boolean;
	groupDesc		: Integer;
	cargoTyp		: CM_CargoType;
		criteria : CM_YACriteria;	
	voyAlloc : CM_VoyageAllocation;
begin

	
	// ### PAR 34184
	// This is an attempt to use Voyage Allocations to build the OLD non voyage Allocation CODE
	
	voyAlloc := self.allAllocations.first.CM_VoyageAllocation;
	
	if voyAlloc	 = null then
		return "";
	endif;
	
		
	groupDesc := null;
	voyAlloc := self.getFirstAllocation();
	if voyAlloc = null then
		return null;
	endif;
	
	cargoTyp := voyAlloc.getCargotype();
	if cargoTyp = null or cargoTyp.id = TI_CargoType_Container then
		if voyAlloc.getIs40() then
			groupDesc := PlanningGroup_FortyFoot;
		elseif voyAlloc.getIs30() then
			groupDesc := PlanningGroup_ThirtyFoot;
		elseif voyAlloc.getIs45() then
			groupDesc := PlanningGroup_FortyFiveFoot;
		elseif voyAlloc.getIs53() then
			groupDesc := PlanningGroup_FiftyThreeFoot;
		else
			groupDesc := PlanningGroup_TwentyFoot;
		endif;
		
		
		// Now check special attributes
		if voyAlloc.getIsFlatRack() then
			groupDesc := groupDesc + PlanningGroup_FlatRack;
		elseif voyAlloc.getIsCrib() then
			groupDesc := groupDesc + PlanningGroup_Crib;
		elseif voyAlloc.getIsFrame() then	//05 Feb 2018	NDL	TFS 36752
			groupDesc := groupDesc + PlanningGroup_Frame;
		elseif voyAlloc.getIsTank() then
			groupDesc := groupDesc + PlanningGroup_Tank;
		elseif voyAlloc.getIsOpenTop() then
			groupDesc := groupDesc + PlanningGroup_OpenTop;
		elseif voyAlloc.getIsFantainer() then
			groupDesc := groupDesc + PlanningGroup_Fantainer;
		else
			isGen := true;
		endif;
		
		// Now empty or power
		if voyAlloc.getIsEmpty() then
			groupDesc := groupDesc + PlanningGroup_Empty;
		elseif voyAlloc.getIsPowerRequired() then
			groupDesc := groupDesc + PlanningGroup_PowerRequired;
		elseif isGen then
			groupDesc := groupDesc + PlanningGroup_General;
		endif;
		
		// Finally High Cube
		if voyAlloc.isHiCubed	 then
			groupDesc := groupDesc + PlanningGroup_HighCube;
		endif;
			
	else
		// Non-container cargo, so sort to the end, with System-defined types before
		// User-defined types
		groupDesc := cargoTyp.id;
		if groupDesc &lt; TI_CargoBOLType_Max then
			groupDesc := TI_CargoBOLType_Max - groupDesc;
		endif;
	endif;		

	return groupDesc.String.padLeadingZeros(5).truncatedAt(5);		// Allow for extreme cargoType id values
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageAllocationGroupDesc" id="9375d653-3718-471e-bdca-b6c94048bc54">
        <source>getVoyageAllocationGroupDesc(): String protected;
/*
Purpose:			
Date		Who		Reason
20 May 2014	cnwab1	Initial creation
*/

vars

	isGen			: Boolean;
	groupDesc		: String;
	cargoTyp		: CM_CargoType;
		criteria : CM_YACriteria;	
	voyAlloc : CM_VoyageAllocation;
begin

	if self.myTerminal &lt;&gt; null
	and self.myTerminal.getConfig(ReportGrpDescriptionType).Integer = RepGrpDscType_ISOGroup then
		return inheritMethod();
	endif;
	
	
	// ### PAR 34184
	// This is an attempt to use Voyage Allocations to build the OLD non voyage Allocation CODE
	
	voyAlloc := self.allAllocations.first.CM_VoyageAllocation;
	
	if voyAlloc	 = null then
		return "";
	endif;
	
		
	groupDesc := null;
	voyAlloc := self.getFirstAllocation();
	if voyAlloc = null then
		return null;
	endif;
	
	cargoTyp := voyAlloc.getCargotype();
	if cargoTyp = null or cargoTyp.id = TI_CargoType_Container then
		if voyAlloc.getIs40() then
			groupDesc := app.getErrorString(FortyFoot);
		elseif voyAlloc.getIs30() then
			groupDesc := app.getErrorString(ThirtyFoot);
		elseif voyAlloc.getIs45() then
			groupDesc := app.getErrorString(FortyFiveFoot);
		elseif voyAlloc.getIs53() then
			groupDesc := app.getErrorString(FiftyThreeFoot);
		else
			groupDesc := app.getErrorString(TwentyFoot);
		endif;
		
		
		// Now check special attributes
		if voyAlloc.getIsFlatRack() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_FlatRack);
		elseif voyAlloc.getIsCrib() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Crib);
		elseif voyAlloc.getIsFrame() then	//05 Feb 2018	NDL	TFS 36752
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Frame);
		elseif voyAlloc.getIsTank() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Tank);
		elseif voyAlloc.getIsOpenTop() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_OpenTop);
		elseif voyAlloc.getIsFantainer() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Fantainer);
		else
			isGen := true;
		endif;
		
		// Now empty or power
		if voyAlloc.getIsEmpty() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Empty);
		elseif voyAlloc.getIsPowerRequired() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Integral);
		elseif isGen then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_General);
		endif;
		
		// Finally High Cube
		if voyAlloc.isHiCubed	 then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_HighCube);
		endif;
			
	else
		// Non-container cargo, so use Cargo Type Description
		groupDesc := cargoTyp.description;
	endif;
	
	return groupDesc.truncatedAt(30);
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageAllocationGroupKey" id="7564fb40-2121-462b-84f3-9c952ff6397b">
        <source>getVoyageAllocationGroupKey() : String;
// --------------------------------------------------------------------------------
// Created:		28 October 2010 by cnwjo3
//
// Purpose:		return Voyage Allocation Group Key, eg: 20BX*+
//				par 24993
//
vars
	group : String;
	ct : CM_CargoType;	
	criteria : CM_YACriteria;
	iso : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
begin
	if self.myTerminal &lt;&gt; null
	and self.myTerminal.getConfig(ReportGrpDescriptionType).Integer = RepGrpDscType_Attributes then // PAR 34184
		return getVoyageAllocationGroupCode(); // PAR 34184
	endif;


	criteria := self.getAttrByType(YACriteriaType_ISOGroup);
	if criteria &lt;&gt; null then
		isoGroup := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup;
	endif;

	if isoGroup = null then
		criteria := self.getAttrByType(YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			iso := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType;
			if iso &lt;&gt; null then
				isoGroup := iso.myISOTypeGroup;
			endif;
		endif;
	endif;
	
	if isoGroup = null then
//		group := "???";
		criteria := self.getAttrByType(YACriteriaType_CargoType);
		if criteria &lt;&gt; null then
			ct := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CargoType;
		endif;
		
		if ct = null then
			group := "???";
		else
			group := ct.abbreviation;
		endif;

	else
		group := isoGroup.code;
	endif;
	
	if self.getAttrPowerRequired() then
		group := group &amp; "*";
	endif;
	if self.getAttrEmpty() then
		group := group &amp; "+";
	endif;		
	
	return group[1:5];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
