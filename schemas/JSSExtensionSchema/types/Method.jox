<Class name="Method">
    <JadeMethod name="jssGetCallingMethod" id="b9fbaf56-8af5-41d4-900e-a8aee304b4cb">
        <source>jssGetCallingMethod():Method;
// --------------------------------------------------------------------------------
// Created:		06 July 2001 by cnwdad1
//
// Purpose:		This method will return the calling method of the requestor.
//
// Parameters:	None
//
// Returns:		The method that invoked the requesting method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCallingMethod	: Method;
	allMethodCalls		: ProcessStackArray;
	theMethodCall		: MethodCallDesc;
	loopCount			: Integer;
	
begin
	create allMethodCalls transient;
	
	// Get the call stack for the current process.
	
	process.currentStack(allMethodCalls);
	
	// Iterate through the process stack array to find the calling method we want.
	
	foreach theMethodCall in allMethodCalls do
		loopCount	:=	loopCount + 1;
		
		// Loop 1 will yield the method call to fetch the Current Stack.
		// Loop 2 will yield method call for this method.
		// Loop 3 will yield the method call of the method that wants it's caller.
		// Loop 4 will yield the caller of the method requesting its caller.
		
		if loopCount = 4 then
			theCallingMethod	:=	theMethodCall.method;
			break;
		endif;
	endforeach;

	return theCallingMethod;
epilog
	// Before finishing, delete the transient MethodCallDesc objects created by the
	// currentStack method, then delete the call stack array itself.
	allMethodCalls.purge();
	delete allMethodCalls;
end;</source>
        <ReturnType type="Method"/>
    </JadeMethod>
</Class>
