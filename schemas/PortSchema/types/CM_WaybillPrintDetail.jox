        <updating/>
        <source>setWaybillDateStr( _vvr : CM_VehicleVisitRecord; _date : Date ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	date : Date;

begin

	date := _vvr.getWaybillFirstPrintedDate();
	if date &lt;&gt; null then
		self.waybillDateStr := date.format("dd-MMM-yyy");
	else
		self.waybillDateStr := _date.format("dd-MMM-yyy");
	endif;

epilog

