    <JadeMethod name="getDisplayStringForAttribute" id="4adc29e1-dedc-4490-82ce-d9a8b68fa6b5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
	ti		: CM_TrackedItem;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := "Connection to ";
			if self.getOtherTrackedItem() &lt;&gt; null then
				lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
			else
				lDetail := lDetail &amp; " Power";
			endif;
			
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;
						
			return lDetail;
			
		endif;
							
	elseif _attrName = ETRow_ConnectTo then
		ti := self.getOtherTrackedItem();
		if ti &lt;&gt; null then
			return ti.id;
		else
			return null;
		endif;	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="be7d5d2e-0d42-45f2-af1d-beccd36e6d04">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:   May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();

	lDetail := lDetail &amp; "Connection to ";
	if self.getOtherTrackedItem() &lt;&gt; null then
		lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
	else
		lDetail := lDetail &amp; " Power";
	endif;
	
	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOtherTrackedItem" id="72125e27-f5dc-4190-8d68-71beea03c205">
        <source>getOtherTrackedItem(): CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	mar 2006	cnwrs1		can be expected to be invalid 
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidTI		: Boolean;
	id				: String;
	othTrackedItem	: CM_TrackedItem;
begin
	othTrackedItem := self.otherTrackedItem;
	if othTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, othTrackedItem, invalidTI);
		// Dereference TI to check it is valid
		id := othTrackedItem.id;
	endif;
	
	if invalidTI then
		return null;
	endif;

	return othTrackedItem;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
