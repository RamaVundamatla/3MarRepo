    <JadeMethod name="getOldNewValueForTag" id="f43d3236-0d22-44e9-b236-b07d04c06098">
        <source>getOldNewValueForTag(pTag : String; pOldValue, pNewValue : String output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     26 July 2001 by cnwrs2
//
// Purpose:     Returns true if the tag is found and sets the old &amp; new values
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pStr	: String;
	tmpStr	: String;
	valLen,
	pos		: Integer;
	
begin

	if (not self.getValueForTag(self.auditText, pTag, pOldValue)) then
		return false;
	endif;
	
	self.getValueForTag(self.postAuditText, pTag, pNewValue);
	
	return true;

end;</source>
        <Parameter name="pTag" type="String"/>
        <Parameter name="pOldValue" type="String" usage="output"/>
        <Parameter name="pNewValue" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
