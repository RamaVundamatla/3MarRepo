    <JadeMethod name="myPrimaryQueue" id="d9a211f7-7a24-45e4-aab6-cca756aadbc8">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myPrimaryQueue(set: Boolean; _value: CM_RadioTelemetryQueue io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     09 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldQueue 				: CM_RadioTelemetryQueue;
	
begin

	if set then
		oldQueue:=self.myPrimaryMachineQueue;
		

			
		self.myPrimaryMachineQueue := _value;
		if 	(oldQueue &lt;&gt; self.myPrimaryMachineQueue) then
			
			self.checkMachineCoverage(oldQueue);
	
			self.checkMachineCoverage(self.myPrimaryMachineQueue);
		
			if self.myPrimaryMachineQueue = null then
				self.clearWorkzone;
			endif;
		endif;	
	
		
		
	else
		_value := self.myPrimaryMachineQueue;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_RadioTelemetryQueue" usage="io"/>
    </JadeMethod>
    <JadeMethod name="purgeMachineHistory" id="f128d1f7-1bd1-4428-82c5-e98b0c9ea48f">
        <source>purgeMachineHistory( _ts	: TimeStamp; _agent : CM_DBPurgeAgent input );
/*

Date		Who		Reason
24 Aug 2004	cnwdvb1	Created 
08 Jun 2011	cnwkpd1	PAR #27693 - 1086 exception from Garbage Collection
06 Jul 2011 cnwjre1	par 27778 this code is holding locks for long periods - add time-based commits
*/
constants
	MaxTransactionTime = 2000;
vars
	lastCommit,
	now					: Decimal[20];
	completed			: Integer;
	iter				: Iterator;
	machineHistory		: CM_MachineHistory;
	interfaceHistory	: CM_InterfaceHistory;
	interfaceMessage	: CM_ITSInterfaceMessage;		// PAR #27693
	
begin
	lastCommit := app.relativeMachineTime();

	iter := self.history.createIterator();
	self.history.startKeyLeq(_ts, iter);
	while iter.back(machineHistory) do
		self.exclusiveLock(machineHistory);
		delete machineHistory;
		completed := completed + 1;
		// Check for commit 27778
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			app.myPassport.doDeferredUpdates();
			app.cmsCommitTransaction(app.myPassport);
			lastCommit := app.relativeMachineTime();
			beginTransaction;
		endif;
	endwhile;
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;completed.String&amp;' for '&amp;self.code&amp;' '&amp;app.getErrorString(Machine_History)&amp;' '&amp;"0"&amp;' '&amp;app.getErrorString(Errors));
	
	// cnwrl1 21/05/2009 PAR 19668 - CCMS 1814 - start of coding
	// Need to purge the InterfaceHistory instances for the same time period.
	delete iter;
	completed	:= null;
	iter		:= self.allInterfaceHistories.createIterator;
	self.allInterfaceHistories.startKeyLeq( _ts, iter );
	while iter.back( interfaceHistory ) do : interfaceHistory_loop
		self.exclusiveLock( interfaceHistory );
		delete interfaceHistory;
		completed	:= completed + 1;
		// Check for commit 27778
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			app.myPassport.doDeferredUpdates();
			app.cmsCommitTransaction(app.myPassport);
			lastCommit := app.relativeMachineTime();
			beginTransaction;
		endif;
	endwhile interfaceHistory_loop;
	
	// Note: The existing message (above for MoveHistory) is hardcoded for zero errors, removed below!
	_agent.setStats(	app.getErrorString( Purged ) &amp; Space &amp; completed.display &amp;
						' for ' &amp; self.code &amp; Space &amp; app.getErrorString( InterfaceHistory ) );
	// cnwrl1 21/05/2009 PAR 19668 - CCMS 1814 - end of coding
	
	//+ cnwmd1 CCMS MES 1014 ITS - Purge ITS Interface Messages
	delete iter;
	completed	:= null;
	iter		:= self.allITSInterfaceMessages.createIterator;
	self.allITSInterfaceMessages.startKeyLeq( _ts, iter );
	while iter.back( interfaceMessage ) do
		self.exclusiveLock( interfaceMessage );
		delete interfaceMessage;
		completed	:= completed + 1;
		// Check for commit 27778
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			app.myPassport.doDeferredUpdates();
			app.cmsCommitTransaction(app.myPassport);
			lastCommit := app.relativeMachineTime();
			beginTransaction;
		endif;
	endwhile;
	
	_agent.setStats(	app.getErrorString( Purged ) &amp; Space &amp; completed.display &amp;
						' for ' &amp; self.code &amp; Space &amp; app.getErrorString( Interface_message ) );
	//End of CCMS MES 1014 ITS changes

epilog	
	delete iter;
	
end;
</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8b193198-08cd-4133-a870-c3f600803733">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyMachine:CM_Machine;
	completedOK		: Boolean;
	
begin

	proxyMachine := inheritMethod();

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy
	//epr 14/9/06 changed from allowedTerminalAreas to allowedTAMasters
	self.allowedTAMasters.copy(proxyMachine.allowedTAMasters);	
	self.allAllowedCargoTypes.copy(proxyMachine.allAllowedCargoTypes);
	self.allQueues.copy(proxyMachine.allQueues);
	self.allAllowableContentsStatuses.copy(proxyMachine.allAllowableContentsStatuses);
	proxyMachine.myRTDevice := self.myRTDevice;
	proxyMachine.setMyPhysicalEndBay(self.myPhysicalEndBay);
	proxyMachine.setMyPhysicalStartBay(self.myPhysicalStartBay);
	
	proxyMachine.myOwner := self.myOwner;	//16 May 2018	NDL	TFS 38570
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyMachine;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyMachine;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="queueId" id="f7290f82-14bf-4dd2-86d5-af39ce902f41">
        <methodInvocation>mapping</methodInvocation>
        <source>queueId(set: Boolean; value: String io) mapping;
/*
21 Feb 2024 navma1 Bug 62555: MSL - URGENT - Intermodal Marine Terminal - MACHINE WEB APP UNAVAILABLE


*/
vars

begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.myPrimaryQueue = null then
		//---------------
		//Not in ANY queue.
		//---------------
		return;
	endif;
	
	if self.myNextPrimaryQueue &lt;&gt; null then
		value := self.myNextPrimaryQueue.id[1:30]; //21.02.2024 navma1 #62555
		return;
	endif;
	
	value := self.myPrimaryQueue.id[1:30];		   //21.02.2024 navma1 #62555
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeFromQueue" id="53869d94-9c4a-4b67-bf45-a3598d59eaf4">
        <updating/>
        <source>removeFromQueue(pQueue : CM_RadioTelemetryQueue) updating;
//Removes the ref to the queue from the machine, this may be either a primary or secondary queue
vars

begin
	if pQueue = null then
		return;
	endif;
	if self.myPrimaryQueue = pQueue then
		self.myPrimaryQueue := null;
	endif;

end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="removeRejectedTask" id="d7bff072-86cd-4c1a-84e0-c3781393ebb7">
        <updating/>
        <source>removeRejectedTask(aTask	:	CM_RTQueueTask) updating;
//Removes supplied task from the machines list of recently rejected tasks.
vars

begin
	if aTask = null then
		return;
	endif;
	if rejectedRTQueueTasks.size &lt;= 0 then
		return;
	endif;
	exclusiveLock(self);
	if rejectedRTQueueTasks.includes(aTask) then
		rejectedRTQueueTasks.remove(aTask);
	endif;
epilog
	if isLockedByMe(self) then
		unlock(self);
	endif;
end;</source>
        <Parameter name="aTask" type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="resetFaultQuestions" id="fccd9b69-9541-41b2-bdc7-275935f4b758">
        <source>resetFaultQuestions();
/*

Date		Who		Reason
22 May 2017	cnwer1	Initial creation TFS 995


Purpose:			Reset the Fault Questions to the default for the machine attached to the receiver,
					and create empty fault response values for each question.

Parameters:			None

Return Value:		None


Date		Who		Reason
25 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	question		: CM_FaultQuestion;
	
begin
	// First unconditionally clear everything
	self.allCurrentFaultQuestions.clear;
	self.allCurrentFaultResponses.clear;
		
	// Copy all the fault Questions from the machine type to the receiver collection
	self.getMachineType().allFaultQuestions.copy(self.allCurrentFaultQuestions);
	
	// Create null responses for each questions
	foreach question in self.allCurrentFaultQuestions do
		self.allCurrentFaultResponses.add(null);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetMediator" id="6db28df4-7f78-43e3-b419-3e5e081baacc">
        <updating/>
        <source>resetMediator() updating;

/*

Date		Who		Reason
01 Sep 2011	cnwkpd1	PAR #27747 - Fix up RT Queue form refreshing after Machine "Reset session..."
	
*/


vars

begin
	//epr TFS 4620 16/6/17
	if  self.loggedOn then
		self.addInfoToHistory(CM_MachineInfoHistory.InfoType_ControlReset, null, null,null);
	endif;
	self.causeEvent(EVENT_RESET_MEDIATOR, true, self);
	self.causeEvent(self.myTerminal.getTerminalEvent(RTMachine_Update_Event), false, null);		// PAR #27747
	self.setLoggedOn(false);
	self.clearWebsession();		// TFS 51226 navmd1 16/02/2021
end;</source>
    </JadeMethod>
