	theTable.pictureViewMethod := 'picViewMethod';
	theTable.pictureLoadMethod := 'picLoadMethod';
	theTable.pictureExtractMethod := 'picExtractMethod';
	
	theTable.optimiseHeadingColumn();
	theTable.resetSize();




end;</source>
