    <JadeMethod name="validatePrefixAndNumber" id="6a4b743c-da7b-4b72-a2a5-2a9572ba793f">
        <source>validatePrefixAndNumber(_fullValidation : Boolean) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
// 24/06/2021	navdap1		TFS 51381 ASPA Bulk Voyage Create - Cargo ID
//
vars
	prefix : String;
	number : Integer;
	msg : String;

begin
	prefix := self.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.txtTotal.text.Integer;
	
	if _fullValidation then
		if prefix = null then
			msg := app.getErrorString( Input_require_prefix_field );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			self.txtVoyageCode.setFocus();
			return false;
		endif;
		
		if number = 0 then
			msg := app.getErrorString1( Must_least, "1" );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			self.txtTotal.setFocus();
			return false;
		endif;
	endif;
	
	if prefix.length &gt; 19 then
		msg := app.getErrorString2( Field_Value_Too_Long, self.lblVessel.caption, "19" );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtVoyageCode.setFocus();
		return false;
	elseif prefix.length &gt; 18 and number &gt; 9 then
		msg := app.getErrorString2( Field_Value_Too_Long, self.lblVessel.caption, "18, when " &amp; self.lblTotal.caption &amp; " &gt; 9 ");
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtVoyageCode.setFocus();
		return false;
	endif;
	if number &gt; 30 then
		msg := app.getErrorString1( Maximum_value, "30" );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtTotal.setFocus();
		return false;
	endif;
	
	self.changeIDsIfRequired(prefix, number);			// TFS 51381
	
	return true;

epilog

end;</source>
        <Parameter name="_fullValidation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
