03 April 2020	jlgndl1	Initial creation	TFS 47985
*/
vars

begin

	self.oxygen := _oxygen;

epilog
	
end;</source>
        <Parameter name="_oxygen" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e3af5399-e35d-4ec4-ba81-eabf1607db99">
        <updating/>
        <source>setProxy(_ti:CM_TrackedItem input; _controller: CMIF_TIUpdateController input; _passport : CM_Passport input) updating;
//
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	voyage: CM_Voyage;
begin
	
	voyage := _passport.myTerminal.lookupVoyage(self.myEDIData.CM_EDIDataBayPlan.voyageCode, null, false);

	_ti.setPxyFromEDIBayPlanTI(self, voyage, _controller, _passport);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_controller" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="dea8444e-56ec-4329-bbe0-32a3b31d8989">
        <updating/>
        <source>setVoyageCode(_value: String) updating;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars

begin
	if self.myEDIData.CM_EDIDataBayPlan.voyageCode = null then
		self.myEDIData.CM_EDIDataBayPlan.voyageCode := _value;
	endif;
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupLocationDetails" id="0fc1a776-4689-4e93-986b-db2d2829b3ba">
        <source>setupLocationDetails(voyageLocationId : String io; location : CM_SlotController io);
//
// 14/02/2012	cnwrs1	Par 29157 - look after errors
// 19/09/2017	jlgdap1	TFS 6851 SSL Allow baplie to use voyage code or inward code
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	voyage : CM_Voyage;						// TFS 6851
	vCode : String;							// TFS 6851

begin
	voyage := self.getMyTerminal.lookupVoyage(self.myEDIData.CM_EDIDataBayPlan.voyageCode, null, false);			// TFS 6851
	if voyage &lt;&gt; null then																							// TFS 6851
		vCode := voyage.code;																						// TFS 6851
	else																											// TFS 6851
		vCode := self.myEDIData.CM_EDIDataBayPlan.voyageCode;														// TFS 6851
	endif;																											// TFS 6851
	
	if self.locationId.length &gt; 6 then
		//voyageLocationId := self.myEDIData.CM_EDIDataBayPlan.voyageCode.trimBlanks &amp; " " &amp; self.locationId[2:6];	// TFS 6851
		voyageLocationId := vCode.trimBlanks &amp; " " &amp; self.locationId[2:6];											// TFS 6851
	else
		//voyageLocationId := self.myEDIData.CM_EDIDataBayPlan.voyageCode.trimBlanks &amp; " " &amp; self.locationId;		// TFS 6851
		voyageLocationId := vCode.trimBlanks &amp; " " &amp; self.locationId;												// TFS 6851
	endif;
end;
</source>
        <Parameter name="voyageLocationId" type="String" usage="io"/>
        <Parameter name="location" type="CM_SlotController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateVolume" id="8942a803-0e26-4104-b8ac-d1f313ad36a5">
        <updating/>
        <source>validateVolume(_volume: Real) updating;
//------------------------------------------
//			04/04/2003		Jason Chapman
//------------------------------------------

vars

begin
	if not (_volume &gt; 0) then
		return;
	endif;
	 	
	if self.height = 0 then
		self.height := 100;
	endif;
	
	//have height
	
	if self.width = 0 then
		if self.length = 0 then
			self.width := 100;
			self.length := (_volume * 100).Integer;
		else
			//have length and height
			self.width := (_volume/((self.length.Real/100) * (self.height.Real/100))).Integer;
		endif;
	else
		//have width and height  adjust length
		self.length := (_volume/((self.width.Real/100) * (self.height.Real/100))).Integer;
	endif;	
	


end;</source>
        <Parameter name="_volume" type="Real"/>
    </JadeMethod>
    <JadeMethod name="width" id="6bc25919-28f3-4c76-809a-1065a5fac900">
        <methodInvocation>mapping</methodInvocation>
        <source>width(set : Boolean; _value : Decimal io) mapping;

vars
	owl, owr : Decimal[14,4];
begin
	if not set then
		if (overWidthLeft &lt;&gt; null 
		or overWidthRight &lt;&gt; null) 
		and self.overWidthLeft &lt;&gt; NULL_INTEGER				//cnwmc5 - 28 Jan 2014 - PAR 33001
		or self.overWidthRight &lt;&gt; NULL_INTEGER then			//cnwmc5 - 28 Jan 2014 - PAR 33001
			//cnwmc5 - 28 Jan 2014 - PAR 33001
			owl := self.overWidthLeft;
			owr := self.overWidthRight;
			if owl = NULL_INTEGER then
				owl := 0;
			elseif owr = NULL_INTEGER then
				owr := 0;
			endif;
			_value	:= owl + owr;
		endif;
	endif;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
</Class>
