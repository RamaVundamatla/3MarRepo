    <JadeMethod name="auditId" id="84d860c1-3e30-4bff-b1db-d4ece9711709">
        <source>auditId(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

begin

	return self.code;

epilog

end;</source>
