    <JadeWebServicesMethod name="getLocationsForTerminalArea" id="42b0f556-222f-43f4-a929-3d90eb2bbe24">
        <source>getLocationsForTerminalArea(terminalAreaId : String) : WS_LocationsResponse webService;

/*

Purpose:			Get a list of available Locations for the passed in Terminal Area.

Parameters:			Terminal Area ID (or OID)

Return Value:		Populated Locations response


Date		Who		Reason
02 Feb 2009	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response			: WS_LocationsResponse;	
	location			: WS_LocationsController;
	
	cmTAType			: CM_TerminalAreaType;
	cmTAMaster			: CM_TerminalAreaMaster;
	cmLocation			: CM_LocationsController;
	
	failedDAC			: CM_DataAccessController;
	passport			: CM_Passport;
	
	iter				: Iterator;
	terminal			: CM_Terminal;
	obj					: Object;
	completedOK			: Boolean;
	allLCsSet : CM_LCSet;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
		
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	//epr TFS 5535 10/8/17 
	cmTAMaster := app.myPassport.getObjectOfTypeFromOid(terminalAreaId,CM_TerminalAreaMaster).CM_TerminalAreaMaster;
	
	if cmTAMaster = null then
		cmTAMaster := terminal.allTerminalAreaMastersById[terminalAreaId];
	endif;	
	
	// Code cloned from CMUI_Assistant::comboBoxLocationControllers and CMUI_Assistant::displayEntryLocationController
	if cmTAMaster &lt;&gt; null then
		//jlier1 TFS 53766 30/6/22
		if cmTAMaster.isKindOf(CM_IrregularBlockArea) then
			create allLCsSet transient; 
			cmTAMaster.CM_IrregularBlockArea.getValidLCsCollectionForMove(allLCsSet);
			iter:=allLCsSet.createIterator;
		else
			iter := cmTAMaster.getLCsCollectionForDisplay.createIterator();
		endif;
	
		passport := app.myPassport;

		while iter.next(cmLocation) do
		
			if not cmLocation.canUserAccessSelf(null, failedDAC, passport) then
				continue;
			endif;
			
			create location transient;
			location.setProxyFromObject(cmLocation);
			response.allLocationsControllers.add(location);
		endwhile;	
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	delete iter;
	delete allLCsSet;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get a list of available Locations for the passed in Terminal Area.</text>
        <wsdlName>getLocationsForTerminalArea</wsdlName>
        <Parameter name="terminalAreaId" type="String"/>
        <ReturnType type="WS_LocationsResponse"/>
    </JadeWebServicesMethod>
