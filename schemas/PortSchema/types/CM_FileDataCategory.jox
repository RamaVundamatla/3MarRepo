    <JadeMethod name="getAuditText" id="95f7d84a-bdfd-4f94-b491-0483a190150e">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2022	navhl20	Initial creation

*/

vars
txt,
	tmpStr: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	tmpStr := null;
	tmpStr := app.getContextTextIntToStr(self.categoryContext);
	txt := txt &amp; 'Category Context' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c37113c9-e64e-4569-87c9-a30549f1038a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30/11/2022  navmv20 	TFS CR 55299 Task 55519: UI - New File Category Maintenance UI
24/01/2023	navvt20  	TFS CR 56024 Task 56206: UI - File Category Maintenance
*/

vars

begin
	if _attrName = ETRow_Context then
		return app.getContextTextIntToStr(self.categoryContext);
    // Start 24 Jan 2023 navvt20 TFS 56206
	elseif _attrName = ETRow_IsExternal then
		return self.external.String;
	endif;
	// End 24 Jan 2023 navvt20 TFS 56206
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
