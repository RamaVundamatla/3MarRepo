    <JadeMethod name="setApproved" id="26fae185-c661-422b-b8a6-6c517a9ba026">
        <updating/>
        <source>setApproved(_approvedBy: String; _approvedBtDT: TimeStamp; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2018	jlgdap1		Initial creation TFS 39815 PEL1 WO Approved Set Voyage Status
// 30 Aug 2018  cnwma1		ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
// 29 Sep 2021  navma1 		hangeRequest 51925: SAL - Web Portal Cargo Work Orders
//
vars
	woDtl 			: CM_WorkOrderDtl;
	cashReceipt     : CM_CashReceipt;
	financeApproved : Boolean;
begin
	//if not self.isTransient and self.myTerminal.isSapFinancialEnabled then	//29.09.2021 navma1 #51925
	if not self.isTransient and self.requireFinanceApproval then  		  	  	//29.09.2021 navma1 #51925
		financeApproved:=true;
		foreach cashReceipt in	self.allCashReceipts discreteLock do
			//if  cashReceipt.needSAPRequest then								//29.09.2021 navma1 #51925	
			if  cashReceipt.requireFinanceCheck then							//29.09.2021 navma1 #51925
				financeApproved:=false;
				break;
			endif;
		endforeach;
		
		if not financeApproved then
			//if there are BGP requests  leave it as is and return
			if self.taskStatus &lt;&gt; WO_STATUS_PENDING_FIN then
				self.taskStatus:=WO_STATUS_PENDING_FIN;
				//self.processSAPRequest(false);								//29.09.2021 navma1 #51925
			endif;
			return;
		endif;
	endif;
	
	inheritMethod(_approvedBy, _approvedBtDT, _passport);
	if self.isTransient then
		return;
	endif;
	foreach woDtl in self.allWoDtls discreteLock do
		woDtl.actionForApproved(self.getMyVoyageObject);
	endforeach;
epilog

end;</source>
        <Parameter name="_approvedBy" type="String"/>
        <Parameter name="_approvedBtDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCancelled" id="2bee95bb-b827-4f99-aba5-122b84a45307">
        <source>setCancelled();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2018	jlger1	Initial creation
16 Aug 2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
11/06/2025	navcs2	MTN-34987 
*/

vars
woDtl : CM_WorkOrderDtl;

begin
	
	inheritMethod();
	if self.isTransient then
		return;
	endif;
	
	/*
	11/06/2025	navcs2	MTN-34987
	if not self.isTransient and self.myTerminal.isSapFinancialEnabled then //16.8.2018 cnwma1 TFS #39698
		//self.processSAPRequest(true); 		    
	endif;
	*/
	foreach woDtl in self.allWoDtls discreteLock do
		woDtl.actionForCancelled(self.getMyVoyageObject);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCancelledNoSAP" id="3ab553c1-9645-4ac5-a6aa-6272e5b28a43">
        <updating/>
        <source>setCancelledNoSAP()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	woDtl : CM_WorkOrderDtl;

begin

	self.taskStatus := WO_STATUS_CANCELLED;
	
	if self.isTransient then
		return;
	endif;
	
	foreach woDtl in self.allWoDtls discreteLock do
		woDtl.actionForCancelled(self.getMyVoyageObject);
	endforeach;
	
	self.doEmailStatusChange( WO_STATUS_CANCELLED );

	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WorkOrder_Update);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="539dc4cf-6f7a-4c25-b162-0bdf0bc36782">
        <updating/>
        <source>setForCreate(_proxyWO: CM_WorkOrder) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 11 Oct 2021	jlier1		TFS 51963
vars


begin
	self.myVoyage := _proxyWO.CM_WorkOrderVoyage.myVoyage;
