    <JadeMethod name="showHookCodeMaintForm2" id="35f2f196-7270-4f69-a230-8e0c6a2b4189">
        <source>showHookCodeMaintForm2(_hookType : CM_HookType; _jadeCode : String io; _readOnly : Boolean; _methodName : String; _class : Class;
					   _formCaption : String; _showDelete : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     Aug 2010 copied from showHookCodeMaintForm
//
// Purpose:     additional parameters to enable compiling hook source for validation
// ---------------------------------------------------------------------------
vars
	tmpForm	: CMUI_HookCodeMaintForm;
begin
	create tmpForm transient;
	
	tmpForm.showDelete := _showDelete;
	tmpForm.init(_hookType, _jadeCode, _readOnly);
	tmpForm.methodName := _methodName;
	tmpForm.parentClass := _class;
	tmpForm.formCaption := _formCaption;

	tmpForm.showModal();
	
	if (not _readOnly) then
		if tmpForm.modalResult = IDOK then
			_jadeCode := tmpForm.getJadeCode();
		endif;
	endif;
	
	return (tmpForm.modalResult = IDOK);

epilog
	delete tmpForm;
end;</source>
        <Parameter name="_hookType" type="CM_HookType"/>
        <Parameter name="_jadeCode" type="String" usage="io"/>
        <Parameter name="_readOnly" type="Boolean"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_formCaption" type="String"/>
        <Parameter name="_showDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
