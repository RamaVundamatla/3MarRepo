/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	parent : CM_HarmonizedSystem;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valHarmonizedSystem(_pxyHS);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	parent := _pxyHS.getMyParent();
	if parent &lt;&gt; null then
		if parent.pxyIsProxy then
			parent := parent.pxyGetRealObject();
		endif;
		_pxyHS.setMyParent(parent);
	endif;

	create _realHS as _pxyHS.class persistent;
	_realHS.setForCreate(_pxyHS);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realHS);
	endif;
	
epilog

end;</source>
