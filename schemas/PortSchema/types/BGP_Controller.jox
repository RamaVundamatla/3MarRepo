begin
	app.writeLog(class.name&amp;'::'&amp;method.name, LogTRACE);	//25 Nov 2019	NDL	TFS 47053

	if self.isRunning() and self.myCurrentRequest &lt;&gt; null then
		self.abortProcessing := true;
	endif;


end;</source>
    </JadeMethod>
