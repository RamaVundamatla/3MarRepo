    <JadeMethod name="getProductCode" id="cba5f520-732a-4afe-845f-74302cbb6642">
        <source>getProductCode(_glCode : CM_GLCode): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2018	jlgma1	ChangeRequest 40241: PEL1 - COPA - Product Code

*/

vars
	copa : String;
begin
	if _glCode = null then
		return null;
	endif;
	if _glCode.externalRef = null then
		return null;
	endif;
	copa := _glCode.externalRef;
	copa := copa[copa.length - 4 : copa.length];
	return copa;
	
epilog

end;</source>
        <Parameter name="_glCode" type="CM_GLCode"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRefDocNo" id="de40dc33-b9f3-4dc1-8454-63ce3b2f33f1">
        <source>getRefDocNo(_invoice: CM_Invoice; _field : String):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces

*/

vars
	postedPendingInv : CM_Invoice;
	refDocNo         : String;
begin
	if _invoice.myPostedPendingInvoice &lt;&gt; null then
		if _field = "refDocNo" then	// 01 Apr 2019	NDL	TFS 44080 - For Ref Doc Field, find
									// the original in the chain, not just the previous one
			postedPendingInv := _invoice.getPostedPendingInvOriginal();
		else
			postedPendingInv := _invoice.myPostedPendingInvoice; 
		endif;
		refDocNo   := postedPendingInv.exportCurrencyCode;
	endif;
	
	if refDocNo &lt;&gt; null then
		return refDocNo;
	else
		return Space;
	endif;
	
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxCode" id="1ef4679a-2063-4960-aee6-92be64962e23">
        <source>getTaxCode(_invoice : CM_Invoice):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jul 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
22 Nov 2018 cnwma1  ChangeRequest 42118: PEL1 - Generate tax number and invoice date
08 Apr 2019	NDL		TFS 44244
*/

vars
	finIOClass : CM_ExtFinanceIO;
	headerText ,
	taxCode     : String;
	
begin
	
	if _invoice.externalTaxNumber &lt;&gt; null then
		headerText := _invoice.externalTaxNumber;
	else
		finIOClass := _invoice.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIOClass.isKindOf(CM_Pelindo1Interface) then
			headerText := finIOClass.CM_Pelindo1Interface.getPelindoInvTaxStatusStr(_invoice);
		endif;
	endif;
	
	if ( headerText[1:3] = "010" or headerText[1:3] = "011" ) then
		taxCode := "A0";
	elseif ( headerText[1:3] = "020" or headerText[1:3] = "021" or
				headerText[1:3] = "030" or headerText[1:3] = "031") then
		taxCode := "A1";	
	elseif ( headerText[1:3] = "070" or headerText[1:3] = "071" ) then
		taxCode := "A2";
	elseif ( headerText[1:3] = "080" or headerText[1:3] = "081" ) then
		taxCode := "A3";	
	endif;
	
	return taxCode;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminalAreaForWorkOrderTI" id="784c421c-d299-403a-98b0-b172f48a4da2">
        <source>getTerminalAreaForWorkOrderTI(_invLine : CM_InvoiceLine): CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Feb 2019	cnwma1 Bug 43223: PEL1 - Container Services - WSDL 1.12 FacilityID/Name

*/

vars
	termArea    : CM_TerminalArea;
	invoice     : CM_Invoice;
	ti          : CM_TrackedItem;
	wo          : CM_WorkOrder;
	strArea     : String;
	currentLoc,
	lc          : CM_LocationsController;
	foundHeight : Integer;
	  
begin
	invoice := _invLine.invoice;
	if invoice.paymentType &lt;&gt; PaymentType_PrePay then
		return null;
	endif;
	
	if invoice.myWorkOrder = null then
		return null;
	endif;
	wo := invoice.myWorkOrder;
	ti := _invLine.getTrackedItem();
	
	if ti = null then
		return null;
	endif;
	if ti.myPrimaryActualLocation &lt;&gt; null then
		currentLoc := ti.myPrimaryActualLocation;
	endif;
	
	if wo.isWorkOrderForReceival then
	
		if _invLine.getCalcType.calculationType = INV_CALC_TYPE_TRANSQUANTITY then
			termArea := ti.getToDoTaskCompleteLocation();
		else
			termArea := ti.getFirstLocationAfterReceival();
		endif;
		
	elseif wo.isWorkOrderForRelease then
		
		strArea := ti.getLastLocationBeforeRoadRel();
		if strArea &lt;&gt; null then
			ti.myTerminal.findLocationFromString(strArea,true,lc, foundHeight);
			if lc &lt;&gt; null and lc.isKindOf(CM_YardController) then
				termArea := lc.getMyTerminalArea;
			endif;
		endif;
		
	elseif wo.isWorkOrderForNullVoyage then
		
		if currentLoc &lt;&gt; null then
			termArea := currentLoc.myTerminalArea;
		endif;
		
	elseif wo.isWorkOrderForToDo then
		
		termArea := ti.getToDoTaskCompleteLocation();
		
	elseif wo.isWorkOrderForMove then
	
		termArea := wo.allWoDtls.first.CM_WodMove.myTargetLocation.myTerminalArea;
	
	elseif wo.isWorkOrderForExportReturn then
	
		termArea := currentLoc.myTerminalArea;
	else
	
	endif;
	return termArea;
epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getTotalAmtDPP" id="b21fbd5e-7c53-48bc-8123-2283f52ee424">
        <source>getTotalAmtDPP(_invoice :CM_Invoice):Integer64;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2019 cnwma1	Bug 42690: PEL1 - Exchange Rate field in WSDLs for INT Invoices
28 Jan 2019 cnwma1	Bug 43115: PEL1 - SAP Integration - Decimal String
*/

vars
	lineTotal,
	amtDPPTotal	: Decimal[23,6];
	invLine         : CM_InvoiceLine;
begin
	foreach invLine in _invoice.invoiceLines  discreteLock  where not invLine.voided do  
		
		lineTotal   := self.getAmtDPP(invLine);
		amtDPPTotal := amtDPPTotal + lineTotal;	
		
	endforeach;
	
	amtDPPTotal := amtDPPTotal.truncatedTo(0);  //28.01.2019 cnwma1 Bug #43115
	return amtDPPTotal.Integer64;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="getTotalAmtDocCurAR" id="8d89b7b6-5d03-4cc0-8a41-0933c6580fad">
        <source>getTotalAmtDocCurAR(_invoice : CM_Invoice):Integer64;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jan 2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
28 Jan 2019 cnwma1	Bug 43115: PEL1 - SAP Integration - Decimal String
*/

vars
	lineTotal,
	amtDocCurArTotal	: Decimal[23,6];
	invLine       	    : CM_InvoiceLine;
begin
	foreach invLine in _invoice.invoiceLines  discreteLock  where not invLine.voided do 
		
		lineTotal := self.getAmtDocCurAR(invLine);
		
		amtDocCurArTotal := amtDocCurArTotal + lineTotal;
	endforeach;
	
	amtDocCurArTotal := amtDocCurArTotal.truncatedTo(0); //28.01.2019 cnwma1 Bug #43115
	
	return amtDocCurArTotal.Integer64;	
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="getVoyageBerth" id="47926651-6852-451d-8df3-0223880865c4">
        <source>getVoyageBerth(_voyage : CM_Voyage): HMS_Berth;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2019	jlgma1	ChangeRequest 43558: PEL1 - SAP - Profit center for a NULL voyage

*/

vars
	berth : HMS_Berth;
begin
	
	if _voyage = null then
		return null;
	endif;
	
	if _voyage.isNullVoyage then
		if _voyage.myTerminal.myHarbour &lt;&gt; null then
			foreach berth in _voyage.myTerminal.myHarbour.allBerths discreteLock do
				if berth.description.toUpper = "LAUT" then
					return berth;
				endif;
			endforeach;
		endif;
	else
		if _voyage.getMyBerth &lt;&gt; null then
			return  _voyage.getMyBerth;
		endif;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getVoyageMovement" id="11b1d41f-ef49-447d-b816-b2930b5a9997">
        <source>getVoyageMovement(_trans :HMS_VTMISTransaction):HMS_VoyageMovement;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2018	jlgma1	Initial creation

*/

vars
	movement : HMS_VoyageMovement;
begin
	if _trans.myMovement &lt;&gt; null then
		if _trans.myMovement.isKindOf(HMS_VoyageMovement) then
			movement := _trans.myMovement.HMS_VoyageMovement;
		endif;
	endif;
	return movement;
epilog

end;</source>
        <Parameter name="_trans" type="HMS_VTMISTransaction"/>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
