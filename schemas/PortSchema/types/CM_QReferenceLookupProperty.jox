<Class name="CM_QReferenceLookupProperty" id="3534a590-45ef-4e59-a2bb-4cbbfa39827b">
    <superclass name="CM_QLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="3026f1a7-d839-4cd5-bebe-ca9e14780791">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QReferenceLookup persistent;
	self.allAllowedOperators.add(oper);


end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="eb41f159-9113-4318-81bb-e0399b6eff35">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _op.isKindOf(CM_QReferenceLookup) then
		return QueryControl_ComboBox;
	elseif _op.isKindOf(CM_QReferenceIsOneOf) then
		return QueryControl_MultiSelect;
	endif;

	return inheritMethod(_op);

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGradesList" id="ab85da63-ec0b-4c92-a463-4154cd570aec">
        <source>getGradesList(_crit : CM_SelectorCriteriaLine) : CM_CodeSet;
/*

Purpose:			TFS 7821

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2017	jlgab1	Initial creation

*/

vars
	opset : CM_CodeSet;
	ls : CM_LogGrade;
	anything : Any;
	array : ObjectSet;
	lookup : String;
	type : CM_CodeGroupType;
	group : CM_CodeGroup;
	groupls : CM_CodeGroup;
	codels, codeg : CM_Code;
	grade : CM_LogGrade;
	obj : Object;
begin
	create array transient;
	create opset transient;
	
	anything := _crit.myQueryOperator.getSearchValue();
	if anything &lt;&gt; null then
		if anything.isKindOf(ObjectSet) then
			anything.ObjectSet.copy(array);		
		elseif anything.isKindOf(Object) then
			array.add(anything.Object);
		
		endif;
	endif;
	
	type := app.myRoot.allCodeGroupTypes[CodeGroup_LogSpecs];
	foreach obj in array do
		ls := obj.CM_LogGrade;
		
			if array.includes(ls) then
				opset.addNoDuplicates(ls, false);
			endif;
	endforeach;
	

	
	
	return opset;
epilog

end;</source>
        <Parameter name="_crit" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="CM_CodeSet"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="788175f2-c40b-409f-8b3d-c383924253e1">
