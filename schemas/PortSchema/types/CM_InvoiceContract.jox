    <JadeMethod name="getDisplayStringForAttribute" id="a205c312-c0a8-4bfc-94c9-266b5810c312">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55671
*/

vars

begin
	// ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1 FROM
	if _attrName = ETRow_ContractId then
		return self.contractId;
	elseif _attrName = ETRow_DebtorName then
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.name;
		endif;
		
		return null;
	elseif _attrName = ETRow_FromTS then
		return self.systemToLocalTime(self.fromTS).asStringJMT();
	elseif _attrName = ETRow_ToTS then
		return self.systemToLocalTime(self.toTS).asStringJMT();
	elseif _attrName = ETRow_IsActive then
		return self.active.getYes();
	elseif _attrName = ETRow_Description then
		if self.description.length &gt; 50 then
			return self.description[1:50] &amp; "...";
		else
			return self.description;
		endif;
	elseif _attrName = ETRow_IsPrimary then
		return self.primary.getYes();
	elseif _attrName = ETRow_HasAttachments then
		//return self.allFiles.isNotEmpty().getYes();	//16-05-2023	navtnr20 57964
		return self.hasAttachements().asStringJMT(); //16-05-2023	navtnr20 57964
	else
	// ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1 TO
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
