    <JadeMethod name="jtdGetUserCommandLine" id="ccb66830-26ca-47dd-8b7e-bbd3366c0775">
        <source>jtdGetUserCommandLine() : String;

constants
	EndJadeCommandLine = "endJade";
	
vars
	n : Integer;
	s : String;
	
begin
	s := self.jtdGetCommandLine;
	
	n := s.pos(EndJadeCommandLine, 1);
	
	if n &lt; 1 then
		return null;
	endif;

	n := n + EndJadeCommandLine.length;
	
	if n &gt; s.length then
		return null;
	endif;
	
	return s[n : end];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetVersionString" id="073da91a-b3cf-41e6-881c-a73dc9e5f8c6">
        <source>jtdGetVersionString() : String;

begin
	return JtdVersionMajor.String &amp; '.' &amp;
		JtdVersionMinor.String &amp; '.' &amp; JtdVersionPatch.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdHasInitialFormPosition" id="ca6fb8e4-92b0-4f7b-b9e2-7237be895fdd">
        <source>jtdHasInitialFormPosition() : Boolean;

begin
	return self.jtdInitialFormTop &gt; 0 or
		   self.jtdInitialFormLeft &gt; 0 or
		   self.jtdInitialFormWidth &gt; 0 or
		   self.jtdInitialFormHeight &gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdInitialize" id="97cf9fea-5a04-431d-88f8-132df1e643fd">
        <updating/>
        <source>jtdInitialize() updating;

vars
	s : String;
	
begin
	self.jtdFinalize;
	
	self.jtdLoadErrorMessages;

	self.jtdSetInitialFormPosition(0, 0, 0, 0);

	self.jtdInitialStatusDisplayEnabled := true;
	
	self.jtdTrxDelay := 0;
	self.jtdAutoPingResponseInterval := 0;
	self.jtdStartupDelaySecs := 0;
	self.jtdShutdownDelaySecs := 0;
	self.jtdTotalRunSecs := 0;

	self.jtdClearTrxSelectionState;

	self.jtdMethodNameToProfile := null;
	self.jtdProfilerOutputFileName := null;

	self.jtdCreateTrxGeneratorRecursive(JtdTransactionGenerator);
	
	// Semi-colons are delimiters in notification info, so we want
	// to keep things simple and not confuse the controller app with
	// embedded semi-colons in computer names. If the computer names
	// include semi-colons, we'll just replace them with underscores.
	// Computer names are used only for display and are unlikely to
	// contain any semi-colons in the first place.

	s := app.computerNameAppServer;
	s.replaceChar(';', '_');
	self.jtdComputerNameLocal := s;
	
	if process.isUsingThinClient then
		s := app.computerName;
		s.replaceChar(';', '_');
		self.jtdComputerNameThinClient := s;
	else
		self.jtdComputerNameThinClient := null;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdInitializeFromParamObj" id="89cd827b-db67-458f-8721-7628617f2917">
        <updating/>
        <source>jtdInitializeFromParamObj(aip : JtdAppInitializationParameter) updating, protected;

begin
	if aip = null then
		return;
	endif;
	
	self.jtdSetInitialFormPosition(aip.jtdFormTop, aip.jtdFormLeft,
		aip.jtdFormHeight, aip.jtdFormWidth);
	
	self.jtdSetTrxDelay(aip.jtdTrxDelay);
	
	self.jtdSetAutoPingResponseInterval(aip.jtdAutoPingResponseInterval);

	self.jtdSetDriverProfile(aip.jtdProfileName);
	
	self.jtdMachineId:=aip.jtdMachineId;
	self.jtdTerminalId:=aip.jtdTerminalId;
	
	self.jtdInitialStatusDisplayEnabled := aip.jtdStatusDisplayEnabled;

	self.jtdSetStartupDelaySecs(aip.jtdStartupDelaySecs);
	self.jtdSetShutdownDelaySecs(aip.jtdShutdownDelaySecs);
end;</source>
        <access>protected</access>
        <Parameter name="aip" type="JtdAppInitializationParameter"/>
    </JadeMethod>
    <JadeMethod name="jtdLastMethodHasCallsRemaining" id="8fda7bf1-7bc0-47d4-9637-fa63ca40df16">
        <source>jtdLastMethodHasCallsRemaining() : Boolean;

begin
	return
		self.jtdMyLastSelectedTrxMthProfile &lt;&gt; null and
		self.jtdLastSelectedTrxCallCount &gt; 0 and
		self.jtdLastSelectedTrxCallCount &lt; self.jtdMyLastSelectedTrxMthProfile.jtdNumCalls;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdLoadErrorMessages" id="15d570c5-31f6-4447-9bbe-9286c9862957">
        <updating/>
        <source>jtdLoadErrorMessages() updating, protected;

vars
	category : ConstantCategory;
	errMsg : JtdErrorMessage;
	consts : ConstantNDict;
	const : Constant;
	
begin
	category := currentSchema.getCategory("JtdExceptions");
	
	if category = null then
		self.jtdErrorMsg("Cannot find JtdExceptions global constant category in " &amp;
			currentSchema.name &amp; '.', true);
		return;
	endif;

	consts := category.getConstants;
	
	if consts = null then
		self.jtdErrorMsg("JtdExceptions global constant category returned null dictionary.", true);
		return;
	endif;

	const := consts["JtdBaseExceptionNumber"];
	
	if const = null then
		self.jtdErrorMsg("Cannot find JtdBaseExceptionNumber global constant.", true);
		return;
	endif;

	self.jtdExceptionNumberBase := const.valueAsInteger;
	
	if self.jtdExceptionNumberBase &lt; 0 then
		self.jtdErrorMsg("JtdBaseExceptionNumber global constant value cannot be negative.", true);
		return;
	endif;
				
	foreach const in consts do
		create errMsg transient;
		errMsg.jtdInitializeFromGlbConstant(const.GlobalConstant, self.jtdExceptionNumberBase);
		
		if self.jtdAllErrorMessages[errMsg.jtdNumber] &lt;&gt; null then
			self.jtdErrorMsg("Duplicated error number: " &amp; errMsg.jtdNumber.String, true);
			return;
		endif;
		
		self.jtdAllErrorMessages.add(errMsg);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdPoissonRandom" id="49427cea-3037-4438-9093-6a90a89180aa">
        <source>jtdPoissonRandom(lambda : Integer) : Integer;

vars
	randomInteger, result : Integer;
	total, factor, randomReal: Real;

begin
	factor := -(1 / lambda).Real;

	while true do
		randomInteger := app.random(1000);
		if randomInteger = 0 then
			randomInteger := 1;
		endif;

		randomReal := randomInteger.Real * 0.001;
		
		total := total + (factor * randomReal.log);
		if total &gt;= 1 then
			return result;
		endif;
		
		result := result + 1;
	endwhile; 
end;</source>
        <Parameter name="lambda" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdRaiseJtdException" id="11fd7dca-ad03-40aa-90a6-5ec11b917522">
        <source>jtdRaiseJtdException(errNo : Integer);

vars
	exceptionObject : JtdException;

begin
	create exceptionObject transient;
	exceptionObject.errorCode := errNo;
	exceptionObject.errorItem := app.name &amp; " error " &amp; errNo.String;
	exceptionObject.extendedErrorText := self.jtdGetErrorString(errNo);
	raise exceptionObject;
end;</source>
        <Parameter name="errNo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdSelectTransaction" id="13d90287-1bfd-4420-b8b0-b1d58fe428c5">
        <updating/>
        <source>jtdSelectTransaction() : JtdMethodProfile updating;

vars
	dp : JtdDriverProfile;
	mp : JtdMethodProfile;
	idx, sz, n : Integer;
	
begin
	mp := self.jtdMyLastSelectedTrxMthProfile;
	n := self.jtdLastSelectedTrxCallCount;

	// check if we're to run our previous transaction again
	if mp &lt;&gt; null and n &lt; mp.jtdNumCalls then
		self.jtdLastSelectedTrxCallCount := n + 1;
		return mp;
	endif;

	self.jtdMyLastSelectedTrxMthProfile := null;
	self.jtdLastSelectedTrxCallCount := 0;
	
	dp := self.jtdMyDriverProfile;
	
	if dp = null then
		return null; // belts and braces
	endif;

	// prolog selection
	if self.jtdTrxSelectionState = self.JtdSelectFromProlog then
		sz := dp.jtdAllPrologProfiles.size;
		idx := self.jtdLastSelectedTrxIndex + 1;

		if sz &lt; 1 or idx &gt; sz then
			// The prolog is always executed in sequence and only once
			// per run. Callers must change state when they want to move
			// out of prolog execution.
			return null;
		endif;
		
		if idx &lt; 1 then
			idx := 1;
		endif;

		mp := dp.jtdAllPrologProfiles[idx];
		self.jtdLastSelectedTrxIndex := idx;

	// main selection
	elseif self.jtdTrxSelectionState = self.JtdSelectFromMain then
		sz := dp.jtdAllMethodProfiles.size;
	
		if sz &lt; 1 then
			// callers must change state to run the epilog
			return null;
		endif;

		// we will continue to select main methods until the caller
		// changes state to run either the prolog or the epilog
		if dp.jtdRandomSelection then
			mp := dp.jtdAllMethodProfiles.jtdGetRandomMember;
		else
			idx := self.jtdLastSelectedTrxIndex + 1;

			if idx &lt; 1 or idx &gt; sz then
				idx := 1;
			endif;

			mp := dp.jtdAllMethodProfiles[idx];
			self.jtdLastSelectedTrxIndex := idx;
		endif;

	// epilog selection
	elseif self.jtdTrxSelectionState = self.JtdSelectFromEpilog then
		sz := dp.jtdAllEpilogProfiles.size;
		idx := self.jtdLastSelectedTrxIndex + 1;

		if sz &lt; 1 or idx &gt; sz then
			// The epilog is always executed in sequence and only once
			// per run. Callers must change state when they want to move
			// out of epilog execution.
			return null;
		endif;
		
		if idx &lt; 1 then
			idx := 1;
		endif;

		mp := dp.jtdAllEpilogProfiles[idx];
		self.jtdLastSelectedTrxIndex := idx;
	endif;
		
	self.jtdMyLastSelectedTrxMthProfile := mp;
	self.jtdLastSelectedTrxCallCount := 1;
			
	return mp;
end;</source>
        <ReturnType type="JtdMethodProfile"/>
    </JadeMethod>
    <JadeMethod name="jtdSetAutoPingResponseInterval" id="c94ecb92-16de-4396-99ab-c7b8f84a0d5f">
