    <JadeMethod name="setComboValues" id="2f5239ec-dedf-41d9-bf67-0a259105f268">
        <source>setComboValues(comboBox					: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

// ----------   ----------  --------------------------------------------------
Date			Name		TFS#		Description
14 May 2014		cnwndl1					Initial creation
21 Aug 2018		jlgka1		40200		Add Termninal description to the list Argument
*/

vars
	termSelCriteriaLine	: CM_SelectorCriteriaLine;
	userTerminal		: CM_UserTerminal;
	terminal			: CM_Terminal;
	bisUnit				: CM_Bank;
	object				: Object;
	objectSet			: ObjectSet;
	idx					: Integer;
	storeIdx			: Integer;
	selectStr			: String;
	str					: String;
	multiTerminal		: Boolean;
	selectedBank		: CM_Bank;
begin
	comboBox.clear();	
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	create objectSet transient;
	
	// 34364 company specific to terminal otherwise companies for terminals the user can see
	foreach termSelCriteriaLine in queryCriteriaLineHolder.allCriteriaLines do
		if termSelCriteriaLine.myQueryProperty.propertyName = 'myTerminal' then
			termSelCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
			break;
		endif;
	endforeach;
	if objectSet.isEmpty() then
		//app.myRoot.allTerminals.copy(os);
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			objectSet.add(userTerminal.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		foreach bisUnit in terminal.companies where bisUnit.isBusinessUnit do
			if multiTerminal then
				str := bisUnit.code &amp; Tab &amp; '- ' &amp; terminal.code &amp; Tab &amp; ' ('  &amp; bisUnit.mailingName &amp; ')';
			else
				str := bisUnit.code &amp; Tab &amp; ' ('  &amp; bisUnit.mailingName &amp; ')';
			endif;
			idx := comboBox.addItem(str);
			comboBox.itemObject[idx] := bisUnit;
			
			if bisUnit.code = selectStr then
				selectedBank := bisUnit;
			endif;
		endforeach;
	endforeach;
	
	storeIdx  := comboBox.findObject(selectedBank);
	
	if storeIdx &gt; 0 and storeIdx &lt; comboBox.listCount then
		comboBox.listIndex := storeIdx;
	endif;

epilog
	delete objectSet;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="0ffb2314-f031-4706-a2aa-9825d7727021">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(CM_Bank) then
			return _value.CM_Bank.code;
		else
			return _value.String;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="a151a0ba-48cc-442e-afc1-9b77d558be90">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation

*/

vars
	invalidObj 		: Boolean;
	object			: CM_Bank;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_Bank) then
			object := _value.CM_Bank;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="8c0bbf7c-7b01-4b18-8385-d814d88c7920">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	bank : CM_Bank;
	term : CM_Terminal;

begin
	if _value.isKindOf(String) then
		term := app.myPassport.myTerminal;
		if term &lt;&gt; null then
			bank := term.companies[_value.String];
			if bank &lt;&gt; null then
				return bank.code;
			endif;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
