    <JadeMethod name="populateAP" id="4c118811-6fe5-4220-bf50-aef5cdd1d5be">
        <source>populateAP();
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/08/2008	Simon Ward	SFW1030 - Remove unused auto plan flags
// 25/02/2010	cnwcs5		Removed reference to VTA
// 16/02/2015   cnwma1      PAR # 34140 Terminal Area Def [AutoPlan Stack Direction]
// ---------------------------------------------------------------------------

vars

	idx 			: Integer;
	theTA 			: CM_TerminalArea;
	theAutoPlanTest : CM_AutoPlanTests;
	deckingOptionIn,
	deckingOptionOut: Integer;
	
begin
	theTA := self.myCurrentObject.CM_TerminalArea;

// cnwdad1 28/11/2008.
//	shtAutoPlan.visible := true;
	
	if theTA = null then
		return;
	endif;
	
		
	theAutoPlanTest := theTA.autoPlanTest;
	
	self.tblAPYardStack.setTableFromObject(theAutoPlanTest,null);
	
	idx := theTA.getConfig(AutoPlanApStackDirection).Integer;
	if idx &lt; STACK_UP_STACK or idx &gt; STACK_ALL_HEIGHT then
		idx := STACK_UP_STACK;
	endif;
//app.writeStatement(  'GD' &amp; class.name &amp;' '&amp; method.name &amp; ' ' &amp; idx.String &amp; ' ' &amp; self.cmbStackDirIn.itemText[idx+1].String);
	self.tblAPYardStack.setValueByName(ETRow_ApStackDirection,self.cmbStackDirIn.itemText[idx+1]);
	self.cmbStackDirIn.listIndex := idx+1;
	
	idx := theTA.getConfig(AutoPlanApStackDirectionOut).Integer;
	if idx &lt; 0 or idx &gt; 2 then
		idx := 0;
	endif;		
	self.tblAPYardStack.setValueByName(ETRow_ApStackDirectionOut,self.cmbStackDirOut.itemText[idx + 1]);
	self.cmbStackDirOut.listIndex := idx + 1;
	


	//epr 26/9/06 have changed VTA from CM_BlockStack to CM_VehicleTransferArea so same rules apply here 
	if  not theTA.isDeckable  then	
		self.shtAutoPlan.visible:=false; //epr par 32613 num rows machine sep only valid for gridded areas which meant now no options are valid for block stack so just hide this sheet
	else
		
		//self.tblAPYardStack.showRowByName(ETRow_ApStackDirection, false);     // 16/02/2015 cnwma1 PAR # 34140
		//self.tblAPYardStack.showRowByName(ETRow_ApStackDirectionOut, false);  // 16/02/2015 cnwma1 PAR # 34140
		self.tblAPYardStack.hideRowByName(ETRow_ApStackDirection, false);		// 16/02/2015 cnwma1 PAR # 34140
		self.tblAPYardStack.hideRowByName(ETRow_ApStackDirectionOut, false);	// 16/02/2015 cnwma1 PAR # 34140
		self.tblAPYardStack.showRowByName(ETRow_YardAllocationDeckingIn, false);
		self.tblAPYardStack.showRowByName(ETRow_YardAllocationDeckingOut, false);
		self.tblAPYardStack.showRowByName(ETRow_NumRowsMachineSep,false);
		self.tblAPYardStack.setValueByName(ETRow_NumRowsMachineSep,theTA.getConfig(AutoPlanNumRowsMachineSep).Integer);
	endif;
	
//	self.tblAPYardStack.hideRowByName(ETRow_ClearAccessToTarget,false);  // adm 170909 Par 20303
	if  theTA.isKindOf( CM_ForkLiftStack) then
		self.tblAPYardStack.showRowByName(ETRow_ForkLiftStartColumn,false);
	else
		self.tblAPYardStack.hideRowByName(ETRow_ForkLiftStartColumn,false);
	endif;
	
	if theTA.isKindOf(CM_StraddleStack) or  theTA.isKindOf( CM_ForkLiftStack) then
		self.myAssistant.comboBoxInDeckGridArea(self.cmbDeckingOptIn, DeckingLevel_TA, theTA.type, theTA.myYADeckingOptions);
		self.myAssistant.comboBoxOutDeckGridArea(self.cmbDeckingOptOut, DeckingLevel_TA, theTA.type, theTA.myYADeckingOptions);
		self.cmbColumnDir.setIndexForItemData(theTA.CM_GridArea.defaultDeckingStartType);
//		self.tblAPYardStack.hideRowByName(ETRow_TestNumFromEnd,false);
//		self.tblAPYardStack.hideRowByName(ETRow_TestAllInBlockStack,false);
//	else adm 170909 Par 20303
//		self.tblAPYardStack.showRowByName(ETRow_TestNumFromEnd,false);
//		self.tblAPYardStack.showRowByName(ETRow_TestAllInBlockStack,false);
	endif;

	if theTA.isKindOf(CM_StraddleStack) then
		self.tblAPYardStack.showRowByName(ETRow_StraddleStartRow,false);
	else
		self.tblAPYardStack.hideRowByName(ETRow_StraddleStartRow,false);
	endif;
		
	self.tblAPYardStack.setValueByName(ETRow_YardAllocationDeckingIn, self.cmbDeckingOptIn.text);
	self.tblAPYardStack.setValueByName(ETRow_YardAllocationDeckingOut, self.cmbDeckingOptOut.text);
	self.tblAPYardStack.setValueByName(ETRow_ForkLiftStartColumn, self.cmbColumnDir.text);
	self.tblAPYardStack.setValueByName(ETRow_StraddleStartRow, self.cmbRowDir.text);

	self.tblAPYardStack.setValueByName(ETRow_StackTests,"Select...");

	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbColGroup" id="efdbdc2d-dcf1-46d5-9956-6f64dc0471e6">
        <source>populateCmbColGroup( _tam : CM_TerminalAreaMaster );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2021	navndl1	Initial creation	TFS 49912

*/

vars

	selectedObj : Object;
	columnGroup : CM_RowController;
	index : Integer;

begin

	selectedObj := self.cmbColGroup.listObject;
	
	self.cmbColGroup.clear();
	self.cmbColGroup.sorted := false;
	
	self.cmbColGroup.addItem("All Columns (per Column)");
	if _tam &lt;&gt; null and _tam.isKindOf( CM_GeneralCargoAllocRowArea ) then
		foreach columnGroup in _tam.CM_GeneralCargoAllocRowArea.allRowControllersById do
			index := self.cmbColGroup.addItem( "Group Column - " &amp; _tam.id &amp; " " &amp; columnGroup.ident );
			self.cmbColGroup.itemObject[index] := columnGroup;
		endforeach;
	endif;
	
	self.cmbColGroup.listIndex := 1;
	
	if selectedObj &lt;&gt; null then
		index := self.cmbColGroup.findObject( selectedObj );
		if index &gt; 0 then
			self.cmbColGroup.listIndex := index;
		endif;
	endif;
	
	self.tblExtra.setValueByControlName(self.cmbColGroup.name, self.cmbColGroup.text);
	
epilog

end;</source>
        <Parameter name="_tam" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="populateCmbTrxType" id="254f0213-512f-410c-9a31-6307e6b449d0">
        <source>populateCmbTrxType( _trxType : CM_TransactionType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2018	jlgndl1	Initial creation	TFS 38897

*/

vars

	trxType : CM_TransactionType;

begin

	self.cmbTrxType.clear();
	foreach trxType in app.myRoot.allTransactionTypes do
		if trxType.classNameToCreate = "CM_Release" then
			if not trxType.isSystemTransType then
				self.cmbTrxType.itemObject[self.cmbTrxType.addItem( trxType.description )] := trxType;
			endif;
		endif;
	endforeach;
	
	if _trxType &lt;&gt; null then
		self.cmbTrxType.listIndex := self.cmbTrxType.findObject( _trxType );
	endif;
	
	self.cmbTrxType.lostFocus( self.cmbTrxType );

epilog

end;</source>
        <Parameter name="_trxType" type="CM_TransactionType"/>
    </JadeMethod>
    <JadeMethod name="populateDesign" id="36d75c17-78ec-4d13-beba-d4dc47edc98a">
        <updating/>
        <source>populateDesign() updating, protected;


	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	designCaption : String;
begin
	shtDefDesign.translateCaption(Xlat_0004049, app.myCurrentLocale);


	if self.flipHorizontal then
		if self.flipVertical then
			shtDefDesign.caption := shtDefDesign.caption  &amp; "-reversed H &amp;&amp; V";
		else
			shtDefDesign.caption := shtDefDesign.caption  &amp; "-reversed H";
		endif;
	else
		if self.flipVertical then
			shtDefDesign.caption := shtDefDesign.caption  &amp; "-reversed V";
		endif;
	endif;
	self.myCurrentSOPGridArea.setFlips(self.flipHorizontal,self.flipVertical);
	self.frmMain.drawSelf();
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateFormNew" id="25fb6ad1-db39-49a3-87ab-a2de754418e7">
        <updating/>
        <source>populateFormNew(obj: Object) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2009	cnwer1	Initial creation - refactored out of populateForm to use ent table defs and CM_Object::getDisplayStringForAttribute
sept 2009		cnwcs5	Remove VTA code
22/08/2011	cnwdap1	PAR #28047 CCMS POL 2095 maintain machines for terminal areas
10/06/2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars
	ta 				: CM_TerminalArea;
	taMaster 		: CM_TerminalAreaMaster;
	viewName 		: String;
	isLogMarkedUp	: Boolean;
	terminal		: CM_Terminal;
	prodMinMax 		: CM_TerminalAreaProductMinMax;
	entRowTransient : EntTableRowTransient;
	entTableView 	: EntTableView;
	entRow 			: Object;
	entTableDef		: EntTableDef;
	tat				: CM_TerminalAreaType;
	terminalAreas	: CM_TerminalAreaSet;
	prevRTGArea,
	nextRTGArea 	: CM_RTGArea;
	idx 			: Integer;
	
begin
	self.btnGPSLiebherr.visible := false;
	self.tblExtraList.visible := false;
	
	taMaster	:=obj.CM_TerminalAreaMaster;
	tat 		:= app.myRoot.allTerminalAreaTypes[taMaster.type];
	
	self.sptThumbEdit.hideRightControl(true);
	self.displayProductMinMax(null);
	
	shtGateLanes.visible		:= false;	
	shtTerminalAreas.visible 	:= false;
	shtTerminalAreas.caption	:= app.getErrorString (TerminalAreas);
	listsTermAreas.resetButtonsVisible;
	self.btnStackEdit.visible := false;	//07 Sep 2020	NDL	TFS 49984
	
	viewName:=tat.getTADefintionViewName;
	entTableDef:=app.myController.getEntTableDef(ETDef_TAMain);
	entTableView:=entTableDef.allEntTableViews[viewName];
	self.tblMain.setEntTableFromView(entTableDef,entTableView,null,CM_BaseForm::entTableDefSetupWarning.name);
	foreach entRow in self.tblMain.allEntRowTransients do
		entRowTransient:=entRow.EntTableRowTransient;
		self.tblMain.setValueByName(entRowTransient.name, taMaster.getDisplayStringForAttribute(entRowTransient.name,false));
	endforeach;	
	
	if taMaster.type = TA_TYPE_LOGAREA then
		isLogMarkedUp := taMaster.CM_RowArea.isMarkedUp;		

	elseif taMaster.myType.isGantryAreaType then
		self.btnGPSLiebherr.visible := app.isSpecial();
		//ccms 1076 epr RMGs
		self.myAssistant.comboBoxLaneGrouping(taMaster.type,self.cmbLaneGroup);
		if self.myCurrentObject.CM_RTGArea.allTerminalAreaGroups.first &lt;&gt; null then
			self.cmbLaneGroup.listObject:=self.myCurrentObject.CM_RTGArea.allTerminalAreaGroups.first;
			self.doBuildComboNextPrevLane();
			
			prevRTGArea:=self.myCurrentObject.CM_RTGArea.getPreviousRTGAreaInRTGLane;
			if prevRTGArea &lt;&gt; null then
				self.cmbPrevArea.listObject:=prevRTGArea;
			endif;
			nextRTGArea:=self.myCurrentObject.CM_RTGArea.getNextRTGAreaInRTGLane;
			if nextRTGArea &lt;&gt; null then
				self.cmbNextArea.listObject:=nextRTGArea;
			endif;
		endif;
		idx := self.cmbSideICPos.findItemData(self.myCurrentObject.CM_RTGArea.getSideInterchangeAreaPosition);
		if idx &gt; 0 then
			self.cmbSideICPos.listIndex:=idx;
		endif;
	elseif taMaster.type =TA_TYPE_INTERTERM_TRANS_AREA then
		if taMaster.CM_InterTerminalTransferArea.myOtherTerminalTransferArea &lt;&gt; null then
			terminal := taMaster.CM_InterTerminalTransferArea.myOtherTerminalTransferArea.myTerminal;
			if terminal &lt;&gt; null then
				self.tblMain.setValueByName(ETRow_Terminal, terminal.code);
				self.cmbTerminal.listObject := terminal;
			endif;
		endif;
	//elseif taMaster.type = TA_TYPE_BULK or taMaster.type = TA_TYPE_BLOCK_STACK then	// R Barr 3/11/2006 Comalco
	elseif taMaster.type = TA_TYPE_BULK or taMaster.type = TA_TYPE_BLOCK_STACK or taMaster.type = TA_TYPE_IRREGULAR_BLOCK_AREA or	//20 Jun 2016	NDL	TFS 1752
	taMaster.type = TA_TYPE_GEN_CARGO_ALLOC_ROW then								// TFS 49453
		//epr CCMS 1366 3/4/14 setup product maxs
		self.initExtraTable( taMaster.myType );
		self.displayProductMinMaxs(taMaster);
		if self.tblExtraList.rows &gt; 1 then
			self.tblExtraList.selectRow(2,false);
			self.doTblExtraListClick();
		else
			self.displayProductMinMax(null);
		endif;
		if taMaster.type = TA_TYPE_IRREGULAR_BLOCK_AREA then // ### TFS CR 58499 TASK 61459 04JAN2024 NAVAB1
			self.initTableGateLanes(self.tblGateLanes,TA_TYPE_IRREGULAR_BLOCK_AREA);
			self.populateTransferList(taMaster.CM_IrregularBlockArea);
		endif;
		
	elseif taMaster.type = TA_TYPE_CRANE_TRANS then
		self.initTableGateLanes(self.tblGateLanes,TA_TYPE_CRANE_TRANS);
		self.shtGateLanes.visible:=true;
		self.loadLanesForCTA(taMaster.CM_CraneTransferArea);
	elseif taMaster.type = TA_TYPE_YARD_INTERCHANGE then
		self.setDefaultTAsForInterchange(ta);
		listsTermAreas.setSelected(taMaster.CM_InterchangeArea.allAssociatedTerminalAreas);		
		
		//cnwjo3 ccms 1061 par 20582
		self.initTableGateLanes(self.tblGateLanes, TA_TYPE_YARD_INTERCHANGE);	// cnwjk3 ccms 1018 18/11/09
		//cnwjo3 ccms 1061 par 20582, populate existing instances into table!
		self.loadLanesForInterchange (taMaster.CM_YardInterchangeArea);	// cnwcs5 11/09/2009
	
		if taMaster.CM_AreaWithLanes.isBufferZone then
			self.tblMain.hideRowByName(ETRow_LaneCount, false);
			self.shtGateLanes.visible:=false;
		
		else
			self.tblMain.showRowByName(ETRow_LaneCount, false);
			self.shtGateLanes.visible:=true;
		endif;
		
	elseif taMaster.type = TA_TYPE_WORKPOINT_INTERCHANGE then
		//cnwjo3 ccms 1061 par 20582
		self.initTableGateLanes(self.tblGateLanes, TA_TYPE_YARD_INTERCHANGE);	// cnwjk3 ccms 1018 18/11/09
		//cnwjo3 ccms 1061 par 20582, populate existing instances into table!
		self.loadLanesForInterchange (taMaster.CM_AreaWithLanes);	// cnwcs5 11/09/2009
	
		if taMaster.CM_AreaWithLanes.isBufferZone then
			self.tblMain.hideRowByName(ETRow_LaneCount, false);
			self.shtGateLanes.visible:=false;
		
		else
			self.tblMain.showRowByName(ETRow_LaneCount, false);
			self.shtGateLanes.visible:=true;
		endif;
		// 28604 Nov 2011 populate work point combo with available entries
		if self.mode &lt;&gt; self.Mode_Update then
			self.doBuildComboWorkPoints(taMaster);
		endif;
		
		//epr par 30128 21/8/12 
		self.cmbWorkPoint.listObject:=taMaster.CM_WorkPointInterchangeArea.myWorkPoint;
	// cnwjk3 ccms 1018 18/11/09
	elseif taMaster.type = TA_TYPE_RORO_LANE_AREA then
		self.shtGateLanes.visible 	:= true;
		self.shtGateLanes.caption := app.getErrorString(XLAT_Caption_Lanes);
		self.initTableGateLanes(self.tblGateLanes, TA_TYPE_RORO_LANE_AREA);	// cnwjk3 ccms 1018 18/11/09
		self.loadLanesForRoRoLaneArea(taMaster.CM_RoRoLaneArea);
	elseif  taMaster.myType.isGantryLaneAreaType then
		self.setDefaultTAsForGantryLane(taMaster.myType);
		listsTermAreas.setSelected(taMaster.CM_RTGLane.allTAsByTypeId);		
	endif;	
		
	//07 Sep 2020	NDL	TFS 49984
	if taMaster.allowsGriddedStackHeightCrit() then	
		self.initExtraTable( taMaster.myType );
		self.displayStackHeights(taMaster);
		
	endif;
	
	
	//28 May 2018	NDL	TFS 38897
	if taMaster.type = TA_TYPE_RELTRANS and taMaster.CM_BlockStack.actAsReleasePoint &gt; 0 then
		self.populateCmbTrxType( taMaster.CM_BlockStack.getTrxTypeOnReleaseObj );
		self.tblMain.showRowByName(ETRow_AutoRelease, false);
		self.tblMain.showRowByName(ETRow_TrxTypeOnRelease, false);
	else
		self.tblMain.hideRowByName(ETRow_AutoRelease, false);
		self.tblMain.hideRowByName(ETRow_TrxTypeOnRelease, false);
		self.cmbTrxType.listIndex := -1;
	endif;
	
	if taMaster.myType.canAssociateInterchangeAreas then
		ta:= taMaster.CM_TerminalArea;
		self.setDefaultICAreas();
		listsTermAreas.setSelected(ta.allAssociatedInterchangeAreas);		
		self.doBuildDefaultInterchangeCombo(ta.myDefaultInterchangeArea);
	endif;
	
	// PAR #28047 start
	self.listsMachines.setupControl(app.getErrorString(Machines), self.myTerminal.machines, SOP_TerminalAreaDefForm::listsMachinesDisplayEntry.name);
	self.listsMachines.setSelected(taMaster.allowedMachines);
	self.listsMachines.readOnly := true;
	// PAR #28047 end

	
	if not isLogMarkedUp then
		tblMain.hideRowByName(ETRow_Width, false);
	endif;

	if taMaster.canBeStockControlled then
		self.tblMain.showRowByName(ETRow_StockControlled, false);
	else
		self.tblMain.hideRowByName(ETRow_StockControlled, false);
	endif;
	
	//04 Aug 2017	NDL	TFS 5679
	if taMaster.myType.isLogicalDeleteArea then
		self.tblMain.showRowByName(ETRow_DoCreateLogicalDelTrx,false);	
	else
		self.tblMain.hideRowByName(ETRow_DoCreateLogicalDelTrx,false);	
	endif;
	
	self.frmToolbar.cnEcResizeContents();
	self.tblMain.optimiseTableHeight();
	//self.tblMain.adjustHeight(1000);
epilog
	delete terminalAreas;
end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="populateTransferList" id="29a59aa6-6d52-4426-8c2b-7c366faac5e8">
        <source>populateTransferList(_gcArea : CM_IrregularBlockArea);
/*
Purpose:			

Date		Who		Reason
04 January 2024	navab1	CR 58499 TASK 61459
*/

vars

	lc : CM_LocationsController;
begin
	self.shtGateLanes.visible	:= true;
	self.shtGateLanes.caption:=app.getErrorString(Transfer_areas);
	self.tblGateLanes.rows := self.tblGateLanes.fixedRows;
	
	foreach lc in _gcArea.allLocationsControllers discreteLock do
		self.tblGateLanes.updateItemObject(lc, White, White, app.myPassport);		
	endforeach;
	


epilog

end;</source>
        <Parameter name="_gcArea" type="CM_IrregularBlockArea"/>
    </JadeMethod>
    <JadeMethod name="resetTblAPYardStack" id="a5242bb9-ab11-481d-875f-271539f63c46">
        <source>resetTblAPYardStack();
//----------------------------------------------------------------
//	Created:	20 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//set AP/YP defaults
	
	self.cmbDeckingOptIn.text := app.getDeckingInCaption(DeckingMenu_In_Opt1);
	self.tblAPYardStack.setValueByControlName(self.cmbDeckingOptIn.name,self.cmbDeckingOptIn.text);

	self.cmbDeckingOptOut.text := app.getDeckingOutCaption(DeckingMenu_Out_Opt10);
	self.tblAPYardStack.setValueByControlName(self.cmbDeckingOptOut.name,self.cmbDeckingOptOut.text);

	self.cmbColumnDir.listIndex := 1;
	self.tblAPYardStack.setValueByControlName(self.cmbColumnDir.name,self.cmbColumnDir.text);

	self.cmbRowDir.listIndex := 1;
	self.tblAPYardStack.setValueByControlName(self.cmbRowDir.name,self.cmbRowDir.text);
	

end;</source>
    </JadeMethod>
