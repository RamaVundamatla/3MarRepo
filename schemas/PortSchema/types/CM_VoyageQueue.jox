    <JadeMethod name="addQueueEntry" id="ddffc099-b048-4c49-9d77-c8afb13ba2e7">
        <updating/>
        <source>addQueueEntry(entry : CM_RTQueueEntry input) updating;
//Override here if there is a problem.
vars
begin
	//----------------
	//Call super method (does all the work)
	//----------------
	inheritMethod(entry);

	if entry.myJob = null then
		return;
	endif;
	
	if not entry.myJob.isKindOf(CM_VoyageJob) then
		if entry.myJob.isKindOf(CM_YardInternalJob) and entry.myJob.CM_YardInternalJob.type = Door_Turnaround then
			return;
		endif;
		
		if entry.myJob.isRoadJob then
			return;
		endif;
		
		//23 Jun 2021	NDL	TFS 51231
		if entry.isLoadBargeMoveToInterchange then
			return;
		endif;
		
		// Direct release moves to a voyage will need to be added to the voyage queue, 
		// but entry may be linked to a Rail/Road Job
		// TFS 42863 jlgzm1 06/08/2019
		if entry.myWorkListEntry &lt;&gt; null and
		   entry.myWorkListEntry.getDRLinkedVoyageJob() &lt;&gt; null then
			return;
		endif;	
		
		//----------------
		//Only voyage jobs need apply here!
		//----------------
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_CANNOT_SHIFT_ENTRY, self.id.trimRight, "Enry Job is NOT a Voyage Job", null, null);
		return;		
	endif;
end;</source>
        <Parameter name="entry" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
