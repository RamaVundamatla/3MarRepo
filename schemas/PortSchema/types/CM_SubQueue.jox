    <JadeMethod name="validateUpdate" id="bb469a55-db0b-42d3-8eab-debae4c0230e">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	realSelf : CM_SubQueue;
begin
	inheritMethod(_passport);

	realSelf:=self.pxyGetRealObject;
	// DVB changed 11/08/06
	//self will be a proxy get the real object
	//epr par 21699 subqueue can not have its parent be its self.
	if realSelf &lt;&gt; null and self.myParentQueue = realSelf then
		app.raiseCMException(Queues_parent_queue_self,null,null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
