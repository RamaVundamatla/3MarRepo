    <JadeMethod name="addSingleCalendarDate" id="5180251f-a572-486d-a56d-f66678c286dd">
        <source>addSingleCalendarDate(_date : Date; _description : String; _calendar : CM_Calendar) : CM_CalendarDate;
// CCMS 1295 free storage days - add individual holidays
vars

	calendarDateProxy : CM_CalendarDate;
	calendarDate	: CM_CalendarDate;
	year : Integer;
	nullTime	: Time;
	calendarYear : CM_CalendarYear;
	calendarYearProxy : CM_CalendarYear;

begin
	if not _date.isValid or
	   _description = null then
		return null;
	endif;
	
	create calendarDateProxy transient;
	
	year := _date.year;
	calendarYear := _calendar.allCalendarYears.getAtKey(year);
	if calendarYear = null then
	
		// have to create a new calendar year first...
		create calendarYearProxy transient;
		calendarYearProxy.setProxy( year, _calendar);
	
		app.myTrxCA.trxCreateCalendarYear(calendarYearProxy, calendarYear, app.myPassport, false);
		delete calendarYearProxy;
		
	endif;
	
	// set up the calendar and calendar year on the calendar date transient.
	calendarDateProxy.setProxy(	_date,	//_date : Date;
								_description,	//_description : String;
								_calendar,	//_myCalendar : CM_Calendar;
								calendarYear,	//_myCalendarYear : CM_CalendarYear
								0	//_dataSource : Integer
								);
	nullTime := "00:00:00".Time;
	calendarDateProxy.setStartEndTime( nullTime, nullTime );
	
	app.myTrxCA.trxCreateCalendarDate(calendarDateProxy, calendarDate, app.myPassport);
	return calendarDate;

epilog

	delete calendarDateProxy;

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_calendar" type="CM_Calendar"/>
        <ReturnType type="CM_CalendarDate"/>
    </JadeMethod>
    <JadeMethod name="addSourceLocation" id="1f722d8c-e3df-4768-887f-f4eb40dbc166">
        <source>addSourceLocation( _codeGroup : CM_CodeGroup; _code : String; _description : String; _numSubs : Integer; _numSubSubs :Integer ):CM_SourceLocation;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2013	cnwndl1	Initial creation		Par 31770

*/

vars

	proxy	: CM_SourceLocation;
	sourceLocation : CM_SourceLocation;
	index : Integer;
	subCode : String;
	subDesc : String;

begin

	create proxy transient;
	proxy.setForProxy(	_code,	//_code : String;
						_description,	//_description : String;
						false,	//_isFSC : Boolean;
						app.mayBe,	//_notAvailableForEntry :Boolean;
						_codeGroup	//pCodeGroup : CM_CodeGroup
						);
										
	app.myTrxCA.trxCreateSourceLocation(proxy, sourceLocation, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		self.assertTrueMsg( false, app.myPassport.getErrorsAndWarningsAsString );
		return null;
	endif;
	
	foreach index in 1 to _numSubs do
		subCode := _code[1:3] &amp; index.padLeadingWith("0",3);
		subDesc := _description &amp; index.padLeadingWith("0",3);
		if self.addSourceSubLocation( 	sourceLocation,	//_mySourceLocation : CM_SourceLocation;
										subCode,	//_code : String;
										subDesc,	//_description : String;
										_numSubSubs	//_numSubSubs :Integer
										) = null then
			return null;	// had an error.
		endif;

	endforeach;
	
	return sourceLocation;

epilog

	delete proxy;

end;</source>
        <Parameter name="_codeGroup" type="CM_CodeGroup"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_numSubs" type="Integer"/>
        <Parameter name="_numSubSubs" type="Integer"/>
        <ReturnType type="CM_SourceLocation"/>
    </JadeMethod>
    <JadeMethod name="addSourceSubLocation" id="cc9673f7-9101-48ff-95e0-685fe29fd16a">
        <source>addSourceSubLocation( _mySourceLocation : CM_SourceLocation; _code : String; _description : String; _numSubSubs :Integer ):CM_SourceSubLocation;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2013	cnwndl1	Initial creation		Par 31770

*/

vars

	proxy	: CM_SourceSubLocation;
	sourceSubLocation : CM_SourceSubLocation;
	index : Integer;
	subSubCode : String;
	subSubDesc : String;
		
begin

	create proxy transient;
	proxy.setForProxy(	_code,	//_code : String;
						_description,	//_description : String;
						false,	//_isFSC : Boolean;
						app.mayBe,	//_notAvailableForEntry :Boolean;
						_mySourceLocation	//_sourceSubLocn: CM_SourceSubLocation
						);
										
	app.myTrxCA.trxCreateSourceSubLocation(proxy, sourceSubLocation, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		self.assertTrueMsg( false, app.myPassport.getErrorsAndWarningsAsString );
		return null;
	endif;
	
	foreach index in 1 to _numSubSubs do
		subSubCode :=  index.padLeadingWith("0",3) &amp; _code[1:3];
		subSubDesc :=  index.padLeadingWith("0",3) &amp; _description;
		if self.addSourceSubSubLocation( 	sourceSubLocation,	//_mySourceSubLocation : CM_SourceSubLocation;
											subSubCode,	//_code : String;
											subSubDesc	//_description : String
											) = null then
			return null;	// had an error.
		endif;

	endforeach;
	
	return sourceSubLocation;

epilog

	delete proxy;

end;</source>
        <Parameter name="_mySourceLocation" type="CM_SourceLocation"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_numSubSubs" type="Integer"/>
        <ReturnType type="CM_SourceSubLocation"/>
    </JadeMethod>
