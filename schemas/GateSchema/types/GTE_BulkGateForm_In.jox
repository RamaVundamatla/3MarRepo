epilog

end;</source>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doFind" id="0a2f9c61-f576-40d7-82ce-2f846317e255">
        <updating/>
        <source>doFind() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwns1	Initial creation

*/

vars
	vvr 	: CM_VehicleVisitRecord;
	myItem 	: CM_TrackedItem;
	entity 	: CMGTE_Entity;
	realVVR : CM_VehicleVisitRecord;
begin
	if self.detailsChangedVehicle then
		if (self.txtDriverCode.text &lt;&gt; null 
			or self.txtRegno.text &lt;&gt; null 
			or self.cmbCarrier.listIndex &gt; 0 
			or self.cmbGateLanes.listIndex &gt; 0 
			or self.txtState.text &lt;&gt; null) then 
			if app.msgBox(app.getErrorString(Have_enter_data_will_be_lost) &amp; Cr 
						&amp; app.getErrorString(DoYouWantToContinue), 
						  app.getErrorString(Problem), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
				return;
			endif;
		endif;
	endif;
		
	self.doQuery(vvr);
		
	realVVR := self.myBulkGateAgent.myRealVVR;
	
	if realVVR &lt;&gt; null and realVVR.isBulkGateVVR and  realVVR.isIncomplete then
		foreach entity in realVVR.allGateEntities do
			if entity.isKindOf(CMGTE_Receival) and entity.CMGTE_Receival.myTrackedItem &lt;&gt; null then
				myItem := entity.CMGTE_Receival.myTrackedItem;
			elseif entity.isKindOf(CMGTE_Release) and entity.CMGTE_Release.myTrackedItem &lt;&gt; null then
				myItem := entity.CMGTE_Release.myTrackedItem;
			endif;
		endforeach;
	endif;
	
	if myItem &lt;&gt; null then
		self.gateAndLaneSetFromVVR := true;
		self.enableFieldsAfterQuery(false);		
		//self.txtWeightIN.enabled := self.allowManualWeight;
		//19 Apr 2017	NDL	TFS 4126
		if  self.myWeightInterfaceController &lt;&gt; null and self.myWeightInterfaceController.hasValidConnection then
			self.txtWeightIN.setFieldsEnabled( self.allowManualWeight );	
		else
			//self.txtWeightIN.setFieldsEnabled( app.getMyUser.canDo(self.myTerminal,PmGteBulkInMaint) );
			self.txtWeightIN.setFieldsEnabled( self.allowManualWeight ); // After confirmation from Salman
		endif;
		self.btnSave.enabled := self.allowManualWeight;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPreSaveValidation" id="c942876c-f77c-4ff3-a1dc-584437054e4b">
        <updating/>
        <source>doPreSaveValidation( _rego : String output):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2016	cnwndl1	Initial creation	TFS 2867
// 08/06/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN

*/

vars

	printBuckSlip : Boolean;
	realVVR : CM_VehicleVisitRecord;
	edition : Integer;
	invalid : Boolean;

begin

	if self.txtRegno.visible then
		if self.txtRegno.text.isBlank() then
			app.raiseCMException(Input_required_field_regNum, "RegNo", null);
			self.txtRegno.setFocus;
			return false;
		endif;
		_rego := self.txtRegno.text;
	else
		if self.cmbRegNo.text.isBlank() then
			app.raiseCMException(Input_required_field_regNum, "RegNo", null);
			self.cmbRegNo.setFocus;
			return false;
		endif;
		_rego := self.cmbRegNo.text;
	endif;
	
	if self.cmbCarrier.text.isBlank() then
		app.raiseCMException(Input_required_field_carCode, "Carrier", null);
		self.cmbCarrier.setFocus;
		return false;
	endif;
	
	//Start 08/06/2022 navhl20 TFS 53430
	if isSubCarrierMandatory and self.cmbSubCarrier.text.isBlank() then
		app.raiseCMException(Input_Require_Subcarrier_Field, "SubCarrier", null);
		self.cmbCarrier.setFocus;
		return false;
	endif;
	//End 08/06/2022 navhl20 TFS 53430
	
	if self.txtWeightIN.getRawValue() = null then
		app.raiseCMException(Input_required_field_weight, "Weight Null", null);
		self.txtWeightIN.setFocus;
		return false;
	endif;
	
	
	if 	self.txtWeightIN.getConvertedValue() = 0 then	
		app.raiseCMException(Total_weight_should_not_zero, "Weight Zero", null);
		self.txtWeightIN.setFocus;
		return false;
	endif;
	
	if self.myBulkGateAgent.cargoDirection &lt;&gt; Inward and  self.myBulkGateAgent.cargoDirection &lt;&gt; Outward then 
		app.raiseCMException(Err_Release_Receival_Not_Set, "Release_Receival_Not_Set", null);
		return false;
	endif;
	
	printBuckSlip := self.myTerminal.getConfig(PrintBuckslip).Boolean;
	if printBuckSlip then
		if self.cmbPrinter.listIndex &lt; 1 then	
			app.raiseCMException(Input_required_field_printer,null,null); 
			return false;
		endif;
	endif;
	
	on Exception do app.handleDeletedObject(exception,realVVR,invalid);
	realVVR := self.myBulkGateAgent.myRealVVR;
	
	if realVVR &lt;&gt; null then
		edition := realVVR.edition;
		if invalid then	
			self.clearForm();
			self.myBulkGateAgent.myPxyGTEEntity := null;
			app.raiseCMException(Vehicle_visit_invalid,null,null);

			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_rego" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintBuckSlip" id="be1bc5b5-7fe3-403d-b067-80d2b072de1b">
        <source>doPrintBuckSlip(realVVR :CM_VehicleVisitRecord input) protected;
/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars

	printCopies	 : Integer;
	printConfirm : GTE_PrintConfirmationForm;	
	printerName  : String;
	
begin
	
	printCopies := 1;
	printerName := self.cmbPrinter.text;
		
	if self.myTerminal.getConfig(DisplayPrintConfirmation).Boolean then
		create printConfirm transient;
		printConfirm.setPrintDetails(printCopies, printerName, self);
		printCopies := printConfirm.showModal;
		printerName := self.cmbPrinter.text; // may have been updated within GTE_PrintConfirmationForm 
	endif;
	
	if printCopies &gt; 0 then
		realVVR.myRoadJob.printDriverDetails(printCopies, self.myTerminal.getConfig(PrintPreview).Boolean, null, printerName);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="realVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="eb46fe5f-cb0a-4a30-ab07-6ca71dd54435">
        <updating/>
        <source>doQuery(_vvr :CM_VehicleVisitRecord) updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	24 Feb 2021	NDL	TFS 50849 - Remove deug messages relative to Par 36079
// ---------------------------------------------------------------------------

vars
	tmpStr 		: String;
	tmpVVR		: CM_VehicleVisitRecord;
	flexyForm 	: GTE_FlexiGateForm;
	tmpVisitNo 	: String;
	realVVR : CM_VehicleVisitRecord;
begin
	tmpStr := self.txtVisitNumber.text.trimBlanks();
	
//	app.writeLog(method.qualifiedName &amp; " Started with self.txtVisitNumber.text of '" &amp; self.txtVisitNumber.text &amp; "'", LogINFO);	// PAR #36079
	
	if tmpStr &lt;&gt; null then
		if _vvr &lt;&gt; null and _vvr.visitNumber =tmpStr then  
			tmpVVR :=_vvr;
		else
			tmpVVR := self.myTerminal.getVehicleVisitRecordByTran(tmpStr);
		endif;
		
		if tmpVVR &lt;&gt; null and tmpVVR.visitNumber &lt;&gt; tmpStr then								
			tmpVVR := null;																	
			app.writeLog(method.qualifiedName &amp; " no VVR found direct for " &amp; tmpStr, LogINFO);
		endif;																				
		
		
		if tmpVVR &lt;&gt; null then
			if not tmpVVR.isIncomplete then
				app.raiseCMException1(Vehicle_visit_complete, tmpVVR.visitNumber,"Completed Visit", null);	
				return;
			endif;
		
			if not tmpVVR.isBulkGateVVR and tmpVVR.visitType &lt;&gt; CM_VehicleVisitRecord.VisitType_SecurityGate then
				flexyForm := app.loadForm(GTE_FlexiGateForm, GTE_Assistant, false, false, false,  self.myTerminal, null).GTE_FlexiGateForm;		
				if flexyForm &lt;&gt; null then
					tmpVisitNo := self.txtVisitNumber.text;
					self.clearForm();
					flexyForm.show;
					flexyForm.txtVisitNumber.text := tmpVisitNo;
					flexyForm.doQuery(tmpVVR);
				else	
					app.raiseCMException1(Vehicle_Visit__Not_Bulk_only,self.caption,"wrongGate", null);	 
				endif;
				return;
			endif;	
		else
			if self.myTerminal.getConfig(SiteHasSecurityGate).Boolean then	
				tmpVVR := self.myTerminal.getVehicleVisitForBatNumber(tmpStr);					
				if tmpVVR &lt;&gt; null then																
					app.writeLog(method.qualifiedName &amp; " VVR found via bat check for " &amp; tmpStr, LogINFO);	
					if tmpVVR.getSecurityGateArrivedDetail = null then								
						app.writeLog(method.qualifiedName &amp; " VVR has no security gate arrival", LogINFO);	
					else																			
						app.writeLog(method.qualifiedName &amp; " VVR has a security gate arrival", LogINFO);		
					endif;																			
				endif;																			
			endif;																				
			
			if tmpVVR = null then
				app.msgBox(app.getErrorString(No_Record_found) &amp; tmpStr,app.getErrorString(Error), 0);
				self.clearForm();
				return;
			endif;
		endif;
				
		self.setMyCurrentVVR(tmpVVR);
	
		realVVR := self.myBulkGateAgent.myRealVVR;
		
		if not realVVR.isUpdatable or not realVVR.isCancelled then	
			self.enableFieldsAfterQuery(false);
			self.allowAddToTruck(tmpVVR);	
			if realVVR.visitType = CM_VehicleVisitRecord.VisitType_SecurityGate then
				self.enableVisitFields(true);	
			endif;
		endif;
		
		self.cmbRFID.listIndex := -1;	
		if realVVR.myRoadJob &lt;&gt; null then
			self.btnPrint.visible := true;
			self.btnPrint.enabled := true;
			if realVVR.myRoadJob.getMyRFIDTag &lt;&gt; null and self.cmbRFID.visible then
				self.myAssistant.comboBoxRFIDTag( self.cmbRFID, self.myTerminal, realVVR.myRoadJob.myRFIDTag );
			endif;
		else
			self.btnPrint.visible := false;
		endif;
		
		// build the gate combo so it defaults to the default gate
		if realVVR.myGateIn = null then		
			self.doBuildGateCombo();							
		endif;													
		
	else
		app.msgBox(app.getErrorString(Must_enter_trans_num_search) &amp; tmpStr, 'Error', 0);
		self.clearForm();
	endif;
	
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="64c2d332-9242-491e-af16-8d16d9458741">
        <updating/>
        <source>doQueryUnload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/
constants
	MaxWaitTime = 5000;
vars
	endWaitTime : Decimal[20];
	maxWaitTime : Integer;
begin
    if self.myWeightInterfaceController &lt;&gt; null then
		// Need to delay the actual form close and weight interface controller delete until all pending
		// serial port communications are complete
		
		self.myWeightInterfaceController.stopListening;
		self.visible := false;
		endWaitTime := app.relativeMachineTime() + maxWaitTime;
		
		while not self.myWeightInterfaceController.isOkToDelete() do
			app.writeLog(method.qualifiedName &amp; " waiting for serial port operations to complete", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			app.doWindowEvents(1000);
			if app.relativeMachineTime() &gt; endWaitTime then
				app.writeLog(method.qualifiedName &amp; " maximum wait time exceeded, exiting", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				break;
			endif;
		endwhile;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="b8880780-6893-4522-a270-97777d9c79ae">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/05/2017	cnwdap1		TFS 4111 PKT Raise error for cash debtor with outstanding balance
// ---------------------------------------------------------------------------

vars
	result				: Integer;
	pxyVVR				: CM_VehicleVisitRecord; 
	realVVR				: CM_VehicleVisitRecord;
	printBuckSlip		: Boolean;	
	gate				: CM_Gate;	
	defaultPrinterName	: String;
	newScaleWeight		: Decimal[16,4];		// in kilos
	rawScaleWeight		: Decimal[16,4];		// in kilos
	realTruck			: CM_Vehicle;
	pxyVehicle			: CM_Vehicle;
	rego				: String;
	state				: String;
	weighBridge			: CM_WeighBridgeObj;
	allProformaLines	: ObjectSet;			// TFS 4111
	vbsProcess			: CM_VBSProcess;		// ### TFS 58164 30May2023 NAVPW1
	
begin	
	
	//Validate that we have all the data we need.
	if not self.doPreSaveValidation( rego ) then
		return false;
	endif;
	
	defaultPrinterName := app.printer.getPrinterName;
	printBuckSlip := self.myTerminal.getConfig(PrintBuckslip).Boolean;
	
	//Get or create the Vehicle visit Record, and grab a proxy
	realVVR := self.myBulkGateAgent.myRealVVR;
	if realVVR &lt;&gt; null then
		pxyVVR := app.createUpdateProxy(realVVR).CM_VehicleVisitRecord;
	else
		create pxyVVR transient;
		pxyVVR.setIsUpdatable(true); // jlier1 TFS 59732 6/9/23  
	endif;
	
	self.allVehicleBookingTimeslots.copyNoDuplicates(pxyVVR.allVehicleBookingSlots, false);	// ### TFS 58164 29May2023 NAVPW1
	
	//set up the proxy with the values from the form
	self.setProxyVVR(pxyVVR);
	if 	self.myBulkGateAgent.myPxyGTEEntity &lt;&gt; null then		
		self.myBulkGateAgent.myPxyGTEEntity.setMyVehicleVisit(pxyVVR);
	else
		self.myBulkGateAgent.myPxyGTEEntity :=  pxyVVR.allGateEntities.first();
	endif;
	//get the sacle weight
	newScaleWeight := self.txtWeightIN.getConvertedValue();
	
	self.myBulkGateAgent.doSetGTEWeights(pxyVVR);
	
	realTruck :=  self.myTerminal.vehicles.getAtKey(rego,state);
	if realTruck = null then
		create pxyVehicle transient;
		state := self.txtState.text;
		pxyVehicle.setProxy( rego, null, null, 0, self.cmbCarrier.listObject.CM_Carrier, state,  false, self.myTerminal);

		while true do
			app.myTrxCA.trxCreateVehicle( pxyVehicle, realTruck, app.myPassport );
	
			if app.myPassport.trxCompletedOK then
				break;
			else												
				result := app.showErrorWarningDialog(app.getErrorString(Create_truck), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged     := true;
						continue;
				endif;
				return false;
			endif;
			break;
		
		endwhile;
		delete pxyVehicle;
	endif;
	
	weighBridge := self.myBulkGateAgent.myWeighBridge;
	
	rawScaleWeight := self.myBulkGateAgent.retrievedWeight;
	
	// TFS 4111 have to check cash before the main trx and not in that trx because the pro forma	// TFS 4111
	// does it's calc and aborts																	// TFS 4111
	// check terminal is cash enabled																// TFS 4111
	create allProformaLines transient;																// TFS 4111
	if not self.doCashOnlyValidation(pxyVVR, allProformaLines) then									// TFS 4111
		return false;																				// TFS 4111
	endif;																							// TFS 4111
	
	
	//pass in te data to do the entire Gate in.
	// checks the Pro Forma stuff, and all std Gate validation, gates truck in creates WLE for the move
	// ans the specialised VVR record for Bulk Weigh In.
	while true do
		app.myTrxCA.trxProcessBulkGateIn(pxyVVR, realVVR, newScaleWeight, rawScaleWeight,  weighBridge, app.myPassport);

        if app.myPassport.trxCompletedOK then
			self.allVehicleBookingTimeslots.clear(); // ### TFS 58164 29May2023 NAVPW1
            break;
        else
			// Strip out the warnings we know that we don't want to see again.									
		//	app.myPassport.removeWarnings(arrAllWarnings);													
			if app.myPassport.noErrors() and app.myPassport.noWarnings then  // Can happen with attachments	
				app.myPassport.warningsAcknowledged     := true;											
				continue;																					
			endif;																							

			result := app.showErrorWarningDialog(app.getErrorString(Bulk_gate_in), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged     := true;
					continue;
			endif;
			return false;
        endif;
        break;
	
	endwhile;

	//must be deleted before return and not in epilog to accomodate cancel button
	delete pxyVVR;

	if not self.applyRFIDtoJob( realVVR.myRoadJob ) then
		return false;
	endif;	
	
	// the job has been saved - we may need to show the rfid tag form
	self.myAssistant.GTE_Assistant.showRFIDTagFormForRoadEntry (realVVR.myRoadJob);
	
	gate := self.myBulkGateAgent.myGate;	
	
	self.clearForm();
	self.doChangeGate(gate);						
	
	if self.myTerminal.isVehicleBookingEnabled then
		vbsProcess := self.myVBSProcess;	// ### TFS 58164 30May2023 NAVPW1
		//if realVVR &lt;&gt; null and realVVR.myVehicleBookingTimeslot = null then
		//Should show form if the vbsProcess is either Standard or null
		if vbsProcess = null or (vbsProcess &lt;&gt; null and vbsProcess.isVbsStandard) and realVVR &lt;&gt; null and realVVR.myVehicleBookingTimeslot = null then		// ### TFS 58164 30May2023 NAVPW1
			if not self.myTerminal.hideTheVbsAssocForm( realVVR ) then	
				self.myAssistant.showVehicleBookingAssociation( self, realVVR, null, null );
			endif;
		endif;
	endif;
	
	if printBuckSlip then
		self.doPrintBuckSlip(realVVR);
	endif;
	
	self.detailsChangedVehicle := false;	
	if realVVR &lt;&gt; null then																					
		realVVR.causeEvent(realVVR.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, realVVR);	
	endif;																									
	// Make way for the next VVR to be created
	self.myBulkGateAgent.myRealVVR := null;
	
	if self.myBulkGateAgent.myVehicleBookingTimeslot &lt;&gt; null then       
		self.myBulkGateAgent.myVehicleBookingTimeslot := null;
	endif;
	
	return true;
		
epilog

	delete pxyVehicle;
		
	app.printer.setPrinter( defaultPrinterName );					
	app.myPassport.clearErrorsToIgnore(); 
		
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnload" id="06f02867-7876-4e13-b365-5816d651d55d">
        <updating/>
        <source>doUnload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars

begin
    self.myBulkGateAgent.deletePxyGTEEntity();
		
	if self.myWeightInterfaceController &lt;&gt; null and not self.myWeightInterfaceController.isOkToDelete then
		app.writeLog(method.qualifiedName &amp; " Serial port has not closed within 5 second, Modal dialog shown", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		app.doWindowEvents(0);
		//app.msgBox(self.caption &amp; CrLf &amp; "closing Serial port connection, click OK to continue",app.getErrorString(Error_warning_messages),0);
	endif;
		
	delete self.myWeightInterfaceController;
		
	delete	self.myBulkGateAgent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doUpdateChangeStatus" id="5ea9ae34-73a0-4bd2-bab5-cce5c96dc8f7">
        <updating/>
        <source>doUpdateChangeStatus() updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
	if self.myBulkGateAgent.myRealVVR = null then
		return;
	endif;
	while true do
		app.myTrxUA.trxUpdateInOutGateStatus(self.myBulkGateAgent.myRealVVR,CMGTE_Entity.Status_Cancelled, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doVehicleVisitCancel" id="693f427f-5445-4b91-b3e1-df87eb2581e1">
        <updating/>
        <source>doVehicleVisitCancel(_reason :String) updating, protected;

/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
*/

vars
	theReturn	: Integer;
begin

	while true do
		app.myTrxUA.trxUpdateVVRCancel(self.myBulkGateAgent.myRealVVR, _reason, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
        else
			theReturn := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged     := true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);       // copies errors to this form and shows in err/warnings window
			return;
        endif;
        break;
	endwhile;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="doVvrAssocToVbts" id="80a88dd7-d2cb-4a1c-8b29-d8391dd03585">
        <updating/>
        <source>doVvrAssocToVbts(_vbsts : CM_VehicleBookingTimeSlot) protected, updating;
/*

Purpose:			Associates the vehicle booking timeslot to the vehicle visit dependant on the Vbs process

Parameters:			_vbsts	CM_VehicleBookingTimeSlot	The vehicle booking time slot to associate to the vehicle visit

Return Value:		NONE

Date		Who		Reason
11 May 2023	navpw1	Initial creation TFS: 54049 (55841)
29 May 2023	navpw1	TFS: 58164 - Removed code and made method function similar to Flexi Gate Form

*/

vars
	vbsProcess	: CM_VBSProcess;
	
begin
	vbsProcess := self.myVBSProcess;
	
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
		self.doVvrAssocToVbtsSlotValidation(_vbsts);
		
	else
		self.doVvrAssocToVbtsStandard(_vbsts);
		
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_vbsts" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="doVvrAssocToVbtsSlotValidation" id="3ae64ff2-53e9-4fec-93bc-6b43f5239064">
        <source>doVvrAssocToVbtsSlotValidation(_vbsts : CM_VehicleBookingTimeSlot) protected;
/*

Purpose:			Associates the vehicle booking timeslot to the vehicle visit for the vbs slot type validation process

Parameters:			_vbsts		CM_VehicleBookingTimeSlot	The vehicle booking time slot to associate to the vehicle visit

Return Value:		NONE

Date		Who		Reason
11 May 2023	navpw1	Initial creation TFS: 54049 (55841)
29 May 2023	navpw1	TFS: 58164 - Removed code and made method function similar to Flexi Gate Form

*/

begin
	if _vbsts = null or _vbsts.myVehicleVisitRecord &lt;&gt; null then
		return;
	endif;
	
	self.allVehicleBookingTimeslots.addNoDuplicates(_vbsts, false);

end;</source>
        <access>protected</access>
        <Parameter name="_vbsts" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="doVvrAssocToVbtsStandard" id="f774add6-dd0d-4249-8617-b4f39e55a44b">
        <source>doVvrAssocToVbtsStandard( _vbsts : CM_VehicleBookingTimeSlot ) protected;
/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021	navadp1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

vars

	proxy 		: CM_VehicleBookingTimeSlot;
	theReturn 	: Integer;
	loadState 	: Boolean;
	strArray 	: StringArray;
	deliveryIds, pickupIds 	: StringArray;		// TFS 51248
	realVVR : CM_VehicleVisitRecord;
begin

	if _vbsts = null or _vbsts.myVehicleVisitRecord &lt;&gt; null then
		return;
	endif;
	
	realVVR := self.myBulkGateAgent.myRealVVR;
	if realVVR = null or realVVR.myVehicleBookingTimeslot &lt;&gt; null then
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	proxy := _vbsts.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
	app.cmsEndLoad(loadState);
	
	create strArray transient;
	create deliveryIds transient;										// TFS 51248
	create pickupIds transient;											// TFS 51248
	//_vbsts.getTiIdsFromBookedItemsOrVvr(strArray);					// TFS 51248
	_vbsts.getTiIdsFromBookedItemsOrVvr(deliveryIds, pickupIds);		// TFS 51248
	deliveryIds.copy(strArray);											// TFS 51248
	pickupIds.copy(strArray);											// TFS 51248
	
	proxy.setProxy(	_vbsts.bookingTSstart,	
					_vbsts.bookingTSend,	
					_vbsts.myVehicleBookingTerminal,
					_vbsts.myCarrier,
					null,					//_mySubCarrier : CM_Carrier;
					_vbsts.myDriver,	
					_vbsts.myVehicle,	
					_vbsts.remarks,	
					_vbsts.includesDelivery,
					_vbsts.includesPickUp,
					strArray,	
					realVVR,	
					_vbsts.myVBTimeSlotType,	
					_vbsts.id,	
					_vbsts.allBookingRefs,	
					_vbsts.allBulkReleases,
					null,					//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
					null,					//_preGateInCheck : Boolean;
					null,					//_preGateOutChck : Boolean;
					null,					//_kioskCheck : Boolean;
					null,					//_externalReference : String
					null					//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
					);
					
	while true do
		//app.myTrxUA.trxUpdateVehicleBooking(proxy, app.myPassport);							// TFS 51248
		app.myTrxUA.trxUpdateVehicleBooking(proxy, deliveryIds, pickupIds, app.myPassport);		// TFS 51248
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog

	delete strArray;
	delete deliveryIds;			// TFS 51248
	delete pickupIds;			// TFS 51248
	delete proxy;
	
	app.cmsEndLoad(loadState);

end;</source>
        <access>protected</access>
        <Parameter name="_vbsts" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="enableFields" id="b906c987-d828-481f-9b6d-7b65ef4a9ed5">
        <source>enableFields(_enabled : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//2/10/2017  jlgns1 TFS 6865 PKT - Weighbridge Connection Issue
//08/06/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
// ---------------------------------------------------------------------------

vars
	enable : Boolean;

begin 
	enable := _enabled;
	
	
	if not app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint) then
		enable := false;
		self.enableFieldsAfterQuery(false);
	endif;
		
	// Main
	self.txtDriverCode.enabled 	:= enable;
	
	self.txtRegno.enabled 		:= enable;
	self.cmbRegNo.enabled		:= true;
	
	self.cmbDriver.enabled		:= true;
	
	self.cmbCarrier.enabled 	:= enable;
	self.cmbSubCarrier.enabled 	:= enable;		//08/06/2022 navhl20 TFS 53430
	
	self.txtState.enabled 		:= enable;
	self.cmbInterchange.enabled := enable;	
	
	if 	self.myBulkGateAgent.gateAndLaneSet 						//TFS 6865
	and self.myWeightInterfaceController &lt;&gt; null	 				//TFS 6865
	and self.myWeightInterfaceController.hasValidConnection then	//TFS 6865 
		self.cmbGateLanes.enabled 	:= false;
		self.cmbGate.enabled 		:= false;
	else
		self.cmbGateLanes.enabled 	:= enable;
		self.cmbGate.enabled 		:= enable;
	endif;
		
	if enable then
		self.setTxtPinToNullOrVbsId();
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableFieldsAfterQuery" id="45cb0078-6210-42a0-8781-b3506d15a76e">
        <source>enableFieldsAfterQuery(_enabled : Boolean) protected;

/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason

*/
vars
	control : Control;
	idx 	: Integer;
	enable 	: Boolean;
	
begin

	enable := _enabled and app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
	
	foreach idx in 1 to self.controlCount do
		control := self.controls(idx);
		if control.isKindOf(CMUI_Label) or 
		   control.isKindOf(CMUI_TextBox) or
		   control.isKindOf(CMUI_ComboBox) or
		   control.isKindOf(CMUI_OptionButton) or
		   control.isKindOf(CMUI_CheckBox) then
		   control.enabled 					:= enable;	
		endif;		
	endforeach;
		
	self.txtVisitNumber.enabled := true;
	self.cmbPrinter.enabled := app.myCurrentUserCan(self.myTerminal, PmGteCanPrintFlexiGate);
	
end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableVisitFields" id="35bd5036-647a-4f22-b6ab-bf0f63e5a120">
        <source>enableVisitFields(_enabled : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2017	cnwns1	Initial creation

*/

vars
	enable : Boolean;
begin
	enable := _enabled and app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);

	lblPIN.enabled := enable;
	txtPIN.enabled := enable;
	lblCargoType.enabled := enable;
	cmbCargoTypes.enabled := enable;
	lblInterchange.enabled := enable;
	cmbInterchange.enabled := enable;
	
end;
</source>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDeleteReason" id="e586bce1-10ab-46ac-bbe4-25915b270abb">
        <source>getDeleteReason( _extraInfo : String ) : String;

/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
*/

vars
	inputBox	: CMUI_InputBox;
	errorSet	: CM_ErrorSet;
	result 		: String;
begin
	app.mousePointer := MousePointer_Default;
	
	create inputBox transient;
	create errorSet transient;
	
	inputBox.init(	app.getErrorString( Cancellation ),app.getErrorString( Road_cancellati_reason) &amp; _extraInfo,
					'', 30, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
	
	inputBox.myTerminal := self.myTerminal;
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return '';
	endif;
	
	result := inputBox.txtInput.text.String;
	app.mousePointer := MousePointer_HourGlass;
	return result;
epilog

end;</source>
        <Parameter name="_extraInfo" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDriverId" id="7f050e01-97da-4cc7-b9d5-a423c6766a2b">
        <source>getDriverId();

/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/06/2024	jlizm1	TFS 63908 Allow duplicate driver names
*/
vars
	aDriver : CM_DriverDetails;
	
	currentDriver 		: CM_DriverDetails;
	currentDriverCode 	: String;
	driverSet 			: CM_DriverDetailsSet;
	
begin

	if self.txtDriverName.text.trimBlanks = null then
		self.txtDriverCode.enabled := true;
		self.lblDriverCode.enabled := true;
		self.cmbDriver.visible := false;
		self.cmbDriver.clear();
		self.txtDriverCode.visible := true;
		return;
	endif;

	create driverSet transient;
	if self.myTerminal.getConfig(AllowDupDriverNames).Boolean then	
		self.myTerminal.findDriversWithName(self.txtDriverName.text, driverSet);
		
		if not driverSet.isEmpty then
			if driverSet.size = 1 then
				aDriver := driverSet.first;
			else
				if self.cmbDriver.listObject &lt;&gt; null then
					currentDriver := self.cmbDriver.listObject.CM_DriverDetails;
				elseif self.txtDriverCode.text &lt;&gt; null then
					currentDriverCode := self.txtDriverCode.text;
				endif;
				
				self.txtDriverCode.text := null;
				self.txtDriverCode.visible := false;
				self.cmbDriver.visible := true;
				self.cmbDriver.listCollection(driverSet, false, ComboBox.DisplayCollection_Forward);
				
				if currentDriverCode &lt;&gt; null then
					foreach aDriver in driverSet do
						if aDriver.code.toUpper() = currentDriverCode.toUpper() then
							currentDriver  := aDriver;
							break;
						endif;
					endforeach;
				endif;
				
				if currentDriver &lt;&gt; null then
					self.cmbDriver.setIndexFromObject(currentDriver);
				endif;

				return;
			endif;
		endif;

	else
		aDriver := self.myTerminal.findDriver(self.txtDriverName.text);
	endif;
	
	self.cmbDriver.clear();
	self.cmbDriver.visible := false;
	self.txtDriverCode.visible := true;
	
	if aDriver = null and driverSet.isEmpty then
		self.txtDriverCode.enabled := true;
		self.lblDriverCode.enabled := true;
		return;
	endif;

	if aDriver &lt;&gt; null and self.txtDriverCode.text.toUpper() &lt;&gt; aDriver.code.toUpper() then
		self.txtDriverCode.text := aDriver.code;
		self.txtDriverCode.enabled := false;
		self.lblDriverCode.enabled := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getDriverName" id="1e32957e-82ae-4d78-945d-e17f703e4bad">
        <source>getDriverName();
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 13/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
// ---------------------------------------------------------------------------
vars
	aDriver : CM_DriverDetails;

begin

	if self.txtDriverCode.text.trimBlanks = null then
		self.lblDriverName.enabled := true;
		self.txtDriverName.enabled := true;
		return;
	endif;

	aDriver := self.myTerminal.findDriver(self.txtDriverCode.text);		

	if aDriver = null then
		self.lblDriverName.enabled := true;
		self.txtDriverName.enabled := true;
		return;
	endif;

	if self.txtDriverName.text.toUpper() &lt;&gt; aDriver.name.toUpper() then
		self.txtDriverName.text := aDriver.name;
		self.txtDriverName.enabled := false;
		self.lblDriverName.enabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getExtraPermissions" id="a72ba6b3-e2de-4dd2-bdb4-9e87e9a0e048">
        <source>getExtraPermissions(permArray: IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2017	jlgns1	Initial creation

*/

vars

begin
	inheritMethod(permArray);
	permArray.add(PmGteGateCanCancelFlexiJob);

epilog

end;</source>
        <Parameter name="permArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMatchingObjectToSelect" id="6e906239-b442-44a8-b48a-ee4ff2af6958">
        <updating/>
        <source>getMatchingObjectToSelect(_pCode : String; _pickerShown : Boolean output; _isCompleted : Boolean output)  : Object protected, updating;
// -----------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1	

// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
/* Changes

Date		Name	TFS#		Description
============================================================================
 22/05/2018	jlgdap1	TFS 38501 	PEL1 Work Order Changes - new parameter for pickerWindowForObject
12/04/2019	jlgka1	TFS 44368	Add isCompleted flag to identify what error message 
								to display when doing a road gate.
29/05/2023	navpw1	TFS: 58163	Fixed searching by External Reference for Vbs Slots
============================================================================*/

vars
	bulkRelease					: CM_BulkRelease;
	bookingRef					: CM_BookingRef;
	bookingRefItem  			: CM_BookingRefItem;
	reserveDetail				: CM_ReserveDetail;
	tmpTI						: CM_TrackedItem;
	reserve						: CM_ReserveDetail;
	objArr						: ObjectArray;
	iter						: Iterator;
	compareCode					: String;
	pickerReturnValue 			: Integer;	
	selectedObject 				: Object;	
	allowMultiSelect			: Boolean;
	tis							: CM_TIArray;
	entity						: CMGTE_Entity;
	splitRollEvt				: CMEVT_SplitRollBooking;
	vbt							: CM_VehicleBookingTerminal;
	vbsts						: CM_VehicleBookingTimeSlot;
	skipOver 					: Boolean;		
	realVVR 					: CM_VehicleVisitRecord;
	allowBookingWithoutPrenote 	: Boolean;
begin
	create objArr transient;
	create tis transient;
	
	compareCode := _pCode.toUpper();
	
	//This feature is not needed in PKT terminal so I wont allow it
	allowBookingWithoutPrenote := false;
	
	pickerReturnValue := self.myAssistant.getBulkRelease(compareCode, bulkRelease, _isCompleted); // jlgka1 TFS 44368	
	if pickerReturnValue = MsgBox_Return_Cancel then
		//user cancelled, bail
		return null;
	endif;
	realVVR := self.myBulkGateAgent.myRealVVR;
	
	if realVVR &lt;&gt; null then
		foreach entity in realVVR.allGateEntities do
			if entity.isKindOf(CMGTE_Receival) and
			   entity.CMGTE_Receival.myTrackedItem &lt;&gt; null then
				tis.add(entity.CMGTE_Receival.myTrackedItem);
			endif;
		endforeach;
	endif;

	// Booking ref items and associated release------------------
	iter := self.myTerminal.allBookingRefsByRef.createIterator;
	self.myTerminal.allBookingRefsByRef.startKeyGeq(_pCode, iter);
	while iter.next(bookingRef) do
		if bookingRef.bookingReference &lt;&gt; _pCode then
			break;
		endif;
		
		//If the booking has been rolled, then raise a message saying what it has been rolled to..
		foreach splitRollEvt in bookingRef.allSplitRollEventsAsOld do
			if splitRollEvt.isKindOf(CMEVT_RollBooking) then
				if bookingRef.bookingReference &lt;&gt; splitRollEvt.myNewBookingReference.bookingReference then	
					app.msgBox(app.getErrorString2(Bookin_been_rolled, bookingRef.bookingReference, splitRollEvt.myNewBookingReference.bookingReference), app.getErrorString(Rolled_booking), MsgBox_OK_Only);
					_pickerShown := true;	//Set this to true so doesn't show another error once returned..
					return null;
				endif;
			endif;
		endforeach;
		
		foreach bookingRefItem in bookingRef.allBookingRefItems discreteLock do
			//cnwjo3 par 23674. In the weird situation they are releasing something
			//but not expecting something back.  Possibly releasing 10 ISO Group ABC
			//expecting 5 2100 and 5 2200s dont place this booking item in Picker
			if bookingRefItem.quantity &lt; 1 and bookingRefItem.weight = 0 then
				continue;
			endif;
			
			if allowBookingWithoutPrenote then
				objArr.add(bookingRefItem);
				if bookingRefItem.myReserveDetail &lt;&gt; null then
					reserveDetail := bookingRefItem.myReserveDetail;
					if reserveDetail.hasOutstanding and reserveDetail.myReserveHeader.type = BR_TYPE_ROAD then
						objArr.addExclusive(reserveDetail);	
					endif;
					if bulkRelease = reserveDetail.myReserveHeader then
						bulkRelease := null;
					endif;
				endif;
			endif;

			if bookingRefItem.allTIs.size() &gt; 0 then		
				foreach tmpTI in bookingRefItem.allTIs do	
					if tmpTI.isPreNote() and not tmpTI.isChild then		
						if not tis.includes(tmpTI) then
							objArr.addExclusive(tmpTI);	
							allowMultiSelect := true;
						endif;
					endif;									
				endforeach;									
			endif;
		endforeach;
	endwhile;
	
	/// Bulk Release----------------------
	if bulkRelease &lt;&gt; null and bulkRelease.code = compareCode and bulkRelease.type = BR_TYPE_ROAD then
		if bulkRelease.releaseByType then
			foreach reserve in bulkRelease.allReserveDetails discreteLock do
				objArr.addExclusive(reserve);	
			endforeach;
		else
			foreach reserve in bulkRelease.allReserveDetails discreteLock do
				if reserve.hasOutstanding() then
					objArr.addExclusive(reserve);
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	//bulk releases assigned to the booking
	bookingRef := self.myTerminal.allBookingRefsByRef[_pCode];
	if bookingRef &lt;&gt; null then
		foreach bulkRelease in bookingRef.allReleaseRequests do
			if bulkRelease.status &lt;&gt; BR_ACTIVE and bulkRelease.status &lt;&gt; BR_PENDING then	
				continue;																	
			endif;																			
			if bulkRelease.releaseByType then
				foreach reserve in bulkRelease.allReserveDetails discreteLock do
					objArr.addExclusive(reserve);	
				endforeach;
			else
				foreach reserve in bulkRelease.allReserveDetails discreteLock do
					if reserve.hasOutstanding() or
						reserve = bulkRelease.allReserveDetails.last then
						objArr.addExclusive(reserve);	
						break;
					endif;
				endforeach;
			endif;	
		endforeach;
	endif;
	
	///Inter Term TI-----------------------------------
	tmpTI := self.myTerminal.lookupTrackedItem(_pCode, TI_CargoType_Null, TI_STATE_TRANSFER, null, true);	
	if tmpTI &lt;&gt; null then
		objArr.addExclusive(tmpTI);	
	endif;
	
	///Pre Note TI -----------------------------------
	tmpTI := self.myTerminal.lookupTrackedItem(_pCode, TI_CargoType_Null, TI_STATE_NOTIFIED, null, true);
	if tmpTI &lt;&gt; null then
		objArr.addExclusive(tmpTI);	
	endif;
	
	///Normal TI-----------------------------------
	if self.allowGateInByCargoID and	objArr.size = 0 then
		tmpTI := self.myTerminal.lookupTrackedItem(_pCode, TI_CargoType_Null,TI_STATE_NORMAL , null, true);	
		if tmpTI &lt;&gt; null then
			if not  tmpTI.isBulkCargo then
				app.raiseCMException1(Cargoty_not_bulk_cargo, tmpTI.cargoTypeDescr, null, tmpTI);
				return null;
			else
				self.myBulkGateAgent.setDirection(false);
				objArr.addExclusive(tmpTI);	
			endif;
		endif;
	endif;

	//vehicle booking timeslot has refs to all sorts, add them all...
	if self.myTerminal &lt;&gt; null then
		vbt := self.myTerminal.myVehicleBookingTerminal;
		if vbt &lt;&gt; null then
			vbsts := vbt.allVBTimeslotsById.getAtKey( compareCode );
			
			// ### TFS 58163 29May2023 NAVPW1
			if vbsts = null and self.myTerminal.isUsingVbsSlotValProcess then
				vbsts := vbt.allVBTimeslotsByExtRef.getAtKey( compareCode );
			endif;
			// ### TFS 58163 29May2023 NAVPW1
			
			if vbsts &lt;&gt; null then
				_pickerShown := true; 
				foreach tmpTI in vbsts.allBookedTrackedItems do
					objArr.addExclusive(tmpTI);
				endforeach;
				foreach bulkRelease in vbsts.allBulkReleases do
					if bulkRelease.releaseByType then
						foreach reserve in bulkRelease.allReserveDetails discreteLock do
							objArr.addExclusive(reserve);
						endforeach;
					else
						foreach reserve in bulkRelease.allReserveDetails discreteLock do
							if reserve.hasOutstanding() or
								reserve = bulkRelease.allReserveDetails.last then
								objArr.addExclusive(reserve);
								break;
							endif;
						endforeach;
					endif;	
				endforeach;
				foreach bookingRef in vbsts.allBookingRefs do
					skipOver := false;
					foreach splitRollEvt in bookingRef.allSplitRollEventsAsOld do
						if splitRollEvt.isKindOf(CMEVT_RollBooking) then
							if bookingRef.bookingReference &lt;&gt; splitRollEvt.myNewBookingReference.bookingReference then	//31 Oct 2014	NDL	Par 32671
								skipOver := true;
								break;
							endif;
						endif;
					endforeach;
					if skipOver then
						continue;
					endif;
					foreach bookingRefItem in bookingRef.allBookingRefItems discreteLock do
						if bookingRefItem.quantity &lt; 1 and bookingRefItem.weight = 0 then
							continue;
						endif;
						
						objArr.add(bookingRefItem);
						if bookingRefItem.myReserveDetail &lt;&gt; null then
							reserveDetail := bookingRefItem.myReserveDetail;
							if reserveDetail.hasOutstanding and reserveDetail.myReserveHeader.type = BR_TYPE_ROAD then
								objArr.addExclusive(reserveDetail);
							endif;
						endif;
						if bookingRefItem.allTIs.size() &gt; 0 then	
							foreach tmpTI in bookingRefItem.allTIs do	
								if tmpTI.isPreNote() and not tmpTI.isChild then		
									if not tis.includes(tmpTI) then
										objArr.addExclusive(tmpTI);
										allowMultiSelect := true;
									endif;
								endif;									
							endforeach;									
						endif;
					endforeach;
				endforeach;
			endif;
		endif;
	endif;
	
	/// Bring up the pickupwindow if is needed--------------------
	if objArr.size = 0 then
		return null;
	elseif objArr.size = 1 then
		if objArr.first.isKindOf(CM_BookingRef) then
			bookingRef := objArr.first.CM_BookingRef;
			if objArr.first.CM_BookingRef.allBookingRefItems.size = 1 then
				return objArr.first.CM_BookingRef.allBookingRefItems.first.CM_BookingRefItem;
			else
				_pickerShown := true;
				//self.myAssistant.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, null);			// TFS 38501
				self.myAssistant.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, null, false);		// TFS 38501
				return selectedObject;
			endif;
		else 
			return objArr.first.CM_Object;
		endif;
	else
		_pickerShown := true;
		//self.myAssistant.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, self);					// TFS 38501
		self.myAssistant.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, self, false);				// TFS 38501
		return selectedObject;
	endif;
	
epilog
	if objArr &lt;&gt; null then
		delete objArr;
	endif;	
	delete iter;
	delete tis;
end;</source>
        <access>protected</access>
        <Parameter name="_pCode" type="String"/>
        <Parameter name="_pickerShown" type="Boolean" usage="output"/>
        <Parameter name="_isCompleted" type="Boolean" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getVisitDetails" id="c0a85d16-e961-4eca-b8e8-3699b5716c1b">
        <updating/>
        <source>getVisitDetails(_obj : Object; _newVisit : Boolean) updating;
/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/04/2017	cnwdap1	TFS 3932 Carrier not populating from release request
20/11/2017	jlgmd1	TFS7610 Fix possible 1090 while qual'ing
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	bulkItem 	  : CM_TrackedItem;
	invalid		  : Boolean;
	visitDetail	  : String;
	cargoType 	  : CM_CargoType;
	bulkRel 	  : CM_BulkRelease;	//16 Dec 2016	NDL	
	resDet 		  : CM_ReserveDetail;	//16 Dec 2016	NDL	
	entity 		  : CMGTE_Entity;
	bookingItem   : CM_BookingRefItem;
	prenote 	  : CM_TrackedItem;
	bookingItemId : String;
	iter 		  : Iterator;
	cargoSubType  : CM_Product;
	tempBulkItem  : CM_TrackedItem;
	onsiteId   	  : String;		//9 Jan 17 NDS
	biCandidate   : CM_TrackedItem;
	allTIs		  : CM_TISet;
	
begin
	create allTIs transient;
	
	if _obj.isKindOf(CM_BulkRelease) then
		visitDetail := _obj.CM_BulkRelease.code;
		resDet := _obj.CM_BulkRelease.allReserveDetails.first;	//9 Jan 17 NDS
		cargoType := resDet.getCargoType;						//9 Jan 17 NDS
		resDet.getAllTrackedItems(allTIs, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach biCandidate in resDet.allTrackedItems where biCandidate.myPrimaryActualLocation &lt;&gt; null and biCandidate.myPrimaryActualLocation.isKindOf(CM_YardController) do	// 15/2/18 MAP TFS37006
		foreach biCandidate in allTIs where biCandidate.myPrimaryActualLocation &lt;&gt; null and biCandidate.myPrimaryActualLocation.isKindOf(CM_YardController) do	//23/06/2023	navkc1	CR 58406 Task 58408
			bulkItem := biCandidate;
			break;
		endforeach;
		if bulkItem = null then
			bulkItem :=	self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq(cargoType.id,null);	
		endif;
		if bulkItem.myCargoType &lt;&gt; cargoType then
			bulkItem := null;
		else	
			self.myBulkGateAgent.setDirection(false);
		endif;
		bulkRel := _obj.CM_BulkRelease;	//16 Dec 2016	NDL	
	elseif  _obj.isKindOf(CM_BookingRefItem) then
		bookingItem := _obj.CM_BookingRefItem;
		onsiteId := bookingItem.id;			//9 Jan 17 NDS
		visitDetail := bookingItem.getDisplayString();
		cargoType := bookingItem.myCargoType;
		
		bulkItem :=	self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq(cargoType.id,onsiteId);	//9 Jan 17 NDS
		if bulkItem = null then
			bulkItem :=	self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq(cargoType.id,null);	//9 Jan 17 NDS	
		endif;
		
		if  bulkItem &lt;&gt; null and bulkItem.myCargoType &lt;&gt; cargoType then
			// check for a prenote if we don't find an on-site cargo item for this cargo type
			if bookingItem.id &lt;&gt; null then
				bookingItemId := bookingItem.id.toUpper;
				prenote := self.myTerminal.allNotifiedTIsByCargoTypeId[cargoType.id, bookingItemId];
			else
				prenote := self.myTerminal.allNotifiedTIsByCargoTypeId.getAtKeyGeq(cargoType.id, null);
			endif;
			if prenote &lt;&gt; null and prenote.myCargoType = cargoType then
				if bookingItemId &lt;&gt; null and prenote.id &lt;&gt; bookingItemId then
					bulkItem := null;
				else
					bulkItem := prenote;
				endif;
			else
				bulkItem := null;
			endif;
		else
			self.myBulkGateAgent.setDirection(true);
		endif;
	elseif _obj.isKindOf(CM_ReserveSelection) then
		resDet := _obj.CM_ReserveSelection;	//16 Dec 2016	NDL	
		bulkRel := resDet.myReserveHeader;	//16 Dec 2016	NDL	
		visitDetail := resDet.getDescription;
		cargoType := resDet.CM_ReserveSelection.myCargoType;
		cargoSubType := resDet.CM_ReserveSelection.myProduct;
		if bulkRel.releaseByType then
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			self.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(cargoType.id, null, iter);
			while iter.next(tempBulkItem) do
				if tempBulkItem.myPrimaryActualLocation &lt;&gt; null and not tempBulkItem.myPrimaryActualLocation.isKindOf(CM_YardController) then		// 15/2/18 MAP TFS37006
					continue;
				endif;
				if tempBulkItem.myCargoType &lt;&gt; cargoType then
					break;
				endif;
				if cargoSubType &lt;&gt; null and tempBulkItem.myProduct &lt;&gt; cargoSubType then
					continue;
				endif;
				if tempBulkItem.isExport then
					continue;
				endif;
				bulkItem := tempBulkItem;
			endwhile;
			if bulkItem &lt;&gt; null and bulkItem.myCargoType &lt;&gt; cargoType then
				bulkItem := null;
			endif;
			if bulkItem &lt;&gt; null and ((bulkItem.myProduct &lt;&gt; cargoSubType and cargoSubType &lt;&gt; null) or bulkItem.isExport) then
				bulkItem := null;
			endif;
		else
			//bulkItem := resDet.allTrackedItems.first;
			bulkItem := resDet.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
		endif;
		if bulkItem &lt;&gt; null then
			self.myBulkGateAgent.setDirection(false);
		endif;
	elseif _obj.isKindOf(CMGTE_Release) then	
		visitDetail := _obj.CMGTE_Release.getTableDisplayString();
		bulkItem := _obj.CMGTE_Release.myTrackedItem;
		self.myBulkGateAgent.setDirection(false);
		resDet := _obj.CMGTE_Release.myReserveDetail;	//16 Dec 2016	NDL	
		bulkRel := _obj.CMGTE_Release.myBulkRelease;	//16 Dec 2016	NDL	
	elseif _obj.isKindOf(CMGTE_Receival) then
		visitDetail := _obj.CMGTE_Receival.id;
		bulkItem := _obj.CMGTE_Receival.myTrackedItem;
		self.myBulkGateAgent.setDirection(true);
	elseif _obj.isKindOf(CM_ReserveTI) then
		visitDetail := _obj.CM_ReserveTI.getDescription ;
		/*
		if _obj.CM_ReserveTI.allTrackedItems.size &gt;0 then
			bulkItem :=	_obj.CM_ReserveTI.allTrackedItems.first();
		endif;
		*/
		bulkItem := _obj.CM_ReserveTI.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
		self.myBulkGateAgent.setDirection(false);
		resDet := _obj.CM_ReserveTI;	//16 Dec 2016	NDL	
		bulkRel := _obj.CM_ReserveTI.myReserveHeader;	//16 Dec 2016	NDL	
	elseif  _obj.isKindOf(CM_TrackedItem) then
		if _obj.CM_TrackedItem.isNotified() then
			visitDetail := app.getErrorString(Prenote);
			self.myBulkGateAgent.setDirection(true);
		else
			self.myBulkGateAgent.setDirection(false);
			
			visitDetail := app.getErrorString(Onsite);
		endif;
		bulkItem := _obj.CM_TrackedItem;
		resDet := _obj.CM_TrackedItem.allReserveDetails.first;	//16 Dec 2016	NDL	
		if resDet &lt;&gt; null then	//16 Dec 2016	NDL	
			bulkRel := resDet.myReserveHeader;	
		endif;
	else
		app.raiseCMException(Unknown_bulk_release,null,_obj);
	endif;	
	if bulkRel &lt;&gt; null and ( bulkItem = null or not bulkItem.isOnSite ) then	//11 Apr 2017	NDL	TFS 4078
		app.raiseCMException1(No_Matchin_cargo_found_onsite, null, null, bulkItem);
		return;
	endif;
	
	//if not bulkItem.isBulkCargo then
	if bulkItem &lt;&gt; null and not bulkItem.isBulkCargo then	// ### TFS 58138 25May2023 NAVPW1
		app.raiseCMException1(Cargoty_not_bulk_cargo, bulkItem.cargoTypeDescr, null, bulkItem);
		return;
	endif;
			
	if self.myBulkGateAgent.myPxyGTEEntity &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,self.myBulkGateAgent.myPxyGTEEntity,invalid);
		delete self.myBulkGateAgent.myPxyGTEEntity;
		self.myBulkGateAgent.myPxyGTEEntity := null;
	endif;
		
	if bulkItem &lt;&gt; null then	
		self.setDirectionLabel(self.myBulkGateAgent.cargoDirection);
		if _newVisit then
			if self.myBulkGateAgent.cargoDirection = Inward then
				create entity as CMGTE_Receival transient;
					
			elseif self.myBulkGateAgent.cargoDirection = Outward then
				create entity as CMGTE_Release transient;
				
			else
				//Is not Inward or outward - we have a problem
				return;
			endif;
			entity.setPxyFromTI(bulkItem);
			entity.setWeight(bulkItem.totalWeight);
			
			if entity.isCMGTE_Release and bulkRel &lt;&gt; null then	//16 Dec 2016	NDL	
				entity.CMGTE_Release.setPXYFromBulkRelease(bulkRel, resDet);
				if bulkItem.totalWeight &gt; resDet.getWeightOutstanding then
					entity.setWeight(resDet.getWeightOutstanding);
				endif;
			endif;
		endif;
		
		self.txtPIN.enabled := false;
		self.cmbCargoTypes.enabled := false;
				
		lblVisitType.caption :=	visitDetail;
		lblCargoId.caption := bulkItem.id;
		
		if self.btnGetWeight.enabled and self.btnGetWeight.visible then
			self.btnGetWeight.setFocus();
		else
			self.txtWeightIN.setFocus();
		endif;
	else
		lblVisitType.caption := null;
		lblCargoId.caption := null;
	endif;
	
	// TFS 3932 Default Carrier from the bulk release (only if it hasn't already been set by the vehicle)
	if bulkRel &lt;&gt; null then																		// TFS 3932
		if self.cmbCarrier.listIndex &lt; 0 then													// TFS 3932
			self.cmbCarrier.listIndex := self.cmbCarrier.findObject(bulkRel.getCarrier);		// TFS 3932
		endif;																					// TFS 3932
	endif;																						// TFS 3932

epilog
	self.myBulkGateAgent.myPxyGTEEntity := entity;
	delete iter;
	delete allTIs;
end;
</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_newVisit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="f9e06e88-1000-47ec-b513-92018282ab8c">
        <source>getXMLSettingsForSetup();

/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	userWindow	: CM_UserWindow;
	gate		: CM_Gate;
	gateName,
	theXML		: String;
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;

	theXML := userWindow.xmlInfo;
	gateName := theXML.cnEcGetTagValueOfName('GateName');
 	if gateName &lt;&gt; null then
 		gate := self.myTerminal.allGates[gateName];
		self.cmbGate.listObject := gate;
 	endif;	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initCargoTypeCombo" id="801c4040-e3ba-48b9-8f4e-a28a940fb79b">
        <source>initCargoTypeCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2016	cnwns1	Initial creation

*/

vars
	iter 			: Iterator;
	allPotentialTypes : CM_CargoTypeSet;
	aCargoType 		: CM_CargoType;
	aCargoBolType 	: CM_CargoBOLType;
	combo 			: CMUI_ComboBox;
begin

	create allPotentialTypes transient;
	

	iter:=self.myTerminal.allCargoBOLTypes.createIterator;
	while iter.next(aCargoBolType) do
		if not aCargoBolType.isCargoType then
			continue;
		endif;
		aCargoType := aCargoBolType.CM_CargoType;
		if allPotentialTypes.includes(aCargoType) then
			continue;
		endif;	
		if  aCargoType.isNotAvailableForEntry or not aCargoType.isBulkProduct then 
			continue;
		endif;
		allPotentialTypes.addNoDuplicates(aCargoType,false);
	endwhile;
	delete iter;

			
	combo := self.cmbCargoTypes;
	combo.clear();
		
	if allPotentialTypes.isEmpty  then
		combo.enabled := false;
	else
		foreach aCargoType in allPotentialTypes do
			combo.addItemObject(aCargoType.description, aCargoType);
		endforeach;
	endif;

epilog
	delete allPotentialTypes;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="initCarrierInterchCombos" id="4ded43d0-063f-4ecf-a8a9-058be1ba8de4">
        <source>initCarrierInterchCombos();
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	
// ---------------------------------------------------------------------------

vars
	aCarrier : CM_Carrier;
	combo 	 : CMUI_ComboBox;
	termArea : CM_TerminalArea;
begin
	combo := self.cmbCarrier;
	combo.clear();

	foreach aCarrier in app.myRoot.allCarriersRoad discreteLock where not aCarrier.isNotAvailableForEntry do 
		combo.addItemObject(aCarrier.description, aCarrier);
	endforeach;
	
	combo := self.cmbInterchange;
	combo.clear();
	
	foreach termArea in self.myTerminal.allTerminalAreas where termArea.type = TA_TYPE_YARD_INTERCHANGE do
		combo.addItemObject(termArea.id, termArea);
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initSubCarrierCombo" id="f1a576b3-a2e2-40c2-9e30-db911824cce1">
        <updating/>
        <source>initSubCarrierCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN 

*/

vars
	aCarrier : CM_Carrier;
	combo    : CMUI_ComboBox;
begin
	combo := self.cmbSubCarrier;
	combo.clear();
	
	foreach aCarrier in app.myRoot.allSubCarriersRoad discreteLock  do
		combo.addItemObject(aCarrier.description, aCarrier);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadPrinterCombo" id="5e50ae83-ae75-4b4b-8c1a-1c3d4a16a097">
        <source>loadPrinterCombo();
// Created:     09 December 2016 by cnwns1

// Changed On	By			Reason
// ----------	--------	-------------------------------------------------

vars
	
	gate 		: CM_Gate;
	gateArea 	: CM_GateArea;
	obj 		: Object;
	objSet 		: CM_ObjectSet;
	objArr 		: CM_ObjectArray;
	laneCont 	: CM_LaneController;
	existingPrinterName : String;
	printerName : String;
	index 		: Integer;
	
begin

	if self.printerIsUserSelected and self.cmbPrinter.listIndex &gt; 0 then
		existingPrinterName := self.cmbPrinter.text;
	endif;
	
	self.myAssistant.comboBoxPrintersLocal( self.cmbPrinter, existingPrinterName );
	
	//gate := self.cmbGate.listObject.CM_Gate;
	gate := self.myBulkGateAgent.myGate;
	
	if gate &lt;&gt; null then										
		create objSet transient;
		create objArr transient;
		
		gate.getPGateAreas_IN(objSet);
		foreach obj in objSet do
			gateArea := obj.CM_GateArea; 
			gateArea.getAllLaneControllers(objArr);
		endforeach;	
		
		foreach obj in objArr do
			laneCont := obj.CM_LaneController;
			if laneCont.getLaneNumber = self.cmbGateLanes.text.Integer then
				printerName := laneCont.getPrinterPhysicalName;
				if printerName &lt;&gt; null then
					index := self.cmbPrinter.findStringExact( 1, printerName );
					if index &gt; 0 then
						self.cmbPrinter.listIndex := index;
					endif;
				endif;
				return;
			endif;
		endforeach;
	endif;														
	
epilog
	delete objSet;
	delete objArr;
end;	</source>
    </JadeMethod>
    <JadeMethod name="onGateChange" id="3311f5cd-7a57-4bfa-94fa-de80002d3c4e">
        <source>onGateChange() protected;

/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	gate 		: CM_Gate;
	gateArea 	: CM_GateArea;
	laneNumber	: Integer;
	laneCont	: CM_LaneController;
	myLaneCont	: CM_LaneController;
	objSet 		: CM_ObjectSet;
	obj			: Object;	
	numberOfLanes : Integer;
		gridController : CM_GridController;
begin

	myLaneCont := self.myBulkGateAgent.myGateAreaLaneController;
	gate := self.myBulkGateAgent.myGate;
	
	
	self.cmbGateLanes.clear();
	
	if gate &lt;&gt; null then
		create objSet transient;
		gate.getPGateAreas_IN(objSet);
		foreach obj in objSet do
			gateArea := obj.CM_GateArea;
			if gateArea &lt;&gt; null then
				if gateArea.laneCount &gt; 0 then
					self.cmbGateLanes.enabled := not self.myBulkGateAgent.gateAndLaneSet;
					self.lblGateLane.visible := true; 
					self.cmbGateLanes.visible := true; 
					foreach gridController  in gateArea.allGridControllersByName where gridController.isKindOf(CM_GateAreaLaneController)	do
						laneCont:=gridController.CM_GateAreaLaneController;
						if  laneCont.isOut then
							continue;
						endif;
							
						if laneCont.isUnavailable then 
							continue;					
						endif;								

					self.cmbGateLanes.addItemObject(gridController.getID , laneCont);
				endforeach;

				endif;
			endif;
		endforeach;
		self.cmbGateLanes.setIndex(1);
	endif;
	
	if self.cmbGateLanes.listCount &gt; 0 then
		if myLaneCont &lt;&gt; null then
			self.cmbGateLanes.setIndexFromObject(myLaneCont);
		endif;
	else
		self.lblGateLane.visible := false;
		self.cmbGateLanes.visible := false;
	endif;
	
	self.loadPrinterCombo();
epilog
	delete objSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="onPINChange" id="e29e65b5-c198-4731-9efa-be5d5c8005f3">
        <updating/>
        <source>onPINChange(_pinCode : String) updating, protected;
/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#				Description
============================================================================
11/3/2019	jlgns1	TFS 3827 			XLAT_FormCaptions need to be sorted out
12/04/2019	jlgka1	TFS 44368			Add isCompleted flag to identify what error message 
										to display when doing a road gate.	
26/05/2023	navpw1	TFS: 57756 (57896)	Moved validation for vehicle to VBS Process
05 Feb 2025	navhl20 Bug MTN-19856: MTN - VBS Slot validation is not using the retrospective date/time entered in the gate.
============================================================================*/								
vars
	pickerShown	: Boolean;
	pinNo		: CM_PinNo;
	iter		: Iterator;
	obj			: Object;
	itemIds		: StringArray;
	vbt			: CM_VehicleBookingTerminal;
	vbsts		: CM_VehicleBookingTimeSlot;
	msg 		: String;
	tiSet		: CM_TISet;
	realVVR 	: CM_VehicleVisitRecord;
	isCompleted	: Boolean; // jlgka1 TFS 44368
	terminal	: CM_Terminal;		// ### TFS 54049 (55841) 11May2023 NAVPW1
	result		: Boolean;			// ### TFS 54049 (55841) 11May2023 NAVPW1
	vbsProcess	: CM_VBSProcess;	// ### TFS 54049 (55841) 11May2023 NAVPW1
	
begin
	if _pinCode = null then
		return;
	endif;
	
	terminal := self.myTerminal;
	
	vbsProcess := self.myVBSProcess;	// ### TFS 54049 (55841) 11May2023 NAVPW1
	
	if terminal &lt;&gt; null then
		// ### TFS 54049 (55841) 11May2023 NAVPW1
		vbt		:= terminal.myVehicleBookingTerminal;				
		result	:= self.checkVBSSlot(vbt, _pinCode, vbsts);
		
		if not result then
			return;
		endif;
		// ### TFS 54049 (55841) 11May2023 NAVPW1
		
		/*vbt := terminal.myVehicleBookingTerminal;
		if vbt &lt;&gt; null then
			vbsts := vbt.allVBTimeslotsById.getAtKey( _pinCode.trimBlanks.toUpper );
			realVVR := self.myBulkGateAgent.myRealVVR;
			if realVVR &lt;&gt; null 
				and realVVR.myVehicleBookingTimeslot &lt;&gt; null 
				and realVVR.myVehicleBookingTimeslot &lt;&gt; vbsts 
			then
				msg := app.getErrorString1( Vehic_booki_times_alrea_been_a,  realVVR.myVehicleBookingTimeslot.id );
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
				return;
			endif;
			
			if vbsts &lt;&gt; null then
				self.populateFromVehicleBookingTS( vbsts );
				self.myBulkGateAgent.myVehicleBookingTimeslot := vbsts;       
			endif;
		endif;*/
		
		// ### TFS 54049 (55841) 11May2023 NAVPW1
		//if vbsts &lt;&gt; null and vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
		if vbsts &lt;&gt; null and terminal.isUsingVbsSlotValProcess and self.myBulkGateAgent &lt;&gt; null and self.myBulkGateAgent.myRealVVR &lt;&gt; null then	// ### TFS 57756 (57756) 26May2023 NAVPW1
			//result := self.myAssistant.validateVehicleAganistVBSSlot(vbsts, vbt, self.myBulkGateAgent.myRealVVR.allVehicleBookingSlots);// ### TFS 57756 (57756) 26May2023 NAVPW1	//05.02.2025 navhl20 #19856
			result := self.myAssistant.validateVehicleAganistVBSSlot(vbsts, vbt, self.myBulkGateAgent.myRealVVR.allVehicleBookingSlots,null);	//05.02.2025 navhl20 #19856
			
			if not result then
				return;
			endif;
		endif;
		// ### TFS 54049 (55841) 11May2023 NAVPW1
	endif;
	
	pinNo := self.myTerminal.allPinNos[_pinCode];
	if pinNo &lt;&gt; null then
		if pinNo.status = PIN_InProcess then
			app.msgBox(app.getErrorString(ERR_PIN_INPROCESS),app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		self.openFormFromPinNo(pinNo);		
		return;
	else
		obj := self.getMatchingObjectToSelect(_pinCode, pickerShown, isCompleted); // jlgka1 TFS 44368
		// Cancelled from Picker?
		if  obj = null then
			if not pickerShown then
				self.txtPIN.setFocus();
				app.raiseCMException1(No_Matchin_cargo_found_onsite, null, null, obj);				
			endif;
			return;
		endif;
		// Booking Ref check
		if obj &lt;&gt; null  then
			//populate booking ref onto table
			self.getVisitDetails(obj,true);		
			//self.doVvrAssocToVbtsStandard(vbsts);
			self.doVvrAssocToVbts(vbsts);			// ### TFS 54049 (55841) 11May2023 NAVPW1
			self.setTxtPinToNullOrVbsId();
			return;
		endif;
		//jlgka1 TFS 44368 --&gt;
		if isCompleted then 
			app.msgBox(app.getErrorString(Warning_RelReq_NotActive),app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);		
		else
			app.msgBox(app.getErrorString1(WARNING_ITEM_NUMBER,null),app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);		
		endif;
		//jlgka1 TFS 44368 &lt;--
		self.txtPIN.setFocus();
		self.txtPIN.selectAll();
	endif;
epilog
	delete iter;
	if obj &lt;&gt; null and
	   obj.isKindOf(ObjectArray) then
		delete obj;
	endif;
	delete itemIds;
	delete tiSet;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_pinCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="onRegChanged" id="b03302b7-dd66-4c25-b6a3-9bbf00fc1e1b">
        <updating/>
        <source>onRegChanged() protected, updating;
/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/06/2024	jlizm1	TFS 63908 Allow duplicate driver names
*/
vars
	vehicle 	: CM_Vehicle;
	driver 		: CM_DriverDetails;
	myItem 		: CM_Object;
	entity 		: CMGTE_Entity;
	vvrd 		: CM_VehicleVisitRecordDetail;
	scaleWeight	: Decimal[16,4];
	measure 	: CM_MeasurementType;
	state		: String;
	reg			: String;
	realVVR : CM_VehicleVisitRecord;
begin
	
	state := self.txtState.text.trimBlanks();
	if self.cmbRegNo.visible then
		reg := self.cmbRegNo.text;
		vehicle := self.cmbRegNo.listObject.CM_Vehicle;
	else
		reg := self.txtRegno.text.trimBlanks();
		if reg &lt;&gt; null then
			vehicle := self.myTerminal.vehicles[reg, state];
		endif;
	endif;
				
	if vehicle &lt;&gt; null then
		self.cmbCarrier.cnEcSetObjectIndex(vehicle.carrier);
		if self.cmbCarrier.listObject &lt;&gt; null and self.cmbDriver.visible then
			self.cmbCarrier.enabled:=false;
		else
			self.cmbCarrier.enabled:=true;
		endif;
		
		if self.myTerminal.getConfig(KnownTruckDriverRequired).Boolean then
			self.cmbDriver.clear;
			if self.cmbDriver.visible then
				self.cmbDriver.listCollection(vehicle.allDrivers,true,ComboBox.DisplayCollection_Forward);	
			endif;
		endif;
		
		driver :=vehicle.getOnlyDriverForTerminal;
		if driver &lt;&gt; null then
			if self.txtDriverCode.visible and self.txtDriverCode.text.trimBlanks = null then
				self.txtDriverCode.text:=driver.code;
			endif;
			if self.txtDriverName.visible and self.txtDriverName.text.trimBlanks = null then
				self.txtDriverName.text:=driver.name;
			endif;
			
			if self.cmbDriver.visible and self.cmbDriver.listObject = null then
				self.cmbDriver.listObject:=driver;
			endif;
		endif;
		
		if self.myBulkGateAgent.myRealVVR = null then
			self.checkVehicleVisit(vehicle)	;					
		endif;
			
		realVVR := self.myBulkGateAgent.myRealVVR;
		if realVVR &lt;&gt; null then
			myItem := realVVR.allGateEntities.first;
			vvrd := realVVR.getBulkGateIn(null);
			if vvrd &lt;&gt; null then	
				scaleWeight := vvrd.getExtraInfo_BulkGateInOrOut;
				if scaleWeight &gt; 0 then
					measure := app.getDefaultMeasurementForType(Type_Weight);
					self.txtWeightIN.setValues(app.convertMeasurementForDisplay(measure.shortName, scaleWeight) &amp; Space &amp; measure.shortName);
				endif;
			endif;
		endif;
	
		if myItem &lt;&gt; null then
			self.getVisitDetails(myItem,false);
		endif;		
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="openFormFromPinNo" id="5e60fe61-3dda-415c-bd03-79acf5733785">
        <updating/>
        <source>openFormFromPinNo(_pinNo : CM_PinNo) updating, protected;

/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	item		: Object;
	ti			: CM_TrackedItem;
	br,bulkRelease	: CM_BulkRelease;	
	reserve		: CM_ReserveDetail;
begin
	foreach item in _pinNo.allItems discreteLock do  
		if item.isKindOf(CM_TrackedItem) then	
			ti := item.CM_TrackedItem;
		 	self.getVisitDetails(item,true);
		elseif item.isKindOf(CM_BulkRelease) then
			br := item.CM_BulkRelease;												
			if self.myTerminal.allBulkReleasesByCodeDate.includes(br) then			
				bulkRelease := br;													
			endif;
			if self.myAssistant.getReserveDetailFromCode(br.code, bulkRelease, reserve, true) then
				if not bulkRelease.isActiveRoadRelease() then					
					app.msgBox(app.getErrorString(WARNING_PIN_NOT_ACTIVE_RR), app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);		
					self.txtPIN.setFocus();
					self.txtPIN.selectAll();
					return;
				endif;			
			 	self.getVisitDetails(br,true);
			endif;				
		else
			app.raiseUnexpectedProgramError(class.name, method.name,app.getErrorString1(ERROR_UNKNOWN_PIN,item.String ));
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pinNo" type="CM_PinNo"/>
    </JadeMethod>
    <JadeMethod name="populateFromVehicleBookingTS" id="ded48617-8aaf-4df2-a8a9-17a2de72505c">
        <updating/>
        <source>populateFromVehicleBookingTS( vbsts : CM_VehicleBookingTimeSlot ) updating, protected;
/*
// Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 08/06/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN

*/

vars

	vvr 	: CM_VehicleVisitRecord;
	driver 	: CM_DriverDetails;
	vehicle : CM_Vehicle;
	carrier,subCarrier : CM_Carrier;

begin

	if vbsts = null then
		return;
	endif;
	
	if self.myBulkGateAgent.myRealVVR = null then
		// don't do it if its already set up.
		vvr := vbsts.myVehicleVisitRecord;
	endif;
	if vvr &lt;&gt; null then
		self.txtVisitNumber.text := vvr.visitNumber;
		self.doQuery(vvr); 
	
		driver := vvr.myDriverDetails;
		vehicle := vvr.vehicle;
		carrier := vvr.getCarrier;
		subCarrier := vvr.getSubCarrier;		//08/06/2022 navhl20 TFS 53430
	else
		driver := vbsts.myDriver;
		vehicle := vbsts.myVehicle;
		carrier := vbsts.myCarrier;
		subCarrier := vbsts.mySubCarrier;		//08/06/2022 navhl20 TFS 53430
	endif;
		
	if vehicle &lt;&gt; null then
		if self.txtRegno.visible  and self.txtRegno.text &lt;&gt; vehicle.regNumber then
			self.detailsChangedVehicle := true;
			self.txtRegno.text := vehicle.regNumber;
			if vehicle.state.trimBlanks &lt;&gt; null and self.txtState.text &lt;&gt; vehicle.state then
				self.txtState.text := vehicle.state;
			endif;
			self.onRegChanged();
		elseif self.cmbRegNo.visible then
			self.cmbRegNo.setIndexFromObject(vehicle);
			self.onRegChanged();
		endif;
	endif;
	
	if driver &lt;&gt; null then
		self.setDriverDetails(driver);
	endif;
	
	if carrier &lt;&gt; null and self.cmbCarrier.listObject &lt;&gt; carrier then
		self.detailsChangedVehicle := true;
		if self.cmbCarrier.findObject(carrier) = -1 then 
			self.cmbCarrier.addItemObject(carrier.description, carrier);
		endif;
		self.cmbCarrier.listObject := carrier;
	endif;
	
	//08/06/2022 navhl20 TFS 53430
	if isSubCarrierEnabled and subCarrier &lt;&gt; null and self.cmbSubCarrier.listObject &lt;&gt; subCarrier then
		self.detailsChangedVehicle := true;
		if self.cmbSubCarrier.findObject(subCarrier) = -1 then 
			self.cmbSubCarrier.addItemObject(subCarrier.description, subCarrier);
		endif;
		self.cmbSubCarrier.listObject := subCarrier;
	endif;
	//08/06/2022 navhl20 TFS 53430

epilog

end;</source>
        <access>protected</access>
        <Parameter name="vbsts" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="5d2c5aa3-ce27-45e8-a84a-55d97e6fed80">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

constants
	
vars
	
begin
	self.doQueryUnload();

epilog

end;</source>
