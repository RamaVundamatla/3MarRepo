    <JadeMethod name="getPreInvoiceApprovalDT" id="4169372b-0c77-4c72-9bbb-00727278446a">
        <source>getPreInvoiceApprovalDT(_invoice : CM_Invoice): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlgma1	ChangeRequest 39645: PEL1 WP - Work Order List Invoice Acceptance Time Stamp
*/

vars
	dt : TimeStamp;
	fa : CM_OfflineFutureActor;
begin
	if _invoice.status &lt;&gt; CM_Invoice.INVOICE_PREPEND  then
		return null;
	endif;
	
	fa := app.myRoot.allOfflineFutureActorParents[_invoice];
	if fa &lt;&gt; null then
		return	fa.actionTimeStamp;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
