    <JadeMethod name="utlCreateEDIDataFromTIs" id="6031e44f-6d50-4eed-bf72-1085aa5a4ac4">
        <updating/>
        <source>utlCreateEDIDataFromTIs(
	_tiDict			: CM_TIByIdDict; 
	_ediData		: CM_EDIData output; 
	_ediConfig		: CM_EDIConfig input; 
	_fileName		: String; 
	_fileType		: CM_EDIFileType; 
	_passport		: CM_Passport input;
	_ediClientRef	: String;					// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
	_messageType	: String;					// cnwrl1 25/09/2009 PAR 20320 - MES 1011 New Messina Messages
	_message		: Binary ) updating;		// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//----------------------------------------------------------------
vars
	ediFile	: CM_EDIFile;
	message : String;
	messageType : String;
	transformedMsg : String;
	ediConfig : CM_EDIConfig;
	ediTI : CM_EDITrackedItem;
	str : String;
	invalidEdiTI : Boolean;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if _ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI config is null');
	endif;
	
	app.myValCA.valEDIData(_ediConfig, _fileName, _fileType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	ediConfig := _ediConfig;
	if ediConfig.setupEDITransformWrap(_message.String, transformedMsg, messageType) then
		message := transformedMsg.String;
		messageType := System_EDIFileType;
	else
		message := _message.String;
		messageType := _messageType;
	endif;

	if not tryLock(_ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_ediConfig);
	endif;

	create ediFile;

	ediFile.setForCreate(	_fileName,
							app.actualTimeServer,
							CM_EDIFile.EDI_STATUS_EXTRACTED,
							_ediConfig,
							_fileType,
							_ediClientRef,
							messageType,
							message);
	
	if _passport.noErrors then
		_ediData := _fileType.createEDIData(false);

		if _ediData &lt;&gt; null then
			_ediData.setForCreateFromTIs(_tiDict, _ediConfig, ediFile, _passport.userCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010
			if ediFile.ediData.allEDITrackedItems.size &gt; 0 then
				if not tryLock(ediFile.ediData.ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
					self.exclusiveLock(ediFile.ediData.ediConfig);
				endif;
				if not tryLock(ediFile.ediData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
					self.exclusiveLock(ediFile.ediData.ediConfig.allEDITrackedItemsByIdStatus);
				endif;
				foreach ediTI in ediFile.ediData.allEDITrackedItems do
					invalidEdiTI := false;
					str := ediTI.id;
					if not invalidEdiTI then
						ediTI.setMyEDIConfig(ediFile.ediData.ediConfig);
						ediTI.doTranslations(ediFile.ediData.getXlationOperator);
					endif;
				endforeach;
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'ediData not created');
		endif;
	endif;

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_ediData);	// 04 May 2012	cnwrs1	par 29531
		global.causeEvent(_ediConfig.myTerminal.getTerminalEvent(EDIData_Create_Event), false, _ediData);
	endif;
epilog

end;</source>
        <Parameter name="_tiDict" type="CM_TIByIdDict"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="output"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_ediClientRef" type="String"/>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIDeckPlan" id="21c66135-ad99-4f21-9155-24b9cb17a4c6">
        <updating/>
        <source>utlCreateEDIDeckPlan(_validateOnly : Boolean; _ediData : CM_EDIDataDeckPlan input; _cmifDeckPlan : CMIF_EDIDeckPlan input; _passport : CM_Passport input) updating;
/*
Date		Who		Reason
24 May 2012	cnwcs5	Initial creation - par 29583 - improve exception handling.  Code moved from trxCreateEDIDeckPlan
*/
// 11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
// 23 Jul 2012	cnwcs5		CCMS MES 2168 / par 29124 - new remarks parameter
//27 Aug 2012	cnwrs1	Par 30205 dont proceed if the voyage does not have a RORO structure
//11 Dec 2012	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotaion 1X1
//29 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//04 Feb 2013	cnwrs1	Par 31119 include Tranships as ROBs for EDI Proposed
// 14/03/2013	cnwmh5	#31258 - OOTL's now have the tier details on them, need to change to handle this
//30 Apr 2013	cnwrs1	Par 31258 EDI RORO Deck Plan extracting OOTL containers in incorrect order
vars
	ediTI : CM_EDITrackedItem;
	locationID, lookupCode : String;
	roroLC : CM_LocationsController;
	newLocation : Boolean;
	foundHeight : Integer;
	newLocations : StringArray;
	newLocnClasses : ObjectArray;
	idx : Integer;
	roroDeck : CM_DeckVoyage;
	newDefnID : String;
	newDefnClass : Class;
	newDefnPoints : DecimalArray;
	newDefnWeights : RealArray;
	newDefnWeight : Real;
	newCargoLength : Integer;
	newLength : IntegerArray; 
	roro : CM_ROROVoyageStructure;
	voyage : CM_Voyage;
	pxyTI, realTI : CM_TrackedItem;
	moveController : CMIF_MoveController;
	cmifDeckPlanGCCargo : CMIF_DeckPlanGCCargo;
	obj : Object;
	startLocn : CM_ROROLocnDefnVoyage; 
	ootlLocnDefn : CM_ROROLocnDefn; 
	items, split : Integer;
	errorSet : CM_ErrorSet;
	deckItem : CM_DeckItem;
	ootlLayer : CM_DeckLayerLayout;
	dinaDict : DynaDictionary;
	iter : Iterator;
	rotateLabel : String;
begin
	create newLocations transient;
	create newLocnClasses transient;
	create newDefnPoints transient;
	create newLength transient;
	create newDefnWeights transient;
	create errorSet transient;	// 22 Feb 2012	cnwrs1	Par 29157
	
	if not _validateOnly then
		_passport.useTIDictDeferUpdate 			:= true;
		_passport.useTITransactionDeferUpdate 	:= true;
	endif;
	
	// #######################
	// ### CREATE ALL NEW LOCATIONS
	// #######################
	voyage := _ediData.getVoyage;
	if voyage = null then
		app.raiseCMException1(Voyage_code_invalid, voyage.code, null, _ediData);
		return;
	endif;
	roro := voyage.myROROStructure;
	if roro = null then	//27 Aug 2012	cnwrs1	Par 30205
		//error message should already have been created in valEDIDataPlan
		if not _passport.hasErrors then
			app.raiseCMException1(Voyage_code_invalid, voyage.code, null, _ediData);
		endif;
		return;
	endif;
	
	// ### First get all the new location IDs
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDILayoutTI) do
		locationID := ediTI.CM_EDILayoutTI.layoutId.trimBlanks();
		
		if locationID &lt;&gt; null then
			if ediTI.CM_EDILayoutTI.isRotationMaster then
				// nothing more to do for a rotation master
				continue;
			endif;
			
			lookupCode := voyage.code &amp; " " &amp; locationID;
			
			_ediData.getMyTerminal().findLocationFromString(lookupCode,true, roroLC, foundHeight);
			
			if roroLC = null then
				
				// Equipment or general area deck items
				if ediTI.CM_EDILayoutTI.layoutType = "E" or ediTI.CM_EDILayoutTI.layoutType = "G" then
					roroDeck := roro.getDeckFromLocationString(locationID).CM_DeckVoyage;
					
					if roroDeck &lt;&gt; null then
					// check that they do not exist
						if roroDeck.allDeckItems[locationID] = null then
							newLocations.add(locationID);
							idx := newLocations.size;
							newDefnWeights.atPut(idx, ediTI.CM_EDILayoutTI.weight);
							if ediTI.CM_EDILayoutTI.layoutType = "E" then
								newLocnClasses.atPut(idx, CM_ROROEquipment);
							elseif ediTI.CM_EDILayoutTI.layoutType = "G" then
								newLocnClasses.atPut(idx, CM_ROROGeneralArea);
							else 
								newLocnClasses.atPut(idx, null);	// 16 Feb 2012	cnwrs1	Par 29131 fail with unused OOTL layouts
							endif;
							newLength.atPut(idx,0);
						endif;
					endif;
				else // CARGO
					newLocations.add(locationID);
					idx := newLocations.size;
				endif;
						
			 endif;
		endif;
	endforeach;
	
	newLocation := false;	
	
	// ### Second work out the class of the new location based on the cargo - GC or OOTL
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDICargoOnShipTI) do
		locationID := ediTI.CM_EDICargoOnShipTI.locationId.trimBlanks();
		
		if locationID &lt;&gt;  null then
			idx := newLocations.indexOf(locationID);
			if idx &lt;= 0 then
				
				//// 14/03/2013 cnwmh5 #31258 - rewrite
				roroDeck := roro.getDeckFromLocationString(locationID).CM_DeckVoyage;
				global.getExtraData(roroDeck.getAllStateDataObject(), RoRoRotatedLabel, rotateLabel);
				if locationID[locationID.length:1] = rotateLabel then	// note must use the config setting
					locationID := locationID[1:locationID.length-1];
					idx := newLocations.indexOf(locationID);
				endif;
				
				//// 14/03/2013 cnwmh5 #31258 - changed code
				//locationID := roro.getLocationIDFromLocationStr(locationID);
				//idx := newLocations.indexOf(locationID);
				if idx &lt;= 0 then
					continue;
				endif;
			endif;
			if ediTI.CM_EDICargoOnShipTI.cargoType = TI_CargoType_Container then // OUT OF TWIST LOCK CONTAINER
				// PAR 29989 only set this if it has not been set before. If a mix of 20s and 40s, the 20s are first and we do not want the location being changed to a 40
				if ((idx &lt;= newLength.size) and (newLength[idx] &lt;&gt; 20)) // Existing so update but only if the new value is 20 // PAR 29989 40 and 0 are overridable
				or (idx &gt; newLength.size) then // New so add
					newLocnClasses.atPut(idx, CM_ROROLocnDefnVoyage);
					newLength.atPut(idx,ediTI.CM_EDICargoOnShipTI.getContainerLength());
					newDefnWeights.atPut(idx, ediTI.CM_EDICargoOnShipTI.weight);
				endif;
			else // GENERAL CARGO
				newLocnClasses.atPut(idx, CM_ROROGCDefnVoyage);
				newLength.atPut(idx, 0);
				newDefnWeights.atPut(idx, ediTI.CM_EDICargoOnShipTI.weight);
			endif;
		endif;
	endforeach;
	
	newLocation := false;
	
	foreach locationID in newLocations discreteLock do		// 22 Feb 2012	cnwrs1	Par 29157 check all position have been used
		idx := newLocations.indexOf(locationID);
		
		// PAR 29881 default empty polygons to GENERAL CARGO
		if idx &gt; newLocnClasses.size then
			newLocnClasses.atPut(idx, CM_ROROGCDefnVoyage);
			newLength.atPut(idx, 0);
			//04 Feb 2013	cnwrs1	Par 31119 include tranships as ROBs for EDI Proposed
			newDefnWeights.atPut(idx, 0);
			foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDICargoOnShipTI) do
				if locationID = ediTI.CM_EDICargoOnShipTI.locationId.trimBlanks() then
					newDefnWeights.atPut(idx, ediTI.CM_EDICargoOnShipTI.weight);
					break;
				endif;
			endforeach;
		elseif newLocnClasses[idx] = null then
			newLocnClasses[idx] := CM_ROROGCDefnVoyage;
			newLength[idx] := 0;
			newDefnWeights[idx] := 0;
		endif;
		
		// 29881	if idx &gt; newLocnClasses.size or newLocnClasses[idx] = null then
		// 29881		app.raiseCMException1(Locat_does_not_have_cargo_inva, locationID, null, ediTI);	// 22 Feb 2012	cnwrs1	Par 29157
		// 29881	endif;
	endforeach;

	if _passport.hasErrors() then
		// no need to abort transaction as trx will do the for us because there are errors
		return;
	endif;

	// ### Next create the new defns with the POLYGON
	foreach locationID in newLocations discreteLock do
		newDefnPoints.clear();
		foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDILayoutPointTI) and ediTI.CM_EDILayoutPointTI.layoutId = locationID do
			newDefnPoints.add(ediTI.CM_EDILayoutPointTI.longPos); // X
			newDefnPoints.add(ediTI.CM_EDILayoutPointTI.transPos); // Y
		endforeach;

		if not newDefnPoints.isEmpty() then
			idx := newLocations.indexOf(locationID);
			if idx &gt; newLocnClasses.size then	// 16 Feb 2012	cnwrs1	Par 29131 fail with unused OOTL layouts
				continue;
			endif;
			if idx &gt; 0 then
				newDefnID := locationID;
				newDefnClass := newLocnClasses[idx].Class;
				newDefnWeight := newDefnWeights[idx];
				newCargoLength := newLength[idx];
			endif;
			roroDeck := roro.getDeckFromLocationString(newDefnID).CM_DeckVoyage;
			_passport.moveErrorsToSet(errorSet); //par 29157 save off all current errors
			
			deckItem := app.myUtilityCA.utlCreateROROCargoLocation(newDefnID, null, newDefnClass, newDefnWeight, newDefnPoints, roroDeck, newCargoLength, true, newLocations, _passport);	//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
			
			if _passport.hasErrors() and not _validateOnly then	//cnwrs1 testing 28 Mar 2012
				return;
			endif;
			
			if deckItem = null then
				app.raiseCMException1(Location_invalid, locationID, null, ediTI);	// 22 Feb 2012	cnwrs1	Par 29157
			endif;
		endif;
	endforeach;
	
	if _passport.hasErrors() then
		// no need to abort transaction as trx will do the for us because there are errors
		return;
	endif;
	
	// PAR 29396 - auto link the fwd OOTL positions to the aft  OOTL positions.
	foreach ootlLocnDefn in roro.allROROLocnDefnByOrd  discreteLock where ootlLocnDefn.isOOTLLocn and ootlLocnDefn.myAdjacentSlotAft = null do
		ootlLayer := ootlLocnDefn.myDeck.myDeckLayout.getOOTLLayer(); // Gets or creates
		ootlLayer.setAftLocnByPosition(ootlLocnDefn);
	endforeach;
	
	//****************************************************
	// now do the rotations
	//****************************************************	
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDILayoutTI) do
		locationID := ediTI.CM_EDILayoutTI.layoutId.trimBlanks();
		if locationID &lt;&gt; null then
			if ediTI.CM_EDILayoutTI.isRotationMaster then
				locationID := ediTI.CM_EDILayoutTI.layoutId;
				roroDeck := roro.getDeckFromLocationString(locationID).CM_DeckVoyage;
				if roroDeck &lt;&gt; null then
					global.getExtraData(roroDeck.getAllStateDataObject(), RoRoRotatedLabel, rotateLabel);
					deckItem := roroDeck.allDeckItems[locationID&amp;rotateLabel];
					if deckItem &lt;&gt; null then
						app.raiseCMException1(Posit_canno_rotat_becau_alread, locationID, null, ediTI);	// 21 Feb 2012	cnwrs1	Par 29157
						continue;
					endif;
					deckItem :=  roroDeck.allDeckItems[locationID];//06 Dec 2012	cnwrs1	Par 30868 unable to do OOTL rotation in EDI
					if deckItem &lt;&gt; null then
						if not deckItem.isKindOf(CM_ROROLocnDefnVoyage) then
							idx := newLocations.indexOf(locationID);	//28 Jan 2013	cnwrs1	Par30951 find out if the location is a new location
							if idx = 0 then	// if its a new location (ie OOTL) and it doesnt exist then ignore it
								app.raiseCMException1(Posit_canno_rotat_becau_not_ex, locationID, null, ediTI);	// 21 Feb 2012	cnwrs1	Par 29157
							endif;
							continue;
						else
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;locationID&amp;' '&amp;deckItem.CM_ROROLocnDefnVoyage.myPlannedRotatedMaster.String&amp;' '&amp;deckItem.CM_ROROLocnDefnVoyage.isPlannedRotated.String&amp;' '&amp;deckItem.CM_ROROLocnDefnVoyage.myRotateDischarge.String&amp;' '&amp;deckItem.CM_ROROLocnDefnVoyage.isRotatedCargoLayer.String;
							if deckItem.CM_ROROLocnDefnVoyage.isPlannedRotated then
								app.raiseCMException1(Posit_canno_rotat_becau_alread, locationID, null, ediTI);
								continue;
							endif;
						endif;
						startLocn := deckItem.CM_ROROLocnDefnVoyage;
						if startLocn.setItemsAndSplit(ediTI.CM_EDILayoutTI.rotation, items, split) then
							_passport.moveErrorsToSet(errorSet); //par 29157 save off all current errors
							
							app.myUtilityUA.utlUpdateROROLocnDefnRotate(startLocn, items, split, false, _passport, false); // PAR 31453 changed first boolean to false
							
							if _passport.hasErrors() then
								// no point going any further ?
								return;
							endif;
						else
							app.raiseCMException1(Inval_rotat_group_been_speci_i, ediTI.CM_EDILayoutTI.rotation, null, ediTI);
							//An invalid rotation grouping has been specified, 4X5 is invalid. Try 3X1
						endif;
					else
						global.getExtraData(roroDeck.getAllStateDataObject(), RoRoRotatedLabel, rotateLabel);
						deckItem := roroDeck.allDeckItems[locationID&amp;rotateLabel];
						if deckItem &lt;&gt; null then
							app.raiseCMException1(Posit_canno_rotat_becau_alread, locationID, null, ediTI);	// 21 Feb 2012	cnwrs1	Par 29157
						else
							app.raiseCMException1(Posit_canno_rotat_becau_not_ex, locationID, null, ediTI);	// 21 Feb 2012	cnwrs1	Par 29157
						endif;
					endif;
				else
					app.raiseCMException1(Valid_deck_code_could_not_deri, locationID, null, ediTI);	// 21 Feb 2012	cnwrs1	Par 29157
				endif;
				// nothing more to do for a rotation master
				continue;
			endif;
		endif;
	endforeach;
	
	// #######################
	// ### MOVE ALL THE CARGO
	// #######################
	
	// PAR 29396 11 Apr 2012	cnwrs1		Par 29396 - sort Ship Cargo by messgaenum
	create dinaDict transient;
	dinaDict.setMembership(CM_EDITrackedItem);
	dinaDict.addMemberKey(CM_EDITrackedItem::messageNum.name, false, false);
	dinaDict.endKeys(true);
	_ediData.allEDITrackedItems.copy(dinaDict);
	iter := dinaDict.createIterator;
	
	// par 29583 - once we call a utl method below we have lost tracked of the EDITI that 
	// actually caused the error.  we need the EDITI for the 'Jump-to-line' functionality in the EDI Operations form
	// I am arming an exception handler here so that if a CM_Exception occurs we trap it an update it with the correct
	// EDITI
	on CM_Exception do _ediData.xHandlerCMExceptionUserObject (exception, ediTI);	// par 29563
	
	while iter.next(ediTI) do
		if not ediTI.isKindOf(CM_EDICargoOnShipTI) then
			continue;
		endif;
//PAR 29396 	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDICargoOnShipTI) do
	
		pxyTI 		:= null;
		realTI 		:= null;
		locationID 	:= ediTI.CM_EDICargoOnShipTI.locationId.trimBlanks();
		
		// ### CREATE TI
		if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then
			
			foreach obj in _cmifDeckPlan.allDeckPlanGCCargoToAdd discreteLock do
				cmifDeckPlanGCCargo := obj.CMIF_DeckPlanGCCargo;
				if cmifDeckPlanGCCargo.myProxyCargoItem.id = ediTI.CM_EDICargoOnShipTI.id then
					pxyTI := cmifDeckPlanGCCargo.myProxyCargoItem;
					break;
				endif;
			endforeach;
			
			if pxyTI &lt;&gt; null then
				_passport.moveErrorsToSet(errorSet); //par 29157 save off all current errors
				
				app.myUtilityCA.utlCreateTrackedItem(pxyTI, realTI, _passport); 
				
				// par 29583 - reworked this block of code so we trap as many errors as possible
				// i think the reason we delete the cmif transient is so the array size reduces over the course of time
				_cmifDeckPlan.allDeckPlanGCCargoToAdd.remove(cmifDeckPlanGCCargo);
				delete cmifDeckPlanGCCargo;												// 23 Jan 2012	cnwrs1	CCMS 1009 Plans Par 29024

				if _passport.hasErrors() or realTI = null then
					// if we had errors but are only validating then we want to keep validating
					if _validateOnly then
						continue;
					else
						// go no further
						return;
					endif;
				endif;
			else
				continue;
			endif;
		else
			continue; // NO UPDATES or DELETES
		endif;
		
		// ### MOVE TI
		locationID := ediTI.CM_EDICargoOnShipTI.locationId.trimBlanks();
		
		if locationID &lt;&gt;  null then
			lookupCode := voyage.code &amp; " " &amp; locationID;
			_ediData.getMyTerminal().findLocationFromString(lookupCode,true, roroLC, foundHeight);
			if roroLC &lt;&gt; null then
				if roroLC.isROROVoyageLane() or roroLC.isROROVoyageLanePos() then
					app.myUtilityCA.utlCreateROROLaneCargo(false, roroLC.getDefn().CM_ROROLaneDefn,locationID,realTI, _passport);
				else
					// PAR 29489 - switch the primary for a 40 footer
					if not realTI.isTwenty then // is a 40
						if roroLC.getAftLC() = null then // there is no back end LC
							if roroLC.getFwdLC &lt;&gt; null then // there is a forward  LC
								roroLC := roroLC.getFwdLC; // switch to the forward LC
							endif;
						endif;
					endif;
							
					create moveController transient;
					moveController.setMyToPrimaryLocation(roroLC);
					moveController.setMoveMode(REAL_MODE);
					moveController.setMyTrackedItem(realTI);
					_passport.moveErrorsToSet(errorSet); //par 29157 save off all current errors
					
					app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
					
					if  _passport.noErrors() then
						app.myEventManager.createSingleObjInfoNoteEvt(moveController.myToPrimaryLocation.CM_VoyageController.myVoyage,
								_passport.myTerminal.getTerminalEvent(EVENT_TI_MOVE),moveController.myToPrimaryLocation);
					endif;
					delete moveController;	// cnwrs1 23 Jan 2012 par 29024
				endif;
			else

			
			endif;
		endif;

	endwhile;
	
	_passport.addErrorsFromSet(errorSet);	//par 29077 restore current errors back to

	errorSet.clear();
epilog
	_passport.addErrorsFromSet(errorSet);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
	
	delete moveController;		// par 29583 May 2012
	delete newLength;
	delete newLocations;
	delete newLocnClasses;
	delete newDefnPoints;
	delete newDefnWeights;
	delete errorSet;
	delete dinaDict;
	delete iter;
end;
</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIDataDeckPlan" usage="input"/>
        <Parameter name="_cmifDeckPlan" type="CMIF_EDIDeckPlan" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIDeckStowageAdvice" id="296d1727-a034-4f13-933f-b549dcbf3124">
        <updating/>
        <source>utlCreateEDIDeckStowageAdvice(_validateOnly : Boolean; _ediData : CM_EDIDataDeckStowageAdvice input;  _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
/*
Date		Who		Reason
09 Aug 2012	cnwcs5	Initial creation - CCMS MES 2168 / par 29124
					Code moved from trx method so that exception handling will work
20 Aug 2012 cnwcs5 	par 29124:2 - handle voyage slot location remarks correctly
//19 Dec 2012	cnwrs1	Par 30922 check is the Layout is a position id rather than location Id and if so take the first location
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
*/
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//04 Feb 2013	cnwrs1	Par 31119 include Tranships as ROBs for EDI Proposed
vars
	ediTIs			: CM_EDIStowAdviceTIByLoadOrder;
	ediTI, ediStowage 			: CM_EDITrackedItem;
	locationID, lookupCode : String;
	roroLC 			: CM_LocationsController;
	newLocation 	: Boolean;
	foundHeight 	: Integer;
	newLocations	: StringArray;
	newEDILayoutTIs	: ObjectArray;					// par 29124 Aug 2012
	newRemarksColl 	: HugeStringArray;				// par 29124 July 2012
	newLocnClasses 	: ObjectArray;
	idx 			: Integer;
	roroDeck 		: CM_DeckVoyage;
	newDefnID, newRemarks 		: String;			// par 29124 July 2012
	newDefnClass 	: Class;
	newDefnPoints 	: DecimalArray;
	newDefnWeights 	: RealArray;
	newDefnWeight 	: Real;
	newCargoLength, layoutPointCount 	: Integer;	// par 29124:2 August 2012
	newLength 		: IntegerArray; 
	roro 			: CM_ROROVoyageStructure;
	voyage 			: CM_Voyage;
	startLocn, ootlLocnDefn : CM_ROROLocnDefn; 
	deckItem : CM_DeckItem;
	items, split 	: Integer;
	voyageCode, remarks, oldRemarks	: String;		// par 29124:2 August 2012
	errorSet 		: CM_ErrorSet;				//30 Mar 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
	ootlLayer 		: CM_DeckLayerLayout;
	loadPortCode : String;
	createLocation : Boolean;
	rotateLabel : String;
begin 
	// GET VOYAGE
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDIVoyageHeaderTI) do
		voyageCode 	:= ediTI.CM_EDIVoyageHeaderTI.getVoyageCode();
		voyage 		:= _ediData.getMyTerminal().allVoyagesByCode.getAtKeyGeq(voyageCode,null );
		break; // should only be 1 voyage line
	endforeach;

	roro := voyage.myROROStructure;
	
	if roro = null then
		return;
	endif;
		
	create newLocations transient;
	create newEDILayoutTIs transient;		// par 29124 Aug 2012
	create newRemarksColl transient;
	create newLocnClasses transient;
	create newDefnPoints transient;
	create newLength transient;
	create newDefnWeights transient;
	create errorSet transient;

// PAR 30040 we are in transaction state, even if just verifying, so always delete existing load colour coding. 
// 					Whether there are errors or not this transaction is aborted.	
// PAR 30040	if not _validateOnly then
		// PAR 29884 Updating - clear all existing Stowage Advice
	roro.removeAllLoadStowageAdvice();
// PAR 30040	endif;
	
	// ##################################
	// ### ROTATE PRE DEFINED CONTAINER POSITIONS
	// ##################################
	on CM_Exception do _ediData.xHandlerCMExceptionUserObject (exception, ediTI);
	
	// ##############################################
	// ### CREATE ALL NEW LOCATIONS ON THE LOAD COLOUR CODING LAYER
	// ##############################################
	loadPortCode 	:= _ediData.getMyTerminal.getConfig(PortDestCode).String.trimBlanks;	// PAR 30067
	
	// ### First get all the new location IDs
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDILayoutTI) do
		locationID := ediTI.CM_EDILayoutTI.layoutId.trimBlanks();
		
		if locationID &lt;&gt; null then
			if ediTI.CM_EDILayoutTI.isRotationMaster then
				roroDeck := roro.getDeckFromLocationString(locationID).CM_DeckVoyage;
				if roroDeck &lt;&gt; null then
					global.getExtraData(roroDeck.getAllStateDataObject(), RoRoRotatedLabel, rotateLabel);
					locationID := locationID &amp; rotateLabel; // has been rotated will now have an R in teh end
				endif;
			endif;
			lookupCode := voyage.code &amp; " " &amp; locationID;
			_ediData.getMyTerminal().findLocationFromString(lookupCode,true, roroLC, foundHeight);
			if roroLC = null then	//19 Dec 2012	cnwrs1	Par 30922 check is the Layout is a position id rather than location Id and if so take the first location
				roroDeck := roro.getDeckFromLocationString(locationID).CM_DeckVoyage;
				if roroDeck &lt;&gt; null then
					startLocn :=  roroDeck.allDeckItems[locationID].CM_ROROLocnDefn;
					if startLocn &lt;&gt; null and startLocn.allROROSlotDefnByOrdinal.size &gt; 0 then
						roroLC := startLocn.allROROSlotDefnByOrdinal.first.CM_ROROSlotDefnVoyage.mySlotController;
					endif;
				endif;
			endif;
			if roroLC = null then
				if not ediTI.CM_EDILayoutTI.isRotationMaster then //11 Dec 2012	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotaion 1X1
					newLocations.add(locationID);
					newEDILayoutTIs.add (ediTI);							// par 29124 Aug 2012
					newRemarksColl.add (ediTI.CM_EDILayoutTI.description);	// par 29124 July 2012
				endif;
			else
				// par 29125:2 - if the location is a pre-defined slot location then they may be 
				// loading remarks for it
				if roroLC.isROROVoyageSlot then												// par 29124:2 Aug 2012
					remarks := ediTI.CM_EDILayoutTI.description;							// par 29124:2 Aug 2012
						
					if remarks &lt;&gt; null then													// par 29124:2 Aug 2012
						// if we already have some voyage layout remarks (copied from vessel layout remarks)
						// then we will prepend these layout remarks to them. Any existing layout remarks from
						// previous stowage advice EDI file will have been removed by now
						oldRemarks := roroLC.CM_ROROSlotController.getROROLayoutRemarks;	// par 29124:2 Aug 2012
						
						if oldRemarks &lt;&gt; null then											// par 29124:2 Aug 2012
							remarks := remarks &amp; CrLf &amp; oldRemarks;							// par 29124:2 Aug 2012
						endif;																// par 29124:2 Aug 2012
						
						roroLC.CM_ROROSlotController.setROROLayoutRemarks (remarks);		// par 29124:2 Aug 2012
					endif;																	// par 29124:2 Aug 2012
				endif;																		// par 29124:2 Aug 2012
			endif;
		endif;
	endforeach;
	
	create ediTIs transient;
	
	newLocation := false;	
	
	// ### Second work out the class of the new location based on the cargo - GC or OOTL
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDIStowAdviceTI) do
		ediTIs.add(ediTI.CM_EDIStowAdviceTI);
		
		locationID := ediTI.CM_EDIStowAdviceTI.stowageId.trimBlanks();
		
		if locationID &lt;&gt;  null then
			idx := newLocations.indexOf(locationID);
			
			if idx &lt;= 0 then
				idx := newLocations.indexOf(locationID[1:locationID.length - 1]);
				
				if idx &lt;= 0 then		
					if ediTI.CM_EDIStowAdviceTI.cargoType &lt;&gt; TI_CargoType_Container and ediTI.CM_EDIStowAdviceTI.mode &lt;&gt; CM_EDIStowAdviceTI.MODE_LOA then // GC DLR/SOB
						locationID := ediTI.CM_EDIStowAdviceTI.newStowageId.trimBlanks();
						
						if locationID &lt;&gt;  null then
							idx := newLocations.indexOf(locationID);
							
							if idx &lt;= 0 then
								idx := newLocations.indexOf(locationID[1:locationID.length - 1]);
								
								if idx &lt;= 0 then
									continue;
								endif;
							endif;
						endif;
					else
						continue;
					endif;
				endif;
			endif;
			
			if ediTI.CM_EDIStowAdviceTI.cargoType = TI_CargoType_Container then // OUT OF TWIST LOCK CONTAINER
				// PAR 29396 - mixed 20/40 stack, 20s are first, so use that. This was then getting the 40 and creating an unnecessary aft slot.
				/* PAR 29989 
				if (idx &lt;= newLength.size and newLength[idx] = 0) or (idx &gt; newLength.size) then
					newLocnClasses.atPut(idx,CM_ROROLocnDefnVoyage);
					newLength.atPut(idx,ediTI.CM_EDIStowAdviceTI.getContainerLength());
					newDefnWeights.atPut(idx,ediTI.CM_EDIStowAdviceTI.weight);
				endif;
*/
				
				if ((idx &lt;= newLength.size) and (newLength[idx] &lt;&gt; 20)) // Existing so update but only if the new value is 20 // PAR 29989 40 and 0 are overridable
				or (idx &gt; newLength.size) then // New so add
					newLocnClasses.atPut(idx, CM_ROROLocnDefnVoyage);
					newLength.atPut(idx,ediTI.CM_EDIStowAdviceTI.getContainerLength());
					newDefnWeights.atPut(idx, ediTI.CM_EDIStowAdviceTI.weight);
				endif;
			else // GENERAL CARGO
				newLocnClasses.atPut(idx,CM_ROROGCDefnVoyage);
				newLength.atPut(idx,0);
				newDefnWeights.atPut(idx,ediTI.CM_EDIStowAdviceTI.weight);
			endif;
		endif;
	endforeach;
	
	newLocation := false;
	// ### Next create the new defns with the POLYGON
	idx := 0;
	
	foreach locationID in newLocations discreteLock do
		newDefnPoints.clear();
	
		foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDILayoutPointTI) and ediTI.CM_EDILayoutPointTI.layoutId = locationID do
			newDefnPoints.add(ediTI.CM_EDILayoutPointTI.longPos); // X
			newDefnPoints.add(ediTI.CM_EDILayoutPointTI.transPos); // Y
		endforeach;

		idx := idx + 1;
		
		if not newDefnPoints.isEmpty() and
			not (idx &gt; newLength.size) then	//31 Dec 2012	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotaion 1X1
			newDefnID 		:= locationID;
			newRemarks		:= newRemarksColl[idx];	// par 29124 july 2012
			newDefnClass 	:= newLocnClasses[idx].Class;
			newDefnWeight 	:= newDefnWeights[idx];
			newCargoLength 	:= newLength[idx];
			// set EDITI so our exception handler knows what EDI TI caused the error when we call the utl method below
			ediTI			:= newEDILayoutTIs[idx].CM_EDILayoutTI;	// par 29124 Aug 2012 
			roroDeck 		:= roro.getDeckFromLocationString(newDefnID).CM_DeckVoyage;
			//make sure there are at least 4 layout points for GC and exactly 5 layout points for container poistions
			layoutPointCount	:= newDefnPoints.size div 2;									// par 29124:2 August 2012
			
			if newDefnClass = CM_ROROGCDefnVoyage and layoutPointCount &lt; 4 then					// par 29124:2 August 2012
				app.raiseCMException2 (XLAT_LAYOUTPOINT_ERR2, newDefnID, '4', null, ediTI);		// par 29124:2 August 2012
				continue;																		// par 29124:2 August 2012
				
			elseif newDefnClass = CM_ROROLocnDefnVoyage and layoutPointCount &lt;&gt; 5 then			// par 29124:2 August 2012
				app.raiseCMException2 (XLAT_LAYOUTPOINT_ERR1, newDefnID, '5', null, ediTI);		// par 29124:2 August 2012
				continue;																		// par 29124:2 August 2012		
			endif;																				// par 29124:2 August 2012

			
			// PAR 30336 moved the code to here to only check GC areas. We were ignoring rotations and remarks on container items.
			// PAR 30067 - do not create empty polygons, if the load port is not 'here' then later on in this TRX we ignore the colour coding lines
			createLocation := true;
			
			if newDefnClass = CM_ROROGCDefnVoyage then
				createLocation := false;
				foreach ediStowage in _ediData.allEDITrackedItems  discreteLock where ediStowage.isKindOf(CM_EDIStowAdviceTI) 
																								and ediStowage.CM_EDIStowAdviceTI.stowageId = locationID 
																								and ediStowage.CM_EDIStowAdviceTI.loadPort = loadPortCode do
					createLocation := true;
					break;
				endforeach;
			endif;
			
			if not createLocation then
				app.raiseCMWarning2(Roro_stowa_advic_layou_being_i, locationID, loadPortCode, 'layout' , null,ediTI);
				continue;
			endif;
			
			
			_passport.moveErrorsToSet(errorSet); // 30 Mar 2012	cnwrs1	Par 29077
			_passport.clearErrorsWarnings();

			
			app.myUtilityCA.utlCreateROROCargoLocation(newDefnID,  newRemarks, newDefnClass, newDefnWeight, newDefnPoints, roroDeck, newCargoLength, false, newLocations, _passport);	//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
		endif;
	endforeach;

	if _passport.hasErrors() then
		return;
	endif;
		
	// PAR 29396 - auto link the fwd OOTL positions to the aft  OOTL positions.
	foreach ootlLocnDefn in roro.allROROLocnDefnByOrd  discreteLock where ootlLocnDefn.isOOTLLocn and ootlLocnDefn.myAdjacentSlotAft = null do
		ootlLayer := ootlLocnDefn.myDeck.myDeckLayout.getCCLoadLayer(); // Gets or creates
		
		ootlLayer.setAftLocnByPosition(ootlLocnDefn);
	endforeach;
	
	// PAR 29990 these OOTL are on teh Load Layer, but they had a layout type of LOAD CC from teh utlCreateROROCargoLocation call, they need to be locations, else the rotation does not work.
	foreach ootlLocnDefn in roro.allROROLocnDefnByOrd  discreteLock where ootlLocnDefn.isOOTLLocn  do
// PAR 30231		ootlLocnDefn.myLayout.setType(DeckItemLayoutType_Locn);
		ootlLocnDefn.myLayout.showAllHiddenAndChangeType(); // PAR 30231
	endforeach;
	
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDILayoutTI) and ediTI.CM_EDILayoutTI.isRotationMaster = true do
		locationID 	:= ediTI.CM_EDILayoutTI.layoutId;
		roroDeck 	:= roro.getDeckFromLocationString(locationID).CM_DeckVoyage;
		
		if roroDeck &lt;&gt; null then
			deckItem :=  roroDeck.allDeckItems[locationID];
			//04 Feb 2013	cnwrs1	Par 31119 include Tranships as ROBs for EDI Proposed
			if not deckItem.isKindOf(CM_ROROLocnDefnVoyage) then
				app.raiseCMException1(Rotati_locati_does_not_exist, locationID, null, ediTI); 	//An invalid rotation grouping has been specified, 4X5 is invalid. Try 3X1
				continue;
			endif;
			startLocn := deckItem.CM_ROROLocnDefnVoyage;
			if startLocn &lt;&gt; null then
				if startLocn.setItemsAndSplit(ediTI.CM_EDILayoutTI.rotation, items, split) then
					_passport.moveErrorsToSet(errorSet); // 30 Mar 2012	cnwrs1	Par 29077
					_passport.clearErrorsWarnings();
					app.myUtilityUA.utlUpdateROROLocnDefnRotate(startLocn, items, split,true, _passport, true);
				else
					app.raiseCMException1(Inval_rotat_group_been_speci_i,ediTI.CM_EDILayoutTI.rotation,null,ediTI); 	//An invalid rotation grouping has been specified, 4X5 is invalid. Try 3X1
				endif;
			endif;
		endif;
	endforeach;
	
	if _passport.hasErrors() then
		return;
	endif;

	// ######################################
	// ### CREATE ALL THE LOAD CC and Voyage Allocations
	// ####################################
	_passport.moveErrorsToSet(errorSet); 				// 30 Mar 2012	cnwrs1	Par 29077
	_passport.clearErrorsWarnings();
	
	// disarm exception handler because it will be armed in following method
	on CM_Exception do null;
	
	app.myUtilityCA.utlCreateEDILoadColourCodeRORO(ediTIs, roro, _ediData,_validateOnly, _passport ); // CM_EDIStowAdviceTIByLoadOrder
epilog
	_passport.addErrorsFromSet(errorSet);				// 30 Mar 2012	cnwrs1	Par 29077
	
	delete newLength;
	delete newLocations;
	delete newEDILayoutTIs;								// par 29124 Aug 2012
	delete newRemarksColl;								// par 29124 July 2012
	delete newLocnClasses;
	delete newDefnPoints;
	delete newDefnWeights;
	delete ediTIs;
	delete errorSet;
end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIDataDeckStowageAdvice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIDiskFile" id="1a44316a-c41b-4a58-97c0-16a27ae487d1">
        <updating/>
        <source>utlCreateEDIDiskFile(_ediFile: CM_EDIFile io; _messageNumber: Integer; _ediDataDetails: CMIF_EDIDataDetails; _passport: CM_Passport input)updating;
//----------------------------------------------------------------
//	Created:	25 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	fileType	: CM_EDIFileType;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(false);
	fileType := _ediFile.myEDIFileType;
	
	if not fileType = app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_VSLStow, null) then//changed by cnwyl1 for ccms 1062
		if _ediDataDetails.operator = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Recipients), 'recipient', null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Recipients), 'recipient', null); // cnwdb2	PAR 35364
			return;
		endif;
	endif;//changed by cnwyl1 for ccms 1062

	//validate	- check for voyage
	_ediFile.ediData.validateForWrite();
	
	
	self.raiseExceptionIfNull(fileType, 'File Type');
	
	if (not app.myRoot.canDoEDIFileType(fileType.type)) then
		app.raiseCMException1(NotLicensedToPerformAction, 'Extract EDI File ' &amp; fileType.name, null, null);
		return;	
	endif;
	
	exclusiveLock(_ediFile);
	
	_ediFile.ediData.setDeliveryDetails(_ediDataDetails);
	fileType.extractFile(_ediFile, _messageNumber, _ediDataDetails.operator);

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_messageNumber" type="Integer"/>
        <Parameter name="_ediDataDetails" type="CMIF_EDIDataDetails"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIFile" id="c0c9c36f-f075-4f44-b053-b3ba90d631d2">
        <source>utlCreateEDIFile(
	_realEdiFile	: CM_EDIFile io;
	_ediFileType	: CM_EDIFileType;
	_fileName		: String;
	_fileCreatedTs	: TimeStamp;
	_status			: Integer;
	_ediConfig		: CM_EDIConfig;
	_passport		: CM_Passport input;
	_ediClientRef	: String;					// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
	_messageType	: String;					// cnwrl1 25/09/2009 PAR 20320 - MES 1011 New Messina Messages
	_message		: Binary;					// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
	_transformedMsg : String;					//tfs42276
	_ediFileAndData : Boolean);

// cnwdvb1 29 January 2003 
// 16 Aug 2016	cnwrs1	TFS 2534 Par 38135 - dead locking between edidata process and edidata deletion
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// 19 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 3
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 25 Mar 2019	jlgzm1	TFS 42276 transformMessage running twice per message
// 21 Aug 2023	navmd1	TFS 59024 Save the pre-transformed JSON message
// 03 May 2024	navsaa30 TFS 63660: CUX - Empty data file when sending Wagon data with sendEDI REST API
// 09 Jul 2024	navmd1	TFS 65114 More fixes for loading files on Unicode environments
vars
	message : String;
	messageType : String;
	transformedMsg : String;
	ediConfig : CM_EDIConfig;
	messageString : String;			// TFS 63660
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValCA.valEDIFileExtract(_ediFileType, _fileName, _status, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
	if not tryLock(_ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_ediConfig);
	endif;
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//	if _ediFileType &lt;&gt; null then
//		self.exclusiveLock(_ediFileType);
//	endif;

	ediConfig := _ediConfig;
	//tfs42276 start
	transformedMsg := _transformedMsg;
	messageType := _messageType;
	
	if not app.isFromEDIviaWeb then
		// If uploading a file in EDI Ops, then we're already a sensible string, so don't mangle by assuming ANSI
		// Same goes for if we're (re)load a file
		messageString := _message.String;
	else
		// Otherwise, we're coming from the Web and were base64 encoded, which means we need to be trated as an ANSI file
		messageString := _message.ansiToString;
	endif;
	
	// We haven't tried to transform this message yet
	if transformedMsg = null then
		ediConfig.setupEDITransformWrap(messageString, transformedMsg, messageType);	// TFS 63660
	endif;
	
	// Has the message been successfully transformed
	if transformedMsg &lt;&gt; null then
		messageType := System_EDIFileType;
	else
		transformedMsg := messageString;												// TFS 63660
	endif;
	
	message := transformedMsg;
	//tfs42276 end
	
	if not _ediFileAndData then
		ediConfig := null;
	endif;
	create _realEdiFile persistent;
	
	_realEdiFile.setForCreate(	_fileName,
								_fileCreatedTs,
								_status,
								ediConfig,
								_ediFileType,
								_ediClientRef,
								messageType,
								message);
	
	// If we're a JSON message, set the pre-transformed message
	if _ediFileType.isJSON() then
		_realEdiFile.setOriginalFileDataString(messageString);							// TFS 63660
	endif;
	
end;</source>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_fileCreatedTs" type="TimeStamp"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_ediClientRef" type="String"/>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="Binary"/>
        <Parameter name="_transformedMsg" type="String"/>
        <Parameter name="_ediFileAndData" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIFileTypeUser" id="39a17d01-1629-40d8-8433-5f7232c3f972">
        <updating/>
        <source>utlCreateEDIFileTypeUser(_realFileTypeUser	: CM_EDIFileTypeUser io;
				     _pxyFileTypeUser		: CM_EDIFileTypeUser;
					 _passport				: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValCA.valEDIFileTypeUser(_pxyFileTypeUser, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _realFileTypeUser persistent;
	_realFileTypeUser.setForCreate(_pxyFileTypeUser);
		
end;</source>
        <Parameter name="_realFileTypeUser" type="CM_EDIFileTypeUser" usage="io"/>
        <Parameter name="_pxyFileTypeUser" type="CM_EDIFileTypeUser"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIIssue" id="ae715a35-e00a-44fb-aa0e-c3ebe5f29aae">
        <source>utlCreateEDIIssue(_pxyObject : CM_EDIIssue; _realObject : CM_EDIIssue output; _passport : CM_Passport input);
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars
	theTerminal : CM_Terminal;

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valEDIIssue(_pxyObject);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject);
	
	if _passport.noErrors then
		// only required if the class is audited
		self.myCreateAuditAgent.audCreateGeneric(_realObject);
	endif;
	
	if _passport.noErrors then
		theTerminal := _realObject.myTerminal;
		app.myEventManager.createSingleObjInfoNoteEvt(theTerminal,theTerminal.getTerminalEvent(Event_EDIIssueCreate),_realObject);	
	endif;
end;</source>
        <Parameter name="_pxyObject" type="CM_EDIIssue"/>
        <Parameter name="_realObject" type="CM_EDIIssue" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDILoadColourCode" id="df50e102-7cf3-47cd-bde3-2d550e1e06e3">
        <updating/>
        <source>utlCreateEDILoadColourCode(_ediData 	 : CM_EDIDataStowAdvice input;  
						   _ediTIs		 : CM_EDIStowAdviceTIByLoadOrder;
						   _structure	 : CM_CellularVoyageStructure;
						   _validateOnly : Boolean; 
						   _passport	 : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
13 Aug 2012	cnwgb1	Initial creation
08 Oct 2015	cnwrs1	Par 36863  	make EDI consistant times when refreshing progress bar
16 May 2016	cnwns1	TFS 488  	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
29 Oct 2019	cnwrs1	TFS 47281
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	ediTI				: CM_EDITrackedItem;
	ediStowAdviceTI		: CM_EDIStowAdviceTI;
	stowID, mode		: String;
	moveType			: Integer;
	strs				: StringArray;
	theLoadSC,
	theDischSC			: CM_SlotController;
	loadPortCode		: String;
	tiCount, totalTIs	: Integer;
	aLC					: CM_LocationsController;
	loadCC				: CMIF_LoadColorCode;
	theEditions			: CM_ObjectByOidEditionDict;
	foundHeight			: Integer;
	dlrIDs				: StringArray;
	dlrID				: String;
	msg					: String;
	restowID			: String;
	loadSlots			: CM_LCSet;
	ignoreNotMarkedForDisch	: Boolean;	
	theStructure		: CM_CellularVoyageStructure;
	errorSet 			: CM_ErrorSet; //7.8.2012 cnwgb1 PAR 30133
    slotAttribute   	: String;
	progressTS 			: TimeStamp;
begin
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if _validateOnly then
		msg := "Validating EDI data";
	else
		msg := "Processing EDI data";
	endif;
	
	
	//-----------------------------------------------
	// Clear the ship of load CC's first
	//-----------------------------------------------
// PAR 30040 we are in transaction state, even if just verifying, so always delete existing load colour coding. 
// 					Whether there are errors or not this transaction is aborted.	
// Graeme I will comment this IF out after you have re factored the code.

//	if not _validateOnly then	//replacements validated further down
		app.myUtilityDA.utlDeleteSlotRequests(_structure, LOAD_MOVETYPE, true, _passport);
//	endif;

	//-----------------------------------------------
	// Create the new colour codes
	//-----------------------------------------------
	create strs transient;
	create theEditions transient;
	create loadCC transient;
	create dlrIDs transient;
	create loadSlots transient;
	create errorSet transient;  //7.8.2012 cnwgb1 PAR 30133    
	
	totalTIs := _ediTIs.size;
	tiCount := null;
	_ediData.updateProgress(progressTS, msg, totalTIs, tiCount, true, _passport);
	
    on CM_Exception do _ediData.xHandlerCMExceptionUserObject (exception, ediTI);	// par 29563 // cnwgb1 30133 8.8.2012

	foreach ediTI in _ediTIs do

		tiCount := tiCount + 1;
		_ediData.updateProgress(progressTS, msg, totalTIs, tiCount, false, _passport);		
		
		ignoreNotMarkedForDisch := false;
		ediStowAdviceTI := ediTI.CM_EDIStowAdviceTI;
		mode := ediStowAdviceTI.mode;
		
		
		if mode = CM_EDIStowAdviceTI.MODE_LOA or
		   mode = CM_EDIStowAdviceTI.MODE_VOI then
			moveType := LOAD_MOVETYPE;
		//  NO DLRs or SOBs to be loaded  PAR 5879 - add configs for this
		elseif mode = CM_EDIStowAdviceTI.MODE_DIS then
			app.writeLog("Auto Load Colour Code - Unsupported Move Mode (" &amp; CM_EDIStowAdviceTI.MODE_DIS &amp; " is ignored)", LogINFO);
			continue;
		elseif mode = CM_EDIStowAdviceTI.MODE_SHI then
			moveType := SOB_MOVETYPE;
		elseif mode = CM_EDIStowAdviceTI.MODE_RES then
			moveType := DLR_MOVETYPE;
		else
			app.raiseCMWarning2(ERR_FIELD_MOVEMODE, ediStowAdviceTI.mode, "Move Mode (mode not supported)", 'moveMode' , ediStowAdviceTI, ediTI);
			continue;
		endif;
		
		loadPortCode := app.getMyTerminalConfigDO_NOT_USE(PortDestCode).String.trimBlanks;
		
		if moveType = LOAD_MOVETYPE then
			if ediStowAdviceTI.loadPort &lt;&gt; loadPortCode then
				if not dlrIDs.includes(ediStowAdviceTI.id) then	//check to see if it was a restow before raising this warning
					//app.raiseCMWarning2(ERR_FIELD_LOAD_PORT, ediStowAdviceTI.loadPort, "Load Port (this edi item will be ignored)", 'loadPort' , ediStowAdviceTI, ediTI);
					app.raiseCMWarning1(Stowage_Advice_LoadPort_Ignore, ediStowAdviceTI.loadPort, 'loadPort', ediStowAdviceTI, ediTI);		// 21/02/2013 cnwmh5 #29916
				endif;
				continue;
			endif;
		elseif moveType = DLR_MOVETYPE or moveType = SOB_MOVETYPE then
			if ediStowAdviceTI.newStowageId = null then
				app.raiseCMWarning2(ERR_STOWAGE_FIELD, "(" &amp; app.getErrorString(Null) &amp; ")", "'New Stowage ID' (this edi item will be ignored)", 'newStowageId' , ediStowAdviceTI, ediTI);
				continue;
			elseif ediStowAdviceTI.newStowageId.length() &lt; 7 then
				app.raiseCMWarning2(ERR_STOWAGE_FIELD, "(" &amp; ediStowAdviceTI.newStowageId &amp; ")", "'New Stowage ID' (this edi item will be ignored)", 'newStowageId' , ediStowAdviceTI, ediTI);
				continue;
			endif;
			
			dlrID := ediStowAdviceTI.id;//newStowageId;
		endif;
		
		theEditions.clear;
		aLC := null;
		theDischSC := null;
		theLoadSC := null;
		
		//get the load slot
		strs.clear;
		strs.add(ediStowAdviceTI.stowageId[2:6]);
		_structure.myVoyage.findLocation(strs, false, aLC, foundHeight);
		
		// 30224 if aLC = null then
		if not aLC.isKindOf(CM_SlotController) then // PAR 30224
			stowID := null;
			if ediStowAdviceTI.stowageId &lt;&gt; null then
				stowID := ediStowAdviceTI.stowageId[2:end];
			endif;
			app.raiseCMException2(ERR_FIELD_VALUE, stowID, 'stowageId', 'Stowage', ediStowAdviceTI);
			continue;
		endif;
	
		theEditions.add(aLC);
		
		if moveType = DLR_MOVETYPE or moveType = SOB_MOVETYPE then
			//this is actually the disch slot if we're doing a restow
			theDischSC := aLC.CM_SlotController;
			//now get the DLR load slot 
			strs.clear;					
			
			restowID := ediStowAdviceTI.newStowageId[2:6];
			strs.add(restowID);
			_structure.myVoyage.findLocation(strs, false, aLC, foundHeight);
			
			if aLC = null then
				app.raiseCMException2(ERR_FIELD_VALUE, restowID, 'restow Id', 'Stowage', ediStowAdviceTI);
				continue;
			endif;
			
			//restowing back to orginal location - so ignore NotMarkedForDischarge error
			ignoreNotMarkedForDisch := theDischSC = aLC;
					
			dlrIDs.add(dlrID);
			theEditions.add(aLC);
		endif;
	
		theLoadSC := aLC.CM_SlotController;
		
		//set this now - useful in validation
		ediStowAdviceTI.setLoadCC(loadCC);
		if _validateOnly then
			//we miss this validation in the utl's if _validateOnly, so do it here
			//also, we want to keep going for these warnings when doing this for real 
			//validate disch
			if theDischSC &lt;&gt; null then
				if not theDischSC.validateForEDIDischarge(ediStowAdviceTI) then
					continue;
				endif;
			endif;
			
			if loadSlots.includes(theLoadSC) then
				//mulitple load to same slot
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED,theLoadSC.getFullId,"Load","Job Not Yet Created", 'Stowage', ediStowAdviceTI);
				continue;
			else
				if not theLoadSC.validateForEDILoad(ediStowAdviceTI, dlrIDs, ignoreNotMarkedForDisch) then
					continue;
				endif;
				loadSlots.add(theLoadSC);
				
				if ( loadCC.isForty or loadCC.isFortyFive or loadCC.isThirty or loadCC.isFiftyThree )	// 08 Apr 2010	NDL	Par 22526
				and theLoadSC.myAftSlot &lt;&gt; null then
					//theSC is the forty front
					if loadSlots.includes(theLoadSC.myAftSlot) then
						//mulitple load to same slot
						app.raiseCMException3(Tryin_creat_load_colou_codin_l,"40",theLoadSC.getFullId,theLoadSC.myAftSlot.getFullId, 'Stowage', ediStowAdviceTI);
						continue;
					else
						if not theLoadSC.myAftSlot.validateForEDILoad(ediStowAdviceTI, dlrIDs, ignoreNotMarkedForDisch) then
							continue;
						endif;
						loadSlots.add(theLoadSC.myAftSlot);
					
					endif;
				endif;
			endif;		
		endif;
				
		if moveType = DLR_MOVETYPE then
            slotAttribute := CM_SlotRequest.Attribute_DLR;
 		elseif moveType = SOB_MOVETYPE then
            slotAttribute := CM_SlotRequest.Attribute_SOB;
        else
            slotAttribute := CM_SlotRequest.Attribute_ColourCode;
        endif;
        
        app.myUtilityCA.utlCreateSlotRequestAttribute(theLoadSC, theDischSC, true, loadCC, theEditions, slotAttribute, _validateOnly, _passport);
                
        if _passport.hasErrorsOrWarnings then   //7.8.2012 cnwgb1 PAR 30133
            _passport.moveErrorsToSet( errorSet ); 
            _passport.clearErrorsWarnings();
        endif;
		
	endforeach;

 	on CM_Exception do null; // 8.8.2012 cnwgb1	PAR 30133

    _passport.addErrorsFromSet( errorSet );  //7.8.2012 cnwgb1 PAR 30133    
    errorSet.clear();  //7.8.2012 cnwgb1 PAR 30133    
    
	theStructure := _structure;// PAR 16676
	
	if not _passport.hasErrors() and theStructure &lt;&gt; null then
		app.myUtilityCA.utlCreateVoyageOOWCreation(theStructure,_passport); // PAR 16676 PAR 17802 put this back
		if _passport.noErrors and theStructure.myVoyage &lt;&gt; null then
			theStructure.causeEvent(theStructure.myVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, theStructure); // PAR 16676
		endif;
	endif;
	
	_ediData.updateProgress(progressTS, msg, totalTIs, tiCount, true, _passport);
	
	
epilog
	delete strs;
	delete theEditions;
	delete loadCC;
	delete dlrIDs;
	delete loadSlots;
    delete errorSet;  //7.8.2012 cnwgb1 PAR 30133    
end;
</source>
        <Parameter name="_ediData" type="CM_EDIDataStowAdvice" usage="input"/>
        <Parameter name="_ediTIs" type="CM_EDIStowAdviceTIByLoadOrder"/>
        <Parameter name="_structure" type="CM_CellularVoyageStructure"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDILoadColourCodeRORO" id="b7c23420-ace0-41d9-9778-ef9b0cc5ca19">
        <updating/>
        <source>utlCreateEDILoadColourCodeRORO(	_ediTIs: CM_EDIStowAdviceTIByLoadOrder;
								_structure: CM_ROROVoyageStructure input;
								_ediData: CM_EDIData input;
								_verifyOnly: Boolean;
								_passport: CM_Passport input) updating;
/*
Date			Who			Reason
NOVEMBER 2011	CNWAB1		Initial creation
30 Mar 2012		cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
24 Apr 2012		cnwab1		PAR 29489 - switch the primary for a 40 footer
25 Jul 2012		cnwcs5		par 29124 - remarks on stowage advice
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
vars
	ediTI				: CM_EDITrackedItem;
	ediStowAdviceTI		: CM_EDIStowAdviceTI;
	stowID, mode 	    : String;
	moveType			: Integer;
	strs				: StringArray;
	theLoadSC,
	theDischSC			: CM_VoyageROROController;
	aftSlot 			: CM_ROROSlotController;
	loadPortCode		: String;
	tiCount, totalTIs	: Integer;
	aLC					: CM_LocationsController;
	loadCC				: CMIF_LoadColorCode;
	theEditions			: CM_ObjectByOidEditionDict;
	foundHeight			: Integer;
	dlrIDs				: StringArray;
	dlrID				: String;
	msg, restowID		: String;
	loadSlots			: CM_LCSet;
	ignoreNotMarkedForDisch, wasFound	: Boolean;	
	aDeck 				: CM_DeckVoyage;
	// PAR 30165  roroControllers 	: CM_LCSet;
	theSlots, theSlotsAlt : CM_LCArray;
	errorSet 			: CM_ErrorSet;	//30 Mar 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
	progressTS : TimeStamp;
begin
	if _verifyOnly then
		msg := "Validating EDI data";
	else
		msg := "Processing EDI data";
	endif;
	
	create errorSet transient;	//30 Mar 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
	
	//-----------------------------------------------
	// Clear the ship of load CC's first
	//-----------------------------------------------
	// PAR 30165 create roroControllers transient;
	
/*	PAR 30165 this has already been done in utlCreateEDIDeckStowageAdvice line 60ish
	if not _verifyOnly then	
		foreach aDeck in _structure.allDecks discreteLock do
			roroControllers.clear();
			aDeck.allROROControllers.copyNoDuplicates(roroControllers,false);
			_passport.moveErrorsToSet(errorSet);	//30 Mar 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
			_passport.clearErrorsWarnings();
			app.myUtilityDA.utlDeleteRORORequests(roroControllers, true, _passport);
		endforeach;
	endif;
*/
	//-----------------------------------------------
	// Create the new colour codes
	//-----------------------------------------------
	create strs transient;
	create theEditions transient;
	create loadCC transient;
	create dlrIDs transient;
	create loadSlots transient;
	create theSlots transient;
	create theSlotsAlt transient;
	
	loadPortCode 	:= app.getMyTerminalConfigDO_NOT_USE(PortDestCode).String.trimBlanks;	// par 29124 July 2012 - moved from within loop
	
	progressTS		:= app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	totalTIs 		:= _ediTIs.size;
	tiCount			:= null;
	_ediData.updateProgress(progressTS, msg, totalTIs, tiCount, true, _passport);

	on CM_Exception do _ediData.xHandlerCMExceptionUserObject (exception, ediTI);			// par 29124 Aug 2012
	
	foreach ediTI in _ediTIs do
		tiCount 				:= tiCount + 1;
		_ediData.updateProgress(progressTS, msg, totalTIs, tiCount, false, _passport);
		
		ignoreNotMarkedForDisch := false;
		ediStowAdviceTI 		:= ediTI.CM_EDIStowAdviceTI;
		mode 					:= ediStowAdviceTI.mode;
		
		if mode = CM_EDIStowAdviceTI.MODE_LOA or mode = CM_EDIStowAdviceTI.MODE_VOI then
			moveType := LOAD_MOVETYPE;
		//  NO DLRs or SOBs to be loaded  PAR 5879 - add configs for this
		elseif mode = CM_EDIStowAdviceTI.MODE_DIS then
			app.writeLog("Auto Load Colour Code - Unsupported Move Mode (" &amp; CM_EDIStowAdviceTI.MODE_DIS &amp; " is ignored)", LogINFO);
			continue;
		//	moveType := DISCHARGE_MOVETYPE;
		elseif mode = CM_EDIStowAdviceTI.MODE_SHI then			// cnwrl1 09/11/2010 PAR 25918.
			moveType := SOB_MOVETYPE;							// cnwrl1 09/11/2010 PAR 25918.

		elseif mode = CM_EDIStowAdviceTI.MODE_RES then
			moveType := DLR_MOVETYPE;

		else
			app.raiseCMWarning2(ERR_FIELD_MOVEMODE, ediStowAdviceTI.mode, "Move Mode (mode not supported)", 'moveMode' , ediStowAdviceTI, ediTI);
			continue;
		endif;
				
		if moveType = LOAD_MOVETYPE then
			if ediStowAdviceTI.loadPort &lt;&gt; loadPortCode then
				if not dlrIDs.includes(ediStowAdviceTI.id) then	//check to see if it was a restow before raising this warning
					//app.raiseCMWarning2(ERR_FIELD_LOAD_PORT, ediStowAdviceTI.loadPort, "Load Port (this edi item will be ignored)", 'loadPort' , ediStowAdviceTI, ediTI);
					app.raiseCMWarning1(Stowage_Advice_LoadPort_Ignore, ediStowAdviceTI.loadPort, 'loadPort', ediStowAdviceTI, ediTI);		// 21/02/2013 cnwmh5 #29916
				endif; 
				continue;
			endif;

		elseif moveType = DLR_MOVETYPE or moveType = SOB_MOVETYPE then
			wasFound := false;
			
			if ediStowAdviceTI.newStowageId = null then
				app.raiseCMWarning2(ERR_STOWAGE_FIELD, "(" &amp; app.getErrorString(Null) &amp; ")", "'New Stowage ID' (this edi item will be ignored)", 'newStowageId' , ediStowAdviceTI, ediTI);
				continue;
			else
				restowID := ediStowAdviceTI.newStowageId;
				
 				foreach aDeck in _structure.allDecks discreteLock do
					if _structure.allROROGCDefnByCode[restowID] &lt;&gt; null or 
						_structure.allROROLaneDefnByCode[aDeck,restowID] &lt;&gt; null or 
						_structure.allROROSlotDefnByCode[aDeck,restowID] &lt;&gt; null then
						wasFound := true;
						break;
					endif;
				endforeach;
				
				if not wasFound then
					app.raiseCMWarning2(ERR_STOWAGE_FIELD, "(" &amp; restowID &amp; ")", "'New Stowage ID' (this edi item will be ignored)", 'newStowageId' , ediStowAdviceTI, ediTI);
					continue;
				endif;
			endif;
			
			wasFound 	:= false;
			stowID		:= ediStowAdviceTI.stowageId;
			
			foreach aDeck in _structure.allDecks discreteLock do
				if _structure.allROROGCDefnByCode[stowID] &lt;&gt; null or 
					_structure.allROROLaneDefnByCode[aDeck,stowID] &lt;&gt; null or 
					_structure.allROROSlotDefnByCode[aDeck,stowID] &lt;&gt; null then
					wasFound := true;
					break;
				endif;
			endforeach;
			
			if not wasFound then
				app.raiseCMWarning2(ERR_STOWAGE_FIELD, "(" &amp; stowID &amp; ")", "'Current Stowage ID' (this edi item will be ignored)", 'newStowageId' , ediStowAdviceTI, ediTI);
				continue;
			endif;
			
			dlrID := ediStowAdviceTI.id;//newStowageId;
		endif;
		
		theEditions.clear;
		
		aLC 		:= null;
		theDischSC 	:= null;
		theLoadSC 	:= null;
		
		//get the load slot
		strs.clear;
		strs.add(ediStowAdviceTI.stowageId);
		_structure.myVoyage.findLocation(strs, false, aLC, foundHeight);
		
		if aLC = null then
			stowID := null;
			if ediStowAdviceTI.stowageId &lt;&gt; null then
				stowID := ediStowAdviceTI.stowageId;
			endif;
			app.raiseCMException2(ERR_FIELD_VALUE, stowID, 'stowageId', 'Stowage', ediStowAdviceTI);
			continue;
		endif;
	
		theEditions.add(aLC);
		
		if moveType = DLR_MOVETYPE or moveType = SOB_MOVETYPE then
			//this is actually the disch slot if we're doing a restow
			theDischSC := aLC.CM_VoyageROROController;
			//now get the DLR load slot 
			strs.clear;					
			
			restowID := ediStowAdviceTI.newStowageId;
			
			strs.add(restowID);
			_structure.myVoyage.findLocation(strs, false, aLC, foundHeight);
			
			if aLC = null then
				app.raiseCMException2(ERR_FIELD_VALUE, restowID, 'restow Id', 'Stowage', ediStowAdviceTI);
				continue;
			endif;
			
			//restowing back to orginal location - so ignore NotMarkedForDischarge error
			ignoreNotMarkedForDisch := theDischSC = aLC;
					
			dlrIDs.add(dlrID);
			theEditions.add(aLC);
		endif;
	
		theLoadSC := aLC.CM_VoyageROROController;
		
		//set this now - useful in validation
		ediStowAdviceTI.setLoadCC(loadCC);
		
		// PAR 29489 - switch the primary for a 40 footer
		if loadCC.isForty then
			if theLoadSC.getAftLC() = null then 		// there is no back end LC
				if theLoadSC.getFwdLC &lt;&gt; null then 		// there is a forward  LC
					theLoadSC := theLoadSC.getFwdLC; 	// switch to the forward LC
				endif;
			endif;
		
		endif;
		
		if _verifyOnly then
			//we miss this validation in the utl's if _verifyOnly, so do it here
			//also, we want to keep going for these warnings when doing this for real 
			//validate disch
			if theDischSC &lt;&gt; null then
				if not theDischSC.validateForEDIDischarge(ediStowAdviceTI) then
					continue;
				endif;
			endif;
			
			// PAR 29375 if general CARGO area then we only need 1 request
			if not theLoadSC.isContainerLC() and loadSlots.includes(theLoadSC) then
				continue;
			endif;
			
			if loadSlots.includes(theLoadSC) then
				//mulitple load to same slot
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED,theLoadSC.getFullId,"Load","Job Not Yet Created", 'Stowage', ediStowAdviceTI);
				continue;
			else
				if not theLoadSC.validateForEDILoad(ediStowAdviceTI, dlrIDs, ignoreNotMarkedForDisch) then
					continue;
				endif;
				loadSlots.add(theLoadSC);
				
				aftSlot := theLoadSC.getAftLC().CM_ROROSlotController;
			
				if ( loadCC.isForty or loadCC.isFortyFive or loadCC.isThirty or loadCC.isFiftyThree )
				and aftSlot &lt;&gt; null then
					//theSC is the forty front
					if loadSlots.includes(aftSlot) then
						//mulitple load to same slot
						// PAR 29375 app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED,aftSlot.getFullId,"Load","Job Not Yet Created", 'Stowage', ediStowAdviceTI);
						app.raiseCMException3(Tryin_creat_load_colou_codin_l,"40",theLoadSC.getFullId,aftSlot.getFullId, 'Stowage', ediStowAdviceTI);
						continue;
					
					else
						if not aftSlot.validateForEDILoad(ediStowAdviceTI, dlrIDs, ignoreNotMarkedForDisch) then
							continue;
						endif;
						loadSlots.add(aftSlot);
					
					endif;
				endif;
			endif;		
		endif;
		
		if moveType = LOAD_MOVETYPE then
			_passport.moveErrorsToSet(errorSet); // 30 Mar 2012	cnwrs1	Par 29077
			_passport.clearErrorsWarnings();
			
			app.myUtilityCA.utlCreateRORORequestAttribute(theLoadSC, theDischSC, true, loadCC, moveType, theEditions, _verifyOnly, _passport);
		else // DLR SOB
			theSlots.clear();
			theSlots.add(theDischSC);
			theSlotsAlt.clear();
			theSlotsAlt.add(theLoadSC);
			
			_passport.moveErrorsToSet(errorSet); // 30 Mar 2012	cnwrs1	Par 29077
			_passport.clearErrorsWarnings();
			app.myTrxUA.doUpdateRORORequestDLRSob(theSlots, theSlotsAlt, false, moveType, _passport);
		endif;
	endforeach;
	
	if not _passport.hasErrors() and _structure &lt;&gt; null then
		_passport.moveErrorsToSet(errorSet); // 30 Mar 2012	cnwrs1	Par 29077
		_passport.clearErrorsWarnings();
		
		app.myUtilityCA.utlCreateVoyageOOWCreationRORO(_structure,  _passport);
		
		if _passport.noErrors and _structure.myVoyage &lt;&gt; null then
			_structure.causeEvent(_structure.myVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, _structure); 
		endif;
	endif;
	
	_passport.addErrorsFromSet(errorSet);	// 30 Mar 2012	cnwrs1	Par 29077
	errorSet.clear();
	
	// we used to set edi status to DB loaded here  but this is now done at the end of the trx.
	
	_ediData.updateProgress(progressTS, msg, totalTIs, tiCount, true, _passport);

epilog
	_passport.addErrorsFromSet(errorSet);	// 30 Mar 2012	cnwrs1	Par 29077 just in case we got here via an exception
	
	delete strs;
	delete theEditions;
