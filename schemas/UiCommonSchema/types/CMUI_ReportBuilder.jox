    <JadeMethod name="setDefaultDateTimes" id="cbf0e831-269a-4280-9e2d-20d33b9715a9">
        <source>setDefaultDateTimes() protected;
// ---------------------------------------------------------------------------
// Created:     21 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
