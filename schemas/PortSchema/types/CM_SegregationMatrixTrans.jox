    <JadeMethod name="exportMyReferencesXML" id="fc1d8884-9372-4066-a101-f236e255ce8a">
        <source>exportMyReferencesXML(_file: File; _objArray: ObjectArray io);
/*
----------   ----------  --------------------------------------------------
Created:	29 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	_file.writeLine('&lt;myHazardClass1&gt;' &amp; self.myEntity1.CM_HazardClass.code &amp; '&lt;/myHazardClass1&gt;');
	_file.writeLine('&lt;myHazardClass2&gt;' &amp; self.myEntity2.CM_HazardClass.code &amp; '&lt;/myHazardClass2&gt;');
	if self.mySegregationRule &lt;&gt; null then
		_file.writeLine('&lt;segregationCondition&gt;' &amp; self.mySegregationRule.mySegregationCondition.code &amp; '&lt;/segregationCondition&gt;');
	endif;

end;


</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEntity1Code" id="bd4c8045-86ca-4b32-b96d-a845b13480ba">
        <source>getEntity1Code() : String;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if CM_HazardClass.hasInstance(self.myEntity1) then
		return self.myEntity1.CM_HazardClass.code;
	endif;

end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
