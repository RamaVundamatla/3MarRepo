    <JadeMethod name="outputFileGroup" id="423a022b-87c3-4d39-998d-36ecf07cedb3">
        <updating/>
        <source>outputFileGroup(_camTaskHistory :CM_CamTaskHistory input; _group :HugeStringArray; _count :Integer io) : String updating, protected;
/*
Purpose: refactored code	

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
19 Dec 2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	str	:String;
	strLine : String;
begin
	foreach str in _group do
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, str, null);
		_count := _count + 1;
	endforeach;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_group" type="HugeStringArray"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputFileMessage" id="0f44ca87-4e49-456f-84ff-b99714a8479d">
        <updating/>
        <source>outputFileMessage(_camTaskHistory : CM_CamTaskHistory input; _message : String; _coll :HugeStringArray input) : String updating;
//26 Mar 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	str	: String;
	camProtocol : CM_CamProtocol;
begin
	camProtocol := _camTaskHistory.camProtocol;
	str := _camTaskHistory.addFileDataLineEDIFACT(_message);
	
	if _coll &lt;&gt; null then
		_coll.add (str);
	endif;
	
	return str;
end;</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputTrailer_UNT" id="b249c2c5-31f1-4cb3-bf6f-ed7a612b3253">
        <updating/>
        <source>outputTrailer_UNT(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _count, _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars

begin
	return self.outputFileMessage(_camTaskHistory, self.makeUNTSegment (_protocol, _count, _seqNumber, _camTaskHistory.runDateTime), _coll);		//cnwmc5 - 16 Oct 2014 - CCMS 2380
epilog

end;</source>
