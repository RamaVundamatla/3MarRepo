    <JadeMethod name="doShowNavSearch" id="7a3e47d0-d4c7-4d0f-9a7f-7539e8af4560">
        <updating/>
        <source>doShowNavSearch() updating;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Date			Changed By	Reason
// ----------   ----------  --------------------------------------------------
// 27/03/2025	navlw1		JIRA-33938: MTN | Navigator Collapse Option
vars
	toolbar : CMUI_Toolbar;
begin
	toolbar := self.frmSearchToolbar;
	toolbar.showCaptions := false;

	if toolbar.visible = false then
		toolbar.addButton(self.btnSearchTV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnResetSearchTV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnCloseSearchTV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnCollapseNav, CMUI_Toolbar.Control_Alignment_Left); // navlw1 #JIRA-33938 27/03/2025
		toolbar.positionToolbarControls();
	endif;

	txtNavFind.selStart := 0;
	txtNavFind.selLength := txtNavFind.text.length;
	txtNavFind.setFocus;
	txtNavFind.parentAspect:=TextBox.ParentAspect_StretchRight;
	txtNavFind.zOrder(1);
	
	if frmFind.visible = true then
		doNavSearch;
	else
		//cnwmc5 - PAR 31334
		if app.isUsingSkin() then
			self.txtNavFind.top := 7;
			self.frmSearchToolbar.top := 2;
		endif;
		lstTest.height := lstTest.height - frmFind.height;
		lstTest.top := lstTest.top + frmFind.height;
		//  TFS 50421 toolbar.width := 750;
		txtNavFind.left := CMUI_ToolbarButton.WidthTotalWithoutCaption * 4.2; // navlw1 #JIRA-33938 27/03/2025
		txtNavFind.width := self.clientWidth - (CMUI_ToolbarButton.WidthTotalWithoutCaption * 4.2); // navlw1 #JIRA-33938 27/03/2025
		txtNavFind.top := 12; // TFS 50421
		toolbar.visible := true;
		frmFind.visible := true;
		txtNavFind.setFocus;
	endif;
end;</source>
    </JadeMethod>
