    <JadeMethod name="drawVoyageOverviewLines" id="4d21809f-3af7-40f2-a1f2-d96169f9cf99">
        <source>drawVoyageOverviewLines();
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	middle,
	frameWidth,
	bayLeft: Real;  
	//voyage : CM_Voyage;
	cellularStructure : CM_CellularVoyageStructure;
	bay : CM_Bay;
	bayVoyage : CM_BayVoyage;
	top : Real;
	showComments : Boolean;
	//bayOverviewDict : CMUI_BayOverviewByBayId;
	bayOverviewObj,
	lastBayOverviewObj,
	bayBeforeBridge: CMUI_BayOverviewObject;
	x1,x2,y1,y2,
	startX, startY,
	endX,endY,
	vertex,length: Real;
	lastHoldBayId,
	bridgeAfterBay: String;
	concave, useImages : Boolean;
	yOffset : Real;
	currentSidePicture : Picture;
begin
	if showComments then
/*
	
	Drawing something like this with elipse around it
		_____	
	   _______ 
	  _________
	  _________
	  _________
	  _________
	  _________
	  _________
	  _________
	  _________
	  |        |
	  |Bridge  |
	  |________|
	  _________
	  _________
	  _________
	  _________
	  _________
	  _________
	  _________
*/
	endif;

	self.myLabelFrame.clearGraphics;
	self.myPicSide1.clearGraphics;
	useImages:=self.myPicAft &lt;&gt; null and self.myPicBridge &lt;&gt; null and self.myPicFore &lt;&gt; null and self.myPicSide1 &lt;&gt; null;
	self.myLabelFrame.top:=0;
	self.myLabelFrame.drawTextAlign:=Window.DrawTextAlign_Center;

	cellularStructure:=self.myVoyage.myCellularVoyageStructure;
	
	if cellularStructure = null then // TFS 3631
		return;
	endif;
	
	if cellularStructure.allBayVoyagesById.size = 0 then
		return;
	endif;
	bridgeAfterBay := cellularStructure.bridgeAfterBay;
	self.getOverviewStructure(	cellularStructure);
	
	frameWidth:=BaseBayWidth + (offsetLeft * 2);
	
	y1:=0;
	
	if getStartFromTop then
		startY:=self.allBayOverviewObjects.first.y;
		endY:=self.allBayOverviewObjects.last.y;
	else
		startY:=self.allBayOverviewObjects.last.y;
		endY:=self.allBayOverviewObjects.first.y;
	endif;
	
	//draw the bridge start line
	bayBeforeBridge:=self.allBayOverviewObjects[bridgeAfterBay];
	self.myPicBridge.visible:=bayBeforeBridge &lt;&gt; null;
	
	//place the aft and forward images in the correct y position
	if useImages then
		self.myPicAft.parent:=self.myLabelFrame;
		self.myPicAft.left:=offsetLeft;
		self.myPicFore.parent:=self.myLabelFrame;
		self.myPicFore.left:=offsetLeft;
		if getStartFromTop then
			self.myPicFore.top:=self.offsetTop.Integer - self.myPicFore.pictureHeight.Integer ;
			self.myPicAft.top:=endY + bayLength;
			if bayBeforeBridge &lt;&gt; null and bayBeforeBridge = self.allBayOverviewObjects.last then
				self.myPicAft.top:=self.myPicAft.top + self.myPicBridge.height;
			endif;
		else
			self.myPicFore.top:=endY + bayLength;
			self.myPicAft.top:=self.offsetTop.Integer -self.myPicAft.pictureHeight.Integer ;
		endif;
	endif;		
	
	//place the bridge picture where it needs to be 
	if bayBeforeBridge &lt;&gt; null then
		self.myPicBridge.parent:=self.myLabelFrame;
		self.myPicSide1.parent:=self.myLabelFrame;
		self.myPicSide1.left:=offsetLeft;
		self.myPicBridge.left:=offsetLeft;
		self.myPicSide1.top:=startY;
		if getStartFromTop then
			self.myPicBridge.top:=bayBeforeBridge.y + bayLength;
		else
			self.myPicBridge.top:=bayBeforeBridge.y -  self.myPicBridge.pictureHeight;
		endif;
		
	else
		self.myPicSide1.parent:=self.myLabelFrame;
		self.myPicSide1.left:=offsetLeft;
		self.myPicSide1.top:=startY;
	endif;
	if getStartFromTop then
		self.myPicSide1.height:= self.myPicAft.top - startY;
	else
		self.myPicSide1.height:=self.myPicFore.top - startY;
	endif;
	
	self.myPicSide1.autoRedraw:=true;
	self.myPicSide1.drawTextAlign:=Window.DrawTextAlign_Center;
	currentSidePicture:=self.myPicSide1;
	if getStartFromTop then
		yOffset:= self.allBayOverviewObjects.first.y;
	else
		yOffset:=self.allBayOverviewObjects.last.y;
	endif;
	

	//draw the lines that seperate the bays and the bay ids
	foreach bayOverviewObj in self.allBayOverviewObjects do		
		x1:=bayOverviewObj.x; 
		x2:=bayOverviewObj.x + bayOverviewObj.length - 5;
		bayLeft:=x1 + (bayOverviewObj.length/2);
		if getStartFromTop then
			y1:=bayOverviewObj.y - yOffset;
			y2:=y1;
		else
			y1:=bayOverviewObj.y - yOffset + bayLength;
			y2:=y1-self.myPicSide1.drawTextHeight(bayOverviewObj.bayId);
		endif;	
		if bayOverviewObj.bayNumberInHold &gt;= 1 then		
			self.myPicSide1.drawLine( x1 ,y1,x2, y1,Black);
		endif;
		if getStartFromTop then
			self.myPicSide1.drawTextAt(bayOverviewObj.bayId,bayLeft,y2 ,Black);
		else
			self.myPicSide1.drawTextAt(bayOverviewObj.bayId,bayLeft,y2,Black);
		endif;
	endforeach;
	
	//make sure the bridge shows over the sides
	self.myPicBridge.zOrder(1);
	//set the height and width of the drawing frame;
	self.myLabelFrame.width:=frameWidth;
	if getStartFromTop then	
		self.myLabelFrame.height:=self.myPicAft.top + self.myPicAft.height;
	else
		self.myLabelFrame.height:=self.myPicFore.top + self.myPicFore.height;
	endif;
	
epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="getBayFromX" id="57cb0b41-8a06-4f07-8f1d-8f582d3894c1">
        <source>getBayFromX(_y : Real) : CM_BayVoyage;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	bay, bridgeHeight : Real;
	bayNo,
	bridgeNo: Integer;
	cellularStructure : CM_CellularVoyageStructure;
	bridgeAfterBay: String;
	bridgeBay,theBay : CM_BayVoyage;
	bridgeY : Real;
begin
	
	cellularStructure:=self.myVoyage.myCellularVoyageStructure;
	bridgeAfterBay:=cellularStructure.bridgeAfterBay;
	bridgeBay :=cellularStructure.allBayVoyagesById[bridgeAfterBay];
	if bridgeBay = null then	//PAR14282
		return null;
	endif;
	bridgeHeight :=self.myPicBridge.height;
	bridgeNo:=bridgeBay.ordinalBay;	
	bridgeY:=self.myPicBridge.top - self.offsetTop.Integer;


	// its before the bridge
	if _y  &lt; bridgeY then
		//get the bay it is from the top
		bay:=(_y/self.bayLength);// + 1;
		
		if self.getStartFromTop then
			bayNo:=bay.Integer + 1;
		else
			bayNo:=cellularStructure.allBayVoyagesByOrdinal.last.CM_BayVoyage.ordinalBay -bay.Integer;
		endif;
	// its after the bridge
	elseif _y &gt; bridgeY  then
		//epr par 15589 21/12/07
		//get the bay it is from after the bridge
		if bridgeY &gt; 0 then
			bay:=((_y - (bridgeY + bridgeHeight))  /self.bayLength);
		else
			bay:=_y/self.bayLength;
		endif;
		
		if self.getStartFromTop then
			bayNo:=bridgeNo + bay.Integer + 1;
		else
			bayNo:=bridgeNo - bay.Integer;
		endif;
	
	
	else
		return null;
	endif;
		
	theBay:=cellularStructure.allBayVoyagesByOrdinal[bayNo];
	if theBay &lt;&gt; null then
		return theBay;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_y" type="Real"/>
        <ReturnType type="CM_BayVoyage"/>
    </JadeMethod>
    <JadeMethod name="getBridgeHeight" id="1c9293e3-46fa-4f9e-b3dd-1f17214b1811">
        <source>getBridgeHeight() : Real;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myVoyage.myCellularVoyageStructure.bridgeAfterBay = null then
		return 0;
	endif;

	if self.myPicBridge = null then
		return (bayLength * 2);
	else
		return self.myPicBridge.pictureHeight;
	endif;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCellWidth" id="e61a72a1-0dc5-480d-ac74-83a59d7887f7">
        <source>getCellWidth()  :Real;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	return bayLength * cellWidthProportion;
	
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getOverviewBayStructure" id="90e07958-2b9d-4c83-b0c1-246ba2f80062">
        <source>getOverviewBayStructure(	bay : CM_Bay input;
							bayNo : Integer input;
							top: Real io;
							maxNoCells : Integer io) : CMUI_BayOverviewObject;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
constants
	ImageOffsetLeft = 5;
	
vars
	noCells: Integer;
	
	bayOverviewObj : CMUI_BayOverviewObject;
begin
	noCells:=bay.allCellsOnDeck.size.max(bay.allCellsUnderDeck.size);
	maxNoCells:=maxNoCells.max(noCells);

	create bayOverviewObj;
	bayOverviewObj.bayId:=bay.id;
	bayOverviewObj.bayNumberInHold:=bayNo;
	bayOverviewObj.x :=offsetLeft + ImageOffsetLeft;
	bayOverviewObj.length:=(BaseBayWidth - (ImageOffsetLeft*2)) - bayOverviewObj.x;
	bayOverviewObj.y:=top;
	top:=top + bayLength;

	return 	bayOverviewObj;

epilog

end;</source>
        <Parameter name="bay" type="CM_Bay" usage="input"/>
        <Parameter name="bayNo" type="Integer" usage="input"/>
        <Parameter name="top" type="Real" usage="io"/>
        <Parameter name="maxNoCells" type="Integer" usage="io"/>
        <ReturnType type="CMUI_BayOverviewObject"/>
    </JadeMethod>
    <JadeMethod name="getOverviewStructure" id="d36a0c5f-c0e0-4669-9a78-eff25d59a2c0">
        <source>getOverviewStructure( 	_cellularStructure : CM_CellularVoyageStructure input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	holdIter,
	bayIter : Iterator;
	hold : CM_Hold;
	bayNo,maxNoCells : Integer;
	bay : CM_Bay;
	bayOverviewObj : CMUI_BayOverviewObject;
	top,middle : Real;
	bridgeAfterBay : String;
begin
	
	top:=offsetTop;

	bridgeAfterBay := _cellularStructure.bridgeAfterBay;
	
	holdIter:=_cellularStructure.allHolds.createIterator;
	if getStartFromTop then
		while holdIter.next(hold) do
			bayNo:=1;
			bayIter:=hold.allBays.createIterator;
			while bayIter.next(bay) do
				bayOverviewObj:=self.getOverviewBayStructure(	bay,bayNo,top,maxNoCells); 
				self.allBayOverviewObjects.add(bayOverviewObj);	
				bayNo:=bayNo + 1;
				
				if bay.id = bridgeAfterBay then
					top:=top + self.getBridgeHeight;
					
				endif;
				
			endwhile;
			delete bayIter;
		endwhile;
		
	else
		top:=top;// - bayLength;
		while holdIter.back(hold) do
			bayIter:=hold.allBays.createIterator;
			bayNo:=hold.allBays.size;
			while bayIter.back(bay) do
			
			if bay.id = bridgeAfterBay then
				top:=top + self.getBridgeHeight;	
			endif;
			
				bayOverviewObj:=self.getOverviewBayStructure(bay,bayNo,top,maxNoCells); 
				self.allBayOverviewObjects.add(bayOverviewObj);
				bayNo:=bayNo - 1;
			endwhile;
			delete bayIter;
		endwhile;
	endif;
		
	delete holdIter;

epilog

end;</source>
        <Parameter name="_cellularStructure" type="CM_CellularVoyageStructure" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStartFromTop" id="7c122ca5-7f9c-4bec-9651-1949b60345ee">
        <source>getStartFromTop() : Boolean;
/*

Purpose:	start from top if the voyage is starboard berthed (startboard = right)		


Return Value:		


Date		Who		Reason
14 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if not flipVertical then
		return self.myVoyage.starboardBerthed;
	else
		return not self.myVoyage.starboardBerthed;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initControl" id="284c43ae-2ef9-43f9-8d99-f61ede368b98">
        <updating/>
        <source>initControl(_myLabelFrame : CMUI_ScrollableLabelsFrame;
			_voyage : CM_Voyage;
			_zoom   : Real;
			_screenSize : Real;
			_flipVertical : Boolean;
			_picAft,
			_picFore,
			_picBridge,
			_picSide1 : Picture;
			_offsetTop : Real)updating;

vars
	now : TimeStamp;
	tmpFontSize	: Real;
	
begin
	self.myLabelFrame:=_myLabelFrame;
	//Set up scrollable label
	self.myLabelFrame.drawMode 		:= self.myLabelFrame.DrawMode_Copy;
	self.myLabelFrame.drawFontName	:= 'Arial';	
	self.myLabelFrame.drawFontSize	:= 8;
	self.myLabelFrame.borderStyle	:= self.myLabelFrame.BorderStyle_Single;	
	self.myLabelFrame.ignoreSkin:=true;
	self.myVoyage:=_voyage;
	self.zoom:=_zoom;
	self.flipVertical:=_flipVertical;
	self.screenSize :=_screenSize;
	self.myPicAft:=_picAft;
	self.myPicAft.height:=self.myPicAft.pictureHeight;
	self.myPicAft.width:=self.myPicAft.pictureWidth;
	self.myPicFore:=_picFore;
	self.myPicFore.height:=self.myPicFore.pictureHeight;
	self.myPicFore.width:=self.myPicFore.pictureWidth;
	self.myPicBridge:=_picBridge;
	self.myPicBridge.height:=self.myPicBridge.pictureHeight;
	self.myPicBridge.width:=self.myPicBridge.pictureWidth;
	self.myPicSide1:=_picSide1;
	self.myPicSide1.width:=self.myPicSide1.pictureWidth;
	self.myPicSide1.autoRedraw:=true;
	self.myPicSide1.drawTextAlign:=Window.DrawTextAlign_Center;

	//for testing

	bayLength:= BaseBayLength; //lenth in pixels
	
	self.offsetLeft:=10;
	cellWidthProportion:= 0.4; 
	
	if self.zoom &gt; 0 then
		bayLength:=bayLength*zoom;
	else
	//if zoom is zero then fit to screen 
		if _screenSize &lt;&gt; null then	
		//( offsetTop *2)
			bayLength:=(_screenSize - self.myPicAft.height - self.myPicFore.height - getBridgeHeight )/(self.myVoyage.myCellularVoyageStructure.allBayVoyagesByOrdinal.size);
		endif;
	endif;
	
	if getStartFromTop then
		offsetTop:=self.myPicFore.height.Integer + _offsetTop.Integer;
	else
		offsetTop:=self.myPicAft.height.Integer  + _offsetTop.Integer;
	endif;

epilog

end;</source>
        <Parameter name="_myLabelFrame" type="CMUI_ScrollableLabelsFrame"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_zoom" type="Real"/>
        <Parameter name="_screenSize" type="Real"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <Parameter name="_picAft" type="Picture"/>
        <Parameter name="_picFore" type="Picture"/>
        <Parameter name="_picBridge" type="Picture"/>
        <Parameter name="_picSide1" type="Picture"/>
        <Parameter name="_offsetTop" type="Real"/>
    </JadeMethod>
</Class>
