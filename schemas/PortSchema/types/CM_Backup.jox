    <JadeMethod name="setProxy" id="0c4f63cc-e070-4a15-a7ee-df48d140c642">
        <updating/>
        <source>setProxy(_binaryBackupPath, _dbBackupPath, _journalLocalBackupPath, _binaryRemoteBackupPath, _dbRemoteBackupPath, _journalRemoteBackupPath:String; 
         _dbCompress, _dbOverwrite, _dbVerify, _debug, _journalCompress, _journalVerify, _purgeDBJournals, _purgeLocalJournals, _purgeRemoteJournals, _purgeSDSJournals: Boolean; 
         _journalNumber, _purgeLogDays: Integer; _sdsSecondaryBackup : Boolean; _databaseWorkers : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------
vars

begin
//	self.binaryBackupPath := _binaryBackupPath;
	self.dbBackupPath := _dbBackupPath;
	self.journalLocalBackupPath := _journalLocalBackupPath;
//	self.binaryRemoteBackupPath := _binaryRemoteBackupPath;
	self.dbRemoteBackupPath := _dbRemoteBackupPath;
	self.journalRemoteBackupPath := _journalRemoteBackupPath;
	self.dbCompress := _dbCompress;
//	self.dbOverwrite := _dbOverwrite;
//	self.dbVerify := _dbVerify;
	self.debug := _debug;
	self.journalCompress := _journalCompress;
	self.journalVerify := _journalVerify;
	self.purgeDBJournals := _purgeDBJournals;
	self.purgeLocalJournal := _purgeLocalJournals;
	self.purgeRemoteJournals := _purgeRemoteJournals;
	self.purgeSDSJournals := _purgeSDSJournals;	// CCMS1150 cnwrs1 04 July 2011
	self.journalNumber := _journalNumber;
	self.purgeJournalDays := _purgeLogDays;
	self.sdsSecondaryBackup := _sdsSecondaryBackup;	//cnwrs1 21 Jan 2010 ccms1150
	self.databaseWorkers := _databaseWorkers;	//cnwrs1 21 Jan 2010 ccms1150
end;</source>
        <Parameter name="_binaryBackupPath" type="String"/>
        <Parameter name="_dbBackupPath" type="String"/>
