    <JadeMethod name="longDisplay" id="4458d37f-ce56-4165-b71c-173f6e790308">
        <source>longDisplay(): String;

/*

Purpose:			


Return Value:		


Date		Who		Reason

*/

vars
	returnVal		: String;
	
begin
	returnVal := self.String &amp; ", actionTimeStamp=" &amp; self.actionTimeStamp.String;
		
	if self.lockExceptionTimeStamp &lt;&gt; null then
		returnVal := returnVal &amp; ", lockExceptionTimeStamp=" &amp; self.lockExceptionTimeStamp.String;
	endif;
	
	return returnVal;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
