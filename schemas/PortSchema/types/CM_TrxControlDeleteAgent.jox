        <updating/>
        <source>trxDeleteDBCargoPhotosForTI(_trackedItem : CM_TrackedItem; _ts : TimeStamp; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 01 Dec 2009 by cnwdz2
// -------------------------------------------
// SPECIAL TRX FOR GARBAGE COLLECTION.
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX
	on LockException do app.alertLockExceptionHandler(exception);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityDA.utlDeleteCargoPhotosForTI(_trackedItem, _ts, _agent);
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_ts" type="TimeStamp"/>
