    <JadeMethod name="getMenuDetails" id="5f8974ac-f501-417b-8eed-6dc4508ebb1f">
        <source>getMenuDetails(_short : Boolean;_displayMode : Integer): String;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		This function is only called on a blockStack or Sub-block
//				stack, and extracts the restriction and optionally total # of
//				containers in the stack. This is added to the TerminalArea Menu Caption
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - remove location restrictions
vars
	aString : String;
begin

	if not _short then
		aString := self.getTAEnqRestrictionLocString();		// PAR 12237
	endif;
	if self.myLocationsController &lt;&gt; null then
		if _displayMode = DISPLAY_MODE_ACTUAL then
			//aString := aString &amp; " " &amp; self.myLocationsController.allTrackedItems.size.String;
			aString := aString &amp; " " &amp; self.myLocationsController.getTrackedItemCount.String;//cnwrd1 31736 break bulk counting
		elseif _displayMode = DISPLAY_MODE_QUEUE then
			aString := aString &amp; " " &amp; self.myLocationsController.allQueuedFutureMoves.size.String;
		elseif _displayMode = DISPLAY_MODE_PLAN then
			aString := aString &amp; " " &amp; self.myLocationsController.allPlannedFutureMoves.size.String;
		endif;
	endif;
	
	if aString.trimBlanks &lt;&gt; null then
		aString := "[" &amp; aString.trimBlanks &amp; "]" ;
	endif;
	
	return aString;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <Parameter name="_displayMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyLocationsController" id="f03b37a6-5551-4f48-8d9c-63cf28c0b8ac">
