    </JadeMethod>
    <JadeMethod name="setSubHeading" id="f5c4e796-65ec-4f34-b1a9-704571c6a278">
        <updating/>
        <source>setSubHeading(pSubHeading : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm		: GTE_ContainerFrame;
	menuAction	: CMUI_MenuAction;
	
begin
	menuAction := self.myMenuAction;
	if menuAction &lt;&gt; null then
		//menuAction.setSubHeading(pSubHeading);
		menuAction.setHeading(pSubHeading);
		self.caption := menuAction.heading;
		foreach contFrm in self.allContainerFrames do
			contFrm.setId(menuAction.heading);
		endforeach;
	endif;

end;</source>
        <Parameter name="pSubHeading" type="String"/>
    </JadeMethod>
