            <optionsList>
                <value>0 - None</value>
                <value>1 - Inset</value>
                <value>2 - Raised</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="bevelInnerWidth">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelOuter">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Inset</value>
                <value>2 - Raised</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="bevelOuterWidth">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelShadowColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderColorSingle">
