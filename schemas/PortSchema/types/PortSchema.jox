    <JadeMethod name="printReportViaTextFile" id="18d4ac14-64ca-4599-9215-b22237451798">
        <source>printReportViaTextFile(_reportName : String);
//----------------------------------------------------------------------
// Created by 	cnwjre1
// Date 		July 2011
//
// Par 27851 printing to lineflow printer
// Date  		User  		Change
//	2 Aug 2011	cnwjre1		27950 add the fontSize parameter, set font name to Courier, add the isSpecial show the file via notepad
//  4 Aug 2011  cnwjre1		27966 add fontName parameter, default to Courier
// 14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
// 23 Feb 2018	jlgmd1		TFS #37318 - JMT - Printing with extra TXT formatting does not display an error if the 'New Page Character' is missing
//----------------------------------------------------------------------
vars
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	ls					: Boolean;
	reportString 		: String;
	reportName			: String;
	fontSize,
	pageWidth, pageHeight, startTop : Integer;
	outputType,
	endOfPageStr : String;
	exitValue	: Integer;
	args 		: StringArray;
	workFile			: File;
	outputFileName		: String;
	reportStr,
	printStr	: String;
	fontName	: String;
	pos1,
	pos2,
	pos3,
	count	: Integer;
	workStr	: String;
	charPosition : Integer;
	endOfPageStrLen	: Integer;
	didPrint			: Boolean;
	
begin
	reportString := _reportName;
	fontName := "Courier";			// default if not specified
	// We can store the additional info in the config (i.e. suffix with "?TXT?width?height?startpos?newpagechar?fontSize?fontName")
	// use "?" delimiter as this is not allowed in JRW report names
	pos1 := 1;
	while true do
		pos2 := reportString.pos("?", pos1);
		if pos2 &gt; 0 then
			pos3 := reportString.pos("?", pos2+1);
			if pos3 &gt; 0 then
				workStr := reportString[pos2+1:pos3-pos2-1];
			elseif pos2 &lt; reportString.length then
				workStr := reportString[pos2+1:end];
			endif;
			count := count + 1;
		else
			break;
		endif;
		pos1 := pos2 + 1;
		if count = 1 then
			outputType := workStr;
		elseif count = 2 then
			pageWidth := workStr.Integer;
		elseif count = 3 then
			pageHeight := workStr.Integer;
		elseif count = 4 then
			startTop := workStr.Integer;
		elseif count = 5 then
			endOfPageStr := workStr;
		elseif count = 6 then
			fontSize := workStr.Integer;
		elseif count = 7 then
			fontName := workStr;
		else
			break;
		endif;
	endwhile;

	pos2 := reportString.pos("?", 1);
	if pos2 &gt; 1 then
		reportName := reportString[1:pos2-1];
	else
		reportName := reportString;
	endif;
	
	jrwManager := app.createReportWriterManager();
	jrwReport := jrwManager.getReport(reportName);
	if jrwReport = null then
		if jrwReport = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Driver Instructions report class not specified in gate config (" &amp; reportString &amp; " does not exist)");
			return;
		endif;
	endif;
	// validate the options
	if outputType &lt;&gt; "TXT" or
	   pageWidth = 0 or
	   pageHeight = 0 or
	   endOfPageStr = null or
	   fontSize = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, "Report text print options incorrect: " &amp; reportString &amp; ", expecting format of 'report name?TXT?pagewidth?pageheight?startpos?newpagechar?fontSize?fontName'");
		return;
	endif;
	
	// create temporary file
	outputFileName := app.getTempDir &amp; app.relativeMachineMicros.String &amp; "_" &amp;
					self.getInstanceIdForObject64(process).String &amp; "_" &amp; 
					self.getInstanceIdForObject64(self).String &amp; '.txt';
	
	jrwReport.setOutputDestination(JadeReportWriterReport.TEXT);
	jrwReport.setOutputFileTitle(outputFileName);
	
	// do not allow print preview
	jrwReport.setPreviewOptions(false, true, false, true, null);
	
//	app.cmsBeginLoad(ls);

	jrwReport.run;

	app.printer.abort();

	// Read the created file back into the system and send to printer
	create workFile transient;
	
	workFile.fileName := outputFileName;
	workFile.usePresentationFileSystem := true;
	if (not workFile.isAvailable) then
		app.raiseUnexpectedProgramError(class.name, method.name, outputFileName &amp; ' was not available');
		return;
	endif;

	workFile.kind := workFile.Kind_Binary;
	workFile.open;
	reportStr := workFile.readBinary(workFile.fileLength).String;
	
	// Add the length of the CrLf to the end of page identifier
	endOfPageStrLen := endOfPageStr.length + CrLf.length; //PAR27988 cnwsh3 09/08/2011

	app.printer.printPreview := false;
	app.printer.setCustomPaperSize(pageWidth, pageHeight);

	while true do
		charPosition := 1;
		//Look for the special character set.
		charPosition := reportStr.pos(endOfPageStr, 1);
		if charPosition &gt; 0 then
			//Set the print string to be from the begining of the report string to where the special character set starts.
			printStr := reportStr[1:charPosition-1];
			
			//Set up the printer for this run, print the string and reset the printer ready for the next time through.
			app.printer.drawFontName := fontName;
			app.printer.drawFontSize := fontSize;

			app.printer.drawTextAt(printStr, 0, startTop, Black);
			
			app.printer.newPage;
			app.printer.close();
			didPrint := true;
			
			//Set the report string to begin just after the special character set we found.
			if charPosition + endOfPageStrLen &gt; reportStr.length then
				break;
			endif;
			reportStr := reportStr[charPosition + endOfPageStrLen:end];
		else
			break;
		endif;
	endwhile;
	
	// TFS #37318 jlgmd1 23/02/2018
	if not didPrint then
		app.raiseUnexpectedProgramError(class.name, method.name, outputFileName &amp; ' did not contain the New Page Character');
	endif;
	
	// for debugging show the file if special - brings up Notepad modally so the file is kept until notepad is closed
	if app.isSpecial then
		if workFile &lt;&gt; null and not node.isServerNode then
			create args transient;
			args[1] := workFile.fileName;
			node.createExternalProcess(".", "notepad", args, "notepad", true, true, exitValue);
		endif;
	endif;

	if workFile &lt;&gt; null and didPrint then
		workFile.purge();
	endif;

epilog
	delete jrwManager;

	delete workFile;
	delete args;
//	app.cmsEndLoad(ls);
	app.printer.abort();
end;</source>
        <Parameter name="_reportName" type="String"/>
    </JadeMethod>
    <JadeMethod name="printerFixPAR34782" id="bc8785b9-f1a2-4608-83c5-f2ab49a90ebb">
        <source>printerFixPAR34782(_jadeReport : JadeReport);
// ---------------------------------------------------------------------------
// Created:     20 September 2004 by cnwrs2
//
// Purpose:     JADE PAR 34782
//				blank page being printed prior to first page of report
//				need to set printer attributes before printer opened
// ---------------------------------------------------------------------------
vars
	page	: JadePrintPage;
	data : JadePrintData;
	int : Integer;
begin

	if _jadeReport = null then
		return;
	endif;
	
	page := _jadeReport.getPage(1);
	if page &lt;&gt; null then
		app.printer.orientation := page.orientation;
		// do NOT set paperSource as get an error if
		// printer does not support original paper source
		// If need to change this when will need to trap for
		// expection
		//app.printer.paperSource := app.printer.getDefaultPaperSource();//page.paperSource;
		app.printer.documentType := page.documentType;
	endif;
	// to here
end;</source>
        <Parameter name="_jadeReport" type="JadeReport"/>
    </JadeMethod>
    <JadeMethod name="processGlobalConstantGroup" id="d0707a23-419d-45a7-b147-708ab4e919f7">
        <source>processGlobalConstantGroup(pSchemaName, pGroupName, pCallBackMethod : String; pCallBackObject : Object);
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	passport	: CM_Passport;
begin

	baseScm := rootSchema.getSchema(pSchemaName);
	category := baseScm.getCategory(pGroupName);
	constDict := category.getConstants();
	passport := app.myPassport;
	passport.clearErrorsWarnings();   //par15235 cnwrs1 Nov 2007

	foreach const in constDict do
		pCallBackObject.sendMsgWithParams(pCallBackMethod, const, passport);
		if passport &lt;&gt; null
		and passport.hasErrors then
			break;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="pSchemaName" type="String"/>
        <Parameter name="pGroupName" type="String"/>
        <Parameter name="pCallBackMethod" type="String"/>
        <Parameter name="pCallBackObject" type="Object"/>
    </JadeMethod>
