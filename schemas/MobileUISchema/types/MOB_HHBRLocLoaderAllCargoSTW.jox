    <JadeMethod name="handleNotifications" id="d2c303dd-9e14-4f9d-8020-5e49aed05099">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

begin

	if theObject &lt;&gt; null and theObject.isKindOf( CM_ReserveSelection ) then
		if self.btnThree.caption = app.getErrorString(Refresh) then
			//to indicate a refresh is potentially needed.
			self.btnThree.foreColor := Red;
		endif;
		return;
	endif;

	inheritMethod(eventType, theObject, eventTag, userInfo);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
