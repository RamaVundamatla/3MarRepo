epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="redrawGridArea" id="60369964-11c0-4c1e-b446-4337df099ce7">
        <updating/>
        <source>redrawGridArea() updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/06/2009	consw1		PAR 20004 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	saveWidth, saveHeight : Real;
	saveHLabelWidth : Real;
	
begin
	saveWidth := self.myGridAreaFrame.width;
	saveHeight := self.myGridAreaFrame.height;
	saveHLabelWidth :=self.myHLabelsFrame.width;

	self.updatePictures;
	
	inheritMethod();
	
	self.myGridAreaFrame.width := saveWidth;
	self.myGridAreaFrame.height := saveHeight;
	self.myHLabelsFrame.width := saveHLabelWidth;
end;</source>
    </JadeMethod>
    <JadeMethod name="redrawWheels" id="16f62904-d0cf-42da-94a4-57e52bf14835">
        <source>redrawWheels();

/*

Purpose:			Redraw the wheels.  The wheels are used to indicate if the wagon has been selected.

Parameters:			

Return Value:		


Date		Who		Reason
04 Jun 2009	consw1	Initial creation

*/

vars
	gridPoint : CMUI_GridPoint;
	lastColumn : Integer;
	
begin
	lastColumn := self.allGridColumns.size;

	foreach gridPoint in self.allGridPoints do
		if gridPoint.isKindOf(YRD_WagonWheels) then
			if gridPoint.column = 1 or gridPoint.column =  lastColumn then
				gridPoint.drawSelf(self.myGridAreaFrame);
			endif;
		endif;
		if gridPoint.isKindOf(YRD_WagonBody) and self.isWellcar then	// to redraw the well car wheels	Par 35346 / CCMS 1408
			if gridPoint.column = 1 then
				gridPoint.YRD_WagonBody.drawBody(self.myGridAreaFrame);
			endif;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectSinglePoint" id="f6a7be82-c2a6-42c1-8578-626c062e860c">
        <updating/>
        <source>selectSinglePoint(x: Real; y: Real): CMUI_GridPoint updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2009	consw1	Initial creation

*/

vars
	gridPoint, returnPoint : CMUI_GridPoint;
	lastColumn : Integer;
	toggleWagonSelected : Boolean;
	wasWagonSelected : Boolean;
	
begin
	gridPoint := self.convertPositionToGridPoint(x, y);
	wasWagonSelected := self.isWagonSelected();

	returnPoint := inheritMethod(x, y);

	if gridPoint &lt;&gt; null and (gridPoint.isKindOf(YRD_WagonBody) or gridPoint.isKindOf(YRD_WagonWheels)) then
		//  Clicked on wagon - toggle wagon selection if not already done
		toggleWagonSelected := wasWagonSelected = self.isWagonSelected();
	endif;
	
	if toggleWagonSelected then
		foreach gridPoint in self.allGridPoints do
			if gridPoint.isKindOf(YRD_WagonBody) and gridPoint.column = 1 then
				if self.allSelectedPoints.includes(gridPoint) then
					self.allSelectedPoints.remove(gridPoint);
				else
					self.allSelectedPoints.add(gridPoint);
				endif;
				break;
			endif;
		endforeach;
	endif;
	
	if wasWagonSelected &lt;&gt; self.isWagonSelected() then
		//  Redraw wagon wheels to highlight selection change
		self.redrawWheels();
	endif;

	return returnPoint;
	
epilog

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="selectWagon" id="d24dfe1a-8377-46d6-b833-83273c69d840">
        <updating/>
        <source>selectWagon() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jun 2009	consw1	Initial creation

*/

vars
	gridPoint : CMUI_GridPoint;
	
begin
	foreach gridPoint in self.allGridPoints do
		if gridPoint.isKindOf(YRD_WagonBody) and gridPoint.column = 1 then
			if not self.allSelectedPoints.includes(gridPoint) then
				self.allSelectedPoints.add(gridPoint);
				//  Redraw wagon wheels to highlight selection change
				self.redrawWheels();
			endif;
			return;
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDisabledAppearance" id="94625e1a-e828-4a6a-8f90-7ed8ed8ae3fe">
        <updating/>
        <source>setDisabledAppearance(pFilterTrain : CM_Train; pWagon : CM_Wagon) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2010 by cnwab1
//
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 18/02/2010	consw1		PAR 21739 - Unarrived train cargo does not show colours
// ---------------------------------------------------------------------------

vars

begin
	if self.isOutward then
		self.disabledAppearance := (pFilterTrain &lt;&gt; null and pWagon.myTrainOutwards &lt;&gt; pFilterTrain);
	else
		self.disabledAppearance := (pFilterTrain &lt;&gt; null and pWagon.myTrainInwards &lt;&gt; pFilterTrain);
		if not self.disabledAppearance then	// 01 Sep 2009	NDL	CCMS 1067
			self.disabledAppearance := (self.myRailLine &lt;&gt; null and not pWagon.confirmed);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="pFilterTrain" type="CM_Train"/>
        <Parameter name="pWagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f985a0eb-c834-4f16-b9df-70194d415604">
        <updating/>
        <source>setForCreate(pWagon : CM_Wagon; pOutward : Boolean; pTrain : CM_Train; pRailLine : CM_RailLine; pFilterTrain : CM_Train;
		pRow, pCol, pColWagon, pColBack, pColLoc, pMaxHeight : Integer;
		showUnconfirmed : Boolean; singleWagonArea : Boolean;
		_controller : CMIF_DrawingAttrController input) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 24/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 12/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	cWagonController	: CM_WagonController;
	yWagonRow,
	yWagonTLRow,
	yWagonActualRow	: YRD_WagonRow;
	yWagonCCRow		: YRD_WagonRow;
	yWagonCol		: YRD_WagonColumn;
	yWagonPoint		: YRD_WagonPoint;
	yWagonTL		: YRD_WagonBody;
	yWagonWheels	: YRD_WagonWheels;
	yWagonColourCode: YRD_WagonColorCode;
	idx				: Integer;
	boxcarLength : Integer;
	doorPosArray : IntegerArray;
	
begin

	beginLoad;

	self.isOutward		:= pOutward;
	self.singleWagonOnly := singleWagonArea;

	self.row			:= pRow;
	self.column			:= pCol;
	
	self.colourBack 	:= pColBack;
	self.colourWagon 	:= pColWagon;
	self.colourLocation := pColLoc;
	self.myTrain	 	:= pTrain;
	self.myRailLine 	:= pRailLine;
	self.maxStackHeightForRailLine := pMaxHeight;

	if pWagon = null then
		return;
	endif;

	self.setDisabledAppearance(pFilterTrain, pWagon);

	if (not showUnconfirmed and not pWagon.confirmed) then
		return;
	endif;	
	
	self.label		:= pWagon.id;
	self.myWagon	:= pWagon;
	
	create yWagonRow transient;
	yWagonRow.setForCreate(1, self);
	create yWagonTLRow transient;
	yWagonTLRow.setForCreate(2, self);
	create yWagonActualRow transient;
	yWagonActualRow.setForCreate(3, self);
	create yWagonCCRow transient;
	yWagonCCRow.setForCreate(4, self);
	
	idx := 0;

	if pWagon.isBoxcar then	//19 Mar 2013	NDL	Par 31278
	
		create doorPosArray transient;
		cWagonController := pWagon.allLocationsControllersArray.first;
		pWagon.getBoxcarLengthAndDoorPosition(boxcarLength,doorPosArray);
		
		foreach idx in 1 to boxcarLength do
			
			create yWagonCol transient;
			yWagonCol.setForCreate(cWagonController.id, idx, self);
	
			create yWagonPoint transient;
			yWagonPoint.setForCreate(cWagonController, yWagonRow, yWagonCol, self, pMaxHeight, _controller);
			yWagonPoint.boxcarLocIndex := idx;
			
			if pWagon.myWagonClass &lt;&gt; null and pWagon.myWagonClass.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicBulk then // TFS 49523 SET LAST COLUMN
				if idx = boxcarLength then // TFS 49523 
					yWagonPoint.isBoxcarDoor := true; // TFS 49523 
				endif; // TFS 49523 
			
			else // TFS 49523 
				if doorPosArray.includes(idx) then
					yWagonPoint.isBoxcarDoor := true;
				endif;
			endif; // TFS 49523 
	
			create yWagonTL transient;
			yWagonTL.setForCreate(cWagonController, yWagonTLRow, yWagonCol, self);
	
			if idx = 1 then	//02 Oct 2014	NDL	Par 34981 
				create yWagonWheels transient;
				yWagonWheels.setForCreate(cWagonController, yWagonActualRow, yWagonCol, self);
			endif;
			
			//if idx = 1 and self.isOutward and not self.disabledAppearance then
			if idx = 1 and (( self.isOutward and not self.disabledAppearance ) or pWagon.hasMasterCargoRestriction ) then	//12 Feb 2014	NDL	Par 33439
				create yWagonColourCode transient;
				yWagonColourCode.setForCreate(cWagonController, yWagonCCRow, yWagonCol, self);
			endif;
		endforeach;
		
	elseif pWagon.isFlatcar or pWagon.isWellcarVisit then
	
		if not self.flipHorizontal then
			foreach cWagonController in pWagon.allLocationsControllersArray do
	
				idx := idx + 1;
				create yWagonCol transient;
				yWagonCol.setForCreate(cWagonController.id, idx, self);
		
				create yWagonPoint transient;
				yWagonPoint.setForCreate(cWagonController, yWagonRow, yWagonCol, self, pMaxHeight, _controller);
		
				create yWagonTL transient;
				yWagonTL.setForCreate(cWagonController, yWagonTLRow, yWagonCol, self);
		
				//02 Oct 2014	NDL	Par 34981  - we weren't using these objects.
				if idx = 1 or idx = pWagon.allLocationsControllersArray.size then
					create yWagonWheels transient;
					yWagonWheels.setForCreate(cWagonController, yWagonActualRow, yWagonCol, self);
				endif;
				
				//if idx = 1 and self.isOutward and not self.disabledAppearance then
				if idx = 1 and (( self.isOutward and not self.disabledAppearance ) or pWagon.hasMasterCargoRestriction ) then	//12 Feb 2014	NDL	Par 33439
					create yWagonColourCode transient;
					yWagonColourCode.setForCreate(cWagonController, yWagonCCRow, yWagonCol, self);
				endif;
			endforeach;
		else
			foreach cWagonController in pWagon.allLocationsControllersArray reversed do
	
				idx := idx + 1;
				create yWagonCol transient;
				yWagonCol.setForCreate(cWagonController.id, idx, self);
		
				create yWagonPoint transient;
				yWagonPoint.setForCreate(cWagonController, yWagonRow, yWagonCol, self, pMaxHeight, _controller);
		
				create yWagonTL transient;
				yWagonTL.setForCreate(cWagonController, yWagonTLRow, yWagonCol, self);
		
				//02 Oct 2014	NDL	Par 34981  - we weren't using these objects.
				if idx = 1 or idx = pWagon.allLocationsControllersArray.size then
					create yWagonWheels transient;
					yWagonWheels.setForCreate(cWagonController, yWagonActualRow, yWagonCol, self);
				endif;
				
				//if idx = 1 and self.isOutward and not self.disabledAppearance then
				if idx = 1 and (( self.isOutward and not self.disabledAppearance ) or pWagon.hasMasterCargoRestriction ) then	//12 Feb 2014	NDL	Par 33439
					create yWagonColourCode transient;
					yWagonColourCode.setForCreate(cWagonController, yWagonCCRow, yWagonCol, self);
				endif;
			endforeach;
		endif;
	
	elseif pWagon.isSkeletonCar then	// TFS 2533
		cWagonController := pWagon.allLocationsControllersArray.first;
		pWagon.getBoxcarLengthAndDoorPosition(boxcarLength, null);

		foreach idx in 1 to boxcarLength do
			create yWagonCol transient;
			yWagonCol.setForCreate(cWagonController.id, idx, self);
	
			create yWagonPoint transient;
			yWagonPoint.setForCreate(cWagonController, yWagonRow, yWagonCol, self, pMaxHeight, _controller);
			if idx.bitAnd(2) = 2 then
				yWagonPoint.isSkeletonCarArm := true;
			endif;
			yWagonPoint.boxcarLocIndex := idx;
	
			create yWagonTL transient;
			yWagonTL.setForCreate(cWagonController, yWagonTLRow, yWagonCol, self);
	
			if idx = 1 or idx = boxcarLength then
				create yWagonWheels transient;
				yWagonWheels.setForCreate(cWagonController, yWagonActualRow, yWagonCol, self);
			endif;
	
			if idx = 1 and (( self.isOutward and not self.disabledAppearance ) or pWagon.hasMasterCargoRestriction ) then
				create yWagonColourCode transient;
				yWagonColourCode.setForCreate(cWagonController, yWagonCCRow, yWagonCol, self);
			endif;
		endforeach;
	endif;
	
	
epilog
	endLoad;
	delete doorPosArray;
end;</source>
        <Parameter name="pWagon" type="CM_Wagon"/>
        <Parameter name="pOutward" type="Boolean"/>
        <Parameter name="pTrain" type="CM_Train"/>
        <Parameter name="pRailLine" type="CM_RailLine"/>
        <Parameter name="pFilterTrain" type="CM_Train"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <Parameter name="pColWagon" type="Integer"/>
        <Parameter name="pColBack" type="Integer"/>
        <Parameter name="pColLoc" type="Integer"/>
        <Parameter name="pMaxHeight" type="Integer"/>
        <Parameter name="showUnconfirmed" type="Boolean"/>
        <Parameter name="singleWagonArea" type="Boolean"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setGridRowColPositions" id="71a4c362-4085-49f2-8152-388cbe91ae3b">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>setGridRowColPositions() updating, serverExecution;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
constants
	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 20;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	ColWidth		: Integer = 10;
	RowHeight		: Integer = 10;
vars
	tmpRow		: CMUI_GridRow;
	tmpCol		: CMUI_GridColumn;
	yWagonRow	: YRD_WagonRow;
	yWagonCol	: YRD_WagonColumn;
	theRowHeight,
	theColWidth,
	tmpPos1,
	tmpPos2		: Real;
	firstTime	: Boolean;
	maxHeight,
	rowHeightTI	: Integer;
begin
	// set to the heightest stacked wagon on the rail line
	rowHeightTI := RowHeight * self.maxStackHeightForRailLine;
		
	if self.myWagon = null then
		// Set the height of a blank wagon area to the same as the  height of a wagon.
		// The height of a wagon is made up of:
		//   a container that is RowHeight
		//   a body that is RowHeight div 2
		//   wheels that are RowHeight div 2
		//   multiplied by the scalefactor
		//   plus margins btwn the parts and at top and bottom that equal 11
		self.totalPointHeight := ((RowHeight + rowHeightTI) * self.scaleYFactor) + 15 + YRD_WagonColorCode.Height;
		// set the width of a blank position to the width of a wagon with 5 controllers
		// but not smaller than the minimum position width
		self.totalPointWidth := ColWidth * 5 * self.scaleXFactor;
		return;
	endif;

	theColWidth	 := ColWidth * self.scaleXFactor;

	foreach tmpRow in self.allGridRows do
		yWagonRow := tmpRow.YRD_WagonRow;

		if yWagonRow.row = 1 then	// Locations
			theRowHeight := rowHeightTI * self.scaleYFactor;
			tmpPos1 := 5;  // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; this effects the drag drop. in drag drop minus 5 from Y
			tmpPos2 := tmpPos1 + theRowHeight;//(yWagonRow.row * theRowHeight); 
		elseif yWagonRow.row = 2 then	// TwistLocks
			theRowHeight := (RowHeight div 2) * self.scaleYFactor;
			tmpPos1 := tmpPos2 + 1; // tmpPos2 set above by first iteration
			tmpPos2 := tmpPos1 + theRowHeight; 
		elseif yWagonRow.row = 3 then	// Wheels
			theRowHeight := (RowHeight div 2) * self.scaleYFactor;
			tmpPos1 := tmpPos2 + 2; // tmpPos2 set above by first iteration
			tmpPos2 := tmpPos1 + theRowHeight; 
		elseif yWagonRow.row = 4 then	// Colour Code
			theRowHeight := YRD_WagonColorCode.Height;
			tmpPos1 := tmpPos2 + 5; // tmpPos2 set above by first iteration
			tmpPos2 := tmpPos1 + theRowHeight; 
		endif;
		yWagonRow.setYPos(tmpPos1, tmpPos2);
	endforeach;
	
	self.y1 := tmpPos1; //tmpPos2;
	self.y2 := tmpPos2 + 1; //WagonHeight;	// height of wagon body
	self.totalPointHeight := self.y2 + 1; //BottomMargin;

	firstTime := true;
	foreach tmpCol in self.allGridColumns do
		yWagonCol := tmpCol.YRD_WagonColumn;
		tmpPos1 := LeftMargin + ((yWagonCol.column - 1) * theColWidth);
		tmpPos2 := tmpPos1 + theColWidth;
		yWagonCol.setXPos(tmpPos1, tmpPos2);
		if firstTime then
			firstTime := false;
			self.x1 := tmpPos1;
		endif;
	endforeach;
	
	self.totalPointWidth := tmpPos2 + RightMargin;
	self.x2 := tmpPos2;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updatePictures" id="6b320f46-ae5c-469f-8897-6aef5d32a419">
        <updating/>
        <source>updatePictures() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 07/06/24		jlier1 TFS 64530
vars
	aWagonBody : CMUI_GridPoint;
	wagonFrame	: CMUI_GridAreaFrame;
	lPicture : Binary;
	aController : CM_WagonController;	
	invalidController,
	available : Boolean;
begin
	
	self.pictureAvail := self.mySDF.picture1;
	self.pictureUnavail := self.mySDF.picture2;
	self.pictureTLsUp := self.mySDF.picture3;
	self.pictureHasTLs := self.mySDF.picture4;
	
	on Exception do app.handleDeletedObject(exception,aController,invalidController);
	
	foreach aWagonBody in self.allGridPoints do
		if aWagonBody.isKindOf(YRD_WagonBody) then
			invalidController:=false;
			aController := aWagonBody.myLocationsController.CM_WagonController;
			available:= aController.isAvailable;
			if aController = null or invalidController then
				lPicture := self.pictureUnavail;			
			elseif aController.twistlocksAreUp then
				lPicture := self.pictureTLsUp;
			elseif aController.hasTwistlocks then
				lPicture := self.pictureHasTLs;
			elseif available then
				lPicture := self.pictureAvail;
			else
				lPicture := self.pictureUnavail;
			endif;
			aWagonBody.YRD_WagonBody.picture := lPicture;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
</Class>
