        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearchTV_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	prof     : JadeProfiler;
	folder   : String;
	clock	 : String;
	now 	 : TimeStamp;
	strPar   : String;
begin
	
	if process.isMohamed  then
	
		strPar := self.getName();
		clock  := app.clock.String;
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 50;
		prof.fileName := folder&amp;"\MA" &amp; '\'  &amp;" -" &amp;strPar &amp; "- " &amp; clock.String &amp;".csv";
		prof.clearMethodCache();
		prof.start;
	endif;
	
	app.mousePointer	:=	Busy;
	self.zDoSearch();
	self.tblData.setFocus();
epilog
	app.mousePointer	:=	Idle;
		if prof &lt;&gt; null then
		prof.report;
		delete prof;
		process.removeMethodProfileInfo();
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
