    <JadeMethod name="translateToSearchValueForWeb" id="f36e331f-51d8-4e8a-8197-992e36ce97f3">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	int : Integer;
	rtnVal, collStr : String;
	strArray : StringArray;
	coll : IntegerArray;

begin
	if _value.isKindOf(Integer) then
		return app.planningStateEnumToString(_value.Integer);
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create coll transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach rtnVal in strArray do
				coll.add(app.planningStateStringToEnum(rtnVal));
			endforeach;
			return coll;
		endif;
		
		if not _sending then
			return app.planningStateStringToEnum(_value.String);
		endif;
		
		return _value.String;
		
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			rtnVal := rtnVal &amp; app.planningStateEnumToString(int) &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnVal := rtnVal[1:rtnVal.length-2];
		return rtnVal;
		
	endif;
		
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
