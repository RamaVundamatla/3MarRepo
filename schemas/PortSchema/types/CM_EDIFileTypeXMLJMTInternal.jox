//09 Dec 2014	cnwrs1	PAR #34713 - .NET EDI transform integration
vars

begin
	_ediDataClass := app.myRoot.myEdiConfig.getEDIDataClassForType(_dataType);
	_fileTypeCode := self.type;
end;
</source>
