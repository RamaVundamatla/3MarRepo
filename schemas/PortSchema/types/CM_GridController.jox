    <JadeMethod name="getMyNextController" id="d7ee1111-4472-47f6-a06b-0d3ab5200f11">
        <source>getMyNextController(pControllerType: Class) : CM_GridController;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		By passing in the class of the controller - Stack, Gap Tower etc this will check the next 2 controllers in the 
//				chain. If one of them is of the passed in type  then pass it back else pass null
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myNextController = null then
		return null;
	endif;
	if pControllerType &lt;&gt; CM_StackController 
	and self.testMyNextController(CM_StackController) then // is the controller next to me a Stack Controller? If so then stop
		return null;
	endif;
	
	if self.testMyNextController(pControllerType) then
		return self.myNextController;
	elseif self.myNextController.testMyNextController(pControllerType) then 
		return self.myNextController.myNextController;
	else
		return null;
	endif;


end;</source>
        <Parameter name="pControllerType" type="Class"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="getMyPreviousController" id="5469787d-45cd-4173-ae20-1c61e98054ac">
