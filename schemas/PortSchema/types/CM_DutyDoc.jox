    <JadeMethod name="getPortRemarksString" id="d686cec8-73dd-4fc6-a3a5-1299f032ab0b">
        <source>getPortRemarksString( _items : CM_DutyDocItemSet ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2013	cnwndl1	Initial creation	par 33229

*/

vars

	str : String;
	voyage : CM_Voyage;
	date : Date;

begin

	//line 1
	str := self.invTerms &amp; ": ";
	if self.invTerms = FOB then
		str := str &amp; getFOBvalue( _items ).asCurrencyJMT();
	endif;
	str := str &amp; CrLf;
	
	//line 2
	str := str &amp; "Frt: " &amp; self.getLocalFreight( _items ).asCurrencyJMT() &amp; CrLf;
	
	//line 3
	str := str &amp; "Ins: " &amp; self.getLocalInsurance( _items ).asCurrencyJMT() &amp; CrLf;
	
	//line 4
	voyage := self.getMyVoyage();
	date := null;
	if voyage &lt;&gt; null then
		date := voyage.arrivedDT.Date;
	endif;
	str := str &amp; "Arvl: ";
	if date.isValid then
		str := str &amp; date.shortFormatJMT;
	endif;
	str := str &amp; CrLf;
	
	//line 5
	date := null;
	if voyage &lt;&gt; null then
		date := voyage.departedDT.Date;
	endif;
	str := str &amp; "Dep: ";
	if date.isValid then
		str := str &amp; date.shortFormatJMT;
	endif;
	str := str &amp; CrLf;
	
	//line 6
	str := str &amp; "Doct: " &amp; self.getDocumentationDepositValue.asCurrencyJMT() &amp; CrLf;
	
	//line 7
	str := str &amp; "Duty: " &amp; self.dutyDeposit.asCurrencyJMT() &amp; CrLf;

	return str;

epilog

end;</source>
        <Parameter name="_items" type="CM_DutyDocItemSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
