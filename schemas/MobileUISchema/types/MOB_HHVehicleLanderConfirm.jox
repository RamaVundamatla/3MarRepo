    <JadeMethod name="translateForm" id="24946309-6f16-4429-a685-0112c4ccc8da">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 September 2016 10:43:43.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021299, locale);
	lblDirection.translateCaption(Xlat_0021300, locale);
	lblInYard.translateCaption(Xlat_0021292, locale);
	lblOnShip.translateCaption(Xlat_0021293, locale);
	lblROROArea.translateCaption(Xlat_0021303, locale);
	lblROROLane.translateCaption(Xlat_0021304, locale);
	lblVoyage.translateCaption(Xlat_0021296, locale);
	optLeft.translateCaption(Xlat_0021297, locale);
	optRight.translateCaption(Xlat_0021307, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
