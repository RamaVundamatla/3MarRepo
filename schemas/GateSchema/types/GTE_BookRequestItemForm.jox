        <source>cmbIsoType_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
//13 October 2009	cnwml2
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------
// 14/03/2016	cnwdap1		PAR #37606 Don't show if not available for entry
vars

begin
	if obj = null then
		return null;
	endif;
	if obj.CM_ISOType.isNotAvailableForEntry then				// PAR #37606
		return null;											// PAR #37606
	endif;														// PAR #37606
	
	return obj.CM_ISOType.code.trimRight &amp; Tab &amp; obj.CM_ISOType.description.trimRight;
epilog

end;</source>
