vars
	pFromTimeStamp : TimeStamp;
	pToTimeStamp : TimeStamp;
	date : Date;
	ts : TimeStamp;
	idx,i : Integer;
	time : Time;
	pClassName : String;
	msg : String;
	changedTs : TimeStamp;
	result : Integer;
