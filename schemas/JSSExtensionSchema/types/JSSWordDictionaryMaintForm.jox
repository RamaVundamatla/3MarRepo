    <JadeMethod name="addWord" id="7daa3263-f6c6-45de-bf81-3cb95810e559">
        <source>addWord() protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theWord			: JSSWord;
	theDictionary	: JSSWordDictionary;
	newWord			: String;
	errorMessage	: String;
	
begin
	newWord	:=	txtEditWord.jssString.toLower;
	
	if newWord &lt;&gt; null then
		theDictionary	:=	cmbDictionary.listObject.JSSWordDictionary;
		errorMessage	:=	self.aMyTA.trxCreateWord(	theDictionary,
														newWord,
														theWord);
		
		if errorMessage = null then
			tblWords.clearAllSelected();
			self.selectWord();
		else
			app.msgBox(errorMessage, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnA_click" id="24d4a09b-3b48-41ca-90d5-7817692484a2">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnA_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.setStartRow(jadeMask.name[jadeMask.name.length()]);
	txtStartFrom.text	:=	null;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
