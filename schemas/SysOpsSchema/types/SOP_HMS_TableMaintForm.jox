    <JadeMethod name="doBerthEndPosition" id="fd2e98d8-02d4-4779-8edb-97567dbe2c80">
        <source>doBerthEndPosition(_table: CM_EntryTable input; newRow: Integer);
//--------------------------------------------------
// Created:	20 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	currentRowName : String;
begin
	currentRowName := _table.getAttrName(_table.row);	
	
	if currentRowName = ETRow_Length
	or currentRowName = ETRow_StartPosition	then
		_table.setValueByName(ETRow_EndPosition, (_table.getValueByName(ETRow_StartPosition).Integer + _table.getValueByName(ETRow_Length).Integer));
	endif;				


end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doClearRestrictionValues" id="cc89cde7-f2ae-4a1d-9c24-8959f1cf841c">
        <source>doClearRestrictionValues(_tableObj:CM_EntryTable input) protected;
// --------------------------------------------------------------------------------
// Created:		20 March 2007 by cnwdad1
//
// Purpose:		When editing a Restriction (Check Point), if the either of the
//				"Relative to tide" or "Tide Range" options are cleared, then we also
//				need to clear out the data values for those options.
//
// Parameters:	_tableObj - A reference to the editing table control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowName		: String;
	rowValue	: String;
	
begin
	rowName	:=	_tableObj.getAttrName(_tableObj.row);
	
	if rowName = ETRow_RelativeToTide then
		rowValue	:=	_tableObj.getValueByName(ETRow_RelativeToTide).String.trimBlanks();
		
		if rowValue = null then
			_tableObj.setValueByName(ETRow_RelativeToTime, null);
			_tableObj.setValueByName(ETRow_RelativeFromTime, null);
		endif;
		
	elseif rowName = ETRow_RelativeToTide2 then
		rowValue	:=	_tableObj.getValueByName(ETRow_RelativeToTide2).String.trimBlanks();
		
		if rowValue = null then
			_tableObj.setValueByName(ETRow_RelativeToTime2, null);
			_tableObj.setValueByName(ETRow_RelativeFromTime2, null);
		endif;
		
	elseif rowName = ETRow_TideRangeReference then
		rowValue	:=	_tableObj.getValueByName(ETRow_TideRangeReference).String.trimBlanks();
		
		if rowValue = null then
			_tableObj.setValueByName(ETRow_TideRangeAmount, null);
		endif;
		
	elseif rowName = ETRow_TideRangeReference2 then
		rowValue	:=	_tableObj.getValueByName(ETRow_TideRangeReference2).String.trimBlanks();
		
		if rowValue = null then
			_tableObj.setValueByName(ETRow_TideRangeAmount2, null);
		endif;
	elseif rowName = ETRow_ShipsDepartTimings then
		rowValue	:=	_tableObj.getValueByName(ETRow_RelativeToTide).String.trimBlanks();
		
		if rowValue = null then
			_tableObj.setValueByName(ETRow_ShipsDepartTimings, null);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_tableObj" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbFiltHarbourClick" id="4b9ab24e-c820-4666-bd8d-bbbeedac5023">
        <updating/>
        <source>doCmbFiltHarbourClick() protected, updating;
// -------------------------------------------
