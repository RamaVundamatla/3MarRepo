    <JadeMethod name="populateTable" id="0b086a6b-31cd-4336-821a-7460b5b08e32">
        <source>populateTable() protected;
/*
Date		Who		Reason
22/02/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	altColour		: Boolean;
	criteriaColl, 
 	selectedColl	: ObjectSet;
	hasDescription	: Boolean;
	row				: Integer;
	rowMax			: Integer;
	table			: CMUI_ListTable;
begin
	table			:= self.tblAvailable;
	hasDescription 	:= self.chkByDescription.visible;

	//  Initialise table
	self.initialiseTable();
	
	self.setSortOrder();

	//  Get collection of selected/all to load
	create criteriaColl transient;
	create selectedColl transient;
	
	self.getCollectionToLoad (criteriaColl, selectedColl);
	
	// load collection into table
	self.loadTable (criteriaColl, selectedColl);
	
	//  Colour row etc.
	rowMax := table.rows;
	
	foreach row in table.fixedRows + 1 to rowMax do
		if not hasDescription then
			table.accessCell(row, 2).mergeCells := Table.MergeCells_Merge;
		endif;
	
		altColour := not altColour;
		
		if altColour then
			table.accessRow(row).backColor := self.colorRow1;
		else
			table.accessRow(row).backColor := self.colorRow2;
		endif;
	endforeach;
	
	//  Position display
	if table.rows &gt;= 1 then
		table.row := 1;
	endif;

	if not table.allSelectedObjects.isEmpty then
		table.findObjectInRow(table.allSelectedObjects.first, table.row);
	
		self.positionDisplay();
	endif;

	self.chkByDescription.visible := hasDescription;
	
	self.txtFind.setFocus();	
epilog
	delete criteriaColl;
	delete selectedColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="positionDisplay" id="5b56c0d0-d2e8-4fcc-aeeb-e109d09746c0">
        <source>positionDisplay() protected;
/*
Date		Who		Reason
22/12/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	topRow 	: Integer;
	table	: CMUI_ListTable;
begin
	table	:= self.tblAvailable;
	topRow 	:= table.row - 3;
	
	if topRow &gt; table.fixedRows then
		table.topRow := topRow;
		
	elseif table.rows &gt; table.fixedRows then
		table.topRow := table.fixedRows + 1;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSortOrder" id="ddfc3fcf-b36d-4d96-a6b4-450c49b3e79d">
        <source>setSortOrder();
/*
Date		Who		Reason
22 February 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	checkbox	:CheckBox;
	table		:Table;
begin
	checkbox	:= self.chkByDescription;
	table		:= self.tblAvailable;
	
	if checkbox.visible and checkbox.value then
		table.sortColumn[1] := 3;
		table.sortCased[1] 	:= true;
	else
		table.sortColumn[1] := 2;
		table.sortCased[1] 	:= true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5453a6bf-b2fb-4a05-8fdd-e6d0ab6941cd">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
22/12/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars

begin
	inheritMethod();

	self.centreWindow();

	self.chkByDescription.visible 	:= false;
	self.btnSaveBase.visible 		:= false;
	self.btnCancelBase.visible 		:= false;
	
	self.populateTable();
	self.doFind();	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="01f55099-7d90-444e-8223-fc724db2a027">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018626, locale);
	chkByDescription.translateBubbleHelp(Xlat_0018627, locale);
	chkByDescription.translateCaption(Xlat_0018628, locale);
	lblFind.translateCaption(Xlat_0018629, locale);
	optAll.translateCaption(Xlat_0018630, locale);
	optSelected.translateCaption(Xlat_0018631, locale);
end;</source>
    </JadeMethod>
