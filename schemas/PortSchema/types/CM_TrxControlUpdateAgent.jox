    <JadeMethod name="trxSortMenuEntityChildren" id="b2207b7e-77fe-45b1-b66c-3621060111f8">
        <updating/>
        <source>trxSortMenuEntityChildren(_menuEntityObj:CM_MenuEntity; _isDescending:Boolean; _isParentsFirst:Boolean; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		27 October 2005 by cnwdad1
//
// Purpose:		Sorts the array of children on the specified Menu Entity.
//
// Parameters:	_menuEntityObj - A reference to the Menu Entity who's children to sort.
//				_isDescending - If true, the children will be sorted in descending order.
//				_isParentsFirst - If true, the entities with children will be placed
//					at the top or the sort order (or bottom if descending order),
//					followed by entities with no children.
//				_passport - The user passport thingy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers.
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlSortMenuEntityChildren(_menuEntityObj, _isDescending, _isParentsFirst, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_menuEntityObj" type="CM_MenuEntity"/>
        <Parameter name="_isDescending" type="Boolean"/>
        <Parameter name="_isParentsFirst" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
