    <JadeMethod name="setComboValues" id="41211cae-36a0-4e33-aba1-ada3828ea9e1">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	serviceObjSet : ObjectSet;
	obj : Object;
	service : CM_Service;
	qrl : CM_QReferenceLookup;
	edition : Integer;
	invalidObj : Boolean;

begin
	
	_combo.clear();

	//We get services in play based on the banks in play.
	create serviceObjSet  transient;
	self.getServicesInPlay( _params, serviceObjSet );
	
	if serviceObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the services based on the banks found
	foreach obj in serviceObjSet do
		service := obj.CM_Service;
		_combo.itemObject[ _combo.addItem( self.translateToDisplayValue(service).String ) ] := service;
	endforeach;
	
	//now set the value in the combo
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		on Exception do app.handleDeletedObject( exception, qrl.mySelectionValue, invalidObj );
		if qrl.mySelectionValue &lt;&gt; null then
			edition := qrl.mySelectionValue.edition;
			if not invalidObj then
				if _combo.findObject(qrl.mySelectionValue) &gt; 0 then
					_combo.listObject := qrl.mySelectionValue;
				endif;
			endif;
		endif;
	endif;

epilog

	delete serviceObjSet;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="5c9ee7b6-127c-458a-8821-e2a8681f018b">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	serviceObjSet : ObjectSet;
	obj : Object;
	service : CM_Service;
	selectionValue : Integer;
	idx : Integer;

begin

	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2;
	
	//We get services in play based on the banks in play.
	create serviceObjSet  transient;
	self.getServicesInPlay( _params, serviceObjSet );
	
	if serviceObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the services based on the banks found
	foreach obj in serviceObjSet do
		service := obj.CM_Service;
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(service) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem( selectionValue.String &amp; Tab &amp; self.translateToDisplayValue(service).String );
		_tbl.accessRow(idx).itemObject := service;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;

epilog

	delete serviceObjSet;

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="688ea0c7-7f22-4b5d-9353-213134b300e4">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	service : CM_Service;

begin
	if _value.isKindOf(CM_Service) then
		if _value &lt;&gt; null then
			service := _value.CM_Service;
			return service.name &amp; "  [" &amp; service.bank.code &amp; "/" &amp; service.bank.terminal.code &amp; "]";
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="961783a5-f53a-4cda-9d53-c39e3d02c43d">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_Service) then
			return _value.CM_Service;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
