    <JadeMethod name="updateWodReleaseBooking" id="99cd1c22-c0d8-4cd1-a099-7fe89b78b71f">
        <source>updateWodReleaseBooking(_controller: CnEcReleaseController);
/*

Purpose:			
	This script will be used to update the following using CM_WodRelease::exportBookingNumber
	CM_WodRelease::myBookingRef
	CM_WodRelease::myBookingRefItem
Parameters:			

Return Value:		

Date		Who		Reason
06 Jul 2023	navhl20	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order

*/

vars
	wod			: CM_WorkOrderDtl;
	booking		: CM_BookingRef;
	term		: CM_Terminal;
	workOrder	: CM_WorkOrder;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Update Release Workorder booking", LogINFO); 
	if _controller &lt;&gt; null then
		_controller.logEntry(" Update Release Workorder booking") ;	
	endif;
	
	beginTransaction;
	foreach term in app.myRoot.allTerminals do 
		foreach workOrder in term.allWorkOrders do
			if not workOrder.isKindOf(CM_WorkOrderTI) then
				continue;
			endif;
			foreach wod in workOrder.allWoDtls do
				if not wod.isKindOf(CM_WodRelease) then
					continue;
				endif;
				
				if wod.CM_WodRelease.exportBookingNumber = null then
					continue;
				endif;
				
				booking := term.allBookingRefsByRef[wod.CM_WodRelease.exportBookingNumber];
				if booking &lt;&gt; null then
					wod.CM_WodRelease.setBooking(booking);
				endif;
			endforeach;
		endforeach;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Updated Release Workorder booking", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Updated Release Workorder booking");
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
