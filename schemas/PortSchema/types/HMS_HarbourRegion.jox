    <JadeMethod name="findAvailableToBerthsFromPaths" id="1c84422d-c3e0-4721-9f67-50dc7cc32359">
        <source>findAvailableToBerthsFromPaths( _allBerths : HMS_BerthByCodeDict input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2008	cnwer1	Initial creation

*/

vars
	pathSegement : HMS_PathSegment;
	movementPath : HMS_MovementPath;
	berth : HMS_Berth;
begin
	
	foreach pathSegement in self.allPathSegments do
		if pathSegement.myRegionFrom &lt;&gt; self then
			continue;
		endif;
		
		if pathSegement.myRegionTo = null then
			continue;
		endif;
		
		foreach berth in pathSegement.myRegionTo.allBerthsInRegion do
			
			if not _allBerths.includes(berth) then
				_allBerths.add(berth);
			endif;
		endforeach;
	
	endforeach;
	
	foreach movementPath in self.allMovementPaths do
		if movementPath.myRegionFrom &lt;&gt; self then
			continue;
		endif;
		
		if movementPath.myRegionTo = null then
			continue;
		endif;
		
		foreach berth in movementPath.myRegionTo.allBerthsInRegion do
			if not _allBerths.includes(berth) then
				_allBerths.add(berth);
			endif;
		endforeach;
	
	endforeach;
	
epilog

end;</source>
        <Parameter name="_allBerths" type="HMS_BerthByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fixCheckpoints" id="15df2972-8114-43ba-a957-145db669016f">
        <source>fixCheckpoints();
// ---------------------------------------------------------------------------
// Created:     09 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
begin
	if (not self.allCheckpoints.includes(self.myCurrentCheckpoint)) and
	   self.myCurrentCheckpoint &lt;&gt; null then
		self.allCheckpoints.add(self.myCurrentCheckpoint);
	endif;
	if (not self.allCheckpoints.includes(self.myHeightCheckpoint))  and
	   self.myHeightCheckpoint &lt;&gt; null then
		self.allCheckpoints.add(self.myHeightCheckpoint);
	endif;
	if (not self.allCheckpoints.includes(self.myHiLoCheckpoint))  and
	   self.myHiLoCheckpoint &lt;&gt; null then
		self.allCheckpoints.add(self.myHiLoCheckpoint);
	endif;
	//jlgka1 TFS 45620 --&gt;
	/*if (not self.allCheckpoints.includes(self.myTideRangeCheckPoint))  and
	   self.myTideRangeCheckPoint &lt;&gt; null then
		self.allCheckpoints.add(self.myTideRangeCheckPoint);
	endif;*/
	//jlgka1 TFS 45620 &lt;--
	if (not self.allCheckpoints.includes(self.myTimeGapCheckpoint))  and
	   self.myTimeGapCheckpoint &lt;&gt; null then
		self.allCheckpoints.add(self.myTimeGapCheckpoint);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getArrivalBerth" id="e73a3436-108f-47f0-9653-f3c80794823a">
        <source>getArrivalBerth(): HMS_Berth;
//-----------------------------------------------------------------------
//	Created:	15 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	berth : HMS_Berth;
begin	
	if self.myPreferredBerth &lt;&gt; null then
		return self.myPreferredBerth;
	endif;
	
	if self.getHarbourReal() &lt;&gt; null then
		berth := self.getHarbourReal.getDefaultBerthForMoveType(HMSMovementTypeArrival);
	endif;
	
	return berth;
epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="d882c2b8-211c-4f12-b92c-e733494365c0">
        <source>getAuditText(): String;
//-----------------------------------------------------------------------
//	Created:	May 2007 cnvwu1
//-----------------------------------------------------------------------
vars
	txt				: String;
	tmpStr			: String;
	checkpoint		:  HMS_CheckPoint;
	berthInRegion	: HMS_Berth;
begin

	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

		//allCheckpoints
	tmpStr := null;
	foreach checkpoint in allCheckpoints do				
		if tmpStr = null then			
			tmpStr := checkpoint.code;		
		else	
			tmpStr := tmpStr &amp;', ' &amp; checkpoint.code;
		endif;	
	endforeach;		
	txt := txt &amp; 'allCheckpoints' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		

		//allBerthsInRegion	
	tmpStr:=null;		
	foreach berthInRegion in allBerthsInRegion do				
		if tmpStr = null then			
			tmpStr := berthInRegion.code;		
		else	
			tmpStr := tmpStr &amp;', ' &amp; berthInRegion.code;
		endif;	
	endforeach;		
	txt := txt &amp; 'allBerthsInRegion' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		
		
		
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getChartDatum" id="8e8ce313-bd04-49a8-89d1-c2baf06eff07">
        <source>getChartDatum() : Real;
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myHeightCheckpoint = null or
	   self.myHeightCheckpoint.myTidalModel = null then
		return null;
	endif;

	return self.myHeightCheckpoint.myTidalModel.getChartDatum();
	

end;


</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getClosestArrivalMovement" id="facb67fe-17a1-4a85-936f-462d705bb14a">
        <source>getClosestArrivalMovement(_time : TimeStamp; _voyagesToIgnore : CM_VoyageSet ) : HMS_Movement;
/*

Purpose:	Should get the closest arrival/shift  movement to the time , can be either side of the time.
			Will ignore movements that have departed before the _time
			Will ignore movements for the voyages in the _voyagesToIgnore method	


Return Value:		


Date		Who		Reason
10 April 2008	cnwer1	Initial creation - PAR#16514

*/
vars
	berth : HMS_Berth;
	movement,ourMovement : HMS_Movement;
	found : Boolean;
	movementTime,
	arrivalTimeBerth: TimeStamp;
begin	
	foreach berth in self.allBerthsInRegion do
		movement:=berth.getClosestArrivalMovement(_time,_voyagesToIgnore);
		if movement &lt;&gt; null then
			arrivalTimeBerth := movement.getArrivalTimeAtBerth(berth);
				
			if ourMovement = null or _time.getDifferenceInMinutes(arrivalTimeBerth)&lt; _time.getDifferenceInMinutes(movementTime)  then
				ourMovement := movement;
				movementTime := arrivalTimeBerth;
			endif;
		endif;
	
	endforeach;
	return ourMovement;
epilog
	
end;</source>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_voyagesToIgnore" type="CM_VoyageSet"/>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="getDepartureBerth" id="151fdbcc-857b-47df-906d-3f7b334a6177">
        <source>getDepartureBerth(): HMS_Berth;
//-----------------------------------------------------------------------
//	Created:	15 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	berth : HMS_Berth;
begin	
	if self.myPreferredBerth &lt;&gt; null then
		return self.myPreferredBerth;
	endif;
	
	if self.getHarbourReal() &lt;&gt; null then
		berth := self.getHarbourReal().getDefaultBerthForMoveType(HMSMovementTypeDeparture);
	endif;
	
	return berth;
epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getDepartureMovementsBetween" id="c7cbbcee-ed87-44bc-84c0-37aa627045c4">
        <source>getDepartureMovementsBetween(_fromTime, _toTime : TimeStamp; _movementCollection : HMS_MovementByDateDict input; 
			_ignoreVoyageGlobal : CM_VoyageGlobal; _voyagesToIgnore : CM_VoyageSet);
//-----------------------------------------------------------------------
//	Created:	07 May 2007 Lorcan Bolster  (cnwlb1/lorcan)
//
//	30 Mar 08	Changed to use departureTimeFromFromRegion so correct departure time
//				for shift movements.
//				Also always include locked departure times
//-----------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
23/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	movement,
	ourMovement	: HMS_Movement;
	berth		: HMS_Berth;
	iter	 	: Iterator;
begin

	foreach berth in self.allBerthsInRegion do
		iter := berth.getAllDepartingMovements.createIterator();
		berth.getAllDepartingMovements.startKeyGeq(_fromTime, iter);
		
		while iter.next(movement) do
			//if movement.occursOnDTNEW &lt;= _toTime and 
			// change to use departureTimeFromFromRegion as for shifts we want to exclude steaming time
			if movement.departureTimeFromFromRegion &lt;= _toTime and 
			   movement.myVoyageGlobal &lt;&gt; _ignoreVoyageGlobal and 
			   
			   // If _voyagesToIgnore &lt;&gt; null then doing a recalc so ignore voyages not recalced yet BUT
			   // need to also take into account movements where departure time is locked			   
			   (_voyagesToIgnore &lt;&gt; null and ((not _voyagesToIgnore.includes(movement.getVoyage))) 
			   //jlgka1 TFS 45620 --&gt;
			   //or  movement.departureTimeLocked
			   )
			   //jlgka1 TFS 45620 --&gt;
			   then
				_movementCollection.add(movement);
			endif;
		endwhile;
		
		delete iter;
	endforeach;

epilog
	delete iter;
end;
</source>
        <Parameter name="_fromTime" type="TimeStamp"/>
        <Parameter name="_toTime" type="TimeStamp"/>
        <Parameter name="_movementCollection" type="HMS_MovementByDateDict" usage="input"/>
        <Parameter name="_ignoreVoyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_voyagesToIgnore" type="CM_VoyageSet"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="5546c96a-5427-4be2-8268-8db61517cd44">
