    <JadeMethod name="isTaxExempt" id="6e97cf37-fe8e-4467-9910-93594ed42e27">
        <source>isTaxExempt() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlger1	Initial creation refactored part of TFS 44550

*/

vars
	voyage : CM_Voyage;
	voyageData	   : HMS_VoyageData;		
begin
	voyage := self.getMyVoyageObject;
	if voyage = null 
	or voyage.myVoyageProcess = null // found in unit tests NDL 19 Sep 2019
	then
		return false;
	endif;
	voyageData:=  voyage.myHMSVoyageData;
	if voyageData = null then
		return false;
	endif;
	
	if voyage.myVoyageProcess.isMTNWOProcess  then //jlier1 TFS 51963 1/10/21
		if voyageData.isZeroRatedTax then 				
			if voyageData.isZeroRatedTaxCargo then	
				return true;						
			else										
				if self.isKindOf(CM_WorkOrderVoyageDtl)
				and ( not self.isKindOf(CM_WodCargoRequest) )	//21 May 2019	NDL	TFS 44651
				and ( not self.isKindOf(CM_WodVoyageCargoRequest) )	//21 May 2019	NDL	TFS 44651
				and  not ( self.isKindOf(CM_WodPermitRequest) and self.CM_WodPermitRequest.isAdditionalCargo )	//22 May 2019 NDL TFS 44651
				then	
					return true;					
				endif;								
			endif;									
		endif;	
	else
		if voyageData.isZeroRatedTax and self.isKindOf(CM_WorkOrderVoyageDtl) then 	
			return true;
		endif;
		if voyageData.isZeroRatedTaxCargo and self.isKindOf(CM_WorkOrderTIDtl) then 	
			return true;
		endif;
		
	endif;
					
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToGetAdvWOTransType" id="a9e1e57c-fd9f-4797-a2b5-dbd834cb50ce">
        <source>isToGetAdvWOTransType(_transType : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62898: Jade - Unit Test

*/

vars

begin
	if 	_transType = TRANS_TYPE_WOJOBSTART or
		_transType = TRANS_TYPE_WOJOBSTOP or
		_transType = TRANS_TYPE_WOJOBRESUME or
		_transType = TRANS_TYPE_WOJOBCOMPLETE
		
		then
		
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
