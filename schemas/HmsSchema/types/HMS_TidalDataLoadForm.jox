    <JadeMethod name="doBtnLoadClick" id="bf4c3bd1-6827-4890-8853-3bc90a8fbbd4">
        <updating/>
        <source>doBtnLoadClick() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
// 10/12/2014  cnwdb2	PAR 35364

----------   ----------  --------------------------------------------------
*/

vars
	errorMsg : String;
	valueTypeStr			: String;
	chartDatum				: Real;
begin

	if  self.txtLoadFile.text = null then	
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'File Name'), 'File name required', MsgBox_Stop_Icon + MsgBox_OK_Only);	
		app.msgBox(app.getErrorString(Input_required_field_fileName), app.getErrorString(File_name_required), MsgBox_Stop_Icon + MsgBox_OK_Only);	// cnwdb2	PAR 35364
		self.txtLoadFile.setFocus();
		return;
	endif;


	self.setFileType();
	
	if tidalDataFileType = null then 
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'File Type'), 'File type required', MsgBox_Stop_Icon + MsgBox_OK_Only);	
		app.msgBox(app.getErrorString(Input_required_field_fileTypes), app.getErrorString(File_type_required), MsgBox_Stop_Icon + MsgBox_OK_Only);	// cnwdb2	PAR 35364

		self.cmbType.setFocus();
		return;
	endif;
	
	valueTypeStr := self.cmbMultiplier.text;
	if valueTypeStr = null then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'Value type'), 'Value type required', MsgBox_Stop_Icon + MsgBox_OK_Only);	
		app.msgBox(app.getErrorString(Input_required_field_value_typ), app.getErrorString(Value_type_required), MsgBox_Stop_Icon + MsgBox_OK_Only); // cnwdb2	PAR 35364
	
		self.cmbMultiplier.setFocus();
		return;
	endif;
	self.valueMultiplier := app.tidalDataMultiplierForType(valueTypeStr);
	
	self.doLoadTidalData(errorMsg);
	
	if errorMsg = 'loaded' then
		app.msgBox('Data Loaded Successfully','Data Loaded', MsgBox_OK_Only);
		self.unloadForm;
		return;
	endif;
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg,'Load Failed', MsgBox_Exclamation_Mark_Icon+  MsgBox_OK_Only);
		return;
	else
		app.msgBox('No data to be loaded','Load Failed', MsgBox_OK_Only);
	endif;
	
	
end;



</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadCmbMultiplier" id="aa6222d4-45c8-4277-9810-a0f020031dd4">
        <source>doLoadCmbMultiplier() protected;
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cmb			: CMUI_ComboBox;
begin
	cmb := self.cmbMultiplier;
	cmb.clear();
	cmb.addItem(HMS_TidalModelDefinition.VALUE_TYPE_MM);
	cmb.addItem(HMS_TidalModelDefinition.VALUE_TYPE_CM);
	cmb.addItem(HMS_TidalModelDefinition.VALUE_TYPE_METERS);
	cmb.addItem(HMS_TidalModelDefinition.VALUE_TYPE_FEET);
	cmb.addItem(HMS_TidalModelDefinition.VALUE_TYPE_INCHES);
	
	cmb.listIndex := 1;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadHILOLine" id="81e57dc2-f5dd-40d8-9d75-6ace4caebbf7">
        <source>doLoadHILOLine(_str : String);
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2006 By cnwmo1

Purpose:	an example of a line to be processed "  PRED   2 02012006-10133 0480 11658 3160

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	Delim = ' ';
vars
	numHeights,
	height				: Real;
	nextPos,
	tideType			: Integer;
	
	tideTypeArray		: IntegerArray;
	valueArray			: RealArray;
	timeArray			: TimeArray;
	dateForLine			: Date;
	time				: Time;
	ts 					: TimeStamp;
	pxyTidalData		: HMS_TidalData;
	idx,
	arraySize			: Integer;
	
begin
	
	dateForLine := null;
	create tideTypeArray transient;
	create valueArray transient;
	create timeArray transient;
	nextPos := 10;
	numHeights := _str.cnEcNextDelimitedField(Delim, nextPos).trimBlanks().Integer;
	dateForLine := _str[12:8].convertDDMMYYYToDate();
	nextPos := 20;
	while numHeights &gt; 0 do // e.g. "-10133 0480"
		tideType := _str[nextPos:2].trimBlanks().Integer;
		tideTypeArray.add(tideType);
		nextPos := nextPos+2;
		time 	:= _str[nextPos:4].trimBlanks().convertHHMMToTime();
		timeArray.add(time);
		nextPos := nextPos+4;
		height 	:= _str[nextPos:5].trimBlanks().Integer;
		valueArray.add(height);
		nextPos := nextPos+5;
		numHeights := numHeights - 1;
	endwhile;
	
	if (not dateForLine.isValid) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid date (' &amp; dateForLine.String &amp;')');
	endif;
	
	time := null;
	ts.setDate(dateForLine);
	ts.setTime(time);
	
	
	arraySize := valueArray.size;
	foreach idx in 1 to arraySize do
		
		if (not ts.isValid) then 
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid date (' &amp; time.String &amp;')');
		 endif;
	
		height := valueArray[idx] * self.valueMultiplier;
		time := timeArray[idx];
		tideType := tideTypeArray[idx];
		ts.setTime(time);
		
		pxyTidalData := self.myPxyTidalModelDef.allHMSTidalData[ts];
		//tide data has already been loaded for this timestamp, but different data type, so delete and replace
		if pxyTidalData &lt;&gt; null and (not pxyTidalData.isKindOf(HMS_HiLoTidalData)) then
			delete pxyTidalData;
		endif;
		
		if pxyTidalData = null then
			create pxyTidalData as HMS_HiLoTidalData transient;
		endif;
		pxyTidalData.HMS_HiLoTidalData.setProxy(ts, self.myPxyTidalModelDef, height, tideType);	
	endforeach;

epilog
	delete valueArray;
	delete timeArray;
	delete tideTypeArray;
end;
</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadHeightLine" id="21052c13-aad8-4577-b4e2-cf4d5b939a36">
        <source>doLoadHeightLine(_lineOne : String; _lineTwo :String);
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	Delim = ' ';
	Delim2 = 'CrLf';
vars
	height				: Real;
	nextPos,
	len					: Integer;
	
	valueStr,
	str					: String;
	valueArray			: RealArray;
	dateForLine			: Date;
	time				: Time;
	ts 					: TimeStamp;
	pxyTidalData		: HMS_TidalData;
	
	flag				: Boolean;
begin
	flag := false;
	len := _lineOne.length;
	dateForLine := null;
	create valueArray transient;
	nextPos := 1;
	str := _lineOne;
	
	while nextPos &lt;= len do
	
		if flag then
			str := _lineTwo;
		endif;
	
		valueStr := str.cnEcNextDelimitedField(Delim, nextPos).trimBlanks();	
	
		if valueStr = null then 
			valueStr := str.cnEcNextDelimitedField(Delim2, nextPos).trimBlanks();
			nextPos:=nextPos + len; // this is the end of the line
		endif;
		
		if valueStr.length &gt; 2 and valueStr.length &lt; 7  then
			valueArray.add(valueStr.Real * self.valueMultiplier);
		elseif valueStr.length &gt;7 then
			dateForLine := valueStr.convertDDMMYYYToDate();
			if not flag then
				flag :=true; // we can do the second line now
				nextPos:=1; // restart for the second line
			endif;
		endif;
		
	endwhile;
	
	if (not dateForLine.isValid) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid date (' &amp; valueStr &amp;')');
	endif;
	
	time := null;
	ts.setDate(dateForLine);
	ts.setTime(time);
	
	foreach height in valueArray do
		 
		 if (not ts.isValid) then 
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid date (' &amp; time.String &amp;')');
		 endif;
		 
		pxyTidalData := self.myPxyTidalModelDef.allHMSTidalData[ts];
		//tide data has already been loaded for this timestamp, but different data type, so delete and replace
		if pxyTidalData &lt;&gt; null and (not pxyTidalData.isKindOf(HMS_DraftTidalData)) then
			delete pxyTidalData;
		endif;
		
		if pxyTidalData = null then
			create pxyTidalData as HMS_DraftTidalData transient;
		endif;
		
		pxyTidalData.HMS_DraftTidalData.setProxy(ts, self.myPxyTidalModelDef, height);
	
		time.setTime(time.hour + 1, null, null, null);
		if time.hour &gt;= 24 then 
			time := null;
		endif;
		ts.setTime(time);
	endforeach;

epilog
	delete valueArray;

end;
</source>
        <Parameter name="_lineOne" type="String"/>
        <Parameter name="_lineTwo" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadTidalData" id="955a9860-b465-46f8-8b12-ddd11240c844">
        <updating/>
        <source>doLoadTidalData(_errorMsg : String io) updating;
// ---------------------------------------------------------------------------
// Created:     09/10/2006	cnwmo1
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 29/03/2016	cnwdap1		PAR #35843 Make progress bar updates time-based, not object counts
vars
	file		: File;
	lineOneStr,
	lineTwoStr 		: String;
	ts 				: TimeStamp;
	cmifMonitor		: CMIF_Monitor;
	lastUpdated		: Decimal [20];					// PAR #35843
begin

	create file transient;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	file.fileName :=  txtLoadFile.text;
	if (not file.isAvailable) then
		_errorMsg := app.getErrorString1(FileUnavailable, 'File Name');
		return;
	endif;
	
	file.open;
	
	delete app.myPassport.myCMIFMonitor;
   	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	
	if (self.myPxyTidalModelDef.dataType &lt;&gt; null) then
		if (self.tidalDataFileType = HMS_TidalFile_QLD_Current and self.myPxyTidalModelDef.dataType &lt;&gt; HMS_TidalDataType_Current) or
		   (self.tidalDataFileType = HMS_TidalFile_QLD_Height and self.myPxyTidalModelDef.dataType &lt;&gt; HMS_TidalDataType_Height) or
		   (self.tidalDataFileType = HMS_TidalFile_QLD_HiLo and self.myPxyTidalModelDef.dataType &lt;&gt; HMS_TidalDataType_HiLo) then
			_errorMsg := 'The Tidal Model data type selected (' &amp; self.myPxyTidalModelDef.getDataTypeDescr() &amp; ') and file type selected (' &amp; app.tidalFileTypeEnumToString(self.tidalDataFileType) &amp; ') do not match.';
			return;
		endif;
		
	endif;
	
   	cmifMonitor.myParent := self;
	self.frmModalDialog.zOrder(1);
	
	cmifMonitor.partsDone := 0;
	cmifMonitor.partsInJob :=0;
	
	cmifMonitor.message := 'Loading Data';
	self.modalDialogShow(null, 'Cancel', null, null, 'Loading Data', cmifMonitor.message);
	
	self.updateProgress(cmifMonitor);
	while not file.endOfFile() do
		if self.tidalDataFileType = HMS_TidalFile_QLD_Height then
			lineOneStr := file.readLine().trimBlanks();
			lineTwoStr := file.readLine().trimBlanks();
			if isLineFormatHeightData(lineOneStr) and isLineFormatHeightData(lineTwoStr) then
				self.doLoadHeightLine(lineOneStr, lineTwoStr);
				cmifMonitor.partsDone:= cmifMonitor.partsDone+2;
				_errorMsg := 'loaded';
			endif;
		elseif self.tidalDataFileType = HMS_TidalFile_QLD_HiLo then
			lineOneStr := file.readLine(); // this is ok without trimBlanks.
			if isLineFormatHILOData(lineOneStr) then
				self.doLoadHILOLine(lineOneStr);
				cmifMonitor.partsDone:= cmifMonitor.partsDone+1;
				_errorMsg := 'loaded';
			endif;
		elseif self.tidalDataFileType = HMS_TidalFile_QLD_Current then
			break;
		elseif self.tidalDataFileType = null then
			break;
		endif;
		
		//if (cmifMonitor.partsDone mod 100) = 0 then 												// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			self.updateProgress(cmifMonitor);
			lastUpdated := app.relativeMachineTime;													// PAR #35843
		endif;	
	endwhile;
	
epilog	
	file.close;
	delete file;
	delete cmifMonitor;
	self.frmModalDialog.visible := false;
   	app.myPassport.setMyCMIFMonitor(null);
end;
</source>
        <Parameter name="_errorMsg" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isLineFormatHILOData" id="fccabca4-ccda-483c-a449-6fc3f7eb2a10">
        <source>isLineFormatHILOData(_str : String) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	11 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
 program	: String;
begin
	
	program := _str[3:4];
	if program = 'PRED' or program = 'HILO' then
		return true;
	else
		return false;
	endif;
end;
</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLineFormatHeightData" id="3bde10cc-922c-45f4-91c2-0b2938a8ca4d">
        <source>isLineFormatHeightData(lineStr : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     06/10/2006	cnwmo1
//
// Purpose:     Line formate of HeightData
//			 
// ----------   ----------  --------------------------------------------------
vars
startPos,
spacePos : Integer;
fieldStr : String;

begin
	startPos :=1; // always start at 1;
	spacePos := lineStr.pos(' ', startPos);
	fieldStr := lineStr[startPos: spacePos].trimBlanks();
	if fieldStr.isReal() then
		startPos := spacePos;
		spacePos := lineStr.pos(' ', startPos);
		
		fieldStr := lineStr[startPos:spacePos].trimBlanks();
	
			if fieldStr.isReal() then	
				return true;
			endif;
	endif;
	return false;
end;
</source>
        <Parameter name="lineStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadFileTypes" id="ea36864d-d0a0-46e2-b208-345029c7d506">
        <source>loadFileTypes(_dataType : Integer);
// ---------------------------------------------------------------------------
// Created:     06/10/2006	cnwmo1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
begin
	self.cmbType.clear();
	self.cmbType.sorted := false;
		
	//process.debug;
	
	if _dataType = HMS_TidalFile_QLD_HiLo then
		self.cmbType.addItemWithData(app.tidalFileTypeEnumToString(HMS_TidalFile_QLD_HiLo), HMS_TidalFile_QLD_HiLo);
	elseif _dataType = HMS_TidalFile_QLD_Height then
		self.cmbType.addItemWithData(app.tidalFileTypeEnumToString(HMS_TidalFile_QLD_Height), HMS_TidalFile_QLD_Height);
	elseif _dataType = HMS_TidalFile_QLD_Current then
		self.cmbType.addItemWithData(app.tidalFileTypeEnumToString(HMS_TidalFile_QLD_Current), HMS_TidalFile_QLD_Current);
	else
		self.cmbType.addItemWithData(app.tidalFileTypeEnumToString(HMS_TidalFile_QLD_HiLo), HMS_TidalFile_QLD_HiLo);
		self.cmbType.addItemWithData(app.tidalFileTypeEnumToString(HMS_TidalFile_QLD_Height), HMS_TidalFile_QLD_Height);
		self.cmbType.addItemWithData(app.tidalFileTypeEnumToString(HMS_TidalFile_QLD_Current), HMS_TidalFile_QLD_Current);
	endif;
end;
</source>
        <Parameter name="_dataType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFileType" id="509ba999-ba5b-4c1c-bb42-0af981c49fa1">
        <updating/>
        <source>setFileType() updating; 
// ---------------------------------------------------------------------------
// Created:     06/10/2006	cnwmo1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.cmbType.text &lt;&gt; null then
		self.tidalDataFileType := self.cmbType.itemData[self.cmbType.listIndex];
	else
		self.tidalDataFileType := null;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0cbf6fc8-d480-4b2c-bdc1-4bdb7c8118af">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myPxyTidalModelDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy Tidal Model Definition reference is null');
		return;
	endif;
	self.btnSaveBase.visible := false;
	//self.loadFileTypes();
	self.doLoadCmbMultiplier();
	inheritMethod();


end;


</source>
