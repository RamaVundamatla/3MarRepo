    <JadeMethod name="timerEvent" id="666aa68e-baec-4628-988d-c52925d043dc">
        <updating/>
        <source>timerEvent(_eventTag: Integer) updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars

begin
	inheritMethod(_eventTag);
	if _eventTag = RetryTimerEvent then
		self.doCheckForRetries();
	endif;

epilog

end;</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="6bfd6b21-08ce-4ddc-94e2-4c34c802e70a">
        <updating/>
        <source>userNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
/*
Purpose:			

Date		Who		Reason
19 August 2021	navab1	TFS 50669
*/

vars

begin
	inheritMethod(_eventType, _theObject, _eventTag, _userInfo);
	
	if _eventType = BGP_Object.BGP_NavisSmartProducerStarting then
		app.writeLog(method.qualifiedName &amp; " BGP_NavisSmartProducerStarting for " &amp; self.String, LogDEBUG);
		
		app.myTrxUA.trxUpdateEWSforBGPRequests(self,EWS_STATUS_STARTING, app.myPassport);
	elseif _eventType = BGP_Object.BGP_NavisSmartProducerRunning then
		app.writeLog(method.qualifiedName &amp; " BGP_NavisSmartProducerRunning for " &amp; self.String, LogDEBUG);
		
		app.myTrxUA.trxUpdateEWSforBGPRequests(self,EWS_STATUS_RUNNING, app.myPassport);
		

	elseif _eventType = BGP_Object.BGP_NavisSmartProducerStopped then
		app.writeLog(method.qualifiedName &amp; " BGP_NavisSmartProducerStopped for " &amp; self.String, LogDEBUG);
		
		app.myTrxUA.trxUpdateEWSforBGPRequests(self,EWS_STATUS_STOPPED, app.myPassport);
	elseif _eventType = BGP_Object.BGP_NavisSmartProducerSnapshot then
		
		app.writeLog(method.qualifiedName &amp; " BGP_NavisSmartProducerSnapshot for " &amp; self.String, LogDEBUG);
		
		app.myTrxUA.trxUpdateEWSforBGPRequests(self,EWS_ACTION_SNAPSHOT, app.myPassport);
	endif;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ed683578-8407-4a84-a4e0-19a8a2e359a0">
        <source>validateForUpdate();
//
// 13 June 2018	jlgrs1	TFS 39013 (37190)TFS 37190 Pelindo BGP Web Service
//

// ### TFS 50669 23AUG2021 NAVAB1 - NOTE this vaidation is called after the setForUpdate
vars
	wsBgpController : BGP_ExternalWSController;

begin
	inheritMethod();
	
	if self.myExternalWSDef = null then
		app.raiseCMException(Input_require_externa_service, null, self);
	endif;
	
	if self.myTerminal &lt;&gt; null
	and self.myExternalWSDef.isOpsView() then // ### TFS 50669 23AUG2021 NAVAB1
		if self.myExternalWSDef.getNumBGPControllerForTerminal(self.myTerminal) &gt; 1 then // ### TFS 50669 23AUG2021 NAVAB1
		app.raiseCMException(Termi_alrea_view_contr_only_al, null, self); // ### TFS 50669 23AUG2021 NAVAB1
		endif;
	endif;
	
	//navra1 - 27th Feb 2024 - DEFECT 62277 - start
	//if you are trying to assign an invoiceapi ws, check if you already dont have one defined for the terminal - only 1 is allowed
	if self.myExternalWSDef &lt;&gt; null and self.myExternalWSDef.isInvoiceAPIDef() then					//navra1 - 12th Mar 2024 - BUG 62878
		foreach wsBgpController in BGP_ExternalWSController.instances where wsBgpController.myTerminal &lt;&gt; null and wsBgpController.myTerminal.code = self.myTerminal.code do
			if wsBgpController.myExternalWSDef	&lt;&gt; null then
				if wsBgpController.myExternalWSDef.isInvoiceAPIDef() and wsBgpController &lt;&gt; self then
					app.writeLog("A terminal can be assigned to only one InvoiceAPI WS", LogERROR);
					app.raiseCMException2(Cant_ass_mul_invapiws_per_ter, wsBgpController.myTerminal.code, wsBgpController.myExternalWSDef.name, null, null);
				endif;
			endif;
		endforeach;
	endif;																							//navra1 - 12th Mar 2024 - BUG 62878
	//navra1 - 27th Feb 2024 - DEFECT 62277 - end
epilog

end;</source>
    </JadeMethod>
</Class>
