/*

Purpose:			


Return Value:		


Date		Who		Reason
06 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _wle.isReceipt then
		// PAR 25687 return "IN";
		return app.getErrorString(RoadJob_IN);
