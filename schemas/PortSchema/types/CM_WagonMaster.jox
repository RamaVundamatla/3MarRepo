    <JadeMethod name="differsFrom" id="f82c87a0-1670-48eb-89da-76f9d19d28e4">
        <source>differsFrom( _realWagonMaster : CM_WagonMaster; _changes : String output ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 July 2009	cnwndl1	Initial creation
17/07/2024	jlier1 TFS 65100 - handle invalid carrier
*/
constants
	Becomes : String = " --&gt; ";
	ColonSep : String = " : ";
	EmptyValue : String = "' '";
vars

	attribName : String;
	current : String;
	new : String;
	invalidCarrier : Boolean;
begin

	if _realWagonMaster = null then
		return false;
		
	else
		if _realWagonMaster.getMaxCargoHeight &lt;&gt; self.getMaxCargoHeight then	//Par 21924
			attribName := app.getErrorString(Maximum_cargo_height);
			current := "'" &amp; _realWagonMaster.getMaxCargoHeight.asStringJMTWithPrecision(2,false) &amp; "'";
			new := "'" &amp; self.getMaxCargoHeight.asStringJMTWithPrecision(2,false) &amp; "'";
			if _changes &lt;&gt; null then
				_changes := _changes &amp; CrLf;
			endif;
			_changes := _changes &amp; attribName &amp; ColonSep &amp; current &amp; Becomes &amp; new;
		endif;
			
		if _realWagonMaster.getMaxCargoWeight &lt;&gt; self.getMaxCargoWeight then	//Par 21924
			attribName := app.getErrorString(Maximum_cargo_weight);
			current := "'" &amp; _realWagonMaster.getMaxCargoWeight.asStringJMTWithPrecision(2,false) &amp; "'";
			new := "'" &amp; self.getMaxCargoWeight.asStringJMTWithPrecision(2,false) &amp; "'";
			if _changes &lt;&gt; null then
				_changes := _changes &amp; CrLf;
			endif;
			_changes := _changes &amp; attribName &amp; ColonSep &amp; current &amp; Becomes &amp; new;
		endif;
		
		if _realWagonMaster.getTareWeight &lt;&gt; self.getTareWeight then	//Par 21924
			attribName := app.getErrorString(Tare_weight);
			current := "'" &amp; _realWagonMaster.getTareWeight.asStringJMTWithPrecision(2,false) &amp; "'";
			new := "'" &amp; self.getTareWeight.asStringJMTWithPrecision(2,false) &amp; "'";
			if _changes &lt;&gt; null then
				_changes := _changes &amp; CrLf;
			endif;
			_changes := _changes &amp; attribName &amp; ColonSep &amp; current &amp; Becomes &amp; new;
		endif;
		on Exception do app.handleDeletedObject(exception,_realWagonMaster.myCarrier, invalidCarrier);
		if _realWagonMaster.myCarrier &lt;&gt; self.myCarrier then
			attribName := app.getErrorString(Carrier);
			if _realWagonMaster.myCarrier = null then
				current := EmptyValue;
			else
				current := "'" &amp; _realWagonMaster.myCarrier.code &amp; "'";
			endif;
			if self.myCarrier = null then
				new := EmptyValue;
			else
				new := "'" &amp; self.myCarrier.code &amp; "'";
			endif;
			if _changes &lt;&gt; null then
				_changes := _changes &amp; CrLf;
			endif;
			_changes := _changes &amp; attribName &amp; ColonSep &amp; current &amp; Becomes &amp; new;
		endif;
		
		if _realWagonMaster.myWagonClass &lt;&gt; self.myWagonClass then
			attribName := app.getErrorString(Wagon_class);
			if _realWagonMaster.myWagonClass = null then
				current := EmptyValue;
			else
				current := "'" &amp; _realWagonMaster.myWagonClass.code &amp; "'";
			endif;
			if self.myWagonClass = null then
				new := EmptyValue;
			else
				new := "'" &amp; self.myWagonClass.code &amp; "'";
			endif;
			if _changes &lt;&gt; null then
				_changes := _changes &amp; CrLf;
			endif;
			_changes := _changes &amp; attribName &amp; ColonSep &amp; current &amp; Becomes &amp; new;
		endif;
		
		return _changes.trimBlanks &lt;&gt; null;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_realWagonMaster" type="CM_WagonMaster"/>
        <Parameter name="_changes" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
