    <JadeMethod name="trxCreateTempReading" id="c291b98c-b9d1-445d-9ba5-1aa628e4ec8b">
        <updating/>
        <source>trxCreateTempReading(_tempParams: CMIF_TempReading input; _connectTime: TimeStamp; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	connectParams			: CMIF_ConnectParams;
	tempReading				: CM_TempReading;
	transController			: CMIF_TempTransController;
	tempReadingTransaction	: CM_TITransaction;
	now						: TimeStamp;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
/* rs oct 2005 use the connect trx instead from the calling program
	beginTransaction;
	//connect if a refon reading and not connected
	if not _tempParams.myContainer.isConnected then
		if _tempParams.isRefConReading and _tempParams.allowConnect then
			app.writeLog("Connecting " &amp; _tempParams.myContainer.id, LogAlways);
			create connectParams transient;
			connectParams.action := ACTION_CONNECT;
			if _connectTime.isValid then
				connectParams.dateTime := _connectTime;
			else
				connectParams.dateTime := _tempParams.dateTime;
			endif;
			connectParams.myTerminal := _tempParams.myTerminal;
			connectParams.myTrackedItem := _tempParams.myContainer;
			connectParams.noCharge := _tempParams.noCharge;
			connectParams.userId := _tempParams.userId;
			connectParams.myOtherTrackedItem := _tempParams.myContainer.getOtherTrackedItem(ACTION_CONNECT);
			connectParams.locationsController := _tempParams.myContainer.getPrimaryLocation(REAL_MODE);
			
			app.myUtilityUA.utlUpdateConnect(connectParams, null, _passport);
		endif;
	endif;
	
	if _tempParams.connectOnly then
		return;
	endif;
	
	//should not let a failure to connect stop a reading from being added here	
	if _passport.hasErrors then
		app.writeLog("Error connecting container", LogAlways);
		_passport.clearErrorsWarnings();
	endif;
*/					
	beginTransaction;
	//create temperature reading
	tempReading := app.myUtilityCA.utlCreateTempReading(_tempParams, _passport);

	if _passport.noErrors then
		//create temperature TItrans
		create transController transient;
		_tempParams.setTITransController(transController);
		transController.myTempReading := tempReading;
		app.myUtilityCA.utlCreateTITransaction(transController, tempReadingTransaction, _passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete connectParams;
	delete transController;
end;</source>
        <Parameter name="_tempParams" type="CMIF_TempReading" usage="input"/>
        <Parameter name="_connectTime" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
