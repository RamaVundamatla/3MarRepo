    <JadeMethod name="delete" id="73452a42-db88-4ce0-ae79-d4e3c806f3f8">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2021	navndl1	Initial creation	TFS 50942

*/

vars

begin

	if not self.allDetails.isEmpty then
		self.allDetails.purge();
	endif;
	delete self.allDetails;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getBOLItems" id="e4932311-9fb3-4451-9ef9-1f5b73db4b7e">
        <source>getBOLItems(currentObject : CM_Object) : CM_BOLDtl;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	cmifDetail	: CMIF_ReserveTIDetail;
	object		: Object;
	cargoType	: CM_CargoType;
	product		: CM_Product;
begin
	foreach object in self.allDetails do
		if object.isKindOf(CMIF_ReserveTIDetail) then
			cmifDetail := object.CMIF_ReserveTIDetail;
			if currentObject.isKindOf(CM_CargoType) then
				cargoType := currentObject.CM_CargoType;
				if cmifDetail.myCargoType = cargoType then
					return cmifDetail.myBOLDtl;
				endif;
			elseif currentObject.isKindOf(CM_Product) then
				product := currentObject.CM_Product;
				if cmifDetail.myProduct = product then
					return cmifDetail.myBOLDtl;
				endif;
			endif;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="currentObject" type="CM_Object"/>
        <ReturnType type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="getCargoProductDescription" id="9532c774-99d3-475d-807b-c72942ae3160">
        <source>getCargoProductDescription(currentObject : CM_Object) : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	cmifDetail	: CMIF_ReserveTIDetail;
	object		: Object;
	cargoType	: CM_CargoType;
	product		: CM_Product;
begin
	foreach object in self.allDetails do
		if object.isKindOf(CMIF_ReserveTIDetail) then
			cmifDetail := object.CMIF_ReserveTIDetail;
			if currentObject.isKindOf(CM_CargoType) then
				cargoType := currentObject.CM_CargoType;
				if cmifDetail.myCargoType = cargoType then
					return cargoType.description;
				endif;
			elseif currentObject.isKindOf(CM_Product) then
				product := currentObject.CM_Product;
				if cmifDetail.myProduct = product then
					if product.myCargoType &lt;&gt; null then	//18 May 2021	NDL	TFS 51183
						return product.myCargoType.description &amp; ", " &amp; product.description;		//18 May 2021	NDL	TFS 51183
					else
						return product.description;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="currentObject" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalAllowed" id="b24aedba-506c-4151-b845-cde7ca9c4b6b">
        <source>getTotalAllowed(currentObject : CM_Object) : Integer;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	cmifDetail		: CMIF_ReserveTIDetail;
	totalAllowed	: Integer;
	object			: Object;
	cargoType		: CM_CargoType;
	product			: CM_Product;
begin
	foreach object in self.allDetails do
		if object.isKindOf(CMIF_ReserveTIDetail) then
			cmifDetail := object.CMIF_ReserveTIDetail;
			if currentObject.isKindOf(CM_CargoType) then
				cargoType := currentObject.CM_CargoType;
				if cmifDetail.myCargoType = cargoType then
					totalAllowed := totalAllowed + cmifDetail.totalAllowed;
					break;
				endif;
			elseif currentObject.isKindOf(CM_Product) then
				product := currentObject.CM_Product;
				if cmifDetail.myProduct = product then
					totalAllowed := totalAllowed + cmifDetail.totalAllowed;
					break;
				endif;
			endif;
		endif;
	endforeach;
	return totalAllowed;
end;</source>
        <Parameter name="currentObject" type="CM_Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalOnsite" id="309fbe0c-52fd-46e2-af0c-4bf78d62a637">
        <source>getTotalOnsite(currentObject : CM_Object) : Integer;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 17 April 2019
