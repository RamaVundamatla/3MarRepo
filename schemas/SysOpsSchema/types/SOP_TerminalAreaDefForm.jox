    <JadeMethod name="newBlockLocation" id="c9a2a9cb-a3bc-4d65-9933-f8aaff6c30d3">
        <source>newBlockLocation();
// Add a new location to the block area
vars
	blockArea : CM_IrregularBlockArea;
	locationProxy : CM_IrregularBlockController;
	region : PointArray;
	form : SOP_BlockLocationDetailForm;
	result	: Integer;
	shelfProxy : CM_RackShelfController;
	numShelves : Integer;
	int : Integer;
begin
	// Get location name from user
	create form transient;
	form.setLocationProxy(null, self.myTerminal, self);	//21 Aug 2013	NDL	Par 32308
	//form.txtName.setFocus();
	if form.showModal = IDOK then
		blockArea := self.myProxyObject.CM_IrregularBlockArea;
		create region transient;
		self.frmBlkArea.myDrawingController.getSelectedRegion(region);
		create locationProxy transient;
		locationProxy.setProxy(	blockArea,
								form.txtName.text,
								region,
								form.clrColour.getColor,	//_colour : Integer;
								form.txtDefCapacity.text.Integer,	//_defaultCapacity : Integer;
								form.cmbType.listData,	//_locationType : Integer;
								form.txtMaxWeight.getConvertedValue,	//_maximumWeight : Real;
								form.cmbICArea.listObject.CM_InterchangeArea	//_myICArea : CM_InterchangeArea
								);
		
		self.frmBlkArea.myDrawingController.addLocation(locationProxy, true); // PAR 32836
		
		//21 Aug 2013	NDL	Par 32308						
		if form.txtNumShelves.visible then
			numShelves := form.txtNumShelves.text.Integer;
			if numShelves &gt; 0 then
				foreach int in 1 to numShelves do
					create shelfProxy transient;
					shelfProxy.setDefaultProxy( int, locationProxy, null );
				endforeach;
				self.editBlockLocation();
			endif;
			
		endif;
		
	endif;		
epilog
	delete region;
end;</source>
    </JadeMethod>
