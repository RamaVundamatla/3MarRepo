    <JadeMethod name="tRoRoLaneLength" id="ad344001-824a-4ea5-af5d-b7a60f0b08c6">
        <source>tRoRoLaneLength();
/*

Purpose:		Update Freed Lenght for the Roro lane area	

Parameters:			

Return Value:		

Date		Who		Reason
20/04/2014	cnwma1	Initial creation

*/

vars
	roroArea  	: CM_RoRoLaneArea;
	firstLane,lastLane 	: CM_RoRoController;

	location	: CM_LocationsController;
begin

	// Delete Roro Area
	self.deleteTerminalArea("UMA1");
	// Create Roro Area
	roroArea := self.addROROArea("UMA1",7,60);
	assertNotNull(roroArea);
	
	// Get Location conroller

		
	location :=roroArea.allLocationsControllers.first;
	firstLane := location.CM_RoRoController;
	// Set Freed Length
	app.myTrxUA.trxUpdateRoRoLaneFreedLength(firstLane, 5, app.myPassport );
	assertNoTrxErrorsOrWarnings();
	assertEqual(firstLane.getSpareLength(),55.00);
	
	location :=roroArea.allLocationsControllers.last;
	lastLane := location.CM_RoRoController;
	// Set used  Length
	app.myTrxUA.trxUpdateRoRoLaneUsedLength(lastLane,40,app.myPassport);
	assertNoTrxErrorsOrWarnings();
	assertEqual(lastLane.getSpareLength(),20.00);
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tRotatingROROCellsActual" id="d8a04de5-da4a-4607-bb0e-6f217778fb95">
