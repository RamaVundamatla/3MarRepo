    <JadeMethod name="doNoteForObject" id="e598f441-9cd9-4ffd-8ad6-b4cc29279286">
        <updating/>
        <source>doNoteForObject(_anObject: Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		A Call Back Method. Called from SetForUpdate on the CMUI_GridPoint
// ---------------------------------------------------------------------------
vars
	aPoint : CMUI_GridPoint;
	theTI : CM_TrackedItem;
begin
	if self.tblGridAreaInfo.userObject = null or not global.isValidObject(self.tblGridAreaInfo.userObject) then
		return;
	endif;
	
	if _anObject &lt;&gt; null then
		if _anObject.isKindOf(CMUI_GridPoint) then
			aPoint := _anObject.CMUI_GridPoint;
			
			if self.tblGridAreaInfo.userObject.isKindOf(CM_TrackedItem) then
				theTI := self.tblGridAreaInfo.userObject.CM_TrackedItem;
				if self.sdf01.moveMode = REAL_MODE then
					if aPoint.myLocationsController &lt;&gt; null and aPoint.myLocationsController.allTrackedItems.includes(theTI) then
						self.showExtraInfoForObject(theTI);
					endif;
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegend" id="73a40923-a2e0-40fa-b779-e02039ba24a1">
        <source>doNotesForLegend(_startNote : Boolean);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	idx, numRows : Integer;
	theTable : Table;
begin

	theTable := self.frmColLegendTIs.myLegendTable;
	numRows := theTable.rows;

	foreach idx in 2 to numRows do
		anObject := theTable.accessRow(idx).itemObject;
		if global.isValidObject(anObject) then
			if _startNote then
				self.beginNotification(anObject, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			else
				self.endNotification(anObject, EVENT_CODE_COLOUR_CHANGE);
			endif;
		endif;
	endforeach;
	
	
end;</source>
        <Parameter name="_startNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegendStartStop" id="4fb5fdf6-3abb-4661-b7ed-44e41d0ae74b">
        <updating/>
        <source>doNotesForLegendStartStop(_theIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doNotesForLegend(false);
	if not self.frmColLegendTIs.displayViewModeCodes(self.sdf01.viewMode, self.sdf01.myDrawingAttrController) then
		self.frmColLegendTIs.doChangeViewMode(_theIndex);
	else
		self.doResize();
	endif;
	self.doNotesForLegend(true);

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="c9f1d98e-cc99-4eef-b3eb-71049f0a6898">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	inheritMethod();

	self.frmStatusLine.left := 0;
	self.frmStatusLine.top := self.height - self.frmStatusLine.height;
	self.frmStatusLine.width := self.clientWidth;
	self.frmStatusLine.doResize();

end;</source>
    </JadeMethod>
    <JadeMethod name="doScrollToCorner" id="348cca83-d5a7-46fb-af37-7a9dcb6420ac">
        <source>doScrollToCorner(_theSDF : CMUI_ScrollableDrawingFrame;  _theCorner : Integer);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	lHLabHeight, lVLabHeight,lFarRight, lFarBottom : Integer;
	lScrollBarV, lScrollBarH : Integer;
	theSDF : CMUI_ScrollableDrawingFrame;
	theGridFrame : CMUI_GridAreaFrame;
	theGridArea : CMUI_GridArea;
begin
	theSDF := _theSDF;
	if theSDF = null then
		return;
	endif;
	
	if theSDF &lt;&gt; null then
		theGridArea := theSDF.allGridAreasByRowColumn.first;
		if theGridArea &lt;&gt; null then
			theGridFrame := theGridArea.myGridAreaFrame;
			
			lFarBottom := theGridFrame.height.Integer - theSDF.height.Integer;
			lScrollBarV := theGridFrame.height.Integer;
			if theSDF.myHLabels.visible then
				lHLabHeight := theSDF.myHLabels.height.Integer;
			else
				lHLabHeight := 0;
			endif;
			lFarBottom := 1 - (lFarBottom + lHLabHeight);
	
	
			lFarRight := theGridFrame.width.Integer - theSDF.width.Integer;
			lScrollBarH := theGridFrame.width.Integer;
			if theSDF.myVLabels.visible then
				lVLabHeight := theSDF.myVLabels.width.Integer;
			else
				lVLabHeight := 0;
			endif;
			lFarRight := 1 - (lFarRight + lVLabHeight);
	
			if _theCorner = VIEW_LEFT_TOP then
				lFarBottom := lHLabHeight;
				lScrollBarV := 1;
				lFarRight := lVLabHeight;
				lScrollBarH := 1;
			elseif _theCorner = VIEW_RIGHT_TOP then
				lFarBottom := lHLabHeight;
				lScrollBarV := 1;
			elseif _theCorner = VIEW_LEFT_BOTTOM then
				lFarRight := lVLabHeight;
				lScrollBarH := 1;
			elseif _theCorner = VIEW_RIGHT_BOTTOM then
				// use defaults
			endif;
			// VERTICAL
			theSDF.myDrawingFrame.top := lFarBottom;
			if theSDF.myVLabels &lt;&gt; null then
				theSDF.myVLabels.top := lFarBottom;
				theSDF.myHScroll.value := lScrollBarH;
			endif;
			// HORIZONTAL
			theSDF.myDrawingFrame.left := lFarRight;
			if theSDF.myHLabels &lt;&gt; null then
				theSDF.myHLabels.left := lFarRight;
				theSDF.myVScroll.value := lScrollBarV;
			endif;
		endif;
	endif;


end;</source>
        <Parameter name="_theSDF" type="CMUI_ScrollableDrawingFrame"/>
        <Parameter name="_theCorner" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblPopupInfoDbClick" id="3142ec4f-bc8f-4bf2-95c0-088a072315f2">
        <updating/>
        <source>doTblPopupInfoDbClick(table : Table input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	obj	: Object;
begin
	if table.row &lt;= table.fixedRows or 
	   table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	obj := table.accessCell(table.row, table.column).itemObject.Object;
	if obj &lt;&gt; null then
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " "  );
		if obj.isKindOf(CM_GridController) then
			self.myAssistant.showTerminalAreaForm(obj.CM_LocationsController.myTerminalArea, self.myMasterMenuAction);
		elseif obj.isKindOf(CM_TrackedItem)  then
			self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, true, false);	
		elseif obj.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(obj.CM_Voyage, self.myMasterMenuAction, false, false);

		elseif obj.isKindOf(CM_SlotController) or 
			   obj.isKindOf(CM_SlotDefn) or 
			   obj.isKindOf(CMUI_GridPoint) or 
			   obj.isKindOf(CM_SlotRequest) or 
			   obj.isKindOf(CM_Bay) or 
			   obj.isKindOf(CM_WorkListEntry) or
			   obj.isKindOf(CM_Voyage) then
			if app.isAllowedToInspect() then
				obj.inspect;
			endif;

		elseif obj.isKindOf(CM_Object) then
			self.myAssistant.showTableMaintForm(obj.CM_Object, self.myMasterMenuAction, true, true);
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTurnOffContextMenus" id="c66e75d3-0753-4a8b-a9db-baea12e00e52">
        <source>doTurnOffContextMenus();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	mnuChild : MenuItem;	
	idx : Integer;

begin

	self.mnuCargoManagement.visible := false;
	self.mnuTaskAdd.visible := true;
	self.mnuWorkShowTips.visible := false;
	self.mnuTaskComplete.visible := true;
	self.mnuStops.visible := true;
	self.mnuGridShowTips.visible := false;
	self.mnuGridSeperator01.visible := true;
	self.mnuGridBigFont.visible := false;
	self.mnuGridSelector.visible := false;
	self.mnuGridSelectorClear.visible := false;
	self.mnuCargo.visible 	:= false;
	self.mnuSubBlock.visible 	:= false;
	self.mnuRestriction.visible := false;
	self.mnuStockMovements.visible := false;
	self.mnuLog.visible 		:= false;
	self.mnuZoomSub.visible := false;
	self.mnuMove.visible := false;
	self.mnuDisplay.visible := false;
	self.mnuOther.visible := false;
	self.mnuLcnAreaMain.visible 	:= false;
	self.mnuLcnPadMain.visible 	:= false;
	self.mnuGridPrint.visible 	:= false;
	self.mnuCargoErase.visible := false;
	// Clear Out The Clones
	foreach idx in 1 to 20 do
		mnuChild := 	self.mnuCargoErase.getMenuItem(idx);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
	endforeach;
	self.mnuGridFlipH.visible := false;
	self.mnuGridFlipV.visible := false;
	self.mnuGridSelectAreas.visible := false;
	self.mnuGridNewJob.visible := false;
	self.mnuGridPlanDischarge.visible := false;
	self.mnuGridPlanLoad.visible := false;
	self.mnuGridTBA.visible := false;
	self.mnuGridReverse.visible := false;
	self.mnuGridShuffle.visible := false;
	self.mnuGridSelectCargo.visible := false;
	self.mnuGridSetSeed.visible := false;
	self.mnuGridBulkEdit.visible := false;
	self.mnuGridAutoplan.visible := false;
	self.mnuGridHideLegend.visible := true;
	self.mnuGridHideToolbar.visible := true;
	self.mnuGridSelector.visible := not self.sdf01.allGridAreasByRowColumn.isEmpty;
end;</source>
    </JadeMethod>
