    <JadeMethod name="isSlotNumberFree" id="c2e7a2a5-6223-4305-9ca1-88ff0a45dd23">
        <source>isSlotNumberFree(_intendedTI : CM_TrackedItem;
					_posInStack : Integer;
					_intendedIsoType : CM_ISOType;
					_intendedIsoTypeGroup : CM_ISOTypeGroup;
					_mode : Integer;
					_doValidations : Boolean;
					_slotNo : Integer;
					_slotLC : CM_WagonController) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwphb1	Initial creation (Par 21725)

*/

vars
	numCurrently, numLCs,
	numUnitsRequired,
	pos, totalToBeUsed,
	errorPosition		: Integer;
	tiActual, tiQueue,
	tiPlan				: CM_TrackedItem;
	isPN				: Boolean;
	lc					: CM_WagonController;
	cmifControl			: CMIF_MoveController;
	rulesMet			: CM_WagonPositionalRuleSet;
	trackClearance		: CM_TrackClearance;
	clearanceError		: String;
begin
	if _intendedIsoType &lt;&gt; null then
		numUnitsRequired := _intendedIsoType.getLengthInUnitsForWagon - 1; // minus 1 because we are inclusive
	elseif _intendedIsoTypeGroup &lt;&gt; null then
		numUnitsRequired := _intendedIsoTypeGroup.getLengthInUnitsForWagon - 1; // minus 1 because we are inclusive
	else
		numUnitsRequired := _intendedTI.getLengthInUnits().Integer - 1; // minus 1 because we are inclusive
	endif;
	// How big is the wagon?
	isPN := _intendedTI.state =  TI_STATE_NOTIFIED or _intendedTI.state = TI_STATE_UNDEFINED;
	
	// Check the controller. Is it avail, empty, and the locations after it empty, for the required length?
	
	if (not _slotLC.CM_WagonController.isAvailable) then
		return false;
	endif;
		
	// Check overstow is ok
	if _slotLC.numTIs &gt; 0 then
		tiActual := _slotLC.getTIAtIndex(REAL_MODE, _slotLC.allTrackedItems.size);
		if tiActual &lt;&gt; null then
			if self.isTIOutward(tiActual) or	// This TI is on the wagon and will be worked off
			   isPN then						// Create 2 prenotes for same wagon and they both go to position 1
				if (_slotLC.numQueuedTIs + _slotLC.numTIs) &gt;= _posInStack then	// Is Full
					return false;
				endif;
				//if not tiActual.isOverStowable(_intendedTI,_intendedIsoType) then
				if not tiActual.isOverStowableOnWagon(self,_intendedTI,_intendedIsoType,_intendedIsoTypeGroup) then//10 May 2010	NDL Par 24064
					return false;
				endif;
			endif;
		endif;
	endif;

	if _slotLC.numQueuedTIs &gt; 0 then
		tiQueue := _slotLC.getTIAtIndex(QUEUE_MODE, _slotLC.allQueuedFutureMoves.size);
		//if tiQueue &lt;&gt; null and not tiQueue.isOverStowable(_intendedTI,_intendedIsoType) then
		if tiQueue &lt;&gt; null and not tiQueue.isOverStowableOnWagon(self,_intendedTI,_intendedIsoType,_intendedIsoTypeGroup) then//10 May 2010	NDL Par 24064
			return false;
		endif;
	endif;
	if _slotLC.numPlannedTIs &gt; 0 then
		tiPlan := _slotLC.getTIAtIndex(PLANNING_MODE, _slotLC.allPlannedFutureMoves.size);
		//if tiPlan &lt;&gt; null and not tiPlan.isOverStowable(_intendedTI,_intendedIsoType) then
		if tiPlan &lt;&gt; null and not tiPlan.isOverStowableOnWagon(self,_intendedTI,_intendedIsoType,_intendedIsoTypeGroup) then//10 May 2010	NDL Par 24064
			return false;
		endif;
	endif;
	
	if _intendedIsoType &lt;&gt; null then
		if not _slotLC.allRailWLELoad.isEmpty then
			if _slotLC.allRailWLELoad[_posInStack] &lt;&gt; null then
				// Already earmarked a release request for this position in stack
				return false;
			endif; 
		endif;
	endif;

	// The slot number is empty
	numLCs := self.myWagonClass.getLenInUnits;
	totalToBeUsed := _slotNo + numUnitsRequired;
	if totalToBeUsed &gt; numLCs then	// Too big
		return false;
	endif;

	// check that our TI will fit i.e. that the LCs that the TI will cover are also MT and Avail
	foreach pos in _slotNo to totalToBeUsed do
		lc := self.allLocationsControllersArray[pos];
		
		if (not lc.CM_WagonController.isAvailable) then
			return false;	// Unavailable or full
		endif;

		if lc.numTIs &gt; 0 or tiActual &lt;&gt; null then
			if lc.numTIs = 0 or
			   tiActual &lt;&gt; lc.getTIAtIndex(REAL_MODE, lc.allTrackedItems.size) then
				return false;	// Unavailable or cannot overstow (note that overhang is not permitted)
			endif;
		endif;

		if lc.numQueuedTIs &gt; 0 or tiQueue &lt;&gt; null then
			if lc.numQueuedTIs = 0 or
			   tiQueue &lt;&gt; lc.getTIAtIndex(QUEUE_MODE, lc.allQueuedFutureMoves.size) then
				return false;	// Unavailable or cannot overstow (note that overhang is not permitted)
			endif;
		endif;

		if lc.numPlannedTIs &gt; 0 or tiPlan &lt;&gt; null then
			if lc.numPlannedTIs = 0 or
			  tiPlan &lt;&gt; lc.getTIAtIndex(PLANNING_MODE, lc.allPlannedFutureMoves.size) then
				return false;	// Unavailable or cannot overstow (note that overhang is not permitted)
			endif;
		endif;
		
		//if _intendedIsoType &lt;&gt; null then
		if _intendedIsoType &lt;&gt; null or _intendedIsoTypeGroup &lt;&gt; null then	//10 May 2010	NDL Par 24064
			if not lc.allRailWLELoad.isEmpty then
				if lc.allRailWLELoad[_posInStack] &lt;&gt; null then
					// Already earmarked a release request for this position in stack
					return false;
				endif;
			endif;
		endif;
	endforeach;
	
	// Slot is free
	if _doValidations then
		create cmifControl transient;
		cmifControl.setMyToPrimaryLocation(self.allLocationsControllersArray[_slotNo]);
		cmifControl.setMyTrackedItem(_intendedTI);
		if self.myWagonMaster &lt;&gt; null then
			if self.myWagonMaster.myWagonClass &lt;&gt; null then
				if not self.myWagonMaster.myWagonClass.allWagonPositionalRules.loadMeetsWagonPositionalRule(cmifControl, self, errorPosition, rulesMet) then
					// Not right for this position on the wagon
					return false;
				endif;
			endif;
		endif;
		if self.myTrainOutwards &lt;&gt; null then
			trackClearance := self.myTrainOutwards.myTrackClearance;
			if trackClearance &lt;&gt; null then
				clearanceError := self.validateUsingTrackClearance(cmifControl, trackClearance, _mode, false, false);
				if clearanceError &lt;&gt; null then
					// Exceeds track clearance settings in this pos.
					return false;
				endif;
			endif;
		endif; 
	endif;

	return true;
epilog
	delete cmifControl;
end;</source>
        <Parameter name="_intendedTI" type="CM_TrackedItem"/>
        <Parameter name="_posInStack" type="Integer"/>
        <Parameter name="_intendedIsoType" type="CM_ISOType"/>
        <Parameter name="_intendedIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_doValidations" type="Boolean"/>
        <Parameter name="_slotNo" type="Integer"/>
        <Parameter name="_slotLC" type="CM_WagonController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTIOutward" id="4a95e83f-0039-4ce9-b716-df46c3272a0d">
        <source>isTIOutward(_ti : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by cnwab1, PAR 20068
//
// This method is needed so that cargo that is on a wagon can be deemed to be there for the outward journey
//	The wagon has a collection of all received and released TIS but these collections are only populated when the wagon is confirmed in or oout.
// Before being confirmed the TIs are on the wagon locations, but if they are there because they are about to be confirmed IN but are actually exports then we do not want to see them in the out list.
// When the wagon is confirmed we just look at the collections of TIs on the wagon, prior to that we have to ask questions of the TIs.
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	railJob	: CM_RailJob;
	wle : CM_WorkListEntry;
	locCont : CM_LocationsController;
	splitTrx : CM_Split;
	
begin
	if _ti = null then
		return false;
	endif;
	
	if _ti.isInTransitOnShip then // If it is in transit then it can be on the outward view
		return true;
	endif;
	
	// it was received so as it is not in transit it's a no, this TI will be worked off the wagon.
	if self.allTIsReceived.includes(_ti) then
	
		//26 Feb 2010 NDL	Par 22511
		//If it came in on this wagon, and the wle is completed, but has been worked back onto
		//the same wagon for the trip out, its valid.
		railJob := self.getReceiveJob; // the inward job.
		if railJob &lt;&gt; null then
			wle := railJob.getTIWLE(_ti);	// the wle for the unload of the receival
			if wle &lt;&gt; null and wle.status = WLE_COMPLETED then
				locCont := _ti.myPrimaryActualLocation;	// current location
				if locCont &lt;&gt; null and locCont.isWagon() then
					return locCont.CM_WagonController.myWagon = self;
				endif;
			endif;
		endif;
		
		return false;
	endif;
	
	// OK it is on the wagon but it has never been received so it must be an unconfirmed export TI, that will be worked off the wagon
	//  		if it had a receive transaction it means that its on the wagon but it has come from the yard via road, ship, rail.
	if _ti.getTransReceive() = null then
		//19 Sep 2013	NDL Par 32479
		if _ti.canMergeBreakBulk then
			//If it has been split from other cargo we will assume is was in the yard at some stage.
			splitTrx := _ti.getLastTransOfType(TRANS_TYPE_SPLIT).CM_Split;
			if splitTrx &lt;&gt; null then
				return true;
			endif;
		else
			return false;
		endif;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isThereRoomForTi" id="089481db-e0a5-4881-91a3-24f2e4b69561">
        <source>isThereRoomForTi( _primaryWagonController : CM_WagonController; _ti : CM_TrackedItem ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2017	cnwndl1	Initial creation	TFS 2314 - temporary method moved from HH layer for web call

*/

vars

	primaryPortion : Integer;
	availableLengthFreeSpace : Integer;
	tiLen : Integer;
	iter : Iterator;
	wagCont : CM_WagonController;
	atHeight : Integer;
	tiSize 	 : Integer;
begin

	if _ti = null then
		return false;
	endif;
	
	if _primaryWagonController = null then
		return false;
	endif;

	if _primaryWagonController.offsetFlexi = 0 then
		primaryPortion := 10;
	else
		primaryPortion := (10 - _primaryWagonController.offsetFlexi).Integer;
	endif;
	
	availableLengthFreeSpace := primaryPortion;
	tiLen := _ti.getActualLength().Integer;
	
	if availableLengthFreeSpace &gt;= tiLen then
		return true;
	endif;
	
	//15 Oct 2014	NDL	Par 35040
	atHeight := 1;
	if self.myWagonClass &lt;&gt; null and self.isFlatcar then
		if self.myWagonClass.maxNumInStack &gt; 1 and _primaryWagonController.allTrackedItems.size &lt; self.myWagonClass.maxNumInStack then
			atHeight := _primaryWagonController.allTrackedItems.size + 1;
		endif;
	endif;
	
	iter := self.allLocationsControllersArray.createIterator;
	iter.startAtObject(_primaryWagonController);
	while iter.next( wagCont ) do
		if wagCont = _primaryWagonController then
			//skip the starting one, we've already added it.
			continue;
		endif;
		
		tiSize := wagCont.allTrackedItems.size;
		if wagCont.allTrackedItems.includes(_ti) then
			tiSize := tiSize - 1;
		endif;
	//	if not wagCont.allTrackedItems.isEmpty then
		if  tiSize&gt;= atHeight then
			//no more room.
			return false;
		else
			//if not wagCont.allTrackedItems.includes(_ti) then
			//found another 10 contiguous feet
				availableLengthFreeSpace := availableLengthFreeSpace + 10;
		//	endif;
		endif;
		if availableLengthFreeSpace &gt;= tiLen then
			return true;
		endif;
	endwhile;
	if availableLengthFreeSpace &gt;= tiLen then
		return true;
	endif;
	return false;
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_primaryWagonController" type="CM_WagonController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
