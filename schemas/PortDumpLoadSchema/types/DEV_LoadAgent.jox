    <JadeMethod name="loadHMSVessel" id="678d73c3-c2a0-44f6-8126-bc590872637c">
        <source>loadHMSVessel(_vesselProxy:CM_Vessel io) :Boolean protected;

vars
	realObject, proxyObject: CM_Vessel;
	error: CM_Error;
	conflictManager: CMIF_HMS_ConflictsManager;
	countError,countOK: Integer;
begin
	realObject := app.myRoot.allVessels[_vesselProxy.code];
	if realObject = null then
		app.myTrxCA.trxCreateVessel(_vesselProxy, realObject, conflictManager, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_vesselProxy.code&amp;" ERROR: "&amp;"Vessel already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_vesselProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_vesselProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
