    <JadeMethod name="getTiTxnTypesForMoveFromToLC" id="d3a939e7-2fdb-4d58-bdcd-85f835e8112b">
        <source>getTiTxnTypesForMoveFromToLC(_toController: CM_LocationsController; _intArray: IntegerArray input; _moveController : CMIF_MoveController);
//----------------------------------------------------------------
//	Created:	12 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	txn		: CM_TITransaction;
	origArea: CM_TerminalArea;
begin
	inheritMethod(_toController, _intArray, _moveController);

	if _toController &lt;&gt; null
	and _toController.myTerminalArea &lt;&gt; null then		//the controller is onsite somewhere
		if _toController.myTerminalArea.type = TA_TYPE_DELETE then
			return;
		endif;
		
		origArea := self.myTerminalArea;	
		if origArea &lt;&gt; null 
		and origArea.type = TA_TYPE_DELETE then	//area is LDA
			//moving out of an LDA - transactions are logically deleted
			//check for receival and create one if none found
			theTI := _moveController.myTrackedItem;
			if theTI &lt;&gt; null then
				txn := theTI.getLastTransOfTypeAdv(TRANS_TYPE_RECEIVE);
				if txn = null then
					//no rec trans - create one for this ti/move
					_intArray.add(TRANS_TYPE_REC_ROAD);
					app.addTiTxnSubTerminalReceive(theTI, TI_TRANSMODE_ROAD, _intArray);		// CCMS 1875.
				endif;	
			endif;	
		endif;
	endif;

end;</source>
        <Parameter name="_toController" type="CM_LocationsController"/>
