    <JadeMethod name="cloneReferences" id="04be5b3a-b0d9-4a07-90a6-62f5b2232e73">
        <updating/>
        <source>cloneReferences(_obj: CMQF_InvoiceLine; _transient: Boolean) updating;

vars

begin
	inheritMethod(_obj, _transient);
	
	self.allCompanies.clear();
	_obj.allCompanies.copy(self.allCompanies);
	
	self.setMyConsignee( _obj.getMyConsignee );
	self.setMyDebtor( _obj.getMyDebtor );
	self.setMyInvoice( _obj.getMyInvoice );
	self.setMyInvoiceLineType( _obj.getMyInvoiceLineType );
	self.setMyInvoiceType( _obj.getMyInvoiceType );
	self.setMyVoyage( _obj.getMyVoyage );
	self.setMyShippingLine(_obj.getMyShippingLine);	 // ### TFS BUG 56660 23FEB2023 NAVAB1
	
end;
</source>
        <Parameter name="_obj" type="CMQF_InvoiceLine"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="1ecdf3fd-3946-407f-ba5c-bc928add5ae1">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// invoice line filtering
// 16/11/2016 cnwrh7	TFS2934 Invoice Report and Line Report type error

vars

	iter : Iterator;
	bank	: CM_Bank;
	invoiceLine : CM_InvoiceLine;
	breakOut : Boolean;
	passport : CM_Passport;

begin
	// 34442 financial selector reports
	if (not self.allQueryCriteriaHolders.isEmpty) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;

	passport := app.myPassport;
	bank := self.allCompanies.first;
	
	// invoice 37009
	if bank &lt;&gt; null then																														//+TFS2934 In case Company not beling included in Report Criterial On Report Maintenance Form
		self.setMyInvoice( bank.allInvoices[bank.terminal, bank, self.invoiceNumber] );
	endif;
	// if not found, return so don't print anything
	if self.invoiceNumber &lt;&gt; null and
	   self.getMyInvoice = null then
		return;
	endif;
	if self.getMyInvoice &lt;&gt; null then
		iter := self.getMyInvoice.invoiceLines.createIterator;
		while iter.next(invoiceLine) do
			if self.includesObject(invoiceLine, passport, breakOut) then
				_collection.add(invoiceLine);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
				
	// debtor but no invoice
	elseif self.getMyDebtor &lt;&gt; null then
		iter := self.getMyDebtor.invoiceLines.createIterator;
		while iter.next(invoiceLine) do
			if self.includesObject(invoiceLine, passport, breakOut) then
				_collection.add(invoiceLine);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
			
	// company but no debtor or invoice, all other filtering covered in includesObject
	elseif bank &lt;&gt; null then
		iter := bank.invoiceLines.createIterator;
		while iter.next(invoiceLine) do
			if self.includesObject(invoiceLine, passport, breakOut) then
				_collection.add(invoiceLine);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
			
	endif;

epilog

	delete iter;

end;
</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="d8b1337a-492b-4926-bd1e-5b09e774f6e6">
        <source>filterSelectorQuery(_collection  : Collection input;
					_passport : CM_Passport) protected;
//	34442 Oct 2014 for invoice line selector reports
vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;

begin

	// Special one because we need the copy
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Invoicing_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.Invoicing_Query_Type, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyConsignee" id="57dadd69-2033-4b21-b46b-5198b14196fd">
        <source>getMyConsignee():CM_ConsigneeConsignor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_ConsigneeConsignor;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myConsignee;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
