    <JadeMethod name="setSpkPandu" id="ccfd61cc-4e47-4172-9f2f-6ba92e7478d8">
        <source>setSpkPandu(	_agent : CM_InaportnetWSConsumerAgent input;
				_success : Boolean io) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlger1	Initial creation 39322
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
23 May 2019	jlgsl4	TFS 44918 - PEL1 - multiple pilot names being truncated; need 2nd pilot launch
*/

vars

	request			: CMIF_IPNSetSpkPanduReq;
	response		: CMIF_IPNSetSpkPanduResp;
	movement 		: HMS_VoyageMovement;
	pilotLaunchTime : TimeStamp;
	iter			: Iterator;
	tugCount		: Integer;
	tug		: 	HMS_Tug;
	workOrder	: CM_WorkOrderVoyageDtl;
	pilotLaunch : HMS_PilotLaunch;	//09 Nov 2018	NDL	TFS 41826
begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	
	if self.myVoyage.status = Voyage_Status_IInitSerConfirm then
		movement :=self.myVoyage.getMovementArrival;	
		workOrder:=self.myVoyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL).CM_WorkOrderVoyageDtl;
	elseif self.myVoyage.status = Voyage_Status_IShiftApp then
		movement :=self.myVoyage.getLastMovementShift;
		workOrder:=self.myVoyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_SHIFTMOVEMENT).CM_WorkOrderVoyageDtl;
	elseif self.myVoyage.status = Voyage_Status_IDepReqApp then
		movement :=self.myVoyage.getMovementDeparture;
		workOrder:=self.myVoyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART).CM_WorkOrderVoyageDtl;
	endif;
	
	create request transient;
	request.nomorPKK:=self.myVoyage.getInaportnetPKK;
	request.nomorPPK:=movement.getInaportnetPPK;
	request.nomorSPKPandu:= workOrder.getInaportnetSPK;
	request.jenisPandu:="LAUT";
	
	if movement &lt;&gt; null then
	
		//06 Nov 2018	NDL	TFS 41826, 09 Nov 2018 NDL TFS 41826
		pilotLaunch := movement.getFirstPilotLaunch(); //myPilotLaunch; // TFS 44438
		if pilotLaunch &lt;&gt; null then
			request.namaKapalPandu1 := pilotLaunch.description; // TFS 44438
		endif;

		pilotLaunch := movement.getSecondPilotLaunch(); // --&gt; TFS 44918 - 2nd not 1st launch
		if pilotLaunch &lt;&gt; null then
			request.namaKapalPandu2 := pilotLaunch.description;
		endif; // &lt;-- TFS 44918 - 2nd not 1st launch

		//name pilot officer
		/*if movement.getUnConvertedMyPilotRef &lt;&gt; null then // --&gt; TFS 44918
			request.namaPetugasPandu := movement.getUnConvertedMyPilotRef.description; //[1:50]; // TFS 44918
		else*/ // &lt;-- TFS 44918
		if movement.getFirstPilot() &lt;&gt; null then
			request.namaPetugasPandu := movement.getFirstPilot().description; //getPilotsSummary()[1:50]; // TFS 44918
		endif;
		//endif; // TFS 44918
		
		pilotLaunchTime:= movement.getPilotLaunchTime;
		//date of pilot 
		request.tanggalPandu:=pilotLaunchTime.date.asStringInaportnet;  //the date 
		//time of pilot
		request.jamPandu:=pilotLaunchTime.time.asStringInaportnet; //supposed to be a time ??? 
		
		// "Masuk" = arrival , "Pindah" = shift, "Labuh" = anchored @ sea, "Keluar" = departure 
		request.kegiatan:=movement.getInaportnetKegiatan; //think this means move
	
		//time of motion
		request.waktuGerak:= movement.occursOnDT.Date;
	endif;
	
	tugCount:=0;
	iter:= movement.allTugsUsed.createIterator;
	while iter.next(tug) do
		tugCount:=tugCount +1;
		if tugCount = 1 then
			request.namaKapalTunda1:=tug.description;
		elseif tugCount = 2 then
			request.namaKapalTunda2:=tug.description;
		elseif tugCount = 3 then	
			request.namaKapalTunda3:=tug.description;
		elseif tugCount = 4 then	
			request.namaKapalTunda4:=tug.description;
			break;
		endif;
	endwhile;	
	
	movement.getInaportnetBerthsStartEnd(request.lokasiAwal,request.lokasiAkhir);
		
	//activities 
	
	
	
	response := _agent.setSpkPandu(request);
	//epr TFS 42098 23/11/18
	self.updateActivityHistory(_agent,response);
	// Check for timeout
	if response &lt;&gt; null then
		_success:=response.isSuccess;
		return true;
	else
		return false;
	endif;
		
epilog
	delete request;
	delete response;
end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_InaportnetWSConsumerAgent" usage="input"/>
        <Parameter name="_success" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
