    <JadeMethod name="addRowToSchedule" id="a7d8a161-22f1-4d79-b55d-3cd0e642c848">
        <updating/>
        <source>addRowToSchedule(_dateTime: TimeStamp; _col1Value: String; _col2Value: String; _col3Value: String; _atRow : Integer) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	localDateTime : TimeStamp;
begin
	row := _atRow;
	//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	localDateTime := self.systemToLocalTime(localDateTime);
	if row = 0 then
		row := self.tblSchedule.addItem( localDateTime.asStringJMT() );
	else
		self.tblSchedule.addItemAt( localDateTime.asStringJMT(), row);
	endif;
	
	self.tblSchedule.accessColumn(1).visible := false;
	//self.tblSchedule.accessCell(row,1).  itemObject := localDateTime;
	self.tblSchedule.accessCell(row,1).gridRight := false;	
	self.tblSchedule.accessCell(row,2).gridRight := false;
	//self.tblSchedule.accessCell(row,3).gridRight := false;	
	
	if _col1Value &lt;&gt; null then
		self.tblSchedule.accessCell(row,2).text := _col1Value &amp; CrLf &amp; _col2Value;	
	else
		self.tblSchedule.accessCell(row,2).text :=  _col2Value;	
	endif;
	
//	self.tblSchedule.accessCell(row,2).text := _col1Value;
	//self.tblSchedule.accessCell(row,3).text := _col2Value;
	self.tblSchedule.accessCell(row,3).text := _col3Value;
	if localDateTime.date.day mod 2 = 1 then
		self.tblSchedule.accessCell(row, 1).backColor := self.colorRow1;
		self.tblSchedule.accessCell(row, 2).backColor := self.colorRow1;
		self.tblSchedule.accessCell(row, 3).backColor := self.colorRow1;
		//self.tblSchedule.accessCell(row, 4).backColor := self.colorRow1;
	else
		self.tblSchedule.accessCell(row, 1).backColor := self.colorRow2;
		self.tblSchedule.accessCell(row, 2).backColor := self.colorRow2;
		self.tblSchedule.accessCell(row, 3).backColor := self.colorRow2;
	//	self.tblSchedule.accessCell(row, 4).backColor := self.colorRow2;
	endif;
		
end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_col1Value" type="String"/>
        <Parameter name="_col2Value" type="String"/>
        <Parameter name="_col3Value" type="String"/>
        <Parameter name="_atRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addScheduleDetails" id="86d1ca10-d721-4187-a73b-22c16e0cd881">
        <updating/>
        <source>addScheduleDetails(_schedule : CM_WorkOrderSchedule; _row : Integer) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		Add schedule details
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	col : Integer;
	lastWorkOrder : CM_WorkOrder;
	numberActioned,
	numberCompleted, 
	numWorkOrders: Integer;
	taskType : Object;
	tbl : CM_BaseTable;
	plannedText,
	actionedText,
	completeText : String;
	woSet : CM_WorkOrderSet;
begin

	
	tbl := self.tblSchedule;

	taskType := self.getTaskTypeForWoDtl(_schedule.myParent);
	
	col := tbl.fixedColumns + 1;
	while col &lt; tbl.columns do
		if self.getTaskTypeForColumn(col) = taskType then
			break;
		endif;
		col := col + self.TaskColumns;
	endwhile;
	
	if col &gt;= tbl.columns then
		return;
	endif;
			
	//  # Work Order
	//createWorkOrderSet
	woSet :=  tbl.accessCell(_row, col).itemObject.CM_WorkOrderSet;
	
	if woSet = null then
		woSet := self.createWorkOrderSet();
		woSet.add ( _schedule.myParent.myParent ) ;
		tbl.accessedCell.text := (tbl.accessedCell.text.asIntegerJMT() + 1).asStringJMT();
		tbl.accessedCell.itemObject := woSet;
	else
		if not woSet.includes(_schedule.myParent.myParent)  then
			woSet.add ( _schedule.myParent.myParent ) ;
			tbl.accessedCell.text := (tbl.accessedCell.text.asIntegerJMT() + 1).asStringJMT();		
		endif;
	
	endif;
	/*
	
	lastWorkOrder := tbl.accessCell(_row, col).itemObject.CM_WorkOrder;
	
	if _schedule.myParent.myParent &lt;&gt; lastWorkOrder then
		tbl.accessedCell.text := (tbl.accessedCell.text.asIntegerJMT() + 1).asStringJMT();
		tbl.accessedCell.itemObject := _schedule.myParent.myParent;
//		self.tblSummary.accessCell(self.TotalRow, _col);
//		self.tblSummary.accessedCell.text := (self.tblSummary.accessedCell.text.asIntegerJMT() + 1).asStringJMT();
	endif;
	*/

	//  Planned
	
	tbl.accessCell(_row, col+1);
	plannedText := (tbl.accessedCell.text.asIntegerJMT() + _schedule.numberScheduled).asStringJMT();
	
	if plannedText &lt;&gt; '0' then
		tbl.accessedCell.text := plannedText;
	else
		tbl.accessedCell.text := '';
	endif;
	
	self.tblSummary.accessCell(self.TotalRow, col+1);	
	self.tblSummary.accessedCell.text := (self.tblSummary.accessedCell.text.asIntegerJMT() + _schedule.numberScheduled).asStringJMT();

	//  Actioned
	
	numberActioned := _schedule.getNumberActioned();

	tbl.accessCell(_row, col+2);
	actionedText :=(tbl.accessedCell.text.asIntegerJMT() + numberActioned).asStringJMT();
	if actionedText &lt;&gt; '0' then
		tbl.accessedCell.text := actionedText;
	else
		tbl.accessedCell.text := '';
	endif;
	
	self.tblSummary.accessCell(self.TotalRow, col+2);
	self.tblSummary.accessedCell.text := (self.tblSummary.accessedCell.text.asIntegerJMT() + numberActioned).asStringJMT();
	
	
	//  Complete
	
	numberCompleted := _schedule.getNumberComplete();

	tbl.accessCell(_row, col+3);
	completeText :=(tbl.accessedCell.text.asIntegerJMT() + numberCompleted).asStringJMT();
	if completeText &lt;&gt; '0' then
		tbl.accessedCell.text := completeText;
	else
		tbl.accessedCell.text := '';
	endif;
	
	self.tblSummary.accessCell(self.TotalRow, col+3);
	self.tblSummary.accessedCell.text := (self.tblSummary.accessedCell.text.asIntegerJMT() + numberCompleted).asStringJMT();

epilog

end;</source>
        <Parameter name="_schedule" type="CM_WorkOrderSchedule"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="504454f7-1ece-4ba9-a27f-caf83348c818">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	toolbar : CMUI_Toolbar;
	
begin

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);

//	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.zOrder(1);	
	toolbar.visible := true;
	
	//  Query Toolbar
	
	toolbar := self.frmQueryToolbar;

	toolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.zOrder(1);	
	toolbar.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
