    <JadeMethod name="setDebtorLongNameStr" id="d0568adc-f2d0-4115-823b-28c0dac41a69">
        <updating/>
        <source>setDebtorLongNameStr( _tiSet : CM_TISet; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	cusAgent : CM_CustomsAgent;
	allDebtors : CM_DebtorSet;
	debtor : CM_Debtor;
	ti : CM_TrackedItem;
	drNameStr : String;
	completeStr : String;

begin

	create allDebtors transient;
	
	foreach ti in _tiSet do
		cusAgent := ti.myCustomsAgent;
		if cusAgent = null then
			continue;
		endif;
		debtor := cusAgent.myDebtor;
		if debtor &lt;&gt; null then
			allDebtors.addNoDuplicates( debtor, false );
		endif;
	endforeach;
	
	foreach debtor in allDebtors do
		drNameStr  := debtor.longName;
		if drNameStr.trimBlanks &lt;&gt; null then
			if completeStr = null then
				completeStr := drNameStr;
			else
				completeStr := completeStr &amp; _delim &amp; drNameStr;
			endif;
		endif;
	endforeach;
	
	self.debtorLongNameStr := completeStr;

epilog

	delete allDebtors;

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDeliveryOrderNumberStr" id="b118a7b7-2bcb-4738-93b2-02e0d3cdc5d1">
        <updating/>
        <source>setDeliveryOrderNumberStr( _tiSet : CM_TISet; _nullVoyage: CM_Voyage; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	bolNumber : String;
	voyage : CM_Voyage;
	allBols : CM_BOLSet;
	ti : CM_TrackedItem;
	str : String;
	bol : CM_BOL;
	passedDelOrderNumArray : StringArray;
	localDelOrderNumArray : StringArray;
	completeStr : String;

begin

	create allBols transient;
	create passedDelOrderNumArray transient;
	create localDelOrderNumArray transient;
	
	foreach ti in _tiSet do
		bolNumber := ti.billOfLading;
		if bolNumber.trimBlanks = null then
			continue;
		endif;
		voyage := ti.myVoyage;
		if voyage = null or voyage = _nullVoyage then
			continue;
		endif;
		bol := voyage.getBOL(bolNumber);
		if bol &lt;&gt; null then
			allBols.addNoDuplicates( bol, false );
		endif;
	endforeach;
	
	foreach bol in allBols do
		passedDelOrderNumArray.clear();
		bol.getDeliveryOrderNums( passedDelOrderNumArray );
		if not passedDelOrderNumArray.isEmpty then
			foreach str in passedDelOrderNumArray do
				if str.trimBlanks = null then
					continue;
				endif;
				if not localDelOrderNumArray.includes( str ) then
					localDelOrderNumArray.add( str );
				endif;
			endforeach;
		endif;
	endforeach;
	
	foreach str in localDelOrderNumArray do
		if completeStr = null then
			completeStr := str;
		else
			completeStr := completeStr &amp; _delim &amp; str;
		endif;
	endforeach;
	
	self.deliveryOrderNumberStr := completeStr;

epilog

	delete allBols;
	delete passedDelOrderNumArray;
	delete localDelOrderNumArray;

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_nullVoyage" type="CM_Voyage"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a7c7dc17-65cb-4df4-8cca-81f355b44d38">
        <updating/>
        <source>setForUpdate(	_proxy : CM_WaybillPrintDetail ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

begin
	
	self.agentsOperativeStr := _proxy.agentsOperativeStr;
	self.billOfEntryNumberStr := _proxy.billOfEntryNumberStr;
	self.billOfLadingNumberStr := _proxy.billOfLadingNumberStr;
	self.checkedBy := _proxy.checkedBy;
	self.consigneeStr := _proxy.consigneeStr;
	self.containerNumberStr := _proxy.containerNumberStr;
	self.debtorLongNameStr := _proxy.debtorLongNameStr;
	self.deliveryOrderNumberStr := _proxy.deliveryOrderNumberStr;
	self.driversLicenseNumberStr := _proxy.driversLicenseNumberStr;
	self.driversNameStr := _proxy.driversNameStr;
	self.goodsDescriptionStr := _proxy.goodsDescriptionStr;
	self.isProForma := _proxy.isProForma;
	self.loadingCommencedStr := _proxy.loadingCommencedStr;
	self.loadingCompletedStr := _proxy.loadingCompletedStr;
	self.marksAndNumbersStr := _proxy.marksAndNumbersStr;
	self.numberOfPackagesStr := _proxy.numberOfPackagesStr;
	self.operativeIdNumberStr := _proxy.operativeIdNumberStr;
	self.packageTypeStr := _proxy.packageTypeStr;
	self.pdf147BarcodePic := _proxy.pdf147BarcodePic;
	self.pdf147BarcodeStr := _proxy.pdf147BarcodeStr;
	self.placeOfLoadingStr := _proxy.placeOfLoadingStr;
	self.printDateTimeStr := _proxy.printDateTimeStr;
	self.releaseDateStr := _proxy.releaseDateStr;
	self.releaseInstructionsStr := _proxy.releaseInstructionsStr;
	self.remarksStr := _proxy.remarksStr;
	self.rotationNumberStr := _proxy.rotationNumberStr;
	self.tallyClerk := _proxy.tallyClerk;
	self.vehicleExitStr := _proxy.vehicleExitStr;
	self.vehicleRegistrationNumberStr := _proxy.vehicleRegistrationNumberStr;
	self.vesselArrivalDateStr := _proxy.vesselArrivalDateStr;
	self.vesselStr := _proxy.vesselStr;
	self.waybillDateStr := _proxy.waybillDateStr;
	self.waybillNumberStr := _proxy.waybillNumberStr;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_WaybillPrintDetail"/>
    </JadeMethod>
    <JadeMethod name="setGoodsDescriptionStr" id="42a3c78f-d913-418f-978b-24e05b56aa63">
        <updating/>
        <source>setGoodsDescriptionStr( _tiSet : CM_TISet; _delim : String  )updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	tiDesc : String;
	descStr : String;
	ti : CM_TrackedItem;

begin

	foreach ti in _tiSet do
		tiDesc := ti.description.trimBlanks;
		if tiDesc = null then
			continue;
		endif;
		if descStr = null then
			descStr := tiDesc;
		else
			descStr := descStr &amp; _delim &amp;  tiDesc;
		endif;
	endforeach;

	self.goodsDescriptionStr := descStr;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
