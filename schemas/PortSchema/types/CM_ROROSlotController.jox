    <JadeMethod name="getROROLayoutRemarks" id="a725aa47-fe7e-4137-96e3-5c0815f0c035">
        <updating/>
        <source>getROROLayoutRemarks( ):String updating;
/*
Date		Who		Reason
20 Aug 2012	cnwcs5	Initial creation - par 29124:2
*/
vars
	slot 		:CM_ROROSlotDefnVoyage;
	location	:CM_ROROLocnDefn;
	layout		:CM_DeckItemLayout;
begin
	slot := self.mySlotDefn;
	
	if slot = null then
		return null;
	endif;
	
	location := slot.myROROLocnDen;
	
	if location = null then
		return null;
	endif;
	
	layout := location.myLayout;
	
	if layout &lt;&gt; null then
		return layout.remarks;
	endif;	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
