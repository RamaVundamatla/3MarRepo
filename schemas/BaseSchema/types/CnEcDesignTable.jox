    </JadeMethod>
    <JadeMethod name="mouseUp" id="ebe2c6ee-a91d-46e8-8db8-e012be50718f">
        <updating/>
        <source>mouseUp(table : Table input; button : Integer; shift : Integer; x : Real; y : Real) updating;

vars
	dropColumn					: Integer;
	dragDrop					: Boolean;
begin
	if self.mousePointer = Control.MousePointer_NS or self.mousePointer = Control.MousePointer_WE then
		return;
	endif;
	if app.mousePointer = Control.MousePointer_NS or app.mousePointer = Control.MousePointer_WE then
		return;
	endif;
	if button = 1 then
		mouseIsDown := false;
		if self.drawSize &gt; mouseDownDrawSize then
			dragDrop := true;
 		   	self.drawUndo(mouseDownDrawSize);
		endif;
		if clickColumn &gt; 1 then

			if y &lt; self.rowHeight[1] then
				dropColumn := convertPositionToColumn(x);
				if dropColumn &lt;&gt; clickColumn then
					self.applyMoveColumn(clickColumn, dropColumn);
					return;
				endif;
//			if we drew something, then we went into column move mode, so don't do the column sort
				if dragDrop then
					return;
				endif;
			endif;

			if not disableVirtualScroll then
				return;
			endif;

			if self.column = clickColumn then
				if self.row = 1 then
					if self.sortColumn[1] = clickColumn then
						self.sortAsc[1] := not self.sortAsc[1];
					else
						if shift.bitAnd(1) &lt;&gt; 0 then
							if self.sortColumn[2] = 0 then
								self.sortColumn[2] := clickColumn;
								self.sortAsc[2] := true;
							else
								if self.sortColumn[2] = clickColumn then
									self.sortAsc[2] := not self.sortAsc[2];
								else
									if self.sortColumn[3] = 0 then
										self.sortColumn[3] := clickColumn;
										self.sortAsc[3] := true;
									else
										if self.sortColumn[3] = clickColumn then
											self.sortAsc[3] := not self.sortAsc[3];
										else
											app.msgBox('You may only sort on up to Three (3) columns.','Sort Columns Exceeded',MsgBox_OK_Only + 48);
										endif;
									endif;
								endif;
							endif;
						else
							self.sortColumn[1] := clickColumn;
							self.sortAsc[1] := true;
							self.sortColumn[2] := 0;
							self.sortColumn[3] := 0;
						endif;
					endif;
					self.resort;
				endif;
			endif;
		else
			self.positionScrollbar();
		endif;
	endif;
epilog
	self.refresh();
	inheritMethod(table, button, shift, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="openup" id="e5bc2e0d-09d2-48fb-ba35-7643fc62247f">
        <updating/>
        <source>openup(table : Table input) updating;

vars

begin
	self.zOrder(1);
	
	if self.myVerticalScrollBar.max &gt; self.lines() then
		self.myVerticalScrollBar.visible := true;
		self.positionScrollbar();
		self.myVerticalScrollBar.zOrder(1);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="positionScrollbar" id="b1b8755d-d645-44f1-b129-f65c5d3233eb">
        <source>positionScrollbar();

constants
	SCROLLBAR_WIDTH = 16;
vars
	horizontalScrollBar		: Integer;
	tableHeight				: Real;
	
begin
	if self.scrollsHorizontally() then
		horizontalScrollBar := 16;
	endif;
	if self.dropDown &gt; 0 then
		tableHeight := self.expandedHeight + horizontalScrollBar;
	else
		tableHeight := self.height;
	endif;
	
	self.myVerticalScrollBar.move(	self.left + (self.width - SCROLLBAR_WIDTH) - 1,
									self.top + 1,
									SCROLLBAR_WIDTH, tableHeight - 2 - horizontalScrollBar);

	/*	put the scroll bar on top */
	self.myVerticalScrollBar.zOrder(1);								
end;</source>
    </JadeMethod>
    <JadeMethod name="rebuildColumnHeadingArray" id="42c2d3d7-71f1-4581-b982-00556bbc53c2">
        <updating/>
        <source>rebuildColumnHeadingArray() updating;
//
// *********************************************************************************
// ***** WARNING: THIS METHOD IS A TEMPORARY FIX ONLY FOR THE DATABASE BROWSER *****
// *********************************************************************************
//
vars
	columnIndex	: Integer;
	columnCount	: Integer;
	
begin
	columnCount	:=	self.columns;
	
	foreach columnIndex in 2 to columnCount do
		self.columnHeadingArray[(columnIndex - 1)]	:=	self.getCellText(1, columnIndex);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeItem" id="cbf07673-32a3-495c-8a5c-bcb762b362b7">
        <updating/>
        <source>removeItem(removeRow :Integer)updating;
/*
	Purpose:	
	Parameters:	?
	Returns:	nothing	
*/
vars

begin
	if showUpdates then
		self.row := removeRow;
		self.column := 1;
		endNotification (self.itemObject, Object_Update_Event);	
	endif;
	inheritMethod(removeRow);
end;</source>
        <Parameter name="removeRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="schemaExtract" id="e0854669-643a-49eb-b07f-2f9005eccef2">
        <updating/>
        <source>schemaExtract() updating;

vars
	obj					: Object;
	table				: CnEcDesignTable;
	theFile				: File;
	fileSaveCMD 		: CMDFileSave;
	arrayBoolean		: Boolean;
	arrayInteger		: Integer;
	arrayString			: String;
	line				: String;
begin
	create fileSaveCMD ;
	fileSaveCMD.dialogTitle := 'JACDesignTable Unload File Save As';
	fileSaveCMD.fileName := currentSchema.name &amp; '.JAC';
	fileSaveCMD.filter := 'JACDesignTable Unload File (*.JAC)|*.JAC|All Files(*.*)|*.*';

	if fileSaveCMD.open = 0 then					// user clicked OK
		create theFile;
		theFile.fileName := fileSaveCMD.fileName;	// get selected name
		theFile.mode := File.Mode_Output;
		theFile.allowCreate := true;				// create if not there
		theFile.open;								// not mandatory

		theFile.writeLine ('*****JACDesignTable Definitions Begin');
		foreach obj in CnEcDesignTable.instances do
			table := obj.CnEcDesignTable;
			theFile.writeLine ('JACDesignTable\' &amp; table.name &amp; '\' &amp; table.form.name &amp; '\' &amp; table.layout &amp; '\');
			line := 'Heading\';
			foreach arrayString in table.columnHeadingArray do
				line := line &amp; arrayString &amp; '\';
			endforeach;
			theFile.writeLine(line);
			line := 'Alignment\';
			foreach arrayString in table.columnAlignmentArray do
				line := line &amp; arrayString &amp; '\';
			endforeach;
			theFile.writeLine(line);
			line := 'InputType\';
			foreach arrayString in table.columnInputTypeArray do
				line := line &amp; arrayString &amp; '\';
			endforeach;
			theFile.writeLine(line);
			line := 'Visible\';
			foreach arrayString in table.columnVisibleArray do
				line := line &amp; arrayString &amp; '\';
			endforeach;
			theFile.writeLine(line);
			line := 'Picture\';
			foreach arrayBoolean in table.columnPictureArray do
				line := line &amp; arrayBoolean.String &amp; '\';
			endforeach;
			theFile.writeLine(line);
			line := 'Width\';
			foreach arrayInteger in table.columnWidthArray do
				line := line &amp; arrayInteger.String &amp; '\';
			endforeach;
			theFile.writeLine(line);
			line := 'Length\';
			foreach arrayInteger in table.columnLengthArray do
				line := line &amp; arrayInteger.String &amp; '\';
			endforeach;
			theFile.writeLine(line);
			theFile.writeLine('Height\' &amp; table.columnHeight.String &amp; '\');
			theFile.writeLine('WEB\' &amp; table.webHyperlinkColumn.String &amp; '\');
		endforeach; 
		theFile.writeLine ('*****JACDesignTable Definitions End');

		theFile.close();
		delete theFile;
	endif;
	delete fileSaveCMD;
end;</source>
    </JadeMethod>
    <JadeMethod name="schemaLoad" id="addddb74-fc38-4f1d-bcf8-8e8d1eb6986f">
        <updating/>
        <source>schemaLoad() updating;

vars
	obj					: Object;
	table				: CnEcDesignTable;
	dataFile			: File;
	line				: String;
	fileOpen 			: CMDFileOpen;
	pos					: Integer;
	token				: String;
	tableName			: String;
	formName			: String;
begin
	create fileOpen;
	fileOpen.filter := 'JACDesignTable Unload File (*.JAC)|*.JAC|All Files(*.*)|*.*';
	fileOpen.fileMustExist := true;
	if fileOpen.open = 0 then
		create dataFile;
		dataFile.kind := File.Kind_Unknown_Text;	// 23/2/16 cnwmp6 PAR 36286 unicode version
		dataFile.openInput(fileOpen.fileName);
		line := dataFile.readLine;
		if line = '*****JACDesignTable Definitions Begin' then
			line := dataFile.readLine;
		else
			app.msgBox('This file is not a JACDesignTable Unload File','Incorrect File',MsgBox_OK_Only);
			delete dataFile;
			return;
		endif;

		beginTransaction;

		while not dataFile.endOfFile() do
			pos := 1;
            token := line.cnEcNextDelimitedField('\', pos);
            if token = 'JACDesignTable' then
            	table := null;
            	tableName := line.cnEcNextDelimitedField('\', pos);
            	formName := line.cnEcNextDelimitedField('\', pos);
            	token := line.cnEcNextDelimitedField('\', pos);
            	foreach obj in CnEcDesignTable.instances do
            		if obj.CnEcDesignTable.name = tableName then
	            		if obj.CnEcDesignTable.form.name = formName then
	            			table := obj.CnEcDesignTable;
	            			table.layout := token;
	            			break;
	            		endif;
            		endif;
            	endforeach;
            elseif token = 'Heading' then
            	if table &lt;&gt; null then
            		table.columnHeadingArray.clear();
            		token := line.cnEcNextDelimitedField('\', pos);
            		while pos &gt; 1 do
            			table.columnHeadingArray.add(token);
            			token := line.cnEcNextDelimitedField('\', pos);
            		endwhile;
            	endif;
            elseif token = 'Alignment' then
            	if table &lt;&gt; null then
            		table.columnAlignmentArray.clear();
            		token := line.cnEcNextDelimitedField('\', pos);
            		while pos &gt; 1 do
            			table.columnAlignmentArray.add(token);
            			token := line.cnEcNextDelimitedField('\', pos);
            		endwhile;
            	endif;
            elseif token = 'InputType' then
            	if table &lt;&gt; null then
            		table.columnInputTypeArray.clear();
            		token := line.cnEcNextDelimitedField('\', pos);
            		while pos &gt; 1 do
            			table.columnInputTypeArray.add(token);
            			token := line.cnEcNextDelimitedField('\', pos);
            		endwhile;
            	endif;
            elseif token = 'Visible' then
            	if table &lt;&gt; null then
            		table.columnVisibleArray.clear();
            		token := line.cnEcNextDelimitedField('\', pos);
            		while pos &gt; 1 do
            			table.columnVisibleArray.add(token);
            			token := line.cnEcNextDelimitedField('\', pos);
            		endwhile;
            	endif;
            elseif token = 'Picture' then
            	if table &lt;&gt; null then
            		table.columnPictureArray.clear();
            		token := line.cnEcNextDelimitedField('\', pos);
            		while pos &gt; 1 do
            			table.columnPictureArray.add(token = 'true');
            			token := line.cnEcNextDelimitedField('\', pos);
            		endwhile;
            	endif;
            elseif token = 'Width' then
            	if table &lt;&gt; null then
            		table.columnWidthArray.clear();
            		token := line.cnEcNextDelimitedField('\', pos);
            		while pos &gt; 1 do
            			table.columnWidthArray.add(token.Integer);
            			token := line.cnEcNextDelimitedField('\', pos);
            		endwhile;
            	endif;
            elseif token = 'Length' then
            	if table &lt;&gt; null then
            		table.columnLengthArray.clear();
            		token := line.cnEcNextDelimitedField('\', pos);
            		while pos &gt; 1 do
            			table.columnLengthArray.add(token.Integer);
            			token := line.cnEcNextDelimitedField('\', pos);
            		endwhile;
            	endif;
            elseif token = 'Height' then
            	if table &lt;&gt; null then
            		table.columnHeight := line.cnEcNextDelimitedField('\', pos).Integer;
            	endif;
            elseif token = 'WEB' then
            	if table &lt;&gt; null then
            		table.webHyperlinkColumn := line.cnEcNextDelimitedField('\', pos).Integer;
            	endif;
            endif;

			line := dataFile.readLine;
		endwhile;
		commitTransaction;
		delete dataFile;
	endif;
epilog
	delete fileOpen;
end;</source>
    </JadeMethod>
    <JadeMethod name="scrollHorizontal" id="d3066049-6f46-43e0-b9ff-a1b59ccd4759">
        <updating/>
        <source>scrollHorizontal() : Boolean updating, protected;

vars
	saveCol					: Integer;
	saveRow					: Integer;
	rtn						: Boolean;
begin
	if self.leftColumn &gt; 2 then
		return(true);
	endif;
	saveCol := self.column;
	saveRow := self.row;

	self.column := self.columns;
	self.row	:= 1;
	if self.positionLeft &lt; 0 then
		rtn := true;
	else
		if (self.positionLeft + self.columnWidth[self.columns]) &gt;= self.width then
			rtn := true;
		endif;
	endif;
	self.column := saveCol;
	self.row	:= saveRow;

	return(rtn);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="scrollTable" id="c2097eec-f2d7-4966-a66b-ff23b9dd7388">
        <updating/>
        <source>scrollTable() updating;
/*
	Purpose:	
	Parameters:	none
	Returns:	nothing	
*/
vars

begin
	if sortOrder = SORT_REVERSED then
		self.scrollTableReversed();
		return;
	endif;

	self.clear();
	self.myIterator.startAtIndex (myVerticalScrollBar.value);

	if myVerticalScrollBar.value &gt;= currentScrollbarPosition then
		/* 	we are going down the list */
		myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(true, false);
		loadSubset(END_OF_LIST);		
	else
		/* we are going up the list */
		myVerticalScrollBar.value := myVerticalScrollBar.value - setIteratorToIncludeObject(false, false);
		loadSubset(START_OF_LIST);
	endif;
	currentScrollbarPosition := myVerticalScrollBar.value;
	if selectedRow &gt; 0 then
		self.row := selectedRow;
	else
		if self.row &gt; 1 then
			self.row := 2;
			self.selectRow();
		endif;
	endif;
	
	self.refreshNow();
end;</source>
    </JadeMethod>
    <JadeMethod name="scrollTableReversed" id="724218ca-09b1-434a-8040-838d71288ffd">
        <updating/>
        <source>scrollTableReversed() updating;
/*
	Purpose:	
	Parameters:	none
	Returns:	nothing	
*/
vars

begin
	self.clear();
	self.myIterator.startAtIndex (currentCollectionSize - (myVerticalScrollBar.value - 1));

	if myVerticalScrollBar.value &gt;= currentScrollbarPosition then
		/* 	we are going down the list */
		myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(false, true);
		loadSubsetReversed(END_OF_LIST);	//chg	
	else
		/* we are going up the list */
		myVerticalScrollBar.value := myVerticalScrollBar.value - setIteratorToIncludeObject(true, true);
		loadSubsetReversed(START_OF_LIST);//chg
	endif;
	currentScrollbarPosition := myVerticalScrollBar.value;
	if selectedRow &gt; 0 then
		self.row := selectedRow;
	else
		if self.row &gt; 1 then
			self.row := 2;
			self.selectRow();
		endif;
	endif;
	
	self.refreshNow();
end;</source>
    </JadeMethod>
    <JadeMethod name="scrollTableWEB" id="6a91a649-b40e-4d4f-9cc1-9e19b9af42f8">
        <updating/>
        <source>scrollTableWEB(scroll : Integer) updating;

vars

begin
	if myVerticalScrollBar.value + scroll &gt;= myVerticalScrollBar.min and
	   myVerticalScrollBar.value + scroll &lt;= myVerticalScrollBar.max then
		myVerticalScrollBar.value := myVerticalScrollBar.value + scroll;
		self.scrollTable();
	endif;
	if myVerticalScrollBar.value + scroll &lt; myVerticalScrollBar.min then
		myVerticalScrollBar.value := myVerticalScrollBar.min;
		self.scrollTable();
	endif;
	if myVerticalScrollBar.value + scroll &gt; myVerticalScrollBar.max then
		myVerticalScrollBar.value := myVerticalScrollBar.max - (TABLE_ROWS_ON_WEB - 1);
		self.scrollTable();
	endif;
end;</source>
        <Parameter name="scroll" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="scrollsHorizontally" id="c02b14e0-7eb7-42a8-b1f9-d1390c1ed0b0">
        <source>scrollsHorizontally() : Boolean;

vars
	widthSoFar			: Integer;
	loopIndex			: Integer;
	maxIndex			: Integer;
	
begin
	maxIndex := self.columns;
	loopIndex := 1;
	
	while loopIndex &lt;= maxIndex do
		if self.columnVisible[loopIndex] then
			break;
		endif;
		
		loopIndex := loopIndex + 1;
	endwhile;
	
	if self.leftColumn &gt; loopIndex then
		return(true);
	endif;
	
	loopIndex := 1;
	
	while loopIndex &lt;= maxIndex do
		if self.columnVisible[loopIndex] then
			widthSoFar := widthSoFar + self.columnWidth[loopIndex];
			
			if widthSoFar &gt; self.clientWidth() then
				return(true);
			endif;
		endif;
		
		loopIndex := loopIndex + 1;
	endwhile; 
	
	return(false);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectAllObjects" id="5fefbad8-56a8-4344-99c0-b55365722c45">
        <updating/>
        <source>selectAllObjects() updating;
// --------------------------------------------------------------------------------
// Created:		19 June 2000 -  selectAllObjects
// By:			cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	start,
	finish,
	rownum,
	stepinc					: Integer;
	obj						: Object;	
	wasInLoadState			: Boolean;	
	iter					: Iterator;	
begin
	// Clear the currently selected objects 
	selectedObjects.clear();

	// Decide if we are using iterator (listCollection) or have added rows manually
	if myIterator &lt;&gt; null then
		// Do this in load state to reduce loacking
		wasInLoadState := process.isInLoadState;
		if not wasInLoadState then
			beginLoad;
		endif;

		// Create a new iterator and set the start point and end object
		iter := myIterator.getCollection.createIterator();

		// Iterate through until we meet the end object
		while iter.next(obj) do
			selectedObjects.add(obj);
		endwhile;
	else
		// We just use the table 'naturally'
		finish	:= self.rows;	
		start	:= 1;
		stepinc	:= 1;
		
		foreach rownum in start to finish step stepinc do
			row := rownum;
			selectedObjects.add(self.getRowObject());
		endforeach;		

		// reset the current row to where we clicked
		self.row:=finish;
	endif;
epilog
	if iter &lt;&gt; null then
		delete iter;
	endif;

	if not wasInLoadState then
		endLoad;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectRow" id="0a7a2391-1329-4eba-a68d-925636a200f9">
        <updating/>
        <source>selectRow() updating;

vars
	loopIndex		: Integer;
	rowIndex		: Integer;
	
begin
	rowIndex := self.row;
	
	if rowIndex &gt; 1 then
		if self.multiSelect = 0 then	//	0 - None	can only select one row at a time
			self.clearAllSelected();
			selectedObjects.clear();
			selectedObject := null;
		endif;
		
		loopIndex := self.columns;
		
		while loopIndex &gt; 1 do
			self.setCellSelected(rowIndex, loopIndex, true);
			loopIndex := loopIndex - 1;
		endwhile;
		
		self.column := 1;
		selectedObject := self.itemObject;
	endif;
	
	self.refreshNow();
end;</source>
    </JadeMethod>
    <JadeMethod name="setCollection" id="aca93fa6-fbbb-4146-83cd-37bc5dd22d20">
        <updating/>
        <source>setCollection(coll :Collection; update :Boolean) updating, protected;

vars

begin
	if self.myCollectionOid &lt;&gt; null then
		if showUpdates then
//			endNotificationForSubscriber(self);
			endNotification(self.myIterator.getCollection(), Any_System_Event);
		endif;
	endif;
	
	if self.myIterator &lt;&gt; null then
		delete self.myIterator;
	endif;
	
	selectedObjects.clear();
	
	if coll = null then
		/*	reset related properties */
		self.myCollectionOid 				:= null;
		self.myVerticalScrollBar.visible	:= false;
		currentCollectionSize				:= 0;
		currentIteratorPosition 			:= 0;
		self.currentScrollbarPosition		:= 0;
		self.clear();
	else
		/*	Set related properties */
		self.myCollectionOid 			:= coll.getOidString();
		self.myIterator 				:= coll.createIterator();
		currentIteratorPosition 		:= 0;
		self.clear();
		self.currentScrollbarPosition	:= 0;

		/*	Set up scrollbar */
		self.myVerticalScrollBar.min	:= 1;
		
		if coll.size() &gt; (self.lines() - 2) then
			self.myVerticalScrollBar.max	:= coll.size() - (self.lines() - 2);
		else
			self.myVerticalScrollBar.max	:= coll.size();
		endif;
		
		self.myVerticalScrollBar.smallChange	:= 1;
		self.myVerticalScrollBar.largeChange	:= self.lines() - 1;
		self.myVerticalScrollBar.value			:= 1;
		
		if coll.size() &gt; self.lines() - 1 then
			self.myVerticalScrollBar.visible	:= true;
			self.positionScrollbar();
			self.myVerticalScrollBar.zOrder(1);
		else
			self.myVerticalScrollBar.visible	:= false;
		endif;
		
		self.currentCollectionSize 		:= coll.size();
		self.showUpdates := update;
		if showUpdates then
			beginNotification(coll, Any_System_Event, Response_Continuous, 
							NOTIFY_COLLECTION_UPDATE);
		endif;
		
		/*	Load the list */
		if sortOrder = SORT_COLLECTION then
			self.myIterator.reset;
			self.loadSubset(END_OF_LIST);
		else
			self.myIterator.reset();
			self.loadSubsetReversed(END_OF_LIST);
		endif;
		
		self.currentScrollbarPosition	:=	1;
		self.row := 1;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="coll" type="Collection"/>
        <Parameter name="update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIteratorToIncludeObject" id="d86250f4-5e00-4ef0-b924-2e48860f624d">
        <updating/>
        <source>setIteratorToIncludeObject(fwd : Boolean; inReverse : Boolean) : Integer updating;

vars
	obj				: Object;
	count			: Integer;
	wasInLoadState			: Boolean;
begin
	wasInLoadState := process.isInLoadState;
	if not wasInLoadState then
		beginLoad;
	endif;

	if fwd then
	 	while myIterator.next(obj) do
	 		if stopLoading(obj, self.cnEcGetCollection(), not inReverse) then	//(fwd &lt;&gt; inReverse)) then
				self.myVerticalScrollBar.max := (self.myVerticalScrollBar.value + count) - self.myVerticalScrollBar.largeChange;
	 			break;
	 		endif;
	 		if excludeObject(obj) then
	 			count := count + 1;
	 		else
	 			if not inReverse then
	 				myIterator.back(obj);
	 			else
	 				myIterator.next(obj);
	 				if obj = null then
	 					myIterator.reset;
//		 				myIterator.back(obj);
	 				endif;
	 			endif;
	 			break;
	 		endif;
	 	endwhile;
	else
	 	while myIterator.back(obj) do
	 		if stopLoading(obj, cnEcGetCollection, not inReverse) then	//(fwd &lt;&gt; inReverse)) then
				self.myVerticalScrollBar.max := myVerticalScrollBar.value + count;
	 			break;
	 		endif;
	 		if excludeObject(obj) then
	 			count := count + 1;
	 		else
	 			if inReverse then
	 				myIterator.next(obj);
	 				if obj = null then
	 					myIterator.reset;
	 				endif;
	 			else
	 				myIterator.back(obj);
	 				if obj = null then
	 					myIterator.reset;
	 				endif;
	 			endif;
	 			break;
	 		endif;
	 	endwhile;
 	endif;
 	return(count);
epilog
	if not wasInLoadState then
		endLoad;
	endif;
end;</source>
        <Parameter name="fwd" type="Boolean"/>
        <Parameter name="inReverse" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIteratorToThisObject" id="2993bd97-d5af-4a1d-8ed7-2a8f77846a54">
        <updating/>
        <source>setIteratorToThisObject(obj : Object) updating;

vars
	o						: Object;
	scrollBarValue			: Integer;
	wasInLoadState			: Boolean;
begin
	wasInLoadState := process.isInLoadState;
	
	if not wasInLoadState then
		beginLoad;
	endif;
	
	self.rows	:= 1;
	self.myIterator.reset;

	if obj = null then
		self.myIterator.reset;
	else
		self.myIterator.startAtObject(obj);
	endif;
	
	self.myIterator.next(o);
	scrollBarValue := myIterator.getCollection.indexOf(obj);

	if sortOrder = SORT_COLLECTION then
		self.myIterator.back(o);
		
		if o = null then
			self.myIterator.reset;
		endif;
		
		self.currentIteratorPosition	:= scrollBarValue - 1;
 	else
		self.myIterator.next(o);
		
		if o = null then
			self.myIterator.reset;
		endif;
		
		self.currentIteratorPosition	:= scrollBarValue + 1;
 	endif;
 	
	self.myVerticalScrollBar.min	:= scrollBarValue;
	self.myVerticalScrollBar.max	:= self.currentCollectionSize - (self.lines() - 2);
	
	/*	Load the table */
	if sortOrder = SORT_COLLECTION then
		self.loadSubset (END_OF_LIST);
	else
		self.loadSubsetReversed(END_OF_LIST);
	endif;
	
	self.myVerticalScrollBar.value := scrollBarValue;
	self.currentScrollbarPosition  := scrollBarValue;
epilog
	if not wasInLoadState then
		endLoad;
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setScrollBarMaxObject" id="a434013b-2144-403d-a8f2-05f579c20ac7">
        <updating/>
        <source>setScrollBarMaxObject(obj : Object) updating;

vars
	o						: Object;
	scrollBarValue			: Integer;
	maxIterator				: Iterator;
	wasInLoadState			: Boolean;
begin
	wasInLoadState := process.isInLoadState;
	if not wasInLoadState then
		beginLoad;
	endif;

	scrollBarValue := myIterator.getCollection.indexOf(obj);
//	maxIterator := getCollection.createIterator;
//	maxIterator.startAtIndex(self.myVerticalScrollBar.min);
//	scrollBarValue := self.myVerticalScrollBar.min;
// 	while maxIterator.next(o) do
// 		scrollBarValue := scrollBarValue + 1;
// 		if o = obj then
// 			maxIterator.back(o);
// 			break;
// 		endif;
// 	endwhile;
	self.myVerticalScrollBar.max	:= scrollBarValue - self.myVerticalScrollBar.largeChange;
epilog
//	delete maxIterator;
	if not wasInLoadState then
		endLoad;
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setSelectedRow" id="3f86fad0-af65-484b-b7b3-7930e4e09e68">
        <updating/>
        <source>setSelectedRow(value: Integer) updating;

vars

begin
	if selectedRow &lt;&gt; value then 
		selectedRow := value;
	endif;

end;
</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showColumnByHeading" id="be6646e1-8ec9-4de9-8886-c4b6a555e712">
        <updating/>
        <source>showColumnByHeading(columnHeading : String) updating;

vars
	loopIndex			: Integer;
	heading				: String;
begin
	loopIndex	:= 1;
	foreach heading in columnHeadingArray do
		loopIndex := loopIndex + 1;
		if heading = columnHeading then
			self.columnVisible[loopIndex] := true;
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="columnHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="showPropertyPage" id="348e62d6-c38f-42b4-aeee-7debbd072c63">
        <updating/>
        <source>showPropertyPage(nam : String) : Boolean updating;

vars
	f					: CnEcDesignTableForm;
	result				: Integer;

	loopIndex			: Integer;
	maxIndex			: Integer;
begin
	if nam = 'layout' then
		self.sizeColumnArrays();
		create f transient;
		f.transientTable := self;
		result := f.showModal();
		if result = 0 then
			if persistTable &lt;&gt; null then
				beginTransaction;
				persistTable.columnHeadingArray.clear();
				persistTable.columnWidthArray.clear();
				persistTable.columnVisibleArray.clear();
				persistTable.columnPictureArray.clear();
				persistTable.columnLengthArray.clear();
				persistTable.columnAlignmentArray.clear();
				persistTable.columnInputTypeArray.clear();

				self.columnHeadingArray.copy(persistTable.columnHeadingArray);
				self.columnWidthArray.copy(persistTable.columnWidthArray);
				self.columnVisibleArray.copy(persistTable.columnVisibleArray);
				self.columnPictureArray.copy(persistTable.columnPictureArray);
				self.columnLengthArray.copy(persistTable.columnLengthArray);
				self.columnAlignmentArray.copy(persistTable.columnAlignmentArray);
				self.columnInputTypeArray.copy(persistTable.columnInputTypeArray);

				persistTable.columnHeight	:= self.columnHeight;

				myCollectionOid := null;
				commitTransaction;
			endif;
			layout := 'Defined';
			buildTableColumns();
			return true;
		else
			return false;	
		endif;
	else
		return inheritMethod(nam);
	endif;	
end;</source>
        <Parameter name="nam" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showTable" id="3822d4c7-51d7-4af9-81ce-c1ff08554ad7">
        <updating/>
        <source>showTable() updating;

vars

begin
	self.visible	:= true;
	
	if self.myVerticalScrollBar.max &gt; self.lines() then
		self.myVerticalScrollBar.visible := true;
		self.positionScrollbar();
		self.myVerticalScrollBar.zOrder(1);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="sizeColumnArrays" id="8225f0bf-0303-4561-9a7c-24c89783d045">
        <updating/>
        <source>sizeColumnArrays() updating;

vars
	maxIndex					: Integer;
begin
	maxIndex := self.columns;
	while columnHeadingArray.size() &lt; maxIndex do
		columnHeadingArray.add("");
	endwhile;
	while columnHeadingArray.size() &gt; maxIndex do
		columnHeadingArray.removeAt(columnHeadingArray.size());
	endwhile;
//					Visible
	while columnVisibleArray.size() &lt; maxIndex do
		columnVisibleArray.add('1 - True');
	endwhile;
	while columnVisibleArray.size() &gt; maxIndex do
		columnVisibleArray.removeAt(columnVisibleArray.size());
	endwhile;
//					Picture
	while columnPictureArray.size() &lt; maxIndex do
		columnPictureArray.add(false);
	endwhile;
	while columnPictureArray.size() &gt; maxIndex do
		columnPictureArray.removeAt(columnPictureArray.size());
	endwhile;
//					Width
	while columnWidthArray.size() &lt; maxIndex do
		columnWidthArray.add(50);
	endwhile;
	while columnWidthArray.size() &gt; maxIndex do
		columnWidthArray.removeAt(columnWidthArray.size());
	endwhile;
//					InputType
	while columnInputTypeArray.size() &lt; maxIndex do
		columnInputTypeArray.add('0 - None');
	endwhile;
	while columnInputTypeArray.size() &gt; maxIndex do
		columnInputTypeArray.removeAt(columnInputTypeArray.size());
	endwhile;
//					Alignment
	while columnAlignmentArray.size() &lt; maxIndex do
		columnAlignmentArray.add('0 - Default');
	endwhile;
	while columnAlignmentArray.size() &gt; maxIndex do
		columnAlignmentArray.removeAt(columnAlignmentArray.size());
	endwhile;
//					Length
	while columnLengthArray.size() &lt; maxIndex do
		columnLengthArray.add(0);
	endwhile;
	while columnLengthArray.size() &gt; maxIndex do
		columnLengthArray.removeAt(columnLengthArray.size());
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="startAtObject" id="e3781a0f-81dd-4168-9347-023ec521c001">
        <updating/>
        <source>startAtObject(obj :Object)updating;
/*
	Purpose:	Display the list starting with a specific object.
				This could be slow for arrays and external 
				key dictionaries.
	Parameters:	none
	Returns:	nothing	

	Created by cms on 11 November 1997
*/
vars

begin
	/*	First position the iterator */
	self.myIterator.startAtObject(obj);

	if sortOrder = SORT_COLLECTION then
		self.clear();
		self.loadSubset(END_OF_LIST);
	else	
		self.clear();
		self.loadSubsetReversed(END_OF_LIST);
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <ExternalMethod name="stopLoading" id="e7e71f7f-c68c-41c7-9f82-687523c6f8c7">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>stopLoading(obj : Object; coll : Collection; ascending : Boolean) : Boolean is CallControlEvent in jadpmap updating;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="coll" type="Collection"/>
        <Parameter name="ascending" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </ExternalMethod>
    <JadeMethod name="sysNotification" id="575def8d-498a-47bd-92ab-d1a79fdb0de3">
        <updating/>
        <source>sysNotification(eventType : Integer; theObject : Object; eventTag : Integer) updating;
/*
	Purpose:	Creates and deletes of objects are caught by the
				notification on the collection.
				Updates to objects being displayed are caught by 
				a notification on the objects themselves.	
	Parameters:	
	Returns:	nothing	

	Created by cms on 04 November 1997
*/
vars
	pos, collPos : Integer;
	coll : Collection;
	
begin
	app.mousePointer	:=	Busy;
	
//	crappy fix, but effective!
	if myIterator = null then
		return;
	endif;
	
	coll := myIterator.getCollection;
	
	if eventTag = NOTIFY_COLLECTION_UPDATE then
		if eventType = Object_Delete_Event then
			return;
		endif;
		
		/*	Entries have been added to or removed from the 
			collection */
		if currentCollectionSize &lt;&gt; coll.size() then
			/*	Set scrollbar values */
			if coll.size() &lt;= self.lines then
				/*	Just display from the beginning */
				myVerticalScrollBar.visible := false;
				if coll.size() &gt; (self.lines - 2) then
					myVerticalScrollBar.max		:= coll.size() - (self.lines - 2);
				else
					myVerticalScrollBar.max		:= coll.size();
				endif;
				
				self.clear();
				self.myIterator.reset();
				
				if self.sortOrder = SORT_COLLECTION then
					self.loadSubset(START_OF_LIST);
				else
					self.loadSubsetReversed(START_OF_LIST);
				endif;
				
				self.currentScrollbarPosition := 1;
			else
				if coll.size() &gt; (self.lines - 2) then
					myVerticalScrollBar.max		:= coll.size() - (self.lines - 2);
				else
					myVerticalScrollBar.max		:= coll.size();
				endif;
				
	            if self.myVerticalScrollBar.visible = false then
	            	self.myVerticalScrollBar.value 		:= 1;
	            	self.myVerticalScrollBar.visible 	:= true;
	            	self.currentScrollbarPosition 		:= 1;	            	
					positionScrollbar();
					myVerticalScrollBar.zOrder(1);
	            endif;
	            
	            if self.currentScrollbarPosition &gt; 
	            		self.myVerticalScrollBar.max then
	            	/*	The size of the collection has reduced so that our
	            		previous position is beyond the end of the
	            		collection */
					self.clear();
					
					if self.sortOrder = SORT_COLLECTION then
						self.myIterator.startAtIndex(self.myVerticalScrollBar.max);	
						self.loadSubset(START_OF_LIST);
					else
						pos := myIterator.getCollection.size() - (myVerticalScrollBar.value  - 1);
	 					self.myIterator.startAtIndex(pos);
						self.loadSubsetReversed(START_OF_LIST);
					endif;
					
	            	self.myVerticalScrollBar.value	:= self.myVerticalScrollBar.max;
	            	self.currentScrollbarPosition 	:= self.myVerticalScrollBar.value;
	            else
	            	/*	We just redisplay from the same position */
                	self.clear();

                	if self.sortOrder = SORT_COLLECTION then
//                		self.myIterator.startAtIndex(self.myVerticalScrollBar.value);
//						self.loadSubset(START_OF_LIST);
						if myVerticalScrollBar.value &lt; 2 then
							self.myIterator.reset;
						else
							self.myIterator.startAtIndex (myVerticalScrollBar.value);
							myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(true, false);
						endif;
						
						self.loadSubset(END_OF_LIST);		
					else
//						pos := myIterator.getCollection.size()  -
//	 							(myVerticalScrollBar.value  - 1);
//	 					self.myIterator.startAtIndex(pos);
//						self.loadSubsetReversed(START_OF_LIST);
						if myVerticalScrollBar.value &lt; 2 then
							self.myIterator.reset;
						else
							self.myIterator.startAtIndex (currentCollectionSize - myVerticalScrollBar.value);
							myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(false, true);
						endif;
						
						self.loadSubsetReversed (END_OF_LIST);
					endif;
	            endif;
	 		endif;	
	 		
	 		currentCollectionSize := coll.size();
		endif;
		
        self.refreshNow();
        
	elseif eventTag = NOTIFY_INSTANCE_UPDATE then
    	if eventType = Object_Update_Event then
    		/*	An object in the list has been updated */
			/*	redisplay the list */
			self.rows := 1;
			
			if sortOrder = SORT_COLLECTION then
//				self.myIterator.startAtIndex(self.currentScrollbarPosition);
//				self.loadSubset (END_OF_LIST);
				if myVerticalScrollBar.value &lt; 2 then
					self.myIterator.reset;
				else
					self.myIterator.startAtIndex (myVerticalScrollBar.value);
					myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(true, false);
				endif;
				
				loadSubset(END_OF_LIST);		
			else
//				pos := myVerticalScrollBar.value + (self.rows - 1);
//				self.myIterator.startAtIndex(pos);
				if myVerticalScrollBar.value &lt; 2 then
					self.myIterator.reset;
				else
					self.myIterator.startAtIndex (currentCollectionSize - myVerticalScrollBar.value);
					myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(false, true);
				endif;
				self.loadSubsetReversed(END_OF_LIST);
 			endif;
		endif;
		
        self.refreshNow();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="5ec3adc7-1667-4678-baf8-9e8102451757">
        <updating/>
        <source>sysNotify(table : Table input; eventType : Integer; theObject : Object; eventTag : Integer) updating;
/*
	Purpose:	Creates and deletes of objects are caught by the
				notification on the collection.
				Updates to objects being displayed are caught by 
				a notification on the objects themselves.	
	Parameters:	
	Returns:	nothing	

	Created by cms on 04 November 1997
*/
vars
	pos, collPos : Integer;
	coll : Collection;
begin
	app.mousePointer	:=	Busy;
//	crappy fix, but effective!
	if myIterator = null then
		return;
	endif;
	coll := myIterator.getCollection;
	if eventTag = NOTIFY_COLLECTION_UPDATE then
		if eventType = Object_Delete_Event then
			return;
		endif;
		/*	Entries have been added to or removed from the 
			collection */
		if currentCollectionSize &lt;&gt; coll.size() then
			/*	Set scrollbar values */
			if coll.size() &lt;= self.lines() then
				/*	Just display from the beginning */
				myVerticalScrollBar.visible := false;
				if coll.size() &gt; (self.lines() - 2) then
					myVerticalScrollBar.max		:= coll.size() - (self.lines() - 2);
				else
					myVerticalScrollBar.max		:= coll.size();
				endif;
				self.clear();
				self.myIterator.reset();
				if self.sortOrder = SORT_COLLECTION then
					self.loadSubset(START_OF_LIST);
				else
					self.loadSubsetReversed(START_OF_LIST);
				endif;
				self.currentScrollbarPosition := 1;
			else
				if coll.size() &gt; (self.lines() - 2) then
					myVerticalScrollBar.max		:= coll.size() - (self.lines() - 2);
				else
					myVerticalScrollBar.max		:= coll.size();
				endif;
	            if self.myVerticalScrollBar.visible = false then
	            	self.myVerticalScrollBar.value 		:= 1;
	            	self.myVerticalScrollBar.visible 	:= true;
	            	self.currentScrollbarPosition 		:= 1;	            	
					positionScrollbar();
					myVerticalScrollBar.zOrder(1);
	            endif;
	            if self.currentScrollbarPosition &gt; 
	            		self.myVerticalScrollBar.max then
	            	/*	The size of the collection has reduced so that our
	            		previous position is beyond the end of the
	            		collection */
					self.clear();
					if self.sortOrder = SORT_COLLECTION then
						self.myIterator.startAtIndex(self.myVerticalScrollBar.max);	
						self.loadSubset(START_OF_LIST);
					else
						pos := myIterator.getCollection.size()  -
	 							(myVerticalScrollBar.value  - 1);
	 					self.myIterator.startAtIndex(pos);
						self.loadSubsetReversed(START_OF_LIST);
					endif;
	            	self.myVerticalScrollBar.value	:= self.myVerticalScrollBar.max;
	            	self.currentScrollbarPosition 	:= self.myVerticalScrollBar.value;
	            else
	            	/*	We just redisplay from the same position */
                	self.clear();

                	if self.sortOrder = SORT_COLLECTION then
//                		self.myIterator.startAtIndex(self.myVerticalScrollBar.value);
//						self.loadSubset(START_OF_LIST);
						if myVerticalScrollBar.value = 1 then
							self.myIterator.reset;
						else
							self.myIterator.startAtIndex (myVerticalScrollBar.value);
						endif;
						myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(true, false);
				loadSubset(END_OF_LIST);		
					else
//						pos := myIterator.getCollection.size()  -
//	 							(myVerticalScrollBar.value  - 1);
//	 					self.myIterator.startAtIndex(pos);
//						self.loadSubsetReversed(START_OF_LIST);
						if myVerticalScrollBar.value = 1 then
							self.myIterator.reset;
						else
							self.myIterator.startAtIndex (currentCollectionSize - myVerticalScrollBar.value);
						endif;
						myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(false, true);
						self.loadSubsetReversed (END_OF_LIST);
					endif;
	            endif;
	 		endif;	
	 		currentCollectionSize := coll.size();
		endif;
		
        self.refreshNow();
        
	elseif eventTag = NOTIFY_INSTANCE_UPDATE then
    	if eventType = Object_Update_Event then
    		/*	An object in the list has been updated */
			/*	redisplay the list */
			self.rows := 1;
			if sortOrder = SORT_COLLECTION then
//				self.myIterator.startAtIndex(self.currentScrollbarPosition);
//				self.loadSubset (END_OF_LIST);
				if myVerticalScrollBar.value = 1 then
					self.myIterator.reset;
				else
					self.myIterator.startAtIndex (myVerticalScrollBar.value);
				endif;
				myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(true, false);
				loadSubset(END_OF_LIST);		
			else
//				pos := myVerticalScrollBar.value + (self.rows - 1);
//				self.myIterator.startAtIndex(pos);
				if myVerticalScrollBar.value = 1 then
					self.myIterator.reset;
				else
					self.myIterator.startAtIndex (currentCollectionSize - myVerticalScrollBar.value);
				endif;
				myVerticalScrollBar.value := myVerticalScrollBar.value + setIteratorToIncludeObject(false, true);
				self.loadSubsetReversed (END_OF_LIST);
 			endif;
		endif;
		
        self.refreshNow();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
