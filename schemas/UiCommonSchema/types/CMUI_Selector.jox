    <JadeMethod name="cleanUp" id="b7a26637-6aa1-4334-93f3-fd168cb3f90e">
        <updating/>
        <source>cleanUp() protected, updating;
// ---------------------------------------------------------------------------
// Created:     23 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

	numSheets,
	idx					: Integer;
	tbl					: CM_DataTable;
	tblSheet			: JadeTableSheet;
	criteriaHolder		: CM_QueryCriteriaLineHolder;
	entTableDef			: EntTableDef;
	obj					: Object;
begin
	self.clearSheets();
	
	if self.myEnqController &lt;&gt; null and
	   self.myEnqController.allObjects &lt;&gt; null then
		self.myEnqController.allObjects.clear();
	endif;
	
	delete self.myEnqController;
	

	if self.tblResults.myEntTableDef &lt;&gt; null then
		self.tblResults.myEntTableDef.allEntTableRows.purge;
		delete self.tblResults.myEntTableDef;
	endif;
	
	self.tblCriteria.purgeTableObjects(); 	//+ cnwmd1, CCMS 1067, Par 19710
	
	self.properties.clear();
	self.operators.clear();
	self.values.clear();
	
	// CCMS Tranship: unload the unused forms that were created in self.showScreensToSendTo();
	foreach obj in self.allDefaultForms do
		if (not app.isValidObject(obj)) then //form has been closed by user
			self.allDefaultForms.remove(obj);
			obj := null;
			continue;
		endif;
		
		if (not obj.Form.visible) then
			obj.Form.unload();
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cleanUpEntDef" id="0deb1d96-ca7d-44f0-a930-f2db6bdcaf46">
        <updating/>
        <source>cleanUpEntDef() protected, updating;
// JIRA 14794 - NAVAB1 30OCT2024
vars

	numSheets,
	idx					: Integer;
	tbl					: CM_DataTable;
	tblSheet			: JadeTableSheet;
	criteriaHolder		: CM_QueryCriteriaLineHolder;
	entTableDef			: EntTableDef;
	obj					: Object;
begin
	self.clearSheets();
	
	if self.myEnqController &lt;&gt; null and
	   self.myEnqController.allObjects &lt;&gt; null then
		self.myEnqController.allObjects.clear();
	endif;
	
	delete self.myEnqController;
	
	self.tblCriteria.purgeTableObjects(); 
	
	// CCMS Tranship: unload the unused forms that were created in self.showScreensToSendTo();
	foreach obj in self.allDefaultForms do
		if (not app.isValidObject(obj)) then //form has been closed by user
			self.allDefaultForms.remove(obj);
			obj := null;
			continue;
		endif;
		
		if (not obj.Form.visible) then
			obj.Form.unload();
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
