    <JadeMethod name="hasUnsavedChanges" id="a1c73190-86d1-4adc-9165-8a7089f05f8d">
        <source>hasUnsavedChanges(): Boolean;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if cmbCriteria1.text &lt;&gt; null
	or cmbCriteria2.text &lt;&gt; null
	or cmbCriteria3.text &lt;&gt; null
	or cmbCriteria4.text &lt;&gt; null
	or txtCode.text &lt;&gt; null
	or txtLocation.text &lt;&gt; null then
		return true;
	endif;
	return inheritMethod();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
