    <JadeMethod name="isMatch" id="1a2ff191-e379-4c13-8cfa-dc9fcb59e0b1">
        <source>isMatch( _item : String; _fileValue : String; _ruleValue, _segmentValue :String output) : Boolean;
/*
Date				Who		Reason
17 December 2012	cnwgb1	CCMS 2216 PAR 30902 
14 Apr 2013			cnwcs5	CCMS pol 2097 / par 31259
24/07/2013			cnwcs5	par 31942
*/

vars

begin
    if self.item = _item then 
        if _item = self.Item_MEA_3_2
		or _item = self.Item_FTX_4_1
		then 
            return self.isMatch_MultiSegment( _item, _fileValue, _ruleValue, _segmentValue);
        else
            if self.value = _fileValue then
                return true;
            endif;
        endif;
    endif;
    return false;
end;</source>
        <Parameter name="_item" type="String"/>
        <Parameter name="_fileValue" type="String"/>
        <Parameter name="_ruleValue" type="String" usage="output"/>
        <Parameter name="_segmentValue" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMatch_MultiSegment" id="d2792ba2-4c63-433e-a139-edf62fa8f61d">
        <source>isMatch_MultiSegment( _item : String; _fileValue : String; _ruleValue, _segmentValue :String output) : Boolean protected;
/*
Purpose		: Determine if MEA 3.2 rule match criteria is met. 			
Parameters	:	_item			- MEA3.2, FTX4.1, FTX4.0
				_fileValue		- segment contents
				_ruleValue		- value for _item in rule
				_segmentValue	- value of _item in segment

Date		Who		Reason
17 Dec 2012	cnwgb1	CCMS 2216 PAR 30902 
15/04/2013	cnwcs5	CCMS POL 2097 / par 31259 - mt grade xlations
													  - renamed method, added code to compare field values of segement 1 &amp; 2
04/07/2013	cnwcs5	par 31942	
//02 Jul 2014	cnwrs1	par 34494 - fix 1413 string out of bounds exception
14 Jun 2016 cnwma1	TFS #2048 POL - HSD EDI Empty Release Request
//23/03/2017 cnwrh7     TFS3602       #EDI Party Enquiry FTX value not consistently used
*/
vars
    rulePos 			: Integer;
    ruleFieldValue 		: String;
    ruleAlphaValue 		: String;
    ruleIntegerValue 	: Integer;
    
    filePos 			: Integer;
    fileFieldValue 		: String;
    fileAlphaValue 		: String;
    fileIntegerValue 	: Integer;
	ruleFieldValueWithoutFTX : String;                                                                                                //+TFS3602

begin 
    if _item = self.Item_MEA_3_2 or
        // Rule is to do a string comparison of fields 1, 2 and 3:1
        // Then we do an Integer comparison of field 3:2
		_item = self.Item_FTX_4_1 then
		// Rule requires match on fields 1, 2 and 3 - 4.1 contains text to use
		if not self.value[1:4].cnContains("FTX+") then                                                                //+TFS3602
			ruleFieldValueWithoutFTX := self.value;
       else
            ruleFieldValueWithoutFTX := self.value[5:end];
       endif;
	   
        filePos := 1;
        rulePos := 1;	
        /*fileFieldValue :=  _fileValue.scanUntil("+", filePos); // Field 1 								//-TFS3602 Don't need to compare with Field1 which was "FTX+"
       // ruleFieldValue :=  self.value.scanUntil("+", rulePos); // Field 1 
		
        if filePos = 0 or rulePos = 0 or fileFieldValue &lt;&gt; ruleFieldValue then
            return false;
        endif;
		*/
        filePos := filePos +1;
        rulePos := rulePos +1;
		/*																																						//-TFS3602
		if rulePos &gt; self.value.length then
			rulePos := self.value.length;
		endif;
		*/
		if rulePos &gt; ruleFieldValueWithoutFTX.length then														//+TFS3602
			rulePos := ruleFieldValueWithoutFTX.length;
		endif;
		
        fileFieldValue :=  _fileValue.scanUntil("+", filePos); // Field 2
        //ruleFieldValue :=  self.value.scanUntil("+", rulePos); // Field 2 															//-TFS3602
		  ruleFieldValue :=  ruleFieldValueWithoutFTX.scanUntil("+", rulePos); // Field 2 						//+TFS3602
		
        if filePos = 0 or rulePos = 0 or fileFieldValue &lt;&gt; ruleFieldValue then
            return false;
        endif;
		
		if _item = self.Item_FTX_4_1 then
	
			//epr TFS 4275 8/5/17 it was returning segnment with extra + 
			if ruleFieldValueWithoutFTX = _fileValue then
				_ruleValue:=ruleFieldValueWithoutFTX;
				_segmentValue:=ruleFieldValueWithoutFTX;
				return true;
			endif;
			
			rulePos:=_fileValue.pos(ruleFieldValueWithoutFTX,1);
	
			if rulePos &gt; 0 then
				ruleFieldValue:=_fileValue[rulePos+ruleFieldValueWithoutFTX.length:_fileValue.length];
				rulePos:=1;
				ruleFieldValue:=ruleFieldValue.scanUntil("+", rulePos);
				
				rulePos:=1;
				ruleFieldValue:=ruleFieldValue.scanUntil(":", rulePos);
				_ruleValue:=ruleFieldValue;
				_segmentValue:=ruleFieldValue;
				if self.function = self.Function_FTX_4_1_EstReqDT then	// gets the date from last 6 characters
					if _segmentValue.length &gt;= 6 then
						_segmentValue :=_segmentValue[_segmentValue.length-6:end];
					else
						_segmentValue:=null;
					endif;
				endif;
				return true;
			else
				return false;
			endif;
		
			
			/*
			filePos := filePos +1;
			rulePos := rulePos +1;
		
			if rulePos &gt; ruleFieldValueWithoutFTX.length then																				//+TFS3602
				rulePos := ruleFieldValueWithoutFTX.length;
			endif;
			
			
			
			
			fileFieldValue :=  _fileValue.scanUntil("+", filePos); // Field 3																
																//-TFS3602
			ruleFieldValue :=  ruleFieldValueWithoutFTX.scanUntil("+", rulePos); // Field 3 								//+TFS3602
			
			if filePos = 0 or rulePos = 0 or fileFieldValue &lt;&gt; ruleFieldValue then
				return false;
			endif;
			
			filePos := filePos +1;
			rulePos := rulePos +1;
			
			if rulePos &gt; ruleFieldValueWithoutFTX.length then																						//+TFS3602
				rulePos := ruleFieldValueWithoutFTX.length;
			endif;
			
			fileFieldValue :=  _fileValue.scanUntil(":", filePos); // Field 4.1																	//-TFS3602
			ruleFieldValue :=  ruleFieldValueWithoutFTX.scanUntil(":", rulePos); // Field 4.1											//+TFS3602
						
			if self.function = self.Function_FTX_4_1_Heavy then
				// we have match on fields 1, 2, &amp; 3 - field 4.1 contains the text which will be used to decide if we are heavy rated or not
				if fileFieldValue = null or ruleFieldValue = null then
					// nothing to compare
					return false;
				elseif fileFieldValue = ruleFieldValue or fileFieldValue.pos (ruleFieldValue, 1) &gt; 0 then
					_ruleValue 		:= ruleFieldValue;
					_segmentValue	:= fileFieldValue;
					return true;
				endif;
				
			elseif self.function = self.Function_FTX_4_1_MTGradeText then
				// we have match on fields 1, 2, &amp; 3 - field 4.1 contains the text which will be used in MT grade xlation
				if fileFieldValue &lt;&gt; null and fileFieldValue = ruleFieldValue or fileFieldValue.pos (ruleFieldValue, 1) &gt; 0 then
					_ruleValue		:= ruleFieldValue;
					_segmentValue 	:= fileFieldValue;
					return true;
				endif;
	
			elseif self.function = self.Function_FTX_4_1_EstReqDT then					//cnwma1 TFS #2048 14/06/2016 
				
				if fileFieldValue &lt;&gt; null and fileFieldValue = ruleFieldValue or fileFieldValue.pos (ruleFieldValue, 1) &gt; 0 then
					_ruleValue		:= ruleFieldValue;
					_segmentValue :=fileFieldValue[fileFieldValue.length-6:fileFieldValue.length];
					return true;
				endif;
			endif;	
			*/
		elseif _item = self.Item_MEA_3_2 then
			filePos := filePos +1;
			rulePos := rulePos +1;
			/*																																		//-TFS3602
			if rulePos &gt; self.value.length then
				rulePos := self.value.length;
			endif;
			*/
			if rulePos &gt; ruleFieldValueWithoutFTX.length then										//+TFS3602
				rulePos := ruleFieldValueWithoutFTX.length;
			endif;
			
			fileFieldValue :=  _fileValue.scanUntil(":", filePos); // Field 3.1
			//ruleFieldValue :=  self.value.scanUntil(":", rulePos); // Field 3.1													//-TFS3602
			ruleFieldValue :=  ruleFieldValueWithoutFTX.scanUntil(":", rulePos); // Field 3.1						//+TFS3602
			
			
			if filePos = 0 or rulePos = 0 or fileFieldValue &lt;&gt; ruleFieldValue then
				return false;
			endif;
			
			fileAlphaValue :=  _fileValue[1:filePos]; // Field 1 tp Field 3.1 String Comparison
		//	ruleAlphaValue :=  self.value[1:rulePos]; // Field 1 to Field 3.1 String Comparison										//-TFS3602
			ruleAlphaValue :=  ruleFieldValueWithoutFTX[1:rulePos]; // Field 1 to Field 3.1 String Comparison		//+TFS3602
			filePos := filePos +1;
			rulePos := rulePos +1;
			
			if ruleAlphaValue = fileAlphaValue then
				fileIntegerValue := _fileValue[filePos:end].Integer; // Field 3.2 Integer Comparison
				//ruleIntegerValue := self.value[rulePos:end].Integer; // Field 3.2 Integer Comparison															//-TFS3602
				ruleIntegerValue := ruleFieldValueWithoutFTX[rulePos:end].Integer; // Field 3.2 Integer Comparison							//+TFS3602
				
				if ruleIntegerValue &lt;= fileIntegerValue then
					_ruleValue 		:= ruleIntegerValue.String;
					_segmentValue	:= fileIntegerValue.String;
					return true;
				endif;
			endif;
		endif;
    endif;
    return false;
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="String"/>
        <Parameter name="_fileValue" type="String"/>
        <Parameter name="_ruleValue" type="String" usage="output"/>
        <Parameter name="_segmentValue" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d4924fcc-30c4-48f0-a113-48d6298288e7">
        <updating/>
        <source>setForCreate(_proxy :CM_EDIEDIFactRule) updating;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
