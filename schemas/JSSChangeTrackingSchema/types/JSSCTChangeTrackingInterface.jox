    <JadeMethod name="getLastJournalTimeStamp" id="4d880129-cc19-40a2-8e77-b18c44c54191">
        <source>getLastJournalTimeStamp(): TimeStamp;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	nibbler: JSSCTNibblerManager;
begin
	nibbler := JSSCTNibblerManager.firstInstance;

	return (nibbler.lastAuditFileTimeStamp);
end;</source>
