    <JadeMethod name="canHaveAsChild" id="d2d61752-6444-400c-98b0-a8bbf907da2e">
        <source>canHaveAsChild(proposedChild: Control; rejectionReason: String output): Boolean;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not inheritMethod(proposedChild, rejectionReason)) then
		return false;
	endif; 

	if proposedChild.isKindOf(BaseControl)
	or proposedChild.isKindOf(Folder)
	or proposedChild.isKindOf(Frame)
	or proposedChild.isKindOf(GroupBox)
	or proposedChild.isKindOf(ListBox)
	or proposedChild.isKindOf(Picture)
	or proposedChild.isKindOf(Table)
	or proposedChild.isKindOf(TextBox)
	then
		return true;
	else
		rejectionReason	:=	proposedChild.class().name &amp; " controls not allowed in a CnEcSplitContainer";
		return false;
	endif;
end;</source>
        <Parameter name="proposedChild" type="Control"/>
        <Parameter name="rejectionReason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideLeftControl" id="2fd4ea42-32fe-4830-8deb-d9f13908e040">
        <updating/>
        <source>hideLeftControl() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:     Hides the left-hand control, plus the splitter bar.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.myLeftControl.visible	:=	false;
	
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	false;
	else
		self.myVerticalSplitter.visible		:=	false;
	endif;

	self.setLeftToRightRatio(0);
end;</source>
    </JadeMethod>
    <JadeMethod name="hideRightControl" id="5ce488a1-ad33-4c87-8ee6-250671f0e8b7">
        <updating/>
        <source>hideRightControl() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:     Hides the left-hand control, plus the splitter bar.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.myLeftControl.visible	:=	false;
	
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	false;
	else
		self.myVerticalSplitter.visible		:=	false;
	endif;

	self.setLeftToRightRatio(0);
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeSplitter" id="b22f6905-5b97-46ce-b852-e2f400b0a99a">
        <updating/>
        <source>initializeSplitter() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theVertical		: JSSVerticalSplitter;
	theHorizontal	: JSSHorizontalSplitter;

begin
	if self.isSplitHorizontal then
		theHorizontal	:=	self.myHorizontalSplitter;

		if theHorizontal = null then
			create theHorizontal transient;
		endif;

		theHorizontal.parent	:=	self;
		self.form.addControl(theHorizontal);
   	else
		theVertical	:=	self.myVerticalSplitter;

		if theVertical = null then
			create theVertical transient;
		endif;

		theVertical.parent	:=	self;
		self.form.addControl(theVertical);
 	endif;
epilog
	if isSplitHorizontal then
		self.myHorizontalSplitter	:=	theHorizontal;	
	else
		self.myVerticalSplitter		:=	theVertical;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isLockBottom" id="5ca7d86a-ad98-45c2-9d7b-cb35496fd5f4">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isLockBottom(set: Boolean; _value: Boolean io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if set and _value then
		if isStretchHeight then
			isStretchHeight	:=	false;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
