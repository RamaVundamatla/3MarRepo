    <JadeMethod name="getWLEsInTableOfClass" id="d827aab7-d9e0-4ed9-8b07-9d0857ebcdc9">
        <source>getWLEsInTableOfClass(_class : Class; _wleArray : CM_WLEArray input);
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	wle : CM_WorkListEntry;
	idx,
	rows : Integer;
begin

	on Exception do self.handleExceptionWLE(exception, wle);
	rows := self.tblWorkEntries.rows;
	
	foreach idx in 2 to rows do
		wle := self.tblWorkEntries.accessRow(idx).itemObject.CM_WorkListEntry;
		if wle = null or not wle.isKindOf(_class) then
			continue;
		endif;		
		if wle = null then
			// wle is set to null by the ex handler if it is not found / deleted
			continue;
		endif;
		if not _wleArray.includes(wle) then			
			_wleArray.add(wle);
		endif;
	endforeach;

end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWLEsInTableSelectedOfClass" id="da53889d-6604-4899-a593-65b7c2d895ee">
        <source>getWLEsInTableSelectedOfClass(_class : Class; _wleArray : CM_WLEArray input);
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	obj : Object;
	wle	: CM_WorkListEntry;
begin

	on Exception do self.handleExceptionWLE(exception, wle);
	
	foreach obj in self.tblWorkEntries.allSelectedObjects do
		wle := obj.CM_WorkListEntry;
		if wle = null or not wle.isKindOf(_class) then
			continue;
		endif;		
		if wle = null then
			// wle is set to null by the ex handler if it is not found / deleted
			continue;
		endif;
		_wleArray.add(wle);
	endforeach;

end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="2b5d5a9b-7a4a-48af-bd85-aecbfb384f8a">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	xmlStr	: String;

begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblJobs.getXmlStrForColumns(true);

	if self.optViewJob.value then
		xmlStr := xmlStr &amp; global.formatAsXML(XML_ViewBy,self.optViewJob.caption);	
	else
		xmlStr := xmlStr &amp; global.formatAsXML(XML_ViewBy,self.optViewWorkList.caption);	
	endif;
	
	return xmlStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="19e3e2fc-864d-4c35-8de6-46fd327fd1cd">
        <source>getXMLSettingsForSetup();
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	userWindow : CM_UserWindow;
	theXML, theXMLValue, theCaption : String;
	theRealValue : Real;
	
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;

	// Set View By
	if self.myCurrentJob = null then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_ViewBy);
		if theXMLValue &lt;&gt; null then
			self.optViewJob.value := (theXMLValue = self.optViewJob.caption);
			if self.optViewJob.value then
				self.tblWorkEntries.visible := false;
				self.tblJobs.visible := true;
			endif;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="includeJob" id="53097486-c399-4cd5-84bf-2e720dd367c5">
        <source>includeJob( _job : CM_Job ) : Boolean;
// -----------------------------------------------------------------------------
// Created:		21 July 2009 by consw1
//
// Purpose:		Basic check for inclusion of Job
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	wle : CM_WorkListEntry;
	wleArray : CM_WLEArray;
	invalidjOB : Boolean; 
begin

	on Exception do app.handleDeletedObject(exception, _job, invalidjOB); 

	if _job.isKindOf(CM_VoyageJob) and (not _job.CM_VoyageJob.isLoadedToOperations) then
		return false;
	endif;
	
	if _job.isKindOf(CM_RoadJob) then
		return false;
	endif;
	
	create wleArray transient;
	_job.getAllWLEs(wleArray);		

	if wleArray.size = 0 then
		return true;
	endif;
	
	foreach wle in wleArray where self.includeWLE(wle) do
		return true;
	endforeach;

	return false;
	
epilog
	delete wleArray;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeWLE" id="6cec61e1-1e01-4037-b280-5f4c4891c6bb">
        <source>includeWLE(_wle: CM_WorkListEntry): Boolean;
// -----------------------------------------------------------------------------
// Created:		21 July 2009 by consw1
//
// Purpose:		Basic check for inclusion of WLE
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	invalidWLE : Boolean; 
begin

	on Exception do app.handleDeletedObject(exception, _wle, invalidWLE); 


/*	
	if  self.lstTskSelected.findString( 1,_wle.getTaskTypeDesc() ) &lt; 1 then
		return false;
	endif;
*/
	if _wle.myRequest = null then
		return false;
	endif;

	return _wle.myRequest.isRequestForYardOps;
	
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initMnuPriority" id="3196e023-5d4a-4faa-bdd9-9c55f4d8b01c">
        <updating/>
        <source>initMnuPriority() updating;
// -----------------------------------------------------------------------------
// Created:		24 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	idx : Integer;
	mnuChild : MenuItem;
	
begin
	self.mnuSetPrioritySub.visible := false;

	foreach idx in 1 to CM_Job.MaxPriority do
		mnuChild := self.mnuSetPriority.loadSubMenu(idx);
		mnuChild.caption := idx.String;
		mnuChild.visible := true;
		mnuChild.enabled := true;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
