    <JadeMethod name="doSendToControl" id="c4f7dec0-43ca-4937-9e5e-500a219e81bc">
        <updating/>
        <source>doSendToControl() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	alert : CM_SystemAlert;
	preGateAlertType : CM_SystemAlertType;
	linkedTo : CM_Object;
begin
	preGateAlertType:=app.myRoot.allSystemAlertTypes[EVENT_AT_PreGateFailedAutoPlan];


	if cmbRFID.listCount = 0 or not cmbRFID.enabled then
	// no rfid tags to select raise alert
	
	else
	// tried to save but user did not select rfid tags and there were some to give 
		if not self.doUpdateRFIDTag then
			return;
		endif;
	endif;
	
	//there are preGateAlerts i.e. wle has not autoplanned
	if self.preGateAlerts.size &gt; 0 then
		foreach alert in self.preGateAlerts do
		beginTransaction;
			alert.setMySystemAlertType(preGateAlertType);
			linkedTo:=alert.getLinkedTo;
			if linkedTo &lt;&gt; null then
				linkedTo.addToAlerts(alert);
				alert.commitAlert(); //+ cnwmd1, CCMS 1871 - Noticed that this was not called so added in.  Now is consistant with CM_AlertManager::commitAlert()
			endif;
		commitTransaction;
		endforeach;
	endif;
	
	//mark job on hold
	self.unloadForm;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateRFIDTag" id="601f6723-0e18-4978-89bf-ca672e2db921">
        <updating/>
        <source>doUpdateRFIDTag()  : Boolean updating;
/*

Purpose:			


Return Value:		Returns whether update was successful


Date		Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx
10/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/
vars
	rfidTag : CM_RFIDTag;
	rfidCode	: String;
	invalidObject:Boolean ; 
	job	: CM_RoadJob;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	job := self.myJob;
	if job &lt;&gt; null then
		if self.cmbRFID.listIndex = -1 then
			
		else
			rfidCode:=self.cmbRFID.itemText[self.cmbRFID.listIndex];
			//par 16790---inorder to display a sensible msg to the user when a MyJob is deleted
			on Exception do app.handleDeletedObject(exception, job, invalidObject);
			rfidTag:=job.myTerminal.allRFIDTagsByCode[rfidCode];
			
			if invalidObject then
				app.msgBox('The current Job had been deleted.', 'Error', MsgBox_OK_Only+MsgBox_Stop_Icon);
				self.unloadForm;
			endif;
		endif;
		
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateRoadJobRFIDTag(job,rfidTag,app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				return true;
			else
				theResult := app.showErrorWarningDialog('RFID Tag', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return false;
			
		endwhile;
	
	endif;

	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadJobInfo" id="0a796c0a-538d-40d2-8958-0c0435b3cbce">
        <updating/>
        <source>loadJobInfo()updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	ti	 			: CM_TrackedItem;
	str				: String;
	wle 			: CM_WorkListEntry;
	locId			: String;
	indx 			: Integer;
	alert			: CM_SystemAlert;
begin
	lstInfo.clear();
	if myJob = null then
		return;
	endif;
	
	//th2 04/05/07 - job could be vaidly deleted from another user processing road exit
	//and the job has been deleted by now - also added lock (doesn't take long but prevents timing hole)
	if (not app.isValidObject(myJob)) then
		self.myJob	:= null; // adm 060709 Par 17867 prevents Error 4 later
		return;
	endif;
	
	foreach wle in myJob.workListEntries do
		str:=null;
		if wle.status = WLE_COMPLETED or wle.myTrackedItem = null then
			continue;
		endif;
	
		if wle.isReceipt then
		// recevial get where the container is queued to
			locId:= wle.getFinalTaskTargetLocId(); //jlier1 TFS 54675 9/11/22
			if locId &lt;&gt;  null then
				str:=str &amp; "Receival " &amp; wle.myTrackedItem.id.String &amp; " queued to " &amp; locId;
			else
				str:=str &amp; "Receival " &amp; wle.myTrackedItem.id.String &amp; " was not auto-queued";
				
				//31 jan 2013	NDL	Par 31102
				if wle.isDirectDelivery then
					str:=str &amp; "[" &amp; app.getErrorString(Direct_delivery) &amp; "]"; 
				endif;
			endif;
		else
		// its release get the actual location of the container
			locId:= wle.getLocationIdForMode(REAL_MODE);
			if locId &lt;&gt;  null then
				str:=str &amp; "Pick up " &amp; wle.myTrackedItem.id.String &amp; " from "  &amp; locId;		
			endif;
		endif;
		
		indx:=lstInfo.addItem(str);
		if locId = null and indx &lt;&gt; - 1 then
			lstInfo.itemForeColor[indx]:=Red;
		endif;
	endforeach;
	
	foreach alert in myJob.alerts do
		if alert.reviewed then
			continue;
		endif;
		
		indx := lstInfo.addItem(alert.details);
		lstInfo.itemForeColor[indx]:=Red;
		lstInfo.itemObject[indx] := alert;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForMode" id="d3512c3c-232b-4777-ae8d-6f4fe82adfa3">
        <updating/>
        <source>setForMode() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	self.setCaption('Select RFID Tag');
	
	if self.mode = self.Mode_FromGateIn then
		if (not app.isDevelopmentSystem) then
			self.cmbRFID.enabled := false;
		endif;
		self.lblRFID.caption := 'Listening for tag...';
		//self.lblRFID.foreColor := Yellow;
		self.beginTimer(500, Timer_Continuous, null);
	elseif self.mode = self.Mode_FromRoadOps then
		self.cmbRFID.enabled := true;
		self.btnSendControl.visible := false;
		self.btnProceed.distanceFromRight := self.btnSendControl.distanceFromRight;
	endif;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
