    <JadeMethod name="getSelectedInvoiceStatus" id="afb77715-5197-4326-9330-f4c4ff26f3be">
        <source>getSelectedInvoiceStatus(_bank : CM_Bank): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/03/2018	jlger1	Initial creation 37654
04/04/2018	jlgdap1	TFS 37560 PEL1 Prepend Invoice Status
31/10/2018  cnwma1  ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice
17/12/2020  cnwma1  Bug 48590: ADP - Passing Invoice Status is not Working when passed by web services
*/

vars

	tmpStr		: String;
	reportParam	: WS_ReportParameter;	
	invProcess  : CM_InvoiceProcess;
	invStatus   : CM_InvoiceStatus;
begin
	reportParam := self.allWSReportParams.getAtKey(ETRow_InvoiceStatus);
	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;	
	
	if tmpStr = Any_String then
		return CM_Invoice.INVOICE_ALL_STATUS;
	endif;
	
	if _bank = null then
		return CM_Invoice.INVOICE_ALL_STATUS;
	endif;
	
	invProcess := _bank.getMyInvoiceProcess;
	
	if _bank.getMyInvoiceProcess &lt;&gt; null then
		foreach invStatus in _bank.getMyInvoiceProcess.allStatuses discreteLock do
			if tmpStr = invStatus.description then
					return invStatus.id;
				endif;
		endforeach;
	endif;
	
	return CM_Invoice.INVOICE_ALL_STATUS;
epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
