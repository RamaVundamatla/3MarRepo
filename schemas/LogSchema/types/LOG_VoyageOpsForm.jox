    <JadeMethod name="setupShtVoyage" id="1813b2e7-6823-45c1-8fa5-045949072d2c">
        <updating/>
        <source>setupShtVoyage() updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	archiveVisible 	: Boolean;
	tmpWidth : Real;
	tmpLeft	: Real;
begin

	if self.fldInfo.topSheet &lt;&gt; self.shtVoyage then
		return;
	endif;

	tmpWidth := (self.shtVoyage.width - (WinLeftMargin*4))/2;								 

	// Global Voyage table
	tmpWidth := tmpWidth/3;
	self.tblVoyage.width := (tmpWidth*2).max(300);
	self.tblVoyage.cnEcResizeContents();							 
		
	// Archive stuff
	self.tblArchiveSearch.width	:= self.tblVoyage.width;
	self.tblArchiveSearch.top 	:= optCurrentView.top + optCurrentView.height + VerticalSpacing;
	// set table visible so it resizes ready for subsequent showing
	archiveVisible := self.tblArchiveSearch.visible;
	self.tblArchiveSearch.visible := true;
	self.tblArchiveSearch.cnEcResizeContents();
	self.tblArchiveSearch.visible := archiveVisible;	// restore the catual visibility

	self.btnArchiveSearch.move(tblArchiveSearch.left + tblArchiveSearch.width - btnArchiveSearch.width, tblArchiveSearch.top + tblArchiveSearch.height + VerticalSpacing, btnArchiveSearch.width, btnArchiveSearch.height);
	
	self.tblVoyage.top := self.btnArchiveSearch.top + self.btnArchiveSearch.height + VerticalSpacing;
	
	// Voyage data table
	tmpLeft := self.tblVoyage.left + self.tblVoyage.width + WinLeftMargin * 2;
	self.tblVoyTermDtl.move(tmpLeft, self.tblVoyTermDtl.top, self.shtVoyage.width - tmpLeft - WinRightMargin, self.shtVoyage.height - (WinTopMargin*3) - self.btnAdminSave.height);	
	self.tblVoyTermDtl.cnEcResizeContents();			
end;</source>
    </JadeMethod>
    <JadeMethod name="setupShtVoyageAdmin" id="a5eecda1-0750-4e98-b24c-eef32433ec17">
        <updating/>
        <source>setupShtVoyageAdmin() updating;
//	CCMS 1124
vars
	tmpWidth : Real;
begin

	if self.fldInfo.topSheet &lt;&gt; self.shtVoyageAdmin then
		return;
	endif;

	tmpWidth := (self.shtVoyageAdmin.width - (WinLeftMargin * 4)) / 2;								 
	
	// Global Voyage table
	tmpWidth := tmpWidth / 2;
	self.tblVoyageAdmin.width := tmpWidth + 30;
	self.tblVoyageAdmin.cnEcResizeContents();
	
	self.btnEditName.left := self.tblVoyageAdmin.left + self.tblVoyageAdmin.width + WinLeftMargin;
	self.btnEditName.top := self.tblVoyageAdmin.top + 40;
		
	// All Terminal Stuff 
	self.lbxUnassTerminal.move(self.btnEditName.left + self.btnEditName.width + 2 * WinLeftMargin, self.lblUnassigned.top + self.lblUnassigned.height + WinTopMargin,
							   tmpWidth, shtVoyageAdmin.height - (WinTopMargin*5) - btnAdminSave.height);
	self.btnVoySelectPort.left 	:= self.lbxUnassTerminal.left + self.lbxUnassTerminal.width + WinLeftMargin;
	self.btnVoyDeSelPort.left 	:= self.btnVoySelectPort.left;
	self.lbxVoyTerminals.move(self.btnVoyDeSelPort.left + self.btnVoyDeSelPort.width + WinLeftMargin, self.lblUnassigned.top + self.lblAssigned.height + WinTopMargin,
							  tmpWidth, shtVoyageAdmin.height - (WinTopMargin*5) - btnAdminSave.height);
	self.lblUnassigned.left := self.lbxUnassTerminal.left;
	self.lblAssigned.left := self.lbxVoyTerminals.left;
	self.btnVoySelectPort.top	:= self.lbxUnassTerminal.top + WinTopMargin;
	self.btnVoyDeSelPort.top 	:= self.btnVoySelectPort.top + self.btnVoySelectPort.height + WinTopMargin;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupSideto" id="fe9ce18a-da5a-403e-b961-3c038c0b9dc9">
        <updating/>
        <source>setupSideto(_row : Integer; _option : Boolean) updating, protected;
// Side-to combo
vars
	str,
	sideTo	: String;
	
begin
	
	self.tblVoyTermDtl.accessCell(_row, 3).inputType := Table.InputType_ComboBox;
	str := "Port" &amp; Tab &amp; "Starboard";
	self.tblVoyTermDtl.accessCell(_row, 3).comboList := str;
	
	if _option then
		sideTo := "Starboard";
	else
		sideTo := "Port";
	endif;

	self.tblVoyTermDtl.accessCell(_row, 3).text := sideTo;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_option" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupVisibleSheet" id="1987ba7b-2529-44da-b96a-508d5392dc91">
        <updating/>
        <source>setupVisibleSheet() updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/02/2011	cnwcs5		CCMS JML 1114 / PAR 26847 - allow multi-select on shipside scan sheet
// ---------------------------------------------------------------------------
vars
	topSheet		: Sheet;
	table			: CM_DataTable;					// 09/02/2011 cnwcs5 CCMS JML 1114
	oldValue, newValue
					: Integer;
	oldRow			: Integer;
begin

	topSheet 	:= fldInfo.topSheet;
	table		:= self.tblOrderData;				// 09/02/2011 cnwcs5 CCMS JML 1114
	oldValue	:= self.tblOrderData.multiSelect;	// 09/02/2011 cnwcs5 CCMS JML 1114
	newValue	:= CM_DataTable.MultiSelect_None;	// 09/02/2011 cnwcs5 CCMS JML 1114
	oldRow		:= table.row;						// 09/02/2011 cnwcs5 CCMS JML 1114

	
	if topSheet = self.shtVoyageAdmin then
		self.setupShtVoyageAdmin();
	elseif topSheet = self.shtVoyage then
		self.setupShtVoyage();
	elseif topSheet = self.shtSuppliers then
		self.setupShtSuppliers();		
		self.showSupplierDetails();
	elseif topSheet = self.shtDetails then
		self.setupShtDetails();	
	elseif topSheet = self.shtAllocateRows then
		self.setupShtAllocateRows();
	elseif topSheet = self.shtAllocToDetail then
		self.setupShtAllocToDetail();
	elseif topSheet = self.shtAdditInfo then
		self.setupShtAdditInfo();
	elseif topSheet = self.shtSSScan then	
		self.setupShtShipsideScan();
		
		newValue := CM_DataTable.MultiSelect_Simple;	// 09/02/2011 cnwcs5 CCMS JML 1114
	endif;

	// if going from selectWholeRows to selectCurrentRow then current row remains selected
	// if going other way just need to select previously selected row as all other date will be displayed OK
	if oldValue &lt;&gt; newValue then							// 09/02/2011 cnwcs5 CCMS JML 1114
		table.multiSelect	:= newValue;					// 09/02/2011 cnwcs5 CCMS JML 1114
	
		if table.allSelectedObjects.size &gt; 1 then				// 09/02/2011 cnwcs5 CCMS JML 1114
			if newValue = CM_DataTable.MultiSelect_None then	// 09/02/2011 cnwcs5 CCMS JML 1114
				// going from multi-select to single select
				table.clearAllSelected;							// 09/02/2011 cnwcs5 CCMS JML 1114
				
				if oldRow &gt; self.tblOrderData.fixedRows  then	// 09/02/2011 cnwcs5 CCMS JML 1114
					table.selectRow (oldRow, false);			// 09/02/2011 cnwcs5 CCMS JML 1114
				endif;											// 09/02/2011 cnwcs5 CCMS JML 1114
				
				self.sssShowLogRowsForDownload();				// 09/02/2011 cnwcs5 CCMS JML 1114
			endif;												// 09/02/2011 cnwcs5 CCMS JML 1114		
		endif;											// 09/02/2011 cnwcs5 CCMS JML 1114
	endif;												// 09/02/2011 cnwcs5 CCMS JML 1114
end;</source>
    </JadeMethod>
    <JadeMethod name="showAdditionalInfo" id="72a20acb-2d41-45cb-b281-c0c0c0202bd3">
        <source>showAdditionalInfo(_obj : Object);
//--------------------------------------------------------------
//Created: 05 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx	: Integer;
	str	: String;
	extraInfo : HugeStringArray;
begin

	tblAdditInfo.rows := 0;

	create extraInfo transient;
	if _obj &lt;&gt; null then
		if _obj.isKindOf(CM_StockOrderObject) then
			_obj.CM_StockOrderObject.getExtraInfoLogVoyOps(extraInfo, self.myTerminal);
		elseif _obj.isKindOf(CM_Voyage) then
			_obj.CM_Voyage.getExtraInfoLogVoyOps(extraInfo,  self.myTerminal);
		elseif _obj.isKindOf(CM_VoyageOperator) then			
			_obj.CM_VoyageOperator.getExtraInfoLogVoyOps(extraInfo,  self.myTerminal);
		elseif _obj.isKindOf(CM_VoyageGlobal) then			
			_obj.CM_VoyageGlobal.getExtraInfoLogVoyOps(extraInfo,  self.myTerminal);		
		endif;
	endif;

	self.showInfoFromArray(extraInfo);

	
epilog
	delete extraInfo;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showAllocQtyForSearchResults" id="79d52905-3bdc-4f67-98d6-9fe96f52dfdf">
        <source>showAllocQtyForSearchResults();
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	sohLocn		: CM_SOHLocation;
	qtyStr,
	allocTypeStr : String;
	availVol,
	allocQty	: Real;
	idx,
	colAvailVol,
	colAllocQty,
	numRows		: Integer;
	stkOrderLine: CM_StockOrderProductLine;
	stkOrder	: CM_StockOrderObject;
begin

	numRows := tblSrchResults.rows;
	colAllocQty	:= tblSrchResults.getColumnByRowName(ETRow_AllocVolume);
	colAvailVol := tblSrchResults.getColumnByRowName(ETRow_AvailableVolume);
	stkOrder := self.myCurrentStockOrderObject;
	stkOrderLine := self.myCurrentStockOrderLine;
	qtyStr := CM_StockOrderAllocation.AllocTypeStr_Quantity;
	
	foreach idx in 2 to numRows do
		sohLocn := tblSrchResults.accessRow(idx).itemObject.CM_SOHLocation;
		
		availVol := sohLocn.calAvailableVolumeForStkOrder(stkOrderLine, false);
		allocTypeStr := sohLocn.getAllocTypeStringForOrderLine(stkOrder);
		
		if allocTypeStr = qtyStr then
			allocQty := sohLocn.getAllocQtyForOrderLine(stkOrder);
			allocTypeStr := self.volumeDisplayString(allocQty);
		endif;
		
		if idx &gt; 1 then
			tblSrchResults.accessCell(idx, colAllocQty).text := allocTypeStr;
			tblSrchResults.accessCell(idx, colAvailVol).text := self.volumeDisplayString(availVol);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="showAllocToDetail" id="26a784a7-52a1-4845-add9-21e719e7a700">
        <source>showAllocToDetail();
//--------------------------------------------------------------
//Created: 08 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str,
	strAmt,
	orderStr,
	tmpRemain,
	tmpStr,
	fellDateStr 	: String;
	orderSummary 	: CM_StockOrderSummary;
	order 			: CM_StockOrderLine;
	orderLine 		: CM_LogStockOrderLine;
	orderLineSet 	: CM_StockOrderLineSet;
	allocation 		: CM_StockOrderSummaryAlloc;
	allocationSet 	: CM_StockOrderSummaryAllocSet;
	row, col, idx,
	backColour,
	colWidth		: Integer;
	amt,
	totSplit,
	unAllocAmt		: Decimal[16,4];
	textBox			: TextBox;
	sohLocn 		: CM_SOHLocation;
	fellDate 		: Date;
begin

	tblAllocDetail.columns 		:= (tblAllocDetail.fixedColumns);
	tblAllocDetail.rows 		:= tblAllocDetail.fixedRows;
	self.txtAllocRowSpecs.text 	:= null;	

	if self.fldInfo.topSheet &lt;&gt; self.shtAllocToDetail then
		return;
	endif;
		
	if self.myCurrentStockOrderSummary = null then
		return;
	endif;

	orderSummary := self.myCurrentStockOrderSummary;
	orderLineSet := orderSummary.allStockOrderLines;
	tblAllocDetail.columns := (tblAllocDetail.fixedColumns + orderLineSet.size);
	row := 1;
	col := (tblAllocDetail.fixedColumns + 1);
	
	//Display columns (stock orders)
	foreach order in orderLineSet do
		//Customer and Discharge port of Stock Order
		orderLine := order.CM_LogStockOrderLine;
		//First row - Stock Order lot number
		tblAllocDetail.accessCell(row, col).text := orderLine.getDisplayDetails(true);
		/*if orderLine.myLogLot &lt;&gt; null then
			tblAllocDetail.accessCell(row, col).text := 'Lot ' &amp; orderLine.lotNo;
		else			
			tblAllocDetail.accessCell(row, col).text := orderLine.consigneeCode &amp;
														'/' &amp; orderLine.dischargePort &amp;
														'/' &amp; 'Lot ' &amp; orderLine.lotNo;
		endif;*/

		//Second Row - Amount ordered by customer for lot					
		row := (row + 1);
		tblAllocDetail.accessCell(row, col).text := orderLine.reqdQuantity.rounded.asStringJMT;

		//Third row - Balance still to be allocated to order
		row := (row + 1);
		unAllocAmt := orderLine.getNumberUnfulfilled();
		str := self.volumeDisplayString(unAllocAmt);
		tblAllocDetail.accessCell(row, col).text := str;
		
		//Lot Column item object
		tblAllocDetail.accessColumn(col).itemObject := orderLine;
		
		//Hide lots that have been completed
		if self.hideCompleted then
			tmpStr := tblAllocDetail.accessCell(row, col).text;
			if tmpStr = '0' or tmpStr = '0.000' then
				tblAllocDetail.accessColumn(col).visible := false;		
			endif;
		else
			tblAllocDetail.accessColumn(col).visible := true;					
		endif;
		row := 1;		
		col := (col + 1);
	endforeach;

	allocationSet := orderSummary.allStockAllocations;
	row := tblAllocDetail.fixedRows + 1;
	col := 3;
	str := null;

	//Display Rows (log rows allocated to summary)
	foreach allocation in allocationSet do
		sohLocn := allocation.mySOHLocation;
		if sohLocn.myExtension &lt;&gt; null then
			//Date column is hidden, used for sorting
			fellDate := sohLocn.myExtension.getOldestDate();
			fellDateStr := fellDate.shortFormatJMT();	// format('yyyyMMdd');
		endif;
		foreach order in orderLineSet do
			strAmt := allocation.getAllocQtyDisplayStrForOrder(order);
			amt	:= allocation.mySOHLocation.getAllocAmtForDetail(order);
			//strAmt := self.volumeDisplayString(amt);
			totSplit := totSplit + amt;
			//if strAmt.isInteger then
				orderStr := orderStr &amp; Tab &amp; strAmt;
			/*else
				orderStr := orderStr &amp; Tab &amp; self.volumeDisplayString(amt);
			endif;*/
		endforeach;	
		
		tmpRemain := self.volumeDisplayString((allocation.allocQuantity - totSplit));

		/*if orderStr.isInteger then
			orderStr := orderStr.Integer.String;
		endif;*/		
		
		str := fellDateStr &amp; Tab &amp; allocation.myLocationsController.getID() &amp; Tab &amp;
			   self.volumeDisplayString(allocation.allocQuantity) &amp; Tab &amp; tmpRemain;
			   
		str := str &amp; orderStr;
		idx := tblAllocDetail.addItem(str);
		tblAllocDetail.accessRow(idx).itemObject := allocation;
		
		if self.hideCompleted then
			tmpStr := tblAllocDetail.accessCell(row, col).text;
			if tmpStr = '0' or tmpStr = '0.000' then
				tblAllocDetail.accessRow(idx).visible := false;		
			endif;
		else
			tblAllocDetail.accessRow(idx).visible := true;					
		endif;
		
		str := null;
		orderStr := null;
		totSplit := null;		
	endforeach;			

//	tblAllocDetail.accessColumn(2).width := 60; 
//	tblAllocDetail.accessColumn(3).width := 60; 
//	tblAllocDetail.accessColumn(4).width := 70; 
	
	if tblAllocDetail.rows &gt; 3 and tblAllocDetail.columns &gt; 4 then
		tblAllocDetail.row 			:= 4;
		tblAllocDetail.column 		:= 5;
//		tblAllocDetail.inputType 	:= Table.InputType_TextNumeric;
		tblAllocDetail.inputType 	:= Table.InputType_TextBox;
		tblAllocDetail.decimals		:= 3;	
		textBox 					:= tblAllocDetail.accessCell(4,5).cellControl.TextBox;
		textBox.selectionStyle 		:= TextBox.SelectionStyle_SelectAll;
	endif;

	txtAllocRowSpecs.text := null;
	tblAllocDetail.sortAscending := false;		
	tblAllocDetail.resortTableByColumn(1);
	tblAllocDetail.colourRows(self.colorRow1, self.colorRow2);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showAllocVolumeForOrderData" id="280633df-bf26-4f95-bcdd-7fe04ce26e44">
        <source>showAllocVolumeForOrderData();
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocQty	: Decimal[16,4];
	colAllocQty,
	rowIdx 		: Integer;
	orderLine	: CM_StockOrderLine;
	str			: String;
	summary 	: CM_StockOrderSummary;
begin

	colAllocQty	:= tblOrderData.getColumnByRowName(ETRow_AllocVolume);

	if self.myCurrentStockOrderLine &lt;&gt; null then
		allocQty := self.myCurrentStockOrderLine.calAllocatedAmount();
		summary := self.myCurrentStockOrderLine.myStockOrderSummary;
	elseif self.myCurrentStockOrderSummary &lt;&gt; null then
		allocQty := self.myCurrentStockOrderSummary.calAllocatedTotal();
		summary := self.myCurrentStockOrderSummary;
	else
		return;
	endif;
	str := self.volumeDisplayString(allocQty);
	tblOrderData.accessCell(tblOrderData.row, colAllocQty).text := str;				
			
	if summary &lt;&gt; null then
		allocQty := summary.calAllocatedTotal();
		str := self.volumeDisplayString(allocQty);
		if allocQty = 0 then
			foreach orderLine in summary.allStockOrderLines do
				if tblOrderData.findObjectInRow(orderLine, rowIdx) then
					if str.isInteger then
						tblOrderData.accessCell(rowIdx, colAllocQty).text := allocQty.Integer.String;	
					else
						tblOrderData.accessCell(rowIdx, colAllocQty).text := self.volumeDisplayString(allocQty);
					endif;
				endif;
				rowIdx := 0;				
			endforeach;
		endif;
		rowIdx := 0;						
		if tblOrderData.findObjectInRow(summary, rowIdx) then
			if str.isInteger then
				tblOrderData.accessCell(rowIdx, colAllocQty).text := str;	
			else
				tblOrderData.accessCell(rowIdx, colAllocQty).text := self.volumeDisplayString(allocQty);
			endif;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showAllocVolumeForOrderLine" id="2eff6cc8-127c-4335-9be8-6d8634af3e18">
        <source>showAllocVolumeForOrderLine(_orderLine : CM_StockOrderLine);
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	str 		: String;
	allocQty	: Decimal[16,4];
	rowIdx,
	colAllocQty : Integer;
begin

	if _orderLine = null then	
		return;
	endif;
	
	if tblOrderData.findObjectInRow(_orderLine, rowIdx) then
		colAllocQty	:= tblOrderData.getColumnByRowName(ETRow_AllocVolume);
		allocQty := _orderLine.calAllocatedAmount();
		str := self.volumeDisplayString(allocQty);
		tblOrderData.accessCell(rowIdx, colAllocQty).text := str;
		/*if str.isInteger then
			tblOrderData.accessCell(rowIdx, colAllocQty).text := str;
		else
			tblOrderData.accessCell(rowIdx, colAllocQty).text := self.volumeDisplayString(allocQty);
		endif;*/
	endif;

end;</source>
        <Parameter name="_orderLine" type="CM_StockOrderLine"/>
    </JadeMethod>
    <JadeMethod name="showAllocatedRows" id="151009e2-7144-4541-bd00-011704d3f6f2">
        <source>showAllocatedRows(_allocSet : CM_StockOrderAllocationSet);
// ---------------------------------------------------------------------------
// Created:     01 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	allocation	: CM_StockOrderAllocation;
	ls			: Boolean;
	str			: String;
	idx, col	: Integer;
begin

	tblAllocatedRows.rows := tblAllocatedRows.fixedRows;
	app.cmsBeginLoad(ls);
	
	foreach allocation in _allocSet reversed do
		sharedLock(allocation);
		str := self.dataTableDisplayRow(tblAllocatedRows, allocation);
		idx := tblAllocatedRows.addItem(str);
		tblAllocatedRows.accessRow(idx).itemObject := allocation;
	endforeach;
	
	//col := tblAllocatedRows.getColumnByRowName(ETRow_Date);//par 11608
	col := tblAllocatedRows.getColumnByRowName(ETRow_OldestFellDate);
	self.tblAllocatedRows.sortAscending := false;		
	self.tblAllocatedRows.resortTableByColumn(col);
	self.tblAllocatedRows.colourRows(self.colorRow1, self.colorRow2);	
	
epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_allocSet" type="CM_StockOrderAllocationSet"/>
    </JadeMethod>
    <JadeMethod name="showCannotAccessSheetMsg" id="4ba7294b-aa9d-4633-88be-cff73b6b1e4b">
        <source>showCannotAccessSheetMsg(_sheet : Sheet; _msg : String);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	StdHeight	= 125;
	StdWidth	= 300;
vars
	tmpWidth,
	tmpHeight,
	tmpX,
	tmpY	: Real;

begin
	
	if self.modeView = Mode_ArchiveView or self.mode = self.Mode_View_Only or
	   self.modeView = Mode_LimitedEdit then
		return;
	endif;
	
	self.setControlsForSheet(_sheet, false);

	frmMessage.parent		:= _sheet;
	frmMessage.caption 		:= _msg;
	frmMessage.alignment	:= frmMessage.Alignment_Center_Middle;
	
	if _sheet.height &gt; StdHeight then
		tmpHeight	:= StdHeight;
		tmpY		:= (_sheet.height - StdHeight) / 2;
	else
		tmpHeight	:= _sheet.height;
		tmpY		:= 0;
	endif;
	if _sheet.width &gt; StdWidth then
		tmpWidth	:= StdWidth;
		tmpX		:= (_sheet.width - StdWidth) / 2;
	else
		tmpWidth	:= _sheet.width;
		tmpX		:= 0;
	endif;

	frmMessage.move(tmpX, tmpY, tmpWidth, tmpHeight);
	
	frmMessage.visible := true;

end;</source>
        <Parameter name="_sheet" type="Sheet"/>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="showInfoFromArray" id="eb4a1c1c-a3da-496b-89c3-cd7977ea2b16">
        <source>showInfoFromArray(_extraInfo : HugeStringArray);
//--------------------------------------------------------------
//Created: 05 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str	: String;
	idx	: Integer;
begin

	if _extraInfo = null then
		return;
	endif;
	foreach idx in 1 to _extraInfo.size do
		str := _extraInfo[idx];
		str.replaceChar(Cr," ");
		str.replaceChar(Lf," ");
		if str &lt;&gt; "" then
			self.tblAdditInfo.addItem(str);
		endif;
	endforeach;
	tblAdditInfo.accessColumn(1).backColor := self.ColourYellowLight;
//	tblAdditInfo.accessedColumn.fontBold := true;
end;</source>
        <Parameter name="_extraInfo" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="showRequiredAllocatedQtys" id="9fb131a2-5db4-4747-ac01-ca5db77f6467">
        <source>showRequiredAllocatedQtys();
//--------------------------------------------------------------
//Created: 06 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	toAllocate : Decimal[12,4];
begin

	if self.myCurrentStockOrderLine &lt;&gt; null then
		self.txtAllocateReq.text := self.myCurrentStockOrderLine.reqdQuantity.Integer.String;
		// PAR 10314
		self.txtAllocated.text := self.myCurrentStockOrderLine.CM_LogStockOrderLine.getNumerStillToAllocate();		
		//toAllocate := self.myCurrentStockOrderLine.getNumberUnfulfilled;
		//self.txtAllocated.text := toAllocate.Integer.String;
			
	elseif self.myCurrentStockOrderSummary &lt;&gt; null then
		self.txtAllocateReq.text := self.myCurrentStockOrderSummary.reqdQuantity.Integer.String;
		toAllocate := (self.myCurrentStockOrderSummary.reqdQuantity - self.myCurrentStockOrderSummary.calAllocatedTotal);		
		if toAllocate &lt; 0 then
			toAllocate := 0;
		endif;
		self.txtAllocated.text := toAllocate.Integer.String;
	else
		self.txtAllocateReq.text := null;
		self.txtAllocated.text := null;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showSOHSearchResults" id="d20bcd75-665c-4aa6-b56e-30615d35aaf9">
        <source>showSOHSearchResults();
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	sohLocn		: CM_SOHLocation;
	qtyStr,
	allocStr,
	str			: String;
	availVol,
	allocQty	: Real;
	colAvailVol,
	colAllocQty,
	idx, col	: Integer;
	stkOrderLine: CM_StockOrderProductLine;
	stkOrder	: CM_StockOrderObject;	
begin
	
	tblSrchResults.rows := tblSrchResults.fixedRows;
	colAllocQty := tblSrchResults.getColumnByRowName(ETRow_AllocVolume);
	colAvailVol := tblSrchResults.getColumnByRowName(ETRow_AvailableVolume);
	stkOrder := self.myCurrentStockOrderObject;
	stkOrderLine := self.myCurrentStockOrderLine;
	qtyStr := CM_StockOrderAllocation.AllocTypeStr_Quantity;	
	
	foreach sohLocn in self.allSOHSearchResults do
		str := self.dataTableDisplayRow(tblSrchResults, sohLocn);
		idx := tblSrchResults.addItemObject(sohLocn, str);
		
		allocStr := sohLocn.getAllocTypeStringForOrderLine(stkOrder);
		if allocStr = qtyStr then
			allocQty := sohLocn.getAllocQtyForOrderLine(stkOrder);
			allocStr := self.volumeDisplayString(allocQty);
		endif;
		tblSrchResults.accessCell(idx, colAllocQty).text := allocStr;
				
		availVol := sohLocn.calAvailableVolumeForStkOrder(stkOrderLine,false);
		tblSrchResults.accessCell(idx, colAvailVol).text := self.volumeDisplayString(availVol);
				
		beginNotification(sohLocn, Object_Update_Event, Response_Continuous, null);
	endforeach;

	//col := tblSrchResults.getColumnByRowName(ETRow_Date);//par 11608
	col := tblSrchResults.getColumnByRowName(ETRow_OldestFellDate);
	
	self.tblSrchResults.sortAscending := false;		
	self.tblSrchResults.resortTableByColumn(col);
	self.tblSrchResults.colourRows(self.colorRow1, self.colorRow2);	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showStockOrderData" id="0514eb74-ad0b-46ac-a794-2913a2a759b8">
        <source>showStockOrderData(_objectSet : CM_ObjectArray);
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 11/04/2011	cnwcs5	par 27367 - use clearAllData instead of setting rows to fixed rows
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	obj 		: Object;
	str			: String;
	selectRow 	: JadeTableRow;
	backColour, 
	foreColour, 
	idx 		: Integer;
	theUser		: CM_User;
	table		: CM_DataTable;		// par 27367 - use local variable instead of repeated getPropertyValue calls
begin
	table := self.tblOrderData;		// par 27367
	table.clearAllData;				// par 27367
	table.resortTableByColumn(0);
	theUser := app.getMyUser();	
	foreach obj in _objectSet do
		if (not self.includeStockOrder(obj.CM_StockOrderObject, theUser)) then
			continue;
		endif;
		str := self.dataTableDisplayRow(table, obj.CM_Object);
		//get colour for row
		if table.rows mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;		
		idx := table.addItem(str);
		table.accessRow(idx).itemObject := obj;
		if self.optBoth.value and obj.isKindOf(CM_StockOrderSummary) then
			table.accessedRow.backColor := ColourPink;
			table.accessedRow.foreColor := White;			
			table.accessedRow.fontBold := true;			
		else
			table.accessedRow.backColor := backColour;
		endif;
	endforeach;
	if self.optSummary.value then
		table.accessColumn(table.getColumnByRowName(ETRow_MyLogLot)).visible := false;
		table.accessColumn(table.getColumnByRowName(ETRow_ConsigneeCode)).visible := false;
		table.accessColumn(table.getColumnByRowName(ETRow_DischargePort)).visible := false;
		table.sortAscending := false;
		table.resortTableByColumn(table.getColumnByRowName(ETRow_MyOperator));
		table.colourRows(self.colorRow1, self.colorRow2);
	else
		table.accessColumn(table.getColumnByRowName(ETRow_MyLogLot)).visible := true;
		table.accessColumn(table.getColumnByRowName(ETRow_ConsigneeCode)).visible := true;
		table.accessColumn(table.getColumnByRowName(ETRow_DischargePort)).visible := true;
		if self.optDetails.value then
			table.sortAscending := false;
			table.resortTableByColumn(table.getColumnByRowName(ETRow_MyLogLot));
			table.colourRows(self.colorRow1, self.colorRow2);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_objectSet" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="showSupplierDetails" id="d9eade1c-aecf-4e9f-ad54-51ea0cdf343f">
        <updating/>
        <source>showSupplierDetails() updating;
//--------------------------------------------------------------
//Created: 11 July 2002 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
09/07/2019	jlgka1 	45365	JMT - Log Voyage Operations - Suppliers Tab - Lot Plan Version issue.
							Instead of using TimeStamp as a casting method use asTimeStampJMT.
============================================================================*/

vars
	assist			: LOG_Assistant;
	row				: Integer;
	terminalName 	: String;
	terminal		: CM_Terminal;
	voyage			: CM_Voyage;
	globalVoy 		: CM_VoyageGlobal;
	selectedVoyOp,
	voyOperator		: CM_VoyageOperator;
	operator		: CM_Operator;
	allVoyOpers		: CM_VoyageOperatorByOperator;
	theUser			: CM_User;

begin

	theUser := app.getMyUser;
	selectedVoyOp := self.myCurrentVoyageOperator;

	if self.fldInfo.topSheet = self.shtSuppliers then
		globalVoy := self.myCurrentVoyageGlobal;
		if self.myCurrentVoyage &lt;&gt; null then
			terminal := self.myCurrentVoyage.myTerminal;
			tblSupplierEnt.disableRowByName(ETRow_Port);
		else
			tblSupplierEnt.enableRowByName(ETRow_Port);					
		endif;
		
		tblSupplierEnt.clearValues();
		assist := self.myAssistant.LOG_Assistant;
		self.tblSupplierDtl.rows := self.tblSupplierDtl.fixedRows;
		
		if globalVoy &lt;&gt; null then
			foreach voyage in globalVoy.allVoyages do
				if (not self.includeVoyage(voyage, theUser)) then
					continue;
				endif;
				terminal := voyage.myTerminal;
				terminalName := terminal.name;			
				allVoyOpers :=  voyage.allVoyageIOperators;
				if allVoyOpers = null then
					continue;
				endif;
				foreach voyOperator	in allVoyOpers do
					if (not self.includeOperator(voyOperator.myOperator)) then
						continue;
					endif;
					row := tblSupplierDtl.addItem(voyOperator.myOperator.code &amp; Tab
												 &amp; terminalName &amp; Tab
												 &amp; voyOperator.agentCode &amp; Tab									 
												 &amp; voyOperator.stevedoreCode1 &amp; Tab									 
												 &amp; voyOperator.stevedoreCode2 &amp; Tab
												 &amp; self.systemToLocalTime(voyOperator.lotPlanVersion.asTimeStampJMT).asStringJMT());	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support // jlgka1 TFS 45365
					tblSupplierDtl.accessRow(row).itemObject := voyOperator;
				endforeach;
			endforeach;
			tblSupplierDtl.accessColumn(2).visible := true;				

		elseif terminal &lt;&gt; null then
			terminalName := terminal.name;
			foreach voyage in terminal.allVoyagesByCode do
				if (not self.includeVoyage(voyage, theUser)) then
					continue;
				endif;
				allVoyOpers :=  voyage.allVoyageIOperators;
				if allVoyOpers = null then
					continue;
				endif;			
				foreach voyOperator in allVoyOpers do
					if (not self.includeOperator(voyOperator.myOperator)) then
						continue;
					endif;				
					row := tblSupplierDtl.addItem(voyOperator.myOperator.code &amp; Tab
												 &amp; terminalName &amp; Tab
												 &amp; voyOperator.agentCode &amp; Tab									 
												 &amp; voyOperator.stevedoreCode1 &amp; Tab									 
												 &amp; voyOperator.stevedoreCode2 &amp; Tab
												 &amp; self.systemToLocalTime(voyOperator.lotPlanVersion.TimeStamp).asStringJMT());	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
					tblSupplierDtl.accessRow(row).itemObject := voyOperator;
				endforeach;
			endforeach;	
			tblSupplierDtl.accessColumn(2).visible := false;
		endif;
	endif;					
	tblSupplierDtl.sortAscending := false;
	tblSupplierDtl.resortTableByColumn(tblSupplierDtl.getColumnByRowName(ETRow_MyOperator));
	tblSupplierDtl.colourRows(self.colorRow1, self.colorRow2);

	tblSupplierDtl.selectObject(selectedVoyOp, true);
	self.voyageOperatorShow(self.myCurrentVoyageOperator);

end;</source>
    </JadeMethod>
    <JadeMethod name="showTableDataForCurrentObject" id="d5598b74-11d4-46a7-b8e7-20e5c0664b36">
        <updating/>
        <source>showTableDataForCurrentObject() updating;
//--------------------------------------------------
// Created:	19 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCurrentStockOrderObject &lt;&gt; null then
		if self.myCurrentStockOrderObject.isKindOf(CM_StockOrderSummary) then
			self.showAllocatedRows(self.myCurrentStockOrderSummary.allStockAllocations);
			self.showAllocToDetail();
		elseif self.myCurrentStockOrderObject.isKindOf(CM_LogStockOrderLine) then
			self.showAllocatedRows(self.myCurrentStockOrderLine.allStockAllocations);
		endif;

		self.detailsDisplaySelected();		
		self.showAdditionalInfo(self.myCurrentStockOrderObject);
		self.showAllocQtyForSearchResults();
		
		self.sssShowLogRowsForDownload();	// 06/04/2009 cnwar2 CCMS-1099 #19395
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showTxtAllocRowDtls" id="87a491f0-dac9-48ca-be84-4a5780606d22">
        <source>showTxtAllocRowDtls(_sohLocn : CM_SOHLocation);
//--------------------------------------------------------------
//Created: 25 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	str, display 	: String;
	logRow 			: CM_SOHLocation;
	extraInfoArray 	: HugeStringArray;
begin

	txtAllocRowDtls.text := null;
	
	if _sohLocn = null then
		return;
	endif;
	
	create extraInfoArray transient;
//	logRow := _table.accessRow(_table.row).itemObject.CM_SOHLocation;
	_sohLocn.getExtraInfoLogVoyOps(extraInfoArray);
	foreach str in extraInfoArray do
		display := display &amp; str &amp; CrLf;
	endforeach;
	txtAllocRowDtls.text := display;

epilog
	delete extraInfoArray;
end;</source>
        <Parameter name="_sohLocn" type="CM_SOHLocation"/>
    </JadeMethod>
    <JadeMethod name="showVoyageDetails" id="8f25dd17-2b3c-4e46-af2c-88481a610e35">
        <updating/>
        <source>showVoyageDetails() updating;
//--------------------------------------------------------------
//Created: 11 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	user		: CM_User;
	globalVoy 	: CM_VoyageGlobal;
	voyage		: CM_Voyage;
	allVoyages	: CM_VoyageByArrivalDTTerminal;
	voyCode		: String;
	imoCode		: String;
	assist		: LOG_Assistant;
	terminal	: CM_Terminal;
	row,
	backColour,
	statusCol	: Integer;
begin

	if self.fldInfo.topSheet &lt;&gt; self.shtVoyage and
	   self.fldInfo.topSheet &lt;&gt; self.shtVoyageAdmin then
		return;
	endif;

	self.tblVoyage.clearValues();
	self.tblVoyageAdmin.clearValues();
	
	self.tblVoyTermDtl.rows := tblVoyTermDtl.fixedRows;	
	statusCol := tblVoyTermDtl.getColumnByRowName(ETRow_Status);	
	user := app.getMyUser();

	if self.mode &lt;&gt; Mode_Update or self.mode &lt;&gt; Mode_Add then
		if self.myCurrentVoyageGlobal &lt;&gt; null then
			globalVoy := self.myCurrentVoyageGlobal;
			voyCode := globalVoy.code;
			imoCode := globalVoy.vesselCode;
			
			tblVoyageAdmin.setValueByName(ETRow_IMO, imoCode);
			tblVoyageAdmin.setValueByName(ETRow_VoyageCode, voyCode);
			tblVoyageAdmin.setValueByName(ETRow_VesselName, globalVoy.vesselName);
			tblVoyageAdmin.setValueByName(ETRow_NumHatches, globalVoy.numHatches);

			tblVoyage.setValueByName(ETRow_IMO, imoCode);
			tblVoyage.setValueByName(ETRow_VoyageCode, voyCode);
			tblVoyage.setValueByName(ETRow_VesselName, globalVoy.vesselName);			
			tblVoyage.setValueByName(ETRow_NumHatches, globalVoy.numHatches);		
			
			assist := self.myAssistant.LOG_Assistant;
			allVoyages := self.myCurrentVoyageGlobal.allVoyages;
			self.showVoyageTerminalData(allVoyages);
		endif;
		tblVoyTermDtl.userInputEnabled := false;		
	endif;			
	
	if self.modeView = Mode_ArchiveView then					
		if self.tblVoyTermDtl.rows &gt; self.tblVoyTermDtl.fixedRows then
			if user.canDo(self.myTerminal, PmVoyageArchive) then
				btnAdminEdit.enabled := true;		
			else
				btnAdminEdit.enabled := false;					
			endif;
		else
			btnAdminEdit.enabled := false;				
		endif;					
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showVoyageTerminalData" id="f519375a-3e91-4199-8f20-ff0e8466722e">
        <updating/>
        <source>showVoyageTerminalData(_allVoyages	: CM_VoyageByArrivalDTTerminal) updating;
//--------------------------------------------------------------
//Created: 12 July 2004 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	user		: CM_User;
	voyage		: CM_Voyage;
	assist		: LOG_Assistant;
	terminal	: CM_Terminal;
	hmsBerth	: HMS_Berth;
	enabled		: Boolean;
	berth,
	sideTo		: String;
	idx,
	row,
	column,
	backColour,
	rateCol,
	statusCol	: Integer;
	loadRate	: Decimal[13,3];
	arriveDT,
	loadStartDT,
	loadEndDT	: TimeStamp;
	sailDT		: TimeStamp;

begin
	self.allClonedControls.purge();
	self.tblVoyTermDtl.rows := self.tblVoyTermDtl.fixedRows;	
	statusCol := self.tblVoyTermDtl.getColumnByRowName(ETRow_Status);
	rateCol := self.tblVoyTermDtl.getColumnByRowName(ETRow_LoadRate);
	user := app.getMyUser();
	assist := self.myAssistant.LOG_Assistant;

	foreach voyage in _allVoyages do
		if voyage.isTransient then
			if (not self.includeVoyage(voyage.pxyGetRealObject, user)) then
				continue;
			endif;
		elseif (not self.includeVoyage(voyage, user)) then
			continue;
		endif;
		
		arriveDT := self.systemToLocalTime(voyage.arrivedDT);	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
		loadStartDT := self.systemToLocalTime(voyage.loadStartDT);	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
		loadEndDT := self.systemToLocalTime(voyage.loadEndDT);	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
		sailDT := self.systemToLocalTime(voyage.departedDT);	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
		loadRate := voyage.loadRate;
		terminal := voyage.myTerminal;
		
		hmsBerth := voyage.getMyBerth();
		if hmsBerth = null then
			berth := null;
		else
			berth := hmsBerth.code;
		endif;
		
		if voyage.starboardBerthed then
			sideTo := "Starboard";
		else
			sideTo := "Port";
		endif;
		
		if loadStartDT &lt;&gt; null 
		and (not loadStartDT.isValid) then
			loadStartDT := null;
		endif;

		if loadEndDT &lt;&gt; null 
		and (not loadEndDT.isValid) then
			loadEndDT := null;
		endif;		
		
		if sailDT &lt;&gt; null 
		and (not sailDT.isValid) then
			sailDT := null;
		endif;		

		//	Aug 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, add sail date and load rate
		// 33174 CCMS 1124 new columns
		row := self.tblVoyTermDtl.addItem(terminal.name &amp; Tab
									 &amp; berth &amp; Tab
									 &amp; sideTo &amp; Tab
									 &amp; arriveDT.date.shortFormatJMT() &amp; Tab
									 &amp; arriveDT.time.currentLocaleFormatJMT() &amp; Tab
									 &amp; loadStartDT.date.shortFormatJMT() &amp; Tab
									 &amp; loadStartDT.time.currentLocaleFormatJMT() &amp; Tab
									 &amp; loadEndDT.date.shortFormatJMT() &amp; Tab
									 &amp; loadEndDT.time.currentLocaleFormatJMT() &amp; Tab 
									 &amp; sailDT.date.shortFormatJMT() &amp; Tab
									 &amp; sailDT.time.currentLocaleFormatJMT() &amp; Tab
									 &amp; loadRate.asStringJMT());

		if self.mode = self.Mode_Update then
			enabled := true;
			if self.viewMode = Mode_ArchiveView then
				enabled := false;
			else
			// 28082 Sep 2011 disable all but status if voyage is closed
				enabled := not voyage.isClosedStatus();
			endif;
			idx := idx + 1;
			tblVoyTermDtl.accessCell(row, statusCol).inputType := Table.InputType_ComboBox;
			tblVoyTermDtl.accessCell(row, rateCol).inputType := Table.InputType_TextNumeric;
			tblVoyTermDtl.accessCell(row, rateCol).decimals := 3;
			// CCMS 1120 only allow edit of status if voyage is closed or archived
			foreach column in self.tblVoyTermDtl.fixedColumns + 1 to self.tblVoyTermDtl.columns do
				if column &lt;&gt; statusCol then
					tblVoyTermDtl.accessCell(row, column).enabled := enabled;
				endif;
			endforeach;
		endif;
		self.setupSideto(row, voyage.starboardBerthed);
		self.setupBerth(terminal, row, berth);		

		if (self.tblVoyTermDtl.rows mod 2) = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;				
		tblVoyTermDtl.accessRow(row).backColor := backColour;				
		
		assist.comboBoxVoyageStatus(self.tblVoyTermDtl, statusCol, row, voyage.status);

		tblVoyTermDtl.accessRow(row).itemObject := voyage;
		tblVoyTermDtl.accessCell(row, 1).itemObject := 	terminal;
		
	endforeach;
		
	tblVoyTermDtl.clearSort();
	self.listVoyTerminalsPopulate();
end;</source>
        <Parameter name="_allVoyages" type="CM_VoyageByArrivalDTTerminal"/>
    </JadeMethod>
