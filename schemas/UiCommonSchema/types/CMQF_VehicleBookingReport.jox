<Class name="CMQF_VehicleBookingReport">
    <JadeMethod name="setFromAgent" id="9f6153d4-7c0f-4efe-9ddf-81654410e98c">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 April 2013	cnwndl1	Initial creation
09 Sep 2014		NDL	Par 33534
25/05/2022 		navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
8/11/2022		navgm20	Bug 51311: MTN - Vehicle Booking Report returning no Data on web
05 May 2023		navlw1	Initial creation TFS: 53902
24 May 2023 	navhl20 ChangeRequest 53902:[57781] EUP - VBS MTN - [6] - Selector Query and JRW
28 Aug 2023 	navhl20 Bug 60056: FR | 53429 - VBS Selector issues
*/

vars

	string : String;
	dateStr : String;
	tplType : Integer;
	tplFactor : Integer;

begin

	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_FromDate) then
	//	self.dateFrom := _agent.getValueByName(ETRow_FromDate).Date;
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
		   dateStr := _agent.getValueForTemplateDates(ETRow_FromDate);
			self.setTemplateDateFields( dateStr, tplType, tplFactor, ETRow_FromDate);
			self.setDateFromType(tplType);
			self.setDateFromFactor(tplFactor);
		else
			//self.dateFrom := _agent.getValueByNameIfVisible(ETRow_FromDate).Date;	//8/11/2022	navgm20	TFS 51311
			self.dateFrom := _agent.getValueByNameIfVisible(ETRow_FromDate).TimeStamp.Date;	//8/11/2022	navgm20	TFS 51311
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_ToDate) then
	//	self.dateTo := _agent.getValueByName(ETRow_ToDate).Date;
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
		   dateStr := _agent.getValueForTemplateDates(ETRow_ToDate);
			self.setTemplateDateFields( dateStr, tplType, tplFactor, ETRow_ToDate);
			self.setDateToType(tplType);
			self.setDateToFactor(tplFactor);
		else
			//self.dateTo := _agent.getValueByNameIfVisible(ETRow_ToDate).Date;	//23 Oct 2014	NDL	Par 35008	//8/11/2022	navgm20	TFS 51311
			self.dateTo := _agent.getValueByNameIfVisible(ETRow_ToDate).TimeStamp.Date;	//8/11/2022	navgm20	TFS 51311
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_CarrierFilter) then	// 07 June 2013	NDL	Par 31729
		if _agent.isKindOf(CMUI_ReportAgentStd) then
			self.setMyCarrier( _agent.CMUI_ReportAgentStd.myCmbCarrier.listObject.CM_Carrier );
		else
			string := _agent.getValueByName(ETRow_CarrierFilter).String.trimBlanks;
			if string &lt;&gt; null then
				self.setMyCarrier( string.asOid.CM_Carrier );
			endif;
		endif;
	endif;
	
	//Start 25/05/2022 navhl20 TFS 53430  
	if _agent.isRowIncluded(ETRow_SubCarrierFilter) then
		if _agent.isKindOf(CMUI_ReportAgentStd) then
			self.setMySubCarrier( _agent.CMUI_ReportAgentStd.myCmbSubCarrier.listObject.CM_Carrier );
		else
			string := _agent.getValueByName(ETRow_SubCarrierFilter).String.trimBlanks;
			if string &lt;&gt; null then
				self.setMySubCarrier( string.asOid.CM_Carrier );
			endif;
		endif;
	endif;
	//End 25/05/2022 navhl20 TFS 53430  
	
	if _agent.isRowIncluded(ETRow_IncludeUnBooked) then
		self.inclUnBooked := _agent.getValueByName(ETRow_IncludeUnBooked).Boolean;
	endif;
	
	// 5/5/2023 navlw1 tfs 53902
	self.id 						:= _agent.getValueByName(ETRow_Id).String.toUpper()[1:30];
	self.externalReference 			:= _agent.getValueByName(ETRow_ExternalRef).String.trimBlanks();
	self.remarks 					:= _agent.getValueByName(ETRow_Remarks).String.trimBlanks();
	self.bookingId 					:= _agent.getValueByName(ETRow_BookingId).String;
	self.vehicleVisitRecordNumber 	:= _agent.getValueByName(ETRow_VehicleVisitNumber).String;
	self.cargoId 					:= _agent.getValueByName(ETRow_CargoId).String;
	self.preGateInCheck 			:= _agent.getValueByName(ETRow_PreGateInCheck).Boolean;
	self.preGateOutCheck 			:= _agent.getValueByName(ETRow_PreGateOutCheck).Boolean;
	self.kioskCheck					:= _agent.getValueByName(ETRow_KioskCheck).Boolean;
	//self.status 					:= app.vbsStatusStringToNum(_agent.getValueByName(ETRow_Status).String);			//24.5.2023 navhl20 #53902[57781]		//28.8.2023 navhl20 #60056
	self.sourceType					:= _agent.getValueByName(ETRow_SourceType).Integer;
	self.bulkReleaseId				:= _agent.getValueByName(ETRow_BulkReleaseId).String;

	self.allUsers.clear;							   						 
	if  _agent.isRowIncluded(ETRow_AllUsers) then
		_agent.getSelectedUsers(self.allUsers);
	endif;
	
	self.allVBSStatus.clear;																//28.8.2023 navhl20 #60056				   						 
	if  _agent.isRowIncluded(ETRow_VBSStatus) then
		_agent.getSelectedVBSStatus(self.allVBSStatus);
	endif;
	
	self.allVBSTimeSlotTypes.clear;																//28.8.2023 navhl20 #60056				   						 
	if  _agent.isRowIncluded(ETRow_TsType) then
		_agent.getSelectedVBSTsType(self.allVBSTimeSlotTypes);
	endif;

	/*if _agent.isRowIncluded(ETRow_VehicleBookingSlots) then
		if _agent.isKindOf(CMUI_ReportAgentStd) then
			self.setMySubCarrier( _agent.CMUI_ReportAgentStd.myCmb.listObject.CM_Carrier );
		else
			string := _agent.getValueByName(ETRow_SubCarrierFilter).String.trimBlanks;
			if string &lt;&gt; null then
				self.setMySubCarrier( string.asOid.CM_Carrier );
			endif;
		endif;
	endif;
	*/
epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
