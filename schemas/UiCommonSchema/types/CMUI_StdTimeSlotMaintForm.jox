    <JadeMethod name="doDelTimeSlot" id="303a1ed1-293b-4aef-be93-de801f8a184f">
        <updating/>
        <source>doDelTimeSlot(_row : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, 
	currentRow,
	theReturn : Integer;
	toDelete : CM_TimeSlotEntity;
begin
	currentRow := _row;
	while true do
		foreach idx in 2 to self.tblTimeSlot.columns do
			toDelete := self.tblTimeSlot.accessCell(currentRow, idx).itemObject.CM_TimeSlotEntity;
			
			app.myTrxDA.trxDeleteTimeSlot(toDelete, app.myPassport);
			if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				continue;
			else
				theReturn := app.showErrorWarningDialog('Worker Shift Deletion', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
		endforeach;
		break;
	endwhile;
	return currentRow - 1;
epilog
end;</source>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
