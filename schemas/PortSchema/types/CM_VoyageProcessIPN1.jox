    <JadeMethod name="getInvoiceReportForInvoice" id="044e2190-fa06-4dc6-b586-ff5ee1574d44">
        <source>getInvoiceReportForInvoice(_invoice: CM_Invoice): String;
/*
Purpose:	TFS 41539		
Date				Who			Reason
OCTOBER 2018		CNWAB1		Initial creation
*/

vars

begin
	if _invoice = null then
		return "";
	endif;
	
	if _invoice.status = CM_Invoice.INVOICE_PREPEND then
		return self.reportInvoicePreinvoice;
	endif;

	
	if _invoice.status.isOneOf(CM_Invoice.INVOICE_PENDING, CM_Invoice.INVOICE_POSTED) then
		return self.reportInvoiceTaxinvoice;
	endif;

	return "";
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceReportForStatus" id="2bd8c2c2-66c3-427e-89f6-d4a0c5b753c2">
        <source>getInvoiceReportForStatus(_voyage: CM_Voyage): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlger1	Initial creation 38530
11/09/2018	jlgdap1	TFS 40030 PEL1 Multiple Estimates and Invoices
*/

vars
	currentStatus : Integer;
begin
	if _voyage &lt;&gt; null then															// TFS 38214
		currentStatus := _voyage.status;											// TFS 38214
	endif;																			// TFS 38214
	
	if currentStatus = null then
		return null;
	
	endif;
	
	//if currentStatus = Voyage_Status_IInitSerRquested then													// TFS 40030
	if currentStatus = Voyage_Status_IInitSerRquested or currentStatus = Voyage_Status_ICargoRequested then		// TFS 40030
		return self.reportInvoiceEstimate;
		
	elseif currentStatus = Voyage_Status_ICargoPreInvGen or currentStatus = Voyage_Status_IServPreInvGen  then
		return self.reportInvoicePreinvoice;
		
	elseif currentStatus = Voyage_Status_ICargoTaxInvGen or currentStatus =Voyage_Status_IServTaxInvGen then
		return self.reportInvoiceTaxinvoice;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextValidStatuses" id="253a71bc-c96c-4b3b-a4f0-4c7b491d07cc">
        <source>getNextValidStatuses(_voyage: CM_Voyage; _nextStatuses: CM_VoyageStatusByPriority input; _includeAll : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/03/2018	jlgdap1		Initial creation TFS 37544 PEL1 Voyage Statuses InaPortNet1
// 11/04/2018	jlgdap1		TFS 37966 new Vessel Archived status
// 23/04/2018	jlgdap1		TFS 38214 PEL1 Voyage Status Changes
// 06/06/2018	jlgdap1		TFS 38851 PEL1 Voyage Statuses For INAPORTNET - rewritten
///10/11/18		jlger1		TFS 41879	 want to set to this first before 
vars
	status, nextStatus : CM_VoyageStatus;
	currentStatus : Integer;						// TFS 38214

begin

	if _includeAll then	//21 Jun 2018	NDL	TFS 39216
		self.allStatuses.copy(_nextStatuses);
		return;
	endif;
	
	if _voyage &lt;&gt; null then															// TFS 38214
		currentStatus := _voyage.status;											// TFS 38214
	endif;																			// TFS 38214
	
	if currentStatus = null then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyRequested]);
	else
		if app.myRoot.allVoyageStatuses[currentStatus] &lt;&gt; null then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[currentStatus]);
		endif;
	endif;
	
	if currentStatus = Voyage_Status_IVoyCreated then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyRequested]);
		
	elseif currentStatus = Voyage_Status_IVoyRequested then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IETMALCalculated]);	
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IServicesPending]);			// TFS 38214

		_nextStatuses.add(self.allStatusesById[Voyage_Status_ICargoReqPending]);		// TFS 38214
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_IETMALCalculated then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyReqRejected]);
		// TFS 38214 If the voyage has no Holds then there is no cargo				// TFS 38214
		// - next status is ServicesPending	not CargoReqPending						// TFS 38214
		if _voyage &lt;&gt; null and _voyage.myGeneralCargoVoyage = null then				// TFS 38214
			_nextStatuses.add(self.allStatusesById[Voyage_Status_IServicesPending]);// TFS 38214
		else																		// TFS 38214
			_nextStatuses.add(self.allStatusesById[Voyage_Status_ICargoReqPending]);
		endif;																		// TFS 38214
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_IVoyReqRejected then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ICargoReqPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_ICargoReqPending then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ICargoRequested]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_ICargoRequested then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ICargoReqReject]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IServicesPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_ICargoReqReject then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IServicesPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_IServicesPending then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IInitSerRquested]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_IInitSerRquested then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IInitSerApproved]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IInitSerRejected]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_IInitSerApproved then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IInitSerIPNPend]);
		
	elseif currentStatus = Voyage_Status_IInitSerRejected then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IApprovalPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IApprovalReject]);
		
	elseif currentStatus = Voyage_Status_IInitSerIPNPend then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IInitSerIPNAppr]);
		
	elseif currentStatus = Voyage_Status_IInitSerIPNAppr then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IInitSerConfirm]);
		
	elseif currentStatus = Voyage_Status_IInitSerConfirm then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IAppPendIPN]);
		
	elseif currentStatus = Voyage_Status_IAppPendIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyageApproved]);
		
	elseif currentStatus = Voyage_Status_IApprovalPending then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IInitSerApproved]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IInitSerRejected]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyageApproved]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_IApprovalReject then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IApprovalPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_IVoyageApproved then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyageArrived]);
		
	elseif currentStatus = Voyage_Status_IVoyageArrived then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyageArrIPN]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ICargoPreInvGen]);
		
	elseif currentStatus = Voyage_Status_IVoyageArrIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ICargoPreInvGen]);
		
	elseif currentStatus = Voyage_Status_ICargoPreInvGen then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ICargoTaxInvGen]);
		
	elseif currentStatus = Voyage_Status_ICargoTaxInvGen then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepServPending ]);
		
	elseif currentStatus = Voyage_Status_IExtReqIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IExtMSReq]);
		
	elseif currentStatus = Voyage_Status_IExtMSReq then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IExtApproved]);
		
	elseif currentStatus = Voyage_Status_IExtApproved then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IExtPendIPN]);
		
	elseif currentStatus = Voyage_Status_IExtPendIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IExtAppIPN]);
		
	elseif currentStatus = Voyage_Status_IExtAppIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyageArrIPN]);
		
	elseif currentStatus = Voyage_Status_IShiftReqIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IShiftReqApp]);
		
	elseif currentStatus = Voyage_Status_IShiftReqApp then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IShiftRPendIPN]);
		
	elseif currentStatus = Voyage_Status_IShiftRPendIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IShiftRAppIPN]);
		
	elseif currentStatus = Voyage_Status_IShiftRAppIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IShiftApp]);
		
	elseif currentStatus = Voyage_Status_IShiftApp then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IShiftPendIPN]);
		
	elseif currentStatus = Voyage_Status_IShiftPendIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IShiftAppIPN]);
		
	elseif currentStatus = Voyage_Status_IShiftAppIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IShiftConfirm]);
		
	elseif currentStatus = Voyage_Status_IShiftConfirm then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IShiftSentIPN]);
		
	elseif currentStatus = Voyage_Status_IShiftSentIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyageArrIPN]);
		
	elseif currentStatus = Voyage_Status_ICancelReqIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ICancelApproved]);
		
	elseif currentStatus = Voyage_Status_ICancelApproved then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVoyageArrIPN]);
		
	elseif currentStatus = Voyage_Status_IDepServPending then
		//epr TFS 37190 email from Cristian/Fernando departure does not need to send entryRKBM and receive PPK so 
		//can jump straight to this status 
	//	_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepReqApp]);
	//epr TFS 41879 10/11/18 
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepServRequest]);
		
	elseif currentStatus = Voyage_Status_IDepServRequest then
	//	_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepReqApp]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepServApproved]);
		
	elseif currentStatus = Voyage_Status_IDepServApproved then
	//	_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepRPendIPN]);
	//	_nextStatuses.add(self.allStatusesById[Voyage_Status_IVesselDeparted]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepReqApp]);
	elseif currentStatus = Voyage_Status_IDepRPendIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepRAppIPN]);
		
	elseif currentStatus = Voyage_Status_IDepRAppIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepReqApp]);
		
	elseif currentStatus = Voyage_Status_IDepReqApp then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepReqIPN]);
		
	elseif currentStatus = Voyage_Status_IDepReqIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IDepAppIPN]);
		
	elseif currentStatus = Voyage_Status_IDepAppIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVesselDeparted]);
		
	elseif currentStatus = Voyage_Status_IServPreInvGen then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IServTaxInvGen]);
		
	elseif currentStatus = Voyage_Status_IServTaxInvGen then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVesselDeparted]);
		
	elseif currentStatus = Voyage_Status_IVesselDeparted then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVessDepIPN]);
		
	elseif currentStatus = Voyage_Status_IVessDepIPN then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVesselArchived]);
		
	elseif currentStatus = Voyage_Status_IVoyCancelled then	//02 Aug 2018	NDL	TFS 39924
		_nextStatuses.add(self.allStatusesById[Voyage_Status_IVesselArchived]);
		
	endif;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_nextStatuses" type="CM_VoyageStatusByPriority" usage="input"/>
        <Parameter name="_includeAll" type="Boolean"/>
    </JadeMethod>
