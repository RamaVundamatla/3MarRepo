    <JadeMethod name="setBasicDetails" id="e9726fa9-f7b0-4bd6-ba11-1b0e6a9e5039">
        <updating/>
        <source>setBasicDetails(_name, 
			_heading : String; 
			_inputType : Integer; 
			_inputEnabled, 
			_visible : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     19 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.name			:= _name[1:35].trimBlanks;
	self.heading		:= _heading[1:60];	// testing 12 Sep 2012
	self.inputType		:= _inputType;
	self.inputEnabled	:= _inputEnabled;
	self.visible 		:= _visible;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_inputType" type="Integer"/>
        <Parameter name="_inputEnabled" type="Boolean"/>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDisplayNullIfZero" id="ee398e75-730e-4945-a693-49339b0b5e58">
        <updating/>
        <source>setDisplayNullIfZero( _displayNullIfZero : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2016	cnwndl1	Initial creation	TFS 2959 / 2420

*/

vars

begin

	self.displayNullIfZero := _displayNullIfZero;

epilog

end;</source>
        <Parameter name="_displayNullIfZero" type="Boolean"/>
