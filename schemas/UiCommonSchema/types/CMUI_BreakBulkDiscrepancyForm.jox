    <JadeMethod name="translateForm" id="29b1231c-300f-4718-8e65-a6b88c8f1862">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 17 May 2023 14:28:52.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019077, locale);
	lblAmount.translateCaption(Xlat_0019078, locale);
	lblExistingCargo.translateCaption(Xlat_0019079, locale);
	lblOverlanded.translateCaption(Xlat_0026012, locale);
	lblReason.translateCaption(Xlat_0019080, locale);
	lblShortlanded.translateCaption(Xlat_0025961, locale);
	lblWeight.translateCaption(Xlat_0019081, locale);
	lblWeightCargo.translateCaption(Xlat_0022192, locale);
	lblWeightTare.translateCaption(Xlat_0022193, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtAmount_keyUp" id="21dbc8da-7746-47da-a1e4-a9a3c1eb5687">
        <controlMethod name="TextBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtAmount_keyUp(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2013	cnwrd1	Initial creation

*/

vars

	strValue : String;
	value : Integer;
	msg : String;

begin

	//10 Jul 2017	NDL	TFS 5322
	strValue := textbox.text;
//	if strValue.isInteger then
	if strValue.isInteger or strValue.trimBlanks = null then //22 Nov 2017	NDL	TFS 7849
		value := strValue.Integer;
	else
		msg := app.getErrorString(Numeric_value_large);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.btnOk.enabled := false;
		return;	
	endif;
	self.btnOk.enabled := true;
	
	self.lQuantityChange.caption := ( value - self.myTrackedItem.totalQuantity ).asStringJMT;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="0d738fd4-0f66-45e2-ba94-9aa45defb09c">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	option			: Integer; 
	timeRemaining	: Integer;

begin

	if self.getTimerStatus(WeightChange, option, timeRemaining) then
		self.endTimer(WeightChange);
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
</GUIClass>
