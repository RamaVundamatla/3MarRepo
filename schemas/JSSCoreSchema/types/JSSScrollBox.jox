    <JadeMethod name="jssDate" id="4bdbb41c-f10c-4a90-b6fc-37039a7017ab">
        <source>jssDate(): Date;
// -----------------------------------------------------------------------------
// Created:		03 January 2002 by cnwdad1
//
// Purpose:		Returns the receiver's numeric Julian day number as a date.
//
// Parameters:	None
//
// Returns:		The current date setting.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	dateValue	: Date;
	
begin
	dateValue	:=	self.getValue().Date;
	
	if dateValue.isValid then
		return dateValue;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
