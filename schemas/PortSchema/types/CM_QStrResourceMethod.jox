<Class name="CM_QStrResourceMethod" id="42e1b44a-929b-40e2-8035-17c273648b1c">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="e5cbe900-e661-4fd9-b034-9e41b71b267d">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 September 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="99248f37-f721-4d2b-887c-0582618dc537">
        <source>setComboValues(comboBox 				: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 September 2018
TFS#		: 40200
Function	: Populate comboBox List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	resource				: HMS_Resource;
	harbour					: HMS_Harbour;
	storeIdx				: Integer;
	idx						: Integer;
	selectStr				: String;
	str						: String;
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	terminal				: CM_Terminal;
	object					: Object;
	objectSet				: ObjectSet;
	multiTerminal			: Boolean;
	selectedResource		: HMS_Resource;
begin
	comboBox.clear();
	comboBox.sorted := true;
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	create objectSet transient;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" or selectorCriteriaLine.propName = "getTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		app.myRoot.allTerminals.copy(objectSet);
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		if terminal.myHarbour = null then
			if multiTerminal then
				continue;
			else			
				str := "Terminal " &amp; terminal.code &amp; " does not have any Harbour. Please go to Harbour Admin to set Terminal Harbour";
				idx := comboBox.addItem(str);
				return;			
			endif;
		endif;
		
		harbour := terminal.myHarbour;
		
		foreach resource in harbour.allResources do		
			if multiTerminal then
				str := resource.code &amp; Tab &amp; ' (' &amp; resource.description &amp; ')' &amp; "- " &amp; terminal.code;			
			else
				str := resource.code &amp; Tab &amp; ' (' &amp; resource.description &amp; ')';
			endif;
			idx := comboBox.addItem(str);
			comboBox.itemObject[idx] := resource;
			
			if resource.code = selectStr then
				selectedResource := resource;
			endif;
		endforeach;
	endforeach;
	
	storeIdx  := comboBox.findObject(selectedResource);
	if storeIdx &gt; 0 and storeIdx &lt; comboBox.listCount then
		comboBox.listIndex := storeIdx;
	endif;
epilog
	delete objectSet;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="63580036-ef79-4b5d-9f20-eec35418a676">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 September 2018
TFS#		: 40200
Function	: Populate Selection List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	resource				: HMS_Resource;
	harbour					: HMS_Harbour;
	terminal				: CM_Terminal;
	object					: Object;
	objectSet				: ObjectSet;
	selectionValue			: Integer;
	idx						: Integer;
	array					: ObjectArray;
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	multiTerminal			: Boolean;
begin
	
	table.rows := table.fixedRows;
	
	array := table.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	create objectSet transient;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		app.myRoot.allTerminals.copy(objectSet);
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		if terminal.myHarbour = null then
			if multiTerminal then
				continue;
			else
				return;
			endif;
		endif;
		harbour := terminal.myHarbour;
		
		foreach resource in harbour.allResources do	
		
			selectionValue := 0;
			if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(resource.code) then
				selectionValue := 1;
				array.add(resource);
			endif;
			if multiTerminal then	
				idx := table.addItem(selectionValue.String &amp; Tab  &amp; resource.code &amp; ' (' &amp; resource.description&amp; ')' &amp; Tab &amp; "- " &amp; terminal.code);
			else
				idx := table.addItem(selectionValue.String &amp; Tab  &amp; resource.code &amp; ' (' &amp; resource.description&amp; ')');
			endif;
			
			table.accessRow(idx).itemObject := resource;
		endforeach;
	endforeach;
epilog
	delete objectSet;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="db6b902a-7ce5-43d3-8ac0-593054497c65">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 September 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	resource	: HMS_Resource;
	str			: String;
	numRows		: Integer;
	idx			: Integer;
	strArray	: StringArray;

begin

	create strArray transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			resource := table.accessRow(idx).itemObject.HMS_Resource;
			strArray.add(resource.code);
		endif;
	endforeach;
	
	queryOperator.setSearchValue(strArray);

epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="c937f86c-e19c-4e51-9032-8b8612bd6ab0">
        <source>translateToDisplayValue(_value: Any): String;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 September 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	
	if _value.isKindOf(HMS_Resource) then
		if _value &lt;&gt; null then
			return _value.HMS_Resource.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	return null;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="949e8f18-6cea-4857-b39e-f04e30e7734e">
        <source>translateToSearchValue(_value: Any): Any;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 September 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 		: Boolean;
	object			: HMS_Resource;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then		
			return _value;
		endif;

		if _value.isKindOf(HMS_Resource) then
			object := _value.HMS_Resource;
		endif;
		
		if _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
