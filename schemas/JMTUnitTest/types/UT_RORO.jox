	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D20081R,,0.0000,,"&amp;ContainerId25&amp;",Remain On Board,4200,0.0000,,,,,,,"&amp;TestOperator&amp;",,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,"&amp;VoyageName2&amp;",,,0.0000,,,,false,,");
