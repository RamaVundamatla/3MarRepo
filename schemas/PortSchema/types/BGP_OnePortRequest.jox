	return 10;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processOnePortRequest" id="176fb03e-248b-4f88-85ce-4e44082a11dc">
        <updating/>
        <source>processOnePortRequest(_agent : CM_APIConsumerAgent input; _webServiceDef : CM_APIEndpointServiceDef io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jul 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev
09 Sep 2024	navdap1	TFS 66034 NSW OnePort Integration Post-Dev Demo Issues - removed EWS activity creation (duplicated)
24 Oct 2024	navdap1	MTN-14005 NSW | OnePort Integration - Requested Changes - added _longMsg parameter
27 Nov 2024	navdap1	MTN-33469 NSW | OnePort - Issues With Request
05 Dec 2024	navmd1	MTN-33527 Save pre-transformed message to EDI file
21 Feb 2025	navdap1	MTN-34142 NSW | OnePort - New Voyages Not Created When OnePort Response Loads to DB Automatically
					MTN-34063 POB | QSHIPS - Voyage Loaded to DB in EDI Operations but No Record of Voyage in Voyage Enquiry
14 Mar 2025 navhn30 MTN-34332 NSW | OnePort - Date/Time in Request Means Not All Movements Are Returned
09 Dec 2025 navah1	MTN-36364: NSW | OnePort API Last Run Date - Use the terminal-specific Last Successful Date/Time for external web service task runs
*/
vars
	alertMsg,
 	resultString 		: String;
	edifile				: CM_EDIFile;
	lastSuccessfulTS 	: TimeStamp;
	terminal			: CM_Terminal;
	tmpStatus 			: Integer;
	interfaceName		: String;
	invalid				: Boolean;
	lastSuccessfulTStr	: String;
	apiMapper			: CMIF_ApiMapper;		// MTN-14005
	errors				: String;				// MTN-14005
	transformedStr		: String;				// MTN-14005
	requestingPort		: String;		// MTN33469
	lastSuccessfulUTC	: TimeStamp;	// MTN34332
begin	
	
	interfaceName := _webServiceDef.name;
	
	terminal 	:= self.myTerminal;
	
	if terminal.myHarbour = null then		
		alertMsg := app.getErrorString(Termina_default_harbour_null);
		self.createAlert(alertMsg, null, SEVERE_INFO);					// MTN-14005			
		return;
	endif;
	
	if terminal.myHarbour.defaultDepartBerth = null then
		alertMsg := app.getErrorString(Termi_harbo_defau_depar_berth);
		self.createAlert(alertMsg, null, SEVERE_INFO);					// MTN-14005
		return;
	endif;
	
	on Exception do app.handleException11052( exception, invalid );
	
	//lastSuccessfulTS := _webServiceDef.lastSuccessfullTS; 		  //09.12.2025 navah1 #MTN-36364
	lastSuccessfulTS := _webServiceDef.getLastSuccessfulTS(terminal); //09.12.2025 navah1 #MTN-36364
	
	if lastSuccessfulTS = null then
		lastSuccessfulTS := app.actualTimeServer.addDays(-2);
	endif;
	lastSuccessfulUTC := lastSuccessfulTS.systemToUTC();	//14.03.25	navhn30   MTN-34389
	lastSuccessfulTStr := lastSuccessfulUTC.date.format("yyyy-MM-dd") &amp; "T" &amp; lastSuccessfulUTC.time.format("HH-mm") &amp; "-0";
	
	//Send message to OnePort
	requestingPort := terminal.getConfig(PortDestCode).String;		// MTN-33469
	if requestingPort = "AUSYD" then								// MTN-33469
		requestingPort := "AUBTB";									// MTN-33469
	endif;															// MTN-33469
	//resultString := _agent.sendOnePortVesselMovementReq(_webServiceDef, ETRow_NswVesselMovements, lastSuccessfulTStr, terminal.getConfig(PortDestCode).String, terminal);		// MTN-33469
	resultString := _agent.sendOnePortVesselMovementReq(_webServiceDef, ETRow_NswVesselMovements, lastSuccessfulTStr, requestingPort, terminal);								// MTN-33469
	
	// MTN-14005 Transform the message if necessary
	if _webServiceDef.baseAuthEndpoint &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Transforming incoming message - this is 'old' OnePort", LogINFO);
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Pre-transformed request" &amp; CrLf &amp; resultString, LogDEBUG);
		
		create apiMapper transient;
		transformedStr := apiMapper.transformIncomingMessage(CMIF_ApiMapper.CUSTOMER_NSW, "VesselMovements", resultString, JadeHTTPConnection.Verb_GET, errors);
		
		if errors &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "errors from transform " &amp; errors, LogERROR);
			self.createAlert("Failed to transform incoming OnePort message", errors, SEVERE_INFO);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "transformed message is " &amp; transformedStr, LogDEBUG);
		endif;
	endif;
	// MTN-14005 end
	
	edifile := self.processOnePortResponse(resultString, transformedStr, _webServiceDef, lastSuccessfulTS, terminal);	
	
	if edifile &lt;&gt; null and edifile.ediData &lt;&gt; null then					
		edifile.ediData.verifyAll();
		app.myPassport.setWarningsAcknowledged(true);	// MTN-34142 / MTN-34063
		app.myPassport.setWarningsIgnored(true);		// MTN-34142 / MTN-34063
		edifile.ediData.loadDB(true, app.myPassport);			
		
		tmpStatus := edifile.ediData.getStatusAfterVerifyOrDBLoad(false, app.myPassport);	
		if tmpStatus &lt;&gt; 0 then
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(edifile.ediData, tmpStatus);	
		endif;
	endif;	
epilog

end;</source>
        <Parameter name="_agent" type="CM_APIConsumerAgent" usage="input"/>
        <Parameter name="_webServiceDef" type="CM_APIEndpointServiceDef" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processOnePortResponse" id="fcea6b2a-f84c-4d98-99f3-84bb98996606">
        <updating/>
        <source>processOnePortResponse(_response, _transformedResponse : String; _webService : CM_APIEndpointServiceDef io; _lastSuccessfullTS : TimeStamp; _terminal : CM_Terminal) : CM_EDIFile updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jul 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev
05 Dec 2024	navmd1	MTN-33527 Include pre-transformed message on EDI file

*/

vars
	jsonHelper		 	: JadeJson;
	ediDataVoyage		: CM_EDIData;
	ediFile				: CM_EDIFile;	
	filePath			: String;
	tempFilePath		: String;	
	ediFileType			: CM_EDIFileType;
	timeStamp			: String;
	passport			: CM_Passport;
	jsonStr				: String;
begin
	
	if _response &lt;&gt; null then
		create jsonHelper transient;
		jsonStr := jsonHelper.generateJson(_response, JadeJson.Format_Json_Microsoft);			
		
		if jsonStr &lt;&gt; null then
			
			// Get a unique file path for this run.
			tempFilePath := app.getTempDirectoryFromSysConfig(); 
			
			app.checkTempDirFolderPath(tempFilePath, method.qualifiedName, CMIF_ConfigRoot.class.name &amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name );
			
			timeStamp := app.actualTimeAppServer.time.format("HHmmss");
			
			filePath := tempFilePath &amp; "GetVesselMovementsNSWPorts"&amp;timeStamp&amp;".json" ;	//renamed from "GetVoyageExportDataByDomainAndDates"	//MTN-33159
			
			ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_JSONOnePortVoyage, null).CM_EDIFileTypeJSONOnePortVoy;
			
			passport := app.myPassport;
			
			app.myTrxCA.trxCreateEDIPortAuthVoyage(_webService, _lastSuccessfullTS, _terminal, ediFile, ediFileType, ediDataVoyage, filePath, _response, _transformedResponse, passport);								
			
			return ediFile;
		endif;		
	endif;			
	
	return null;
epilog
	delete jsonHelper;
end;</source>
        <Parameter name="_response" type="String"/>
        <Parameter name="_transformedResponse" type="String"/>
        <Parameter name="_webService" type="CM_APIEndpointServiceDef" usage="io"/>
        <Parameter name="_lastSuccessfullTS" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
