<CollClass name="CMIF_WagonPositionDataDict" id="32798a78-5d83-44d7-b82e-d1c01e4b273b">
    <loadFactor>66</loadFactor>
    <memberType name="CMIF_WagonPositionData"/>
    <superclass name="CMIF_Dicts"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CMIF_WagonPositionData::position"/>
    </MemberKey>
    <JadeMethod name="addTI" id="a352bb61-c5c3-4d87-8ec9-0f873fef49a8">
        <lockReceiver/>
        <updating/>
        <source>addTI( _ti : CM_TrackedItem; _position : Integer; _length : Integer ): CMIF_WagonPositionData updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2009	cnwndl1	Initial creation

*/

vars

	posiData : CMIF_WagonPositionData;
	
begin

	posiData := self.getAtKey(_position);
	
	if posiData = null then
		create posiData transient;
		posiData.setBaseData( 	_position,	//_position : Integer;
								_length	//_length : Integer
								);
		self.add(posiData);
	endif;
	
	if not posiData.allTrackedItems.includes( _ti ) then
		posiData.allTrackedItems.add( _ti );
	endif;
	
	return posiData;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="CMIF_WagonPositionData"/>
    </JadeMethod>
    <JadeMethod name="delete" id="1158cf85-78e2-4c7a-a276-1d92f9c00fa4">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected, lockReceiver, lockReceiver;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwndl1	Initial creation

*/

vars

begin
	if not self.isEmpty then
		self.purge;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</CollClass>
