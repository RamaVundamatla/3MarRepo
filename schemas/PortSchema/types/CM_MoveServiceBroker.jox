    <JadeMethod name="auditIdDisplay" id="e41e966b-6068-4a46-a8ad-90d9e5224e6c">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jan 2017	cnwma1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	auditIdStr : String;
begin
	auditIdStr := self.auditId() ;
	
	if auditIdStr &lt;&gt; null then
		return 'Transaction Type [Move] Map' &amp; ' - ' &amp; auditIdStr;
	else
		return 'Transaction Type [Move] Map';
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="copyFrom" id="af75e2bc-8cfc-4b32-8165-cbab1ef92f24">
        <updating/>
        <source>copyFrom(_map: CM_MoveServiceBroker; _parent : CM_CommodityMap) updating;
// 32311 set up self from the parameter, copy all of the parameter map children under self.
vars
	newQuantityMap	: CM_QuantityMap;
	debtorMap		: CM_DebtorMap;
	newDebtorMap	: CM_DebtorMap;
begin
	self.moveFrom := _map.moveFrom;
	self.moveTo := _map.moveTo;
	if _parent = null then
		self.commodityMap := _map.commodityMap;
	else
		self.commodityMap := _parent;
	endif;
	create newQuantityMap persistent;
	newQuantityMap.copyFrom(_map.myChildQuantityMap, self);
	
	foreach debtorMap in _map.allDebtorMapsByDebtor do
		create newDebtorMap persistent;
		newDebtorMap.copyFrom(debtorMap, debtorMap.myDebtorNode, debtorMap.myDebtorType, self);
	endforeach;
end;
</source>
        <Parameter name="_map" type="CM_MoveServiceBroker"/>
        <Parameter name="_parent" type="CM_CommodityMap"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="0cf08223-8c05-465d-a0c8-39805483c019">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	tmpStr := self.getTranMapBreadCrumb;
	txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.commodityMap &lt;&gt; null then
		tmpStr := self.commodityMap.getCommodityString;
		txt := txt &amp; app.getErrorString(Commodity) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.moveFrom &lt;&gt; null then
		tmpStr := self.moveFrom;
		txt := txt &amp; 'Move From' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.moveFrom &lt;&gt; null then
		tmpStr := self.moveTo;
		txt := txt &amp; 'Move To' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
			if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.commodityMap.getBank &lt;&gt; null then
		tmpStr := self.commodityMap.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="c8388367-32c0-4447-a70d-d6404080fa12">
        <source>getBank() : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		02 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.commodityMap &lt;&gt; null then
		return self.commodityMap.getBank();
	endif;
	return null;
end;</source>
        <ReturnType type="CM_Bank"/>
