    <JadeMethod name="timesOverlap" id="3b717ebd-f6b7-4fe9-bafa-9a9c321f613e">
        <source>timesOverlap(otherArrivalMove : HMS_Movement) : Boolean;
//
// Purpose:			Does my occursOnDTNEW overlap the arrival/departure time of the supplied movement's voyage?
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19 June 2014	cnwdap1		Initial creation PAR #34175 resubmit
//
vars
	workMove : HMS_Movement;
	myRangeStartDT : TimeStamp;
	myRangeEndDT : TimeStamp;
	hisRangeStartDT : TimeStamp;
	hisRangeEndDT : TimeStamp;

begin
	if otherArrivalMove = null then
		return false;
	endif;

	myRangeStartDT := self.occursOnDTNEW;
	workMove := self.getMovementNext();	
	if workMove &lt;&gt; null then
		myRangeEndDT := workMove.occursOnDTNEW;
		workMove := null;
	else	
		myRangeEndDT := null;
	endif;

	hisRangeStartDT := otherArrivalMove.occursOnDTNEW;
	workMove := otherArrivalMove.getMovementNext();	
	if workMove &lt;&gt; null then
		hisRangeEndDT := workMove.occursOnDTNEW;
	else
		hisRangeEndDT := null;
	endif;
	
	workMove := null;

	workMove := self.getMovementNext();	
	if workMove &lt;&gt; null then
		myRangeEndDT := workMove.occursOnDTNEW;
		workMove := null;
	else
		myRangeEndDT := null;
	endif;
	
	if myRangeEndDT = null and hisRangeEndDT = null then
		//can't check with out at least one range
		return false;
	endif;
	
	if myRangeEndDT &lt;&gt; null and hisRangeEndDT &lt;&gt; null then
		if myRangeStartDT &gt;= hisRangeStartDT and myRangeStartDT &lt;= hisRangeEndDT then
			return true;
		else
			return false;
		endif;
	elseif myRangeEndDT &lt;&gt; null then
		//we have our range and his start only
		if ( myRangeStartDT &lt;= hisRangeStartDT ) and ( hisRangeStartDT &lt;= myRangeEndDT ) then
			return true;
		else	
			return false;
		endif;
	elseif hisRangeEndDT &lt;&gt; null then
		//web have his range and our start only
		if ( hisRangeStartDT &lt;= myRangeStartDT ) and ( myRangeStartDT &lt;= hisRangeEndDT ) then
			return true;
		else	
			return false;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="otherArrivalMove" type="HMS_Movement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="d60b48e9-da9a-43a7-8589-be53d4edc75d">
