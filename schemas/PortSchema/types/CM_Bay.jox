    <JadeMethod name="getMaxCells" id="703fd1bb-0d47-4713-9af6-8bf72ccf2f31">
        <source>getMaxCells(_displayMode : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     31 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	onDeckCells, underDeckCells, maxCells : Integer;
begin
	// PAR 26760 
	if _displayMode = ShpDisplayMode_Defn then
		return self.allCellsOnDeck.size.max(self.allCellsUnderDeck.size);
	else
//		onDeckCells := self.getNumCellsTotallyAvailable(true);
//		underDeckCells := self.getNumCellsTotallyAvailable(false);
//		maxCells := onDeckCells.max(underDeckCells);

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. onDeckCells: ' &amp; onDeckCells.String &amp; " underDeckCells: " &amp; underDeckCells.String &amp; " maxCells: " &amp; maxCells.String );	

		return self.getNumCellsTotallyAvailable(true).max(self.getNumCellsTotallyAvailable(false));
	endif;
end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxTiers" id="9a99338d-026e-400f-90f8-f3b171a54eae">
        <source>getMaxTiers() : Integer;
// ---------------------------------------------------------------------------
// Created:     31 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.allTiersOnDeck.size + self.allTiersUnderDeck.size;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getName" id="6ea09ea2-daf2-4274-ae09-af83b5bad16d">
        <source>getName(): String;
