end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCompatibleSwapJob" id="53f99c25-3da5-49e1-9073-3d5d932e21df">
        <source>getCompatibleSwapJob(	swapStack	:	CM_SwapStack) : CM_YardInternalJob;
/*
This method trolls the jobs on the master queue looking for one that originates
from the passed in swapStack. We are looking for an existing job to add
new entries to...
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/
vars
	entry	: CM_RTQueueEntry;
	aTask :	CM_RTQueueTask;
begin
	if swapStack = null then
		return null;
	endif;	
	//---------------------
	//Troll thru entries, find pickup task with location == us and a yardInternalJob
	//---------------------
	//foreach entry in self.allEntries do
	foreach entry in self.allEntries discreteLock do	//15 Feb 2011	NDL	Par 26994
		if entry.status = ENTRY_UNACTIONED then
			if entry.myJob.isKindOf(CM_YardInternalJob) then
				if entry.myJob.CM_YardInternalJob.isSwapJob then
					aTask := entry.getTaskOfType(TASK_PICKUP, null);
					if aTask = null then
		      	return null;	//This means the pickup task's are all complete, so the job probably is too.
					endif;
					//--------------
					//Is Task a pickup from this swapStack?
					//--------------
					if aTask.sourceLocation = swapStack.myLocationsController then
						return entry.myJob.CM_YardInternalJob;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	//Nothing, quit...
	return null;
end;</source>
        <Parameter name="swapStack" type="CM_SwapStack"/>
        <ReturnType type="CM_YardInternalJob"/>
    </JadeMethod>
