    <JadeMethod name="myReleaseBOL" id="1487a922-f9c0-40e7-a3c5-0d747a067bac">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myReleaseBOL(set: Boolean; _value: CM_BOLOut io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     21 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if _value &lt;&gt; null then
			if _value.myExtension &lt;&gt; null and
			   _value.myExtension.isKindOf(CM_BOLExtLogOut) then
				self.myBOLExtLogOutForNN := _value.myExtension.CM_BOLExtLogOut;
			else
				self.myBOLExtLogOutForNN := null;
			endif;
		else
			self.myReleaseBOL := null;
			self.myBOLExtLogOutForNN := null;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_BOLOut" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myVoyage" id="97fd438e-7d19-4345-96bb-d3ef68ce241f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myVoyage(set: Boolean; _value: CM_Voyage io) mapping, updating;
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if set then
		if _value &lt;&gt; null and _value.myLogVoyageStructure &lt;&gt; null then
//			self.myLogVoyage := _value.CM_LogVoyage;
			self.myVoyage := _value;
			self.myLogVoyageStructure := _value.myLogVoyageStructure;
		else
//			self.myLogVoyage := null;
			self.myVoyage := null;
			self.myLogVoyageStructure := null;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreateSubClasses" id="efa6fe09-1cb7-4817-bfa2-67fe18af0cef">
        <updating/>
        <source>setForCreateSubClasses(_ti: CM_LogNoNumber; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 27 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_ti, _passport);
	self.ediNoNumberID 	:= _ti.id;
	self.isAveraged		:= _ti.isAveraged;
	// DVB changed 2/08/04 Phasing out jas volume.
//	self.jasVolume 		:= _ti.jasVolume;
	self.operatorCode 	:= _ti.operatorCode;
	self.speciesCode 	:= _ti.speciesCode;
	self.gradeCode		:= _ti.gradeCode;
	self.logLength		:= _ti.logLength;
	self.typeCode 		:= _ti.typeCode;
	self.treatmentCode	:= _ti.treatmentCode;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_LogNoNumber"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromEDILog" id="73e180b6-98c1-4385-aec8-1a55884cabf2">
        <updating/>
        <source>setFromEDILog(_ediLog : CM_EDIBOLOutLogTI; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 27 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	self.ediNoNumberID 	:= _ediLog.id;
	self.isAveraged		:= _ediLog.isAveraged;
	// DVB changed 2/08/04 Phasing out jas volume.
//	self.jasVolume 		:= _ediLog.jasVolume;
	self.operatorCode 	:= _ediLog.operatorCode;
	self.speciesCode 	:= _ediLog.logSpeciesCode;
	self.gradeCode		:= _ediLog.logGradeCode;
	self.logLength		:= _ediLog.logLength;
	self.typeCode 		:= _ediLog.logTypeCode;
	self.treatmentCode	:= _ediLog.logTreatmentCode;
	self.setProductCode(_passport);
end;</source>
        <Parameter name="_ediLog" type="CM_EDIBOLOutLogTI"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIsRetainedOnVoyage" id="27fca8de-6894-4955-b5da-4b2383af1c6c">
        <updating/>
        <source>setIsRetainedOnVoyage(_bool : Boolean; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 30 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	transaction		: CM_TITransaction;
	txnParams		: CMIF_TITransactionController;

begin

	exclusiveLock(self);
	if self.isRetainedOnVoyage = _bool then
		return;
	endif;

	self.isRetainedOnVoyage := _bool;
	
	if _bool then
		create txnParams transient;
		txnParams.dateTime 	:= app.serverTimestampAtTrxStart;
		txnParams.userId 	:= _passport.userCode;
		txnParams.noCharge := false;
		txnParams.type 		:= TRANS_TYPE_LogNoNumberRetain;
		transaction 		:= self.createTransaction(txnParams, _passport);
//		transaction.CM_LogNoNumberRetain.setAdditionalFields(self.myLogVoyage);
		if self.myLogVoyageStructure &lt;&gt; null then 
			transaction.CM_LogNoNumberRetain.setAdditionalFields(self.myLogVoyageStructure.myVoyage);
		endif;

	endif;
	
end;</source>
        <Parameter name="_bool" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
