    <JadeMethod name="getHelpDescr" id="3de85724-e5bc-4e79-b8c9-4c66f15cdf1e">
        <source>getHelpDescr(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

constants
	Bullet = 149;
vars
	railLine : CM_RailLine;
	msgStr,
	railLineStr : String;
	pos : String;
begin

	railLine := self.myMobileGenericAgent.myCurrentRailLine;
	if railLine &lt;&gt; null then
		railLineStr := railLine.getFullId();
	endif;
	if cmbRakePos.listIndex &gt; 0 then
		pos := " " &amp; cmbRakePos.itemData[cmbRakePos.listIndex].padLeadingWith('0',2);
		railLineStr := railLineStr &amp; pos;
	endif;
		
	msgStr := app.getErrorString(RAILHHHELP_WGN001) &amp; CrLf  &amp; CrLf &amp; 
			//Enter wagon details.
			Bullet.Character &amp; " " &amp; app.getErrorString1(RAILHHHELP_WGN002, railLineStr) &amp; CrLf  &amp; 
			//'%1'. This is the position of the wagon on rail rake.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN003) &amp; CrLf;
	if self.isKindOf(MOB_HHRailPlaceWagonIn) then
		// To change the wagon ID for an empty unconfirmed wagon, enter the updated ID and press 'Find'.
		msgStr := msgStr &amp; Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN003A) &amp; CrLf;
	endif;
	msgStr := msgStr &amp;		
			//To add wagon to empty position. Enter a new wagon ID and press 'Add' to create.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN004) &amp; CrLf  &amp; 
			//'&lt;&lt;' &amp; '&gt;&gt;' use these to change position on the rake.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN005) &amp; CrLf  &amp; 
			//Damage. Press the Damage button to enter wagon damage.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN006) &amp; CrLf  &amp; CrLf &amp;
			//Cargo. Press the appropriate position button for cargo details.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN007) &amp; CrLf  &amp; 
			//Back. Takes you back to the choose Train  options.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN008) &amp; CrLf  &amp; 
			//Confirm. Acknowledges that you have checked this position.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN009) &amp; CrLf  &amp; CrLf &amp;
			//Finish. Will take you to the session summary screen.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN010) &amp; CrLf  &amp; 
			//Cargo colour defined in 'Vehicle RT Config' form.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN011) &amp; CrLf  &amp; 
			//Confirmed cargo = 'Day' Table back Colour
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_WGN012);
			//Unconfirmed cargo = 'Night' Table back Colour
	return msgStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
