    <JadeMethod name="getSOHValuesForProduct" id="64a845f4-47a2-4b3b-9f97-ae57957747f0">
        <source>getSOHValuesForProduct(_product: CM_Product; _quantity: Integer io; _weight: Decimal io; _volume: Decimal io);
// ---------------------------------------------------------------------------
// Created:     23 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc		: CM_LocationsController;
	qty		: Integer;
	wght	: Decimal[14,4];
	vol		: Decimal[16,4];

begin

	foreach lc in self.allLocationsControllers do
		lc.getSOHValuesForProduct(_product, qty, wght, vol);
		_quantity	:= _quantity + qty;
		_weight		:= _weight + wght;
		_volume		:= _volume + vol;
	endforeach;

end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_quantity" type="Integer" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_volume" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSVGForTerminalArea" id="8d718901-ea8a-402b-a689-9fb55ddf6c2b">
        <source>getSVGForTerminalArea() : String;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theHeader, theDocument : String;
	theFooter : String;
	theGraphic : CM_Graphic;
	thePoints : PointArray;
	theColour : Integer;
	theSVG, tmpString, theColourHex : String;
	aPoint : Point;
begin
// &lt;polygon points="0,2,347,1,158,497,197,766,366,782,632,704,670,891,578,1036,1,1081,0,2" stroke="#008000" fill="none"/&gt;
// notive none for no fill
	theGraphic := self.myLayoutGraphic;
	if theGraphic = null then
		return null;
	endif;
	thePoints := theGraphic.pointsPolygon;
	if thePoints.isEmpty then
		return null;
	endif;
	
	theColour := theGraphic.CM_LayoutGraphic.drawLineColour;
	theColourHex := "#" &amp; theColour.cnEcGetHexColor;
	
	theSVG := theSVG &amp; '&lt;polygon points="';
	tmpString := null;
	foreach aPoint in thePoints do
		tmpString := tmpString &amp; aPoint.x.String &amp; ",";
		tmpString := tmpString &amp; aPoint.y.String &amp; ",";
	endforeach;
	tmpString := tmpString[1:tmpString.length - 1];
	
	theSVG := theSVG &amp; tmpString &amp; '" stroke="' &amp; theColourHex &amp; '" fill="' &amp; theColourHex &amp; '"/&gt;' &amp; CrLf; 
	
	return theSVG;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTAEnqRestrictionLocString" id="5dcb2876-0988-443a-9f02-1802e7b7e82c">
        <source>getTAEnqRestrictionLocString(): String;
//----------------------------------------------------------------
//	Created:	09 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
// 01/11/2012	cnwcs5		par 30475 - split into 2 methods

vars
	str, result 		: String;
	labourRestriction	: CM_LabourRestriction;
begin

	// CCMS 1013 
	result := self.getYardAllocationsAsString;
	
	
	//ccms1573	15/08/2007	cnwvu1
	str := self.getLabourRestrictionsAsString;
	
	
	if str &lt;&gt; null then
		if result &lt;&gt; null then
			result	:= result &amp; '; ';
		endif;
		
		result := result &amp; str;
	endif;
	
	return result;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
