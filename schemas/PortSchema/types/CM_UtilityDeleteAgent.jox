    <JadeMethod name="utlDeleteReeferBlock" id="4143e0eb-10b8-4229-be50-a585a63160cd">
        <source>utlDeleteReeferBlock( _realReeferBlock : CM_ReeferBlock io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	ta : CM_TerminalArea;
	trxUpdAA : CM_UpdateTransactionAuditAgent;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	self.raiseExceptionIfNull( _realReeferBlock, "Reefer Block" );
	_realReeferBlock.validateDelete(_passport);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	ta := _realReeferBlock.myTerminalArea;
	exclusiveLock(ta);
	
	create trxUpdAA transient;
	if _passport.noErrors then
		trxUpdAA.audUpdateGeneric( ta, true );
	endif;

	if _passport.noErrors then
		_realReeferBlock.erase(NORMAL_ERASE);
	endif;
	
	if _passport.noErrors then
		trxUpdAA.audUpdateGeneric( ta, false );
	endif;

epilog

	delete trxUpdAA;

end;</source>
        <Parameter name="_realReeferBlock" type="CM_ReeferBlock" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteRemoteData" id="272a1209-9d5a-4ed6-9b66-5bbd44affed4">
        <source>utlDeleteRemoteData(_remoteHdrSet : CM_RemoteDataHdrSet);

vars

	remote : CM_RemoteDataHdr;

begin


	foreach remote in _remoteHdrSet do
		if not self.exclusiveLockObjectToDelete(remote) then
	    	// _remote Hdr is null, invalid or has already been deleted
	    	continue;
	    endif;
	    delete remote;	
	endforeach;

end;</source>
        <Parameter name="_remoteHdrSet" type="CM_RemoteDataHdrSet"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteRepairReason" id="420b0b0b-1409-4b9c-ac54-e09324df8026">
        <source>utlDeleteRepairReason(_repairReason : CM_RepairReason io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	
begin

	if not self.exclusiveLockObjectToDelete(_repairReason) then
	    return;
	endif;
	_repairReason.validateForDelete();
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_repairReason);
	endif;
	
	_repairReason.erase(NORMAL_ERASE);

end;
</source>
