    <JadeMethod name="createBGPRequest" id="cd3c0dd2-b91e-48e7-9db1-ccd316c16df2">
        <updating/>
        <source>createBGPRequest() updating;
/*
Purpose:			

Date		Who		Reason
03 August 2021	navab1	TFS 50669
*/

vars
	bgpRequest 		: BGP_OpsViewWSRequest;
begin
	if self.myBGPRequest = null then
		create bgpRequest persistent;
		
		/* we already have the  JSON to send so no need to set all this stuff on the request.
		
		if self.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
			objInfo := self.objectOid;
		else
			objInfo := self.myOpsviewObject;
		endif;
		
		bgpRequest.setRequestDetails(self.dataAction ,self.dataType,objInfo );			
		*/
		
		self.myBGPRequest := bgpRequest;
		
		// SEND TO THE BGP CONTROLLER
		bgpRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);

		
	else	
		self.myBGPRequest.action();

	endif;
epilog

end;</source>
    </JadeMethod>
