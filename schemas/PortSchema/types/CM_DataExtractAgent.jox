    <JadeMethod name="buildExtractTransientMethod" id="3c87e757-cef5-43dd-b920-492996ac6d52">
        <source>buildExtractTransientMethod(_extractClass : CM_DataExtractClass) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	#cnwdz2	 

*/

vars
	field           : CM_DataExtractField;
begin
	foreach field in _extractClass.allDataExtractFields do		
		field.buildExtractTransientMethod(self.allDataExtractTransientMethods);
	endforeach;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_extractClass" type="CM_DataExtractClass"/>
    </JadeMethod>
    <JadeMethod name="buildOutputFilePath" id="fbb27320-206c-4924-a02a-aca2a7e1cad6">
        <source>buildOutputFilePath(_outputFolderName, _createDate, _createTime, _extractClassName : String; _isDocumentation: Boolean) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2011	#cnwdz2	 

*/

vars
	fileName,
	filePath : String;
begin
	fileName := _createDate &amp; "_" &amp; _createTime &amp; "_" &amp; _extractClassName;
	if _isDocumentation then
		fileName := fileName &amp; CM_DataExtractClass.DocumentationOutputFileName;
	endif;
	fileName := fileName &amp; CM_DataExtractClass.CSVOutputFileExtension;
	fileName := fileName.removeString(" ");
		
	if _outputFolderName.endsWith("\") then
		filePath := _outputFolderName &amp; fileName;
	else
		filePath := _outputFolderName &amp; "\" &amp; fileName;
	endif;
	
	return filePath;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_outputFolderName" type="String"/>
        <Parameter name="_createDate" type="String"/>
        <Parameter name="_createTime" type="String"/>
        <Parameter name="_extractClassName" type="String"/>
        <Parameter name="_isDocumentation" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="4010427d-9fd3-4967-a151-30632fcf2e30">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services

*/

