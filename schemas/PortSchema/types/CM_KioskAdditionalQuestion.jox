    </JadeMethod>
    <JadeMethod name="doesTIMatch" id="54a44102-584a-41f8-8c26-6d7db18bc5e4">
        <source>doesTIMatch(_ti : CM_TrackedItem ) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2023	jlier1 	Initial creation 59732
*/
vars
	criteria : CM_YAKioskCriteria;
	cmifAutoPlan : CMIF_YAAutoPlanNormal;
begin
	create cmifAutoPlan transient;
	cmifAutoPlan.attachTI(_ti);

	foreach criteria in self.allCriteria discreteLock do
		if not criteria.isCMIFAutoPlanDataMatch(cmifAutoPlan) then
			return false;
		endif;
	endforeach;
	
	return true;
epilog
	delete cmifAutoPlan;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
