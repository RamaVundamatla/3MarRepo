<Class name="CM_CodeGroupLogSpecs" id="2d032917-26cc-4109-a94f-14305e81a1be">
    <superclass name="CM_CodeGroup"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allLogLengths" id="2a55b31e-b1fd-40b8-9059-4093dccaa90d">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_LogLengthsByCode"/>
        <access>readonly</access>
        <Inverse name="CM_LogLength::myCodeGroupLogSpecs"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allLogTreatments" id="4ac44c11-6dde-4952-b985-19e9ff2c8580">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_LogTreatmentsByCodeDict"/>
        <access>readonly</access>
        <Inverse name="CM_LogTreatment::myCodeGroupLogSpecs"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allLogTypes" id="606febf7-0652-4eab-a0b9-429c5e4be4f1">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_LogTypeByCodeDict"/>
        <access>readonly</access>
        <Inverse name="CM_LogType::myCodeGroupLogSpecs"/>
