    <JadeMethod name="setTIFromBookingRefItem" id="7e49ce76-33a4-4b79-9a07-38407ce254f8">
        <updating/>
        <source>setTIFromBookingRefItem(_bookingRefItem : CM_BookingRefItem) updating;

/*
Date		Who		Reason
12/06/2009	cnwar2	Initial creation
01/12/2009	cnwdap1	CCMS MES 1007 Move reefer properties up to CM_TrackedItem level
*/
vars

begin
	inheritMethod(_bookingRefItem);
	
	if _bookingRefItem.clean then
		self.washDT := app.actualTimeServer;
	endif;
	if _bookingRefItem.myISOType &lt;&gt; null then
		self.setISOType(_bookingRefItem.myISOType.code);
		self.setSizeAndTypeAttibutesYA(_bookingRefItem.myISOType);
