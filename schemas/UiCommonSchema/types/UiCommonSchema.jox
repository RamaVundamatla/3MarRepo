    <JadeMethod name="showHookCodeMaintComboForm" id="0ac71f44-2e57-40c1-b888-da99a72c0b38">
        <source>showHookCodeMaintComboForm(_hookType : CM_HookType; _jadeCode : String io; _readOnly : Boolean; _field : EntTableRow io; _comboList : ObjectArray) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	cnwrd1	Initial creation

*/

vars
	tmpForm	: CMUI_HookCodeMaintComboForm;
begin
	create tmpForm transient;
	
	tmpForm.init(_hookType, _jadeCode, _readOnly);
	tmpForm.setCombo( _comboList, _field ) ;
	
	tmpForm.edtMain.height := 300; // cnwrd1 30.10.08 par #18402
	tmpForm.edtMain.top := 47; // cnwrd1 30.10.08 par #18402
	tmpForm.showModal();
	
	if (not _readOnly) then
		if tmpForm.modalResult = IDOK then
			_jadeCode := tmpForm.getJadeCode();
			_field := tmpForm.getComboObject();
		endif;
	endif;
	
	return (tmpForm.modalResult = IDOK);

epilog
	delete tmpForm;
end;</source>
        <Parameter name="_hookType" type="CM_HookType"/>
        <Parameter name="_jadeCode" type="String" usage="io"/>
        <Parameter name="_readOnly" type="Boolean"/>
        <Parameter name="_field" type="EntTableRow" usage="io"/>
        <Parameter name="_comboList" type="ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
