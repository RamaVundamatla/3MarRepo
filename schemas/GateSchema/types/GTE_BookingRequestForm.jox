    <JadeMethod name="doReseveCargo" id="38ae7279-a5b3-4111-a680-b7e32f131574">
        <updating/>
        <source>doReseveCargo() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 September 2008	cnwer1	Initial creation

*/

vars
	form 	: GTE_BookRefReserveItemsForm;
	modalResult 	: Integer;
	br				: CM_BulkRelease;
	brItem 			: CM_BookingRefItem;
		row : Integer;

begin
	
	// NEED TO CHECK
	
	/*
		I think to open this form there needs to be atlease one equipment detail line
		simply so we have something to assiociate with this and so when we look up 
		containers we know the ISO type to filter by	
	
	*/

	row := self.tblBookingItems.row;
	
	if row &gt; 1 then
		brItem := self.tblBookingItems.accessRow(row).itemObject.CM_BRefItemContainer;	
	endif;
	
	if brItem = null or brItem.myReserveDetail = null or
		brItem.myReserveDetail.maxToRelease = 0 then
		//write "Must select a Equipment item with a Max to release greater than zero";
		app.raiseCMException(Add_Reserve_MaxToRelease,app.getErrorString(Equipment),null);
		return;
	endif;
	
	if self.myAddTIsForm = null  then
		self.myAddTIsForm := app.loadForm(CMUI_TrackedItems,CMUI_Assistant,false,false,false,
	                      self.myTerminal, self.myMasterMenuAction).CMUI_TrackedItems;
	endif;
	
	if self.myAddTIsForm = null then
		return;
	endif;
	
	self.myAddTIsForm.myParentForm := self;
	
	self.myAddTIsForm.myIsoTypeGroup := app.myRoot.allISOTypeGroups[brItem.isoTypeGroup];
	self.myAddTIsForm.myISOType:=brItem.myISOType;

	self.myAddTIsForm.allISOTypes.clear;
	self.myAddTIsForm.allISOTypes.add(brItem.myISOType);
	
	br := self.myProxyBookingRef.allReleaseRequests.first.CM_BulkRelease;
	self.myAddTIsForm.isEmptyOnly 		:= true;
	self.myAddTIsForm.myOperator 		:= br.myOperator;
	self.myAddTIsForm.isReleaseByType 	:= true;
	
	self.myAddTIsForm.filterForCargo 	:= true;
	self.myAddTIsForm.myVoyage 			:= br.myVoyage;
	self.myAddTIsForm.myOperatorGroup 	:= br.myOperatorGroup;
	self.myAddTIsForm.myFiltFreightFwdr := br.myFreightForwarder;
	self.myAddTIsForm.myFiltConsignee	:= br.myConsignee;
	
	self.myAddTIsForm.centreWindow;
	self.myAddTIsForm.show;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="fea8afae-4f81-4068-8ad4-e7f53cd04193">
        <updating/>
        <source>doSave():Boolean updating;
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
23 Dec 2024	navbs1	Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created
 
*/
vars
	newBookingRef : CM_BookingRef;
	newBulkRelease : CM_BulkRelease;
	result : Integer;
begin
	
	self.saveDataToProxyBookingRef(self.myProxyBookingRef);

	if self.myProxyBookingRef.isReleaseEmptiesAllowed() then	// PAR 21656 18/02/2010
		self.saveDataToProxyBulkRelease(self.myProxyBookingRef.allReleaseRequests.first,self.myProxyBookingRef);
		
	else //	PAR 21656 18/02/2010	
		// for bookings with a corresponding PACKING release request (Nelson Warehousing), there is specific way for changing the PACKING release. 
		// PACKING release request will be updated later in utlUpdateBulkReleaseNew( ) using the same functionality as before ("old" booking screen mode)
	endif;

	while true do
		if self.myCurrentBookingRef = null then
			app.myTrxCA.trxCreateBookingBulkRel(	self.myProxyBookingRef, 
													newBookingRef,
													newBulkRelease,
													app.myPassport);
		else	
			app.myTrxUA.trxUpdateBookingBulkRel(self.myProxyBookingRef,
												app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			if self.myCurrentBookingRef = null then 			//23.12.2024 navbs1 #33524
				self.myCurrentBookingRef := newBookingRef;
			endif;
			unloadForm;
			return true;
		else
			result := app.showErrorWarningDialog('Booking', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="frmButtons_click" id="82c3b9c4-6782-4f0b-86f2-100a836755e1">
