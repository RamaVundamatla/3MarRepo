        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReceivals_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 24 July 2007
//
//----------------------------------------------------------------------

vars

begin
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
