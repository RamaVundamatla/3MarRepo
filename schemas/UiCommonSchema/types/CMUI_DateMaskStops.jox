        <source>dblClick( editMask : JadeEditMask input ) updating, clientExecution;

/*
Purpose:	To stop the CalenderForm being displayed since cannot handle the return in the listbox stops table.

Date				Who		Reason
06 January 2010		cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	
begin
	return;
	
epilog
	
end;
</source>
