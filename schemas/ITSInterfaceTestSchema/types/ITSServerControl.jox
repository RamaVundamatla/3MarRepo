    <JadeMethod name="create" id="f85e386c-68d0-471f-b0a6-41ddf002a783">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	self.allMachines.instantiate();
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getNextMessageNumber" id="22572455-c4b3-476a-b24b-ec1710f7bc0a">
        <updating/>
        <source>getNextMessageNumber(): Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Dec 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	beginTransaction;
	self.messageNumber := self.messageNumber + 1;
	commitTransaction;
	
	return self.messageNumber;
	

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
