    <JadeMethod name="getEnterDT" id="31687ef3-8f5d-4897-8e22-5e3d98f0402c">
        <source>getEnterDT() : TimeStamp;
/*
----------   ----------  --------------------------------------------------
Created:	03 August 2007 By cnwth2

Purpose:	Used in JRW - don't delete

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	hmsMovement			: HMS_Movement;
	hmsVoyageData			: HMS_VoyageData;
begin
	if self.myHMSVoyageData = null then
		return null;
	endif;
	hmsMovement := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeShift);
	
	if hmsMovement = null then
		return null;
	endif;
	
	return hmsMovement.departureTimeFromFromRegion;

end;


</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEnterDTLocalTZ" id="4d858445-329c-4d70-92b1-51ae7147b7bf">
        <source>getEnterDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	hmsMovement			: HMS_Movement;
	hmsVoyageData			: HMS_VoyageData;
begin
	if self.myHMSVoyageData = null then
		return null;
	endif;
	hmsMovement := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeShift);
	
	if hmsMovement = null then
		return null;
	endif;
	
	return self.systemToLocalTime(hmsMovement.departureTimeFromFromRegion);

end;


</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
