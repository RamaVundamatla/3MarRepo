    <JadeMethod name="valCMIF_LogStockAlloc" id="9d57673c-60b6-4fdf-afaa-fa192b662047">
        <source>valCMIF_LogStockAlloc(_cmifAllocSet : CMIF_LogStockOrderAllocSet; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpIFA,
	iFaceAlloc 	: CMIF_StockOrderAllocation;
	summAlloc	: CM_StockOrderSummaryAlloc;
	totAllocForSummary,
	totalAlloc,
	totalQty	: Decimal[16,4];
	tmpSet		: CMIF_LogStockOrderAllocSet;
	tmpSummSet  : CM_StockOrderSummaryAllocSet;
begin
	self.raiseExceptionIfNull(_cmifAllocSet, '_cmifAllocSet');
	
	create tmpSummSet transient;
	
	create tmpSet transient;
	_cmifAllocSet.copy(tmpSet);

	foreach tmpIFA in tmpSet do
		tmpIFA.setValues();
		tmpIFA.validate(_passport);
		if (not _passport.noErrors) then
			return;
		endif;
		if tmpIFA.allocAmount &lt;= 0 then
			continue;
		endif;				
		if tmpIFA.mode = tmpIFA.Mode_SummarySplit then
			totalAlloc := tmpIFA.allocAmount;
			totAllocForSummary := null;
			summAlloc := tmpIFA.mySummaryAllocation;
			if tmpSummSet.includes(summAlloc) then
				summAlloc := null;
			else
				tmpSummSet.add(summAlloc);
				totAllocForSummary := tmpIFA.allocAmount;
			endif;
			foreach iFaceAlloc in _cmifAllocSet where iFaceAlloc &lt;&gt; tmpIFA do
				iFaceAlloc.setValues();
				iFaceAlloc.validate(_passport);
				if (not _passport.noErrors) then
					return;
				endif;						
				if iFaceAlloc.myLogStockOrderLine = tmpIFA.myLogStockOrderLine then
					totalAlloc := totalAlloc + iFaceAlloc.allocAmount;
					tmpSet.remove(iFaceAlloc);
				endif;
				if summAlloc &lt;&gt; null and iFaceAlloc.mySummaryAllocation = summAlloc then
					totAllocForSummary := totAllocForSummary+iFaceAlloc.allocAmount;
				endif;
			endforeach;
			if (not _passport.noErrors) then
				return;
			endif;								
			tmpIFA.validateQuantity(totalAlloc, _passport);
			if summAlloc &lt;&gt; null then
				if totAllocForSummary &gt; summAlloc.allocQuantity then
					app.raiseCMException3(StockOrderAllocAmountExceeded, totAllocForSummary.jasVolumeString, summAlloc.mySOHLocation.getID() &amp; ' available', summAlloc.allocQuantity.jasVolumeString, ETRow_AllocQuantity, null);						
				endif;					
			endif;
		else
			totalQty := totalQty + tmpIFA.allocAmount;		
		endif;
	endforeach;
	
	if (not _passport.noErrors) then
		return;
	endif;	

	if tmpIFA &lt;&gt; null then //and tmpIFA.mode &lt;&gt; tmpIFA.Mode_SummarySplit then	
		if totalQty &gt; 0 then
			tmpIFA.validateQuantity(totalQty, _passport);
		endif;
	endif;
	
epilog
	delete tmpSet;
	tmpSummSet.clear();
	delete tmpSummSet;
end;</source>
        <Parameter name="_cmifAllocSet" type="CMIF_LogStockOrderAllocSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valCM_Object" id="a5bbd64d-c6c5-4a90-962f-f848c0b553e3">
