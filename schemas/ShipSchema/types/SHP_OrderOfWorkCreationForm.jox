    </JadeMethod>
    <JadeMethod name="doUpdateMoveCC" id="785cbaff-31bb-40f4-978b-835be7ca9f17">
        <updating/>
        <source>doUpdateMoveCC(_srcOOWC : CM_OOWCreation input; _attribute : String; _srcBay : CM_BayVoyage; _srcDeck : Integer; _targetJS : CM_VoyageJobSheet ) updating;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	theTable : CM_DataTable;
	fstOOWC, pxyOOWC, realOOWC : CM_OOWCreation;
	theReturn : Integer;
	idx, st, en : Integer;
	anObj : Object;
	aCrane : CM_Crane;
	ls, found : Boolean;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	if _srcOOWC.myCraneJobSheet = _targetJS then
		return;
	endif;

	foreach realOOWC in self.myCurrentVoyage.myCellularVoyageStructure.allOOWCreations do
		if realOOWC.myBay = _srcBay 
		and realOOWC.getIs40() = _srcOOWC.getIs40()
		and realOOWC.ordinalDeck = _srcDeck 
		and realOOWC.myCraneJobSheet = _targetJS then
			found := true;
			break;
		endif;
	endforeach;

	if found and realOOWC &lt;&gt; null then // UPDATE
		app.cmsBeginLoad(ls);
		pxyOOWC := app.createUpdateProxy(realOOWC).CM_OOWCreation;
		app.cmsEndLoad(ls);
		self.mode := self.Mode_Update;
		pxyOOWC.setProxyAttribute(_srcOOWC,_attribute,_targetJS, _srcOOWC.order, 2,_srcOOWC.getIs40());
	else
		fstOOWC := _targetJS.allOOWCreations.first;
		create pxyOOWC as CM_OOWCreationDetail transient;
		self.mode := self.Mode_Add;
		pxyOOWC.setProxyAttribute(_srcOOWC,_attribute,_targetJS,fstOOWC.order , fstOOWC.orderType + 1,_srcOOWC.getIs40()); //
	endif;
	
	while true do
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateVoyageOOWMoveCC(pxyOOWC,_srcOOWC, _attribute, app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageOOWMoveCC(pxyOOWC,_srcOOWC, _attribute, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			theReturn := app.showErrorWarningDialog("OOW Creation Move CC", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyOOWC;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_srcOOWC" type="CM_OOWCreation" usage="input"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_srcBay" type="CM_BayVoyage"/>
        <Parameter name="_srcDeck" type="Integer"/>
        <Parameter name="_targetJS" type="CM_VoyageJobSheet"/>
    </JadeMethod>
    <JadeMethod name="doUpdateOOW" id="bfa5b94e-b924-42f8-9fc3-ffc7c67a8b40">
        <updating/>
        <source>doUpdateOOW(_theJobSheets : CM_VoyageJobSheetByCraneDict) updating;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : CM_DataTable;
	_controller : CMIF_VoyageJobParams;
	theReturn : Integer;
	idx, st, en : Integer;
	anObj : Object;
	aCrane : CM_Crane;
begin
	if not self.doCheckCraneJobsSetup(_theJobSheets) then
			return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	create _controller transient;
	while true do
		app.myTrxCA.trxCreateVoyageJobOOW(_theJobSheets, app.myPassport, _controller);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("OOW Creation Process", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	// CCM S1061 CentrePort
	if not _controller.allTIs.isEmpty then
		_controller.myVoyage := self.myCurrentVoyage;
		self.myAssistant.showShipNowSingleLiftForm(_controller, self.myMasterMenuAction);
	endif;

epilog
	delete _controller;
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <Parameter name="_theJobSheets" type="CM_VoyageJobSheetByCraneDict"/>
    </JadeMethod>
    <JadeMethod name="doUpdateOOWReset" id="aba2d2b0-2f50-4fad-997f-a233034255ab">
        <updating/>
        <source>doUpdateOOWReset() updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : CM_DataTable;
	
	theReturn : Integer;
