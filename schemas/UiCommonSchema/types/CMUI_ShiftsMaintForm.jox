    <JadeMethod name="translateForm" id="e1cdc6fe-16c8-4973-8d6d-edf783c1f2e3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008103, locale);
	btnAdd.translateBubbleHelp(Xlat_0005203, locale);
	btnAdd.translateCaption(Xlat_0005204, locale);
	btnCancelShift.translateCaption(Xlat_0005205, locale);
	btnCancelShiftDa.translateCaption(Xlat_0005206, locale);
	btnDelete.translateBubbleHelp(Xlat_0005207, locale);
	btnDelete.translateCaption(Xlat_0005208, locale);
	btnEdit.translateBubbleHelp(Xlat_0005209, locale);
	btnEdit.translateCaption(Xlat_0005210, locale);
	btnNext.translateCaption(Xlat_0005211, locale);
	btnNextDay.translateCaption(Xlat_0005212, locale);
	btnRefresh.translateBubbleHelp(Xlat_0005213, locale);
	btnRefresh.translateCaption(Xlat_0005214, locale);
	btnSaveShift.translateCaption(Xlat_0005215, locale);
	btnSaveShiftDay.translateCaption(Xlat_0005216, locale);
	btnShowDays.translateBubbleHelp(Xlat_0005217, locale);
	btnShowDays.translateCaption(Xlat_0005218, locale);
	frmReport.translateCaption(Xlat_0005219, locale);
	lblCode.translateCaption(Xlat_0005220, locale);
	lblCode_1.translateCaption(Xlat_0005221, locale);
	lblDay.translateCaption(Xlat_0005222, locale);
	lblDayNum.translateCaption(Xlat_0005223, locale);
	lblDesc.translateCaption(Xlat_0005224, locale);
	lblDesc_1.translateCaption(Xlat_0005225, locale);
	lblEndTime.translateCaption(Xlat_0005226, locale);
	lblEndTime_1.translateCaption(Xlat_0005227, locale);
	lblReport.translateCaption(Xlat_0005228, locale);
	lblStartTime.translateCaption(Xlat_0005229, locale);
	lblStartTime_1.translateCaption(Xlat_0005230, locale);
	mnuAddShift.translateCaption(Xlat_0008104, locale);
	mnuCopyShift.translateCaption(Xlat_0008105, locale);
	mnuDelShift.translateCaption(Xlat_0008106, locale);
	mnuEditShift.translateCaption(Xlat_0008107, locale);
	mnuInspect.translateCaption(Xlat_0008108, locale);
	mnuWSM.translateCaption(Xlat_0008109, locale);
	optByDate.translateCaption(Xlat_0005231, locale);
	optStandard.translateCaption(Xlat_0005232, locale);
end;</source>
    </JadeMethod>
