    <JadeMethod name="getAttribStrForDefArrayAsync" id="02021d65-7dda-4889-8696-b064a65eef05">
        <source>getAttribStrForDefArrayAsync(_array: JadeDynamicObjectArray;
								_localeId : Integer				//navra1 - MTN-11745 - 12th March 2025
								): String;
/*

04 April 2024   annamth     CR 61540: MTN - [POC - Phase 1] - Enhancing Query Performance through Multi-Process
*/

vars
	entRow		: EntTableRow;
	tmpStr,
	rtnStr		: String;
	firstTime	: Boolean;
	dynObj:JadeDynamicObject;
	_attrName:String;
	obj:Object;
	jmtFullInfo		: LocaleFullInfo;		//navra1 - MTN-11745 - 12th March 2025
begin
	obj:=self;
	on Exception do zDisplayStringExHandler(exception,obj);
	firstTime := true;
	
	//navra1 - MTN-11745 - 12th March 2025 - start
	if app.getMyLocaleInfoJMT().localeId &lt;&gt; _localeId then
		create jmtFullInfo transient;
		currentSchema.getLocaleFullInfo(_localeId, jmtFullInfo);
		app.setMyLocaleInfoJMT(jmtFullInfo);
	endif;
	//navra1 - MTN-11745 - 12th March 2025 - end
	
	foreach dynObj in _array do  
        _attrName:= dynObj.getPropertyValue("attrName").String;
		tmpStr := self.getDisplayStringForAttribute(_attrName, true);
		
		if dynObj.getPropertyValue("inputType").Integer = Table.InputType_CheckBox then
			if tmpStr.Boolean = true or tmpStr.toLower='yes' or tmpStr = '1' or tmpStr = app.getErrorString(Planned) then    //cnwjo3 par 24661
				tmpStr := '1';
			else
				tmpStr := '0';
			endif;

		endif;
		if firstTime then
			firstTime := false;
			rtnStr := tmpStr;
		else
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
		
		if  dynObj.getPropertyValue("sortFieldName").String &lt;&gt; null then
			tmpStr := self.getDisplayStringForAttribute(entRow.sortFieldName, false);
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
	endforeach;
	
	return rtnStr;
epilog
end;</source>
        <Parameter name="_array" type="JadeDynamicObjectArray"/>
        <Parameter name="_localeId" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAttributeStringForDefArray" id="4e793728-3490-4eaf-8bcd-767aa87fb257">
        <source>getAttributeStringForDefArray(_array: EntTableRowArray): String;
/*

Date		Who		Reason
30 Mar 2017	cnwer1	Initial creation TFS 830 - promoted from CM_Object and CMIF_Object
08 Mar 2022	jlika1	52659 SAL - HMS Movement Current Berth  (Movement is Planned is not returning 0 or 1 or true or false valure rather it is returning Planned or Actual so we have to include that in the checkbox options)
31 Oct 2023	navma1  ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
*/

vars
	entRow		 : EntTableRow;
	tmpStr,
	rtnStr		 : String;
	firstTime	 : Boolean;
	tblInputType : Integer;
begin

	firstTime    := true;
    tblInputType := Table.InputType_CheckBox;										   //31.10.2023 navma1 #60920
	
	foreach entRow in _array do	
		tmpStr := self.getDisplayStringForAttribute(entRow.name, true);

		if entRow.inputType = tblInputType then							 			  //31.10.2023 navma1 #60920
			// RJS - not ideal but the best I can come up with at the time
			if tmpStr.Boolean = true or tmpStr.toLower='yes' or tmpStr = '1'  then    //31.10.2023 navma1 #60920
				tmpStr := '1';
			else
				tmpStr := '0';
			endif;

		endif;
		if firstTime then
			firstTime := false;
			rtnStr := tmpStr;
		else
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
		
		if entRow.sortFieldName &lt;&gt; null then
			tmpStr := self.getDisplayStringForAttribute(entRow.sortFieldName, false);
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
	endforeach;

	return rtnStr;

end;</source>
        <Parameter name="_array" type="EntTableRowArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
