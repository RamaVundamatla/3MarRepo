    <JadeMethod name="tblStops_contextMenu" id="b6a6c90f-9d59-4ecd-8b3e-52ffea82c132">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStops_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

begin

	if not self.wasCalledViaContext(false) then
		return false;
	endif;

	// we only want to show these contexts if we started at the enquiry form.

	return buildContextMenu(table, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="48154fd3-34c4-43e0-9aea-859145e9ed3b">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013147, locale);
	lblCargoId.translateCaption(Xlat_0019049, locale);
	mnuContext.translateCaption(Xlat_0015233, locale);
	mnuGrades.translateCaption(Xlat_0015234, locale);
	mnuMove.translateCaption(Xlat_0015235, locale);
	mnuTasks.translateCaption(Xlat_0015236, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="30e3d2aa-d903-4f00-9ced-00562ff1912d">
