<Class name="CMIF_TMCSBDefault" id="2d04531e-5031-4a00-a84e-04bb9bb8a7ea">
    <superclass name="CMIF_TMCSBGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <JadeMethod name="setEnableObjects" id="b57fcd0a-d681-4972-9fa3-d751cc62b342">
        <source>setEnableObjects(form: INV_TransactionMap io);
// ---------------------------------------------------------------------------
// Created:		25 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);
	form.menuSItemProperties.visible := false;
	form.btnProperties.enabled := false;

	form.menuSItemDelete.visible := false;
	form.btnDelete.enabled := false;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
