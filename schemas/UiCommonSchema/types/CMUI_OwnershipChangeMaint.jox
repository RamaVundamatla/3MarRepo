        <updating/>
        <source>cmbCurrentOperator_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58233	Task 58234: Jade - Terminal Configuration
*/

vars
begin
	if self.myTerminal.getConfig(CooSplitOperator).Boolean then
		self.cmbNewOperator.listIndex := self.cmbNewOperator.findObject(self.cmbCurrentOperator.listObject);
		self.cmbNewOperator.enabled := false;
