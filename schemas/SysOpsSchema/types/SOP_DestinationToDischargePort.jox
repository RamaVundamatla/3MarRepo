    <JadeMethod name="addDestToDischPort" id="6d51382a-74d3-4ad2-8709-120f0fe99d22">
        <updating/>
        <source>addDestToDischPort() updating;

vars
	operShippingLine : CM_OperatorShippingLine;
	operator : CM_Operator;
	shippingLine : CM_ShippingLine; 
	destination : CM_Port; 
	dischargePort : CM_Port;	
begin
	// check the Oper shippingLine exists.
	operator := self.cmbOperator.listObject.CM_Operator; 
	shippingLine := self.cmbShippingLine.listObject.CM_ShippingLine; 
	destination := self.cmbPortDest.listObject.CM_Port; 
	dischargePort := self.cmbPortDisch.listObject.CM_Port;	
	operShippingLine := app.myRoot.allOperatorShippingLines[operator, shippingLine];
	app.myTrxCA.trxCreateDestToDischargePort(operator, shippingLine, destination, dischargePort, app.myPassport);	
	if operShippingLine = null then
		operShippingLine := app.myRoot.allOperatorShippingLines[operator, shippingLine];
		self.populateTableOperShippingLine();
	endif;
	self.populateTableDestDischPort(operShippingLine, shippingLine);
	self.btnAdd.enabled := false;
end;</source>
    </JadeMethod>
