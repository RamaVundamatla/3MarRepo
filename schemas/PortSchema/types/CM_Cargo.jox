    <JadeMethod name="adjustSplitReserveDetail" id="0d5d323f-f6aa-492e-a5ed-d7161fc5a666">
        <source>adjustSplitReserveDetail(newTI : CM_TrackedItem input; bulkRelease : CM_BulkRelease input);
/*
Purpose:	Refactored to have all code execute for all bulk releases		

Date		Who		Reason
15 Sep 2021	navab1	TFS 51936
14 Oct 2025	navdap1	MTN-36227 Yara | Cater for multiple lines in an OrderCreate / OrderChange / OrderResponse
02 Dec 2025 navhl20 Bug MTN-36765: MTN - Release Request / Bulk Gate - Requested Amount on Release Request getting changed when using Bulk Gate Out
*/

vars
	tmpReserveTI, 
	existingReserveTI 	: CM_ReserveTI;		// MTN-36227
	extraData 			: String;									// MTN-36227
	tmpReserveDet 		: CM_ReserveDetail;
begin
	if bulkRelease.releaseByType then
		bulkRelease.addTIAssigned(newTI,CM_ReserveDetail.PackType_Parent);
	else
		create tmpReserveTI;			
		tmpReserveTI.setMyHeader(bulkRelease);
		tmpReserveTI.addTI(newTI);
		
		if self.isKindOf(CM_Bulk) then
			tmpReserveTI.setTotalRequested( 1 );
			tmpReserveTI.setWeightRequested( newTI.totalWeight );
		else
			tmpReserveTI.setTotalRequested( newTI.totalQuantity.max(1) );
		endif;
		
		
		
		foreach tmpReserveDet in self.allReserveDetails do
			//only adjust for the bulk release we are releasing for
			//epr TFS 43404 14/2/19
			if tmpReserveDet.myReserveHeader &lt;&gt; bulkRelease then
				continue;
			endif;
			
			if tmpReserveDet.isKindOf(CM_ReserveTI) then
				existingReserveTI := tmpReserveDet.CM_ReserveTI;	// MTN-36227
				if self.isKindOf(CM_Bulk) then
					existingReserveTI.setWeightRequested( existingReserveTI.weightRequested - newTI.totalWeight );	// MTN-36227		//02.12.2025 navhl20 #36765
				else
					existingReserveTI.adjustTotalRequested((newTI.totalQuantity.max(1) * -1));	// MTN-36227
				endif;
				// MTN-36227 transfer extra data to the new Reserve TI so CAMS can use that information
				global.getExtraData(existingReserveTI.allExtraData, ReserveTIYaraData, extraData);
				if extraData &lt;&gt; null then
					global.setExtraData(tmpReserveTI.allExtraData, tmpReserveTI, ReserveTIYaraData, extraData);
				endif;
			endif;
		endforeach;
		
		
	endif;
epilog

end;</source>
        <Parameter name="newTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="bulkRelease" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
