    <JadeMethod name="lstSavedDisplays_contextMenu" id="f003ec3e-7069-44fe-ae30-8a8b7b63e179">
        <controlMethod name="ListBox::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSavedDisplays_contextMenu(
	_listbox	: ListBox input;
	_conwin		: Window input;
	_mouse		: Boolean;
	_x			: Integer;
	_y			: Integer ) : Boolean updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
14 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	// decided what should be enabled at any particular time.
	self.mnuPopup3New.enabled			:= btnNewDefn.enabled;
	self.mnuPopup3Save.enabled			:= btnSaveDefn.enabled;
	self.mnuPopup3SaveAs.enabled		:= btnSaveAsDefn.enabled;
	self.mnuPopup3Delete.enabled		:= btnDeleteDefn.enabled;
	self.mnuPopup3Run.enabled			:= btnRunDefn.enabled;
	self.mnuPopup3HideDetails.enabled	:= btnHideDetails.visible;		// visible not enabled
	self.mnuPopup3ShowDetails.enabled	:= btnShowDetails.visible;		// visible not enabled
	
	// now show the menu and terminate further processing
	return self.showContextMenu( self.mnuPopup3, _listbox, _conwin, _mouse, _x, _y );
	
epilog
	
end;
</source>
        <Parameter name="_listbox" type="ListBox" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
