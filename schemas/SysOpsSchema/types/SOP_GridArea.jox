        <source>doColumnSelection(gridColumn: CMUI_GridColumn input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2008	cnwjk3	CCMS 1032

*/

vars

begin
	inheritMethod(gridColumn, button, shift, x, y);
	if button = 2 then
		self.myGridAreaFrame.form.SOP_TerminalAreaDefForm.showGridFrameContextMenu(x.Integer, y.Integer, false);
	else
