    <JadeMethod name="addMoveToHistoryLoc" id="53481a66-5158-46dc-906a-de69ba44641b">
        <updating/>
        <source>addMoveToHistoryLoc(_sourceLocationId, _targetLocationId : String; _ti : CM_TrackedItem) : CM_MachineMoveHistory updating;
/*
Purpose	This method is called when the driver completes a move(as opposed to doing a pickup or setdown)

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed as part of refactoring methods
01/11/2010	cnwcs5	par 23714/ccms 1132 - machine productivity reporting
										- always create pickup/setdown pair
*/

vars
	histEntry	: CM_MachineMoveHistory;	
	tmpUser		: CM_User;
begin

	create histEntry persistent;
	
	tmpUser := self.user;
	
	if tmpUser = null then
		histEntry.completedMove(_sourceLocationId, _targetLocationId, _ti, CM_MachineHistory.Unknown_Value, self);	// 02/11/2010 cnwcs5 par 23714/ccms 1132
	else
		histEntry.completedMove(_sourceLocationId, _targetLocationId, _ti, tmpUser.code, self);	// 02/11/2010 cnwcs5 par 23714/ccms 1132
	endif;
	
	return histEntry; //ccms 1416 feb 2006 cnwrs1
end;</source>
        <Parameter name="_sourceLocationId" type="String"/>
        <Parameter name="_targetLocationId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
