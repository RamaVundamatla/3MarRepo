    <JadeMethod name="setupControls" id="7e16b84a-b2e9-4e9e-ab6c-3f5a9df239ba">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 June 2011	cnwndl1	Initial creation	Par 27003

*/

vars

