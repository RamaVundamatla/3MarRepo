    <JadeMethod name="tblReadingSortAndShow" id="76074c1e-091a-4946-979d-676eac00b8c2">
        <updating/>
        <source>tblReadingSortAndShow() updating;
// ---------------------------------------------------------------------------
// Created:		05 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Trailers as Reefers
// 11/03/2010	cnwdap1		PAR #22938 Correct reefer checking
// 17/03/2015	cnwdap1		PAR #35874 TFS 265 Added Ventilation and Humidity reading classes
// 04/05/2016	cnwns1		TFS 488 - Multi Timezone Support
// 16/01/2026	navdap1		MTN-36569 CPL | Reefer Runner Integration
vars
	reefer			: CM_TrackedItem;	// CCMS 1007
	tempReadings	: CM_TempReadingByDateTimeDict;
	humidReadings	: CM_HumidReadingByDateTimeDict;			// PAR #35874
	ventReadings	: CM_VentReadingByDateTimeDict;				// PAR #35874
	temp			: CM_TempReading;							// PAR #35874
	humid			: CM_HumidReading;							// PAR #35874
	vent 			: CM_VentReading;							// PAR #35874
	co2Readings		: CM_CO2ReadingByDateTimeDict;			// MTN-36569
	co2				: CM_CO2Reading;						// MTN-36569
	o2Readings		: CM_O2ReadingByDateTimeDict;			// MTN-36569
	o2				: CM_O2Reading;							// MTN-36569
begin

	reefer := self.myCurrentObject.CM_TrackedItem;	// CCMS 1007

	if reefer &lt;&gt; null then	//cnwrs1 Aug 2006 par 12368
		self.allReadings.clear;														// PAR #35874
		tempReadings := reefer.getAllTemperatureReadings;			// PAR #23150
		foreach temp in tempReadings discreteLock do								// PAR #35874
			self.allReadings.putAtKey(self.systemToLocalTime(temp.dateTime), temp.getOidString, temp);		// PAR #35874//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endforeach;																	// PAR #35874
		humidReadings := reefer.getAllHumidityReadings();							// PAR #35874
		foreach humid in humidReadings discreteLock do								// PAR #35874
			self.allReadings.putAtKey(self.systemToLocalTime(humid.dateTime), humid.getOidString, humid);	// PAR #35874//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endforeach;																	// PAR #35874
		ventReadings := reefer.getAllVentilationReadings();							// PAR #35874
		foreach vent in ventReadings discreteLock do								// PAR #35874
			self.allReadings.putAtKey(self.systemToLocalTime(vent.dateTime), vent.getOidString, vent);		// PAR #35874//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endforeach;																	// PAR #35874
		// MTN-36569 CO2 and O2 readings
		co2Readings := reefer.getAllCO2Readings();
		foreach co2 in co2Readings do
			self.allReadings.putAtKey(self.systemToLocalTime(co2.dateTime), co2.getOidString, co2);
		endforeach;
		o2Readings := reefer.getAllO2Readings();
		foreach o2 in o2Readings do
			self.allReadings.putAtKey(self.systemToLocalTime(o2.dateTime), o2.getOidString, o2);
		endforeach;
		// MTN-36569 end of this bit
		
		self.setNavigatorHeading('Reefer ' &amp; reefer.id);
		self.tblReadings.accessCell(1, 1).text := 'Date Time'&amp;Tab&amp;'Temperature'&amp;Tab&amp;"Humidity"&amp;Tab&amp;"Ventilation"&amp;Tab&amp;"CO2"&amp;Tab&amp;"O2"&amp;Tab&amp;"User Code";	// MTN-36569
		
		self.tblReadings.displayCollection(self.allReadings, false, Table.DisplayCollection_Reversed, null);						// PAR #35874
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblReadingsDisplayRow" id="9dc65a85-0c36-4a85-a86f-23874f3d34bf">
        <source>tblReadingsDisplayRow(_reading : CM_Object) : String;
// ---------------------------------------------------------------------------
// Created:		05 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/03/2015	cnwdap1		PAR #35874 TFS 265 Added ventilation and humidity reading types
// 04/05/2016	cnwns1		TFS 488 - Multi Timezone Support
// 16/01/2026	navdap1		MTN-36569 CPL | Reefer Runner Integration
vars
	str				: String;
	userCode		: String;
	//trTrans		: CM_TemperatureReading;		// PAR #35874
	trans			: CM_TITransaction;				// PAR #35874
	tempReading		: CM_TempReading;				// PAR #35874
	humidReading	: CM_HumidReading;				// PAR #35874
	ventReading		: CM_VentReading;				// PAR #35874
	co2Reading		: CM_CO2Reading;		// MTN-36569
	o2Reading		: CM_O2Reading;			// MTN-36569
begin
	
	if _reading = null then
		//return "null Temp Reading";				// PAR #35874
		return "null Reading";						// PAR #35874
	endif;
	
	//str :=  _tempReading.dateTime.String &amp; Tab &amp; 						// PAR #35874
	//		_tempReading.getDisplayTemp();								// PAR #35874
	
	if _reading.isKindOf(CM_TempReading) then							// PAR #35874
		tempReading := _reading.CM_TempReading;							// PAR #35874
		str := self.systemToLocalTime(tempReading.dateTime).asStringJMT &amp; Tab &amp;		// PAR #35874//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				tempReading.getDisplayTemp() &amp; Tab &amp; Tab &amp; Tab &amp; Tab;				// MTN-36569
		userCode := tempReading.userId;									// PAR #35874
		trans := tempReading.myTemperatureReading;						// PAR #35874
	elseif _reading.isKindOf(CM_HumidReading) then						// PAR #35874
		humidReading := _reading.CM_HumidReading;						// PAR #35874
		str := self.systemToLocalTime(humidReading.dateTime).asStringJMT &amp; Tab &amp; Tab &amp;	// PAR #35874 //04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				humidReading.getDisplayHumidity() &amp; Tab &amp; Tab &amp; Tab;				// MTN-36569
		userCode := humidReading.userId;								// PAR #35874
		trans := humidReading.myHumidityReading;						// PAR #35874
	elseif _reading.isKindOf(CM_VentReading) then						// PAR #35874
		ventReading := _reading.CM_VentReading;							// PAR #35874
		str := self.systemToLocalTime(ventReading.dateTime).asStringJMT &amp; Tab &amp; Tab &amp; Tab &amp;		// PAR #35874 //04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				ventReading.getDisplayVentilation() &amp; Tab &amp; Tab;					// MTN=36569
		userCode := ventReading.userId;									// PAR #35874
		trans := ventReading.myVentilationReading;						// PAR #35874
		
	// MTN-36569 CO2 and O2 readings
	elseif _reading.isKindOf(CM_CO2Reading) then
		co2Reading := _reading.CM_CO2Reading;
		str := self.systemToLocalTime(co2Reading.dateTime).asStringJMT &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp;
				co2Reading.co2.asStringJMT() &amp; Tab;
		userCode := co2Reading.userId;
		trans := co2Reading.myCO2ReadingTransaction;
	elseif _reading.isKindOf(CM_O2Reading) then
		o2Reading := _reading.CM_O2Reading;
		str := self.systemToLocalTime(o2Reading.dateTime).asStringJMT &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp;
				o2Reading.o2.asStringJMT();
		userCode := o2Reading.userId;
		trans := o2Reading.myO2ReadingTransaction;
	// MTN-36569 end
	endif;																// PAR #35874
	
	//if _tempReading.userId.trimBlanks = "" then	// try to get it off the transaction	// PAR #35874
	if userCode.trimBlanks = "" then		// try to get it off the transaction			// PAR #35874
		//trTrans := _tempReading.myTemperatureReading;					// PAR #35874
		if trans &lt;&gt; null then											// PAR #35874
			//userCode := trTrans.userId;								// PAR #35874
			userCode := trans.userId;									// PAR #35874
		endif;
	//else																// PAR #35874
	//	userCode := _tempReading.userId;								// PAR #35874
	endif;

	return str &amp; Tab &amp; userCode;
	
end;</source>
        <Parameter name="_reading" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblReadings_contextMenu" id="33d45ec6-9f45-4f5b-ad49-aa2eb4c47f23">
