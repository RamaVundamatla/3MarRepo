    <JadeMethod name="getAvailabilityGradeTranslated" id="b4e98277-7a64-488e-9f90-d3930f55bf61">
        <source>getAvailabilityGradeTranslated() : String;
// -------------------------------------------
// Created 27 October 2004 by cnwdvb1
// 31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
// -------------------------------------------
vars

	grade		: CM_MTGrade;
	code		: CM_MTGradeCode;
	canDisplay	: Boolean;

begin

 	grade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];   					//31.10.2023 navma1 #60920

	if grade = null then
    	return "Undefined";
    else
    	grade.getTranslationForOperator(grade, self.myOperator, null, code, canDisplay);    	
    	if code &lt;&gt; null then
    		return code.code;
    	elseif canDisplay then
    		return grade.code.String;
    	else
    		return null;
    	endif;
    endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCO2FromLoadList" id="3c7afb17-d9b9-401f-8dc3-61ff3bde9779">
        <source>getCO2FromLoadList(): String;
//----------------------------------------------------------------
//	Created:	11 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
//	Used in reports
//
vars
	lls	: CM_EDIDataArray;
begin
	if self.myVoyage &lt;&gt; null then
//		if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then					cnwrl1 16/04/2009 PAR 19471
			create lls transient;
//			self.myVoyage.myCellularVoyageStructure.getAllEDILoadLists(lls);	cnwrl1 16/04/2009 PAR 19471
			self.myVoyage.getAllEDILoadLists(lls);
			if not lls.isEmpty then
				return lls.last.CM_EDIDataLoadList.getFieldValueForTI(ETRow_CarbonDioxide, self);			
			endif;
//		endif;
	endif;
	return null;
epilog
	delete lls;
end;</source>
