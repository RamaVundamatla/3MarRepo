<Class name="CM_LDPrinterDef" id="8688c2f5-b326-4117-82ab-9fe47d467f04">
    <superclass name="CM_LaneDevice"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="myPrinter" id="e0923e80-847e-48d0-9dd2-15401dfac3c1">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_PrinterDef"/>
        <access>readonly</access>
        <Inverse name="CM_PrinterDef::allLaneDevices"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="19d71fb0-24dc-4adb-8506-343e363dd3af">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.type	:= CM_LaneDevice.Type_Printer;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="bc2f04bc-50ee-4e04-b6e1-f657cdf5ee3e">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		gDansk gate issue 
// ---------------------------------------------------------------------------
vars
	txt	:String;
begin
	txt := inheritMethod();
	
	if self.myPrinter = null then													// 20/04/2010	cnwcs5		gDansk gate issue 
		txt := txt &amp; self.formatAuditText("Printer", app.getErrorString (Unknown));	// 20/04/2010	cnwcs5		gDansk gate issue 
	else																			// 20/04/2010	cnwcs5		gDansk gate issue 
		txt := txt &amp; " " &amp; self.formatAuditText("Printer", self.myPrinter.logicalPrinterName);
	endif;																			// 20/04/2010	cnwcs5		gDansk gate issue 

	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasDevice" id="f30c1460-4318-441e-99df-0b83cba09de5">
        <source>hasDevice(): Boolean;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		gDansk gate issue
// ---------------------------------------------------------------------------
vars

begin
	return self.myPrinter &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPrinter" id="83435ed2-7fe3-4a04-94f6-4c96ed80fd94">
        <source>isPrinter():Boolean;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e480b631-fda4-4bee-943e-3cc5d5a65d26">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     28 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy	:SelfType;
	completedOK		: Boolean;
begin
	proxy :=  inheritMethod();

	proxy.myPrinter	:= self.myPrinter;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2bf63d9b-9da7-47c4-8170-650dff07bff5">
        <updating/>
        <source>setForUpdate(_proxy: CM_LDPrinterDef) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myPrinter	:= _proxy.myPrinter;
	
	inheritMethod(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_LDPrinterDef"/>
    </JadeMethod>
    <JadeMethod name="setPrinter" id="6d95928f-64be-4ff0-a3d2-a544d307164a">
        <updating/>
        <source>setPrinter(_printer :CM_PrinterDef)updating;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	if self.myPrinter &lt;&gt; _printer then
		self.myPrinter := _printer;
	endif;
epilog

end;</source>
        <Parameter name="_printer" type="CM_PrinterDef"/>
    </JadeMethod>
    <JadeMethod name="validate" id="5d0fdec5-08d8-4cfe-8d5e-78ba40ae1efd">
        <source>validate(_passport: CM_Passport input)protected;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_passport);

	if self.myPrinter = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Printer required');
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
