    <JadeMethod name="setTIsForCreate" id="c036d75e-5b00-4a57-804e-1c968d7164c2">
        <updating/>
        <source>setTIsForCreate(_tiDict : CM_TISet; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 05 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	realTI,
	pxyTI : CM_TrackedItem;
begin

	self.detachTIs();

	foreach pxyTI in _tiDict do
		if pxyTI.isTransient and (not self.isTransient) then
			//Create a persistent version of the proxy object
			realTI := self.myTerminal.createTrackedItem(pxyTI, _passport);
		else
			realTI := pxyTI;	//Just attach the passed in object
		endif;
		// PAR 15206 We are creating a new TI, however when creating a new TI we are also seeing 
		//			if the BOL already exists and if so we have already attached it to 
		//			a different BOL so do not add to this one.
		if self.isReleaseDocket then
			if realTI.myReleaseBOL &lt;&gt; null then
				continue;
			endif;
		else
			if realTI.myReceivalBOL &lt;&gt; null then
				continue;
			endif;
		endif;
		self.attachTI(realTI);
	endforeach;

end;</source>
        <Parameter name="_tiDict" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTIsForUpdate" id="25147716-38d5-40f5-b605-dc2dc9b8b2c0">
        <updating/>
        <source>setTIsForUpdate(_tis : CM_TISet; _passport : CM_Passport input) updating, protected;
//Updates the list of children for a tracked Item
//Works with both proxy and persistent children
vars
	deleteTIs,
	origTIs		: CM_TIByCargoTypeIdDict;
	realTI,
	proxyTI		: CM_TrackedItem;
	expectedEdition,
	idx,
	arraySize	: Integer;
	tiUpdateCntrlr : CMIF_TIUpdateController;
begin
	if _tis.isEmpty then
		return;
	endif;//added by cnwyl1 for Par13288 and Par14735
	
	_tis.first.pxyGetRealObjectAndEdition(realTI, expectedEdition);

	create deleteTIs transient;
	create origTIs transient;

	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	self.allTrackedItems.copy(origTIs);

	// detach and we will reattach below
	self.detachTIs();
	
	foreach realTI in origTIs do
		exclusiveLock(realTI);
		if realTI.state = TI_STATE_NOTIFIED then
			deleteTIs.add(realTI);
		endif;
	endforeach;

	// as notified items are not on the terminal just erase and recreate the kids
	while deleteTIs.size &gt; 0 do
		realTI := deleteTIs.last;
		deleteTIs.remove(realTI);
		realTI.erase(NORMAL_ERASE);
	endwhile;

	foreach proxyTI in _tis do
		if proxyTI.isTransient and (not self.isTransient) then
			// If this is an issue then need to set this elsewhere - rjs
			//proxyTI.setPropertyValue("isValid", true);
			realTI := null;
			proxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);

			if realTI = null then
				//validate proxyTI 
				realTI := self.myTerminal.createTrackedItem(proxyTI, _passport);
			else
				//Update the child object
				realTI.setForUpdate(proxyTI, tiUpdateCntrlr, null, true, _passport); //cnwrd1 28.8.09 par 20545
			endif;
		else		//'Proxy' child is real object
			realTI := proxyTI;	//Just attach the passed in object
		endif;

		self.attachTI(realTI);
	endforeach;

epilog
	delete origTIs;
	delete deleteTIs;
	delete tiUpdateCntrlr;
end;</source>
        <access>protected</access>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTransportMode" id="4eee42fd-1297-4b4e-8e98-37e51654d964">
