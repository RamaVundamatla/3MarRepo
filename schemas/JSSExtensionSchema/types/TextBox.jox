<GUIClass name="TextBox">
    <JadeMethod name="jssDate" id="f3d3f927-e7f9-4384-8c6f-3c7210f85af6">
        <source>jssDate():Date;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver as a Date value.
//
// Parameters:	None
//
// Returns:		Date - the trimmed text cast to a Date value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.trimBlanks().Date;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssDecimal" id="dbbe385d-50b6-46e8-a978-494cf42a7678">
        <source>jssDecimal():Decimal;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver as a Decimal value.
//
// Parameters:	None
//
// Returns:		Decimal - the trimmed text cast to a Decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.trimBlanks().jssRemoveSubstring(",").Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="jssDoSpellCheck" id="da2613d1-3ca9-466e-8449-206f0517a370">
        <updating/>
        <source>jssDoSpellCheck(pDictionaryName:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		08 December 2001 by cnwdad1
//
// Purpose:		Spell-Checks the receiver's text, and updates it if the prose has
//				been modified.
//
// Parameters:	None
//
// Returns:		True if the text was changed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSpellCheck	: JSSSpellCheck;
	theDictionary	: JSSWordDictionary;
	theRoot			: JSSRoot;
	checkedProse	: String;
	
begin
	theRoot	:=	app.jssMyRoot;
	
	if theRoot = null then
		JSSException.raise_(JSS_X_03002, "The JSS root object is null.");
	endif;
	
	theDictionary	:=	theRoot.allDictionaries[pDictionaryName];
	
	if theDictionary = null then
		JSSException.raise_(JSS_X_03000, "The requested Word Dictionary (" &amp; pDictionaryName &amp; ") was not found.");
	endif;
	
	create theSpellCheck transient;
	theSpellCheck.setDictionary(theDictionary);
	
	if theSpellCheck.isCheckProse(self.text, checkedProse) then
		self.text	:=	checkedProse;
		return true;
	else
		return false;
	endif;
epilog
	delete theSpellCheck;
end;</source>
        <Parameter name="pDictionaryName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssInteger" id="3d5a07cc-6d33-468a-b5de-0f7a119f2113">
        <source>jssInteger():Integer;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver as a Integer value.
//
// Parameters:	None
//
// Returns:		Integer - the trimmed text cast to a Integer value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.trimBlanks().jssRemoveSubstring(",").Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssReal" id="0e4dc441-65fd-4c45-8d54-23dc2c67732a">
