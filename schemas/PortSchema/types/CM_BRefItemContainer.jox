    </JadeMethod>
    <JadeMethod name="zdontuseccms1017temp" id="033da745-6a7b-425e-82cc-95cb60b76aa9">
        <source>zdontuseccms1017temp(_carbonDioxide : Decimal output; _curtainsIn : Boolean output; _humidity : Integer output; _isControlledAtmosphere : Boolean output; _oxygen : Decimal output; _temperature : Real output; _ventilation : Decimal output; _ventilationUnits : Integer output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2009	cnwdap1	Initial creation
*/
vars

begin
	_carbonDioxide			:= self.carbonDioxide;
	_curtainsIn				:= self.curtainsIn;
	_humidity				:= self.humidity.Integer;
	_isControlledAtmosphere	:= self.isControlledAtmosphere;
	_oxygen					:= self.oxygen;
	_temperature			:= self.temperature;
	_ventilation			:= self.ventilation;
	_ventilationUnits		:= self.ventilationUnits;
epilog

end;</source>
        <Parameter name="_carbonDioxide" type="Decimal" usage="output"/>
        <Parameter name="_curtainsIn" type="Boolean" usage="output"/>
        <Parameter name="_humidity" type="Integer" usage="output"/>
        <Parameter name="_isControlledAtmosphere" type="Boolean" usage="output"/>
        <Parameter name="_oxygen" type="Decimal" usage="output"/>
        <Parameter name="_temperature" type="Real" usage="output"/>
        <Parameter name="_ventilation" type="Decimal" usage="output"/>
        <Parameter name="_ventilationUnits" type="Integer" usage="output"/>
    </JadeMethod>
