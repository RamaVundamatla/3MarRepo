<Class name="JadeScript">
    <JadeMethod name="checkOS" id="6e09dbfb-9746-4844-a72d-ee13f4664a8a">
        <source>checkOS(pIsThinClient:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		16 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	platform		: Integer;
	version			: String;
	architecture	: Integer;
	
begin
	if pIsThinClient then
		platform	:=	process.getOSPlatform(version, architecture);
	else
		platform	:=	node.getOSPlatform(version, architecture);
	endif;
	
	if platform.bitAnd(Node.OSWindows) &lt;&gt; 0 then
		// Operating System is the Windows family (95, 98, 2000, or NT)
		if platform = Node.OSWindowsHome then
			// version is one of Windows 95 or Windows 98
			return "Windows " &amp; version;
		endif;
		
		if platform = Node.OSWindowsEnterprise then
			return "Windows NT " &amp; version; // version 4, for Windows NT 4.0
		endif;
	elseif platform.bitAnd(Node.OSUnix) &lt;&gt; 0 then
		// Operating System is unix (aix, linux, solaris, etc)
		if platform = Node.OSUnixAIX then  
			// version 4.3, for all releases of AIX 4.3
			return "IBM AIX " &amp; version;
		else
			return "* Unknown UNIX platform: " &amp; platform.String &amp; " version: " &amp; version;
		endif;
	else
		return "* Unknown platform: " &amp; platform.String &amp; " version: " &amp; version;
	endif;
end;</source>
        <Parameter name="pIsThinClient" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkOSAllNodes" id="2c7a05df-eb71-4c29-bd2c-8fb06e6b953f">
        <executionLocation>client</executionLocation>
        <source>checkOSAllNodes() clientExecution;
// --------------------------------------------------------------------------------
// Created:		16 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	write "Client OS: " &amp; self.checkOS(true);
	write "Database Server OS: " &amp; self.checkOSServer();
	write "Application Server OS: " &amp; self.checkOS(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="checkOSServer" id="46b35b13-b527-48e9-b03e-9d5c6f66a6fe">
        <executionLocation>server</executionLocation>
        <source>checkOSServer():String serverExecution;
// --------------------------------------------------------------------------------
// Created:		16 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.checkOS(false);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="fetchDrives" id="968dc905-2e8a-4357-868d-55d493fb027c">
        <source>fetchDrives(pAllDriveNames:StringArray io);
// --------------------------------------------------------------------------------
// Created:		16 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	LOWER_DRIVE	: Character = "C";
	UPPER_DRIVE	: Character = "Z";
	
vars
	theFolder		: FileFolder;
	driveCharacter	: Integer;
	driveLetter		: String;
	
begin
	create theFolder transient;
	theFolder.usePresentationFileSystem	:=	true;
	
	foreach driveCharacter in LOWER_DRIVE.Integer to UPPER_DRIVE.Integer do
		driveLetter	:=	driveCharacter.Character &amp; ":\";
		
		theFolder.fileName	:=	driveLetter;
		
		if theFolder.isAvailable then
			pAllDriveNames.add(driveLetter);
		endif;
	endforeach;
epilog
	delete theFolder;
end;</source>
        <Parameter name="pAllDriveNames" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="listDrives" id="11a0f174-bb21-4b79-a8ee-2134f2f93eba">
        <source>listDrives();
// --------------------------------------------------------------------------------
// Created:		25 June 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allDriveLetters	: StringArray;
	driveLetter		: String;
	
begin
	write "&lt;&lt;&lt; Local Disk Drives &gt;&gt;&gt;";
	
	create allDriveLetters transient;
	
	self.fetchDrives(allDriveLetters);
	
	foreach driveLetter in allDriveLetters do
		write "Drive " &amp; driveLetter &amp; " exists.";
	endforeach;
	
	write CrLf &amp; "&lt;&lt;&lt; Server Disk Drives &gt;&gt;&gt;";
	
	allDriveLetters.purge();
	self.listServerDrives(allDriveLetters);
	
	foreach driveLetter in allDriveLetters do
		write "Drive " &amp; driveLetter &amp; " exists.";
	endforeach;
epilog
	delete allDriveLetters;
end;</source>
    </JadeMethod>
    <JadeMethod name="listServerDrives" id="e2090d84-bf91-4935-87e6-4446d941e93d">
        <executionLocation>server</executionLocation>
        <source>listServerDrives(pAllDriveLetters:StringArray io) serverExecution;
// --------------------------------------------------------------------------------
// Created:		16 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.fetchDrives(pAllDriveLetters);
end;</source>
        <Parameter name="pAllDriveLetters" type="StringArray" usage="io"/>
    </JadeMethod>
</Class>
