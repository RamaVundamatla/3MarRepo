    <JadeMethod name="addPropToTable" id="fa397dc3-a3fd-4ecd-80d8-06c0245e0137">
        <source>addPropToTable(_prop : String);
// ---------------------------------------------------------------------------
// Created:     05 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	voyage : CM_Voyage;
	vv : String;
begin		
	if _prop = "productCode" then
		self.tbl_Display.addItem(app.getErrorString(Product) &amp; Tab &amp; self.myTI.getDisplayStringForAttribute(_prop, false));
	elseif _prop = "cargoTypeDescr" then
		self.tbl_Display.addItem("Cargo Type" &amp; Tab &amp; self.myTI.getDisplayStringForAttribute(_prop, false));
	elseif _prop = "locationId" and self.myTI.locationId &lt;&gt; null then
		self.tbl_Display.addItem("Location" &amp; Tab &amp; self.myTI.getDisplayStringForAttribute(_prop, false));
	elseif _prop = "bookingReference" and self.myTI.bookingReference &lt;&gt; null then
		self.tbl_Display.addItem("Booking Reference" &amp; Tab &amp; self.myTI.getDisplayStringForAttribute(_prop, false));
	elseif _prop = "voyageCode" then
		voyage := self.myTI.myVoyage;
		if voyage &lt;&gt; null then
			if voyage.vesselName &lt;&gt; null then
				vv := voyage.vesselName.trimBlanks &amp;  " - (" &amp; voyage.code.trimBlanks &amp; ")" ;
			else
				vv := voyage.code.trimBlanks;	
			endif;
		endif;
		self.tbl_Display.addItem("Voyage" &amp; Tab &amp; vv);
	elseif _prop = "mark" /*and self.myTI.mark &lt;&gt; null*/ then
		self.tbl_Display.addItem("Marks" &amp; Tab &amp; self.myTI.getDisplayStringForAttribute(_prop, false));
	elseif _prop = "weight" then
		//if self.myTI.weight &gt; 0 then						//-cnwml2 MSL CCMS 1017
		if self.myTI.totalWeight &gt; 0 then					//+cnwml2 MSL CCMS 1017
			self.tbl_Display.addItem("Weight" &amp; Tab &amp; self.myTI.getDisplayStringForAttribute('totalWeight', false));
        //elseif self.myTI.myProduct &lt;&gt; null and self.myTI.myProduct.myWeight.value &gt; 0 then // cnwrd1 ccms 1060 changes to cm_product for imp measurements
		elseif self.myTI.myProduct &lt;&gt; null and self.myTI.myProduct.getWeightValue() &gt; 0 then
			self.tbl_Display.addItem("Weight" &amp; Tab &amp; self.myTI.myProduct.getDisplayStringForAttribute('myWeight', false));
		endif;
	elseif _prop = "length" then
		if self.myTI.length &gt; 0 then
			self.tbl_Display.addItem("Length" &amp; Tab &amp; self.myTI.getDisplayStringForAttribute(_prop, false));
        //elseif self.myTI.myProduct &lt;&gt; null and self.myTI.myProduct.myLength.value &gt; 0 then  // cnwrd1 ccms 1060 changes to cm_product for imp measurements
		elseif self.myTI.myProduct &lt;&gt; null and self.myTI.myProduct.getLengthValue() &gt; 0 then
			self.tbl_Display.addItem("Length" &amp; Tab &amp; self.myTI.myProduct.getDisplayStringForAttribute('myLength', false));
		endif;
	elseif _prop = "height" then
		if self.myTI.height &gt; 0 then
			self.tbl_Display.addItem("Height" &amp; Tab &amp; self.myTI.getDisplayStringForAttribute(_prop, false));
        //elseif self.myTI.myProduct &lt;&gt; null and self.myTI.myProduct.myHeight.value &gt; 0 then// cnwrd1 ccms 1060 changes to cm_product for imp measurements
		elseif self.myTI.myProduct &lt;&gt; null and self.myTI.myProduct.getHeightValue() &gt; 0 then
		 
			self.tbl_Display.addItem("Height" &amp; Tab &amp; self.myTI.myProduct.getDisplayStringForAttribute('myHeight', false));
		endif;
	endif;
end;</source>
        <Parameter name="_prop" type="String"/>
    </JadeMethod>
    <JadeMethod name="btn_Cancel_click" id="d7db495a-ccfe-455b-84c3-5ca1471b509b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btn_Cancel_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer	:=	Busy;
	self.doCloseForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
