    <JadeMethod name="getMyActiveEDIData" id="c2902f7e-1138-4333-aaba-c6a1e61a4ea2">
        <updating/>
        <source>getMyActiveEDIData(): CM_EDIData updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest
28 Jun 2024 navhn30 Bug 64799: EUP - FR 53824 - UHE 1090 When Processing a Transport Manifest EDI 
*/

vars
	ediData : CM_EDIData;
begin
	if self.myCargoOnSite &lt;&gt; null then
		ediData := self.myCargoOnSite;
	elseif self.myTrainConsist &lt;&gt; null then
		ediData := self.myTrainConsist;
	elseif self.myGateDocument &lt;&gt; null then
		ediData := self.myGateDocument;
	elseif self.myShipManifest &lt;&gt; null then
		ediData := self.myShipManifest;
	endif;
	if ediData = null then
		if self.type.toUpper = TRANSPORT_TYPE_CARGOONSITE or
		   self.type.toUpper = TRANSPORT_TYPE_INTERNAL or
		   self.type.toUpper.startsWith(TRANSPORT_TYPE_CARGO) then		// 28.06.24		navhn30 	TFS #64799 
			if self.isTransient then
				create self.myCargoOnSite transient;
				ediData := self.myCargoOnSite;
			else
				create self.myCargoOnSite persistent;
				ediData := self.myCargoOnSite;
			endif;
		elseif self.type.toUpper = TRANSPORT_TYPE_GATEDOCUMENT or
		   self.type.toUpper = TRANSPORT_TYPE_VEHICLE or
		   self.type.toUpper = TRANSPORT_TYPE_ROAD or
		   self.type.toUpper.startsWith(TRANSPORT_TYPE_VEHICLE) or
		   self.type.toUpper.startsWith(TRANSPORT_TYPE_ROAD) then		// 28.06.24		navhn30 	TFS #64799
			if self.isTransient then
				create self.myGateDocument transient;
				ediData := self.myGateDocument;
			else
				create self.myGateDocument persistent;
				ediData := self.myGateDocument;
			endif;
		elseif self.type.toUpper = TRANSPORT_TYPE_SHIPMANIFEST or
		   self.type.toUpper = TRANSPORT_TYPE_SHIP or
		   self.type.toUpper = TRANSPORT_TYPE_SEA or
		   self.type.toUpper.startsWith(TRANSPORT_TYPE_SHIP) or		// 28.06.24		navhn30 	TFS #64799
		   self.type.toUpper.startsWith(TRANSPORT_TYPE_SEA) then
			if self.isTransient then
				create self.myShipManifest transient;
				ediData := self.myShipManifest;
			else
				create self.myShipManifest persistent;
				ediData := self.myShipManifest;
			endif;
		elseif self.type.toUpper = TRANSPORT_TYPE_TRAINMANIFEST or
		   self.type.toUpper = TRANSPORT_TYPE_TRAIN or
		   self.type.toUpper = TRANSPORT_TYPE_RAIL or
		   self.type.toUpper.startsWith(TRANSPORT_TYPE_RAIL) or		// 28.06.24		navhn30 	TFS #64799
		   self.type.toUpper.startsWith(TRANSPORT_TYPE_TRAIN)then
			if self.isTransient then
				create self.myTrainConsist transient;
				ediData := self.myTrainConsist;
			else
				create self.myTrainConsist persistent;
				ediData := self.myTrainConsist;
			endif;
		endif;
	endif;
	if ediData = null then
		return self;
	endif;
	return ediData;
epilog

end;</source>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefNames" id="a8bab876-1310-49eb-a4b9-57ef410a1dc9">
        <source>getMyTIDisplayDefNames(_names: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
