    <JadeMethod name="doPrint" id="29193875-b724-4627-aebe-6e7d6d14ae95">
        <source>doPrint();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	tmpJadeReport : JadeReport;
begin
	create tmpJadeReport transient;
	tmpJadeReport.description := "Report";
	app.printer.setReport(tmpJadeReport);
	app.printer.documentType := Print_A4;
	app.printer.printPreview:=true;
	app.printer.print(self.frame1);
	
	app.printer.close;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawFilledSquare" id="de23f7aa-98fb-415a-900b-87cc7918db32">
        <source>drawFilledSquare(_pattern : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	points : RealArray;
begin
	self.frame1.clearGraphics;
	self.frame1.autoRedraw:=true;
	self.frame1.drawFillColor:=Blue;
	self.frame1.drawFillStyle:=_pattern;
	create points transient;
	points.add(50);
	points.add(50);
	
	points.add(100);
	points.add(50);
	
	points.add(100);
	points.add(100);
	
	points.add(50);
	points.add(100);
	self.frame1.drawFilledPolygon( points, Black);
	
epilog

end;</source>
        <Parameter name="_pattern" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="4dbe9ea9-5dce-4ce1-ad8d-6383441b187b">
