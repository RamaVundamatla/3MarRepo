    <JadeMethod name="btn0_click" id="41757a9f-46e2-4d3d-943d-191be39bc397">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btn0_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		25 July 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	app.beep();
	self.doKeyboardInput(J_key_0.Character);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
