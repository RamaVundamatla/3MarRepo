    <JadeMethod name="doGateOutTruck" id="7086d667-f72e-49dc-b77c-84b1e039b8d4">
        <source>doGateOutTruck():Boolean;
/*

Purpose:

Parameters:

Return Value:

Date		Who		Reason
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
*/
vars
	theVehicle : CM_Vehicle;
	theRoadJob : CM_RoadJob;
	jobNumber  : String;
	alertCreated : Boolean;
begin
	if not app.myCurrentUserCan(self.myTerminal, PmGteRoadExitUpdate) then
		app.msgBox("You do not have permission to perform this task", "Road Exit", MsgBox_OK_Only);
		return false;
	endif;
	if self.myRoadJob &lt;&gt; null then
		theRoadJob := self.myRoadJob;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "No road job for this form");
		return false;
	endif;
	//app.myTrxDA.trxRoadExit(theRoadJob, app.myPassport);		//16.02.2024 navnk30 #62414
	app.myTrxDA.trxRoadExit(theRoadJob, null, app.myPassport);	//16.02.2024 navnk30 #62414
	
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Road Receipt Jobs', null, self);
		return false;
	endif;

	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogOnMobile" id="d4bbb9ae-e5e5-4077-b50c-30f5cdec9a58">
        <updating/>
        <source>doLogOnMobile(_userName: String; _password: String; _errorString : String output): Boolean updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	rtnValue,
	result		: Integer;
	user		: CM_User;
	passport 	: CM_Passport;
begin
	result := app.validateUserPassword(_userName, _password);
	if result = 0 then
		user := app.myRoot.allUsers[_userName];
		if not user.canDo(null, Mod_WebApps) then
			app.msgBox(app.getErrorString1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps)),
							"", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
							return false;
		endif;
	else
		_errorString := app.getErrorString(result);
	endif;
	
	if result &lt;&gt; 0 then
	// dh 4/4/2008 - for now we are ignoring the case where a password has expired, as this
	// 				check has been omitted fro the other RT apps, and RS suggests we leave it for now.
		if result &lt;&gt; Err_Password_Expired then
			app.msgBox(_errorString , "", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
			return false;
		endif;
	endif;
	
	passport := app.myPassport;
	rtnValue := app.myTrxRT.trxLogon(self, strClientConnectionDetails, false, passport);
	if not app.myPassport.trxCompletedOK then
		
		return false;
	endif;
	
	writeUserNameToIniFile(_userName);

	return true;
end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveCMIFs" id="6e92cdd0-2ccd-453f-a5a5-3a53027efbcd">
        <updating/>
        <source>doSaveCMIFs(_selectedCMIFs: CMIF_Array; _id : String io):Boolean updating;
/*
	Created on 20 May 2009
	
	by cnwdz2
	
	Purpose: ccms1801
*/

vars
	
begin
	if _selectedCMIFs.size &gt; 0 then
		app.myTrxUA.trxHandleGenCargo(self.myRoadJob, _selectedCMIFs, app.myPassport, _id);
	else
		app.myTrxUA.trxHandleGenCargo(self.myRoadJob, self.allCMIFs, app.myPassport, _id);
	endif;
	if app.myPassport.trxCompletedOK then
		return true;
	endif;
	return false;
end;</source>
        <Parameter name="_selectedCMIFs" type="CMIF_Array"/>
        <Parameter name="_id" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findAndVerifyLocation" id="3b0997aa-0018-4399-9629-c8cd4648b940">
        <source>findAndVerifyLocation(loc : String):CM_LocationsController;
/*
	Created on 15 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	location : CM_LocationsController;
begin
	location := self.findLocationByID(loc);

	if location = null then
		app.msgBox("This is not a valid location","Location Error",MsgBox_OK_Only);
		return null;
	endif;
	
	return location;
end;</source>
        <Parameter name="loc" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="findCargoOnRoadJob" id="35ec7892-3bf9-4874-8889-19bb5f12a537">
        <source>findCargoOnRoadJob(_id : String): CM_TrackedItem;
/*
	Created on 30 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	wle 		: CM_WorkListEntry;
	ti 			: CM_TrackedItem;
begin
	if self.myRoadJob = null then
		return null;
	endif;
	foreach wle in self.myRoadJob.workListEntries do
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		ti := wle.myTrackedItem;
		if ti &lt;&gt; null and ti.id.toUpper = _id.toUpper then
			return ti;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findLocationByID" id="745be65d-7936-4398-9918-0f767a9acf13">
        <source>findLocationByID(loc : String) : CM_LocationsController;
/*
	Created on 15 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	foundLoc 	: CM_LocationsController;
	foundHt 	: Integer;
begin
	myTerminal.findLocationFromString(loc, false, foundLoc, foundHt);
	return foundLoc;
end;</source>
        <Parameter name="loc" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="findOnsiteCargoByID" id="e2a82d5f-53c5-4b5e-97ce-16548c118942">
        <source>findOnsiteCargoByID(_cargoID : String) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     18 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTI 		: CM_TrackedItem;
	cargoType 	: Integer;
	prenote 	: CM_TrackedItem;
	result 		: Integer;
begin
	
	tmpTI := self.myTerminal.allOnsiteTIsByIdCargoType.lookupTIUsingIdCargoType(_cargoID, null);
	if tmpTI &lt;&gt; null and tmpTI.id = _cargoID then
		return tmpTI;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_cargoID" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findOrCreateMasterPack" id="e6828d08-e76e-4b43-af22-dd550cc91c7b">
        <source>findOrCreateMasterPack(_id : String; _cargoType : CM_CargoType; _weight : Integer): CM_TrackedItem;

vars
	ti 		: CM_TrackedItem;
	pxyTI 	: CM_BreakBulkGeneric;
begin
	ti := self.myTerminal.allOnsiteTIsByIdCargoType.lookupTIUsingIdCargoType(_id, _cargoType.id);
	if ti = null or ti.id &lt;&gt; _id or ti.cargoType &lt;&gt; _cargoType.id then
		// create a proxy masterpack and return it
		create pxyTI transient;
		pxyTI.zSetPxyId(_id);
		pxyTI.setCargoType(_cargoType.id);
		pxyTI.setPropertyValue('weight', _weight);
		return pxyTI;
	else
		return ti;
	endif;
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_weight" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findOrCreateRoadJob" id="b3b99e38-7705-4616-8594-b485b6a684a6">
        <updating/>
        <source>findOrCreateRoadJob(truckID : String): CM_RoadJob updating;
/*
	Created on 04 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/
/*

Date		Who		Reason
22 Jan 2018	jlgkpd1	TFS 36660 - Locking issues at Penn
	
*/

vars
	roadJob 		: CM_RoadJob;
	term 			: CM_Terminal;
	truck 			: CM_Vehicle;

begin
	if truckID = null then
		app.msgBox("Truck ID must be entered", 'Truck ID Error', MsgBox_OK_Cancel);
		return null;
	endif;	
	term := self.myTerminal;
	truck := term.vehicles[truckID, ""];
	if truck = null then
		app.msgBox("This vehicle is not recognised by the system." &amp; CrLf &amp; "Please re-enter, or send the truck back to the Gate", 'Truck Error', MsgBox_OK_Only);
		return null;
	elseif truck.isNotAvailableForEntry then
		app.msgBox(app.getErrorString(NotAvailableForEntry), app.getErrorString(Vehicle) &amp; ' (' &amp; truckID &amp; ') ', MsgBox_OK_Only);
		return null;
	endif;
	
	// TFS 36660 - Use inversed collection on Vehicle for performance
	roadJob := truck.allRoadJobs.first().CM_RoadJob;
	if roadJob &lt;&gt; null then
		return roadJob;
	endif;
	
	// if we get this far, no road job exists, so error, or create one 
	if roadJob = null and (not term.getConfig(GateAllowUngatedTrucks).Boolean) then
		app.msgBox("This truck has not been gated in. Please send it back to the gate.", app.getErrorString(Vehicle) &amp; ' (' &amp; truckID &amp; ') ', MsgBox_OK_Only);
		return null;
	endif;
	self.createDefaultRoadJob(roadJob, truck);
	if not app.myPassport.trxCompletedOK then
		return null;
	endif;
	return roadJob;
	
epilog

end;</source>
        <Parameter name="truckID" type="String"/>
        <ReturnType type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="findPrenoteByID" id="f4ae9898-4af5-477d-9423-1f4a0f903dce">
        <source>findPrenoteByID(_cargoID : String) : CM_TrackedItem;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	// copied and modified from code on the prenote form
	Purpose:
*/

vars
	tmpTI 		: CM_TrackedItem;
	cargoType 	: Integer;
	prenote 	: CM_TrackedItem;
	result 		: Integer;
begin
	cargoType := TI_CargoType_Null;
	tmpTI := self.myTerminal.lookupPrenoteByIDExact(_cargoID);

	return tmpTI;
end;</source>
        <Parameter name="_cargoID" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="gateOutTruck" id="46b91708-8ce9-4406-bd6e-2234cb398442">
        <source>gateOutTruck():Boolean;
/*
	Created on 08 May 2008
	
	by Debby Hutchison
	
	Purpose:
	
	16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
*/

vars
	theVehicle : CM_Vehicle;
	theRoadJob : CM_RoadJob;
	jobNumber  : String;
	alertCreated : Boolean;
begin
	if not app.myCurrentUserCan(self.myTerminal, PmGteRoadExitUpdate) then
		app.msgBox("You do not have permission to perform this task", "Road Exit", MsgBox_OK_Only);
		return false;
	endif;
	if self.myRoadJob &lt;&gt; null then
		theRoadJob := self.myRoadJob;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "No road job for this form");
		return false;
	endif;
	if theRoadJob.allReleaseTrackedItems.size &gt; 0 then
		app.msgBox("This truck has cargo to be released, so you cannot complete it here.", "Road Exit", MsgBox_OK_Only);
		return false;
	endif;
	//app.myTrxDA.trxRoadExit(theRoadJob, app.myPassport);		//16.02.2024 navnk30 #62414
	app.myTrxDA.trxRoadExit(theRoadJob, null, app.myPassport);	//16.02.2024 navnk30 #62414
	
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Road Receipt Jobs', null, self);
		return false;
	endif;
	
	return true;
epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDefaultLocationForTI" id="3db805b2-81bd-438a-b185-b42ff2f15a16">
        <source>getDefaultLocationForTI(ti : CM_TrackedItem):CM_LocationsController;
/*
	Created on 15 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	loc : CM_LocationsController;
begin
	if ti.plannedLocnId &lt;&gt; null then
		loc := self.findLocationByID(ti.plannedLocnId);
	endif;
	if loc &lt;&gt; null then
		return loc;
	else
		return app.autoPlanTiYATest(myTerminal, null, ti, false);  // PAR 19412
	endif;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLoadCount" id="66e4305a-ad04-4599-b887-90aaa626a37e">
        <source>getLoadCount(): Integer;
/*
	Created on 22 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	count : Integer;
	ti : CM_TrackedItem;
	cmif : CMIF_TIGenCargo;
	cmifObj : CMIF_Object;
	tiArray : ObjectArray;
begin
	count := allCMIFs.size;
	if myRoadJob &lt;&gt; null then
		create tiArray transient;
		foreach cmifObj in allCMIFs do
			cmif := cmifObj.CMIF_TIGenCargo;
			if cmif.myTrackedItem &lt;&gt; null then
				tiArray.add(cmif.myTrackedItem);
			endif;
		endforeach;
		foreach ti in myRoadJob.allReceiveTrackedItems 
		where ti.myPrimaryActualLocation = null 
		or not ti.myPrimaryActualLocation.isKindOf(CM_VehicleController) do
		// to avoid counting gated-in items still on the truck
			if not tiArray.includes(ti) then
				count := count + 1;
			endif;
		endforeach;
	endif;
	return count;
epilog
	delete tiArray;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMeasureConvertedForDisplay" id="0dd1de99-8852-4c05-a9c1-e99c5efe2e6b">
        <source>getMeasureConvertedForDisplay( _product : CM_Product; _type : String; _measureValue : Decimal) : String;

/*

Purpose:			
//cnwrd1 ccms 1321 imperial measurements
Parameters:			

Return Value:		


Date		Who		Reason
15/03/2013	cnwrd1	Initial creation
06/09/2013	NDL	Par 32413
13/05/2014	cnwdap1	PAR #34120 Correct measureType test
*/

vars
	measureType : CM_MeasurementType;	
begin

	//05 Sep 2013	NDL	Par 32413
	if _product &lt;&gt; null and _type &lt;&gt; null then
		measureType := _product.getDefaultMeasurementForType(_type);
	endif;
	
	//if measureType &lt;&gt; null then									// PAR #34120
	if measureType = null then										// PAR #34120
		measureType := app.getDefaultMeasurementForType(_type);
	endif;
	
	if measureType = null then
		//return _measureValue.asStringWeightJMT();
		return _measureValue.asStringJMT();	//25 Oct 2013	NDL	Par 32720
	else
		return app.convertMeasurementForDisplay(measureType.shortName, _measureValue);
	endif;
epilog

end;
	</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_measureValue" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasureConvertedForStorage" id="aadeff1a-4fe8-45e3-a0ca-fe34015556d4">
        <source>getMeasureConvertedForStorage(_product : CM_Product; _type : String; _decimalAsString : String):  Decimal;


/*

Purpose: //cnwrd1 ccms 1321 imperial measurements			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2013	cnwrd1	Initial creation
06 Sep 2013	NDL	Par 32413

*/

vars
	measureType : CM_MeasurementType;	
begin

	//05 Sep 2013	NDL	Par 32413
	if _product &lt;&gt; null and _type &lt;&gt; null then
		measureType := _product.getDefaultMeasurementForType(_type);
	endif;
	
	if measureType &lt;&gt; null then
		measureType := app.getDefaultMeasurementForType(_type);
	endif;		

	if measureType = null then
		return _decimalAsString.trimBlanks.Decimal;
	else
		return app.convertMeasurementForStorage(measureType.shortName,_decimalAsString.Decimal);
	endif;

epilog

end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_decimalAsString" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMeasureLabelUnit" id="34539c8f-6025-4075-b226-c07e60de1e51">
        <source>getMeasureLabelUnit( _product : CM_Product; _type : String ): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2013	cnwrd1	Initial creation
06 Sep 2013	NDL	Par 32413

*/

vars
	result : String;
	measureType : CM_MeasurementType;	
begin

	//05 Sep 2013	NDL	Par 32413
	if _product &lt;&gt; null and _type &lt;&gt; null then
		measureType := _product.getDefaultMeasurementForType(_type);
	endif;
	if measureType = null then
		measureType := app.getDefaultMeasurementForType(_type);
	endif;

	if measureType = null then
		result := null ;
	else
		result :=  Left_Round_Bracket &amp; measureType.shortName &amp; Right_Round_Bracket;	
	endif;

	return result;
	
epilog

end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_type" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPackReleaseById" id="904e9b7b-878c-49d7-bce1-bd56934f0b64">
        <source>getPackReleaseById(_id : String): CM_BulkRelease ;
/*
	Created on 14 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	rel : CM_BulkRelease;
begin
	rel := self.myTerminal.allBulkReleaseByTypeByStByCd.getAtKeyGeq(BR_TYPE_PACKING, BR_ACTIVE, _id, null);

	if rel &lt;&gt; null and rel.code = _id then
		return rel;
	else
		return null;	
	endif;
end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getSingleBookingRefForJob" id="6e0a4167-a726-4937-acc4-c28c1bf6fcc9">
        <source>getSingleBookingRefForJob(_job : CM_RoadJob):CM_BookingRef;

vars
	ti : CM_TrackedItem;
	cmif : CMIF_Object;
	tmpBR,
	tiBR : CM_BookingRef;
begin
	if _job = null then
		return null;
	endif;

	foreach ti in _job.allReceiveTrackedItems do
		if ti.myBookingRef &lt;&gt; null then
			if tmpBR = null then
				tmpBR := ti.myBookingRef;
			elseif tmpBR &lt;&gt; ti.myBookingRef then // more than one br on the road job
				return null;  // there are several brs on this job
			endif;
		endif;
	endforeach;
	foreach cmif in self.allCMIFs do
		ti := cmif.CMIF_TIGenCargo.getTrackedItem;
		if ti = null then 
			continue;
		endif;
		if ti.myBookingRef = null then
			if ti.bookingReference &lt;&gt; null then
				tiBR := self.myTerminal.getBookingReference(ti.operatorCode, ti.bookingReference.trimRight, ti.myVoyage); // adm 150908 Par 17936
			endif;
		else
			tiBR := ti.myBookingRef;
		endif;	
		if tmpBR = null then
			tmpBR := tiBR;
		elseif tmpBR &lt;&gt; tiBR then // more than one br on the road job
			return null;  // there are several brs on this job
		endif;
	endforeach;
	return tmpBR;
end;
</source>
        <Parameter name="_job" type="CM_RoadJob"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getWLEForTI" id="93857396-6dd5-43ca-9dbf-2f3084257726">
        <source>getWLEForTI(_job : CM_RoadJob ; _ti : CM_TrackedItem):CM_WorkListEntry;

vars
	wle : CM_WorkListEntry;
begin
	foreach wle in _job.workListEntries do
		if wle.myTrackedItem = _ti then
			return wle;
		endif;
	endforeach;
	return null;
end;
</source>
        <Parameter name="_job" type="CM_RoadJob"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="moveTrackedItem" id="5d63ff40-d77a-430a-8176-a3d666a7eb09">
        <source>moveTrackedItem(_ti : CM_TrackedItem; _location : CM_LocationsController; _roadJob : CM_RoadJob);
/*
	Created on 21 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	tmpMoveController : CMIF_MoveController;
begin
	create tmpMoveController transient;

	tmpMoveController.setMoveMode(Real_Mode);
	tmpMoveController.setMyToPrimaryLocation(_location);
	tmpMoveController.setMyTrackedItem(_ti);
	tmpMoveController.setJobForMove(_roadJob);

	app.myUtilityUA.utlUpdateMoveTrackedItem(tmpMoveController, app.myPassport);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="recalculateLoadCounts" id="c06d42d0-8054-4db0-b35a-a0e265bc6825">
        <source>recalculateLoadCounts();
/*
	Created on 22 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmif 		: CMIF_Object;
	cmifTI 		: CMIF_TIGenCargo;
	itemNumber, 
	load,
	items		: Integer;
begin
	load := getLoadCount;
	items := allCMIFs.size;
	foreach itemNumber in items to 1 step -1 do
		cmif := self.allCMIFs[itemNumber];
		if cmif.isKindOf(CMIF_TIGenCargo) then
			cmif.CMIF_TIGenCargo.setLoadCount(load);
			load := load - 1; 
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeCMIF" id="6599c85b-3d99-4524-b2f3-6006a30e50c9">
        <source>removeCMIF(_cmif : CMIF_Object io);
/*
	Created on 14 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if allCMIFs.includes(_cmif) then
		allCMIFs.remove(_cmif);
		delete _cmif;
	endif;
end;</source>
        <Parameter name="_cmif" type="CMIF_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setClientConnectionDetails" id="1b26bd29-c558-4cd0-a674-c96fc948e3c2">
        <updating/>
        <source>setClientConnectionDetails(_warnings : Boolean io):Boolean updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	iniFileName : String;
	device : CM_RadioTelemetryDevice;
begin
	iniFileName 			:= app.getIniFileName();
	self.strTerminalName	:= app.getProfileString(iniFileName, RTIniFileSection, MOB_TerminalName, null);
	self.strDevice			:= app.getProfileString(iniFileName, RTIniFileSection, MOB_DeviceName, null);
	if self.strDevice = null then
		device := 	app.getRTDeviceForSelf(app.computerName);
		if device &lt;&gt; null then
			self.strDevice := device.id;
			self.strTerminalName := device.myRadioTelemetry.myTerminal.code;
		endif;
	endif;
	// cnwdad1 21/04/2008 - Moved the following test here so that I get told that my INI settings are
	// missing before we try to find the Terminal &amp; Device, otherwise all I get is the exception to say
	// that the Terminal is not valid!
	if self.strTerminalName = null or self.strDevice = null then
		self.showMessage('Ini file [RadioTelemetry] section has not been configured correctly:' &amp; CrLf &amp;
		'[RadioTelemetry]' &amp; CrLf &amp;
		'RTTerminal= ' &amp; CrLf &amp; 
		'RTDeviceID= ', true, _warnings);
		self.strClientConnectionDetails := null;
		return false;
	endif;
	self.myTerminal		:= app.myRoot.allTerminals[self.strTerminalName];
	if self.myTerminal = null then
		self.showMessage(app.getErrorString(ERR_TerminalCode_Invalid) &amp; '(' &amp; self.strTerminalName &amp; ')',true, _warnings);
		return false;
	endif;
	app.myPassport.setMyTerminal(self.myTerminal);
	self.strClientConnectionDetails := self.strDevice &amp; ':' &amp; self.strTerminalName &amp; ':' &amp; app.computerName() &amp; ':1010';
	return true;
end;
</source>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="e71f7938-363d-4f08-82d5-5909046bcfbc">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwer1	Initial creation

*/

vars

begin
	self.myTerminal:=_terminal;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setup" id="7cc3c02b-e673-45d9-a30d-d5f265aeb57e">
        <updating/>
        <source>setup()updating;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

	iniFileName : String;
	strTerminalName : String;
	term : CM_Terminal;
	
begin 

//	self.myTerminal := app.getMyTerminalDO_NOT_USE;

	// 27 Apr 2010	NDL	- ( during fix of Par 23902 ) updated to use the ini file setting if possible...
	iniFileName := app.getIniFileName();
	app.writeLog("Inifilename: " &amp; iniFileName, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	if iniFileName &lt;&gt; null then
		strTerminalName := app.getProfileString(iniFileName, RTIniFileSection, MOB_TerminalName, null);
		app.writeLog("strTerminalName: " &amp; strTerminalName, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		if strTerminalName &lt;&gt; null then
			term := app.myRoot.allTerminals[strTerminalName];
			app.writeLog("term: " &amp; term.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			if term &lt;&gt; null then
				self.myTerminal :=  term;
				return;
			endif;
		endif;
	endif;
	
	// last resort...
	app.writeLog("getMyTerminalDO_NOT_USE: " &amp; app.getMyTerminalDO_NOT_USE.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	self.myTerminal :=  app.getMyTerminalDO_NOT_USE;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupRoadJob" id="6f0ff7f5-d43e-48f1-b99d-d22efe477c16">
        <updating/>
        <source>setupRoadJob(roadJob: CM_RoadJob; _strDevice : String) updating;
/*
	Created on 21 April 2008
	
	by Debby Hutchison
	
