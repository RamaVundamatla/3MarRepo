    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="fc504272-1815-4773-9907-1c42b808ca13">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	pxy : CM_NotifiedCargoGroup;
	completedOK : Boolean;
	iter : Iterator;
	obj : Object;
	cargoId : String;

begin

	pxy := inheritMethod();
	
	pxy.myCargoType := self.myCargoType;
	pxy.myOperator := self.myOperator;
	pxy.myTerminal := self.myTerminal;
	
	pxy.myCargoGroupAssignment := self.myCargoGroupAssignment;
	
	if not self.allPreAssignedCargoIdsDict.isEmpty then
		iter := self.allPreAssignedCargoIdsDict.createIterator;
		while iter.next( obj ) do
			cargoId := iter.getCurrentKey( 1 ).String;
			if cargoId &lt;&gt; null then
				pxy.allPreAssignedCargoIds.add( cargoId );
			endif;
		endwhile;
	endif;
	
	completedOK := true;
	return pxy;

epilog

	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDefaultLocation" id="f900755b-0e8f-4c12-a6e5-2bbff05377aa">
        <updating/>
        <source>setDefaultLocation(_location : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/01/2018	jlgdap1		Initial creation TFS 36658 STWR Cargo Scanning Enhancements
//
vars

begin
	if self.defaultLocation &lt;&gt; _location then
		self.defaultLocation := _location;
	endif;
epilog

end;</source>
        <Parameter name="_location" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6f452d22-2337-4232-ab7a-2a6efad5b907">
        <updating/>
        <source>setForCreate(	_pxyNotifiedCargo : CM_NotifiedCargoGroup;
				_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/07/2015	cnwndl1	Initial creation	Par 36608
16/01/2018	jlgdap1	TFS 36658 STWR Cargo Scanning Enhancement
*/

vars

begin
	// default minWeight and maxWeight							// TFS 36658
	self.minWeight := null;										// TFS 36658
	self.maxWeight := 99999999;									// TFS 36658
	
	self.id := _pxyNotifiedCargo.id;
	
	self.setForUpdate(_pxyNotifiedCargo, _passport );
	
	self.myCargoGroupAssignment := _pxyNotifiedCargo.myCargoGroupAssignment;

	self.myTerminal := _pxyNotifiedCargo.myTerminal;			// TFS 36658
	if self.myCargoGroupAssignment &lt;&gt; null then					// TFS 36658
		self.createCargoGroup(self.id, _passport);				// TFS 36658
	endif;														// TFS 36658
	
epilog

end;</source>
        <Parameter name="_pxyNotifiedCargo" type="CM_NotifiedCargoGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="aa48750f-da15-49b6-afd8-881716ccdaf8">
        <updating/>
        <source>setForUpdate(	_pxyNotifiedCargo : CM_NotifiedCargoGroup;
				_passport : CM_Passport input) updating;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	pxyCargoId : String;

begin

	
	self.defaultLocation := _pxyNotifiedCargo.defaultLocation;
	self.remarks := _pxyNotifiedCargo.remarks;	//21 Sep 2015	NDL	Par 36338
	self.minWeight := _pxyNotifiedCargo.minWeight;
	self.maxWeight := _pxyNotifiedCargo.maxWeight;
	self.myCargoType := _pxyNotifiedCargo.myCargoType;
	self.myOperator := _pxyNotifiedCargo.myOperator;
	
	self.allPreAssignedCargoIds.clear();
//	_pxyNotifiedCargo.allPreAssignedCargoIds.copy(self.allPreAssignedCargoIds);
	self.allPreAssignedCargoIds.purge();
	
	foreach pxyCargoId in _pxyNotifiedCargo.allPreAssignedCargoIds do
		allPreAssignedCargoIdsDict.putAtKey(pxyCargoId, self); // the object doesn't matter.
	endforeach;

epilog

end;</source>
        <Parameter name="_pxyNotifiedCargo" type="CM_NotifiedCargoGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoGroupAssignment" id="546485e9-d0f3-49be-907c-7427df8fd636">
        <updating/>
        <source>setMyCargoGroupAssignment( _myCargoGroupAssignment : CM_CargoGroupAssignment ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	self.myCargoGroupAssignment := _myCargoGroupAssignment;

epilog

end;</source>
        <Parameter name="_myCargoGroupAssignment" type="CM_CargoGroupAssignment"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="63953411-d713-41a3-8cbc-d969a204d697">
        <updating/>
        <source>setProxy(	_id : String;
			_defaultLocation : String;
			_remarks : String;	//21 Sep 2015	NDL	Par 36338
			_minWeight : Decimal;
			_maxWeight : Decimal;
			_myCargoType : CM_CargoType;
			_myOperator : CM_Operator;
			_allPreAssigned : StringArray;
			_myCgAssign : CM_CargoGroupAssignment
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/07/2015	cnwndl1	Initial creation	Par 36608
16/01/2018	jlgdap1	TFS 36658 STWR Cargo Scanning Enhancement
*/

vars

begin

	self.id := _id;
	self.defaultLocation := _defaultLocation;
	self.remarks := _remarks;	//21 Sep 2015	NDL	Par 36338
	self.minWeight := _minWeight;
	self.maxWeight := _maxWeight;
	self.myCargoType := _myCargoType;
	self.myOperator := _myOperator;
	
	self.allPreAssignedCargoIds.clear();
	_allPreAssigned.copy( self.allPreAssignedCargoIds );
	
	self.myCargoGroupAssignment := _myCgAssign;
	self.myTerminal := _myCgAssign.myTerminal;					// TFS 36658

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_defaultLocation" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_minWeight" type="Decimal"/>
        <Parameter name="_maxWeight" type="Decimal"/>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_myOperator" type="CM_Operator"/>
        <Parameter name="_allPreAssigned" type="StringArray"/>
        <Parameter name="_myCgAssign" type="CM_CargoGroupAssignment"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="98c380d6-6843-4ba0-b0f8-2de9d2b8b618">
        <source>validateMe(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	if self.myCargoGroupAssignment.myTerminal = null then
		app.raiseCMException( Select_Terminal, self.id, null );
		return;
	endif;

	if self.myCargoType = null then
		app.raiseCMException1( Requires_cargo_type, self.id, null, null );
		return;
	elseif not self.myCargoType.isCargoGroup then
		app.raiseCMException2( Cargo_type_selec_not_defin_car, self.myCargoType.description, self.id, null, null );
		return;
	endif;
	
	if id = null then
		app.raiseCMException( ERR_INVALID_TI_ID, null, null );
		return;
	endif;
	
	if self.myOperator = null then
		app.raiseCMException( Please_select_operator, null, null );
		return;
	endif;
	

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
