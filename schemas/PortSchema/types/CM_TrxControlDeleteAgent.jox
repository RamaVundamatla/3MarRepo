    <JadeMethod name="trxDeleteStopForBOLsBulk" id="50c60e3f-1b9d-40f9-bb24-2dd95f8d5403">
        <updating/>
        <source>trxDeleteStopForBOLsBulk(_bolSet : CM_BOLSet; _stopTable : CM_StopsTable; _theCENumber : String; _passport : CM_Passport input) updating;
//---------------------------------------
// Created: May 2006 By: cnwgd1
//---------------------------------------
vars
	bol	: CM_BOL;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	foreach bol in _bolSet do
		reserveLock(bol);//only I can upgrade to exclusive from this point on, but others can get share
	endforeach;
	
	app.myUtilityDA.utlDeleteStopBOLsBulk(_bolSet, _stopTable, _theCENumber, _passport);	
 
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_bolSet" type="CM_BOLSet"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_theCENumber" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
