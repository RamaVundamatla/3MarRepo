        <source>setPXYFromBooking(_booking: CM_BookingRefItem) updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
