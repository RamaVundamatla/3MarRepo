    <JadeMethod name="processDDTurnaround" id="b23d30b4-e73b-4f84-a57d-376a4076794e">
        <source>processDDTurnaround() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	ddCompletedTargetWle : CM_WorkListEntry;

begin

	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	if self.myTrackedItem = null then
		return;
	endif;

	if not self.myTrackedItem.isCompletedDD( ddCompletedTargetWle ) then
		return;
	endif;
	
	if ddCompletedTargetWle = null or ddCompletedTargetWle.locationTarget = null then
		return;
	endif;
	

	//	if self.myToPrimaryLocation.getFullId = ddCompletedTargetWle.locationTarget or self.myToPrimaryLocation.getStowageId(self.myTrackedItem) = ddCompletedTargetWle.locationTarget then
	if self.myToPrimaryLocation = null	//05 Nov 2014	NDL	Par 35166
	or self.myToPrimaryLocation.getFullId = ddCompletedTargetWle.locationTarget
	or self.myToPrimaryLocation.getStowageId(self.myTrackedItem) = ddCompletedTargetWle.locationTarget
	then
		return;
	endif;
	
	// OK we have a direct delivery cargo item that is already in its DD target location
	// But is now being moved somewhere else. (presumably turned around)
	// We need to make sure that IF the original target was a truck that the item is removed from
	// the trucks associated VVR and Release request.
	
	if ddCompletedTargetWle.job = self.myTrackedItem.jobRoadRelease then
		
		ddCompletedTargetWle.unassignTI();
		
	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="rotatableContainerPostMove" id="dfe218b9-5580-4a5c-ace1-f0d40eea1f85">
        <updating/>
        <source>rotatableContainerPostMove(_passport : CM_Passport input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2025	jlier1	Initial creation 36155
10 Nov 2025 jlier1	MTN-36536 	
*/

vars
	tmpLocn,priorLC : CM_LocationsController;
	plannedToGCArea : Boolean;
	moveController : CMIF_MoveController;
	lastReleaseTrx : CM_ReleaseShip;
	wle : CM_WorkListEntry;
	undoMode : Integer;
begin

	if self.myRotatableContainer = null then
		return;
	endif;

	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	
	wle:=self.myRotatableContainer.getVoyageWLEUnactioned(true);
	
	if wle &lt;&gt; null and wle.getMyVoyageObject = self.myToPrimaryLocation.CM_VoyageController.myVoyage then
		if wle.myFutureMove.isKindOf(CM_FutureMoveQueued)  then
			undoMode:=QUEUE_MODE;
		elseif wle.myFutureMove.isKindOf(CM_FutureMovePlanned) then
			undoMode:=PLANNING_MODE;
		endif;
		
		if undoMode = QUEUE_MODE or undoMode = PLANNING_MODE then
			self.myRotatableContainer.undoMove(undoMode,_passport);
			if app.myPassport.noErrors then
				//these should both be invalid after the undo
				self.myWorkListEntry:=null;
				self.jobForMove:=null;
			endif;
		endif;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	

	tmpLocn := app.autoPlanJobTiYA(self.myRotatableContainer.myTerminal, null ,null,null, self.myRotatableContainer, null, false, null, plannedToGCArea);	
	create moveController transient;
	moveController.setMyTrackedItem(self.myRotatableContainer);
	priorLC:= self.myRotatableContainer.getPriorLocationLC;
	if priorLC &lt;&gt; null and priorLC.isMachineController then
		//get an autoplan location
		//If we get an planned location - queue it
		//location is on a machine - in either crane or work point interchange
		if tmpLocn &lt;&gt; null then
			moveController.setMoveMode(QUEUE_MODE);
			moveController.setMyToPrimaryLocation(tmpLocn);
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		endif;
	else
		//auto plan
		//move it back to yard or where was orginally
		moveController.setMoveMode(REAL_MODE);
		if tmpLocn &lt;&gt; null then
			moveController.setMyToPrimaryLocation(tmpLocn);
		else
			moveController.setMyToPrimaryLocation(priorLC);
		endif;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		
		//if we got errors queueing or moving then don't stop the whole move especially the real move above
		if _passport.hasErrors then
			_passport.clearErrorsWarnings;
		endif;
	endif;
	
	
	
	//finally get the last released ship transaction - hopefully all the trx have been created by this point
	
	//update it with the myRotableContainer ID
	lastReleaseTrx:=self.myTrackedItem.getLastTransOfType(TRANS_TYPE_REL_SHIP).CM_ReleaseShip;
	if lastReleaseTrx &lt;&gt; null then
		lastReleaseTrx.setLocationYard(self.myRotatableContainer.id);
	endif;
	
epilog
	delete moveController;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
