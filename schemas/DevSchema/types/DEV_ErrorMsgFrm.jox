    <JadeMethod name="btnNext_click" id="51369eac-28e5-426b-995d-297cf91a48f1">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNext_click(btn: Button input) updating;

vars

begin
	tblData.selected := false;
	
	if tblData.row = tblData.rows then
		tblData.row := 1;
	else
		tblData.row := tblData.row + 1;
	endif;		
		
	if self.findText then
		tblData.setFocus;
	endif;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
