<Class name="CM_Offload" id="cb7db828-a066-43f3-8383-54d23e8da4e6">
    <superclass name="CM_LogVoyageTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <JadeMethod name="getDisplayString" id="ea2559fa-d9f7-4934-bcc5-613f3c19fc3d">
        <source>getDisplayString(): String;
// ---------------------------------------------------------------------------
// Created:     02 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpVoy	: CM_Voyage;
	cloneTI	: CM_TrackedItem;
	str		: String;
begin

	if self.myTrackedItem &lt;&gt; null then
		cloneTI := self.myTrackedItem.myMoveCloneToTI;
		if cloneTI &lt;&gt; null then
			str := cloneTI.myTerminal.name;
		else
			str := '&lt;unknown&gt;';
		endif;
	endif;
	
	tmpVoy := self.myVoyage;
	if tmpVoy &lt;&gt; null then
		return 'From voyage ' &amp; self.myVoyage.code &amp; ' to terminal ' &amp; str &amp; '.';
	else
		return 'From unknown voyage to terminal ' &amp; str &amp; '.';
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0d85edbf-230d-4678-bb81-5ffaf02ae055">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			return self.getDisplayString;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="b6b7f037-8d56-438c-ad5d-f8dde9e11863">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:     02 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;
begin
	str := inheritMethod();
	
	str := str &amp; self.getDisplayString;
	
	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
