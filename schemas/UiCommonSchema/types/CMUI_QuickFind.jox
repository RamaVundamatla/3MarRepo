        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2014	cnwndl1	Initial creation

*/

vars

begin

	app.instrumentFormUsage( self );	//25 Feb 2014 NDL	Par 33587

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="openForm" id="26aa3061-c881-4d60-9f80-e5992372aee7">
        <source>openForm( _restrictSearchTo : String; _text : String ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
23 January 2014	cnwndl1		Initial creation	Par 33350
08 Apr 2025 	naviv1		MTN-34407 - MTN | Remove old Windows CE based Handheld and Vehicle apps from Quick Find
*/

vars

	menuAction : CMUI_MenuAction;
	baseForm : CM_BaseForm;
	tmpDevice : CM_RadioTelemetryDevice;
	baseObj : CM_Object;
	baseText : String;
	machine : CM_Machine;
	rtDevice : CM_RadioTelemetryDevice;
	spacePos : Integer;
	keyText : String;
	quickAccess : CM_QuickAccess;
	user : CM_User;
	vssForm : CMUI_VehicleBookingDayView;
	hideHHandVM	: Boolean;
begin

	// to add standard forms, add the permission to "buildQuickAccessFormsHelp" method, and to "PortSchema::PortSchemaRelease::createSystemQuickAccessObjects"

	baseObj := null;
	baseText := null;
	user := app.getMyUser; 
	hideHHandVM  := app.myRoot.getConfig(HideAccessHHandVMApps).Boolean; //JIRA-34407
	
	spacePos := _text.pos(" ",1);
	if spacePos &gt; 1 then
		keyText := _text[1:spacePos].trimBlanks;
		baseText := _text[spacePos:end].trimBlanks;
	else
		keyText := _text;
	endif;
	
	if keyText = self.USER then
		self.showUserPref( user );
		return true;
	endif;
	
	quickAccess := self.getQuickAccess(keyText,0);	
	
	if quickAccess = null or hideHHandVM then
		self.buildQuickAccessFormsHelp( _restrictSearchTo, _text );
		return true;
	else
		if quickAccess.isForm then
			if quickAccess.permissionInteger = PmGteVehSchView then
				//does not have a menu item
				if not self.myTerminal.isVehicleBookingEnabled then
					return false;
				endif;
				
				if _restrictSearchTo = "X" then
					vssForm := app.getForm(CMUI_VehicleBookingDayView.name).CMUI_VehicleBookingDayView;
				endif;
				if vssForm &lt;&gt; null and vssForm.myTerminal = self.myTerminal then
					vssForm.windowState := vssForm.WindowState_Normal;
					vssForm.zOrder(1);
					return true;
				endif;
				if vssForm = null or vssForm.myTerminal &lt;&gt; self.myTerminal then
					vssForm := app.loadForm(CMUI_VehicleBookingDayView, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingDayView;
				endif;
				if vssForm &lt;&gt; null then
					vssForm.show;
					return true;
				endif;
				return false;
			
			else
				//to open new forms that have menus items
				menuAction := quickAccess.getMenuAction(self.myTerminal);
				if not quickAccess.allowsOption then
					baseText := null;
				endif;
				
				if menuAction &lt;&gt; null then
					if _restrictSearchTo = "X" and baseText = null then
						//try opening an existing one.
						baseForm := app.getForm( menuAction.myMenuDtl.windowClassName ).CM_BaseForm;
						if baseForm &lt;&gt; null then
							baseForm.windowState := vssForm.WindowState_Normal;
							baseForm.zOrder(1);
							return true;
						endif;
					endif;
					
					baseForm := menuAction.goToObject(null, null, false, null).CM_BaseForm;
					if baseForm &lt;&gt; null then
						baseForm.show();
						baseForm.setFromQuickFind(baseObj,baseText);
						return true;
					endif;
				endif;
			endif;
			
		else
			if not hideHHandVM then //JIRA-34407 --&gt; added this check
				//to open Hand Held App variants
				if quickAccess.permissionInteger = PmAdmHandHeldLogonAs then	
					foreach tmpDevice in self.myTerminal.radioTelemetry.allRTDevices discreteLock do
						if tmpDevice.isKindOf(CM_RTDeviceHandHeld) then
							app.startApplicationWithParameter('MobileUISchema', 'HandHeldWithDevApp', tmpDevice);
							return true;
						endif;
					endforeach;
					
				elseif quickAccess.permissionInteger = PmAdmVehicleRTLogonAs then
					if baseText &lt;&gt; null then
						machine := self.myTerminal.machines[baseText];
						if machine &lt;&gt; null then
							rtDevice := machine.myRTDevice;
						endif;
					endif;
					
					if rtDevice &lt;&gt; null and app.getMyUser.canDo( self.myTerminal, PmAdmVehicleRTLogonAs ) then
						rtDevice.startAppFor();
						return true;
					endif;
					
				endif;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_restrictSearchTo" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="openPrintForm" id="76d4a30b-0e8c-4a50-8c95-1f2eb93528c7">
        <source>openPrintForm( _text : String ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2014	cnwndl1	Initial creation

*/


vars

	menuAction : CMUI_MenuAction;
	baseForm : CM_BaseForm;
	helpStr : String;

begin


	menuAction := app.myController.createMenuAction(PmReportRunnerView, null, null, self.myTerminal);
	
	if menuAction &lt;&gt; null then
		baseForm := menuAction.goToObject(null, null, false, null).CM_BaseForm;
		if baseForm &lt;&gt; null then
			baseForm.show();
			baseForm.setFromQuickFind( null, _text );
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
