        <source>valMachine(pExistingMachine,pProxyMachine:CM_Machine);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(pProxyMachine, 'Machine Proxy');
	self.raiseExceptionIfNull(pExistingMachine, "Machine Existing");
	pProxyMachine.raiseExceptionIfNotProxy(method);
	if pExistingMachine.id = pProxyMachine.id then
		pProxyMachine.validateForUpdate;
	else
