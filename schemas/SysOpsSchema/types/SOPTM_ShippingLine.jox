    <JadeMethod name="doDelete" id="fe2b648b-f0d3-4257-9320-8d87857c2cd6">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.myTrxDA.trxDeleteShippingLine(pObj.CM_ShippingLine, app.myPassport);

end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
