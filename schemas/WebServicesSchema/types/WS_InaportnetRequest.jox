    <JadeMethod name="doUpdateVoyageStatus" id="a309f723-260e-476c-9b83-942539287c23">
        <source>doUpdateVoyageStatus(_voyage : CM_Voyage input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2018	jlger1	Initial creation

*/

vars
	nextVoyStatus : CM_VoyageStatus;
begin
	if _voyage = null then
		return;
	endif;
	
	nextVoyStatus := self.getOutgoingVoyageStatus( _voyage );
	if nextVoyStatus = null then
		return;
	endif;
	
		app.myPassport.setWarningsIgnored(true);
	
		app.myTrxUA.trxUpdateVoyageVoyageStatus(_voyage,nextVoyStatus.id,true,app.myPassport);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBerth" id="49f6e27c-607d-46d2-87ae-8be1a57df9bb">
        <source>getBerth( _rawValue : String ):HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	term : CM_Terminal;
	harbour : HMS_Harbour;
	berth : HMS_Berth;

begin

	term := app.myPassport.myTerminal;
	
	harbour := term.myHarbour;
	if harbour &lt;&gt; null then
		//berth := harbour.allBerths.getAtKey( _rawValue );
		foreach berth in harbour.allBerths discreteLock do
			if berth.externalReference2 = _rawValue or
				berth.code=_rawValue then
				return berth;
			endif;
		endforeach;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_rawValue" type="String"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
