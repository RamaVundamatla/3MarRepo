<Class name="CnEcDateRange" id="3b8d7e68-2890-4c00-b4b7-d6167c57092a">
    <superclass name="CnEcValueRange"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
