    <JadeMethod name="getPageHeight" id="8d0bd3fa-0865-404f-90df-670dea1307ee">
        <source>getPageHeight(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

begin

	if app.isDevelopmentSystem and app.printer.getPrinterName[1:5].toUpper &lt;&gt; "EPSON" then
		return inheritMethod();
	endif;

	return 1400;	//	140.0 mm

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="makeLabelsAvailable" id="3f3f2dea-e35b-4c47-ab1b-8b0b14e9ddf5">
        <source>makeLabelsAvailable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

begin

	self.allLabelsArray.add( self.lblA );
	self.allLabelsArray.add( self.lblB );
	self.allLabelsArray.add( self.lblC );
	self.allLabelsArray.add( self.lblD );
	self.allLabelsArray.add( self.lblE );
	self.allLabelsArray.add( self.lblF );
	self.allLabelsArray.add( self.lblG );
	self.allLabelsArray.add( self.lblH );
	self.allLabelsArray.add( self.lblI );
	self.allLabelsArray.add( self.lblJ );
	self.allLabelsArray.add( self.lblK );
	self.allLabelsArray.add( self.lblL );
	self.allLabelsArray.add( self.lblM );
	self.allLabelsArray.add( self.lblN );
	self.allLabelsArray.add( self.lblO );
	self.allLabelsArray.add( self.lblP );
	
	self.lblA.alignment := Label.Alignment_Right_Top;
	self.lblB.alignment := Label.Alignment_Right_Top;
	self.lblC.alignment := Label.Alignment_Right_Top;
	self.lblD.alignment := Label.Alignment_Left_Top;
	self.lblE.alignment := Label.Alignment_Left_Top;
	self.lblF.alignment := Label.Alignment_Left_Top;
	self.lblG.alignment := Label.Alignment_Left_Top;
	self.lblH.alignment := Label.Alignment_Left_Top;
	self.lblI.alignment := Label.Alignment_Left_Top;
	self.lblJ.alignment := Label.Alignment_Left_Top;
	self.lblK.alignment := Label.Alignment_Left_Top;
	self.lblL.alignment := Label.Alignment_Left_Top;
	self.lblM.alignment := Label.Alignment_Left_Top;
	self.lblN.alignment := Label.Alignment_Left_Top;
	self.lblO.alignment := Label.Alignment_Left_Top;
	self.lblP.alignment := Label.Alignment_Left_Top;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateLineUp" id="a75ff789-ddc3-49ec-9370-9ba04c8d0823">
        <updating/>
        <source>populateLineUp(): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	xxString : String;
	repDetails : String;

begin

	repDetails := inheritMethod();
	
	xxString := self.lblD.caption;	
	self.lblD.caption := "XX  '" &amp; repDetails &amp; "'  " &amp; xxString;
	
	return repDetails;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="repositionLabels" id="ce8e8017-6f33-457f-a610-e49febde2547">
        <source>repositionLabels() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation		Par 30901

*/

vars

	topMMs : Real;
	leftMMs : Real;
	rightMMs : Real;
	bottomMMs : Real;

begin
	
	topMMs := 12;
	bottomMMs := 17;
	leftMMs := 8;	rightMMs := 40;	self.moveLabel( self.lblA, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 18;
	bottomMMs := 23;
	leftMMs := 8;	rightMMs := 40;	self.moveLabel( self.lblB, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 29;
	bottomMMs := 34;
	leftMMs := 60;	rightMMs := 106;	self.moveLabel( self.lblC, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 55;
	bottomMMs := 60;
	leftMMs := 8;	rightMMs := 165;	self.moveLabel( self.lblD, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 62;
	bottomMMs := 67;
	leftMMs := 8;	rightMMs := 88;	self.moveLabel( self.lblJ, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 103;	rightMMs := 178;	self.moveLabel( self.lblE, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 68;
	bottomMMs := 73;
	leftMMs := 8;	rightMMs := 85;	self.moveLabel( self.lblK, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 103;	rightMMs := 178;	self.moveLabel( self.lblF, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 75;
	bottomMMs := 80;
	leftMMs := 8;	rightMMs := 88;	self.moveLabel( self.lblL, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 103;	rightMMs := 176;	self.moveLabel( self.lblG, topMMs, leftMMs, rightMMs, bottomMMs );

	topMMs := 82;
	bottomMMs := 87;
	leftMMs := 8;	rightMMs := 73;	self.moveLabel( self.lblM, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 103;	rightMMs := 178;	self.moveLabel( self.lblH, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 88;
	bottomMMs := 93;
	leftMMs := 8;	rightMMs := 74;	self.moveLabel( self.lblN, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 103;	rightMMs := 181;	self.moveLabel( self.lblI, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 105;
	bottomMMs := 124;
	leftMMs := 103;	rightMMs := 192;	self.moveLabel( self.lblO, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 112;
	bottomMMs := 117;
	leftMMs := 8;	rightMMs := 86;	self.moveLabel( self.lblP, topMMs, leftMMs, rightMMs, bottomMMs );
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDataFieldsFromObject" id="2b86fdf9-e3cb-450e-8046-9b92b29bb9dc">
        <updating/>
        <source>setDataFieldsFromObject(_obj: CM_Object; _lineUp: Boolean; _showLabelArea: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

begin

	if _showLabelArea then
		//app.printer.print( self.testFrame );
		self.printLabelFieldAreaBoundary();	//21 July 2014	NDL Par 34611
	endif;
		
	if _lineUp then
		self.populateLineUp();
		return;
			
	elseif _obj &lt;&gt; null then
	
		self.myPopulatingObject := _obj;	//31 Jan 2014	NDL	Par 33181
	
		if _obj.isKindOf( CM_DutyDocCarItem ) then
			self.setFromDutyDocCar( _obj.CM_DutyDocCarItem );
		else
			self.populateLineUp();
		endif;
	
		return;
		
	endif;
	
	inheritMethod( _obj, _lineUp, _showLabelArea );

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_lineUp" type="Boolean"/>
        <Parameter name="_showLabelArea" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromDutyDocCar" id="462b37e7-7b81-4563-89c5-892326c094a7">
        <updating/>
        <source>setFromDutyDocCar( _dutyDocCarItem : CM_DutyDocCarItem ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

begin

	self.lblA.caption := _dutyDocCarItem.vccNo;
	self.lblB.caption := _dutyDocCarItem.vccDate.shortFormatJMT;
	self.lblC.caption := "Ajman";//_dutyDocCarItem.;
	self.lblD.caption := _dutyDocCarItem.vehicleType &amp; " " &amp; _dutyDocCarItem.vehicleMake;
	self.lblE.caption := _dutyDocCarItem.vehicleModel;
	self.lblF.caption := _dutyDocCarItem.origin;
	self.lblG.caption := _dutyDocCarItem.chassisNo;
	self.lblH.caption := _dutyDocCarItem.engineNo;
	self.lblI.caption := _dutyDocCarItem.color;
//	self.lblJ.caption := _dutyDocCarItem.;
//	self.lblK.caption := _dutyDocCarItem.;
//	self.lblL.caption := _dutyDocCarItem.;
	self.lblM.caption := _dutyDocCarItem.consignee;
//	self.lblN.caption := _dutyDocCarItem.;
	self.lblO.caption := _dutyDocCarItem.cargoDetails; 				// remarks
	self.lblP.caption := _dutyDocCarItem.numberPlate;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dutyDocCarItem" type="CM_DutyDocCarItem"/>
    </JadeMethod>
</GUIClass>
