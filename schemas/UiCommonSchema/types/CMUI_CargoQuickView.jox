    <JadeMethod name="toolbarShowCaptions" id="5665eb05-e0b1-4676-a1ac-7be172371718">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//
//
// ---------------------------------------------------------------------------
// Created:     20 Jan 2017	by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date			Who		Reason
20 Jan 2017		cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
30/05/2025		navlw1	JIRA-34824: MTN | Quick Cargo Review UI Refactor
*/

vars
	newHeight : Real;
begin
	
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	// only need to move the main frame as it contains all the controls
	self.frmMain.move(0, newHeight, self.clientWidth, self.clientHeight - newHeight);
	
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a49d8f9e-30b9-44ab-b964-185c531c5b9a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 November 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007295, locale);
	btnEdit.translateCaption(Xlat_0004993, locale);
	btnPrint.translateCaption(Xlat_0004994, locale);
	btnPrintList.translateCaption(Xlat_0004995, locale);
	btnSearch.translateCaption(Xlat_0004996, locale);
	btnView.translateCaption(Xlat_0004997, locale);
	chkArchivedVoy.translateCaption(Xlat_0004998, locale);
	chkCheckAccess.translateCaption(Xlat_0004999, locale);
	chkPartialMatch.translateCaption(Xlat_0005000, locale);
	frmMain.translateCaption(Xlat_0005001, locale);
	lblAdvanced.translateCaption(Xlat_0005002, locale);
	lblCargoID.translateCaption(Xlat_0005003, locale);
	lblCargoType.translateCaption(Xlat_0005004, locale);
	lblSearchInstns.translateCaption(Xlat_0005005, locale);
	mnuCargoTaskAdd.translateCaption(Xlat_0021048, locale);
	mnuCargoTaskComplete.translateCaption(Xlat_0021049, locale);
	mnuCargoTaskRemarks.translateCaption(Xlat_0021050, locale);
	mnuCargoTaskRemove.translateCaption(Xlat_0021051, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0007296, locale);
	mnuContext.translateCaption(Xlat_0007297, locale);
	mnuEdit.translateCaption(Xlat_0007298, locale);
	mnuRequestTask.translateCaption(Xlat_0009120, locale);
