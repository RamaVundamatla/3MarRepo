<Class name="CM_StockOrderLineAlloc" id="50fcf028-1f23-474e-9a58-ea731da8a2a2">
    <superclass name="CM_StockOrderAllocation"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stkOrd"/>
    <ExplicitInverseRef name="myStockOrderLine" id="ca9f6960-3e17-4f02-925e-95412fd9f719">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_StockOrderProductLine"/>
        <access>readonly</access>
        <Inverse name="CM_StockOrderProductLine::allStockAllocations"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myStockOrderSummaryAlloc" id="b345f27b-ff5a-439c-aeb6-a45a4994d1a0">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_StockOrderSummaryAlloc"/>
        <access>readonly</access>
        <Inverse name="CM_StockOrderSummaryAlloc::allStockOrderLineAllocations"/>
