    <JadeMethod name="getCurrentTaskTI" id="e210d993-2832-4674-9e0b-9d4eb98b43e4">
        <source>getCurrentTaskTI(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2009	cnwer1	Initial creation

*/

vars
	ti : CM_TrackedItem;
begin

	
	ti:= inheritMethod();
	//is the container on a chassis
	if ti.isOnTrailer then
		return ti.myPrimaryActualLocation.CM_TILCController.myTILC;
	endif;
	
	return ti;

epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
