<Class name="CM_MenuUserToolbar" id="c02ee2e7-a0b3-420d-ba9e-e511f67f6467">
    <superclass name="CM_MenuUserItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmenu"/>
    <ExplicitInverseRef name="myMenuUserToolbarRoot" id="370e6064-6d0c-4ced-8a9c-0432fe6dbccf">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_MenuUserToolbarRoot"/>
        <access>readonly</access>
        <Inverse name="CM_MenuUserToolbarRoot::allMenuUserToolbarItems"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="mySystemToolbar" id="9cec13ca-d64d-4299-ac26-59d5fd42e700">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_MenuToolbar"/>
        <access>readonly</access>
        <Inverse name="CM_MenuToolbar::allUserToolbars"/>
    </ExplicitInverseRef>
    <JadeMethod name="setFromSystemToolbar" id="fa8cfebe-203a-41e3-9b93-cf388021191c">
        <updating/>
        <source>setFromSystemToolbar(_sysToolbar : CM_MenuToolbar) updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _sysToolbar = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'System toolbar object was null');
		return;
	endif;
	
	self.mySystemToolbar 			:= _sysToolbar;
	
	self.pictureStringButton 		:= _sysToolbar.pictureStringButton;
	self.pictureStringButtonDown	:= _sysToolbar.pictureStringButtonDown;
	self.pictureStringIcon	 		:= _sysToolbar.pictureStringIcon;
	
	self.heading					:= _sysToolbar.heading;
	self.toolTip					:= _sysToolbar.toolTip;
	
end;</source>
        <Parameter name="_sysToolbar" type="CM_MenuToolbar"/>
    </JadeMethod>
</Class>
