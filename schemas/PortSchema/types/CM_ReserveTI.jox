****************************************************/
begin
	self.myBOLDtl := bolDtl;
end;


</source>
        <Parameter name="bolDtl" type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b8f58c97-7131-4b2b-89b3-5f273b8e3b5f">
        <updating/>
        <source>setProxy(	_packType				: Integer;
			_bookRefItemObj			: CM_BookingRefItem;
			_bestPick 				: Boolean;
			_remarks				: String;
			_totalRequested			: Integer;
			_maxToRelease			: Integer;
			_myReceivalBOL			: CM_BOLIn;
			_totalWeight 			: Decimal;
			_sequence 				: String;
			_totalRequestedAllowed	: Integer;
			_myBOLDtl 				: CM_BOLDtl;	
			_deliveryParty 			: CM_DeliveryParty;
			_deliveryAddress 		: CM_Address;
			_deliveryInstructions 	: String;
			_deliveryFromDT 		: TimeStamp;
			_deliveryToDT  			: TimeStamp
			) updating;				// PAR #34058
// --------------------------------------------------------------------------------
// Created:		27 October 2010
//
/* Changes

Date		Name	TFS#			Description
============================================================================
			cnwdad1					Initial creation.
19/09/2012	cnwcs5	par 30390 - 	removed deliveryNumber, doorsDirection, consignee, consignorVoyageCode, 
										freightForwarderCode voyageCode from CM_ReserveDetail
										renamed removeStops to bestPick
05/05/2014	cnwdap1	PAR #34058 		Added _totalWeight parameter
09/09/2014	cnwrs1	CCMS 2351 		att Sequence to Release request 
24/01/2019	jlgka1	41708			Add _totalRequestedAllowed, _myBOLDtl.
13 Jan 2025	navhl20 CR MTN-33695: 	TPT | Release Request Delivery Party Info for Unique IDs
============================================================================*/
begin
	self.packType 					:= _packType;
	self.myBookingRefItem			:= _bookRefItemObj;
	self.remarks					:= _remarks;
	self.totalRequested 			:= _totalRequested;
	self.bestPick					:= _bestPick;					// par 30390 Sept 2012
	self.maxToRelease				:= _maxToRelease;
	self.myBOLIn 					:= _myReceivalBOL; 				// jlgka1 TFS 41708
	self.anyAmtAnyIdAllowedAmount	:= _totalRequestedAllowed;		// jlgka1 TFS 41708
	self.myBOLDtl					:= _myBOLDtl;					// jlgka1 TFS 41708
	
	self.weightRequested			:= _totalWeight;				// PAR #34058	
	//Start 13.01.2025 navhl20 #33695
	self.myDeliveryParty			:=_deliveryParty;
	self.myDeliveryAddress			:=_deliveryAddress;
	self.deliveryInstructions		:=_deliveryInstructions;
	self.deliveryFrom				:=_deliveryFromDT;
	self.deliveryTo					:=_deliveryToDT;
	//End 13.01.2025 navhl20 #33695
end;</source>
        <Parameter name="_packType" type="Integer"/>
        <Parameter name="_bookRefItemObj" type="CM_BookingRefItem"/>
        <Parameter name="_bestPick" type="Boolean"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_totalRequested" type="Integer"/>
        <Parameter name="_maxToRelease" type="Integer"/>
        <Parameter name="_myReceivalBOL" type="CM_BOLIn"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_sequence" type="String"/>
        <Parameter name="_totalRequestedAllowed" type="Integer"/>
        <Parameter name="_myBOLDtl" type="CM_BOLDtl"/>
        <Parameter name="_deliveryParty" type="CM_DeliveryParty"/>
        <Parameter name="_deliveryAddress" type="CM_Address"/>
        <Parameter name="_deliveryInstructions" type="String"/>
        <Parameter name="_deliveryFromDT" type="TimeStamp"/>
        <Parameter name="_deliveryToDT" type="TimeStamp"/>
    </JadeMethod>
