    <JadeMethod name="createSelf" id="246dd755-e5b0-4079-bfa5-ed675d995003">
        <updating/>
        <source>createSelf(_field :CM_XTABField)updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// add properties
	if _field.function = CM_XTABField.Function_Count then
		self.addProperty (self.Function_Count, Integer);
	elseif _field.function = CM_XTABField.Function_Sum then
		self.addProperty (self.Function_Sum, Decimal);
	elseif _field.function = CM_XTABField.Function_Average then
		self.addProperty (self.Function_Count, Integer);
		self.addProperty (self.Function_Sum, Decimal);
	elseif _field.function = CM_XTABField.Function_Max then
		self.addProperty (self.Function_Max, Decimal);
	elseif _field.function = CM_XTABField.Function_Min then
		self.addProperty (self.Function_Min, Decimal);
		// if we leave 'min' at zero we can't handle min values &gt; 0
		self.setPropertyValue (self.Function_Min, Max_Integer.Decimal);
	endif;
	
	// set hard-codeed property values
	self.function	:= _field.function;
	self.heading 	:= _field.getHeading;
	self.index		:= _field.getIndex;	
	self.decimals	:= _field.decimals;
epilog

end;</source>
        <Parameter name="_field" type="CM_XTABField"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="9e7410cf-ef18-47a9-b49e-b2d5535c6f10">
        <source>getValue():String;
// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	intValue	:Integer;
	decValue	:Decimal[23, 8];
begin
	if self.function = CM_XTABField.Function_Count then
		intValue := self.getPropertyValue (self.Function_Count).Integer;
		return intValue.String;
	elseif self.function = CM_XTABField.Function_Sum then
		decValue := self.getPropertyValue (self.Function_Sum).Decimal;
		
		return decValue.roundedTo (self.decimals).String;
	elseif self.function = CM_XTABField.Function_Average then
		intValue := self.getPropertyValue (self.Function_Count).Integer;
		decValue := self.getPropertyValue (self.Function_Sum).Decimal;
		
		return (decValue/intValue).roundedTo (self.decimals).String;	// to-do decimal places
	elseif self.function = CM_XTABField.Function_Max then
		decValue := self.getPropertyValue (self.Function_Max).Decimal;
		return decValue.roundedTo (self.decimals).String;
	elseif self.function = CM_XTABField.Function_Min then
		decValue := self.getPropertyValue (self.Function_Min).Decimal;
		return decValue.roundedTo (self.decimals).String;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateSelf" id="b09b939b-ddab-485d-9a25-aafd9953fc86">
        <updating/>
        <source>updateSelf(_value :Decimal)updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	intValue	:Integer;
	decValue	:Decimal[23, 8];
begin
	if self.function = CM_XTABField.Function_Count then
		intValue := self.getPropertyValue (self.Function_Count).Integer;
		self.setPropertyValue (self.Function_Count,intValue + 1);
		
	elseif self.function = CM_XTABField.Function_Sum then
		decValue := self.getPropertyValue (self.Function_Sum).Decimal;
		self.setPropertyValue (self.Function_Sum, decValue + _value.Decimal);
		
	elseif self.function = CM_XTABField.Function_Average then
		
		intValue := self.getPropertyValue (self.Function_Count).Integer;
		self.setPropertyValue (self.Function_Count,intValue + 1);
		
		decValue := self.getPropertyValue (self.Function_Sum).Decimal;
		self.setPropertyValue (self.Function_Sum, decValue + _value.Decimal);
		
	elseif self.function = CM_XTABField.Function_Max then
		decValue := self.getPropertyValue (self.Function_Max).Decimal;
		if _value &gt; decValue then
			self.setPropertyValue (self.Function_Max, _value);
		endif;
		
	elseif self.function = CM_XTABField.Function_Min then
		decValue := self.getPropertyValue (self.Function_Min).Decimal;
		if _value &lt; decValue then
			self.setPropertyValue (self.Function_Min, _value);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
</Class>
