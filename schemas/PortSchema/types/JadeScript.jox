    <JadeMethod name="rel842_Par37402" id="17ac6233-eab6-4a65-860f-2fb5d5f99d79">
        <source>rel842_Par37402();
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
vars
	etAgent : EntTableAgent;
//	array : StringArray;
	transAgent : CM_TranslationAgent;
	tmpArray : StringArray;
begin
	app.initialize();
	create etAgent transient;
	create tmpArray transient;

	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;

	tmpArray.add("ETRow_RequestDetailID");
	tmpArray.add("ETRow_CriteriaName");
	tmpArray.add("ETRow_CriteriaValue");
	tmpArray.add("ETRow_IsChild");
	tmpArray.add("ETDef_EDITIRequestHeader");
	tmpArray.add("ETDef_EDITIRequestDetail");
	tmpArray.add("ETDef_EDITIRequestCriteria");
	etAgent.trxUpdateFromConstant(tmpArray);
	
	create transAgent transient;
	tmpArray.clear;
	tmpArray.add('Request_header');
	tmpArray.add('Request_detail');
	tmpArray.add('Request_criteria');
	tmpArray.add('Request_multiline');
	transAgent.trxLoadSpecificErrors(tmpArray);
	return;
	
	write ETRow_RequestDetailID;
	write ETRow_CriteriaName;
	write ETRow_CriteriaValue;
	write ETRow_IsChild;
	write ETDef_EDITIRequestHeader;
	write ETDef_EDITIRequestDetail;
	write ETDef_EDITIRequestCriteria;
	write EDIDataType_RequestMultiLine;
	write EDIDataType_RequestHeader;
	write EDIDataType_RequestDetail;
	write EDIDataType_RequestCriteria;
	write Request_multiline.String;
	write Request_header.String;
	write Request_detail.String;
	write Request_criteria.String;
epilog
	delete etAgent;
	delete transAgent;
	delete tmpArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel842_par32883" id="02e234d1-82c1-471c-9d93-eaa804f7ed18">
        <source>rel842_par32883();
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	tmpArray : StringArray;
	etAgent	: EntTableAgent;
	transAgent 	: CM_TranslationAgent;
	newPerms : IntegerArray;
	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
begin
	app.initialize();
	create tmpArray transient;
	create etAgent transient;
	tmpArray.add('ETRow_Sender');
	tmpArray.add('ETRow_Recipient');
	tmpArray.add('ETRow_FileType');
	tmpArray.add('ETRow_FileVersion');
	tmpArray.add('ETRow_FileDateTime');
	tmpArray.add('ETRow_LastFileName');
	tmpArray.add('ETRow_SeqNumber');
	tmpArray.add('ETRow_ProcessInSeqOrder');
	tmpArray.add('ETRow_ProcessInDateOrder');
	tmpArray.add('ETDef_EDISenderRecip');
	tmpArray.add('ETGrp_EDISenderRecip');
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	etAgent.trxUpdateFromConstant(tmpArray);

	create transAgent transient;
	tmpArray.clear;
	tmpArray.add('Sender_recip_file_types');
	tmpArray.add('Sender_recip_file_history');
	tmpArray.add('Sender_recip_file_history1');
	tmpArray.add('Sender_recip_file_history2');
	tmpArray.add('Sequence_error');
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	create newPerms transient;
	newPerms.add(PmAdmEDISenderMaint);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, true);	//true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, false);	//true if system permission
	commitTransaction;
	delete newPerms;

return;

	write PmAdmEDISenderMaint;
	write Sender_recip_file_types;
	write Sender_recip_file_history;
	write Sender_recip_file_history1;
	write Sender_recip_file_history2;
	write ETRow_Sender;
	write ETRow_Recipient;
	write ETRow_FileType;
	write ETRow_FileVersion;
	write ETRow_FileDateTime;
	write ETRow_LastFileName;
	write ETRow_SeqNumber;
	write ETRow_ProcessInSeqOrder;
	write ETRow_ProcessInDateOrder;
	write ETDef_EDISenderRecip;
	write ETGrp_EDISenderRecip;
	write Sequence_error;
epilog
	delete tmpArray;
	delete etAgent;
	delete transAgent;
end;
</source>
    </JadeMethod>
