<Class name="SOPTM_DataAccessStevedore" id="4612e5c1-6dc5-4df8-a08a-187b9bf6f058">
    <superclass name="SOPTM_DataAccess"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="b0ebce5b-81f2-4ba4-ad9d-d4573c6de37e">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/05/2019	jlgdap1		Initial creation TFS 44554 Stevedore Data Access
//
vars

begin
	self.name := SOP_TableMaintForm.Table_DataAccessStevedores;
	self.permissionView	 := PmCmpDAStevedoreTableView;
	self.permissionMaint := PmCmpDAStevedoreTableMaint;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getMultiGroupHeading" id="204674ae-b46e-429a-8d7c-fd9356e20b5a">
        <source>getMultiGroupHeading(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars

begin
	return "Stevedores";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="dee7b9d0-d94b-419b-b4fa-9a11fe11e853">
        <source>setupThumbnailDetails();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	theForm : SOP_TableMaintForm;

begin
	theForm := self.myForm;
	
	theForm.setupForDataAccessController('Stevedores', 'displayEntryStevedore', CM_Stevedore);
    theForm.mulSelect1.setAvailable(app.myRoot.allStevedores, true);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="47281c02-86ac-4cef-9d8f-a10cdebe8e2b">
        <updating/>
        <source>showThumbnail(_dataAccess : CM_DataAccessController) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	theForm : SOP_TableMaintForm;

begin
	theForm := self.myForm;
	theForm.chkIncludeNotSet.visible := true;
	theForm.myDataAccessClass := CM_Stevedore;
	theForm.shtMultiSelect1.caption := "Stevedore";
	theForm.chkIncludeNotSet.value := _dataAccess.includeIfNull;

	theForm.txtName.text := _dataAccess.name;
	theForm.optAllow.value := (not _dataAccess.mustNotBeIncluded);
	theForm.optDisallow.value := _dataAccess.mustNotBeIncluded;
	theForm.setMSHeadingsForDataAccess();
	theForm.mulSelect1.setSelected(_dataAccess.allObjects);
	self.disableMulSelect1Contents();
epilog

end;</source>
        <Parameter name="_dataAccess" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="2a94c6af-ca55-4044-b6f5-aecc382ab9fc">
        <source>tblDataDisplayRow(table: Table input; obj: Object): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars

begin
	if obj.CM_DataAccessController.classContainedName = CM_Stevedore.name then
		return inheritMethod(table, obj);
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
