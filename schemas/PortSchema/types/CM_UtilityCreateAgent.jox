    <JadeMethod name="utlCreateVVRSecurityGate" id="53aaa74c-1b3e-4e21-a9fd-b93196a62558">
        <source>utlCreateVVRSecurityGate(	_proxyVVR : CM_VehicleVisitRecord;
							_realVVR : CM_VehicleVisitRecord output; 
							_batNumber : String;
							_passport : CM_Passport input	);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	// do validation
	_proxyVVR.validateForCreateSecurityGate(_batNumber, _passport);
	
	if _passport.hasErrorsIgnored() then
		return;
	endif;
	
	create _realVVR persistent;
	
	_realVVR.setForCreateFlexi(_proxyVVR, _batNumber);
	
	if _passport.noErrors() then
		// create notifications
		_realVVR.causeEvent(_realVVR.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, _realVVR);

		// ### TFS 51853 27AUG2021 NAVAB1
		if _passport.isOpsViewEnabled(_realVVR.myTerminal) then
			_realVVR.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_VVR, _realVVR);		
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxyVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="output"/>
        <Parameter name="_batNumber" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
