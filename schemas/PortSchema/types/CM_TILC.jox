    <JadeMethod name="hasChilledOnboardTIs" id="7efe501a-b026-40f8-9885-d301cc63072c">
        <source>hasChilledOnboardTIs() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
16 September 2024		jlizm1	Initial creation TFS 66095 Don't show non operational reefers in VOL

*/

vars
	tiSet 	: CM_TISet;
	ti 		: CM_TrackedItem;
	
begin
	create tiSet transient;
	self.getAllOnboardTIs(tiSet);
		
	foreach ti in tiSet discreteLock do
		if ti.isChilled then
			return true;
		endif;
	endforeach;

epilog
	delete tiSet;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasConnectedOnboardTIs" id="3c70488c-1713-4fa0-b4e2-7666e8bd96d5">
        <source>hasConnectedOnboardTIs() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
22 November 2023		jlizm1	Initial creation TFS 61275 Vehicle app display reefer and connected symbols for onboard cargo

*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;

begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
			if ti.isConnected then
				return true;
			endif;
		endforeach;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasGeneratorSetAttached" id="c95bb0ba-4868-4c94-832f-233046d95cce">
        <source>hasGeneratorSetAttached() : Boolean;
/* ---------------------------------------------------------------------------
Created:	01 September 2008	by cnwvu1

Purpose:	//Par 17775, ccms1045 - APM yard Ops- new generator types. September 2008
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.myGenerator &lt;&gt; null and self.myGenerator.isUnderSlung()	then
		return true;
	endif;

	return false;

end;</source>
