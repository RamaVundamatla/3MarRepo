    <JadeMethod name="shortFormatJMT" id="b0dc7170-be42-4a18-a72b-686ea6815f1e">
        <source>shortFormatJMT() : String;
// ---------------------------------------------------------------------------
// Created:     25 February 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Extra info: if format changes then you may have to change primitiveType String.convertToDate();
vars
//	yearStr		: String;
//	sep			: String;
//	str			: String;

begin

/*
	sep := app.currentLocaleInfo.dateInfo.separator;
	
	if app.currentLocaleInfo.dateInfo.showFullCentury then
		yearStr := 'yyyy';
	else
		yearStr := 'yy';
	endif;

	if app.currentLocaleInfo.dateInfo.shortFormatOrder = DateFormat.MonthDayYear then
		str := 'MM' &amp; sep &amp; 'dd' &amp; sep &amp; yearStr;
	elseif app.currentLocaleInfo.dateInfo.shortFormatOrder = DateFormat.DayMonthYear then
		str := 'dd' &amp; sep &amp; 'MM' &amp; sep &amp; yearStr;
	elseif app.currentLocaleInfo.dateInfo.shortFormatOrder = DateFormat.YearMonthDay then
		str := yearStr &amp; sep &amp; 'MM' &amp; sep &amp; 'dd';
	else
		// the default
		str := 'dd' &amp; sep &amp; 'MM' &amp; sep &amp; yearStr;
	endif;
*/
	if self.isValid() and self.year &gt; 1600 then
		return self.format(app.getDateShortFormat());
	else
		return null;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
