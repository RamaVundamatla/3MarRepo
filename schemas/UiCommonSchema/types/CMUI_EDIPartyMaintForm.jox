begin
	
	return app.myRoot.allToDoTaskDescsByShortDesc[_shortDesc];
	
/*	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions
		where toDoDesc.description.trimBlanks = _desc do
			return toDoDesc;
		break;
	endforeach;

	return null;*/

epilog

end;</source>
        <Parameter name="_shortDesc" type="String"/>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
