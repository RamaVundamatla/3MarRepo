    <JadeMethod name="comboBoxRORODeckItemType" id="18065cbb-fd7a-4ec1-ba6e-046bfe829470">
        <source>comboBoxRORODeckItemType(_cmb : CMUI_ComboBox input; _type : Integer);
/*

