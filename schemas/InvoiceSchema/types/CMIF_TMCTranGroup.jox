    <JadeMethod name="getRealMapObject" id="4171833c-f89c-4597-86af-e8d6aefd1a4b">
        <source>getRealMapObject(): Object;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myTranMapCargo &lt;&gt; null then
		return self.myTranMapCargo;
	elseif self.myTranMapVTMIS &lt;&gt; null then
		return self.myTranMapVTMIS;
	elseif self.myTranMapEvent &lt;&gt; null then
		return self.myTranMapEvent;
	elseif self.myTranMapWO &lt;&gt; null then // TFS 39236
		return self.myTranMapWO; // TFS 39236
	elseif self.myTranMapBOL &lt;&gt; null then //31 Oct 2019	NDL	TFS 47100
		return self.myTranMapBOL;	 //31 Oct 2019	NDL	TFS 47100
	elseif self.myTranMapSSSummary &lt;&gt; null then
		return self.myTranMapSSSummary;
	elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
		return self.myCurrentMapTMCargoAllocation; // PAR 35833
	elseif self.myTranMapInventory &lt;&gt; null then // ### TFS 51219 25MAY2021 NAVAB1
		return self.myTranMapInventory;  // ### TFS 51219 25MAY2021 NAVAB1
