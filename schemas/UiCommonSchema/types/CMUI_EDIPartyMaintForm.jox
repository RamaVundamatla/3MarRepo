    <JadeMethod name="addFrmLoadFileToolbar" id="71a4184e-4163-43d4-abe0-e450a5d52e59">
        <source>addFrmLoadFileToolbar();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2024	navsp1	Initial creation MTN-33228

*/

vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
begin
	toolbar 				:= self.frmLoadFileTool;
	toolbar.showCaptions 	:= showCaptions;	
		
	toolbar.addButton(self.btnHideLoadFile, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnLoadFile, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="79111d84-6b2c-4f7a-839f-dae11b2a6dd5">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2024	navsp1	Initial creation MTN-33228

*/

vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
begin
	inheritMethod();
	toolbar 				:= self.frmLoadFileTool;
	toolbar.showCaptions 	:= showCaptions;	
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnLoadFile, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
