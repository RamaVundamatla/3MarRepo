    <JadeMethod name="jobTypeString" id="44eda1d7-ca44-434e-af9d-6c066e563214">
        <methodInvocation>mapping</methodInvocation>
        <source>jobTypeString(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     25 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		return;// set code here
	else
		_value := null;
		if self.jobType = self.JobType_ChassisIN then
			_value :=  "Receive Chassis";
		elseif self.jobType = self.JobType_ChassisOut then
			_value := "Release Chassis";
		elseif self.jobType = self.JobType_EmptyIN then
			_value := "Receive Empty";
		elseif self.jobType = self.JobType_EmptyOUT then
			_value := "Release Empty";
		elseif self.jobType = self.JobType_FullIN then
			_value := "Receive Full";
		elseif self.jobType = self.JobType_FullOUT then
			_value := "Release Full";
		elseif self.jobType = self.JobType_GeneralIN then
			_value := "Receive General Cargo";
		elseif self.jobType = self.JobType_GeneralOUT then
			_value := "Release General Cargo";
		elseif self.jobType = self.JobType_VehicleDetails then
			_value := "Vehicle Details";		
		elseif self.jobType = self.JobType_ReceivalByType then
			_value := "Receival by Type";
		endif;
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="80d3a4b4-ceab-496d-b8fd-a0b00ceb0f1a">
        <source>pxyCreateUpdateProxy(): SelfType;
/* ---------------------------------------------------------------------------
Created:     06 May 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
07/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
15/05/2014	cnwdap1	PAR #34157 Handle possible error 4 for myBookingRefItem (not inversed)
------------------------------------------------------------------------------*/
vars
	pxyGTE, 		
	pxyGTESub,
	realGTESub 	: CMGTE_Entity;  
	completedOK		: Boolean;
	realDamageInstance,
	pxyDamageInstance : CM_DamageInstance;
	realAttachment,
	pxyAttachment 		: CM_Attachment;
	bookingItem			: CM_BookingRefItem;											// PAR #34157
	invalidItem			: Boolean;														// PAR #34157
	edition				: Integer;														// PAR #34157
begin

	pxyGTE := inheritMethod();
	
	self.allSourceTAs.copy(pxyGTE.allSourceTAs); //cnwrd1 par 24169 10.6.2010
	self.allSourceTAGridObjs.copy(pxyGTE.allSourceTAGridObjs);  //cnwrd1 par 28628 5.12.2011
	
	pxyGTE.myTerminal := self.myTerminal;
	pxyGTE.myVehicleVisitRecord := self.myVehicleVisitRecord;
	pxyGTE.myYardRequest := self.myYardRequest;
	pxyGTE.myTransferToTerminal := self.myTransferToTerminal;
	
	pxyGTE.myProduct := self.myProduct;								// PAR #33606	
	
	bookingItem := self.myBookingRefItem;												// PAR #34157
	if bookingItem &lt;&gt; null then															// PAR #34157
		on Exception do app.handleDeletedObject(exception, bookingItem, invalidItem);	// PAR #34157
		edition := bookingItem.edition;													// PAR #34157
		if invalidItem then																// PAR #34157
			bookingItem := null;														// PAR #34157
		endif;																			// PAR #34157
	endif;																				// PAR #34157
	pxyGTE.myBookingRefItem := bookingItem;												// PAR #34157
	
	// do not clone allErrorsAndWarnings as these are just added to

	foreach realGTESub in self.allChildren do
		if realGTESub.myVehicleVisitRecord &lt;&gt; null then
			continue;
		endif;
		pxyGTESub := realGTESub.pxyCreateUpdateProxy();
		pxyGTESub.setMyMasterObjectIfPxy(pxyGTE); // add to allSubItems 
	endforeach;
	
	//epr par 31845 29/10/13
	foreach realDamageInstance in self.allDamageInstancesByPos do
		pxyDamageInstance:= realDamageInstance.pxyCreateUpdateProxy();
		pxyDamageInstance.setMySubject(pxyGTE);
	endforeach;
	
	//epr par 31845 29/10/13	
	foreach realAttachment in self.allAttachments do
		pxyAttachment:= realAttachment.pxyCreateUpdateProxy();
		pxyAttachment.setMyGTEEntity(pxyGTE);
	endforeach;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyGTE;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyGTE;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="replaceSealCheckDetails" id="0b3de3c5-02d5-4573-9fbd-335081e26348">
        <updating/>
        <source>replaceSealCheckDetails( _sealCheckDetailSet : CM_SealCheckDetailSet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars

	real : CM_SealCheckDetail;
	proxy : CM_SealCheckDetail;

begin

	self.allSealCheckDetails.purge();
	
	if _sealCheckDetailSet &lt;&gt; null and not _sealCheckDetailSet.isEmpty then
		foreach proxy in _sealCheckDetailSet do
			create real persistent;
			real.setFromProxy( proxy );
			self.allSealCheckDetails.add( real );
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_sealCheckDetailSet" type="CM_SealCheckDetailSet"/>
    </JadeMethod>
    <JadeMethod name="requires1StopVehicleBooking" id="30d73785-3d65-43cf-9c34-124cbb4e9665">
        <source>requires1StopVehicleBooking() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/02/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
//
vars

begin
	if self.isKindOf(CMGTE_Container) and not self.CMGTE_Container.commodity = self.myTerminal.getConfig(EmptyCommodity).String
	and self.getMyVoyageObject &lt;&gt; null and not self.getMyVoyageObject.isNullVoyage and self.getMyVoyageObject.structureIncludesLOLO then
		return true;
	endif;
	
	if self.isKindOf(CMGTE_Release) and self.CMGTE_Release.myBulkRelease &lt;&gt; null and not self.CMGTE_Release.myBulkRelease.isForMTs
	and self.getMyVoyageObject &lt;&gt; null and not self.getMyVoyageObject.isNullVoyage and self.getMyVoyageObject.structureIncludesLOLO then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
