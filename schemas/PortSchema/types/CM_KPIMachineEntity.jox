    <JadeMethod name="calculateNetRunningTime" id="b1726af3-15b1-4cc7-a037-2f28fcc83639">
        <updating/>
        <source>calculateNetRunningTime() updating;
/*
Purpose: Work out net running time - sum of net running times		

Date		Who		Reason
05 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars
	log		:CM_KPIMachineLogonOffDtl;
	value	:Integer;
begin
	foreach log in self.allKPIMachineLogonOff do
		value := value + log.netDuration;
	endforeach;
	
	self.netRunningTime	:= value; 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="calculateNetWorkingTime" id="385a586e-1728-42dd-a245-7c5c282867df">
        <updating/>
        <source>calculateNetWorkingTime() updating;
/*
Purpose: Work out net working time - sum of net lift durations		

Date		Who		Reason
05 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars
	lift	:CM_KPIMachineLiftDtl;
	value	:Integer;
begin
	foreach lift in self.allKPIMachineLifts do 
		value := value + lift.netDuration;
	endforeach;
	
	self.netWorkingTime	:= value;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createKPILiftDtl" id="2718e1d3-fdfc-4077-bf08-682c672234cc">
        <source>createKPILiftDtl(_history :CM_MachineMoveHistory):CM_KPIMachineLiftDtl protected;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiLift	:CM_KPIMachineLiftDtl;
begin
	if self.isTransient then
		create kpiLift transient;
	else
		create kpiLift persistent;
	endif;
	
	if _history.type = CM_MachineMoveHistory.Type_Move then
		kpiLift.setForMoveLift (_history, self);
	else
		kpiLift.setForSetDown (_history, self);
	endif;
	
	return kpiLift;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
        <ReturnType type="CM_KPIMachineLiftDtl"/>
    </JadeMethod>
    <JadeMethod name="createKPILogonOffDtl" id="d7653ee5-c955-4bf5-979a-2ee412738a61">
        <source>createKPILogonOffDtl(_history :CM_MachineLogOnOffHistory):CM_KPIMachineLogonOffDtl protected;
/*
Purpose:		Create record of a session within a date/shift		
Parameters:		The logon or logoff machine history item 	
Return Value:	The CM_KPIMachineLogonOffDtl created	

Date		Who		Reason
05 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars
	kpiLog	:CM_KPIMachineLogonOffDtl;
	keep : Boolean;
begin
	if self.isTransient then
		create kpiLog transient;
	else
		create kpiLog persistent;
	endif;
				
	if _history.type = _history.Type_LogOn  then
		keep := kpiLog.setForLogon (_history, self);
	else
		keep := kpiLog.setForLogoff (_history, self);
	endif;
	
	if not keep then // PAR 34932
		delete kpiLog; // PAR 34932
		return null; // PAR 34932
	endif;
	
	return kpiLog;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineLogOnOffHistory"/>
        <ReturnType type="CM_KPIMachineLogonOffDtl"/>
    </JadeMethod>
    <JadeMethod name="createKPIMoveDtl" id="57bb2963-970d-47d7-98f3-2b7ef4a1c9d9">
        <source>createKPIMoveDtl(_history :CM_MachineMoveHistory):CM_KPIMachineMoveDtl protected;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiMove		:CM_KPIMachineMoveDtl;
	historyType	:Integer;
begin
	if self.isTransient then
		create kpiMove transient;
	else
		create kpiMove persistent;
	endif;
	
	historyType := _history.type;
	
	if historyType = CM_MachineHistory.Type_Move then
		kpiMove.setForMove (_history, self);
	elseif historyType = CM_MachineHistory.Type_SetDown then
		kpiMove.setForSetDown (_history, self);
	endif;
	
	return kpiMove;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
        <ReturnType type="CM_KPIMachineMoveDtl"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6e306242-3939-46a5-986e-4e7703448752">
