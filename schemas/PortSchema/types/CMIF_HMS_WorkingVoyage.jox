    <JadeMethod name="checkForDuplicateInCurrentView" id="4c7b92f9-ab40-434b-a9cf-3e9f9ebcde82">
        <source>checkForDuplicateInCurrentView():Boolean;
//28/06/2022 navds20 TFS 53760 MTN - DuplicateItem not Translatable


vars
 	msgBoxType: 		Integer;
 	viewController:		CMIF_HMS_ViewController;
 	previousVoyage,
	duplicateVoyage:		CMIF_HMS_WorkingVoyage;
 	permVoyage:			CM_Voyage;
begin
  	// This method checks the view controllers collection allVoyagesViewedByCode dict
  	// to see if the proposed newly keyed voyage uses the same key as another 
  	// voyage in the current view
	if self.code=null or self.code="" then
  	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage Code', null, null);
		app.raiseCMException(Input_required_field_VoyCode, null, null); // cnwdb2	PAR 35364
  		return true;
	endif;
	
  	viewController := self.ofViewController;
  	previousVoyage := self.ofClonedVoyage;

  	if previousVoyage &lt;&gt; null then
  		// Edit mode
  		if previousVoyage.code = self.code then
		//hasn't changed is ok
			return false;
		endif;
		
		// Code key has changed - check new key
		
		permVoyage := self.ofTerminal.lookupVoyage (self.code, null, false);
		// Check for duplicate in database
		if permVoyage &lt;&gt; null and self.ofPermanentVoyage &lt;&gt; permVoyage then
			//app.raiseCMException2(DuplicateItem, app.getErrorString(Voyage), self.code &amp; app.getErrorString(MSGBOX_DuplicatedVoyageMsgB), null, null); //28/06/2022 navds20 TFS 53760
			// Voyage already exists for %1 Please enter a new code for this voyage. :Voyag_alrea_exist_pleas_enter_
			app.raiseCMException1(Voyag_alrea_exist_pleas_enter_, self.code , null, null); //28/06/2022 navds20 TFS 53760
			return true;
		endif;	
  	else
  		// Add mode
		// Check for duplicate in database
  		permVoyage:= self.ofTerminal.lookupVoyage (self.code, null, false);
  		if permVoyage &lt;&gt; null and self.ofPermanentVoyage &lt;&gt; permVoyage then
				//app.raiseCMException2(DuplicateItem, app.getErrorString(Voyage), self.code &amp; app.getErrorString(MSGBOX_DuplicatedVoyageMsgB), null, null); //28/06/2022 navds20 TFS 53760
				//Voyage already exists for %1 Please enter a new code for this voyage. :Voyag_alrea_exist_pleas_enter_
				app.raiseCMException1(Voyag_alrea_exist_pleas_enter_, self.code , null, null); //28/06/2022 navds20 TFS 53760
  			return true;
		endif;	
  	endif;
		
	// Check for duplicate in current view
	/* epr 19/12/07 par 15467 changed from getAtKey the dict has been changed to be keyed on code and arrivalDT 
		therefore getAtKey(self.code, self.arrivalDT won't find the duplicate unless the screnario voyages are added at the same time
	*/

	duplicateVoyage:= viewController.allVoyagesViewedByCode.getAtKeyGeq(self.code, null);
  	if duplicateVoyage &lt;&gt; null and duplicateVoyage.code = self.code then
			//app.raiseCMException2(DuplicateItem, app.getErrorString(Voyage), self.code &amp; app.getErrorString(MSGBOX_DuplicatedVoyageMsgB), null, null);  //28/06/2022 navds20 TFS 53760
			//Voyage already exists for %1 Please enter a new code for this voyage. :Voyag_alrea_exist_pleas_enter_
			app.raiseCMException1(Voyag_alrea_exist_pleas_enter_, self.code , null, null); //28/06/2022 navds20 TFS 53760
  		return true;
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForSameShipInPort" id="47a8643e-efe5-406e-b45c-501c64c333c6">
        <updating/>
        <source>checkForSameShipInPort(_arriveDT, _departDT : TimeStamp) : Boolean updating;

/*

Date		Who		Reason
04 Apr 2008	cnwkpd1	PAR #16373 - Handle "To Be Named" ships in the Graphical View, by excluding this
					check
18/08/2011	cnwmh5	#27968 - Add checking for cancelled voyages so it doesn't include them
*/

vars
	workingVoyage:	CMIF_HMS_WorkingVoyage;	
	vController:	CMIF_HMS_ViewController;
	shipToCheck:	String;
	departDT:		TimeStamp;
	arriveDT:		TimeStamp;
	msgBoxType:		Integer;
	tmpDict:		HMS_ViewVoyageByArrvDTDict;
	vessel:			CM_Vessel;						// PAR #16373
	
begin
 	// This method checks to see in the proposed visit for a ship is taking 
 	// place at the same time as an already booked visit of this ship - ie a 
 	// double entry of a booking.
	
	// PAR #16373 - Before checking anything else, check whether we are a "To Be Named" vessel
	vessel := self.getMyVessel();
	if vessel &lt;&gt; null and vessel.isToBeNamed() then
		return true;
	endif;
	
 	vController := self.ofViewController;
 	shipToCheck := self.myHMSVoyageData.vesselCode;

 	arriveDT := _arriveDT;
	departDT := _departDT;
	
	if (not arriveDT.isValid) then
		if self.allClonedMovements.size &gt; 1 then
		 	arriveDT := self.allClonedMovements.first.occursOnDT;
		else		
		 	arriveDT := self.arrivedDT;
		endif;
	endif;

	if (not departDT.isValid) then
		if self.allClonedMovements.size &gt; 1 then
			departDT := self.allClonedMovements.last.occursOnDT;
		else		
			departDT := self.departedDT;
		endif;
	endif;
	 	
	tmpDict := vController.allVoyagesViewedByArrvDT;

 	foreach workingVoyage in tmpDict where workingVoyage.myHMSVoyageData.vesselCode = shipToCheck do
 		if workingVoyage &lt;&gt; self.ofClonedVoyage then
 			// Test for overlap
			if workingVoyage.arrivedDT &lt;= departDT
 			and workingVoyage.departedDT &gt;= arriveDT then 
 				// Overlap occurs - ie there is already a bookibg in the system for this ship at this time
				app.raiseCMException1(BookingExists, self.myHMSVoyageData.vesselName &amp; " at " &amp;  
						workingVoyage.ofTerminal.code &amp; ', arrival ' &amp; workingVoyage.arrivedDT.asStringJMT() &amp; 
						' departure ' &amp; workingVoyage.departedDT.asStringJMT() &amp; 
						' voyage ' &amp; workingVoyage.code, null, null); 
 				return false;
 			endif;	
 		endif;
 	endforeach;

  	// Proposed visit for this ship is not already booked into the system.
 	return true;
end;</source>
        <Parameter name="_arriveDT" type="TimeStamp"/>
        <Parameter name="_departDT" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyVoyage" id="a10510ab-ff86-4d82-b4ee-1fe0da8a5fb5">
        <updating/>
        <source>copyVoyage(permVoyage:CM_Voyage; viewController:CMIF_HMS_ViewController) updating;

vars
	workingMovement: 	CMIF_HMS_WorkingMovement;
	permanentMovement:	HMS_VoyageMovement;
	workingDelay:		CMIF_HMS_VoyageDelay;
	permanentDelay:		HMS_VoyageDelay;
	//cargo: 				CM_Commodity;	// ### TFS 53132 21Apr2022 NAVPW1
	cargoForecast		: CM_CargoForecast;	// ### TFS 53132 21Apr2022 NAVPW1
	stevedore:			CM_Stevedore;
	tmpDict:			HMS_VoyageMovementByDateDict;
	voyageData:			HMS_VoyageData;
	
begin
	// This method copies all attributes and references from the the permanentVoyage
	// to the working voyage
	voyageData				:=	permVoyage.myHMSVoyageData;
    self.arrivedDT			:=	permVoyage.arrivedDT;
    self.code				:=	permVoyage.code;
    self.departedDT			:=	permVoyage.departedDT;
    self.remarks			:=	permVoyage.remarks;
    self.voyageStatus		:=	voyageData.voyageStatus;	//Modified by Russell 04/08/99
    self.archived			:=	permVoyage.archived;	//Modified by Russell 13/08/99
    self.archivedDT			:=	permVoyage.archivedDT;//Modified by Russell 13/08/99
    self.ofHmsShippingLine	:=	permVoyage.myShippingLine;
    self.ofTerminal			:=	permVoyage.myTerminal;
    self.ofHarbour			:=	self.ofTerminal.myHarbour;
    //ofVessel				:=	voyageData.myVoyage.getMyVessel();
	self.myHMSVoyageData	:=	voyageData;
	self.ofPortFrom			:=	voyageData.myPortFrom;
	self.ofPortTo			:=	voyageData.myPortTo;

	// Modified by Russell 25/05/99
    // -------------------------------------------
    self.shortComment	:=	voyageData.shortComment;
    // -------------------------------------------

	self.ofClassIn	:=	voyageData.myVesselCategoryIn;
 	self.ofClassOut	:=	voyageData.myVesselCategoryOut;

 	/*foreach cargo in voyageData.allCommodityDischarge do
 		self.allCargoDischarge.add(cargo);
 	endforeach;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
	
 	/*foreach cargo in voyageData.allCommodityLoad do
 		self.allCargoLoad.add(cargo);
 	endforeach;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
	
	// ### TFS 53132 11Apr2022 NAVPW1
	foreach cargoForecast in permVoyage.allCargoForecasts do
 		self.allCargoForecasts.add(cargoForecast);
 	endforeach;
	// ### TFS 53132 11Apr2022 NAVPW1
	
 	// Modified by Russell 04/05/99
 	// ---------------------------------------------------------------------
 	foreach stevedore in voyageData.allStevedoresDischarge do
 		self.allStevedoresDischarge.add(stevedore);
 	endforeach;
	
 	foreach stevedore in voyageData.allStevedoresLoad do
 		self.allStevedoresLoad.add(stevedore);
 	endforeach;
 	// ---------------------------------------------------------------------

	self.vesselCode			:=	voyageData.vesselCode;
	self.ofViewController	:=	viewController;

	tmpDict					:=	voyageData.allVoyageMovements;
	
	foreach permanentMovement in tmpDict do
		create workingMovement;
	    workingMovement.copyMovement(permanentMovement, self, null, false, app.myPassport);
		workingMovement.myViewController := viewController;
	endforeach;

	foreach permanentDelay in voyageData.allVoyageDelays do
		create workingDelay;
		workingDelay.copyDelay(permanentDelay, self);
	endforeach;

	self.ofPermanentVoyage	:=	permVoyage;
end;</source>
        <Parameter name="permVoyage" type="CM_Voyage"/>
        <Parameter name="viewController" type="CMIF_HMS_ViewController"/>
    </JadeMethod>
    <JadeMethod name="createClone" id="361a667d-b710-4370-baa3-7f75d59ecfb9">
        <updating/>
        <source>createClone() : CMIF_HMS_WorkingVoyage updating;

vars
 	cloneWorkingVoyage: 	CMIF_HMS_WorkingVoyage;
 	workingMovement:		CMIF_HMS_WorkingMovement;
 	workingDelay:			CMIF_HMS_VoyageDelay;
 	delay:					CMIF_HMS_VoyageDelay;
 	cargo:					CM_Commodity;
 	stevedore:				CM_Stevedore;
 	numMoves,
 	cnt:					Integer;
begin

 	// This method creates a temporary clone of a working voyage for checking/reversal purposes
	cloneWorkingVoyage := self.cloneSelf(true);

	numMoves := self.allWorkingMovements.size;
	foreach workingMovement in self.allWorkingMovements do
		workingMovement.createClone(cloneWorkingVoyage, null);
	endforeach;

	// Clone voyage delays
	foreach workingDelay in self.allCMIFVoyageDelays do
		create delay;
		delay.isChargeable 			:= workingDelay.isChargeable;
		delay.startTime				:= workingDelay.startTime;
		delay.stopTime				:= workingDelay.stopTime;
		delay.myDelay				:= workingDelay.myDelay;
		delay.myPersistentVoyageDelay:= workingDelay.myPersistentVoyageDelay;
		delay.myWorkingVoyage		:= cloneWorkingVoyage;
	endforeach;

	cloneWorkingVoyage.myHMSVoyageData 	:= self.myHMSVoyageData;
	cloneWorkingVoyage.ofClonedVoyage	:= self;
	cloneWorkingVoyage.ofPermanentVoyage:= self.ofPermanentVoyage;
	cloneWorkingVoyage.ofPortFrom		:= self.ofPortFrom;
	cloneWorkingVoyage.ofPortTo			:= self.ofPortTo;
	cloneWorkingVoyage.ofShippingLine	:= self.ofShippingLine;
	cloneWorkingVoyage.ofTerminal		:= self.ofTerminal;
	cloneWorkingVoyage.ofHarbour 		:= self.ofHarbour;
	cloneWorkingVoyage.ofViewController	:= self.ofViewController;

	cloneWorkingVoyage.ofClassIn		:= self.ofClassIn;
 	cloneWorkingVoyage.ofClassOut		:= self.ofClassOut;

 	foreach cargo in self.allCargoDischarge do
 		cloneWorkingVoyage.allCargoDischarge.add(cargo);
 	endforeach;

 	foreach cargo in self.allCargoLoad do
 		cloneWorkingVoyage.allCargoLoad.add(cargo);
 	endforeach;

 	// Modified by Russell 04/05/99
 	// ------------------------------------------------------------------
 	foreach stevedore in self.allStevedoresDischarge do
 		cloneWorkingVoyage.allStevedoresDischarge.add(stevedore);
 	endforeach;

 	foreach stevedore in self.allStevedoresLoad do
 		cloneWorkingVoyage.allStevedoresLoad.add(stevedore);
 	endforeach;
 	// ------------------------------------------------------------------

	return cloneWorkingVoyage;
end;</source>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="createWorkingVoyage" id="668a8093-7b93-4065-acb4-d221f5e0b486">
        <updating/>
        <source>createWorkingVoyage():CMIF_HMS_WorkingVoyage updating;

vars
  	editVoyageChange:	 	CMIF_HMS_VoyageEdit;
  	addVoyageChange:		CMIF_HMS_VoyageAdd;
  	workingVoyage:		   	CMIF_HMS_WorkingVoyage;
  	workingMovement:		CMIF_HMS_WorkingMovement;
  	newClonedMovement:		CMIF_HMS_WorkingMovement;
	workingDelay:			CMIF_HMS_VoyageDelay;
	delay:					CMIF_HMS_VoyageDelay;
	cargo:					CM_Commodity;
	stevedore:				CM_Stevedore;

begin
	// Do not create any cloned movements in this method - keep it separate

	// This method creates a new workingVoyage from a clonedWorkingVoyage
	create workingVoyage transient;
 	workingVoyage:=self.cloneSelf(true);

 	// Set references
	//workingVoyage.ofVessel:=self.ofVessel;
	workingVoyage.myHMSVoyageData:=self.myHMSVoyageData;
	workingVoyage.ofPermanentVoyage:=self.ofPermanentVoyage;
	workingVoyage.ofPortFrom:=self.ofPortFrom;
	workingVoyage.ofPortTo:=self.ofPortTo;
	workingVoyage.ofHmsShippingLine:=self.ofHmsShippingLine;
	workingVoyage.ofTerminal:=self.ofTerminal;
	workingVoyage.ofHarbour := self.ofHarbour;	
	workingVoyage.ofViewController:=self.ofViewController;

	workingVoyage.ofClassIn:=self.ofClassIn;
 	workingVoyage.ofClassOut:=self.ofClassOut;

 	foreach cargo in self.allCargoDischarge do
 		workingVoyage.allCargoDischarge.add(cargo);
 	endforeach;
 	foreach cargo in self.allCargoLoad do
 		workingVoyage.allCargoLoad.add(cargo);
 	endforeach;

 	// Modified by Russell 04/05/99 
 	// --------------------------------------------------------------------
 	foreach stevedore in self.allStevedoresDischarge do
 		workingVoyage.allStevedoresDischarge.add(stevedore);
 	endforeach;
 	foreach stevedore in self.allStevedoresLoad do
 		workingVoyage.allStevedoresLoad.add(stevedore);
 	endforeach;
 	// --------------------------------------------------------------------

	// May need all references in here

	// Create new working arrival and departure movements for new voyage
	if self.ofClonedVoyage=null then
		// New ADDED voyage - create wrokingMovements
		foreach newClonedMovement in self.allClonedMovements do
			newClonedMovement.createWorkingMovement(workingVoyage, false, false, false);
		endforeach;

	endif;

	// Create voyage delays
	foreach workingDelay in self.allCMIFVoyageDelays do
		create delay;
		delay.isChargeable 			:= workingDelay.isChargeable;
		delay.startTime				:= workingDelay.startTime;
		delay.stopTime				:= workingDelay.stopTime;
		delay.myDelay				:= workingDelay.myDelay;
		delay.myPersistentVoyageDelay:= workingDelay.myPersistentVoyageDelay;
		delay.myWorkingVoyage		:= workingVoyage;
	endforeach;

  	// Purge allWorkingDelays on clone  
  	self.allCMIFVoyageDelays.purge;

	if self.ofClonedVoyage=null then
		// Create stackChange objects for the update
		// Add mode
		create addVoyageChange;
		addVoyageChange.appliesToVoyage:=workingVoyage;
		addVoyageChange.ofViewController:=ofViewController;
		ofViewController.changeApply(addVoyageChange,false, true);
	else
		// Edit mode
		create editVoyageChange;
		editVoyageChange.versionPrevious:=self.ofClonedVoyage;
		editVoyageChange.appliesToVoyage:=workingVoyage;
		editVoyageChange.ofViewController:=ofViewController;
		ofViewController.changeApply(editVoyageChange,false, true);
	endif;

	return workingVoyage;
end;</source>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="delete" id="65a3df81-967f-4461-99c4-060a23a274b8">
        <updating/>
        <source>delete() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 February 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myCMIF_VoyageGlobal &lt;&gt; null and self.myCMIF_VoyageGlobal.allCMIF_WorkingVoyages.size = 1 then
		delete self.myCMIF_VoyageGlobal;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getBerthingDT" id="3ac44392-2dc4-4da1-b83a-3d8cb437eecb">
        <source>getBerthingDT():TimeStamp;

// gets the Berthing Date/Time, as occurence Date/Time of the first movement whose region is a terminal

vars
	workingMovement : CMIF_HMS_WorkingMovement;
	berth			: HMS_Berth;
	region			: HMS_HarbourRegion;
begin

	foreach workingMovement in allWorkingMovements do
		berth := workingMovement.myBerth;
		if berth &lt;&gt; null then
			region := workingMovement.myBerth.myHarbourRegion;
			if region &lt;&gt; null and region.getTerminal() &lt;&gt; null then
				return workingMovement.occursOnDT;
			endif;
		endif;
	endforeach;
	return null;
end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="b23b9113-0450-44ca-82f4-f6993323a02c">
        <source>getDisplayDetails(_short: Boolean): String;
//--------------------------------------------------
// Created:	16 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myHMSVoyageData &lt;&gt; null then
		return self.myHMSVoyageData.getDisplayDetails(_short);
	else
		return self.code;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="c3e58367-942c-4ffe-bb8a-27591330e585">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//--------------------------------------------------
// Created: 07 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	block : CM_DataContainerBlock;
	tmpMove : CMIF_HMS_WorkingMovement;
	tmpVessel : CM_Vessel;
begin
	
	if _dataContainer = null then
		return;
	endif;
	
	if self.ofPermanentVoyage &lt;&gt; null then
		self.ofPermanentVoyage.myHMSVoyageData.getExtraInfo(_dataContainer);
		return;
	endif;
	
	foreach tmpMove in self.allWorkingMovements do
		tmpMove.getExtraInfo(_dataContainer);
	endforeach;
	
	tmpVessel := self.getMyVessel();
	
	if tmpVessel &lt;&gt; null then
		tmpVessel.getExtraInfo(_dataContainer);
	endif;															
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Voyage Remarks', DC_Label, 1, null);
	block.addNewItem(self.remarks, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Voyage Short Comments', DC_Label, 1, null);
	block.addNewItem(self.shortComment, DC_Data, 1, null);
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyVessel" id="94652220-2f29-4add-a323-5505ecb3c1fd">
        <source>getMyVessel() : CM_Vessel;
//--------------------------------------------------
// Created:	28 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	vesselObj	: CM_Vessel;
	failedDAC  :CM_DataAccessController;
	
begin
	if self.myHMSVoyageData &lt;&gt; null then
		vesselObj	:=	app.myRoot.allVessels[self.myHMSVoyageData.vesselCode];
		
		if vesselObj &lt;&gt; null and vesselObj.canUserAccessSelf(null, failedDAC, app.myPassport) then
			return vesselObj;
		endif;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getOperator" id="df7038c8-d309-46f1-888f-643c8b2abf8f">
        <source>getOperator():CM_Operator;
// --------------------------------------------------------------------------------
// Created:		09 October 2006 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's Operator.
//
// Parameters:	None
//
// Returns:		A refertence to the receiver's operator, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	voyageObj	: CM_Voyage;
	
begin
	if self.myHMSVoyageData &lt;&gt; null then
		voyageObj	:=	self.myHMSVoyageData.myVoyage;
		
		if voyageObj &lt;&gt; null then
			return voyageObj.myOperator;
		endif;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getPreviousCMIFWorkingVoyage" id="2751ab12-2c27-4ffd-b9a3-9fa386dcb0d3">
        <source>getPreviousCMIFWorkingVoyage() : CMIF_HMS_WorkingVoyage;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 February 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars
	index : Integer;
begin
	if self.myCMIF_VoyageGlobal = null then
		return null;
	endif;
	index:=self.myCMIF_VoyageGlobal.allCMIF_WorkingVoyages.indexOf(self);
	
	if index &lt;= 1 then
		return null;
	endif;
	
	return self.myCMIF_VoyageGlobal.allCMIF_WorkingVoyages[index-1];
	

epilog

end;</source>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="getWaitingCostForDate" id="f96c19fd-f210-444e-a14f-dc2e124e68cb">
        <source>getWaitingCostForDate(_date : Date): Integer;

// R Barr 25/10/2006 Comalco Initial Requirements
// calculate waitingMinutes, and hence waitingCost (dollars  &amp; cents) for the vessel, based on the formula documented below.
// Durations are in minutes

vars
	nonChargeMinutes			: Decimal[12,0];	// non-charge time as entered against vessel/voyage (units: minutes.seconds)
	allowedExchangeMinutes		: Decimal[12,0];	// Time allowed to load/discharge, bsed on load/discharge rate specified for voyage/postion (units: minutes)
	waitingMinutes				: Decimal[12,0];	// Time vessel spends waiting for a berth  (units: minutes)
	arrivalTime					: TimeStamp;		// time at which the vessel arrives in the harbour
	departureTime				: TimeStamp;		// time at which the vessel departs the harbour
	berthingTime				: TimeStamp;		// time at which the vessel ties up at berth
	stopChargingTime			: TimeStamp;		// Either the vessel departure time, or the load/discharge completed time
	exchangeCompletedTime		: TimeStamp;		// berthing time + time allowed to load/discharge
	nonChargeTimeRemains		: Boolean;			// has the ship waited the full non-charge time before going to berth?
	vesselDailyCost				: Integer;			// rate entered against vessel/voyage; dollars &amp; cents
	vesselDespatchRate			: Integer;			// rate entered against vessel/voyage; dollars &amp; cents
	waitingCost					: Integer;			// dollars &amp; cents
	vesselObj					: CM_Vessel;
	
begin
	// persistent vessel
	vesselObj	:=	self.getMyVessel();

	// calculate allowed duration for load + discharge
	allowedExchangeMinutes := self.ofPermanentVoyage.getExpectedLoadMinutes() + self.ofPermanentVoyage.getExpectedDischargeMinutes();
			
	// times - arrival, berthing, departure, exchange complete
	berthingTime 			:=	self.getBerthingDT();
	arrivalTime				:=	self.arrivedDT;
	departureTime			:=	self.departedDT;
	exchangeCompletedTime	:=	berthingTime.addMinutes(allowedExchangeMinutes.rounded);

	// time at which charging stops
	if departureTime &lt; exchangeCompletedTime then
		stopChargingTime	:=	departureTime;
	else
		stopChargingTime	:=	exchangeCompletedTime;
	endif;
	
	if arrivalTime = null or departureTime = null or berthingTime = null then

		return 0;
	endif;
	
	// vessel daily cost and discharge rate (both $) from Vessel Definition Form, Vessel Details sheet
	vesselDailyCost		:=	vesselObj.dailyCost;
	vesselDespatchRate	:=	vesselObj.despatchRate;
	
	// non charge time (duration) from Vessel Definition Form, Waiting costs sheet
	nonChargeMinutes	:=	self.ofPermanentVoyage.getNonChargeTimeInMinutes();
	
	// has non-charge time waiting for berth been used?
	nonChargeTimeRemains	:=	berthingTime &gt; arrivalTime.addMinutes(nonChargeMinutes.rounded);
	
	// calculate waiting duration
	if nonChargeTimeRemains then
		waitingMinutes	:=	exchangeCompletedTime.getDifferenceInMinutes(arrivalTime) - allowedExchangeMinutes;
	else
		waitingMinutes	:=	stopChargingTime.getDifferenceInMinutes(arrivalTime) - nonChargeMinutes - allowedExchangeMinutes;
	endif;
	
	// calculate cost, using vessel daily cost if positive (over-run) or despatch rate if negative (under-run)
	if waitingMinutes &gt;= 0 then
		waitingCost	:=	waitingMinutes.rounded() * vesselDailyCost;
	else
		waitingCost	:=	-waitingMinutes.rounded() * vesselDespatchRate;
	endif;
	
	return waitingCost;
end;
</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="myWharf" id="1448fdf8-bdb5-4326-9d58-696fe9386644">
        <methodInvocation>mapping</methodInvocation>
        <source>myWharf(set: Boolean; _value: HMS_Wharf io) mapping;
//--------------------------------------------------
// Created:	12 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	movement : CMIF_HMS_WorkingMovement;
begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := null;
		movement := self.allWorkingMovements.first.CMIF_HMS_WorkingMovement;
		if movement = null then
			movement := self.allClonedMovements.first.CMIF_HMS_WorkingMovement;
		endif;
		if movement &lt;&gt; null then
			_value := movement.myBerth.myWharf;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="HMS_Wharf" usage="io"/>
    </JadeMethod>
    <JadeMethod name="newVoyageAsClone" id="11ba4e6d-eecd-4081-b200-6bb5d01956a9">
        <updating/>
        <source>newVoyageAsClone(voyCode: String; ship: CM_Vessel; arrvDT, deptDT: TimeStamp; _terminal : CM_Terminal; _viewController : CMIF_HMS_ViewController) updating;

vars
 	workingMovement:		CMIF_HMS_WorkingMovement;
 	workingDelay:			CMIF_HMS_VoyageDelay;
 	delay:					CMIF_HMS_VoyageDelay;
begin
	if ship = null then
		return;
	endif;
 	// This set properties on a new temporary clone for a working voyage for checking/reversal purposes

	// Set Default Properties
	self.code:=voyCode;
	self.arrivedDT:=arrvDT;
	self.departedDT:=deptDT;

    // Set default references
	//self.ofControllerForClone := _viewController;
	//self.ofVessel:=ship;
	create self.myHMSVoyageData transient;
	self.myHMSVoyageData.setPxyFromVessel(ship, _terminal);
	
	self.ofClonedVoyage:=null;
	self.ofPermanentVoyage:=null;
	self.ofPortFrom:=null;
	self.ofPortTo:=null;
	self.ofTerminal:= _terminal;
	self.ofHarbour := _terminal.myHarbour;
	self.ofViewController := _viewController;
	
	self.ofHmsShippingLine:=ship.myHMSVesselData.myDefaultShippingLine;

	self.ofClassIn:=self.myHMSVoyageData.myVesselCategoryIn;
 	self.ofClassOut:=self.myHMSVoyageData.myVesselCategoryOut;

	// Create new default movements
	// Default Arrival movement
	create workingMovement transient;
	workingMovement.newMovementAsClone(self,HMSMovementTypeArrival,self.arrivedDT, _viewController);
	// Default Departure movement
	create workingMovement transient;
	workingMovement.newMovementAsClone(self,HMSMovementTypeDeparture,self.departedDT, _viewController);



end;</source>
        <Parameter name="voyCode" type="String"/>
        <Parameter name="ship" type="CM_Vessel"/>
        <Parameter name="arrvDT" type="TimeStamp"/>
        <Parameter name="deptDT" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_viewController" type="CMIF_HMS_ViewController"/>
    </JadeMethod>
    <JadeMethod name="setMyCMIF_VoyageGlobal" id="18cf7d0f-4572-49c9-b1f0-834e43d2fa55">
        <updating/>
        <source>setMyCMIF_VoyageGlobal(_voyageGlobal : CMIF_VoyageGlobal) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 February 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myCMIF_VoyageGlobal &lt;&gt; _voyageGlobal then
		self.myCMIF_VoyageGlobal:=_voyageGlobal;
	endif;

epilog

end;</source>
        <Parameter name="_voyageGlobal" type="CMIF_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="validateVoyage" id="cc3e1bf9-d913-491e-96d5-642d7e2a55ba">
        <updating/>
        <source>validateVoyage(_checkClearances : Boolean):Boolean updating;

vars
	clonedMovement : CMIF_HMS_WorkingMovement;
	raiseWarningMsg,
	checkWarnPeriod : Boolean;
	checkNonPlannedEffective : Boolean;
	warnDT : TimeStamp;
begin
 	// This method runs validation checks on all clonedMovements for a cloned
 	// voyage and returns true is all checks are OK
	if (not self.checkForSameShipInPort(null, null)) then 
		return true;
	endif;
	
	checkWarnPeriod := self.ofHarbour.checkWarningPeriod(warnDT);
	
 	foreach clonedMovement in self.allClonedMovements do
 		raiseWarningMsg := true;
 		if checkWarnPeriod then
 			if clonedMovement.occursOnDT &gt; warnDT then
	 			//CCMS 1011 only validate if movement is within warn period
 				raiseWarningMsg := false;
 			endif;
 		endif; 	
 		
 		//re-calculate and update clearances for movements
 		if _checkClearances then
			///epr 25/9/08  par 16784
			if (not clonedMovement.check_Clearances(true, raiseWarningMsg)) then
				//User has not excepted changes to the clearances, cancel save.
				return false;
			endif; 	
		endif;	 	
		
		if raiseWarningMsg then
 			//CCMS 1011 only validate if movement is within warn period		
 			clonedMovement.validateMovement();
 		endif;
		//epr par 15303 8/11/07 
		if self.ofPermanentVoyage &lt;&gt; null then //Wrapper added to allow for voyages that are being added as opposed to edited. PAR15481
			checkNonPlannedEffective:= self.ofPermanentVoyage.isRetrospective();
			if checkNonPlannedEffective then
				if clonedMovement.moveType =HMSMovementTypeDeparture and  self.ofPermanentVoyage.nonPlannedEffectiveDT &gt; clonedMovement.occursOnDT then
					app.raiseCMWarning1(AutoScheduleDateError, 'The non-effective date is now after the departure date.', null, self ,self.myHMSVoyageData);	
				endif;
				
				if clonedMovement.moveType =HMSMovementTypeArrival and  self.ofPermanentVoyage.nonPlannedEffectiveDT &lt; clonedMovement.occursOnDT then
					app.raiseCMWarning1(AutoScheduleDateError, 'he non-effective date is now  before the arrival date.', null, self,null);	
				endif;
			endif;
		endif;
 	endforeach;
 
	
 	return true;
 	
end;</source>
        <Parameter name="_checkClearances" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
