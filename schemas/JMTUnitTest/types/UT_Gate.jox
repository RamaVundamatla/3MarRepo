    <JadeMethod name="tReceivePrenotedGCByType" id="3e12352f-a1dc-4acb-b20e-1e85bb4b1837">
        <updating/>
        <source>tReceivePrenotedGCByType() updating;
// cnwdap1
//30 July 2009	cnwdw1	
// gate In comtainer thru A Gate only
vars
	vvr: CM_VehicleVisitRecord;
	truck, driver: String;
	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	agent: CM_MobileAgent;
	wle: CM_WorkListEntry;
	
	flexiController: CMIF_FlexiGateController;
	pxyGateEntity: CMGTE_Receival;
	gateEntity: CMGTE_Entity;
begin
	
	deleteContainer("UUT00000001");
	self.deleteBooking("UT_BOOKING");
	booking := self.addBookingForContainer("UT_BOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
		assertNotNull(booking);
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UUT00000001");
		assertNotNull(ti);

	truck := getTruckName();
	driver := getDriverName();
	
	deleteVehicle(truck);

	self.opts.addAssoc("YardInterchangeArea", self.yic.id);

	vvr := gateInGCByType(truck, "", driver, dualGate);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		assertTrue(vvr.vehicle.allRoadJobs.first.workListEntries.first.myRequest.isKindOf(CM_ReceivalRequest));
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.myRequest.CM_ReceivalRequest.allReceivalInfo.size, 1);
		
		
	self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		if vvr.myTerminal.getConfig (GateTransitIntoYard).Boolean then
			assertEqual(vvr.vehicle.myPrimaryActualLocation, self.yic.myInTransitToLocation);
		else
			assertEqual(vvr.vehicle.myPrimaryActualLocation, self.yic.getDefaultLane);
		endif;
	
	create agent transient;
	wle := vvr.vehicle.allRoadJobs.first.workListEntries.first;
	
	create flexiController transient;
	flexiController.id := ti.id;
	flexiController.cargoType := ti.myCargoType.id;
	flexiController.commodity := ti.commodity;
	flexiController.myTerminal := ti.myTerminal;							
	flexiController.isoTypeCode := ti.getISOType();							
	flexiController.operatorCode := ti.operatorCode;						
	flexiController.allowableTimeOffPower := ti.getAllowableTimeOffPower();	
	flexiController.coolingType := ti.getCoolingType();				
	flexiController.voltageType := ti.getVoltageType();
	flexiController.curtainsIn := ti.getCurtainsIn();
	flexiController.setCarbonDioxide( ti.getCarbonDioxide );					
	flexiController.setOxygen( ti.getOxygen );								
	flexiController.setHumidity( ti.getHumidity );							
	flexiController.ventilation := ti.getVentilation();
	flexiController.weightTotal := ti.totalWeight;	
	pxyGateEntity := flexiController.createCMGTE_ReceivalProxy(ti.myCargoType);
	pxyGateEntity.setMoveToTruckOnly(true);	//04 Jun 2010	NDl	Par 23903
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateAndActionGateEntity(vvr, pxyGateEntity, wle.myRequest.CM_ReceivalRequest.allReceivalInfo.first, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	app.myPassport.setWarningsIgnored(false);
	
	//agent.moveTI(ti, "", bs.getLocationsController, wle, true, 0, 0);
	//self.assertNoTrxErrorsOrWarnings;
	
epilog
	
	app.myPassport.setWarningsIgnored(false);

	// 10/11/2014 cnwmh5
	delete agent;
	delete flexiController;
	delete pxyGateEntity;

end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveReefer" id="5bf97469-ae97-4c49-ab75-9c9c89348795">
        <source>tReceiveReefer();
// jlgmd1
// cnwkpd1
// CNWMD1
/*

Purpose:			Test the Gate Receival for Reefers as part of CCMS 1871 OMAR changes.
					The Commodity needs Requires Pack Details (MAF...) and Requires Power options set to true.
					System Alert Type needs to include one email.
					If all goes well then the Reefer should be created, Alert created, Transaction created, and Email Created

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2010	cnwmd1	Initial creation

*/

vars
	bs: CM_BlockStack;
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	packTS : TimeStamp;
	commodity : CM_Commodity;
	emailAdd : CM_EmailAddress2;
	sysAlertType : CM_SystemAlertType;
	emailAddress 	: String;
begin
	deleteContainer("MRD00000001");
	deleteContainer("MRD00000002");
	deleteContainer("MRD00000003");
	deleteContainer("MRD00000004");
	deleteContainer("MRD00000005");
	deleteVehicle("MRDTRK1");
	deleteVehicle("MRDTRK2");	
	deleteVehicle("MRDTRK3");
	deleteVehicle("MRDTRK4");
	deleteVehicle("MRDTRK5");
	
	//Set up commodity correctly so that a check on Exceeded Power off Time is done
	commodity := app.myRoot.allCommodities['APLD'].CM_Commodity;
	self.opts.addAssoc( ETRow_RequiresPackInfo, true );
	self.opts.addAssoc( ETRow_RequiresPower, true );
	self.updateCommodity( commodity );
	
	//Set up Email Addresses so that the emails can be sent out
	emailAddress := self.activeProfile.getSetting(UT_Profile.P_EMAILADDRESS).asString;			// 17/02/202 jlgmh5 
	if emailAddress.toUpper() = "BITBUCKET" then
		emailAddress := app.getBitbucketEmailAddress();
	endif;
	self.opts.addAssoc( ETRow_Email, emailAddress);
	//self.opts.addAssoc( ETRow_Email, self.activeProfile.getSetting(UT_Profile.P_EMAILADDRESS).asString );
	sysAlertType := app.myRoot.allSystemAlertTypes[EVENT_POWER_OFF_EXCEEDED].CM_SystemAlertType;
	self.updateSystemAlertType(sysAlertType);
	
	opts.addAssociation("Location", "BS1");
	packTS := testStartTime.addDays(-5);
	//packTS := testStartTime;
	opts.addAssociation("PackDate", packTS.date.asStringJMT);
	opts.addAssociation("PackTime", packTS.time.asStringJMT);
	opts.addAssociation("AllowableTimeOffPower", 10);
	opts.addAssociation("PackTempC", 3);
	opts.addAssociation("CarriageTempC", 3);
	//08 Apr 2020	NDL	TFS 47958
	opts.addAssociation("CarbonDioxide", "10.1".Decimal);
	opts.addAssociation("Humidity", "25.25".Decimal);
	opts.addAssociation("Oxygen", "73".Decimal);
	
	gateInContainer("MRDTRK1", "MRD00000001", "22R8", operator.code, commodity.code, singleGate);
	gateInContainer("MRDTRK2", "MRD00000002", "22R8", operator.code, commodity.code, singleGate);
	gateInContainer("MRDTRK3", "MRD00000003", "22R8", operator.code, commodity.code, singleGate);
	gateInContainer("MRDTRK4", "MRD00000004", "22R8", operator.code, commodity.code, singleGate);
	gateInContainer("MRDTRK5", "MRD00000005", "22R8", operator.code, commodity.code, singleGate);
	
	//08 Apr 2020	NDL	TFS 47958
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( 1, "MRD00000001" );
	self.assertTrueMsg( ti &lt;&gt; null and ti.id = "MRD00000001", "Container MRD00000001 not created");
	self.assertTrueMsg( ti.getCarbonDioxide = "10.1".Decimal, "Container MRD00000001 CarbonDioxide should be 10.1");
	self.assertTrueMsg( ti.getHumidity = "25.25".Decimal, "Container MRD00000001 Humidity should be 25.25");
	self.assertTrueMsg( ti.getOxygen = "73".Decimal, "Container MRD00000001 Oxygen should be 73");
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveTIWithInspectedNoPTIDa" id="6444657e-fc50-4dc7-a45e-c8ba37e9d335">
        <updating/>
        <source>tReceiveTIWithInspectedNoPTIDa() updating;
// cnwdap1
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Dec 2011	cnwrd1	Initial creation
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

constants
	ToDoTaskCode : String = "UT_27192";
	Containerid : String = "RJD11122004";
	BookingID : String = "UT_BOOKING";
	BlockStackName				= 'UT_BS';
	YA 		= 'UT_YA';
	TruckID	 = "UTRJD";
vars
	toDoTaskDesc		: CM_ToDoTaskDesc;
	tiSet 				: CM_TISet;
	booking				: CM_BookingRef;
	ti					: CM_TrackedItem;	
	bs					: CM_BlockStack;
	allowPinWithoutVGM	: Boolean;
begin

	allowPinWithoutVGM := self.setTerminalConfig(AllowPINwithoutVGM, true).Boolean;
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	self.deleteVehicle(TruckID);	
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
	
	deleteYA (YA);	
	self.addYACatchAll (YA, bs);
	//setup new todo task desc with all sub terms available.
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode];
	self.deleteToDoTaskDescription(toDoTaskDesc);
	self.opts.addAssoc(ETRow_TransactionToCreate, 4);
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode);
	self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	//self.deleteContainer(Containerid);
	//container := self.addContainerOpts(Containerid, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null);
	
	
	deleteContainer(Containerid);
	self.deleteBooking(BookingID);
	booking := self.addBookingForContainer(BookingID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2231", "MT");
	assertNotNull(booking);	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  Containerid);

	create tiSet transient;
	tiSet.add(ti);
	self.addToDoTask(toDoTaskDesc, tiSet);
	self.completeToDoTask(toDoTaskDesc, tiSet,null);				//23.01.2023 navma1 #54349[54262]
	
	self.assertNotNull(ti.inspectDT);
	
	self.gateInPinReceival(ti.myPinNo.pinNo, TruckID); //old gate
	
	assertEqual(ti.state, TI_STATE_NORMAL);
	assertEqual(ti.getImExStatus, TI_IMEX_STATUS_EXPORT);
	
	self.assertNull(ti.getPreTripDT);
	
epilog
	delete tiSet;
	self.setTerminalConfig(AllowPINwithoutVGM, allowPinWithoutVGM);
end;</source>
    </JadeMethod>
