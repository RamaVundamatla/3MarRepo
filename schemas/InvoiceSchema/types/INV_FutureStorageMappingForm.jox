    <JadeMethod name="tblGroups_contextMenu" id="020cf272-020a-4060-b2d2-971bb9b460a3">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGroups_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//  added from 37434
vars
	row		: Integer;
	qrm		: CM_QuantityRangeMap;
begin
	mnuContext.visible := false;
	if app.isAllowedToInspect then
		row := table.row;
		if row &gt; table.fixedRows and
		   row &lt;= table.rows then
			qrm :=  table.accessRow(row).itemObject.CM_QuantityRangeMap;
			if qrm = null or not app.isValidObject(qrm) then
				return false;
			endif;
		
			self.mnuInspect.userObject := qrm;
			self.mnuInspect.visible := true;
			return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);
		endif;
	endif;
	return false;
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
