    <JadeMethod name="btnAddQatar_click" id="b9c9e06f-f185-4b82-89f2-aca9d2f409a0">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddQatar_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2015	cnwndl1	Initial creation	Par 36543

*/

vars

	item, list, text	:String;

begin

	self.doAddAction (self.tblActionsQatar);
	
	list	:= self.getComboListForItem (CM_QatarRule.Item_Qatar, EDIFileType_XML_Milaha_Customs);
	
	self.tblActionsQatar.accessCell (self.tblActionsQatar.rows, 3).comboList := list;
	
	text := self.tblActionsQatar.accessedCell.text;
	
	if text &lt;&gt; null and list.pos (text, 1) = 0 then
		self.tblActionsQatar.accessedCell.text := null;
	endif;

epilog

end; </source>
