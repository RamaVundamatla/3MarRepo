    <JadeMethod name="btnBrowse_click" id="64fe6042-17db-4613-afe7-ad0a44863854">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowse_click(btn: Button input) updating;

vars
	dlg : CMDFileSave;
	
begin
	create dlg transient;

	dlg.fileName := self.txtFileName.text.trimBlanks;
	dlg.createPrompt := false;
	dlg.fileMustExist := false;
	dlg.hideReadOnly := true;
	dlg.noReadOnlyReturn := true;
	dlg.overwritePrompt := false;
	dlg.pathMustExist := true;
	dlg.validate := true;
	dlg.filter := "Text Files (*.txt)|*.txt|Log Files (*.log)|*.log|Output Files (*.out)|*.out|All Files|*.*";
	dlg.defaultExt := ".txt";
	
	if dlg.open &lt;&gt; 0 then
		return;
	endif;

	if self.txtFileName.maxLength &gt; 0 then
		self.txtFileName.text := dlg.fileName.truncatedAt(self.txtFileName.maxLength);
	else
		self.txtFileName.text := dlg.fileName.trimBlanks;
	endif;
		
epilog
	delete dlg;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="fc736316-4d6c-4b31-91d2-434876d15cdd">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

begin
	self.selectedMethodName := null;
	self.modalResult := 1;
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="c0ae0e40-ce1a-4e3b-82d0-4e480c42cad9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

begin
	self.doOK;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMethodNameChanged" id="991febc2-df51-4925-bcad-df2ba672f78a">
        <updating/>
        <source>doMethodNameChanged() updating, protected;

vars
	listbox : ListBox;
	s : String;
	n : Integer;
		
begin
	s := self.txtMethodName.text.trimBlanks;
	listbox := self.lstMethods;

	if s = null then
		listbox.listIndex := -1;
		self.selectedMethodName := null;
		return;
	endif;
	
	n := listbox.findString(1, s);
	
	if n &lt; 1 or n &gt; listbox.listCount then
		listbox.listIndex := -1;
		self.selectedMethodName := null;
		return;
	endif;

	listbox.listIndex := n;
	self.selectedMethodName := listbox.text;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="7eaff778-e27d-484b-b2f6-e6bfb69f8d70">
        <updating/>
        <source>doOK() updating, protected;

begin
	if self.selectedMethodName = null then
		app.msgBox("Please select a method to profile.", "No Method Selected",
			MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.txtMethodName.setFocus;
		return;
	endif;
	
	self.outputFileName := self.txtFileName.text.trimBlanks;
	
	if self.outputFileName = null then
		app.msgBox("Please specify an output filename.", "No Output File",
			MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.txtFileName.setFocus;
		return;
	endif;
	
	self.modalResult := 0;
	self.unloadForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="9ac254d4-0205-4d51-9df3-542e5885395b">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	self.selectedMethodName := null;
	
	self.txtFileName.text := app.mySession.lastProfiledOutputFileName;
	
	if app.mySession.lastProfiledMethodName &lt;&gt; null then
		self.txtMethodName.text := app.mySession.lastProfiledMethodName;
		self.doMethodNameChanged;
	endif;
	
	self.centreWindow;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstMethods_click" id="13ad0c15-f702-4653-86ea-bc0b770f9fde">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMethods_click(listbox: ListBox input) updating;

begin
	self.selectedMethodName := listbox.text;
	self.txtMethodName.text := listbox.text;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstMethods_dblClick" id="4d9ff906-fe05-44c8-86ca-a5129f3ae5de">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMethods_dblClick(listbox: ListBox input) updating;

begin
	self.selectedMethodName := listbox.text;
	self.txtMethodName.text := listbox.text;

	self.doOK;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtMethodName_change" id="cab46be0-3365-4891-a66f-016d1e005eb4">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtMethodName_change(textbox: TextBox input) updating;

begin
	self.doMethodNameChanged;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
