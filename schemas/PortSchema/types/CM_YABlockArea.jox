<Class name="CM_YABlockArea" id="92427cd0-a483-4032-a287-f324614430bd">
    <superclass name="CM_YardAllocationItem"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allLocationsControllers" id="7b6454d4-b943-40d4-9f65-75b19e09e052">
        <memberTypeInverse/>
        <type name="CM_LCArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myParser" id="43bf8f97-cc7d-43dd-a675-9e3bc639e1b1">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_YAParser"/>
        <access>protected</access>
        <Inverse name="CM_YAParser::allBlockAreas"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myTerminalArea" id="e476fc73-29ed-4df2-9542-e45eda555458">
        <embedded/>
        <type name="CM_TerminalArea"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="buildBlock" id="c472f5cd-b343-4030-826b-22d23330b2f7">
        <source>buildBlock(	pYardAllocationObj:CM_YardAllocation;
			pAllBlocksInObj:CM_YABlockArray input;
			pAllBlocksOutObj:CM_YABlockArray input):Boolean;
// --------------------------------------------------------------------------------
// Created:		20 April 2005 by cnwdad1
//
// Purpose:		Build/update a Yard Allocation Block for the Terminal Area and
//				Locations Controllers of the receiver.
//
// Parameters:	pYardAllocationObj - A reference to the Yard Allocation which the
//					Blocks will belong to.
//				pAllBlocksInObj - A collection of all of the current "In" YA Blocks.
//					Any new Blocks will be added to this, and some existing Blocks
//					may be updated.
//				pAllBlocksOutObj - A collection of all of the current "Out" YA Blocks.
//					Any new Blocks will be added to this, and some existing Blocks
//					may be updated.
//
// Returns:		True if the Block was successfully assembled/updated, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allControllers	: CM_LCArray; 
	
begin
	allControllers	:=	self.allLocationsControllers;
	
	self.myTerminalArea.yaBuildBlocks(pYardAllocationObj, allControllers, pAllBlocksInObj, pAllBlocksOutObj);
	
	return true;
end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray" usage="input"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="parseAreaRowString" id="a02226a2-8c8c-425f-919f-9b052c3a4df3">
        <updating/>
        <source>parseAreaRowString(	pParserObj:CM_YAParser;
					pTerminalAreaObj:CM_TerminalArea;
					pRowString:String;
					pErrorMsg:String output):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		13 April 2005 by cnwdad1
//
// Purpose:		Parses the locations within the string of row/column Ids.
//
// Parameters:	pParserObj - A reference to the transient YA Parser object.
//				pTerminalAreaObj - A reference to the Terminal Area of the rows/columns.
//				pRowString - Contains the Area location ID, and a list/range of rows/columns.
//				pErrorMsg - An error message, should any occur.
//
// Returns:		True if the locations were successfully parsed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	allControllersObj	: CM_LCArray;
	controllerObj		: CM_LocationsController;
	charPos				: Integer;
	workString			: String;
	locationRange		: String;
	hyphenPos			: Integer;
	rangeStart			: String;
	rangeEnd			: String;
	
begin
	self.myTerminalArea	:=	pTerminalAreaObj;
	workString			:=	pRowString.cnEcRemoveSubstring(" ");
	charPos				:=	0;
	
	create allControllersObj transient;
	
	while true do
		charPos		:=	charPos + 1;
		
		if charPos &gt; workString.length() then
			break;
		endif;
		
		locationRange	:=	workString.scanUntil(J_key_Comma.Character, charPos).trimBlanks();
		
		if locationRange = null then
			continue;
		endif;
		
		hyphenPos	:=	locationRange.pos(J_key_Hyphen.Character, 1);
		
		if hyphenPos &gt; 0 then
			if hyphenPos = 1 or hyphenPos = locationRange.length() then
				pErrorMsg	:=	"This is a badly formed location range: " &amp;
								pTerminalAreaObj.id &amp; " " &amp; locationRange;
				return false;
			endif;
			
			rangeStart	:=	locationRange[1:(hyphenPos - 1)];
			rangeEnd	:=	locationRange[(hyphenPos + 1):end];
			
			// AKB2005JUL might include a to terminal ID which we do not want. 
			// DQ was testing and entering unnecessary terminal area IDs i.e. B 3002 - B 3011 instead of B3002-3011
			if rangeEnd.length &gt; rangeStart.length then
				rangeEnd := rangeEnd[ (rangeEnd.length - rangeStart.length + 1):end];
			endif;
			
			pTerminalAreaObj.yaFindLCs(rangeStart, rangeEnd, allControllersObj);
		else
			pTerminalAreaObj.yaFindLCs(locationRange, null, allControllersObj);
		endif;
		
		if allControllersObj.isEmpty() then
			pErrorMsg	:=	"No Location Controller was found for this location: " &amp;
									pTerminalAreaObj.id &amp; " " &amp; locationRange;
			return false;
		else
// Avoid duplicates if the same location is entered twice by the user.
//			allControllersObj.copy(self.allLocationsControllers);
			foreach controllerObj in allControllersObj do
				if not self.allLocationsControllers.includes(controllerObj) then
					self.allLocationsControllers.add(controllerObj);
				endif;
			endforeach;
		endif;
		
		if charPos = 0 then
			break;
		endif;
		
		allControllersObj.clear();
	endwhile;
	
	self.myParser	:=	pParserObj;
	return true;
epilog
	delete allControllersObj;
end;</source>
        <Parameter name="pParserObj" type="CM_YAParser"/>
        <Parameter name="pTerminalAreaObj" type="CM_TerminalArea"/>
        <Parameter name="pRowString" type="String"/>
        <Parameter name="pErrorMsg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateForWholeArea" id="c59002de-d49c-422a-b6f1-c321fb82d9ec">
        <updating/>
        <source>populateForWholeArea(	pParserObj:CM_YAParser;
						pTerminalAreaObj:CM_TerminalArea;
						pErrorMsg:String output):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		13 April 2005 by cnwdad1
//
// Purpose:		Populates the receiver with all of the specified Terminal Area's
//				locations.
//
// Parameters:	pParserObj - A reference to the transient YA Parser object.
//				pTerminalAreaObj - A reference to the Terminal Area.
//				pErrorMsg - An error message, should any occur.
//
// Returns:		True if the locations were successfully populated, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	dict : DynaDictionary;
	
begin
	self.myTerminalArea	:=	pTerminalAreaObj;
	create dict transient;
	dict.setMembership(CM_LocationsController);
	dict.addMemberKey(CM_LocationsController::ident.name, false, false);
	dict.endKeys(true);
	pTerminalAreaObj.allLocationsControllers.copy(dict);
	dict.copy(self.allLocationsControllers);
	//pTerminalAreaObj.allLocationsControllers.copy(self.allLocationsControllers);
	self.myParser		:=	pParserObj;
	
	return true;
epilog
	delete dict;
end;</source>
        <Parameter name="pParserObj" type="CM_YAParser"/>
        <Parameter name="pTerminalAreaObj" type="CM_TerminalArea"/>
        <Parameter name="pErrorMsg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateFromLocations" id="318e214e-d723-4622-ab08-18c0b40e2f99">
        <updating/>
        <source>populateFromLocations(_yaParser: CM_YAParser; _locations: CM_LCArray) updating;
//09 September 2008	cnwdw1	
//
vars

begin
	self.myParser := _yaParser;
	self.myTerminalArea := _locations[1].myTerminalArea;
	_locations.copy(self.allLocationsControllers);
end;</source>
        <Parameter name="_yaParser" type="CM_YAParser"/>
        <Parameter name="_locations" type="CM_LCArray"/>
    </JadeMethod>
</Class>
