    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lstBays" id="b86f74b1-da91-4eb9-b2d6-fea82fc984ff">
        <embedded/>
        <type name="CM_DataTable"/>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="bfdc48a9-6cad-4fff-bcf4-63e32dbc61b7">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     02 February 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.permissionView  := PmShipVoyageEnquiryView;
	self.permissionMaint := PmShipVoyageEnquiryMain;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayBays" id="b6826205-97d6-4f1f-9758-5a31745228ba">
        <source>displayBays();
// ---------------------------------------------------------------------------
// Created:     02 February 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aVoyage : CM_Voyage;
	aBay : CM_BayVoyage;
	row : Integer;
begin
	aVoyage := self.myTerminal.allVoyagesByCode.getAtKeyGeq("AORJC04", null);
	
	self.lstBays.rows := 0;
	self.lstBays.columns := 14;
	self.lstBays.selectMode := Table.SelectMode_CurrentRow;
	
	self.lstBays.addItem("ID" &amp; Tab &amp; "Type" &amp; Tab &amp; "Hold" &amp; Tab &amp; "40 Bay" &amp; Tab &amp; "40 Only" &amp; Tab &amp; "20 OD Seq" &amp; Tab &amp; "20 UD Seq" &amp; Tab &amp; "40 OD Seq" &amp; Tab &amp; "40 UD Seq" &amp; Tab &amp; "Plugs" &amp; Tab &amp; "20 IB Max" &amp; Tab &amp; "20 OB Max" &amp; Tab &amp; "TL OD" &amp; Tab &amp; "TL UD");
	self.lstBays.fixedRows := 1;
	self.lstBays.fixedColumns := 1;
	row := 1;

	foreach aBay in aVoyage.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
		self.lstBays.addItem(aBay.id &amp; Tab &amp; aBay.bayTypeString  &amp; Tab &amp; aBay.myHold.ordinalHold.String &amp; Tab &amp; aBay.fortyFootBay.cnEcGetTableCheckBoxValue() &amp; Tab &amp; aBay.fortyFootOnly.cnEcGetTableCheckBoxValue() &amp; Tab &amp; "Cell/Tier" &amp; Tab &amp; "Cell/Tier" &amp; Tab &amp; "Tier/Cell" &amp; Tab &amp; "Tier/Cell" &amp; Tab &amp; aBay.numOfPlugs.String &amp; Tab &amp;  aBay.maxPileWeight20IB.String
			&amp; Tab &amp; aBay.maxPileWeight20OB.String &amp; Tab &amp; aBay.isTwinLiftOD.cnEcGetTableCheckBoxValue() &amp; Tab &amp; aBay.isTwinLiftUD.cnEcGetTableCheckBoxValue());
		row := row + 1;
		self.lstBays.accessCell(row,4).inputType := Table.InputType_CheckBox;
		self.lstBays.accessCell(row,5).inputType := Table.InputType_CheckBox;
		self.lstBays.accessCell(row,13).inputType := Table.InputType_CheckBox;
		self.lstBays.accessCell(row,14).inputType := Table.InputType_CheckBox;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySlots" id="a2fe4691-fc36-4528-99a9-23bd7b2e4952">
        <source>displaySlots();
// ---------------------------------------------------------------------------
// Created:     02 February 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aVoyage : CM_Voyage;
	aBay : CM_BayVoyage;
	row, vcg, lcg, tcg : Integer;
	slot : CM_SlotController;
	deck : String;
begin
	aVoyage := self.myTerminal.allVoyagesByCode.getAtKeyGeq("AORJC04", null);
	
	self.lstBays.rows := 0;
	self.lstBays.columns := 13;
	self.lstBays.selectMode := Table.SelectMode_CurrentRow;
	
	self.lstBays.addItem("Location" &amp; Tab &amp; "Cell" &amp; Tab &amp; "Tier" &amp; Tab &amp; "Deck" &amp; Tab &amp; "VCG" &amp; Tab &amp; "LCG" &amp; Tab &amp; "TCG" &amp; Tab &amp; "Power" &amp; Tab &amp; "40" &amp; Tab &amp; "45" &amp; Tab &amp; "30" &amp; Tab &amp; "20 Door" &amp; Tab &amp; "40 Door");
	self.lstBays.fixedRows := 1;
	self.lstBays.fixedColumns := 1;
	row := 1;

	aBay := aVoyage.myCellularVoyageStructure.allBayVoyagesByOrdinal.first;

	tcg := 35;

	foreach  slot in aBay.allSlotControllersByOrdinal discreteLock do
	
		vcg := ((10 - slot.mySlotDefnVoyage.ordinalTier) * 7);
		lcg := ((5 - slot.mySlotDefnVoyage.ordinalCell) * 2.5).Integer;
		if  slot.mySlotDefnVoyage.isOnDeck then
			deck := "OD";
		else
			deck := "UD";
		endif;
		self.lstBays.addItem(aBay.id &amp; slot.ident &amp; Tab &amp;
		slot.mySlotDefnVoyage.cellId &amp; Tab &amp;
		slot.mySlotDefnVoyage.tierId &amp; Tab &amp;
		deck &amp; Tab &amp;
		
		
		vcg.String &amp; Tab &amp; lcg.String &amp; Tab &amp; tcg.String &amp; Tab &amp; slot.mySlotDefnVoyage.power.cnEcGetTableCheckBoxValue() &amp; Tab &amp; 
		slot.mySlotDefnVoyage.fortyFront.cnEcGetTableCheckBoxValue() &amp; Tab &amp;
		slot.mySlotDefnVoyage.is45.cnEcGetTableCheckBoxValue() &amp; Tab &amp;
		slot.mySlotDefnVoyage.is30.cnEcGetTableCheckBoxValue() &amp; Tab &amp;
		slot.mySlotDefnVoyage.doors20Aft.cnEcGetTableCheckBoxValue() &amp; Tab &amp;
		slot.mySlotDefnVoyage.doors40Aft.cnEcGetTableCheckBoxValue());
		
		
		row := row + 1;
		self.lstBays.accessCell(row,8).inputType := Table.InputType_CheckBox;
		self.lstBays.accessCell(row,9).inputType := Table.InputType_CheckBox;
		self.lstBays.accessCell(row,10).inputType := Table.InputType_CheckBox;
		self.lstBays.accessCell(row,11).inputType := Table.InputType_CheckBox;
		self.lstBays.accessCell(row,12).inputType := Table.InputType_CheckBox;
		self.lstBays.accessCell(row,13).inputType := Table.InputType_CheckBox;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c894d9ed-192c-49e6-9488-c9de65391a54">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     02 February 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	self.caption := "Voyage Bay Definition";
	self.caption := "AOR56578 Bay 03 Slot details";
	
	self.displayBays();
//	self.displaySlots();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="cb8a8deb-4265-42ea-968e-0c827bea7e30">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018508, locale);
end;</source>
    </JadeMethod>
</GUIClass>
