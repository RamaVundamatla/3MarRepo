    <JadeMethod name="exportMyCollections" id="4c9ca478-337a-4e5c-8578-f162e794f45d">
        <source>exportMyCollections(_file:File; _objArray:ObjectArray io; _property:Property);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	object:Object;
	coll:Collection;
begin
	
	if _property.getName = "allCellsOnDeck" then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		coll := self.getPropertyValue(_property.getName).Collection;
		foreach object in coll.CM_CellDefnByOrdinalDict do
			if object.isKindOf(CM_Object) then
				object.CM_Object.exportMe(_file, _objArray);
			endif;
		endforeach;
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	endif;
	if _property.getName = "allCellsUnderDeck" then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		coll := self.getPropertyValue(_property.getName).Collection;
		foreach object in coll.CM_CellDefnByOrdinalDict do
			if object.isKindOf(CM_Object) then
				object.CM_Object.exportMe(_file, _objArray);
			endif;
		endforeach;
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	endif;
	if _property.getName = "allHatchLids" then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		coll := self.getPropertyValue(_property.getName).Collection;
		foreach object in coll.CM_HatchLidSet do
			if object.isKindOf(CM_Object) then
				object.CM_Object.exportMe(_file, _objArray);
			endif;
		endforeach;
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	endif;
	if _property.getName = "allSlotsOnDeck" then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		coll := self.getPropertyValue(_property.getName).Collection;
		foreach object in coll.CM_SlotDefnByCellIdTierIdDict do
			if object.isKindOf(CM_Object) then
				object.CM_Object.exportMe(_file, _objArray);
			endif;
		endforeach;
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	endif;
	if _property.getName = "allSlotsUnderDeck" then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		coll := self.getPropertyValue(_property.getName).Collection;
		foreach object in coll.CM_SlotDefnByCellIdTierIdDict do
			if object.isKindOf(CM_Object) then
				object.CM_Object.exportMe(_file, _objArray);
			endif;
		endforeach;
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	endif;
	if _property.getName = "allTiersUnderDeck" then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		coll := self.getPropertyValue(_property.getName).Collection;
		foreach object in coll.CM_TierDefnByOrdinalDict do
			if object.isKindOf(CM_Object) then
				object.CM_Object.exportMe(_file, _objArray);
			endif;
		endforeach;
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	endif;
	if _property.getName = "allTiersOverDeck" then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		coll := self.getPropertyValue(_property.getName).Collection;
		foreach object in coll.CM_TierDefnByOrdinalDict do
			if object.isKindOf(CM_Object) then
				object.CM_Object.exportMe(_file, _objArray);
			endif;
		endforeach;
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
    </JadeMethod>
    <JadeMethod name="getDefinitionXML" id="f408408d-51bc-4c07-98d5-a852528e6c31">
        <source>getDefinitionXML() : String;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXml, sml : String;
	aSlot : CM_SlotDefn;
begin

	theXml := theXml &amp; "&lt;mv&gt;" &amp; self.myVesselCellular.myVessel.code &amp; "&lt;/mv&gt;" &amp; inheritMethod();

	
	return theXml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="5300666b-30ea-4789-96ea-2648274de5ac">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	childElement : JadeXMLElement;
	pxyHold : CM_VesselHold;
	holdOrdinal : Integer;
begin
	if _property = CM_Bay::myHold then
		childElement:=_xmlElement.getElementByTagName(CM_Hold::ordinalHold.name);
		if childElement &lt;&gt; null then
			holdOrdinal:=childElement.textData.Integer;
			pxyHold:=self.myVesselCellular.allHolds[holdOrdinal].CM_VesselHold;
			if pxyHold = null then
				create self.myHold  as CM_VesselHold transient;
				self.myHold.CM_VesselHold.setProxy(self.myVesselCellular,holdOrdinal);
			else
				self.myHold:=pxyHold;
			endif;
		endif;
	else
		inheritMethod(_property, _xmlElement);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
