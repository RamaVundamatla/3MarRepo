<Class name="CM_DeleteTransactionAuditAgent" id="7b08746e-946d-44c2-a445-7a8c083019ae">
    <superclass name="CM_TransactionAuditAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myUDA" id="333850a4-691f-481c-8f33-28eaa1a0a4ca">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_UtilityDeleteAgent"/>
        <access>protected</access>
        <Inverse name="CM_UtilityDeleteAgent::myDeleteAuditAgent"/>
    </ExplicitInverseRef>
    <JadeMethod name="audDeleteGeneric" id="2d9ec79d-ed3b-4b5d-a28e-8c492e673b3b">
        <source>audDeleteGeneric(pSubject : CM_Object);
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
// ---------------------------------------------------------------------------
vars
	s : String;
	
begin
	if pSubject = null then
		return;
	endif;
	
	if pSubject.isTransient  then //16.10.2019 cnwma1 #46974
		return;
	endif;
	
	s := pSubject.getAuditText;
	app.myAA.auditDeleteTrx(pSubject, s, null);
	
end;</source>
        <Parameter name="pSubject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="audDeleteGenericWithExtraInfo" id="445d2997-1417-4fbc-958f-28d2494721cf">
        <source>audDeleteGenericWithExtraInfo(pSubject : CM_Object; _extraInfo : String);
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
// ---------------------------------------------------------------------------
vars
	s : String;
	
begin
	if pSubject = null then
		return;
	endif;
	
	if pSubject.isTransient  then //16.10.2019 cnwma1 #46974
		return;
	endif;
	
	s := pSubject.getAuditText;
	app.myAA.auditDeleteTrx(pSubject, s, _extraInfo);
	
end;</source>
        <Parameter name="pSubject" type="CM_Object"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
</Class>
