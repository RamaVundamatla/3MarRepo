    <JadeMethod name="canPerformMonitoring" id="6c230d61-1509-42e0-b5b1-9c6e0477ad2b">
        <source>canPerformMonitoring( _passport : CM_Passport ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
19 November 2019	jlgndl1	Initial creation	TFS 47546
19 Obtober 2020		jlgmd1	TFS 49971 - Removed CM_EDIFile.mode check so this method will work for non-web messages too

*/

vars

begin

	if _passport = null then
		return false;
	endif;
	
	if _passport.myCMIFMonitor = null then
		return false;
	endif;

	if self.myEDIFile = null then
		return false;
	endif;
	
	// This prevents non-web files from getting updates!
	/*if self.myEDIFile.mode = null then
		return false;
	endif;*/
	

	return true;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
