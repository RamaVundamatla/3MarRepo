    <JadeMethod name="makeArrCarrVesselSubSectXML" id="4d6b31af-920d-46fa-bc21-8169831b568e">
        <source>makeArrCarrVesselSubSectXML( _ti : CM_TrackedItem; _voyage : CM_Voyage; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277
06 December 2018 jlggb1	Use Inwards voyage for discharges 42351

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	vessel : CM_Vessel;
	foundMatch : Boolean;
	operator : CM_Operator;	//11 Apr 2017	NDL	TFS 4074
	tmpVoyage : CM_Voyage;  //06 Dec 2018   GB1 TFS 42351
	voyageCode : String;    //06 Dec 2018   GB1 TFS 42351

begin

	rootElem := _parentElem.addElement('ArrivalCarrierVessel');
	
	if _ti = null and _voyage = null then	//11 Apr 2017	NDL	TFS 4074
		return;
	endif;
	
	if _voyage &lt;&gt; null then
		vessel := _voyage.getMyVessel();
		operator := _voyage.myOperator;
	elseif _ti &lt;&gt; null then	//11 Apr 2017	NDL	TFS 4074
		if _ti.myVoyage &lt;&gt; null then
			vessel := _ti.myVoyage.getMyVessel();
			operator := _ti.myVoyage.myOperator;
		endif;
	endif;
	
	if vessel = null then
		return;
	endif;
	
	xmlElem := rootElem.addElement('CTO_Reference');
	xmlElem.setText( vessel.getOidString );
	
	xmlElem := rootElem.addElement('LloydsNumber');
	xmlElem.setText( vessel.lloydsNumber );
	
	xmlElem := rootElem.addElement('CallSign');
	xmlElem.setText( vessel.callSign );
	
	xmlElem := rootElem.addElement('Name');
	xmlElem.setText( vessel.name );
	
	xmlElem := rootElem.addElement('Acos_Code');
	xmlElem.setText(  vessel.code );
	
	xmlElem := rootElem.addElement('SOP_VoyageInBound');
	if _voyage &lt;&gt; null then
		tmpVoyage := _voyage;
	else 
		tmpVoyage := _ti.myVoyage;
	endif;
	if tmpVoyage &lt;&gt; null then
		if tmpVoyage.inwardCode &lt;&gt; null then
			voyageCode := tmpVoyage.inwardCode;
		else
			voyageCode := tmpVoyage.code;
		endif;
	endif;
	if operator = null then
		xmlElem.setText(voyageCode);
	else
		xmlElem.setText( operator.getXlationForeignCode(voyageCode, XLATION_TYPE_VOYAGETERMINAL, foundMatch) );
	endif;

/*	
	xmlElem := rootElem.addElement('SOP_VoyageOutBound');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('LOP_VoyageInBound');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('LOP_VoyageOutBound');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ScheduledDeparture');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ScheduledArrival');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('IsVesselChanged');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('IsVoyageChanged');
	xmlElem.setText( null );
*/	

epilog

end;</source>
