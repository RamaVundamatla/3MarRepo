	self.mnuYardAllocRemove.visible := false;	//23 Jul 2020	NDL	TFS 49775 - Not currently coded to do anything.
	self.mnuShowRackShelves.visible := false;
	self.mnuGridSelectAreas.visible := false;
	self.mnuGridHideLegend.visible := true;
	self.mnuGridHideToolbar.visible := true;

	self.mnuGridHideLegend.visible := true;
	self.mnuGridHideMacro.visible := true;
	self.mnuGridHideToolbar.visible := true;
	self.mnuGridSelectAreas.caption := "Select Terminal &amp;Areas...";
	self.mnuGridSelectAreas.visible := true;
	self.mnuGridSelectorClear.visible := not self.myDrawingController.allSelectorTIs.isEmpty;
end;</source>
