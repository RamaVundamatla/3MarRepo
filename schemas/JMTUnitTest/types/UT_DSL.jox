    <JadeMethod name="deleteVbsTimeslotType" id="4b847a95-d7d0-4128-8b1f-223a023fa66f">
        <source>deleteVbsTimeslotType( _code : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation
21 Jun 2022 navsrk20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
*/

vars
	vbtst : CM_VehicleBookingTimeSlotType;
	obj : CM_Object;
	term : CM_Terminal;				//21.06.2022 navsrk20 TFS 53697

begin
	if _code.trimBlanks = null then
		return;
	endif;
	
	term := self.getTerminal();																//21.06.2022 navsrk20 TFS 53697

	//vbtst := app.myRoot.allVehicleBookingTSTypes.getAtKey( _code.trimBlanks.toUpper );	//21.06.2022 navsrk20 TFS 53697
	vbtst := term.allTerminalVBSSlotTypes.getAtKey( _code.trimBlanks.toUpper );				//21.06.2022 navsrk20 TFS 53697
	
	if vbtst = null then
		return;
	endif;
	
	obj := vbtst;

	app.myPassport.clearErrorsWarnings();
	app.myTrxDA.trxDeleteCMObject( obj, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "VehicleBookingTimeSlotype not deleted - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteVehicle" id="04f9d7ec-5a48-46e7-aab5-4e7aca256890">
        <source>deleteVehicle(_reg: Any);
//29 August 2008	cnwdw1	
// 06/07/2011 cnwmh5	Add delete of inter terminal moves
vars
	vehicle: CM_Vehicle;
	job: CM_Job;
	terminal: CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	itm : CM_InterTerminalMove;
	obj			: Object;
	itvj		: CM_InterTermVehicleJob;

	itmArray				: ObjectArray;
	
	mergeIter : MergeIterator;
	iter		: Iterator;
	
	dontDeleteCarrier			: Boolean;

begin
	terminal := self.getTerminal;
	if _reg.isKindOf(String) then
		vehicle := terminal.vehicles[_reg.String, ""];
	else
		vehicle := _reg.CM_Vehicle;
	endif;
	if vehicle &lt;&gt; null then
		foreach job in vehicle.allRoadJobs do
			self.deleteJob(job);
		endforeach;
		
		// delete any inter terminal moves
		create mergeIter transient;
		mergeIter.addCollection(terminal.allInterTerminalMovesIn);
		mergeIter.addCollection(terminal.allInterTerminalMovesOut);
		mergeIter.startKeyGeq(null, null, vehicle.regNumber);
		while mergeIter.next(itm) do
			if itm.vehicleID &lt;&gt; vehicle.regNumber then
				continue;
			endif;
			app.myTrxDA.trxDeleteInterTerminalMove(itm, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endwhile;
		
		// 26/06/2013 cnwmh5 - Check Inter Terminal Move Jobs and remove any for the current vehicle
		create itmArray transient;
		iter := app.myRoot.allInterTerminalVehicleJobs.createIterator;
		app.myRoot.allInterTerminalVehicleJobs.startKeyGeq(vehicle.regNumber, vehicle.state, iter);
		while iter.next(itvj) and itvj.vehicleID = vehicle.regNumber do
			itmArray.clear();
			itvj.allInterTerminalMoves.copy(itmArray);
			foreach obj in itmArray do
				itm := obj.CM_InterTerminalMove;
				app.myTrxDA.trxDeleteInterTerminalMove(itm, app.myPassport);
				self.assertNoTrxErrorsOrWarnings();
			endforeach;
			beginTransaction;
			delete itvj;												// 07/08/2014 cnwmh5
			commitTransaction;
		endwhile;
		
		foreach vvr in vehicle.visitRecords do
			self.deleteVVR(vvr);
		endforeach;
		
		dontDeleteCarrier := self.opts.bool("DontDeleteCarrier");		// 20/08/2012 cnwmh5
		if not dontDeleteCarrier then
			beginTransaction;
			vehicle.carriers.clear();
			commitTransaction;
		endif;
		
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteVehicle(vehicle, app.myPassport); 
		assertNoTrxErrorsOrWarnings();
	endif;
	
epilog
	delete mergeIter;
	delete iter;
	delete itmArray;
end;
</source>
        <Parameter name="_reg" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteVessel" id="1e21978d-467c-45fa-beff-30f096b22bca">
        <source>deleteVessel(_code: String) ;
//29 August 2008	cnwdw1	
//
vars
	vessel: CM_Vessel;
//	root: CM_Root;
	voyage : CM_Voyage;
	invalid : Boolean;
begin
//	root := CM_Root.firstInstance;
//	vessel := root.allVessels[_code];
	vessel	:= self.getVessel( _code );
	if vessel &lt;&gt; null then
	
		on Exception do app.handleDeletedObject( exception, voyage, invalid );
		foreach voyage in vessel.allVoyagesByTermCodeArrival do
			self.deleteVoyage(voyage.code);
		endforeach;
		
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteVessel(vessel, app.myPassport); 
		assertNoTrxErrorsOrWarnings();
	endif;
end;
</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
