    <JadeMethod name="getXMLSettingsForSave" id="8266e58a-90c2-46fe-8f83-682efcf0a7fe">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	xmlStr	: String;
	entRow	: EntTableRow;	
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblPlanned.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblDLR.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblTranShip.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblTBA.getXmlStrForColumns(true); // TFS 45590
	xmlStr := xmlStr &amp; self.tblAll.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourPlanned, self.xmlColourPlanned.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourNonPlanned, self.xmlColourNonPlanned.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourOnShip, self.xmlColourOnShip.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XMLTag_DefaultSummaryFunction, self.defaultDblClickFunction.String);
	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="5cb8e25d-dc71-4e68-86de-1e7b651329ee">
        <updating/>
        <source>getXMLSettingsForSetup() updating;

vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, hideL,hideT,hideM : Boolean;
	zoomScale : Real;
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;
		// #### HIDE MACRO
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HM);
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
	
	self.xmlMacro := hideM;

end;
</source>
    </JadeMethod>
    <JadeMethod name="handleDeletedTI" id="09ae7263-89c5-412e-8e4e-370ffe4782bf">
        <updating/>
        <source>handleDeletedTI(aTI : CM_TrackedItem input) updating;
/*

Purpose:			TFS 45590

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2019	jlgab1	Initial creation

*/

vars
	theRow : Integer;
begin
	if self.tblTBA.findObjectInRow(aTI, theRow) then
		self.tblTBA.removeItem(theRow);
		self.tblTBA.setSortColumnTableObjects(); // Regenerate the dyna dict for the columns (CM_DataTable.allTableObjects)
		self.doNotableRemove(aTI);
		self.doTblDataRenumberItems(self.tblTBA, 0); 
	elseif self.tblPlanned.findObjectInRow(aTI, theRow) then
		self.tblPlanned.removeItem(theRow); // TFS 47702 had incorrect table 
		self.tblPlanned.setSortColumnTableObjects(); // Regenerate the dyna dict for the columns (CM_DataTable.allTableObjects) // TFS 47702 had incorrect table 
		self.doNotableRemove(aTI);
		self.doTblDataRenumberItems(self.tblPlanned, 0); 
	endif;
	if self.tblAll.findObjectInRow(aTI, theRow) then
		self.tblAll.removeItem(theRow); // TFS 47702 had incorrect table 
		self.tblAll.setSortColumnTableObjects(); // Regenerate the dyna dict for the columns (CM_DataTable.allTableObjects) // TFS 47702 had incorrect table 
		self.doNotableRemove(aTI);
		self.doTblDataRenumberItems(self.tblAll, 0); 
	endif;
	self.updateShtCaptions();
epilog

end;</source>
        <Parameter name="aTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleFunctionForObject" id="e38a0461-d63d-4623-b504-a1b7a6822402">
        <updating/>
        <source>handleFunctionForObject(_function: Integer; _allSummariesObj: CMIF_LoadListSummaryObjectSet; _columnKey: Integer) updating;
//----------------------------------------------------------------
//	Created:	16 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	objArray		: CM_ObjectArray;
	cargoEnqForm	: CM_ContainerEnqForm;
	masterTI		: CM_TrackedItem;
	allObjects		: ObjectSet;
	theENQ			: CM_EnquiryController;
	summaryObj		: CMIF_LoadListSummaryObject;
begin
	create objArray transient;
	
	// epr par 16713 deleted all the saving xml on the self.btnQuitSmmryMode.helpKeyword WTF??? 
	
	foreach summaryObj in _allSummariesObj do
		self.getTIsForColumnKey(objArray, summaryObj.allTrackedItems, _columnKey);
	endforeach;
	
	if objArray.isEmpty then
		return;
	endif;
	
	if _function = self.Function_Enquiry then
		masterTI := objArray.first.CM_TrackedItem;
		cargoEnqForm := self.myAssistant.showCargoEnquiryForTIs(masterTI, objArray,	self.myMasterMenuAction, false);
		if cargoEnqForm = null then
			return;
		endif;
		cargoEnqForm.tblData.clearAllSelected();
		cargoEnqForm.tblData.selectObject(masterTI, true);
		
	elseif _function = self.Function_LocateGridRows then
		create allObjects transient;
		objArray.copy(allObjects);
		//theENQ := self.doGetSelectorTIs(allObjects);
		theENQ := self.myAssistant.SHP_Assistant.doGetSelectorTIsLoadList(allObjects, self.myCurrentVoyage);
	
		self.myAssistant.showYardRowEnquiryForm(allObjects, self.myMasterMenuAction,  theENQ, true, VIEW_DISPORT, 3, null); // PAR 19913 PAR 21148
		
	elseif _function = self.Function_ShowInLoadList then
		//make sure DLRs are showing
		self.doQuerySelectorDLR();
		//self.showTableRowsForObjects(objArray, _columnKey);
		self.createFiltersFromObjects(objArray); //25 Jan 2012	NDL	Par 25297
		self.statusStub := _allSummariesObj.getCaptionDisplay();
		self.frmStatLine.caption := self.statusStub;// &amp; " " &amp; $SHP_Summary_Selection_Mode;
		self.doFldMainClick();

	endif;
epilog
	delete objArray;

end;</source>
        <Parameter name="_function" type="Integer"/>
        <Parameter name="_allSummariesObj" type="CMIF_LoadListSummaryObjectSet"/>
        <Parameter name="_columnKey" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleTimerException" id="45215265-7f80-472b-b3f1-fa559f304be3">
        <source>handleTimerException(_exc : Exception) : Integer;
// ---------------------------------------------------------------------------
// Created:    April 2014 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	TimerError	= 1400;
	
vars
	returnVal		: Integer;
	aForm : Form;
begin
	returnVal := Ex_Pass_Back;

	if _exc.errorCode = TimerError then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="90fb1444-8b67-4ea1-8db3-b4bd6b8db7bd">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _userWindow = null then
		return;
	endif;

	inheritMethod(_userWindow);

	self.defaultDblClickFunction := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_DefaultSummaryFunction).Integer;
	self.xmlColourPlanned := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourPlanned).Integer;
	self.xmlColourNonPlanned := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourNonPlanned).Integer;
	self.xmlColourOnShip := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourOnShip).Integer;
	self.setColours();
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="9c1cff3d-c7f3-426a-a97e-0205570fa807">
        <source>initQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	HorzGap = 5;
vars
	sht			: CMUI_Sheet;
	lstTable	: CMUI_ListTable;
begin
	
	sht := self.shtQuery1;
	sht.caption := app.getErrorString(VoyageCapitalV);
	self.cmbVoyageNote.left := HorzGap;
	self.cmbVoyageNote.width := self.cmbVoyageNote.parent.width - (HorzGap * 2);
	sht.visible := true;
	
	sht := self.shtQuery2;
	sht.caption := app.getErrorString(CargoTypes);
	lstTable := self.lstCargoTypes;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;

	sht := self.shtQuery3;
	sht.caption := app.getErrorString(Operators);
	lstTable := self.lstOperators;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;
	
	sht := self.shtQuery4;
	sht.caption := app.getErrorString(Ports);
	lstTable := self.lstPorts;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;
	
	sht := self.shtQuery5;
	sht.caption := "Cargo Position";
	sht.visible := true;
	self.lblCargoPos.width := sht.clientWidth - 25;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initSummaryTable" id="b6555f48-486b-4e19-bcd1-29b7f3c154ef">
        <source>initSummaryTable();
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
02 Jun 2010	cnwkpd1	PAR #21621 - Remove ISO from Grouping heading
25 Nov 2010	cnwdap1	PAR #26426 CCMS MES 1102 Release Requests on Ship Load List
*/

vars
	int			: Integer;
	tableObj	: CM_DataTable;
	colHeading1	: String;			// PAR #26426
	colHeading2	: String;			// PAR #26426
	showRelReqOnLoadList : Boolean;
begin
	tableObj	:=	self.tblSummary;
	
	tableObj.clear();
	tableObj.selectionType	:=	CM_BaseTable.SelectionType_Row;
	tableObj.selectMode		:= Table.SelectMode_WholeRows;
	tableObj.multiSelect	:=	CM_BaseTable.MultiSelect_Simple;
	tableObj.fixed3D 		:= false;
	tableObj.rows			:= 2;
	tableObj.fixedRows		:= 2;
	tableObj.fixedColumns	:= 0;
	tableObj.gridLines		:= true;
	tableObj.gridColor		:= Grey;

	showRelReqOnLoadList:=self.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean;
	if showRelReqOnLoadList then
		tableObj.columns	:= 15;
	else
		tableObj.columns	:= 11;	//18 Nov 2009	NDL	CCMS 1864 Par 21652
	endif;
	// PAR #26426 end of this bit

	self.setColorsForTable(self.tblSummary);

	foreach int in 1 to tableObj.fixedRows do
		tableObj.accessRow(int).alignment	:=	Table.Alignment_Left;
	endforeach;
	
	foreach int in 5 to 8 do
		tableObj.accessColumn(int).alignment	:=	Table.Alignment_Right;
	endforeach;
	
	// PAR #26426 add extra columns for release requests if config says so
	if showRelReqOnLoadList then
		foreach int in 9 to 12 do
			tableObj.accessColumn(int).alignment	:=	Table.Alignment_Right;
		endforeach;
		foreach int in 13 to 15 do
			tableObj.accessColumn(int).alignment	:=	Table.Alignment_Center_Middle;
		endforeach;
	else
		foreach int in 9 to 11 do	//18 Nov 2009	NDL	CCMS 1864 Par 21652
			tableObj.accessColumn(int).alignment	:=	Table.Alignment_Center_Middle;
		endforeach;
	endif;
	// PAR #26426 end of this bit
	
	tableObj.accessColumn(2).width	:=	100;
	tableObj.accessColumn(3).width	:=	100;
	tableObj.accessColumn(4).width	:=	100;
	tableObj.accessColumn(tableObj.columns).alignment	:=	Table.Alignment_Center;
	
	// PAR 1993 changed same columns in new Rail load List
	// PAR #26426 Show release request headings if config says to
	//tableObj.accessCell(1, 2).text := 	app.getErrorString(CM_Type) &amp; Tab &amp;			// PAR #26426
	colHeading1					 := 	app.getErrorString(CM_Type) &amp; Tab &amp;				// PAR #26426
										app.getErrorString(LL_Discharge) &amp; Tab &amp;
										app.getErrorString(LL_Grouping) &amp; Tab &amp;			// PAR #21621
										app.getErrorString(LL_Colour_code) &amp; Tab &amp;
										app.getErrorString(LL_Load) &amp; Tab &amp;
										//app.getErrorString(LL_Load) &amp; Tab &amp;
										//app.getErrorString(LL_Load) &amp; Tab &amp;
										Tab &amp; Tab;	//18 Nov 2009	NDL	CCMS 1864 Par 21652
	if showRelReqOnLoadList then						// PAR #26426
		colHeading1 := colHeading1 &amp; 	app.getErrorString(LL_ReleaseRequestFull) &amp; Tab &amp;	// PAR #26426
										Tab &amp; Tab &amp; Tab;									// PAR #26426
	endif;																					// PAR #26426
										//app.getErrorString(LL_Special)
	colHeading1 := colHeading1 &amp; 		app.getErrorString(LL_Special_stows) &amp; 				// PAR #26426
										Tab &amp; Tab;
	
	tableObj.accessCell(1, 6).mergeCells := Table.MergeCells_Merge;	//18 Nov 2009	NDL	CCMS 1864 Par 21652
	tableObj.accessCell(1, 6).alignment := Table.Alignment_Center_Middle;	//18 Nov 2009	NDL	CCMS 1864 Par 21652
	tableObj.accessCell(1, 9).mergeCells := Table.MergeCells_Merge;	//18 Nov 2009	NDL	CCMS 1864 Par 21652
	if showRelReqOnLoadList then						// PAR #26426
		tableObj.accessCell(1, 9).alignment := Table.Alignment_Center_Middle;				// PAR #26426
		tableObj.accessCell(1, 13).mergeCells := Table.MergeCells_Merge;					// PAR #26426
		tableObj.accessCell(1, 13).alignment := Table.Alignment_Center_Middle;				// PAR #26426
	endif;
	
	//tableObj.accessCell(2, 2).text	:=	"" &amp; Tab &amp;										// PAR #26426
	colHeading2						:=	"" &amp; Tab &amp;											// PAR #26426
										app.getErrorString(LL_Port) &amp; Tab &amp;
//										app.getErrorString(LL_Grouping) &amp; Tab &amp;			// PAR #21621
										Tab &amp; 
										app.getErrorString(LL_ALLOPS) &amp; Tab &amp;
										app.getErrorString(LL_OnSite) &amp; Tab &amp;
										app.getErrorString(LL_Planned) &amp; Tab &amp;
										app.getErrorString(LL_Nonplanned) &amp; Tab;
	if showRelReqOnLoadList then						// PAR #26426
		colHeading2 := colHeading2 &amp;	app.getErrorString(LL_Total) &amp; Tab &amp;				// PAR #26426
										app.getErrorString(LL_Planned) &amp; Tab &amp;				// PAR #26426
										app.getErrorString(LL_Nonplanned) &amp; Tab &amp;			// PAR #26426
										app.getErrorString(LL_Assigned) &amp; Tab;				// PAR #26426
	endif;																					// PAR #26426
	colHeading2 := colHeading2 &amp; 		app.getErrorString(LL_OnSite) &amp; Tab &amp; 	//18 Nov 2009	NDL	CCMS 1864 Par 21652
										app.getErrorString(LL_Colour_coded) &amp; Tab &amp; 	//18 Nov 2009	NDL	CCMS 1864 Par 21652
										app.getErrorString(LL_Planned);	//18 Nov 2009	NDL	CCMS 1864 Par 21652
										
	tableObj.accessCell(1, 2).text := colHeading1;						// PAR #26426
	tableObj.accessCell(2, 2).text := colHeading2;						// PAR #26426
end;</source>
    </JadeMethod>
    <JadeMethod name="initTableData" id="f11234e0-a3c8-40b9-80cf-4c1a7790ccec">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
// ---------------------------------------------------------------------------
// Created:     20 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
begin

	inheritMethod(_theEntDef);
	
	// Data table
	theTable := self.tblData;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	theTable.allowDragSelect := true;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);

	// ################
	// ### PLANNED
	// ################
	theTable := self.tblPlanned;
	
	
	theTable.userInputEnabled := false;
	theTable.allowDragSelect := true;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);

	// ################
	// ### TRANSHIP
	// ################
	theTable := self.tblTranShip;
	
	theTable.userInputEnabled := false;
	theTable.allowDragSelect := true;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);

	// ################
	// ### TBA
	// ################
	theTable := self.tblTBA; // TFS 45590
	
	theTable.userInputEnabled := false;
	theTable.allowDragSelect := true;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);

	// ################
	// ### DLR
	// ################
	theTable := self.tblDLR;
//	process.debug;
	
	theTable.userInputEnabled := false;
	theTable.allowDragSelect := true;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);
	// ################
	// ### All
	// ################
	theTable := self.tblAll;
	
	
	theTable.userInputEnabled := false;
	theTable.allowDragSelect := true;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);


end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="65575c17-0905-48e8-81a0-66990f841255">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		23 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(keyCode, shift);
	if keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.tblData.dragMode := self.DragMode_None;
		
		return;
	elseif keyCode = J_key_A then
		if shift.isControlKeyPressed()
		and not shift.isShiftKeyPressed()
		and not shift.isAltKeyPressed() then
			self.btnSelectAllTIs.click(btnSelectAllTIs);
		endif;
	elseif keyCode = J_key_F8 then
		self.doMnuLLLocateGridAreaClick();
	endif;
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
