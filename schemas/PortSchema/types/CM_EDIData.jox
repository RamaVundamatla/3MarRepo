    <JadeMethod name="getStatusAfterVerifyOrDBLoad" id="06ad9fb3-8be8-445b-912f-dfd0342b023a">
        <source>getStatusAfterVerifyOrDBLoad(_verifyOnly : Boolean; _passport : CM_Passport) : Integer;
/*
Date		Who		Reason
26/06/2012  cnwcs5	Initial creation - par 29747:2 (not included in 8.1.1 patch)
13/08/2012  cnwcs5	par 29124 - included in 8.1.1.patch
17/01/2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
14/05/2025	naviv1	MTN-19104 - MTN - Transport Manifest Handling of locking in EDI Operations
12/08/2025	navdap1	MTN-35604 MSW - Partial Load Voyage EDI
*/
vars
    newStatus : Integer;
	terminal : CM_Terminal;			// MTN-35604
begin
    if _verifyOnly then
        if _passport.noErrors and _passport.noWarnings then
            newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
		else
			if _passport.hasErrors then
				if hasOnlyLockErrors(_passport) then	// MTN-19104 -- Only lock errors
					newStatus := CM_EDIFile.EDI_STATUS_LOCKERROR;
				elseif _passport.allErrors.includesErrorCode(Voyage_departed) then
					newStatus := CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X;
				else
					newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
				endif;
			else
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
			endif;
        endif;
    else  // DB loading
        if _passport.hasErrors() then
			terminal := self.getMyTerminal;			// MTN-35604
            if _passport.allErrors.includesErrorCode(Voyage_departed) then
                newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X;
            elseif hasOnlyLockErrors(_passport) then  // MTN-19104 -- Only lock errors
                newStatus := CM_EDIFile.EDI_STATUS_LOCKERROR;
			// MTN-35604
			elseif self.isKindOf(CM_EDIDataVoyage) and terminal &lt;&gt; null and terminal.getConfig(EdiVoyageAllowPartial).Boolean then
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
            else
                newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
            endif;
        else
            newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
        endif;
    endif;

    return newStatus;
epilog

end;
</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStatusFromEDITrackedItems" id="a761f254-4e09-4dc7-bcbb-227a165f49c2">
        <source>getStatusFromEDITrackedItems(_verifyOnly : Boolean) : Integer;
/*
Purpose:	Determine the status of the receiver when a subset of EDI tracked items have
			been processed.

Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136 (moved code from a utl method to this class)
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	ediTI			: CM_EDITrackedItem;
	loadCount, todoCount, total	:Integer;
	verifyWarnings, 
	verifyErrors	: Boolean;
	status			: Integer;
begin
	if not self.canGetStatusFromEDITrackedItem then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for invalid EDI data type");
		return null;
	endif;
	
	total := self.allEDITrackedItems.size;
	
	foreach ediTI in self.allEDITrackedItems discreteLock do
		if ediTI.status = CM_EDIFile.EDI_STATUS_DBLOADED then
			loadCount := loadCount + 1;
		else
			todoCount := todoCount + 1;
		endif;
		
		if ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS then
			verifyErrors	:=	true;
			
			break;
			
		elseif ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then	
			verifyWarnings	:=	true;
		endif;
	endforeach;
	
	if total = 0 then
		// nothing to do
		status := CM_EDIFile.EDI_STATUS_UNPROCESSED;
		
	elseif loadCount = total then
		// everything is loaded
		if _verifyOnly then
			status := CM_EDIFile.EDI_STATUS_VERIFIED;
		else
			status := CM_EDIFile.EDI_STATUS_DBLOADED;
		endif;
		
	elseif loadCount &gt; 0 then
		// we have some EDi TIs that have DBLoaded and some not
		status := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;		
		
	else
		// nothing has loaded - there are some that have not loaded (obviously)
		if verifyErrors then
			// there are some with verify errors
			status := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
		elseif verifyWarnings then
			// there are some with verify warnings
			status := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
		else
			// must be all OK
			status := CM_EDIFile.EDI_STATUS_VERIFIED;
		endif;
	endif;

	return status;
epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
