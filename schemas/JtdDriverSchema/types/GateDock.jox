begin
	if myCMUI_Navigator.pbProgressBar.caption &lt;&gt; '' then
		return 81;
	endif;
	if myCMUI_Navigator.lblModalInfo.caption &lt;&gt; 'LblModalInfo' then
		return 82;
	endif;
	if myCMUI_Navigator.lblModalMessage.caption &lt;&gt; 'LblModalMessage' then
		return 83;
	endif;
	if myCMUI_Navigator.txtNavFind.text &lt;&gt; '' then
		return 84;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="runTest" id="6d631d3c-c34d-4e0c-8ec9-609a70c03cd4">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
	retCode:Integer;
begin
	create sa transient;
	sa.add('gd002_CUN_lstTest_click');
	sa.add('gd004_CUN_lstTest_dblClick');
	sa.add('gd006_GIOF_cmbTiType_click');
	sa.add('gd008_GIOF_cmbCarrier_click');
	sa.add('gd010_GIOF_cmbCarrier_click');
	sa.add('gd012_GIOF_cmbCarrier_click');
	sa.add('gd014_GIOF_cmbCommodity_click');
	sa.add('gd016_GIOF_picture_click');
	sa.add('gd018_CUN_lstTest_click');
	sa.add('gd020_CUN_lstTest_dblClick');
	sa.add('gd022_CUBRF_cmbVoyage_click');
	sa.add('gd024_CUN_mnuHelp_click');
	sa.add('gd999_tidyUp');

	foreach meth in sa do
		app.doWindowEvents(2000);
		retCode:=self.sendMsg(meth).Integer;
		if retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			write "Test "&amp;meth&amp;" failed with error code "&amp;retCode.String;
			break;
		endif;
	endforeach;
	app.logMessage("All tests completed");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startup" id="38b9b894-7418-4778-b4ad-36d84fda02f2">
        <updating/>
        <source>startup() updating;

begin
	inheritMethod();
end;</source>
    </JadeMethod>
