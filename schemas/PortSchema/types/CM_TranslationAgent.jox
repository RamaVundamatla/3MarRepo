    <JadeMethod name="isIncludedInSearchResults" id="82fcb612-0b86-44c6-91f2-bfc7e2d8bab0">
        <source>isIncludedInSearchResults(_translatableText : XLAT_TranslatableText):Boolean;

vars
	category 		: XLAT_Category;
	searchResults	: XLAT_SearchResults;
begin
	if _translatableText = null then
		return false;
	endif;
	category := _translatableText.myCategory;
	
	if category = null then
		return false;
	endif;
	searchResults := self.allSearchResults[category.constantCategoryName];
	if searchResults = null then
		return false;
	endif;
	
	return searchResults.allTranslatableText[_translatableText.number] &lt;&gt; null;

end;
</source>
        <Parameter name="_translatableText" type="XLAT_TranslatableText"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="replaceTranslationText" id="64786b18-9918-4d86-a4a0-3dede731e463">
        <source>replaceTranslationText(_translation : XLAT_Translation; _searchPhrase : String; _replaceText : String) : String;

vars
	searchPhraseLocal : String;
	searchPhraseLocalFirstCharToUp : String;
	replaceTextLocal : String;
	pos : Integer;
	searchLength : Integer;
	replaceLength : Integer;
	str : String;

begin
	str := _translation.text;
	searchLength := _searchPhrase.length;
	replaceLength := _replaceText.length;
	
	// Loop to replace all occurrences of searchPhrase.
	pos := _translation.text.toLower.pos(_searchPhrase.toLower, 1);
	while pos &gt; 0 do
		searchPhraseLocal := str[pos : searchLength];
	
		// Rudimentary attempt to match the case of the replacement text to that of the search text.
		replaceTextLocal := _replaceText;
		if searchPhraseLocal = searchPhraseLocal.toLower then
			replaceTextLocal := replaceTextLocal.toLower;
		elseif searchPhraseLocal = searchPhraseLocal.toUpper then
			replaceTextLocal := replaceTextLocal.toUpper;
		else
			searchPhraseLocalFirstCharToUp := searchPhraseLocal;
			searchPhraseLocalFirstCharToUp.firstCharToUpper;
			if searchPhraseLocalFirstCharToUp = searchPhraseLocal then
				replaceTextLocal.firstCharToUpper;
			endif;
		endif;
	
		// Substitute the replacement text in the reconstructed translation string.
		if str.length &lt; pos + searchLength then
			str := str[1 : pos - 1] &amp; replaceTextLocal;
		else
			str := str[1 : pos - 1] &amp; replaceTextLocal &amp; str[pos + searchLength : end];
		endif;
		
		// searchPhrase may occur more than once.
		pos := str.toLower.pos(_searchPhrase.toLower, pos + replaceLength);

	endwhile;

	return str;
end;
</source>
        <Parameter name="_translation" type="XLAT_Translation"/>
        <Parameter name="_searchPhrase" type="String"/>
        <Parameter name="_replaceText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
