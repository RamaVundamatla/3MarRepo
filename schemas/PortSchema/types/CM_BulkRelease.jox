    <JadeMethod name="getLoadedAmountsForTarget" id="db6c723e-48cb-422e-b694-4090655c0b26">
        <source>getLoadedAmountsForTarget(	_targetLocation : CM_LocationsController;
							_countLoaded 	: Integer output;
							_countToLoad 	: Integer output;
							_weightLoaded	: Decimal output;
							_weightToLoad 	: Decimal output);	// 11/01/2024	navcs2	ChangeRequest 61549
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	jlier1	Initial creation 51789
22 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
11/01/2024	navcs2	ChangeRequest 61549: EUP | Release Request by Weight - Pack/Load, Rail Lander
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti				: CM_TrackedItem;
	wagon 			: CM_Wagon;
	lc 				: CM_LocationsController;
	wle				: CM_WorkListEntry;
	job				: CM_Job;
	reserveDetail	: CM_ReserveDetail;
	tiSet			: CM_TISet;

begin
	if  _targetLocation = null then
		return;
	endif;
	
	if _targetLocation.isWagon then
		wagon := _targetLocation.CM_WagonController.myWagon;
	endif;
	
	create tiSet transient;
	self.allTrackedItemsAssigned.copy(tiSet);							//06.03.2025 navma1 #MTN-34179
	
	foreach ti in tiSet discreteLock do									//06.03.2025 navma1 #MTN-34179
		
		lc := ti.myPrimaryActualLocation;
		
		if wagon &lt;&gt; null then
			if lc = null or not lc.isWagon then
				continue;
			endif;
			if lc.CM_WagonController.myWagon &lt;&gt; wagon then
				continue;
			endif;	
		else
			if lc &lt;&gt; _targetLocation then
				continue;
			endif;
		endif;
		_countLoaded	:=_countLoaded   + ( ti.totalQuantity.max(1) );
		_weightLoaded 	:= _weightLoaded + ti.totalWeight;
	endforeach;
	
	if wagon &lt;&gt; null then
		foreach lc in wagon.allLocationsControllersArray discreteLock do
			foreach wle in lc.CM_WagonController.allRailWLELoad discreteLock do		//06.03.2025 navma1 #MTN-34179
				if wle.myRequest &lt;&gt; null then
					reserveDetail := wle.myRequest.myReserveDetail;
					if reserveDetail &lt;&gt; null and reserveDetail.myReserveHeader = self then									// 30/01/2024	navcs2	ChangeRequest 61549
						if reserveDetail.byTypeByWeight then																// 30/01/2024	navcs2	ChangeRequest 61549
							if wagon.maxCargoWeight &lt;&gt; 0 and wagon.maxCargoWeight &lt; reserveDetail.getWeightOutstanding then	// 30/01/2024	navcs2	ChangeRequest 61549
								_weightToLoad := wagon.maxCargoWeight;														// 30/01/2024	navcs2	ChangeRequest 61549
							else 																							// 30/01/2024	navcs2	ChangeRequest 61549
								_weightToLoad := reserveDetail.weightRequested;												// 30/01/2024	navcs2	ChangeRequest 61549
							endif;																							// 30/01/2024	navcs2	ChangeRequest 61549
						else							
							if reserveDetail.myReserveHeader = self then
								_countToLoad	:= _countToLoad  + wle.quantity.max(1);								// 30/01/2024	navcs2	ChangeRequest 61549
								_weightToLoad	:= _weightToLoad + wle.myRequest.weightRequested;					// 11/01/2024	navcs2	ChangeRequest 61549
							endif;
						endif;
					endif;
				endif;
			endforeach;
		endforeach;
	else
		if _targetLocation.isVehicle then
			job := _targetLocation.CM_VehicleController.vehicle.getCurrentRoadJob;
		elseif _targetLocation.isTILCController then
			job := _targetLocation.CM_TILCController.myTILC.jobRoadRelease;
		endif;
		if job &lt;&gt; null then
			foreach wle in job.workListEntries discreteLock do
				if wle.myRequest &lt;&gt; null then
					if wle.myRequest.myOriginatingBulkRelease = self then
						_countToLoad		:=_countToLoad + wle.quantity.max(1);
						if wle.isYardWle then
							_weightToLoad	:=_weightToLoad + wle.CM_YardWLE.getReleaseGateWeight;	// 11/01/2024	navcs2	ChangeRequest 61549
						endif;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	if self.type = BR_TYPE_SHIP and _targetLocation.isVoyageController  then		//22.12.2023 navhl20 #61092[61621]
		
		foreach ti in self.allTrackedItemsReleased discreteLock do
			if ti.myPrimaryActualLocation &lt;&gt; _targetLocation then
				continue;
			endif;
			_countLoaded	:=	_countLoaded  + ( ti.totalQuantity.max(1) );
			_weightLoaded	:=  _weightLoaded + ti.totalWeight;
		endforeach;
		_countToLoad	:= self.totalRequested;
		_weightToLoad	:= self.getWeightRequested;											// 11/01/2024	navcs2	ChangeRequest 61549
	endif;
epilog
	delete tiSet;
end;</source>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_countLoaded" type="Integer" usage="output"/>
        <Parameter name="_countToLoad" type="Integer" usage="output"/>
        <Parameter name="_weightLoaded" type="Decimal" usage="output"/>
        <Parameter name="_weightToLoad" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getLocation" id="48cb9697-371b-4aab-91fe-2cfee59a3d6a">
        <source>getLocation() : String;
// Get the primary location of the bulk release
vars
begin
	if self.allReserveDetails.size &gt; 0 then
		return self.allReserveDetails.first.getLocation();
	endif;	
	return "";
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMTTotalOutstanding" id="b44c6901-3ca3-4f74-a88f-e8867fcbcd69">
        <source>getMTTotalOutstanding() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2012	cnwndl1	Initial creation	Par 28931

*/

vars

begin
	return self.getMTTotalRequested() - self.getMTTotalReleased();

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMTTotalReleased" id="2390b616-8d08-428e-9958-5f62d2df70d7">
        <source>getMTTotalReleased():Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/04/2012	cnwndl1	Initial creation	Par 28931
12/04/2016	cnwdap1	PAR #37677 Packing releases can count non-MT containers as when a container is packed 
					as part of a packing release it should no longer be treated as outstanding
*/

vars
	reserveDetail : CM_ReserveDetail;
	totalMTsReleased : Integer;
	ti : CM_TrackedItem;
	count : Integer;
begin
	foreach reserveDetail in self.allReserveDetails do
		count := 0;
		foreach ti in reserveDetail.allTrackedItemsReleased do
			if self.isPackingType and ti.isContainer and ti.getISOTypeObject &lt;&gt; null and ti.getISOTypeObject.isContainer then	// PAR #37677
				count := count + 1;																								// PAR #37677
			//if ti.isEmpty and ti.isContainer and ti.getISOTypeObject &lt;&gt; null and ti.getISOTypeObject.isContainer then			// PAR #37677
			elseif ti.isEmpty and ti.isContainer and ti.getISOTypeObject &lt;&gt; null and ti.getISOTypeObject.isContainer then		// PAR #37677
				count := count + 1;
			endif;
		endforeach;
		totalMTsReleased := totalMTsReleased + count;
	endforeach;

	return totalMTsReleased;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMTTotalRequested" id="5fd1c901-39cb-4406-b313-0aeb67d21e9e">
        <source>getMTTotalRequested():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2012	cnwndl1	Initial creation	Par 28931

*/

vars
	reserveDetail : CM_ReserveDetail;
	isoType : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
	totalMTsRequested : Integer;
	count : Integer;
	
begin

	if not self.isForMTs then
		return 0;
	endif;
	
	foreach reserveDetail in self.allReserveDetails do
		isoType := reserveDetail.getISOType;
		if isoType = null then
			isoGroup := reserveDetail.getISOGroup;
			if isoGroup &lt;&gt; null and not isoGroup.allISOTypes.isEmpty then
				isoType := isoGroup.allISOTypes.first();
			endif;
		endif;
		if isoType &lt;&gt; null and isoType.isContainer then
			if self.releaseByType then
				totalMTsRequested := totalMTsRequested + reserveDetail.totalRequested;
			else
				totalMTsRequested := totalMTsRequested + 1;
			endif;
		endif;
	endforeach;

	return totalMTsRequested;
	
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaskIdString" id="c9e2fee9-130b-4ceb-b828-350a83196b41">
        <source>getMaskIdString():String;
/*
	Created on 25 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	str : String;
	res : CM_ReserveDetail;
begin
	foreach res in allReserveDetails do 
		if str = '' then
			str := str &amp; res.getMaskIdString;
		else
			str := str &amp; ',' &amp; res.getMaskIdString;
		endif;
	endforeach;
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMatchingReserveSelection" id="78286b12-0008-4021-8511-ba7b79bcac94">
        <source>getMatchingReserveSelection(_ti : CM_TrackedItem) : CM_ReserveSelection;
/* ---------------------------------------------------------------------------
Created:     09 March 2010 by cnwrs2

Purpose:     Trys to find the bast match line on the reserve selection
  
Change Date	Who		Reason
30 Jun 2025 navma1 MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
06/11/2025	navcs2	MTN-36068 STWR | CargoFieldUpdate cannot attach specific items when Release Request contains container line and child detail filtered by Cargo Group
------------------------------------------------------------------------------*/
vars
	reserveDetail	: CM_ReserveDetail;
	bestMatch		: CM_ReserveSelection;
	tiCargoType		: CM_CargoType;
begin
	tiCargoType := _ti.myCargoType;												//30.06.2025 navma1 #MTN-34090

	foreach reserveDetail in  self.allReserveDetails discreteLock do 	
		if reserveDetail.CM_ReserveSelection.myCargoType = tiCargoType then		//30.06.2025 navma1 #MTN-34090
			if reserveDetail.CM_ReserveSelection.isMatchForISOTypeProduct(_ti, false) then
				bestMatch := reserveDetail.CM_ReserveSelection;
				return bestMatch;												// 06/11/2025	navcs2	MTN-36068
			endif;
		endif;
	endforeach;
	
	// 06/11/2025	navcs2	MTN-36068 Start
	// need to also check the packing reserveDetails if the BR is type packing
	// They are stored in a separate collection to the one above so will never be checked otherwise
	// Also only check if we havent already found a match to not change the behaviour from before
	if bestMatch = null and self.type = BR_TYPE_PACKING then
		foreach reserveDetail in self.allReservePackingChildren do
			if reserveDetail.CM_ReserveSelection.myCargoType = tiCargoType then		
				bestMatch := reserveDetail.CM_ReserveSelection;
				return bestMatch;
			endif;
		endforeach;
	endif;
	// 06/11/2025	navcs2	MTN-36068
	

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="getMyCargoType" id="e10dd48b-e529-4f6a-86dd-3e6f6402e522">
