    <JadeMethod name="buildSelf" id="b2851e4e-206b-45aa-86e6-f478f82a4604">
        <updating/>
        <source>buildSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Create all the child controls which are part of this one - called
//				once only, at windowCreated time.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	weekDay			: Integer;
	monthWeek		: Integer;
	headingLabelObj	: CnEcCalendarHeading;
	dayFrameObj		: CnEcCalendarDay;

begin
	// First create headings.
	
	if self.myMonthHeading &lt;&gt; null then
		delete self.myMonthHeading;
	endif;
	
	create self.myMonthHeading transient;
	self.myMonthHeading.parent		:= self;
	self.myMonthHeading.foreColor	:= self.headingTextColor;
	self.myMonthHeading.backColor	:= self.headingColor;
	self.myMonthHeading.cnEcCopyFontSettings(self);
	self.form.addControl(self.myMonthHeading);

	self.allDayHeadings.purge();
	
	foreach weekDay in 1 to 7 do
		create headingLabelObj transient;
		headingLabelObj.parent		:= self;
		headingLabelObj.foreColor	:= self.headingTextColor;
		headingLabelObj.backColor	:= self.headingColor;
		headingLabelObj.cnEcCopyFontSettings(self);
		self.form.addControl(headingLabelObj);
		self.allDayHeadings.add(headingLabelObj);
	endforeach;

	// Then create all the day frames that might be required.
	
	self.allDays.purge();
	
	foreach monthWeek in 1 to 6 do
		foreach weekDay in 1 to 7 do
			create dayFrameObj transient;
			
			dayFrameObj.setMyCalendar(self);
			dayFrameObj.parent	:= self;
			dayFrameObj.cnEcCopyFontSettings(self);
			self.form.addControl(dayFrameObj);
			self.allDays.add(dayFrameObj);
		endforeach;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="changeColors" id="b2aadcb8-0477-483d-86bf-611f4f00b9c5">
        <updating/>
        <source>changeColors(	pNewAvailableColor:Integer;
				pNewAvailableTextColor:Integer;
				pNewUnavailableColor:Integer;
				pNewUnavailableTextColor:Integer;
				pNewHighlightColor:Integer;
				pNewHighlightTextColor:Integer;
				pNewHeadingTextColor:Integer;
				pNewHeadingBackColor:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Action a pending change in one of the colors of the control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
   	controlObj	: Control;

begin
  	// Heading colour change.
  	
  	if pNewHeadingTextColor &lt;&gt; self.headingTextColor then
  		self.myMonthHeading.foreColor	:=	pNewHeadingTextColor;

  		foreach controlObj in self.allDayHeadings do
  			controlObj.foreColor := pNewHeadingTextColor;
  		endforeach;
  	endif;
  	
  	if pNewHeadingBackColor &lt;&gt; self.headingColor then
  		self.myMonthHeading.backColor := pNewHeadingBackColor;
  		
  		foreach controlObj in self.allDayHeadings do
  			controlObj.backColor := pNewHeadingBackColor;
  		endforeach;
  	endif;

	// Any other colour change.
	
	if pNewAvailableColor &lt;&gt; self.availableColor
	or pNewAvailableTextColor &lt;&gt; self.availableTextColor
	or pNewUnavailableColor &lt;&gt; self.unavailableColor
	or pNewUnavailableTextColor &lt;&gt; self.unavailableTextColor
	or pNewHighlightColor &lt;&gt; self.highlightColor
	or pNewHighlightTextColor &lt;&gt; self.highlightTextColor
	then
		foreach controlObj in self.allDays do
			if controlObj.backColor = self.highlightColor or controlObj.foreColor = self.highlightTextColor then
				controlObj.backColor	:= pNewHighlightColor;
				controlObj.foreColor	:= pNewHighlightTextColor;
				
			elseif controlObj.CnEcCalendarDay.dayNo &lt;&gt; 0 then
				controlObj.backColor	:= pNewAvailableColor;
				controlObj.foreColor	:= pNewAvailableTextColor;
				
			else
				controlObj.backColor	:= pNewUnavailableColor;
				controlObj.backColor	:= pNewUnavailableTextColor;
				
			endif;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pNewAvailableColor" type="Integer"/>
        <Parameter name="pNewAvailableTextColor" type="Integer"/>
        <Parameter name="pNewUnavailableColor" type="Integer"/>
        <Parameter name="pNewUnavailableTextColor" type="Integer"/>
        <Parameter name="pNewHighlightColor" type="Integer"/>
        <Parameter name="pNewHighlightTextColor" type="Integer"/>
        <Parameter name="pNewHeadingTextColor" type="Integer"/>
        <Parameter name="pNewHeadingBackColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clear" id="9abc008e-e186-473e-be14-272a92ed4fbf">
        <updating/>
        <source>clear() updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Clear all the contents of the calendar - remove all events
//				associated with the calendar, and redraw the current month,
//				clearing all highlights
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allEventsByDate.purge();
	self.setSelectedDate(null, false);
	self.redrawSelf();
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="377a9561-a268-4cd3-88a6-d288ca64fc5c">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    self.availableColor			:= White;
    self.availableTextColor		:= Black;
    self.unavailableColor		:= DarkGray;
    self.unavailableTextColor	:= Gray;
    self.highlightColor			:= Red;
    self.highlightTextColor		:= White;
    self.headingTextColor		:= Black;
    self.headingColor			:= White;
    self.weekStartsOn			:= 1;
    self.isShowWeekends			:= true;
    self.isShowMonthHeading		:= true;
    self.isMonthHeadingBold		:= true;
end;</source>
    </JadeMethod>
    <JadeMethod name="dayClick" id="269f79cf-e873-4b84-a74f-aa4718dd3c80">
        <updating/>
        <source>dayClick(pDay : Integer) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		This method is invoked when a day (date) is clicked.
//
// Parameters:	pDay - The day number that was clicked.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateClicked	: Date;

begin
	dateClicked.setDate(pDay, self.currentMonth, self.currentYear);
	self.setSelectedDate(dateClicked, false);
	self.click(self);
end;</source>
        <Parameter name="pDay" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dayDblClick" id="91d44923-5a9f-46a1-9910-6cce339cba15">
        <updating/>
        <source>dayDblClick(pDay : Integer) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		This method is invoked when a day (date) is double-clicked.
//
// Parameters:	pDay - The day number that was clicked.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.dblClick(self);
end;</source>
        <Parameter name="pDay" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAddEvent" id="f7d3f655-0b78-4c7f-ac8b-ba8777d6eac8">
        <updating/>
        <source>doAddEvent(pEventObj:CnEcCalendarEvent input; pIsHighlight:Boolean):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		04 May 2008 by cnwdad1
//
// Purpose:		Adds the specified calendar event to Calendar. If highlight is true,
//				then switch the display to the month of the event, and highlight
//				the day.
//
// Parameters:	pEventObj - A reference to the event object to add to the calendar.
//				pIsHighlight (Boolean) - Indicates whether to highlight the event.
//
// Returns:		True if the event was added successfully, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// --------------------------------------------------------------------------------
begin
	pEventObj.setMyCalendarControl(self);

	// Switch to date and highlight if necessary.
	
	if pIsHighlight then
		self.setSelectedDate(pEventObj.eventDate, true);
	endif;

	// If the date is visible then redisplay the caption.
	
	if self.isDateVisible(pEventObj.eventDate) then
		self.findControlForDay(pEventObj.eventDate.day).CnEcCalendarDay.refreshCaption();
	endif;

	return true;
end;</source>
        <Parameter name="pEventObj" type="CnEcCalendarEvent" usage="input"/>
        <Parameter name="pIsHighlight" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClearHighlightedDays" id="04eb0393-9764-42ce-957d-707005579e9a">
        <updating/>
        <source>doClearHighlightedDays() updating;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Resets the background color of all highlighted (and available) days.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj	: Control;
	
begin
	foreach controlObj in self.allDays do
		if controlObj.backColor = self.highlightColor or controlObj.foreColor = self.highlightTextColor then
			controlObj.backColor	:=	self.availableColor;
			controlObj.foreColor	:=	self.availableTextColor;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateEvent" id="7cb7ab88-dfb6-4709-8350-ac081a207d78">
        <updating/>
        <source>doCreateEvent(pDate:Date; pDisplay:String; pAssociatedObject:Object; pIsHighlight:Boolean):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Create a calendar event on the requested date, with the specified
//				display text, and with the associated object. If highlight is true,
//				then switch the display to the month of the event, and highlight
//				the day.
//
// Parameters:	pDate (Date) - The date of the event.
//				pDisplay (String) - A display value for the event.
//				pAssociatedObject (Object) - The object to be asociated with the event.
//				pIsHighlight (Boolean) - Indicates whether to highlight the event.
//
// Returns:		True if the event is created successfully, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/05/2001	cnwdad1		Where the display text was being set for an event, the
//							"display" method was being used instead of the
//							"pDisplay" parameter.
// --------------------------------------------------------------------------------
vars
	eventObj	: CnEcCalendarEvent;

begin
	create eventObj transient;
	eventObj.setEventDate(pDate);
//	eventObj.setDisplayText(display);		// cnwdad1 28/05/2001.
	eventObj.setDisplayText(pDisplay);		// cnwdad1 28/05/2001.
	eventObj.setAssociatedObject(pAssociatedObject);
	eventObj.setMyCalendarControl(self);

	// Switch to date and highlight if necessary.
	
	if pIsHighlight then
		self.setSelectedDate(pDate, true);
	endif;

	// If the date is visible then redisplay the caption.
	
	if self.isDateVisible(pDate) then
		self.findControlForDay(pDate.day).CnEcCalendarDay.refreshCaption();
	endif;

	return true;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pDisplay" type="String"/>
        <Parameter name="pAssociatedObject" type="Object"/>
        <Parameter name="pIsHighlight" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteEventsForDate" id="8baafabc-2a88-469f-9f44-ae3c473b44e3">
        <updating/>
        <source>doDeleteEventsForDate(pDate : Date) : Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Delete all the events on the date specified, and redraw the date
//				if necessary.
//
// Parameters:	pDate (Date) - The date whose events will be deleted.
//
// Returns:		True if at least one event was deleted, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	eventIterObj		: Iterator;
	eventObj			: CnEcCalendarEvent;
  	isAnEventDeleted	: Boolean;

begin
	isAnEventDeleted	:= false;
 	eventIterObj		:= self.allEventsByDate.createIterator();

	self.allEventsByDate.startKeyGeq(pDate, null, eventIterObj);
	
	while eventIterObj.next(eventObj) do
		if eventObj.eventDate &lt;&gt; pDate then
			break;
		endif; 

		isAnEventDeleted := true;
		delete eventObj;
	endwhile;

	if isAnEventDeleted and self.isDateVisible(pDate) then
		self.findControlForDay(pDate.day).CnEcCalendarDay.refreshCaption();
	endif;

	return isAnEventDeleted;
epilog
	delete eventIterObj;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteEventsForObject" id="91a0a4cd-9020-4eba-97d0-3ac4217d4088">
        <updating/>
        <source>doDeleteEventsForObject(pAssociatedObject : Object) : Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Delete all events from the calendar that are associated with the
//				object, and redraw the calendar if required.
//
// Parameters:	None
//
// Returns:		True if any events are found, false otherwise.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	eventIterObj		: Iterator;
	eventObj			: CnEcCalendarEvent;
  	isAnyEventsDeleted	: Boolean;
  	redrawDate			: Date;

begin
	isAnyEventsDeleted	:= false;
 	eventIterObj		:= self.allEventsByObject.createIterator();

	self.allEventsByObject.startKeyGeq(pAssociatedObject, null, eventIterObj);

	redrawDate	:= null;	
	
	while eventIterObj.next(eventObj) do
		if eventObj.associatedObject &lt;&gt; pAssociatedObject then
			break;
		endif; 

		isAnyEventsDeleted := true;				// Found at least one.
		
		if self.isDateVisible(eventObj.eventDate) then
			redrawDate := eventObj.eventDate;		// And it's in the current month.
		endif;

		delete eventObj;

		// Now refresh the date just deleted from
		if redrawDate &lt;&gt; null then
			self.findControlForDay(redrawDate.day).CnEcCalendarDay.refreshCaption();
			redrawDate := null;
		endif;

	endwhile;

	return isAnyEventsDeleted;
epilog
	delete eventIterObj;
end;</source>
        <Parameter name="pAssociatedObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteSpecificEvent" id="daebb66f-a483-4270-8ed8-eb2779c42506">
        <source>doDeleteSpecificEvent(pEventObj:CnEcCalendarEvent io):Boolean;
// --------------------------------------------------------------------------------
// Created:		04 May 2008 by Darrell2
//
// Purpose:		Deletes the specific event from the Calendar.
//
// Parameters:	pEventObj - A reference to the event to delete.
//
// Returns:		True if the event was deleted, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.allEventsByDate.includes(pEventObj) then
		// Automatic inverse maintenance should remove this from the control's collections.
		delete pEventObj;
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="pEventObj" type="CnEcCalendarEvent" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHighlightDate" id="e87233df-89ca-41e2-bc8f-8cc35793db91">
        <updating/>
        <source>doHighlightDate(pDate:Date; pIsChangeMonth:Boolean) : Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Highlight the date passed, changing to the necessary month if
//				pChangeMonth is true.
//
// Parameters:	pDate (Date) - The date to be highlighted.
//				pChangeMonth (Boolean) - Indicates whether the month can be changed.
//
// Returns:		True if the date was successfully highlighted.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj	: Control;

begin
 	if pIsChangeMonth then
 		self.setDisplayMonth(pDate.month, pDate.year);
 	else
 		// Return false if the date is not in the current month.
 		
 		if pDate.month &lt;&gt; self.currentMonth or pDate.year &lt;&gt; self.currentYear then
 			return false;
 		endif;
 	endif;

	controlObj := self.findControlForDay(pDate.day);

	if controlObj = null then
		return false;
	endif;

	if not controlObj.visible then			// Must be a weekend day not showing.
		return false;
	endif;

	controlObj.backColor	:= self.highlightColor;
	controlObj.foreColor	:= self.highlightTextColor;
	return true;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pIsChangeMonth" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHighlightDatesForObject" id="5b984513-fa37-401c-aa09-cb8d8674ff49">
        <updating/>
        <source>doHighlightDatesForObject(pObject : Object) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Find all the events associated with the specified object, and
//				switch the display to the first one, then highlight all the ones
//				in the same month.
//
// Parameters:	pObject (Object) - The object wose events to find.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	eventIterObj	: Iterator;
	eventObj		: CnEcCalendarEvent;
	isFirst			: Boolean;
	controlObj		: Control;

begin
 	eventIterObj := self.allEventsByObject.createIterator();

	self.allEventsByObject.startKeyGeq(pObject, null, eventIterObj);
	isFirst		:= true;

	while eventIterObj.next(eventObj) do
		if eventObj.associatedObject &lt;&gt; pObject then
			break;
		endif; 

 		if isFirst then
 			self.setSelectedDate(eventObj.eventDate, true);
 			isFirst		:= false;
 		else
			if self.isDateVisible(eventObj.eventDate) then
				controlObj				:= self.findControlForDay(eventObj.eventDate.day);
				controlObj.backColor	:= self.highlightColor;
				controlObj.foreColor	:= self.highlightTextColor;
			endif;
		endif;

		// Skip any other entries for this date.
		
		self.allEventsByObject.startKeyGtr(pObject, eventObj.eventDate, eventIterObj);
	endwhile;
epilog
	delete eventIterObj;
end;</source>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doResetRepeatDates" id="6530c3cc-981b-4d05-8419-a791684869ea">
        <source>doResetRepeatDates():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		22 May 2008 by cnwdad1
//
// Purpose:		Resets the repeat dates for all repeating events.
//
// Parameters:	None
//
// Returns:		True if a matching repeat date has been reset.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateStart	: Date;
	dateEnd		: Date;
	eventObj	: CnEcCalendarEvent;
	isRepeatSet	: Boolean;
	
begin
	dateStart.setDate(1, self.currentMonth, self.currentYear);
	dateEnd.setDate(dateStart.cnEcDaysInMonth(), self.currentMonth, self.currentYear);
	isRepeatSet	:=	false;
	
	foreach eventObj in self.allEventsByDate do
		if eventObj.isRepeating then
			if eventObj.isRepeatInRange(dateStart, dateEnd) then
				isRepeatSet	:=	true;
			endif;
		endif;
	endforeach;
	
	return isRepeatSet;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findControlForDay" id="5f4933f2-070e-4e35-abbf-65a7bd5caa1e">
        <source>findControlForDay(pDay : Integer) : Control;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Within the currently displayed month, find the control for the day
//				specified, if it is valid.
//
// Parameters:	pDay (Integer) - The day number whose control to find.
//
// Returns:		A reference to the control representing the specified day.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj	: Control;

begin
	// Check for an invalid day.
	
	if pDay &lt; 1 or pDay &gt; self.currentMonth.cnEcDaysInMonth(self.currentYear.cnEcIsLeapYear()) then
		return null;
	endif;

 	foreach controlObj in self.allDays do
 		if controlObj.CnEcCalendarDay.dayNo = pDay then
 			return controlObj;
 		endif;
 	endforeach;

	return null;
end;</source>
        <Parameter name="pDay" type="Integer"/>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="getDatesForObject" id="6d4f1fdc-782b-4234-8436-e5537a29a63c">
        <source>getDatesForObject(pAssociatedObject : Object; pDateArray : DateArray input);
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Get a list of unique dates on which events associated with the 
//				requested object occur, and fill the array with those dates.
//
// Parameters:	pAssociatedObject (Object) - The object whose dates to list.
//				pDateArray (DateArray) - The array of returned dates.
//
// Returns:		An array of dates.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	eventIterObj	: Iterator;
	eventObj		: CnEcCalendarEvent;

begin
	// Clear out array to start.
	
 	pDateArray.clear();
 	eventIterObj	:= self.allEventsByObject.createIterator();

	self.allEventsByObject.startKeyGeq(pAssociatedObject, null, eventIterObj);
	
	while eventIterObj.next(eventObj) do
		if eventObj.associatedObject &lt;&gt; pAssociatedObject then
			break;
		endif; 

		pDateArray.add(eventObj.eventDate);

		// Skip any other entries for this date.
		
		self.allEventsByObject.startKeyGtr(pAssociatedObject, eventObj.eventDate, eventIterObj);
	endwhile;
epilog
	delete eventIterObj;
end;</source>
        <Parameter name="pAssociatedObject" type="Object"/>
        <Parameter name="pDateArray" type="DateArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayMonth" id="73df9acc-3262-450e-9e34-aada6c4fc099">
        <source>getDisplayMonth(pMonth:Integer io; pYear:Integer io);
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Return the current month and year displayed.
//
// Parameters:	pMonth (Integer) - The month number.
//				pYear (Integer) - The year number.
//
// Returns:		The month and year numbers by I/O parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pMonth	:= self.currentMonth;
	pYear	:= self.currentYear;
end;</source>
        <Parameter name="pMonth" type="Integer" usage="io"/>
        <Parameter name="pYear" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEventObjectsForDate" id="b820998f-3d60-4789-aa34-29b0c3f5595c">
        <source>getEventObjectsForDate(pDate:Date; pAllEventsObj:CnEcCalendarEventArray input);
// --------------------------------------------------------------------------------
// Created:		05 May 2008 by cnwdad1
//
// Purpose:		Populates the specified array with all Calendar Events for the
//				specified date.
//
// Parameters:	pDate - The date for which to fetch Calendar Events.
//				pAllEventsObj - A reference to the array to populate.
//
// Returns:		The populated array parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iteratorObj	: Iterator;
	eventObj	: CnEcCalendarEvent;
	
begin
	iteratorObj	:=	self.allEventsByDate.createIterator();
	self.allEventsByDate.startKeyGeq(pDate, null, iteratorObj);
	
	while iteratorObj.next(eventObj) do
		if eventObj.eventDate &gt; pDate then
			break;
		endif;
		
		pAllEventsObj.add(eventObj);
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pAllEventsObj" type="CnEcCalendarEventArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEventsForDate" id="512abefc-6903-4613-9d95-d6fc8e5a056f">
        <source>getEventsForDate(pDate:Date; 
				 pDisplayArray:StringArray input; 
				 pObjectArray:ObjectArray input);
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Get the display strings and objects for the specified date, and
//				return the two arrays populated with them.
//
//				Null references in either will mean that only the other half is
//				passed back.
//
// Parameters:	pDate (Date) - The date whose strings and objects to return.
//				pDisplayArray (StringArray) - An array for the date's strings.
//				pObjectArray (ObjectArray) - An array for the date's objects.
//
// Returns:		An array of the date's strings, and an array of the date's objects.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	eventIterObj	: Iterator;
	eventObj		: CnEcCalendarEvent;

begin
	if pDisplayArray &lt;&gt; null then
		pDisplayArray.clear();
	endif;
	
	if pObjectArray &lt;&gt; null then
		pObjectArray.clear();
	endif;

 	eventIterObj := self.allEventsByDate.createIterator();

	self.allEventsByDate.startKeyGeq(pDate, null, eventIterObj);
	
	while eventIterObj.next(eventObj) do
		if eventObj.eventDate &lt;&gt; pDate then
			break;
		endif;

		if pDisplayArray &lt;&gt; null then
	      	pDisplayArray.add(eventObj.displayText);
		endif;
		
		if pObjectArray &lt;&gt; null then
			pObjectArray.add(eventObj.associatedObject);
		endif;
	endwhile;
epilog	
	delete eventIterObj;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pDisplayArray" type="StringArray" usage="input"/>
        <Parameter name="pObjectArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getObjectsForDate" id="7e1dfaca-8c12-4303-b55c-119151bd22b5">
        <source>getObjectsForDate(pDate : Date; pCollectionObj : Collection input);
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Get the objects associated with events on the specified date, and
//				add the unique ones to the input collection.
//
// Parameters:	pDate - The date whose objects to return.
//				pCollectionObj - A collection of the date's objects.
//
// Returns:		A collection of the date's objects.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	eventIterObj	: Iterator;
	eventObj		: CnEcCalendarEvent;

begin
 	eventIterObj	:= self.allEventsByDate.createIterator();

	self.allEventsByDate.startKeyGeq(pDate, null, eventIterObj);
	
	while eventIterObj.next(eventObj) do
		if eventObj.eventDate &lt;&gt; pDate then
			break;
		endif; 

		if not pCollectionObj.includes(eventObj.associatedObject) then
			pCollectionObj.add(eventObj.associatedObject);
		endif;
	endwhile;
epilog	
	delete eventIterObj;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pCollectionObj" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDate" id="f4be8f9e-9646-48ab-90b0-cf2871ce9e5f">
        <source>getSelectedDate() : Date;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Returns the currently selected date.
//
// Parameters:	None
//
// Returns:		The currently selected date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
 	return self.selectedDate;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="isDateVisible" id="b201e484-6d6c-4b3e-b971-2dbae90583d4">
        <source>isDateVisible(pDate : Date) : Boolean;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Find out whether the requested date is currently visible in the
//				calendar (takes into account hidden weekend days).
//
// Parameters:	pDate (Date) - The date to look for.
//
// Returns:		True if the date is visible, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Is date is a different month ?
	
  	if pDate.month &lt;&gt; self.currentMonth or pDate.year &lt;&gt; self.currentYear then
  		return false;
  	endif;

	// If it's in this month, check if it's visible.
	
	return self.isShowWeekends or pDate.dayOfWeek &lt; 6;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLockBottom" id="0972cae4-8d93-4bee-84be-381cca263184">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isLockBottom(set: Boolean; _value: Boolean io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Mapping method to unset the isStretchHeight flag if the isLockBottom
//				flag is set.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if set and _value then
		if self.isStretchHeight then
			self.isStretchHeight := false;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isLockRight" id="90f6454c-4edb-47c3-afdc-3fcca6b5e62f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isLockRight(set: Boolean; _value: Boolean io) mapping, updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
