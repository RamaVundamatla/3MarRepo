	self.myCurrentCargoBOLType := _sohLocn.getCargoBOLType;
	self.myAssistant.comboBoxCargoBolType(cmbFiltTiType, self.myCurrentCargoBOLType.id, true, true, true, true);
	self.cmbFiltTiType.lostFocus(cmbFiltTiType);	
	self.myAssistant.comboBoxTerminalArea(cmbFiltTermArea, _sohLocn.myTerminalArea.myType.type, _sohLocn.myTerminalArea);	
	self.cmbFiltTermArea.lostFocus(cmbFiltTermArea);
	self.myAssistant.comboBoxLocationControllers(cmbFiltYardLocn, self.filterTerminalArea.getLCsCollectionForDisplay(), false);
	self.tblSearch.setValueByControlName(cmbFiltYardLocn.name, _sohLocn.myLocationsController.displayEntry);

end;</source>
