	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", childCargoType1.id );
	self.assertTrueMsg( tiArray.includes(ti), "Agent method 'getCargoBasedOnSTW12Rules' should include '" &amp; ti.id &amp; "' for Rule 7");
	
