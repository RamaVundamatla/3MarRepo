    <JadeMethod name="doMove" id="160229fd-27e2-4096-bfbe-3aa664bafbfe">
        <updating/>
        <source>doMove():Boolean updating, protected;
/*
// ---------------------------------------------------------------------------
// Created:	14 January 2009 By Graeme Black cnwgb1
// Purpose:	Call the agent to perform the move, then reset the form.
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------

*/
vars

	obj : Object;
	target : String;
	targetLC : CM_LocationsController;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	measureType : CM_MeasurementType;
	foundHeight: Integer;
	
begin
	
	if self.myTrackedItem &lt;&gt; null then
		obj := self.cmbYardLocation.listObject;
		if obj &lt;&gt; null then
			targetLC := obj.CM_LocationsController;
		endif;
		target := self.txtTargLocn.text;
		if self.myTrackedItem.isBulkByQuantity then
			quantity := self.txtQuantity.text.Integer;	//20 May 2013 CCMS 2274
		elseif self.myTrackedItem.isBulkByWeight then
			weight := self.tblWeightVolume.getConvertedValue();
		elseif self.myTrackedItem.isBulkByVolume then
			volume := self.tblWeightVolume.getConvertedValue();
			weight := volume * self.myTrackedItem.getDensity;
		endif;
		if target &lt;&gt; null then
			app.mousePointer := self.MousePointer_HourGlass;
			
			// Check that target is a yard area 35640
			app.myPassport.myTerminal.findLocationFromString(target, false, targetLC, foundHeight);
			if targetLC = null or not targetLC.isKindOf (CM_YardController) then
				app.msgBox(app.getErrorString1(Err_InvalidLocation, target), app.getErrorString1(Err_InvalidLocation, target), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return false;	//02 Mar 2017	NDL	TFS 3298
			endif;
			
			if self.myMobileGenericAgent.moveTI( self.myTrackedItem, target, targetLC, null, false, quantity, weight, null ) then
				self.displayCurrentLocation();
				self.cmbAreaType.listIndex := 1;
				self.handleAreaTypeSelect();
				self.setMoveEnabledDisabled();
				
				if self.txtQuantity.visible or self.tblWeightVolume.visible then
					//we were dealing with a Break bulk 
					if self.myTrackedItem.hasBeenMerged then
						if self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
							self.setBulkWeightVolumeFields( self.myTrackedItem, self.tblWeightVolume, self.lblQuantity, 0.00 );
						endif;
						self.txtQuantity.text := "0";
						self.txtQuantity.visible := false;
						self.lblQuantity.visible := false;
						self.tblWeightVolume.visible := false;
						self.txtCargoId.text := self.lblCargoId.caption.toUpper;
						self.setMyTrackedItem( null );
					else
						self.populateTrackedItem;
					endif;
				endif;
				return true;	//02 Mar 2017	NDL	TFS 3298
			endif;
		endif;
	endif;
	
	return false;	//02 Mar 2017	NDL	TFS 3298
	
epilog
	app.mousePointer := self.MousePointer_Default;	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="a6071402-d1b3-4435-ba10-5099912643d9">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.resizedMargin - stdHeight;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	cWidth := stdWidth / 2;
	if _initialSetup then
		self.lblCurLocation.setAndIncrementTabIndex( tabIndex );
		self.lblCurLocation.visible := true;
	endif;
	self.lblCurLocation.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	if _initialSetup then
		self.lblCurLocValue.setAndIncrementTabIndex( tabIndex );
		self.lblCurLocValue.visible := true;
	endif;
	self.lblCurLocValue.move(	self.txtCargoId.left + self.lblCurLocation.width + self.resizedMargin,
								cTop - 4,
								cWidth,
								cHeight );
	if _initialSetup then
		self.lblCurLocValue.foreColor := Blue;
		self.lblCurLocValue.alignment := Label.Alignment_Center_Middle;
	endif;
								
	cTop := cTop + self.lblCurLocation.height + ( stdHeight /2 );
	cWidth := stdWidth;
	if _initialSetup then
		self.lblSelectTarget.setAndIncrementTabIndex( tabIndex );
		self.lblSelectTarget.visible := true;
	endif;
	self.lblSelectTarget.move(	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
							
	cTop := cTop + self.lblSelectTarget.height + self.resizedMargin;
	if _initialSetup then
		self.cmbAreaType.setAndIncrementTabIndex( tabIndex );
		self.cmbAreaType.visible := true;
	endif;
	self.cmbAreaType.move(	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
	if _initialSetup then
		self.getSessionAgent().loadAreaTypeCmb( self.cmbAreaType );
		self.cmbAreaType.itemText[1] := "&lt;Area Type&gt;";
		self.cmbAreaType.itemEnabled[1] := false;
		self.cmbAreaType.listIndex := 1;
	endif;

	cTop := cTop + self.cmbAreaType.height + self.resizedMargin;
	if _initialSetup then
		self.lblTerminalArea.visible := false;
		self.cmbTerminalArea.setAndIncrementTabIndex( tabIndex );
		self.cmbTerminalArea.visible := true;
	endif;
	self.cmbTerminalArea.move(	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
							
	cTop := cTop + self.cmbTerminalArea.height + self.resizedMargin;
	if _initialSetup then
		self.lblYardLocation.visible := false;
		self.cmbYardLocation.setAndIncrementTabIndex( tabIndex );
		self.cmbYardLocation.visible := true;
	endif;
	self.cmbYardLocation.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.cmbYardLocation.height + ( stdHeight /2 );
	if _initialSetup then
		self.lblTargLocn.setAndIncrementTabIndex( tabIndex );
		self.lblTargLocn.visible := true;
	endif;
	self.lblTargLocn.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	cTop := cTop + self.lblTargLocn.height + self.resizedMargin;
	if _initialSetup then
		self.txtTargLocn.setAndIncrementTabIndex( tabIndex );
		self.txtTargLocn.visible := true;
	endif;
	self.txtTargLocn.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtTargLocn.height + self.resizedMargin;
	cWidth := (( stdWidth - self.resizedMargin - self.resizedMargin )/ 2).Integer;
	if _initialSetup then
		self.lblQuantity.setAndIncrementTabIndex( tabIndex );
		self.lblQuantity.visible := true;
	endif;
	self.lblQuantity.move(	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
								
	cLeft := self.lblQuantity.left + self.lblQuantity.width +  self.resizedMargin;
	if _initialSetup then
		self.txtQuantity.setAndIncrementTabIndex( tabIndex );
		self.txtQuantity.visible := true;
	endif;
	self.txtQuantity.move(	cLeft,
							cTop,
							cWidth,
							cHeight );
							
	if _initialSetup then
		self.tblWeightVolume.setAndIncrementTabIndex( tabIndex );
		self.tblWeightVolume.visible := false;
	endif;
	self.tblWeightVolume.move(	cLeft,
								cTop,
								cWidth,
								cHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
								);
								
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="62e30496-01b2-4c11-ac10-6c4c1cb5b572">
