    <JadeMethod name="getCranes" id="d64dcc07-02c9-4366-9feb-5737ea584d4d">
        <source>getCranes(_cranesArray : ObjectArray output)protected;
/*
	Purpose:		Populate crabes arrays 
	Parameters:		_cranesArray	- one entry per crane, index corresponds to column in table 
									  the cranes data will be displayed in

	Return Value:		

Date			Who		Reason
24 July 2008	concms1	Initial creation
*/

vars
	voyage		:CM_Voyage;
	obj			:Object;
	index, size	:Integer;
	crane		:CM_Crane;
begin
	voyage	:= self.getVoyage;
	
	create _cranesArray transient;
	
	foreach obj in voyage.allJobSheets do
		crane	:= obj.CM_VoyageJobSheet.getMyCrane;
		
		if crane = null then
			continue;	// what else can we do?
		endif;
		
		if _cranesArray.includes (crane) then
			continue;// already there
		endif;
		
		_cranesArray.add (crane);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cranesArray" type="ObjectArray" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDelays" id="2d6be306-14e4-42d6-a300-fe4b025df9fa">
        <source>getDelays(_dd :DynaDictionary output) protected;
/*
	Purpose:		populate collection of delays for voyage
	Parameters:			
	Return Value:		

Date		Who		Reason
01 August 2008	concms1	Initial creation
*/

vars
	voyage	:CM_Voyage;
begin
	voyage		:= self.getVoyage;
	
	self.createDelaysDictionary (_dd);
	
	voyage.getAllCraneDelays (_dd);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dd" type="DynaDictionary" usage="output"/>
    </JadeMethod>
