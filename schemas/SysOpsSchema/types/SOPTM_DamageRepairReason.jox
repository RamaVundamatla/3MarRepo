    <JadeMethod name="doSave" id="cbbbd482-efd2-4de4-bf89-76235c6f9b8b">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description				: String;
	isNotAvailableForEntry 	: Boolean;
	pxyDamageRepairReason,
	newDamageRepairReason		: CM_RepairReason;
	terminal				:CM_Terminal;
begin
	theForm := self.myForm;
	tbl := theForm.tblInput1;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	isNotAvailableForEntry := tbl.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	terminal			   := self.myForm.myTerminal;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_RepairReason transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyDamageRepairReason := theForm.myProxyObject.CM_RepairReason;
	pxyDamageRepairReason.setProxy(code, description, isNotAvailableForEntry,terminal);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateRepairReason(pxyDamageRepairReason, newDamageRepairReason, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateRepairReason(pxyDamageRepairReason, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
