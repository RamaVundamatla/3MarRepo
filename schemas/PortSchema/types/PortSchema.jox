    <JadeMethod name="stringToTimeStamp" id="84188697-2204-412a-8e48-8ea7d31513c5">
        <source>stringToTimeStamp(str: String): TimeStamp;
// ---------------------------------------------------------------------------
// Created:			21 May 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	Date_Delimiters = " ";
	Time_Delimiters = ":";
	STR_yesterday   = "yesterday";
	LEN_yesterday   = 9;
	STR_today       = "today";
	LEN_today       = 5;
vars
	strlen:      Integer;
	ts:          TimeStamp;
	time:        Time;
	token:       String;
	timeString:  String;
	pos:         Integer;
begin
	strlen := str.length();
	if strlen = 0 then
		return null;
	endif;
	// discard delimeters at start of string
	pos := 1;
	str.scanWhile(Date_Delimiters, pos);
	
	if pos &lt;= 0 then return null; endif;
	
	token := str.scanUntil(Date_Delimiters, pos);
	token := token.toLower();

	if token = STR_yesterday then
		ts := self.actualTimeServer();
		ts.setDate(ts.date - 1);
		if pos &lt; strlen then
			timeString := str[pos + 1: end];
		endif;
	elseif token = STR_today then
		ts := self.actualTimeServer();
		if pos &lt; strlen then
			timeString := str[pos + 1: end];
		endif;
	elseif token.pos(Time_Delimiters, 1) &gt; 0 then
		timeString := token;
		ts.setDate(null);
	else
		// a standard date or date-time
		ts := str.TimeStamp;
		if ts.isValid then
			return ts;
		else
			return null;
		endif;
	endif;
	
	
	if timeString &lt;&gt; null then
		// it should be a time
		time := timeString.Time;
		if time.isValid() then
			ts.setTime(time);
		else
			ts.setTime(null);
		endif;
	endif;
	return ts;
end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="subTerminalTypeEnumToString" id="f192662e-77ee-4303-a0b3-d815ee9716e5">
        <source>subTerminalTypeEnumToString(_value:Integer):String;
// --------------------------------------------------------------------------------
// Created:		19 May 2009 by cnwdad1
//
// Purpose:		Converts a numeric Sub-Terminal Type into a string description.
//
// Parameters:	_value - The numeric value.
//
// Returns:		The equivalent Sub-Terminal Type description.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _value = SubTermType_Marine_Int then
		return SubTermType_Marine;
	elseif _value = SubTermType_Depot_Int then
		return SubTermType_Depot;
	elseif _value = SubTermType_Warehouse_Int then
		return SubTermType_Warehouse;
	else
		app.raiseCMException1(SubTerminal_Type_Unknown, _value.String, null, null);
	endif;
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
