        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateControls" id="64d77ac3-d2b7-40ec-86dd-474440a30972">
        <updating/>
        <source>populateControls() updating, protected;
// populate with default values
vars
	startTime 	: TimeStamp;
	endTime		: TimeStamp;
	date		: Date;
	
begin

	startTime 	:= self.systemToLocalTime(app.actualTimeServer());	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
	endTime := startTime;
	endTime := endTime.addMinutes(15);
	
	self.populateDriverCombo();
	
	self.populateDelayTypeCombo();
	
	self.populateWorkPointsCombo();	// 21 June 2012	NDL	Par 29689
	
	self.txtStartDate.setDate(startTime.date());
	self.txtStartTime.setTime(startTime.time());

	self.txtPlusHrs.text := "0";
	self.txtPlusMins.text := "15";
	
	self.txtEstEndDate.setDate(endTime.date());
	self.txtEstEndTime.setTime(endTime.time());
	self.txtEstEndDate.enabled := false;
	self.txtEstEndTime.enabled := false;
	self.lblEstEndTime.enabled := false;	// disabled text box looks the same as enabled, disabled the label as well to get a visual effect
	
	self.txtRemarks.text := self.lblRemarks.caption;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateDelayForSave" id="2d09676a-80c8-4cc3-b6d7-165a246b40dd">
        <updating/>
        <source>populateDelayForSave(_delay : CM_Delay input) : Boolean updating, protected;

vars
	errorMsg		: String;
	date			: Date;
	time			: Time;
	endDT,
	startDT,
	estEndDT		: TimeStamp;
	voyage 			: CM_Voyage;
	delayType		: CM_DelayType;
	machine			: CM_Machine;
	driver			: CM_User;
	workPoint		: CM_WorkPoint;
	remarks			: String;
begin
	endDT := null;

	startDT.setDate(self.txtStartDate.getDate(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblStartTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		self.txtStartDate.setFocus();
		return false;
	endif;

	startDT.setTime(self.txtStartTime.getTime(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblStartTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		self.txtStartTime.setFocus();
		return false;
	endif;
	
	estEndDT.setDate(self.txtEstEndDate.getDate(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblEstEndTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		return false;
	endif;

	estEndDT.setTime(self.txtEstEndTime.getTime(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblEstEndTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		return false;
	endif;

	voyage := self.myVoyage;
	delayType := self.cmbDelayType.listObject.CM_DelayType;
	machine := self.myMachine;
	driver 	:= self.cmbDriver.listObject.CM_User;
	workPoint := self.cmbWorkPoint.listObject.CM_WorkPoint;	// 21 Jun 2012	NDL	29689
	remarks := self.txtRemarks.text.asStringJMT;
	if remarks = self.lblRemarks.caption then		// default value
		remarks := null;
	endif;
	
	_delay.setProxy(self.myTerminal,
					voyage,
					delayType,
					self.localToSystemTime(startDT),
					self.localToSystemTime(estEndDT),	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
					self.localToSystemTime(endDT),
					machine,
					driver,
					workPoint,	// 21 Jun 2012	NDL	29689
					remarks);
					
	return true;
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_delay" type="CM_Delay" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateDelayTypeCombo" id="24d7b50d-befd-4e99-a6d3-1b11289e35ee">
        <updating/>
        <source>populateDelayTypeCombo() updating, protected;
// populate the delay type combo
vars
	obj		: Object;
	dd		: DynaDictionary;
	type	: CM_DelayType;
	delayTypeGroup	: CM_DelayTypeGroup;
begin
	create dd transient;
	
	dd.setMembership(CM_DelayType);
	dd.addMemberKey(CM_DelayType::delayTypeOrder.name, false, false);
	dd.endKeys(true);
	
	// get the terminal config delay type group, if any
	delayTypeGroup := self.myTerminal().getConfig(HhDelayTypeGroup).CM_DelayTypeGroup;
	foreach type in app.myRoot.allDelayTypes do
		if type.isNotAvailableForEntry then
			continue;
		endif;
		if delayTypeGroup &lt;&gt; null then
			if not delayTypeGroup.allDelayTypes.includes(type) then
				continue;
			endif;
		endif;
		if self.myMachine = null and
		   type.requiresMachine then
			continue;
		endif;
		
		dd.add (type);
	endforeach;
	// load up the combo
	self.cmbDelayType.clear;
	self.cmbDelayType.sorted := false;
	self.cmbDelayType.itemObject[self.cmbDelayType.addItem(self.lblDelayType.caption)] := null;
	foreach obj in dd do
		type := obj.CM_DelayType;
		self.cmbDelayType.itemObject[self.cmbDelayType.addItem(type.description)] := type;
	endforeach;
	self.cmbDelayType.listIndex := 1;

epilog
	delete dd;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateDriverCombo" id="5b3637f4-c402-4fca-b564-e25f7935cc6c">
        <updating/>
        <source>populateDriverCombo() updating, protected;
// populate the driver combo
vars
	obj		: Object;
	user	: CM_User;
begin
	// load up the combo
	self.cmbDriver.clear;
	self.cmbDriver.sorted := false;
	self.cmbDriver.itemObject[self.cmbDriver.addItem(self.lblDriver.caption)] := null;
	foreach user in app.myRoot.allUsers do
		if user.isNotAvailableForEntry or
		   user.code.trimBlanks.toUpper = 'SUPERUSER' then
			continue;
		endif;
		
		self.cmbDriver.itemObject[self.cmbDriver.addItem(user.userName &amp; ' (' &amp; user.code &amp; ')')] := user;
	endforeach;
	self.cmbDriver.listIndex := 1;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateWorkPointsCombo" id="79faffbe-24c8-4f71-9891-49cd98676b21">
        <updating/>
        <source>populateWorkPointsCombo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2012	cnwndl1	Initial creation	Par 29689

*/

vars

	voyage : CM_Voyage;
	machine : CM_Machine;
	objSet : CM_ObjectSetActual;
	obj : CM_Object;
	workPoint : CM_WorkPoint;
	index : Integer;
	iter : Iterator;

begin

	self.cmbWorkPoint.clear;
	self.cmbWorkPoint.sorted := false;
	self.cmbWorkPoint.itemObject[self.cmbWorkPoint.addItem(self.lblWorkPoint.caption)] := null;

	voyage := self.myVoyage;
	machine := self.myMachine;
	
	if voyage &lt;&gt; null then
		create objSet transient;
		voyage.findAllMyCranesAndWorkpoints( objSet );
		foreach obj in objSet where obj.isKindOf( CM_WorkPoint ) do
			workPoint := obj.CM_WorkPoint;
			index := self.cmbWorkPoint.addItem(workPoint.code);
			self.cmbWorkPoint.itemObject[index] := workPoint;
			self.cmbWorkPoint.itemEnabled[index] := not workPoint.isNotAvailableForEntry;
		endforeach;
		
	elseif machine &lt;&gt; null and machine.myTerminal &lt;&gt; null then
		iter := machine.myTerminal.allWorkPointsByCode.createIterator;
		while iter.next( workPoint ) do
			if workPoint.isNotAvailableForEntry then
				continue;
			endif;
			index := self.cmbWorkPoint.addItem(workPoint.code);
			self.cmbWorkPoint.itemObject[index] := workPoint;
		endwhile;
		
	endif;

	self.cmbWorkPoint.listIndex := 1;

epilog

	delete objSet;
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshEstEndTime" id="f4dc6700-a958-4f2b-810b-fa7a5a454a53">
        <updating/>
        <source>refreshEstEndTime() updating, protected;
// called on lostFocus of the start date/time and duration hours/mins text fields to refresh the displayed estimated end time
vars
	errorMsg	: String;
	startDate	: TimeStamp;
	durationHours,
	durationMins	: Integer;
	estEndDate	: TimeStamp;
begin
	startDate.setDate(self.txtStartDate.getDate(errorMsg));
	startDate.setTime(self.txtStartTime.getTime(errorMsg));
	durationHours := self.txtPlusHrs.text.Integer;
	durationMins := self.txtPlusMins.text.Integer;
	if durationMins &gt; 59 then
		durationMins := 59;
		self.txtPlusMins.text := durationMins.String;	
	endif;
	estEndDate := startDate;
	estEndDate := estEndDate.addHours(durationHours);
	estEndDate := estEndDate.addMinutes(durationMins);

	if estEndDate.isValid then
		self.txtEstEndDate.setDate(estEndDate.date);
		self.txtEstEndTime.setTime(estEndDate.time);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControls" id="9890e653-36e2-4b4e-b91b-c9fabead93e5">
        <updating/>
        <source>setupControls() updating, protected;
// position the controls
vars
	
begin
	
	self.doResizeControls(true);
	
	if self.myMachine = null then
		self.cmbDriver.enabled := false;
	endif;
	self.cmbDelayType.setFocus();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d4c7f277-c0aa-4346-9469-8b42abdbad9a">
        <updating/>
        <source>setupForm() updating, protected;
// main form setup code
vars
	msg	: String;
begin
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	inheritMethod();
	
	self.myVoyage := self.myMobileGenericAgent.myVoyage;
	self.myMachine := self.myMobileGenericAgent.stringField1.asOid.CM_Machine;
	self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
	
	if self.myVoyage &lt;&gt; null then
		msg := app.getErrorString(Voyage) &amp; " " &amp; self.myVoyage.code &amp; " ";
	endif;
	if self.myMachine &lt;&gt; null then
		msg := msg &amp; app.getErrorString(Machine) &amp; " " &amp; self.myMachine.code;
	endif;
	self.lblVoyageMachine.caption := msg;

	self.setupControls();
	
	self.populateControls();

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d7906490-8766-4b31-b9c5-44f4c2f2fd4a">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016579, locale);
	lblDelayType.translateCaption(Xlat_0016580, locale);
	lblDriver.translateCaption(Xlat_0016581, locale);
	lblEstEndTime.translateCaption(Xlat_0016582, locale);
	lblPlus.translateCaption(Xlat_0016583, locale);
	lblPlusHrs.translateCaption(Xlat_0016584, locale);
	lblPlusMins.translateCaption(Xlat_0016585, locale);
	lblRemarks.translateCaption(Xlat_0016586, locale);
	lblStartTime.translateCaption(Xlat_0016587, locale);
	lblVoyageMachine.translateCaption(Xlat_0016588, locale);
	lblWorkPoint.translateCaption(Xlat_0018053, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
