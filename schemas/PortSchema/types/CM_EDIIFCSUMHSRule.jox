    <JadeMethod name="setProxyIFCSUMHS" id="48fa3082-14b8-46a7-9dd3-8a48bf32c61f">
        <updating/>
        <source>setProxyIFCSUMHS(_cargoSubType, _hsCode : String; _cargoType : Integer; _myEdiPartyRule : CM_EDIPartyIFCSUMRules) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements

*/

vars

begin
	self.cargoType 		:= _cargoType;
	self.cargoSubType	:= _cargoSubType;
	self.hsCode 		:= _hsCode;
	self.myEDIPartyRules := _myEdiPartyRule;
epilog

end;</source>
