    <JadeMethod name="createLogRowEntry" id="f23d0aeb-51ee-4cbd-9f0d-a881d93c2a8a">
        <source>createLogRowEntry(_logRowEntryHdr: CM_RemoteLogRowMaintHdr input; _logRowEntryObj: CnEcXmlStructureInstance);
/* ---------------------------------------------------------------------------
Created:	02 May 2011	by cnwvu1
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	detailObj	: CM_RemoteLogRowMaintDtl;
	logAreaId,
	logRowId,
	action,
	supplier				: String;
	supplierXMLPresent		: Boolean;
	species					: String;
	speciesXMLPresent		: Boolean;
	grade					: String;
	gradeXMLPresent			: Boolean;
	logType					: String;	
	logTypeXMLPresent		: Boolean;
	treatment				: String;
	treatmentXMLPresent		: Boolean;
	length					: String;
	lengthXMLPresent		: Boolean;
	status					: String;
	statusXMLPresent		: Boolean;
	comment					: String;
	commentXMLPresent		: Boolean;
	docketChecked			: String;
	docketCheckedXMLPresent	: Boolean;
	checkScaled				: String;
	checkScaledXMLPresent	: Boolean;
	inspected				: String;
	inspectedXMLPresent		: Boolean;
	fumigated				: String;
	fumigatedXMLPresent		: Boolean;

begin

	create detailObj transient;

	logAreaId				:= self.getTagDataFromXML(XML_LOGAREA,	_logRowEntryObj);
	logRowId				:= self.getTagDataFromXML(XML_LOGROW,	_logRowEntryObj);
	action					:= self.getTagDataFromXML(XML_ACTION,	_logRowEntryObj);
	supplierXMLPresent		:= self.getTagDataFromXMLIfPresent(XML_SUPPLIER,		_logRowEntryObj, supplier);	
	speciesXMLPresent		:= self.getTagDataFromXMLIfPresent(XML_SPECIES,			_logRowEntryObj, species);	
	gradeXMLPresent			:= self.getTagDataFromXMLIfPresent(XML_GRADE,			_logRowEntryObj, grade);
	logTypeXMLPresent		:= self.getTagDataFromXMLIfPresent(XML_LOGTYPE,			_logRowEntryObj, logType);
	treatmentXMLPresent		:= self.getTagDataFromXMLIfPresent(XML_TREATMENT,		_logRowEntryObj, treatment);
	lengthXMLPresent		:= self.getTagDataFromXMLIfPresent(XML_LENGTH,			_logRowEntryObj, length);
	statusXMLPresent		:= self.getTagDataFromXMLIfPresent(XML_STATUS,			_logRowEntryObj, status);
	commentXMLPresent		:= self.getTagDataFromXMLIfPresent(XML_COMMENT,			_logRowEntryObj, comment);
	docketCheckedXMLPresent	:= self.getTagDataFromXMLIfPresent(XML_DOCKETCHECKED,	_logRowEntryObj, docketChecked);
	checkScaledXMLPresent	:= self.getTagDataFromXMLIfPresent(XML_CHECKSCALED,		_logRowEntryObj, checkScaled);
	inspectedXMLPresent		:= self.getTagDataFromXMLIfPresent(XML_INSPECTED,		_logRowEntryObj, inspected);
	fumigatedXMLPresent		:= self.getTagDataFromXMLIfPresent(XML_FUMIGATED,		_logRowEntryObj, fumigated);
	
	detailObj.setProxyForLogRowEntry(	logAreaId,
										logRowId,
										action,
										supplier,				
										supplierXMLPresent,
										species,	
										speciesXMLPresent,
										grade,	
										gradeXMLPresent,
										logType,
										logTypeXMLPresent,
										treatment,	
										treatmentXMLPresent,
										length,	
										lengthXMLPresent,
										status,		
										statusXMLPresent,
										comment,		
										commentXMLPresent,
										docketChecked,	
										docketCheckedXMLPresent,
										checkScaled,
										checkScaledXMLPresent,
										inspected,
										inspectedXMLPresent,
										fumigated,	
										fumigatedXMLPresent,
										_logRowEntryHdr);
	

end;</source>
        <Parameter name="_logRowEntryHdr" type="CM_RemoteLogRowMaintHdr" usage="input"/>
        <Parameter name="_logRowEntryObj" type="CnEcXmlStructureInstance"/>
    </JadeMethod>
    <JadeMethod name="createLogRowEntryDetail" id="dc9416bc-dac2-47a0-910e-ee800cb81c56">
        <updating/>
        <source>createLogRowEntryDetail(_logRowEntryHdr: CM_RemoteLogRowMaintHdr input): Boolean updating;
/* ---------------------------------------------------------------------------
Created:	02 May 2011	by cnwvu1

Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	logRowEntryObj	: CnEcXmlStructureInstance;
	allLogRowObjs	: CnEcXmlStructureInstanceSet;
	canContinue		: Boolean;
	className		: String;
	typeName		: String;
	
begin
	on SystemException do self.handleException(exception, canContinue);
	
	create allLogRowObjs transient;
	
	canContinue	:=	true;
	self.xmlStruct.findAllStructures(XML_LCNENTRYGRP, allLogRowObjs);
	
	foreach logRowEntryObj in allLogRowObjs do
		_logRowEntryHdr.getAttributes(logRowEntryObj.tagAttribute, className, typeName);
		
		if className &lt;&gt; CM_RemoteDataObject.Class_Log then
			continue;
		endif;
		
		self.createLogRowEntry(_logRowEntryHdr, logRowEntryObj);
	endforeach;
	
	return canContinue;
	
epilog
	delete allLogRowObjs;
	
end;</source>
        <Parameter name="_logRowEntryHdr" type="CM_RemoteLogRowMaintHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRegradeDetail" id="2f497632-3fb3-40ea-bb85-c2ec6dd5c63e">
        <updating/>
        <source>createRegradeDetail(_regradeHdr: CM_RemoteRegradingHdrExt): Boolean updating;

// cnwdvb1 27 March 2003 

vars

	
	batchrq				: CnEcXmlGroupInstance;
	tibatch				: CnEcXmlStructureInstance;
	tidtls				: CnEcXmlGroupInstance;
	ti					: CnEcXmlStructureInstance;
	canContinue			: Boolean;
	class,
	type,
	batchHdr,
	tiString			: String;
	remoteDetail		: CM_RemoteDataDtl;
	 

begin

	on SystemException do self.handleException(exception, canContinue);
	
	canContinue 	:= true;	
	batchrq 		:=	self.xmlStruct.findStructure(XML_BATCHRQ).CnEcXmlGroupInstance;
	foreach tibatch in batchrq.allFields do
		_regradeHdr.getAttributes(tibatch.tagAttribute, class, type);
		batchHdr := tibatch.findStructure(XML_BATCHHDR).tagData; 
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Regrade then
			canContinue := false;
			return canContinue;
		endif;
		
		remoteDetail	:= self.parseBatchHdr(batchHdr, _regradeHdr, class, type);
		tidtls		:= tibatch.findStructure(XML_TIDTLS).CnEcXmlGroupInstance;	
		_regradeHdr.getAttributes(tidtls.tagAttribute, class, type);
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Regrade then
			canContinue := false;
			return canContinue;
		endif;
				
		foreach ti in tidtls.allFields do
			tiString := ti.tagData;
			self.parseTiToExtraDetail(tiString, remoteDetail, class, type);
		endforeach;
	endforeach;
epilog
	return canContinue;
end;</source>
        <Parameter name="_regradeHdr" type="CM_RemoteRegradingHdrExt"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRejectDetail" id="b7e3f41c-ba30-45da-a534-ee5d002028f5">
        <updating/>
        <source>createRejectDetail(_rejectHdr: CM_RemoteRejectHdr): Boolean updating;

vars

	batchrq				: CnEcXmlGroupInstance;
