    <JadeMethod name="drawBasicBox" id="f03d842b-3fea-43b4-a5a1-c5ae502ad0fc">
        <updating/>
        <source>drawBasicBox(_theTI: CM_TrackedItem; _theGridAttributes: CMUI_GridAttributes input; _x1: Integer; _y1: Integer; _x2: Integer; _yBase: Integer io; _frame: CMUI_GridAreaDrawingFrame input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		08 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	behaviour : CM_TIBehaviourType;
	idx, maxX, tmpY1offset, tmpY2offset, objectY1 : Integer;
	lengthX, numLC, tmpXOffSet, tmpXOffSet2,midX, locLengthFT, tiLengthFT : Integer;
	anLC : CM_TILCController;
	tiLC, kidTIlc : CM_TILC;
	aLC : CM_LocationsController;
	lenUnits : Integer;
begin
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1._theTI " &amp; _theTI.id);
	// draw basic rectangle
	_yBase := _yBase - 2;
	tmpY1offset := (_yBase - (self.Height_Box * self.scaleFactor).Integer);
	tmpY2offset := _yBase; 
	tmpXOffSet := _x1;
	if not _theTI.isKindOf(CM_TILC) then
		lenUnits := (_theTI.getLengthInUnits() / 2).Integer;
		tmpXOffSet2 := _x2;
		
		if _theTI.myPrimaryActualLocation.isKindOf(CM_TILCController) then
			anLC := _theTI.myPrimaryActualLocation.CM_TILCController;
		endif;
		if anLC &lt;&gt; null then
			tiLC := anLC.myTILC ;
			if tiLC &lt;&gt; null then
				behaviour := tiLC.myCargoType.myTIBehaviourType;
				if behaviour &lt;&gt; null then
					if behaviour.myGraphic &lt;&gt; null then
						tmpXOffSet2 := _x1 + behaviour.myGraphic.getDrawWidth();//maxX;
					endif;
				endif;
				numLC := tiLC.allLCs.size;
				idx := tiLC.allLCs.indexOf(anLC);
			endif;
			idx := idx - 1;
			lengthX := tmpXOffSet2 - _x1;
			lengthX := ((lengthX / numLC) *self.scaleFactor) .Integer ;
		else
			behaviour := _theTI.myCargoType.myTIBehaviourType;
			aLC :=  _theTI.myPrimaryActualLocation;
			locLengthFT := aLC.myTerminalArea.locationLength.Integer;
			tiLengthFT := _theTI.getActualLength().Integer;
			numLC := (locLengthFT / tiLengthFT).Integer;
			idx := 1;
			idx := idx - 1;
			lengthX := tmpXOffSet2 - _x1;
			lengthX := ((lengthX / numLC) ) .Integer ;
		endif;

		tmpXOffSet := tmpXOffSet + (lengthX * idx);
		idx := idx + 1;
		tmpXOffSet2 := tmpXOffSet + ((lengthX * lenUnits));
				
//		behaviour.drawGraphic(_frame,self.scaleFactor,tmpXOffSet,_yBase,self.flipHorizontal,
		behaviour.drawGraphic(_frame,self.scaleFactor,tmpXOffSet,tmpY2offset,self.flipHorizontal,
					true,self.getFillColourForTI(_theTI),lenUnits, _theTI.id,lengthX);

		self.addToDrawnObjects(tmpXOffSet.Integer,tmpY1offset,tmpXOffSet2,tmpY2offset, _theTI,true);
		self.setIconPositions(tmpXOffSet.Integer - _x1,tmpY1offset,tmpXOffSet2,tmpY2offset); // _x1.Integer, _y1.Integer, _x2.Integer, _yBase);
		
		// ### Only move up to next row if this is the last item
		if (idx) = numLC then
			_yBase := (_yBase - (30 * self.scaleFactor).Integer);
		else
			_yBase := _yBase + 2;

		endif;


	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_yBase" type="Integer" usage="io"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBlankSpace" id="8fc679e4-6337-4879-a5fb-0cb291fe43d7">
        <source>drawBlankSpace(pColor: Integer; pHeight: Integer; pX1: Real; pY1: Real; pX2: Real; pY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	
begin
	theFrame := self.myDrawingFrame;

	theFrame.drawStyle := Frame.DrawStyle_Dash;
	theFrame.drawFillColor := pColor;
	if pColor = theFrame.backColor then
		theFrame.drawStyle := Frame.DrawStyle_Transparent;
	endif;
	self.setTmpPointArrayXYs(pX1.Integer, pY1.Integer, pX2.Integer, pY2.Integer);
	self.tmpPointArray.drawFilledPolygon(theFrame, Black, 1);		
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBuilding" id="c0da0684-8f68-4e01-b8dc-d619cbf91505">
        <updating/>
        <source>drawBuilding() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	anOffset1, anOffset2, aSlotHeight, aWindowHeight,aColour, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
	aLetter : String;
	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
	lPicture : Binary;
begin
	theFrame := self.myDrawingFrame;

	self.drawOverLappingRectangle(theSamePrev, theSameAbove, DarkGray, Green, theFrame);

	
	lPicture := app.myRoot.getConfig(PicWHouseRowsUp).Binary;
	theFrame.drawPictureAt(lPicture, self.x1 + 1, self.y1 + 1);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawCargoLetter" id="a6818928-62ae-4139-8d35-9b1e52ad69df">
        <source>drawCargoLetter(_letter : String; _x1, _y1, _x2, _y2 : Integer; _frame: CMUI_GridAreaDrawingFrame input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 October 2009	cnwjk3	Initial creation

*/

vars	
	txHeight,
	tx,
	ty,
	tyOffset,
	nx1,
	ny1,
	nx2,
	ny2	: Integer;
begin
	_frame.drawWidth := 1;
	_frame.drawStyle := Frame.DrawStyle_Solid;
	_frame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_frame.drawFontName := "Arial";
	_frame.drawFillColor := White;

	txHeight := (12 * self.scaleFactor).Integer;
	tyOffset := (3 * scaleFactor).Integer;
	nx1 := _x1;
	nx2 := _x2;
	ny1 := _y1 + (((_y2 - _y1) / 4).Integer);
	ny2 := ny1 + (((_y2 - _y1) / 2).Integer);
	tx := _x1 + ((_x2 - _x1) / 2).Integer;
	ty := (_y1 + (((_y2 - _y1) - txHeight) /2).Integer)-tyOffset;
	
	_frame.drawFontSize := txHeight;
	_frame.drawFilledRectangle(nx1, ny1, nx2, ny2, Black); 
	_frame.drawTextAlign := Window.DrawTextAlign_Center;
	_frame.drawTextAt(_letter, tx, ty, Black);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_letter" type="String"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawCurrentObject" id="4b30e53d-beee-4778-91cd-44a7cdbdf7d7">
        <updating/>
        <source>drawCurrentObject(_frame: CMUI_GridAreaDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	frame: CMUI_GridAreaDrawingFrame;
begin

	if self.myCurrentObject.isKindOf(CM_LocationsController) then
		self.drawLC(self.myCurrentObject.CM_GridController);
	elseif self.myCurrentObject.isKindOf(CM_TrackedItem) then
		theTI := self.myCurrentObject.CM_TrackedItem;
		//self.drawTI(theTI, null, self.x1, self.y1, self.x2, self.y2,self.myDrawingFrame);			// cnwjk3 PAR 23875 23/04/10
		self.drawTI(theTI, null, self.x1, self.y1, self.x2, self.y2,self.myDrawingFrame, null);		// cnwjk3 PAR 23875 23/04/10
	endif;

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawFMLetter" id="83319705-1c4b-4b7d-9cc2-1cf62c9ffb67">
        <source>drawFMLetter(_theLetter: String; _isP40: Boolean; _isQ40: Boolean; _isA40: Boolean; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real; _theFill: Integer; _mode: Integer; _tiIndex: Integer);
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame	: CMUI_GridAreaDrawingFrame;
	is40, hasA, hasQ, hasP : Boolean;
	xOffset, yOffset,yOffsetFnt,xOffsetFnt,xWidth : Integer;
	aReal : Real;
	aGridAttribute : CMIF_GridAttributes;
	theLetter : String;
begin

	theFrame := self.myDrawingFrame;

	if _mode = 1 then
		hasP := true;
	elseif _mode = 2 then
		hasQ := true;
	elseif _mode = 6 then
		hasA := true;
	elseif _mode = 3 then
		hasP := true;
		hasQ := true;
	elseif _mode = 7 then
		hasP := true;
		hasA := true;
	elseif _mode = 8 then
		hasQ := true;
		hasA := true;
	elseif _mode = 9 then
		hasQ := true;
		hasP := true;
		hasA := true;
	else
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. UNKNOWN MODE " &amp; _mode.String);
		return;
	endif;
	
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	theLetter := _theLetter.trimBlanks;

	theFrame.drawFontName := "Arial";
	theFrame.drawStyle := Frame.DrawStyle_Dash;
	theFrame.drawFillColor := _theFill;
	self.setTmpPointArrayXYs(_theX1.Integer, _theY1.Integer, _theX2.Integer, _theY2.Integer);
	self.tmpPointArray.drawFilledPolygon(theFrame, Black, 1);		

	theFrame.drawWidth := 2;
	xWidth := 0;
	if self.scaleFactor = .5 then
		xWidth := 4;
		theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset :=8;
		yOffsetFnt := 3;

		if theLetter.length = 1 then
			xOffsetFnt := 7;
		else
			xOffsetFnt := 4;
		endif;
		theFrame.drawFontSize := 12;
		theFrame.drawFontBold := true;
	elseif self.scaleFactor = .75 then
		xWidth := 4;
		theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset :=11;
		yOffsetFnt := 6;

		if theLetter.length = 1 then
			xOffsetFnt := 7;
		else
			xOffsetFnt := 4;
		endif;
		theFrame.drawFontSize := 16;
		theFrame.drawFontBold := true;
	elseif self.scaleFactor = 1 then
		xWidth := 4;
		theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset :=15;
		yOffsetFnt := 9;
		if theLetter.length = 1 then
			xOffsetFnt := 10;
		else
			xOffsetFnt := 3;
		endif;
		theFrame.drawFontSize := 20;
		theFrame.drawFontBold := true;
	elseif self.scaleFactor = 1.5 then
		xWidth := 6;
		xOffset := 2;
		yOffset := 26;
		if theLetter.length = 1 then
			xOffsetFnt := 14;
		else
			xOffsetFnt := 8;
		endif;
		if theLetter.length &gt; 2 then
			yOffsetFnt := 13;
			theFrame.drawFontSize := 20;
		else
			yOffsetFnt := 13;
			theFrame.drawFontSize := 26;
		endif;
	elseif self.scaleFactor = 2 then
		xWidth := 8;
		xOffset := 6;
		yOffset := 36;
		if theLetter.length = 1 then
			xOffsetFnt := 22;
		else
			xOffsetFnt := 11;
		endif;
		if theLetter.length &gt; 2 then
			yOffsetFnt := 14;
			theFrame.drawFontSize := 26;
		else
			yOffsetFnt := 18;
			theFrame.drawFontSize := 36;
		endif;
	endif;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillColor := White;

	aReal :=  _theX1 + ((_theX2 - _theX1) / 2);
	xOffsetFnt := aReal.Integer;

	if _isQ40 or _isP40 or _isA40  then // the dummy side of a 40
		//theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);

		self.setTmpPointArrayXYs((_theX1 + xOffset).Integer, (_theY1 + yOffset).Integer, (_theX2 - xOffset).Integer, (_theY2 - yOffset.Integer).Integer);
		self.tmpPointArray.drawFilledPolygon(theFrame, Black, 1);		


		theFrame.drawTextAt(theLetter, xOffsetFnt, _theY1 + yOffsetFnt, Black); 
	else
		if is40 then
			//theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
			self.setTmpPointArrayXYs((_theX1 + xOffset).Integer, (_theY1 + yOffset).Integer, (_theX2 - xOffset).Integer, (_theY2 - yOffset.Integer).Integer);
			self.tmpPointArray.drawFilledPolygon(theFrame, Black, 1);		
		else
//			theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
			self.setTmpPointArrayXYs((_theX1 + xOffset).Integer, (_theY1 + yOffset).Integer, (_theX2 - xOffset).Integer, (_theY2 - yOffset.Integer).Integer);
			self.tmpPointArray.drawFilledPolygon(theFrame, Black, 1);		
		endif;
		theFrame.drawTextAt(theLetter, xOffsetFnt, _theY1 + yOffsetFnt, Black); 
	endif;
epilog
	theFrame.drawWidth := 1;
	theFrame.drawFontBold := false;

end;</source>
        <Parameter name="_theLetter" type="String"/>
        <Parameter name="_isP40" type="Boolean"/>
        <Parameter name="_isQ40" type="Boolean"/>
        <Parameter name="_isA40" type="Boolean"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
        <Parameter name="_theFill" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tiIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLC" id="dd45d5ea-c2b2-4361-8ea8-e6f06af3edcd">
        <updating/>
        <source>drawLC(_lc : CM_GridController) updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	FONTSIZE = 6;
vars
	startY,
	endY,
	endX: Real;
	idx,
	tmpNumTIs,
	theFrameHeight,
	twentyLength : Integer; //epr par 16701
	theTI: CM_TrackedItem; // theDummyTI
	theDisplayMode,
	aColour, 
	theFillColour : Integer;
	aLetter : String;
	tmpTIs	: CM_TIArray;
	theCellHeight, numHalfHeights  : Integer;
	theFrame	: YRD_ContainerDrawingFrame;
	tmpUsage,
	tmpAvail,
	tmpHeightNoStackFrom	: Integer;
	tmpBlockStack	: CM_BlockStack;
	isUnavailable,
	hasHeightRestriction	: Boolean;
	tmpPrimaryLC	: CM_LocationsController;
begin

	if self.drawFromNote then
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1._lc " &amp; _lc.String);
		self.allDrawnObjects.removeObjectsInDict(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer);
	endif;
	self.myLocationsController := _lc;
	theFrame := self.myDrawingFrame;
	
	if _lc = null or self.heightOfStack = 0 then
		// Nothing to draw
		return;
	endif;

	theDisplayMode := self.displayMode;
	tmpBlockStack			:= _lc.mySubBlockStack;
	twentyLength:=self.getLengthPerFoot(20); //epr par 16701
	
	
	if CM_StackController.hasInstance(_lc) then
		tmpUsage := _lc.CM_StackController.usage;
		tmpAvail := _lc.CM_StackController.availability;
		hasHeightRestriction := _lc.CM_StackController.hasHeightRestriction(self.heightOfStack);
		isUnavailable := (tmpUsage = UNAVAILABLE_USE or 
						 tmpAvail = PAD_USER_UNAVAILABLE or 
		   				 tmpAvail = PAD_UNAVAILABLE);

	endif;

	theFrame.drawFontName := "Arial";
	theFrame.drawFontSize := FONTSIZE * self.scaleFactor;
	
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	if self.myLocationsController.hasPower() then 
		theFillColour := self.POWER_FILL_COLOUR;
	else
		theFillColour := Gray;
	endif;

	theFrameHeight	:= theFrame.height.Integer;

	if theDisplayMode = DISPLAY_MODE_ACTUAL then
		tmpTIs := _lc.allTrackedItems;
	elseif theDisplayMode = DISPLAY_MODE_QUEUE then
		tmpTIs := self.allTempTIs;
		_lc.getAllQueuedTrackedItems(tmpTIs, true);
	elseif theDisplayMode = DISPLAY_MODE_PLAN then
		tmpTIs := self.allTempTIs;
		_lc.getAllPlannedTrackedItems(tmpTIs, true, false);
	endif;
	
	
	tmpNumTIs := tmpTIs.size;
	theFrame.drawWidth	:= 1;

	aColour := self.colour;
	aLetter := self.letter;
	
	if tmpBlockStack &lt;&gt; null then
		aColour := LightYellow;
		if tmpBlockStack.myLayoutGraphic &lt;&gt; null then
			aColour := tmpBlockStack.myLayoutGraphic.drawLineColour;
		endif;
		self.drawSubBlockStack(tmpBlockStack, aColour);

	elseif tmpUsage = BUILDING_USE then // BUILDING
		self.drawBuilding();

	elseif tmpUsage = LIGHT_TOWER_USE then // LIGHT
		self.drawLight();


	else
		self.cellHeight := ((self.y2 - self.y1) / self.heightOfStack).Integer;
		numHalfHeights := 0;
		startY := self.y2;

		self.drawNoTIs((tmpNumTIs = 0)); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;

		while true do
			idx := idx + 1;


			
			theTI := null;
			
			if idx &gt; tmpNumTIs or idx &gt; 20 then
				break;
			endif;
			theTI := tmpTIs[idx];
			

			if theDisplayMode = DISPLAY_MODE_ACTUAL then
				tmpPrimaryLC := theTI.myPrimaryActualLocation;
			elseif theDisplayMode = DISPLAY_MODE_QUEUE then
				tmpPrimaryLC := theTI.myPrimaryQueuedLocation;
			elseif theDisplayMode = DISPLAY_MODE_PLAN then
				tmpPrimaryLC := theTI.myPrimaryPlannedLocation;
			endif;
			
			theCellHeight := self.cellHeight.Integer;
			startY 	:= startY - theCellHeight ; 
			endY	:= startY + theCellHeight;
			if startY &lt; self.y1 then
				break;
			endif;
			startY:= endY - self.getContainerHeight;
			if tmpPrimaryLC &lt;&gt; _lc then
				// the TI will be drawn when its primary location is drawn
				continue;
			endif;
			endX:=self.x2;
			if theTI.isForty then
				endX:=self.x1 + ( twentyLength * 2).Integer;
			else
				endX:=self.x1 + twentyLength;
			endif;
			
			//self.drawTI(theTI, null, self.x1, startY, endX, endY, theFrame);		// cnwjk3 PAR 23875 23/04/10
			self.drawTI(theTI, null, self.x1, startY, endX, endY, theFrame, null);	// cnwjk3 PAR 23875 23/04/10
		endwhile;
	endif;

epilog

	if not self.allDrawnObjects.includes(self.myLocationsController) and tmpBlockStack = null then
		self.addToDrawnObjects(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer,self.myLocationsController,false);
//		self.setTmpPointArray();
//		create aPointArray transient;
//		self.tmpPointArray.copy(aPointArray);
//		self.allDrawnObjects.putAtKey(aPointArray, self.myLocationsController);
	endif;

	theFrame.drawFontName := "Arial";
	theFrame.drawFontSize := FONTSIZE * self.scaleFactor;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="drawLabour" id="63065734-e6fb-4e87-9016-04bfcfe03af3">
        <source>drawLabour( _tmpLabourRestriction: CM_LabourRestriction;_theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	label : String; 
	colour : Integer;
	anOffset1, anOffset2, aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;

	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
	aRest : CM_Restriction;
begin
	// This is so that we can clear up when a restriction is deleted
	self.addLCbyOID(_tmpLabourRestriction);
	
	theFrame := self.myDrawingFrame;
	theFrame.drawFillColor := _tmpLabourRestriction.colour;
	theFrame.drawFillStyle := Frame.DrawFillStyle_DownDiagonal;

	theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2, _tmpLabourRestriction.colour);
epilog
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

end;</source>
        <access>protected</access>
        <Parameter name="_tmpLabourRestriction" type="CM_LabourRestriction"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawLetter" id="60eccb87-1951-4c38-a67e-2cd909337211">
        <updating/>
        <source>drawLetter(_theFrame: CMUI_GridAreaDrawingFrame input; _theLetter: String; _theX: Integer; _theY: Integer; _theColour: Integer; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real; _theFill: Integer; _mode: Integer; _tiIndex: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	is40 : Boolean;
	xOffset, yOffset,yOffsetFnt,xOffsetFnt,xWidth : Integer;
	theLetter : String;
begin

	_theFrame.drawFillColor := _theFill;

	self.setTmpPointArrayXYs(_theX1.Integer, _theY1.Integer, _theX2.Integer, _theY2.Integer);
	self.tmpPointArray.drawFilledPolygon(_theFrame, _theFill, 1);		


	_theFrame.drawTextAt(_theLetter, _theX, _theY, _theColour);

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_theLetter" type="String"/>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY" type="Integer"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
        <Parameter name="_theFill" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tiIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLight" id="eab8a6c5-cc34-4f16-9765-e21fa09a8348">
        <updating/>
        <source>drawLight() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	anOffset1, anOffset2, aSlotHeight, aWindowHeight,aColour, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
	aLetter : String;
	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
	lPicture : Binary;
begin
	theFrame := self.myDrawingFrame;

	self.drawOverLappingRectangle(theSamePrev, theSameAbove, DarkGray, Yellow, theFrame);

	
	lPicture := app.myRoot.getConfig(PicLightBulb).Binary;
	theFrame.drawPictureAt(lPicture, self.x1 + 1, self.y1 + 1);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawNoTIs" id="4910d5bc-c1bc-4727-aee8-e6085189e979">
        <updating/>
        <source>drawNoTIs(_drawLetters : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		07 December 2005  By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 07/11/2012	CNWCS5	PAR 30475 - remove location restrictions
constants
	FONTSIZE = 6;
vars
	startY, endY 					: Real;
	idx, theDisplayMode, aColour, theFillColour,  letterIndex: Integer;
	deckStr 						: String;
	theCellHeight, numHalfHeights  	: Integer;
	theFrame						: YRD_ContainerDrawingFrame;
	tmpLabourRestriction			: CM_LabourRestriction;
	tmpUsage, tmpAvail, tmpHeightNoStackFrom	: Integer;
	tmpBlockStack					: CM_BlockStack;
	isUnavailable, hasHeightRestriction	: Boolean;
	tmpPrimaryLC					: CM_GridController;
	rowDeckingIndex, taDeckingIndex : Integer;
begin
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. LC: " &amp; self.myLocationsController.getFullId());
	theFrame := self.myDrawingFrame;
	
	tmpPrimaryLC := self.myLocationsController.CM_GridController;
	
	tmpLabourRestriction 	:= tmpPrimaryLC.allLabourRestrictions.first;
	tmpBlockStack			:= tmpPrimaryLC.mySubBlockStack;

	if tmpPrimaryLC.hasPower() then 
		theFillColour := self.POWER_FILL_COLOUR;
	else	
		theFillColour := Gray;
	endif;
	if CM_StackController.hasInstance(tmpPrimaryLC) then
		tmpUsage := tmpPrimaryLC.CM_StackController.usage;
		tmpAvail := tmpPrimaryLC.CM_StackController.availability;
		hasHeightRestriction := tmpPrimaryLC.CM_StackController.hasHeightRestriction(self.heightOfStack);
		isUnavailable := (tmpUsage = UNAVAILABLE_USE or 
						 tmpAvail = PAD_USER_UNAVAILABLE or 
		   				 tmpAvail = PAD_UNAVAILABLE);

	endif;
	self.cellHeight := ((self.y2 - self.y1) / self.heightOfStack).Integer;
	numHalfHeights := 0;
	startY := self.y2;

	// #######################
	theCellHeight := self.cellHeight.Integer; // there have been an even number of 1/2s so reset now

	startY 	:= startY - theCellHeight ; 
	if startY &lt; self.y1 then
		return;
	endif;
	endY	:= startY + theCellHeight;
	theCellHeight := self.cellHeight.Integer; // this may be half height to fill in, so reset it for next time

	if tmpPrimaryLC.isKindOf(CM_GapController) then
		if theFillColour &lt;&gt; self.POWER_FILL_COLOUR then
			theFillColour := self.myDrawingFrame.backColor;
		endif;
		self.drawBlankSpace(theFillColour, idx, self.x1, startY, self.x2, endY - 1); 

	elseif tmpLabourRestriction &lt;&gt; null and (not isUnavailable) then
		if hasHeightRestriction then // HEIGHT RESTRICTION
			if idx &gt;= tmpHeightNoStackFrom then
				self.drawBlankSpace(theFillColour, idx, self.x1, startY, self.x2, endY - 1); 
				if _drawLetters then
//							self.drawHeight(aLetter, Red, self.x1, startY, self.x2, endY);	
				endif;
			else
				aColour := tmpLabourRestriction.colour;
				self.drawBlankSpace(theFillColour, idx, self.x1, self.y1, self.x2, self.y2 - 1); 
				self.drawLabour(tmpLabourRestriction, self.x1, self.y1, self.x2, self.y2);
			endif;
		else
			aColour := tmpLabourRestriction.colour;
			self.drawBlankSpace(theFillColour, idx, self.x1, self.y1, self.x2, self.y2 - 1); 
			self.drawLabour(tmpLabourRestriction, self.x1, self.y1, self.x2, self.y2);
		endif;
	elseif hasHeightRestriction then // HEIGHT RESTRICTION
		self.drawBlankSpace(theFillColour,idx, self.x1, startY, self.x2, endY - 1); 
		if idx &gt;= tmpHeightNoStackFrom then
				if _drawLetters then
//						self.drawHeight(aLetter, Red, self.x1, startY, self.x2, endY);
				endif;
		endif;
//		elseif theDisplayMode &lt;&gt; DISPLAY_MODE_ACTUAL and 
//			   idx &lt;= tmpTIs.size and 
//			   tmpTIs.size &gt; 0 then
				if _drawLetters then

//			self.drawLetter(theFrame,"A", (self.x1+((self.x2-self.x1)/2)-5).Integer, (startY + 2).Integer, Black,self.x1, startY, self.x2, endY,theFillColour,REAL_MODE,idx);
				endif;
	else
		if isUnavailable then
			theFillColour := theFrame.backColor;
		endif;
		// fill colour set up top - Gray or Blue
		self.drawBlankSpace(theFillColour,idx, self.x1, self.y1, self.x2, endY ); 
	endif;
	
	// draw the Ps and Qs in addition to the actual TI graphic
	letterIndex := letterIndex + 1;
				if _drawLetters then
	self.doDrawFMLetter(theDisplayMode, letterIndex, theFillColour, startY, endY, null);
endif;
	if app.isSpecial() then
		return;
	
		if idx &lt;= self.heightOfStack then
			rowDeckingIndex := tmpPrimaryLC.getRowIndexForYALocnCell(idx, true).Integer;
			taDeckingIndex := tmpPrimaryLC.getTAIndexForYALocnCell(idx, true).Integer;
			if self.scaleFactor = ScaleFactor_1 then
				deckStr := rowDeckingIndex.String;
			else
				deckStr := taDeckingIndex.String &amp; "/"&amp; rowDeckingIndex.String;
			endif;

			theFrame.drawFontSize  := 8;
			theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			theFrame.drawTextAt(deckStr, self.x1 + 2, startY , Black);
		endif;
	endif;


end;</source>
        <Parameter name="_drawLetters" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawObject" id="100a3e33-a6e1-4eee-bcbb-5dca27584356">
        <updating/>
        <source>drawObject(_frame : CMUI_GridAreaDrawingFrame input; _obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		09 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	points : PointArray;
begin
	if _obj = null then
		return;
	endif;
	
	points := self.allDrawnObjects.getPolygonForObject(_obj);
	if points = null then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. could not find object " &amp; _obj.String &amp; ". Cannot draw");
		return;
	endif;
	

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="drawOverLappingRectangle" id="9d313785-95fa-4652-9540-0feb50f6b674">
        <source>drawOverLappingRectangle(_theSamePrev, _theSameAbove: Boolean; _backColour, _foreColour : Integer; _frame: CMUI_GridAreaDrawingFrame input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaDrawingFrame;
	anOffset1, anOffset2,anOffset3,anOffset4,aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
begin
	theFrame := _frame;
	
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

	tmpx1 := self.x1.Integer + 2;
	tmpy1 := self.y1.Integer;
	anOffset4 := 2;
	tmpx2 := self.x2.Integer + 4;
	tmpy2 := self.y2.Integer;
	if _theSameAbove then
		anOffset3 := 8;
	else
		anOffset3 := 0;
	endif;
	if _theSamePrev then // the previous point is also the same sub block
		anOffset1:= 2;
		anOffset2 := 4;
	else
		anOffset1:= 0;
		anOffset2 := 2;
	endif;

	theFrame.drawFillColor := _backColour;
	theFrame.drawFilledRectangle(tmpx1 - anOffset1 , tmpy1 - 2 - anOffset3 , tmpx2 , tmpy2,_backColour);
	theFrame.drawFillColor := _foreColour;
	theFrame.drawFilledRectangle(tmpx1 - anOffset2, tmpy1 - 4 - anOffset3, tmpx2 - anOffset4, tmpy2 - 2,_foreColour);

end;</source>
        <Parameter name="_theSamePrev" type="Boolean"/>
        <Parameter name="_theSameAbove" type="Boolean"/>
        <Parameter name="_backColour" type="Integer"/>
        <Parameter name="_foreColour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawPlannedQueuedContainers" id="04039d73-6c0c-460f-b3f2-2ba4dd6c8481">
        <source>drawPlannedQueuedContainers(_x1, _y1, _x2, _y2 : Integer; _trailer : CM_TILC; _frame: CMUI_GridAreaDrawingFrame input ) protected;

/*

Purpose:			
	My attempt to hack this hacky code even further, to allow queued and planned containers/trailers to be drawn on top of a trailer

Parameters:			
	_x1 		: far left of trailer
	_y1 		: a few pixels above trailer
	_x2 		: far right of trailer  (as far right as we could display a container)
	_y2 		: just above base of trailer (where bottom of container will sit)
	_trailer	: trailer we are drawing on top of
	_frame 		: drawing frame
Return Value:		


Date		Who		Reason
23 October 2009	cnwjk3	Initial creation

*/

vars
	lc : CM_LocationsController;
	
	containerHeight,
	twentyLength,
	fortyLength,
	oldcx1,
	oldcy1,
	cx1,
	cx2,
	cy1,
	cy2	: Integer;
	
	futureMove	: CM_FutureMove;
	futureMoveQ	: CM_FutureMoveQueued;
	futureMoveP	: CM_FutureMovePlanned;
begin
	_frame.drawWidth := 1;
	_frame.drawStyle := Frame.DrawStyle_Solid;
	_frame.drawFillColor := Red;
	_frame.drawFillStyle := Frame.DrawFillStyle_Solid;

	containerHeight:=self.getContainerHeight();
	twentyLength:=self.getLengthPerFoot(20);
	fortyLength:=self.getLengthPerFoot(40);

	
	cx1 := _x1;
	cx2 := _x1;
	cy1 := _y2 - containerHeight;
	cy2 := _y2;
	foreach lc in _trailer.allLCs do
		
		oldcx1 := cx1;
		oldcy1 := cy1;
		// Draw the queued moves
		foreach futureMove in lc.allQueuedFutureMoves do	
			futureMoveQ := futureMove.CM_FutureMoveQueued;
			if futureMoveQ.myTrackedItem.isKindOf(CM_TILC) then
				// Use same width as a 40ft
				cx2 := cx1 + fortyLength;
			else
				cx2 := cx1 + twentyLength;
			endif;
			self.drawCargoLetter("Q", cx1, cy1, cx2, cy2, _frame); 
			cy1 := cy1 - containerHeight;
			cy2 := cy2 - containerHeight;
		endforeach;
		
		cx1 := oldcx1;
		
		// Draw the planned moves
		foreach futureMove in lc.allPlannedFutureMoves do	
			futureMoveP := futureMove.CM_FutureMovePlanned;
			if futureMoveP.myTrackedItem.isKindOf(CM_TILC) then
				// Use same width as a 40ft
				cx2 := cx1 + fortyLength;
			else
				cx2 := cx1 + twentyLength;
			endif;
			self.drawCargoLetter("P", cx1, cy1, cx2, cy2, _frame); 
			cy1 := cy1 - containerHeight;
			cy2 := cy2 - containerHeight;
		endforeach;		
		
		// Adjust for next LC
		cx1 := cx2;
		cx2 := cx1 + twentyLength; 
		cy1 := _y2 - containerHeight;
		cy2 := _y2;
	endforeach;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_trailer" type="CM_TILC"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSelfLC" id="5de389bf-1d06-4370-a1ba-da10425e84eb">
        <updating/>
        <source>drawSelfLC(_lc: CM_GridController; _xpos1,_xpos2 : Real io; _colIdx	: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	ColWidth		: Integer = 24;
	ColumnSpacing	: Integer = 2;

vars
	theColWidth : Real;
begin

	theColWidth	 := self.drawColWidth * self.scaleFactor;

	self.x1 := _xpos1;
	self.x2 := _xpos2;
	self.drawLC(_lc);
	_colIdx := _colIdx + 1;
	_xpos1 := _xpos1 + ColumnSpacing + theColWidth;
	_xpos2 := _xpos1 + theColWidth;
end;</source>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
        <Parameter name="_xpos2" type="Real" usage="io"/>
        <Parameter name="_colIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfRowDrawStackDir" id="50ca47a3-cfa5-4cd1-809d-31d34d9bb652">
        <updating/>
        <source>drawSelfRowDrawStackDir(_row : CM_GridRow; _frame : Frame input; _x,_y,_y1,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
//				ONly call this for rows with decking options
//
// ---------------------------------------------------------------------------
constants
	RowHeight = 12;
vars
	tmpCaption 			: String;
	tmpX, tmpY,cellY1,cellY2,cellIdx,theRowHeight,char, yOffset : Integer;
	dirArray			: IntegerArray;
	deckingOptions		: CM_YADeckingOptions;
begin
	if not self.configAutoPlanUseAllocations then
		return;
	endif;

	deckingOptions := _row.myDeckingOptions;
	if deckingOptions = null then
		deckingOptions := _row.myGridArea.myYADeckingOptions;
	endif;
	
	theRowHeight := (RowHeight * self.heightOfStack * self.scaleFactor).Integer;
	cellHeight := (theRowHeight / self.heightOfStack).Integer;

	// ##### ROW STACKING DIRECTION 
	if deckingOptions.isDeckingDirectionDown(_row) then
		if self.flipVertically then
			tmpCaption := 225.Character; //"^"
		else
			tmpCaption := 226.Character; // "\/"
		endif;
	elseif deckingOptions.isDeckingDirectionUp(_row) then
		if self.flipVertically then
			tmpCaption := 226.Character; // "\/"
		else
			tmpCaption := 225.Character; //"^"
		endif;
	elseif deckingOptions.isDeckingLeftToRight() then
		if self.flipHorizontal then
			tmpCaption := 223.Character; // "&lt;--"
		else
			tmpCaption := 224.Character; // "--&gt;"
		endif;
	else
		if self.flipHorizontal then
			tmpCaption := 224.Character; // "--&gt;"
		else
			tmpCaption := 223.Character; // "&lt;--"
		endif;
	endif;		

	_frame.drawFontName := "Wingdings";

	tmpX := _x;
	tmpY := _y;
	_frame.drawTextAt(tmpCaption, tmpX + 1, tmpY + 1, White);
	_frame.drawTextAt(tmpCaption, tmpX, tmpY, Black);
	
	
	// ##### ROW and STACK POSITION DECKING DIRECTION UP, LEFT or RIGHT
	dirArray := self.deckingArray;
	dirArray.clear;
	deckingOptions.getHeightDirections(dirArray); // Decking_Left

	if dirArray.isEmpty then
		return;
	endif;

	tmpX := _x + 31;
	yOffset  := 8;

	if self.scaleFactor = self.ScaleFactor_1 then
		yOffset := 3;
	elseif self.scaleFactor = self.ScaleFactor_1_5 then
		yOffset := 3;
	elseif self.scaleFactor = self.ScaleFactor_2 then
		yOffset := 5;
	endif;
	cellY1 := _y2;
	foreach cellIdx in 1 to self.heightOfStack do : cellLoop
		cellY2 := cellY1 - cellHeight;
		
		char := dirArray[cellIdx];
		if char = Decking_Left then
			if self.flipHorizontal then
				tmpCaption := 224.Character; // "--&gt;"
			else
				tmpCaption := 223.Character; // "&lt;--"
			endif;
		elseif char = Decking_Right then
			if self.flipHorizontal then
				tmpCaption := 223.Character; // "&lt;--"
			else
				tmpCaption := 224.Character; // "--&gt;"
			endif;
		elseif char = Decking_Up then
			tmpCaption := 225.Character; //"^"
		elseif char = Decking_Down then
			tmpCaption := 226.Character; // "\/"
		else
			tmpCaption := 243.Character; // "&lt;-&gt;" = custom or no particular direction
		endif;

		tmpY := (((cellY1 - cellY2) / 2) + cellY2).Integer;
		
		tmpY := tmpY - yOffset;
		_frame.drawTextAt(tmpCaption, tmpX + 1, tmpY + 1, White);
		_frame.drawTextAt(tmpCaption, tmpX, tmpY, Black);


		cellY1 := cellY2;
	endforeach;
	

epilog
	
	_frame.drawFontName := "Arial"; // PAR 20182 was Ariel

end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSubBlockStack" id="5061d0fd-27ec-414c-ba17-908436dc7604">
        <updating/>
        <source>drawSubBlockStack(_tmpBlockStack : CM_BlockStack; _colour: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	label: String;
//	theFrame : CMUI_GridAreaFrame;
//	anOffset1, anOffset2,aSlotHeight, aWindowHeight, idx : Integer;
//	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
//	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
//	aTA : CM_TerminalArea;
//	theGridArea : CMUI_GridArea;
	myGC, prevGC, aboveGC : CM_GridController;
	colIdx, rowIdx : Integer;
begin
	// This is so that we can clear up when a SBS is deleted
	self.addLCbyOID(_tmpBlockStack);
	
	self.addToDrawnObjects(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer,_tmpBlockStack,false);
	myGC := self.myLocationsController.CM_GridController;

	theSamePrev := false;
	if self.flipHorizontal then
		prevGC := myGC.getNextControllerOfType(CM_GridController);
	else
		prevGC := myGC.getPreviousControllerOfType(CM_GridController);
	endif;
	if prevGC &lt;&gt; null then
		if prevGC.mySubBlockStack = _tmpBlockStack then
			theSamePrev := true;
		endif;
	endif;
	theSameAbove := false;
	
	colIdx := myGC.myGridColumn.myGridArea.allGridColumns.indexOf(myGC.myGridColumn);
	rowIdx := myGC.myGridRow.myGridArea.allGridRows.indexOf(myGC.myGridRow);
	if self.flipVertically then
		rowIdx := rowIdx + 1;
	else
		rowIdx := rowIdx -1;
	endif;
	aboveGC := myGC.myGridColumn.myGridArea.allGridControllersByRowColumn[rowIdx,colIdx];
	if aboveGC &lt;&gt; null then
		if aboveGC.mySubBlockStack = _tmpBlockStack then
			theSameAbove := true;
		endif;
	endif;
	
	self.drawOverLappingRectangle(theSamePrev,theSameAbove, DarkGray, _colour, self.myDrawingFrame);

end;</source>
        <access>protected</access>
        <Parameter name="_tmpBlockStack" type="CM_BlockStack"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSubBlockStackLabels" id="bf53ddeb-a8d6-44bd-a99a-36800c819fad">
        <source>drawSubBlockStackLabels();
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpObj : Object;
	aLabel : String;
	theSBS : CM_SubBlockStack;
	pointX ,pointY,aColour : Integer;
	anIterator : Iterator;
	objs : ObjectSet;
	tmpP : PointArray;
	tmpPoint : Point;
begin
	create objs transient;
	anIterator := self.allDrawnObjects.createIterator( );
	while anIterator.next(tmpObj)  do 
		if tmpObj.isKindOf(CM_SubBlockStack) then
			theSBS := tmpObj.CM_SubBlockStack;
			if not objs.includes(theSBS) then
				objs.add(theSBS);
				aLabel := theSBS.id;
				if theSBS.myLayoutGraphic &lt;&gt; null then
					aColour := theSBS.myLayoutGraphic.drawLineColour.getInverseColour;
				else
					aColour := Black;
				endif;
				aLabel := aLabel &amp; Cr &amp; theSBS.getMenuDetails(true, self.displayMode);
		
				tmpP := anIterator.getCurrentKey(5).PointArray;
				tmpPoint := tmpP[1];
				pointX := tmpPoint.x + 4;
				pointY := tmpPoint.y;
				self.myDrawingFrame.drawFontSize := self.scaleFactor * 16;
				self.myDrawingFrame.drawTextAt(aLabel,pointX ,pointY, aColour);
			endif;
		endif;
	endwhile;
epilog
	delete objs;
	delete anIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawTI" id="12bd2d44-e72d-40df-81c1-ac99c478b1b9">
        <updating/>
        <source>drawTI(_theTI: CM_TrackedItem; _theGridAttributes: CMUI_GridAttributes input; _x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: CMUI_GridAreaDrawingFrame input;  _lc : CM_LocationsController) updating, protected;
// ---------------------------------------------------------------------------
// Created:		02 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
tiLC, kidTIlc : CM_TILC;
	anLC : CM_TILCController;
	aTI : CM_TrackedItem;
	theTIs : CM_TIByOrder;
	yBase, tier : Integer;
begin
	yBase := _y2.Integer;
	if _theTI.isKindOf(CM_TILC) then
		self.drawTILC(_theTI,_theGridAttributes, _x1.Integer, _y1.Integer, _x2.Integer, yBase, _frame);

	else 
		self.setIconPositions(0, _y1, _x2, _y2); 
		//inheritMethod(_theTI, _theGridAttributes,  _x1, _y1, _x2, _y2, _frame,);		// cnwjk3 PAR 23875 23/04/10
		inheritMethod(_theTI, _theGridAttributes,  _x1, _y1, _x2, _y2, _frame, _lc);	// cnwjk3 PAR 23875 23/04/10
		self.addToDrawnObjects( _x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer, _theTI,true);
	endif;
epilog

end;</source>
