    <JadeMethod name="doTblEntryQryRowColChange" id="ce7c12bc-209a-4d2a-9157-b761d5de2027">
        <updating/>
        <source>doTblEntryQryRowColChange(_tbl : CM_EntryTable input; newRow: Integer; newCol: Integer) : Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 May 2007 By cnwth2

Purpose:	re-implement as necessary

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	firstVisibleRow,
	listCount,
	idx						: Integer;
	nextTreeItem			: Object;
begin
	firstVisibleRow := _tbl.getFirstVisibleRow();
	//th2 - PAR 15060 - if tabbing out of the bottom most field, or tabbing back from the top most field
	//in the entry table, automatically
	//take the user to the next logical field for the next item in the tree
	if _tbl.row = _tbl.rows then//handle tabbing forward from the bottom most field
		if newRow &gt; firstVisibleRow then//shift+tabbing back from the bottom most field
			return true;
		endif;
		
		listCount := self.lstTree.listCount;
		idx := self.lstTree.listIndex;
		
		/*
			Date		 Who		Reason
		  23 July 2008	cnwdz2	    Par17610 - check for tree selection.
		*/
		if idx &gt; 0 then 
			while true do
				idx := idx + 1;
				if idx &gt; listCount then
					break;
				endif;
				
				nextTreeItem := self.lstTree.itemObject[idx];
				if CM_Object.hasInstance(nextTreeItem) then
					self.saveUserEntry();
					self.selectObject(nextTreeItem.CM_Object);
					self.zSetTblEntryFocus();
					return false;
				endif;
			endwhile;
		endif;

	endif;

	return true;

end;


</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
