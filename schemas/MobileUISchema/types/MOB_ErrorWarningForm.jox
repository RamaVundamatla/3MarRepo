    <JadeMethod name="canAckWarningsSkipErrors" id="83105d3e-b2aa-454f-bd59-2d3b0d63f2e8">
        <source>canAckWarningsSkipErrors():Boolean;
/*
	Created on 01 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return self.mode.bitAnd(ErrWarnMode_CanAckWarnSkipErr).Boolean;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canAcknowledgeWarnings" id="3e3b6626-b60c-4f4e-9316-41bca06d74f5">
        <source>canAcknowledgeWarnings():Boolean;
/*
	Created on 01 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return self.mode.bitAnd(ErrWarnMode_CanAckWarnings).Boolean;
end;	</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="0c5ebec9-6507-4c14-aa1f-fe9c3acfdc15">
        <updating/>
        <source>init(_heading : String; _passport : CM_Passport; _mode : Integer) updating;
/*
	Created on 01 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	err			: CM_Error;
	rowNo,
	cellHeight	: Integer;
	tblRow		: JadeTableRow;
	tmpStr		: String;
	
begin
	self.mode 			:= _mode;
	self.hasErrors		:= (not _passport.allErrors.isEmpty);
	self.hasWarnings	:= (not _passport.allWarnings.isEmpty);
	
	self.setHeadings(_heading);
	
	foreach err in _passport.allErrors do
		tblErrors.fitTextToCell(err.text, tmpStr, tblErrors.width.Integer, cellHeight);
		rowNo := tblErrors.addItem(tmpStr);
		tblRow := tblErrors.accessRow(rowNo);
		tblRow.foreColor := Red;
		tblRow.height := cellHeight;
	endforeach;

	foreach err in _passport.allWarnings do
		tblErrors.fitTextToCell(err.text, tmpStr, tblErrors.width.Integer, cellHeight);
		rowNo := tblErrors.addItem(tmpStr);
		tblRow := tblErrors.accessRow(rowNo);
		tblRow.foreColor := Blue;
		tblRow.height := cellHeight;
	endforeach;
	
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isModeDelete" id="2499614d-bc6a-43a2-b920-8b97cc4b6989">
        <source>isModeDelete():Boolean;
/*
	Created on 01 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return 	self.mode.bitAnd(ErrWarnMode_Delete).Boolean;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHeadings" id="dda6145e-8faf-40cb-bb29-ec1fcf16f5d7">
        <updating/>
        <source>setHeadings(_heading : String) updating;
/*
	Created on 01 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	titleStr	: String;
	
begin
	if self.hasErrors and (not self.canAckWarningsSkipErrors) then
		if self.hasWarnings then
			titleStr := app.getErrorString(EWD_Errors_Warnings);
		else
			titleStr := app.getErrorString(Errors);
		endif;

	elseif self.canAckWarningsSkipErrors then
		if self.hasErrors and self.hasWarnings then
			titleStr := app.getErrorString(EWD_Errors_Warnings);
		elseif self.hasErrors then
			titleStr := app.getErrorString(Errors);
		else
			titleStr := app.getErrorString(EWD_Warnings);
		endif;
		
	elseif self.canAcknowledgeWarnings then
		titleStr := app.getErrorString(EWD_Warnings);
	else
		titleStr := app.getErrorString(EWD_Warnings);
	endif;
	
	if _heading &lt;&gt; null then
		self.caption := titleStr &amp; ': ' &amp; _heading;
	else
		self.caption := titleStr;
	endif;
end;</source>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c99db9c3-f787-4259-8371-e452f91d5ced">
        <updating/>
        <source>setupForm() updating, protected;
/*
	Created on 01 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	actionStr	: String;
	
begin
	inheritMethod();
	
	if self.isModeDelete then
		actionStr := 'deleted';
	else
		actionStr := 'saved';
	endif;

	if self.hasErrors and (not self.canAckWarningsSkipErrors) then
		if self.hasWarnings then
			lblHeader.caption := app.getErrorString1(EWD_Cannot_Continue, actionStr);
		else
			lblHeader.caption := app.getErrorString1(EWD_Error_Cannot_Continue, actionStr);
		endif;
		
		btnOK.visible := false;

	elseif self.canAckWarningsSkipErrors then
		if self.hasErrors and self.hasWarnings then
			lblHeader.caption := app.getErrorString(EWD_Warn_SkipErrors);
			btnOK.caption := 'Save';
			btnCancel.caption := 'Cancel';			
		elseif self.hasErrors then
			lblHeader.caption := app.getErrorString1(EWD_Error_Cannot_Continue, actionStr);
			btnOK.visible := false;				
		else
			if self.isModeDelete then
				lblHeader.caption := app.getErrorString(EWD_Warn_Continue_Cancel);
				btnOK.caption := 'Delete';
			else
				lblHeader.caption := app.getErrorString(EWD_Warn_Continue_Review);
				btnOK.caption := 'Save';
			endif;
			
			btnCancel.caption := 'Cancel';
		endif;
		
	elseif self.canAcknowledgeWarnings then
		if self.isModeDelete then
			lblHeader.caption := app.getErrorString(EWD_Warn_Continue_Cancel);
			btnOK.caption := 'Delete';
		else
			lblHeader.caption := app.getErrorString(EWD_Warn_Continue_Review);
			btnOK.caption := 'Save';
		endif;
		
		btnCancel.caption := 'Cancel';

	else
		lblHeader.caption := app.getErrorString(EWD_Warning_Resubmit);
		btnOK.visible := false;						
	endif;
	
	if self.isNonTransaction then
		lblHeader.caption	:=	app.getErrorString(EWD_warning_found);
		btnOK.visible		:=	false;
		btnCancel.cnEcSet("&amp;OK");
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
