    <JadeMethod name="setMultiStackWagon" id="28dde58b-9fc3-4ff8-922c-48f0f8a7cbc5">
        <updating/>
        <source>setMultiStackWagon( _wagon : CM_Wagon ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2014	cnwndl1	Initial creation	Par 35040

*/

vars

	multiStack : Boolean;

begin

	multiStack := false;

	if _wagon &lt;&gt; null then
		if _wagon.isFlatcar or _wagon.isWellcarVisit then
			multiStack := _wagon.myWagonClass.maxNumInStack &gt; 1;
		endif;
	endif;

	if self.multiStackWagon &lt;&gt; multiStack then
		self.multiStackWagon := multiStack;
		self.shuffleControls();
	endif;

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
