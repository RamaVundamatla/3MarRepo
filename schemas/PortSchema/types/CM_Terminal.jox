/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2020	jlgndl1	Initial creation	TFS 50279

*/

vars

begin
	
	if self.allStateObjects = null then
		return false;
	endif;
	
	return self.allStateObjects.hasStateDataRefToObj( _obj, _key );

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_key" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTrackedItemForCargoType" id="f12ff948-0ff0-44b6-b208-cc4eaa0aae26">
        <source>hasTrackedItemForCargoType(_cargoType : Integer; _checkCurrentOnly : Boolean) : Boolean;
/*---------------------------------------
	Created: April 2006 By: cnwgd1
	
	_checkCurrentOnly is intended to check onsite and cargo about to be delivered and recent voyages

---------------------------------------*/
vars
	tmpTI : CM_TrackedItem;
	tmpVoyage : CM_Voyage;
begin

	//----------------------
	// Lookup every dictionary until we find one...
	//----------------------
	tmpTI := self.allOnsiteTIsByCargoTypeId.getAtKeyGeq(_cargoType, null);
	if tmpTI &lt;&gt; null
	and tmpTI.cargoType = _cargoType then
		return true;
	endif;
	//----------------------
	// TBA Dictionary
	//----------------------
	tmpTI := self.allTbaTIsByCargoTypeId.getAtKeyGeq(_cargoType, null);
	if tmpTI &lt;&gt; null
	and tmpTI.cargoType = _cargoType then
		return true;
	endif;
	//16 Mar 2020	NDL	TFS 47004
	//----------------------
	// RRP Dictionary
	//----------------------
	tmpTI := self.allRRPTIsByCargoTypeId.getAtKeyGeq(_cargoType, null);
	if tmpTI &lt;&gt; null
	and tmpTI.cargoType = _cargoType then
		return true;
	endif;
	//----------------------
	//Notified Dictionary
	//----------------------
	tmpTI := self.allNotifiedTIsByCargoTypeId.getAtKeyGeq(_cargoType, null);
	if tmpTI &lt;&gt; null
	and tmpTI.cargoType = _cargoType then
		return true;
	endif;

	//----------------------
	//Current Voyages
	//----------------------
	foreach tmpVoyage in self.allVoyagesByCode do
		tmpTI := tmpVoyage.allOnshipTIsByCargoTypeId.getAtKeyGeq(_cargoType, null);
		if tmpTI &lt;&gt; null
		and tmpTI.cargoType = _cargoType then
			return true;
		endif;
	endforeach;
	
	if (not _checkCurrentOnly) then

		//-----------
		//Lookup the OFFSITE dict
		//-----------
		if (not _checkCurrentOnly) then
			tmpTI := self.allOffsiteTIsByCargoTypeId.getAtKeyGeq(_cargoType, null, null);
			if tmpTI &lt;&gt; null
			and tmpTI.cargoType = _cargoType then
				return true;
			endif;
		endif;

		//-----------
		//Lookup the DELETED dict
		//-----------
		tmpTI := self.allDeletedTIsByCargoTypeId.getAtKeyGeq(_cargoType, null, null);
		if tmpTI &lt;&gt; null
		and tmpTI.cargoType = _cargoType then
			return true;
		endif;
		
		//----------------------
		//Archived Voyages
		//----------------------
		foreach tmpVoyage in self.allVoyagesArchived do
			tmpTI := tmpVoyage.allOnshipTIsByCargoTypeId.getAtKeyGeq(_cargoType, null);
			if tmpTI &lt;&gt; null
			and tmpTI.cargoType = _cargoType then
				return true;
			endif;
		endforeach;

	endif;
	
	// not found
	return false;
end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_checkCurrentOnly" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTransactionOfType" id="c61a960c-1ba1-4aa6-9a01-5cb34e11945f">
        <source>hasTransactionOfType(_txnType : CM_TransactionType) : Boolean;
// ---------------------------------------------------------------------------
// Created:     10 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTrans	: CM_Transaction;
begin
	if _txnType.trxGroup = TRANS_TYPE_GROUP_BOL then
	elseif _txnType.trxGroup = TRANS_TYPE_GROUP_HMS then
		tmpTrans := self.allHMSTransactionsByTypeDate[_txnType.trxType, null];
		if tmpTrans &lt;&gt; null and tmpTrans.getType() = _txnType.trxType then
			return true;
		endif;
	elseif _txnType.trxGroup = TRANS_TYPE_GROUP_SOH then
	elseif _txnType.trxGroup = TRANS_TYPE_GROUP_WO then // TFS 39236

	elseif _txnType.trxGroup = TRANS_TYPE_GROUP_TI then
		tmpTrans := self.allTITransactionsByTypeDate[_txnType.trxType, null];
		if tmpTrans &lt;&gt; null and tmpTrans.getType() = _txnType.trxType then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="_txnType" type="CM_TransactionType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
