    <JadeMethod name="getExtraInfo" id="9ce2f39c-c44f-4213-b8a2-b17cc61b077b">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2018	jlgab1	Initial creation
30 Nov 2021 navma1	Bug 52482: SAL - Web Portal - Cargo Work Orders
*/

vars
	block   : CM_DataContainerBlock;
	tmpTS   : TimeStamp;
	wodres  : CM_WodMarineServiceDetail;
	invalid : Boolean;
	voyage  : CM_Voyage;
begin

	on Exception do app.handleDeletedObject(exception,self.myNewVoyage,invalid);// TFS 52176

	inheritMethod(_dataContainer);

	tmpTS := self.systemToLocalTime(self.requiredByDT);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Required_By_Caption), DC_Label, 1, null);
	block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null); 
	

	if self.myNewVoyage &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Voyage), DC_Label, 1, null);
		
		if not self.myNewVoyage.isNullVoyage then							//30.11.2021 navma1 #52482
			voyage := self.myNewVoyage;
		endif;
		block.addNewItem(self.myNewVoyage.code , DC_Data, 1, voyage);       //30.11.2021 navma1 #52482
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageObject" id="bdcfd4c5-30af-41d0-9172-622891a5e223">
