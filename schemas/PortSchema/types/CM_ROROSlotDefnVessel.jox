<Class name="CM_ROROSlotDefnVessel" id="5362aeac-3553-4af5-83b5-3c69e6401417">
    <superclass name="CM_ROROSlotDefn"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="myROROStructure" id="d0ff3179-46d7-4b08-8fa6-3b201aa42e25">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_ROROVesselStructure"/>
        <access>readonly</access>
        <Inverse name="CM_ROROVesselStructure::allROROSlotDefnByDeckCode"/>
        <Inverse name="CM_ROROVesselStructure::allROROSlotDefnByDeckOrdinal"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneMySelf" id="84a90a30-6b5b-4ce6-be57-848080fca103">
        <source>cloneMySelf(_newLocn: CM_ROROLocnDefn; _copy : Boolean): CM_ROROSlotDefn;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	newMe : CM_ROROSlotDefn;
begin
	newMe :=  inheritMethod(_newLocn, _copy).CM_ROROSlotDefn;

	if newMe.isKindOf(CM_ROROSlotDefnVessel) then
		newMe.CM_ROROSlotDefnVessel.myROROStructure := _newLocn.myDeck.CM_DeckVessel.getROROStructure;
	elseif newMe.isKindOf(CM_ROROSlotDefnVoyage) then
		newMe.CM_ROROSlotDefnVoyage.setMyVoyageStructure(_newLocn.myDeck.CM_DeckVoyage.myVoyageStructure);
		newMe.CM_ROROSlotDefnVoyage.createSlotController();
	endif;
	return newMe;
epilog

end;</source>
        <Parameter name="_newLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_ROROSlotDefn"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d99c7733-446d-4e85-ae81-fedd6edf017c">
        <source>pxyCreateUpdateProxy(): SelfType ;
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
*/

vars
	completedOK		: Boolean;
	pxyMe : SelfType;
begin
	pxyMe :=  inheritMethod();

	pxyMe.myDeck := self.myDeck.pxyGetProxyObject();
	pxyMe.myROROLocnDen := self.myROROLocnDen.pxyGetProxyObject();
	pxyMe.myROROStructure := self.myROROStructure.pxyGetProxyObject();

	completedOK := true;
	return pxyMe;
epilog
	if not completedOK then
		delete pxyMe;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCode" id="0592db27-075a-4cf0-8128-885fdf9b3732">
        <updating/>
        <source>setCode(_code: String) : Boolean updating;
/*
Purpose:			
Date		Who		Reason
09 February 2012	cnwab1	Initial creation
*/

vars
	realMe : CM_ROROSlotDefnVessel;
	otherMe : CM_ROROSlotDefn;
begin

	// PAR 29088
	if self.pxyIsProxy then // update proxy
		realMe := self.pxyGetRealObject();
	elseif self.isTransient then // create proxy
		realMe := self;
	else
		realMe := self;
	endif;
	
	if realMe.myROROStructure &lt;&gt; null then
		otherMe := realMe.myROROStructure.allROROSlotDefnByDeckCode[realMe.myDeck, _code];
		if otherMe &lt;&gt; null and otherMe &lt;&gt; realMe then
			return false;
		endif;
	elseif self.myDeck &lt;&gt; null then
		otherMe := realMe.myDeck.allSlotDefnByCode[_code];
		if otherMe &lt;&gt; null and otherMe &lt;&gt; realMe then
			return false;
		endif;
	endif;
	
	return  inheritMethod(_code);

epilog
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7582dc4f-c9cd-4cfc-ace3-cef94e94bd79">
        <updating/>
        <source>setForCreate(_pxySelf : CM_ROROSlotDefnVessel) updating;
/*
Purpose:			
Date		Who		Reason
19 April 2011	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(_pxySelf);
	
	if self.myDeck &lt;&gt; null then
		self.myROROStructure := self.myDeck.CM_DeckVessel.getROROStructure;
	endif;
epilog

end;</source>
        <Parameter name="_pxySelf" type="CM_ROROSlotDefnVessel"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="83b71534-8a69-42ef-8378-4ad27936a766">
        <updating/>
        <source>setForCreateImport(_pxySelf: CM_ROROSlotDefn; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod(_pxySelf, _passport);

	self.myROROStructure:=self.myDeck.CM_DeckVessel.getROROStructure;
epilog

end;</source>
        <Parameter name="_pxySelf" type="CM_ROROSlotDefn"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
