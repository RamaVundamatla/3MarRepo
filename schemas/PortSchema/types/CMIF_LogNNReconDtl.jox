    <JadeMethod name="doUpdate" id="1d22e430-0e58-4f1c-bc16-4305301d8564">
        <updating/>
        <source>doUpdate(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.mode = Mode_RetainOnVoyageNN then
		if self.allNoNumberLogs.size &gt; 0 then	
			self.keepNoNumberLogsOnVoyage(_passport);
		endif;
	elseif self.mode = Mode_LoadResidue then
		if self.myDynaDict.size &gt; 0 then
			self.loadResidueToVoyage(_passport);
		endif;
	elseif self.mode = Mode_OffLoadNN then
		if self.allNoNumberLogs.size &gt; 0 then
			self.offLoadNoNumberLogs(_passport);
		endif;
	elseif self.mode = Mode_RejectResidue then
		if self.myDynaDict.size &gt; 0 then	
			self.rejectResidue(_passport);
		endif;
	elseif self.mode = Mode_ReturnResidue then
		if self.myDynaDict.size &gt; 0 then	
			self.returnResidueToStock(_passport);
		endif;
	elseif self.mode = Mode_SwapNN then
		if self.allNoNumberLogs.size &gt; 0 then
			self.swapNoNumbers(_passport);
		endif;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPlaceHoldFromString" id="28c9ceeb-781b-40a2-b757-ae93cc3635b1">
        <source>getPlaceHoldFromString(_str : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     02 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if _str.toUpper = 'HOLD' then
		return PlaceHold;
	elseif _str.toUpper = 'DECK' then
		return PlaceDeck;
	endif;	
end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keepNoNumberLogsOnVoyage" id="c501cf17-9764-4d4e-a910-ec3985b3bad9">
        <updating/>
        <source>keepNoNumberLogsOnVoyage(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	nnLog 		: CM_LogNoNumber;
	bolExtSet 	: CM_BOLExtLogOutSet;
	bolExt		: CM_BOLExtLogOut;	
begin
	if self.allNoNumberLogs.size = 0 then
		return;
	endif;
	create bolExtSet transient;

	foreach nnLog in self.allNoNumberLogs do
		exclusiveLock(nnLog);
		if (not bolExtSet.includes(nnLog.myBOLExtLogOutForNN)) then
			bolExtSet.add(nnLog.myBOLExtLogOutForNN);
		endif;		
		if nnLog.isOnShip then
			nnLog.setIsRetainedOnVoyage(true, _passport);
		endif;
	endforeach;
	
	foreach bolExt in bolExtSet do
		bolExt.setPartiallyLoaded();
		bolExt.setMyLogVoyageIfInError();
	endforeach;
	
epilog
	if bolExtSet &lt;&gt; null then
		delete bolExtSet;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadResidueToVoyage" id="194e5758-a0b8-4c1c-aea6-3b65462343ad">
        <source>loadResidueToVoyage(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj		: Object;
	log 	: CM_Log;
	cnt 	: Integer;
	iFaceBOLOut : CMIF_BOLOut;
	terminal : CM_Terminal;
	pxyLogVoyCntrl : CM_LogVoyageController;
	realLogVoyCntrl : CM_VoyageController;	
begin
	if self.myDynaDict.size = 0 or
	  self.numberOfPieces &lt;= 0 or
	  self.myDynaDict.size &lt; self.numberOfPieces then
		app.raiseCMException2(LogResidueImbalance, self.myDynaDict.size.String, self.numberOfPieces.String, ETRow_PieceCount, null);				
		return;
	endif;
	
	create iFaceBOLOut transient;
	terminal := self.myLogVoyageStructure.myVoyage.myTerminal;
	cnt := self.numberOfPieces;
	
	foreach obj in self.myDynaDict do
		log := obj.CM_Log;
		exclusiveLock(log);
		if log.isOnShip then
			continue;
		endif;
		if cnt &gt; 0 then
			iFaceBOLOut.allTrackedItems.add(log);
		else
			break;	
		endif;	
		cnt := (cnt - 1);
	endforeach;
	
	iFaceBOLOut.bolType				:= BOLType_Log;
	iFaceBOLOut.bolNumber			:= terminal.bolOutNextSeqNumber;
	if self.myLogLot.myConsignee &lt;&gt; null then
		iFaceBOLOut.consignorCode	:= self.myLogLot.myConsignee.code;
	endif;
	if self.myLogLot.myDischargePort &lt;&gt; null then
		iFaceBOLOut.dischargePort	:= self.myLogLot.myDischargePort.code;
	endif;
	iFaceBOLOut.logGradeCode		:= log.gradeCode;
	iFaceBOLOut.logSpeciesCode		:= log.speciesCode;
	iFaceBOLOut.lengthRandom		:= log.lengthCode;
	iFaceBOLOut.logTreatmentCode	:= log.treatmentCode;
	iFaceBOLOut.logTypeCode			:= log.typeCode;
	iFaceBOLOut.hatch				:= self.hatch;
	iFaceBOLOut.place				:= self.place;
	iFaceBOLOut.myConsignee			:= self.myLogLot.myConsignee;									
	iFaceBOLOut.myLogLot 			:= self.myLogLot;
	iFaceBOLOut.myTerminal			:= terminal;
	iFaceBOLOut.myOperator			:= log.myOperator;
	iFaceBOLOut.myStevedore			:= self.myStevedore;
	iFaceBOLOut.myVoyage	 		:= self.myLogVoyageStructure.myVoyage;				
	iFaceBOLOut.numItems			:= iFaceBOLOut.allTrackedItems.size;
	iFaceBOLOut.operatorCode		:= log.myOperator.code;
	iFaceBOLOut.unitOfMeasure		:= BOL_UOM_PIECE_COUNT;
	iFaceBOLOut.transportMode 		:= TI_TRANSMODE_SHIP;				
	iFaceBOLOut.myPlannedLocation 	:= self.myLogVoyageStructure.getLogVoyController(self.myLogLot.lotNo, self.hatch, self.place);
	if iFaceBOLOut.myPlannedLocation = null then
		if pxyLogVoyCntrl = null then
			create pxyLogVoyCntrl transient;
		endif;
		pxyLogVoyCntrl.setProxy(self.myLogLot, self.myLogVoyageStructure, self.hatch, self.place);
		app.myUtilityCA.utlCreateVoyageController(pxyLogVoyCntrl, realLogVoyCntrl, _passport);
		if (not app.myPassport.noErrors()) then
			return;
		endif;				
		iFaceBOLOut.myPlannedLocation := realLogVoyCntrl;
	endif;	
	iFaceBOLOut.userCode			:= _passport.userCode;

	if iFaceBOLOut.myPlannedLocation = null then
		app.raiseCMException3(LogVoyageControllerNotFound, self.myLogLot.lotNo,
							  self.hatch.String, app.vesselPlaceEnumToStr(self.place), null, null);			
	endif;
	if iFaceBOLOut.allTrackedItems.size &lt;&gt; iFaceBOLOut.numItems then
		app.raiseCMException2(LogResidueImbalance, iFaceBOLOut.allTrackedItems.size.String, iFaceBOLOut.numItems.String, ETRow_PieceCount, null);						
	endif;
	if app.myPassport.noErrors then
		app.myUtilityCA.utlCreateBOLOut(iFaceBOLOut, _passport);
	endif;

epilog
	delete iFaceBOLOut;	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="logGrade" id="e349d6bc-3089-41a2-af72-fb35f8df37af">
