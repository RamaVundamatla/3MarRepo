    <JadeMethod name="availableTransactions" id="fa73b3f7-9616-4f07-8354-43d153ec5342">
        <source>availableTransactions(_classColl: ClassColl input);
/*

Purpose: Suzano Warehouse Releases These are the transactions

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2014	cnwgb1	Initial creation CCMS 2346 PAR 34561

*/

vars

