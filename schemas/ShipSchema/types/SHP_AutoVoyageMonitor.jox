    <JadeMethod name="addRowToTable" id="901ddae5-aa5a-4e93-aa9f-97217bb76f18">
        <source>addRowToTable(_stage : CM_VoyageStage);
/*
Purpose - 	
Who - NAVAB1
Date - 18JUL2024
ADO - CR 64612 TASK 64659
*/

vars

	theDataLine : String;
	docTypeColumn: Integer;
	row, backclr			: Integer;
begin
	theDataLine := _stage.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	row := self.tblData.addItem(theDataLine); 
	self.tblData.accessRow(row).itemObject := _stage;
	self.doNotableAdd(_stage);
	
	if self.chkShowColours.value then
		backclr :=  self.getColourForStatus(_stage.status);
		self.tblData.accessRow(row).backColor := backclr;
		self.tblData.accessedRow.foreColor := backclr.getInverseColour();
	endif;
epilog

end;</source>
        <Parameter name="_stage" type="CM_VoyageStage"/>
    </JadeMethod>
