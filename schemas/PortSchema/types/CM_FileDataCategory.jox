    <JadeMethod name="shouldAuditProperty" id="076ceaad-727b-4637-8cd3-cd2fd4eb4b0f">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2022	navhl20	TFS CR 55299 TASK 55516: Jade - Write TRX for new file category

*/

vars

begin
	if _property = null then
		return false;
	endif;
	
	if _property.name = CM_FileDataCategory::categoryContext.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
