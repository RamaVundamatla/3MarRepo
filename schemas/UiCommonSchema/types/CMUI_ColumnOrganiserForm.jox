    <JadeMethod name="setupForm" id="f4af2410-ad25-4177-b030-3d4493e0504f">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.refreshToolbar();	//05 Jan 2012	NDL	Par 28889
	
	inheritMethod();

	self.allowSort := myDataTable &lt;&gt; null and (not self.myDataTable.disallowColumnSorter);
	self.allowShiftUpDown := self.myDataTable &lt;&gt; null and (not self.myDataTable.disallowColumnShiftUpDown);
	
	if app.getMyUser.canDo(self.myTerminal, PmCmpColumnOrgSystemMaint) then
	//	self.cbxSystem.enabled := true;
		if not self.hideSaveAsSysDefault then	//09 May 2018	NDL	TFS 38460
			self.cbxSystem.enabled :=  not self.myEntTableDef.isTransient;	//21 Jan 2015	NDL	Par 35541
		endif;
	endif;
	
	if myDataTable &lt;&gt; null and self.myDataTable.maxSortColumns &gt; self.maxSortingColumns then
		self.maxSortingColumns := self.myDataTable.maxSortColumns;
	endif;
	
	//self.mulColumnSorter.formDisplayEntryMethodName := CMUI_ColumnOrganiserForm::displaySelectedSortName.name;
	
	self.modalResult := IDCANCEL;
	self.btnAscDesc.parent := self.mulColumnSorter;	
	self.initMultiSelectShts();	
	self.showAllEntTblRows();	
	if myDataTable &lt;&gt; null then
		self.caption := self.Caption &amp; ' ' &amp; self.myDataTable.form.caption;
	elseif self.myTextTable &lt;&gt; null then
		self.caption := self.Caption &amp; ' ' &amp; self.myTextTable.form.caption;
	endif;
	
	//20 Dec 2011	NDL	Par 28889
	if self.myDataTable &lt;&gt; null and self.myDataTable.allowsColumnFilters then
		self.shtColumnFilter.visible := true;
		self.tblFilterValues.fixedRows := 1;
		self.tblFilterValues.rows := 1;
		create self.allFilterColumns transient;
		self.myDataTable.form.getTableColumFilters( self.myDataTable, self.allFilterColumns );
	endif;
	
	self.printOrientation:=Print_Portrait;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnResetJMT.enabled:= false;
		self.btnResetSys.enabled:= false;
		self.cbxSystem.enabled:= false;
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showAllEntTblRows" id="37ac4962-3c01-4cc8-955e-2345f6cbb804">
        <updating/>
        <source>showAllEntTblRows() updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------
// 20/02/2013	cnwdap1		PAR #31155 CMS SFW 1321 Imperial Measurements - Don't show the original
//								ent table row in the column organiser
// 15 Sep 2023 	navnk30 	ChangeRequest 60463: MTN - Adding Filter to column organizer screen
// 01 Sep 2025	naviv1 		MTN-35722 : Release Number field disappeared from Column Organiser
vars

	entRow		: EntTableRow;
	array		: EntTableRowArray;
	iter : Iterator;
	invalid : Boolean;
begin
	// This method gets all the available columns for the table
	if self.myDataTable = null and self.myTextTable = null then
		return;
	endif;
	
	// add the current visible columns
	//tmpTable.allTblDataEntRows.copy(self.allTblDataEntRows);

	// add any hiden rows
	if self.myDataTable &lt;&gt; null then
		if self.myDataTable.myEntTableView = null or self.myDataTable.myEntTableView.name = SystemDefault then //01-Sep-2025 naviv1 #MTN-35722
			array	:=	self.myDataTable.myEntTableDef.allEntTableRows;
		else
		//epr if table has a view only show those available to that view
		// view is set if CM_DataTable::setTblDataEntRowsFromView is called
			array	:=	self.myDataTable.myEntTableView.allEntTableRows;
		endif;
	elseif self.myTextTable &lt;&gt; null then
		array	:=	self.myTextTable.myEntTableDef.allEntTableRows;
	endif;
	
	foreach entRow in array do
		//in situations where there are hidden rows don't want to allow them to be organised
		if not entRow.visible then
			if (not self.allTblHiddenEntRows.includes(entRow)) then
				self.allTblHiddenEntRows.add(entRow);
			endif;
			
			continue;
		endif;
		//epr TFS 830 wanted to add hidden rows that are not in array and exclude them
		if self.allTblHiddenEntRows.includes(entRow) then
			continue;
		endif;
		//19/06/2009 cnwdz2  par20027 currently checking if sub-terminal module is eabled for a terminal has to
		// be done in the following hard way by comparing the entrow's name
		if entRow.name = ETRow_MySubTerminal and not app.isSubTerminalsOn(self.myTerminal) then
			continue;
		endif;
		
		//epr par 33900 4/4/14
		if entRow.measurementType &lt;&gt; null then
			self.addMeasurementRow(entRow);
			continue;
		endif;
		
		//if (not self.allTblDataEntRows.includes(entRow)) then									// PAR #31155
		if (not self.allTblDataEntRows.includes(entRow)) and entRow.measurementType = null then	// PAR #31155
			self.allTblDataEntRows.add(entRow);
		endif;
	endforeach;
	
	//01 Nov 2013	NDL	Par 32894 - ent rows built from user stored xml can result
	// in entrow proxys that are selected but not in the def, but still valid (Cargo enquiry form does this.)
	if self.myDataTable &lt;&gt; null then
		iter := self.myDataTable.allTblDataEntRows.createIterator;
	else
		iter := self.myTextTable.allDisplayEntTableRows.createIterator;
	endif;
	
	on Exception do app.handleDeletedObject(exception,entRow,invalid);
	
	while iter.next( entRow ) do
		entRow.fetchLatest;
		if invalid then
			invalid:=false;
			continue;
		endif;
		if not entRow.visible then
			continue;
		endif;
		//epr TFS 830 wanted to add hidden rows that are not in array and exclude them
		if self.allTblHiddenEntRows.includes(entRow) then
			continue;
		endif;
		self.allTblDataEntRows.addExclusive( entRow );
	endwhile;
	//////////
	
	self.mulColumns.setAvailable(self.allTblDataEntRows, true);
	self.setFilterCollection(self.mulColumns);								//15.09.2023 navnk30 #60463
	if self.myDataTable &lt;&gt; null then
		self.mulColumns.setSelected(self.myDataTable.allTblDataEntRows);
	else
		self.mulColumns.setSelected(self.myTextTable.allDisplayEntTableRows);
	endif;
	
	self.setColumnSorter(true);
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showFilterSheet" id="7a232b2e-27d3-4dc4-aa8a-4230f5517b7f">
        <source>showFilterSheet();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation

*/

vars
	allSelectedCols : EntTableRowArray;
	col : EntTableRow;
	columnHeading : String;
	index : Integer;

begin

	self.btnResetJMT.visible := false;
	self.btnResetSys.visible := false;
	self.cbxSystem.visible := false;
	self.frmFilterValues.visible := false;

	create allSelectedCols transient;
	self.mulColumns.getSelected(allSelectedCols);
	
	self.cmbColumnFilter.clear();
	foreach col in allSelectedCols do
		columnHeading := displayMultiSelectAvailable(col);
		self.cmbColumnFilter.itemObject[ self.cmbColumnFilter.addItem( columnHeading ) ] := col;
	endforeach;
	
	self.refreshCmbFilterColour();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblFilterValues_mouseDown" id="0e94f9d1-ba75-4b29-a7ba-8cbaed7229bb">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFilterValues_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if table.column = 1 then
		if table.row &gt; table.fixedRows then
			if table.row &lt;= table.rows then
				self.selectFilterUpdated := true;
				self.enabledFilterButtons();
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3bdbdf88-c119-4599-84c2-2286b02764a9">
