    <JadeMethod name="setControlsForAddEdit" id="1de4942b-0b62-4a02-be91-a2bcf5440b30">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	formObj	: SOP_TableMaintForm;

begin
	formObj	:=	self.myForm;
	formObj.tblInput1.userInputEnabled := true;
			
	if formObj.mode = formObj.Mode_Add then
		formObj.tblInput1.clearValues;
		formObj.tblInput1.enableRowByName(ETRow_Code);
		formObj.tblInput1.enableRowByName(ETRow_Description);
		formObj.tblInput1.disableRowByName(ETRow_Ports);
		formObj.tblInput1.moveFirst();
		formObj.tblInput1.setFocus;
		formObj.tblInput1.gotFocus(formObj.tblInput1);	// sets case etc.		
	
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(formObj.myProxyObject.CM_VoyagePlanningCode);
		// cannot update code
		formObj.tblInput1.enableRowByName(ETRow_Code);
		formObj.tblInput1.enableRowByName(ETRow_Description);
		formObj.tblInput1.disableRowByName(ETRow_Ports);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="bb581bbd-d761-4c15-9de5-a419928f3812">
