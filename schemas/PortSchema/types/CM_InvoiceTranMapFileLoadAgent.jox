    <JadeMethod name="getTransactionDetails" id="3d0e8daf-ac48-40d2-948f-c61168f9c486">
        <updating/>
        <source>getTransactionDetails(_transaction : String; _default : Boolean output; _move : Boolean output; _tranTypeObj : CM_TransactionType output) updating, protected;
/* Changes

Date		Name	TFS#	Description
============================================================================
03/07/2019	jlgka1	45371	JMT - Unable to Import Cargo Map with Move Transaction Type.
							Move Transaction type is being export with either (Move) or Move.							
============================================================================*/
vars
	tranTypeObj : CM_TransactionType;
begin
	_move := false;
	if _transaction = "(Move)" or _transaction = "Move"  then
		_move := true;
	elseif _transaction = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		tranTypeObj := findTransactionType(_transaction);
		if tranTypeObj = null then
			self.validationError("Invalid transaction", _transaction);
		else
			_tranTypeObj := tranTypeObj;
		endif;
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_transaction" type="String"/>
        <Parameter name="_default" type="Boolean" usage="output"/>
        <Parameter name="_move" type="Boolean" usage="output"/>
        <Parameter name="_tranTypeObj" type="CM_TransactionType" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTransferType" id="30eb0074-b103-4f6e-9c38-2855581379bc">
        <updating/>
        <source>getTransferType(_id: String; _transferType: CM_VoyageJobTransferType output) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2018	jlgmp6	Initial creation	TFS38899

*/

vars
	transferType: CM_VoyageJobTransferType;
begin
	if _id &lt;&gt; null and _id &lt;&gt; app.getErrorString(AnyString) then
		transferType := self.findTransferType(_id);
		if transferType = null then
			self.validationError("Invalid transfer type", _id);
		endif;
	endif;

	_transferType := transferType;
end;
</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_transferType" type="CM_VoyageJobTransferType" usage="output"/>
    </JadeMethod>
