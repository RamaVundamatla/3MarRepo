    <JadeMethod name="updateUsedBy" id="8e8ae730-1ae4-4316-a9cc-531cfa582beb">
        <source>updateUsedBy(_newResult	: UM_UnitTestResult);  

/*

Purpose:		Update allUnitTestResultsUsedBy

Date			Who		Reason
09/09/2013		cnwmh5	Initial creation

*/

vars

	result 					: UM_UnitTestResult;
	
begin

epilog

	// get the correct result
	result := self.allUnitTestResultsUsedBy[_newResult.myClassMethod.className, _newResult.myClassMethod.methodName];
	
	// found then remove
	beginTransaction;
	if result &lt;&gt; null then
		self.allUnitTestResultsUsedBy.remove(result);
	endif;
	
	// add the new object
	self.allUnitTestResultsUsedBy.add(_newResult);
	commitTransaction;

end;</source>
        <Parameter name="_newResult" type="UM_UnitTestResult"/>
    </JadeMethod>
</Class>
