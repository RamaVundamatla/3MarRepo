    <JadeMethod name="trxDeleteYATemplate" id="c0f05d79-1dd5-4edb-af27-a2d4d927abb0">
        <updating/>
        <source>trxDeleteYATemplate(_yATemplate: CM_YATemplate io; _passport : CM_Passport input) updating;
vars
	ya : CM_YardAllocation;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Ensure that we serialize all updates to YA Templates
	reserveLock(_yATemplate);

	app.myUtilityDA.myDeleteAuditAgent.audDeleteGeneric(_yATemplate);

	ya := _yATemplate.myYardAllocation;
	app.myUtilityDA.utlDeleteYardAllocation(ya, _passport);
	if _passport.noErrors() then
		_yATemplate.setTemplate(null);
		app.myUtilityDA.utlDeleteYATemplate(_yATemplate, _passport);
	endif;
	
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_yATemplate" type="CM_YATemplate" usage="io"/>
