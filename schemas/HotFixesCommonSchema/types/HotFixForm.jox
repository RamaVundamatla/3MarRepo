    <JadeMethod name="checkFileUNL" id="17bd852d-e6b7-4604-868b-f4cb50072b74">
        <source>checkFileUNL( _fileUNL : String input) : Boolean;
// cnwvu1 02/2007
// gets UNL file for _par
// gives an empty string, if there is some problems
// Prameters:
// _par - par's full directory


vars
	fUNL	: File;
	rt		: RootHotFixes;
	s		: String;
//	k		: Integer;

begin

	create fUNL transient;
	rt := app.myRootHotFix;

	if _fileUNL.length() = 0 then
		app.writeStatement( 'UNL file name is empty...');
		return false;
	endif;

	fUNL.fileName := _fileUNL;
	fUNL.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	fUNL.mode := File.Mode_Input;
	if not fUNL.isAvailable then
		app.writeStatement( ' UNL file is not available - ' &amp; fUNL.fileName);
		return false;
	endif;

	fUNL.open;

// check content
	s := fUNL.readLine();

	if s.length() = 0 then
		app.writeStatement( ' The first line is empty. UNL file ' &amp; fUNL.fileName);
		return false;
	endif;
	
//	s := s.toUpper();
	// check for CLASS
//	k := s.pos(RootHotFixes.TXT_CLASS,1);
//	if k &gt; 0 then
//		_isWholeClassExported := true;
//	endif;
	
	
//	fUNL.commit;
	fUNL.close;
	
	return true;
	
epilog
	delete fUNL;

end;
</source>
        <Parameter name="_fileUNL" type="String" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyExtraPossibleFiles" id="cfc69b4f-f91d-4caa-a862-3fc9542ba9c5">
        <source>copyExtraPossibleFiles( _par: String; _newHotFix: String; _nameNewHotFix: String ) : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 June 2008		cnwvu1	
// Purpose:		Copying extra files as SQL etc. included in JadeMaster 
//					and Client directories
// ---------------------------------------------------------------------------
vars
	rt : RootHotFixes;
	
begin

	rt := app.myRootHotFix;
// for JadeMast
	if not rt.copyDirectoryExtraFiles( 	_par &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\',
										_newHotFix &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\',
										true) then
		return false;
	endif;

// for Client
	if not rt.copyDirectoryExtraFiles(	_par &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\',
										_newHotFix &amp;'\'&amp; _nameNewHotFix &amp;'\',
										true) then
		return false;
	endif;
	
	
	
	return true;

end;</source>
        <Parameter name="_par" type="String"/>
        <Parameter name="_newHotFix" type="String"/>
        <Parameter name="_nameNewHotFix" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyJMTInstall" id="e056fe50-14b5-4220-aca7-c22296bc5379">
        <source>copyJMTInstall(_newHotFix: String; _nameNewHotFix: String) : Boolean;
// Vytenis	11/2006
vars
	rt		: RootHotFixes;
	fInst	: File;			// client JMTInstal file
	pErrTxt	: String;
begin

	create fInst transient;
	rt := app.myRootHotFix;
	fInst.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	fInst.fileName := _newHotFix &amp;'\'&amp; _nameNewHotFix &amp;'\'&amp; rt.FILE_JMT_INSTALL_NAME;
	fInst.mode := File.Mode_Append;
	fInst.open;

	fInst.writeLine( rt.setHotfixVersionForJMTInstall( _nameNewHotFix) );	// writes JMTPATCH::7.5.3::22::NOERRORS
	fInst.writeLine( rt.JMT_INSTALL_STR_LAST_SCMCHK );	//SCMCHK::NOERRORS
	fInst.writeLine( rt.JMT_INSTALL_STR_LAST );	
	fInst.commit;
	fInst.close;
	
	if rt.ZJade_Local_Mode_For_File_Copy then
		if not fInst.cnCopyFile( _newHotFix &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\'&amp; rt.FILE_JMT_INSTALL_NAME, true, pErrTxt) then
			return false;
		endif;
	else
		if not rt.copyFile( fInst.fileName, _newHotFix &amp;'\'&amp; rt.DIR_JADE_NAME, true ) then
			return false;
		endif;
	endif;

	return true;

epilog
	delete fInst;

end;
</source>
        <Parameter name="_newHotFix" type="String"/>
        <Parameter name="_nameNewHotFix" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyPar" id="ce932da1-31d2-4352-9102-5c5838119514">
        <source>copyPar( _par: String; _newHotFix: String ) : Boolean;
// Vytenis 11/2006
vars
	pParName: String;
	rt: RootHotFixes;
	dirF	: FileFolder;
begin

	create dirF		transient;
	
	rt := app.myRootHotFix;
	
	pParName := self.getParName( _par );

// copy PAR main directory, just in case if there are some files
	dirF.fileName := _newHotFix &amp;'\'&amp; pParName;
	dirF.make;
	if not rt.copyDirectory( _par &amp;'\', dirF.fileName, true) then
		return false;
	endif;

	if not self.isWebPar(_par) then
	
	// copy PAR JadeMast
		dirF.fileName := _newHotFix &amp;'\'&amp; pParName &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\';
		dirF.make;
		if not rt.copyDirectory( _par &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\', dirF.fileName, true) then
			return false;
		endif;
	
	// copy JadeMast Schemas
		dirF.fileName := _newHotFix &amp;'\'&amp; pParName &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\'&amp; rt.DIR_SCHEMAS_NAME;
		dirF.make;
		if not rt.copyDirectory( _par &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\'&amp; rt.DIR_SCHEMAS_NAME, dirF.fileName, true) then
			return false;
		endif;
	
	// for PAR Client
		dirF.fileName := _newHotFix &amp;'\'&amp; pParName &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\';
		dirF.make;
		if not rt.copyDirectory( _par &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\', dirF.fileName, true) then
			return false;
		endif;
	
	// for PAR Client Schemas
		dirF.fileName := _newHotFix &amp;'\'&amp; pParName &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\'&amp; rt.DIR_SCHEMAS_NAME &amp;'\';
		dirF.make;
		if not rt.copyDirectory( _par &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\'&amp; rt.DIR_SCHEMAS_NAME &amp;'\', dirF.fileName, true) then
			return false;
		endif;
	endif;
	
	app.writeLogMessage(pParName &amp; ' copied.'); //***********
	return true;
	
epilog
	delete dirF;

end;
</source>
        <Parameter name="_par" type="String"/>
        <Parameter name="_newHotFix" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copy_schemas" id="b76d71b0-7238-4325-b32a-959fe5d5ae35">
        <source>copy_schemas( _par: String; _newHotFix: String; _nameNewHotFix: String ) : Boolean;
// Vytenis	11/2006
vars
	rt : RootHotFixes;
	
begin

	rt := app.myRootHotFix;
// for JadeMast
	if not rt.copyDirectory( _par &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\'&amp; rt.DIR_SCHEMAS_NAME &amp;'\',
							 _newHotFix &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\'&amp; rt.DIR_SCHEMAS_NAME &amp;'\',
							 true) then
		return false;
	endif;

// for Client
	if not rt.copyDirectory( _par &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\'&amp; rt.DIR_SCHEMAS_NAME &amp;'\',
							 _newHotFix &amp;'\'&amp; _nameNewHotFix &amp;'\'&amp; rt.DIR_SCHEMAS_NAME,
							 true) then
		return false;
	endif;

	return true;
	
end;

</source>
        <Parameter name="_par" type="String"/>
        <Parameter name="_newHotFix" type="String"/>
        <Parameter name="_nameNewHotFix" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copy_web" id="6e861cba-d68f-4612-95bc-4f0c4438fb99">
        <source>copy_web(_newHotFix: String; _newHotFixName: String) : Boolean;
// Vytenis	11/2006
vars
	rt : RootHotFixes;
	targetWebFolder: FileFolder;
begin
	rt := app.myRootHotFix;
	if not app.folderExists(rt.getDirOfPatches &amp; RootHotFixes.DIR_WEB_NAME, true) then
		return true;
	endif;
	
	create targetWebFolder transient;
	targetWebFolder.fileName := _newHotFix &amp; '\' &amp; _newHotFixName &amp; '\' &amp; RootHotFixes.DIR_WEB_NAME;
	if not targetWebFolder.isAvailable then
		targetWebFolder.make;
		app.writeLogMessage(' created ' &amp; targetWebFolder.fileName);
	endif;		

	if not app.copyAFolder( rt.getDirOfPatches &amp; RootHotFixes.DIR_WEB_NAME, true, targetWebFolder.fileName, true) then
		return false;
	endif;

	return true;
epilog
	delete targetWebFolder;
end;

</source>
        <Parameter name="_newHotFix" type="String"/>
        <Parameter name="_newHotFixName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteDirectory" id="95016267-44d1-4471-94e7-ed2f4e58532e">
        <source>deleteDirectory( _fileFld	: FileFolder input; _dir : String ) : Boolean;

vars
	
begin
	
	_fileFld.fileName := _dir;
	if _fileFld.isAvailable then
		_fileFld.purge;
		return true;
	else
		app.writeStatement( 'Directory is not available - ' &amp; _dir);
		app.writeStatement( 'Please delete it by hand.');
		app.msgBox( 'Directory is not available - ' &amp; _dir  &amp; '. Please delete it by hand and check the new Hotfix.',
					'PAR directory has not been deleted', MsgBox_OK_Only );
		return false;
	endif;
	
end;
</source>
        <Parameter name="_fileFld" type="FileFolder" usage="input"/>
        <Parameter name="_dir" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteFilesInDirectory" id="6d33419b-a591-4208-ba88-19eb0ec6ee8a">
        <source>deleteFilesInDirectory( _sourceDir: String ) : Boolean;
// Vytenis	11/2006
vars
	fileFld	: FileFolder;
	fileList: FileNodeArray;
	fileOne	: FileNode;
	
begin

	create fileFld	transient;
	
	fileFld.fileName := _sourceDir;
	if not fileFld.isAvailable then
		app.writeStatement( 'Directory is not available - ' &amp; _sourceDir);
		app.writeStatement( 'Please delete PAR by hand.');
		app.msgBox( 'Directory is not available - ' &amp; _sourceDir  &amp; '. Please delete it by hand and check the new Hotfix.',
					'PAR directory is not available', MsgBox_OK_Only );
		return false;
	endif;
	
	fileList := fileFld.files;

	foreach fileOne in fileList do
		if fileOne.isKindOf(File) then
			if fileOne.isAvailable then
				fileOne.purge;
			else
				app.writeStatement( 'File is not available - ' &amp; fileOne.fileName);
				app.writeStatement( 'Please delete the PAR by hand.');
				app.msgBox( 'File is not available - ' &amp; fileOne.fileName  &amp; '. Please delete it by hand and check the new Hotfix.',
							'File in the PAR directory has not been deleted', MsgBox_OK_Only );
				return false;
			endif;
		endif;
	endforeach;

	return true;
	
epilog
	delete fileFld;
	
end;
</source>
        <Parameter name="_sourceDir" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deletePar" id="0807f713-151b-4289-9d96-18631a70167b">
        <source>deletePar( _par: String ) : Boolean;
// Vytenis 11/2006
vars
	rt: RootHotFixes;
	fileFld	: FileFolder;
	isWebPar: Boolean;

begin
	
	create fileFld	transient;
	rt := app.myRootHotFix;
	isWebPar := self.isWebPar(_par); // Save this before any files deleted.
	
// delete files in PAR
	if not self.deleteFilesInDirectory( _par ) then
		return false;
	endif;
	
	if not isWebPar then
	
	// delete files in PAR JadeMast
		if not self.deleteFilesInDirectory( _par &amp;'\'&amp; rt.DIR_JADE_NAME ) then
			return false;
		endif;
	
	// delete files in JadeMast Schemas
		if not self.deleteFilesInDirectory( _par &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\'&amp; rt.DIR_SCHEMAS_NAME ) then
			return false;
		endif;
	
	// delete files in PAR Client
		if not self.deleteFilesInDirectory( _par &amp;'\'&amp; self.getParPatchNo(_par) ) then
			return false;
		endif;
	
	// delete files in PAR Client Schemas
		if not self.deleteFilesInDirectory( _par &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\'&amp; rt.DIR_SCHEMAS_NAME ) then
			return false;
		endif;
	
	// _____________ deleting empty directories	________________
		if not deleteDirectory( fileFld, _par &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\'&amp; rt.DIR_SCHEMAS_NAME ) then
			return false;
		endif;
		if not deleteDirectory( fileFld, _par &amp;'\'&amp; rt.DIR_JADE_NAME ) then
			return false;
		endif;
		if not deleteDirectory( fileFld, _par &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\'&amp; rt.DIR_SCHEMAS_NAME ) then
			return false;
		endif;
		if not deleteDirectory( fileFld, _par &amp;'\'&amp; self.getParPatchNo(_par) ) then
			return false;
		endif;
	endif;
	
	if not deleteDirectory( fileFld, _par ) then
		return false;
	endif;

	app.writeLogMessage(self.getParName( _par ) &amp; ' deleted.');
	return true;
	
epilog
	delete fileFld;

end;
</source>
        <Parameter name="_par" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteWeb" id="f78f2675-375e-4de4-b9ab-88b20c48c8bc">
        <source>deleteWeb() : Boolean;
// Vytenis	11/2006
vars
	rt : RootHotFixes;
	webFolder: FileFolder;
begin
	rt := app.myRootHotFix;
	if not app.folderExists(rt.getDirOfPatches &amp; RootHotFixes.DIR_WEB_NAME, true) then
		return true;
	endif;
	
	if not app.deleteAFolder(rt.getDirOfPatches &amp; RootHotFixes.DIR_WEB_NAME, true) then
		return false;
	endif;
	
	create webFolder transient;
	return self.deleteDirectory(webFolder, rt.getDirOfPatches &amp; RootHotFixes.DIR_WEB_NAME);
	
epilog
	delete webFolder;
end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doStartHotFix" id="53eb7f02-ca7c-4e6d-a6fb-edf68117c276">
        <updating/>
        <source>doStartHotFix() updating;
// Vytenis	11/2006
vars
	rtH							: RootHotFixes;
	listOfPars					: FileNodeArray;	// list of all pars directories
	dirOfPars					: FileFolder;		// folder of Pars
	pPar						: FileNode;
	pNameNewHotFix,	pNewHotFix	: String;
//	 wholeClassExportedFinal	: Boolean;
	 isSingleUser				: Boolean;
	 isSingleUserFinal			: Boolean;
	 willBeSingleUserMode		: Boolean;
	logFileFullName 			: String;
	hotFixCreated				: Boolean;
	unexpectedPARDeletingError	: Boolean;
	errStr						: String;
	errFound					: Boolean;
	
	//cnwmc5
	masterArray					: StringArray512;
	todayArray					: StringArray512;
	
	outputFile					: File;
	
	line						: String;
	
begin

	hotFixCreated				:= false;
	unexpectedPARDeletingError	:= false;
	errFound					:= false;
	willBeSingleUserMode		:= false;
	
	create listOfPars transient;
	create dirOfPars transient;
	
	rtH := app.myRootHotFix;
	if not rtH.initRootHotFixes( self.txtDirSetup.text, self.txtReleaseNo.text ) then
		return;
	endif;
			
	app.writeLogMessage( '');
	app.writeLogMessage( ' __________________ Creating HOTFIX __________________');

	if not self.getDirsOfAllPars( dirOfPars, listOfPars ) then
		return;
	endif;

// name for new Hotfix
	pNameNewHotFix	:= self.getNameForNewHotFix();
	pNewHotFix		:= rtH.getDirHotFixes() &amp; pNameNewHotFix;

	logFileFullName := rtH.getDirHotFixes() &amp; 'Hotfix' &amp; rtH.getReleaseVersionNo() &amp; '.log';
	rtH.logFileOutput( logFileFullName, '-');
	rtH.logFileOutput( logFileFullName, '========== ' &amp; pNameNewHotFix &amp; ' ==========');
	rtH.logFileOutput( logFileFullName, '- User ' &amp; app.getUserCode() );

	
// -------------------- check UNL files - for whole class extracted --------------------------
	app.writeLogMessage( '');
	app.writeLogMessage( ' Checking UNL files:');
//	wholeClassExportedFinal := false;
	foreach pPar in listOfPars do
		if not self.executePar_checkUNL( pPar.fileName, errStr ) then
			rtH.logFileOutput( logFileFullName, '-' &amp; errStr );
			errFound := true;
		endif;
//		if isSingleUser then
//			wholeClassExportedFinal := true;

//			rtH.logFileOutput( logFileFullName, '-' &amp; pPar.fileName &amp;' - a whole class is exported. Hotfix will be run in singleUser mode.' );
//		endif;
	endforeach;
	if errFound then
		app.writeLogMessage( ' Creating failed...');
		return;
	else
		app.writeLogMessage( ' ok.');	// something to say for conclusion
	endif;
// -------------------- check for SingleUser mode --------------------------
	app.writeLogMessage( '');
	app.writeLogMessage( ' Checking for ' &amp; rtH.TXT_SINGLEUSER &amp; ':');
	isSingleUserFinal := false;
	foreach pPar in listOfPars do
		if not self.executePar_checkSingleuser( pPar.fileName, isSingleUser ) then
			rtH.logFileOutput( logFileFullName, '- incorrect install file - ' &amp; getFileParJMTInstall( pPar.fileName ) );
			errFound := true;
		endif;
		if isSingleUser then
			isSingleUserFinal := true;
			app.writeLogMessage( ' ' &amp; pPar.fileName &amp;' - singleuser mode is found. Hotfix will be run in singleUser mode.');
			rtH.logFileOutput( logFileFullName, '-' &amp; pPar.fileName &amp;' - singleuser mode is found. Hotfix will be run in singleUser mode.' );
		endif;
	endforeach;
	if errFound then
		app.writeLogMessage( '');
		app.writeLogMessage( ' Creating failed...');
		return;
	else 
		app.writeLogMessage( ' ok.');	// something to say for conclusion
	endif;
	
	if /*wholeClassExportedFinal or*/ isSingleUserFinal then
		willBeSingleUserMode := true;
		rtH.logFileOutput( logFileFullName, '- singleUser mode.' );
		app.writeLogMessage( '');
		app.writeLogMessage( ' creating ' &amp; pNameNewHotFix &amp;' - SingleUser Mode.');
	else
		willBeSingleUserMode := false;
		rtH.logFileOutput( logFileFullName, '- multiUser mode.' );
		app.writeLogMessage( '');
		app.writeLogMessage( ' creating ' &amp; pNameNewHotFix &amp;' - MultiUser Mode.');
	endif;
	
	if pNameNewHotFix = '' then
		rtH.logFileOutput( logFileFullName, 'Error. New hotfix name is empty. Contact developer.' );
		app.writeLogMessage( '');   
		app.writeLogMessage( ' Error. New hotfix name is empty. Contact developer.');
		return;
	endif;
// ------------------------- creating Hotfix directories -------------------------
	if not rtH.createDirsForHotFix( 2, pNameNewHotFix,'', '', false, false ) then
		rtH.logFileOutput( logFileFullName, 'Cannot create directories for new hotfix ' &amp; pNameNewHotFix);
		app.writeLogMessage( ''); 
		app.writeLogMessage(' Cannot create directories for new hotfix ' &amp; pNameNewHotFix);
		return;
	endif;
// ------------------------- loading schemas -------------------------
	app.writeLogMessage( '');
	app.writeLogMessage(' Loading schemas:');
	rtH.logFileOutput( logFileFullName, '- Loading schemas into Hotfix:');
	foreach pPar in listOfPars do
		if self.executePar( pPar.fileName, pNewHotFix, pNameNewHotFix, willBeSingleUserMode ) then
			rtH.logFileOutput( logFileFullName, self.getParName( pPar.fileName ) &amp; ' ok.');
		else
			rtH.logFileOutput( logFileFullName, pPar.fileName &amp; ' creating failed...');
			app.writeLogMessage( '');
			app.writeLogMessage( ' Creating Hotfix failed...');
			return;
		endif;
	endforeach;

	if self.copy_web(pNewHotFix, pNameNewHotFix) then
		rtH.logFileOutput( logFileFullName, 'Web folder copied.');
		app.writeLogMessage( ' Web folder copied.');	
	else
		rtH.logFileOutput( logFileFullName, 'Copying Web folder failed...');
		app.writeLogMessage( '');
		app.writeLogMessage( ' Copying Web folder failed...');
		return;
	endif;
	
	self.copyJMTInstall( pNewHotFix, pNameNewHotFix );
// ------------------------- copying PARs -------------------------
// it is better to copy firstly, because sometimes we cannot delete active directories
	app.writeLogMessage( '');
	rtH.logFileOutput( logFileFullName, '- Copying PARs:');
	app.writeLogMessage( ' Copying PARs:');
	
	//cnwmc5
	create masterArray transient;
	create todayArray transient;
	
	// copying pars
	foreach pPar in listOfPars do
		// 03/09/2012 cnwmh5 - create Unit Test Hotfix Unl(s)
		if not self.executePar_createUnitTestUNL(pPar.fileName, pNewHotFix, errStr, masterArray, todayArray) then		// 03/09/2012 cnwmh5		
			rtH.logFileOutput( logFileFullName, '-' &amp; errStr );
		endif;
		if self.copyPar( pPar.fileName, pNewHotFix ) then
			rtH.logFileOutput( logFileFullName, self.getParName(pPar.fileName) &amp; ' copied.');
		else
			rtH.logFileOutput( logFileFullName, 'copying ' &amp;pPar.fileName &amp; ' failed...');
			app.writeLogMessage( '');
			app.writeLogMessage(' Copying failed...');
			app.writeLogMessage( 'Delete please ' &amp; pNameNewHotFix);
			return;
		endif;
	endforeach;
	
	//cnwmc5 - start
	create outputFile transient;
	outputFile.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	outputFile.mode := File.Mode_Append;
	outputFile.allowCreate := true;
	
	//Saave data to output file, depending if hotfixes were created today 
	if not todayArray.isEmpty() then
		outputFile.fileName := pNewHotFix &amp; '\'&amp; rtH.DIR_JADE_NAME &amp;'\'&amp; rtH.DIR_SCHEMAS_NAME&amp; "\PortSchema_UnitTestHotfixToday.unl";
		
		foreach line in todayArray do
			outputFile.writeLine(line);
		endforeach;
	else
		outputFile.fileName := pNewHotFix &amp; '\'&amp; rtH.DIR_JADE_NAME &amp;'\'&amp; rtH.DIR_SCHEMAS_NAME&amp; "\PortSchema_UnitTestHotfix.unl";		
		
		foreach line in masterArray do
			outputFile.writeLine(line);
		endforeach;
	endif;
	//cnwmc5 - end
	
	hotFixCreated 				:= true;	// HotFix created successfuly
	unexpectedPARDeletingError	:= true;	// we will try do delete all PARs directories automatically

// ----------------- deleting Pars in PAR directory - make empty directory for new PARs ----------------
	app.writeLogMessage( '');
	app.writeLogMessage( ' Deleting PARs:');
	rtH.logFileOutput( logFileFullName, '- Deleting PARs:');
	foreach pPar in listOfPars do
		if self.deletePar( pPar.fileName ) then
			rtH.logFileOutput( logFileFullName, self.getParName(pPar.fileName) &amp; ' deleted.');
			app.writeLogMessage( ' ' &amp; self.getParName(pPar.fileName) &amp; ' deleted.');	
		else
			app.writeLogMessage( '');
			app.writeLogMessage( ' Deleting ' &amp; pPar.fileName &amp; ' failed...');
			rtH.logFileOutput( logFileFullName, 'Deleting ' &amp; pPar.fileName &amp; ' failed...');
		endif;
	endforeach;

	if self.deleteWeb() then
		rtH.logFileOutput( logFileFullName, 'Web folder deleted.');
		app.writeLogMessage( ' Web folder deleted.');	
	else
		rtH.logFileOutput( logFileFullName, 'Deleting Web folder failed...');
		app.writeLogMessage( '');
		app.writeLogMessage( ' Deleting Web folder failed...');
		return;
	endif;
	
	
	unexpectedPARDeletingError	:= false;	// deletion reached this point successfuly - no unexpected deleting errors

	
epilog
	delete listOfPars;
	delete dirOfPars;
	delete masterArray;
	delete todayArray;

	if not hotFixCreated then
		//app.app.writeLogMessage(Statement() - don't use. This app should display info for developers all the time regardless debug or developmentSystem
		app.writeLogMessage( ' Creating Hotfix failed...');
		rtH.logFileOutput( logFileFullName, 'Hotfix failed...');
		app.msgBox( 'Hotfix failed...',	'Hotfix failed...', MsgBox_OK_Only );

	else
	
		// isSingleUser mode - some attention
		if willBeSingleUserMode then
			//app.app.writeLogMessage(Statement() - don't use. This app should display info for developers all the time regardless debug or developmentSystem
			app.writeLogMessage( '');
			app.writeLogMessage( ' The following text is added into JMT install file:');
			app.writeLogMessage( ' ' &amp; RootHotFixes.TXT_SINGLEUSER_NOTE1);
			
			rtH.logFileOutput( logFileFullName, '- The following text is added into JMT install file:');
			rtH.logFileOutput( logFileFullName, '- ' &amp; RootHotFixes.TXT_SINGLEUSER_NOTE1);
			//rtH.logFileOutput( logFileFullName, '- ' &amp; RootHotFixes.TXT_SINGLEUSER_NOTE2);
		endif;

		// check for unexpectedPARDeletingError
		if unexpectedPARDeletingError then
			app.writeLogMessage( ' cannot delete a PAR directory... Please check the new Hotfix and delete the PAR directory manually.');
			rtH.logFileOutput( logFileFullName, '- cannot delete a PAR directory... Please check the new Hotfix and delete the PAR directory manually.');
			app.msgBox( 'Please check the new Hotfix and delete the PAR directory manually.',	'cannot delete a PAR directory...', MsgBox_OK_Only );
		endif;
		
		app.writeLogMessage( '');
		app.writeLogMessage( ' ' &amp; pNameNewHotFix &amp; ' is created.');
		rtH.logFileOutput( logFileFullName, pNameNewHotFix &amp; ' has been created.');
	
	endif;

	self.unloadForm();
	delete self;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="executePar" id="201c428e-a3b2-4094-aec7-a72c28e7a264">
        <source>executePar( _par: String; _newHotFix: String; _nameNewHotFix: String; _isSingleUser: Boolean ) : Boolean;
//-------------------------------------------------------------------------------------------------------
// Created:		Vytenis	11/2006
// Putpose:		To copy all files from one directory to another (all schemas, UNLs)
// Parameters:	_par - par directory, _newHotFix - new Hotfix directory
//-------------------------------------------------------------------------------------------------------
vars

begin

	// create Readme and JMTInstall
	if not self.executePar_filesReadmeInstall( _par, _newHotFix, _nameNewHotFix, false, _isSingleUser ) then
		return false;
	endif;
	if not self.executePar_filesReadmeInstall(  _par, _newHotFix, _nameNewHotFix, true, _isSingleUser ) then
		return false;
	endif;

	if not self.isWebPar(_par) then
		// copy all Schemas files
		if not self.copy_schemas( _par, _newHotFix, _nameNewHotFix ) then
			return false;
		endif;
		
		// copying extra files as SQL etc. included in JadeMaster and Client directories
		if not self.copyExtraPossibleFiles(  _par, _newHotFix, _nameNewHotFix ) then
			return false;
		endif;
	endif;
	
	app.writeLogMessage(_par &amp; ' - ok.');
	return true;

end;
</source>
        <Parameter name="_par" type="String"/>
        <Parameter name="_newHotFix" type="String"/>
        <Parameter name="_nameNewHotFix" type="String"/>
        <Parameter name="_isSingleUser" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executePar_checkSingleuser" id="26047e24-4bea-485b-a592-30989077cfa2">
        <source>executePar_checkSingleuser( _par : String; _isSingleUser : Boolean output ) : Boolean;
// Vytenis	01/2007
// checks in an JMTInstall.txt for singleUser option
// _par - par full directory

vars
	rt		: RootHotFixes;
	fInst	: File;
	s		: String;
	k		: Integer;
begin

	create fInst transient;
	fInst.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	_isSingleUser := false;

	rt := app.myRootHotFix;
	if rt = null then
		app.writeLogMessage( 'RootHotFixes empty...');
		return false;
	endif;
	
	if self.isWebPar(_par) then
		return true;
	endif;

	// opening JMTInstall.txt
	fInst.fileName := getFileParJMTInstall( _par );
	fInst.mode := File.Mode_Input;
	if not fInst.isAvailable then
		app.writeLogMessage(' Not found JMTInstall.txt - ' &amp;fInst.fileName);
		return false;
	endif;
	fInst.open;
			
	// searching singleUser
	s := fInst.readLine();
	s := s.toUpper();
	// check for MULTIUSER
	k := s.pos(RootHotFixes.TXT_MULTIUSER,1);
	//	if k &gt; 0 - there is nothing to do - _isSingleUser := false by default
	if k = 0 then
		// check for SINGLEUSER
		k := s.pos(RootHotFixes.TXT_SINGLEUSER,1);
		if k &gt; 0 then
			_isSingleUser := true;
		else
			app.writeLogMessage('');
			app.writeLogMessage(' Install file is incorrect. app.writeLogMessage(please either MULTIUSER or SINGLEUSER in the first row of the file ' &amp; fInst.fileName);
			return false;
		endif;
	endif;

	return true;

epilog
	delete fInst;

end;
</source>
        <Parameter name="_par" type="String"/>
        <Parameter name="_isSingleUser" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executePar_checkUNL" id="c7f1f943-c05a-4314-affc-89e70c6bdb83">
        <source>executePar_checkUNL( _par : String input; _errStr : String output ) : Boolean;
// cnwvu1	02/2007
// checks an UNL file and looks for Single User Mode (exported whole class)
// Parameters:
// _par - par's full directory
// _isClassExported = true - there is a whole class exported in UNL - Hotfix will be run in Single User Mode

vars
	rt		: RootHotFixes;
	fJd		: FileFolder;
	fileOne	: FileNode;
	isError : Boolean;
	
begin

	create fJd transient;

	rt := app.myRootHotFix;
	if rt = null then
		_errStr := 'RootHotFixes empty...';
		app.writeLogMessage(_errStr);
		return false;
	endif;

	if self.isWebPar(_par) then
		return true;
	endif;
	
	fJd.mask	:= '*.' &amp; rt.FILE_TYPE_UNL;
	fJd.fileName:= _par &amp;'\'&amp; RootHotFixes.DIR_JADE_NAME &amp;'\'&amp; RootHotFixes.DIR_SCHEMAS_NAME;

	if not fJd.isAvailable then
		_errStr := 'Directory not found... '&amp; fJd.fileName;
		app.writeLogMessage(_errStr);
		return false;
	endif;	

	if fJd.files.size = 0 then
		// if there are no UNL files, we have to check RWV report file - it doesn't require UNL
		fJd.mask	:= '*.' &amp; rt.FILE_TYPE_RWV;
		if fJd.files.size = 0 then	// there are no rwv files as well, so checking for rwr
			fJd.mask	:= '*.' &amp; rt.FILE_TYPE_RWR;
			if fJd.files.size = 0 then	// there are no rwr files as well, so should be UNL here by default
				_errStr := 'UNL file not found... ' &amp; _par;
				app.writeLogMessage(_errStr);
				return false;
			endif;
		endif;
	endif;

	//looping through all UNL files
	isError := false;
	fJd.mask	:= '*.' &amp; rt.FILE_TYPE_UNL;	// back to UNL after possible RWV files
	foreach fileOne in fJd.files do
		if not checkFileUNL( fJd.fileName &amp;'\'&amp; fileOne.name ) then
			_errStr := 'Bad UNL file ' &amp; fileOne.name &amp; '... ';
			app.writeLogMessage(_errStr);
			isError := true;
		endif;
	endforeach;

	if isError then
		return false;
	else
		return true;
	endif;

epilog
	delete fJd;

end;</source>
        <Parameter name="_par" type="String" usage="input"/>
        <Parameter name="_errStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executePar_createUnitTestUNL" id="925872eb-c28e-489b-9c72-803ddf194c82">
        <source>executePar_createUnitTestUNL(_parFileName, _hotFixDirectory : String input; _errStr : String io; _masterArray, _todayArray : StringArray512 io) : Boolean;

/*

Purpose:		Create the Unit Test Hotfix UNL
				Only interested in the PortSchema unl

Date			Who		Reason
03/09/2012 		cnwmh5	Initial creation

*/

vars

	rt				: RootHotFixes;
	fJd				: FileFolder;
	fileOne			: FileNode;
	inputFile		: File;
	
	parNumber		: Integer;
	posParFile		: Integer;
	posSlash		: Integer;
	isError 		: Boolean;
	line			: String;
	
	today 			: Date;
begin

	create fJd transient;

	rt := app.myRootHotFix;
	if rt = null then
		_errStr := 'RootHotFixes empty...';
		app.writeLogMessage(_errStr);
		return false;
	endif;

	fJd.mask	:= '*.' &amp; rt.FILE_TYPE_UNL;
	fJd.fileName:= _parFileName &amp;'\'&amp; RootHotFixes.DIR_JADE_NAME &amp;'\'&amp; RootHotFixes.DIR_SCHEMAS_NAME;

	if not fJd.isAvailable then
		_errStr := 'Directory not found... '&amp; fJd.fileName;
		app.writeLogMessage(_errStr);
		return false;
	endif;
	
	//looping through all UNL files
	isError := false;
	fJd.mask	:= 'PortSchema*.' &amp; rt.FILE_TYPE_UNL;	// back to UNL after possible RWV files
	foreach fileOne in fJd.files do
		
		// get the par number we are details with
		posParFile := _parFileName.toUpper().pos("_PAR", 1);
		if posParFile &gt; 0 then
			parNumber := _parFileName[posParFile+4:end].Integer;
		endif;
		
		// if no par number found then ignore
		if parNumber = null then
			continue;
		endif;
	
		delete inputFile;
		create inputFile transient;
		inputFile.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
		inputFile.fileName := fJd.fileName &amp;'\'&amp; fileOne.name;
		inputFile.mode := File.Mode_Input;
		if not inputFile.isAvailable then
			app.writeStatement( ' UNL file is not available - ' &amp; inputFile.fileName);
			return false;
		endif;
		inputFile.open;
		
		//Add data to arrays
		while not inputFile.endOfFile do
			line := inputFile.readLine;
			if line[1:5].toUpper() = "CLASS" then
				line := line &amp; Tab &amp; "PAR" &amp; parNumber.String;
			endif;
			_masterArray.add(line);
			if inputFile.timeCreated.date = today then
				_todayArray.add(line);
			endif;
		endwhile;
			
	endforeach;	

	return isError;

epilog

	delete fJd;
	delete inputFile;
end;</source>
        <Parameter name="_parFileName" type="String" usage="input"/>
        <Parameter name="_hotFixDirectory" type="String" usage="input"/>
        <Parameter name="_errStr" type="String" usage="io"/>
        <Parameter name="_masterArray" type="StringArray512" usage="io"/>
        <Parameter name="_todayArray" type="StringArray512" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executePar_filesReadmeInstall" id="b7a27779-dc02-411f-ab34-2e52b64ab02b">
        <source>executePar_filesReadmeInstall( _par: String; _hotFix: String; _nameNewHotFix: String; _createReadme: Boolean; _isSingleUser: Boolean) : Boolean;
// Vytenis	11/2006
// cretaes files: Readme.txt and JMTInstall.txt
// _createReadme =
//		true  - Readme.txt
//		false - JMTInstall.txt
//10 Feb 2013	cnwrs1	Par 33405 insist that JapInstaller 1.0.22 is used in hotfixes.
vars
	fPar	: File;			// PARs either Readme or JMTInstal file
	fNew	: File;			// either readme or JMTInstal file for new Hotfix file
	rt		: RootHotFixes;
	s		: String;
	
begin

	create fPar	transient;
	create fNew	transient;

	rt := app.myRootHotFix;
	if rt = null then
		app.writeLogMessage( 'RootHotFixes empty...');
		return false;
	endif;

	if _createReadme then
		if self.isWebPar(_par) then
			fPar.fileName := _par &amp;'\'&amp; rt.FILE_README_NAME;
		else
			fPar.fileName := _par &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\'&amp; rt.FILE_README_NAME;
		endif;
		fNew.fileName := _hotFix &amp;'\'&amp; _nameNewHotFix &amp;'\'&amp; rt.FILE_README_NAME;
	else
		if self.isWebPar(_par) then
			return true;		// No Install file for web par
		endif;
		fPar.fileName := getFileParJMTInstall( _par );
		fNew.fileName := _hotFix &amp;'\'&amp; _nameNewHotFix &amp;'\'&amp; rt.FILE_JMT_INSTALL_NAME;
	endif;
	fPar.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	fPar.mode := File.Mode_Input;
	if not fPar.isAvailable then
		app.writeLogMessage(' Not found file - ' &amp;fPar.fileName);
		return false;
	endif;
	fPar.open;

	if not fNew.isAvailable then
		fNew.mode := File.Mode_Output;
	else
		fNew.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
		fNew.mode := File.Mode_Append;
	endif;
	fNew.open;
	
// first line is different - it is appended only one time - 'This hotfix addresses the following issues:'
// or SET::SERVER::MULTIUSER/SINGLEUSER for JMTInstall.txt
	if fNew.mode = File.Mode_Output then
		if _createReadme then	// Readme.txt
			if _isSingleUser then
				fNew.writeLine(RootHotFixes.TXT_SINGLEUSER_NOTE1);
				//fNew.writeLine(RootHotFixes.TXT_SINGLEUSER_NOTE2);
				fNew.writeLine('');
			endif;
			fNew.writeLine(rt.README_STR_BEGIN_HOTFIX &amp;'#'&amp; _nameNewHotFix[ _nameNewHotFix.length-2 : _nameNewHotFix.length ] &amp; rt.README_STR_BEGIN_HOTFIX2); //***************************
			fNew.writeLine('');
		else		// JMTInstall.txt
			if _isSingleUser then
				fNew.writeLine( RootHotFixes.JMT_INSTALL_STR_FIRST_SNGLUSER );
			else
				fNew.writeLine( RootHotFixes.JMT_INSTALL_STR_FIRST );
			endif;
		endif;
	endif;
	
	// Par 18452. The new line - JAPCHECKPATCH::7.6.1::001::NOERRORS
	if fNew.mode = File.Mode_Output then // output means the file is newly created
		if not _createReadme then	// JMTInstall.txt
			fNew.writeLine("JAPVER::1.0.22");
			fNew.writeLine( rt.getJAPCheckPatchString(_nameNewHotFix) );
		endif;
	endif;
	
	s := fPar.readLine;		// We've created the first line already for JMTInstall
	if _createReadme then	// for Readme.txt we have to check whether the first line is not empty
		if s.length() &gt; 0 then
			fNew.writeLine(s);
		endif;
	endif;

	while not fPar.endOfFile() do

		s := fPar.readLine;
		if not s.trimBlanks = '' then  

			if _createReadme then	// Readme.txt
				if (s.toUpper &lt;&gt; rt.README_STR_BEGIN.toUpper) then
					fNew.writeLine( s );
				endif;
			else
				// JMTInstall.txt					
				if (s.toUpper &lt;&gt; rt.JMT_INSTALL_STR_LAST.toUpper)
				and (s.toUpper &lt;&gt; rt.JMT_INSTALL_SCMCHK) then		//cnwmc5 - 27 Jan 2014 - PAR 32864
					fNew.writeLine( s );
				endif;
			endif;

		endif;
		
	endwhile;

	if _createReadme then	// Readme.txt - adding empty row for pars separation 
		fNew.writeLine( '' );
	endif;
	
	fPar.close;
	fNew.commit;
	fNew.close;

	return true;
	
epilog
	delete fPar;
	delete fNew;	

end;
</source>
        <Parameter name="_par" type="String"/>
        <Parameter name="_hotFix" type="String"/>
        <Parameter name="_nameNewHotFix" type="String"/>
        <Parameter name="_createReadme" type="Boolean"/>
        <Parameter name="_isSingleUser" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDirsOfAllHotFix" id="f9e1e40f-5765-490d-845a-e14502042840">
        <source>getDirsOfAllHotFix( _dirOfHotFixes : FileFolder input; _listOfHotFixes : FileNodeArray io ) : Boolean;
// Vytenis 11/2006
vars
	rt : RootHotFixes;

begin

	rt := app.myRootHotFix;

	app.writeLogMessage('');
	app.writeLogMessage(' List of all Hotfixes:');
	
	rt.getListOfActualFiles( rt.getDirHotFixes(), RootHotFixes.MASK_DIR_HOTFIXES, _dirOfHotFixes, _listOfHotFixes, true );

	if not ( _listOfHotFixes.size &gt; 0 ) then
		app.writeLogMessage(' There are no Hotfixes in directory - ' &amp; rt.getDirHotFixes());
		return false;
	endif;

	return true;
	
end;
</source>
        <Parameter name="_dirOfHotFixes" type="FileFolder" usage="input"/>
        <Parameter name="_listOfHotFixes" type="FileNodeArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDirsOfAllPars" id="c1eeb0f2-7e8d-48fc-84bd-2054ae900f00">
        <source>getDirsOfAllPars( _dirOfPars : FileFolder input; _listOfPars : FileNodeArray io ) : Boolean;
// Vytenis 11/2006
vars
	rt : RootHotFixes;

begin

	rt := app.myRootHotFix;

	app.writeLogMessage('');
	app.writeLogMessage(' List of all PARs:');
	
	rt.getListOfActualFiles( rt.getDirOfPatches(), RootHotFixes.MASK_DIR_PARS, _dirOfPars, _listOfPars, true );
	rt.getListOfActualFiles( rt.getDirOfPatches(), RootHotFixes.MASK_DIR_TFS, _dirOfPars, _listOfPars, false );		// TFS 38497 jlgmd1 12/10/2018

	if not ( _listOfPars.size &gt; 0 ) then
		app.writeLogMessage(' There are no PARs in directory - ' &amp; rt.getDirOfPatches());
		return false;
	endif;

	return true;
	
end;
</source>
        <Parameter name="_dirOfPars" type="FileFolder" usage="input"/>
        <Parameter name="_listOfPars" type="FileNodeArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFileParJMTInstall" id="58d8e5e0-1ab9-4407-a232-98bc60184dfd">
        <source>getFileParJMTInstall( _par: String ) : String;
// Vytenis	01/2007
// _par - full directory
vars

begin

	return _par &amp;'\'&amp; self.getParPatchNo(_par) &amp;'\'&amp; RootHotFixes.FILE_JMT_INSTALL_NAME;

end;
</source>
        <Parameter name="_par" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNameForNewHotFix" id="9f70c8cb-0574-43b3-ae27-46517902c2ad">
        <source>getNameForNewHotFix() : String;
// Vytenis 11/2006
// analise all hotFixes and create name for new hotFix
vars
	fHtFx		: FileFolder;
	listHtFx	: FileNodeArray;
	rt			: RootHotFixes;
	sBeg,sEnd	: String;
	sE3			: String;
	sInt		: String;

begin
	
	create fHtFx transient;
	create listHtFx transient;
	rt := app.myRootHotFix;
	
	fHtFx.fileName := rt.getDirHotFixes();
	if not self.getDirsOfAllHotFix( fHtFx, listHtFx ) then
		return rt.getReleaseVersionNo() &amp; rt.DIR_PART_HOTFIX &amp; '001';
	endif;

	sEnd := listHtFx[ listHtFx.size ].fileName;
	sInt := sEnd[ sEnd.length - 2 : 3];  // sInt = '012';
	sEnd := sEnd[ rt.getDirHotFixes().length+1 : sEnd.length - rt.getDirHotFixes().length - 3];
	sE3  := (sInt.Integer + 1).String;
	if sE3.length = 1 then
		sE3 := '00' &amp; sE3;
	elseif sE3.length = 2 then
		sE3 := '0' &amp; sE3;
	elseif sE3.length = 3 then
		sE3 := sE3;
	else
		app.writeLogMessage(' Bad Hotfix directory name - ' &amp; sEnd);
		return '';
	endif;
	
	return sEnd &amp; sE3;

epilog
	delete fHtFx;
	delete listHtFx;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParName" id="eb8951b8-ab83-4a45-be79-bfba97fb591b">
        <source>getParName( _par : String) : String;

vars
	s		: String;
	pos		: Integer;
	
begin

 	s := _par.reverse();
	pos := 1;
	s := s.scanUntil("\/", pos);
	
	return s.reverse();
	
end;
</source>
        <Parameter name="_par" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParPatchNo" id="41b83eb3-7d35-4b47-a74e-30407072c7fa">
        <source>getParPatchNo( _par: String) : String;
// Vytenis	11/2006
vars
	rt		: RootHotFixes;
	sUpp,
	s		: String;
	iP		: Integer;
	pos		: Integer;
	
begin

    rt := app.myRootHotFix;
	
	sUpp := _par.toUpper();
	iP := sUpp.pos( rt.DIR_PART_PAR.toUpper() , 1);

	if iP &lt;= 0 then											// TFS 38497 jlgmd1 12/10/2018
		iP := sUpp.pos( rt.DIR_PART_TFS.toUpper() , 1);		// TFS 38497 jlgmd1 12/10/2018
	endif;													// TFS 38497 jlgmd1 12/10/2018
	
	if iP &lt;= 0 then
		app.writeLogMessage('');
		app.writeLogMessage('Par name is wrong...' &amp; class().name &amp;'&gt;&gt;'&amp; method.name);
		return '';
	endif;

	
	s := _par[1:iP-1];
	s := s.reverse();
	pos := 1;
	s := s.scanUntil("\/", pos);
	
	return s.reverse();
	
end;
</source>
        <Parameter name="_par" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isWebPar" id="bfdd7ce1-674c-4723-95dc-acb7b52369b9">
        <source>isWebPar(_par: String) : Boolean;
/*
Purpose: Is this a par for a web fix? Web fixes only have a readme file in the par folder.

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwdw1	Initial creation
*/
vars
	readmeFile: File;
	parFolder: FileFolder;
begin
	create parFolder transient;
	parFolder.fileName := _par;
	if parFolder.files.size &lt;&gt; 1 then
		return false;
	endif;
	
	create readmeFile transient;
	readmeFile.fileName := _par &amp; '\' &amp; app.myRootHotFix.FILE_README_NAME;
	return readmeFile.isAvailable;
	
epilog
	delete readmeFile;
	delete parFolder;
end;</source>
        <Parameter name="_par" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
