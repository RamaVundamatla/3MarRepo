    <JadeMethod name="setMyBay" id="d2d4c59e-6c28-4ada-bd80-9ece81bc74f4">
        <updating/>
        <source>setMyBay(_bay: CM_Bay; _onDeck: Boolean) updating;
/*
 ------------------------------------------------------------------------
Created:			15 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if _onDeck then
		self.myBayOD := _bay;
	else
		self.myBayUD := _bay;
	endif;
end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f9e65e9d-2c9b-4899-bef0-9a99d74951a5">
        <updating/>
        <source>setProxy( _id:String; _alignment:Real; _ordinal:Integer; _myBayOD, _myBayUD:CM_Bay;_maxNumHighCubesIfFull : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 mar 2002	DQ	Added some more properties
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.alignment := _alignment;
	self.id := _id;
	self.ordinal := _ordinal;
	self.maxNumHighCubesIfFull := _maxNumHighCubesIfFull;
	
	self.myBayOD := null;
	self.myBayUD := null;
	
	self.myBayOD := _myBayOD;
	self.myBayUD := _myBayUD;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_alignment" type="Real"/>
        <Parameter name="_ordinal" type="Integer"/>
        <Parameter name="_myBayOD" type="CM_Bay"/>
        <Parameter name="_myBayUD" type="CM_Bay"/>
        <Parameter name="_maxNumHighCubesIfFull" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyOrdinal" id="5d14eee0-b189-4e0c-84b7-4f8443e5b4ad">
        <updating/>
        <source>setProxyOrdinal(_ordinal: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);

	if _ordinal = self.ordinal then
		return;
	endif;
	
	self.ordinal := _ordinal;

epilog

end;</source>
        <Parameter name="_ordinal" type="Integer"/>
    </JadeMethod>
