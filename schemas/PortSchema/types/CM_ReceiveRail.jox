    <JadeMethod name="locationYard" id="a652b197-d3c1-47b0-8d4b-4b4ac6e1b6b2">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>locationYard(set : Boolean; _value : String io) mapping, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2020	jlgndl1	Initial creation	TFS 49202
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

vars

	trxDict : CM_TITransactionByTypeDateDict;
	trx : CM_TITransaction;
	lc : CM_LocationsController;
	ta : CM_TerminalArea;
	iter : Iterator;

begin

	if set then
		//all good, just let it happen
		return;
	endif;
	
	if _value &lt;&gt; null then
		//all good, just use what we got
	endif;

	//Ok so we get to here means we have no value, lets try to work it out;
	
	create trxDict transient;
	if self.myTrackedItem &lt;&gt; null then		// 08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
		self.myTrackedItem.allTransactions.getAllTransactionsOfClass( CM_Move, trxDict, false );
		self.myTrackedItem.allTransactions.getAllTransactionsOfClass( CM_SetDown, trxDict, false );
	endif;
	iter := trxDict.createIterator;
	while iter.next( trx ) do
		if trx.CM_Move.mode &lt;&gt; REAL_MODE then
			continue;
		endif;
		lc := trx.CM_Move.getTargetLocationsController();
		if lc &lt;&gt; null and lc.isYardLocation then
			ta := trx.CM_Move.getTargetTA();
			if ta &lt;&gt; null and not ta.isTransferArea then
				_value := lc.getFullId;
				break;
			endif;
		endif;
	endwhile;
	
	if _value &lt;&gt; null and process.isInTransactionState then
		self.locationYard := _value;
	endif;
	
epilog

	delete trxDict;
	delete iter;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="2cf789eb-fb05-4da8-847e-b5b78a69d3f8">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2020	jlgndl1	Initial creation	TFS 49202
04 Nov 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars

	wle   : CM_WorkListEntry;
	drWle : CM_WorkListEntry;
	wagon : CM_Wagon;
	train : CM_Train;
	ti    : CM_TrackedItem;
	lc    : CM_LocationsController;
begin

	inheritMethod(_tiTransCntrl, _passport);
	
	if _tiTransCntrl.isKindOf( CMIF_MoveTransactionController ) then
		if _tiTransCntrl.myOriginatingLocation &lt;&gt; null and _tiTransCntrl.myOriginatingLocation.isWagon then
			self.locationRail := _tiTransCntrl.myOriginatingLocation.getFullId();  // creating a receive during splitting off cargo during unload
			wagon := _tiTransCntrl.myOriginatingLocation.CM_WagonController.myWagon;
			if wagon &lt;&gt; null then
				self.wagonCode := wagon.id;
				train := wagon.myTrainInwards;
				if train &lt;&gt; null then
					trainCode := train.code;
				endif;
			endif;
			return;
		else
			self.locationRail := _tiTransCntrl.CMIF_MoveTransactionController.targetLocn; // normal create during wagon confirm in
		endif;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		ti := self.myTrackedItem;
		lc := ti.myPrimaryActualLocation;
		if lc &lt;&gt; null then
			if lc.isWagon then
				if self.locationRail = null then
					self.locationRail := lc.getFullId();
				endif;
				wagon := lc.CM_WagonController.myWagon;
				if wagon &lt;&gt; null then
					self.wagonCode := wagon.id;
					train 		   := wagon.myTrainInwards;
					if train &lt;&gt; null then
						trainCode := train.code;
					endif;
					//04.11.2020 cnwma1 TFS #50112
					if self.stevedoreCode = null then
						ti.updateStevedoreForRail(CM_Stevedore.STEVEDORE_RECEIVE,wagon);
						self.stevedoreCode := ti.getStevedoreCodeRecieve();
					endif;
					//04.11.2020 cnwma1 TFS #50112
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="fd1b0faf-8a54-4004-99db-bde93c5db79d">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController) updating;
