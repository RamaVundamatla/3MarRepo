    <JadeMethod name="createInvoiceINCOTerm" id="57118008-83dd-4c9a-8944-5001e220683b">
        <source>createInvoiceINCOTerm(_code, _desc : String; _bank : CM_Bank) : CM_InvoiceINCOTerm;
/*
Purpose - 	
Who - NAVAB1
Date - 07FEB2024
ADO -  CR 58263 TASK 58264
*/

vars
	pxyInvoiceINCOTerm : CM_InvoiceINCOTerm;
	realInvINCOTerm: CM_InvoiceINCOTerm;
	bank : CM_Bank;
begin
	//Create Invoice ship term
	bank := _bank;
    create pxyInvoiceINCOTerm transient;
	pxyInvoiceINCOTerm.setProxy(_code,_code &amp; " Description",bank);

	app.myTrxCA.trxCreateInvINCOTerms(pxyInvoiceINCOTerm, realInvINCOTerm, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realInvINCOTerm.code,_code);
	self.assertEqual(realInvINCOTerm.description,_code &amp; " Description");
	self.assertEqual(realInvINCOTerm.myBusinessUnit,bank);
	
	return realInvINCOTerm;
epilog
	delete pxyInvoiceINCOTerm;
end;</source>
