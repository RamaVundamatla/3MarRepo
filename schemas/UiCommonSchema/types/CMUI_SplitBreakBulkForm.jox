    <JadeMethod name="resetProposedId" id="b83d0083-d114-4bb2-842f-85ec88c76e63">
        <source>resetProposedId();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	quantity : Integer;
	startSuffixValue : Integer;
	endSuffixValue : Integer;
	suffixLength : Integer;
	newBaseId : String;

begin

	self.lblProposedId.caption := null;
	
	if self.optBreakBulk.value then
		return;
	endif;
	
	newBaseId := self.txtId.text.trimBlanks.toUpper;
	if newBaseId = null then
		return;
	endif;
	quantity := self.txtQuantity.text.Integer;
	if quantity &lt; 1 then
		return;
	endif;
	suffixLength := self.txtIdSuffix.text.trimBlanks.length;
	if suffixLength &lt; 1 then
		return;
	endif;
	startSuffixValue := self.txtIdSuffix.text.Integer;
	endSuffixValue := ((startSuffixValue + quantity ) -1 );
	
	if endSuffixValue.String.length &gt; suffixLength then
		suffixLength := endSuffixValue.String.length;
	endif;
	
	self.lblProposedId.foreColor := Blue;
	self.lblProposedId.caption := newBaseId &amp; startSuffixValue.padLeadingWith('0',suffixLength);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="15e18ee2-6380-4e50-af41-e9c06936ce74">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	msg : String;

begin

	self.myTrackedItem := _ti;
	
	if _ti &lt;&gt; null and _ti.canSplitTotalQuantity then
		self.lblExistingCargo.caption := _ti.id &amp; " (" &amp; _ti.totalQuantity.String &amp; ")";
		return true;
		
	else
		self.lblExistingCargo.caption := null;
		if _ti = null then
			msg := app.getErrorString(No_Cargo_selected);
		else
			msg := app.getErrorString(No_split_cargo_not_BB);
		endif;
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.unloadForm();
		return false;
		
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1a460f1f-103a-40c5-a168-458fca899d9e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars
	ct : CM_CargoType;
	convertedAmount : String;
	allChecks : ObjectArray;
	check 	: Object;
	top, left : Real;
	count 	: Integer;
begin

	inheritMethod();
	
	self.myAssistant.comboBoxOperator(cmbOperator, self.myTrackedItem.myOperator, null);
	self.cmbOperator.listIndex := self.cmbOperator.findObject( self.myTrackedItem.myOperator );
	
	self.optBreakBulk.value := true;
	
	self.clickOptions();

	ct:=self.myTrackedItem.myCargoType;
	if ct.isBulkMulti then
		self.optPieceBBB.visible:=false;
		self.optBreakBulk.caption:= app.getErrorString(Create_bulk_item);
		self.tblAmount.visible:=true;
		self.txtQuantity.visible:=false;
		if ct.isTrackByWeight then
			self.lblQuantity.caption:= app.getErrorString(CM_Total_Weight);
			self.tblAmount.setup(Type_Weight, self.backColor);
			convertedAmount:=self.myTrackedItem.getConvertedTotalWeightIn(ct.myWeightMeasurementType.shortName);
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; ct.myWeightMeasurementType.shortName);
		else
			self.lblQuantity.caption:= app.getErrorString(CM_Volume);
			convertedAmount:=self.myTrackedItem.getConvertedTotalVolumeIn(ct.myVolumeMeasurementType.shortName);
			self.tblAmount.setup(Type_Volume, self.backColor);		
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; ct.myVolumeMeasurementType.shortName);
		endif;
	else
		self.tblAmount.visible:=false;
		self.txtQuantity.visible:=true;
	endif;
	
	//29 Jan 2018	NDL	TFS 36697
	self.optTotalWt.value := true;
	
	self.tblAmount.enabled := true;
	self.tblCargoWeight.enabled := false;
	self.tblTareWeight.enabled := false;
		
	if ct.useTareCargoWeight and ct.isTrackByWeight then
		self.optTotalWt.visible := true;
		self.optCargoWt.visible := true;
		self.lblCargoWeight.visible := true;
		self.lblTareWeight.visible := true;
		self.tblCargoWeight.visible := true;
		self.tblTareWeight.visible := true;
		
		self.tblCargoWeight.setup( Type_Weight, self.backColor );
		convertedAmount := app.convertMeasurementForDisplay( ct.myWeightMeasurementType.shortName, self.myTrackedItem.weightCargo );
		self.tblCargoWeight.setValues( convertedAmount &amp; " " &amp; ct.myWeightMeasurementType.shortName );
		
		self.tblTareWeight.setup( Type_Weight, self.backColor );
		convertedAmount := app.convertMeasurementForDisplay( ct.myWeightMeasurementType.shortName, self.myTrackedItem.weightTare );
		self.tblTareWeight.setValues( convertedAmount &amp; " " &amp; ct.myWeightMeasurementType.shortName );
		
		self.tblTareWeight.enabled := not self.myTrackedItem.usesAutoWeightCalculate();
			
	else
		self.optTotalWt.visible := false;
		self.optCargoWt.visible := false;
		self.lblCargoWeight.visible := false;
		self.lblTareWeight.visible := false;
		self.tblCargoWeight.visible := false;
		self.tblTareWeight.visible := false;
		
	endif;
	
	self.chkHazards.value:=true;
	self.chkHazards.visible:= self.myTrackedItem.allTIHazards.size &gt; 0;
	self.chkToDo.visible:= self.myTrackedItem.allToDoTasksToDo.size &gt;0 ;
	self.chkToDo.value:=true;
	self.chkStops.visible:= self.myTrackedItem.hasStops;
	self.chkStops.value:=true;
	self.chkDamage.visible:=self.myTrackedItem.allDamageInstances.size&gt;0; //self.myTrackedItem.isBulkCargo and self.myTrackedItem.allDamageInstances.size&gt;0;
	self.chkDamage.value:=true;
	self.lblDamageQty.visible:=false;
	self.txtDamageQty.visible:=false;
	
	create allChecks transient;
	if self.chkHazards.visible then
		allChecks.add( self.chkHazards);
	endif;
	
	if self.chkToDo.visible then
		allChecks.add( self.chkToDo);
	endif;
	
	if self.chkStops.visible then
		allChecks.add( self.chkStops);
	endif;
	
	if self.chkDamage.visible then
		allChecks.add( self.chkDamage);
	endif;
	
	top:= self.lblIdSuffix.top + self.lblIdSuffix.clientHeight + 10;
	left:=self.lblIdSuffix.left;
	
	count:=0;
	foreach check in allChecks do
		check.CheckBox.left:=left;
		check.CheckBox.top:=top;
		count:=count + 1;
		if count = 2 then
			left:= self.chkToDo.left + self.chkToDo.clientWidth + 10;
			top:=self.lblIdSuffix.top + self.lblIdSuffix.clientHeight + 10;
		else
			top:=top + check.CheckBox.clientHeight + 10;
		endif;
	endforeach;
	//self.lblDamageQty.visible:=self.myTrackedItem.isBulkByQuantity and self.myTrackedItem.allDamageInstances.size&gt;0;
	//self.txtDamageQty.visible:= self.lblDamageQty.visible;
epilog
	delete allChecks;
end;</source>
    </JadeMethod>
    <JadeMethod name="splitBreakBulk" id="dc447c68-559e-408b-ac71-d137c2bc4032">
        <updating/>
        <source>splitBreakBulk():Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars
	weight 	: Decimal[14,4];
	allTiIds : StringArray;
	quantity : Integer;
	operator : CM_Operator;
	tiID : String;
	theReturn : Integer;
	includeStops,
	includeToDo,
	includeDamage,
	includeHaz 	: Boolean;
begin

	create allTiIds transient;
	if not self.validate( allTiIds, quantity,weight, operator ) then
		return false;
	endif;
	
	includeStops:=true;
	includeToDo:=true;
	includeDamage:=true;
	includeHaz:=true;
	if self.chkStops.visible then
		includeStops:=self.chkStops.value;
	endif;
	if self.chkToDo.visible then
		includeToDo:=self.chkToDo.value;
	endif;
	if self.chkHazards.visible then
		includeHaz:=self.chkHazards.value;
	endif;
	if self.chkDamage.visible then
		includeDamage:=self.chkDamage.value;
	endif;
	
	while true do 
	
		app.myTrxUA.trxSplitBreakBulkToNewID(	self.myTrackedItem.CM_Cargo,	//_sourceTi : CM_Cargo;
												allTiIds,	//_newTiIds : StringArray;
												quantity,	//_quantity : Integer;
												weight,	// _weightOrVolume : Decimal;
												operator,	//_operator : CM_Operator;
												includeStops,
												includeToDo,
												includeDamage,
												includeHaz,
												app.myPassport	//_passport : CM_Passport input
												);
	
		
		if not app.myPassport.trxCompletedOK then	
			theReturn := app.showErrorWarningDialog(app.getErrorString(Split_breakbulk), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
		
	endwhile;
	return true;

epilog

	delete allTiIds;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblAmount_lostFocus" id="ae8cd7cb-f94e-463d-8ac7-8b81b7ac409d">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAmount_lostFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2018	jlgndl1	Initial creation	TFS 36697

*/

vars

begin

	self.adjustWeights( table );

epilog

end;</source>
