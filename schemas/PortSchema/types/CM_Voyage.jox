    <JadeMethod name="findAllMyCranesAndWorkpoints" id="4bef7a99-5e1c-41bc-86e9-98d719b5cfcd">
        <source>findAllMyCranesAndWorkpoints( _objSet : CM_ObjectSetActual input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwndl1	Initial creation	Par 29745 - get all of the Cranes
								and workpoints associated with the voyage,

*/

vars

	voyageQueue : CM_VoyageQueue;
	subQueue : CM_RadioTelemetryQueue;
	crane : CM_Crane;
	workPoint : CM_WorkPoint;
	jobSheet : CM_VoyageJobSheet;

begin

	// via the queues first
	voyageQueue := self.myQueue;
	if voyageQueue &lt;&gt; null then	
		foreach subQueue in voyageQueue.allSubQueuesById do
			if subQueue &lt;&gt; null then
				if subQueue.isKindOf(CM_VoyageCraneQueue) then
					crane := subQueue.CM_VoyageCraneQueue.crane;
					if crane &lt;&gt; null then
						_objSet.addNoDuplicates( crane, false );	
					endif; 
				elseif subQueue.isKindOf(CM_VoyageWorkPointQueue) then
					workPoint := subQueue.CM_VoyageWorkPointQueue.myWorkPoint;
					if workPoint &lt;&gt; null then
						_objSet.addNoDuplicates( workPoint, false );	
					endif;
				endif;
			endif;		
		endforeach;
	endif;
	
	if not self.allJobSheets.isEmpty then
		foreach jobSheet in self.allJobSheets do
			if jobSheet.myWorkPoint &lt;&gt; null then
				_objSet.addNoDuplicates( jobSheet.myWorkPoint, false );
			else
				crane := jobSheet.getMyCrane();
				if crane &lt;&gt; null then
					_objSet.addNoDuplicates( crane, false );
				endif;
			endif;
		endforeach;
		
	elseif _objSet.isEmpty then
		crane := self.getCraneWithNoJS();
		if crane &lt;&gt; null then
			_objSet.addNoDuplicates( crane, false );
		endif;
		workPoint := self.getWorkPointWithNoJS();
		if workPoint &lt;&gt; null then
			_objSet.addNoDuplicates( workPoint, false );
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_objSet" type="CM_ObjectSetActual" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="3f0b5f4e-89df-47f4-852e-dac39306099b">
        <source>findLocation(_strs : StringArray; _noException : Boolean; _foundLC : CM_LocationsController io; _foundHeight : Integer io);
// Purpose:			strs are the remaining "bits" of the location string we are looking for.     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	trailer : CM_TILC;
	tiid, locnid : String;
	pos : Integer;
begin
	_foundLC := null;
	_foundHeight := NULLINDEX;
	if _strs.isEmpty then
		//if the voyage has a block stack and the location ID is null, then just stick it in the block stack, no more nonworked/nonplanned mumbo-jumbo 
		if self.myShipBlockStack &lt;&gt; null then						//+cnwas3 par 24191
		//if self.isNonPlannedVoyage or self.isNonWorkedVoyage then //-cnwas3 par 24191
			_foundLC := self.myShipBlockStack;
		endif;
	endif;
	
	if _foundLC &lt;&gt; null then
		return;
	endif;

	if self.myROROStructure &lt;&gt; null then
		self.myROROStructure.findLocation(_strs, _noException, _foundLC, _foundHeight);
	endif;

	if _foundLC &lt;&gt; null then
		return;
	endif;
	
	if self.myCellularVoyageStructure &lt;&gt; null then
		self.myCellularVoyageStructure.findLocation(_strs, _noException, _foundLC, _foundHeight);
	endif;

	if _foundLC &lt;&gt; null then
		return;
	endif;

	if self.myLogVoyageStructure &lt;&gt; null then
		self.myLogVoyageStructure.findLocation(_strs, _noException, _foundLC, _foundHeight);					
	endif;

	if _foundLC &lt;&gt; null then
		return;
	endif;	

	if self.myGeneralCargoVoyage &lt;&gt; null then
		self.myGeneralCargoVoyage.findLocation(_strs, _noException, _foundLC, _foundHeight);
	endif;

	if _foundLC &lt;&gt; null then
		return;
	endif;	

	 // ### TFS CR 56806 TASK 56807 07MAR2023 NAVAB1
	 // If Location is a trailer/MAFI then move it to that location
	if _strs.size &gt;= 1 then
		tiid := _strs[1];
		ti := self.allOnshipTIsByIdCargoType.getAtKeyGeq(tiid,null);
		if ti &lt;&gt; null 
		and ti.isChassis() then
			trailer := ti.CM_TILC;
			if _strs.size = 1 then
				_foundLC := trailer.allLCs.first;
			elseif  _strs.size &gt; 1 then
				pos := _strs[2].Integer;
				if trailer.allLCs.size &gt;= pos then
					_foundLC := trailer.allLCs[pos];
				endif;
			endif;
		endif;
		
	endif;
	if _foundLC &lt;&gt; null then
		return;
	endif;	
	
    if self.myShipBlockStack &lt;&gt; null then //cnwgb1 24.2.2014 PAR 33579 
		// ### TFS CR 56806 TASK 56807 07MAR2023 NAVAB1
		if _strs.size &gt;= 1 then
			locnid := _strs[1];
			
			if locnid = self.code then
				_foundLC := self.myShipBlockStack;
			endif;
				
		endif;
// PAR 33644        if self.isNonPlannedVoyage and self.isNonWorkedVoyage then
		if self.isHOLDSorSHIP() then
            _foundLC := self.myShipBlockStack;
        endif;
    endif;	

	if _foundLC &lt;&gt; null then
		return;
	endif;	

    //01/02/2011 cnwdz2 par26577 As suggested by cnwjre1, the following has been implemented in the above
	//self.myCellularVoyageStructure.findLocation(_strs, _noException, _foundLC, _foundHeight);
	// 02/02/2010 cnwjre1 CCMS 1071 general cargo
	// this causes problems with hand-held ship lander, more specific test now in CM_CellularVoyageStructure::findLocation to replace this
	/*if self.myCellularVoyageStructure &lt;&gt; null and
	   self.myCellularVoyageStructure.type = CellularStructureRORO then
		_foundLC := self.myShipBlockStack;
	endif;*/
	
		
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findLocationFromString" id="3c4b950d-ccf7-41c9-abd9-41bf4255acad">
        <source>findLocationFromString(_locStr : String; _noException : Boolean; _foundLC : CM_LocationsController io);
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

constants
	DoubleSpace : String = "  ";
	SingleSpace : String = " ";
vars
	tStr : String;
	strs : StringArray;
	ta	 : CM_TerminalArea;
	pos : Integer;
	got1035 : Boolean;
	height : Integer;
begin
	_foundLC := null;
	tStr := _locStr.trimBlanks;	//Tidy up both ends of the string
	if tStr = null then
		return;
	endif;
	
	// remove any double spaces... 
	pos := tStr.pos(DoubleSpace, 1);
	while pos &gt; 1 do
		tStr := tStr.replaceString(DoubleSpace,SingleSpace);
		pos := tStr.pos(DoubleSpace, 1);
	endwhile;
	
	on Exception do doHandle1035ForLocation(exception, got1035);
	
	create strs transient;
	tStr.getTokensForDelimiter(Space,strs);
	
	if got1035 then	
		return;
	endif;

	//---------------------
	//Call the method that does all the work
	//---------------------
	self.findLocation(strs, _noException, _foundLC, height);

epilog
	delete strs;
end;</source>
        <Parameter name="_locStr" type="String"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findUnlinkedCancelledShift" id="85546874-8e04-497b-b14e-9ea743cc98a4">
        <source>findUnlinkedCancelledShift() : HMS_VoyageMovement;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2018	jlgndl1	Initial creation	TFS 42043

	//Find a pre-existing cancelled shift movement
	// that is not linked to a replacement. 

*/

vars

	iter : Iterator;
	workOrder : CM_WorkOrder;
	wodShiftMovement : CM_WodShiftMovement;
	movement : HMS_VoyageMovement;

begin

	iter := self.allWorkOrders.createIterator;
	while iter.next( workOrder ) do
		if not workOrder.isWorkOrderForShift then
			//not a shift workorder
			continue;
		endif;
		wodShiftMovement := workOrder.allWoDtls.first.CM_WodShiftMovement;
		if wodShiftMovement = null then
			// not a shift movement
			continue;
		endif;
		movement := wodShiftMovement.myHMSVoyageMovement;
		if movement = null then
			//no related movement
			continue;
		endif;
		if movement.moveType &lt;&gt; HMSMovementTypeCanceledShift then
			//not cancelled
			continue;
		endif;
		if movement.myReplacementMovement &lt;&gt; null then
			//already linked.
			continue;
		endif;
		
		//finally we have an umlinked cancelled shift movement
		return movement;
		
	endwhile;

epilog

	delete iter;

end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="findWorkOrderDtlNotApproved" id="7dbad31d-a3b9-4a1e-b243-3f5ad63b358c">
        <source>findWorkOrderDtlNotApproved(_type : Integer) : CM_WorkOrderVoyageDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2018	jlger1	Initial creation

*/

vars
	workOrder  : CM_WorkOrder;
	workOrderDetail : CM_WorkOrderDtl;
	workOrderDtl : CM_WorkOrderVoyageDtl;
begin
		foreach workOrder in self.allWorkOrders discreteLock  do
			if workOrder.taskStatus &lt;&gt; WO_STATUS_PENDING and workOrder.taskStatus &lt;&gt; WO_STATUS_USERENTRY then
				continue;
			endif;
			foreach workOrderDetail in workOrder.allWoDtls discreteLock do
				if workOrderDetail.detailType = _type then 				
					 return workOrderDetail.CM_WorkOrderVoyageDtl;					
				endif;
			endforeach;		
		endforeach;	
		
		return null;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_WorkOrderVoyageDtl"/>
    </JadeMethod>
    <JadeMethod name="firstTowedVoyage" id="f8669e69-7357-4fe8-8897-d87bdaaf3784">
        <source>firstTowedVoyage():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2018	jlgndl1	Initial creation	TFS 41425

*/

vars

	hmsData : HMS_VoyageData;
	voyage : CM_Voyage;

begin

	if not self.allTowedVoyages.isEmpty then
		hmsData := self.allTowedVoyages.first;
		if hmsData &lt;&gt; null then
			voyage := hmsData.myVoyage;
		endif;
	endif;
	
	return voyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
