    <JadeMethod name="checkCurrentUserHasAccess" id="717d001a-f4d4-4b5f-8b95-bb122df06177">
        <source>checkCurrentUserHasAccess(_status : Integer) : Boolean;
/*

Purpose:	// TFS 39618 PATCH 1 		

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2019	jlgab1	Initial creation

*/

vars
	invStatus : CM_InvoiceStatus;
	term : CM_Terminal;
	user : CM_User;
begin
	term := self.getMyTerminal();
	if term = null then
		return false;
	endif;
	
	if self.getMyInvoiceProcess = null then
		return false;
	endif;
	
	invStatus := self.getMyInvoiceProcess.allStatuses[_status];
	
	if invStatus = null then
		return false;
	endif;
	user := app.getMyUser();
	if user = null then
		return false;
	endif;
	
	if not invStatus.userCanSet(term) then
				app.raiseCMException2(ERR_USER_NO_PERMISSION,
								   user.code, 
								   invStatus.description,
								   null, 
								   null);
	endif;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="closedInvoiceCoveringTSExists" id="2dae585d-52b9-4d59-b1d6-2cd0d024f2cc">
        <source>closedInvoiceCoveringTSExists(param: CMIF_InvoiceSelection input; timestamp: TimeStamp): Boolean;
// closed means posted or pending
vars
	invoices:       CM_InvoiceBySeqNumDict;
	invoice:        CM_Invoice;
begin
	create invoices transient;

	param.status := CM_Invoice.INVOICE_ALL_STATUS;
	getInvoices(param, invoices);
	foreach invoice in invoices do
		if ( 	//(invoice.status = CM_Invoice.INVOICE_POSTED)
				invoice.isPostedOrReversal //04 Sep 2017	NDL	TFS 6759
				or (invoice.status = CM_Invoice.INVOICE_PENDING)
			)
		and	invoice.coversTimeStamp(timestamp) then
			return true;
		endif;
	endforeach;

	return false;
epilog
	delete invoices;
end;</source>
        <Parameter name="param" type="CMIF_InvoiceSelection" usage="input"/>
        <Parameter name="timestamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyInvoiceLineChargeMappings" id="23cbe885-1a57-4aff-8698-d734f7d34e2d">
        <source>copyInvoiceLineChargeMappings(_mappings : CM_InvLineChargingMapsDict; _copyParent : CM_Object);
// ---------------------------------------------------------------------------
// Created:		20 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyMap, newMap, aMap : CM_InvoiceLineChargeMapping;
begin
	create pxyMap transient;
	
	foreach aMap in _mappings discreteLock do
		pxyMap.setProxy(self, _copyParent, aMap.myInvoiceLineDesc, aMap.myCombinationMappingObject, aMap.chargeByOpCon, aMap.myDebtorType, aMap.chargeTypeCode);

		newMap := self.allInvLineChargeMappings[aMap.myInvoiceLineDesc, _copyParent, aMap.myCombinationMappingObject];
		if newMap = null then
			create newMap;
			newMap.setForCreate(pxyMap);
		else
			newMap.setForUpdate(pxyMap);
		endif;
	endforeach;
epilog
	delete pxyMap;
end;</source>
        <Parameter name="_mappings" type="CM_InvLineChargingMapsDict"/>
        <Parameter name="_copyParent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="createCharge" id="ce1accc3-81af-43ed-b51d-85603935fc0a">
        <updating/>
        <source>createCharge(transaction: CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:		December 2007 By Andrew Bishop cnwab1
//
// Purpose:		This is the method that was used for the first 8-9 years of invoicng,
//					it uses the TI to look at the transaction map, this has been changed 
//					in 'createChargeCargo' to use only the transaction.
//
//					DO NOT DELETE
//
// ---------------------------------------------------------------------------



//					DO NOT DELETE



vars
	invLineDesc:  CM_InvoiceLineDesc;
	newInvLine : CM_InvoiceLine;
	debtor:       CM_Debtor;
	chargeableBusinessUnit: CM_Bank;
	tmpCode,
	lMessageText	: String;
	tmpTerminal		: CM_Terminal;
	tmpConsigneeOr	: CM_ConsigneeConsignor;
	tmpVoyage		: CM_Voyage;
	tmpOperator		: CM_Operator;
	aSBController : CMIF_ServiceBroker;
	qrm : CM_QuantityRangeMap;
	idx, range1, range2 : Integer;
	proxyTi : CM_TrackedItem;
begin
	if transaction = null then
		return;
	endif;
	// why do we need to get the latest version of the tracked item?
	// because the operator may have been edited.
	if not tryLock(transaction.myTrackedItem, Share_Lock, Transaction_Duration, 2000) then
		// create invoicing alert
	endif;
	// PAR 7272 AKB2004JAN - no charging for PreNotes
	if transaction.myTrackedItem &lt;&gt; null and transaction.myTrackedItem.isPreNote() then
		return;
	endif;
	
	// ### CCMS 1234. Changed this to pass in a controller rather than pass in a trans and  out an ILD
	create aSBController transient;
	aSBController.myTransaction := transaction;
	
	self.getInvoiceLineDescForXaction(aSBController);

	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null or invLineDesc.isVoid then
			continue;
		endif;
		debtor := transaction.getDebtorForInvoiceLine(invLineDesc); // TFS 42221
		// TFS 42221 		debtor := invLineDesc.getDebtorFromTransaction(transaction);
		if debtor &lt;&gt; null then
			newInvLine := invLineDesc.createInvoiceLine(debtor, transaction);
			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= aSBController.allQuantityRangeMaps.size then
					qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				
				if aSBController.myTransaction.type = TRANS_TYPE_STORAGE then //and not aSBController.allRanges.isEmpty() then
				/*
					range1 := aSBController.allRanges[idx].x;
					range2 := aSBController.allRanges[idx].y;
					newInvLine.setQuantityRange(range1, range2,false);
					*/
					newInvLine.setFromQuantityRangeMap(qrm);
				else
					newInvLine.setFromQuantityRangeMap(qrm);
				endif;
		
			endif;
		else
			app.raiseCMException2(ERR_TRANSACTION_MAP, transaction.myTrackedItem.id, "Debtor" , null, null);

		endif;
	endforeach;
	/*
	invLineDesc := aSBController.myInvoiceLineDesc;

	// there is only one VOID invoice line, it means 'do nothing'
	if invLineDesc = null or invLineDesc.isVoid then
		return;
	endif;
		
	if not tryLock(invLineDesc, Share_Lock, Transaction_Duration, 2000) then
		// create invoicing alert
	endif;
	lMessageText := "";
	tmpTerminal := transaction.myTerminal;

	// ## CCMS 1234. Get the debtor from the ILD
	debtor := invLineDesc.getDebtorFromTransaction(transaction);
	
	if debtor &lt;&gt; null then
		invLineDesc.createInvoiceLine(debtor, transaction);
	else
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, transaction.myTrackedItem.id,  lMessageText, null, null);
		return;
	endif;
	*/
epilog
	delete aSBController;
end;</source>
        <Parameter name="transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="createChargeBOL" id="cb1d3e77-acdb-44f1-9db1-3acfec6fdb49">
        <updating/>
        <source>createChargeBOL(_bolTransaction : CM_BOLTransaction) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Nov 2019	jlgndl1	Initial creation	TFS 47100
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars

	invLineDesc   : CM_InvoiceLineDesc;
	newInvLine    : CM_InvoiceLine;
	qrm 		  : CM_QuantityRangeMap;
	debtor		  : CM_Debtor;
	idx 		  : Integer;
	aSBController : CMIF_ServiceBroker;
begin

	if self.myCurrentTranMapBOL = null then
		if app.canLogExtraDetail then				//05.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " BU " &amp; self.String &amp; " ERROR (" &amp; self.code &amp; ") has no ACTIVE BOL transaction map", LogTRACE.String);
		endif;
		return;
	endif;

	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myBOLTransaction  := _bolTransaction;
	
	self.getInvoiceLineDescForBOL(aSBController);  // this guy might also set aSBController.myDebtor
	
		
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null or invLineDesc.isVoid then
			continue;
		endif;
		
		//29 Nov 2019	NDL	TFS 47100
		debtor := aSBController.myDebtor;	
		
		if debtor = null then 
			debtor := _bolTransaction.getDebtorForInvoiceLine( invLineDesc );
		endif;
		
		if debtor &lt;&gt; null then
			newInvLine := invLineDesc.createInvoiceLineBOL(debtor, _bolTransaction);
			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= aSBController.allQuantityRangeMaps.size then
					qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setFromQuantityRangeMap(qrm);
			endif;
		endif;
	endforeach;
	
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="_bolTransaction" type="CM_BOLTransaction"/>
    </JadeMethod>
    <JadeMethod name="createChargeBOLResync" id="dd731ed2-8d49-49a6-b137-bda42ec60f7d">
        <updating/>
        <source>createChargeBOLResync(transaction: CM_BOLTransaction) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Nov 2019	jlgndl1	Initial creation	TFS 47100
10 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	invLineDesc   :  CM_InvoiceLineDesc;
	newInvLine, invoiceLine    : CM_InvoiceLine;
	qrm 	      : CM_QuantityRangeMap;
	debtor 		  : CM_Debtor;
	idx 		  : Integer;
	aSBController : CMIF_ServiceBroker;
	canLogExtra	  : Boolean;
begin

	canLogExtra := app.canLogExtraDetail();			//10.10.2022 navma1 #52967
	
	// by default we do not create an BOL transaction map, so is possible that this does not exist. No TranMap no charging
	if self.myCurrentTranMapBOL = null then
		if canLogExtra then							//10.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " BU " &amp; self.String &amp; " ERROR (" &amp; self.code &amp; ") has no ACTIVE BOL transaction map", LogINFO.String);
		endif;
		return;
	endif;

	if canLogExtra then								//10.10.2022 navma1 #52967
		app.invLog("Charging for business unit " &amp; self.code, LogINFO.String); 
	endif;
	
	create aSBController transient;
	aSBController.myBank := self;
	
	aSBController.myBOLTransaction := transaction;
	
	self.getInvoiceLineDescForBOL(aSBController);
	
	transaction.doResyncInvoiceLines(aSBController);
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null then
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog("Void invoice item, no invoice line created", LogINFO.String);
			endif;
			continue;
		endif;
		if invLineDesc.isVoid then
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog(invLineDesc.narration &amp; " - Void invoice item, no invoice line created", LogINFO.String);
			endif;
			continue;
		endif;
		debtor := transaction.getDebtorForInvoiceLine( invLineDesc );
		if debtor &lt;&gt; null then
			newInvLine := invLineDesc.createInvoiceLineBOL(debtor, transaction);
			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= aSBController.allQuantityRangeMaps.size then
					qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setFromQuantityRangeMap(qrm);
			endif;
		else
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog(invLineDesc.narration &amp; " - debtor on BOL is null, no invoice line created", LogINFO.String);
			endif;
		endif;
	endforeach;
	
	// ### JIRA 33347 19NOV2024 NAVAB1
	foreach invoiceLine in transaction.allInvoiceLines do
		invoiceLine.setTotalAndTaxForResync();
	endforeach;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="transaction" type="CM_BOLTransaction"/>
    </JadeMethod>
    <JadeMethod name="createChargeCargo" id="f11eead2-309c-417b-9d45-fffb15fcae9c">
        <updating/>
        <source>createChargeCargo(transaction: CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:		December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 05 Oct 2022  navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
// 25 Jun 2024 jlier1	TFS 64775
// 18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------
vars
	invLineDesc		: CM_InvoiceLineDesc;
	newInvLine	 	: CM_InvoiceLine;
	aSBController	: CMIF_ServiceBroker;
	idx 			: Integer;
	paymentType 	: Integer;				//12 Mar 2019	NDL	TFS 43405
	ti				: CM_TrackedItem;
	canlogExtra		: Boolean;
	resourceTypeUsage : CM_ResourceTypeUsage;
	invlintypes : CM_InvoiceLineDescArray;
	isFutureStorage : Boolean;
begin
	if transaction = null then
		return;
	endif;
	
	if not transaction.isChargeable then	 //28.05.2024 navma1 #64224
		return;
	endif;
	
	isFutureStorage := transaction.isKindOf(CM_FutureStorage); // ### JIRA 33015 03OCT2024 NAVAB1
	
	canlogExtra := app.canLogExtraDetail;			//05.10.2022 navma1 #52967
	ti 			:= transaction.myTrackedItem;		//05.10.2022 navma1 #52967
	
	//cash system if in pro forma ti can/will be a prenote when receiving cargo
	if not app.isInProformaMode and ti &lt;&gt; null and ti.isPreNote() then
		if not transaction.canChargeForPrenote() then // TFS 38524
			if canlogExtra then						  //05.10.2022 navma1 #52967
				app.invLog(method.qualifiedName &amp; " INFO: Prenotes do not create invoice lines", LogINFO.String);
			endif;
			return;
		endif;
	endif;
	
	//12 Mar 2019	NDL	TFS 43405
	paymentType := transaction.getPaymentType();
	if paymentType = PaymentType_NoCharge then	
		if canlogExtra then						  //05.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " INFO: Payment type is No Charge", LogINFO.String);
		endif;
		return;
	elseif paymentType = PaymentType_PrePay then	
		if canlogExtra then						  //05.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " INFO: Payment type is Pre Pay", LogINFO.String);
		endif;
		return;
	endif;
	
	// ### CCMS 1234. Changed this to pass in a controller rather than pass in a trans and  out an ILD
	if canlogExtra then						  //05.10.2022 navma1 #52967
		
		// log the transaction type
		app.invLog("  ", LogDEBUG.String);
		app.invLog("'" &amp; transaction.typeString &amp; "' Transaction", LogTRACE.String);
	endif;
	
	create aSBController transient;
	aSBController.myTransaction := transaction;
	
	
	if not isFutureStorage // ### JIRA 33015 03OCT2024 NAVAB1
	and self.terminal.getConfig(InvUseInvoiceCargoAlloc).Boolean then // PAR 35833
		//jlier1 TFS 64775 24/6/24
		if transaction.allResourceUsages.first &lt;&gt; null then
	
			// ### TFS BUG 65167 22JUL2024 NAVAB1 - 
			// See if there is any invoice lines for the to do task on its own
			aSBController.isInvoiceCargoAllocation := true;
			aSBController.myResourceTypeUsage:=null;
			self.getInvoiceLineDescForTIAlloc(aSBController);
			foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock   do
				idx := idx + 1;
				newInvLine := self.createInvoiceLine(invLineDesc,transaction,resourceTypeUsage,idx,aSBController);	
			endforeach;		
	
			// In addition see if there is any invoice lines for each to do task resource 
			foreach resourceTypeUsage in transaction.allResourceUsages do
				aSBController.isInvoiceCargoAllocation := true;
				aSBController.myResourceTypeUsage:=resourceTypeUsage;
				self.getInvoiceLineDescForTIAlloc(aSBController); // PAR 35833	
				foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock   do
						idx := idx + 1;
						newInvLine := self.createInvoiceLine(invLineDesc,transaction,resourceTypeUsage,idx,aSBController);	
				endforeach;		
			endforeach;
			aSBController.myResourceTypeUsage:=null;
		else	
			aSBController.isInvoiceCargoAllocation := true;
			self.getInvoiceLineDescForTIAlloc(aSBController); // PAR 35833
		endif;
		
		
		if aSBController.allInvoiceLineTypes.isEmpty() and idx = 0 then // nothing for allocations so try transaction map
			aSBController.isInvoiceCargoAllocation := false;
			self.getInvoiceLineDescForCargo(aSBController);
		endif;		
	else
		self.getInvoiceLineDescForCargo(aSBController);
	endif;
		
	if idx = 0 then //if we have not created lines for each resource type create the one invoice line with out the resource
		foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock   do
			idx := idx + 1;
			newInvLine := self.createInvoiceLine(invLineDesc,transaction,resourceTypeUsage,idx,aSBController);	
		endforeach;
	endif;
	//13 Jan 2009	NDL	CCMS MES 1006
	if not transaction.allResourceUsages.isEmpty then
		self.createInvLinesForTaskResources(aSBController);
	endif;

epilog
	delete invlintypes;
	delete aSBController;
end;</source>
        <Parameter name="transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="createChargeCargoResync" id="5bf9bdc7-a3f8-487f-a686-3e02feb0f70f">
        <updating/>
        <source>createChargeCargoResync(transaction: CM_TITransaction; _controller:CMIF_TiTransactionResync) updating;
// ---------------------------------------------------------------------------
// Created:		December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 25 Jun 2024 jlier1		TFS 64775
// 18 Oct 2024 navlw1		JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------
vars
	invLineDesc		: CM_InvoiceLineDesc;
	newInvLine 		: CM_InvoiceLine;
	aSBController 	: CMIF_ServiceBroker;
	idx 			: Integer;
	debtor			: CM_Debtor;
	invoiceLine		: CM_InvoiceLine;
	ti              : CM_TrackedItem;
	canLogExtra		: Boolean;
	resourceTypeUsage 		: CM_ResourceTypeUsage;
	hasCargoAllocResources  : Boolean;
begin
	if transaction = null then
		return;
	endif;
	
	ti 				:= transaction.myTrackedItem;						//05.10.2022 navma1 #52967
	canLogExtra		:= app.canLogExtraDetail();							//05.10.2022 navma1 #52967
	
	if ti &lt;&gt; null and ti.isPreNote() then								//05.10.2022 navma1 #52967
		if not transaction.canChargeForPrenote() then 					// TFS 38524
			if canLogExtra then						 		 			//05.10.2022 navma1 #52967
				// ### TFS 2682
				app.invLog("Cargo item is pre note, no charge", LogINFO.String);
			endif;
			return;
		endif;
	endif;
	
	if canLogExtra then						 		 					//05.10.2022 navma1 #52967
		app.invLog("Charging for business unit " &amp; self.code, LogINFO.String);
	endif;
	
	if ti &lt;&gt; null then
		foreach invoiceLine in transaction.allInvoiceLines do
			debtor := invoiceLine.debtor;
			if debtor &lt;&gt; null then
				break;
			endif;
		endforeach;
		if debtor &lt;&gt; null and ti.getPaymentType(debtor) = PaymentType_NoCharge then		// 26/6/18 MAP TFS39250
			if canLogExtra then						 		 							//05.10.2022 navma1 #52967
				app.invLog(method.qualifiedName &amp; " INFO: Payment type is No Charge", LogINFO.String);
			endif;
			return;
		endif;
	endif;

	create aSBController transient;
	aSBController.myTransaction := transaction;
	aSBController.myBank := self;

	if self.terminal.getConfig(InvUseInvoiceCargoAlloc).Boolean then // PAR 37549
		//jlier1 TFS 64775 25/6/24
		if transaction.allResourceUsages.first &lt;&gt; null then
			foreach resourceTypeUsage in transaction.allResourceUsages do
				aSBController.isInvoiceCargoAllocation 	:= true;
				aSBController.myResourceTypeUsage		:= resourceTypeUsage;
				self.getInvoiceLineDescForTIAlloc(aSBController); 
				if not hasCargoAllocResources then
					hasCargoAllocResources:=aSBController.allInvoiceLineTypes.first &lt;&gt; null;
				endif;
				transaction.doResyncInvoiceLines(aSBController, _controller);		
				foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock   do
					//create the invoiceLine
					idx := idx + 1;
					newInvLine := self.createInvoiceLine(invLineDesc,	//_invLineDesc : CM_InvoiceLineDesc io;
												transaction,	//_transaction : CM_TITransaction;
												resourceTypeUsage,	//_resourceTypeUsage : CM_ResourceTypeUsage;
												idx,	//_index : Integer;
												aSBController	//_cmifServiceBroker : CMIF_ServiceBroker
												);	
				endforeach;
			endforeach;
			
			if hasCargoAllocResources then
				return;
			endif;		
			aSBController.myResourceTypeUsage:=null;
		else
			aSBController.isInvoiceCargoAllocation := true;
			self.getInvoiceLineDescForTIAlloc(aSBController); // PAR 37549
		endif;
		
		if aSBController.allInvoiceLineTypes.isEmpty() then // nothing for allocations so try transaction map
			// TFS 37994
			if self.myCurrentTranMapCargoAlloc &lt;&gt; null then
				if canLogExtra then						 		 			//05.10.2022 navma1 #52967
					//13 Feb 2019	NDL	TFS 43373
					app.invLog("Cargo invoice allocation map " &amp; self.myCurrentTranMapCargoAlloc.name &amp; " - NO Matching Allocation Found, Trying Cargo Transaction Map", LogTRACE.String);
				endif;
			endif;
			aSBController.isInvoiceCargoAllocation := false;
			self.getInvoiceLineDescForCargo(aSBController);
		endif;
	else
		self.getInvoiceLineDescForCargo(aSBController);
	endif;

	
	transaction.doResyncInvoiceLines(aSBController, _controller);

	//Note: "doResyncInvoiceLines" specifically ignores 'resource usage' based lines,
	// these are a special case and are processed by "doResyncLinesForTaskResources" which
	// is called later in this method. NDL 14 Jan 2010.
	
	// these will only have the line types that are new
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1; 
		newInvLine := createInvoiceLine(	invLineDesc,	//_invLineDesc : CM_InvoiceLineDesc io;
											transaction,	//_transaction : CM_TITransaction;
											null,	//_resourceTypeUsage : CM_ResourceTypeUsage;
											idx,	//_index : Integer;
											aSBController	//_cmifServiceBroker : CMIF_ServiceBroker
											);
	endforeach;
	
	//13 Jan 2009	NDL	CCMS MES 1006
	self.doResyncLinesForTaskResources(aSBController);
	
	// ### JIRA 33347 19NOV2024 NAVAB1
	foreach invoiceLine in transaction.allInvoiceLines do
		invoiceLine.setTotalAndTaxForResync();
	endforeach;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="transaction" type="CM_TITransaction"/>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
    </JadeMethod>
    <JadeMethod name="createChargeEvent" id="5fef03bc-6444-4b3e-93f3-0bfd675aa73d">
        <updating/>
        <source>createChargeEvent(transaction: CM_EventTransaction) updating;
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/07/2017	cnwdap1		TFS 5286 Minimum Charge Line being calculated when not required
// 10/10/2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 18 Oct 2024 navlw1		JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------
vars
	invLineDesc		: CM_InvoiceLineDesc;
	newInvLine  	: CM_InvoiceLine;
	qrm 			: CM_QuantityRangeMap;
	debtor			: CM_Debtor;
	idx 			: Integer;
	aSBController 	: CMIF_ServiceBroker;
	voyage			: CM_Voyage;
	canLogExtra		: Boolean;
begin

	canLogExtra	:= app.canLogExtraDetail();			//10.10.2022 navma1 #52967
	// PAR 15329
	// by default we do not create an event transaction map, so is possible that this does not exist. No TranMap no charging
	if self.myCurrentTranMapEvent = null then
		if canLogExtra then							//10.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " BU " &amp; self.String &amp; " ERROR (" &amp; self.code &amp; ") has no ACTIVE event transaction map", LogINFO.String);
		endif;
		return;
	endif;

	if transaction &lt;&gt; null and transaction.isVoyageEvent() then
		voyage := transaction.CMEVT_VoyageEvent.getMyVoyage();
		if voyage &lt;&gt; null and voyage.paymentType = PaymentType_NoCharge then		// 27/6/18 MAP TFS39250
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog(method.qualifiedName &amp; " INFO: Payment type is No Charge", LogINFO.String);
			endif;
			return;
		endif;
	endif;

	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myEventTransaction := transaction;
	
	self.getInvoiceLineDescForEvent(aSBController);
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null or invLineDesc.isVoid then
			continue;
		endif;
		debtor := transaction.myDebtor;
		if debtor &lt;&gt; null then
			newInvLine := invLineDesc.createInvoiceLineEvent(debtor, transaction);
			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= aSBController.allQuantityRangeMaps.size then
					qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setFromQuantityRangeMap(qrm);
				invLineDesc.checkForMinimumCharge(debtor, newInvLine, transaction);			// TFS 5286
			endif;
		endif;
	endforeach;
	
	// ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
	if not transaction.allResourceUsages.isEmpty then
		self.createInvLinesForEventTaskRsrc(aSBController);
	endif;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="transaction" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="createChargeEventResync" id="be00ce85-564d-495f-81e7-8c1c8b996d43">
        <updating/>
        <source>createChargeEventResync(transaction: CM_EventTransaction) updating;
// ---------------------------------------------------------------------------
// Created:		Feb 2012 
//
// Purpose:		CCMS 1262 Transaction Enquiry, implement resync for events as well as cargo
//
// Changed On	By		Reason
// ---------------------------------------------------------------------------
// 10 Oct 2022	navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// 18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	invLineDesc   : CM_InvoiceLineDesc;
	newInvLine, invoiceLine    : CM_InvoiceLine;
	qrm 		  : CM_QuantityRangeMap;
	debtor		  : CM_Debtor;
	idx 		  : Integer;
	aSBController : CMIF_ServiceBroker;
	voyage		  : CM_Voyage;
	canLogExtra	  : Boolean;
begin

	canLogExtra	:= app.canLogExtraDetail();			//10.10.2022 navma1 #52967
	// by default we do not create an event transaction map, so is possible that this does not exist. No TranMap no charging
	if self.myCurrentTranMapEvent = null then
		if canLogExtra then							//10.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " BU " &amp; self.String &amp; " ERROR (" &amp; self.code &amp; ") has no ACTIVE event transaction map", LogINFO.String);
		endif;
		return;
	endif;

	if transaction &lt;&gt; null and transaction.isVoyageEvent() then
		voyage := transaction.CMEVT_VoyageEvent.getMyVoyage();
		if voyage &lt;&gt; null and voyage.paymentType = PaymentType_NoCharge then		// 27/6/18 MAP TFS39250
			if canLogExtra then														//10.10.2022 navma1 #52967
				app.invLog(method.qualifiedName &amp; " INFO: Payment type is No Charge", LogINFO.String);
			endif;
			return;
		endif;
	endif;

	if canLogExtra then							//10.10.2022 navma1 #52967
		app.invLog("Charging for business unit " &amp; self.code, LogINFO.String);
	endif;
	
	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myEventTransaction := transaction;
	
	self.getInvoiceLineDescForEvent(aSBController);
	
	transaction.doResyncInvoiceLines(aSBController);
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null then
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog("Void invoice item, no invoice line created", LogINFO.String);
			endif;
			continue;
		endif;
		if invLineDesc.isVoid then
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog(invLineDesc.narration &amp; " - Void invoice item, no invoice line created", LogINFO.String);
			endif;
			continue;
		endif;
		debtor := transaction.getDebtor;
		if debtor &lt;&gt; null then
			newInvLine := invLineDesc.createInvoiceLineEvent(debtor, transaction);
			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= aSBController.allQuantityRangeMaps.size then
					qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setFromQuantityRangeMap(qrm);
			endif;
		else
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog(invLineDesc.narration &amp; " - debtor on event is null, no invoice line created", LogINFO.String);
			endif;
		endif;
	endforeach;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	self.doResyncLinesForEventTaskRsrc(aSBController);
	
	// ### JIRA 33347 19NOV2024 NAVAB1
	foreach invoiceLine in transaction.allInvoiceLines do
		invoiceLine.setTotalAndTaxForResync();
	endforeach;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="transaction" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="createChargeInventory" id="bbc42796-ba72-48f1-8168-530f8cd13aa4">
        <source>createChargeInventory(_event : CMEVT_LocationActivity input; _resync : Boolean);
/*
Purpose:			

Date		Who		Reason
31MAY2021	NAVAB1	TFS 51219
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	invLineDesc   : CM_InvoiceLineDesc;
	newInvLine    : CM_InvoiceLine;
	idx 		  : Integer;
	aSBController : CMIF_ServiceBroker;
begin
	if self.myCurrentTranMapInventory = null then
		if app.canLogExtraDetail then				//05.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " BU " &amp; self.String &amp; " ERROR (" &amp; self.code &amp; ") has no ACTIVE Inventory transaction map", LogINFO.String);
		endif;
		return;
	endif;


	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myInventoryEvent := _event;
	
	self.getInvoiceLineDescForInventory(aSBController);
		
	if _resync then
		_event.doResyncInvoiceLines(aSBController);
	endif;
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		newInvLine := createInventoryInvoiceLine(invLineDesc,
											_event,
											idx,
											aSBController);
	endforeach;
	
	
epilog
	delete aSBController;

end;</source>
        <Parameter name="_event" type="CMEVT_LocationActivity" usage="input"/>
        <Parameter name="_resync" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createChargeSnapshot" id="1a85cb29-0dda-41b2-8983-8b84919131a1">
        <updating/>
        <source>createChargeSnapshot(_quantityMap : CM_QuantityMap; _snapshotData : CM_DynamicObject_Snapshot; 
									_snapShotQuantity : CM_SnapshotField; _debtor : CM_Debtor; _quantity : Integer; _broker : CM_SnapShotServiceBroker) updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars
	invLineDesc:  CM_InvoiceLineDesc;
	newInvLine : CM_InvoiceLine;
	qrm : CM_QuantityRangeMap;
	idx : Integer;
	dateTime	: TimeStamp;
	escalating	: Boolean;
	quantity	: Integer;
	aSBController : CMIF_ServiceBroker;
begin

	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myServiceBroker := _broker; //21 Feb 2019	NDL	TFS 43153
	
	quantity := _quantity;
	
	if _quantityMap.mappingType = CM_QuantityMap.MapType_Single then
		_quantityMap.getInvLineDescForSingle(aSBController, _quantity);
	else
		_quantityMap.getInvLineDescForEscalating(aSBController, _quantity);
		escalating := true;
	endif;
	dateTime := _snapshotData.mySnapshotData.runDateTime;
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null or invLineDesc.isVoid then
			continue;
		endif;

		qrm := null;
		if idx &lt;= aSBController.allQuantityRangeMaps.size then
			qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
		endif;
		if escalating then
			if qrm &lt;&gt; null then
				if _quantity &gt; qrm.rangeEnd then
					quantity := qrm.rangeEnd.Integer - qrm.rangeStart.Integer;
					if qrm.rangeStart &gt; 0 then
						quantity := quantity + 1;
					endif;
				else
					quantity := _quantity - qrm.rangeStart.Integer + 1;
				endif;
			endif;
		endif;
		
		newInvLine := invLineDesc.createInvoiceLineSnapshot(dateTime, _debtor, quantity);
		if newInvLine &lt;&gt; null then
			newInvLine.setFromQuantityRangeMap(qrm);
			newInvLine.setSnapShot(_snapshotData, _snapShotQuantity);

		endif;

	endforeach;

epilog
	delete aSBController;
end;</source>
        <Parameter name="_quantityMap" type="CM_QuantityMap"/>
        <Parameter name="_snapshotData" type="CM_DynamicObject_Snapshot"/>
        <Parameter name="_snapShotQuantity" type="CM_SnapshotField"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_broker" type="CM_SnapShotServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="createChargeSnapshotMTPOOL" id="0322e761-b051-4eee-9570-e41ec377cf99">
        <updating/>
        <source>createChargeSnapshotMTPOOL(_quantityMap 		 : CM_QuantityMap; 
						   _snapshotData 		 : CM_DynamicObject_Snapshot; 
						   _snapShotQuantity	 : CM_SnapshotField; 
						   mtParty 				 : CM_MTPoolingParty input; 
						   _quantity 			 : Integer; 
						   _broker : CM_SnapShotServiceBroker) updating;
// ---------------------------------------------------------------------------
// Created:     08 May 2017 by cnwab1 TFS 3509
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 05 Oct 2022 		navma1			Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 18 Oct 2024 		navlw1			JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------

vars
	invLineDesc 		: CM_InvoiceLineDesc;
	qrm 				: CM_QuantityRangeMap;
	idx 				: Integer;
	dateTime			: TimeStamp;
	escalating			: Boolean;
	quantity, 
	originalInvoiceAmt	: Integer;
	aSBController 		: CMIF_ServiceBroker;
	debtor 				: CM_Debtor;
    op 					: CM_Operator;
	partner 			: CM_MTPoolingPartner;
	total 				: Real;
	newTotalAmt 		: Real;
	newInvoiceLine 		: CM_InvoiceLine;
	seqNum 				: Integer;
	now 				: TimeStamp;
	invoice				: CM_Invoice;
	invType 			: CM_InvoiceDesc;
begin
	
	foreach partner in mtParty.allPoolingPartners do
		total := total + partner.percentageOfCharges;
	endforeach;
	
	if total &lt;&gt; 100 then
		if app.canLogExtraDetail then						//05.10.2022 navma1 #52967
			app.invLog("Can not calculate Empty Pool Party (" &amp; mtParty.code &amp; ") lines because Pool Partners' percentages do not add up to 100", LogINFO.String);
		endif;
		return;
	endif;


	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myServiceBroker := _broker; // ### TFS BUG 57457 04APR2023 NAVAB1

	quantity := _quantity;
	
	if _quantityMap.mappingType = CM_QuantityMap.MapType_Single then
		_quantityMap.getInvLineDescForSingle(aSBController, _quantity);
	else
		_quantityMap.getInvLineDescForEscalating(aSBController, _quantity);
		escalating := true;
	endif;
	dateTime := _snapshotData.mySnapshotData.runDateTime;
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null or invLineDesc.isVoid then
			continue;
		endif;

		qrm := null;
		if idx &lt;= aSBController.allQuantityRangeMaps.size then
			qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
		endif;
		if escalating then
			if qrm &lt;&gt; null then
				if _quantity &gt; qrm.rangeEnd then
					quantity := qrm.rangeEnd.Integer - qrm.rangeStart.Integer;
					if qrm.rangeStart &gt; 0 then
						quantity := quantity + 1;
					endif;
				else
					quantity := _quantity - qrm.rangeStart.Integer + 1;
				endif;
			endif;
		endif;
		
		
		originalInvoiceAmt := quantity;
		
		now := app.actualTimeServer();
		
		foreach partner in mtParty.allPoolingPartners do
			debtor := null;
			
			op := partner.myOperator;
			if op &lt;&gt; null then
				debtor := op.debtor;
			endif;
		
			invType := invLineDesc.getInvoiceType(debtor);
			invoice := self.getAutoInvoiceSnapshot(invType, debtor, now, false, invLineDesc);
		
			create newInvoiceLine;
			seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
			newInvoiceLine.setForCreate(seqNum, false, null, invLineDesc, invoice, debtor, self, 1, now);
			newInvoiceLine.setSnapShot(_snapshotData, _snapShotQuantity); 
			newInvoiceLine.createCharges();
			newInvoiceLine.setQuantityAndTotal((partner.percentageOfCharges / 100) * originalInvoiceAmt);
			newTotalAmt := newTotalAmt + newInvoiceLine.quantity;
		endforeach;

	endforeach;

epilog
	delete aSBController;
end;</source>
        <Parameter name="_quantityMap" type="CM_QuantityMap"/>
        <Parameter name="_snapshotData" type="CM_DynamicObject_Snapshot"/>
        <Parameter name="_snapShotQuantity" type="CM_SnapshotField"/>
        <Parameter name="mtParty" type="CM_MTPoolingParty" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_broker" type="CM_SnapShotServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="createChargeVoyage" id="1b6eb92b-5b5b-4cc4-9fee-c6e9b065e416">
        <updating/>
        <source>createChargeVoyage(transaction: HMS_VTMISTransaction; _message : String io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 10 Oct 2022	navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------
vars
	invLineDesc		: CM_InvoiceLineDesc;
	newInvLine 		: CM_InvoiceLine;
	qrm 			: CM_QuantityRangeMap;
	debtor			: CM_Debtor;
	idx 			: Integer;
	aSBController 	: CMIF_ServiceBroker;
	canLogExtra		: Boolean;
	voyage			: CM_Voyage;
begin
	canLogExtra := app.canLogExtraDetail();							//10.10.2022 navma1 #52967
	
	if canLogExtra then												//10.10.2022 navma1 #52967
		// TFS 42084 log the transaction type
		app.invLog("  ", LogDEBUG.String);
		app.invLog(method.qualifiedName &amp; " '" &amp; transaction.typeString &amp; "' Transaction", LogTRACE.String);
	endif;
	
	if transaction.myResourceUsed &lt;&gt; null then
		if canLogExtra then											//10.10.2022 navma1 #52967
			// TFS 42084 log the transaction type
			app.invLog(method.qualifiedName &amp; " '" &amp; transaction.myResourceUsed.myResource.description &amp; "' RESUSED", LogINFO.String);
		endif;
	endif;

	// PAR 15329
	// by default we do not create a voyage transaction map, so it is possible that this does not exist. No TranMap no charging
	if self.myCurrentTranMapVoyage = null then
		if canLogExtra then											//10.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " BU " &amp; self.String &amp; " ERROR (" &amp; self.code &amp; ") has no ACTIVE voyage transaction map", LogINFO.String);
		endif;
		return;
	endif;

	if transaction &lt;&gt; null then
		voyage := transaction.myVoyage;							   						//10.10.2022 navma1 #52967
		if voyage &lt;&gt; null and voyage.paymentType = PaymentType_NoCharge then			// 27/6/18 MAP TFS39250
		
			if canLogExtra then															//10.10.2022 navma1 #52967
				app.invLog(method.qualifiedName &amp; " INFO: Voyage Payment type is No Charge", LogINFO.String);
			endif;
			return;
		endif;
	endif;

	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myVTMISTransaction := transaction;
	
	self.getInvoiceLineDescForVTMIS(aSBController, _message);
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null or invLineDesc.isVoid then
			continue;
		endif;
		
		debtor := transaction.myDebtor;
		if debtor &lt;&gt; null then
			newInvLine := invLineDesc.createInvoiceLineVTMIS(debtor, invLineDesc, transaction);
			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= aSBController.allQuantityRangeMaps.size then
					qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setFromQuantityRangeMap(qrm);
			endif;
		endif;
	endforeach;
epilog
	delete aSBController;
end;</source>
        <Parameter name="transaction" type="HMS_VTMISTransaction"/>
        <Parameter name="_message" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createChargeVoyageResync" id="d3493b25-5f25-4c48-882d-f439887f5150">
        <updating/>
        <source>createChargeVoyageResync(transaction: HMS_VTMISTransaction; _message : String io) updating;
// Feb 2012 CCMS 1262 Transaction Enquiry, implement resync for HMS as well as cargo
// 10 Oct 2022 	navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	invLineDesc		: CM_InvoiceLineDesc;
	newInvLine, invoiceLine		: CM_InvoiceLine;
	qrm 			: CM_QuantityRangeMap;
	debtor			: CM_Debtor;
	idx 			: Integer;
	aSBController 	: CMIF_ServiceBroker;
	canLogExtra		: Boolean;
begin
	canLogExtra	:= app.canLogExtraDetail();
	
	// by default we do not create a voyage transaction map, so it is possible that this does not exist. No TranMap no charging
	if self.myCurrentTranMapVoyage = null then
		if canLogExtra then							//10.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " BU " &amp; self.String &amp; " ERROR (" &amp; self.code &amp; ") has no ACTIVE voyage transaction map", LogINFO.String);
		endif;
		return;
	endif;

	if transaction &lt;&gt; null and transaction.myVoyage &lt;&gt; null and transaction.myVoyage.paymentType = PaymentType_NoCharge then		// 27/6/18 MAP TFS39250
		if canLogExtra then							//10.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " INFO: Payment type is No Charge", LogINFO.String);
		endif;
		return;
	endif;
	
	if canLogExtra then								//10.10.2022 navma1 #52967
		app.invLog("Charging for business unit " &amp; self.code, LogINFO.String);
	endif;
	
	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myVTMISTransaction := transaction;
	
	self.getInvoiceLineDescForVTMIS(aSBController, _message);
	
	transaction.doResyncInvoiceLines(aSBController);	// 29833 missing from original development

	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null then
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog("Void invoice item, no invoice line created", LogINFO.String);
			endif;
			continue;
		endif;
		if invLineDesc.isVoid then
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog(invLineDesc.narration &amp; " - Void invoice item, no invoice line created", LogINFO.String);
			endif;
			continue;
		endif;
		
		debtor := transaction.myDebtor;
		
		if debtor = null then
			debtor := invLineDesc.getDefaultDebtorFromTran(true,transaction);
			if canLogExtra then							//10.10.2022 navma1 #52967
				app.invLog("Debtor on the " &amp; transaction.typeString &amp; " transaction is null! Switching to default " &amp; debtor.name, LogINFO.String);
			endif;
		endif;
		
		if debtor &lt;&gt; null then
			newInvLine := invLineDesc.createInvoiceLineVTMIS(debtor, invLineDesc, transaction);

			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= aSBController.allQuantityRangeMaps.size then
					qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setFromQuantityRangeMap(qrm);
			endif;
		
		endif;
	endforeach;
	
	// ### JIRA 33347 19NOV2024 NAVAB1
	foreach invoiceLine in transaction.allInvoiceLines do
		invoiceLine.setTotalAndTaxForResync();
	endforeach;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="transaction" type="HMS_VTMISTransaction"/>
        <Parameter name="_message" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createChargeWOResync" id="5af1c771-3b18-49ee-a637-aaddfe9a2890">
        <updating/>
        <source>createChargeWOResync(transaction: CM_WOTransaction) updating;
/*
Purpose:	TFS 39237		
Date				Who			Reason
JUNE 2018			CNWAB1		Initial creation
10 Oct 2022			navma1  	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
15/05/2023			navkc1		CR 57927 Task 54268 - Transaction Map
18 Oct 2024 		navlw1		JIRA-33107: Invoice Logging Use Levels
*/

vars
	invLineDesc	  :  CM_InvoiceLineDesc;
	newInvLine, invoiceLine 	  : CM_InvoiceLine;
	qrm 		  : CM_QuantityRangeMap;
	debtor		  : CM_Debtor;
	idx 		  : Integer;
	aSBController : CMIF_ServiceBroker;
	canLogExtra	  : Boolean;
begin

	canLogExtra := app.canLogExtraDetail();				//10.10.2022 navma1 #52967
	
	// by default we do not create an WO transaction map, so is possible that this does not exist. No TranMap no charging
	if self.myCurrentTranMapWorkOrder = null then
		if canLogExtra then								//10.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " BU " &amp; self.String &amp; " ERROR (" &amp; self.code &amp; ") has no ACTIVE work order transaction map", LogTRACE.String);
		endif;
		return;
	endif;
	
	// ### TFS DEFECT 59153 17JUL2023 NAVAB1
	if transaction.noCharge then
		if canLogExtra then
			app.invLog("Transaction " &amp; transaction.getDescription() &amp; " has NOCHARGE set to TRUE", LogTRACE.String);
			//return;
		endif;
		return; //20/11/2024	navkc1 JIRA Story MTN-33012 - Should be here
	endif;

	if canLogExtra	then								//10.10.2022 navma1 #52967
		app.invLog("Charging for business unit " &amp; self.code, LogTRACE.String);
	endif;
	
	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myTransactionWO := transaction;
	
	self.getInvoiceLineDescForWO(aSBController);
	
	transaction.doResyncInvoiceLines(aSBController);
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null then
			if canLogExtra	then								//10.10.2022 navma1 #52967
				app.invLog("Void invoice item, no invoice line created", LogTRACE.String);
			endif;
			continue;
		endif;
		if invLineDesc.isVoid then
			if canLogExtra	then								//10.10.2022 navma1 #52967
				app.invLog(invLineDesc.narration &amp; " - Void invoice item, no invoice line created", LogTRACE.String);
			endif;
			continue;
		endif;
		debtor := transaction.getMyDebtor();
		if debtor &lt;&gt; null then
			newInvLine := invLineDesc.createInvoiceLineWO(debtor, transaction);
			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= aSBController.allQuantityRangeMaps.size then
					qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setFromQuantityRangeMap(qrm);
			endif;
		else
			if canLogExtra	then								//10.10.2022 navma1 #52967
				app.invLog(invLineDesc.narration &amp; " - debtor on Work Order is null, no invoice line created", LogTRACE.String);
			endif;
		endif;
	endforeach;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	self.doResyncLinesForWOTaskRsrc(aSBController);
	
	// ### JIRA 33347 19NOV2024 NAVAB1
	foreach invoiceLine in transaction.allInvoiceLines do
		invoiceLine.setTotalAndTaxForResync();
	endforeach;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="transaction" type="CM_WOTransaction"/>
    </JadeMethod>
    <JadeMethod name="createChargeWorkOrder" id="f338099b-5e78-414b-b0e2-760166783095">
        <updating/>
        <source>createChargeWorkOrder(_woTransaction : CM_WOTransaction) updating;
/*

Purpose:		TFS 39237	

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2018	jlgab1	Initial creation
10 Oct 2022	navma1  Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars

	invLineDesc	  : CM_InvoiceLineDesc;
	newInvLine 	  : CM_InvoiceLine;
	qrm 		  : CM_QuantityRangeMap;
	debtor		  : CM_Debtor;
	idx 		  : Integer;
	aSBController : CMIF_ServiceBroker;
	canLogExtra	  : Boolean;
begin
	
	canLogExtra	:= app.canLogExtraDetail();				//10.10.2022 navma1 #52967

	if self.myCurrentTranMapWorkOrder = null then
		if canLogExtra	then								//10.10.2022 navma1 #52967
			app.invLog(method.qualifiedName &amp; " BU " &amp; self.String &amp; " ERROR (" &amp; self.code &amp; ") has no ACTIVE work order transaction map", LogINFO.String);
		endif;
		return;
	endif;

	debtor := _woTransaction.getMyDebtor();
	
	create aSBController transient;
	aSBController.myBank := self;
	aSBController.myTransactionWO  := _woTransaction;
	
	self.getInvoiceLineDescForWO(aSBController);
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null or invLineDesc.isVoid then
			continue;
		endif;
		if debtor &lt;&gt; null then
			newInvLine := invLineDesc.createInvoiceLineWO(debtor, _woTransaction);
			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= aSBController.allQuantityRangeMaps.size then
					qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setFromQuantityRangeMap(qrm);
				endif;
		endif;
	endforeach;
	
	
	// ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
	if not _woTransaction.allResourceUsages.isEmpty then
		self.createInvLinesForWOTaskRsrc(aSBController);
	endif;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="_woTransaction" type="CM_WOTransaction"/>
    </JadeMethod>
    <JadeMethod name="createEscChargeLines" id="e0a40b12-55d8-4ba2-afa5-42bdcd675222">
        <source>createEscChargeLines(_invLine : CM_InvoiceLine input; _qrm : CM_QuantityRangeMap; _existingLines : ObjectArray) ;
//	CCMS SFW 1279 May 2012 Storage Escalating Charges
// create from new transaction or re-create from re-sync
// 10 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	first,
	found			: Boolean;
	idx				: Integer;
	count			: Integer;
	daysIncrement	: Integer;
	qty				: Integer;
	debtor 			: CM_Debtor;
	currentLine		: CM_InvoiceLine;
	newInvLine 		: CM_InvoiceLine;
	qm				: CM_QuantityMap;
	qr				: CM_QuantityRange;
	ct				: CM_CalculationType;
	rtu				: CM_ResourceTypeUsage;
	ild				: CM_InvoiceLineDesc;
	transaction 	: CM_TITransaction;
	canLogExtra		: Boolean;
begin
	canLogExtra	:= app.canLogExtraDetail();					//10.10.2022 navma1 #52967
	qm 			:= _qrm.myQuantityMap;
	
	// only for quantity map type of escalating full
	if not qm.mappingType = CM_QuantityMap.MapType_EscalateFull then
		return;
	endif;
	
	qty := _invLine.quantity.Integer;
	ct  := qm.myCalculationType;
	
	if ct &lt;&gt; null then
		if ct.allQuantityRanges.size &gt; 0 then
			foreach qr in ct.allQuantityRanges do
				if qr.rangeStart = _qrm.rangeStart and
				   qr.rangeEnd = _qrm.rangeEnd then
					daysIncrement := qr.daysIncrement;
					if daysIncrement &gt; 0 then
						found := true;
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	if not found then
		return;
	endif;
	
	debtor 	    := _invLine.debtor;
	rtu 	    := _invLine.myResourceTypeUsage;
	ild 		:= _invLine.invoiceLineDesc;
	transaction := _invLine.myTransactionTI;
	first 		:= true;
	count 	    := 1;
	
	while true do
		if first then
			// reduce the quantity of the existing invoice line
			if qty &gt; daysIncrement then
				_invLine.setQuantityAndTotal(daysIncrement);
			else
				_invLine.setQuantityAndTotal(qty);
			endif;
			_invLine.setEscalatingValues(daysIncrement, count);
		else
			// currentLine is used for transaction resync
			idx := count - 1;		// _existingLines contains the lines after the first - count includes the first
			currentLine := null;
			if _existingLines &lt;&gt; null then
				if _existingLines.size &gt;= idx then
					currentLine := _existingLines[idx].CM_InvoiceLine;
				endif;
			endif;
			if currentLine &lt;&gt; null then
				newInvLine := currentLine;
				if canLogExtra	then								//10.10.2022 navma1 #52967
					app.invLog(ild.narration &amp; " - Updating invoice line " &amp; newInvLine.sequenceNum.String &amp; ", invoice " &amp; newInvLine.invoice.sequenceNum.String &amp; ", debtor " &amp; debtor.name, LogINFO.String);
				endif;
			else
				// create new invoice lines for the remainder of the quantity, every 'daysIncrement'
				newInvLine := ild.createInvoiceLine(debtor, transaction);
				if newInvLine &lt;&gt; null then
					if canLogExtra	then								//10.10.2022 navma1 #52967
						app.invLog(ild.narration &amp; " - New invoice line " &amp; newInvLine.sequenceNum.String &amp; ", invoice " &amp; newInvLine.invoice.sequenceNum.String &amp; ", debtor " &amp; debtor.name, LogINFO.String);
					endif;
				endif;
			endif;
			if newInvLine &lt;&gt; null then
				newInvLine.setMyResourceTypeUsage(rtu);
				newInvLine.setEscalatingValues(daysIncrement, count);	// set before being used in rate calculation in next method
				newInvLine.setFromQuantityRangeMap(_qrm);
				if qty &gt; daysIncrement then
					newInvLine.setQuantityAndTotal(daysIncrement);
				else
					newInvLine.setQuantityAndTotal(qty);
				endif;
			endif;
		endif;
		first := false;
		qty := qty - daysIncrement;
		count := count + 1;
		if qty &lt;= 0 then
			break;
		endif;
	endwhile;
	
	// void any remaining existing invoice lines
	if _existingLines &lt;&gt; null then
		idx := idx + 1;
		if idx &lt;= _existingLines.size then
			count := idx;
			foreach idx in count to _existingLines.size do
				currentLine := _existingLines[idx].CM_InvoiceLine;
				if canLogExtra	then								//10.10.2022 navma1 #52967
					app.invLog("Invoice line " &amp; currentLine.sequenceNum.String &amp; " of invoice " &amp; currentLine.invoice.sequenceNum.String &amp; " voided", LogINFO.String);
				endif;
				currentLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			endforeach;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine" usage="input"/>
        <Parameter name="_qrm" type="CM_QuantityRangeMap"/>
        <Parameter name="_existingLines" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="createEscChargeLinesFromCT" id="1a4c7f80-f3ac-4299-98e7-a8f36600552f">
        <source>createEscChargeLinesFromCT(_invLine : CM_InvoiceLine input; _existingLines : ObjectArray) ;
//	CCMS SFW 1279 May 2012 Storage Escalating Charges
// copy of createEscChargeLines, re-create from invoice re-evaluate, no quantity map available so use the calculation type instead
// 05 Oct 2022			navma1  Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 18 Oct 2024 			navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	first,
	found			: Boolean;
	idx				: Integer;
	count			: Integer;
	daysIncrement	: Integer;
	qty				: Integer;
	debtor 			: CM_Debtor;
	currentLine		: CM_InvoiceLine;
	newInvLine 		: CM_InvoiceLine;
	qr				: CM_QuantityRange;
	ct				: CM_CalculationType;
	rtu				: CM_ResourceTypeUsage;
	ild				: CM_InvoiceLineDesc;
	transaction 	: CM_TITransaction;
	canLogExtra		: Boolean;
begin
	
	canLogExtra	:=	app.canLogExtraDetail();		//10.10.2022 navma1 #52967
	qty 		:= _invLine.quantity.Integer;
	ild 		:= _invLine.invoiceLineDesc;
	ct 			:= ild.myCalculationType;
	
	if ct &lt;&gt; null then
		if ct.allQuantityRanges.size &gt; 0 then
			foreach qr in ct.allQuantityRanges do
				if qr.rangeStart = _invLine.quantityRangeStart and
				   qr.rangeEnd = _invLine.quantityRangeEnd then
					daysIncrement := qr.daysIncrement;
					if daysIncrement &gt; 0 then
						found := true;
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	if not found then
		return;
	endif;
	
	debtor 		:= _invLine.debtor;
	rtu 		:= _invLine.myResourceTypeUsage;
	transaction := _invLine.myTransactionTI;
	first		:= true;
	count 		:= 1;
	
	while true do
		if first then
			// reduce the quantity of the existing invoice line
			if qty &gt; daysIncrement then
				_invLine.setQuantityAndTotal(daysIncrement);
			else
				_invLine.setQuantityAndTotal(qty);
			endif;
			_invLine.setEscalatingValues(daysIncrement, count);
		else
			// currentLine is used for transaction resync
			idx := count - 1;		// _existingLines contains the lines after the first - count includes the first
			currentLine := null;
			if _existingLines &lt;&gt; null then
				if _existingLines.size &gt;= idx then
					currentLine := _existingLines[idx].CM_InvoiceLine;
				endif;
			endif;
			if currentLine &lt;&gt; null then
				newInvLine := currentLine;
				if canLogExtra	then								//10.10.2022 navma1 #5296700
					app.invLog(ild.narration &amp; " - Updating invoice line " &amp; newInvLine.sequenceNum.String &amp; ", invoice " &amp; newInvLine.invoice.sequenceNum.String &amp; ", debtor " &amp; debtor.name, LogINFO.String);
				endif;
			else
				// create new invoice lines for the remainder of the quantity, every 'daysIncrement'
				newInvLine := ild.createInvoiceLine(debtor, transaction);
				if newInvLine &lt;&gt; null then
					if canLogExtra	then								//10.10.2022 navma1 #52967
						app.invLog(ild.narration &amp; " - New invoice line " &amp; newInvLine.sequenceNum.String &amp; ", invoice " &amp; newInvLine.invoice.sequenceNum.String &amp; ", debtor " &amp; debtor.name, LogINFO.String);
					endif;
				endif;
			endif;
			if newInvLine &lt;&gt; null then
				newInvLine.setMyResourceTypeUsage(rtu);
				newInvLine.setEscalatingValues(daysIncrement, count);	// set before being used in rate calculation in next method
				newInvLine.setFromQuantityRangeMap(null);			// call this for the quantity and rate calculation
				if qty &gt; daysIncrement then
					newInvLine.setQuantityAndTotal(daysIncrement);
				else
					newInvLine.setQuantityAndTotal(qty);
				endif;
			endif;
		endif;
		first := false;
		qty := qty - daysIncrement;
		count := count + 1;
		if qty &lt;= 0 then
			break;
		endif;
	endwhile;
	
	// void any remaining existing invoice lines
	if _existingLines &lt;&gt; null then
		idx := idx + 1;
		if idx &lt;= _existingLines.size then
			count := idx;
			foreach idx in count to _existingLines.size do
				currentLine := _existingLines[idx].CM_InvoiceLine;
				if canLogExtra	then								//10.10.2022 navma1 #52967
					app.invLog("Invoice line " &amp; currentLine.sequenceNum.String &amp; " of invoice " &amp; currentLine.invoice.sequenceNum.String &amp; " voided", LogINFO.String);
				endif;
				currentLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			endforeach;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine" usage="input"/>
        <Parameter name="_existingLines" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="createInvLinesForEventTaskRsrc" id="269f1c83-922f-4263-94fb-764335096cba">
        <updating/>
        <source>createInvLinesForEventTaskRsrc( _aSBController : CMIF_ServiceBroker) updating;
/*

Purpose:			
		This method creates invoice line for Event Resources
Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	invLineDesc 					: CM_InvoiceLineDesc; 
	newInvLine 						: CM_InvoiceLine;
	idx 							: Integer;
	
	resourceTypeUsage 				: CM_ResourceTypeUsage;
	resourceCmifServiceBroker 		: CMIF_ServiceBroker;
	realServiceBroker 				: CM_ServiceBroker;
	realToDoResourceServiceBroker 	: CM_ToDoResourceServiceBroker;
	transaction						: CM_EventTransaction;
	
	debtor							: CM_Debtor;
	qrm 							: CM_QuantityRangeMap;
	
begin

	transaction := _aSBController.myEventTransaction;

	if transaction.allResourceUsages.isEmpty then
		// no resources used, nothing to do.
		return;
	endif;
	
	if _aSBController.myServiceBroker = null or not _aSBController.myServiceBroker.isEventServiceBroker() then
		return;
	endif;
	
	realServiceBroker := _aSBController.myServiceBroker.CM_EventServiceBroker;
	
	if realServiceBroker.allToDoResourceServiceBrokers.isEmpty then
		// no mappings for individual resource declared, nothing to do.
		return;
	endif;
	
	debtor := transaction.myDebtor;
	
	//get each of the resources type usages
	foreach resourceTypeUsage in transaction.allResourceUsages do
		
		// find the associated Resource Transaction Broker.
		realToDoResourceServiceBroker := realServiceBroker.allToDoResourceServiceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realToDoResourceServiceBroker = null then
			// no individual mapping for this one, skip it.
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myEventTransaction := transaction;
		realToDoResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		idx := 0;
		// create an invoice line for each invoice line description found in this mapping for this resource usage.
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes do
			idx := idx + 1;
			
			if invLineDesc = null or invLineDesc.isVoid then
				continue;
			endif;
			
			newInvLine := invLineDesc.createInvoiceLineEvent(debtor, transaction);
			
			if newInvLine &lt;&gt; null then
				qrm := null;
				if idx &lt;= _aSBController.allQuantityRangeMaps.size() then
					qrm := _aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setMyResourceTypeUsage(resourceTypeUsage); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
				newInvLine.setFromQuantityRangeMap(qrm);
				invLineDesc.checkForMinimumCharge(debtor, newInvLine, transaction);
			endif;
			
		endforeach;
		
		delete resourceCmifServiceBroker;
		
	endforeach;
	
epilog
	delete resourceCmifServiceBroker;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="createInvLinesForTaskResources" id="5fad0493-5ab2-49ea-99b3-2bea97b1171b">
        <updating/>
        <source>createInvLinesForTaskResources( _aSBController : CMIF_ServiceBroker ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/
vars

	invLineDesc : CM_InvoiceLineDesc; 
	newInvLine : CM_InvoiceLine;
	idx : Integer;
	
	resourceTypeUsage : CM_ResourceTypeUsage;
	resourceCmifServiceBroker : CMIF_ServiceBroker;
	realTransServiceBroker : CM_TransServiceBroker;
	realTransResourceServiceBroker : CM_TransResourceServiceBroker;
	transaction: CM_TITransaction;
	
begin

	transaction := _aSBController.myTransaction;

	if transaction.allResourceUsages.isEmpty then
		// no resources used, nothing to do.
		return;
	endif;
	
	//20 Apr 2017	NDL	TFS 4094
	if _aSBController.myServiceBroker &lt;&gt; null and not _aSBController.myServiceBroker.isKindOf(CM_TransServiceBroker) then
		return;
	endif;
	
	realTransServiceBroker := _aSBController.myServiceBroker.CM_TransServiceBroker;
	if realTransServiceBroker = null then
		// no Broker, somethings wrong here, bail.
		return;
	endif;
	
	if realTransServiceBroker.allResourceBrokers.isEmpty then
		// no mappings for individual resource declared, nothing to do.
		return;
	endif;
	
	//get each of the resources type usages
	foreach resourceTypeUsage in transaction.allResourceUsages do
		
		// find the associated Resource Transaction Broker.
		realTransResourceServiceBroker := realTransServiceBroker.allResourceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realTransResourceServiceBroker = null then
			// no individual mapping for this one, skip it.
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myTransaction := transaction;
		realTransResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		idx := 0;
		// create an invoice line for each invoice line description found in this mapping for this resource usage.
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes do

			idx := idx + 1;
			newInvLine := self.createInvoiceLine(	invLineDesc,	//_invLineDesc : CM_InvoiceLineDesc;
													transaction,	//_transaction: CM_TITransaction;
													resourceTypeUsage,	//_resourceTypeUsage : CM_ResourceTypeUsage
													idx,	//_index : Integer;
													resourceCmifServiceBroker	//_cmifServiceBroker : CMIF_ServiceBroker
													);
		endforeach;
		
		delete resourceCmifServiceBroker;
		
	endforeach;
	
epilog
	
	delete resourceCmifServiceBroker;
	
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="createInvLinesForWOTaskRsrc" id="5735974a-f2a7-4ff4-91d4-778d226f6cec">
        <updating/>
        <source>createInvLinesForWOTaskRsrc(_aSBController : CMIF_ServiceBroker) updating;
/*

Purpose:			
		This method creates invoice lines for WO Resources
Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	invLineDesc 					: CM_InvoiceLineDesc; 
	newInvLine 						: CM_InvoiceLine;
	idx 							: Integer;
	
	resourceTypeUsage 				: CM_ResourceTypeUsage;
	resourceCmifServiceBroker 		: CMIF_ServiceBroker;
	realServiceBroker 				: CM_ServiceBroker;
	realToDoResourceServiceBroker 	: CM_ToDoResourceServiceBroker;
	transaction						: CM_WOTransaction;
	
	debtor							: CM_Debtor;
	qrm 							: CM_QuantityRangeMap;
begin
	transaction := _aSBController.myTransactionWO;

	if transaction.allResourceUsages.isEmpty then
		// no resources used, nothing to do.
		return;
	endif;
	
	if _aSBController.myServiceBroker = null or not _aSBController.myServiceBroker.isWOServiceBroker() then
		return;
	endif;
	
	realServiceBroker := _aSBController.myServiceBroker.CM_WorkOrderServiceBroker;
	
	if realServiceBroker.allToDoResourceServiceBrokers.isEmpty then
		// no mappings for individual resource declared, nothing to do.
		return;
	endif;
	
	debtor := transaction.getMyDebtor();
	
	//get each of the resources type usages
	foreach resourceTypeUsage in transaction.allResourceUsages do
		
		// find the associated Resource Transaction Broker.
		realToDoResourceServiceBroker := realServiceBroker.allToDoResourceServiceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realToDoResourceServiceBroker = null then
			// no individual mapping for this one, skip it.
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myTransactionWO := transaction;
		realToDoResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		idx := 0;
		// create an invoice line for each invoice line description found in this mapping for this resource usage.
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes do
			idx := idx + 1;
			
			if invLineDesc = null or invLineDesc.isVoid then
				continue;
			endif;
			
			newInvLine := invLineDesc.createInvoiceLineWO(debtor, transaction);
			
			if newInvLine &lt;&gt; null then
				newInvLine.setMyResourceTypeUsage(resourceTypeUsage); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
				qrm := null;
				if idx &lt;= _aSBController.allQuantityRangeMaps.size() then
					qrm := _aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
				endif;
				newInvLine.setFromQuantityRangeMap(qrm);
				invLineDesc.checkForMinimumCharge(debtor, newInvLine, transaction);
			endif;
			
		endforeach;
		
		delete resourceCmifServiceBroker;
		
	endforeach;
epilog
	delete resourceCmifServiceBroker;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="createInventoryInvoiceLine" id="2ab64bf4-5f14-43ed-9292-54ded455ca8c">
        <source>createInventoryInvoiceLine(	_invLineDesc     : CM_InvoiceLineDesc input;
						   _transaction      : CMEVT_LocationActivity;
						   _index 		     : Integer;
						  _cmifServiceBroker : CMIF_ServiceBroker
					    ) 				     : CM_InvoiceLine protected;

/*
Purpose:			

Date		Who		Reason
31MAY2021	NAVAB1	TFS 51219
10 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	debtor 	    : CM_Debtor;
	newInvLine  : CM_InvoiceLine;
	qrm 		: CM_QuantityRangeMap;
	canLogExtra : Boolean;
begin
	
	canLogExtra := app.canLogExtraDetail();			//10.10.2022 navma1 #52967

	if _invLineDesc = null
	or _invLineDesc.isVoid
	then
		// this is a no action one
		if canLogExtra then							//10.10.2022 navma1 #52967
			if _invLineDesc &lt;&gt; null then
				app.invLog(_invLineDesc.narration &amp; " - Void invoice item, no invoice line created", LogINFO.String);
			elseif _invLineDesc.isVoid then
				app.invLog("Void invoice item, no invoice line created", LogINFO.String);
			endif;
		endif;
		return null;
	endif;
	
	debtor := _transaction.getDebtorForInvoiceLine(_invLineDesc); // TFS 42221
	if debtor &lt;&gt; null then
		newInvLine := _invLineDesc.createInvoiceLineInventory(debtor, _transaction);
		if newInvLine &lt;&gt; null then
			if canLogExtra  then                       //10.10.2022 navma1 #52967
				app.invLog(method.qualifiedName &amp; " " &amp; _invLineDesc.narration &amp; " - New invoice line " &amp; newInvLine.sequenceNum.String &amp; ", invoice " &amp; newInvLine.invoice.sequenceNum.String &amp; ", debtor " &amp; debtor.name, LogINFO.String);
			endif;
			
			qrm := null;
			if _index &lt;= _cmifServiceBroker.allQuantityRangeMaps.size then
				qrm := _cmifServiceBroker.allQuantityRangeMaps[_index].CM_QuantityRangeMap;
			endif;
			newInvLine.setFromQuantityRangeMap(qrm);
			
			// CCMS SFW 1279 May 2012 Storage Escalating Charges
			if qrm &lt;&gt; null and
			   qrm.myQuantityMap.mappingType = CM_QuantityMap.MapType_EscalateFull then
				self.createEscChargeLines(newInvLine, qrm, null);
			endif;
			
		endif;
	else
		app.raiseCMException2(ERR_TRANSACTION_MAP, _transaction.getDescription, "Debtor" , null, null);
	endif;

	return newInvLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc" usage="input"/>
        <Parameter name="_transaction" type="CMEVT_LocationActivity"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_cmifServiceBroker" type="CMIF_ServiceBroker"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceLine" id="7381e717-9efa-408c-be25-10e40d4c2153">
        <source>createInvoiceLine(	_invLineDesc	   : CM_InvoiceLineDesc input;
					_transaction	   : CM_TITransaction;
					_resourceTypeUsage : CM_ResourceTypeUsage;
					_index 			   : Integer;
					_cmifServiceBroker : CMIF_ServiceBroker
					) 				   : CM_InvoiceLine protected;

/*

Purpose:			
	Migrate common code to a common method
Parameters:			

Return Value:		


Date		Who		Reason
14/01/2010	cnwndl1	Initial creation	CCMS MES 1006
18/09/2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charge changes
11/01/2017	cnwdap1	TFS 3042 SNO Empty Container Pool Management
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
*/
vars
	debtor 		: CM_Debtor;
	newInvLine  : CM_InvoiceLine;
	qrm 		: CM_QuantityRangeMap;
	canLogExtra	: Boolean;
begin
	
	canLogExtra := app.canLogExtraDetail();		//05.10.2022 navma1 #52967

	if _invLineDesc = null
	or _invLineDesc.isVoid
	/* 29 Nov 2017	NDL	TFS 7852 - Take it out again
	or _invLineDesc.isNotAvailableForEntry		//18 Jul 2017	NDL	TFS 5449	*/
	then
		// this is a no action one
		if canLogExtra &lt;&gt; null then				//05.10.2022 navma1 #52967
			if _invLineDesc &lt;&gt; null then
				app.invLog(_invLineDesc.narration &amp; " - Void invoice item, no invoice line created", LogTRACE.String);
			elseif _invLineDesc.isVoid then
				app.invLog("Void invoice item, no invoice line created", LogTRACE.String);
			endif;
		endif;
		return null;
	endif;
	
	//09 Mar 2010 NDL	Par 22813
	if _resourceTypeUsage &lt;&gt; null and _resourceTypeUsage.noCharge then
		
		if canLogExtra then														//05.10.2022 navma1 #52967
			// this is a no action one too.
			app.invLog(_invLineDesc.narration &amp; " - No-charge resource, no invoice line created", LogINFO.String);
		endif;
		return null; 
	endif;

	debtor := _transaction.getDebtorForInvoiceLine(_invLineDesc); // TFS 42221

	if debtor &lt;&gt; null then
		newInvLine := _invLineDesc.createInvoiceLine(debtor, _transaction);
		if newInvLine &lt;&gt; null then
			
			if canLogExtra then														//05.10.2022 navma1 #52967
				app.invLog(method.qualifiedName &amp; " " &amp; _invLineDesc.narration &amp; " - New invoice line " &amp; newInvLine.sequenceNum.String &amp; ", invoice " &amp; newInvLine.invoice.sequenceNum.String &amp; ", debtor " &amp; debtor.name, LogINFO.String);
			endif;
			
			newInvLine.setMyResourceTypeUsage(_resourceTypeUsage);
			qrm := null;
			if _index &lt;= _cmifServiceBroker.allQuantityRangeMaps.size then
				qrm := _cmifServiceBroker.allQuantityRangeMaps[_index].CM_QuantityRangeMap;
			endif;
			newInvLine.setFromQuantityRangeMap(qrm);
			
			// CCMS SFW 1279 May 2012 Storage Escalating Charges
			if qrm &lt;&gt; null and
			   qrm.myQuantityMap.mappingType = CM_QuantityMap.MapType_EscalateFull then
				self.createEscChargeLines(newInvLine, qrm, null);
			endif;
			
			_invLineDesc.checkForMinimumCharge(debtor, newInvLine, _transaction);				// PAR #36909
			
			_invLineDesc.doEmptyPoolPartyCalculations(debtor, newInvLine, _transaction);	// TFS 3042
			
			newInvLine.setTaxDetails(); // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
			newInvLine.setTotalAmount(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
		endif;
	else
		app.raiseCMException2(ERR_TRANSACTION_MAP, _transaction.myTrackedItem.id, "Debtor" , null, null);
	endif;

	return newInvLine;
			
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc" usage="input"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_resourceTypeUsage" type="CM_ResourceTypeUsage"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_cmifServiceBroker" type="CMIF_ServiceBroker"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createTransResourceInvLines" id="aa2ef561-5b69-45a6-b742-ed036d88eec8">
        <updating/>
        <source>createTransResourceInvLines( _aSBController : CMIF_ServiceBroker; _oa : ObjectArray input; _invoice : CM_Invoice ) updating;

/*

Purpose:			Unprotected for 35365

Parameters:			

Return Value:		


Date		Who		Reason
13 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/
vars

	invLineDesc : CM_InvoiceLineDesc; 
	newInvLine : CM_InvoiceLine;
	idx : Integer;
	
	resourceTypeUsage : CM_ResourceTypeUsage;
	resourceCmifServiceBroker : CMIF_ServiceBroker;
	realTransServiceBroker : CM_TransServiceBroker;
	realTransResourceServiceBroker : CM_TransResourceServiceBroker;
	transaction: CM_TITransaction;
	
begin

	transaction := _aSBController.myTransaction;

	if transaction.allResourceUsages.isEmpty then
		// no resources used, nothing to do.
		return;
	endif;
	
	realTransServiceBroker := _aSBController.myServiceBroker.CM_TransServiceBroker;
	if realTransServiceBroker = null then
		// no Broker, somethings wrong here, bail.
		return;
	endif;
	
	if realTransServiceBroker.allResourceBrokers.isEmpty then
		// no mappings for individual resource declared, nothing to do.
		return;
	endif;
	
	//get each of the resources type usages
	foreach resourceTypeUsage in transaction.allResourceUsages do
		
		// find the associated Resource Transaction Broker.
		realTransResourceServiceBroker := realTransServiceBroker.allResourceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realTransResourceServiceBroker = null then
			// no individual mapping for this one, skip it.
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myTransaction := transaction;
		realTransResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		idx := 0;
		// create an invoice line for each invoice line description found in this mapping for this resource usage.
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes do
			
			idx := idx + 1;
			newInvLine := self.createTransientInvoiceLine(	invLineDesc,	//_invLineDesc : CM_InvoiceLineDesc;
															_invoice,		//
															transaction,	//_transaction: CM_TITransaction;
															resourceTypeUsage,	//_resourceTypeUsage : CM_ResourceTypeUsage
															idx,	//_index : Integer;
															resourceCmifServiceBroker	//_cmifServiceBroker : CMIF_ServiceBroker
															);
			if newInvLine &lt;&gt; null then
				_oa.add(newInvLine);
			endif;
		endforeach;
		
		delete resourceCmifServiceBroker;
		
	endforeach;
	
epilog
	
	delete resourceCmifServiceBroker;
	
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker"/>
        <Parameter name="_oa" type="ObjectArray" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="createTransientInvoice" id="02fb6921-59ed-45b8-a1fc-95db64ef223d">
        <source>createTransientInvoice(_invoiceType : CM_InvoiceDesc; _invLineType : CM_InvoiceLineDesc; _debtor : CM_Debtor) : CM_Invoice;
// 14/04/2016 from Milaha cash checking, create a transient invoice specially for the transient invoice lines
vars
	invoice		: CM_Invoice;
	paymentType : Integer;	//10 Oct 2018	NDL	TFS 41281
begin

	//10 Oct 2018	NDL	TFS 41281
	if _invLineType &lt;&gt; null then
		paymentType := _invLineType.getPaymentType( _debtor );
	endif;
	
	create invoice transient;
	invoice.transientInitialise(self, _invoiceType, _debtor, paymentType);
	return invoice;
	
epilog

end;
</source>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="createTransientInvoiceLine" id="334dd9b9-7ed2-43df-ab2d-ca9ac66febee">
        <source>createTransientInvoiceLine(	_invLineDesc : CM_InvoiceLineDesc input;
					_invoice : CM_Invoice;
					_transaction : CM_TITransaction;
					_resourceTypeUsage : CM_ResourceTypeUsage;
					_index : Integer;
					_cmifServiceBroker : CMIF_ServiceBroker
					) : CM_InvoiceLine protected;

/*

Purpose:			
	Migrate common code to a common method
Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars
	debtor : CM_Debtor;
	newInvLine : CM_InvoiceLine;
	qrm : CM_QuantityRangeMap;
	
begin

	if _invLineDesc = null
	or _invLineDesc.isVoid
	then
		return null;
	endif;
	
	if _resourceTypeUsage &lt;&gt; null and _resourceTypeUsage.noCharge then
		// this is a no action one too.
		return null;
	endif;

	debtor := _transaction.getDebtorForInvoiceLine(_invLineDesc); // TFS 42221
	// TFS 42221	debtor := _invLineDesc.getDebtorFromTransaction(_transaction);
	if debtor &lt;&gt; null then
		newInvLine := _invLineDesc.createTransientInvoiceLine(debtor, _invoice, _transaction, _index);
		if newInvLine &lt;&gt; null then
			newInvLine.setMyResourceTypeUsage(_resourceTypeUsage);
			qrm := null;
			if _index &lt;= _cmifServiceBroker.allQuantityRangeMaps.size then
				qrm := _cmifServiceBroker.allQuantityRangeMaps[_index].CM_QuantityRangeMap;
			endif;
				newInvLine.setFromQuantityRangeMap(qrm);
			// CCMS SFW 1279 Storage Escalating Charges
			if qrm &lt;&gt; null and
			   qrm.myQuantityMap.mappingType = CM_QuantityMap.MapType_EscalateFull then
				self.createEscChargeLines(newInvLine, qrm, null);
			endif;
		endif;
	else
		app.raiseCMException2(ERR_TRANSACTION_MAP, _transaction.myTrackedItem.id, "Debtor" , null, null);
	endif;
	
	return newInvLine;
			
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_resourceTypeUsage" type="CM_ResourceTypeUsage"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_cmifServiceBroker" type="CMIF_ServiceBroker"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createTransientInvoiceLine2" id="c0f518c4-b148-46f6-b1e7-83ca4ecc1458">
        <source>createTransientInvoiceLine2(_invLineDesc : CM_InvoiceLineDesc input;
					_invoice : CM_Invoice;
					_transaction : CM_TITransaction;
					_resourceTypeUsage : CM_ResourceTypeUsage;
					_index : Integer;
					_qrm : CM_QuantityRangeMap
					) : CM_InvoiceLine ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16/01/2015	cnwjre1	35365 copy of createTransientInvoiceLine for finding grouped invoice line types

*/

vars
	debtor : CM_Debtor;
	newInvLine : CM_InvoiceLine;
	qrm : CM_QuantityRangeMap;
	
begin

	if _invLineDesc = null
	or _invLineDesc.isVoid
	then
		return null;
	endif;
	
	if _resourceTypeUsage &lt;&gt; null and _resourceTypeUsage.noCharge then
		// this is a no action one too.
		return null;
	endif;

	debtor := _transaction.getDebtorForInvoiceLine(_invLineDesc); // TFS 42221
	// TFS 42221	debtor := _invLineDesc.getDebtorFromTransaction(_transaction);
	if debtor &lt;&gt; null then
		newInvLine := _invLineDesc.createTransientInvoiceLine(debtor, _invoice, _transaction, _index);
		if newInvLine &lt;&gt; null then
			newInvLine.setMyResourceTypeUsage(_resourceTypeUsage);
			qrm := _qrm;
			newInvLine.setFromQuantityRangeMap(qrm);
			// CCMS SFW 1279 Storage Escalating Charges
			if qrm &lt;&gt; null and
			   qrm.myQuantityMap.mappingType = CM_QuantityMap.MapType_EscalateFull then
				self.createEscChargeLines(newInvLine, qrm, null);
			endif;
		endif;
	else
		app.raiseCMException2(ERR_TRANSACTION_MAP, _transaction.myTrackedItem.id, "Debtor" , null, null);
	endif;
	
	return newInvLine;
			
epilog

end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_resourceTypeUsage" type="CM_ResourceTypeUsage"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_qrm" type="CM_QuantityRangeMap"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6133e9f8-a1a2-4645-ab93-38b7ba9ef317">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
// 21 Dec 2016	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	//15 Jul 2016	NDL	TFS 2329
	iter : Iterator;
	cmqfI : CMQF_Invoice;
	cmqfIL : CMQF_InvoiceLine;
	
begin

	//15 Jul 2016	NDL	TFS 2329
	iter := CMQF_Invoice.instances.createIterator;
	while iter.next(cmqfI) do
		if cmqfI.allCompaniesByCode.includes(self) then
			cmqfI.allCompaniesByCode.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	iter := CMQF_InvoiceLine.instances.createIterator;
	while iter.next(cmqfIL) do
		if cmqfIL.allCompanies.includes(self) then
			cmqfIL.allCompanies.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
	delete self.allBankDetails;
	// invoice line types are peer-to-peer, need to explicitly purge to remove the VOID one
	self.invoiceLineDescriptors.purge();
	
epilog

	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteInvoiceLineChargeMapping" id="edd6b2c5-0736-426d-be45-e2d5342f54ba">
        <source>deleteInvoiceLineChargeMapping(_parent : CM_Object);
// ---------------------------------------------------------------------------
// Created:		20 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aMap : CM_InvoiceLineChargeMapping;
	delMe : ObjectSet;
begin
	create delMe transient;
	
	foreach aMap in self.allInvLineChargeMappings discreteLock do
		if aMap.myParentMappingObject = _parent then
			delMe.add(aMap);
		endif;
	endforeach;
	
	delMe.purge;
epilog
	delete delMe;
end;</source>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="85197b65-39f0-4f1f-a330-b9483b374693">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2019	jlgzm1	Initial creation TFS 7286 Additional stable collections required to improve performance

*/

vars
	criteria 	: CM_ProformaTransactionCriteria;
	tranMap 	: CM_TranMap;
begin
	inheritMethod(_converter, _logIndent);
	
	_converter.doChangeVolatilityOfObject(self.allDebtorBankInvTypeDtls, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allFinancialPeriods, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allInvLineChargeMappings, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allProformaCriteria, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allTaxCodes, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allWorkOrderTranMaps, _logIndent);
	_converter.doChangeVolatilityOfObject(self.services, _logIndent);
	_converter.doChangeVolatilityOfObject(self.subCompanies, _logIndent);
	
	foreach criteria in self.allProformaCriteria discreteLock do
		//_converter.logMessage("Processing collections for " &amp; criteria.String, _logIndent);			navma1 14.01.2026
		criteria.doObjectVolatilityConversion(_converter, _logIndent + 1);
		//_converter.logMessage("Finished processing collections for " &amp; criteria.String, _logIndent);	navma1 14.01.2026
	endforeach;
	
	foreach tranMap in self.myCurrentTranMapCargo discreteLock do
		//_converter.logMessage("Processing collections for " &amp; tranMap.String, _logIndent);			navma1 14.01.2026
		tranMap.doObjectVolatilityConversion(_converter, _logIndent + 1);
		//_converter.logMessage("Finished processing collections for " &amp; tranMap.String, _logIndent);	navma1 14.01.2026
	endforeach;

epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResyncLinesForEventTaskRsrc" id="1cd5bb2d-f63b-46d6-b5e2-e5aa7ad89184">
        <source>doResyncLinesForEventTaskRsrc( aSBController : CMIF_ServiceBroker );
/*

Purpose:			
		This method resync the invoice lines for event resources
Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
//22.06.2024 navrv30 Task 64598: Jade - ReserveLock on Invoice
*/

vars

	transaction					: CM_EventTransaction;
	realEventServiceBroker 		: CM_EventServiceBroker;
	callingBank 				: CM_Bank;
	transactionBank 			: CM_Bank;
	resyncedInvoiceLines 		: CM_InvoiceLineByDateTimeDict;
	invLine 					: CM_InvoiceLine;
	resourceTypeUsage 			: CM_ResourceTypeUsage;
	realResourceServiceBroker 	: CM_ToDoResourceServiceBroker;
	resourceCmifServiceBroker 	: CMIF_ServiceBroker;
	invLineDesc 				: CM_InvoiceLineDesc;
	found 						: Boolean;
	idx 						: Integer;
	existingInvLine 			: CM_InvoiceLine;
	debtor 						: CM_Debtor;
	newInvLine 					: CM_InvoiceLine;
	qrm 						: CM_QuantityRangeMap;
	inv : CM_Invoice;
	invoices : CM_InvoiceSet;
begin
	if aSBController.myServiceBroker = null then
		return;
	endif;
	
	if not aSBController.myServiceBroker.isEventServiceBroker() then
		return;
	endif;
	
	create invoices transient; // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1

	transaction := aSBController.myEventTransaction;
	realEventServiceBroker := aSBController.myServiceBroker.CM_EventServiceBroker;
	callingBank := aSBController.myBank;
	transactionBank := transaction.getBank();
	create resyncedInvoiceLines transient;

	// Void or Resync all existing invoice lines that are resource based.
	foreach invLine in transaction.allInvoiceLines discreteLock do
	
		if not invLine.isResourceUsageBased then
			// not one resource based, skip it
			continue;
		endif;
		
		if invoices.tryAddIfNotNull(invLine.invoice) then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
			reserveLock(invLine.invoice);              //22.06.2024 navrv30 Task 64598
		endif;
		if transactionBank &lt;&gt; null and transactionBank &lt;&gt; callingBank then
			// Cm_Bank has changed on the transaction.
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		if realEventServiceBroker = null then
			// Mapping to the individual event type is no longer there.
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		resourceTypeUsage := invLine.myResourceTypeUsage;
		
		if resourceTypeUsage.isVoid then
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		//18 Mar 2010 NDL Par 22813
		if resourceTypeUsage.noCharge then
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		realResourceServiceBroker := realEventServiceBroker.allToDoResourceServiceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realResourceServiceBroker = null then
			// Mapping to the individual ResourceType within the mapped event type is no longer there.
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myEventTransaction := transaction;
		realResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		found := false;
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes discreteLock do
			if invLine.invoiceLineDesc = invLineDesc then		
				invLine.recalculate();
				resyncedInvoiceLines.add(invLine);
				found := true;
				break;
			endif;
		endforeach;
		delete resourceCmifServiceBroker;
		
		if not found then
			// if we get to here he is no longer a valid invLineDesc 
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
			
	endforeach;
	
	debtor := transaction.myDebtor;
	
	//Check each of the resource usages to see if we need to 'add' any Invoice lines. 
	foreach resourceTypeUsage in transaction.allResourceUsages do 

		if resourceTypeUsage.isVoid then
			continue;
		endif;
	
		realResourceServiceBroker := realEventServiceBroker.allToDoResourceServiceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realResourceServiceBroker = null then
			// no broker means no individual mapping for this one, nothing to do skip it.
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myEventTransaction := transaction;
		realResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		idx := 0;
		// check for a resynced invoice line description for each resource usage / inv desc combination
		// create a new invoiceline if a resynced one doesn't already exist.
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes do
			idx := idx + 1;
			if invLineDesc = null or invLineDesc.isVoid then
				// this is a no action one
				continue;
			endif;
			
			existingInvLine := null;
			//find the existing matching invoice line in the resynced trans.
			foreach invLine in resyncedInvoiceLines discreteLock do
				if invLine.myResourceTypeUsage &lt;&gt; resourceTypeUsage then
					continue;
				endif;
				if invLine.invoiceLineDesc &lt;&gt; invLineDesc then
					continue;
				endif;
				existingInvLine := invLine;
				break;
			endforeach;

			if existingInvLine = null then
				// create a new Invoice Line for this one.
				newInvLine := invLineDesc.createInvoiceLineEvent(debtor, transaction);
				if newInvLine &lt;&gt; null then
					qrm := null;
					if idx &lt;= aSBController.allQuantityRangeMaps.size then
						qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
					endif;
					newInvLine.setFromQuantityRangeMap(qrm);
					invLineDesc.checkForMinimumCharge(debtor, newInvLine, transaction);	
					
					if invoices.tryAddIfNotNull(newInvLine.invoice) then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
						reserveLock(newInvLine.invoice);              //22.06.2024 navrv30 Task 64598
					endif;
				endif;
			endif;
			
		endforeach;
		
		delete resourceCmifServiceBroker;
		
	endforeach;
	
	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	foreach inv in invoices do
		inv.setTaxDetailsFromLines();
		inv.setTotalAmountFromLines();
	endforeach;

epilog 
	delete invoices;
	delete resourceCmifServiceBroker;
	delete resyncedInvoiceLines;
	
end;</source>
        <Parameter name="aSBController" type="CMIF_ServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="doResyncLinesForTaskResources" id="bb58da58-8bd8-4405-84ce-ecc4dfbf8f2c">
        <source>doResyncLinesForTaskResources( aSBController : CMIF_ServiceBroker );

/*

Purpose:	

			Method Only reSyncs Resource Usage based Invoice Lines

Parameters:			

Return Value:		


Date		Who		Reason
13 January 2010	cnwndl1	Initial creation	CCMS MES 1006
22.06.2024 navrv30 Task 64598: Jade - ReserveLock on Invoice
*/

vars

	transaction: CM_TITransaction;
	realTransServiceBroker : CM_TransServiceBroker;
	callingBank : CM_Bank;
	transactionBank : CM_Bank;
	resyncedInvoiceLines : CM_InvoiceLineByDateTimeDict;
	invLine : CM_InvoiceLine;
	resourceTypeUsage : CM_ResourceTypeUsage;
	realTransResourceServiceBroker : CM_TransResourceServiceBroker;
	resourceCmifServiceBroker : CMIF_ServiceBroker;
	invLineDesc : CM_InvoiceLineDesc;
	found : Boolean;
	idx : Integer;
	existingInvLine : CM_InvoiceLine;
	debtor : CM_Debtor;
	newInvLine : CM_InvoiceLine;
	qrm : CM_QuantityRangeMap;
	inv : CM_Invoice;
	invoices : CM_InvoiceSet;
	
	
begin
	//epr par 36162 28/5/15
	if aSBController.myServiceBroker = null then
		return;
	endif;
	
	// PAR 29570 MOVES do not use resources
	if not aSBController.myServiceBroker.isTransServiceBroker() then
		return;
	endif;
	
	create invoices transient; // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1

	transaction := aSBController.myTransaction;
	realTransServiceBroker := aSBController.myServiceBroker.CM_TransServiceBroker;
	callingBank := aSBController.myBank;
	transactionBank := transaction.getBusinessUnitObject();
	create resyncedInvoiceLines transient;

	// Void or Resync all existing invoice lines that are resource based.
	foreach invLine in transaction.allInvoiceLines discreteLock do
	
		if not invLine.isResourceUsageBased then
			// not one resource based, skip it
			continue;
		endif;
		
		if invoices.tryAddIfNotNull(invLine.invoice) then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
			reserveLock(invLine.invoice);              //22.06.2024 navrv30 Task 64598
		endif;

		if transactionBank &lt;&gt; null and transactionBank &lt;&gt; callingBank then
			// Cm_Bank has changed on the transaction.
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		if realTransServiceBroker = null then
			// Mapping to the individual transaction type(Commodity) is no longer there.
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		resourceTypeUsage := invLine.myResourceTypeUsage;
		
		if resourceTypeUsage.isVoid then
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		//18 Mar 2010 NDL Par 22813
		if resourceTypeUsage.noCharge then
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		realTransResourceServiceBroker := realTransServiceBroker.allResourceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realTransResourceServiceBroker = null then
			// Mapping to the individual ResourceType within the mapped transaction type(Commodity) is no longer there.
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myTransaction := transaction;
		realTransResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		found := false;
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes discreteLock do
			if invLine.invoiceLineDesc = invLineDesc then		
				invLine.recalculate();		// CCMS 1264 May 2012 rate and quantity no longer dynamic
				invLine.updateFromTransactionResync(transaction);
				resyncedInvoiceLines.add(invLine);
				found := true;
				break;
			endif;
		endforeach;
		delete resourceCmifServiceBroker;
		
		if not found then
			// if we get to here he is no longer a valid invLineDesc 
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
			
	endforeach;
	
	
	//Check each of the resource usages to see if we need to 'add' any Invoice lines. 
	foreach resourceTypeUsage in transaction.allResourceUsages do 

		if resourceTypeUsage.isVoid then
			continue;
		endif;
	
		realTransResourceServiceBroker := realTransServiceBroker.allResourceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realTransResourceServiceBroker = null then
			// no broker means no individual mapping for this one, nothing to do skip it.
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myTransaction := transaction;
		realTransResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		idx := 0;
		// check for a resynced invoice line description for each resource usage / inv desc combination
		// create a new invoiceline if a resynced one doesn't already exist.
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes do
			idx := idx + 1;
			if invLineDesc = null or invLineDesc.isVoid then
				// this is a no action one
				continue;
			endif;
			
			existingInvLine := null;
			//find the existing matching invoice line in the resynced trans.
			foreach invLine in resyncedInvoiceLines discreteLock do
				if invLine.myResourceTypeUsage &lt;&gt; resourceTypeUsage then
					continue;
				endif;
				if invLine.invoiceLineDesc &lt;&gt; invLineDesc then
					continue;
				endif;
				existingInvLine := invLine;
				break;
			endforeach;

			if existingInvLine = null then
				// create a new Invoice Line for this one.
				newInvLine := self.createInvoiceLine(	invLineDesc,	//_invLineDesc : CM_InvoiceLineDesc;
														transaction,	//_transaction: CM_TITransaction;
														resourceTypeUsage,	//_resourceTypeUsage : CM_ResourceTypeUsage
														idx,	//_index : Integer;
														resourceCmifServiceBroker	//_cmifServiceBroker : CMIF_ServiceBroker
														);
				
				if invoices.tryAddIfNotNull(newInvLine.invoice) then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
					reserveLock(newInvLine.invoice);              //22.06.2024 navrv30 Task 64598
				endif;
			endif;
			
		endforeach;
		
		delete resourceCmifServiceBroker;
		
	endforeach;
	
	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	foreach inv in invoices do
		inv.setTaxDetailsFromLines();
		inv.setTotalAmountFromLines();
	endforeach;

epilog 
	delete invoices;
	delete resourceCmifServiceBroker;
	delete resyncedInvoiceLines;
	
end;</source>
        <Parameter name="aSBController" type="CMIF_ServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="doResyncLinesForWOTaskRsrc" id="52bf688c-8fa6-4a21-acf7-abdf0a391880">
        <source>doResyncLinesForWOTaskRsrc(aSBController : CMIF_ServiceBroker);
/*

Purpose:			
		This method resync the invoice lines for WO resources
Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
22.06.2024 navrv30 Task 64598: Jade - ReserveLock on Invoice
*/

vars
	transaction					: CM_WOTransaction;
	realWOServiceBroker 		: CM_WorkOrderServiceBroker;
	callingBank 				: CM_Bank;
	transactionBank 			: CM_Bank;
	resyncedInvoiceLines 		: CM_InvoiceLineByDateTimeDict;
	invLine 					: CM_InvoiceLine;
	resourceTypeUsage 			: CM_ResourceTypeUsage;
	realResourceServiceBroker 	: CM_ToDoResourceServiceBroker;
	resourceCmifServiceBroker 	: CMIF_ServiceBroker;
	invLineDesc 				: CM_InvoiceLineDesc;
	found 						: Boolean;
	idx 						: Integer;
	existingInvLine 			: CM_InvoiceLine;
	debtor 						: CM_Debtor;
	newInvLine 					: CM_InvoiceLine;
	qrm 						: CM_QuantityRangeMap;
	inv : CM_Invoice;
	invoices : CM_InvoiceSet;
	
begin
	if aSBController.myServiceBroker = null then
		return;
	endif;
	
	if not aSBController.myServiceBroker.isWOServiceBroker() then
		return;
	endif;
	
	create invoices transient;// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1

	transaction := aSBController.myTransactionWO;
	realWOServiceBroker := aSBController.myServiceBroker.CM_WorkOrderServiceBroker;
	callingBank := aSBController.myBank;
	transactionBank := transaction.getMyBank();
	create resyncedInvoiceLines transient;

	// Void or Resync all existing invoice lines that are resource based.
	foreach invLine in transaction.allInvoiceLines discreteLock do
	
		if not invLine.isResourceUsageBased then
			// not one resource based, skip it
			continue;
		endif;
		
		if invoices.tryAddIfNotNull(invLine.invoice) then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
			reserveLock(invLine.invoice);              //22.06.2024 navrv30 Task 64598
		endif;

		if transactionBank &lt;&gt; null and transactionBank &lt;&gt; callingBank then
			// Cm_Bank has changed on the transaction.
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		if realWOServiceBroker = null then
			// Mapping to the individual event type is no longer there.
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		resourceTypeUsage := invLine.myResourceTypeUsage;
		
		if resourceTypeUsage.isVoid then
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		//18 Mar 2010 NDL Par 22813
		if resourceTypeUsage.noCharge then
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		realResourceServiceBroker := realWOServiceBroker.allToDoResourceServiceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realResourceServiceBroker = null then
			// Mapping to the individual ResourceType within the mapped event type is no longer there.
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myTransactionWO := transaction;
		realResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		found := false;
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes discreteLock do
			if invLine.invoiceLineDesc = invLineDesc then		
				invLine.recalculate();
				resyncedInvoiceLines.add(invLine);
				found := true;
				break;
			endif;
		endforeach;
		delete resourceCmifServiceBroker;
		
		if not found then
			// if we get to here he is no longer a valid invLineDesc 
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
			
	endforeach;
	
	debtor := transaction.getMyDebtor();
	
	//Check each of the resource usages to see if we need to 'add' any Invoice lines. 
	foreach resourceTypeUsage in transaction.allResourceUsages do 

		if resourceTypeUsage.isVoid then
			continue;
		endif;
	
		realResourceServiceBroker := realWOServiceBroker.allToDoResourceServiceBrokers.getAtKey(resourceTypeUsage.myResourceType);
		if realResourceServiceBroker = null then
			// no broker means no individual mapping for this one, nothing to do skip it.
			continue;
		endif;
		
		// get a coll of the invLineDesc's for the 'Resource Type' mapping of this Resource type usage.
		create resourceCmifServiceBroker transient;
		resourceCmifServiceBroker.myTransactionWO := transaction;
		realResourceServiceBroker.getInvoiceLineDesc(resourceCmifServiceBroker);
		
		idx := 0;
		// check for a resynced invoice line description for each resource usage / inv desc combination
		// create a new invoiceline if a resynced one doesn't already exist.
		foreach invLineDesc in resourceCmifServiceBroker.allInvoiceLineTypes do
			idx := idx + 1;
			if invLineDesc = null or invLineDesc.isVoid then
				// this is a no action one
				continue;
			endif;
			
			existingInvLine := null;
			//find the existing matching invoice line in the resynced trans.
			foreach invLine in resyncedInvoiceLines discreteLock do
				if invLine.myResourceTypeUsage &lt;&gt; resourceTypeUsage then
					continue;
				endif;
				if invLine.invoiceLineDesc &lt;&gt; invLineDesc then
					continue;
				endif;
				existingInvLine := invLine;
				break;
			endforeach;

			if existingInvLine = null then
				// create a new Invoice Line for this one.
				newInvLine := invLineDesc.createInvoiceLineWO(debtor, transaction);
				if newInvLine &lt;&gt; null then
					newInvLine.setMyResourceTypeUsage(resourceTypeUsage); // ### JIRA 23013 17OCT2024 NAVAB1

					qrm := null;
					if idx &lt;= aSBController.allQuantityRangeMaps.size then
						qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
					endif;
					newInvLine.setFromQuantityRangeMap(qrm);
					invLineDesc.checkForMinimumCharge(debtor, newInvLine, transaction);	
					
					if invoices.tryAddIfNotNull(newInvLine.invoice) then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
						reserveLock(newInvLine.invoice);              //22.06.2024 navrv30 Task 64598
					endif;
				endif;
			endif;
			
		endforeach;
		
		delete resourceCmifServiceBroker;
		
	endforeach;
	
	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	foreach inv in invoices do
		inv.setTaxDetailsFromLines();
		inv.setTotalAmountFromLines();
	endforeach;

epilog 
	delete invoices;
	delete resourceCmifServiceBroker;
	delete resyncedInvoiceLines;
	
end;</source>
        <Parameter name="aSBController" type="CMIF_ServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="doUpdateInvoiceStatusBulk" id="78d7c9d5-e3df-4def-82ad-98c4a023c287">
        <updating/>
        <source>doUpdateInvoiceStatusBulk(_seqFrom, _seqTo : Integer; _oldStatus, _newStatus : Integer; _invType : CM_InvoiceDesc) updating;
// ---------------------------------------------------------------------------
// Created:		26 January 2007 By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1514
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 10/04/2018	jlgdap1		TFS 37858 PEL1 Invocie Status Advancement
vars
	theStatus : CMIF_InvoiceStatus;
	theInvoice, pxyInvoice : CM_Invoice;
	iter : Iterator;
	today : TimeStamp;
	anAudit, proxyAudit : CM_Audit;
	passPort : CM_Passport;
	invRemarks : String;
	newInvoiceStatus : CM_InvoiceStatus; // TFS 39618
begin
	if _newStatus &lt;&gt; CM_Invoice.INVOICE_POSTED
	and _newStatus &lt;&gt; CM_Invoice.INVOICE_VOID
	and _newStatus &lt;&gt; CM_Invoice.INVOICE_POSTED_CREDIT	//04 Sep 2017	NDL	TFS 6759
	and _newStatus &lt;&gt; CM_Invoice.INVOICE_POSTED_REVERSE	//04 Sep 2017	NDL	TFS 6759		
	then
		return;
	endif;
	
	invRemarks := "Bulk Status Change To Posted. Auto Qualifying Audits.";
	
	passPort := app.myPassport;
	
	iter := self.invoicesByStatus.createIterator;
	self.invoicesByStatus.startKeyGeq(_oldStatus, iter);
	create theStatus transient;
	theStatus.newStatus := _newStatus;

	
	if _newStatus = CM_Invoice.INVOICE_POSTED then
		theStatus.narration := "Bulk Status Change";
		theStatus.toDT.setDate(today.date);
		theStatus.toDT.setTime(today.time);
	endif;
	
	while iter.next(theInvoice) do

		if theInvoice.status &lt;&gt; _oldStatus then
			break;
		endif;
		if _invType &lt;&gt; null and theInvoice.invoiceType &lt;&gt; _invType then
			continue;
		endif;
		
		if _seqFrom &lt;&gt; 0 and theInvoice.sequenceNum &lt;  _seqFrom then
			continue;
		endif;
		if _seqTo &lt;&gt; 0 and theInvoice.sequenceNum &gt;  _seqTo then
			continue;
		endif;
		
		beginTransaction;

		if _newStatus = CM_Invoice.INVOICE_POSTED then
			foreach anAudit in theInvoice.unqualifiedAudits discreteLock do
				proxyAudit := app.createUpdateProxy(anAudit).CM_Audit;
				proxyAudit.clearingRemarks := invRemarks;
				exclusiveLock(anAudit);
				anAudit.setForUpdate(proxyAudit,theInvoice,passPort);
				delete proxyAudit;
			endforeach;
		
		endif;
		
		pxyInvoice := app.createUpdateProxy(theInvoice).CM_Invoice;
		theStatus.myInvoice := theInvoice;
		if  theInvoice.toDT.isValid() then
			theStatus.toDT := theInvoice.toDT;
		else
			theStatus.toDT := today;
		endif;
		//theInvoice.setForUpdateStatus(theStatus);			// TFS 37858
		theInvoice.setForUpdateStatus(theStatus, false);	// TFS 37858
		delete pxyInvoice;
		commitTransaction;
		
	endwhile;
epilog
	delete iter;
	delete theStatus;
end;</source>
        <Parameter name="_seqFrom" type="Integer"/>
        <Parameter name="_seqTo" type="Integer"/>
        <Parameter name="_oldStatus" type="Integer"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_invType" type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="evaluateDays" id="d3ead5b8-7221-4a74-be5f-f6dc0220d3be">
        <source>evaluateDays(startTimeStamp: TimeStamp; endTimeStamp: TimeStamp): Real;
/*
20 May 2024 navrv30 Bug 64181: EUP - 4013 error in UAT system
*/
vars

begin
	if startTimeStamp.isValid() and endTimeStamp.isValid() then
		return (endTimeStamp.date - startTimeStamp.date);
	endif;
	return 0;
end;</source>
        <Parameter name="startTimeStamp" type="TimeStamp"/>
        <Parameter name="endTimeStamp" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="evaluateDaysCalendar" id="7ae0d4b1-c30c-4f64-98ae-1569c25ec978">
        <source>evaluateDaysCalendar(_startTimeStamp: TimeStamp; _endTimeStamp: TimeStamp; _workingDays : Boolean; _compulsoryDays : Boolean; _tiTrx : CM_TITransaction): Real;
// CCMS 1295 free storage days
vars

	storageConfigType : CM_StorageConfigType;

begin

	// re-write for TFS 7032	NDL	06 Nov 2017
	storageConfigType := self.terminal.getMyStorageConfigType;
	return storageConfigType.evaluateDaysCalendar(	self.terminal,	//_term : CM_Terminal;
													_startTimeStamp,	//_startTimeStamp: TimeStamp;
													_endTimeStamp,	//_endTimeStamp: TimeStamp;
													_workingDays,	//_workingDays : Boolean;
													_compulsoryDays,	//_compulsoryDays : Boolean;
													_tiTrx	//_tiTrx : CM_TITransaction
													);
	
end;
</source>
        <Parameter name="_startTimeStamp" type="TimeStamp"/>
        <Parameter name="_endTimeStamp" type="TimeStamp"/>
        <Parameter name="_workingDays" type="Boolean"/>
        <Parameter name="_compulsoryDays" type="Boolean"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="evaluateDaysOnsite" id="1001df11-a2e1-4ba4-8fbf-8787eaca00a8">
        <source>evaluateDaysOnsite(startTimeStamp: TimeStamp; endTimeStamp: TimeStamp): Real;

vars
	days:  Real;
begin
	days := (endTimeStamp.date - startTimeStamp.date);

	if startTimeStamp.time &lt; self.onsiteStorageChargeTime then
		days := days + 1;
	endif;

	if endTimeStamp.time &lt; self.onsiteStorageChargeTime then
		days := days - 1;
	endif;

	days := days + 1;

	return days;
end;</source>
        <Parameter name="startTimeStamp" type="TimeStamp"/>
        <Parameter name="endTimeStamp" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="evaluateDaysOnsiteAtCalendar" id="6648c87b-ac87-49f9-90e9-6359f18e3ad7">
        <source>evaluateDaysOnsiteAtCalendar(_startTimeStamp: TimeStamp; _endTimeStamp: TimeStamp; _workingDays : Boolean; _compulsoryDays : Boolean; _tiTrx : CM_TITransaction): Real;
// CCMS 1295 free storage days
//Renamed 02 Mar 2020 TFS 48759 to make it clear only used for INV_CALC_TYPE_DAYS_ONSITE_AT
vars

	storageConfigType : CM_StorageConfigType;

begin

	// re-write for TFS 7032	NDL	06 Nov 2017
	storageConfigType := self.terminal.getMyStorageConfigType;
	return storageConfigType.evaluateDaysOnsiteAtCalendar(	self,	//_bank : CM_Bank;	
															_startTimeStamp,	//_startTimeStamp: TimeStamp;
															_endTimeStamp,	//_endTimeStamp: TimeStamp;
															_workingDays,	//_workingDays : Boolean;
															_compulsoryDays,	//_compulsoryDays : Boolean;
															_tiTrx	//_tiTrx : CM_TITransaction
															);
	

end;</source>
        <Parameter name="_startTimeStamp" type="TimeStamp"/>
        <Parameter name="_endTimeStamp" type="TimeStamp"/>
        <Parameter name="_workingDays" type="Boolean"/>
        <Parameter name="_compulsoryDays" type="Boolean"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
