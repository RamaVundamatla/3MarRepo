    <JadeMethod name="makeOverDimensionSectXML" id="a4b3b313-b5a3-4afd-b4e0-fa48bdf68741">
        <source>makeOverDimensionSectXML( _ti : CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	cont : CM_Container;
	workStr : String;
	
begin

	rootElem := _parentElem.addElement('OverDimension');
	
	if _ti = null then
		return;
	endif;
	
	if not _ti.isContainer or not _ti.isOverDimensions  then
		return;
	endif;
	
	cont := _ti.CM_Container;
	
	
	workStr := (cont.overHeight * 10).String;
	xmlElem := rootElem.addElement('Top');
	xmlElem.setText( workStr );
	
	workStr := (cont.overWidthRight * 10).String;
	xmlElem := rootElem.addElement('Right');
	xmlElem.setText( workStr );
	
	workStr := (cont.overWidthLeft * 10).String;
	xmlElem := rootElem.addElement('Left');
	xmlElem.setText( workStr );
	
	workStr := (cont.overLengthFront * 10).String;
	xmlElem := rootElem.addElement('Front');
	xmlElem.setText( workStr );
	
	workStr := (cont.overLengthRear * 10).String;
	xmlElem := rootElem.addElement('Back');
	xmlElem.setText( workStr );
	
	workStr := null;
	xmlElem := rootElem.addElement('Width');
	xmlElem.setText( workStr );
	
	workStr := null;
	xmlElem := rootElem.addElement('Length');
	xmlElem.setText( workStr );
	
epilog

end;</source>
        <access>protected</access>
