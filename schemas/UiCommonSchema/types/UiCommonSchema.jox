    <JadeMethod name="showSystemAlertsWindow" id="ae05ddb1-730f-45a3-bfee-f1821e0e9fcc">
        <source>showSystemAlertsWindow(pMasterMenuAction : CMUI_MenuAction; 
		pTerminal : CM_Terminal; _alerts : CM_AlertsArray);
// ---------------------------------------------------------------------------
// Created:     18 July 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	sysAlertsFrm 	: CMUI_SystemAlerts;
	menuAction 		: CMUI_MenuAction;
begin

	menuAction := app.myController.createMenuAction(PmAdmAlertsView, null, pMasterMenuAction, pTerminal);
	if menuAction = null then
		return;
	endif;
	
	sysAlertsFrm := menuAction.goToObject(null, null, false, null).CMUI_SystemAlerts;
	if sysAlertsFrm = null then
		return;
	endif;
	if _alerts &lt;&gt; null then
		sysAlertsFrm.setSpecificAlerts(_alerts);
	endif;
	sysAlertsFrm.show;	


