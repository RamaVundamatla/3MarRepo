        <source>setProxy(	_id : Integer; 
			_priority : Integer; 
			_description : String;
			_voyageProcess : CM_VoyageProcess;
			_emailTemplate : CM_EmailTemplate;
			_reportToRun : String;	//05 Jun 2018	NDL	TFS 38905
			_autoApplyStatus : Boolean //11/10/21 jlier1 TFS 51963 
			) updating;
//
// Purpose:			
//
