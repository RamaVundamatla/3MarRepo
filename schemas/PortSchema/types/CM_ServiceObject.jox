    <JadeMethod name="getDisplayDetails" id="1c7cf443-4342-4861-a12c-ef4ec2d815ad">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _short then
		return self.name[1:10];
	else
		return self.name;
	endif;

end;</source>
