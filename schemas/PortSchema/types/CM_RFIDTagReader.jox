    <JadeMethod name="delete" id="813c3c60-807f-4849-8d57-5c10cf2910f4">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		par 23859 - stop RFID Tag Reader being deleted if it is in use at a gate lane
// ---------------------------------------------------------------------------
vars

begin
	if not self.allLaneDevices.isEmpty then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'RFID Tag Reader is in use so cannot be deleted');
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doProcessBinary" id="55df0cbb-a839-4eec-889e-d4e75bc582e1">
        <source>doProcessBinary(_bin : Binary) :String;
/*
----------   ----------  --------------------------------------------------
Created:	04 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tagRead		: CM_RFIDAccess7CERead;
	rfidTag		: CM_RFIDTag;
	
begin
	
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-binary received:' &amp; CrLf &amp; _bin.String);
	create tagRead transient;
	tagRead.outputString := _bin.String.removeTabCrLfs().trimBlanks;
	if (not tagRead.populateSelfFromStr()) then
		return null;
	endif;
	rfidTag:=self.myTerminal.allRFIDTagsBySerialNo[tagRead.serialNumber];
	self.doTagRead(tagRead.serialNumber);
	if rfidTag = null then
		return null;
	else
		return rfidTag.code;
	endif;

epilog
	delete tagRead;
end;


</source>
        <Parameter name="_bin" type="Binary"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doTagRead" id="ba875939-e80d-4fff-98b3-8b77ab6b4ac6">
        <source>doTagRead(_serialNumber : String);
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
12/09/2009	cnwcs5		ccms1061 - removed gate lane context
*/
vars
	rfidTag		: CM_RFIDTag;
begin
	rfidTag := self.myTerminal.allRFIDTagsBySerialNo[_serialNumber];
	//th2 08/05/2007 - moved to broadcast the serial number to terminal sysops 
	//screen regardless of whether a tag has already been entered with this number or not.
	self.doTagReadNoTag(_serialNumber);
	
	if rfidTag = null then
		//self.doTagReadNoTag(_serialNumber);
	elseif self.context = TagReaderContext_Machine then
		self.doTagReadMachine(rfidTag);
	elseif self.context = TagReaderContext_WindowsPC then
		self.doTagReadWindowsPC(rfidTag);		
	elseif self.context = TagReaderContext_LaneDevice then
		self.doTagReadLaneDevice(rfidTag);
	endif;
	

end;


</source>
        <Parameter name="_serialNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="doTagReadLaneDevice" id="15cbe4b1-919a-4728-a1fc-44a0d6b2b692">
        <source>doTagReadLaneDevice(_tag : CM_RFIDTag input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
12/09/2009	cnwcs5		ccms1061 - renamed method and changed to handle lane device not gate  lane
*/
vars
	lane	:CM_LaneController;
begin 
	lane := self.getLaneController;
	
	if lane = null then
		app.myPassport.createAlert(SEVERE_ERROR, 
						'Tag "' &amp; _tag.code &amp; '" was swiped on gate lane reader ' &amp; self.code &amp; ' but no gate lane is associated with the reader.',
						EVENT_AT_PreGateAlert,
						_tag);
		beginTransaction;
		app.commitAlert();
		commitTransaction;
		return;
		
	elseif _tag.myRoadJob = null then
		app.myPassport.createAlert(SEVERE_ERROR, 
						'Tag "' &amp; _tag.code &amp; '" was swiped at gate ' &amp; lane.getID &amp; ' but the tags associated road job is null',
						EVENT_AT_PreGateAlert,
						_tag);
		beginTransaction;
		app.commitAlert();
		commitTransaction;
		return;
	/* epr par 14747 27/8/07
	elseif CM_GateLaneController.hasInstance(_tag.myRoadJob.myVehicle.myPrimaryActualLocation) then
		//th2 - without this check and error the below trx will just move it into the yard
		//which is not what we want to happen when a gate RFID reader is swiped
		app.myPassport.createAlert(SEVERE_ERROR, 
						'Tag "' &amp; _tag.code &amp; '" was swiped at gate ' &amp; self.myGateLane.getID &amp; ' but the vehicle (' &amp; _tag.myRoadJob.myVehicle.code &amp; 
									") is already in gate lane " &amp; _tag.myRoadJob.myVehicle.myPrimaryActualLocation.getID() &amp; '"',
						EVENT_AT_PreGateAlert,
						_tag);
		beginTransaction;
		app.commitAlert();
		commitTransaction;
		return;*/
	endif;
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' - processing job "' &amp; _tag.myRoadJob.jobId &amp; '" through lane ' &amp; lane.getID,LogINFO);
	
	app.myPassport.warningsAcknowledged := true;
	app.myTrxUA.trxMoveVehicle(_tag.myRoadJob.myVehicle, lane, app.myPassport);
	
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' - proceed on job "' &amp; _tag.myRoadJob.jobId &amp; '" from lane ' &amp; lane.getID &amp; ' had errors. Converting to system alerts.',LogINFO);
		app.myPassport.createAlertsFromErrors(EVENT_AT_PreGateAlert, _tag.myRoadJob);
	else
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' - proceed on job "' &amp; _tag.myRoadJob.jobId &amp; '" from lane ' &amp; lane.getID &amp; ' successful.',LogINFO);
	
	endif;

end;


</source>
        <access>protected</access>
        <Parameter name="_tag" type="CM_RFIDTag" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTagReadMachine" id="2d6fe678-e1ba-4105-8e88-74afcbdb7916">
        <source>doTagReadMachine(_tag : CM_RFIDTag input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	msg : String;
begin
	msg:=class.name &amp; '::' &amp; method.name;
	if _tag.myRoadJob &lt;&gt; null then
		msg := msg &amp; ' - processing job "' &amp; _tag.myRoadJob.jobId;
	elseif _tag.myMachine &lt;&gt; null then
		msg := msg &amp;  ' - processing internal job for "' &amp; _tag.myMachine.code;
	endif;
	msg:=msg &amp;  '" in yard from machine ' &amp; self.myMachine.id;
	app.writeLog(msg,LogINFO);
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '- ' &amp; msg);
	self.myMachine.causeEvent(self.myTerminal.getTerminalEvent(Event_RFIDTagRead), true, _tag);		
	
end;




</source>
        <access>protected</access>
        <Parameter name="_tag" type="CM_RFIDTag" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTagReadNoTag" id="dd1f1078-d424-4ffa-9689-ae7cba8727d9">
        <source>doTagReadNoTag(_serialNumber : String) protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	app.writeLog('RFID Tag not found for "' &amp; _serialNumber &amp; '" Sending note to (' &amp; self.String &amp; ').', LogINFO);
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_RFIDSerialOnly), true, _serialNumber);		
		
end;


</source>
        <access>protected</access>
        <Parameter name="_serialNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="doTagReadWindowsPC" id="d4e6409c-a5da-42a4-a916-de423c1feb22">
        <source>doTagReadWindowsPC(_tag : CM_RFIDTag) protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _tag.myRoadJob &lt;&gt; null then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' - unexpected swipe: tag with job was swiped on windows PC "' &amp; self.windowsMachineName &amp; ' but the tag already has an associated road job (' &amp; _tag.myRoadJob.jobId &amp; ')', LogINFO);
		app.myPassport.createAlert(SEVERE_ERROR, 
						'Tag "' &amp; _tag.code &amp; '" was swiped on PC ' &amp; self.windowsMachineName &amp; ' but the tag already has an associated road job (' &amp; _tag.myRoadJob.jobId &amp; ')',
						EVENT_AT_PreGateAlert,
						_tag);
		beginTransaction;
		app.commitAlert();
		commitTransaction;
		return;
	endif;
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' - causing event. Tag:' &amp; _tag.String,LogINFO);
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_RFIDTagRead), true, _tag);

end;


</source>
        <access>protected</access>
        <Parameter name="_tag" type="CM_RFIDTag"/>
    </JadeMethod>
    <JadeMethod name="generatePreGateSystemAlerts" id="0d03d301-da2a-4b9b-8749-287da07bdef1">
        <source>generatePreGateSystemAlerts(_passport : CM_Passport);
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	alert 		: CM_SystemAlert;
	alertType 	: CM_SystemAlertType;
	error		: CM_Error;
begin
	alertType:=app.myRoot.allSystemAlertTypes[EVENT_AT_PreGateAlert];
	
	foreach error in _passport.allErrors do	
		create alert transient;
		alert.setSeverity(SEVERE_ERROR);
		alert.details:= error.errorCode.String &amp; ': ' &amp; error.text;
		alert.setMySystemAlertType(alertType);
		alert.add;
	endforeach;
	
	beginTransaction;
	app.commitAlert();
	commitTransaction;


end;


</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getContextDescr" id="7b2f69aa-0cb2-4353-bfb5-aff28ae1266d">
        <source>getContextDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	01 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return app.getErrorString(self.context);

end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2b415462-b976-47c0-92fe-7c323904e4e9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	laneDevice : CM_LaneDevice;
	laneController : CM_LaneController;
	lcTA : CM_TerminalArea;
begin
	if _attrName = ETRow_Code then
		return self.code;
	
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_DeviceName then
		return self.deviceName;
	elseif _attrName = ETRow_GateLane then
		if self.context = TagReaderContext_LaneDevice then
			laneController:=self.getLaneController();
			if laneController &lt;&gt; null then
				return laneController.getLaneId;
			else
				return null;
			endif;
	/*	elseif self.myGateLane &lt;&gt; null then
			return self.myGateLane.getID();*/
		else
			return null;
		endif;
	elseif _attrName = ETRow_IPAddress then
		return self.ipAddress;
	elseif _attrName = ETRow_MacAddress then
		return self.ipAddressListener;
	elseif _attrName = ETRow_ReaderContext then
		return app.getRFIDContextDescrForType(self.context);
	elseif _attrName = ETRow_Machine then
		if self.myMachine &lt;&gt; null then
			return self.myMachine.id;
		else
			return null;	
		endif;
	elseif _attrName = ETRow_PortNumber then
		return self.portNumber.String;
	elseif _attrName = ETRow_IpAddressListener then
		return self.ipAddressListener;
	elseif _attrName = ETRow_GateArea or 
		_attrName = ETRow_TerminalArea then
		if self.context = TagReaderContext_LaneDevice then		// 21/04/2010 cnwar2 #23896
			lcTA:=self.getLaneDeviceTerminalArea();
			if  lcTA &lt;&gt; null then
				return lcTA.id;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_RfidReadAssign then
		if self.context = TagReaderContext_LaneDevice then
			if self.isTypeRead then
				return app.getErrorString (XLAT_RFID_Read);
			elseif self.isTypeAssign then
				return app.getErrorString (XLAT_RFID_Assign);
			endif;
			return null; // probably not used
		endif;
		return null;
	endif;
			
	return inheritMethod(_attrName, _short);


end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLaneController" id="beeaff28-48c2-433f-85d9-1202224f1185">
        <source>getLaneController():CM_LaneController;
// ---------------------------------------------------------------------------
// Created:     12 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ld	:CM_LaneDevice;
begin
	ld := self.allLaneDevices.first;
	
	if ld &lt;&gt; null then
		return ld.myLaneController;
		
	endif;
epilog

end;</source>
        <ReturnType type="CM_LaneController"/>
    </JadeMethod>
    <JadeMethod name="getLaneDeviceTerminalArea" id="99aee610-48e4-4298-a021-36b89fafd87f">
        <source>getLaneDeviceTerminalArea():CM_TerminalArea;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc : CM_LaneController;
begin
	if self.context &lt;&gt; TagReaderContext_LaneDevice then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called for RFID tag reader which is not a lane device');
	endif;
	
	lc:=self.getLaneController();

	if lc = null then
		return null;	// something wrong - should not happen
	endif;
	
	return lc.myTerminalArea;
epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="isTypeAssign" id="afe14473-b3af-4dfd-aa65-e5c22ed5b11a">
        <source>isTypeAssign():Boolean;
// ---------------------------------------------------------------------------
// Created:     10 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.allLaneDevices.isEmpty then
		return false;
	endif;
	// we can only have one usage for a reader
	return self.allLaneDevices.first.CM_LDRFIDTagReader.isTypeAssign;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTypeRead" id="942aa387-cb1f-4a74-aa1f-5862fa71cece">
        <source>isTypeRead():Boolean;
// ---------------------------------------------------------------------------
// Created:     10 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.allLaneDevices.isEmpty then
		return false;
	endif;
	// we can only have one usage for a reader
	return self.allLaneDevices.first.CM_LDRFIDTagReader.isTypeRead;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9acad21f-a05c-44ba-ab63-87f1119f0fc0">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
20/04/2011	 cnwmh5		 PAR #27401 - Add code to handle prossible exceptions occurring when
						 trying to create the proxy
*/
vars
	newTagReader	: CM_RFIDTagReader;
	laneDevice,
	pxyLaneDevice	: CM_LaneDevice;
	completedOK		: Boolean;
	
begin
	newTagReader := inheritMethod();
	newTagReader.myTerminal := self.myTerminal;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return newTagReader;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete newTagReader;
	endif;	
end;


</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0e7302d2-3c68-428e-9b7f-45cf30cf33df">
        <updating/>
        <source>setForCreate(_pxyTagReader : CM_RFIDTagReader;
			_terminal : CM_Terminal) updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyLaneDevice 	: CM_LaneDevice;
begin
	// need to create proxy link so lane device can access reader when created (CM_LDRFIDTagReader :: setForUpdate)
	if _pxyTagReader.pxyGetRealObject = null then	
		app.myProxyManager.createProxyLink(self, _pxyTagReader);
	endif;

	self.setForUpdate(_pxyTagReader, _terminal);
epilog
	
end;


</source>
        <Parameter name="_pxyTagReader" type="CM_RFIDTagReader"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b5865524-e02c-45c2-a297-185ece76091c">
        <updating/>
        <source>setForUpdate(_pxyTagReader : CM_RFIDTagReader;
			_terminal : CM_Terminal) updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
11/09/2009	cnwcs5		ccms1061 - remove gate lane context
*/
vars
	pxyLaneDevice 	: CM_LaneDevice;
	reader			: CM_LDRFIDTagReader;
	lane			: CM_LaneController;
begin
	self.code				:= _pxyTagReader.code;
	self.description		:= _pxyTagReader.description;
	self.deviceName			:= _pxyTagReader.deviceName;
	self.ipAddressListener	:= _pxyTagReader.ipAddressListener;
	self.ipAddress			:= _pxyTagReader.ipAddress;
	self.portNumber			:= _pxyTagReader.portNumber;
	self.context			:= _pxyTagReader.context;
	
	if self.context = TagReaderContext_Machine then
		self.myMachine 			:= _pxyTagReader.myMachine;
		self.windowsMachineName := null;
		
	elseif self.context = TagReaderContext_WindowsPC then
		self.myMachine 			:= null;
		self.windowsMachineName := _pxyTagReader.windowsMachineName;
		
	elseif self.context = TagReaderContext_LaneDevice then
		self.myMachine 			:= null;
		self.windowsMachineName := null;
		
		// get rid of any existing lane device
		self.allLaneDevices.purge;
		
		pxyLaneDevice	:= _pxyTagReader.allLaneDevices.first;
		
		if pxyLaneDevice &lt;&gt; null then
			lane := pxyLaneDevice.myLaneController;
			
			// if we are coming from RFID tag reader maintenance lane will be persistant
			// if we are coming from gate/interchange area maintenance, lane will be transient

			create reader;
			reader.setForCreate(pxyLaneDevice, lane);
		endif;
	endif;
	
	self.myTerminal	:= _terminal;
	
epilog
	if pxyLaneDevice &lt;&gt; null then
		delete pxyLaneDevice;
	endif;
end;


</source>
        <Parameter name="_pxyTagReader" type="CM_RFIDTagReader"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="eb375e01-6f97-44c3-acfd-f184e44979f1">
        <updating/>
        <source>setProxy(_code,
		_description,
		_deviceName,
		_ipAddressListener,
		_ipAddress		: String;
		_portNumber,
		_context		: Integer;
		_type			: Integer;	// lane device type
		_lane			: CM_LaneController;
		_machine		: CM_Machine;
		_windowsMachineName	: String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
cnwcs5	10/09/2009	ccms1061 - added _type parameter (only applies to lane controller)
							 - removed gate lane context
cnwcs5	11/12/2009	par20945 - removed write statement
*/
vars
	laneDevice 	: CM_LDRFIDTagReader;
	pxyLane		: CM_LaneController;
	
begin

	self.code				:= _code;
	self.description		:= _description;	
	self.deviceName			:= _deviceName;
	self.ipAddressListener	:= _ipAddressListener;
	self.ipAddress			:= _ipAddress;
	self.portNumber			:= _portNumber;
	self.context			:= _context;

	if self.context = TagReaderContext_Machine then
		self.myMachine 			:= _machine;
		self.windowsMachineName := null;
		
	elseif self.context = TagReaderContext_WindowsPC then
		self.myMachine 			:= null;
		self.windowsMachineName := _windowsMachineName;
		
	elseif self.context = TagReaderContext_LaneDevice then
		self.myMachine 			:= null;
		self.windowsMachineName := null;
		// we only have 1 usage at a time so get rid of any that are there B4
		// we created a new one
		self.allLaneDevices.purge;
		
		if _lane &lt;&gt; null then
			create laneDevice transient;
			laneDevice.setType(_type);
			laneDevice.setRFIDTagReader(self);
			laneDevice.setMyLaneController (_lane);
		endif;
	endif;
		
end;


</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_deviceName" type="String"/>
        <Parameter name="_ipAddressListener" type="String"/>
        <Parameter name="_ipAddress" type="String"/>
        <Parameter name="_portNumber" type="Integer"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_lane" type="CM_LaneController"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_windowsMachineName" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="bbb0de5a-d2db-4a91-87f5-d87fa77a1ff0">
        <source>validateDelete(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not self.allLaneDevices.isEmpty then
		app.raiseCMException2 (Lane_Device_Delete_Error, self.code, self.allLaneDevices.first.getLaneDescription, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="37f1b845-7303-4b62-8d3c-f5e5278d561e">
        <source>validateForCreate();
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.validateForUpdate();

end;


</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a09d80ae-6f27-4b51-bd4c-a763ec9c9a05">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
//14/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
----------   ----------  --------------------------------------------------
11/09/2009	cnwcs5		ccms 1061 - remove gate lane context
*/
vars
	realTagReader,
	existingTagReader,
	tmpTagReader 		: CM_RFIDTagReader;
	iter 				: Iterator;
	realMachine,
 	machine 			: CM_Machine;
	pxyLaneDevice,
	laneDevice			: CM_LDRFIDTagReader;
	
begin
	if self.context = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Reader context', ETRow_ReaderContext, null); //cnwrs1 June 2009 was ETRow_ReaderType
		app.raiseCMException(Input_required_field_readerCon, ETRow_ReaderContext, null); //cnwrs1 June 2009 was ETRow_ReaderType // cnwdb2	PAR 35364
	elseif self.context &lt;&gt; TagReaderContext_Machine and
	   self.context &lt;&gt; TagReaderContext_WindowsPC and
	   self.context &lt;&gt; TagReaderContext_LaneDevice then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled RFID tag reader context (' &amp; self.getContextDescr() &amp; ')');
	endif;
	
	if self.context = TagReaderContext_LaneDevice then
		pxyLaneDevice := self.allLaneDevices.first.CM_LDRFIDTagReader;
		
		if pxyLaneDevice &lt;&gt; null then
			if pxyLaneDevice.type &lt;&gt; CM_LaneDevice.Type_RFIDTagReaderRead and
				pxyLaneDevice.type &lt;&gt; CM_LaneDevice.Type_RFIDTagReaderAssign then
				app.raiseCMException (XLAT_ReadAssign_Error, null, null);
			endif;
					
			// does the gate lane already have a tag reader of the same type 
			if pxyLaneDevice.isTypeRead then
				existingTagReader := pxyLaneDevice.myLaneController.getRFIDTagReader(true);
			else
				existingTagReader := pxyLaneDevice.myLaneController.getRFIDTagReader(false);
			endif;
			
			if existingTagReader &lt;&gt; null and existingTagReader &lt;&gt; self.pxyGetRealObject then
				app.raiseCMException1(Err_RFIDReader_GateLaneDup, existingTagReader.code, ETRow_GateLane, null);
			endif;
		endif;
		
	elseif self.context = TagReaderContext_Machine and self.myMachine = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Machine', ETRow_Machine, null);	
		app.raiseCMException(Input_required_field_machine, ETRow_Machine, null);	
	elseif self.context = TagReaderContext_WindowsPC and self.windowsMachineName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Windows PC name', ETRow_WindowsMachineName, null);	
		app.raiseCMException(Input_required_field_windowsPC, ETRow_WindowsMachineName, null);		 // cnwdb2	PAR 35364
	endif;

	
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	/*
	if self.macAddress = null then
		app.raiseCMException1(REQUIRED_FIELD, 'MAC Address', ETRow_MacAddress, null);
	endif;
	*/
	
	if self.portNumber = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Port Number', ETRow_PortNumber, null);
		app.raiseCMException(Input_required_field_portNumb, ETRow_PortNumber, null); // cnwdb2	PAR 35364
	endif;

	existingTagReader	:= app.myPassport.myTerminal.allRFIDTagReadersByCode[self.code];
	realTagReader		:= self.pxyGetRealObject();
	
	if existingTagReader &lt;&gt; null and
	   (realTagReader = null or //in which case we are trying add a new one that is duplicate
	   existingTagReader &lt;&gt; realTagReader) //in which case we are trying update one to be same as another
	   then
		//app.raiseCMException2(DuplicateItem, "RFID Tag Reader", self.code, null, null); //14.06.2022 navds20 53760
		// RFID Tag Reader already exists for %1 : Rfid_reader_already_exists
		app.raiseCMException1(Rfid_reader_already_exists, self.code, null, null); //14.06.2022 navds20 53760
	endif;	
	
	//epr par 17534 15/7/08
	if self.context = TagReaderContext_Machine and self.myMachine &lt;&gt; null then
		if realTagReader &lt;&gt; null then
			//this is an update
			realMachine :=realTagReader.myMachine;
		endif;
		iter:=app.myPassport.myTerminal.allRFIDTagReadersByCode.createIterator;
		while iter.next(tmpTagReader) do 
			if tmpTagReader.context &lt;&gt; TagReaderContext_Machine then
				continue;
			endif;
			if realMachine &lt;&gt; null and tmpTagReader.myMachine = realMachine then
				continue;
			endif;
			if tmpTagReader.myMachine = self.myMachine then
				app.raiseCMException3(ERR_DuplicateItemWith,"RFID Tag Reader","Machine", self.myMachine.code,null,null);
				break;
			endif;
		endwhile;
		
	endif;
epilog
	delete iter;
end;


</source>
    </JadeMethod>
</Class>
