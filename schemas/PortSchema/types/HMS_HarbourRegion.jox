end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f3b6ddf7-93ed-4b2f-86e0-d9d78aa13267">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _attrName = ETRow_CheckpointCurrent then
		if self.myCurrentCheckpoint &lt;&gt; null then
			return self.myCurrentCheckpoint.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_CheckpointHeight then
		if self.myHeightCheckpoint &lt;&gt; null then
			return self.myHeightCheckpoint.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_CheckpointHiLo then
		if self.myHiLoCheckpoint &lt;&gt; null then
			return self.myHiLoCheckpoint.code;
		else
			return null;
		endif;
		
		// cnwdb2 PAR 33977 Start
		
		elseif _attrName = ETRow_CheckpointCurrent then
			return myCurrentCheckpoint.String ; 
		
		elseif _attrName = ETRow_CheckpointHeight then
			return myHeightCheckpoint.String ; 
		
		elseif _attrName = ETRow_CheckpointHiLo then
			return myHiLoCheckpoint.String ;
		
		elseif _attrName = ETRow_CheckpointTimeGap then
			if myTimeGapCheckpoint &lt;&gt; null then
				return myTimeGapCheckpoint.code ; 
			else 
				return "" ;
			endif ; 
		
		
		// cnwrs1 Sept 2008 obsolete
//	elseif _attrName = ETRow_CheckpointDaylight then
//		if self.myTimeGapCheckpoint &lt;&gt; null then
//			return self.myTimeGapCheckpoint.code;
//		else
//			return null;
//		endif;
	endif;

	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHarbour" id="79028bec-c454-4b38-8f70-8cd8bf56d941">
        <source>getHarbour() : HMS_Harbour;
// ---------------------------------------------------------------------------
// Created:     08 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot = null then
		return self.myHarbour;
	endif;
	return app.myRoot.getHarbourForScenario(self.myHarbour);
end;</source>
        <ReturnType type="HMS_Harbour"/>
    </JadeMethod>
