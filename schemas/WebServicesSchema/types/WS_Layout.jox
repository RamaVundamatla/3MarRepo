    <JadeMethod name="createProxy" id="fa3a7ab1-8bc9-4023-9d8e-5b8360b50eaa">
        <source>createProxy(_pxyBayItem : CM_BayItem);
/*

Date		Who		Reason
16 August 2013	cnwer1	Initial creation PAR

*/

vars
	layout : CM_BayItemLayout;
begin
	
	create layout transient;
	layout.setProxyBayItemLayout( _pxyBayItem,
									self.code,
									self.description,
									self.drawFillColourHEX.convertHexColourToJadeColor(),
									self.drawFillStyle,
									self.drawFontBackColourHEX.convertHexColourToJadeColor(),
									self.drawFontBold,
									self.drawFontForeColourHEX.convertHexColourToJadeColor(),
									self.drawFontName,
									self.drawFontSize,
									self.drawLineColourHEX.convertHexColourToJadeColor(),
									self.drawLineStyle,
									self.drawText,
									self.drawWidth,
									self.geometryPath,
									self.isVisible,
									self.drawX1,
									self.drawX2Width,
									self.drawY1,
									self.drawY2Height,
									self.drawShapeAngle,
									self.drawShapeType,
									self.remarks);
	
epilog

end;</source>
        <Parameter name="_pxyBayItem" type="CM_BayItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyBayDefault" id="36cdc02b-0763-4164-8edc-2a89d2ee7d77">
        <updating/>
        <source>setProxyBayDefault(_bay : CM_Bay) updating;
/*
Purpose:			
Date		Who		Reason
07 January 2014	cnwab1	Initial creation
*/

vars

begin
		self.drawShapeType := "4";
		self.code := "JADE BAY " &amp; _bay.id;

epilog

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="bb0e50bf-9fc7-48b2-b828-08a13a2bb01c">
        <updating/>
        <source>setProxyFromObject(_object: CM_BayItemLayout) updating;
/*

Date		Who		Reason
16 August 2013	cnwer1	Initial creation PAR

*/

vars

begin
	inheritMethod(_object);
	
	self.code:=_object.code;
	self.description:=_object.description;
	self.drawFillColour:=_object.drawFillColour;
	self.drawFillStyle:=_object.drawFillStyle;
	self.drawFontBackColour:=_object.drawFontBackColour;
	self.drawFontBold:=_object.drawFontBold;
	self.drawFontForeColour:=_object.drawFontForeColour;
	self.drawFontName:=_object.drawFontName;
	self.drawFontSize:=_object.drawFontSize;
	self.drawLineStyle:=_object.drawLineStyle;
	self.drawLineColour:=_object.drawLineColour;
	self.drawText:=_object.drawText;
	self.drawWidth:=_object.drawWidth;
	self.geometryPath:=_object.geometryPath;
	self.isVisible:=_object.isVisible;
	self.remarks:=_object.remarks;
	
	self.drawX1:=_object.drawX1;
	self.drawX2Width:=_object.drawX2Width;
	self.drawY1:=_object.drawY1;
	self.drawY2Height:=_object.drawY2Height;
	self.drawShapeType:=_object.drawShapeType;
	self.drawShapeAngle:=_object.drawShapeAngle;
	
	self.drawFillColourHEX := _object.drawFillColour.convertJadeColorToHexColour();
	self.drawFontBackColourHEX := _object.drawFontBackColour.convertJadeColorToHexColour();
	self.drawFontForeColourHEX := _object.drawFontForeColour.convertJadeColorToHexColour();
	self.drawLineColourHEX := _object.drawLineColour.convertJadeColorToHexColour();
	
epilog

end;</source>
        <Parameter name="_object" type="CM_BayItemLayout"/>
    </JadeMethod>
</Class>
