    <JadeMethod name="setFunction" id="41f6bcf6-49a2-42ec-8000-9f0f3afdb9ab">
        <source>setFunction(_function :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int, size	:Integer;
begin
	size := cmbFunction.listCount;
	
	foreach int in 1 to size do
		if cmbFunction.itemData[int] = _function then
			cmbFunction.listIndex := int;
			return;
		endif;
	endforeach;
	
	cmbFunction.listIndex := 1;	// default to COUNT
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_function" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyChildCollection" id="aefb11ac-a966-49cc-9ca1-f5dcd4edeee1">
        <updating/>
        <source>setMyChildCollection() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation	CCMS 1028

*/

vars

	qDef : CM_QueryDefinition;
	iter : Iterator;
	obj : Object;
	bookingRef : CM_BookingRef;
	
begin

	self.myChildCollection.clear();

	if self.myQueryDefinition = null then
		return;
	endif;
	
	if not self.myQueryDefinition.isBookRefItemType then
		return;
	endif;
	
	if self.myCollection.isEmpty then
		return;
	endif;
	
	if not self.myCollection.first.isKindOf(CM_BookingRef) then
		return;
	endif;
	
	//We have a mode of 'Booking Ref Item' but a collection of 'Bookings' so 
	// we need to populate the 'myChildCollection' with the items from the Bookings.
	
	iter := self.myCollection.createIterator;
	while iter.next( obj ) do
		bookingRef := obj.CM_BookingRef;
		if not bookingRef.allBookingRefItems.isEmpty then
			bookingRef.allBookingRefItems.copy( self.myChildCollection );
		endif;
	endwhile;
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyQueryDefinition" id="3558909f-519b-4d2d-ad84-4df319e8d795">
        <updating/>
        <source>setMyQueryDefinition( _queryDef : CM_QueryDefinition ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myQueryDefinition &lt;&gt; _queryDef then
		self.myQueryDefinition 	:= _queryDef;
		self.cmbMode.listIndex := self.cmbMode.findObject(_queryDef);
		self.loadProperties;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_queryDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="setOutputFormat" id="558fe5cb-0f27-42fd-8589-dedf1688aabc">
        <updating/>
        <source>setOutputFormat( _proxyFormat, _realFormat : CM_OutputFormat_XTAB; _expectedEdition : Integer ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
28 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	self.myProxyXTAB		:= _proxyFormat;
	self.myCurrentXTAB		:= _realFormat;
	self.currentXTABEdition	:= _expectedEdition;
	
epilog
	
end;
</source>
        <Parameter name="_proxyFormat" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_realFormat" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_expectedEdition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setShowDetails" id="48a02cd3-b1b0-4d38-baab-728b5c6e793f">
        <updating/>
        <source>setShowDetails( _value : Boolean ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
23 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	if showDetails &lt;&gt; _value  then
		showDetails	:= _value;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="Boolean"/>
