    <JadeMethod name="setSourceAndTarget" id="6fe1b359-2a33-4c2f-91b8-a4b2ea2bb3d1">
        <updating/>
        <source>setSourceAndTarget(_control: CMIF_MoveController) updating;
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR

*/

vars
	source: CM_LocationsController;
	target: CM_LocationsController;
begin

	source := _control.myOriginatingLocation;
	target := _control.myToPrimaryLocation;

	if source &lt;&gt; null and source.isSwapStack then
		self.sourceLocn := _control.preSwapLocation;
		self.isSwapMove := true;
		self.targetLocn := target.CM_WagonController.id;
		
	endif;
epilog

end;</source>
