    <JadeMethod name="outputHeader_NAD" id="82d905bc-8c4b-43ee-a5a4-de308bca4729">
        <updating/>
        <source>outputHeader_NAD(	_protocol: CM_CamProtocol; 
					_camMessage: CM_CamMessage input; 
					_camTaskHistory: CM_CamTaskHistory input; 
					_coll: HugeStringArray input	): String updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
//
vars
	strLine : String;

begin
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment(_protocol, null, "CF", _protocol.camGroup.shippersCode.trimBlanks, '160', '20'), _coll);

	_camMessage.segmentCount := _camMessage.segmentCount + 1;

	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment(_protocol, null, "MS",  self.getProtocolDepotCode(_protocol), '160', '184'), _coll);

	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	
	return strLine;
	
epilog

end;</source>
