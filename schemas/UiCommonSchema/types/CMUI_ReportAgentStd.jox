    <JadeMethod name="doLoadCarriers" id="7189bb84-ad5c-44b3-9cf5-1fc446a614dd">
        <source>doLoadCarriers(_cmb : CMUI_ComboBox input; _carrierCode : String) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	carrier			: CM_Carrier;
	carrierDict		: CM_CarrierByCodeDict;
	idx : Integer;
	selectedCarrier : CM_Carrier;
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(Any_String);
	
	carrierDict := app.myRoot.allCarriers;
	
	foreach carrier in carrierDict do
		idx := _cmb.addItem(carrier.code &amp; Tab &amp; carrier.description);
		_cmb.itemObject[idx] := carrier;
		if carrier.code = _carrierCode then
			selectedCarrier := carrier;
		endif;
	endforeach;
			
	if selectedCarrier &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(selectedCarrier);
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_CarrierCode, _cmb.text);
	self.setValueByName(ETRow_CarrierFilter, _cmb.text);	//28 Feb 2017	NDL	TFS 37304
	self.setValueByName(ETRow_MyCarrier, _cmb.text);	//28 Feb 2017	NDL	TFS 37304
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_carrierCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadCashDebtors" id="55dd70bb-6455-4259-b4a4-2486e40ad540">
        <updating/>
        <source>doLoadCashDebtors(	_lstTblCashDr	: CMUI_ListTable input;
					_filterObject	: CMQF_FilterReports ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	dr : CM_DebtorNode;

begin

	if _lstTblCashDr = null then
		return;
	endif;
	self.allAllowedCashDebtors.clear();

	// from 33161 get the cash debtors properly
	foreach dr in app.myRoot.myRootCompany.debtors discreteLock do
		if not dr.isKindOf( CM_Debtor ) then
			continue;
		endif;
		if dr.CM_Debtor.allDebtorTerminals.includesCashOnlyTerminals then
			if not self.allAllowedCashDebtors.includes(dr.CM_Debtor) then
				self.allAllowedCashDebtors.addNoDuplicates(dr.CM_Debtor, false);
			endif;
		endif;
	endforeach;
	
	_lstTblCashDr.displayCollection(self.allAllowedCashDebtors, false, Table.DisplayCollection_Forward, null);
		
	if CMQF_CashTransactions.hasInstance(_filterObject) then
		_lstTblCashDr.setSelected(_filterObject.CMQF_CashTransactions.allDebtors);
	endif;
	
	_lstTblCashDr.lostFocus(_lstTblCashDr);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lstTblCashDr" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadCellularVoyages" id="b6ba67cf-0f67-4a4c-b22a-bf62d7d98e7c">
        <source>doLoadCellularVoyages(_cmbVoyage : CMUI_ComboBox input; 
					_defaultTemplate : CMQF_FilterReports; 
					_voyCode : String io) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 03/03/2017 	cnwrh7      TFS3515       #TEMPLATE FOR TASK "TRASPORTI" NOT RUN CORRECTLY
// 14/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	voy				: CM_Voyage;
	terminal		: CM_Terminal;
	idx,
	keepIdx			: Integer;
	tmpCode,
	str				: String;
	useDefaultVoy,
	multiTerminal	: Boolean;
	tmpVoy			: CM_Voyage;
	termIter,
	voyIter			: Iterator;
	dac				: CM_DataAccessController;			// TFS 44554
	user			: CM_User;							// TFS 44554
	passport 		: CM_Passport;						// TFS 44554
begin
	if _cmbVoyage = null then
		return;
	endif;
	
	_cmbVoyage.sorted := false;
	_cmbVoyage.clear();
	//CNWTH2 obviously myVoyage should be on the superclass!
	if CMQF_TrackedItem.hasInstance(_defaultTemplate) or
	   CMQF_VoyageSummary.hasInstance(_defaultTemplate) or
	   CMQF_Transactions.hasInstance(_defaultTemplate) or
	   CMQF_ResourceUsage.hasInstance (_defaultTemplate) then											//+TFS3515
		useDefaultVoy := _defaultTemplate.doUseAppDefaultVoyage;
		tmpVoy := _defaultTemplate.getPropertyValue('myVoyage').CM_Voyage;
		if tmpVoy &lt;&gt; null then
			_voyCode := tmpVoy.code;
		elseif useDefaultVoy and app.getMyCurrentVoyage() &lt;&gt; null then //cnwjo3 par 23105
			_voyCode := app.getMyCurrentVoyage().code;		
		endif;
	endif;
	
	if _voyCode = null then
		_voyCode := Any_String;
	endif;
	
	//if CMUI_ReportBuilder.hasInstance(self.myParentForm) then
	if self.isOptCurrentVoyageAllowed then
		_cmbVoyage.addItem(Any_String);
		_cmbVoyage.addItem(OPT_DEFAULT_VOYAGE);
		if useDefaultVoy then
			_cmbVoyage.text := OPT_DEFAULT_VOYAGE;
		else
			_cmbVoyage.text := Any_String;
		endif;
		_voyCode := _cmbVoyage.text;
		self.setValueByName(ETRow_Voyage, _cmbVoyage.text);
		
		return;	
	endif;
	
	multiTerminal := (self.allTerminals.size &gt; 1);
	keepIdx := -1;
	_cmbVoyage.addItem(Any_String);
	
	termIter := self.allTerminals.createIterator;
	
	user := app.getMyUser;													// TFS 44554
	passport := app.myPassport;												// TFS 44554
	while termIter.next(terminal) do
		tmpCode := terminal.code;
		delete voyIter;
		voyIter := terminal.allVoyagesByCode.createIterator;
		while voyIter.next(voy) do
		// Allow this combo to see all voyages now dvb 10/05/06
		//	if voy.myCellularVoyageStructure &lt;&gt; null then
				if not voy.canUserAccessSelf(user, dac, passport) then		// TFS 44554
					continue;												// TFS 44554
				endif;														// TFS 44554
				if multiTerminal then
					str := voy.code &amp; '  ' &amp; voy.description &amp; ' - ' &amp; tmpCode;
				else
					str := voy.code &amp; '  ' &amp; voy.description;
				endif;
				
				idx := _cmbVoyage.addItem(str);
				_cmbVoyage.itemObject[idx] := voy;
				
				if voy.code = _voyCode then
					keepIdx := idx;
				endif;
		//	endif;
		endwhile;
	endwhile;
	
	if keepIdx &gt; -1 then
		_cmbVoyage.listIndex := keepIdx;
		self.setValueByName(ETRow_Voyage, _cmbVoyage.text );
	else
		_cmbVoyage.listIndex := 1;
		self.setValueByName(ETRow_Voyage, Any_String);
	endif;

epilog
	delete termIter;
	delete voyIter;

end;</source>
        <access>protected</access>
        <Parameter name="_cmbVoyage" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
        <Parameter name="_voyCode" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doLoadClearingAgent" id="ce6a8adf-ca7c-4c62-a42e-3eafe16da97f">
        <source>doLoadClearingAgent(_cmb : CMUI_ComboBox input; _code : String) protected;
// 36778 clearing agent is customs agent or consignee, depending on cash config
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 15/02/2018	jlgdap1	37030 	SSL Demurrage Report
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	con					: CM_ConsigneeConsignor;
	conDict				: CM_ConsignByCodeDict;
	cashDebtorType		: CM_DebtorType;
	customsAgent		: CM_CustomsAgent;
	isConsignor			: Boolean;
	idx,
	keepIdx				: Integer;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
	failedDAC  			: CM_DataAccessController;
	selCustomsAgent	: CM_CustomsAgent;
	selCon : CM_ConsigneeConsignor;
begin
	if _cmb = null then
		return;
	endif;
	
	// cash debtor type is the type of clearing agent, if set in cash module config
	terminal := self.myTerminal;	// null for both maintenance and run
	if self.myTerminal = null then
		terminal := self.myParentForm.myTerminal;
		if terminal = null then
			foreach terminal in self.allTerminals do
				cashDebtorType := terminal.getConfig(CashDebtorType).CM_DebtorType;
				if cashDebtorType &lt;&gt; null then
					break;
				endif;
			endforeach;
		endif;
	endif;
	if terminal &lt;&gt; null and
	   cashDebtorType = null then
		cashDebtorType := terminal.getConfig(CashDebtorType).CM_DebtorType;
	endif;
	if cashDebtorType = null then
		cashDebtorType := app.myRoot.allDebtorTypes["SDT6"];	// default to customs agent
	endif;
	
	passport := app.myPassport;
	_cmb.clear();
	_cmb.addItem("");										// TFS 37030
	keepIdx := -1;
	
	if cashDebtorType.isCustomsAgent then
		foreach customsAgent in app.myRoot.allCustomsAgents do
			if (not customsAgent.canUserAccessSelf(null, failedDAC, passport) or customsAgent.isNotAvailableForEntry) then
				continue;
			endif;
			if customsAgent.myDebtor = null or not customsAgent.myDebtor.isCashOnlyDebtor( terminal ) then
				continue;
			endif;

			idx := _cmb.addItem(customsAgent.code &amp; '  ' &amp; customsAgent.name);
			_cmb.itemObject[idx] := customsAgent;
		
			if customsAgent.code = _code then
				selCustomsAgent := customsAgent;
			endif;
		endforeach;
	else
		isConsignor := cashDebtorType.isConsignor;
		conDict := app.myRoot.allConsigneeConsignors;
	
		foreach con in conDict do
			if (not con.canUserAccessSelf(null, failedDAC, passport)) and (con.code &lt;&gt; _code) then
				continue;
			endif;
			if con.isNotAvailableForEntry then
				continue;
			endif;
			if con.debtor = null or not con.debtor.isCashOnlyDebtor( terminal ) then
				continue;
			endif;
			if isConsignor then
				if not con.isConsignor then
					continue;
				endif;
			else
				if not con.isConsignee then
					continue;
				endif;
			endif;
		
			idx := _cmb.addItem(con.code &amp; '  ' &amp; con.description);
			_cmb.itemObject[idx] := con;
		
			if con.code = _code then
				selCon := con;
			endif;
		endforeach;
	endif;
	
	if (selCustomsAgent = null) and (selCon = null) then
		if _cmb.listCount &gt; 0 then
			_cmb.listIndex := 1;
		endif;
	else
		if selCustomsAgent &lt;&gt; null then 
			_cmb.listIndex := _cmb.findObject(selCustomsAgent);
		else
			_cmb.listIndex := _cmb.findObject(selCon);
		endif;
	endif;
	
	self.setValueByControlName(_cmb.name, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadCmbLoadedOption" id="c67b5b92-55b1-406b-abf8-5d004a053b03">
        <source>doLoadCmbLoadedOption(_cmb : CMUI_ComboBox input; _loadedOption : String) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(CMQF_VoyageAnzecs.LoadedOption_ThisPort);
	_cmb.addItem(CMQF_VoyageAnzecs.LoadedOption_NZ);
	
	if _loadedOption &lt;&gt; null then
		_cmb.text := _loadedOption;
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_LoadedOption, _cmb.text);
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_loadedOption" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadCompanies" id="a16d9a31-400d-439a-9b6a-cf0fb2e2e652">
        <source>doLoadCompanies(_cmb : CMUI_ComboBox input; _companyCode : String) protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 April 2010
//
// Implemented version: JMT 7.8.2
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 				SFW CCMS 1115 	PAR23680   cnwsh3 - Invoice JRW Interface
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
//----------------------------------------------------------------------
vars
	company 		: CM_Bank;
	defaultCompany	: CM_Bank;
	terminal 		: CM_Terminal;
	combo 			: CMUI_ComboBox;
	terminalColl	: CM_TerminalByCodeDict;
	idx : Integer;
	companyCode	: String;
	dynaDict : DynaDictionary;
	obj	: Object;
	selCompany : CM_Bank;
	
begin
	if _cmb = null then
		return;
	endif;

	combo := _cmb;
	combo.clear();
	combo.sorted := false;

	//Get the collection to search based on whether we have specified a terminal.
	//We pass terminals from the Report Runner form but not from the Report Builder/Maint form.
	if self.allTerminals.isNotEmpty() then
		terminalColl := self.allTerminals;
	else
		terminalColl := app.myRoot.allTerminals;
	endif;	

	//combo.addItem(''); //cnwsh3 - Removed at this stage to force a company selection based on the rule, we require a company to search on. 26/04/2010
	
	//Need to sort by company code with dups and show the terminal code in the combo box as well.
	create dynaDict transient;
	dynaDict.setMembership(CM_Bank);
	dynaDict.addMemberKey(CM_Bank::code.name, false, true);
	dynaDict.endKeys(true);
	
	foreach terminal in terminalColl discreteLock do
		// get default company from 1st terminal
		if defaultCompany = null then
			defaultCompany := terminal.getDefaultCompanyBank();
		endif;
		foreach company in terminal.companies where company.isBusinessUnit do
			dynaDict.add(company);							
		endforeach;
	endforeach;
	
	//Now we've got the order we want, chuck it at the combo box.
	foreach obj in dynaDict do
		company := obj.CM_Bank;
		companyCode := null;
		companyCode := company.getNameWithTerminalString();
		idx := combo.addItem(companyCode);
		combo.itemObject[idx] := company;
		
		if (_companyCode &lt;&gt; null) and (_companyCode = companyCode) then
			selCompany := company;
		endif;
		
		// from 37009 testing, if no company set, use the default one not the first
		if (_companyCode = null) and (company = defaultCompany) then
			selCompany := company;
		endif;
	endforeach;
	
	/*
	//The template had a company already designated so we want to set the combo box to this one.
	if keepIdx &gt; -1 then
		combo.listIndex := keepIdx;
	else
		combo.listIndex := 1;
		self.setValueByName(ETRow_Company, app.getErrorString(AllBusinessUnits));
	endif;
	*/
	
	if selCompany &lt;&gt; null then
		combo.listIndex := combo.findObject(selCompany);
	else
		combo.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_Company, combo.text);

epilog
	delete dynaDict;
end;
</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_companyCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadConsign" id="5ab49288-1fe6-40a2-b535-53636668387b">
        <source>doLoadConsign(_cmb : CMUI_ComboBox input; _code : String; _isConsignor : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	con	: CM_ConsigneeConsignor;
	conDict	: CM_ConsignByCodeDict;
	idx : Integer;
	passport : CM_Passport;
	failedDAC : CM_DataAccessController;
	selCon : CM_ConsigneeConsignor;
	
begin
	if _cmb = null then
		return;
	endif;
	
	conDict := app.myRoot.allConsigneeConsignors;
	passport := app.myPassport;
	
	_cmb.clear();
	_cmb.addItem(Any_String);
	
	foreach con in conDict do
//		if (not con.canUserAccessSelf(null, passport) or con.isNotAvailableForEntry) and (con.code &lt;&gt; _code) then		
// 	should be able to see 'not available for entry' objects for reports. 
		if (not con.canUserAccessSelf(null, failedDAC, passport)) and (con.code &lt;&gt; _code) then
			continue;
		endif;
		
		//+cnwml2 PAR25402
		if _isConsignor then
			if not con.isConsignor then
				continue;
			endif;
		else
			if not con.isConsignee then
				continue;
			endif;
		endif;
		
		idx := _cmb.addItem(con.code &amp; '  ' &amp; con.description);
		_cmb.itemObject[idx] := con;
		
		if con.code = _code then
			selCon := con;
		endif;
	endforeach;
	
	if selCon &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(selCon);
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByControlName(_cmb.name, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_isConsignor" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadCraneList" id="883a7a05-34dc-4cb0-8af7-ce1712ff6f78">
        <source>doLoadCraneList(_lstTable	: CMUI_ListTable input; _defaultTemplate : CMQF_FilterReports) protected;
//----------------------------------------------------------------

//----------------------------------------------------------------
vars
	crane			: CM_Crane;
	machine			: CM_Machine;
	terminal		: CM_Terminal;
	idx				: Integer;
	defaultCranes	: CM_MachineSet;
	select			: Integer;
	
begin
	if _defaultTemplate.isKindOf(CMQF_CraneKPI) then
		defaultCranes := _defaultTemplate.CMQF_CraneKPI.allCranes;
	endif;
	
	if _lstTable = null then
		return;
	endif;
	
	terminal := self.allTerminals.first;
	if terminal = null then 
		return;
	endif;

	_lstTable.rows := _lstTable.fixedRows;
	_lstTable.clearSelected();

	foreach machine in terminal.machines do
		if not machine.isCrane then
			continue;
		endif;
		crane := machine.CM_Crane;
		select := 0;
		if defaultCranes &lt;&gt; null and defaultCranes.includes(crane) then
			select := 1;
			_lstTable.allSelectedObjects.add(crane);	
		endif;
		
		idx := _lstTable.addItem(select.String &amp; Tab &amp; machine.description); 
		_lstTable.accessRow(idx).itemObject := crane;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadCranes" id="995075cf-c194-46e6-be12-b40f7b9b473a">
        <source>doLoadCranes(_cmb : CMUI_ComboBox input; _craneId : String) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voy 			: CM_Voyage;
	keepIdx,
	idx 			: Integer;
	jobSheet	 	: CM_VoyageJobSheet;
	crane 			: CM_Machine;
	terminal		: CM_Terminal;
begin
	terminal := self.allTerminals.first;
	if terminal = null or _cmb = null then
		return;
	endif;
	
	_cmb.clear;
	
	voy := self.myCmbCellularVoy.listObject.CM_Voyage;
	
	
	_cmb.itemData[_cmb.addItem("Unallocated Jobs")] := CMQF_VoyageOrderOfWork.JobType_Unallocated;
	_cmb.itemData[_cmb.addItem("All Jobs")] := CMQF_VoyageOrderOfWork.JobType_All;
	
	if voy &lt;&gt; null then
		keepIdx := -1;
		foreach jobSheet in voy.allJobSheets do
			crane := terminal.machines[jobSheet.crane.trimBlanks];
			
			if crane &lt;&gt; null then
				idx := _cmb.addItem(crane.id &amp; " - " &amp; crane.description);
				_cmb.itemObject[idx] := crane;
				_cmb.itemData[idx] := CMQF_VoyageOrderOfWork.JobType_Crane;
			endif;
		endforeach;
	endif;

	_cmb.text := "All Jobs";
	self.setValueByName(ETRow_Crane, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_craneId" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadDebtors" id="7611930c-f7b5-441d-a4ee-c9d000283e16">
        <source>doLoadDebtors(_cmb : CMUI_ComboBox input; _debtorCode : String);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		21 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars	
	combo 		: CMUI_ComboBox;
	debtor 		: CM_Debtor; 
	rootCompany	: CM_Bank;
	
begin
	if _cmb = null then
		return;
	endif;
	
	combo := _cmb;
	combo.clear();
	combo.addItem(app.getErrorString(AnyString));
	
	rootCompany := app.myRoot.myRootCompany;
	
	foreach debtor in rootCompany.debtors do
		combo.itemObject[combo.addItem(debtor.name)] := debtor;
	endforeach;
	
	if _debtorCode &lt;&gt; null then
		combo.text := _debtorCode;
	else
		combo.text := app.getErrorString(AnyString);
	endif;
	
	self.setValueByName(ETRow_Debtor, combo.text);
epilog
end;
	</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_debtorCode" type="String"/>
    </JadeMethod>
