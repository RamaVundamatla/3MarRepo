    <JadeMethod name="populateCargo" id="80ed3c48-581b-4fb1-8068-a08599f17312">
        <updating/>
        <source>populateCargo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation	TFS 2813 / 2549

*/

constants
	TAB_INDEX_START = 1000;
vars
	size : Integer;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	
	toCompleteCargo : CM_TISet;
	storedCargo : CM_TISet;
	
	bookingRef : CM_BookingRef;
	ti : CM_TrackedItem;
	
	here : CM_LocationsController;
	
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	buttonWidth : Real;
	buttonHeight : Integer;
	buttonOffset : Integer;
	extraDisplay : String;
	
	dynaDict : DynaDictionary;
	obj : Object;
	sortOrder : Integer;
	
begin

	self.docActsToDisplay.clear();	//03 Mar 2017	NDL	TFS 3299

	size := self.compTempButtonCount + self.storedButtonCount;
	if size &gt; 0 then
		foreach buttonNumber in 1 to size do
			menuButton := self.btnStoredTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				delete menuButton;
			endif;
			menuButton := self.btnToCompTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				delete menuButton;
			endif;
		endforeach;
		self.compTempButtonCount := 0;
		self.storedButtonCount := 0;
		buttonNumber := 0;
	endif;
	
	here := self.cmbSourceLoc.listObject.CM_LocationsController;
	if here = null then
		self.fldStripped.visible := false;
		self.cmbSourceLoc.setFocus;
		return;
	else
		self.fldStripped.visible := true;
	endif;
	
	create toCompleteCargo transient;
	create storedCargo transient;
	
	foreach bookingRef in self.myMobileGenericAgent.allSelectedBookings discreteLock do
		foreach ti in bookingRef.allTIs discreteLock do
			if ti.isContainer then
				// only want unpacked cargo
				continue;
			endif;
			if ti.isChild then
				// still packed
				continue;
			endif;
			if not ti.isOnSite then
				//gooone
				continue;
			endif;
			if ti.myPrimaryActualLocation = here then
				toCompleteCargo.addNoDuplicates( ti, false );
			else
				storedCargo.addNoDuplicates( ti, false );
			endif;
		endforeach;
	endforeach;
	
	//Find all the cargo to siplay and put in order
	create dynaDict transient;
	dynaDict.setMembership( CM_TrackedItem );
	if self.cmbSortBy.listIndex &gt; 0 then
		sortOrder := self.cmbSortBy.itemData[ self.cmbSortBy.listIndex ];
	endif;
	
	if sortOrder = 1 then	//"Sort By: Cargo Id"
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	elseif sortOrder = 2 then	//"Sort By: Cargo Type / Sub Type"
		dynaDict.addMemberKey(CM_TrackedItem::cargoTypeDescr.name, false, false);
		dynaDict.addMemberKey(CM_TrackedItem::productCode.name, false, false);
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	elseif sortOrder = 3 then	//"Sort By: Cargo Group Id / Cargo Id"
		dynaDict.addMemberKey(CM_TrackedItem::myCargoGroup.name, false, false);
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	else
		dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	endif;
	dynaDict.endKeys(true);
	
	
	//To Complete
	size := toCompleteCargo.size;
	buttonHeight := self.getScrollingButtonHeight();
	self.btnToCompTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmToComplete, self.btnToCompTemp.height, self.scrToComplete );
	
	if not toCompleteCargo.isEmpty then
		toCompleteCargo.copy( dynaDict );
		
		foreach obj in dynaDict discreteLock do
			ti := obj.CM_TrackedItem;
		
			if  ti.myBookingRefItem &lt;&gt; null then
				docActions := ti.myBookingRefItem.myBookingRefItemActions;
			else
				docActions := null;
			endif;
			
			buttonNumber := buttonNumber + 1;
			menuButton := self.btnToCompTemp.loadControl( buttonNumber ).MOB_Button;
			menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
			
			menuButton.userObject := ti;
			if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
											&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
			elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
											&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
			else
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
			endif;
			
			extraDisplay := null;
			if docActions &lt;&gt; null then
				taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
				if taskAndStopStr &lt;&gt; null then
					extraDisplay := " " &amp; taskAndStopStr;
					self.docActsToDisplay.addExclusive( docActions );
				endif;
			endif;
	
			menuButton.caption := menuButton.caption &amp; extraDisplay;
			
			self.addHazDetailsToButton( menuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
			
			menuButton.enabled := true;
			
			buttonOffset := buttonOffset + buttonHeight-2;
			menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
			
		endforeach;
	endif;
	
	self.compTempButtonCount := buttonNumber;
	
	self.btnToCompTemp.visible := false;
	self.frmToComplete.caption := null;
	
	lblNoToComplete.visible := (buttonNumber = 0);
	
	//Stored
	
	dynaDict.clear();
	
	buttonNumber := 0;
	buttonOffset := 0;
	size := storedCargo.size;
	buttonHeight := self.getScrollingButtonHeight();
	self.btnStoredTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmStored, self.btnStoredTemp.height, self.scrStored );
	
	if not storedCargo.isEmpty then
		storedCargo.copy( dynaDict );
		
		foreach obj in dynaDict discreteLock do
			ti := obj.CM_TrackedItem;
		
			if  ti.myBookingRefItem &lt;&gt; null then
				docActions := ti.myBookingRefItem.myBookingRefItemActions;
			else
				docActions := null;
			endif;
			
			buttonNumber := buttonNumber + 1;
			menuButton := self.btnStoredTemp.loadControl( buttonNumber ).MOB_Button;
			menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
			
			menuButton.userObject := ti;
			if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
											&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
			elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
											&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
			else
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
			endif;
			
			extraDisplay := null;
			if docActions &lt;&gt; null then
				taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
				if taskAndStopStr &lt;&gt; null then
					extraDisplay := " " &amp; taskAndStopStr;
					self.docActsToDisplay.addExclusive( docActions );
				endif;
			endif;
			
			menuButton.caption := menuButton.caption &amp; extraDisplay;
			
			self.addHazDetailsToButton( menuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
			
			menuButton.enabled := true;
			
			buttonOffset := buttonOffset + buttonHeight-2;
			menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
			
		endforeach;
	endif;
	
	self.storedButtonCount := buttonNumber;
	
	self.btnStoredTemp.visible := false;
	self.frmStored.caption := null;
	
	lblNoStored.visible := (buttonNumber = 0);
	
	self.resizeAllScrollButtons(); 

epilog

	delete toCompleteCargo;
	delete storedCargo;
	delete dynaDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbLocation" id="6ad33f1b-4c5e-4153-8352-1b48e32c7258">
        <updating/>
        <source>populateCmbLocation( _lc : CM_LocationsController )updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	ta : CM_TerminalArea;
	firstTa : CM_TerminalArea;
	iter : Iterator;
	newIndex : Integer;
	index : Integer;
	lc : CM_LocationsController;

begin

	self.cmbSourceLoc.clear();
	
	term := self.myMobileDataAgent.myTerminal; 
	firstTa := term.allTerminalAreasByTypeId.getAtKeyGeq( TA_TYPE_YARD_INTERCHANGE, null );
	
	if firstTa &lt;&gt; null then
		iter := term.allTerminalAreasByTypeId.createIterator;
		iter.startAtObject( firstTa );
		while iter.next( ta ) do
			if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
				break;
			endif;
			lc := null;
			if ta.isKindOf( CM_InterchangeArea ) then
				lc := ta.CM_InterchangeArea.getDefaultLane;   // 36089
			elseif ta.isKindOf( CM_BlockStack ) then
				lc := ta.CM_BlockStack.myLocationsController;
			endif;
			if lc = null then
				continue;
			endif;
			newIndex := self.cmbSourceLoc.addItem( ta.id );
			self.cmbSourceLoc.itemObject[newIndex] := lc;
		endwhile;
		
		if self.cmbSourceLoc.listCount &lt; 1 then
			self.cmbSourceLoc.addItemAt( app.getErrorString(Interchang_areas_avaialable), 1 );
		elseif self.cmbSourceLoc.listCount = 1 then
			self.cmbSourceLoc.listIndex := 1;
		else
			self.cmbSourceLoc.addItemAt( app.getErrorString(Select_current_area), 1 );
			self.cmbSourceLoc.listIndex := 1;
		endif;
		
		if _lc &lt;&gt; null then
			index := self.cmbSourceLoc.findObject(_lc);
			if index &gt; 0 then
				self.cmbSourceLoc.listIndex := index;
			endif;
		endif;
	endif;

epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="populateCmbSortBy" id="3b321192-0a8c-4efc-8466-cdee349ed2ea">
        <source>populateCmbSortBy();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

begin

	self.cmbSortBy.clear();
	self.cmbSortBy.itemData[self.cmbSortBy.addItem( app.getErrorString(Sort_cargo_id) )] := 1;
	self.cmbSortBy.itemData[self.cmbSortBy.addItem( app.getErrorString(Sort_cargo_type_type) )] := 2;
	self.cmbSortBy.itemData[self.cmbSortBy.addItem( app.getErrorString(Sort_cargo_group_cargo) )] := 3;


epilog

end;</source>
