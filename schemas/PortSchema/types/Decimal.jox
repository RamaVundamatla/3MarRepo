    <JadeMethod name="getFileSizeDisplay" id="c4654a83-2c81-45a7-ad7d-81d3756d6923">
        <source>getFileSizeDisplay(showBytes : Boolean) : String;

/*

Purpose:			Return a string corresponding to the display file size of the 
					receiver number of bytes (as per Windows Properties dialog).
					If the showBytes parameter is true, then display the formatted
					number of bytes as well.


Return Value:		String as described above


Date		Who		Reason
09 Aug 2001	KPD		Initial creation

*/
constants
	OneK			= 1024;
	OneThou			= 1000;
	ByteString		= "bytes";
	KBString		= "KB";
	MBString		= "MB";
	GBString		= "GB";
	TBString		= "TB";
	
vars
	displays		: StringArray;
	byteNF,
	sizeNF			: NumberFormat;
	displayString,
	returnString	: String;
	workDec			: Decimal[23,3];
	i				: Integer;
	
begin
// cnwdad1 01/09/2010 - PAR #20064.
//	byteNF := app.currentLocaleInfo.numericInfo.cloneSelf(true);
//	sizeNF := app.currentLocaleInfo.numericInfo.cloneSelf(true);
	byteNF := app.getMyLocaleInfoJMT().numericInfo.cloneSelf(true);
	sizeNF := app.getMyLocaleInfoJMT().numericInfo.cloneSelf(true);
	
	// Override byte format to display no decimals
	byteNF.decimalPlaces	:= 0;
	sizeNF.showLeadingZeros	:= true;
		
	// Override size format to display leading zero
	sizeNF.showLeadingZeros	:= true;

	create displays transient;
	displays.add(KBString);
	displays.add(MBString);
	displays.add(GBString);
	displays.add(TBString);

	if self &lt; OneThou then
		returnString := self.userNumberFormat(byteNF) &amp; " " &amp; ByteString;
	else
		workDec := self / OneK;
		foreach i in 1 to displays.size do
			if workDec &lt; OneThou or i = displays.size then
				// Change number of decimals to get 3 significant figures
				sizeNF.decimalPlaces := 2 - workDec.Real.log10.Integer.min(2);

				// And display
				returnString := workDec.userNumberFormat(sizeNF) &amp; displays[i];
				break;
			endif;
			
			workDec := workDec / OneK;
		endforeach;
	endif;
				
	// Now attach actual number of bytes if required	
	if showBytes then
		returnString := returnString &amp; " (" &amp; self.userNumberFormat(byteNF) &amp; " " &amp; ByteString &amp; ")";
	endif;
	
	return returnString;
epilog
	delete byteNF;
	delete sizeNF;
	delete displays;
end;</source>
        <Parameter name="showBytes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
