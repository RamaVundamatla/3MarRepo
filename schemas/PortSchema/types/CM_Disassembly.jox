    <JadeMethod name="docketCorrectionLocn_stockMove" id="ae62e3c7-5680-44de-a219-c02f2e9e8312">
        <updating/>
        <source>docketCorrectionLocn_stockMove( _oldLocation, _newLocation : CM_LocationsController ) updating;
// --------------------------------------------------------------------------------------------------------
// Created:     26 March 2008 by cnwvu1
//
// Purpose:		Corrects stock move for the transaction.
//
//				Note. This method is called by docket correction when changed Location
// --------------------------------------------------------------------------------------------------------

vars

begin
	
	inheritMethod( _oldLocation, _newLocation );

	// there are no changes for residual values, because the product hasn't been changed 
	// when Docket Correction changes Location

end;
</source>
        <Parameter name="_oldLocation" type="CM_LocationsController"/>
        <Parameter name="_newLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionProd_stockMove" id="447a1746-5fe6-49dc-8dda-61b0eff97e04">
        <updating/>
        <source>docketCorrectionProd_stockMove( _oldProduct, _newProduct : CM_Product; 	_newQuantity: Integer; _newWeightKgs: Decimal; _newVolume: Decimal ) updating;
// --------------------------------------------------------------------------------------------------------
// Created:     26 March 2008 by cnwvu1
//
// Purpose:		Corrects stock move for the transaction when product has been changed by Docket Correction.
// --------------------------------------------------------------------------------------------------------

vars
	tmpLocation		: CM_LocationsController;
	tmpMovement		: CM_StockMovement;
	sedMean			: Decimal[6,2];
	tmpSOHLocation,
	tmpSOHLocation2	: CM_SOHLocation;
	tmpProduct		: CM_Product;
	tmpDateTime		: TimeStamp;
	tmpBucket		: CM_StockMoveBucket;
	tmpOldLength,
	tmpNewLength	: Decimal[6,2];
	
begin

	// correcting residual values
	self.residualVolume := _newVolume - self.totalVolume + self.residualVolume;
	self.residualLength := (_newProduct.CM_ProductLog.logLength*100).Integer - (_oldProduct.CM_ProductLog.logLength*100).Integer + self.residualLength;
	
	inheritMethod( _oldProduct, _newProduct, _newQuantity, _newWeightKgs, _newVolume );
	
end;
</source>
        <Parameter name="_oldProduct" type="CM_Product"/>
        <Parameter name="_newProduct" type="CM_Product"/>
        <Parameter name="_newQuantity" type="Integer"/>
        <Parameter name="_newWeightKgs" type="Decimal"/>
        <Parameter name="_newVolume" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="2253b22b-d1ca-4555-ab4f-caa5c56a7d0e">
        <source>getDisplayString(): String;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str				: String;
	reassemblyTxn	: CM_Reassembly;

begin

	if self.allReassemblyTransactions.isEmpty then
		return 'Split into unknown items';
	endif;

	foreach reassemblyTxn in self.allReassemblyTransactions do
		if str = null then
			str := reassemblyTxn.myTrackedItem.id;
		else
			str := str &amp; ', ' &amp; reassemblyTxn.myTrackedItem.id;
		endif;
	endforeach;

	return 'Split into ' &amp; str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="c55fde83-c217-492a-b338-dff36b8476f5">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:     31 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;

begin
	str := inheritMethod();
	
	return str &amp; ', ' &amp; self.getDisplayString();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
