    <JadeMethod name="btnReturnSave_click" id="331c9797-504b-43e4-a5a4-a2d6ac65670f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnReturnSave_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation

*/

vars

	wagon : CM_Wagon;
	railLine : CM_RailLine;
	pos : Integer;
	reDisplay : Boolean;
	
begin

	wagon := self.mnuReturnWagon.userObject.CM_Wagon;
	railLine := self.cmbReturnPos.listObject.CM_RailLine;
	if self.cmbReturnPos.listIndex &gt; 0 then
		pos := self.cmbReturnPos.itemData[self.cmbReturnPos.listIndex];
	endif;

	reDisplay :=  self.myAssistant.YRD_Assistant.doReturnWagon( wagon, railLine, pos );
	self.frmReturnWagon.visible := false;
	self.frmToolbar.enabled := true;
	
	if reDisplay then
		// we want to show the wagon in rail area mode now;
		self.myCurrentRailArea := railLine.myRailArea;
		//self.myCurrentTrain := null;
		self.setMyTrain( null );	//14 May 2021	NDL	TFS 51199
		self.doShowTrainRail();
		self.optDirInTB.value := true;
		self.doChangeInOut();
	endif;
	
epilog

end;</source>
