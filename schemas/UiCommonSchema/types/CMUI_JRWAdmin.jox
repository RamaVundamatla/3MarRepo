    <JadeMethod name="create" id="c9c7e411-fba4-40c9-99bb-16369f53b63b">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.permissionView		:= PmReportAdminMaint;
	self.permissionMaint	:= PmReportAdminMaintMaint; // TFS 2198

end;</source>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="3bb3b8fe-fb9a-4762-a871-cc64185df47a">
        <updating/>
        <source>doFormLoad() updating;
// -----------------------------------------------------------------------------
// Created:		05 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.centreWindow();
	self.setNavigatorHeading(self.caption);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnJRWViews.enabled:= false;
		self.btnLoadReport.enabled:= false;
		self.btnLoadView.enabled:= false;
		self.btnOpenReport.enabled:= false;
		self.btnOpenView.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadReport" id="518acdd1-72c7-460d-b84f-942f0b78ca93">
        <updating/>
        <source>doLoadReport() updating, protected;
// -----------------------------------------------------------------------------
// Created:		05 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	jrwSchema 		: Schema;
	jrwGlobalClass 	: Class;
	jrwGlobalObject : Object;

	fileName		: String;
	
	
begin
	fileName := self.txtReportFile.text;
	if fileName = null then
		return;
	endif;
	jrwSchema 		:= rootSchema.getSchema("JadeReportWriterSchema");
	jrwGlobalClass 	:= jrwSchema.getGlobalClass;
	jrwGlobalObject := jrwGlobalClass.firstInstance;

	jrwGlobalObject.sendMsgWithParams('loadReportDefnFile', fileName, true);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadView" id="43c9b448-d52a-4bf9-8059-8b251289f976">
        <updating/>
        <source>doLoadView() updating, protected;
// -----------------------------------------------------------------------------
// Created:		05 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	jrwSchema 		: Schema;
	jrwGlobalClass 	: Class;
	jrwGlobalObject : Object;

	fileName		: String;
	
	
begin
	fileName := self.txtViewFile.text;

	if fileName = null then
		return;
	endif;

	jrwSchema 		:= rootSchema.getSchema("JadeReportWriterSchema");
	jrwGlobalClass 	:= jrwSchema.getGlobalClass;
	jrwGlobalObject := jrwGlobalClass.firstInstance;

	jrwGlobalObject.sendMsgWithParams('loadReportViewFile', fileName, true);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOpenReport" id="ab10023f-e49c-4b8b-8e34-e4b49781f88b">
        <updating/>
        <source>doOpenReport() updating;
// -----------------------------------------------------------------------------
// Created:		05 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	cmd : CMDFileOpen;
	
begin
	create cmd;
	cmd.filter := 'Report Definition (*.rwr)|*.rwr|All files|*.*';

	if cmd.open = 0 then
		txtReportFile.text := cmd.fileName;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenView" id="c2563d78-882e-43fc-aae5-ecdf8fae8dc3">
        <updating/>
        <source>doOpenView() updating;
// -----------------------------------------------------------------------------
// Created:		05 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	cmd : CMDFileOpen;
	
begin
	create cmd;
	cmd.filter := 'Report Views (*.rwv)|*.rwv|All files|*.*';
	if cmd.open = 0 then
		txtViewFile.text := cmd.fileName;
	endif;
end;</source>
    </JadeMethod>
