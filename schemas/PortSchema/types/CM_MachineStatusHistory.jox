*/

vars

begin
	self.setDetails(CM_MachineHistory.Type_SetdownDelay, _machine, _userCode);
epilog

end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
