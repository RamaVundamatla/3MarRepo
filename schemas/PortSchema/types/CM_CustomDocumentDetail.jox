    <JadeMethod name="setMyCustomDocument" id="f240a8ea-c90a-4e03-a6aa-96adfb979844">
        <updating/>
        <source>setMyCustomDocument(_custDoc : CM_CustomDocument) updating;
/*
Purpose:			

Date		Who		Reason
16 August 2023	navab1	CR 59615 TASK 59620
*/

vars

begin
