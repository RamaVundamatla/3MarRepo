    <JadeMethod name="buildOrAdjustAreaSize" id="b5b13178-834e-4d6a-affb-2db3f2fd2946">
        <updating/>
        <source>buildOrAdjustAreaSize(_setCMIF : Boolean) updating, protected;

vars

	row, col, height 		: Integer;
	id						: String;
	refresh					: Boolean;
	taType					: CM_TerminalAreaType;
	cmifTA					: CMIF_TerminalArea;
	use40FtHasChanged		: Boolean;
begin
	taType := self.cmbTAType.listObject.CM_TerminalAreaType;
	if taType = null then
		return;
	endif;
	
	// If the rows,columns, or units have changed, then these need to be saved before the design can be displayed PAR 16979
	if taType.type = TA_TYPE_IRREGULAR_BLOCK_AREA and self.myProxyObject &lt;&gt; null then
		if tblMain.getValueByName(ETRow_NumberOfRows).Integer &lt;&gt; self.myProxyObject.CM_IrregularBlockArea.rows or
		   tblMain.getValueByName(ETRow_NumberOfCols).Integer &lt;&gt; self.myProxyObject.CM_IrregularBlockArea.columns or
		   tblMain.getValueByName(ETRow_Unit).Integer &lt;&gt; self.myProxyObject.CM_IrregularBlockArea.unit then 
		   app.msgBox('The value for Rows, Columns or Unit has changed. Please save before continuing.', self.caption, 0); 
		   self.fldDefinition.topSheet := self.shtDefData;
		endif;
		return;
	endif;
	
	if self.myCMIFTerminalArea = null or self.myCMIFTerminalArea.taType &lt;&gt; taType.type then
		self.createCMIFTerminalArea(taType);
	endif;
	if _setCMIF then
		self.setCMIFFromTable();
	endif;
	
	use40FtHasChanged:=false;
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_GridArea) then
		use40FtHasChanged:= self.myCurrentObject.CM_GridArea.use40ftIds &lt;&gt; self.myCMIFTerminalArea.CMIF_GridArea.use40ftIds;
	endif;
	
	if self.myCurrentSOPGridArea = null or (self.myCurrentSOPGridArea.allGridRows.size = 0 and 
		self.myCurrentSOPGridArea.allGridColumns.size = 0 and self.myCMIFTerminalArea.height = 0 )then
		self.createSOPGridArea();	
		self.myCurrentSOPGridArea.setForCreate(self.myCMIFTerminalArea, self.myAssistant);
		self.frmMain.addGridAreaAndFrame(self.myCurrentSOPGridArea, self.frmGrdArea);
		self.redrawGrid:=true;
	else 
		if (self.myCurrentSOPGridArea.allGridColumns.size &lt;&gt; self.myCMIFTerminalArea.numColumns) or use40FtHasChanged then
			self.myCurrentSOPGridArea.updateForCol(self.myCMIFTerminalArea.CMIF_GridArea);
			self.redrawGrid:=true;
		endif;
		
		if  self.myCurrentSOPGridArea.allGridRows.size &lt;&gt; self.myCMIFTerminalArea.numRows then
			self.myCurrentSOPGridArea.updateForRow(self.myCMIFTerminalArea.CMIF_GridArea);
			self.redrawGrid:=true;
		endif;
		
		if self.myCurrentSOPGridArea.getHeightOfStack &lt;&gt; self.myCMIFTerminalArea.height then
			self.myCurrentSOPGridArea.updateForHeight(self.myCMIFTerminalArea.height);
			self.redrawGrid:=true;
		endif;
	endif;
	
epilog
	
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_setCMIF" type="Boolean"/>
    </JadeMethod>
