    <JadeMethod name="getContentsDesc" id="b810205e-3cd8-4932-bcf1-f54211a32a82">
        <source>getContentsDesc() : String;
/* ---------------------------------------------------------------------------
Created:     08 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	cs : CM_ContentsStatus;
begin
	cs :=  app.myRoot.allContentsStatuses[self.contentsStatus];
	
	if cs &lt;&gt; null then
		return cs.abbreviation;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
