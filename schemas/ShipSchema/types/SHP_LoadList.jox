// ---------------------------------------------------------------------------
// Created:     31 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.frmModalDialog.visible then
		self.modalDialogShow(null,'Return Data','Cancel',null,
						_cmifMonitor.message,
						'Searched ' &amp; _cmifMonitor.partsInJob.String &amp; '  found ' &amp; _cmifMonitor.partsDone.String);
	endif;
		
	self.btnModalDefault.doWindowEvents(0);
	if self.modalDialogReturnValue = ModalDialogReturn_Null then
		// see if the user has pressed the Cancel button
		self.btnModalOpt1.doWindowEvents(0);
		self.btnModalOpt2.doWindowEvents(0);
		
	endif;

	if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Return;
	elseif self.modalDialogReturnValue = self.ModalDialogReturn_Option1 then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;

end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateShtCaptions" id="a5afa0bd-259c-4829-afa8-3057453f0ced">
        <source>updateShtCaptions();
// ---------------------------------------------------------------------------
// Created:		25 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	rows			: String;
	intRow,
	visRows,
	tmpInt			: Integer;
begin

	if self.allColumnFilters = null or self.allColumnFilters.isEmpty then	// 25 Jan 2012	NDL	Par 25297
		self.shtPlanned.caption :=app.getErrorString(Planned) &amp; " (" &amp; (self.tblPlanned.rows - self.tblPlanned.fixedRows).String &amp; ")";
		self.shtNonplanned.caption := app.getErrorString(SHP_Non_Plann01) &amp; " (" &amp; (self.tblData.rows - self.tblData.fixedRows).String &amp; ")";
		tmpInt := self.tblDLR.rows - self.tblDLR.fixedRows;
		if tmpInt &lt;&gt; 0 then
			self.shtDLR.caption := app.getErrorString(SHP_DLR_Non_Planned) &amp; " (" &amp; (self.tblDLR.rows - self.tblDLR.fixedRows).String &amp; ")";
		else
			self.shtDLR.caption := app.getErrorString(SHP_DLR_Non_Planned);
		endif;
	 	self.shtTranship.caption := app.getErrorString(SHP_Tranship_Export_Items) &amp; " (" &amp; (self.tblTranShip.rows - self.tblTranShip.fixedRows).String &amp; ")";
	 	self.shtTBA.caption := app.getErrorString(TBANONPLANNED) &amp; " (" &amp; (self.tblTBA.rows - self.tblTBA.fixedRows).String &amp; ")"; // TFS 45590
		tmpInt := self.tblAll.rows - self.tblAll.fixedRows;
		if tmpInt &lt;&gt; 0 then
			self.shtAll.caption := app.getErrorString(LOADLIST_ALL) &amp; " (" &amp; (self.tblAll.rows - self.tblAll.fixedRows).String &amp; ")";
		else
			self.shtAll.caption := app.getErrorString(LOADLIST_ALL);
		endif;
	else
		//planned
		rows := (self.tblPlanned.rows - self.tblPlanned.fixedRows).asStringJMT;
		visRows := 0;
		foreach intRow in self.tblPlanned.fixedRows+1 to self.tblPlanned.rows do
			if self.tblPlanned.accessRow(intRow).visible then
				visRows := visRows + 1;
			endif;
		endforeach;
		self.shtPlanned.caption :=app.getErrorString(Planned) &amp; " (" &amp; visRows.String &amp; "/" &amp; rows &amp; ")";
		
		//unplanned
		rows := (self.tblData.rows - self.tblData.fixedRows).asStringJMT;
		visRows := 0;
		foreach intRow in self.tblData.fixedRows+1 to self.tblData.rows do
			if self.tblData.accessRow(intRow).visible then
				visRows := visRows + 1;
			endif;
		endforeach;
		self.shtNonplanned.caption := app.getErrorString(SHP_Non_Plann01) &amp; " (" &amp; visRows.String &amp; "/" &amp; rows &amp; ")";
		
		//dlr
		if self.tblDLR.rows &gt; self.tblDLR.fixedRows then
			rows := (self.tblDLR.rows - self.tblDLR.fixedRows).asStringJMT;
			visRows := 0;
			foreach intRow in self.tblDLR.fixedRows+1 to self.tblDLR.rows do
				if self.tblDLR.accessRow(intRow).visible then
					visRows := visRows + 1;
				endif;
			endforeach;
			self.shtDLR.caption := app.getErrorString(SHP_DLR_Non_Planned) &amp; " (" &amp; visRows.String &amp; "/" &amp; rows &amp; ")";		
		else
			self.shtDLR.caption := app.getErrorString(SHP_DLR_Non_Planned);
		endif;
		//tranship
		if self.tblTranShip.rows &gt; self.tblTranShip.fixedRows then
			rows := (self.tblTranShip.rows - self.tblTranShip.fixedRows).asStringJMT;
			visRows := 0;
			foreach intRow in self.tblTranShip.fixedRows+1 to self.tblTranShip.rows do
				if self.tblTranShip.accessRow(intRow).visible then
					visRows := visRows + 1;
				endif;
			endforeach;
			self.shtTranship.caption := app.getErrorString(SHP_Tranship_Export_Items) &amp; " (" &amp; visRows.String &amp; "/" &amp; rows &amp; ")";		
		else
			self.shtTranship.caption := app.getErrorString(SHP_Tranship_Export_Items);
		endif;
		// TBA
		// TFS 45590
		if self.tblTBA.rows &gt; self.tblTBA.fixedRows then 
			rows := (self.tblTBA.rows - self.tblTBA.fixedRows).asStringJMT;
			visRows := 0;
			foreach intRow in self.tblTBA.fixedRows+1 to self.tblTBA.rows do
				if self.tblTBA.accessRow(intRow).visible then
					visRows := visRows + 1;
				endif;
			endforeach;
			self.shtTBA.caption := app.getErrorString(SHP_Tranship_Export_Items) &amp; " (" &amp; visRows.String &amp; "/" &amp; rows &amp; ")";		
		else
			self.shtTBA.caption := app.getErrorString(SHP_Tranship_Export_Items);
		endif;
		
		//all
		if self.tblAll.rows &gt; self.tblAll.fixedRows then
			rows := (self.tblAll.rows - self.tblAll.fixedRows).asStringJMT;
			visRows := 0;
			foreach intRow in self.tblAll.fixedRows +1 to self.tblAll.rows do
				if self.tblAll.accessRow(intRow).visible then
					visRows := visRows + 1;
				endif;
			endforeach;
			self.shtAll.caption := app.getErrorString(LOADLIST_ALL) &amp; " (" &amp; visRows.String &amp; "/" &amp; rows &amp; ")";		
		else
			self.shtAll.caption := app.getErrorString(LOADLIST_ALL);
		endif;
	endif;

	if self.fldMain.topSheet = self.shtNonplanned then
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblData.allSelectedObjects.size.asStringJMT;
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblPlanned.allSelectedObjects.size.asStringJMT;
	elseif self.fldMain.topSheet = self.shtDLR then
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblDLR.allSelectedObjects.size.asStringJMT;
	elseif self.fldMain.topSheet = self.shtTranship then
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblTranShip.allSelectedObjects.size.asStringJMT;
	elseif self.fldMain.topSheet = self.shtTBA then // TFS 45590
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblTBA.allSelectedObjects.size.asStringJMT; // TFS 45590
	elseif self.fldMain.topSheet = self.shtAll then
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblAll.allSelectedObjects.size.asStringJMT;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateSummaryFromEDI" id="64cbda21-b197-4235-b6b6-f808a7ac49aa">
        <updating/>
        <source>updateSummaryFromEDI() updating, protected;
//----------------------------------------------------------------
//	Created:	30 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sumDict				: CMIF_LoadListSumByImexDischISO;
	sumObjectOld,
	sumObject			: CMIF_LoadListSummaryObject;
	deleteSum			: Boolean;
	//sr					: CM_SlotRequest;
	r					: CM_Request;	//20 Nov 2012	NDL	Par 30754
begin
	//remove the SR

	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty then
		return;
	endif;
	
	create sumDict transient;	//think about keeping this on the form

	self.mySummaryReport.allGroupedObjects.copy(sumDict);
	
	foreach sumObject in sumDict do
		foreach r in sumObject.allLoadRequests do
			sumObject.allLoadRequests.remove(r);
		endforeach;
		sumObject.redoTotalsForSR;
		deleteSum := (sumObject.allTrackedItems.isEmpty) and (sumObject.allLoadRequests.isEmpty);
		if deleteSum then
			self.mySummaryReport.removeObject(sumObject);
		endif;
	endforeach;
	
epilog
	delete sumDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateSummarySR" id="af2c254e-40a9-4e0d-80b1-2c4820cb5029">
        <updating/>
        <source>updateSummarySR(_req: CM_Request) updating, protected;
//----------------------------------------------------------------
//	Created:	28 September 2005	by Jason Chapman  (cnwjc2)
// 12/11/2015 cnwma1 PAR #36783 System Error 4 in SHP_LoadList::updateSummarySR
//----------------------------------------------------------------
vars
	sumDict			: CMIF_LoadListSumByImexDischISO;
	sumObjectNew,
	sumObjectCurrent,
	sumObjectOld,
	sumObject		: CMIF_LoadListSummaryObject;
	deleteSum,
	foundSR,
	newSum,
	matchesCriteria	: Boolean;
	imexKey			: Integer;
	ti				: CM_TrackedItem;
	//sr				: CM_SlotRequest;
	req				: CM_Request;	//21 Nov 2012	NDL	Par 30754
	slotReq			: CM_SlotRequest;	//21 Nov 2012	NDL	Par 30754
	voyReq			: CM_VoyageRequest;	//21 Nov 2012	NDL	Par 30754
	invalidObj		: Boolean;
	portCode		: String;	//21 Nov 2012	NDL	Par 30754
	objEdition      : Integer;
	
begin
	//find the SR	- if found		-&gt; update if it's in the wrong summary
	//				- if not found	-&gt; add it
	//on Exception do handleDeletedSRSummUpdate(exception, _sr); // adm 150708 Par 17531 - commented by cnwvu1 19/07/2010
	on Exception do app.handleDeletedObject( exception, req, invalidObj); // #17531 19/07/2010 cnwvu1
	on Exception do app.handleDeletedObject( exception, _req, invalidObj); // 12/11/2015 cnwma1 PAR #36783
	
	objEdition := _req.edition;											   // 12/11/2015 cnwma1 PAR #36783
	if invalidObj then
		return;
	endif;

	//21 Nov 2012	NDL	Par 30754
	if _req &lt;&gt; null and not _req.isKindOf( CM_SlotRequest ) and not _req.isKindOf( CM_RORORequest ) then
		return;
	endif;
	
	//cnwrd1 32670 we'll check the infalidObject from the exception handler we just armed shall we?
	if not invalidObj and _req &lt;&gt; null and _req.getAttrIsBackend() then
		return;
	endif;
	
	if not invalidObj and _req &lt;&gt; null and _req.isKindOf( CM_SlotRequest )
	and _req.CM_SlotRequest.isDischarge then // PAR 21746
		return;
	endif;
	
	if not invalidObj and _req &lt;&gt; null and _req.isKindOf( CM_RORORequest )
	and _req.CM_RORORequest.isDischarge then
		return;
	endif;
	
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty then
		return;
	endif;
	
	if self.mySummaryFilter = null then
		return;
	endif;
	
	invalidObj := false;
	
	self.resetSummaryCriteria();
	create sumDict transient;	//think about keeping this on the form
	self.mySummaryReport.allGroupedObjects.copy(sumDict);
	
	foreach req in self.allRequestsSummUpdate do
		slotReq := null;
		voyReq := null;
		if req.isSlotRequest then
			slotReq := req.CM_SlotRequest;
			matchesCriteria := self.mySummaryFilter.includesObjectSR(slotReq, app.myPassport);
			portCode := slotReq.dischargePort;
		else
			voyReq := req.CM_VoyageRequest;
			matchesCriteria := self.mySummaryFilter.includesObjectVoyReq(voyReq, app.myPassport);
			if voyReq.getAttrDischargePort &lt;&gt; null then
				portCode := voyReq.getAttrDischargePort.code;
			else
				portCode := null;
			endif;
		endif;
		sumObjectOld := null;
		deleteSum := false;
		foundSR := false;
		newSum := false;
		
		imexKey := TI_IMEX_STATUS_EXPORT;
		if ( slotReq &lt;&gt; null and slotReq.isRehandle )
		or ( voyReq &lt;&gt; null and voyReq.isRehandle )
		then
			imexKey := TI_IMEX_STATUS_REMAINONBOARD;
		endif;
		
		if invalidObj then	// #17531 19/07/2010 cnwvu1
			self.allRequestsSummUpdate.remove(req); 	// invalid objects in collection can grow in some scenarios?
			invalidObj := false;						// setting to false for the next instance in the ocllection.
			continue;
		endif;
		
		
		sumObjectCurrent := sumDict[imexKey,portCode,req.getPlannersGroup];
	
		if sumObjectCurrent = null then
			//either changed or new
			newSum := true;
		else
			//changed?
			if sumObjectCurrent.allLoadRequests.includes(req) then
				foundSR := true;
			endif;
		endif;
	
		if not foundSR then
			//search for it (also see if old sumObj is still required)
			foreach sumObject in sumDict do
				if sumObject.allLoadRequests.includes(req) then
					deleteSum := (sumObject.allLoadRequests.size = 1) and (sumObject.allTrackedItems.isEmpty);
					sumObjectOld := sumObject;
					break;	
				endif;
			endforeach;
		elseif not matchesCriteria then // PAR 16276 remove the slot request as it has been updated and is no longer relevant.
		
			sumObjectOld := sumObjectCurrent;
		endif;
		
		if newSum and matchesCriteria then
			create sumObjectNew transient;
			if slotReq &lt;&gt; null then
				sumObjectNew.setFromSR(slotReq, imexKey);
			elseif voyReq &lt;&gt; null then
				sumObjectNew.setFromVoyReq(voyReq, imexKey);
			endif;
			sumDict.add(sumObjectNew);
			sumObjectNew.allLoadRequests.add(req);
			sumObjectNew.redoTotalsForSR;
			self.mySummaryReport.addObject(sumObjectNew);
		endif;
	
		if sumObjectCurrent &lt;&gt; null then
			//this will pickup change in planning state
			if (not foundSR) and matchesCriteria then
				sumObjectCurrent.allLoadRequests.add(req);
			endif;
			sumObjectCurrent.redoTotalsForSR;
		endif;
		
		if sumObjectOld &lt;&gt; null then
			//ti does not belong here
			sumObjectOld.allLoadRequests.remove(req);
			deleteSum := (sumObjectOld.allLoadRequests.isEmpty()) and (sumObjectOld.allTrackedItems.isEmpty());
			if deleteSum then
				sumDict.removeIfPresent(sumObjectOld);	//need to keep this up to date
				self.mySummaryReport.removeObject(sumObjectOld);
			else
				sumObjectOld.redoTotalsForSR();
			endif;
		endif;
	
	endforeach;
	
	self.allRequestsSummUpdate.clear;

epilog
	delete sumDict;
end;</source>
        <access>protected</access>
        <Parameter name="_req" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="updateSummaryTI" id="562d13cc-464d-4297-ac4f-d2b23d95752b">
        <updating/>
        <source>updateSummaryTI(_ti : CM_TrackedItem; _waitForNotes : Boolean)updating, protected;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 13/08/2010	cnwdap1		PAR #25371 Treat Tranships as Exports
vars
	sumDict			: CMIF_LoadListSumByImexDischISO;
	sumObjectNew,
	sumObjectCurrent,
	sumObjectOld,
	sumObject		: CMIF_LoadListSummaryObject;
	deleteSum,
	breakOut,
	foundTI,
	newSum,
	matchesCriteria	: Boolean;
	imexKey, intRow	: Integer;
	ti				: CM_TrackedItem;
	startTime		: TimeStamp;
	
begin
	//find the TI	- if found		-&gt; update if it's in the wrong summary update it
	//				- if not found	-&gt; add it
	
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty then
		return;
	endif;
	
//	if _waitForNotes then 
//		if self.waitForNotesTI(_ti) then	
//			return;
//		endif;
//	else
//	if _ti &lt;&gt; null then
//		self.allTIsSummaryUpdate.addNoDuplicates(_ti, false);
//	endif;
//	endif;

	if self.mySummaryFilter = null then
		return;
	endif;
	//
	//  Replaced by cnStartTransaction in doCentralisedTINoteUpdate PAR 21787
	//
	//startTime := app.actualTimeServer();
	//app.lockKeeperNotifyStartActivity(startTime, method, null, 'Updating loadlist summary', app.myPassport);
	
	self.resetSummaryCriteria();
	sumDict := self.summarySortDict;
	//create sumDict transient;	//think about keeping this on the form
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);

	foreach ti in self.allTIsSummaryUpdate do	
		if not global.isValidObject(ti) then
			self.allTIsSummaryUpdate.remove(ti);
			continue;
		endif;
		
		matchesCriteria := self.mySummaryFilter.checkStatusIncludesObject(ti, app.myPassport, breakOut);
		sumObjectOld := null;
		deleteSum := false;
		foundTI := false;
		newSum := false;
		
		//JT - 06 Oct "not interested in Tranships".  CNWJC2
		// PAR #25371 treat tranships as exports
		if ti.isTranshipItem then
			imexKey := CMIF_LoadListSummaryObject.IMEX_KEY_EXPORT;
		else
			imexKey := ti.getImExStatus;
		endif; 
		
		sumObjectCurrent := sumDict[imexKey,ti.dischargePort,ti.getPlannerReportGroup];
		
		// par 11095 - summary is being updated when ANY new pre-note is created. 
		if not ti.includeOnLoadList(self.myCurrentVoyage, self.myTerminal) then 
			// now need to check if in table if so, summary will need to be updated. (will be removed from table in by calling code.) 
			if self.tblData.findObjectInRow(ti, intRow) then
				sumObjectOld := sumObjectCurrent; // setting this will remove ti from summary.
			else		
				continue; // dont make summary object as this object should not be included. (Pre_Notes for other voyages were getting in here.)
				// However some need to get in here as they may need to be taken off the summary. (eg. voyage changed)
			endif;
		endif;
		
		if sumObjectCurrent = null then
			//either changed or new
			newSum := true;
		else
			//changed?
			if sumObjectCurrent.allTrackedItems.includes(ti) then
				if sumObjectCurrent.imexStatus = 6 and not ti.isRehandle then // PAR 11070
					deleteSum := (sumObjectCurrent.allTrackedItems.size = 1) and (sumObjectCurrent.allLoadRequests.isEmpty); // PAR 11070
					sumObjectOld := sumObjectCurrent; // PAR 11070
					foundTI := true;
				else
					foundTI := true;
				endif;
			endif;
		endif;
	
		if not foundTI then
			//search for it (also see if old sumObj is still required)
			foreach sumObject in sumDict do
				if sumObject.allTrackedItems.includes(ti) then
					deleteSum := (sumObject.allTrackedItems.size = 1) and (sumObject.allLoadRequests.isEmpty);
					sumObjectOld := sumObject;
					break;	
				endif;
			endforeach;
		endif;
		
		if newSum and matchesCriteria then
			create sumObjectNew transient;
			sumObjectNew.setFromTI(ti, imexKey);
			sumDict.add(sumObjectNew);
			sumObjectNew.allTrackedItems.add(ti);
			//sumObjectNew.redoTotalsForTI;
			sumObjectNew.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_ADD);
			self.mySummaryReport.addObject(sumObjectNew);
		endif;
	
		if sumObjectCurrent &lt;&gt; null then
			//this will pickup change in planning state
			if (not foundTI) and matchesCriteria then
				sumObjectCurrent.allTrackedItems.add(ti);
			endif;
			//sumObjectCurrent.redoTotalsForTI;
			sumObjectCurrent.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_UPDATE);
		endif;
		
		if sumObjectOld &lt;&gt; null then
			//ti does not belong here
			sumObjectOld.allTrackedItems.remove(ti);
			//sumObjectOld.redoTotalsForTI;
			sumObjectOld.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_REMOVE);
			if deleteSum then
				sumDict.removeIfPresent(sumObjectOld);	//need to keep this up to date
				self.mySummaryReport.removeObject(sumObjectOld);
			endif;
		endif;

	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_waitForNotes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSummaryTIFromNote" id="6edd3ad5-3c69-4d4c-98be-ad1963c49567">
        <updating/>
        <source>updateSummaryTIFromNote(_ti : CM_TrackedItem)updating, protected;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 13/08/2010	cnwdap1		PAR #25371 Tranships should be included in with Exports
// 12/10/2010	cnwdap1		PAR #26018 Prevent "Key already used in this dictionary" errors by using tranship discharge port for tranships
vars
	sumDict			: CMIF_LoadListSumByImexDischISO;
	sumObjectNew,
	sumObjectCurrent,
	sumObjectOld,
	sumObject		: CMIF_LoadListSummaryObject;
	deleteSum,
	breakOut,
	foundTI,
	newSum,
	matchesCriteria	: Boolean;
	imexKey, intRow	: Integer;
	ti				: CM_TrackedItem;
	startTime		: TimeStamp;
	dischargePort	: String;		// PAR #26018
	
begin
	//find the TI	- if found		-&gt; update if it's in the wrong summary update it
	//				- if not found	-&gt; add it
	
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty 
	or not app.isValidObject(_ti) then
		return;
	endif;
	ti := _ti;

	if self.mySummaryFilter = null then
		return;
	endif;
	//
	//  Replaced by cnStartTransaction in doCentralisedTINoteUpdate PAR 21787
	//
	//startTime := app.actualTimeServer();
	//app.lockKeeperNotifyStartActivity(startTime, method, null, 'Updating loadlist summary', app.myPassport);
	
	// Move this up. Big hit each update.
	
	//self.resetSummaryCriteria();
	sumDict := self.summarySortDict;
	//create sumDict transient;	//think about keeping this on the form
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);

		
	matchesCriteria := self.mySummaryFilter.checkStatusIncludesObject(ti, app.myPassport, breakOut);
	sumObjectOld := null;
	deleteSum := false;
	foundTI := false;
	newSum := false;
	
	//JT - 06 Oct "not interested in Tranships".  CNWJC2
	// PAR #25371 Tranships now included with Export totals
	if ti.isTranshipItem then
		imexKey := CMIF_LoadListSummaryObject.IMEX_KEY_EXPORT;
	else
		imexKey := ti.getImExStatus;
	endif; 
	
	// PAR #26018 get correct discharge port for using in summary comparison
	if ti.isTranshipItem and ti.myTranshipDetail &lt;&gt; null and ti.myTranshipDetail.myDischargePort &lt;&gt; null then
		dischargePort := ti.myTranshipDetail.myDischargePort.code;
	else
		dischargePort := ti.dischargePort;
	endif;
	
	// par 11095 - summary is being updated when ANY new pre-note is created. 
	if not ti.includeOnLoadList(self.myCurrentVoyage, self.myTerminal) then 
		// now need to check if in table if so, summary will need to be updated. (will be removed from table in by calling code.) 
		if self.tblData.findObjectInRow(ti, intRow) then
			sumObjectOld := sumObjectCurrent; // setting this will remove ti from summary.
		else		
			return; // dont make summary object as this object should not be included. (Pre_Notes for other voyages were getting in here.)
			// However some need to get in here as they may need to be taken off the summary. (eg. voyage changed)
		endif;
	endif;
	
	// PAR #26018 use correct discharge port for tranships
	//sumObjectCurrent := sumDict[imexKey,ti.dischargePort,ti.getPlannerReportGroup];
	sumObjectCurrent := sumDict[imexKey,dischargePort,ti.getPlannerReportGroup];
	
	if sumObjectCurrent = null then
		//either changed or new
		newSum := true;
	else
		//changed?
		if sumObjectCurrent.allTrackedItems.includes(ti) then
			if sumObjectCurrent.imexStatus = TI_IMEX_STATUS_REMAINONBOARD and not ti.isRehandle then // PAR 11070
				deleteSum := (sumObjectCurrent.allTrackedItems.size = 1) and (sumObjectCurrent.allLoadRequests.isEmpty); // PAR 11070
				sumObjectOld := sumObjectCurrent; // PAR 11070
				foundTI := true;
			else
				foundTI := true;
			endif;
		endif;
	endif;

	if not foundTI then
		//search for it (also see if old sumObj is still required)
		foreach sumObject in sumDict do
			if sumObject.allTrackedItems.includes(ti) then
				deleteSum := (sumObject.allTrackedItems.size = 1) and (sumObject.allLoadRequests.isEmpty);
				sumObjectOld := sumObject;
				break;	
			endif;
		endforeach;
	endif;
	
	if newSum and matchesCriteria then
		create sumObjectNew transient;
		sumObjectNew.setFromTI(ti, imexKey);
		sumDict.add(sumObjectNew);
		sumObjectNew.allTrackedItems.add(ti);
		//sumObjectNew.redoTotalsForTI;
		sumObjectNew.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_ADD);
		self.mySummaryReport.addObject(sumObjectNew);
	endif;

	if sumObjectCurrent &lt;&gt; null then
		//this will pickup change in planning state
		if (not foundTI) and matchesCriteria then
			sumObjectCurrent.allTrackedItems.add(ti);
		endif;
		//sumObjectCurrent.redoTotalsForTI;
		sumObjectCurrent.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_UPDATE);
	endif;
	
	if sumObjectOld &lt;&gt; null then
		//ti does not belong here
		sumObjectOld.allTrackedItems.remove(ti);
		//sumObjectOld.redoTotalsForTI;
		sumObjectOld.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_REMOVE);
		if deleteSum then
			sumDict.removeIfPresent(sumObjectOld);	//need to keep this up to date
			self.mySummaryReport.removeObject(sumObjectOld);
		endif;
	endif;
	
		
epilog
	//delete sumDict;
	//
	//  Replaced by cnEndTransaction in doCentralisedTINoteUpdate PAR 21787
	//
	//app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateSummaryWLE" id="6f0c5669-d6fe-4d9b-9e71-b120d20db27e">
        <updating/>
        <source>updateSummaryWLE(_wle : CM_WorkListEntry; _waitForNotes : Boolean) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2010	cnwdap1	Initial creation PAR #26426 CCMS MES 1102 Release Requests on Ship Load List
08/03/2011	cnwmh5	PAR #27142 - Change to use handleDeletedObject rather than global.isValidObject
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
	sumDict			: CMIF_LoadListSumByImexDischISO;
	sumObjectNew,
	sumObjectCurrent,
	sumObjectOld,
	sumObject		: CMIF_LoadListSummaryObject;
	deleteSum,
	breakOut,
	foundWLE,
	newSum,
	matchesCriteria	: Boolean;
	imexKey			: Integer;
	wle				: CM_WorkListEntry;
	dischargePort	: String;
	isoGroupingKey	: String;
	invalidObj		: Boolean;
	
begin
	//find the WLE	- if found		-&gt; update if it's in the wrong summary update it
	//				- if not found	-&gt; add it
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty then
		return;
	endif;
	
	if self.mySummaryFilter = null then
		return;
	endif;
	
	wle := _wle;
	
	self.resetSummaryCriteria();
	sumDict := self.summarySortDict;
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);

	on Exception do app.handleDeletedObject(exception, wle, invalidObj);
	
	foreach wle in self.allWLEsSummaryUpdate do	
		
		wle.edition();
		if invalidObj then
			self.allWLEsSummaryUpdate.remove(wle);
			continue;
		endif;
		
		matchesCriteria := self.mySummaryFilter.checkStatusIncludesObject(wle, app.myPassport, breakOut);
		sumObjectOld 	:= null;
		deleteSum 		:= false;
		foundWLE 		:= false;
		newSum 			:= false;
		
		if wle.myRequest &lt;&gt; null and wle.myRequest.myReserveDetail &lt;&gt; null then
			//isoGroupingKey := wle.myRequest.myReserveDetail.myReserveHeader.getPlannerReportGroup();
			isoGroupingKey := wle.myRequest.myReserveDetail.getPlannerReportGroup();
		else
			isoGroupingKey := wle.getPlannerReportGroup;
		endif;
		imexKey := CMIF_LoadListSummaryObject.IMEX_KEY_EXPORT;
		if wle.myRequest &lt;&gt; null then
			dischargePort := wle.myRequest.getDischargePort;
		endif;
		sumObjectCurrent := sumDict[imexKey, dischargePort, isoGroupingKey];
		
		if not wle.includeOnLoadList(self.myCurrentVoyage, self.myTerminal) then 
			continue; // dont make summary object as this object should not be included.
		endif;
		
		if sumObjectCurrent = null then
			//either changed or new
			newSum := true;
		else
			//changed?
			if sumObjectCurrent.allWorkListEntries.includes(wle) then
				foundWLE := true;
			endif;
		endif;
	
		if not foundWLE then
			//search for it (also see if old sumObj is still required)
			foreach sumObject in sumDict do
				if sumObject.allWorkListEntries.includes(wle) then
					deleteSum := (sumObject.allWorkListEntries.size = 1) and (sumObject.allLoadRequests.isEmpty);
					sumObjectOld := sumObject;
					break;	
				endif;
			endforeach;
		endif;
		
		if newSum and matchesCriteria then
			create sumObjectNew transient;
			sumObjectNew.setFromWLE(wle, imexKey);
			sumDict.add(sumObjectNew);
			sumObjectNew.allWorkListEntries.add(wle);
			sumObjectNew.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_ADD);
			self.mySummaryReport.addObject(sumObjectNew);
		endif;
	
		if sumObjectCurrent &lt;&gt; null then
			//this will pickup change in planning state
			if (not foundWLE) and matchesCriteria then
				sumObjectCurrent.allWorkListEntries.add(wle);
			endif;
			sumObjectCurrent.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_UPDATE);
		endif;
		
		if sumObjectOld &lt;&gt; null then
			//ti does not belong here
			sumObjectOld.allWorkListEntries.remove(wle);
			sumObjectOld.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_REMOVE);
			if deleteSum then
				sumDict.removeIfPresent(sumObjectOld);	//need to keep this up to date
				self.mySummaryReport.removeObject(sumObjectOld);
			endif;
		endif;

	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_waitForNotes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSummaryWLEFromNote" id="b4d353d5-4870-4b81-b298-fb70e97c243c">
        <updating/>
        <source>updateSummaryWLEFromNote(_wle : CM_WorkListEntry) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2010	cnwdap1	Initial creation PAR #26426 CCMS MES 1102 Release Requests on Ship Load List
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
	wle				: CM_VoyageWLE;
	sumDict			: CMIF_LoadListSumByImexDischISO;
	sumObjectNew,
	sumObjectCurrent,
	sumObjectOld,
	sumObject		: CMIF_LoadListSummaryObject;
	matchesCriteria,
	breakOut,
	deleteSum,
	foundWLE,
	newSum			: Boolean;
	imexKey			: Integer;
	dischargePort	: String;
	isoGroupingKey	: String;

begin
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty 
	or not app.isValidObject(_wle) then
		return;
	endif;
	wle := _wle.CM_VoyageWLE;

	if self.mySummaryFilter = null then
		return;
	endif;
	
	sumDict := self.summarySortDict;
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);
		
	matchesCriteria := self.mySummaryFilter.checkStatusIncludesObject(wle, app.myPassport, breakOut);
	sumObjectOld	:= null;
	deleteSum 		:= false;
	foundWLE 		:= false;
	newSum 			:= false;
	
	if wle.myRequest &lt;&gt; null and wle.myRequest.bulkRelease &lt;&gt; null and wle.myRequest.bulkRelease.allReserveDetails.size &gt; 0 then
		//isoGroupingKey := wle.myRequest.bulkRelease.getPlannerReportGroup();
		isoGroupingKey := wle.myRequest.bulkRelease.allReserveDetails.first.getPlannerReportGroup();
	elseif wle.myRequest &lt;&gt; null and wle.myRequest.myReserveDetail &lt;&gt; null then
		//isoGroupingKey := wle.myRequest.myReserveDetail.myReserveHeader.getPlannerReportGroup();
		isoGroupingKey := wle.myRequest.myReserveDetail.getPlannerReportGroup();
	else
		isoGroupingKey := wle.getPlannerReportGroup;
	endif;
	imexKey := CMIF_LoadListSummaryObject.IMEX_KEY_EXPORT;
	if wle.myRequest &lt;&gt; null then
		dischargePort := wle.myRequest.getDischargePort;
	endif;
	
	sumObjectCurrent := sumDict[imexKey, dischargePort, isoGroupingKey];
	
	if sumObjectCurrent = null then
		//either changed or new
		newSum := true;
	else
		//changed?
		if sumObjectCurrent.allWorkListEntries.includes(wle) then
			foundWLE := true;
		endif;
	endif;

	if not foundWLE then
		//search for it (also see if old sumObj is still required)
		foreach sumObject in sumDict do
			if sumObject.allWorkListEntries.includes(wle) then
				deleteSum := (sumObject.allWorkListEntries.size = 1) and (sumObject.allLoadRequests.isEmpty);
				sumObjectOld := sumObject;
				break;	
			endif;
		endforeach;
	endif;
	
	if newSum and matchesCriteria then
		create sumObjectNew transient;
		sumObjectNew.setFromWLE(wle, imexKey);
		sumDict.add(sumObjectNew);
		sumObjectNew.allWorkListEntries.add(wle);
		sumObjectNew.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_ADD);
		self.mySummaryReport.addObject(sumObjectNew);
	endif;

	if sumObjectCurrent &lt;&gt; null then
		//this will pickup change in planning state
		if (not foundWLE) and matchesCriteria then
			sumObjectCurrent.allWorkListEntries.add(wle);
		endif;
		sumObjectCurrent.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_UPDATE);
	endif;
	
	if sumObjectOld &lt;&gt; null then
		// wle does not belong here
		sumObjectOld.allWorkListEntries.remove(wle);
		sumObjectOld.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_REMOVE);
		if deleteSum then
			sumDict.removeIfPresent(sumObjectOld);	//need to keep this up to date
			self.mySummaryReport.removeObject(sumObjectOld);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="updateTableColumnFilters" id="05ebe70f-3a0a-4397-b0ab-8a65220d8445">
        <updating/>
        <source>updateTableColumnFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 25297

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	self.allColumnFilters.replaceAllFiltersForTable( _table, _allFilterColumns );

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict"/>
    </JadeMethod>
    <JadeMethod name="updateTableItem" id="3706769f-f8a4-4470-be19-2b9a3e0ded75">
        <updating/>
        <source>updateTableItem(_table : CM_DataTable input; _ti : CM_TrackedItem) updating;
//--------------------------------------------------
// Created:	16 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	numZeros,
	rowIdx	: Integer;
o	: Object;
begin
	if _table = null then
		return;
	endif;

	if _table.allTableObjects &lt;&gt; null
	and (not _table.allTableObjects.noKeys()) then
		// sorting by more than 3 columns update dynaDict to sort
		//_table.setSortColumnTableObjects();
		
		if not _table.allTableObjects.includes(_ti) then
			_table.allTableObjects.addObject(_ti);
		endif;
		
		rowIdx := _table.allTableObjects.indexOf(_ti) + _table.fixedRows;
		
		self.doQueryAddItem(_table, rowIdx, _ti, 0);
		
	else
		rowIdx := self.doQueryAddItem(_table, 0, _ti, numZeros);
	endif;
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="a187400e-9841-4b2d-a4fb-c87ff25fe06e">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object)updating;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	app.mousePointer	:=	Busy;

	if _obj &lt;&gt; null and _event &lt;&gt; VoyageJob_Delete_Event then
		if _event = VoyageJob_Update_Event then
			if _obj.isKindOf(CM_VoyageJob) then
				if _obj.CM_VoyageJob.myVoyage = self.myCurrentVoyage then
	//				self.doQuery();
				endif;
			endif;
		else
			//must be a create, don't worry about showing it just now
		endif;
	else
		inheritMethod(_event,_noteobj, _obj);
	endif;

epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="2b884e74-7754-42e5-9bc7-a4ad73f0ee12">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------
vars
	
begin
	app.mousePointer	:=	Busy;

	self.doNotableNotification(eventType, theObject, eventTag, userInfo);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateCreateFilters" id="4a974bc9-68df-4746-8d41-d0f1d87c776c">
        <source>validateCreateFilters():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2012	cnwndl1	Initial creation

*/

vars

	
	strArray : StringArray;
	columnName : String;
	columIndex : Integer;
	str : String;
	tableList : String;
	msg : String;

begin

	create strArray transient;

	columnName := ETRow_Id;
	
	columIndex := self.tblData.getColumnByRowName( columnName );
	if columIndex &lt; 1 then
		strArray.add( "'" &amp; app.getErrorString(SHP_Non_Plann01) &amp; "'" );
	endif;
	
	columIndex := self.tblPlanned.getColumnByRowName( columnName );
	if columIndex &lt; 1 then
		strArray.add( "'" &amp; app.getErrorString(Planned) &amp; "'" );
	endif;
	
	columIndex := self.tblDLR.getColumnByRowName( columnName );
	if columIndex &lt; 1 then
		strArray.add( "'" &amp; app.getErrorString(SHP_DLR_Non_Planned) &amp; "'" );
	endif;
	
	if self.shtTranship.visible then
	columIndex := self.tblTranShip.getColumnByRowName( columnName );
	if columIndex &lt; 1 then
		strArray.add( "'" &amp; app.getErrorString(SHP_Tranship_Export_Items) &amp; "'" );
	endif;
	endif;
	
	if self.shtTBA.visible then // TFS 45590
		columIndex := self.tblTBA.getColumnByRowName( columnName );
		if columIndex &lt; 1 then
			strArray.add( "'" &amp; app.getErrorString(TBANONPLANNED) &amp; "'" );
		endif;
	endif;
	
	columIndex := self.tblAll.getColumnByRowName( columnName );
	if columIndex &lt; 1 then
		strArray.add( "'" &amp; app.getErrorString(LOADLIST_ALL) &amp; "'" );
	endif;

	if not strArray.isEmpty then
		foreach str in strArray do
			if tableList = null then
				tableList := str;
			else
				tableList := tableList &amp; ", " &amp; str;
			endif;
		endforeach;
		msg := app.getErrorString1( Colum_must_visib_permi_this_ac, columnName ) &amp; CrLf &amp; app.getErrorString1(Tables,tableList);
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	return true;
	
epilog

	delete strArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDEVCreateMOVINS" id="059594e1-39d1-4778-9c65-1e36902b2614">
        <source>zDEVCreateMOVINS();
/*
Purpose:			
Date		Who		Reason
20 March 2014	cnwab1	Initial creation
*/

vars
	movin : String;
	file		: File;
	cmdFile		: CMDFileOpen;

begin

	if self.myCurrentVoyage = null then
		return;
	endif;
	

	app.msgBox("This feature is for Developers." &amp; CrLf &amp; CrLf &amp;  
					"It creates a MOVINS file, based on the onsite" &amp; CrLf &amp; 
					"and prenote exports for the current voyage.","DEVELOPER MOVINS",MsgBox_OK_Only);

	create cmdFile;
	cmdFile.dialogTitle	:= 'Select a file';
	cmdFile.fileName := self.myCurrentVoyage.code &amp; "-MOVINS.txt";

	cmdFile.createPrompt := true;

	if cmdFile.open = 0 then
		app.mousePointer	:= Busy;
	
		movin := self.myCurrentVoyage.zDEV_CreateMOVINS();
		app.mousePointer	:= Idle;
		create file;
		file.mode		:= file.Mode_Output;
		
		//file.kind		:= file.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		file.fileName	:= cmdFile.fileName;
		file.writeString(movin);
	endif;
	
epilog
	delete file;
	delete cmdFile;
	
end;</source>
    </JadeMethod>
</GUIClass>
