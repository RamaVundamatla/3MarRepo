    <JadeMethod name="mnuTransfer_click" id="596a9c67-8642-4421-aa76-4ee541c35716">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuTransfer_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;

begin

	//06 Nov 2019	NDL	TFS 47100
	if not self.tblBOLItems.allSelectedObjects.isEmpty then
		iter := self.tblBOLItems.allSelectedObjects.createIterator();
		while iter.next( ti ) do
			if ti.isChild then
				if self.tblBOLItems.allSelectedObjects.includes( ti.myParent ) then
					app.msgBox( app.getErrorString(Not_proce_paren_their_child_sa), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
					return;
				endif;
			endif;
		endwhile;
	endif;

	self.doTransfer();

epilog

	delete iter;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="positionQueryFrame" id="db07cd82-b4de-4267-a5d0-ffc749cf8218">
        <source>positionQueryFrame()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2010	cnwmd1	Initial creation
7 July 2022 navukv20 ChangeRequest 53915: MTN - BOL Maintenance Toolbars
21 July 2022 navrk21 ChangeRequest 53915: MTN - BOL Maintenance Toolbars
*/

vars

begin
	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	100;
	//self.frmQuery.height	:=	250;	// 21.07.2022 navrk21 TFS 53915
	self.frmQuery.height	:=	245;	// 21.07.2022 navrk21 TFS 53915
	self.frmQuery.width		:=	320;
	
	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.fldQuery.left		:=	0;
	//self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);	// 07.07.2022 navukv20 TFS 53915
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height);	// 07.07.2022 navukv20 TFS 53915
	self.fldQuery.width		:=	self.frmQuery.clientWidth();
	self.lstCargoTypes.height	:= self.shtCargoTypes.height;	// 21.07.2022 navrk21 TFS 53915
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="receiveDrop" id="97f486d3-1d2a-4d5a-91f1-df98d262992e">
        <updating/>
        <source>receiveDrop(_sourceTable : CM_DataTable input; _targetTable : CM_DataTable input) updating, protected;
//--------------------------------------------------------------
// 	drag from tblCargo to tblBOL adds the on-ship cargo to the target BOL detail item.
// 	drag from tblCargo to tblBOLItems adds the on-ship cargo to the current BOL detail item, IF there is a selected tblBOL entry which has set the current BOL detail.
//	drag from tblBOLItems to tblBOL changes the item BOL to the target BOL detail item.
//	drag from tblBOLItems to tblCargo removes the item from the original BOL detail, adding it back on-ship.
//  any other drag combination does nothing.
//
//	a drop on tblBOL uses the table dragRow property to get the BOL detail, making it the new selected BOL detail.  A drop into the table but outside the
//		BOL item rows uses the currently selected row BOL item.
//--------------------------------------------------------------
vars
	idx,
	result 	: Integer;
	obj 	: CM_Object;
	ti		: CM_TrackedItem;
	tiSet	: CM_TISet;
	iter : Iterator;
begin
	if _sourceTable = null or
	   _targetTable = null then
		return;
	endif;
	
	//06 Nov 2019	NDL	TFS 47100
	if _sourceTable = self.tblBOLItems then
		if not self.tblBOLItems.allSelectedObjects.isEmpty then
			iter := self.tblBOLItems.allSelectedObjects.createIterator();
			while iter.next( ti ) do
				if ti.isChild then
					if self.tblBOLItems.allSelectedObjects.includes( ti.myParent ) then
						app.msgBox( app.getErrorString(Not_proce_paren_their_child_sa), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
						return;
					endif;
				endif;
			endwhile;
		endif;
		if _targetTable = self.tblBOL then
			self.doTransfer();
			return;
		endif;
	endif;

	if _targetTable = self.tblBOL then
		// drop row becomes the current, if valid
		if self.tblBOL.dragRow &gt; self.tblBOL.fixedRows then
			obj := self.tblBOL.accessRow(self.tblBOL.dragRow).itemObject.CM_Object;
		endif;
		if obj &lt;&gt; null and
		   global.isValidObject(obj) then
			if obj.isKindOf(CM_BOLDtl) then
				self.myCurrentBOLDetail := obj.CM_BOLDtl;
				self.myCurrentBOL := self.myCurrentBOLDetail.myBOL;
				self.tblBOL.clearAllSelected();
				self.tblBOL.selectRow(self.tblBOL.dragRow, false);
			// 23144 handle cargo linked to BOL but not BOL detail
			elseif obj.isKindOf(CM_BOL) then
				self.myCurrentBOL := obj.CM_BOL;
				self.myCurrentBOLDetail := null;
				self.tblBOL.clearAllSelected();
				self.tblBOL.selectRow(self.tblBOL.dragRow, false);
			endif;
		endif;
	endif;

	if _targetTable = self.tblBOL or
	   _targetTable = self.tblBOLItems then
		if self.myCurrentBOL = null and
		   self.myCurrentBOLDetail = null then
			return;
		endif;
		create tiSet transient;
		_sourceTable.allSelectedObjects.copy(tiSet);
		self.doLinkItems(self.myCurrentBOL, self.myCurrentBOLDetail, tiSet);

	endif;

	if _targetTable = self.tblCargo then
		create tiSet transient;
		_sourceTable.allSelectedObjects.copy(tiSet);
		self.doUnlinkItems(tiSet);

	endif;
epilog
	delete tiSet;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_sourceTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_targetTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="refreshBOLDetailEntry" id="16190ee9-ba7d-4605-8a83-c6341cdc1976">
        <updating/>
        <source>refreshBOLDetailEntry(_oldBOLDetail : CM_BOLDtl) updating, protected;
// after link/unlink/relink refresh the current tblBOL row to show the new quantity differences and totals
// parameter is optional original detail from a change, to refresh that row as well
vars
	idx	: Integer;
begin
	if _oldBOLDetail &lt;&gt; null then
		if self.tblBOL.findObjectInRow(_oldBOLDetail, idx) then
			self.tblBOL.accessCell(idx, 1).text := _oldBOLDetail.getAttributeStringForDefArray(self.tblBOL.allTblDataEntRows);
		endif;
	endif;

	if self.tblBOL.row &gt; self.tblBOL.fixedRows and
	   self.myCurrentBOLDetail &lt;&gt; null then
		self.tblBOL.accessCell(self.tblBOL.row, 1).text := self.myCurrentBOLDetail.getAttributeStringForDefArray(self.tblBOL.allTblDataEntRows);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_oldBOLDetail" type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="refreshBOLEntry" id="32a54d1e-048f-4c7a-a930-915195c94e4b">
        <updating/>
        <source>refreshBOLEntry(_oldBOL : CM_BOL) updating, protected;
// 23144 handle cargo linked to BOL but not BOL detail
// after link/unlink/relink refresh the current tblBOL row to show the new quantity differences and totals
// parameter is optional original detail from a change, to refresh that row as well
vars
	idx	: Integer;
begin
	if _oldBOL &lt;&gt; null then
		if self.tblBOL.findObjectInRow(_oldBOL, idx) then
			self.tblBOL.accessCell(idx, 1).text := _oldBOL.getAttributeStringForDefArray(self.tblBOL.allTblDataEntRows);
		endif;
	endif;

	if self.tblBOL.row &gt; self.tblBOL.fixedRows and
	   self.myCurrentBOL &lt;&gt; null then
		self.tblBOL.accessCell(self.tblBOL.row, 1).text := self.myCurrentBOL.getAttributeStringForDefArray(self.tblBOL.allTblDataEntRows);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_oldBOL" type="CM_BOL"/>
    </JadeMethod>
