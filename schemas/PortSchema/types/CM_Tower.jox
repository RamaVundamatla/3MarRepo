    <JadeMethod name="transactionCleanup" id="210a8abf-9a18-4342-85a2-4699a09dda32">
        <source>transactionCleanup(purgeBeforeDate : Date);
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwdwq1
//This method is designed to be called on objects that lay around in the CMS for a
//long time, it is called from Garbage Collect, and cleans up old transactions.
//Really applies to Towers etc that have heaps of TI's connected/disconnected, then
//shipped away, never to be seen again.
//Method expects a date and searches thru the TI's transactions
//for those OLDER than the supplied date, once found, it determines if the trans
//in question is a "otherTrackedItem" type, if so, it sees if the ref is null, or
//not valid (oid is there, but object does not exist), if so, it removes the 
//transaction from the TI.
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	trans : CM_TITransaction;
	otherTI : CM_TrackedItem;
begin

	foreach trans in self.allTransactions do
		if trans.dateTime.date &gt; purgeBeforeDate then
			//------------------
			//Trans are in pseudo date order, no sense checking any more
			//------------------
			return;
		endif;
		if trans.hasOtherTrackedItem = false then
			continue;
		endif;
		//------------------
		//If otherTi ref is NULL, then clear
		//------------------
		otherTI := trans.getOtherTrackedItem();
		if otherTI = null or (global.isValidObject(otherTI) = false) then
			//--------------
			//We can erase this transaction, it has been nulled, or is no longer valid
			//--------------
			trans.erase(NORMAL_ERASE);
		endif;
	endforeach;

end;</source>
        <Parameter name="purgeBeforeDate" type="Date"/>
    </JadeMethod>
