    <JadeMethod name="utlCreateBarrierCode" id="53b9adca-0197-4b1f-845f-058141217742">
        <source>utlCreateBarrierCode(_vvr : CM_VehicleVisitRecord input; _inward : Boolean;  _regenerated  : Boolean; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023	jlier1	Initial creation 57936
28/06/2023	navcs2	ChangeRequest 58433: [58454]: EUP | TAS Invoicing - Invoice Posting Confirmation Message
14/02/2024	navcs2	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy (Changed Signature)
26/02/2025	naviv1	JIRA-34112 : EUP - Barrier Code messages are sent before the processing the Inspection
*/

vars
	def : CM_ExternalWebServiceDef;
	barrierCode : CM_BarrierCode;
	pxyRequest			: BGP_APIWSRequest;
	bgpExtRequest 			: BGP_ExternalWSRequest;
	sendBarrierCode : Boolean;
	validityStart,
	validityEnd : TimeStamp;
	bufferMins 	  : Integer;
	bgpRequestsToDelete : ObjectSet;
	bgpRequest : BGP_Request;
	gate : CM_Gate;
	futureActor : CM_BarrierCodeReleaseProcess;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	//lets check if it is needed - must be set up and probably need to add attribute on the gate 
	
	def:=app.myRoot.getFirstActiveEWSForEndpoint(ETRow_BarrierCode).CM_APIEndpointServiceDef;
	if def = null then
		app.writeLog(method.qualifiedName &amp; " system does not have a web service defintion for barrier codes - returning", LogDEBUG);
		return; //just return no error
	endif;	
	
	if _vvr = null then
		app.writeLog(method.qualifiedName &amp; " no VVR passed in", LogDEBUG);
		return;
	endif;
	
	
	
	if _regenerated then
		sendBarrierCode:=true;
	endif;
	
	//if there is already a code should return don't need another because it has been issued
	if _inward then
		if _regenerated then
			validityStart:=app.actualTimeAppServer;
		else
			gate :=_vvr.getGateIn;
			if gate = null or not gate.useBarrierCodes then
				app.writeLog(method.qualifiedName &amp; " vehicle visit " &amp; _vvr.visitNumber &amp; " gate  does not use barrier codes", LogDEBUG);
				return;
			endif;
			
			if _vvr.gateInCheckTS = null or not _vvr.gateInCheckTS.isValid then
				validityStart:=_vvr.timeIn;
			else
				validityStart:=_vvr.gateInCheckTS;
			endif;
		endif;
		
		if _vvr.myBarrierCodeIn &lt;&gt; null then
		
			if not _regenerated then
				app.writeLog(method.qualifiedName &amp; "  VVR " &amp; _vvr.visitNumber &amp; " already has an inward barrier code", LogDEBUG);
				return;
			else
			
				//should also check if there are pending API requests for barrier and vvr and delete those
				create bgpRequestsToDelete transient;
				foreach bgpRequest in _vvr.allAPIWSRequests discreteLock do 
					if bgpRequest.BGP_APIWSRequest.datatype = BGP_APIWSRequest.Type_Barrier then
						bgpRequestsToDelete.add(bgpRequest);
					endif;
				endforeach;
				bgpRequestsToDelete.purge;
				delete _vvr.myBarrierCodeIn;
			endif;	
		endif;
		if not _regenerated then
		//JIRA-34112 Barriercode message should be sent only when the gate inspection (gateInCheckStatus) is not required (N/A) or is completed
			if _vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionNA or _vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionCompleted then	//JIRA-34112
				sendBarrierCode:=true;
			elseif _vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionPending or _vvr.gateInCheckStatus = null then  //JIRA-34112
				sendBarrierCode:=false;
			else
				//something else 
				app.writeLog(method.qualifiedName &amp; "  VVR " &amp; _vvr.visitNumber &amp; " gate in check neither N/A or Pending", LogDEBUG);
				return;
			endif;
		endif;
		bufferMins:=_vvr.myTerminal.getConfig(GateBarrierInBuffer).Integer;
		if bufferMins = 0 then
			bufferMins:=30;
		endif;
		validityEnd:=validityStart.addMinutes(bufferMins);
	else 
		sendBarrierCode:=true;
		if _regenerated then
			validityStart:=app.actualTimeAppServer;
		else
			gate :=_vvr.getGateOut;
			if gate = null or not gate.useBarrierCodes then
				app.writeLog(method.qualifiedName &amp; " vehicle visit " &amp; _vvr.visitNumber &amp; " gate  does not use barrier codes", LogDEBUG);
				return;
			endif;
			validityStart:=_vvr.timeOut;
		endif;
		if _vvr.myBarrierCodeOut &lt;&gt; null then
			if not _regenerated then
				app.writeLog(method.qualifiedName &amp; "  VVR " &amp; _vvr.identity &amp; " already has an outward barrier code", LogDEBUG);
				return;
			else
				app.myRoot.deleteFutureActor(_vvr, CM_BarrierCodeReleaseProcess);
				delete _vvr.myBarrierCodeOut;
			endif;
		endif;
		
		bufferMins:=_vvr.myTerminal.getConfig(GateBarrierOutBuffer).Integer;
		if bufferMins = 0 then
			bufferMins:=30;
		endif;
		validityEnd:=validityStart.addMinutes(bufferMins);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	create barrierCode persistent;
	barrierCode.setForCreate(_vvr.myTerminal,_passport);
	barrierCode.setValidityDTs(validityStart,validityEnd);
	if not _inward then
		barrierCode.setBarrierDT(validityStart);
	endif;
	if _inward then
		_vvr.setMyBarrierCodeIn(barrierCode);
	else
		_vvr.setMyBarrierCodeOut(barrierCode);
	endif;
	
	if sendBarrierCode then
		//send the barrier code 
		//BGP Process
		create pxyRequest transient;
		pxyRequest.setDetails(_vvr, null, null,_vvr.myTerminal, BGP_APIWSRequest.Type_Barrier);			// 28.06.2023	navcs2	#58433:[58454]
		pxyRequest.setBarrierIn(_inward); 
		app.myUtilityCA.utlCreateBGPRequestExtWS(pxyRequest, bgpExtRequest, app.myPassport);
	endif;
	
	if not _inward then
		create futureActor persistent;
		futureActor.setParentObject(_vvr);
		//should be after the validityEnd and period after the truck has left the terminal
		futureActor.setActionTimeStamp(validityEnd.addHours(4));
	endif;
epilog
	delete pxyRequest;
	delete bgpRequestsToDelete;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_regenerated" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBatNumber" id="14db378e-56a7-4621-90e6-10dd7a97a0ee">
        <source>utlCreateBatNumber(_passport : CM_Passport input; _nextCode : String; _nextBat : CM_BatNumber output);
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
vars
begin

