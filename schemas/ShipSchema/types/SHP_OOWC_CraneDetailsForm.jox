    <JadeMethod name="setupForm" id="736a7b88-9be9-474b-b853-670c4c46b954">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474
6 April 2011	cnwrs2	remove Next button as never used.

*/

vars
	idx : Integer;
	ctrl : Control;
	
begin

	self.btnNext.visible := false;

	inheritMethod();
	
	self.handleMenusForModalDisplay();
	self.centreOverParent(20);
	self.initFieldsForEntDefName(ETDef_OowCraneUpdate, true);
	self.cmbOrder.clear();
	self.cmbOrder.addItemData(CM_VoyageJobSheet.Crane_FwdAftString, CM_VoyageJobSheet.Crane_FwdAft, null);
	self.cmbOrder.addItemData(CM_VoyageJobSheet.Crane_AftFwdString, CM_VoyageJobSheet.Crane_AftFwd, null);
	//self.btnNext.enabled := false;

	self.setCaption( app.getErrorString(CM_Crane_GC) &amp;  " " &amp; myCrane.id );
	
	self.loadData();
	foreach idx in 1 to self.controlCount do
		ctrl := self.controls(idx);
		if ctrl.visible then
		//	write ctrl.name &amp; Tab &amp; ctrl.tabIndex.String;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7eb7d603-d1a1-4d49-a603-faaa9233798a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011528, locale);
	btnUseShipExch.translateBubbleHelp(Xlat_0011529, locale);
	btnUseShipExch.translateCaption(Xlat_0011530, locale);
	cmbOrder.translateCaption(Xlat_0011531, locale);
	frmExchDate.translateCaption(Xlat_0011532, locale);
	txtCPH.translateCaption(Xlat_0011533, locale);
	txtExchTime.translateCaption(Xlat_0011534, locale);
	txtStartJob.translateCaption(Xlat_0011535, locale);
end;</source>
    </JadeMethod>
</GUIClass>
