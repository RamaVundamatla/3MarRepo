    <JadeMethod name="jreWritePushPropertiesFirst" id="071959f5-fbac-498e-aad2-984710d70b22">
        <source>jreWritePushPropertiesFirst();
// TFS 3243, original attempt, wrote too much
vars
	cls				: Class;
	scm				: Schema;
	root			: CM_Root;
	ddClass			: CM_DataDumpClass;
	ddFeature		: CM_DataDumpFeature;
	type			: String;
	subtype			: String;
	className		: String;
	subClassName	 :String;
	featureName		: String;
	strValue		: String;
	documentation	: String;
	description		: String;
	file			: File;
	
begin
	create file transient;
	file.usePresentationFileSystem := true;
	file.fileName := "C:\temp\pushproperties.csv";
	strValue := "Class name,Sub-class name,Property name,Description";
	file.writeLine(strValue);
	
	scm := rootSchema.getSchema("PortSchema");
	root := CM_Root.firstInstance;
	foreach ddClass in root.allDataDumpClasses do
		className := ddClass.className;
		cls := scm.getClass(className);

		// common properties first
		strValue := className &amp; ",," &amp; "dateTime,  date and time the event occurred in JMT server timezone";
		file.writeLine(strValue);
		strValue := className &amp; ",," &amp; "source, 'Master Terminal'";
		file.writeLine(strValue);
		strValue := className &amp; ",," &amp; "environment, environment where the event occurred";
		file.writeLine(strValue);
		strValue := className &amp; ",," &amp; "terminal, unique object id for the terminal of the event";
		file.writeLine(strValue);
		strValue := className &amp; ",," &amp; "terminalCode, short code for the terminal";
		file.writeLine(strValue);
	
		type := "'Entity'";
		if cls.inheritsFrom(CM_AuditObject) then
			type := "'Audit'";
		elseif cls.inheritsFrom(CM_EventTransaction) then
			type := "'Event'";
		elseif cls.inheritsFrom(CM_Transaction) then
			type := "'Transaction'";
		endif;
		//subtype := obj.getPushEventsSubtype();
		strValue := className &amp; ",," &amp; "type," &amp; type;
		file.writeLine(strValue);
		strValue := className &amp; ",," &amp; "subtype," &amp; subtype;
		file.writeLine(strValue);
		strValue := className &amp; ",," &amp; "oid, unique object id";
		file.writeLine(strValue);
	
		strValue := className &amp; ",," &amp; "class, Jade class name";
		file.writeLine(strValue);
	
		// each featuire
		foreach ddFeature in ddClass.allDataDumpFeatures do
			featureName := ddFeature.featureName;
			// Check to see whether or not to ignore the feature
			if featureName = DataDumpOidBin then
				continue;
			endif;
	
			// Ignore field values for CM_Edit, as these are extracted as property changes separately
			if className = CM_Edit.name then
				if featureName = CM_Edit::getFieldValuesString.name or
				   featureName = CM_Edit::getEditTransactionsDetailsSQL.name then
					continue;
				endif;
			endif;
	
			// Ignore before and after audit text for CM_Audit, as these are extracted as property changes separately
			if className = CM_AuditObject.name then
				if featureName = CM_AuditObject::postAuditText.name or 
				   featureName = CM_AuditObject::auditText.name then
					continue;
				endif;
			endif;
				
			if ddFeature.myFeature &lt;&gt; null then
				documentation := ddFeature.myFeature.text.cnEcGetTagValueOfName(Doc_Documentation);
				description := documentation.cnEcGetTagValueOfName(Doc_Description).removeCrLfs;
			elseif featureName = "edition" then
				description := "this starts at 1 and is incremented in each updating transaction";
			else
				description := null;
			endif;

			subClassName := ddFeature.subClassName;
			if subClassName = className then
				subClassName := "";
			endif;
			strValue := className &amp; "," &amp; subClassName &amp; "," &amp; featureName &amp; "," &amp; description;
			file.writeLine(strValue);
		endforeach;
		
		// Add in any hard coded fields for specific classes here
		if className = CM_TITransaction.name then
			strValue := className &amp; ",CM_Edit," &amp; "changes,an array of the changed property values";
			file.writeLine(strValue);
		elseif className = CM_AuditObject.name then
			strValue := className &amp; ",," &amp; "changes,an array of the changed property values";
			file.writeLine(strValue);
		endif;

	endforeach;
	file.close;
	delete file;
epilog

end;</source>
    </JadeMethod>
