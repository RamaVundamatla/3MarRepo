<CollClass name="CM_CustomLicenseByCode" id="862bab4a-1181-457f-8a51-621a5f340c82">
    <loadFactor>66</loadFactor>
    <memberType name="CM_CustomLicense"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_CustomLicense::code"/>
    </MemberKey>
    <JadeMethod name="auditIdDisplay" id="646fb40f-8833-470e-9d64-507ef19bfbc0">
        <source>auditIdDisplay() : String;
/*
Purpose - 	
Who - NAVAB1
Date - 30AUG2023
ADO - CR 59942 TASK 59943 
*/

vars
	custItem	: CM_CustomLicense;
	rtnStr	: String;
begin

	foreach custItem in self do
		if rtnStr = null then
			rtnStr := custItem.auditId();
		else
			rtnStr := rtnStr &amp; ', ' &amp; custItem.auditId();
		endif;
	endforeach;

	return rtnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
