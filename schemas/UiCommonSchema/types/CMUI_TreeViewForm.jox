    <JadeMethod name="zSetTblEntryFocus" id="79985c03-cf12-4dbf-b2de-8675d5368dea">
        <source>zSetTblEntryFocus() protected;
/*
----------   ----------  --------------------------------------------------
Created:	29 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row		: Integer;
begin
	self.tblEntry.setFocus;
	foreach row in 1 to self.tblEntry.rows do
		if self.tblEntry.accessRow(row).visible then
			self.tblEntry.row := row;
			if self.tblEntry.accessedRow.cellControl &lt;&gt; null then
				self.tblEntry.accessedRow.cellControl.setFocus();
			endif;
			break;
		endif;
	endforeach;

end;


</source>
        <access>protected</access>
    </JadeMethod>
