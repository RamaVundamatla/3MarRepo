end;
</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskGarbageCollection"/>
    </JadeMethod>
    <JadeMethod name="setFromProxy" id="202ca5e6-3f48-4cc6-bb39-0a7b8de97912">
        <updating/>
        <source>setFromProxy(_pxyAutoTask: CM_AutoTaskGarbageCollection) updating;
//
// SFW 1121 cnwrs1  Sept 2011
////9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
//18/11/2022 navmv20 Bug 55001: MTN - Garbage Collection - Release Requests - Not present under "Garbage Collection" Task Type list
//14 Feb 2023 navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars

begin
	self.daysToKeep 				:= _pxyAutoTask.daysToKeep;
	self.archivedLocations 			:= _pxyAutoTask.archivedLocations;
	self.archivedVoyages 			:= _pxyAutoTask.archivedVoyages;
	self.bookingRefTis				:= _pxyAutoTask.bookingRefTis;
	self.cargoPhotos 				:= _pxyAutoTask.cargoPhotos;
	self.navisSmartActivity 		:= _pxyAutoTask.navisSmartActivity; 			// ### TFS 50669 06AUG2021 NAVAB1
	self.dDExtractHistory 			:= _pxyAutoTask.dDExtractHistory;
	self.dutyDocs 					:= _pxyAutoTask.dutyDocs;
	self.eDIData 					:= _pxyAutoTask.eDIData;
	self.eventRequests 				:= _pxyAutoTask.eventRequests;					//25 Jul 2013	NDL	Par 31691
	self.emptyBOLIns 				:= _pxyAutoTask.emptyBOLIns;
	self.lockTransactions 			:= _pxyAutoTask.lockTransactions;
	self.logCheckScaleHdr 			:= _pxyAutoTask.logCheckScaleHdr;
	self.machineHistory 			:= _pxyAutoTask.machineHistory;
	self.menuUserItems 				:= _pxyAutoTask.menuUserItems;
	self.nonContainerDscrp 			:= _pxyAutoTask.nonContainerDscrp;
	self.offsiteTis 				:= _pxyAutoTask.offsiteTis;
	self.prenotedTis 				:= _pxyAutoTask.prenotedTis;
	self.reeferTowerTrans 			:= _pxyAutoTask.reeferTowerTrans;
	self.sundry 					:= _pxyAutoTask.sundry;							//25 Jul 2013	NDL	Par 31691
	self.vehicleBookings 			:= _pxyAutoTask.vehicleBookings;
	self.vehicleVisit 				:= _pxyAutoTask.vehicleVisit;
	self.purgeReleasedCargoGroups 	:= _pxyAutoTask.purgeReleasedCargoGroups;		//22 Jun 2015	NDL	Par 36338
	self.xlations 					:= _pxyAutoTask.xlations;
	self.yardAllocationLogTrans 	:= _pxyAutoTask.yardAllocationLogTrans;
	self.purgeInterTerminalRailBOLs	:= _pxyAutoTask.purgeInterTerminalRailBOLs;		//epr TFS 4157 28//4/17
	self.maxDurationMinutes 		:= _pxyAutoTask.maxDurationMinutes;				//TFS 6960
	self.truncateEDIInfoXML 		:= _pxyAutoTask.truncateEDIInfoXML;				//13 Sep 2021	NDL	TFS 51718
	self.purgeSecGateUnknTrucks 	:= _pxyAutoTask.purgeSecGateUnknTrucks; 		// ### TFS 51994 05Oct2021 NAVPW1
	self.releaseRequests			:= _pxyAutoTask.releaseRequests; 				//18/11/2022 navmv20 TFS 55001
	self.purgeAttachmentCargoTypes	:= _pxyAutoTask.purgeAttachmentCargoTypes;		//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentContract	:= _pxyAutoTask.purgeAttachmentContract;		//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentInvoices	:= _pxyAutoTask.purgeAttachmentInvoices;		//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentVoyages		:= _pxyAutoTask.purgeAttachmentVoyages;			//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentWorkOrders	:= _pxyAutoTask.purgeAttachmentWorkOrders;		//14/02/2023 navhl20 #54900[56518]
	self.purgeWorkOrderJobSheets 	:= _pxyAutoTask.purgeWorkOrderJobSheets;		//21.7.2023 navhl20 #58158
	self.purgeVisitPhotos 			:= _pxyAutoTask.purgeVisitPhotos;				//11.08.2025 navhl20 #35650
	self.purgeAgGatewayMessages		:= _pxyAutoTask.purgeAgGatewayMessages;			//navra1 - MTN-35875- 5th Sep 2025-2
end;
</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskGarbageCollection"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="f78bc1d3-6c58-433c-885e-f26e647ee46b">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
//
// SFW 1121 cnwrs1  Sept 2011
////9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
//18/11/2022 navmv20 Bug 55001: MTN - Garbage Collection - Release Requests - Not present under "Garbage Collection" Task Type list
//14 Feb 2023 navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars

begin
	if _rowName = ETRow_BgpAutoDaysToKeep then
		self.daysToKeep := _value.Integer;
	elseif _rowName = ETRow_BgpAutoArchivedLocations then
		self.archivedLocations :=_value.Boolean;
	elseif _rowName = ETRow_BgpAutoArchivedVoyages then
		self.archivedVoyages := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoBookingRefTIs then
		self.bookingRefTis := _value.Boolean;
	elseif _rowName = ETRow_NavisSmartActivity then 		// ### TFS 50669 06AUG2021 NAVAB1
		self.navisSmartActivity := _value.Boolean; 			// ### TFS 50669 06AUG2021 NAVAB1
	elseif _rowName = ETRow_BgpAutoCargoPhotos then
		self.cargoPhotos := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoDDExtractHistory then
		self.dDExtractHistory := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoEDIData then
		self.eDIData := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoReceivalDockets then		//25 Jul 2013	NDL	Par 31691
		self.emptyBOLIns := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoLockTransactions then
		self.lockTransactions := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoLogCheckScaleHdr then
		self.logCheckScaleHdr := _value.Boolean; 
	elseif _rowName = ETRow_BgpAutoMachineHistory then
		self.machineHistory := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoSavedReports then		//25 Jul 2013	NDL	Par 31691
		self.menuUserItems := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoNonContainerDscrp then
		self.nonContainerDscrp := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoOffsiteTIs then
		self.offsiteTis := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoPrenoteTIs then
		self.prenotedTis := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoReeferTowerTrans then
		self.reeferTowerTrans := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoVehicleVisits then
		self.vehicleVisit := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoVehicleBookings then		//15 Apr 2013	NDL	Par 31393
		self.vehicleBookings := _value.Boolean; 

	elseif _rowName = ETRow_BgpAutoVoyageXlations then		//25 Jul 2013	NDL	Par 31691
		self.xlations := _value.Boolean;	
	elseif _rowName = ETRow_BgpAutoYardAllocLogTrans then
		self.yardAllocationLogTrans := _value.Boolean; 
	elseif _rowName = ETRow_MaxDurationMinutes then
		self.maxDurationMinutes := _value.Integer;
	elseif _rowName = ETRow_BgpDutyDocuments then
		self.dutyDocs := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoEventRequests then		//25 Jul 2013	NDL	Par 31691
		self.eventRequests := _value.Boolean;
	elseif _rowName = ETRow_BgpAutoSundry then				//25 Jul 2013	NDL	Par 31691
		self.sundry :=  _value.Boolean;
	elseif _rowName = ETRow_ReleasedCargoGroups then		//22 Jun 2015	NDL Par 36338
		self.purgeReleasedCargoGroups  :=  _value.Boolean;
	elseif _rowName = ETRow_InterTermRailBOLs then
		self.purgeInterTerminalRailBOLs :=_value.Boolean; 	//epr TFS 4157 28/4/17
	elseif _rowName = ETRow_TruncateEDIInfoXML then			//13 Sep 2021	NDL	TFS 51718
		self.truncateEDIInfoXML := _value.Boolean;
	elseif _rowName = ETRow_SecGateUnknTrucks then			// ### TFS 51994 05Oct2021 NAVPW1
		self.purgeSecGateUnknTrucks := _value.Boolean;
	elseif _rowName = ETRow_ReleaseRequests then			//18/11/2022 navmv20 TFS 55001
		self.releaseRequests := _value.Boolean;				//18/11/2022 navmv20 TFS 55001
	elseif _rowName = ETRow_AttachFilesCargoTypes then		//14/02/2023 navhl20 #54900[56518]
		self.purgeAttachmentCargoTypes := _value.Boolean;	
	elseif _rowName = ETRow_AttachFilesContracts then		//14/02/2023 navhl20 #54900[56518]
		self.purgeAttachmentContract := _value.Boolean;		
	elseif _rowName = ETRow_AttachFilesInvoices then		//14/02/2023 navhl20 #54900[56518]
		self.purgeAttachmentInvoices := _value.Boolean;		
	elseif _rowName = ETRow_AttachFilesVoyages then			//14/02/2023 navhl20 #54900[56518]
		self.purgeAttachmentVoyages := _value.Boolean;		
	elseif _rowName = ETRow_AttachFilesWorkOrders then		//14/02/2023 navhl20 #54900[56518]
		self.purgeAttachmentWorkOrders := _value.Boolean;	
	elseif _rowName = ETRow_WorkOrderJobSheets then			//21.7.2023 navhl20 #58158
		self.purgeWorkOrderJobSheets :=_value.Boolean;	
	elseif _rowName = ETRow_BgpAutoVisitPhotos then			//11.08.2025 navhl20 #35650
		self.purgeVisitPhotos :=_value.Boolean;
	elseif _rowName = ETRow_BgpAgGatewayEWS then			//navra1 - MTN-35875- 5th Sep 2025-2
		self.purgeAgGatewayMessages := _value.Boolean;		//navra1 - MTN-35875- 5th Sep 2025-2
	else
		inheritMethod(_rowName, _value);
	endif;
end;
</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="c95c5818-810a-48c9-8594-74b7ec42f259">
        <source>validate();
//
// SFW 1121 cnwrs1  Sept 2011
//18/11/2022 navmv20 Bug 55001: MTN - Garbage Collection - Release Requests - Not present under "Garbage Collection" Task Type list
//14 Feb 2023 navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars
	requestLimit 	: Integer;
	instancesSize 	: Integer;
begin
	inheritMethod();
	if self.myTerminal = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Terminal), null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.daysToKeep &lt; 90 then
		app.raiseCMWarning1(Days_less_than_days, '90', null, null, self.myTerminal);
	endif;
	

	if not self.archivedVoyages and
	   not self.archivedLocations and
	   not self.bookingRefTis and
	   not self.cargoPhotos and 
	   not self.navisSmartActivity and					  // ### TFS 50669 06AUG2021 NAVAB1
	   not self.dDExtractHistory and
	   not self.dutyDocs and
	   not self.eDIData and
	   not self.emptyBOLIns and
	   not self.lockTransactions and
	   not self.logCheckScaleHdr and 
	   not self.machineHistory and
	   not self.menuUserItems and 
	   not self.nonContainerDscrp and
	   not self.offsiteTis and
	   not self.prenotedTis and
	   not self.reeferTowerTrans and
	   not self.vehicleVisit and
	   not self.vehicleBookings and
	   not self.xlations and
	   not self.eventRequests and						//25 Jul 2013	NDL	Par 31691
	   not self.sundry and								//25 Jul 2013	NDL	Par 31691
	   not self.purgeReleasedCargoGroups and			//22 Jun 2015	NDL	Par 36338
	   not self.yardAllocationLogTrans and
	   not self.truncateEDIInfoXML and					//13 Sep 2021	NDL	TFS 51718
	   not self.purgeInterTerminalRailBOLs and 			//epr TFS 4157 28/4/17
	   not self.purgeAttachmentCargoTypes and           //14/02/2023 navhl20 #54900[56518]
	   not self.purgeAttachmentContract and           	//14/02/2023 navhl20 #54900[56518]
	   not self.purgeAttachmentInvoices and           	//14/02/2023 navhl20 #54900[56518]
	   not self.purgeAttachmentVoyages and           	//14/02/2023 navhl20 #54900[56518]
	   not self.purgeAttachmentWorkOrders and           //14/02/2023 navhl20 #54900[56518]
	   not self.purgeSecGateUnknTrucks and              //18/11/2022 navmv20 TFS 55001
	   not self.releaseRequests	and						//18/11/2022 navmv20 TFS 55001
	   not self.purgeWorkOrderJobSheets	and				//21.7.2023 navhl20 #58158
	   not self.purgeVisitPhotos and					//11.08.2025 navhl20 #35650
	   not self.purgeAgGatewayMessages					//navra1 - MTN-35875- 5th Sep 2025-2
	   then  											// ### TFS 51994 30Sep2021 NAVPW1
		app.raiseCMException(NoItemsSelected, null, null);
	endif;
end;</source>
    </JadeMethod>
</Class>
