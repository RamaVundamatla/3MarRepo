    <JadeMethod name="xPAR31367StatusBarStepB4" id="a855a38f-fe9a-48a4-83c1-06d2c6b893df">
        <source>xPAR31367StatusBarStepB4();

/*

Purpose:		Plan discharge job and check that the status bar is correct	

Date			Who		Reason
23/05/2013		cnwmh5	Initial creation

*/

vars

	location							: CM_LocationsController;
	job									: CM_Job;
	req 								: CM_Request;
	wle 								: CM_WorkListEntry;
	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	locnGCDefnVoyage					: CM_ROROGCDefnVoyage;
	slotDefn 							: CM_ROROSlotDefn;
	slotLC 								: CM_ROROSlotController;
	ti									: CM_TrackedItem;
	roroRequest							: CM_RORORequest;
	
	tisToDischarge						: StringArray;
	dischargeLocn						: StringArray;
	
	locn								: String;
	
begin

	app.writeLog("STEP B4", LogINFO);
	app.writeLog("Planning containers to discharge.  Please wait...", LogINFO);
	
	location := self.myBlockStack.allLocationsControllers.first;
	
	create tisToDischarge transient;

	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	
	create dischargeLocn transient;
	dischargeLocn.add("D4083");
	dischargeLocn.add("D4082");
	dischargeLocn.add("D4087");
	dischargeLocn.add("D4074");
	dischargeLocn.add("D4070");
	dischargeLocn.add("D4075");
	dischargeLocn.add("D4199");
	
	dischargeLocn.add("D4086");
	dischargeLocn.add("D4085");
	dischargeLocn.add("D4076");
	dischargeLocn.add("D4077");
	dischargeLocn.add("D4064");
	dischargeLocn.add("D4040");
	dischargeLocn.add("D4065");
	
	dischargeLocn.add("D4421OR");
	dischargeLocn.add("D4423OR");
	dischargeLocn.add("D4424OR");
	dischargeLocn.add("D4414O");
	dischargeLocn.add("D4412O");
	dischargeLocn.add("D4411O");
	
	dischargeLocn.add("D4426OR");
	dischargeLocn.add("D4428OR");
	dischargeLocn.add("D4420O");
	dischargeLocn.add("D4418O");
	
	foreach locn in dischargeLocn do
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			roroRequest := slotLC.myRORORequestDischarge;
			if roroRequest &lt;&gt; null then
				ti := roroRequest.getTrackedItem();
				if ti &lt;&gt; null then
					tisToDischarge.add(ti.id);
				endif;
			endif;
		endforeach;
	
	endforeach;
	
	foreach job in self.myVoyage.allVoyageJobs do
		if not job.CM_VoyageJob.isDischarge then			// Discharge only
			continue;
		endif;
		
		foreach req in job.allRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				if wle.myTrackedItem &lt;&gt; null and tisToDischarge.includes(wle.myTrackedItem.id) then
					self.movePlannedWLE(wle.myTrackedItem, location, wle);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	/*
