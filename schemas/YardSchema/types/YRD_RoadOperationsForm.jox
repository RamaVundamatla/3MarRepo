        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dkbStage_queryDock(dockbar: JadeDockBar input; dockWith: Window input; dockPosn: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if dockWith.name = dkcMacro.name then
		return false;
	else
		return true;
	endif;

epilog

end;</source>
        <Parameter name="dockbar" type="JadeDockBar" usage="input"/>
        <Parameter name="dockWith" type="Window" usage="input"/>
        <Parameter name="dockPosn" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAssignCargo" id="abf085c9-272b-4f6b-9785-b5a3f5f0d10f">
        <source>doAssignCargo();
/*

Date		Who		Reason
15 May 2014	cnwer1	Initial creation PAR 34107

*/

vars
	ti : CM_TrackedItem;
	mode : Integer;
begin
	if self.myCurrentWLE = null then
		return;
	endif;
	
	ti:=self.myAssistant.showAssignCargo(self.myCurrentWLE);
	
	if ti &lt;&gt; null then
		mode:=NO_MODE;
		if self.myCurrentWLE.allRTQueueEntries.size &gt; 0 then
			mode:=QUEUE_MODE;
		endif;
		self.assignTIToReleaseRequest(ti,mode);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPrint" id="8724dc9d-b759-40ff-a392-89a3ec4dd449">
        <updating/>
        <source>doBtnPrint()updating, protected;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theReport		: CMUI_ReportLine;
	theCode			: String;
	pxyJadeReport	: JadeReport;
	tblPrintParams	: CMIF_PrintTableParams;
//	tblClone	
begin
//
//
//		######  CHANGE THIS TO USE THE GENERIC TABLE PRINT  ######
//
//
	create theReport transient;
	theReport.initReport;
	theReport.lblTitle01.caption := self.caption;
	theReport.lblTitle03.caption :=  '';
	theReport.lblTitle02.caption := ''; 
	theReport.lblTitle04.caption := "";
	theReport.lblPrintedBy.caption := null;
	theReport.lblPrintedBylbl.caption := null;
	
	app.printer.setHeader(theReport.frHeader);
	app.printer.setFooter(null);
	app.printer.suppressDialog := true;

	create tblPrintParams transient;
	tblPrintParams.closePrinter := true;
	tblPrintParams.jadeReport := pxyJadeReport;
	tblPrintParams.newReport := true;
	tblPrintParams.printFrame := self.frmReport;
	tblPrintParams.printLabel := self.lblReport;
	tblPrintParams.title := self.caption[1:100];
	tblPrintParams.useSmallFont := true;
//should really add something to entTableDef &gt; report col width, report col heading?
	tblPrintParams.colWidths.setFromDelimitedString("0/65/65/65/90/65/65/40/0/65/65/65/0/65/65/65/65/65/65/65/65");

	app.printer.orientation := Print_Landscape;
	
//EPR NEED TO FINISH
//	self.tblWorkEntries.doPrintTable(tblPrintParams);

	self.doPrintDriversReceipt();

epilog
	self.doResize();
	delete theReport;
	delete tblPrintParams;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildFindColCombo" id="1b7cc092-16b5-4433-ba5c-1824d32326ef">
        <source>doBuildFindColCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2012	cnwer1	Initial creation SFW 1295

*/

vars
	heading	: String;
	roadOpObj 	: CMIF_RoadOpObject;
	table 		: CM_DataTable;
	allHeadings  : StringArray;
begin
	self.cmbFindColCombo.clear;
	create allHeadings transient;
	allHeadings.add(app.getErrorString(AnyString));
	self.cmbFindColCombo.addItem(app.getErrorString(AnyString));
	foreach roadOpObj in self.myRoadOpController.allCMIFRoadOpObjects do
		table:=roadOpObj.myDataTable;
		foreach heading in table.allTblDataColHeadings do
			if heading[1] = "~" then //hidden sort columns
				continue;
			endif;
			if not allHeadings.includes(heading) then
				allHeadings.add(heading);
				self.cmbFindColCombo.addItem(heading);
			endif;
		endforeach;				
	endforeach;
epilog
	delete allHeadings;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildMnuNullObj" id="e56099a4-75d5-4888-bed6-ec76042017ce">
        <source>doBuildMnuNullObj()protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
// 25/06/2010	cnwcs5	par 24292 - handle new menu items
// 24/01/2013	cnwdap1	PAR #31018 CCMS POL 2223 added Disconnect menu item
// 27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI
vars

begin
	// hide everything on context menu
	self.mnuTableContext.enabled 		:= false;
	self.mnuAdditional.visible 			:= false;
	self.mnuAdditional.userObject 		:= null;	
	self.mnuAssignToTBA.visible 		:= false;
	self.mnuQueue.visible 				:= false;
	self.mnuSetTargetLocn.visible 		:= false;
	self.mnuProcessRoadExit2.visible 	:= false; 	// 15/09/2009 cnwcs5
	self.mnuProcessRoadExit2.userObject	:= null;	// 15/09/2009 cnwcs5
	self.mnuMoveIt.visible 				:= false;			
	self.mnuEnquire.visible 			:= false;
	self.mnuEnquire.userObject			:= null;
	self.mnuRemarks.visible 			:= false;
	self.mnuRemarks.userObject 			:= null;		
	self.mnuDeleteCurrentEntry.visible 	:= false;
	self.mnuComplete.visible 			:= false;	
	self.mnuTurnAround.visible 			:= false;
	self.mnuRebuildWLEStatus.visible 	:= false;
	self.mnuRebuildWLEStatus.userObject := null;
	self.mnuReturnWorkEntry.visible 	:= false;				
	self.mnuSource.visible 				:= false;
	self.mnuUnassignTI.visible 			:= false;
	self.mnuAddDeliveryRequest.visible 	:= false;
	self.mnuAddDeliveryRequest.userObject := null;
	self.mnuEditRegistation.visible		:= false;
	self.mnuDoorsForward.visible		:= false;	//11 Aug 2011	NDL	Par 27582
	self.mnuPrintLabels.visible         := false;
	self.mnuRFIDTag.visible				:=false;
	self.mnuEditRegistation.visible		:=false;
	self.mnuMoveVehicle.visible			:=false;
	self.mnuMoveVehicle.userObject		:=null;
	self.mnuSwapBRItem.visible          := false; 	// PAR 15358
	self.mnuSetICAreas.visible			:= false;	// par 24292 25/06/2010 cnwcs5
	self.mnuAssignCargoIDs.visible		:= false;	//30 Sep 2011	NDL	Par 28285
	self.mnuAssignCargo.visible			:=false; 	//epr par 34107 15/5/14
	self.mnuSwapCargo.visible			:=false;
	self.mnuUpdateDamage.visible		:= false; //cwnrd1 par 29415 23.5.2012
	self.mnuDisconnect.visible			:= false;	// PAR #31018
	self.mnuUndo.visible				:=false; //epr par 33718
	self.mnuWeigh.visible 				:= false;	//17 Mar 2014	NDL	Par 33268
	self.mnuVoyWleDel.visible			:= false;	//24 May 2016	NDL	TFS 2032
	self.mnuCheckSeals.visible			:= false; 	// 06/04/2023 jlizm1 TFS 57098
	self.mnuCheckSeals2.visible			:= false; 	// 06/04/2023 jlizm1 TFS 57098
	self.mnuMaintainSeals.visible		:= false;	// 06/04/2023 jlizm1 TFS 57098
	self.mnuMaintainSeals2.visible		:= false;	// 06/04/2023 jlizm1 TFS 57098
	self.mnuCargoReview.visible			:= false;	//27/09/2023	navkc1	CR 60428 Task 60702
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTblObj" id="fffdc516-ce3f-411c-879e-7c764d722c4a">
        <updating/>
        <source>doBuildMnuTblObj(	_wle : CM_WorkListEntry input;
					_wleTable : CM_DataTable input	) updating, protected;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/03/2011	cnwmh5		PAR #27142 - Change where handleDeletedObject is armed
// 28/08/2019	jlgzm1		TFS 42878 Direct Release Between Road and Voyage
// ---------------------------------------------------------------------------

vars
	lReq 		: CM_Request;
	tiId 		: String;
	invalidWLE 	: Boolean;
	drWLE 		: CM_WorkListEntry;	// TFS 42878
begin
		
	if _wle = null then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception,_wle,invalidWLE);	
	
	lReq := _wle.myRequest;
	
	//epr par 15512 16/7/08
	if invalidWLE then
		return;
	endif;
	
	if self.myCurrentWLE &lt;&gt; _wle then		
		self.tblStageChange(_wle,_wleTable);
	endif;
		
	self.mnuTableContext.enabled 		:= true;
	self.mnuTableContext.userObject		:=_wleTable;
	self.mnuSource.visible 				:= false;
	self.mnuAdditional.visible 			:= false;
	self.mnuComplete.visible 			:= false;			
	self.mnuRebuildWLEStatus.visible 	:= false;
	self.mnuRebuildWLEStatus.userObject	:= null;
	

	self.mnuQueue.visible 				:= true;	
	if _wle.isDRLinkedByFM then							// TFS 42878
		drWLE := _wle.getDRLinkedWLE;					// TFS 42878
		if _wle.allRTQueueEntries.isEmpty and drWLE.allRTQueueEntries.isEmpty then	// TFS 42878
			self.mnuQueueSelected.visible := true;		// TFS 42878
			self.mnuUnqueueSelected.visible := false;	// TFS 42878
		else											// TFS 42878
			self.mnuQueueSelected.visible := false;		// TFS 42878
			self.mnuUnqueueSelected.visible := true;	// TFS 42878
		endif;
	else
		self.mnuQueueSelected.visible:=_wle.allRTQueueEntries.isEmpty ;
		self.mnuUnqueueSelected.visible:=not _wle.allRTQueueEntries.isEmpty;
	endif;
	
	if _wle.myFutureMove = null then
		if _wle.myFutureMoveDR = null then			// TFS 42878
			self.mnuUnplanSelected.visible:=false;	// TFS 42878
		else										// TFS 42878
			self.mnuUnplanSelected.visible:=_wle.myFutureMoveDR.isKindOf(CM_FutureMovePlanned);	// TFS 42878
		endif;
	else
		self.mnuUnplanSelected.visible:=_wle.myFutureMove.isKindOf(CM_FutureMovePlanned);
	endif;

// PAR 33695	self.mnuAssignToTBA.visible 		:= false; ### This has just been turned on/off by the only method that calls this method.
	self.mnuDoorsForward.visible		:= false;	//11 Aug 2011	NDL	Par 27582
	
	self.mnuAdditional.visible 		:=  lReq &lt;&gt; null; //epr 33221 3/3/14
	self.mnuAdditional.userObject	:= lReq;
	self.mnuSource.visible 			:= true;
		if lReq &lt;&gt; null and lReq.myJob &lt;&gt; null then //epr 33221 3/3/14
			self.mnuRemarks.visible 		:= true;
			//self.mnuRemarks.caption 		:= "Edit remarks for " &amp; lReq.myJob.jobId &amp; '...';
			// cnwjre1 May 2011 27097 use combined edit form for remarks, additional info and source
			self.mnuRemarks.caption 		:= "Edit Request Details for " &amp; lReq.myJob.jobId &amp; '...';
			self.mnuRemarks.userObject 		:= lReq;
			self.mnuAdditional.visible 		:= false;
			self.mnuSource.visible 			:= false;
		endif;
	
	self.mnuDeleteCurrentEntry.visible 		:= false;
	self.mnuTurnAround.visible 				:= false;
	self.mnuSetTargetLocn.visible 			:= false;	
	self.mnuReturnWorkEntry.visible 		:= false;
	self.mnuAddDeliveryRequest.visible 		:= false;
	self.mnuAddDeliveryRequest.userObject	:= null;					
	
	if not invalidWLE then
		self.doBuildMnuTblWle(_wle);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_wleTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTblWle" id="f85f61aa-b2f5-489e-956f-ce234c48ed18">
        <source>doBuildMnuTblWle(_wle : CM_WorkListEntry )protected;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//nds TFS 2867 17/01/17PKT - Bulk Process
//19 Oct 2018	jlgrh7 TFS41009 PKT -  Vehicle Queueing Issue
//--------------------------------------------------------------
vars
	job : CM_Job;
	req	: CM_Request;
	reqType, idx : Integer;
	subMenItem : MenuItem;
	relDet : CM_ReserveDetail;
	numSubItems : Integer;
	doorsForward : Boolean;	//11 Aug 2011	NDL	Par 27582
	vvr : CM_VehicleVisitRecord;
	truck : CM_Vehicle;
	voyWle : CM_VoyageWLE;	//24 May 2016	NDL	TFS 2032
	isBulkVisit : Boolean;//nds TFS 2867 17/01/17PKT - Bulk Process
	errMsg : String;	//08 Jan 2018	NDL	TFS 36437
begin

	job 	:= _wle.job;
	req 	:= _wle.myRequest;
	reqType := _wle.getRequestType();
	
	if job = null then
		job := req.myJob;
	endif;

	isBulkVisit := _wle.isBulkGateVisit();
	
	
	if _wle.isReceipt = true then
		self.mnuPrintLabels.visible := true;
	else
		self.mnuPrintLabels.visible := false;
	endif;

	//self.mnuAutoplan.visible := true;	
	self.mnuRebuildWLEStatus.visible := true;
	self.mnuRebuildWLEStatus.userObject := job;
	self.mnuUnassignTI.visible := false;
	self.mnuDeleteCurrentEntry.visible := false;	//18 Feb 2011	NDL Par 27046
	self.mnuWeigh.visible := false;	//17 Mar 2014	NDL	Par 33268
	
	if not isBulkVisit then						//nds TFS 2867 17/01/17PKT - Bulk Process
		if reqType = REQ_TI_RECEIPT and
		   req.isKindOf(CM_TIRequest) and
		   _wle.queue = null then
			self.mnuTurnAround.visible := true;
		endif;	
	else										//nds TFS 2867 17/01/17PKT - Bulk Process
		self.mnuTurnAround.visible := false;	//nds TFS 2867 17/01/17PKT - Bulk Process
		self.mnuQueueSelected.visible := false;					//+TFS41009
		self.mnuQueueAll.visible := false;								//+TFS41009
	endif;
	
	
	if _wle.isKindOf(CM_WOToDoWLE) then
		if _wle.status = WLE_UNACTIONED and (not req.CM_WOToDoRequest.isComplete) then
			self.mnuComplete.visible := true;				
			self.mnuComplete.caption := 'Complete Task';	
		endif;
	//05 Aug 2014	NDL	Par 34675
	elseif req &lt;&gt; null and req.isAnyId then 
		if _wle.status = WLE_UNACTIONED then
			self.mnuComplete.visible := true;				
			self.mnuComplete.caption := 'Complete Task';
			self.mnuComplete.userObject := _wle;
		endif;
	endif;
	
	if _wle.status = WLE_UNACTIONED and not isBulkVisit then
		self.mnuDeleteCurrentEntry.visible := true;			
		if req.isKindOf(CM_DeliveryRequest) then
			// cnwjre1 May 2011 27097, single edit form for remarks, additional info and source
			// PAR 15358
			if req.myOriginatingBulkRelease &lt;&gt; null then 
				if req.myOriginatingBulkRelease.allReserveDetails.size &gt; 1 then 
					self.mnuSwapBRItem.visible := true;
				   //+cnwml2 PAR26298
					numSubItems := 1;
					subMenItem := self.mnuSwapBRItem.getMenuItem(numSubItems);
					while subMenItem &lt;&gt; null do
						numSubItems := numSubItems + 1;
						subMenItem := self.mnuSwapBRItem.getMenuItem(numSubItems);
					endwhile;
					numSubItems := numSubItems - 1; 
					if numSubItems &lt;&gt; null then
						foreach idx in 1 to numSubItems do
							subMenItem := self.mnuSwapBRItem.getMenuItem(idx);
							delete subMenItem;
						endforeach;
					endif;
					
					idx := 0;
					foreach relDet in  req.myOriginatingBulkRelease.allReserveDetails  discreteLock do
						if not relDet.isKindOf( CM_ReserveSelection ) then	//03 Mar 2011	NDL Par 27055
							continue;
						endif;
						idx := idx +1;
						subMenItem := self.mnuSwapBRItem.loadSubMenu(idx);
						subMenItem.caption := relDet.getDescription();
						subMenItem.userObject := relDet;
						
					endforeach;
				endif;
			endif;
		endif;
		
		//11 Aug 2011	NDL	Par 27582
		// unactioned wle with yard request means we can setr teh dorr direction requested.
		if req.isKindOf(CM_YardRequest) then
			if not req.isReceivalType then
				doorsForward := req.CM_YardRequest.doorsForward;
				self.mnuDoorsForward.visible := true;
				self.mnuDoorsForward.checked := false;
				if doorsForward then
					self.mnuDoorsForward.caption := app.getErrorString(Set_Door_dir_Aft);
				else
					self.mnuDoorsForward.caption := app.getErrorString(Set_door_dir_Forward);
				endif;
				self.mnuDoorsForward.userObject := _wle;
			endif;
		endif;
		
	else
		self.mnuSource.visible := false;
		self.mnuSource.userObject := null;						
		self.mnuAdditional.visible := false;
		self.mnuAdditional.userObject := null;			
	endif;
	
	//24 May 2016	NDL	TFS 2032
	self.mnuVoyWleDel.visible := false;
	if _wle.status = WLE_COMPLETED and _wle.myTrackedItem &lt;&gt; null then
		voyWle := _wle.myTrackedItem.getVoyageWLEUnactioned( false );
		if voyWle &lt;&gt; null and voyWle.allRTQueueEntries.isEmpty and voyWle.myFutureMove = null then
			// this is the type that we can't get rid of anywhere else.
			self.mnuVoyWleDel.visible := true;
			self.mnuVoyWleDel.enabled := true;
			self.mnuVoyWleDel.userObject := voyWle;
		endif;
	endif;
	
	//Autoplan iso release
	if _wle.status= WLE_UNACTIONED and  _wle.allRTQueueEntries.isEmpty then
		if reqType = REQ_ISO_RELEASE and _wle.myTrackedItem &lt;&gt; null then
			self.mnuUnassignTI.visible := true;	
			
		endif;
	endif;

	if job &lt;&gt; null then
		if job.jobType = BOLType_Log then
			if _wle.myBOL &lt;&gt; null and
			   _wle.myBOL.isKindOf(CM_BOLIn) then
				self.mnuEnquire.visible := true;
				self.mnuEnquire.caption := 'Enquire ' &amp; _wle.myBOL.number &amp; '...';		
			else
				self.mnuEnquire.visible := false;
			endif;
			self.mnuRemarks.visible := false;
			self.mnuRemarks.userObject := null;			
			self.mnuAdditional.visible := false;
			self.mnuSetTargetLocn.visible := false;		
			self.mnuDeleteCurrentEntry.visible := false;

		elseif // job.status &lt;&gt; JOB_COMPLETE and //epr par 34406 can add delivery request if completed 
		 CM_DeliveryRequest.hasInstance(req) and not req.CM_DeliveryRequest.isBulkMulti then
			self.mnuAddDeliveryRequest.visible := true;
			self.mnuAddDeliveryRequest.userObject := req;											
		endif;
	endif;
	
	if self.showSwapTaskMenuOption then //cnwrd1 par 30819
		self.mnuSwapTasks.visible := true;
	else
		self.mnuSwapTasks.visible := false;
	endif;
	
	//17 Mar 2014	NDL	Par 33268
	if job &lt;&gt; null and job.isRoadJob then
		vvr := job.CM_RoadJob.myVehicleVisit;
		if vvr &lt;&gt; null then
			truck := vvr.vehicle;
		endif;
		if truck &lt;&gt; null and truck.isWeighBridgeWeighable( null, errMsg ) then
			self.mnuWeigh.visible := true;
			self.mnuWeigh.userObject := truck;
		endif;
	endif;
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuAddDeliveryRequest.visible := false;
		self.mnuUnassignTI.visible := false;
		self.mnuDeleteCurrentEntry.visible := false;
		self.mnuAssignCargo.visible:= false;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doChangeInspectionStatus" id="6780bd0f-212e-414b-af34-2ec2302a87ba">
        <updating/>
        <source>doChangeInspectionStatus(_newStatus : String; _isIn : Boolean; _vvr : CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		        Who		Reason
15 December 2022	navmp20	ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes

*/

vars
	pxyVVR    : CM_VehicleVisitRecord;
	theReturn : Integer;
begin
	pxyVVR := app.createUpdateProxy(_vvr).CM_VehicleVisitRecord;
	if pxyVVR = null then
		return;
	endif;
	pxyVVR.updateGateCheckDetails(_isIn, _newStatus, app.actualTimeServer);
	while true do
		app.myTrxUA.trxUpdateVehicleVisitFlexi(pxyVVR,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete pxyVVR;
end;</source>
        <Parameter name="_newStatus" type="String"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="doClearNoteRecords" id="1771c647-69bd-4031-bfc8-26680208b84a">
        <source>doClearNoteRecords(_doClearOthers : Boolean; _doClearCurrentView : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2025	navkc1 JIRA Story MTN-34156: MTN | Road Operations - Handle Notifications

*/

vars
	controller 	: CMIF_RoadOpController;
	obj			: CMIF_RoadOpObject;
	ti			: CM_TrackedItem;
	notableTis	: CM_TISet;
begin
	
	inheritMethod(_doClearOthers,_doClearCurrentView);
	
	if _doClearOthers then
		controller := self.myRoadOpController;
		
		if controller &lt;&gt; null then
			foreach obj in controller.allCMIFRoadOpObjects do
				obj.endNotificationForSubscriber(controller);
				
				notableTis := obj.getNotableTIs();
				notableTis.clear();
				
			endforeach;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_doClearOthers" type="Boolean"/>
        <Parameter name="_doClearCurrentView" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doColourLegendListBox" id="54957c6b-0256-44ef-b762-48717b74eeaa">
        <source>doColourLegendListBox()protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	colLegend	: CMUI_ColourLegend;

begin

	// Update the navigator
	create colLegend;
	colLegend.centreWindow;
	
	colLegend.addLegendItem("Job Unactioned",					Black,				White,				"picJobWLEs", false);
	colLegend.addLegendItem("Job Returned",						Red,				White,				"picJobWLEs", false);
	colLegend.addLegendItem("Job Part Complete",				Black,				White,				"picJobPartComp", false);
	colLegend.addLegendItem("Job Complete",						Black,				White,				"picJobComp", false);

	colLegend.showModal;


epilog
	delete colLegend;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doColourLegendTable" id="1aac2e1c-12a0-4bfd-aa60-36c2f6f8bf45">
        <source>doColourLegendTable()protected;
//--------------------------------------------------------------

//--------------------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
begin
	// Update the navigator
	create colLegend;
	colLegend.centreWindow;
	
	//until we decide leave as old
	colLegend.addLegendItem("",					White,				White,				null, false);
	colLegend.addLegendItem("Unactioned Receipt Job",			CM_Job.Colour_ReceiptUnactioned,		White,				null, false);
	colLegend.addLegendItem("Unactioned Release Job",			CM_Job.Colour_ReleaseUnactioned,				White,				null, false);
	colLegend.addLegendItem("Partially Worked Receipt Job",		CM_Job.Colour_ReceiptPartComplete, White, null, false);
	colLegend.addLegendItem("Partially Worked Release Job",		CM_Job.Colour_ReleasePartComplete,			White,				null, false);
	colLegend.addLegendItem("Completed Receipt Job",			White,				CM_Job.Colour_ReceiptComplete,				null, false);
	colLegend.addLegendItem("Completed Release Job",			White,				CM_Job.Colour_ReleaseComplete, null, false);
	colLegend.addLegendItem("Job is Overstowed",				White,				Red,				null, true);		
	colLegend.addLegendItem("Matched up to a TBA Contaner",		Black,				 LightGreen,		null, false);
	colLegend.addLegendItem("Returned Job",						Black,				Red,				null, false);	
	colLegend.addLegendItem("Pending Lane Change",				White,				Red,				null, true); //cnwgb1 20 May 2008 PAR 16483	
	colLegend.addLegendItem("Gate Elapsed Time Exceeeded - Bold Red or Bold White in the " &amp; ETRow_ElapsedTime &amp; " column", Red, White, 		null, true);//05 Sep 2012	Par 29717

	colLegend.showModal;
epilog
	delete colLegend;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEdit" id="bd1e9e4d-056d-48fb-90da-47494cc569d0">
        <source>doEdit();
//--------------------------------------------------------------
//Created: 15 May 2002 By: cnwgd1
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	bol 	: CM_BOL;
	job 	: CM_Job;
	request : CM_Request;
begin
	if self.myCurrentWLE = null then
		app.msgBox(app.getErrorString(SelectItem),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;	
	endif;
	if self.myCurrentWLE &lt;&gt; null then
		job := self.myCurrentWLE.job;
		request := self.myCurrentWLE.myRequest;
	endif;
	
	if request &lt;&gt; null then
		if request.isKindOf(CM_BOLYardRequest) then
			bol := request.CM_BOLYardRequest.myBOL;
		elseif request.isKindOf(CM_BOLToDoRequest) then
			bol := request.CM_BOLToDoRequest.myBOL;
		endif;
	endif;

	if bol &lt;&gt; null then
		if job.status = JOB_COMPLETE then
			app.msgBox('Cannot edit as Job ' &amp; job.jobId &amp; ' is complete.','Job Complete', MsgBox_Information_Icon + MsgBox_OK_Only);
			return;	
		endif;
	
		if self.myCurrentWLE.allRTQueueEntries.isEmpty = false then
			app.msgBox('Cannot edit as Job Entry' &amp; job.jobId &amp; ' is queued to move.','Job Queue', MsgBox_Information_Icon + MsgBox_OK_Only);
			return;	
		endif;	
		
		self.myAssistant.showDocketMaintForm(bol, self.myMasterMenuAction, true, true);
	elseif self.myCurrentTrackedItem &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(self.myCurrentTrackedItem, self.myMasterMenuAction, true, true);
	else
		app.msgBox('Job Entry ' &amp; job.jobId &amp; ' does not have an associated Cargo Item.','No Item to Edit.', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;	
	endif;
	
end;</source>
    </JadeMethod>
