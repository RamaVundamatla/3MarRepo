<GUIClass name="SHP_ROROVoyageDeckDefnForm" id="b4a98e36-7ed4-4054-8bd0-1c6b8f60116c">
    <superclass name="SHP_RORODeckDefinitionForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myROROStructure" id="0a71f0dd-2f34-4aa6-8c3a-b93d0f9c6ec2">
        <embedded/>
        <type name="CM_ROROVoyageStructure"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createProxyNew" id="ae02b424-c66e-4cc4-9a5a-1cdb2b34e2c1">
        <updating/>
        <source>createProxyNew() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	parentDeck : CM_DeckVoyage;
begin
	//create the proxy
	if self.isSubDeck then
		create self.myCurrentProxyDeck as CM_DeckVoyageSub transient;
		parentDeck:=self.cmbDeck.listObject.CM_DeckVoyage;
		if parentDeck.isKindOf(CM_DeckVoyageSub) then
			parentDeck:=parentDeck.CM_DeckVoyageSub.myParentDeck;
		endif;
		self.myCurrentProxyDeck.CM_DeckVoyageSub.setMyParentDeck(parentDeck);
	else
		create self.myCurrentProxyDeck as CM_DeckVoyage transient;
		self.myCurrentProxyDeck.CM_DeckVoyage.setMyVoyageStructure(self.myROROStructure);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeROROStructure" id="6293806d-818c-4239-8157-5e0c95da21ed">
        <updating/>
        <source>doChangeROROStructure(_voyageStructure: CM_ROROVoyageStructure; _deck: CM_DeckVoyage) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.myROROStructure = _voyageStructure then
		return;
	endif;
	
	self.endNotes();
	self.myROROStructure:=_voyageStructure;
	
	self.startROROStructureNotes();

	self.loadROROStructureCombo(_deck);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyageStructure" type="CM_ROROVoyageStructure"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="doDrawSections" id="94861ae9-47bb-410c-862a-1b08c7eefb4e">
        <source>doDrawSections();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	section : CM_VesselSection;
	frame : Frame;
begin

	frame := self.frmScrollable.myHLabels;
	foreach section in self.myROROStructure.myVoyage.myStructuralElements.allSectionsByPosition discreteLock do
		self.doDrawSection(frame, section);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSectionAdd" id="9fe3f531-9e2e-466a-b33b-4384626967e9">
        <source>doSectionAdd(posM: Decimal);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	tmpSect		: CM_VesselSection;
	proxySection : CM_VesselSectionVoyage;
	
	theResult : Integer;
	code : String;

begin
	if app.msgBox(app.getErrorString(Add).cnEcFirstToUpper() &amp; " " &amp; app.getErrorString(New) &amp; " " &amp; app.getErrorString(Section) &amp; app.getErrorString(At) &amp; posM.String &amp; app.getErrorString(M) &amp; "?", app.getErrorString(Section) &amp; " " &amp; app.getErrorString(Create), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
	
		create proxySection transient;
		code:=self.myROROStructure.getNextSectionCode();
		proxySection.setProxy(code,posM,null);
		proxySection.setMyVoyageStructure(self.myROROStructure.myVoyage.myStructuralElements);//cnwrd1 31874
		while true do
		
			app.myTrxCA.trxCreateVesselSection(proxySection,tmpSect,app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(New) &amp; " " &amp; app.getErrorString(Voyage) &amp; " " &amp; app.getErrorString(Section), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
		endwhile;
	
	endif;

epilog
	delete proxySection;

end;</source>
        <Parameter name="posM" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doShowROROConfig" id="e6510ab6-0ce4-478b-b0d8-81053cf102e3">
        <source>doShowROROConfig() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.myAssistant.showROROVesselConfig(self.myROROStructure.myVoyage.getMyVessel());

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getROROStructure" id="9c7763a8-e3df-4014-ac8c-758f93c39625">
        <source>getROROStructure(): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myROROStructure;

epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getSectionFromPixelX" id="44755669-544c-4e44-8637-87e81dd2f41f">
        <source>getSectionFromPixelX(x: Real; _posM: Decimal io): CM_VesselSection;
/*

Date		Who		Reason
02 August 2013	cnwer1	Initial creation PAR

*/

vars
	tmpSect : CM_VesselSection;
	posM : Decimal[12,2];

begin

	posM := (ROROStructureRearLine * self.scaleFactor);
	posM := x - posM;
	posM := posM / (ROROStructurePixelsPerMetre* self.scaleFactor);
	
	tmpSect := self.myROROStructure.getSectionByPosition(posM, 0.2);
	_posM := posM;
	return  tmpSect;

epilog

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="_posM" type="Decimal" usage="io"/>
        <ReturnType type="CM_VesselSection"/>
    </JadeMethod>
    <JadeMethod name="initDetails" id="d97a18c3-3d72-40e7-ac84-f1b129ac2d38">
        <updating/>
        <source>initDetails(_parent: CM_Object; _deck: CM_DeckVoyage; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	roroVessel	: CM_ROROVoyageStructure;
	deck 		: CM_DeckVoyage;
begin	

	self.mode:=_mode;

	self.setupDeckItemTable();
	
	deck:=_deck;
	if _parent.isKindOf(CM_ROROVoyageStructure) then
		roroVessel:=_parent.CM_ROROVoyageStructure;
	elseif _parent.isKindOf(CM_DeckVoyage) then
		roroVessel:=_parent.CM_DeckVoyage.myVoyageStructure;
		self.isSubDeck:=true;
		
		deck:=_parent.CM_DeckVoyage;
	endif;
	
	self.doChangeROROStructure(roroVessel,_deck);

	
	if _mode = self.Mode_Copy and _deck &lt;&gt;  null and _deck.isTransient then
		self.myCurrentProxyDeck:=_deck;
	endif;	
		
	if self.isSubDeck and _deck &lt;&gt; deck then
		self.cmbDeck.listObject:=deck;
	endif;
	
	self.doChangeMode(self.mode);


epilog

end;</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadROROStructureCombo" id="718f6817-5610-4760-8c9c-e489831ef2b1">
        <updating/>
        <source>loadROROStructureCombo(_deck: CM_DeckVoyage) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.myAssistant.comboBoxROROVoyageStructure(self.cmbVessel,self.myROROStructure,self.myTerminal);
	
	

	inheritMethod(_deck);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="22890353-f236-4ee2-95da-9f297d26a017">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	tmpCaption : String;
	deck 		:  CM_DeckVoyage;
begin
	if self.mode = self.Mode_View then
		tmpCaption  := "(" &amp; app.getErrorString(View).toUpper() &amp; ") ";
	elseif self.mode = self.Mode_Edit then
		tmpCaption  := "(" &amp; app.getErrorString(Edit).toUpper() &amp; ") ";
	elseif self.mode = self.Mode_New then
		tmpCaption  := "(" &amp; app.getErrorString(New).toUpper() &amp; ") ";
	elseif self.mode = self.Mode_Copy then
		tmpCaption  := "(" &amp; app.getErrorString(Copy).toUpper() &amp; ") ";
	endif;

	tmpCaption  := tmpCaption &amp; app.getErrorString(Roro_voyage_deck_definit);
	
	
	if self.myCurrentProxyDeck &lt;&gt; null then
		deck:=self.myCurrentProxyDeck.CM_DeckVoyage;
	elseif self.myCurrentDeck &lt;&gt; null then
		deck:=self.myCurrentDeck.CM_DeckVoyage;
	endif;
	
	if deck  = null then
		return;
	endif;
	
	tmpCaption  := tmpCaption &amp; " - " &amp; deck.getVoyage.code;
	if self.mode = self.Mode_New then
		if deck.isKindOf(CM_DeckVoyageSub) then
		
			tmpCaption  := tmpCaption &amp;", " &amp; app.getErrorString(Parent_deck)  &amp; ": " &amp; deck.CM_DeckVoyageSub.myParentDeck.code;		
		endif;
	else
		tmpCaption  := tmpCaption &amp;", " &amp; app.getErrorString(Deck) &amp; ": " &amp; deck.code;
	endif;

	if self.myCurrentProxyLayerLayout &lt;&gt; null then
		tmpCaption  := tmpCaption &amp; ", " &amp; app.getErrorString(Layer) &amp; ": " &amp; self.myCurrentProxyLayerLayout.code;
	endif;
	
	inheritMethod(tmpCaption);

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="startROROStructureNotes" id="492e5afb-40f6-408b-968e-2298227085a8">
        <source>startROROStructureNotes() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.beginNotification(self.myROROStructure,EVENT_VESSEL_DECK_CREATE,Response_Continuous,null);
	self.beginNotification(self.myROROStructure,EVENT_VESSEL_DECK_UPDATE,Response_Continuous,null);
	self.beginNotification(self.myROROStructure,EVENT_VESSEL_DECK_DELETE,Response_Continuous,null);
	
	//got this error in dmast in reality shouldn't be able to have a roro vessel with no container structure
	if self.myROROStructure.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		self.beginNotification(self.myROROStructure.myVoyage.myCellularVoyageStructure,EVENT_SECTION_CREATE,Response_Continuous,null);
		self.beginNotification(self.myROROStructure.myVoyage.myCellularVoyageStructure,EVENT_SECTION_UPDATE,Response_Continuous,null);
		self.beginNotification(self.myROROStructure.myVoyage.myCellularVoyageStructure,EVENT_SECTION_DELETE,Response_Continuous,null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bcb7d8e2-9927-4957-ae15-b46990d57ed9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 15:45:45.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022920, locale);
end;</source>
    </JadeMethod>
</GUIClass>
