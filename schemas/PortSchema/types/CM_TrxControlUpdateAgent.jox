    <JadeMethod name="trxAutoPlanMultipleTis" id="4fb57e52-7201-4e64-9ae2-380a802e3704">
        <updating/>
        <source>trxAutoPlanMultipleTis(_wleSetIn, _wleSetOut : CM_WLESet input;  _moveMode : Integer; _passport : CM_Passport input) updating;

// Created by cnwdvb1 on 01 May 2006
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 30/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object based
vars

	wle			: CM_WorkListEntry;
	ti 			: CM_TrackedItem;
	partsInJob,
	count		: Integer;
	cmifMonitor	: CMIF_Monitor;
	lastUpdated	: Decimal [20];						// PAR #35843

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	partsInJob := _wleSetIn.size;
	
	_passport.useTIDictDeferUpdate			:= true;
	_passport.useTITransactionDeferUpdate	:= true;
	
	// Break autoplanning into batches of 10.
	beginTransaction;

	foreach wle in _wleSetIn do
		count := count + 1;
		
		app.myUtilityUA.utlAutoPlanTiSimple(wle, _moveMode, _passport);
		if _passport.hasErrors then
			return;
		else
			// Par 12926
			if (_moveMode = PLANNING_MODE and wle.myTrackedItem.myPrimaryPlannedLocation = null) or
				(_moveMode = QUEUE_MODE and wle.myTrackedItem.myPrimaryQueuedLocation = null) then
			else
				if not _wleSetOut.includes(wle) then
				_wleSetOut.add(wle);
				endif;
			endif;
		endif;
		
		if count mod 10 = 0 then
			_passport.doDeferredUpdates();
			commitTransaction;
			beginTransaction;
		endif;
		
		//if count mod 5 = 0 then																	// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			if cmifMonitor &lt;&gt; null then
				cmifMonitor.updateProgress (null, partsInJob, count);
			endif;
			lastUpdated := app.relativeMachineTime;													// PAR #35843
		endif;
	endforeach;
	
	_passport.doDeferredUpdates();
	
epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wleSetIn" type="CM_WLESet" usage="input"/>
        <Parameter name="_wleSetOut" type="CM_WLESet" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAutoPlanOnPickupMultipleTIs" id="e43de679-6e30-402c-8faf-37ce17193228">
        <updating/>
        <source>trxAutoPlanOnPickupMultipleTIs(_wleSet : CM_WLESet input; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/03/2011	cnwrd1	Initial creation
30/03/2016	cnwdap1	PAR #35843 Make monitor time-based rather than object based
*/

vars
	wle			: CM_WorkListEntry;
	ti 			: CM_TrackedItem;
	partsInJob,
	count		: Integer;
	cmifMonitor	: CMIF_Monitor;
	lastUpdated	: Decimal [20];						// PAR #35843

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	partsInJob := _wleSet.size;
	
	_passport.useTIDictDeferUpdate			:= true;
	_passport.useTITransactionDeferUpdate	:= true;
	
	// Break autoplanning into batches of 10.
	beginTransaction;

	foreach wle in _wleSet do
		count := count + 1;

		if wle.myTrackedItem &lt;&gt; null and wle.isPlanOnPickupNoTarget then	 //only if we have a tracke item and its POP with no current target
			app.myUtilityUA.utlAutoPlanOnPickupTI(wle.myTrackedItem, wle, _passport);
		endif;
		if _passport.hasErrors then
			return;
		endif;
		
		if count mod 10 = 0 then
			_passport.doDeferredUpdates();
			commitTransaction;
			beginTransaction;
		endif;
		
		//if count mod 5 = 0 then																	// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			if cmifMonitor &lt;&gt; null then
				cmifMonitor.updateProgress (null, partsInJob, count);
			endif;
			lastUpdated := app.relativeMachineTime;													// PAR #35843
		endif;
	endforeach;
	
	_passport.doDeferredUpdates();
	
epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wleSet" type="CM_WLESet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAutoPlanOverstowedCargo" id="fc097e1f-8a2d-4196-b8d1-828517802741">
