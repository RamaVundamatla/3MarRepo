    <JadeMethod name="comboBoxCustomsInsp" id="e050610f-b07f-46e9-928a-13869deaddfe">
        <source>comboBoxCustomsInsp();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2013	cnwmc5	Initial creation

*/

vars

	ca : CM_CustomsAgent;
	iter : Iterator;
	index : Integer;

begin

	self.cmbCustomsInsp.clear();
	
	iter := CM_CustomsAgent.instances.createIterator;
	while iter.next( ca ) do
		index := self.cmbCustomsInsp.addItem( ca.name );
		self.cmbCustomsInsp.itemObject[index] := ca;
	endwhile;

epilog

	delete iter;

end;</source>
