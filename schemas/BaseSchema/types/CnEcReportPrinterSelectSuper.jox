<GUIClass name="CnEcReportPrinterSelectSuper" id="666df49c-094e-4c53-8055-d78d573cf943">
    <superclass name="CnEcReportBaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

