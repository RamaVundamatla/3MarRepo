    <JadeMethod name="handleComplete" id="322be2f3-f371-453b-a126-1d79966c7a9a">
        <updating/>
        <source>handleComplete() updating;

vars

begin
	//if myCargoTI.allChildren.size = 0 then//PAR 22954
	if not myCargoTI.hasChildren then  // PAR 23966
		app.msgBox('The pack cannot be completed as nothing has been packed.','',MsgBox_OK_Only);
		return;
	endif;
	if app.myMobileGUIAgent.loadPackCompleteForm(myCargoTI) then
		unloadForm;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="handleDisplayDetails" id="f5362c0e-051f-46dd-b713-b6d5baf51ad0">
        <source>handleDisplayDetails();

vars
	form : MOB_PackingDetailsForm;
	r, c :Integer;
	objSelected : CM_Object;
begin
	self.tbl_PackingRqst.selectedNext(r,c);
	if r &lt;&gt; 0 and c &lt;&gt; 0 then
		objSelected := self.tbl_PackingRqst.accessRow(r).itemObject.CM_Object;
		if objSelected &lt;&gt; null and objSelected.isKindOf(CM_ReserveSelection)then
			create form transient;
			form.setMyRequest(objSelected.CM_ReserveSelection);
			form.show();
		endif;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="handleEnterOKClick" id="4f0f10ab-ba96-4696-a650-60aba68f1a1d">
        <updating/>
        <source>handleEnterOKClick()updating;
// ---------------------------------------------------------------------------
// Created:     by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cargoTI 	: CM_TrackedItem;
	id			: String;
	cargoTIDesc : Integer;
	
begin
	id := self.txt_CargoID.text.trimBlanks().toUpper();
	
	if id = null then
		return;
	endif;
	
	if self.allBulkReleases.first().status &lt;&gt; BR_ACTIVE then
		app.msgBox("The request is not active, you can not pack more cargo against it.", '', MsgBox_OK_Only);
		return;
	endif;
	
	if self.itemAlreadyInTable(id, self.tbl_CargoIDs) then
		app.msgBox(app.getErrorString(Duplicate_entry), '', MsgBox_OK_Only);
		self.txt_CargoID.text := '';
		self.txt_CargoID.setFocus();
		return;
	endif;
	
	self.packCargoIdOK(id);
	self.txt_CargoID.text := '';
	self.txt_CargoID.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCargoIDsTbl" id="39a44e2c-9baf-4382-a956-bc7e553babe7">
        <updating/>
        <source>loadCargoIDsTbl(tbl: CM_MobTable io) updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cargoChild  : CM_TrackedItem;
	count 		: Integer;
begin
	tbl.rows := 1;
	count := 0;
	//create children transient;
	//self.myCargoTI.getAllChildren(children);//PAR 22954
	//foreach cargoChild in children do
	foreach cargoChild in self.myCargoTI.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		if cargoChild &lt;&gt; null then
			count := count +1;
			self.addCargoChildToTable(tbl, cargoChild, count);
		endif;
		
	endforeach;
	
	self.txt_GrossWeight.text := self.myCargoTI.totalWeight.asStringWeightJMT();
epilog
	
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadPackingReqTbl" id="28caa273-2551-4a71-946e-fc885b9c0d39">
        <updating/>
        <source>loadPackingReqTbl(_tbl: CM_MobTable io) updating;
// ---------------------------------------------------------------------------
// Created:     17 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	reserve : CM_ReserveDetail;
	currentRow : Integer;
begin
	_tbl.rows :=1;
	currentRow := _tbl.rows;
	
	foreach reserve in self.allBulkReleases.first.allReservePackingChildren do
		self.addReserveToTable(_tbl, reserve, currentRow);
	endforeach;	
end;</source>
        <Parameter name="_tbl" type="CM_MobTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="packCargoIdOK" id="8de5425f-47e1-4567-a7f6-49e6dbc87f13">
        <updating/>
        <source>packCargoIdOK(_ti: String) updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTI				: CM_TrackedItem;
	
begin
	tmpTI := self.myMobileDataAgent.findOnsiteCargoByID(_ti.toUpper());
	
	if tmpTI = null then
		app.msgBox(app.getErrorString(Item_NotFound), app.getErrorString(Item_NotFound), MsgBox_OK_Only);
		return;
	endif;
	
	// pack the item
	if self.validatePackItem(false, tmpTI) then
		if self.doCargoSave(tmpTI, self.myLocation, false) then
			self.loadCargoIDsTbl(self.tbl_CargoIDs);
			
			if self.allBulkReleases.size() &lt;&gt; 0 then
				self.loadPackingReqTbl(self.tbl_PackingRqst);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_ti" type="String"/>
    </JadeMethod>
