    <JadeMethod name="isReleaseTypeRequest" id="abfb202f-b954-4af5-927b-ed612709107e">
        <source>isReleaseTypeRequest(): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2011	cnwer1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
begin

	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null then
		// ### CCMS 1011 Tranship
		//			Basically if the TI is on or is Qing to its export voyage OR is in the yard then it is a load, 
		//			else i.e. when planning, if the TI is still on its import voyage then it is not a load as this will complete the WLE
		if ti.isTranshipExport() then
			lc := ti.myPrimaryActualLocation;
			
			if lc.isVoyageController and not self.job.CM_VoyageJob.isDischarge then  //cnwrd1 par 29239 13.3.2012 - if we are a discharge job (returning to yard) we are a receipt..
				return  ( lc.CM_VoyageController.myVoyage = ti.myVoyageTranshipExport);
			endif;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
