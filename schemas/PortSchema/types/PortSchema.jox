    <JadeMethod name="temperatureConversion" id="b3807a64-9145-4553-b9f5-05f1e239b99c">
        <source>temperatureConversion(_celciusInput : Boolean; _temperature : Real) : Real;
// ---------------------------------------------------------------------------
// Created:     11 June 2001 by cnwrs2
//
// Purpose:     Converts the input temperature (in C or F) to the other
//
// Parameters:  _celciusInput to indicate what conversion is to be done.
//				The temperature to convert
//
// Returns:     The converted temperature.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	inTemp, outTemp	: Real;
	tempConv		: CM_TemperatureConversion;
	
begin	
	inTemp := _temperature.roundedTo(2);
	
	if _celciusInput then
// see cm_container validateTemperature
		tempConv := app.myRoot.allTempsCelsius[inTemp];
		
		if tempConv &lt;&gt; null then
			outTemp := tempConv.fahrenheit;
		else
			outTemp := ((inTemp * (9 / 5)) + 32).roundedTo(1);
		endif;
		
	else
		tempConv := app.myRoot.allTempsFahrenheit[inTemp];
		
		if tempConv &lt;&gt; null then
			outTemp := tempConv.celsius;
		else
			outTemp := ((inTemp - 32) * (5 / 9)).roundedTo(1);
		endif;
	endif;
	
	return outTemp;
	
end;</source>
        <Parameter name="_celciusInput" type="Boolean"/>
        <Parameter name="_temperature" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="temperatureConversionLookup" id="c91f9797-45bf-46ec-87dd-f7a624faeb23">
        <source>temperatureConversionLookup(_inputIsCelsius : Boolean; _temp : Real) : CM_TemperatureConversion;

vars
	tempConv: CM_TemperatureConversion;
begin
	if _inputIsCelsius then
// see cm_container validateTemperature
		tempConv := app.myRoot.allTempsCelsius[_temp];
	else
		tempConv := app.myRoot.allTempsFahrenheit[_temp];
	endif;
	return tempConv;
end;</source>
        <Parameter name="_inputIsCelsius" type="Boolean"/>
        <Parameter name="_temp" type="Real"/>
        <ReturnType type="CM_TemperatureConversion"/>
    </JadeMethod>
