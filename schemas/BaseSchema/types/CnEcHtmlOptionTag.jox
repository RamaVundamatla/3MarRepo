____________________________________________________________________________
Identifies a single option within a menu (select) tag.</text>
    <DbClassMap file="basehtml"/>
    <ExplicitInverseRef name="mySelectTag" id="4d79a6b9-c6bd-4e15-8d17-c6a16fd1de98">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CnEcHtmlSelectTag"/>
        <access>readonly</access>
        <Inverse name="CnEcHtmlSelectTag::allOptions"/>
    </ExplicitInverseRef>
    <PrimAttribute name="optionDisplay" id="f0becb4a-1dff-48de-b64d-5a6ee6eaeb99">
        <type name="String"/>
        <text>Specifies the text that will be displayed for the menu item.</text>
    </PrimAttribute>
    <PrimAttribute name="optionIsSelected" id="806b6f9d-6f20-4fe8-abc9-c2b7649138e5">
        <embedded/>
        <type name="Boolean"/>
        <text>Specifies that this option is the default (pre-selected) menu item.</text>
    </PrimAttribute>
    <PrimAttribute name="optionValue" id="8f8cec33-2dfb-49dc-ba3c-1ab3bd3b7263">
        <type name="String"/>
        <text>Specifies the value if the menu item is selected.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="aea78ce1-b577-465d-b2f5-964fa7cee5bb">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;

begin
	if self.optionIsSelected then
		htmlString	:=	'SELECTED';
	endif;

	htmlString	:=	htmlString &amp; ' VALUE="' &amp; self.optionValue &amp;
					inheritMethod() &amp; '"&gt;' &amp; self.optionDisplay;

	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="36773969-e5ce-4d7e-8cb3-2af6bc8d1f3e">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		30 April 2000 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;OPTION ' &amp; self.buildTagBody() &amp; '&lt;/OPTION&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setSelectTag" id="e7d0e89d-923c-4a78-a74f-ae85dfd3b25d">
        <updating/>
        <source>setSelectTag(pSelectTagObj:CnEcHtmlSelectTag) updating;
// --------------------------------------------------------------------------------
// Created:		30 April 2000 by cnwdad1
//
// Purpose:		Set a reference to the receiver's owning select tag object.
//
// Parameters:	pSelectTagObj - The select tag object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Update the properties.

	// Update references.

	self.mySelectTag	:=	pSelectTagObj;
end;</source>
        <Parameter name="pSelectTagObj" type="CnEcHtmlSelectTag"/>
    </JadeMethod>
</Class>
