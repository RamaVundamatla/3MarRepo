    <JadeMethod name="adjustHeight" id="2f48a54b-c017-4995-a3d4-568f89a65a65">
        <updating/>
        <source>adjustHeight(pMaxHeight : Real) updating;
// ---------------------------------------------------------------------------
// Created:     10 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	numRows		: Integer;
	totHeight	: Real;

begin

	numRows := self.rows;
	
	foreach idx in 1 to numRows do
		if self.accessRow(idx).visible then
			totHeight := totHeight + self.accessRow(idx).height;
			if totHeight &gt; pMaxHeight then
				break;
			endif;
		endif;
	endforeach;

	if totHeight &gt; 0 then
		totHeight := totHeight + 2;
	endif;
	
	if totHeight &gt; pMaxHeight then
		totHeight := pMaxHeight;
	endif;
	
	self.height := totHeight;
	
end;</source>
        <Parameter name="pMaxHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="checkSameAttributeType" id="54b964e5-ec38-48ae-be2a-3cf93a04a1a5">
        <updating/>
        <source>checkSameAttributeType(lSame, lAvail, lSelected, lPad, lGap,lSub,lPow  : Boolean io ) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lLeft : Integer;
	tTop : Integer;
	r, c	: Integer;
	locationController, locationController2	: CM_StackController;
	

begin
		lSame := true;
		lSelected := false;
		lPad := false;
		lGap := false;
		lSub := false;
		// check that the selected cells are all of the same type, else NO!!!!
		foreach r in 2 to self.rows do
			if lSame = false then
				break;
			endif;
			foreach c in 2 to self.columns do
				// Find all the cells that are selected
				self.accessCell(r,c);
				if self.accessedCell.selected then
					// PAD
					if c mod 2 = 0 then
						lSelected := true;
						lPad := true;
						//go through all of the cells and compair each one with the last one
						 locationController2 := self.accessedCell.itemObject.CM_StackController;
						 if locationController2.mySubBlockStack &lt;&gt; null then	// You cannot edit a sub block stack!
						 	lSub := true;
						 endif;
						 lAvail := locationController2.isAvailable(0,null); // PAR 17886
						 lPow := locationController2.power.Boolean;
						 if locationController &lt;&gt; null then
						 	if locationController.usage &lt;&gt; locationController2.usage
						 	or locationController.availability &lt;&gt; locationController2.availability
						 	or locationController.power &lt;&gt; locationController2.power then
						 	// they are different!
						 		lSame := false;
						 		break;
						 	endif;
						 endif;
						 locationController := self.accessedCell.itemObject.CM_StackController;
					
					// GAP
					else
						self.accessCell(r,c - 1);
						locationController2 := self.accessedCell.itemObject.CM_StackController;
						if  locationController2.getMyNextController(CM_GapController) &lt;&gt; null then
							lAvail := locationController2.getMyNextController(CM_GapController).CM_GapController.inUse;
							lSelected := true;
							lGap := true;
							self.accessColumn(c);
							self.accessedColumn.selected := true;
						endif;
					endif;					
				endif;
			endforeach;
		endforeach;
		
end;</source>
        <Parameter name="lSame" type="Boolean" usage="io"/>
        <Parameter name="lAvail" type="Boolean" usage="io"/>
        <Parameter name="lSelected" type="Boolean" usage="io"/>
        <Parameter name="lPad" type="Boolean" usage="io"/>
        <Parameter name="lGap" type="Boolean" usage="io"/>
        <Parameter name="lSub" type="Boolean" usage="io"/>
        <Parameter name="lPow" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="aec6ed12-096d-4d10-a21b-a9f6dce2cb2d">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.rows := 1;
	self.columns := 1;
	
	self.fixedRows := 1;
	self.fixedColumns := 1;


end;</source>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="aa0192b0-a63c-4dc9-993b-02386d1ade1f">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.parent.width &gt; self.myWidth then
		if self.parent.height &gt; self.myHeight then
			self.width := self.myWidth;
		else
			self.width := self.myWidth + 20; // allow for vertical scrolls
		endif;
	else
		self.width := self.parent.width - 40;
	endif;

	if self.parent.height &gt; self.myHeight then
		if self.parent.width &gt; self.myWidth then
			self.height := self.myHeight;
		else
			self.height := self.myHeight + 20; // allow for horizontal scrolls
		endif;
	else
		self.height := self.parent.height - 40;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setDistanceFromBottom" id="f2cbf50c-a721-44ab-a913-7df683e84845">
        <updating/>
        <source>setDistanceFromBottom(_value : Real) updating;
// ---------------------------------------------------------------------------
// Created:     03 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.distanceFromBottom &lt;&gt; _value then
		self.distanceFromBottom := _value;
	endif;

end;</source>
        <Parameter name="_value" type="Real"/>
    </JadeMethod>
