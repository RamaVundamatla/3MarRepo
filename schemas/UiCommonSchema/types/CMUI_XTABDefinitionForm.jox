    <JadeMethod name="clearButtonCollection" id="12330ef2-2695-4dbe-a880-00078bea1996">
        <source>clearButtonCollection(_coll :ObjectArray input)protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
