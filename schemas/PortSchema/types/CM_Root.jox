	self.createAuditedClassProperty(CM_TrackedItem,CM_TrackedItem::contractId.name ,'Invoice Contract ID',true,clsCol);//27.02.2023 navtnr20 TFS CR 55648 Task 55663	
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::portOfOrigin.name, 'Port of Origin', true, clsCol);	//20 Oct 2023 jlika1 TFS 60946	
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::myCustomerPriority.name, 'Customer Priority', true, clsCol);	//13 Nov 2023 jlika1 TFS 61130
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::readyToLoad.name, 'ReadyToLoad', true, clsCol);	//11 Dec 2023 jlika1 TFS 61645
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::readyToLoadManual.name, 'ReadyToLoadManualOverride', true, clsCol);	//11 Dec 2023 jlika1 TFS 61645
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::allCustomsReferences.name, 'Customs References', true, clsCol);		// TFS 63075
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::shipmentNumber.name, 'ShipmentNumber', true, clsCol);	// 22/04/2024 jlizm1 TFS 62856
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::secondaryBarcodeId.name, 'Secondary Barcode', true, clsCol); //05/06/2024	navhn30	TFS #63629
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::orderNumber.name, 'Order Number', true, clsCol);	//05/06/2024	navhn30	TFS #63629
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::incoTermCode.name, 'Incoterm', true, clsCol);	// ### JIRA 12626 26NOV2024 NAVAB1
	self.createAuditedClassProperty(CM_TrackedItem, CM_TrackedItem::myCargoTypeForContents.name, 'Cargo Type for Contents', true, clsCol);//10/11/2025	navkc1 JIRA 36553
	
	//	CM_Car has no subclasses
	clsCol.clear();
	//08.01.2020 cnwma1	 #48173
	self.createAuditedClassProperty(CM_Car, CM_Car::carType.name,  		     'CarType',            true, clsCol);
	self.createAuditedClassProperty(CM_Car, CM_Car::certificate1.name,  	 'Certificate1',	   true, clsCol);
