    <JadeMethod name="resetData_40653" id="c00a1849-b762-4afd-847c-3b0ac1d48d25">
        <source>resetData_40653();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/06/2021	nqvmh5	Initial creation

*/

constants

	ReleaseRequestID		: String = "JLG40653ROADA001";


vars

	terminal				: CM_Terminal;
	ti						: Object;
	releaseRequest			: CM_BulkRelease;
	tempReleaseRequest		: CM_BulkRelease;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
	ediData 				: String;				
	
begin

	
	app.initialize();
	
		
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(terminal);
	
	// delete the release request
	self.deleteReleaseRequest(ReleaseRequestID);
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG40653A01");
		
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	// load release request
	ediData := "&lt;?xml version='1.0' encoding='UTF-8'?&gt; &lt;JMTInternalRequestMultiLine&gt;
	&lt;AllRequestHeader&gt;
	&lt;operationsToPerform&gt;Verify;Load To DB&lt;/operationsToPerform&gt;
      &lt;operationsToPerformStatuses&gt;EDI_STATUS_VERIFIED / EDI_STATUS_VERIFIED_WARNINGS;EDI_STATUS_DBLOADED&lt;/operationsToPerformStatuses&gt;
 
		&lt;RequestHeader Terminal='TT1'&gt;
					&lt;releaseByType&gt;true&lt;/releaseByType&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
					&lt;releaseRequestNumber&gt;JLG40653ROAD001&lt;/releaseRequestNumber&gt;
					&lt;releaseTypeStr&gt;Road&lt;/releaseTypeStr&gt;
					&lt;statusBulkRelease&gt;Active&lt;/statusBulkRelease&gt;
					&lt;subTerminalCode&gt;Depot&lt;/subTerminalCode&gt;
					&lt;carrierCode&gt;CARRIER1&lt;/carrierCode&gt;
			&lt;AllRequestDetail&gt;
				&lt;RequestDetail&gt;
					&lt;quantity&gt;5&lt;/quantity&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;isoType&gt;22G1&lt;/isoType&gt;
					&lt;releaseRequestNumber&gt;JLG40653ROAD001&lt;/releaseRequestNumber&gt;
					&lt;requestDetailID&gt;001&lt;/requestDetailID&gt;
					&lt;fullOrMT&gt;E&lt;/fullOrMT&gt;
					&lt;availabilityGrades&gt;1&lt;/availabilityGrades&gt;
				&lt;/RequestDetail&gt;
				&lt;RequestDetail&gt;
					&lt;quantity&gt;6&lt;/quantity&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;isoType&gt;22G1&lt;/isoType&gt;
					&lt;releaseRequestNumber&gt;JLG40653ROAD001&lt;/releaseRequestNumber&gt;
					&lt;requestDetailID&gt;001&lt;/requestDetailID&gt;
					&lt;fullOrMT&gt;E&lt;/fullOrMT&gt;
					&lt;availabilityGrades&gt;6&lt;/availabilityGrades&gt;
				&lt;/RequestDetail&gt;
			&lt;/AllRequestDetail&gt;
		&lt;/RequestHeader&gt;
		
		
	&lt;/AllRequestHeader&gt;
&lt;/JMTInternalRequestMultiLine&gt;";

	self.ediLoadVerifyDBLoadActualSetup(ediData, null, method.name, EDIFileType_JMTInternal, false, true, false, false, null);
	
	foreach releaseRequest in terminal.allBulkReleasesByCodeDate discreteLock do
		if releaseRequest.code = ReleaseRequestID then
			tempReleaseRequest := releaseRequest;
			break;
		endif;
	endforeach;
	self.assertNull(tempReleaseRequest);
	
	beginTransaction;
	releaseRequest.setPropertyValue("dateRequested", releaseRequest.createdTime);
	commitTransaction;
	
	// load the ti's back in
	ediData := "&lt;?xml version='1.0' encoding='UTF-8'?&gt;
&lt;JMTInternalCargoOnSite xmlns:xsi='http://www.jademasterterminallogistics.com/JMTInternal' xsi:noNamespaceSchemaLocation='JMTInternalCargoOnSite.xsd'&gt;
   &lt;AllCargoOnSite&gt;
      &lt;operationsToPerform&gt;Verify;Load To DB&lt;/operationsToPerform&gt;
      &lt;operationsToPerformStatuses&gt;EDI_STATUS_VERIFIED / EDI_STATUS_VERIFIED_WARNINGS;EDI_STATUS_DBLOADED&lt;/operationsToPerformStatuses&gt;
      &lt;CargoOnSite Terminal='TT1'&gt;
         &lt;TestCases&gt;40653&lt;/TestCases&gt;
     &lt;messageMode&gt;A&lt;/messageMode&gt;
    &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
         &lt;id&gt;JLG40653A01&lt;/id&gt;
         &lt;isoType&gt;22G1&lt;/isoType&gt;
         &lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
         &lt;locationId&gt;MKBS01&lt;/locationId&gt;
         &lt;weight&gt;5000.0000&lt;/weight&gt;
         &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
         &lt;commodity&gt;MT&lt;/commodity&gt;
         &lt;voyageCode&gt;MSCK000002&lt;/voyageCode&gt;
         &lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
         &lt;availabilityGrade&gt;6&lt;/availabilityGrade&gt;
      &lt;/CargoOnSite&gt;
   &lt;/AllCargoOnSite&gt;
&lt;/JMTInternalCargoOnSite&gt;";

	self.ediLoadVerifyDBLoadActualSetup(ediData, null, method.name, EDIFileType_JMTInternal, false, true, false, false, null);

epilog

	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_40675" id="2f0b4ad4-7c6d-4dc6-8e49-c34d5512c6a1">
        <source>resetData_40675();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2020	jlgmh5	Initial creation

*/

constants
	TrainCode : String = "TRAIN40675";
	WagonClassCode : String = "UK";
	WagonMasterCode1 : String = "WGN1";
	WagonMasterCode2 : String = "WGN2";
	RailAreaId : String = "40675";
	TiCode1 : String = "JLG40675A01";
	TiCode2 : String = "JLG40675A02";
	
vars
	train				: CM_Train;
	railArea 			: CM_Rail;
	wagon1 				: CM_Wagon;
	wagon2 				: CM_Wagon;
	wagonClass 			: CM_WagonClass;
	pxyMaster 			: CM_WagonMaster;
	wagonMaster1 		: CM_WagonMaster;
	wagonMaster2 		: CM_WagonMaster;
	ti1 				: CM_TrackedItem;
	ti2 				: CM_TrackedItem;
	terminal			: CM_Terminal;
	operator			: CM_Operator;
				
	allTrackedItems 	: CM_TIByIdDups;
	
begin

	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	app.myPassport.setMyTerminal(terminal);
	
	operator := app.myRoot.allOperators["MSK"];
	self.assertNotNull(operator);


	// ****** DELETE EVERYTHING FROM LAST TEST
	self.deleteRailArea(RailAreaId);
	
	wagonClass	:=	app.myRoot.allWagonClasses[WagonClassCode];

	wagonMaster1 := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster1 &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster1 );
	endif;
	wagonMaster2 := self.getRoot.allWagonMasters[WagonMasterCode2];
	if wagonMaster2 &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster2 );
	endif;
	
	self.deleteTrain(TrainCode,null);

	self.deleteContainer(TiCode1);
	self.deleteContainer(TiCode2);
		
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode, null);
	self.assertNotNull(train);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	
	// ****** CREATE MASTER FOR SOME REASON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode1,	//_id : String;
						wagonClass,	//_myWagonClass : CM_WagonClass;
						CM_Carrier.firstInstance,	//_myCarrier : CM_Carrier;
						300,	//_maxCargoHeight	: Decimal; 
						0,	//_maxCargoWeight	: Decimal;
						0	//_tareWeight	: Decimal
						);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster1, app.myPassport );	
	
	// ****** ADD PLACE CONTAINERS ON WAGONS
	create allTrackedItems transient;
	ti1 := self.createContainer(	TiCode1,
							"220A",	//_isoType: String;
							"APPL",	//_commodity: String;
							operator,	//_operator: CM_Operator
							false
							);
	allTrackedItems.add(ti1);
		
	self.opts.purge();
	self.opts.addAssoc("RailLine", railArea.allRailLinesByIndex[1]);
	wagon1 := self.addWagonToTrainOption2(train, wagonMaster1, allTrackedItems, false);
	delete pxyMaster;
	
	// ****** CREATE MASTER FOR SOME REASON
	allTrackedItems.clear();
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode2,	//_id : String;
						wagonClass,	//_myWagonClass : CM_WagonClass;
						CM_Carrier.firstInstance,	//_myCarrier : CM_Carrier;
						300,	//_maxCargoHeight	: Decimal; 
						0,	//_maxCargoWeight	: Decimal;
						0	//_tareWeight	: Decimal
						);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster2, app.myPassport );	
	
	// ****** ADD PLACE CONTAINERS ON WAGONS
	//create allTrackedItems transient;
	ti2 := self.createContainer(	TiCode2,
							"220A",	//_isoType: String;
							"APPL",	//_commodity: String;
							operator,	//_operator: CM_Operator
							false
							);
	allTrackedItems.add(ti2);
		
	self.opts.purge();
	self.opts.addAssoc("RailLine", railArea.allRailLinesByIndex[1]);
	wagon2 := self.addWagonToTrainOption2(train, wagonMaster2, allTrackedItems, false);
	delete pxyMaster;

epilog
	
	delete pxyMaster;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_40720" id="1212d3a1-e2ac-4086-8a24-2ee94f5676b1">
        <source>resetData_40720();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/12/2022	navmh5	Initial creation

*/


vars

	debtor					: CM_Debtor;
	terminal				: CM_Terminal;
	debtorRate				: CM_DebtorRate;
	rateEntry				: CM_RateEntry;
	
begin

	
	app.initialize();
	
		
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(terminal);
	
	debtor := app.myRoot.myRootCompany.debtors["RDT"];
	assertNotNull(debtor);
	
	foreach debtorRate in debtor.serviceRates discreteLock do
	
		if debtorRate.service = null or debtorRate.service.name &lt;&gt; "TEST40720A" then
			continue;
		endif;
		
		foreach rateEntry in debtorRate.rateEntries discreteLock do
			
			if rateEntry.getPropertyValue("costPerUnit").Decimal &lt;&gt; 50.000000.Decimal and rateEntry.createdTime.Date &lt;&gt; "12/09/2018".Date then
				continue;
			endif;
			
			beginTransaction;
			rateEntry.setCostPerUnit(100.000000.Decimal);
			commitTransaction;
			break;
		
		endforeach;
	
	endforeach;
	

epilog

	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_40789" id="1141cde2-cff3-4e55-bc61-befc7b262439">
        <source>resetData_40789();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/05/2021	navmh5	Initial creation

*/


vars

	terminal				: CM_Terminal;
	ti						: Object;
	voyage					: CM_Voyage;
	jobSheet 				: CM_VoyageJobSheet;
	theRealVJob				 : CM_VoyageJob;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	app.initialize();
	
		
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(terminal);
	
	// delete voyage jobs
	voyage := self.getVoyage("MSCK000002");
	self.assertNotNull(voyage);

	jobSheet := voyage.allJobSheets["WP0001"];
	if jobSheet &lt;&gt; null then
		theRealVJob := jobSheet.allJobsByJobNum["40789JOB"];
		if theRealVJob &lt;&gt; null then
			app.myTrxDA.trxDeleteVoyageJob(theRealVJob, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endif;
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG40789A01");
		
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;

epilog

	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_40968" id="2ba7b3a2-4606-4bf8-b451-cb2e797c8e79">
        <source>resetData_40968();
/*

Purpose:	Reset 37392		

Date		Who		Reason
11/10/2021	navmh5	Initial creation

*/
constants

	RegoNo					: String = "40968";

vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	passportTerm 			: CM_Terminal;
	rfid					: CM_RFIDTag;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	foreach vvr in CM_VehicleVisitRecord.instances discreteLock where vvr.regNumber = RegoNo and vvr.timeOut = null do
		break;
	endforeach;
	
	if vvr &lt;&gt; null then
		self.ignoreTrxWarnings(true); 
		app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	else
		self.deleteVehicle(RegoNo);
	endif;
	
	foreach rfid in CM_RFIDTag.instances discreteLock do
	
		if not rfid.code.cnContains(RegoNo) then
			continue;
		endif;
		
		beginTransaction;
		rfid.setIsAvailableForEntry(true);
		commitTransaction;
	
	endforeach;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_41155" id="25eec22b-fc29-4701-bfcd-a4b01ad420c0">
        <source>resetData_41155();
/*

Purpose:	Reset 37392		

Date		Who		Reason
21/06/2022	navmh5	Initial creation

*/
constants
	VechileID				: String = "41155";

vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	vehicle := self.getVehicle(VechileID);
	if vehicle = null then
		app.writeLog("Unable to find vehicle " &amp; VechileID, LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;
	
	self.deleteVehicle(VechileID);

	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_41189" id="9e0a42a4-5066-4086-a4b2-c812b145ee62">
