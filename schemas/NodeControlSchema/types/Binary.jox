<PrimType name="Binary">
    <JadeMethod name="displayLine" id="083ed9ea-fc42-421f-9f84-7565483fe2b9">
        <source>displayLine(i:Integer):String;

begin
	return i.padLeadingWith("0",10)&amp;self[1:16].display[11:end]&amp;CrLf;
end;</source>
        <Parameter name="i" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayLines" id="5a94bb21-2417-43ca-9f06-f577098221a3">
        <source>displayLines(i:Integer):String;

vars
	j:Integer;
	s:String;
begin
	foreach j in 0 to self.length-1 step 16 do
		s:=s&amp;self[j+1:16].displayLine(i+j);
	endforeach;
	return s;
end;</source>
        <Parameter name="i" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
