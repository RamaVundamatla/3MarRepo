    <JadeMethod name="getDisplayStringForAttribute" id="ec336487-7f32-482e-b6be-b31ed09b3e7b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// -------------------------------------------
// Created 29 November 2005 by cnwdvb1
// -------------------------------------------
// cnwrd1 ccms 1034 13.8.2008
// 07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// 27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
// 20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
//25 July 2022 	navvt20 Bug 54194: EUP - Fleet Maintenance - ISO Container Maintenance issue with what is displayed in Operator column
vars
	tmpTI : CM_TrackedItem;
	tmpStr : String;
	tmpLC : CM_LocationsController;
	ownerCode    : String;
	invalidOwner,	
	invalidOperatorNew : Boolean;
	operatorNew	: CM_Operator;
	owner		: CM_Operator;
begin
	//07/02/2011 cnwdz2 26874 
	on Exception do app.handleDeletedObject(exception, operatorNew, invalidOperatorNew);
	if _attrName = ETRow_Id then
		return self.id;
	elseif _attrName = ETRow_CurrentLocation then
		tmpTI := self.allTis.last;
		if tmpTI = null then
			return "";
		endif;
		tmpLC := tmpTI.getPrimaryLocation(REAL_MODE);
		if tmpLC &lt;&gt; null then
			tmpStr := tmpLC.getFullId();
			if tmpTI.myTerminal &lt;&gt; null then
				tmpStr := tmpTI.myTerminal.code &amp; " " &amp; tmpStr;
			endif;
		else
			if tmpTI.state = TI_STATE_OFFSITE then
				tmpStr := app.stateEnumToString(TI_STATE_OFFSITE);
				if tmpTI.myTerminal &lt;&gt; null then
					tmpStr := tmpTI.myTerminal.code &amp; " " &amp; tmpStr;
				endif;
			else
				return "";
			endif;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_CargoType then
		return self.getCargoTypeDesc();
	elseif _attrName = ETRow_AllStops then
		return self.allStopsNew.listString(",",CM_StopsTable::heading.name);		
	elseif _attrName = ETRow_OpCode then
		operatorNew := myOperatorNew;
		if operatorNew &lt;&gt; null then //ccms 1660
			//07/02/2011 cnwdz2 26874 start
			tmpStr :=  operatorNew.getDisplayDetails(true);
			if invalidOperatorNew then
				return null;
			endif;
			return tmpStr;
			//return self.myOperatorNew.getDisplayDetails(true);
			//26874 end			
		else
			return null;
		endif;
	elseif _attrName = ETRow_OpDescription then
		operatorNew := self.myOperatorNew;
		if operatorNew &lt;&gt; null then //ccms 1660
			//07/02/2011 cnwdz2 26874 start
			tmpStr :=  operatorNew.getDisplayDetails(false);
			if invalidOperatorNew then
				return null;
			endif;
			return tmpStr;
			//return self.myOperatorNew.getDisplayDetails(false);
			// 26874 end
		else
			return null;
		endif;
	elseif _attrName = ETRow_TareWeight then // cnwrd1 ccms JMT 1060 Imp Measurements
		return self.tWeight.asStringWeightJMT();		
	elseif _attrName = ETRow_TWeight then
		return self.tWeight.asStringWeightJMT();			
	elseif	_attrName = ETRow_IntLength then
		return self.intLength.asStringMeasurementJMT();
	elseif	_attrName = ETRow_IntHeight then
		return self.intHeight.asStringMeasurementJMT();
	elseif	_attrName = ETRow_IntWidth then
		return self.intWidth.asStringMeasurementJMT();
	elseif	_attrName = ETRow_ExtLength then
		return self.extLength.asStringMeasurementJMT();
	elseif	_attrName = ETRow_ExtHeight then
		return self.extHeight.asStringMeasurementJMT();
	elseif	_attrName = ETRow_ExtWidth then		
		return self.extWidth.asStringMeasurementJMT(); // cnwrd1 ccms JMT 1060 Imp Measurements
	elseif _attrName = ETRow_Operator then	
		operatorNew := self.myOperatorNew;
		if operatorNew &lt;&gt; null then //ccms 1660
			//return self.myOperatorNew.getDisplayDetailsOther(false);
			//07/02/2011 cnwdz2 26874 start
			//tmpStr :=  operatorNew.getDisplayDetails(true);												// TFS 53362
			//tmpStr :=  operatorNew.getDisplayDetails( app.myRoot.getConfig(ComboByNameOperator).Boolean);	// TFS 53362
			tmpStr :=  operatorNew.getDisplayDetails(not app.myRoot.getConfig(ComboByNameOperator).Boolean); // 25 July 2022 navvt20 BUG 54194 
			if invalidOperatorNew then
				return null;
			endif;
			return tmpStr; 			
			//return self.myOperatorNew.getDisplayDetails(true);
			//26874 end
		else
			return null;
		endif;	
	elseif _attrName = ETRow_MyOwnerTxt then
		owner := self.myOwner;
		if owner &lt;&gt; null then
			//07/02/2011 cnwdz2 26874 start
			on Exception do app.handleDeletedObject(exception, owner, invalidOwner);
			ownerCode := owner.code;
			if invalidOwner then
				return '';
			else
				return ownerCode;
			endif;
			//return self.myOwner.code;	
			//26874 end
		else
			return '';
		endif;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName =ETRow_TilcType then
		return self.getCurrentTi().CM_TILC.myTILCType.description;
	elseif _attrName = ETRow_ToDoTasks then
		return self.allToDoTaskDesc.listString(",",CM_ToDoTaskDesc::description.name);
	elseif _attrName = ETRow_DamageDetails then
		//return self.allDamageInstancess.listString(",",CM_DamageInstance::description.name);		
		return self.allDamageInstancesByPos.listString(", ",CM_DamageInstance::description.name);
	
	//27.02.2018 cnwma1 ChangeRequest #36813
	elseif _attrName = ETRow_GeneratorId then
		if self.allTIMasterAttachees.isNotEmpty then
			return self.allTIMasterAttachees.listString (", " ,CM_TIMaster::id.name);
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;

</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="6f7d39fe-fe9c-41ca-ab88-a4b85bb641e2">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// -------------------------------------------
// Created 29 November 2005 by cnwdvb1
// -------------------------------------------
vars

	block	: CM_DataContainerBlock;
	loc		: CM_LocationsController;
	ti		: CM_TrackedItem;
	c		: Integer;

begin
	inheritMethod(_dataContainer);
	
//	block := _dataContainer.addNewBlock;
//	block.addNewItem("Master Group", DC_Label, 1, self);
//	block.addNewItem(self.myTiMasterGroup.code, DC_Data, 1, self);
	
	foreach ti in self.allTis discreteLock do
		c := c + 1;
		block := _dataContainer.addNewBlock;
		block.addNewItem('Child Item (' &amp; c.String &amp; ') Created on' , DC_Label, 1, self);
		block.addNewItem(ti.createdTsForTiMaster.shortCurrentLocaleFormat(), DC_Data, 1, self);
		loc := ti.myPrimaryActualLocation;
		if loc &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem('Current Location', DC_Label, 1, self);
			block.addNewItem(loc.getFullId(), DC_Data, 1, self);
		endif;
	endforeach;


end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
