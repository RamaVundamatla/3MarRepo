    <JadeMethod name="verifyTI" id="1758ba6b-36c3-442c-a27b-2c79918aadd1">
        <source>verifyTI() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ti : CM_TrackedItem;
	cargoType : Integer;
	errMsg : String;
begin
	if not self.myEDIData.CM_EDIDataPrenote.canSkipDuplicates(self) then // must process normally without skipping here
		return;
	endif;
	cargoType := self.cargoType;
	//epr TFS 6980 26/9/17 was calling a getMyProduct but the cargoType mapping method already does this
	ti := self.getMyTerminal().allOnsiteTIsByIdCargoType[self.id, cargoType];
	if ti &lt;&gt; null then
		errMsg := app.getErrorString1(Dup_on_site_skip, self.id);	//20 May 2016	NDL	TFS 2004
//		self.myEDIData.addSkipErrorMessage(errMsg, self, app.myPassport);	//20 May 2016	NDL	TFS 2004
		return;
	endif;	
	ti := self.getMyTerminal().allNotifiedTIsByIdCargoType[self.id, cargoType];
	if ti &lt;&gt; null then
		errMsg := app.getErrorString1(Preno_dup_found_skip, self.id);	//20 May 2016	NDL	TFS 2004
//		self.myEDIData.addSkipErrorMessage(errMsg, self, app.myPassport);	//20 May 2016	NDL	TFS 2004
		return;
	endif;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyTemperature" id="ceea38f6-3ace-4f55-9b07-0ce724a26b3d">
        <source>verifyTemperature() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	commodityObj	: CM_Commodity;
	isoTypeObj		: CM_ISOType;
begin
	if not self.requiresTemperature and self.temperature &lt;&gt; NULL_TEMPERATURE then
		app.raiseCMWarning(Reefer_details_non_reefer, null, self, self);
	endif;
	if self.requiresTemperature and self.temperature = NULL_TEMPERATURE then
		app.raiseCMWarning(Reefer_details_non_reefer, null, self, self);
	endif;
	if self.temperature &lt;&gt; NULL_TEMPERATURE then
		commodityObj :=	app.getMyRoot.allCommodities[self.commodity];
		isoTypeObj := app.getMyRoot.allISOTypes[self.isoType];
		if commodityObj = null then
			if self.commodity = null then
				app.raiseCMException(ERR_NO_COMMODITY_TEMP,
										ETRow_Commodity,
										self );
			endif;
		endif;
		if isoTypeObj = null then
			app.raiseCMException2(ERR_FIELD_VALUE,
									self.isoType,
									app.getString(ISO_Type),
									ETRow_ISOType,
									self);
		endif;
		if commodityObj = null or isoTypeObj = null then
			return;
		endif;
		if commodityObj.hasTemp then
			if not self.temperature.isBetween(commodityObj.minTemp, commodityObj.maxTemp) then
				app.raiseCMException4(VB_TEMP_VALIDATION,
										app.temperatureDisplayString(self.temperature),
										self.id,
										app.temperatureDisplayString(commodityObj.minTemp),
										app.temperatureDisplayString(commodityObj.maxTemp),
										ETRow_Temperature,
										self);
			endif;
		else
			app.raiseCMException2(ERR_Commodity_does_not_require,
									self.id,
									app.getErrorString(CM_TemperatureExtra),
									ETRow_Temperature,
									self);
		endif;

		if not isoTypeObj.isPowered() then
			app.raiseCMException(Has_Temp_ISOType_Not_Powered,
									ETRow_ISOType,
									self);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyTrailerType" id="cd40d2aa-9f91-462b-9695-e8118b299e8a">
        <source>verifyTrailerType() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	trailerTypeObj : CM_TILCType;
begin
	if self.trailerType &lt;&gt; null then
		trailerTypeObj := app.myRoot.allTILCTypes[ null, self.trailerType ];
		if trailerTypeObj = null then
			app.raiseCMException1(ERR_INVALID_TRAILER_TYPE, self.trailerType, ETRow_TrailerType , self);
		endif;
	endif;

epilog

end;</source>
