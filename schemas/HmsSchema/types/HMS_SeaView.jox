    <JadeMethod name="initMeterMarks" id="22fef76d-2de8-487d-a76f-2b1450aa4d59">
        <updating/>
        <source>initMeterMarks()updating;
//--------------------------------------------------
// Created:	18 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	frm					: CMUI_MoveableFrame;
	entTableDef			: EntTableDef;
	tbl					: CM_EntryTable;
begin

	frm := self.frmMeterMarks;
	frm.backColor := self.backColor;
	//frm.width := 250;
	//frm.height := 250;
	tbl := self.tblMeterMarks;
	tbl.warningMethod := 'entTableWarning';
	tbl.top 	:= self.frmMarksToolbar.height;
	frm.cnEcResizeContents();
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_HMSMovementSelect];
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Entry table definition not found for meter mark table');
		return;
	endif;
	
	tbl.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.cmbMyBerth.style := ComboBox.Style_DropDownList;

	//Hide Data/Time as not implemented yet
	tbl.hideRowByName(ETRow_OccursOnDate, false);
	tbl.hideRowByName(ETRow_OccursOnTime, false);
	
	self.setColorsForEntryTable(tbl);	

	frm.centreWindow();

end;</source>
