	//19.	keterangan, Warehouse Number, Optional
	//self.keterangan
	
	//20.	tanggalMulaiTambat, Mandatory
	//self.tanggalMulaiTambat
/*	if self.tanggalMulaiTambat = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_DetailPPK::tanggalMulaiTambat.name, null, null);
	endif;
	
	//21.	jamMulaiTambat, Mandatory
