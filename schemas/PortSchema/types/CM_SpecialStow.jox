    <JadeMethod name="setProxy" id="e8acc16e-72a2-412d-bca2-3a5a2e187f01">
        <updating/>
        <source>setProxy(pName, pDescription: String)  updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.code 			:= pName[1:5].trimBlanks;
	self.description 	:= pDescription[1:30].trimBlanks;
	self.myRoot 		:= app.myRoot;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e02b9806-020f-4900-988d-c295326b5b8b">
        <source>validateForCreate();
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin

	if app.myRoot.allSpecialStows[self.code] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="e02a4574-4b7f-46e8-916c-f6cf7d63de0b">
        <source>validateForUpdate();
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="f5e40b49-09b0-4391-ba6b-d9eb428ab2c4">
        <source>validateMe() protected;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	if self.code.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Special Stow Code', null, null);
		app.raiseCMException(Input_required_field_specStwCd, null, null); // cnwdb2	PAR 35364


	endif;
	if self.description.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Special Stow Description', null, null);
		app.raiseCMException(Input_required_field_specStwDs, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
