    <JadeMethod name="cmbBusUnitsVess_click" id="b3034446-603b-4c8b-9d0c-0e2936191530">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBusUnitsVess_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2018	jlgab1	Initial creation

*/

vars

	bank : CM_Bank;
	vessel : CM_Vessel;
begin
	self.myProformaTransactionCriteria := null;
	bank := self.cmbBusUnitsVess.listObject.CM_Bank;
	
	vessel := self.cmbVesselsWithDefault.listObject.CM_Vessel;
	if vessel= null then
		if self.cmbVesselsWithDefault.listIndex = 1 then
		self.myProformaTransactionCriteria := bank.getVesselProformaDefault();
		
		else
			mulColumns.clearSelected();
			mulHMSResources.clearSelected();
			self.hookSource := "";
			self.cmbVesselsWithDefault.listIndex := -1;
			return;
		endif;
	else
		self.myProformaTransactionCriteria := bank.getVesselProforma(vessel);
	endif;

	
	
	if self.myProformaTransactionCriteria&lt;&gt; null then
		mulHMSResources.setSelected(self.myProformaTransactionCriteria.allHMSResources);
		mulColumns.setSelected(self.myProformaTransactionCriteria.allEventTypes);
		self.hookSource := self.myProformaTransactionCriteria.getJadeCode();
	else
		mulColumns.clearSelected();
		mulHMSResources.clearSelected();
		self.hookSource := "";
		self.cmbVesselsWithDefault.listIndex := -1;
	endif;

	


epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
