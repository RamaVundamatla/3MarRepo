    <JadeMethod name="removeFO" id="49659fdb-2bae-450f-a4bb-6479c491e7c1">
        <source>removeFO(finacialObject: CM_FinancialObject);

begin
	if auditedFOs.includes(finacialObject) then
		auditedFOs.remove(finacialObject);
	endif;

	if unauditedFOs.includes(finacialObject) then
		unauditedFOs.remove(finacialObject);
	endif;

end;</source>
        <Parameter name="finacialObject" type="CM_FinancialObject"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2806fc02-4743-46bb-83cd-ee3e5093128d">
        <updating/>
        <source>setForUpdate(pProxyAudit:CM_Audit; _financialObject : CM_FinancialObject; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	now : TimeStamp;
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.unauditedFOs.remove(_financialObject);
	self.clearingRemarks := pProxyAudit.clearingRemarks;
	self.clearingUserId := _passport.userCode;
	self.clearedDateTime := now;
	self.auditedFOs.add(_financialObject);

end;</source>
        <Parameter name="pProxyAudit" type="CM_Audit"/>
        <Parameter name="_financialObject" type="CM_FinancialObject"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
