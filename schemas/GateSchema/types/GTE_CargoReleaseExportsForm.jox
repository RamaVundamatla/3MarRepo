    <JadeMethod name="initMainTable" id="317b3156-4fb6-445e-b140-0d1b4ca2af81">
        <source>initMainTable();
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;
	aStopTable			: CM_StopsTable;
	theUser			: CM_User;
	term			: CM_Terminal;
	rowName			: String;
begin

	theTable := tblMain;
	theTable.warningMethod := 'entTableWarning';
	
	entTableDef := app.myController.getEntTableDef(ETDef_ExportReleaseMain);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theUser := app.myPassport.myUser;
	term := app.myPassport.myTerminal;

	// DVB CCMS 1235
//	foreach aStop in app.myRoot.allStopsTable do
	foreach aStopTable in app.myRoot.allAvailableStopsTables do
		if (not theUser.canUpdateStop(term, aStopTable)) then
			if self.mode = Mode_Update then
				continue;
			endif;
		elseif (not theUser.canViewStop(term, aStopTable)) then
			continue;
		endif;
		
		if theUser.canViewStop(term, aStopTable) then
			//rowName := aStopTable.heading &amp; " Stop";
			rowName := aStopTable.getAttrName();
			theTable.addAttribute(rowName, aStopTable.getAttrHeading(), Table.InputType_CheckBox, null, true);
		endif;	
	endforeach;

//	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	theTable.changeMode := theTable.ChangeMode_All;		//changed to All - bulk edit needs to know which rows have changed
end;</source>
    </JadeMethod>
