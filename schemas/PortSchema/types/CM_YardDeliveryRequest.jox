    <JadeMethod name="processDeleteForWO" id="67ba1879-adbd-4cd4-8172-3832b3b8371d">
        <source>processDeleteForWO();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwrd1	Initial creation

*/

vars
	isRBT 	: Boolean;
	wle 	: CM_WorkListEntry;
	incompleteCount : Integer;
	incompleteTISet : CM_TISet;
	ti			: CM_TrackedItem;
begin

	create incompleteTISet transient;
	// here we need to see if we are a Work order job
	if self.myJob.myWODtl &lt;&gt; null then
	
	// figure out if we are from a RBT
	isRBT := ( self.myWORequestByType &lt;&gt; null);
	
		foreach wle in self.allWorkListEntries do
			// if wle not complete then we need to update some work order detail stats &amp; cargo id's
			if wle.status &lt;&gt; WLE_COMPLETED then
				incompleteCount := incompleteCount +1;
				if wle.myTrackedItem &lt;&gt; null then
					incompleteTISet.add(wle.myTrackedItem );
				endif;
			endif;	
		endforeach;
		
		if incompleteCount &gt; 0 then
		// now have work to do on the wod/requets		
			if isRBT then
			// TI's are not assigned to the WOD untill the WLE is compelte so we can ignore the incompleteTISet
			// incompleteCount needs to update the request
			self.myWORequestByType.setTotalActioned( self.myWORequestByType.totalActioned - incompleteCount  );
			else
			//we need to update the WOD allocated count 			
			self.myJob.myWODtl.setTotalActioned( self.myJob.myWODtl.totalActioned - incompleteCount);
			self.myJob.myWODtl.setTotalUnactioned( self.myJob.myWODtl.totalUnactioned + incompleteCount);
			// and unaction the cargo on the WOD
				foreach ti in incompleteTISet do
					self.myJob.myWODtl.setTIUnactioned( ti, false);
				endforeach;
			endif;
		
		endif;
	endif;	

epilog
	delete incompleteTISet;
end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e4ee72f3-edc8-4f37-9e0c-700eea23d760">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose: par 31418 

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2013	cnwrd1	Initial creation
3 Nov 2022 navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request

*/
vars
	proxyRequest	: CM_YardDeliveryRequest;
	completedOK		: Boolean;
begin

	proxyRequest := inheritMethod();
	
	proxyRequest.myRelease := self.myRelease;
	proxyRequest.myReleaseItem := self.myReleaseItem;
	proxyRequest.myTargetSubTerminal := self.myTargetSubTerminal;
	proxyRequest.myWORequestByType := self.myWORequestByType;
	proxyRequest.sourceLocation := self.sourceLocation;
	proxyRequest.targetLocation := self.targetLocation;
	proxyRequest.mtGrade := self.mtGrade;
	proxyRequest.myUpdateSubTerminal := self.myUpdateSubTerminal;	//3.11.2022	navsks20 TFS 52721
	proxyRequest.isAvailable := self.isAvailable;	//3.11.2022	navsks20 TFS 52721

	completedOK := true;
	return proxyRequest;
epilog
	if not completedOK then			
		delete proxyRequest;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b687e8ae-3a0d-4583-81a7-0b2d2b05fd3d">
        <updating/>
        <source>setForCreate(pProxyRequest: CM_YardDeliveryRequest) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		note altough we have passed in a proxy request, the job referenced by it is real
// ---------------------------------------------------------------------------
// 3 Nov 2022 navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
vars
	ta	: CM_TerminalArea;
begin

	inheritMethod(pProxyRequest);
	
	//cnwrd1 par 26633 17.12.2010
	//self.mtGrade := pProxyRequest.mtGrade;
	self.allAvailabilityGrades.clear; 
	pProxyRequest.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	
	self.targetLocation := pProxyRequest.targetLocation;
	self.sourceLocation := pProxyRequest.sourceLocation;

	
	self.setNominatedTAs( pProxyRequest.allTerminalAreas, pProxyRequest.allTerminalAreaGridObj); //cnwrd1 par 24169  3.6.2010
	// 23098
	/*
	ta := pProxyRequest.getNominatedTA();
	if ta &lt;&gt; null then
		self.setNominatedTA("", ta, null); //cnwrd1 par 24169  3.6.2010
	endif;
	*/
	self.isBestPick := pProxyRequest.isBestPick;		// end 23098
	self.isFIFO := pProxyRequest.isFIFO ;  //cnwrd1 par 24169  3.6.2010
	
	self.requiredByDT := pProxyRequest.requiredByDT;	 //cnwrd1 ccms 1075/1735 23.7.09
	self.myTargetSubTerminal := pProxyRequest.myTargetSubTerminal;
	self.myRelease := pProxyRequest.myRelease;
	self.myReleaseItem := pProxyRequest.myReleaseItem;
	self.mySelectedRTQueue := pProxyRequest.mySelectedRTQueue;
	self.myWORequestByType := pProxyRequest.myWORequestByType;
	self.myUpdateSubTerminal	:= pProxyRequest.myUpdateSubTerminal;	//3.11.2022	navsks20 TFS 52721
	self.isAvailable	 := pProxyRequest.isAvailable;	//3.11.2022	navsks20 TFS 52721
	
	
	//cnwrd1 par 26633 17.12.2010 removed
	// seems the parents code runs through the setforupdate which duplicates this so we realy need to clear this here and now.
	//self.allAvailabilityGrades.clear; //cnwrd1 par 25441 17.8.2010
	//self.allAvailabilityGrades.add(self.mtGrade);

	
	// if we have a (packing)request update the numberWLEcreated // cnwrd1 ccms 1075 24.8.09
	/*
	if self.myRelease &lt;&gt; null then
		self.myRelease.setNumberWLECreated( self.myRelease.numberWLECreated + self.totalRequested );
	endif;
	*/

	self.createWLEs();
end;</source>
        <Parameter name="pProxyRequest" type="CM_YardDeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6c0e2ad1-2469-4faa-8c07-4cc3379f8423">
        <updating/>
        <source>setForUpdate(pProxyRequest: CM_YardDeliveryRequest) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 3 Nov 2022 navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
// ---------------------------------------------------------------------------

vars
	release : CM_BulkRelease;
	ta	: CM_TerminalArea;
begin


	self.targetLocation := pProxyRequest.targetLocation; //cnwrd1 par 27009 17.2.2011
	self.sourceLocation := pProxyRequest.sourceLocation;//cnwrd1 par 27009 17.2.2011

	if self.myRelease &lt;&gt; pProxyRequest.myRelease then
	//changed release update
	
		//remove what we added when created
		if self.myRelease &lt;&gt; null then
			self.myRelease.setNumberWLECreated( self.myRelease.numberWLECreated - self.totalRequested  );	
		endif;
		//addon new to new release
		release := pProxyRequest.myRelease;
	
		if release &lt;&gt; null then
			release.setNumberWLECreated( pProxyRequest.myRelease.numberWLECreated + pProxyRequest.totalRequested   );
		endif;
	endif;
	
	if self.totalRequested &lt;&gt; pProxyRequest.totalRequested then
	// changed total	
		if self.myRelease &lt;&gt; null then
			self.myRelease.setNumberWLECreated( self.myRelease.numberWLECreated - self.totalRequested  + pProxyRequest.totalRequested  );	
		endif;
	endif;
	
		
	
		if self.totalRequested &lt;&gt; pProxyRequest.totalRequested then
	endif;

	inheritMethod(pProxyRequest);

	//self.mtGrade := pProxyRequest.mtGrade;
	//cnwrd1 par 26633 17.12.2010
	self.allAvailabilityGrades.clear;
	pProxyRequest.allAvailabilityGrades.copy(self.allAvailabilityGrades);	
	
	self.targetLocation := pProxyRequest.targetLocation;
	self.sourceLocation := pProxyRequest.sourceLocation;
	
	self.setNominatedTAs(pProxyRequest.allTerminalAreas, pProxyRequest.allTerminalAreaGridObj);
	// 23098 
	/*
	ta := pProxyRequest.getNominatedTA();
	if ta &lt;&gt; null then
		self.setNominatedTA("", ta, null); //cnwrd1 par 24169  3.6.2010
	endif;
	*/
	self.isBestPick := pProxyRequest.isBestPick;		// end 23098
	self.isFIFO := pProxyRequest.isFIFO ;  //cnwrd1 par 24169  3.6.2010	
	
	self.requiredByDT := pProxyRequest.requiredByDT;	 //cnwrd1 ccms 1075/1735 23.7.09
	self.myTargetSubTerminal := pProxyRequest.myTargetSubTerminal;
	self.myRelease := pProxyRequest.myRelease;
	self.myReleaseItem := pProxyRequest.myReleaseItem;
	self.mySelectedRTQueue := pProxyRequest.mySelectedRTQueue;
	self.myWORequestByType := pProxyRequest.myWORequestByType;
	self.myUpdateSubTerminal	:= pProxyRequest.myUpdateSubTerminal;	//3.11.2022	navsks20 TFS 52721
	self.isAvailable	 := pProxyRequest.isAvailable;	//3.11.2022	navsks20 TFS 52721
	
	//cnwrd1 par 26633 17.12.2010
	//self.allAvailabilityGrades.clear;
	//self.allAvailabilityGrades.add(self.mtGrade);
	
	self.createWLEs();

end;</source>
        <Parameter name="pProxyRequest" type="CM_YardDeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="setProxyYardDelivery" id="a9b30fac-440b-42d8-8e2a-76ee70a94230">
        <updating/>
        <source>setProxyYardDelivery(	_isoType			: String;
						_operatorCode		: String;
						_remarks			: String;
						_targetLocation		: String;
						_userCode 			: String;
						_clean				: Boolean;
						_bestPick			: Boolean;	// 23098
						_isoGroup 			: String;
						_myJob 				: CM_Job;
						_allAvGrades		: IntegerArray;
						_totalRequested 	: Integer;
						_subTerminalObj 	: CM_SubTerminal;
						_sourceLocation 	: CM_LocationsController;
						_sourceTA 			: CM_TerminalArea;		// 23098
						_sourceGridObj 		: CM_GridObject;
						_requiredByDT 		: TimeStamp ;
						_targetSubTerminal 	: CM_SubTerminal ;
						_release			: CM_BulkRelease ;
						_releaseItem 		: CM_ReserveDetail ;
						_rtQueue			: CM_RadioTelemetryQueue ;
						_myWORequestByType 	: CM_WorkOrderRequestByType ;
						_heavyRated 		: Boolean;	// jlgka1 TFS# 40698
						_updSubTerminal		: CM_SubTerminal;    //3.11.2022	navsks20 TFS 52721
						_avail			    : Boolean) updating; //3.11.2022	navsks20 TFS 52721
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//----------------------------------------------------------------------------
/****Changes

//Date			Name	TFS#		Description
//============================================================================
//03/07/2009	cnwdad1	CCMS 1735 	Added Sub-Terminal.
//03/10/2018	jlgka1	40698		Added "heavyRated" parameter.
//3 Nov 2022 	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
============================================================================*/
vars
	aTerminal : CM_Terminal; //cnwrd1 par 29058 9.2.2012
begin
	//cnwrd1 par 26633 20.12.2010
	//self.mtGrade := _mtGrade;	
	self.allAvailabilityGrades.clear();
	_allAvGrades.copy(self.allAvailabilityGrades);
	
	self.sourceLocation := _sourceLocation;
	self.targetLocation := _targetLocation;
	// 23098
	if _sourceTA &lt;&gt; null then
		self.setNominatedTA("", _sourceTA,_sourceGridObj); 
	endif;
	self.isBestPick := _bestPick;	// 23098
	
	if _myWORequestByType &lt;&gt; null then //cnwrd1 par 29058 9.2.2012
		aTerminal := _myWORequestByType.myWorkOrderTISource.myParent.CM_WorkOrderTI.myTerminal;
	endif;
	
	if aTerminal = null then //cnwrd1 par 29058 9.2.2012
		aTerminal := app.getMyTerminalDO_NOT_USE();
	endif;
	
	if aTerminal &lt;&gt; null then //cnwrd1 par 29058 9.2.2012		 
		self.myTargetTA := aTerminal.lookupTerminalArea(_targetLocation);
	endif;
	
	self.clean 		:= _clean;	
	self.isoGroup 	:= _isoGroup; //cnwrd1 22.12.09
	self.isoType 	:= _isoType;
	self.myJob 		:= _myJob;	
	self.heavyRated := _heavyRated;
	
	//self.doISOGroupCheck := _doISOGroupCheck;
	// 30/11/2010 cnwmh5 #26400 - Start
	if _release &lt;&gt; null then
		self.deliveryNumber := _release.getDeliveryReleaseNumber();
	elseif _myJob &lt;&gt; null then
		self.deliveryNumber := _myJob.id;
	endif;		
	/*
	// Par need a delivery number. Get from job.
	if _myJob &lt;&gt; null then
		self.deliveryNumber := _myJob.id;
	endif;
	*/
	// 30/11/2010 cnwmh5 #26400 - End
	
	self.operatorCode 			:= _operatorCode;
	self.setRemarks(_remarks);
	self.totalRequested 		:= _totalRequested;
	self.userCode				:= _userCode;
	self.mySubTerminalSource	:=	_subTerminalObj; // cnwdad1 03/07/2009 - CCMS 1735.
	
	self.requiredByDT 			:= _requiredByDT;	 //cnwrd1 ccms 1075/1735 23.7.09
	self.myTargetSubTerminal 	:= _targetSubTerminal;
	self.myRelease 				:= _release;
	self.myReleaseItem 			:= _releaseItem;
	self.mySelectedRTQueue 		:= _rtQueue;
	self.myWORequestByType 		:= _myWORequestByType;
	
	self.myCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container]; //29 Mar 2012	NDL	Par 29280
	self.myUpdateSubTerminal := _updSubTerminal;	//3.11.2022	navsks20 TFS 52721
	self.isAvailable := _avail;	//3.11.2022	navsks20 TFS 52721
	
end;</source>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_targetLocation" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_clean" type="Boolean"/>
        <Parameter name="_bestPick" type="Boolean"/>
        <Parameter name="_isoGroup" type="String"/>
        <Parameter name="_myJob" type="CM_Job"/>
        <Parameter name="_allAvGrades" type="IntegerArray"/>
        <Parameter name="_totalRequested" type="Integer"/>
        <Parameter name="_subTerminalObj" type="CM_SubTerminal"/>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
        <Parameter name="_sourceTA" type="CM_TerminalArea"/>
        <Parameter name="_sourceGridObj" type="CM_GridObject"/>
        <Parameter name="_requiredByDT" type="TimeStamp"/>
        <Parameter name="_targetSubTerminal" type="CM_SubTerminal"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_releaseItem" type="CM_ReserveDetail"/>
        <Parameter name="_rtQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_myWORequestByType" type="CM_WorkOrderRequestByType"/>
        <Parameter name="_heavyRated" type="Boolean"/>
        <Parameter name="_updSubTerminal" type="CM_SubTerminal"/>
        <Parameter name="_avail" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setReserveDetail" id="754d5fe6-f2e7-409e-b9f5-1df3393acd0c">
        <updating/>
        <source>setReserveDetail(_reserveDetail: CM_ReserveDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2019	jlgndl1	Initial creation	TFS 46561

*/

vars

begin

	inheritMethod( _reserveDetail );
	
	if CM_ReserveSelection.hasInstance( _reserveDetail ) then
		if self.colour = null then
			self.colour := _reserveDetail.CM_ReserveSelection.colour;
		endif;
		if self.mark.trimBlanks = null then
			self.mark := _reserveDetail.CM_ReserveSelection.markSelection;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="testTargetLocation" id="7c695773-821d-4d00-bb93-802296bd0aac">
        <source>testTargetLocation();

vars
	lc	:	CM_LocationsController;
	height : Integer;
begin
	if targetLocation.trimRight = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN, "[blank]", null, null);
		return;	
	endif;
	self.myTerminal.findLocationFromString(self.targetLocation, false, lc, height);	
	if lc = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN, self.targetLocation, null, null);
		return;	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateWLEs" id="c99816c0-2f3e-4ef6-86ff-f882afb65cd4">
        <source>updateWLEs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwndl1	Initial creation

*/

vars

	wle : CM_WorkListEntry;

begin
	inheritMethod();
	
	if self.allWorkListEntries.isEmpty then
		return;
	endif;
	if self.myCargoType = null or not self.myCargoType.allowDuplicates then
		return;
	endif;
	if self.quantity &lt; 2 then
		return;
	endif;
	
	if self.allWorkListEntries.size = self.totalRequested then
		foreach wle in self.allWorkListEntries do
			wle.setQuantity( self.quantity );
		endforeach;
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
