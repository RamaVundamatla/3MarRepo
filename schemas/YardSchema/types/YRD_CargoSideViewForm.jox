    <JadeMethod name="setFormObject" id="802e1f2d-8dda-4143-a303-19095633c791">
        <updating/>
        <source>setFormObject(_obj: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	cnwer1	Initial creation

*/

vars
	ti : CM_TrackedItem;	
	lc : CM_LocationsController;
	sideAccessDirection : Integer;
begin


	self.myTrackedItem:=_obj.CM_TrackedItem;
	self.myTrackedItem.getAllOverstowedTIs(self.allOverstowingTIs,true,sideAccessDirection,null);
	
	foreach ti in self.allOverstowingTIs do
		lc := ti.getPrimaryLocation(REAL_MODE);
		if lc &lt;&gt; null and
		   lc.isKindOf(CM_GridController) then
			allLCs.addNoDuplicates(lc.CM_GridController, false);
		endif;
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
