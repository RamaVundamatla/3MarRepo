<GUIClass name="CMUI_VesselOperationsReportExt" id="6d7239c8-8c76-4130-a0f1-41203c444131">
    <superclass name="CMUI_VesselOperationsReport"/>
    <transient/>
    <subclassTransientAllowed/>
