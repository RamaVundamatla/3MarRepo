    <JadeMethod name="isCargoTypeForContents_Match" id="757e2833-9851-46f2-ad44-2d9e6e0a6136">
        <source>isCargoTypeForContents_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/10/2025	navkc1 JIRA 36148 AAT | RotaBox ISO Type and New Attributes - Yard Allocation

*/

vars

begin
	if self.myCargoTypeForContents = null then
		return true;
	endif;
	
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(self.myCargoTypeForContents);
epilog

end;</source>
