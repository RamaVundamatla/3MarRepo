    <JadeMethod name="getEntTableDef" id="f4ec393f-107e-40d0-a227-24ab3acddd90">
        <source>getEntTableDef(_name : String) : EntTableDef;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef	: EntTableDef;
begin
	app.myPassport.myActivityCapture.logEntTableDef(_name);

	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[_name];
	return entTableDef;
end;</source>
