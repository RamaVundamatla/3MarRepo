    <JadeMethod name="addCargoBulkAtLocation" id="0d62d33d-3fc1-4b3b-90c0-c05b72b018c7">
        <source>addCargoBulkAtLocation(_id: String; _cargoType : CM_CargoType;	_weight: Integer; _location: CM_LocationsController;
		_dPort : String; _imex : Integer; _voyage : CM_Voyage; _op : CM_Operator; _product : CM_Product): CM_Cargo;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		NAVAB1		Initial creation
17JUN2021 added cargo sub type TFS 51219
*/

// Create Cargo and put it at a specified location
vars
	cargo: CM_Cargo;
begin
	cargo := _location.createNewCargoForLCDetailed(_cargoType,_product, _id, _dPort, _imex, _voyage, _op, 1, null).CM_Cargo;
	self.assertNoTrxErrorsOrWarnings();											// 18/02/2016 cnwmh5
	beginTransaction;
		cargo.setTotalWeightWithoutTrans(_weight);
	commitTransaction;
	return cargo;
epilog
	abortTransaction;
end;</source>
