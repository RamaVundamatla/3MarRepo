    <JadeMethod name="deletePatchLast" id="256b197a-58ac-4ab8-ba05-cac6eb8aaab1">
        <source>deletePatchLast();

vars
	p: Patch;
	scm : SchemaInPatch;
begin

	beginTransaction;

	scm := SchemaInPatch.lastInstance;
	delete scm;
	commitTransaction;
	beginTransaction;
	scm := SchemaInPatch.lastInstance;
	delete scm;
	commitTransaction;
	
	beginTransaction;
	p:= Patch.lastInstance;
	delete p;

	commitTransaction;

end;
</source>
    </JadeMethod>
