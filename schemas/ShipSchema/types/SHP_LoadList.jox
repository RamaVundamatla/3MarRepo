    <JadeMethod name="getCurrentDataTable" id="bee38e5d-c10b-408c-9ef9-4e96d22e5745">
        <source>getCurrentDataTable() : CM_DataTable protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if self.fldMain.topSheet = self.shtPlanned then
		return self.tblPlanned;
	elseif self.fldMain.topSheet = self.shtNonplanned then
		return self.tblData;
	elseif self.fldMain.topSheet = self.shtDLR then
		return self.tblDLR;
	elseif self.fldMain.topSheet = self.shtSummary then
		return self.tblSummary;
	elseif self.fldMain.topSheet = self.shtTranship then
		return self.tblTranShip;
	elseif self.fldMain.topSheet = self.shtTBA then // TFS 45590
		return self.tblTBA;
	elseif self.fldMain.topSheet = self.shtAll then
		return self.tblAll;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="getFilteredTableList" id="e6e57aa8-85c5-4549-b33e-6393cc0fc8e7">
        <source>getFilteredTableList():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2012	cnwndl1	Initial creation	Par 25297

*/

vars

	strArray : StringArray;
	str : String;
	retStr : String;

begin

	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		create strArray transient;
		if self.allColumnFilters.includesFiltersFor( self.tblData ) then
			strArray.add( "'" &amp; app.getErrorString(SHP_Non_Plann01) &amp; "'" );
		endif;
		if self.allColumnFilters.includesFiltersFor( self.tblPlanned) then
			strArray.add( "'" &amp; app.getErrorString(Planned) &amp; "'" );
		endif;
		if self.allColumnFilters.includesFiltersFor( self.tblDLR ) then
			strArray.add( "'" &amp; app.getErrorString(SHP_DLR_Non_Planned) &amp; "'" );
		endif;
		if self.shtTranship.visible then
			if self.allColumnFilters.includesFiltersFor( self.tblTranShip ) then
				strArray.add( "'" &amp; app.getErrorString(SHP_Tranship_Export_Items) &amp; "'" );
			endif;
		endif;
		if self.shtTBA.visible then // TFS 45590
			if self.allColumnFilters.includesFiltersFor( self.tblTBA ) then
				strArray.add( "'" &amp; app.getErrorString(TBANONPLANNED) &amp; "'" );
			endif;
		endif;
		if self.allColumnFilters.includesFiltersFor( self.tblAll ) then
			strArray.add( "'" &amp; app.getErrorString(LOADLIST_ALL) &amp; "'" );
		endif;
		
		foreach str in strArray do
			if retStr = null then
				retStr := str;
			else
				retStr := retStr &amp; ", " &amp; str;
			endif;
		endforeach;
		
		if retStr &lt;&gt; null then
			retStr := retStr &amp; ".";
		endif;
		
	endif;
	
	return retStr;
		
epilog

	delete strArray;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRowsFromTIs" id="7b4e3f84-37c2-4f33-a2b2-440e73ed3555">
        <source>getRowsFromTIs() : CM_ObjectArray;
// ---------------------------------------------------------------------------
// Created:		14 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTIs : CM_TISet;
	theRows : CM_ObjectArray;
	aTI : CM_TrackedItem;
	aRow : CM_GridRow;
	dynaDict : DynaDictionary;
begin
	create theTIs transient;
	create theRows transient;
	
	if self.fldMain.topSheet = self.shtNonplanned then
		self.tblData.allSelectedObjects.copy(theTIs);
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.tblPlanned.allSelectedObjects.copy(theTIs);
	elseif self.fldMain.topSheet = self.shtDLR then
		self.tblDLR.allSelectedObjects.copy(theTIs);
	elseif self.fldMain.topSheet = self.shtTranship then
		self.tblTranShip.allSelectedObjects.copy(theTIs);
	elseif self.fldMain.topSheet = self.shtTBA then // TFS 45590
		self.tblTBA.allSelectedObjects.copy(theTIs);
	elseif self.fldMain.topSheet = self.shtAll then
		self.tblAll.allSelectedObjects.copy(theTIs);
	endif;
	
	foreach aTI in theTIs do
		if not  aTI.myPrimaryActualLocation.isKindOf(CM_GridController) then
			continue;
		endif;
		
		aRow := aTI.myPrimaryActualLocation.CM_GridController.myGridRow;
		
		if not theRows.includes(aRow) then
			theRows.add(aRow);
		endif;
	endforeach;

	create dynaDict transient;	
	dynaDict.setMembership(CM_GridRow);
	dynaDict.addMemberKey("myGridArea.id", false, true);
	dynaDict.addMemberKey("label", false, true);
	dynaDict.endKeys(true);

	theRows.copy(dynaDict);
	theRows.clear;
	dynaDict.copy(theRows);
	
	return theRows;
epilog
	delete dynaDict;
	delete theTIs;
end;</source>
        <ReturnType type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTIs" id="d82cfdf2-3376-430b-96d4-4135f50e6850">
        <source>getSelectedTIs(objArray : ObjectArray input) protected;
/*

Date		Who		Reason
01 October 2013	cnwer1	Initial creation PAR 32613

*/

vars

begin
    if self.fldMain.topSheet = self.shtNonplanned then
		//changed by cnwyl1 for par 12919
		//it was...
		//if self.tblData.row &lt;= self.tblData.fixedRows then//
		if self.tblData.row &lt; self.tblData.fixedRows then//
			return;
		endif;
		self.tblData.allSelectedObjects.copy(objArray);
	elseif self.fldMain.topSheet = self.shtPlanned then
		//if self.tblPlanned.row &lt;= self.tblPlanned.fixedRows then
		if self.tblPlanned.row &lt; self.tblPlanned.fixedRows then
			return;
		endif;
		self.tblPlanned.allSelectedObjects.copy(objArray);
	elseif self.fldMain.topSheet = self.shtDLR then
		//if self.tblDLR.row &lt;= self.tblDLR.fixedRows then
		if self.tblDLR.row &lt; self.tblDLR.fixedRows then
			return;
		endif;
		self.tblDLR.allSelectedObjects.copy(objArray);
	elseif self.fldMain.topSheet = self.shtTranship then
		//if self.tblTranShip.row &lt;= self.tblTranShip.fixedRows then
		if self.tblTranShip.row &lt; self.tblTranShip.fixedRows then
			return;
		endif;
		self.tblTranShip.allSelectedObjects.copy(objArray);
	elseif self.fldMain.topSheet = self.shtTBA then // TFS 45590
		if self.tblTBA.row &lt; self.tblTBA.fixedRows then
			return;
		endif;
		self.tblTBA.allSelectedObjects.copy(objArray);
	elseif self.fldMain.topSheet = self.shtAll then
		if self.tblAll.row &lt; self.tblAll.fixedRows then
			return;
		endif;
		self.tblAll.allSelectedObjects.copy(objArray);
	else
		return;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIsForColumnKey" id="de0f5c82-080c-4352-a7c9-c18ff58a39d0">
        <source>getTIsForColumnKey(_tiArray: ObjectArray input; _tiSet: CM_TISet; _columnKey: Integer);
//----------------------------------------------------------------
//	Created:	16 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	colKey	: Integer;
begin
	colKey := _columnKey;
	
	if _tiSet = null then
		return;
	endif;
	
	foreach ti in _tiSet do
		if colKey = self.Column_LoadPlanned then
			if ti.plannedSite = TI_SITE_ONSHIP then
				_tiArray.add(ti);		
			endif;
			
		elseif colKey = self.Column_LoadToPlan then
			if ti.plannedSite &lt;&gt; TI_SITE_ONSHIP then
				_tiArray.add(ti);		
			endif;
			
		elseif colKey = self.Column_SpecialStows then
			if ti.isSpecialStow then
				_tiArray.add(ti);		
			endif;
			
		else
			_tiArray.add(ti);		
		endif;
	endforeach;
end;</source>
        <Parameter name="_tiArray" type="ObjectArray" usage="input"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_columnKey" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTableColumFilters" id="1373412f-361c-4845-84a1-dfdd7bc30f7a">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 25297

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );
	

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
