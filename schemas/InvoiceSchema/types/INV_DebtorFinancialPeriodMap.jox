    <JadeMethod name="loadTypes" id="f518adf3-ce40-4f05-80a3-afb8b1184c7f">
        <source>loadTypes();
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
vars

	i : Integer;
	invoiceDesc : CM_InvoiceDesc;
	mappingTable : CM_DataTable;
	bank : CM_Bank;
	debtorColumns : Boolean;
begin
	debtorColumns := true;
	mappingTable := self.tblData;
	bank := self.myCurrentBank;		// 35874

	mappingTable.columns := 1;
	mappingTable.fixedColumns := 1;
	i := 1;
	foreach invoiceDesc in bank.invoiceTypes where not invoiceDesc.isNotAvailableForEntry do
		i := i + 1;
	endforeach;
	mappingTable.rows := i;
	mappingTable.clear;
	mappingTable.row := 1;
	mappingTable.columnWidth[1] := 260;
	i := 1;
	mappingTable.accessCell(1,1).text := "Invoice Types";
	mappingTable.accessedCell.fontBold := true;
	mappingTable.accessedCell.alignment := Table.Alignment_Left_Top;
	
	foreach invoiceDesc in bank.invoiceTypes where not invoiceDesc.isNotAvailableForEntry do
		i := i + 1;
		mappingTable.row := i;
		mappingTable.text := invoiceDesc.description;
		mappingTable.accessRow(i).itemObject := invoiceDesc;
	endforeach;
	
	mappingTable.accessColumn(1).backColor := self.colorHeadingColumn;

epilog

end;</source>
    </JadeMethod>
