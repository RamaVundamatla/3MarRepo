    <JadeMethod name="jobOrder" id="cfc6b71f-890c-485d-a261-b3e759c8c8e4">
        <methodInvocation>mapping</methodInvocation>
        <source>jobOrder(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:		29 March 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if set then
		return;
	else
		if self.myJobSheet = null then
			_value := 0;
		else
			_value := self.myJobSheet.allJobsByOrder.indexOf(self);
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jobTypeId" id="38800853-8a50-42da-afda-2bd3032f1f24">
        <methodInvocation>mapping</methodInvocation>
        <source>jobTypeId(set: Boolean; _value: String io) mapping;
//--------------------------------------------------------------
//Created: 25 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	bolType			: CM_BOLType;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.jobType = JOB_TYPE_DISCHARGE then
		_value := app.getErrorString(SHP_Discharge);
	elseif self.jobType = JOB_TYPE_LOAD then
		_value := app.getErrorString(SHP_Load);
	elseif self.jobType = JOB_TYPE_SOB then
		_value := app.getErrorString(SHP_Shift_On_Board);
	elseif self.jobType = JOB_TYPE_USER then
		_value := app.getErrorString(User_defined);
	else//job type and docket/bol type match
		bolType := app.myRoot.allBOLTypes[self.jobType];
		if bolType &lt;&gt; null then
			_value := bolType.description;
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
