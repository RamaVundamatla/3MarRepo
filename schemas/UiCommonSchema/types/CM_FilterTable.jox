    <JadeMethod name="columnFilterApplyFilters" id="e2724532-71ff-4dfd-a699-4601c8186f15">
        <updating/>
        <source>columnFilterApplyFilters() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	colIndex : Integer;
	cloneListTable : CMUI_ListTable;
	startRow : Integer;
	filterStringsArray : StringArray;
	filterText : String;

begin

	self.columnFilterShowAllRows();
	
	startRow := self.fixedRows + 1;
	if self.rows &lt; startRow then
		return;
	endif;
	
	create filterStringsArray transient;
	
	foreach colIndex in 1 to self.columns do
		cloneListTable := self.lstFilterValues.getControl(colIndex);
		if cloneListTable &lt;&gt; null and cloneListTable.rows &gt; 0 then
			filterStringsArray.clear();
			//get the valid filtering values for this column
			foreach rowIndex in 1 to cloneListTable.rows do
				if cloneListTable.accessCell( rowIndex, 1 ).text = TableCheckBox_Selected then
					filterText := cloneListTable.accessCell( rowIndex, 2 ).text;
					filterStringsArray.add( filterText );
				endif;
			endforeach;
			if not filterStringsArray.isEmpty and filterStringsArray.includes(self.AllValues) then
				//every thing is included, i.e. no filtering on this columns data
				self.tblFilterHeaders.accessCell(1,colIndex).foreColor := self.accessCell(1,1).foreColor;
				self.tblFilterHeaders.accessCell(1,colIndex).backColor := self.accessCell(1,1).backColor;
				continue;
			endif;
			//We are filtering, so change the colurs of the Header Cells
			self.tblFilterHeaders.accessCell(1,colIndex).foreColor := White;
			self.tblFilterHeaders.accessCell(1,colIndex).backColor := Black;
			
			if filterStringsArray.isEmpty then
				//nothing is included, i.e. nothing in the table should show
				foreach rowIndex in startRow to self.rows do
					self.accessRow(rowIndex).visible := false;
				endforeach;
				break;
			endif;
			//partial filtering, check each row. (first 60 chars after trimblanked only.)
			foreach rowIndex in startRow to self.rows do
				if not self.accessRow(rowIndex).visible then
					continue;
				endif;
				if not filterStringsArray.includes( self.accessCell( rowIndex, colIndex ).text.trimBlanks[1:MaxMatchLength] ) then
					self.accessRow(rowIndex).visible := false;
				endif;
			endforeach;
		endif;
	endforeach;
	
	self.doPostFilterTableProcessing();

epilog

	delete filterStringsArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="columnFilterGetValues" id="b170701e-4c4f-48bf-9394-311d1f26e1e5">
        <updating/>
        <source>columnFilterGetValues( _colIndex : Integer ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	cloneListTable : CM_FilterTableList;
	rowIndex : Integer;
	startIndex : Integer;
	strArray : StringArray;
	str : String;

begin

	cloneListTable := self.lstFilterValues.getControl( _colIndex ).CM_FilterTableList;
	
	cloneListTable.rows := 0;

	startIndex := self.fixedRows + 1;
	
	if startIndex &gt; self.rows then
		return;
	endif;
	
	create strArray transient;
	
	if startIndex &lt;= self.rows then
		foreach rowIndex in startIndex to self.rows do
			str := self.accessCell( rowIndex, _colIndex).text.trimBlanks[1:MaxMatchLength];
			if not strArray.includes( str ) then
				strArray.add( str );
			endif;
		endforeach;
	endif;
	
	cloneListTable.sortColumn[1] := 2;
	cloneListTable.sortAsc[1] := true;
	
	// we want "self.AllValues" in the table, but only for us, do not show it.
	rowIndex := cloneListTable.addItem( TableCheckBox_Selected  &amp; Tab &amp; self.AllValues );
	cloneListTable.accessRow(rowIndex).visible := false;
	
	foreach str in strArray do
		cloneListTable.addItem( TableCheckBox_NotSelected  &amp; Tab &amp; str );
	endforeach;
	cloneListTable.resort;
	
epilog

	delete strArray;

end;</source>
        <access>protected</access>
        <Parameter name="_colIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="columnFilterSetup" id="f4e9bb8c-7ef9-4945-9c8e-ca43bbf53e05">
        <updating/>
        <source>columnFilterSetup( _firstTime : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	columnCount : Integer;
	colIndex : Integer;
	startCol : Integer;
	cell : JadeTableCell;
	cloneListTable : CM_FilterTableList;

begin

	if _firstTime then
		self.initialise();  //creates the controls, only ever want to do this once per form.
	endif;

	//initial setup
	//add the cloned filter list tables to each column of the header table,
	//and populate them with the list of valid values from the datatable
	// set the selected value to ALL.

	startCol := 1;
	columnCount := self.columns;
	
	self.tblFilterHeaders.accessMode := Table.AccessMode_Cell;
	if startCol &lt;= columnCount then
		foreach colIndex in startCol to columnCount do
			cell := self.tblFilterHeaders.accessCell(1,colIndex);
			cloneListTable := self.lstFilterValues.getControl(colIndex).CM_FilterTableList;
			if cloneListTable = null then
				cloneListTable := self.lstFilterValues.loadControl(colIndex).CM_FilterTableList;
			endif;
			self.columnFilterGetValues( colIndex );	
		endforeach;
	endif;
	
	self.columnFilterApplyFilters();

epilog

end;</source>
        <Parameter name="_firstTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="columnFilterShowAllRows" id="3f85c889-0f31-4554-ac3a-2dcdedf015f7">
        <updating/>
        <source>columnFilterShowAllRows() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;

begin

	foreach rowIndex in 1 to self.rows do
		self.accessRow(rowIndex).visible := true;
	endforeach;
	
	self.doPostFilterTableProcessing();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="columns" id="c3d4d48f-a2d7-40d8-9ba5-5ed8bef54356">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>columns(set: Boolean; value: Integer io) updating, mapping, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod(set, value);
	
	if set then
		if self.tblFilterHeaders &lt;&gt; null then
			self.tblFilterHeaders.columns := value;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doClearFilters" id="f0c21caf-f7ba-4e7f-b932-a2a69fcb6c6c">
        <updating/>
        <source>doClearFilters( _rebuildFilterList : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	colIndex : Integer;
	cloneListTable : CM_FilterTableList;
	foreColour : Integer;
	backColour : Integer;

begin

	foreach colIndex in 1 to self.columns do
		cloneListTable := self.lstFilterValues.getControl( colIndex ).CM_FilterTableList;
		if cloneListTable &lt;&gt; null and cloneListTable.rows &gt;= 1 then
			cloneListTable.setCellText(1,1,TableCheckBox_Selected);
		endif;
	endforeach;
	
	foreColour := self.accessCell(1,1).foreColor;
	backColour := self.accessCell(1,1).backColor;
	
	foreach colIndex in 1 to self.tblFilterHeaders.columns do
		self.tblFilterHeaders.accessCell(1,colIndex).foreColor := foreColour;
		self.tblFilterHeaders.accessCell(1,colIndex).backColor := backColour;
	endforeach;
	
	self.frmUpdFilter.visible := false;
	self.myProxiedFilterToUpdate := null;
	
	if _rebuildFilterList then
		self.columnFilterSetup(false);
	else
		self.columnFilterShowAllRows();
	endif;

epilog

end;</source>
        <Parameter name="_rebuildFilterList" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPostFilterTableProcessing" id="27167e87-dd6b-486c-b254-c624e254c11c">
        <updating/>
        <source>doPostFilterTableProcessing() updating;
/*

Purpose:			

Parameters:			So that functionality can be implemented on a form subsequent to a filter being applied or cleared.

Return Value:		

Date		Who		Reason
14 January 2015	cnwndl1	Initial creation

*/

vars

begin

	if self.form &lt;&gt; null then
		self.form.doPostFilterTableProcessing( self );
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowFilter" id="d84dad19-6aaa-4111-a251-c1aec1ecf92c">
        <updating/>
        <source>doShowFilter( _show : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	colIndex : Integer;
	vOffSet : Integer;

begin

	self.tblFilterHeaders.visible := _show; 
	self.btnClearFilters.visible := _show;
	
	self.tblFilterHeaders.left := 0;
	self.tblFilterHeaders.top := 0;
	self.tblFilterHeaders.accessRow(1).height := self.accessRow(1).height;
	self.tblFilterHeaders.height := self.accessRow(1).height;
	self.tblFilterHeaders.width := self.width;
	vOffSet := self.parentBottomOffset;
	if not _show then
		self.top := 0;
		self.height := self.frmParentFilterTableFrame.height;
		self.parentBottomOffset := vOffSet;
		self.btnShowHide.caption := "v";
		self.btnShowHide.bubbleHelp := app.getErrorString(Enable_filtering);
		if not self.isShowingVertScrollBar() then
			self.btnShowHide.left := self.width - self.btnShowHide.width ;
		else
			self.btnShowHide.left := self.width - ( self.btnShowHide.width * 2 );
		endif;
		self.btnShowHide.top := 0;
		self.btnShowHide.zOrder(1);
		self.doClearFilters( false );
		self.frmUpdFilter.visible := false;
	else
		self.top := self.btnClearFilters.height + 2;
		self.height := self.frmParentFilterTableFrame.height - self.top;
		self.parentBottomOffset := vOffSet;
		self.btnShowHide.caption := "^";
		self.btnShowHide.bubbleHelp := app.getErrorString(Disable_filtering);
		self.btnShowHide.left := self.width - self.btnShowHide.width;
		self.btnShowHide.top := ( self.top - self.btnShowHide.height ) / 2;
		self.btnShowHide.zOrder(1);
		//epr TFS 40334 30/8/18
		if not self.showingFilters then
			self.columnFilterSetup(false);
		endif;
		self.alignFilterHeaderColumns();
		self.tblFilterHeaders.leftColumn := self.leftColumn;
	endif;
	
	self.showingFilters := _show;
	
epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowNext" id="e693cf09-03a6-4ea1-8070-1f655919f547">
        <source>doShowNext(_show : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2022	navkc1	Initial creation ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables

*/

