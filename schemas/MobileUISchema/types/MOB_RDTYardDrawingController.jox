    <JadeMethod name="drawTI" id="914fe8de-3549-40c6-8b11-ca75dc1f8e58">
        <source>drawTI( _x1, _y1, _gridWidth, _gridHeight : Real; _tiDraw : CMIF_RDTTIDrawElement) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
	gx1, gy1,
	gx2, gy2	: Real;
begin	
	if _tiDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			gx1 := _x1 - _gridWidth;
			gy1 := _y1 - _gridHeight;
			gx2 := _x1;
			gy2 := _y1;
		else
			gx1 := _x1 - _gridWidth;
			gy1 := _y1;
			gx2 := _x1;
			gy2 :=  _y1 + _gridHeight;
		endif;
	else
		if self.flipV then
			gx1 := _x1;
			gy1 := _y1 - _gridHeight;
			gx2 := _x1 + _gridWidth;
			gy2 :=  _y1;
		else
			gx1 := _x1;
			gy1 := _y1;
			gx2 := _x1 + _gridWidth;
			gy2 := _y1 + _gridHeight;
		endif;
	endif;

	_tiDraw.draw(gx1, gy1, gx2, gy2, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
	_tiDraw.gridPointsToElementPoints(gx1, gy1, gx2, gy2, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
	self.storeTIScreenPos(gx1, gy1, gx2, gy2, _tiDraw.myTI);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_tiDraw" type="CMIF_RDTTIDrawElement"/>
    </JadeMethod>
    <JadeMethod name="drawTIBox" id="4d643788-66b8-4e5c-bc4d-bb1cd1173655">
        <source>drawTIBox(_frame : Frame; _colour1 : Integer; _colour2 : Integer; _x1,_y1,_x2,_y2 : Integer) protected;
// ---------------------------------------------------------------------------
// Created:		31 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	//lFactor := self.scaleFactor.Integer;

	_frame.drawLine(_x1, _y1, _x2 + 1, _y1 ,  _colour1);
	_frame.drawLine(_x1, _y1, _x1, _y2,  _colour1);
	_frame.drawLine(_x2, _y1 , _x2, _y2 + 1,  _colour2);
	_frame.drawLine(_x1, _y2, _x2, _y2,  _colour2);

	if self.scaleFactor &gt; .75 then

		_frame.drawLine(_x1, _y1 + 1, _x2, _y1 + 1 ,  _colour1);
		_frame.drawLine(_x1 + 1, _y1, _x1 + 1, _y2,  _colour1);
		_frame.drawLine(_x2 - 1, _y1 + 1, _x2 - 1, _y2 + 1,  _colour2);
		_frame.drawLine(_x1 + 1, _y2 - 1, _x2, _y2 - 1,  _colour2);
	endif;

	if self.scaleFactor &gt; 1.5 then

		_frame.drawLine(_x1, _y1 + 2, _x2 - 1, _y1 + 2 ,  _colour1);
		_frame.drawLine(_x1 + 2, _y1, _x1 + 2, _y2 - 2,  _colour1);
		_frame.drawLine(_x2 - 2, _y1 + 2, _x2 - 2, _y2 + 1,  _colour2);
		_frame.drawLine(_x1 + 2, _y2 - 2, _x2, _y2 - 2,  _colour2);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTIOLD" id="0b2ec193-43ef-4663-bd3b-8e442aa988af">
        <source>drawTIOLD( _x1, _y1, _x2, _y2 : Real; _ti : CM_TrackedItem; _lc : CM_GridController; isBackend40 : Boolean) protected;

/*

Purpose:			

Parameters:			
	_x1, _y1, _x2, _y2 - Grid rectangle
Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	operator 		: CM_Operator;
	oldDrawWidth    : Integer;
	oldFontSize		: Real;
	highlightColour,
	tiColour,
	fontColour	 	: Integer;
	x1, y1,
	x2, y2 			: Real;
	frame 			: Frame;
	text			: String;
	picture			: Picture;
begin
	//if _lc &lt;&gt; _ti.myPrimaryActualLocation and not isBackend40 then
	//	return;
	//endif;
	
	frame := self.myTIFrame;

	x1 := _x1;
	y1 := _y1;
	x2 := _x2;
	y2 := _y2;
	self.gridPointsToTIPoints(x1, y1, x2, y2, _ti);
		
	operator := app.myRoot.allOperators[_ti.operatorCode];
	if operator &lt;&gt; null then
		tiColour := operator.colour;
		fontColour := tiColour.getInverseColour();
	else
		tiColour := White;
		fontColour := Black;
	endif;
	
	if self.isFancyGFX then
		fontColour := Black;
	endif;
	
	highlightColour := tiColour;
	
	oldFontSize := frame.drawFontSize;
	oldDrawWidth := frame.drawWidth;

	frame.drawFontBold := true; 
	if self.scaleFactor &lt;= 3 then
		frame.drawFontSize := 2 * self.scaleFactor;
	else
		frame.drawFontSize := 3 * self.scaleFactor;	
	endif;
	
	frame.drawFillColor := tiColour;
	if self.isFancyGFX then
		self.drawFancyTI(x1, y1, x2, y2, _ti, frame);
	else
		frame.drawFilledRectangle(x1, y1, x2, y2, highlightColour);
	endif;
	
	//picture := self.myDrawingFrame.parent.MOB_RDTYardGraphicForm.picGreenV;
	//frame.drawPictureIn(picture.picture, x1, y1, x2, y2);
	
	// 3D look...
	self.drawTIBox(frame, Grey, Black, x1.Integer, y1.Integer, x2.Integer-1, y2.Integer-1);
	
	if self.scaleFactor &gt;= 1 then
		//text := _ti.id;
		text := self.getDisplayTextForTI(_ti);
		//text := text &amp; Cr &amp; Cr &amp; "H:" &amp; _lc.getActualStackPositionOfTI(_ti).String;
		
		text := self.convertStringForWidth((x2-x1-8).Integer, frame, text);
		
		frame.drawTextIn(text, x1+ 4, y1 + 8, x2, y2, fontColour);
		
	endif;
	
	frame.drawFontSize := oldFontSize;
	frame.drawWidth := oldDrawWidth;
	frame.drawFontBold := false; 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="isBackend40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawTrack" id="7789896a-c737-4dba-aac0-cc0234ebc916">
        <source>drawTrack( _x1, _y1, _gridWidth, _gridHeight : Real; _trackDraw : CMIF_RDTTrackDrawElement) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
begin	
	if _trackDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			_trackDraw.draw(_x1 - _gridWidth, _y1 - _gridHeight, _x1, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		else
			_trackDraw.draw(_x1 - _gridWidth, _y1, _x1, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		endif;
	else
		if self.flipV then
			_trackDraw.draw(_x1, _y1 - _gridHeight, _x1 + _gridWidth, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);						
		else
			_trackDraw.draw(_x1, _y1, _x1 + _gridWidth, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_trackDraw" type="CMIF_RDTTrackDrawElement"/>
    </JadeMethod>
    <JadeMethod name="drawWagon" id="050ae57a-e85f-49d5-90c6-2cc94f2cb4ff">
        <source>drawWagon( _x1, _y1, _gridWidth, _gridHeight : Real; _wagonDraw : CMIF_RDTWagonPartDrawElement) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
begin	
	if _wagonDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			_wagonDraw.draw(_x1 - _gridWidth, _y1 - _gridHeight, _x1, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		else
			_wagonDraw.draw(_x1 - _gridWidth, _y1, _x1, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		endif;
	else
		if self.flipV then
			_wagonDraw.draw(_x1, _y1 - _gridHeight, _x1 + _gridWidth, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);						
		else
			_wagonDraw.draw(_x1, _y1, _x1 + _gridWidth, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_wagonDraw" type="CMIF_RDTWagonPartDrawElement"/>
    </JadeMethod>
