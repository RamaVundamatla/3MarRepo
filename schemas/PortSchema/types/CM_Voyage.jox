    <JadeMethod name="getNumTugsUsedDeparture" id="b18d1212-48fc-4b3e-b6a6-ef1461b876c0">
        <source>getNumTugsUsedDeparture() : Integer;

/*

Purpose:			Get the number of tugs assigned to the departure movement to a real Berth


Return Value:		Number of tugs


Date		Who		Reason
18 Apr 2008	cnwkpd1	PAR #16521 - Short Term Movements report

*/

vars
	movement		: HMS_VoyageMovement;
	
begin
	if self.myHMSVoyageData = null then
		return 0;
	endif;

	movement := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture);
	if movement = null then
		return 0;
	endif;
	
	return movement.getNumTugsUsed();
	
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumTugsUsedRealBerth" id="6f21cf5c-9ab7-4eb4-bfd7-e44abaaa0dc1">
