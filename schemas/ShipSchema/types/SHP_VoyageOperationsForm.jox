        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstJobs_dragOver(listbox: ListBox input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	listbox.CM_QueueListBox.doDragOverSelect(x,y, self.origYPos);

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
