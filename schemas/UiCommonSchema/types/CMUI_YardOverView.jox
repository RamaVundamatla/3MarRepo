    <JadeMethod name="doMnuHideLegendClick" id="3bf394bb-ac81-4ff3-a490-545ec98dd3b0">
        <updating/>
        <source>doMnuHideLegendClick() updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.mnuHideLegend.caption = self.Menu_Hide_Legend then
		self.mnuHideLegend.caption := self.Menu_Show_Legend;
		self.xmlHideLegend := true;
		self.sptMain.hideLeftControl(true);
	else
		self.mnuHideLegend.caption := self.Menu_Hide_Legend;
		self.sptMain.showLeftControl(10, true);
		self.xmlHideLegend := false;
		self.resize;
	endif;

end;</source>
