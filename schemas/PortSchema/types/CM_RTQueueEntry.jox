    <JadeMethod name="getOverstowingTis" id="7857e5fd-43df-49e8-8c6d-7247b4d3659c">
        <source>getOverstowingTis(_tiSet : CM_TISet input);
// -------------------------------------------
// Created 23 March 2004 by cnwdvb1
// -------------------------------------------
vars

	futureMove : CM_FutureMoveQueued;

begin

	_tiSet.clear();
	foreach futureMove in self.allQueuedFutureMoves do
		if futureMove.moveType = TI_FutureMoveOverstow then
			_tiSet.add(futureMove.myTrackedItem);
		endif;
	endforeach;

	


end;</source>
