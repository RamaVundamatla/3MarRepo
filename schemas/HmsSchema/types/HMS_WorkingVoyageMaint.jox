        <source>lbxCargoForDis_dblClick(listbox: ListBox input) updating;

vars
	selectedObject:	Object;
 	cargo:			CM_Commodity;
 	posn:			Integer;
begin
	enableDisableApplyBtn(true);
	if lbxCargoForDis.listIndex&gt;0 then
		selectedObject:=lbxCargoForDis.itemObject[lbxCargoForDis.listIndex];
