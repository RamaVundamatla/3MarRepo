    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ff4264c9-2728-493b-8501-3fc54f436d1b">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 22 July 2004 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxy,	
	companion	: CM_InterTerminalTransferArea;
	completedOK		: Boolean;
	
begin
	
	pxy :=  inheritMethod();
	// Create place holder transient as we don't actually allow update of other terminal.
	create companion transient;
	pxy.myOtherTerminalTransferArea := companion;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="releaseAndReceivedTIs" id="02c7b665-733e-4ff5-8153-b7bc70957596">
        <source>releaseAndReceivedTIs(_tiSet : CM_TISet input; _passport : CM_Passport input);
// -------------------------------------------
// Created 23 July 2004 by cnwdvb1
// -------------------------------------------
vars

	ti,
	cloneTi	: CM_TrackedItem;

begin

	foreach ti in _tiSet do
		// This code is copied from cargo yard transfer release.
		ti.undoMove(PLANNING_MODE, _passport);	//undo the planned move
		//ti.moveToLocation(null, null, null, null, REAL_MODE, false, true, false, false, false,   false, null,null,_passport);		// TFS 2651
		ti.moveToLocation(null, null, null, null, REAL_MODE, false, true, false, false, false,   false, null,null,null,null,null,_passport);	// TFS 2651
		self.causeEvent(TIEvent_Terminal_Release, false, null);
		cloneTi := ti.getCloneForInterTerminalMove2(self.myOtherTerminalTransferArea.myTerminal, false);
		//cloneTi.moveToLocation(self.myOtherTerminalTransferArea.myLocationsController, null, null, null, REAL_MODE, false, true, false, false, false,  false,null,null, _passport);		// TFS 2651
		cloneTi.moveToLocation(self.myOtherTerminalTransferArea.myLocationsController, null, null, null, REAL_MODE, false, true, false, false, false,  false,null,null,null,null,null, _passport);	// TFS 2651
	endforeach;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="fd601c12-e28b-4f74-8de1-bc7c753f15a0">
        <updating/>
        <source>setForCreate(_proxy :CM_InterTerminalTransferArea input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 22 July 2004 by cnwdvb1
// -------------------------------------------
vars

	companion : CM_InterTerminalTransferArea;

begin
	inheritMethod(_proxy, _passport);
	
	if self.myOtherTerminalTransferArea = null then
		create companion persistent;
		self.myOtherTerminalTransferArea := companion;
		companion.setForCreate(_proxy.myOtherTerminalTransferArea, _passport);
	endif;
end;</source>
        <Parameter name="_proxy" type="CM_InterTerminalTransferArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setInterTerminalProxy" id="b776d14f-af46-4158-a2c7-5adf9be42a31">
        <updating/>
        <source>setInterTerminalProxy(	_iD,
		 				_comment				: String; 
		 				_type					: Integer;
		 				_height					: Integer;
						_rows					: Integer;	//29 Aug 2011	NDL	Par 28076
						_columns				: Integer;	//29 Aug 2011	NDL	Par 28076
						_enforceMaxCap			: Boolean;	//29 Aug 2011	NDL	Par 28076
		 				_typeString 			: String;
		 				_max 					: Integer;
		 				_rel					: Boolean;
		 				_controllers			: CM_LCArray;
		 				_term					: CM_Terminal;
						_autoRestrictionEnabled,
						_autoPlanEnabled,
		 				_stockControlled, 
						_isOverlapped,
						_hideFromOverView		: Boolean;
						_transferTerminal		: CM_Terminal;
						_allInterchangeAreas	:CM_InterchangeAreaArray;
					_defaultInterchangeArea: CM_InterchangeArea) updating;
// -------------------------------------------
// Created 22 July 2004 by cnwdvb1
// -------------------------------------------
// 27/05/2010	cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array 
vars

	area	: CM_InterTerminalTransferArea;

begin

	if self.myOtherTerminalTransferArea = null then
		area := self.buildCompanionArea(_iD, _comment, _type, _height , _rows, _columns, _enforceMaxCap, _typeString, _max, _rel, _controllers, _term, _autoRestrictionEnabled,
					_autoPlanEnabled, _stockControlled, _isOverlapped, _hideFromOverView, _transferTerminal, _allInterchangeAreas,_defaultInterchangeArea);
					
		
		self.myOtherTerminalTransferArea := area;
	endif;
	
	self.setProxy(_iD[1:13], _comment, _type, _height , _rows, _columns, _enforceMaxCap, _typeString, _max, _rel, _controllers, _term, _autoRestrictionEnabled,
					_autoPlanEnabled, _stockControlled, _isOverlapped, _hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea, false );


end;</source>
        <Parameter name="_iD" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_enforceMaxCap" type="Boolean"/>
        <Parameter name="_typeString" type="String"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_rel" type="Boolean"/>
        <Parameter name="_controllers" type="CM_LCArray"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_autoRestrictionEnabled" type="Boolean"/>
        <Parameter name="_autoPlanEnabled" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_isOverlapped" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_transferTerminal" type="CM_Terminal"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b3dc2591-ea57-4f13-81cb-c4506f42d4ce">
        <source>validateForCreate();
// -------------------------------------------
// Created 22 July 2004 by cnwdvb1
// -------------------------------------------
vars

	area	: CM_InterTerminalTransferArea;
	ta		: CM_TerminalAreaType;
begin
	inheritMethod();
	
	if self.myOtherTerminalTransferArea = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Other Terminal Area null', null, null);
	endif;
	
	if self.myTerminal = self.myOtherTerminalTransferArea.myTerminal then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Other Terminal Area null', null, null);
	endif;
	
	ta := self.myType;
	if ta = null then
		app.raiseCMException1(ERR_INVALID_TA_ID, self.typeString, null, null);
	endif;
	area := ta.findTransferAreaForTerminal(self.myOtherTerminalTransferArea.myTerminal);
	if area &lt;&gt; null then
		app.raiseCMException2(ErrTransferTerminalAreaExists, self.myTerminal.code, self.myOtherTerminalTransferArea.myTerminal.code, null, null);
	endif;


end;</source>
    </JadeMethod>
</Class>
