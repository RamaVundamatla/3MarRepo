    <JadeMethod name="sendCreateDeleteEmail" id="03d753e2-ed17-4075-a1b2-b90bf3f5ead2">
        <source>sendCreateDeleteEmail( _action : String; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			Note the expiry email is coded directly in     BGP_RestrictionExpiryRequest::processRestrictionExpiry

Return Value:		

Date		Who		Reason
08 July 2015	cnwndl1	Initial creation	Par 36588
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	heading : String;
	sender : String;
	emailEntity : CM_EmailEntity;
	email : String;
	body : String;
	invalidObj : Boolean;
	now : TimeStamp;
	
begin

	if self.allNotifyEmailEntities.isEmpty then
		return;
	endif;

	heading := app.getErrorString(CM_Labour_Restriction) &amp; ' ' &amp; _action &amp; ': ' &amp; self.id;
	sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;	
	now := app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	on Exception do app.handleDeletedObject(exception, emailEntity, invalidObj);

	foreach emailEntity in self.allNotifyEmailEntities do
	
		invalidObj := false;
		email := emailEntity.getEmailAddress();
				
		if email &lt;&gt; null and not invalidObj then
		
			body := app.getErrorString5(Labour_restriction_add_del, self.id, _action, self.myOrganisation.name, now.asStringJMT, self.userCode);
				
			app.myUtilityCA.utlCreateEmailSendRequest(	true,
														heading,
														email,
														sender,
														null,
														null,
														heading,
														body,
														null,
														null,
														null,
														null,
														EmailSource_System,
														null,
														_passport
														);
		
			if app.myPassport.hasErrors then
				app.remoteErrorWarningToAlert('Could not send Labour Restriction email for ' &amp; _action &amp; ' of ' &amp; self.id, 
												null,  app.myPassport.allErrors, null, false, true);
				break;
			endif;
			
		endif;
		
	endforeach;

epilog

end;</source>
        <Parameter name="_action" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4fd3e2f8-40a5-4829-a45e-fd54787a8560">
        <updating/>
        <source>setForCreate(pProxyRestriction : CM_LabourRestriction) updating;
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	newTime 		: Boolean;
	tmpExpiryTime 	: TimeStamp;
begin

	pProxyRestriction.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.colour 		:= pProxyRestriction.colour;
	self.userCode		:= pProxyRestriction.userCode;
	self.comment		:= pProxyRestriction.comment.trimBlanks;

	self.id			:= pProxyRestriction.id;
	
	if self.myMasterLabourRestriction = null then	//23 Apr 2014	NDL	Par 33995
		self.myTerminalArea := pProxyRestriction.myTerminalArea;
	endif;
	
	self.myReason := pProxyRestriction.myReason;
	self.myOrganisation := pProxyRestriction.myOrganisation;
	
	self.ignoreLights	:=	pProxyRestriction.ignoreLights;		// cnwdad1 03/06/2010 - CCMS 1947.
	self.durationDays := pProxyRestriction.durationDays;
	self.durationHours := pProxyRestriction.durationHours;
	
	// as on days/hous to current time to get expiry time. 
	if pProxyRestriction.durationHours.isValid and pProxyRestriction.durationHours &lt;&gt; NULL_TIME then 
		newTime := true;
//		tmpExpiryTime := app.actualTimeServer.cnEcAddHours(pProxyRestriction.durationHours.hour);
		
		tmpExpiryTime := tmpExpiryTime + pProxyRestriction.durationHours;
	endif;
	
	if pProxyRestriction.durationDays &lt;&gt; 0 then 
		if newTime = true then
			tmpExpiryTime := tmpExpiryTime.cnEcAddDays(pProxyRestriction.durationDays);
		else
			newTime := true;
			tmpExpiryTime := app.actualTimeServer.cnEcAddDays(pProxyRestriction.durationDays);
		endif;
	endif;
	
	if newTime = true then 
		self.expiryDateTime := tmpExpiryTime;
	endif;

	self.allNotifyEmailEntities.clear();
	pProxyRestriction.allNotifyEmailEntities.copy(self.allNotifyEmailEntities);
	
	self.allLocationControllers.clear();
	if self.myMasterLabourRestriction = null then	//23 Apr 2014	NDL	Par 33995
		pProxyRestriction.allLocationControllers.copy(self.allLocationControllers);
	endif;
	
	if self.myMasterLabourRestriction = null then
		self.createChildLabourRestrictions( pProxyRestriction );	//23 Apr 2014	NDL	Par 33995 - picks up any locations related by 
											// CM_LabourWorkArea (s)
	endif;
end;</source>
        <Parameter name="pProxyRestriction" type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="00718d92-6a8b-4be0-8a46-55b3affcbbb1">
        <updating/>
        <source>setForUpdate(pProxyRestriction : CM_LabourRestriction) updating;
// ---------------------------------------------------------------------------
// Created		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		populate the REAL object from the transient proxy
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	intPrxyTime,
	intCurrentTime,
	intDiffTime  	: Time;
	intPrxy,
	intCurrent,
	intDiff 		: Integer;
	tmpExpiryTime 	: TimeStamp;
begin

	inheritMethod(pProxyRestriction);

	if self.id &lt;&gt; pProxyRestriction.id then 
		self.id		:= pProxyRestriction.id;
	endif;

	self.updateExpiryDTFromProxy(pProxyRestriction);	
	
	self.ignoreLights	:=	pProxyRestriction.ignoreLights;		// cnwdad1 03/06/2010 - CCMS 1947.
	self.durationDays := pProxyRestriction.durationDays;
	self.durationHours := pProxyRestriction.durationHours;
	
	self.myReason := pProxyRestriction.myReason;
	self.myOrganisation := pProxyRestriction.myOrganisation;
	
	self.allNotifyEmailEntities.clear();
	pProxyRestriction.allNotifyEmailEntities.copy(self.allNotifyEmailEntities);
	
	self.allLocationControllers.clear();
	pProxyRestriction.allLocationControllers.copy(self.allLocationControllers);
	
	self.updateChildLabourRestrictions(pProxyRestriction);	//23 Apr 2014	NDL	par 33995

end;</source>
        <Parameter name="pProxyRestriction" type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="122fbdfe-1555-431b-9dd0-e6eeb62417cc">
        <updating/>
        <source>setProxy(	_colour : Integer; 
			_userCode,
			_comment : String; 
			_durationHrs : Time;
			_durationDays : Integer;
			_reason : CM_LabourRestrictionReasonCode;
			_allLocations : CM_LCArray;
			_id : String;
			_ignoreLights : Boolean;
			_organisation : CM_Organisation;
			_email : CM_EmailEntity;
			_emails : CM_EmailAddressByAddressDict;
			_theTerminal : CM_TerminalArea) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	email : CM_EmailAddress2;
	invalid : Boolean;
	edition : Integer;
begin
	self.setForProxyRestriction(_colour,_userCode, _comment);
	self.id				:=	_id[1:35];
	self.ignoreLights	:=	_ignoreLights;
	self.myTerminalArea	:=	_theTerminal;
	self.durationDays	:=	_durationDays;
	self.durationHours	:=	_durationHrs;
	self.myReason		:=	_reason;
	self.myOrganisation	:=	_organisation;
	
	self.allNotifyEmailEntities.clear();
	if _emails &lt;&gt; null and not _emails.isEmpty then
		on Exception do app.handleDeletedObject(exception,email,invalid);
		foreach email in _emails do
			invalid := false;
			edition := email.edition;
			if invalid then
				continue;
			endif;
			self.allNotifyEmailEntities.add(email);
		endforeach;
		on Exception do null;
	elseif _email &lt;&gt; null then 
		self.allNotifyEmailEntities.add(_email);
	endif;
	
	self.allLocationControllers.clear();
	_allLocations.copy(self.allLocationControllers);
end;</source>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_durationHrs" type="Time"/>
        <Parameter name="_durationDays" type="Integer"/>
        <Parameter name="_reason" type="CM_LabourRestrictionReasonCode"/>
        <Parameter name="_allLocations" type="CM_LCArray"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_ignoreLights" type="Boolean"/>
        <Parameter name="_organisation" type="CM_Organisation"/>
        <Parameter name="_email" type="CM_EmailEntity"/>
        <Parameter name="_emails" type="CM_EmailAddressByAddressDict"/>
        <Parameter name="_theTerminal" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setQueueTasksStatus" id="deff1010-6034-4293-9d8f-2692d9c51988">
        <source>setQueueTasksStatus( _queueEntrySet_before, _queueEntrySet_after : CM_RTQueueEntrySet );
// --------------------------------------------------------------------------------------------------------
// Created:		24 August 2007 By cnwvu1
//
// Purpose:		changing tasks' status:
//				a) for unactioned tasks setting the status to "held" when cargo is under labour restrictions
//				b) for held tasks setting the status as "unactioned" when labour restrictions are removed
//
// Parameters:	_queueEntrySet_before	- set of entries before labour restricion updating
// 				_queueEntrySet_after	- set of entries after updating and before labour restricion saving
// ---------------------------------------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------------------------
// 21/11/2012	cnwdap1		PAR #30762 CCMS QNS 2233 Don't set task status to Unactioned if it still has a reason to be Held
// 02/09/2025	jlizm1		MTN 35800 RT entries not set to system held if follow a director task
vars
	rtEntry				: CM_RTQueueEntry;
	task				: CM_RTQueueTask;
	thereAreCargoCovered: Boolean;
	remainHeld			: Boolean;				// PAR #30762
	reason				: String;				// PAR #30762
begin
	
	thereAreCargoCovered := false;	
	if _queueEntrySet_before = null and _queueEntrySet_after = null then	//there is no tasks under labour restriction
		return;
	endif;

	// reset status of all tasks under the area covered by the labour restriction.
	// there are 3 labour restrictions events:
	// CREATE - queueEntrySet_before = null ( _labourRestriction_before = null )
	// UPDATE - both queueEntrySet_before and queueEntrySet_after should be compared
	// DELETE - queueEntrySet_after = null ( _labourRestriction = null )
	
	//---------------------------------------------------------------------------------
	//		labour restriction CREATE - all unactioned tasks should be set as held
	//---------------------------------------------------------------------------------
	if _queueEntrySet_before = null and _queueEntrySet_after &lt;&gt; null then
		foreach rtEntry in _queueEntrySet_after do
			task := rtEntry.allTasks.first;
			if task.status = TASK_UNACTIONED then
				task.setStatus( TASK_SYS_HELD );
				thereAreCargoCovered := true;
				
			elseif task.status = TASK_COMPLETE and task.taskType = TASK_DIRECTOR then
				// Machine tasks can start from 2nd task for director tasks
				task := task.getNextMachineTask();
				if task &lt;&gt; null and task.status = TASK_UNACTIONED then
					task.setStatus( TASK_SYS_HELD );
					thereAreCargoCovered := true;
				endif;
			endif;
		endforeach;
	
	//---------------------------------------------------------------------------------
	//		labour restriction CREATE - tasks 'in progress' should cause :
	//		- Warning for the user creating the labour restriction
	//		- Notification to each affected machine with details of the labour restriction
	//		- new Alert for each queue task
	// cnwrd1 ccms JMT 1750 5.1.09
	//---------------------------------------------------------------------------------
	
		foreach rtEntry in _queueEntrySet_after do		
			foreach task in rtEntry.allTasks do 
				//epr TFS 4620 15/6/17
				task.sendLabourRestrictionWarning(self);
			endforeach;
		endforeach;
	
	//----------------------------------------------------------------------------------
	//		labour restriction DELETE - all held tasks should be set as unactioned
	//----------------------------------------------------------------------------------
	elseif _queueEntrySet_before &lt;&gt; null and _queueEntrySet_after = null then
		foreach rtEntry in _queueEntrySet_before do
			task := rtEntry.allTasks.first;
			if task.status = TASK_COMPLETE and task.taskType = TASK_DIRECTOR then
				// Machine tasks can start from 2nd task for director tasks
				task := task.getNextMachineTask();
				if task = null then
					continue;
				endif;
			endif;
			
	//		remainHeld := false;												// PAR #30762
	//		if task.ti &lt;&gt; null then												// PAR #30762
	//			remainHeld := task.ti.isHeldRTQueueStatus(true, self, reason);	// PAR #30762
	//		endif;																// PAR #30762
	
			remainHeld := task.requiresSystemHold(true, self, reason);	//22 Apr 2015	NDL	Par 36014
			
			if task.status = TASK_SYS_HELD 
			and not task.hasOtherLabourRestrictions(self) 			//Par15891
			and not remainHeld then												// PAR #30762
				task.setStatus(TASK_UNACTIONED);
			endif;
		endforeach;

	//------------------------------------------------------
	//				labour restriction UPDATE
	//------------------------------------------------------
	// There are 3 possibilities:
	// a) entries have been disappeared (i.e. entries are members of _queueEntrySet_before but not of queueEntrySet). All held tasks should be set as unactioned;
	// b) entries are members of queueEntrySet - all unactioned tasks should be held.
	// c) entries are new (i.e. exist in _queueEntrySet_after but not in _queueEntrySet_before - if task in progress raise alert.
	// d) do nothing when entries belong to both sets
	else
		// check for disappeared entries
		foreach rtEntry in _queueEntrySet_before do
			if not _queueEntrySet_after.includes( rtEntry ) then
				task := rtEntry.allTasks.first;
				if task.status = TASK_COMPLETE and task.taskType = TASK_DIRECTOR then
					// Machine tasks can start from 2nd task for director tasks
					task := task.getNextMachineTask();
					if task = null then
						continue;
					endif;
				endif;
				
				remainHeld := task.requiresSystemHold(true, null, reason);	//22 Apr 2015	NDL	Par 36014
				
				if task.status = TASK_SYS_HELD 
				and not task.hasOtherLabourRestrictions( self ) 		//Par15891
				and not remainHeld then												// PAR #30762
					task.setStatus( TASK_UNACTIONED );
				endif;
			endif;
		endforeach;
		// all tasks covered by the labour restrictions should be unactioned
		foreach rtEntry in _queueEntrySet_after do
			if not _queueEntrySet_before.includes(rtEntry) then
				task := rtEntry.allTasks.first;
				if task.status = TASK_COMPLETE and task.taskType = TASK_DIRECTOR then
					// Machine tasks can start from 2nd task for director tasks
					task := task.getNextMachineTask();
					if task = null then
						continue;
					endif;
				endif;
				
				if task.status = TASK_UNACTIONED then
					task.setStatus( TASK_SYS_HELD );
					thereAreCargoCovered := true;
				endif;
			endif;
		endforeach;
	
	//check for in progress task in new tasks (in new locations) and raise alert if needed.
	// par 17663 cnwrd1 13.3.09
		foreach rtEntry in _queueEntrySet_after do
			if not _queueEntrySet_before.includes( rtEntry ) then						
				foreach task in rtEntry.allTasks do 
					//epr TFS 4620 15/6/17 refactored to method
					task.sendLabourRestrictionWarning(self);
				endforeach;				
			endif;
		endforeach;	
	endif;

	if thereAreCargoCovered then
		app.raiseCMWarning(WARN_CargoUnderLabourRestrict, "", null, self);
	endif;
	
epilog

	
end;
</source>
        <Parameter name="_queueEntrySet_before" type="CM_RTQueueEntrySet"/>
        <Parameter name="_queueEntrySet_after" type="CM_RTQueueEntrySet"/>
    </JadeMethod>
    <JadeMethod name="updateChildLabourRestrictions" id="e4df9303-3288-4aef-9b1a-4566784fc2f8">
        <source>updateChildLabourRestrictions( pProxyRestriction : CM_LabourRestriction ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	child : CM_LabourRestriction;

	allWorkAreas : CM_LabourWorkAreaDict;
	lc : CM_LocationsController;
	workArea : CM_LabourWorkArea;
	ta : CM_TerminalArea;
	go : CM_GridObject;
	lcArray : ObjectArray;
	obj : Object;
	taToProcess : CM_TerminalArea;
	
	tasToProcessSet : CM_TerminalAreaSet;
	relatedRestriction : CM_LabourRestriction;
	arrayToAdjust : CM_LCArray;

begin

	//set the base attriobutes first.
	foreach child in self.allChildLabourRestrictions do
	
		if child.id &lt;&gt; pProxyRestriction.id then 
			child.id		:= pProxyRestriction.id;
		endif;
	
		child.updateExpiryDTFromProxy(pProxyRestriction);	
		
		child.ignoreLights	:=	pProxyRestriction.ignoreLights;
		child.durationDays := pProxyRestriction.durationDays;
		child.durationHours := pProxyRestriction.durationHours;
		
		child.myReason := pProxyRestriction.myReason;
		child.myOrganisation := pProxyRestriction.myOrganisation;
		
		child.allNotifyEmailEntities.clear();
		pProxyRestriction.allNotifyEmailEntities.copy(child.allNotifyEmailEntities);
		
		child.allLocationControllers.clear();
		
	endforeach;

	//Find any related labour work areas ( areas logically related to one or more of the selected locations
	// that should have the same restriction applied to them)
	create allWorkAreas transient;
	foreach lc in self.allLocationControllers do
		workArea := lc.getMyLabourWorkArea();
		if workArea &lt;&gt; null and not workArea.notAvailableForEntry then
			allWorkAreas.addNoDuplicates( workArea, false );
		endif;
	endforeach;
	
	//none found nothing to do.
	if allWorkAreas.isEmpty then
		return;
	endif;
	
	//build a collection of ta s that we need to consider.
	// if the related restriction areas are in different terminal areas, we need separate labour restrictions
	create tasToProcessSet transient;
	tasToProcessSet.add(self.myTerminalArea);
	
	foreach workArea in allWorkAreas do
		foreach ta in workArea.allTerminalAreas do
			tasToProcessSet.addNoDuplicates(ta,false);
		endforeach;
		foreach go in workArea.allGridObjects do
			ta := go.getGridArea;
			if ta &lt;&gt; null then
				tasToProcessSet.addNoDuplicates(ta,false);
			endif;
		endforeach;
		foreach lc in workArea.allLocationsControllers do
			ta := lc.myTerminalArea;
			if ta &lt;&gt; null then
				tasToProcessSet.addNoDuplicates(ta,false);
			endif;
		endforeach;
	endforeach;
	
	//iterate thru the terminal areas, create new labour restrictions if required and add the 'related' lcs for
	create lcArray transient;
	foreach taToProcess in tasToProcessSet do
	
		// create the new restriction to populated, or use this one to add to...
		if taToProcess = self.myTerminalArea then
			arrayToAdjust := self.allLocationControllers;
		else
			arrayToAdjust := null;
			foreach child in self.allChildLabourRestrictions do
				if child.myTerminalArea = taToProcess then
					arrayToAdjust := child.allLocationControllers; 
					break;
				endif;
			endforeach;
		
			if arrayToAdjust = null then
				create relatedRestriction persistent;
				relatedRestriction.myMasterLabourRestriction := self;	// set the master first
				relatedRestriction.setForCreate(pProxyRestriction);	// copy the base set up form the original proxy
				relatedRestriction.myTerminalArea := taToProcess;	// set the additional terminal areas
				arrayToAdjust := relatedRestriction.allLocationControllers; 
			endif;
			
		endif;
		
		// Find the lc s related to this ta and populate the restriction.
		foreach workArea in allWorkAreas do
			foreach ta in workArea.allTerminalAreas where ta = taToProcess do
				lcArray.clear();
				ta.getAllLocationsControllers(lcArray);
				foreach obj in lcArray do
					lc := obj.CM_LocationsController;
					arrayToAdjust.addExclusive(lc);
				endforeach;
			endforeach;
			foreach go in workArea.allGridObjects where go.getGridArea = taToProcess do
				lcArray.clear();
				go.getAllLocationsControllers(lcArray, false);
				foreach obj in lcArray do
					lc := obj.CM_LocationsController;
					arrayToAdjust.addExclusive(lc);
				endforeach;
			endforeach;
			foreach lc in workArea.allLocationsControllers where lc.myTerminalArea = taToProcess do
				arrayToAdjust.addExclusive(lc);
			endforeach;
		endforeach;
				
	endforeach;


epilog

	delete lcArray;
	delete tasToProcessSet;
	delete allWorkAreas;

end;</source>
        <access>protected</access>
        <Parameter name="pProxyRestriction" type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="updateExpiryDTFromProxy" id="aee9ef17-c9d4-44b1-a233-c0a5cafce8a3">
        <updating/>
        <source>updateExpiryDTFromProxy(pProxyRestriction : CM_LabourRestriction) updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 March 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	prxyTime,
	currentTime  	: Time;
	intPrxy,
	intDiffTime,
	intCurrent,
	intDiff 		: Integer;
	tmpExpiryTime 	: TimeStamp;
begin

	if self.expiryDateTime.isValid then 
		tmpExpiryTime := self.expiryDateTime;
	else
		tmpExpiryTime := null; // set as null as being timestmp will have current time. want null so if durations 
								// are updated to both 0 then expirytime will be set to 0 (indefinite). 
	endif;
		
	intPrxy := pProxyRestriction.durationDays; 
	intCurrent := self.durationDays;
	intDiff := intPrxy - intCurrent;
	
	if intDiff &lt;&gt; 0 then 
		// if there a difference then the days suration must have changed
		if not tmpExpiryTime.isValid then 
			// if no time set then must have been an indefinte Labour Restriction that is being changed. So use todays date. 
			tmpExpiryTime := app.actualTimeServer; 
		endif;
		tmpExpiryTime := tmpExpiryTime.cnEcAddDays(intDiff);
	endif;
	
	prxyTime := pProxyRestriction.durationHours; 
	if not prxyTime.isValid then 
	prxyTime := NULL_TIME;
	endif;
	currentTime := self.durationHours;
	if currentTime.isValid then 
		intDiffTime := currentTime.cnMinutesDifference(prxyTime);
	else 
		//if current time duration not set then just use the amount of minutes from proxy
		intDiffTime := prxyTime.cnToMinutes;
	endif; 
	
	
	if intDiffTime &lt;&gt; 0 then 
		if not tmpExpiryTime.isValid then 
			tmpExpiryTime := app.actualTimeServer; 
		endif;
		// if no time set then must have been an indefinte Labour Restriction that is being changed. So use todays date. 
		tmpExpiryTime := tmpExpiryTime.changeByXXMinutes(intDiffTime);
	endif;
	
	if intPrxy = 0 and prxyTime = NULL_TIME then 
		self.expiryDateTime := null;
	else
		self.expiryDateTime := tmpExpiryTime;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pProxyRestriction" type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="validate" id="362756c5-c979-448b-85a6-3fed8a990c8f">
        <source>validate();
// -------------------------------------------
// Created 03 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
	if self.id.trimBlanks = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "ID", "Please enter an ID", null, null);
	endif;
	// PAR 32271
	if self.myOrganisation = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "Organisation", "Please select an Organisation", null, null);
	endif;
	
	self.validateTerminalArea(self.myTerminalArea);
	self.validateLocationControllers(self.myTerminalArea, self.allLocationControllers);


end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b82ba2ce-6e47-4c19-bf9f-c2ce7cad0354">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		To validate that the PROXY TRANSIENT is OK before we populate the real thing
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/12/2014   cnwdb2		PAR #35364
// ---------------------------------------------------------------------------

vars

begin

	inheritMethod();
	
	if self.myTerminalArea.allRestrictionsLabour.includesKey(self.id) then
//		app.raiseCMException3(ERR_DUPLICATE_KEY,"Labour Restriction", self.id, null,null, null);
		app.raiseCMException1(Already_exists_labRestrict,self.id,null, null); // cnwdb2 PAR 35364
	endif;
end;</source>
