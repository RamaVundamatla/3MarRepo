    <JadeMethod name="getReserveDetailFromCode" id="6ce55721-7acd-4e06-ac8d-5dc075d703ba">
        <source>getReserveDetailFromCode(_code : String; _bulkRelease : CM_BulkRelease io; _reserve : CM_ReserveDetail io; _showPicker : Boolean) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


/* Changes

Date		Name	TFS#		Description
============================================================================
11/06/2009	cnwjk3	CCMS 1035
12/04/2019	jlgka1	TFS 44368	Add isCompleted flag to identify what error message 
								to display when doing a road gate.
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
============================================================================*/
vars
	compareCode 	  : String;
	ts				  : TimeStamp;
	reserve			  : CM_ReserveDetail;
	objArr			  : ObjectArray;
	pickerReturnValue : Integer;	//30 May 2011	NDL	Par 27573
	isCompleted		  : Boolean; 	// jlgka1 TFS 44368
	
begin
	create objArr transient;
	
	if _bulkRelease = null then					//cnwas3 par26675
		compareCode := _code.toUpper();			// cnwjre1 May 2011 27097 development, par26675 patch fix
	//	_bulkRelease := self.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq(compareCode, ts);
		//30 May 2011	NDL	Par 27573
		pickerReturnValue := self.getBulkRelease(compareCode, _bulkRelease, isCompleted);	// jlgka1 TFS 44368
		if pickerReturnValue = MsgBox_Return_Cancel then
			_bulkRelease := null;
		endif;
	
	endif;
	compareCode := _code.toUpper();	
	if _bulkRelease &lt;&gt; null and _bulkRelease.code = compareCode and _bulkRelease.type = BR_TYPE_ROAD then
		if _bulkRelease.releaseByType then
			foreach reserve in _bulkRelease.allReserveDetails discreteLock do
				objArr.add(reserve);
			endforeach;
		else
			foreach reserve in _bulkRelease.allReserveDetails discreteLock do
				//if reserve.getTotalOutstanding() &gt; 0 then					// 01/11/2012 cnwmh5 #30654
				//if reserve.allTrackedItems.size &gt; 0 then
				if reserve.hasTi() then //23/06/2023	navkc1	CR 58406 Task 58408
					objArr.add(reserve);
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if objArr.size = 0 then
		// Do nothing
	elseif objArr.size = 1 or not _showPicker then
		_reserve := objArr.first().CM_ReserveDetail;
	elseif _showPicker then
		_reserve := self.pickerWindowForReserveDetails(objArr);
	endif;

	return _reserve &lt;&gt; null and _bulkRelease &lt;&gt; null;

epilog
	delete objArr;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="io"/>
        <Parameter name="_reserve" type="CM_ReserveDetail" usage="io"/>
        <Parameter name="_showPicker" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getRowsFromTIs" id="f4455333-c885-4a50-ad15-c767c17958d2">
        <source>getRowsFromTIs(_objs : ObjectSet) : CM_ObjectArray;
// ---------------------------------------------------------------------------
// Created:		14 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTIs : CM_TISet;
	theRows : CM_ObjectArray;
	aTI : CM_TrackedItem;
	aRow : CM_GridRow;
	dynaDict : DynaDictionary;
	non, ts : Integer;
	mess : String;
begin
	create theTIs transient;
	create theRows transient;
	_objs.copy(theTIs);
	
	foreach aTI in theTIs do
		if not  aTI.myPrimaryActualLocation.isKindOf(CM_GridController) then
		
			non := non + 1;
			
			if aTI.isTranshipItem then
				ts := ts + 1;
			endif;
			continue;
		endif;
		
		aRow := aTI.myPrimaryActualLocation.CM_GridController.myGridRow;
		
		if not theRows.includes(aRow) then
			theRows.add(aRow);
		endif;
	endforeach;

	if non &gt; 0 then
		 mess := "Of " &amp; theTIs.size.String &amp; " items " &amp; non.String &amp; " cannot be shown in a yard area.";
		 if ts &gt; 0 then
		 	if ts = non then
			 	mess := mess &amp; Cr &amp; "They cannot be shown because they are all Tranship items.";
			 else
			 	if ts = 1 then
				 	mess := mess &amp; Cr &amp; "1 cannot be shown as it is a Tranship item.";
			 	else
				 	mess := mess &amp; Cr &amp; ts.String &amp; " Of the " &amp; non.String &amp; " cannot be shown because they are Tranship items.";
				 endif;
			 endif;
		 endif;
		app.msgBox(mess,"Selected Items", MsgBox_OK_Only);
	endif;
	
	create dynaDict transient;	
	dynaDict.setMembership(CM_GridRow);
	dynaDict.addMemberKey("myGridArea.id", false, true);
	dynaDict.addMemberKey("label", false, true);
	dynaDict.endKeys(true);

	theRows.copy(dynaDict);
	theRows.clear;
	dynaDict.copy(theRows);
	
	return theRows;
epilog
	delete dynaDict;
	delete theTIs;
end;</source>
        <Parameter name="_objs" type="ObjectSet"/>
        <ReturnType type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getSelectedContext" id="2eaf3945-119f-4367-b5a3-1abef6fb19a9">
