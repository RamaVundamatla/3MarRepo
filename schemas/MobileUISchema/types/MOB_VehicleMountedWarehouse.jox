    <JadeMethod name="getMoveWeight" id="ab073882-615a-4f8f-9090-15bf987586eb">
        <source>getMoveWeight() : Decimal;
/*

Date		Who		Reason
21 March 2014	cnwer1	Initial creation CCMS 1366

*/

vars
	amount,density : Decimal[14,4]; //could be volume or weight
	ti : CM_TrackedItem;
	ct : CM_CargoType;
	workingEntry : CM_RTQueueEntry;
begin
	if not self.tblWeight.visible then
		return null;
	endif;
		
	amount := self.tblWeight.getConvertedValue;
	if self.tblWeight.measurementType = Type_Volume then
	//	ti:=self.getCargoID
		workingEntry:=self.getSelectedWorkingRTEntry;
		if workingEntry &lt;&gt; null then
			density:=workingEntry.myWorkListEntry.getDensity();
		endif;
	
		return amount*density;
		
	else
		return amount;
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDirectorCargo" id="61818d3f-a85d-4e70-9e6d-9b2233663bb8">
        <source>getSelectedDirectorCargo() : CM_TrackedItem;
/*

Date		Who		Reason
14 August 2014	cnwer1	Initial creation PAR

*/

vars
	selectedRow,
	i : Integer;
	allSelectedRows  : StringArray;
	obj : Object;
	ti : CM_TrackedItem;
	
begin

	
	allSelectedRows:=self.tblDirector.tag.getTokens();
	i:=1;
	while i &lt;= allSelectedRows.size do
		selectedRow:=allSelectedRows[i].Integer;
		if selectedRow &lt;= self.tblDirector.rows then
			ti := self.tblDirector.accessRow(selectedRow).itemObject.CM_TrackedItem;
			if ti = null then
				continue;
			endif;
			return ti;
		endif;
		i:=i+1;
	endwhile;

	return null;

epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getSelectedRTQueueEntries" id="309ed9af-6eae-495f-9878-3b74b1884b86">
        <source>getSelectedRTQueueEntries(_selectedEntries : CM_RTQueueEntryArray input);
/*

Date		Who		Reason
06 August 2014	cnwer1	Initial creation PAR

*/

vars
	selectedRow,
	i : Integer;
	allSelectedRows  : StringArray;
	obj : Object;
	rtQueueEntry: CM_RTQueueEntry;
begin
	if _selectedEntries = null then
		return;
	endif;
	
	allSelectedRows:=self.tblSelectTasks.tag.getTokens();
	i:=1;
	while i &lt;= allSelectedRows.size do
		selectedRow:=allSelectedRows[i].Integer;
		if selectedRow &lt;= self.tblSelectTasks.rows then
			obj := self.tblSelectTasks.accessRow(selectedRow).itemObject;
			rtQueueEntry := obj.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
			if rtQueueEntry &lt;&gt; null then
				_selectedEntries.add(rtQueueEntry);
			endif;
		endif;
		i:=i+1;
	endwhile;

epilog

end;</source>
        <Parameter name="_selectedEntries" type="CM_RTQueueEntryArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedWorkingRTEntry" id="d47b1ea4-b6a9-4787-a892-81285517800d">
        <source>getSelectedWorkingRTEntry() : CM_RTQueueEntry;
/*

Date		Who		Reason
11 August 2014	cnwer1	Initial creation PAR
24 Jan    2018  cnwma1  Bug 36814: CPL - FW: Getting this in test
*/

vars
	selectedRow,
	i : Integer;
	allSelectedRows  : StringArray;
	obj : Object;
	rtQueueEntry: CM_RTQueueEntry;
	invalidObj : Boolean;
	edition : Integer;
begin

	on Exception do app.handleDeletedObject( exception, obj, invalidObj );  // 24.01.2018	cnwma1  Bug 36814
	allSelectedRows:=self.tblWorkingTasks.tag.getTokens();
	i:=1;
	while i &lt;= allSelectedRows.size do
		selectedRow:=allSelectedRows[i].Integer;
		if selectedRow &lt;= self.tblWorkingTasks.rows then
			obj := self.tblWorkingTasks.accessRow(selectedRow).itemObject;
			
			invalidObj := false;	 // 24.01.2018	cnwma1  Bug 36814
			edition := obj.edition; // 24.01.2018	cnwma1  Bug 36814		
			if invalidObj then      // 24.01.2018	cnwma1  Bug 36814
				continue;
			endif;
			
			rtQueueEntry := obj.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
			
			if rtQueueEntry = null then
				continue;
			endif;
			return rtQueueEntry;
		endif;
		i:=i+1;
	endwhile;

	return null;
epilog

end;</source>
        <ReturnType type="CM_RTQueueEntry"/>
    </JadeMethod>
