    <PrimAttribute name="code" id="cfaf86d8-ad9c-42a7-8cdc-95b4bfe3bd9e">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="name" id="a6141837-e913-416b-8b69-9e680efce56f">
        <length>81</length>
