			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Report Parameter Value has been changed by another process.  Please refresh the Parameter Value and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pReportParameterValueObj.updateMe(pQueueEntryObj, pReportParameterObj, pObjectValueObj, pStringValue);
	endif;

