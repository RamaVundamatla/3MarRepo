vars
	planForm : CMUI_ShipTIsNowSingleLift;
	shp : Schema;
	aClass : Class;
begin
	shp := rootSchema.getSchema("ShipSchema"); // PAR 21596
	aClass := shp.getClass("SHP_Assistant"); // PAR 21596


