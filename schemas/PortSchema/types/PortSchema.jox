    <JadeMethod name="myRoot" id="2bc37e29-ed76-4fef-8b56-f91a2b1088da">
        <methodInvocation>mapping</methodInvocation>
        <source>myRoot(set : Boolean; _value : CM_Root io) mapping;
/*

Date		Who		Reason
13 Jan 2014	cnwer1	Initial creation PAR
20 Jun 2014	cnwkpd1	PAR #34373 - 1090 error in Starter Database creation

*/

vars

begin
	// PAR #34373 - don't do any mapping on the set, otherwise will not be set up when CM_Root 
	// is first created in the Starter Database
	if not set then
		if self.myRoot = null then
			_value := CM_Root.firstInstance;
		else
			_value := self.myRoot;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
