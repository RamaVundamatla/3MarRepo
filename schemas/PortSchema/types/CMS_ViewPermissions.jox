<GUIClass name="CMS_ViewPermissions" id="ad996651-e103-4cc4-9ce4-9e9976077a90">
    <superclass name="CMS_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="tblPerms" id="183d60fb-89ce-41b0-a9e5-88cf99a7ad4b">
        <embedded/>
        <type name="Table"/>
    </ImplicitInverseRef>
    <JadeMethod name="init" id="59ce5386-af0f-4a9a-a40b-a4fe9cf6c5d1">
        <updating/>
        <source>init(_caption : String; _permsDict : CM_PermissionObjectByNameDict; _agent : CM_PermissionAgent) updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18 Jan 2011  Richard S	Add in column for constant name if user isSpecial
// ---------------------------------------------------------------------------
vars
	permObj	: CM_PermissionObject;
	str		: String;
	uservalue, isSpecial	: Boolean;
	invStatus : CM_InvoiceStatus;
begin

	self.caption := 'Permissions for ' &amp; _caption;
	
	btnHelp.visible := false;
	btnCancel.visible := false;
	
	isSpecial := app.isSpecial();

	tblPerms.rows := 1;
		tblPerms.columns := 4;
	
	str := 'Description' &amp; Tab &amp;
		'User Access' &amp; Tab &amp;
			'Explanation' &amp; Tab &amp;
			'Category';

	if isSpecial then
		str := str &amp; Tab &amp; 'Constant';
		tblPerms.columns := 5;
	endif;

	tblPerms.accessCell(1,1).text := str;
			
	foreach permObj in _permsDict do
	
		uservalue := app.myCurrentUserCan(self.myTerminal, permObj.constValue) ;	// TFS 2198 CNWAB1

		str :=  permObj.description &amp; Tab &amp; 
			   uservalue.getYesNo() &amp; Tab &amp;
			   permObj.explanation  &amp; Tab &amp; 
			   permObj.category ;
		
		if isSpecial then
			str := str &amp; Tab &amp; permObj.constName;
		endif;
		
		tblPerms.addItem(str);
	endforeach;
	
	// TFS 39618 show soft permissions
	foreach invStatus in _agent.allInvoiceStatusesMaint	discreteLock do
		str :=  invStatus.myInvoiceProcess.description &amp; " - " &amp; invStatus.description &amp; Tab &amp; 
			   "Yes" &amp; Tab &amp; "Allows User To Set Invoice To Status '" &amp; invStatus.description &amp; "'" &amp; Tab &amp; 
			   invStatus.myInvoiceProcess.description ;
		
		
		tblPerms.addItem(str);
	
	endforeach;
	


end;</source>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_permsDict" type="CM_PermissionObjectByNameDict"/>
        <Parameter name="_agent" type="CM_PermissionAgent"/>
    </JadeMethod>
</GUIClass>
