    <JadeMethod name="initTable" id="5c261bf7-0c49-4ad1-b323-0abcf4a6268a">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	heading : String;

begin
	self.tblTranship.rows := 0;
	self.tblTranship.columns := 11;
//	self.tblActivity.addItem(app.getErrorString(ISOGroup) &amp; Tab &amp; app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(Type_GC) &amp; Tab  &amp; app.getErrorString(Detail));
	self.tblTranship.addItem("ISOGroup" &amp; Tab &amp; "Total" &amp; Tab &amp; "Discharge"&amp;Tab&amp;"No. Cntrs" &amp; Tab  &amp; "Load Voyage"&amp;Tab&amp;"CommodityGroup" &amp; Tab&amp;"No. Cntrs" &amp; Tab  &amp;"Pads 2 high"&amp;Tab&amp;"Pads 3 High"&amp;Tab&amp;"Allocations" &amp; Tab &amp; " Rows Used");
	self.tblTranship.fixedRows := 1;
	self.tblTranship.fixedColumns := 0;
	self.tblTranship.selectMode := Table.SelectMode_Row;
	self.tblTranship.accessMode := Table.AccessMode_Row;
	self.tblTranship.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblTranship.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblTranship.defaultRowHeight := 17;
	self.tblTranship.allSelectedObjects.clear;
	
	
	//27 Feb 2014	NDL	Par 33607
	self.tblEmpties.rows := 0;
	self.tblEmpties.columns := 11;
	heading := app.getErrorString(Cargo) &amp; CrLf &amp; app.getErrorString(Operator) &amp; Tab
				&amp; app.getErrorString(Total) &amp; CrLf &amp; Tab
				&amp; app.getErrorString(CM_ISO) &amp; CrLf &amp; app.getErrorString(YAM_Msg_Group) &amp; Tab
				&amp; app.getErrorString(Total) &amp; CrLf &amp; Tab
				&amp; app.getErrorString(Availability) &amp; CrLf &amp; app.getErrorString(Grade) &amp; Tab
				&amp; app.getErrorString(Total) &amp; CrLf &amp; Tab
				&amp; app.getErrorString(HasTodo) &amp; CrLf &amp; app.getErrorString(Tasks) &amp; Tab
				&amp; app.getErrorString(NameOf) &amp; CrLf &amp; app.getErrorString(Allocation) &amp; Tab
				&amp; app.getErrorString(Allocation) &amp; CrLf &amp; app.getErrorString(YAM_Stats_Range) &amp; Tab
				&amp; app.getErrorString(Total) &amp; CrLf &amp; Tab
				&amp; app.getErrorString(Notes) &amp; CrLf;
	self.tblEmpties.addItem( heading );
	self.tblEmpties.fixedRows := 1;
	self.tblEmpties.fixedColumns := 0;
	self.tblEmpties.selectMode := Table.SelectMode_Row;
	self.tblEmpties.accessMode := Table.AccessMode_Row;
	self.tblEmpties.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblEmpties.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblEmpties.defaultRowHeight := 17;
	self.tblEmpties.accessColumn(1).fontBold := true;
	self.tblEmpties.accessColumn(2).fontBold := true;
	self.tblEmpties.accessColumn(3).fontBold := true;
	self.tblEmpties.accessColumn(4).fontBold := true;
	self.tblEmpties.accessColumn(5).fontBold := true;
	self.tblEmpties.accessColumn(6).fontBold := true;
	self.tblEmpties.accessCell(1,1).fontBold := false;
	self.tblEmpties.accessCell(1,2).fontBold := false;
	self.tblEmpties.accessCell(1,3).fontBold := false;
	self.tblEmpties.accessCell(1,4).fontBold := false;
	self.tblEmpties.accessCell(1,5).fontBold := false;
	self.tblEmpties.accessCell(1,6).fontBold := false;
	self.tblEmpties.accessColumn(2).alignment := Table.Alignment_Right_Middle;
	self.tblEmpties.accessColumn(4).alignment := Table.Alignment_Right_Middle;
	self.tblEmpties.accessColumn(5).alignment := Table.Alignment_Center_Middle;
	self.tblEmpties.accessColumn(6).alignment := Table.Alignment_Right_Middle;
	self.tblEmpties.accessCell(1,2).alignment := Table.Alignment_Left_Middle;
	self.tblEmpties.accessCell(1,4).alignment := Table.Alignment_Left_Middle;
	self.tblEmpties.accessCell(1,5).alignment := Table.Alignment_Left_Middle;
	self.tblEmpties.accessCell(1,6).alignment := Table.Alignment_Left_Middle;
	self.tblEmpties.allSelectedObjects.clear;
	self.tblEmpties.leftColumn := 1;
	self.tblEmpties.topRow := 1;
	self.tblEmpties.accessRow(1).height := 34;
	
	
	//27 Feb 2014	NDL	Par 33607
	self.tblFulls.rows := 0;
	self.tblFulls.columns := 8;
	heading := app.getErrorString(CM_ISO) &amp; CrLf &amp; app.getErrorString(YAM_Msg_Group) &amp; Tab
				&amp; app.getErrorString(Total) &amp; CrLf &amp; Tab
				&amp; app.getErrorString(Commodity) &amp; CrLf &amp; app.getErrorString(YAM_Msg_Group) &amp; Tab
				&amp; app.getErrorString(Total) &amp; CrLf &amp; Tab
				&amp; app.getErrorString(NameOf) &amp; CrLf &amp; app.getErrorString(Allocation) &amp; Tab
				&amp; app.getErrorString(Allocation) &amp; CrLf &amp; app.getErrorString(YAM_Stats_Range) &amp; Tab
				&amp; app.getErrorString(Total) &amp; CrLf &amp; Tab
				&amp; app.getErrorString(Notes) &amp; CrLf;
	self.tblFulls.addItem( heading );
	self.tblFulls.fixedRows := 1;
	self.tblFulls.fixedColumns := 0;
	self.tblFulls.selectMode := Table.SelectMode_Row;
	self.tblFulls.accessMode := Table.AccessMode_Row;
	self.tblFulls.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblFulls.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblFulls.defaultRowHeight := 17;
	self.tblFulls.accessColumn(1).fontBold := true;
	self.tblFulls.accessColumn(2).fontBold := true;
	self.tblFulls.accessColumn(3).fontBold := true;
	self.tblFulls.accessColumn(4).fontBold := true;
	self.tblFulls.accessCell(1,1).fontBold := false;
	self.tblFulls.accessCell(1,2).fontBold := false;
	self.tblFulls.accessCell(1,3).fontBold := false;
	self.tblFulls.accessCell(1,4).fontBold := false;
	self.tblFulls.accessColumn(2).alignment := Table.Alignment_Right_Middle;
	self.tblFulls.accessColumn(4).alignment := Table.Alignment_Right_Middle;
	self.tblFulls.accessCell(1,2).alignment := Table.Alignment_Left_Middle;
	self.tblFulls.accessCell(1,4).alignment := Table.Alignment_Left_Middle;
	self.tblFulls.allSelectedObjects.clear;
	self.tblFulls.accessRow(1).height := 34;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="05d4ce7d-ec16-4666-8dff-2ee1c19a4ced">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     14 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if keyCode = CMUI_Key_F3 then
		if not app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.frmSelector.visible := not self.frmSelector.visible;
			return;
		endif;
	endif;
	
	inheritMethod(keyCode, shift);
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setToolbarSearch" id="e447f711-0c6c-4ba2-95c9-820bfe91cfc2">
        <source>setToolbarSearch();

vars

begin
	self.frmSelectToolbar.showCaptions := self.frmToolbar.showCaptions;
	self.frmSelector.height := self.frmSelectToolbar.height + self.cmbVoyage.height + 10;
	self.frmSelector.width := 300;
	self.cmbVoyage.top := self.frmSelectToolbar.height;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setValidVoyages" id="22a4970a-9d4d-4cd3-b91f-daab8ca9ba06">
        <source>setValidVoyages();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/11/2019	jlgsl4		TFS 47678 - POL - cancelled voyages in Voyage Discharge Summary
*/

vars
	voyage : CM_Voyage;
	index : Integer;
	voyageCombo : CMUI_ComboBoxVoyage;
begin
	voyageCombo := self.cmbVoyage;
	voyageCombo.clear;
	foreach voyage in self.myTerminal.allVoyagesByCode where not voyage.isCancelled do //jlier1 TFS51963 5/10/21  //navsp1 TFS#54614 30Aug2022
		index := voyageCombo.addItem(voyage.code &amp; '    ' &amp; voyage.description);
		voyageCombo.itemObject[index] := voyage; // ^^^ 4 spaces not Tab which doesn't expand once voyage selected
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c8fd9193-a16e-44be-a560-928874885d83">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Date			Who			Reason
// 01 Oct 2008	consw1		Par 17090 Replace app.getMyTerminal with self.myTerminal
// 02/04/2009	cnwrl1		PAR 19357 Change navigation caption
// 22/11/2019	jlgsl4		TFS 47678 - POL - cancelled voyages in Voyage Discharge Summary

vars

begin
	inheritMethod();
	self.width := 900;	//03 Mar 2014	NDL	Par 33067
	self.height := 500;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;
	self.myTerminal := app.myPassport.myTerminal;
//	self.setNavigatorHeading(app.getErrorString(Activity_History));	// cnwrl1 02/04/2009 PAR 19357
	self.setNavigatorHeading( self.caption );
	self.setValidVoyages(); // TFS 47678
	//self.cmbVoyage.listCollection(self.myTerminal.allVoyagesByCode, false, 0); // TFS 47678
	self.showHideSelector(); // PAR 20186
	
	//03 Mar 2014	NDL	Par 33067
	self.shtEmpty.visible :=  ( app.myRoot.client = Client_PortOtago ) or app.isDevelopmentSystem;
	self.shtFulls.visible :=  ( app.myRoot.client = Client_PortOtago ) or app.isDevelopmentSystem;
end;</source>
    </JadeMethod>
    <JadeMethod name="show" id="d3abf779-812e-41c3-a60e-e841c8397f6a">
        <updating/>
        <source>show() updating;

vars

begin
	inheritMethod();
	if self.myCurrentVoyage &lt;&gt; null then
		self.displayCollectionVoyage();
	elseif self.myEDIDataTranship &lt;&gt; null then
		self.displayCollectionEDI();
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="showHideSelector" id="3d4c9fcc-e7ec-484e-88bc-c659d242c2af">
        <source>showHideSelector();

vars

begin
	if self.frmSelector.visible then
		//self.frmSelector.visible := (self.tblTranship.rows = self.tblTranship.fixedRows); //PAR 20186 
		self.frmSelector.visible := (self.tblTranship.rows = self.tblTranship.fixedRows)
									and (self.tblFulls.rows = self.tblFulls.fixedRows)
									and (self.tblEmpties.rows = self.tblEmpties.fixedRows);
	else
		self.frmSelector.width := 250;
		self.cmbVoyage.width := self.frmSelector.width-40;
		self.frmSelector.cnEcResizeContents();
		self.frmSelector.centreWindow();
		self.frmSelector.visible := true;
		self.frmSelector.zOrder(1);
		self.cmbVoyage.setFocus();
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tblEmpties_dblClick" id="506a070a-3c49-4f70-afff-5ac0419d9929">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEmpties_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2014	cnwndl1	Initial creation	Par 34217

*/

vars

	obj : Object;
	msg : String;

begin

	if app.isDevelopmentSystem or app.isSpecial then
		obj := table.accessCell(table.row,table.column).itemObject;
		if obj &lt;&gt; null and obj.isKindOf( CM_TrackedItem ) then
			msg := "The first cargo item in the set is '" &amp; obj.CM_TrackedItem.id &amp; "'. Allocations displayed pertain to this cargo item.";
			app.msgBox(msg,"First Cargo Item",MsgBox_OK_Only);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
