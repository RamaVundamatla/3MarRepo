    <JadeMethod name="jtdCommonUserFini" id="bb9086dd-e3ea-46a6-87b6-2bdb33c13323">
        <updating/>
        <source>jtdCommonUserFini() updating, protected;

begin
	// put application-specific finalize code in here
	app.logMessage(method.qualifiedName);
	finalize;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdCommonUserInit" id="a0aec963-7be3-47b1-b53a-35574a25fe43">
        <updating/>
        <source>jtdCommonUserInit() updating, protected;

vars
	mthCount:Integer;
begin
	runningBenchmark:=true;
	// put application-specific initialization code in here
	if app.jtdMyContext &lt;&gt; null then
		app.jtdMyContext.jtdGetProfileNameAndMthCount(app.profileName, mthCount);
	endif;
	preventingDeadlocks:=true;
	setProcessUserInfo;  // set profileName so everyone can get seq id's
	app.controlLockAcquire;
	app.doWindowEvents(500);
	setSequenceId;
	setProcessUserInfo;  // set seq id
	app.controlLockRelease;
	preventingDeadlocks:=(getProfileStringAppServer(getIniFileNameAppServer,"JBL","PreventDeadlocks","true") &lt;&gt; "false");
	initialize;
	app.logMessage(method.qualifiedName);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdComputerName" id="d33f0ff9-2725-4f1b-9085-e966e9ef93cc">
        <source>jtdComputerName() : String;

vars
	str		: String;
	pos		: Integer;
begin
	//  Strips off domain part of computer name (for Unix hosts)

	str		:= app.computerName;
	if str &lt;&gt; null then
		pos		:= 1;
		return str.scanUntil(".", pos);
	else
		return "NO_COMPUTERNAME";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdComputerNameAppServer" id="234180ea-993e-4fc6-85f4-539249f231e7">
        <source>jtdComputerNameAppServer() : String;

vars
	str		: String;
	pos		: Integer;
begin
	//  Strips off domain part of computer name (for Unix hosts)

	str		:= app.computerNameAppServer;
	pos		:= 1;
	return str.scanUntil(".", pos);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdFini" id="ede44343-7c06-4dd1-a172-a67d2886b4f8">
        <updating/>
        <source>jtdFini() updating, protected;

begin
	self.jtdCommonUserFini;

	if self.jtdMyContext &lt;&gt; null and global.isValidObject(self.jtdMyContext) then
		self.jtdMyContext.jtdAppFini;
		
		delete self.jtdMyContext;
	endif;

	self.jtdMyContext := null;
end;</source>
        <access>protected</access>
    </JadeMethod>
