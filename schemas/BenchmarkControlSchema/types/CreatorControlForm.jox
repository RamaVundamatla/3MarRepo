    <JadeMethod name="addResults" id="00c28967-6854-4810-a1bb-c75db79d05db">
        <updating/>
        <source>addResults(s:String) updating;

begin
	//if (s[1:28] = "c:\thinbin\jsst6216\jade.exe" or s[1:28] = "c:\thinbin\jsst6304\jade.exe") and not s.cnContains("endJade 0;290;") then return; endif;  // thin the flood
	if s[1:8] = "created " and s.cnContains("_stats.csv") then
		secondLastStatsFile:=lastStatsFile;
		lastStatsFile:=s[9:end];
	endif;
	if txtResults.text.length &gt; 600000 then
		txtResults.text:=txtResults.text[txtResults.text.length-400000:end];
	endif;
	if s.contains("app/instId") then
		txtResults.text:=txtResults.text&amp;s&amp;CrLf;
	else
		txtResults.text:=txtResults.text&amp;app.actualTimeAppServer.logFormat&amp;" "&amp;s&amp;CrLf;
	endif;
	txtResults.scrollVertPos:=99999;
	txtResults.refresh;
	if app.name = "BmkStdRun" then
		app.logMessage(s);
	else
		app.logMyMessage(s);
	endif;
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="analyseTranLog" id="cb743e32-a408-43b4-a39c-38feb002ac38">
        <updating/>
        <source>analyseTranLog(byClient:Boolean) updating;

vars
	sfb:FrmServerFileBrowser;
	aa:Analysis;
begin
	if lastStatsFile = null then
		lastStatsFile:=app.dbPath[1:2]&amp;"\BenchMarkResults";
	endif;

	create sfb;
	sfb.myParentForm:=self;
	sfb.selectedItem:=lastStatsFile;
	sfb.init("Browse for File on " &amp; app.dbServerComputerName, "Select cn_tranlog csv File", null);
	sfb.showModal;
	lastStatsFile:=sfb.selectedItem;
	addResults("cn_tranlog file:    "&amp;sfb.selectedItem);

	if lastStatsFile &lt;&gt; null then
		create aa;
		aa.statsByClient:=byClient;
		aa.inFile.fileName:=lastStatsFile;
		aa.inFile.usePresentationFileSystem:=false;
		addResults("comparison results: "&amp;aa.analyseTranLog);
	endif;
epilog
	delete sfb;
	delete aa;
end;</source>
        <Parameter name="byClient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="btnGo_click" id="0d8ced64-d28f-452c-9ca6-c73c922a2fdd">
