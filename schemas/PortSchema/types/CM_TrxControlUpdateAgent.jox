    <JadeMethod name="trxSapWSDL17Success" id="9c401236-a6b2-46b9-a55a-c8e011c9abdf">
        <updating/>
        <source>trxSapWSDL17Success( _invoice : CM_Invoice input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2019	jlgndl1	Initial creation	TFS 45330

*/

vars

	msgArray : String200Array;
	msg : String;
	baseMsg : String;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
//	on LockException do agtPassportLockExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //Silent lock exception handler for retries...

	create msgArray transient;
	baseMsg :=  method.qualifiedName &amp; ' ' &amp; BGP_SAPWSRequest.WSDL17 &amp; " "; 
		
	beginTransaction;
	
	if _invoice.isPaymentCancelled then				
		app.myUtilityUA.updRealInvoicePaymentStat( _invoice, CM_Invoice.INVOICE_PAYMENT_NOTPAID, BGP_SAPWSRequest.WSDL17, msgArray, _passport);
	endif;
	
	if _passport.noErrors then
		app.myUtilityUA.utlUpdateInvLineExtTS07( _invoice, app.actualTimeAppServer(), _passport);
	endif;

	if _passport.noErrors then
		_invoice.sendSAPKinerja();
	endif;
	
	if _passport.noErrors then
		foreach msg in msgArray do
			app.writeLog(msg ,LogINFO);
		endforeach;
	else
		msg := baseMsg &amp; _passport.getErrorsAndWarningsAsString();
		app.writeLog(msg ,LogINFO);
	endif;
	
epilog

	delete msgArray;

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
