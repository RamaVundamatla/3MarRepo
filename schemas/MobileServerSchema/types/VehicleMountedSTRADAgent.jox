    <JadeMethod name="isSetdownLocationOnVoyage" id="37fbf039-1d5a-4837-be8e-369606b4f28d">
        <source>isSetdownLocationOnVoyage(_rtQueueTask : CM_RTQueueTask) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2009	cnwer1	Initial creation

*/

vars

begin
	if _rtQueueTask = null or _rtQueueTask.targetLocation = null then
		return false;
	endif;
	
	return _rtQueueTask.targetLocation.isKindOf(CM_SlotController);
epilog

end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
