    <JadeMethod name="doSave" id="0f1ab41e-8c77-4312-be9b-31923771e375">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2019	jlgab1	Initial creation

*/

vars
	aComp, pxyComp : CM_Bank;
	ls : Boolean;
	theReturn : Integer;
	theController : CMIF_BankDetails;

begin
	create theController transient;
	self.populateController(theController);
	


	while true do
		if self.mode = self.MODE_NEW then
			create pxyComp transient;
			theController.myProxyBank := pxyComp;
			pxyComp.setProxy(theController);
			app.myTrxCA.trxCreateBank(theController,aComp,app.myPassport);
		else
			app.cmsBeginLoad(ls);
			pxyComp := app.createUpdateProxy(self.myCurrentBank).CM_Bank;
			app.cmsEndLoad(ls);
			theController.myProxyBank := pxyComp;
			pxyComp.setProxy(theController);
			app.myTrxUA.trxUpdateBank(theController,app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Company_Structure), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.unloadForm();
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyComp;
	delete theController;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDebtors" id="b7eeca9c-bf1c-433c-8bec-6ba4f84c51b2">
        <source>loadDebtors();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2019	jlgsl4	TFS39618

*/
vars
	theCMB : CMUI_ComboBox;
	debtor : CM_Debtor;
	index : Integer;
begin
	theCMB := self.cmbDebtor;
	theCMB.clear;
	foreach debtor in app.myRoot.myRootCompany.debtors do
		index := theCMB.addItem(debtor.name);
		theCMB.itemObject[index] := debtor;
	endforeach;
	
	if self.myCurrentBank&lt;&gt; null then
		debtor := self.myCurrentBank.businessUnitDebtor;
		index := theCMB.findObject(debtor);
		if index &gt; 0 then
			theCMB.listIndex := index;
		endif;
	endif;
	theCMB.lostFocus(theCMB);
end;</source>
    </JadeMethod>
    <JadeMethod name="loadPackages" id="77273ab0-901f-47db-af41-f9fd76da264b">
        <source>loadPackages();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2024	navra1	Initial creation for CR 61910/Task 62303 - EUP | API Create default package to run on invoice updating status to POSTED

*/
vars
	theCMB : CMUI_ComboBox;
	invPackage : CM_Package;
	index : Integer;
begin
	theCMB := self.cmbPackage;
	theCMB.clear;
	
	//add "NO DEFAULT PACKAGE" as an option	with the itemObject being null
	index := theCMB.addItem("NO DEFAULT PACKAGE");
	theCMB.itemObject[index] := null;
	theCMB.itemBackColor[index] := Yellow;
	foreach invPackage in app.myRoot.allPackages where invPackage.isKindOf(CM_PackageInvoice) do
		index := theCMB.addItem(invPackage.description);
		theCMB.itemObject[index] := invPackage;
	endforeach;
	
	if self.myCurrentBank &lt;&gt; null then
		invPackage := self.myCurrentBank.myDefaultPackage;
		index := theCMB.findObject(invPackage);
		if index &gt; 0 then
			theCMB.listIndex := index;			
		else
			theCMB.listIndex  := theCMB.findObject(null);			
		endif;
	else		//if there was not bank, we should disable the package combo - how can we come here without a bank?
		theCMB.enabled := false;
	endif;
	theCMB.lostFocus(theCMB);
end;</source>
    </JadeMethod>
    <JadeMethod name="loadProcesses" id="28d99468-4de9-451a-b6ce-08a9de343640">
        <source>loadProcesses();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2019	jlgsl4	TFS39618

*/
vars
	theCMB : CMUI_ComboBox;
	invprocess : CM_InvoiceProcess;
	index : Integer;
begin
	theCMB := self.cmbProcess;
	theCMB.clear;
	foreach invprocess in app.myRoot.allInvoiceProcesses do
		index := theCMB.addItem(invprocess.description);
		theCMB.itemObject[index] := invprocess;
	endforeach;
	
	if self.myCurrentBank &lt;&gt; null then
		invprocess := self.myCurrentBank.getMyInvoiceProcess();
		index := theCMB.findObject(invprocess);
		if index &gt; 0 then
			theCMB.listIndex := index;
		else
			theCMB.listIndex := 2;
		endif;
	else			
		theCMB.listIndex := 2;
	endif;
	theCMB.lostFocus(theCMB);
end;</source>
    </JadeMethod>
    <JadeMethod name="populateController" id="b05cbc96-fa59-4dfe-a861-688331875ee6">
        <updating/>
        <source>populateController(_controller : CMIF_BankDetails input) updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars

begin
	_controller.isBU := true; 
	
	_controller.myParentCompany := self.myCurrentCompany;
	
	_controller.setBankDetails(self.txtBankDetails.text);
	_controller.setMailingAddress(self.txtAddress.text);
	_controller.setRemittanceAddress(self.txtAddressRem.text);
	
	_controller.code := self.txtCode.text;
	_controller.emailAddress := self.txtEmail.text;
	_controller.faxNumber := self.txtFax.text;
	_controller.isSuspended := self.chkSuspended.value;
	_controller.mailingName := self.txtName.text;
	_controller.onsiteStorageChargeTime := self.mskTime.getTime();
	_controller.phoneNumber := self.txtPhone.text;
	_controller.myBusinessUnitDebtor := self.cmbDebtor.listObject.CM_Debtor;
	_controller.myInvoiceProcess := self.cmbProcess.listObject.CM_InvoiceProcess;
	_controller.myDefaultPackage := self.cmbPackage.listObject.CM_PackageInvoice;		//navra1 - CR 61910//Task 62303 - 12th Feb 2024
	_controller.nextInvoiceNumber := self.txtInvNumber.text.Integer;
end;</source>
        <Parameter name="_controller" type="CMIF_BankDetails" usage="input"/>
    </JadeMethod>
