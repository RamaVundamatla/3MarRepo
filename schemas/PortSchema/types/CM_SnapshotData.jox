// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.runDateTime.Date;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="d3021b47-aacb-4a64-b208-001b9008c345">
        <updating/>
        <source>setBaseData(	_outputFormat_SS : CM_OutputFormat_SS; 
				_terminal : CM_Terminal;
				_name : String;
				_user : CM_User;
				_ts :TimeStamp	// 12/08/2010 cnwcs5 [ar 23706
				) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023
12/08/2010			cnwcs5	par 23706 - added _ts parameter	
*/

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.mode 			:= _outputFormat_SS.mode;
	self.type 			:= _outputFormat_SS.type;
	
	// self.runDateTime	:= app.actualTimeServer;
	self.runDateTime	:= _ts;	// par 23706 cnwcs5 12/08/2010
	
	if _name = null then
		self.name := _outputFormat_SS.name;
	else
		self.name := _name;
	endif;
	
	self.myUser := _user;

	self.myOutputFormat_SS := _outputFormat_SS;
	
	self.myTerminal := _terminal;
	
epilog

end;</source>
        <Parameter name="_outputFormat_SS" type="CM_OutputFormat_SS"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b58b2fd9-f70e-476a-b6e7-3648b1d5d8fd">
        <updating/>
        <source>setForUpdate(_proxy: CM_SnapshotData) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwndl1	Initial creation	CCMS 1023
17/02/2010			cnwcs5	Save number of items as a property
*/

vars

	pxyDynaSnapshot : CM_DynamicObject_Snapshot;
	dynaSnapshot : CM_DynamicObject_Snapshot;

begin

	self.raiseExceptionIfTransient (method);
	
	self.exclusiveLock (self);
	
	self.name := _proxy.name;
	self.runDateTime := _proxy.runDateTime;
	self.mode := _proxy.mode;
	self.type := _proxy.type;
	
	self.myUser := _proxy.myUser;
	self.myTerminal := _proxy.myTerminal;
	self.myOutputFormat_SS := _proxy.myOutputFormat_SS;	
	
	self.allSnapshotData.purge;
	foreach pxyDynaSnapshot in _proxy.allSnapshotData do
		dynaSnapshot := pxyDynaSnapshot.cloneSelf (false);
		self.allSnapshotData.add(dynaSnapshot);
		dynaSnapshot.persistReferences(pxyDynaSnapshot);
	endforeach;
	self.numberOfItems := self.getNumItems;	// 17/02/2010 cnwsc5
epilog

end;</source>
        <Parameter name="_proxy" type="CM_SnapshotData"/>
    </JadeMethod>
