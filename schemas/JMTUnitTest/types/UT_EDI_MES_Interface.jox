    <JadeMethod name="zCheckOutput" id="b580f8e7-e7dd-4d92-b2e9-c936dcf9027a">
        <source>zCheckOutput(_camProtocol :CM_CamProtocol; _output :HugeStringArray; _expectedOutput :String)protected;
/*
Date		Who		Reason
06/05 2012	cnwcs5	Initial creation - 
*/
vars
	array	:HugeStringArray;
	temp, str, actual	:String;
//	comma	:Character;
	charActual : Character;
	charStr : Character;
	idx		:Integer;
begin
	// compare with what we expect
	create array transient;
	
	temp := _expectedOutput;
	temp := temp.replaceString (Lf, null);
		
	temp.getHugeTokensForDelimiter (Cr, array);
//	comma := _camProtocol.elementSeparator;
write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' '&amp;self.String&amp;" Actual Size "&amp;_output.size.String&amp;"Expected Size "&amp;array.size.String;

	self.assertEqualMsg (_output.size, array.size, 
								"Actual Size " &amp; _output.size.String &amp; CrLf &amp;
								"Expected Size " &amp; array.size.String);
	
	idx := 0;
	foreach str in array do
		idx 	:= idx + 1;
		actual 	:=  _output[idx];
		charActual := actual[1:1].Character;
		charStr := str[1:1].Character;
		if charActual &lt;&gt; charStr then
			actual := actual[2:end];
		endif;

		self.assertEqualMsg (actual.toUpper, str.toUpper, _camProtocol.description &amp; ' record ' &amp; idx.String);
	endforeach;
epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_output" type="HugeStringArray"/>
        <Parameter name="_expectedOutput" type="String"/>
    </JadeMethod>
    <JadeMethod name="zJMT_To_CICS_1004" id="cf2f42c5-7963-482f-90b6-420c6aa9c73a">
        <source>zJMT_To_CICS_1004(_protocol :String; _camGroup :CM_CamGroup; _start, _end :TimeStamp)protected;
/*
Date		Who		Reason
05/06/2012	cnwcs5	Initial creation - MES1004 - Empty Container Release (CAM Protocol 300_MSL_Releases in messina system)
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	PREFIX 		= '1004';
	JRWREPORT	= 'CM_CamEmptyRelease';
	FILTER		= QFCam_EmptyContainers4Release;	// this filter not actually included in the 300_MSL_Releases protocol
vars
	desc		:CM_CamProtocolDesc;
	trxColl		:StringArray;
	filter		:CMQF_CamTransactionTemplate;
	protocol	:CM_CamProtocol;
	theLines : HugeStringArray;
	runDateTime : TimeStamp;
begin
	create theLines transient;
	self.deleteCamProtocol (_protocol);
	
	desc 	:= CM_CamUserDefRepDesc.firstInstance;
	
	if FILTER &lt;&gt; null then
		filter	:= desc.CM_CamUserDefRepDesc.allQFCamTransactionTemplates[FILTER];
		
		self.assertNotNullMsg (filter, FILTER &amp; ' - Invalid CAM Filter');
	endif;
	
	create trxColl transient;
	
	trxColl.add (global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	trxColl.add (global.getTiTxnTypeForClass(CM_ReleaseRoadInterTerminal).asStringJMT);
	// these rail transaction are not actually included in the 300_MSL_Releases protocol
	trxColl.add (global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
	trxColl.add (global.getTiTxnTypeForClass(CM_ReleaseRailInterTerminal).asStringJMT);
	
	protocol := self.createCamProtocol (_protocol, _camGroup, desc, PREFIX, JRWREPORT, trxColl, filter);
	
	self.assertNotNullMsg (protocol, _protocol &amp; ' - CAM protocol not created');
	self.assertEqual (protocol.jrwReportName, JRWREPORT);
	self.assertNotNull (protocol.myQFCamTransactionTemplate);
	self.assertEqual (protocol.myQFCamTransactionTemplate.queryDesc, FILTER);
	self.assertEqual (protocol.registeredTransactions.size, 4);
		
	beginTransaction;
	protocol.setPropertyValue (CM_CamProtocol::sendUpdateMessage.name, true);
	commitTransaction;
	
	self.runCamsAdhoc (_start, _end, runDateTime, protocol);
	
	self.assertNotNullMsg (protocol.taskHistoryByProtocolSeq.last, protocol.code &amp; ' No history');
	protocol.taskHistoryByProtocolSeq.last.rawDataToHSA(theLines);
	self.assertNotEqualMsg(theLines.size, 0, protocol.code &amp; ' No history');
	
	// expect MT releases by road/rail - must have consignee, have no booking
	// visit number impossible to match so replace with a constant
	self.zReplaceFields(theLines, 8, '&lt;visitNumber&gt;');
	// dates are impossible to match so replace with a constant
	self.zReplaceFields(theLines, 12, '&lt;date&gt;');
	
app.writeLog("jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' '&amp;self.String, 0);	
	self.zCheckOutput(protocol, theLines, self.zCICS1004_output);
epilog
	delete trxColl;
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="zJMT_To_CICS_1006" id="0903e624-01aa-45a3-944f-8f543b14bd56">
        <source>zJMT_To_CICS_1006(_protocol :String; _camGroup :CM_CamGroup; _start, _end :TimeStamp)protected;
/*
Date		Who		Reason
05/06/2012	cnwcs5	Initial creation - MES1006 - Receive Export Container (CAM Protocol 120_MSL_Gate In in messina system)
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	PREFIX 		= '1006';
	JRWREPORT	= 'CM_CamReceiptContainerExport';
	FILTER		= QFCam_ExportContainers;
vars
	desc		:CM_CamProtocolDesc;
	trxColl		:StringArray;
	filter		:CMQF_CamTransactionTemplate;
	protocol	:CM_CamProtocol;
	theLines : HugeStringArray;
	runDateTime : TimeStamp;
begin
	create theLines transient;
	self.deleteCamProtocol (_protocol);
	
	desc 	:= CM_CamUserDefRepDesc.firstInstance;
	filter	:= desc.CM_CamUserDefRepDesc.allQFCamTransactionTemplates[FILTER];
	
	self.assertNotNullMsg (filter, FILTER &amp; ' - CAM Filter not created');
	
	create trxColl transient;
	
	trxColl.add (global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	trxColl.add (global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
	
	protocol := self.createCamProtocol (_protocol, _camGroup, desc, PREFIX, JRWREPORT, trxColl, filter);
	
	self.assertNotNullMsg (protocol, _protocol &amp; ' - CAM protocol not created');
	self.assertEqual (protocol.jrwReportName, JRWREPORT);
	self.assertNotNull (protocol.myQFCamTransactionTemplate);
	self.assertEqual (protocol.myQFCamTransactionTemplate.queryDesc, FILTER);
	self.assertEqual (protocol.registeredTransactions.size, 2);
	
	self.runCamsAdhoc (_start, _end, runDateTime, protocol);
	
	self.assertNotNullMsg (protocol.taskHistoryByProtocolSeq.last, protocol.code &amp; ' No history');
	protocol.taskHistoryByProtocolSeq.last.rawDataToHSA(theLines);
	self.assertNotEqualMsg(theLines.size, 0, protocol.code &amp; ' No history');
	
	// expect MT releases by road/rail - must have consignee, have no booking

	// dates are impossible to match so replace with a constant
	self.zReplaceFields(theLines, 16, '&lt;date&gt;');
	self.zReplaceFields(theLines, 25, '&lt;date&gt;');
	self.zReplaceFields(theLines, 26, '&lt;date&gt;');
	self.zReplaceFields(theLines, 28, '&lt;time&gt;');
	self.zReplaceFields(theLines, 29, '&lt;time&gt;');
	
app.writeLog("jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' '&amp;self.String, 0);	
	self.zCheckOutput(protocol, theLines, self.zCICS1006_output);
epilog
	delete trxColl;
	delete theLines;
end;</source>
