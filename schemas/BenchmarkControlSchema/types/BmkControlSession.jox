    <JadeMethod name="changeDriveLetter" id="f0b9abf8-facb-43b0-ae7e-5a89eae4925a">
        <updating/>
        <source>changeDriveLetter(newDriveLetter:String) updating;

begin
	beginTransaction;
	systemFolder[1]:=newDriveLetter[1];
	binFolder[1]:=newDriveLetter[1];
	iniFileName[1]:=newDriveLetter[1];
	commitTransaction;
end;</source>
        <Parameter name="newDriveLetter" type="String"/>
    </JadeMethod>
    <JadeMethod name="changeEnvid" id="e4b83b2a-5b9c-4184-b904-7888d1ec530f">
        <updating/>
        <source>changeEnvid(newEnvid:String) updating;

begin
	beginTransaction;
	systemFolder:=systemFolder.replace(envid,newEnvid);
	binFolder:=binFolder.replace(envid,newEnvid);
	iniFileName:=iniFileName.replace(envid,newEnvid);
	envid:=newEnvid;
	commitTransaction;
end;</source>
        <Parameter name="newEnvid" type="String"/>
    </JadeMethod>
    <JadeMethod name="changeHost" id="f1c9cda9-3482-4489-90f6-d9de93646b7b">
        <updating/>
        <source>changeHost(newHost:String) updating;

begin
	beginTransaction;
	rapHost:=newHost;
	if newHost = 'cnwchcs46' then
		appServerHost:='cnwchcc46';
	else
		appServerHost:=newHost;
	endif;
	commitTransaction;
end;</source>
        <Parameter name="newHost" type="String"/>
    </JadeMethod>
    <JadeMethod name="cloneFrom" id="c437e1ca-7561-4e26-9f80-f7c80bb1c2a8">
        <updating/>
        <source>cloneFrom(sess:Integer) updating;

vars
	bc:BmkControlSession;
begin
	bc:=global.allBmkControls[sess];
	beginTransaction;
	owner		:= bc.owner;
	envid		:= bc.envid;
	runid		:= bc.runid;
	controlPort	:= bc.controlPort;
	product		:= bc.product;
	rapHost		:= bc.rapHost;
	appServerHost:= bc.appServerHost;
	schemaName	:= bc.schemaName;
	appName		:= bc.appName;
	appServers	:= bc.appServers;
	bmkBasePort	:= bc.bmkBasePort;
	systemFolder:= bc.systemFolder;
	binFolder	:= bc.binFolder;
	iniFileName	:= bc.iniFileName;
	commitTransaction;
end;</source>
        <Parameter name="sess" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="countEverything" id="fb9c4488-96c6-4ae9-a375-d7b4194a869b">
        <updating/>
        <source>countEverything(bc:BmkControlSession):String updating;

vars
	nOde:Node;  proc:Process;
	i,j,k,l,m,n,totalCopies:Integer;
	s,myCreatorName:String;
	cre:Creator;
begin
	myCreatorName:=session.asCreatorName;
	s:="app/instId           copies    profile              appSeqNum    port    user@host"&amp;CrLf;
	create cre;
	cre.setSession(session);
//	foreach nOde in system.nodes do
//		if nOde.isApplicationServer then
//			foreach proc in nOde.processes do
			foreach proc in Process.instances do
				if proc.persistentApp.name=myCreatorName and proc&lt;&gt;process then
					l:=l+1;
//	system.forceOffUser(nOde,proc);  // only to kill stragglers!!
					cre.computerName:=proc.userInfo;
					cre.userCode:=proc.getUserCode;
					cre.setAppSequenceId(proc);
					if session = 0 then
						cre.targetSession:=bc.session;
						cre.setInfo_Creator;
					else
						cre.setInfo;
					endif;
					if cre.copies &gt; 0 then
						totalCopies:=totalCopies+cre.copies;
					endif;
					if cre.copies &lt;&gt; 0 or bc &lt;&gt; null and bc.session = 20 then
						s:=s&amp;(myCreatorName&amp;"/"&amp;getInstanceIdForObject(proc).String&amp;": ").padBlanks(21)
								&amp;cre.copies.String.rightAlign(4)&amp;"      "
								&amp;cre.profile.padBlanks(22)[1:22]
								&amp;cre.appSequenceId.String.rightAlign(5)
								&amp;cre.port.String.rightAlign(12)&amp;"   "
								&amp;(proc.userCode&amp;"@"&amp;proc.userInfo)&amp;CrLf;
					endif;
				endif;
			endforeach;
//		endif;
//	endforeach;
	s:=s&amp;CrLf&amp;session.asCreatorName&amp;"s: "&amp;l.String&amp;", total copies: "&amp;totalCopies.String&amp;CrLf;
	return s;
epilog
	delete cre;
end;</source>
        <Parameter name="bc" type="BmkControlSession"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductConfig" id="74b3ecb7-a1ec-4f3c-bd0d-a9a09f8856d4">
        <source>getProductConfig(product:String):String;

vars
	f:File;
begin
	create f transient;
	f.fileName := "c:\thinbin\tools\configuration\" &amp; product &amp; ".conf";
	return f.readString(f.fileLength);
epilog
	f.close;
	delete f;
end;
</source>
        <Parameter name="product" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initSession" id="b4aea085-a243-451c-97e3-73db71501b97">
        <updating/>
        <source>initSession(_product,_runName,_envid,_runid,_archive,_developerEmail,_numClients,_totalRuns:String) updating;

vars
	dbdir,productConfig:String;
begin
	productConfig := getProductConfig(_product);

	beginTransaction;
	product			:= _product[1:product.maxLength];
	owner			:= process.getUserCode;
	runName			:= _runName;
	envid				:= _envid[1:envid.maxLength];
	runid				:= _runid[1:runid.maxLength];
	archive			:= _archive;
	developerEmail	:= _developerEmail;
	numClients		:= productConfig.getXMLValue("NumClients").Integer;
	if numClients = 0 then
		numClients	:= _numClients.Integer;
	endif;
	totalRuns		:= _totalRuns.Integer;
	
	rapHost			:= app.computerName.toLower;
	appServerHost	:= rapHost;
	bmkBasePort	:= "51700";
	appServers		:= productConfig.getXMLValue("appservers").Integer;
	controlPort		:= productConfig.getXMLValue("controlport");
	
	schemaName	:= "JtdDriverSchema";
	appName		:= "JtdDriverExternalCloneApp";
	
	dbdir				:= "T:\" &amp; _envid &amp; "\server\";
	systemFolder	:= dbdir &amp; "c_system";
	binFolder		:= dbdir &amp; "c_bin";
	iniFileName		:= dbdir &amp; "c_bin\" &amp; envid &amp; ".ini";
	
	currentRun		:= 0;
	commitTransaction;
end;</source>
        <Parameter name="_product" type="String"/>
        <Parameter name="_runName" type="String"/>
        <Parameter name="_envid" type="String"/>
        <Parameter name="_runid" type="String"/>
        <Parameter name="_archive" type="String"/>
        <Parameter name="_developerEmail" type="String"/>
        <Parameter name="_numClients" type="String"/>
        <Parameter name="_totalRuns" type="String"/>
    </JadeMethod>
    <JadeMethod name="modifyIniFile" id="6a9c98ae-c7ed-4e4d-9771-8bee51c17299">
        <source>modifyIniFile(iniFileName,section,key,value:String; readOnly:Boolean);

begin
	write app.getProfileString(iniFileName, section, key, null);
	if not readOnly then
		      app.setProfileString(iniFileName, section, key, value);
		write app.getProfileString(iniFileName, section, key, null)&amp;CrLf;
	endif;
end;</source>
        <Parameter name="iniFileName" type="String"/>
        <Parameter name="section" type="String"/>
        <Parameter name="key" type="String"/>
        <Parameter name="value" type="String"/>
        <Parameter name="readOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="relinquish" id="de82fe5d-e425-410c-b1fb-22dd5c25f2c8">
        <updating/>
        <source>relinquish() updating;

begin
	beginTransaction;
	owner:="";
	commitTransaction;
	write CrLf&amp;"Session relinquished!";
end;</source>
    </JadeMethod>
    <JadeMethod name="setParams" id="63832d55-3916-46d6-b134-864f8662ee0d">
        <updating/>
        <source>setParams(_envid,_host,_runid,_controlPort,_product,_schemaName,_appName:String;
		  _appServers:Integer; _bmkBasePort,_rapHost,_systemFolder,_binFolder,_iniFileName:String) updating;

begin
	beginTransaction;
//	owner		:= app.computerName.toLower;
	owner		:= process.getUserCode;
	envid		:= _envid;
	runid		:= _runid;
	controlPort	:= _controlPort;
	product		:= _product;
	rapHost		:= _rapHost;
	appServerHost:= _host;
	schemaName	:= _schemaName;
	appName		:= _appName;
	appServers	:= _appServers;
	bmkBasePort	:= _bmkBasePort;
	systemFolder:= _systemFolder;
	binFolder	:= _binFolder;
	iniFileName	:= _iniFileName;
	commitTransaction;
end;</source>
        <Parameter name="_envid" type="String"/>
        <Parameter name="_host" type="String"/>
        <Parameter name="_runid" type="String"/>
        <Parameter name="_controlPort" type="String"/>
        <Parameter name="_product" type="String"/>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_appName" type="String"/>
        <Parameter name="_appServers" type="Integer"/>
        <Parameter name="_bmkBasePort" type="String"/>
        <Parameter name="_rapHost" type="String"/>
        <Parameter name="_systemFolder" type="String"/>
        <Parameter name="_binFolder" type="String"/>
        <Parameter name="_iniFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setParamsShort" id="9893dfae-cf36-4589-ad90-85859f244416">
        <updating/>
        <source>setParamsShort(_driveLetter,_envid,_runid,_controlPort,_product,_rapHost:String; _appServers:Integer) updating;

vars
	dbdir:String;
begin
	beginTransaction;
	owner := process.getUserCode;
	envid := _envid[1:envid.maxLength];
	runid := _runid[1:runid.maxLength];
	if runid = null then
		runid:=envid[5:end];  // default to Jade release level
	endif;
	runid := runid.replace("\base_", "\" &amp; envid[5:end] &amp; "_").replace("\upg_", "\" &amp; envid[5:end] &amp; "_");
	
	controlPort	:= _controlPort[1:controlPort.maxLength];
	product		:= _product[1:product.maxLength];
	rapHost		:= _rapHost[1:rapHost.maxLength];
	
	schemaName	:= "JtdDriverSchema";
	appName		:= "JtdDriverExternalCloneApp";
	
	appServerHost:=rapHost;
	
	appServers	:= _appServers;
	bmkBasePort	:= "51700";
	dbdir:=_driveLetter&amp;":\"&amp;_envid&amp;"\server\";
	systemFolder:= dbdir&amp;"c_system";
	binFolder	:= dbdir&amp;"c_bin";
	iniFileName	:= dbdir&amp;"c_bin\"&amp;envid&amp;".ini";
	commitTransaction;
end;</source>
        <Parameter name="_driveLetter" type="String"/>
        <Parameter name="_envid" type="String"/>
        <Parameter name="_runid" type="String"/>
        <Parameter name="_controlPort" type="String"/>
        <Parameter name="_product" type="String"/>
        <Parameter name="_rapHost" type="String"/>
        <Parameter name="_appServers" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="show" id="aa32f847-4278-453b-8f3e-c0c217253b5a">
        <updating/>
        <source>show() updating;

begin
	write "session "&amp;session.String&amp;CrLf&amp;"owner="&amp; owner;
	write "envid="&amp; envid&amp;CrLf&amp;"appserver="&amp; appServerHost;
	write "schema="&amp; schemaName &amp;CrLf&amp;"app="&amp; appName;
end;</source>
    </JadeMethod>
</Class>
