    <JadeMethod name="getAllTrackedItems" id="0809ee1b-b587-4034-b6cf-fbc5f421ffa4">
        <source>getAllTrackedItems(_collection : Collection input; _checkCargoGroup : Boolean);
/*

Purpose: 	This method returns all tracked items in this Reserve details as well as all tracked items in the cargo group

Parameters:			

Return Value:		

Date		Who		Reason
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
17/12/2024	jlizm1	MTN 33632 Truck loader unloader ignoring cargo group after first load

*/

vars

begin
	if _collection = null then
		return;
	endif;

	_collection.clear();
	
	self.allTrackedItems.copy(_collection);
	
	if not _checkCargoGroup or self.isAllocationById()  then
		return;
	endif;
	
	if self.myCargoGroup &lt;&gt; null then
		self.myCargoGroup.allAssignedTrackedItems.copyNoDups(_collection);
	endif;
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_checkCargoGroup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItemsSize" id="757c7512-da7d-4457-912f-2fcc6cb99cf9">
        <source>getAllTrackedItemsSize(_checkCargoGroup : Boolean) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

*/

vars
	size : Integer;
	allTis	: CM_TISet;
	
begin
	
	size := self.allTrackedItems.size();
	
	if self.isAllocationById() or not _checkCargoGroup then
		return size;
	endif;
	
	if self.myCargoGroup &lt;&gt; null then
		size += self.myCargoGroup.allAssignedTrackedItems.size();
	endif;
	
	return size;	
	
epilog

end;</source>
        <Parameter name="_checkCargoGroup" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAssignedAmountHolds" id="01626d5a-9666-49ee-99c4-27019afa25d9">
        <source>getAssignedAmountHolds() : Integer;
/*
Purpose:			
Date				Who		Reason
09 March 2017		cnwab1	Initial creation
31 October 2025		jlizm1	MTN 36255 Rotabox Assign Release To Vessel
*/

vars

	theAmount : Integer;
	req : CM_VoyageRequest;
	wle : CM_WorkListEntry;
begin

	theAmount := self.totalRequested;
	foreach req in self.allVoyageRequestsAssigned discreteLock do
		foreach wle in req.allWorkListEntries discreteLock do
			if wle.quantity &lt; 1 and wle.myTrackedItem &lt;&gt; null then //jlier1 14/1/26 JIRA-36877
				theAmount := theAmount - 1;
			else
				theAmount := theAmount - wle.quantity;
			endif;
		endforeach;
	endforeach;
	
	return theAmount;
	


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAvailGradesForReport" id="1b8f1679-7db3-4dd1-94d3-188849f05a18">
        <source>getAvailGradesForReport() : String;
//----------------------------------------------------------------------
//
//  Created by cnwar2
//
//	Date 02 October 2007
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//----------------------------------------------------------------------

vars
	str : String;
	ti	: CM_TrackedItem;
	
begin
	if self.isAllocationById then
		//ti := self.allTrackedItems.first;
		ti := self.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
		if CM_Container.hasInstance(ti) then
			return ti.CM_Container.availabilityGradeDescription;
		endif;
		return null;
		
	else
		//Work around for reports as report writer will only use the first 100 chars of a string for dyna dict keys.  //Par15009 Par46096
		str := self.CM_ReserveSelection.getAvailabilityGradesDescr();
		return str[1:100];
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
