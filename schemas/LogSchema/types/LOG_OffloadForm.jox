    <JadeMethod name="doSave" id="0b89b9e4-3780-4c07-b429-29f361a6baa7">
        <updating/>
        <source>doSave() : Boolean protected, updating;

vars
	result					: Integer;
	tmpTIs			 		: CM_TISet;
	def						: CMIF_DocketLogDef;
	array					: CMIF_DocketLogDefByLocation;
	//array2					: CM_TISet;
	rowSOHLocation			: CM_SOHLocation;
	rtnValue				: Boolean;
	cancelSave				: Boolean;
	ti						: CM_TrackedItem;	
	row, 
	numRows : Integer;
begin
	// Sep 2011 28082 don't allow save for closed etc voyages
	if self.myLogVoyage.isClosedStatus() then
		app.msgBox("This voyage status is " &amp; self.myLogVoyage.statusDescription &amp; "," &amp; CrLf &amp; "no updates are allowed.", "Error", 0);
		return false;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	create tmpTIs transient;
	if self.selection = DOCKET then
		create array transient;
		self.getSelectedDefs(array);
		foreach def in array do
			def.allTi.copy(tmpTIs);
		endforeach;
		
	elseif self.selection = TICKET then
		if self.myLog &lt;&gt; null then
			tmpTIs.add(self.myLog);
		endif;
		
	elseif self.selection = LOT then
		// par #18033 cnwrd1 30.9.08 - changed to handle multiple LOT moves.
		numRows := self.tblSelectData.rows;
		foreach row in 2 to numRows do
			if self.tblSelectData.accessCell(row, 1).text = '1' then
			//row selected so add to tmpTIs
				rowSOHLocation := self.tblSelectData.accessRow(row).itemObject.CM_SOHLocation;
				rowSOHLocation.allTrackedItems.copy(tmpTIs);
			endif;
		endforeach;
		
		/*
		// -- old code for single reference to one LOT
		if self.mySOHLocation &lt;&gt; null then
			self.mySOHLocation.allTrackedItems.copy(tmpTIs);
		endif;
		*/
		
	elseif self.selection = NONUMBER then
		/*create array2 transient;		//commented by PAR 51211 Oct 2009. It is moved below where trx are processed.
		self.getSelectedLogs(array2);
		rtnValue := self.doDeleteNoNumbers(array2);
		return true;*/
		self.getSelectedLogs(tmpTIs);	//PAR 51211 Oct 2009

		
	elseif self.selection = LOGDETAIL then
		self.getSelectedLogs(tmpTIs);
	endif;

	// ccms 1107 / PAR21511 - need to organize warnings to a user. Moved here from epilog
	if tmpTIs.size = 0 then	// removed from epilog section
		app.addErrorFullPassport(NoItemsSelected, app.getErrorString(NoItemsSelected), null, null, app.myPassport);
		app.showErrorWarningDialog('Offload', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	endif;
	
	// ccms 1107 / PAR21511 - need to organize warnings to a user
	while true do
	
		if self.selection = NONUMBER then
			rtnValue := self.doDeleteNoNumbers(tmpTIs);
		else
			app.myTrxUA.trxReceiveFromShip(tmpTIs, self.cmbLocation.listObject.CM_LocationsController, app.myPassport);
			rtnValue := app.myPassport.trxCompletedOK;
		endif;
	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;

		else
			result := app.showErrorWarningDialog('Off-Load', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
			
		endif;
		
	endwhile;

	
	if rtnValue then
		if self.selection = LOGDETAIL then
			self.selection := DOCKET;
			self.loadSelectionData();
		elseif self.selection = TICKET then
			self.clearAll(false);
		else
			self.doFind();
		endif;
	endif;
	
	return rtnValue;
	

epilog

	delete tmpTIs;
	delete array;
	//delete array2;
	app.mousePointer := MousePointer_Default;	
	/*if self.selection = LOGDETAIL then	//commented by PAR21511 - moved from epilog to above
		self.selection := DOCKET;
		self.loadSelectionData();
	endif;
	if (not rtnValue) then
		app.showErrorWarningDialog('Offload', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	else
		self.clearErrorWarnings();
		if not self.selection = TICKET then
			doFind();
		else
			self.clearAll(false);
		endif;
		return true;
	endif;*/
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowDetail" id="8b5ef4b2-0884-4e3f-9a69-62e0d99247a0">
        <updating/>
        <source>doShowDetail() protected, updating;

vars

	array			: CMIF_DocketLogDefByLocation;
	def				: CMIF_DocketLogDef;
	ti				: CM_TrackedItem;
	log				: CM_Log;

begin

	create array transient;	
	self.allLogs.clear;
	self.getSelectedDefs(array);
	if array.size = 0 then
		return;
	endif;
	self.tblSelectData.setColumnHeadingsFromDef(ETDef_TAOffLoadViewTickets, false);	
	self.tblSelectData.userInputEnabled := true;	
	self.selection := LOGDETAIL;
	foreach def in array do
		if def.myLocationsController.isKindOf(CM_LogVoyageController) then
			foreach ti in def.allTi do
				log := ti.CM_Log;
				self.addDetailLine(log.displayDetail);
				self.allLogs.add(log);
			endforeach;
		endif;
	endforeach;		
	
epilog	
	delete array;
end;</source>
        <access>protected</access>
    </JadeMethod>
