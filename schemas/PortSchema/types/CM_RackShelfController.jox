    <JadeMethod name="myTerminalArea" id="3d3a94d1-e891-4cc0-97dc-0ab889aa10df">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myTerminalArea(set: Boolean; _value: CM_TerminalArea io) updating, mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2013	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod(set, _value);
	
	if not set then
		//epr par 35685 13/2/15
		if self.myTerminalArea = null and  self.myLocation &lt;&gt; null then
			_value := self.myLocation.myTerminalArea;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_TerminalArea" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setDefaultProxy" id="1dd38a06-f707-4949-9572-57949f5195f1">
        <updating/>
        <source>setDefaultProxy( _index : Integer; _lc : CM_IrregularBlockController; _realRack : CM_IrregularBlockController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars
	sub : CM_RackShelfController;
begin

	self.locationOrdinal := _index;

		// PAR 32836
	if _realRack &lt;&gt; null then
		if _index &gt; 0 and _index &lt;= _realRack.allSubLocations.size then
			sub := _realRack.allSubLocations[_index];
			if sub &lt;&gt; null then
				self.ident := sub.ident;
			endif;
		endif;
	endif;

	if self.ident = null then // PAR 32836
		self.ident := _index.padLeadingWith("0",2);
	endif;
	
	self.defaultCapacity := 0;
	self.locationType := GC_ShelfLocation;
	self.maximumWeight := 0;
	self.myAssociatedInterchangeArea := _lc.myAssociatedInterchangeArea;
	
	self.myLocation := _lc;
	
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_lc" type="CM_IrregularBlockController"/>
        <Parameter name="_realRack" type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d8495f34-d3a8-4160-b407-f1aa53e50cc0">
        <updating/>
        <source>setForUpdate(controllerProxy: CM_IrregularBlockController; pTerminalArea: CM_TerminalArea) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod(controllerProxy, pTerminalArea);

	if self.myLocation &lt;&gt; null and self.colour = self.myLocation.colour then
		// we are the same colour as our parent area, use theirs ( allows defaulting to continue.)
		self.colour := 0;
	endif;
	if self.myLocation &lt;&gt; null and self.myAssociatedInterchangeArea = self.myLocation.myAssociatedInterchangeArea then
		// we have the same IC Area as our parent area, use theirs ( allows defaulting to continue.)
		self.myAssociatedInterchangeArea := null;
	endif;

epilog

end;</source>
        <Parameter name="controllerProxy" type="CM_IrregularBlockController"/>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateMaximums" id="e870a700-f47b-4126-a2a0-57fd5182c721">
        <updating/>
        <source>setForUpdateMaximums(_maxCapacity : Integer; _maxWeight : Real; _defaultCapacity : Integer) updating;
/*
Purpose:			
Date		Who		Reason
18 September 2013	cnwab1	Initial creation
*/

vars

begin
//	self.maxCapacity := _maxCapacity;
	self.setYAMaxCapacity(  _maxCapacity );	//22 Jul 2020	NDL	TFS 49775
	self.defaultCapacity := _defaultCapacity;
