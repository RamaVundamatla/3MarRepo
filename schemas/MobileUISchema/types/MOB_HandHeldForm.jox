    <JadeMethod name="doAttachPhoto" id="8f1ced29-a742-4d61-97cb-8162d8467b1d">
        <source>doAttachPhoto( _ti : CM_TrackedItem; _useCameraIfAvailable : Boolean);

/*

Purpose:			Attach a photo to the currently selected TI

Parameters:			Whether or not an attempt to fire up an inbuilt camera on the device

Return Value:		None


Date		Who		Reason
29 Jan 2010	cnwdz2	CCMS MES 1005 par 22294
17 Mar 2010	cnwkpd1	PAR #23221 - Integrate camera using external exe
25 Mar 2010	cnwkpd1	PAR #23415 - Add parameter to control camera use, and check OS version is
					compatible with the camera
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

constants
	
	PictureTaken	= 0;
	PictureCancelled = 1;
	MinimumOSVersion = "5.2";
	MinWindows8 = "6.1";
	CameraAppName ="JadeCam";
vars
	pic 			: CMDFileOpen;
//	ti  			: CM_TrackedItem;
		
	errorMsg		: String;
	photoForm 		: MOB_CargoPhotoForm;
	
	result,
	result2			: Integer;
	args			: StringArray;
	jadeDir,
	photoDir,
	photoName,
	photoFileName,
	appName			: String;
	testPhotoFile	: File;
	
	osVersion		: String;
	osArchitecture	: Integer;
	osPlatform 		: Integer;
	cmdFile 		: CMDFileOpen;
	isWindows		: Boolean;		
begin

	if _ti = null then
		return;
	endif;
	
	
	// PAR #23422 - Only try the camera if required, and OS version is compatible
	osPlatform:=process.getOSPlatform(osVersion, osArchitecture);
	app.writeLog("OS Version check, osVersion=" &amp; osVersion &amp; ", osArchitecture=" &amp; osArchitecture.String, 0);
	if  (_useCameraIfAvailable and osVersion.Real &gt;= MinimumOSVersion.Real) then
		
		// PAR #23221 - First try to run the external camera with a temporary file name
		photoDir := app.getTempDir(); //PAR22336 - presentation client executed so no need for app.getTempDirFromSystemConfig
		photoName := "JadePhoto" &amp; app.actualTimeServer().getNumeralString() &amp; ".jpg";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		photoFileName := photoDir &amp; photoName;
		write photoDir;
		create args transient;
		if osVersion.Real &gt;= MinWindows8.Real then
			args.add( photoDir );
		else
			args.add('"' &amp; photoDir &amp; '"');
		endif;
		args.add(photoName);
	
		jadeDir := process.getJadeInstallDirectory();
		appName := '"' &amp; jadeDir &amp; CameraAppName &amp; '"';
		
		app.writeLog("Running thin client command " &amp; jadeDir &amp; " " &amp; appName &amp; " " &amp; args.concatenate(" "), 0);
	
		result := node.createExternalProcess(jadeDir,
											 appName,
											 args,
											 null,
											 true,
											 true,
											 result2);
											 
		app.writeLog("Returned from " &amp; CameraAppName &amp; ", result=" &amp; result.String &amp; ", result2=" &amp; result2.String, 0);
		
		// If the camera executable returns OK, check that the file can be found
		if result = Node.ExternalProcess_Successful then
			if result2 = PictureTaken then
				create testPhotoFile transient;
				testPhotoFile.fileName := photoFileName;
				if not testPhotoFile.isAvailable() then
					app.writeLog("File " &amp; photoFileName &amp; " returned from " &amp; CameraAppName &amp; " is not available", 0);
					photoFileName := null;
				endif;
			else
				// Some kind of exception case from the camera, or the user cancelled the camera
				photoFileName := null;
			endif;	
		
		else
			// Camera didn't return OK, so need to manually select a file
			photoFileName := null;
		endif;
		
	elseif app.isDevelopmentSystem() then
		// CNWRS2 - 4 Feb 2011 - add in so can test in dev environment
		create cmdFile transient;
		cmdFile.filter := "Photos(*.bmp;*.BMP;*.tif;*.TIF;*.tiff;*.TIFF;*.jpeg;*.JPEG;*.jpg;*.JPG;*.png;*.PNG; *.gif;*.GIF)|*.bmp;*.BMP;*.tif;*.TIF;*.tiff;*.TIFF;*.jpeg;*.JPEG;*.jpg;*.JPG;*.png;*.PNG;*.gif;*.GIF";
		if cmdFile.open = 0 then
			photoFileName := cmdFile.fileName;
		endif;
	endif;
	
	// If we haven't go a valid photo file name yet, then ask for one
	if photoFileName = null then
		create pic transient;
		pic.filter := PHOTO_TYPE_FILTER;
		if pic.open = 0 then
			photoFileName := pic.fileName;
		endif;
	endif;

	on FileException do self.xHandlerFileOpen(exception, errorMsg);

	// All OK, so open form to save photo to DB
	if photoFileName &lt;&gt; null then
		
		errorMsg	:=	null;

		create photoForm transient;
		photoForm.setPicFileName(photoFileName);
		photoForm.myTrackedItem := _ti;
		photoForm.showModal();
		
		if errorMsg &lt;&gt; null then
			app.msgBox(errorMsg, app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;	
	endif;

	// PAR #23221 - If we created a photo, and it is still available, then delete the file
	if testPhotoFile &lt;&gt; null and testPhotoFile.isAvailable() then
		testPhotoFile.purge();
	endif;
	
		
epilog
	delete pic;
	delete photoForm;
	delete args;
	delete testPhotoFile;
	delete cmdFile;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_useCameraIfAvailable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBackButtonClick" id="99cca116-f69c-4c8b-815f-6d5575687a7c">
        <final/>
        <updating/>
        <source>doBackButtonClick() protected, updating, final;
/*
Date		Who		Reason
29 January 2009	cnwcp2	Initial creation
*/

vars

	msg : String;

begin

	//02 Feb 2011	NDL	Par 26843
	if self.hasUnsavedChanges() then
		msg := self.hasUnsavedChangesMessage;
		if self.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;
	
	self.getSessionAgent().setMyProxy( null ); // delete any proxy created
	self.gotoForm(self.getSessionAgent.getPreviousForm, true);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDischargeToGroundTrx" id="0e46ac70-87d2-459c-bd89-956004783745">
        <source>doDischargeToGroundTrx(	_groundOption : Integer;	
						_ti : CM_TrackedItem input;
						groundLocation : CM_LocationsController input;
						_job : CM_VoyageJob;
						_wle : CM_WorkListEntry input;
						_quantity : Integer;
						_weight : Decimal
						):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 June 2012	cnwndl1	Initial creation	Par 29745
01 Apr 2014	NDl	CCMS 1366

*/

vars	
	newId : String;
	quantity : Integer;
	result : Integer;
	weight : Decimal [16,4];
	doSplit : Boolean;
	originalTarget : CM_LocationsController;
	newTi : CM_TrackedItem;
	newJob : CM_VoyageJob;
	existingWle : CM_WorkListEntry;
	newWle : CM_WorkListEntry;
	willMerge : Boolean;	//27 Apr 2016	NDL	TFS 1809

begin

	newTi := groundLocation.allTrackedItemsById.getAtKey( _ti.id, _ti.cargoType );	//27 Apr 2016	NDL	TFS 1809
	willMerge := newTi &lt;&gt; null;	//27 Apr 2016	NDL	TFS 1809


	if _ti.canSplitTotalQuantity or willMerge then	//27 Apr 2016	NDL	TFS 1809
		
		newId := _ti.id;
	
		if _ti.isBulkByWeight or _ti.isBulkByVolume then
			weight := _weight;
			if weight = 0 then
				weight := _ti.totalWeight;
			else
				doSplit := true;
			endif;
		endif;
		quantity := _quantity;
		if quantity = 0 then
			quantity := _ti.totalQuantity;
		endif;
		

		if ( quantity &lt;&gt; _ti.totalQuantity ) or ( newId &lt;&gt; _ti.id ) or doSplit or willMerge then //27 Apr 2016	NDL	TFS 1809
			//we are trying to do a split
			if _groundOption = GroundInTransit then		
				//12 Apr 2016	NDL	TFS 1809
				if _wle &lt;&gt; null then
					originalTarget := _wle.getTargetLocation;
					if originalTarget = groundLocation then
						originalTarget := null;
					endif;
				endif;
							
			endif;
			//epr par 35862 13/3/15
			if not self.myMobileGenericAgent.moveTI(_ti,null,groundLocation,_wle,true,quantity, weight, null) then
				return false;
			endif;
			
			//12 Apr 2016	NDL	TFS 1809
			if originalTarget &lt;&gt; null then
			//	newTi := groundLocation.allTrackedItemsById.getAtKey( _ti.id, _ti.cargoType );
				//previous move consumed the wle, queue the new one, or increment the existing move amount if its merged.
				if newTi &lt;&gt; null then					
					if (( _ti.isBulkByWeight or _ti.isBulkByVolume) and newTi.totalWeight &lt;&gt; weight )
					or  (( not _ti.isBulkByWeight and not _ti.isBulkByVolume) and newTi.totalQuantity &lt;&gt; quantity )
					then 
						//the split one from aboove has been merged
						existingWle := newTi.findExistingWleTo( originalTarget );
						if existingWle = null then
							self.myMobileGenericAgent.doQueueUnplannedUnworkedCargo(newTi, newJob, newWle, quantity, weight, originalTarget);
						else
							if newTi.myCargoType.isBreakBulkMulti then
								app.myTrxUA.trxAmendBreakBulkRTQuantity( existingWle, (existingWle.quantity + quantity), app.myPassport);	
							elseif newTi.myCargoType.isBulkMulti then
								app.myTrxUA.trxAmendBreakBulkRTWeight( existingWle, (existingWle.weight + weight), app.myPassport );
							endif;
						endif;
						
					else
						self.myMobileGenericAgent.doQueueUnplannedUnworkedCargo(newTi, newJob, newWle, quantity, weight, originalTarget);
					endif;
				endif;
			
				if app.myPassport.hasErrors then
					return false;
				endif;
				
			endif;
			

			self.myMobileGenericAgent.setSplitValues( 0, 0, null );
			return true;
		endif;
	endif;

	while true do
		app.myTrxUA.trxLanderDischargeToGround(_groundOption, _ti, groundLocation, _job, _wle, app.myPassport);
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			self.myMobileGenericAgent.setSplitValues( 0, 0, null );
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

epilog

end;</source>
        <Parameter name="_groundOption" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="groundLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHandleTblCargoChecksClick" id="945e805b-7795-4adf-a044-37781a97c0a8">
        <updating/>
        <source>doHandleTblCargoChecksClick(_agent : MOB_HandHeldCheckerAgent input;
							_table: CM_MobEntryTable input;
							_displayOnly: Boolean;
							_otherObject : CM_Object
							) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Feb 2010	cnwdap1	Initial creation
24 Mar 2010	cnwkpd1	PAR #23415 - Fix Select a Photo option by ensuring listIndex is set correctly
					And add parameter to control camera use

*/

vars
	formToDisplay	: Class;
	idx				: Integer;
	ti : CM_TrackedItem;
	
begin
	formToDisplay := _agent.doEquipmentCheckTableClick(_table, _displayOnly, self.btnTick, self.btnCross, self.btnTickDown, self.btnCrossDown, _otherObject );
	if formToDisplay &lt;&gt; null then
		if formToDisplay = MOB_CargoPhotoForm then
			ti := self.myMobileGenericAgent.myNextTiToAction;
						
			self.doAttachPhoto( ti, self.canTakePhoto() );	// PAR #23422
			
			// 06 Jan 2011	NDL	Par 26539
			// adding a photo updates the edition ( but only if it is the first attachment ), then not 
			// calling "self.goToForm", means we don't go back thru setup when we return to the 
			// gate checker, so we need to reload the proxy to reset the edition correctly.
			if self.isKindOf(MOB_HHGateCheckCargo) then
				app.myMobileAgent.setMyProxy( self.MOB_HHGateCheckCargo.myTrackedItem );
			elseif self.isKindOf(MOB_HHShipLanderCargo) then
				app.myMobileAgent.setMyProxy( self.MOB_HHShipLanderCargo.myTrackedItem );
			endif;
			
		else
			self.gotoForm(formToDisplay, false);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_agent" type="MOB_HandHeldCheckerAgent" usage="input"/>
        <Parameter name="_table" type="CM_MobEntryTable" usage="input"/>
        <Parameter name="_displayOnly" type="Boolean"/>
        <Parameter name="_otherObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doIsoTypeChange" id="3914b317-f345-4dff-a90b-320158461ca8">
        <source>doIsoTypeChange( 	_newIsoType : CM_ISOType;
					_realTrackedItem : CM_TrackedItem io;
					_updated : Boolean output
					): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
					Change 2nd cmsBeginLoad to cmsEndLoad
*/

vars

	pxyTi : CM_TrackedItem;
	isLoadStateSet : Boolean;
	result : Integer;
	warning : String;
	job : CM_Job;
	
begin

	if _newIsoType = null then
		return 1;
	endif;
	
	if _realTrackedItem = null then
		return 1;
	endif;
	
	if _newIsoType = _realTrackedItem.getISOTypeObject then
		return 1;
	endif;
	
	
	warning := app.getErrorString(Change_ISOType_Continue);
	app.mousePointer :=	Idle;
	if self.msgBox(warning ,app.getErrorString(Warning), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
		return 1;
	endif;
	app.mousePointer :=	Busy;
	app.cmsBeginLoad(isLoadStateSet);
	pxyTi := _realTrackedItem.pxyCreateUpdateProxy();
	pxyTi.setISOType(_newIsoType.code);
	pxyTi.setSizeAndTypeAttibutesYA(_newIsoType);
	app.cmsEndLoad(isLoadStateSet);
	
	while true do

		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxUpdateTrackedItem(	pxyTi,
											null,
											TI_UPDMODE_NORMAL, 
											null, 
											app.myPassport);


		if app.myPassport.trxCompletedOK then
			result := IDOK;
			break;
		else
			app.mousePointer :=	Idle;
			result := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				app.mousePointer :=	Busy;
				continue;
			endif;
		endif;
		break;
		
	endwhile;
	
	return result;
	
	
epilog
	app.cmsEndLoad(isLoadStateSet);		// 08/04/2011 cnwmh5 #27347
	delete pxyTi;
	app.mousePointer :=	Idle;
end;</source>
        <Parameter name="_newIsoType" type="CM_ISOType"/>
        <Parameter name="_realTrackedItem" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_updated" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPrintCargoLabel" id="430c2a79-aed4-49f0-8e0c-b2629a4c0add">
        <source>doPrintCargoLabel(_ti: CM_TrackedItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars
	printerId	: String;
	rtDevice	: CM_RadioTelemetryDevice;
	errorMess : String;
	thePrinter : CM_PrinterDef;
	printers : StringArray;

begin

	rtDevice := app.myLogonAgent.myRTDevice;
	if rtDevice &lt;&gt; null then
		thePrinter := rtDevice.myLabelPrinter;
	endif;
			
	if thePrinter = null then
		errorMess := app.getErrorString1(Need_Server_Printer, "Label Printer");
		self.msgBox(errorMess, app.getErrorString(Printing_error), MsgBox_OK_Only, true);
	
	else
		create printers transient;
		self.getServerPrinters( printers );

	//	if not app.isDevelopmentSystem and		// FOR TESTING 
		if  not printers.includes( thePrinter.physicalPrinterName.trimBlanks ) then
			errorMess := app.getErrorString2(Unknown_Server_Printer, thePrinter.physicalPrinterName.trimBlanks, printerId);
			self.msgBox(errorMess, app.getErrorString(Printing_error), MsgBox_OK_Only, true);

		else
			_ti.printHHCargoLabel(thePrinter.physicalPrinterName );
			if (not app.myPassport.trxCompletedOK) then
				errorMess := app.myPassport.getAllErrorsWarningsAsString;
				self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
			endif;
		endif;
	endif;

epilog
	delete printers;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doProcessRoadExit_CheckLocn" id="bf10076f-1ef5-488c-8ecb-ed6960798ab7">
        <source>doProcessRoadExit_CheckLocn(_vehicle: CM_Vehicle; _skipGateCheck : Boolean): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2016	cnwndl1	Initial creation		TFS 1593 - moved up 

*/

vars
	obj		:Object;
	job		:CM_RoadJob;
	gate	:CM_Gate;
	lc		:CM_YardController;
begin
	// we really only expect there to be one job for the vehicle and it should be complete
	foreach obj in _vehicle.allRoadJobs do
		job := obj.CM_RoadJob;
		
		if job.status &lt;&gt; JOB_COMPLETE then
			// par 21328 app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called for vehicle with incomplete job');
			self.msgBox(app.getErrorString (XLAT_Road_Exit_Error2), app.getErrorString(Error), MsgBox_OK_Only, true);	// par 21328 - 11/11/2009
			return false;
		endif;
		
		if not _skipGateCheck then	//04 Mar 2016	NDL	TFS 1593
			gate := job.getExitGate;
		endif;
		
		if gate &lt;&gt; null and gate.hasPGateAreas_OUT then
			lc := _vehicle.myPrimaryActualLocation;
			
			if not lc.isGateAreaLocation then
				// cannot road exit from yard
				self.msgBox (app.getErrorString (XLAT_Road_Exit_Error3), app.getErrorString(Error), MsgBox_OK_Only, true);
				return false;
			endif;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_skipGateCheck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
