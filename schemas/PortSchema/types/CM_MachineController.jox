    <JadeMethod name="isOverStowPossible" id="426881e3-e58d-4280-8404-383876be48de">
        <source>isOverStowPossible(): Boolean;

// Created by cnwdvb1 on 03 December 2007

vars

begin

	if self.myMachine = null then
		return false;
	endif;
	
	return self.myMachine.isTandemLift;

end;</source>
