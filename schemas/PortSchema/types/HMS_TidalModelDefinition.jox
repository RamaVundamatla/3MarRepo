    <JadeMethod name="validateForUpdate" id="614afd8a-dccd-4e4f-a78a-f55df664db90">
        <source>validateForUpdate(_passport: CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
----------   ----------  --------------------------------------------------
*/
vars
	existingTidalData,
	tidalData			: HMS_TidalData;
	existingTidalDef,
	realTidalDef		: HMS_TidalModelDefinition;
	theDate,
	nextDate			: Date;
begin
	if self.code = null then
	// 	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null);

	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null);
		app.raiseCMException(Input_required_field_Desc, ETRow_Description,  null); // cnwdb2	PAR 35364

	endif;
	
	if self.dataType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Data Type', ETRow_DataType,  null);
		app.raiseCMException(Input_required_field_dataType, ETRow_DataType,  null); // cnwdb2	PAR 35364
	endif;

	if self.dataSource = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Data Source', ETRow_DataSource,  null);
		app.raiseCMException(Input_required_field_dataSrc, ETRow_DataSource,  null); // cnwdb2	PAR 35364

	endif;
	
	
	
	if self.dataType &lt;&gt; HMS_TidalDataType_HiLo and
	   self.dataType &lt;&gt; HMS_TidalDataType_Current and
	   self.dataType &lt;&gt; HMS_TidalDataType_Height and
	   self.dataType &lt;&gt; HMS_TidalDataType_TimeGap and 
	   self.dataType &lt;&gt; HMS_TidalDataType_TideRange and 
	   self.dataType &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled data type (' &amp; self.dataType.String &amp; ')');
		return;
	endif;
	
	//check for duplicates
	existingTidalDef := app.myRoot.allHMSTidalModelDefinitions[self.code];
	realTidalDef	 := self.pxyGetRealObject();
	
	//validate the fileType against the data type
	if self.dataSource = HMS_TidalDataSource_File or
	   self.dataSource = HMS_TidalDataSourceGetTideFile then //CCMS1640 cnwrs1 jan 2009
		if (self.fileType = HMS_TidalFile_QLD_Current and self.dataType &lt;&gt; HMS_TidalDataType_Current) or
		   (self.fileType = HMS_TidalFile_QLD_Height and self.dataType &lt;&gt; HMS_TidalDataType_Height) or
		   (self.fileType = HMS_TidalFile_QLD_HiLo and self.dataType &lt;&gt; HMS_TidalDataType_HiLo) then
			app.raiseCMException2(Data_type_selec_file_type_load,self.getDataTypeDescr(), self.getFileTypeDescr(), ETRow_DataType, null);
			return;
		endif;
		/*
		if realTidalDef &lt;&gt; null then
			foreach tidalData in self.allHMSTidalData do
				existingTidalData := realTidalDef.allHMSTidalData[tidalData.ts];
				if existingTidalData &lt;&gt; null then
					app.raiseCMWarning1(Full_Replacement_Message, 'Warning: Some of the tidal data loaded overlaps with existing data and will be over-written.', null, null, null);
					break;
				endif;
			endforeach;
		endif;
		*/
		if (not self.allHMSTidalData.isEmpty) and self.allHMSTidalData.first.getDataType &lt;&gt; self.dataType then
			app.raiseCMException1(Data_type_selec_does_match_typ,app.tidalFileTypeEnumToString(self.allHMSTidalData.first.getDataType), null, null);
		endif;
		
		foreach tidalData in self.allHMSTidalData do
			tidalData.validateForUpdate(_passport);
		endforeach;
	endif;
	
	if existingTidalDef &lt;&gt; null and
	   (realTidalDef = null or //in which case we are trying add a new one that is duplicate
	   existingTidalDef &lt;&gt; realTidalDef) //in which case we are trying update one to be same as another
	   then
		//app.raiseCMException2(DuplicateItem, "Tidal Model Definition", self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		// Tidal Model Definition already exists for %1 : Tidal_model_defini_alread_exis
		app.raiseCMException1(Tidal_model_defini_alread_exis, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
	endif;
	if self.dataSource = HMS_TidalDataSourceGetTideFile and //CCMS cnwrs1 jan 2009
		self.getTideFileName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Get Tide File Name', ETRow_GetTideFileName,  null);
		app.raiseCMException(Input_required_field_getTdeFle, ETRow_GetTideFileName,  null); // cnwdb2	PAR 35364
	endif;
end;


