    <JadeMethod name="rel831_Par34159" id="ac592b30-95e4-4f69-8de4-a0d2e9274428">
        <source>rel831_Par34159();
//
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
//
vars
	camProtocol : CM_CamProtocol;
	proxyCamProtocol : CM_CamProtocol;
	ls : Boolean;
begin
	app.initialize;
	foreach camProtocol in CM_CamProtocol.instances do
beginTransaction;
camProtocol.allRegisteredCargoTypes.clear;
commitTransaction;
		if camProtocol.allRegisteredCargoTypes = null or
		   camProtocol.allRegisteredCargoTypes.isEmpty then
			beginTransaction;
			camProtocol.setForJMT831_Par34159();
			commitTransaction;
/*			app.cmsBeginLoad(ls);
			proxyCamProtocol := camProtocol.pxyCreateUpdateProxy;
			proxyCamProtocol.allRegisteredCargoTypes.add(TI_CargoType_Container.String);
			if camProtocol.protocolDesc.isKindOf(CM_CamMskCODECODesc) then
				proxyCamProtocol.allRegisteredCargoTypes.add(TI_CargoType_Generator.String);
			endif;
			app.myTrxUA.trxUpdateCamProtocol(proxyCamProtocol, app.myPassport);
			if app.myPassport.hasErrors then
				app.msgBox(app.myPassport.getErrorsAndWarningsAsString, "Par31459 Failed", 0);
			endif;*/
		endif;
	endforeach;
epilog
	app.cmsEndLoad(ls);
end;
</source>
    </JadeMethod>
