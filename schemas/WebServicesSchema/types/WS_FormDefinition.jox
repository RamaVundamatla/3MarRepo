    <JadeMethod name="buildHazardsPopupGridPanel" id="66422789-d857-4a91-b7da-9d30d0770ebd">
        <updating/>
        <source>buildHazardsPopupGridPanel() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	#cnwdz2	 25439

*/
constants
	CODELABEL    	 : String = "Code";
	DESCRIPTINLABEL  : String = "Description";
	UNDGNUMLABEL     : String = "UNDG Numbers";
	LTDQTYLABEL      : String = "Ltd Qty";
	PACKINGLABEL	 : String = "Packing Grp";
vars
	response    : WS_TIHazardResponse;
	tmpTIHazard	: WS_TIHazard;
	hazClass	: CM_HazardClass;
	fieldDef    : WS_FieldDefinition;
begin
	self.formName := "Hazardous  Details";
	//CMUI_HazardsListTable loadHazardObjects no etrows for hazard table. 
	fieldDef := self.buildField(WS_TIHazard::code.name, CODELABEL, ControlType_TextBox, null, null, true, null, null, null, null, null, null);
	fieldDef.descAbbreviation := "*";
	self.buildField(WS_TIHazard::description.name, DESCRIPTINLABEL, ControlType_TextBox, null, null, true, null, null, null, null, null, null);
	fieldDef := self.buildField(WS_TIHazard::undgCodes.name, UNDGNUMLABEL, ControlType_TextBox, null, null, false, null, null, null, null, null, null);
	fieldDef.descAbbreviation := "(*)";
	fieldDef := self.buildField(WS_TIHazard::limitedQuantity.name, LTDQTYLABEL, ControlType_CheckBox, null, null, false, null, null, null, null, null, null);
	fieldDef.descAbbreviation := "L"; 
	
	//cnwmc5 - 16 July 2015 - PAR 36421 
	fieldDef := self.buildField(WS_TIHazard::packingGroup.name, PACKINGLABEL, ControlType_ComboBox, null, null, false, null, null, null, null, null, null);
	
	create response transient;
	foreach hazClass in app.myRoot.allHazardClasses do
		if hazClass.isNotAvailableForEntry then 
			continue;
		endif; 		
		
		create tmpTIHazard transient;
		tmpTIHazard.setProxyFromObject(hazClass);
		response.allTIHazards.add(tmpTIHazard);
	endforeach;
	
	self.myResponse.myEmbededFormDataResponse := response;
	self.proxySearchClassName := WS_TIHazard.name;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
