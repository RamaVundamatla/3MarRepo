    <JadeMethod name="zSetPxyCustomsSealNums" id="ce7ccffa-e38e-48eb-a64e-448715717bee">
        <updating/>
        <source>zSetPxyCustomsSealNums(_sealNums: StringArray) updating;
//----------------------------------------------------------------
//	Created:	13 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars
	str	: String;
	now : TimeStamp;
	sealNumCustomsValue : String;
begin
	self.raiseExceptionIfNotTransient(method);

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
/*	self.allCustomsSealNumbers.clear;
	self.sealNumCustoms := null;
	foreach str in _sealNums do
		if str.trimBlanks &lt;&gt; null then
			self.allCustomsSealNumbers.add(str.trimBlanks);
		endif;
	endforeach; */

	//16 Sep 2010	NDL	Par 25608 - remove references to 'allCustomsSealNumbers'
	foreach str in _sealNums do
		if str.trimBlanks &lt;&gt; null then
			if sealNumCustomsValue = null then
				sealNumCustomsValue := str.trimBlanks;
			else
				sealNumCustomsValue := sealNumCustomsValue &amp; "," &amp; str.trimBlanks;
			endif;
		endif;
	endforeach;
	
	self.createProxySealTIsFromRawData(	null,	//_sealNum : String;
										null,	//_prevSealNum : String;
										null,	//_sealNumShippers : String;
										null,	//_sealNumVent : String;
										sealNumCustomsValue,	//_sealNumCustoms : String;
										null,
										null,
										now	//_now : TimeStamp
										);

end;</source>
        <Parameter name="_sealNums" type="StringArray"/>
    </JadeMethod>
