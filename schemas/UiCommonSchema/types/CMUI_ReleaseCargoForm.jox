    <JadeMethod name="onReleaseRefChangedEmpty" id="4ad46106-c2e2-448a-b89a-9f357929fe80">
        <updating/>
        <source>onReleaseRefChangedEmpty() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwjk3	Initial creation

*/

vars

begin
	if self.hasBulkRelease() then
		if  self.myBulkRelease.fullRelease then
			self.setIsFullContainer();
			self.initFieldsForEntDefName(ETDef_ReleaseContainerFull, true);
			self.doSetCaption();
			self.doShowPicture();			
			return;
		endif;
	endif;
epilog

end;</source>
