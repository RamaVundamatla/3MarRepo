    <JadeMethod name="initForm" id="8144878f-423d-4f01-b5f6-65ba74d78816">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars

begin
	self.allowSearch := true;
	self.isSelectorCapable := true;
	self.frmDetailsBottom.visible := false;
	self.allowSearch := false;
	self.useTblThumb := false;
	self.useProxyObject := true;
	self.allowPrint  	:= false;
	self.allowExportCSV	:= false;
	
	self.initTableExtractDef;
	self.initTableExtractHistory;
	self.initTableExtractClass;
	
	// setup fldInput
	self.fldInput.stretchToParent := true;
	self.fldInput.tabsStyle := Folder.TabsStyle_RightSloped;
	self.fldInput.topSheet := self.shtExtractDef;
	self.fldInput.useSheetBackColors := true;
	self.fldInput.setDefaultSheetBackColors();
	self.fldInput.initSheetBackColors();

//	self.populateExtractDef(null);
//	self.populateExtractHistory;
//	self.populateExtractClass;
	
	self.tblExtractHist.left := WinLeftMargin;
	self.tblExtractHist.setDistanceFromRight(self.WinRightMargin);
	self.tblExtractHist.setDistanceFromBottom(self.VerticalSpacing);
	self.tblExtractHist.stretchHeight := true;
	self.tblExtractHist.stretchWidth := true;

	self.tblExtractClass.left := WinLeftMargin;
	self.tblExtractClass.setDistanceFromRight(self.WinRightMargin);
	self.tblExtractClass.setDistanceFromBottom(self.VerticalSpacing);
	self.tblExtractClass.stretchHeight := true;
	self.tblExtractClass.stretchWidth := true;
	
	self.mulFeatures.left := WinLeftMargin;
	self.mulFeatures.stretchHeight := true;
	self.mulFeatures.stretchWidth := true;
	self.initMulFeatures();
	
	self.mulObjects.left := WinLeftMargin;
	self.mulObjects.stretchHeight := true;
	self.mulObjects.stretchWidth := true;
	self.initMulObjects();

	self.lblDateFrom.left := WinLeftMargin+10;
	self.lblDateTo.left := WinLeftMargin+10;
	self.lblDateFrom.left := WinLeftMargin+100;
	self.lblDateTo.left := WinLeftMargin+100;
	self.txtDateFrom.visible := false;
	self.txtDateTo.visible := false;
	self.lblDateFrom.visible := false;
	self.lblDateTo.visible := false;

	self.sptDataFilter.width := 150;
	self.btnViewChgTrkMon.visible := true;
	self.btnViewChgTrkMon.enabled := true;

end;</source>
    </JadeMethod>
