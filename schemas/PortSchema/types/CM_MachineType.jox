//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="ca55c499-2137-4a57-ba31-6b2c7e6ecf8c">
        <source>validateMe() protected;

vars

begin
	if self.type &lt; 0 then // DVB changed so users can add theire own types or self.type &gt; (MACHINETYPE_MAX-1) then
		app.raiseCMException1(ERR_FIELD_TYPE, self.type.String, 'MachineType Type', null);
	endif;
	if self.description = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'MachineType Description', null, null);
		app.raiseCMException(Input_required_field_machAvaiD, null, null); // cnwdb2	PAR 35364
		

	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
