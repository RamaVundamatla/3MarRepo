        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetMaskedCharacterType" id="5c3b844c-99f6-4935-9c8d-2a4e02b409a5">
        <source>jssGetMaskedCharacterType():Integer;
// --------------------------------------------------------------------------------
// Created:		13 June 1999 - cnEcGetMaskedCharacterType
// By:			cnwdad1
//
// Purpose:		Gets the type of character in a string being compared to a mask.
//
// Parameters:	pValue (String) - The character in question.
// Returns:		Integer - The ASCII character number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ALPHA_LOWER_LOW			: Integer = 97;
	ALPHA_LOWER_HIGH		: Integer = 122;
	ALPHA_UPPER_LOW			: Integer = 65;
	ALPHA_UPPER_HIGH		: Integer = 90;
	NUM_LOW					: Integer = 48;
	NUM_HIGH				: Integer = 57;

vars
	ascii	: Integer;

begin
	ascii	:=	self.Integer;

	if (ascii &gt;= ALPHA_LOWER_LOW) and (ascii &lt;= ALPHA_LOWER_HIGH) then
		return JSS_CHAR_ALPHA_LOWER;
	elseif (ascii &gt;= ALPHA_UPPER_LOW) and (ascii &lt;= ALPHA_UPPER_HIGH) then
		return JSS_CHAR_ALPHA_UPPER;
	elseif (ascii &gt;= NUM_LOW) and (ascii &lt;= NUM_HIGH) then
		return JSS_CHAR_NUMERIC;
	else
		return JSS_CHAR_SPECIAL;
	endif;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
