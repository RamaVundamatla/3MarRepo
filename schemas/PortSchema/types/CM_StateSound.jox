    </ImplicitInverseRef>
    <JadeMethod name="getValue" id="7dffd52f-d8b3-46a7-9600-b5372c839982">
        <source>getValue(): Any;
// ---------------------------------------------------------------------------
// Created:     23 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
