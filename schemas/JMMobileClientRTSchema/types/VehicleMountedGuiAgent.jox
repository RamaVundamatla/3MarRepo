    <JadeMethod name="doMoveCurrentOversowTI" id="6366060c-73cc-451e-aa5b-caa68706cfcf">
        <source>doMoveCurrentOversowTI(_tiString : String;_locId : String;_errorMsgs : DTO_HandHeldGateErrorDict input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	//check the current ti is the same we are moving
	if _tiString &lt;&gt; self.myVehicleMountedAgent.getOverstowTIId then
		//self.myHandHeldRTGAgent.
		write "Current overstow container id " &amp; self.myVehicleMountedAgent.getOverstowTIId &amp; " does not match the one you are moving " &amp; _tiString;
		return;
	endif;
	
	//moveit
	self.myVehicleMountedAgent.doMoveCurrentOverstow(_locId, _errorMsgs);

epilog

end;</source>
        <Parameter name="_tiString" type="String"/>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
