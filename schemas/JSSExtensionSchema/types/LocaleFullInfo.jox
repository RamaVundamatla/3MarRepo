<Class name="LocaleFullInfo">
    <JadeMethod name="jssCopyInfo" id="a5bced31-f411-4f5b-a019-c4045470b4e3">
        <updating/>
        <source>jssCopyInfo(pTheLocaleFullInfo:LocaleFullInfo) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the Locale Information from the LocaleFullInfo parameter
//				object to the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(pTheLocaleFullInfo);
	
	self.defaultCodePage		:=	pTheLocaleFullInfo.defaultCodePage;
	self.defaultCountryCode		:=	pTheLocaleFullInfo.defaultCountryCode;
	self.defaultLanguageId		:=	pTheLocaleFullInfo.defaultLanguageId;
	self.listSeparator			:=	pTheLocaleFullInfo.listSeparator;
	self.measurementSystem		:=	pTheLocaleFullInfo.measurementSystem;
	self.nativeDigits			:=	pTheLocaleFullInfo.nativeDigits;
	
	self.currencyInfo.jssCopyInfo(pTheLocaleFullInfo.currencyInfo);
	self.dateInfo.jssCopyInfo(pTheLocaleFullInfo.dateInfo);
	self.numericInfo.jssCopyInfo(pTheLocaleFullInfo.numericInfo);
	self.timeInfo.jssCopyInfo(pTheLocaleFullInfo.timeInfo);
end;</source>
        <Parameter name="pTheLocaleFullInfo" type="LocaleFullInfo"/>
    </JadeMethod>
    <JadeMethod name="jssUpdateMe" id="4287b97d-4557-4dc5-8586-9e3eae0ecdc7">
        <updating/>
        <source>jssUpdateMe(	pAbbreviatedCountryName:String;
				pAbbreviatedLangName:String;
				pCountryCode:Integer;
				pEnglishCountryName:String;
				pEnglishLangName:String;
				pLanguageId:Integer;
				pLocaleId:Integer;
				pLocalizedCountryName:String;
				pLocalizedLangName:String;
				pNativeCountryName:String;
				pNativeLangName:String;
				pTheCurrencyFormat:CurrencyFormat;
				pTheDateFormat:DateFormat;
				pDefaultCodePage:Integer;
				pDefaultCountryCode:Integer;
				pDefaultLanguageId:Integer;
				pListSeparator:String;
				pMeasurementSystem:Integer;
				pNativeDigits:String;
				pTheNumberFormat:NumberFormat;
				pTheTimeFormat:TimeFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.abbreviatedCountryName	:=	pAbbreviatedCountryName;
	self.abbreviatedLangName	:=	pAbbreviatedLangName;
	self.countryCode			:=	pCountryCode;
	self.defaultCodePage		:=	pDefaultCodePage;
	self.defaultCountryCode		:=	pDefaultCountryCode;
	self.defaultLanguageId		:=	pDefaultLanguageId;
	self.englishCountryName		:=	pEnglishCountryName;
	self.englishLangName		:=	pEnglishLangName;
	self.languageId				:=	pLanguageId;
	self.listSeparator			:=	pListSeparator;
	self.localeId				:=	pLocaleId;
	self.localizedCountryName	:=	pLocalizedCountryName;
	self.localizedLangName		:=	pLocalizedLangName;
	self.measurementSystem		:=	pMeasurementSystem;
	self.nativeCountryName		:=	pNativeCountryName;
	self.nativeDigits			:=	pNativeDigits;
	self.nativeLangName			:=	pNativeLangName;
	
	self.currencyInfo.jssCopyInfo(pTheCurrencyFormat);
	self.dateInfo.jssCopyInfo(pTheDateFormat);
	self.numericInfo.jssCopyInfo(pTheNumberFormat);
	self.timeInfo.jssCopyInfo(pTheTimeFormat);
end;</source>
        <Parameter name="pAbbreviatedCountryName" type="String"/>
        <Parameter name="pAbbreviatedLangName" type="String"/>
        <Parameter name="pCountryCode" type="Integer"/>
        <Parameter name="pEnglishCountryName" type="String"/>
        <Parameter name="pEnglishLangName" type="String"/>
        <Parameter name="pLanguageId" type="Integer"/>
        <Parameter name="pLocaleId" type="Integer"/>
        <Parameter name="pLocalizedCountryName" type="String"/>
        <Parameter name="pLocalizedLangName" type="String"/>
        <Parameter name="pNativeCountryName" type="String"/>
        <Parameter name="pNativeLangName" type="String"/>
        <Parameter name="pTheCurrencyFormat" type="CurrencyFormat"/>
        <Parameter name="pTheDateFormat" type="DateFormat"/>
        <Parameter name="pDefaultCodePage" type="Integer"/>
        <Parameter name="pDefaultCountryCode" type="Integer"/>
        <Parameter name="pDefaultLanguageId" type="Integer"/>
        <Parameter name="pListSeparator" type="String"/>
        <Parameter name="pMeasurementSystem" type="Integer"/>
        <Parameter name="pNativeDigits" type="String"/>
        <Parameter name="pTheNumberFormat" type="NumberFormat"/>
        <Parameter name="pTheTimeFormat" type="TimeFormat"/>
    </JadeMethod>
</Class>
