    <JadeMethod name="setPxyFromCMIF_Receival" id="dd55fe8d-1bad-423c-8fab-59fcf5e5167a">
        <updating/>
        <source>setPxyFromCMIF_Receival(isUpdateTI: Boolean;_receival: CMIF_Receival; _passport: CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2009	cnwdap1	Initial creation
// 17/04/2018    jlgrh7 TFS 38055 MSL - coparn deletes stop fields
*/
vars

begin
	inheritMethod(isUpdateTI,_receival, _passport);				//+TFS38055
	
	self.myTILCType := app.myRoot.allTILCTypes[null, _receival.trailerType];
	
	//15/10/2025	navkc1 JIRA 36057
	if self.myTILCType &lt;&gt; null and self.myTILCType.allowUpdateTotalWeight then
		self.updateTILCTotalWeightConfig(true);
	endif;


	self.availabilityGrade:=_receival.availabilityGrade;	//16 Oct 2013	NDL	Par 32573
epilog

end;</source>
