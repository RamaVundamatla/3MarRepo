    <JadeMethod name="convertXLSToCSV" id="9466568a-7997-42bb-9964-39521cb01407">
        <source>convertXLSToCSV(_xlsFile: File; _originalName: String; _allFiles: FileNodeArray input);
// ---------------------------------------------------------------------------
// Created:     28 April 2010 by cnwcs5
// Purpose:     Copied from CMUI_EDIForm
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xlFile		: File;
	xlConverter	: CM_XLS2CSVAgent;
	fileData	: CM_FileDataStorageDetail;
	csvFile		: File;
	fileString	: String;
	allFiles	: FileNodeArray;
	aFileName	: String;
	idx			: Integer;
begin
	_allFiles.purge();
	
	aFileName := app.getTempDir() &amp; "\" &amp; _originalName;

	create xlConverter transient;
	
	xlFile := _xlsFile;
	
	if xlFile.tryOpen then
		xlFile.close();
		
		xlConverter.setInputFile(xlFile);
		xlConverter.convert();
		
		idx := 0;
		
		foreach fileData in xlConverter.allOutputFiles do
			idx := idx + 1;
			create csvFile;
			_allFiles.add(csvFile);
			
			csvFile.kind := File.Kind_Binary;
			csvFile.mode := File.Mode_Output;
			csvFile.fileName := aFileName &amp; "_" &amp; idx.String &amp; ".csv";
			csvFile.open();
			csvFile.writeBinary(fileData.csvBlob.uncompressToBinary());
			csvFile.close();
			//csvFile.kind := File.Kind_ANSI;	// 1/3/16 cnwmp6 PAR 36286 unicode version
			csvFile := null;
		endforeach;
	else
		app.writeLog("File open failed", LogINFO);
	endif;
epilog
	if csvFile &lt;&gt; null then
		csvFile.close();
	endif;
	
	xlConverter.setInputFile(null);
	delete xlConverter;
end;</source>
        <Parameter name="_xlsFile" type="File"/>
        <Parameter name="_originalName" type="String"/>
        <Parameter name="_allFiles" type="FileNodeArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEDIBayPlanMergeOptions" id="ec5f0db6-afe6-4597-9ec3-334b86300ccb">
        <source>doEDIBayPlanMergeOptions(_hasCargo, _hasPlanning :Boolean; 
					_clear, _retainAllCargo, _retainEDICargo, _retainManCargo, _retainNoCargo, _planning :Boolean output):Boolean;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     Shows the bay plan merge form
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	:CMUI_EDIBayPlanMerge;
begin
	form := app.loadForm(CMUI_EDIBayPlanMerge, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_EDIBayPlanMerge;
	
	if form = null then
		return false;	// form did not load
	endif;
	
	form.hasCargo 		:= _hasCargo;
	form.hasPlanning 	:= _hasPlanning;
	
	if form.showModal() &lt;&gt; IDOK then
		return false;	// user clicked cancel
	endif;
	// now get input options
	_clear := form.chkClear.value;
	
	if not _clear then
		_retainAllCargo := form.optRetnAllCargo.value;
		_retainEDICargo := form.optRetnEDICargo.value;
		_retainManCargo := form.optRetnManCargo.value;
		_retainNoCargo 	:= form.optRetnNoCargo.value;
		_planning 		:= form.optRetainPlannin.value;
	endif;
	
	return true;
epilog
	delete form;
end;</source>
        <Parameter name="_hasCargo" type="Boolean"/>
        <Parameter name="_hasPlanning" type="Boolean"/>
        <Parameter name="_clear" type="Boolean" usage="output"/>
        <Parameter name="_retainAllCargo" type="Boolean" usage="output"/>
        <Parameter name="_retainEDICargo" type="Boolean" usage="output"/>
        <Parameter name="_retainManCargo" type="Boolean" usage="output"/>
        <Parameter name="_retainNoCargo" type="Boolean" usage="output"/>
        <Parameter name="_planning" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEDIExtract" id="64851684-aba9-4e20-aa2b-17900af7f22a">
        <source>doEDIExtract(_mode : Integer; _ediData : CM_EDIData; _assistant :CMUI_Assistant; _terminal :CM_Terminal; _agent :CM_EDIControllerAgent);
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	:CMUI_EDIDBExtract;
begin 
	create form;
	
	form.mode := _mode;
	form.setAssistantAndTerminalRefs(_assistant, _terminal);
	form.setEDIData(_ediData);
	form.setEDIAgent(_agent);
	form.showModal;
	
epilog
	delete 	form;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_assistant" type="CMUI_Assistant"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_agent" type="CM_EDIControllerAgent"/>
    </JadeMethod>
    <JadeMethod name="doEDIViewInternalXML" id="66aa5e70-5149-4d58-8ff0-b056033686e7">
        <source>doEDIViewInternalXML(_ediData :CM_EDIData; _form : CM_BaseForm input);
/*

Purpose:			View the internal XML transformation for the passed in 
					EDI Data (if there is some)

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
24 Aug 2023	navmd1	TFS 59451 Refactor EDI Ops/EDI Web Service viewer to call this one method too
14 Sep 2023 navmd1	TFS 60086 Change form caption to same as CMUI_ScrollMsgBoxSearchable
*/
vars
	ediFile			: CM_EDIFile;
	fileType		: CM_EDIFileType;
	message			: String;
	theLines 		: HugeStringArray;
	selectText		: String;
	messageLogForm	: CMUI_MessageLogForm;
begin
	if _ediData = null then
		return;
	endif;
	
	//------------------------------------------------------
	// 					getting ediFile
	//------------------------------------------------------
	if _ediData.myEDIFile &lt;&gt; null then //not _ediData.ediFileArray.isEmpty then // ccms1117 cnwrs1 29 Apr 2010
		ediFile := _ediData.myEDIFile; // ediFileArray.last; // ccms1117 cnwrs1 29 Apr 2010
	endif;
	
	if ediFile = null then
		return;
	endif;
	
	//------------------------------------------------------
	// 					showing ediFile
	//------------------------------------------------------
	selectText := ediFile.fileSenderCode;
	message := ediFile.getOriginalFileDataString();
	fileType := ediFile.myEDIFileType;
	
	if message = null then
		return;
	endif;
	
	if fileType &lt;&gt; null and fileType.isJSON() or fileType.isXML() then
		create messageLogForm transient;
		messageLogForm.translateCaption(Xlat_0008069, null);
		messageLogForm.isEDIPostTransform := true;	// Internal XML/JSON is POST Trasform
		messageLogForm.setMyObject(ediFile);
		messageLogForm.show();
	
	elseif fileType &lt;&gt; null then
		create theLines transient;
		fileType.rawDataToHSA(ediFile, theLines);
		// Internal XML is in the allCompressedFileLines array
		app.msgBoxScroll(null, theLines, selectText, app.getErrorString(Special_File_View), 1);
	
	else
		app.msgBoxScroll(message, null, selectText, app.getErrorString(Special_File_View), 1);
	endif;
		
epilog
	delete theLines;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEDIViewRawData" id="e16ecaa2-2818-46d0-9c03-f4e371fa0f5a">
        <source>doEDIViewRawData(_ediData :CM_EDIData; _form : CM_BaseForm input);
// ---------------------------------------------------------------------------
// Created:     22 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/11/2011	cnwcs5		CCMS POL 2122 / par 28696
// 15 Dec 2014	cnwkpd1		PAR #34713 - Changes for .NET EDI Integration
// 12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 24 Aug 2023	navmd1		TFS 59451 Refactor EDI Ops/EDI Web Service viewer to call this one method too
// 14 Sep 2023	navmd1		TFS 60086 Change form caption to same as CMUI_ScrollMsgBoxSearchable
// ---------------------------------------------------------------------------
vars
	ediFile			: CM_EDIFile;
	fileType		: CM_EDIFileType;
	message			: String;
	theLines		: HugeStringArray;
	selectText		: String;
	messageLogForm	: CMUI_MessageLogForm;
begin

	//	ccms 1064	Centreport	cnwvu1
	if _ediData = null then
		return;
	endif;
	
	//------------------------------------------------------
	// 					getting ediFile
	//------------------------------------------------------
	if _ediData.myEDIFile &lt;&gt; null then //not _ediData.ediFileArray.isEmpty then // ccms1117 cnwrs1 29 Apr 2010
		ediFile := _ediData.myEDIFile; // ediFileArray.last; // ccms1117 cnwrs1 29 Apr 2010
	endif;
	
	if ediFile = null then
		return;
	endif;
	
	selectText := ediFile.fileSenderCode;
	fileType := ediFile.myEDIFileType;
	
	//------------------------------------------------------
	// 					showing ediFile
	//------------------------------------------------------
	// 1. Try and get the Pre-Transformed message
	message := ediFile.getOriginalFileDataString();
	
	// 2. Failing that, if the file doesn't have a type, then just get the raw data
	if message = null and fileType = null then
		message := ediFile.getRawDataString();
	endif;
	
	// 3. If the file has a type, then split it using rawDataToHSA
	if message = null and fileType &lt;&gt; null then
		if fileType.isXML() or fileType.isJSON() then
			// We can now display these formats a bit nicer, so lets just grab the Raw data
			message := ediFile.getRawDataString();
		else
			// This skips any specified lines if user-defined
			create theLines transient;
			fileType.rawDataToHSA(ediFile, theLines);
		endif;
	endif;
	
	// If we still don't have any data, or the file type is not XML or JSON
	if message = null then
		app.msgBoxScroll(null, theLines, selectText,  app.getErrorString (Special_File_View), 1);
		return;
	endif;
	
	// Lets reformat things nicely, if we can
	create messageLogForm transient;
	messageLogForm.translateCaption(Xlat_0008069, null);
	
	// Check if its a XML message
	if fileType &lt;&gt; null and fileType.isXML() then
		messageLogForm.myXMLString := message;
		messageLogForm.isXMLRequest := true;
		messageLogForm.show;
	elseif fileType &lt;&gt; null and fileType.isJSON() then
	// Or a JSON message
		messageLogForm.setMyObject(ediFile);
		messageLogForm.show;
	else
	// Otherwise must just be CSV
		app.msgBoxScroll(message, null, selectText,  app.getErrorString (Special_File_View), 1);
	endif;
	
epilog
	delete theLines;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNewEDIFile" id="a64b39e2-3c59-4374-ab7d-51d6c3a81e7a">
        <source>getNewEDIFile(_textbox :CMUI_TextBox input);
// ---------------------------------------------------------------------------
// Created:     28 April 2010 by cnwcs5
// Purpose:     Copied from CMUI_EDIForm::getNewEDIFile
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	fileGet		 		: CMDFileOpen;
begin
	create fileGet;
	fileGet.cnEcSetFilters( true, 2, CNEC_FILE_FILTER_DATA );
	fileGet.fileName	:= null;
	fileGet.initDir		:= self.myTerminal.getConfig_FileDirectory(EDIFileDirectory).String;
	
	if fileGet.open = 0 then	//user clicked OK
		_textbox.text := fileGet.fileName;
	else
		_textbox.text := null;
	endif;
epilog
	delete fileGet;	
end;</source>
        <Parameter name="_textbox" type="CMUI_TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isCollectionOfStopTypeEDIData" id="98ff09b4-2cc7-41aa-98de-0058ebf03ab3">
        <source>isCollectionOfStopTypeEDIData(_coll	:ObjectArray input) : Boolean;
/*

Date		Who		Reason
19 October 2015	cnwer1	Initial creation PAR 37090

*/

vars
	obj				:Object;
	type			:Integer;
	gotException	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, obj, gotException);
	
	foreach obj in _coll do
		// get the type for the first edi data in the collection
		if type = null then
			type := obj.CM_EDIData.getEDIDataType;
			// type must be either a customs or an operator stop
			if type &lt;&gt; EDIDataType_CustomStop and
				type &lt;&gt; EDIDataType_OperatorStop then
				return false;
			endif;
		endif;
		// is this edi data the same as all the others in the collection?
		if obj.CM_EDIData.getEDIDataType &lt;&gt; type then
			return false;
		endif;
	endforeach;
		
	return true;
epilog

end;</source>
        <Parameter name="_coll" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadEDIFileTypes_UserDefined" id="b2d4ff23-caa3-480c-917f-759517435799">
        <source>loadEDIFileTypes_UserDefined(_cmb :CMUI_ComboBox input; _fileType :Integer; _controller :CM_EDIControllerAgent);
// ---------------------------------------------------------------------------
// Created:     28 April 2010 by cnwcs5
// Purpose:     Loads user defined file types into a combo
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_ObjectSet;
	obj		:Object;
	fileType, selectedFileType	:CM_EDIFileType;
begin
	_cmb.clear();
	_cmb.sorted := true;
	
	create coll transient;
	
	_controller.getEDIFileTypes_UserDefined (coll);
	
	foreach obj in coll do
		fileType := obj.CM_EDIFileType;
		_cmb.itemObject[_cmb.addItem(fileType.name)] := obj;
		
		if fileType.type = _fileType then
			selectedFileType := fileType;
		endif;
	endforeach;
	
	if selectedFileType &lt;&gt; null then
		_cmb.listObject := selectedFileType;
	endif;
epilog
	delete coll;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_fileType" type="Integer"/>
        <Parameter name="_controller" type="CM_EDIControllerAgent"/>
    </JadeMethod>
    <JadeMethod name="saveEDITIChangesToPxy" id="0aa400ac-b01f-4de3-bbe6-d6fd62153a21">
        <source>saveEDITIChangesToPxy( _tblEDITi : CM_DataTable input;
						_ediPxyTIs : CM_EDITIById input;						
						_passport : CM_Passport input);
/*

Date		Who		Reason
08 September 2016	cnwer1	Initial creation TFS 2606

*/

vars
int			: Integer;
	realEDITI,
	pxyEDITI 	: CM_EDITrackedItem;
	loadState,
 	gotException: Boolean;
	col 		: Integer;
	done,todo 	: Integer;

	table 		: CM_DataTable;
	object		: Object;
begin
	on Exception do app.handleDeletedObject (exception, object, gotException);
	

	table := _tblEDITi;
	
	col 	:= table.getColumnByRowName(ETRow_HasChanged);
	todo 	:= table.rows;
	
	foreach int in 2 to table.rows do
		done := int;
		
		if table.accessCell(int, col).text &lt;&gt; CMUI_EDIForm.HAS_CHANGED then
			continue;
		endif;
		// *** we have an EDI tracked items that has changed *** //
		if _passport.myCMIFMonitor &lt;&gt; null and (((done/todo)*100).Integer mod 10 = 0) then
			_passport.myCMIFMonitor.updateProgress("Saving changes", todo, done);
		endif;
		
		realEDITI 	:= table.accessRow(int).itemObject.CM_EDITrackedItem;
		object		:= realEDITI;
		
		if realEDITI.status = CM_EDIFile.EDI_STATUS_DBLOADED then 
			// Can't edit a line already loaded
			continue;
		endif;
	
		if gotException then
			// edi TI has been deleted
			continue;
		endif;
		
		app.cmsBeginLoad(loadState);
		
		pxyEDITI := realEDITI.pxyCreateUpdateProxy();
		
		_ediPxyTIs.add(pxyEDITI); 
		
		app.cmsEndLoad(loadState);
		
		self.setPxyEDITIFromTable(pxyEDITI, table, int);
	endforeach;
	

epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	
end;</source>
        <Parameter name="_tblEDITi" type="CM_DataTable" usage="input"/>
        <Parameter name="_ediPxyTIs" type="CM_EDITIById" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setEDIFileInError" id="64d823dc-6607-4741-8900-c9f75fbd52cc">
        <source>setEDIFileInError(_ediFile: CM_EDIFile; _ediFileInError :CM_EDIFile io);
// ---------------------------------------------------------------------------
// Created:     28 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//there can be only one - (is null if file loads ok)
	//if this isn't null then they are abandoning the file load so we will delete
	if _ediFileInError &lt;&gt; null then
		app.myTrxDA.trxDeleteEDIFile(_ediFileInError, app.myPassport);
	endif;
	
	_ediFileInError := _ediFile;
epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_ediFileInError" type="CM_EDIFile" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="e768ee49-493c-4a52-831e-61355e5d1b81">
        <updating/>
        <source>setMyTerminal(_terminal :CM_Terminal)updating;
// ---------------------------------------------------------------------------
