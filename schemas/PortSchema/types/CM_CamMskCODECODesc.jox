    <JadeMethod name="getMessageType" id="7e608efe-5b0f-4d8e-8a5a-4b656435dd4f">
        <source>getMessageType(_transaction: CM_TITransaction;
			_messageTypeArray: IntegerArray input;
			_camProtocol: CM_CamProtocol;
			_camAgent : CM_CamControllerAgent input);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
vars
	temp : String;
begin
	_messageTypeArray.clear;
	
	//epr TFS 5157 25/7/17  the pack and unpack needs to be handled correctly in inherited method
	if _transaction.isCamsEditType() then // PAR-13509
		if self.checkEditForStatusChange(_transaction, temp) then
			_messageTypeArray.add(CODECO_EDIT);
		else
			//epr TFS 2387 19/7/16 more logging
			if _camAgent &lt;&gt; null then
				_camAgent.logReasonForExclusion(_transaction," AV grade has not changed" );
			endif;
		endif;
	else
		inheritMethod(_transaction, _messageTypeArray, _camProtocol, _camAgent);
	endif;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRelevantSnapshot" id="ee049524-f5f5-4e81-be1f-2f3332c3947b">
        <source>getRelevantSnapshot(_theTI : CM_TrackedItem; _theTransaction : CM_TITransaction; _theSnapshot : CM_TISnapShot io);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Nov 2018	jlgsl4	TFS 41640 - PNL - output IMEX from time of transaction

*/

vars
	nextSnapshot : CM_SnapShot;
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,nextSnapshot,invalidObject);
	foreach nextSnapshot in _theTI.snapShots do
		if nextSnapshot.myTransaction = _theTransaction then
			_theSnapshot := nextSnapshot.CM_TISnapShot;
			return;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theTransaction" type="CM_TITransaction"/>
        <Parameter name="_theSnapshot" type="CM_TISnapShot" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="a099159e-d758-418b-a3f0-f2fa6474b461">
        <source>getVoyageCode(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _vesselName : String io):String;
//
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
//
vars
	voyageId,xlVoyageId: String;
	theTI : CM_TrackedItem;

begin

	theTI := _transaction.myTrackedItem;

	//get the voyage code
	//if theTI.isExport then								// PAR #25021
	if theTI.isExport or theTI.isTranshipOutbound then		// PAR #25021
		voyageId := theTI.myVoyage.code;
	//elseif theTI.isImport then							// PAR #25021
	elseif theTI.isImport or theTI.isTranshipInbound then	// PAR #25021
		voyageId := theTI.myVoyage.inwardCode;
		if voyageId = null then
			voyageId := theTI.myVoyage.code;
		endif;
	elseif theTI.isStorage then
		voyageId := theTI.myVoyage.inwardCode;
		if voyageId = null then
			voyageId := theTI.myVoyage.code;
		endif;
	else
		voyageId := theTI.myVoyage.code;
	endif;
	_vesselName := theTI.myVoyage.vesselName; //par18987 cnwrs1 Mar 2009

	//translate the voyage Code
	xlVoyageId := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, voyageId, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);
	if xlVoyageId = NULL_VOYAGE_CODE then //cmwrs1 Mar 2007 CCMS 1050
		xlVoyageId := null;
	endif;
	return xlVoyageId;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_vesselName" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
