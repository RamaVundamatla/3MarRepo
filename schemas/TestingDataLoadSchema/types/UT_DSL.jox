    <JadeMethod name="zapQueueEntry" id="4db59ec4-f57a-4d06-9816-275b7c644851">
        <source>zapQueueEntry(_queueEntry: CM_RTQueueEntry);
//20 September 2010	cnwdw1	
//  Very yucky - It would be good is someone get work out how to do this properly
vars
	obj: Object;
begin
	if _queueEntry &lt;&gt; null then
		beginTransaction;
			obj := _queueEntry;
			delete obj;
		commitTransaction;
	endif;
end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="zapQueueTask" id="b09df063-ab5b-4d43-baee-f0e096fbd930">
        <source>zapQueueTask(_queueTask: CM_RTQueueTask);
//20 September 2010	cnwdw1	
//  Very yucky - It would be good is someone get work out how to do this properly
vars
	obj: Object;
begin
	if _queueTask &lt;&gt; null then
		self.zapQueueEntry(_queueTask.myEntry);
	endif;
end;</source>
        <Parameter name="_queueTask" type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="zapTrackedItem" id="7aa5ad6a-68a8-477a-873a-51c0a5a3505c">
        <source>zapTrackedItem(_ti: CM_TrackedItem );
//20 September 2010	cnwdw1	
//  Very yucky - use only if all other attempts to delete a TI fail
vars
	obj: Object;
begin
	if _ti &lt;&gt; null then
		beginTransaction;
			obj := _ti;
			delete obj;
		commitTransaction;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="zzzMDHDONOTUSE" id="1b77e595-814d-453c-b1a1-54c169592bdc">
        <source>zzzMDHDONOTUSE(_location : CM_LocationsController; _ti : CM_TrackedItem; _moveController : CMIF_MoveController);

/*

Purpose:		

Date			Who		Reason
10/10/2013		cnwmh5	Initial creation

*/

vars
	ti					: CM_TrackedItem;
	error				: CM_Error;
	
	array 				: CM_TIArray;
	
	totalHeight			: Integer;
	warningIds			: String;
	
begin
	create array transient;
	
	_location.getTIs(array, PLANNING_MODE, true); // PAR 27749
	foreach ti in array do
		if _ti &lt;&gt; null and _ti = ti then
			continue;
		endif;
		totalHeight := totalHeight + ti.getHeightOfTI();
	endforeach;

	if totalHeight &lt; 0 then
		totalHeight := 0;
	endif;
	
	warningIds := null;
	if app.myPassport.allWarnings.size &gt; 0 then
		foreach error in app.myPassport.allWarnings do
			if warningIds.length &gt; 0 then
				warningIds := warningIds &amp; ",";
			endif;
			warningIds := warningIds &amp; error.errorCode.String;
		endforeach;	
	endif;
	
	app.writeLog("~~~~~~~~~~~~~~~~~" &amp; CrLf &amp; 'warnings size: ' &amp; app.myPassport.allWarnings.size.String &amp; CrLf &amp;
		'warnings to ignore size: ' &amp; app.myPassport.allWarningsToIgnore.size.String &amp; CrLf &amp;
		'warning Ids: ' &amp; warningIds &amp; CrLf &amp;
		'errors size: ' &amp; app.myPassport.allErrors.size.String &amp; CrLf &amp; 
		'allErrorsWarnings.size: ' &amp; app.myPassport.allErrorWarnings.size.String &amp; CrLf &amp; 
		'numWarningsAtValidationStage: ' &amp; app.myPassport.getPropertyValue("numWarningsAtValidationStage").String &amp; CrLf &amp;
		'status: ' &amp; app.myPassport.status.String &amp; CrLf &amp;
		'trxCompletedOK: ' &amp; app.myPassport.trxCompletedOK().String &amp; CrLf &amp; 
		'ti2: ' &amp; _ti.id &amp; CrLf &amp; 
		'ti.height: ' &amp; _ti.getHeightOfTI().String &amp; CrLf &amp;
		'stackPlanHeight: ' &amp; totalHeight.String &amp; CrLf &amp;
		'maxHeight: ' &amp; (_location.getMaxStackingHeight() * 2).String &amp; CrLf &amp;
		'stackPlanHeight + tiHeight: ' &amp; (totalHeight + ti.getHeightOfTI).String &amp; CrLf &amp;
		'stackPlanHeight + tiHeight &gt; maxHeight: ' &amp; (totalHeight + ti.getHeightOfTI &gt; totalHeight).String &amp; CrLf &amp;
		'ackwarnings: ' &amp; app.myPassport.warningsAcknowledged.String &amp; CrLf &amp;
		'ignorewarning: ' &amp; app.myPassport.warningsIgnored.String &amp; CrLf &amp;
		"~~~~~~~~~~~~~~~~~", LogINFO);
	
	
	///return totalHeight;
epilog
	delete array;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
