        <source>utlDeleteLogScalingHdr(_logScalingHdr : CM_LogScalingHdr io; _passport : CM_Passport input);
// -----------------------------------------------------------------------------
// Created:		27 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	cancelSave	: Boolean;
	terminal	: CM_Terminal;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valLogScalingHdr(_logScalingHdr);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	exclusiveLock(_logScalingHdr);
	

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_logScalingHdr);
	endif;

	if _passport.noErrors then
		terminal := _passport.myTerminal;
		terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Delete_Event), false, _logScalingHdr);	
		_logScalingHdr.erase(NORMAL_ERASE);
	endif;

end;</source>
