<Class name="UT_IFTCSUM_PortAuthortyPOB" id="799a30eb-5a38-4e76-8efd-649c76dfa767">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="createEDIPartyIFCSUMHSCode" id="cb359b1b-e657-4e33-9080-f491cf802ca8">
        <source>createEDIPartyIFCSUMHSCode(	_party 					: CM_EDIParty; 
							_cargoType,
							_defaultCargoType		: CM_CargoType;
							_cargoSubType			: String;
							_hsCodes				: StringArray;
							_operator				: CM_Operator
							) 
							protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements creates ediParty with HSCodes
25 Oct    2024  navsp1  JIRA 33157 NSW | FR - IFCSUM - Consignee to Cargo Type Mappings Not Applied to Matching Cargo
*/

vars
	proxy				: CM_EDIParty;
	rules, pxyRules		: CM_EDIPartyRules;
	hsItem				: CM_EDIIFCSUMHSRule;
	inLoadState 		: Boolean;
	str					: String;
	cargoTypeId			: Integer;
	consignee			: CM_EDIIFCSUMRule;
	consCode, conCT		: String;
begin
	app.cmsBeginLoad(inLoadState);
	
	proxy := app.createUpdateProxy(_party).CM_EDIParty;
	
	rules := proxy.getRulesForFileType (EDIFileType_IFCSUM94B);
	
	if _cargoType &lt;&gt; null then
		cargoTypeId := _cargoType.id;
	endif;
	
	if rules = null then
		create pxyRules as CM_EDIPartyIFCSUMRules transient;
		
		pxyRules.setMyEDIParty (proxy);
		pxyRules.setMyEDIConfig (proxy.myTerminal.myEdiConfig);
		pxyRules.CM_EDIPartyIFCSUMRules.setProxy(true, false, false, true, false, false, null,true,false,true,false,true,TI_SITE_ONSITE,TI_SITE_ONSHIP,null, true,_operator,false,true,false,3, _defaultCargoType, true, false, false);
	else
		pxyRules := rules;
		pxyRules.CM_EDIPartyIFCSUMRules.setProxy(true, false, false, true, false, false, null,true,false,true,false,true,TI_SITE_ONSITE,TI_SITE_ONSHIP,null, true,_operator,false,true,false,3, _defaultCargoType, true, false, false);
	endif;
	
	if _hsCodes &lt;&gt; null then
		foreach str in _hsCodes do
			create hsItem as CM_EDIIFCSUMHSRule transient;
			hsItem.setProxyIFCSUMHS(_cargoSubType, str, cargoTypeId, pxyRules.CM_EDIPartyIFCSUMRules);
		endforeach;
	endif;
	
	if  self.opts.includesKey("CONSIGNEECODE") and self.opts.includesKey("CONSIGNEECT") then						//JIRA 33157
		create consignee as CM_EDIIFCSUMRule transient;																//JIRA 33157
		consignee.setProxyIFCSUM(self.opts.int("CONSIGNEECT"), self.opts.str("CONSIGNEECODE"), null, null);			//JIRA 33157
		consignee.setMyEDIPartyRules (pxyRules);																	//JIRA 33157
	endif;																											//JIRA 33157
	
	app.myTrxUA.trxUpdateEDIParty (proxy, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
epilog
	app.cmsEndLoad(inLoadState);										
	delete proxy;
end;</source>
        <access>protected</access>
        <Parameter name="_party" type="CM_EDIParty"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_defaultCargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="String"/>
        <Parameter name="_hsCodes" type="StringArray"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="createEDIPartyIFCSUMPOB49B" id="dd3cc44e-9d32-44c7-9b2f-79d013890d5f">
        <source>createEDIPartyIFCSUMPOB49B(	_party 						:CM_EDIParty;
							_consignee 					: CM_ConsigneeConsignor;
							_cargoType 					: CM_CargoType;
							_vehicleMake 				: CM_VehicleMake;
							_pci 						: Boolean;
							_bgm 						: Boolean;
							_useDischargeAsDestination 	: Boolean;
							_mafiISOTypeGroup 			: CM_ISOTypeGroup;
							_defCargoType : CM_CargoType;
							_useSystemGenIDs : Boolean)
							protected;
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
============================================================================*/

vars

	proxy			: CM_EDIParty;
	rules, pxyRules	: CM_EDIPartyRules;
	pxyItem			: CM_EDIIFCSUMRule;
	mafiISOType		: CM_CargoType;
begin

	beginLoad;
	proxy := _party.pxyCreateUpdateProxy;
	
		// find existing rules if they are there
	rules := proxy.getRulesForFileType (EDIFileType_IFCSUM94B);
	
	if rules = null then
		create pxyRules as CM_EDIPartyIFCSUMRules transient;
		
		pxyRules.setMyEDIParty (proxy);
		pxyRules.setMyEDIConfig (proxy.myTerminal.myEdiConfig);
		pxyRules.CM_EDIPartyIFCSUMRules.setProxy(_pci, false, _bgm, false, false, false, _mafiISOTypeGroup,false,false,false,false,false,TI_SITE_ONSHIP,TI_SITE_ONSHIP,null, false,null,false,false,false,0, _defCargoType, _useSystemGenIDs, false, false);
	else
		pxyRules := rules;
		pxyRules.CM_EDIPartyIFCSUMRules.setProxy(_pci, false, _bgm, false, false, false, _mafiISOTypeGroup,false,false,false,false,false,TI_SITE_ONSHIP,TI_SITE_ONSHIP,null, false,null,false,false,false,0, _defCargoType, _useSystemGenIDs, false, false);
	endif;
	
	create pxyItem transient;
	pxyItem.setProxyIFCSUM(_cargoType.id, _consignee.code, _vehicleMake.make, _pci);
	pxyItem.setMyEDIPartyRules (pxyRules);
	
	endLoad;

	app.myTrxUA.trxUpdateEDIParty (proxy, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings;

epilog

	endLoad;												
	delete proxy;

end;</source>
        <access>protected</access>
        <Parameter name="_party" type="CM_EDIParty"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_vehicleMake" type="CM_VehicleMake"/>
        <Parameter name="_pci" type="Boolean"/>
        <Parameter name="_bgm" type="Boolean"/>
        <Parameter name="_useDischargeAsDestination" type="Boolean"/>
        <Parameter name="_mafiISOTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_defCargoType" type="CM_CargoType"/>
        <Parameter name="_useSystemGenIDs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tIFCSUMPOB94B" id="e826e184-8cca-4830-935e-f4cee7750122">
        <source>tIFCSUMPOB94B();
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date			Name	TFS#			Description
========================================================================================
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
27 Aug 2024	navlw1	TFS 65152: NSW | Changed how we are verifying/db loading edi files
=======================================================================================*/

constants
	ForeignOperatorCode1 : String = "KLIN";
	ForeignOperatorCode2 : String = "9HA2066";
	ForeignOperatorCode3 : String = "WLA";
	EDIPartyName : String = "IFCSUMAUBNE94B";
	VoyageName1 : String = '851';
	VoyageNameOther : String = "66S";
//	ForeignVoy : String = '00000010415800';

	ForeignVoy1 : String = '66S';
	ForeignVoy2 : String = 'CF704';
	BoatName : String = 'IFCSUMBNE';
vars

	term : CM_Terminal;
	oper1 : CM_Operator;
	ediData : String;
	ediFile	:CM_EDIFile;
	ediParty : CM_EDIParty;
	mazdaConsign : CM_ConsigneeConsignor;
	mazdaMake : CM_VehicleMake;
	hondaConsign : CM_ConsigneeConsignor;
	hondaMake : CM_VehicleMake;
	isuzuConsign : CM_ConsigneeConsignor;
	isuzuMake : CM_VehicleMake;
	mclarenConsign : CM_ConsigneeConsignor;
	mclarenMake : CM_VehicleMake;
	bmwConsign : CM_ConsigneeConsignor;
	bmwMake : CM_VehicleMake;
	lrConsign : CM_ConsigneeConsignor;
	lrMake : CM_VehicleMake;
	carCargoType : CM_CargoType;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	port : CM_Port;
	klinOper : CM_Operator;
	wlaOper : CM_Operator;
	filesToDelete : CM_EDIFileSet;
	rules : CM_EDIPartyRules;
	cargoType : CM_CargoType;
	ediTI : CM_EDITrackedItem;
	ti : CM_TrackedItem;
	tempStr : String;
begin
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, true);
	// self.setTerminalConfig(PortDestCode, "AUPKL");

	create filesToDelete transient;
	
	self.deleteVoyage(VoyageNameOther);
	voyage1 := self.getVoyage(VoyageNameOther);
	self.assertIsDeleted(voyage1);

	self.deleteVoyage(VoyageName1);
	voyage1	:= self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);

	term := self.getTerminal;
	oper1 := app.myRoot.allOperators.getAtKey("UTOP");
	self.assertTrueMsg(oper1 &lt;&gt; null, "Operator of 'UTOP' not found during setup.");
	
	vessel := self.addVesselCellular(BoatName, oper1);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage1 := self.addVoyageWithContainerStructur(	VoyageName1,
													BoatName,
													oper1.code,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1, 'Add voyage failed');
	
	klinOper := app.myRoot.allOperators.getAtKey("KLIN");
	self.assertNotNullMsg(klinOper, 'KLIN operator not found in set up');
	wlaOper := app.myRoot.allOperators.getAtKey("WLA");
	self.assertNotNullMsg(wlaOper, 'WLA operator not found in set up');
	
	beginTransaction;
	if voyage1 &lt;&gt; null then
		port := app.myRoot.allPorts["AUADL"];
		if not voyage1.includesPort(port) then
			voyage1.addPortToAllPorts(port);
		endif;
		port := app.myRoot.allPorts["AUPKL"];
		if not voyage1.includesPort(port) then
			voyage1.addPortToAllPorts(port);
		endif;
		if not voyage1.allOperators.includes(klinOper) then
			voyage1.allOperators.add(klinOper);
		endif;
		if not voyage1.allOperators.includes(wlaOper) then
			voyage1.allOperators.add(wlaOper);
		endif;
	endif;
	commitTransaction;
	
	carCargoType := app.myRoot.allCargoTypesById.getAtKey(7);
	
	mazdaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00231");
	if mazdaConsign = null then
		mazdaConsign := self.addConsigneeConsignor("00231","MAZDA AUSTRALIA PTY",true,true,false);
	endif;
	mazdaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("MAZDA");
	self.assertTrueMsg(mazdaMake &lt;&gt; null, "Vehicle Make of 'MAZDA' not found during setup.");
	
	hondaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00172");
	if hondaConsign = null then
		hondaConsign := self.addConsigneeConsignor("00172","HONDA AUSTRALIA PTY",true,true,false);
	endif;
	hondaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("HONDA");
	self.assertTrueMsg(hondaMake &lt;&gt; null, "Vehicle Make of 'HONDA' not found during setup.");
	
	isuzuConsign := app.myRoot.allConsigneeConsignors.getAtKey("01636");
	if isuzuConsign = null then
		isuzuConsign := self.addConsigneeConsignor("01636","+ISUZU AUSTRALIA LTD",true,true,false);
	endif;
	isuzuMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("ISUZU");
	self.assertTrueMsg(isuzuMake &lt;&gt; null, "Vehicle Make of 'ISUZU' not found during setup.");
	
	mclarenConsign := app.myRoot.allConsigneeConsignors.getAtKey("MCL");
	if mclarenConsign = null then
		self.assertTrueMsg(mclarenMake &lt;&gt; null, "Vehicle Make of 'MCLAREN' not found during setup.");
	endif;
	mclarenMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("MCLAREN");
	self.assertTrueMsg(mclarenMake &lt;&gt; null, "Vehicle Make of 'MCLAREN' not found during setup.");
	
	bmwConsign := app.myRoot.allConsigneeConsignors.getAtKey("BMWAU");
	if bmwConsign = null then
		bmwConsign := self.addConsigneeConsignor("BMWAU","BMW AUSTRALIA LTD",true,true,false);
	endif;
	bmwMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("BMW");
	self.assertTrueMsg(bmwMake &lt;&gt; null, "Vehicle Make of 'BMW' not found during setup.");
	
	lrConsign := app.myRoot.allConsigneeConsignors.getAtKey("LRU");
	if lrConsign = null then
		lrConsign := self.addConsigneeConsignor("LRU","LAND ROVER EXPORTS LTD",true,true,false);
	endif;
	lrMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("LAND ROVER");
	self.assertTrueMsg(lrMake &lt;&gt; null, "Vehicle Make of 'LAND ROVER' not found during setup.");
	
	self.deleteEDIInwardXlation(ForeignOperatorCode1, XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation(ForeignOperatorCode2, XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation(ForeignOperatorCode3, XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation('MCLAREN AUTOMOTIVE ASIA PTE LT', XLATION_TYPE_CONSIGNEE_BYOP, klinOper, null);
	self.deleteEDIInwardXlation('LAND ROVER EXPORTS LTD', XLATION_TYPE_CONSIGNEE_BYOP, klinOper, null);
	self.deleteEDIInwardXlation('BMW AUSTRALIA LTD', XLATION_TYPE_CONSIGNEE_BYOP, klinOper, null);
	self.deleteEDIInwardXlation('MCLAREN AUTOMOTIVE ASIA PTE LT', XLATION_TYPE_CONSIGNEE_BYOP, wlaOper, null);
	self.deleteEDIInwardXlation('LAND ROVER EXPORTS LTD', XLATION_TYPE_CONSIGNEE_BYOP, wlaOper, null);
	self.deleteEDIInwardXlation('BMW AUSTRALIA LTD', XLATION_TYPE_CONSIGNEE_BYOP, wlaOper, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, wlaOper, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, klinOper, null);
	
	self.createEDIXlation(ForeignOperatorCode1,oper1.code, XLATION_TYPE_OPERATOR, false, null, null);
	self.createEDIXlation(ForeignOperatorCode2,wlaOper.code, XLATION_TYPE_OPERATOR, false, null, null);
	self.createEDIXlation(ForeignOperatorCode3,oper1.code, XLATION_TYPE_OPERATOR, false, null, null);
	self.createEDIXlation('MCLAREN AUTOMOTIVE ASIA PTE LT', mclarenConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, klinOper, null);
	self.createEDIXlation('LAND ROVER EXPORTS LTD', lrConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, klinOper, null);
	self.createEDIXlation('BMW AUSTRALIA LTD', bmwConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, klinOper, null);
	self.createEDIXlation('MCLAREN AUTOMOTIVE ASIA PTE LT', mclarenConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, wlaOper, null);
	self.createEDIXlation('LAND ROVER EXPORTS LTD', lrConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, wlaOper, null);
	self.createEDIXlation('BMW AUSTRALIA LTD', bmwConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, wlaOper, null);
	self.createEDIXlation(ForeignVoy1, voyage1.code, XLATION_TYPE_VOYAGETERMINAL, false, klinOper, null);
	self.createEDIXlation(ForeignVoy2, voyage1.code, XLATION_TYPE_VOYAGETERMINAL, true, wlaOper, null);

	//KLINES
	
	self.deleteEDIParty(EDIPartyName &amp; "_KLINE");
	ediParty := self.createEDIParty(EDIPartyName &amp; "_KLINE", method.qualifiedName &amp; " Unit Test", "KLINE_COAST", klinOper); 
	if app.isRunningInDMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10046);		//Cannon
	elseif app.isRunningInWMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10056);		//Cannon
	endif;
//	self.createEDIPartyIFCSUM49B(ediParty, mazdaConsign, carCargoType, mazdaMake, false, false, false, null);
//	self.createEDIPartyIFCSUM49B(ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null);
//	self.createEDIPartyIFCSUM49B(ediParty, isuzuConsign, carCargoType, isuzuMake, false, false, false, null); 						
	self.createEDIPartyIFCSUMPOB49B(ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null, cargoType, true);
//	rules := ediParty.getRulesForFileType (EDIFileType_IFCSUM94B);
//	beginTransaction;
//	rules.setPropertyValue(CM_EDIPartyIFCSUMRules::myDefaultCargoType.name, cargoType);
//	commitTransaction;
	
	ediData := self.xIFCSUMPOB94Bfile_1;
	ediFile	:=	self.ediLoadFileName(ediData, EDIFileType_Unknown, "POB_IFCSUM94B_KLINE", "POB_IFCSUM94B_KLINE" &amp; method.name);
	self.assertTrueMsg(ediFile &lt;&gt; null, "EDI file not created. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	//ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, "POB_IFCSUM94B_KLINE", "POB_IFCSUM94B_KLINE"&amp;method.name, EDIFileType_Unknown, true, true, false, false, null);
	self.clearExpectedTrxErrors();
	self.expectTrxError(Inv_dis_por_not_in_disch_comp);
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED);
	
	self.clearExpectedTrxErrors();
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	filesToDelete.add(ediFile);

	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 26, "Total number of ediTis");
    foreach ediTI in ediFile.ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			if ediTI.CM_EDICargoOnShipTI.id = "510270" then
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "Motor Vehicle", "For Item 1");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.make, "HONDA", "For Item 1"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "JPYOK", "For Item 1"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "KKLUJPN476547", "For Item 1");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "AUPKL", "For Item 1"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "JPYOK", "For Item 1"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "AUPKL", "For Item 1"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 1, "For Item 1"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "1851.0000", "For Item 1"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "15.962", "For Item 1"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "00172", "For Item 1");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 1");
			elseif ediTI.CM_EDICargoOnShipTI.id = "00000002" then
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "Cannon", "For Item 2");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "", "For Item 2"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "00000002", "For Item 2");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "AUPKL", "For Item 2"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "JPNAN", "For Item 2"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "", "For Item 2"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 192, "For Item 2"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "246910.00", "For Item 2"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "2351.460", "For Item 2"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "00172", "For Item 2");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 2");
			elseif ediTI.CM_EDICargoOnShipTI.bol = "00000003" then
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "Cannon", "For Item 3");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "", "For Item 3"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "00000003", "For Item 3");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "AUPKL", "For Item 3"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "JPYOK", "For Item 3"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "", "For Item 3"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 23, "For Item 3"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "115855.0000", "For Item 3"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "1303.796", "For Item 3"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "00172", "For Item 3");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 3");
			elseif ediTI.CM_EDICargoOnShipTI.bol = "00000004" then
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "Cannon", "For Item 4");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "", "For Item 4"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "00000004", "For Item 4");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "AUADL", "For Item 4"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "JPYOK", "For Item 4"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "", "For Item 4"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 2, "For Item 4"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "8200.0000", "For Item 4"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "90.250", "For Item 4"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "00172", "For Item 4");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 4");
			elseif ediTI.CM_EDICargoOnShipTI.bol = "00000005" then
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "Cannon", "For Item 5");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "", "For Item 5"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "00000005", "For Item 5");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "AUPKL", "For Item 5"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "JPHIJ", "For Item 5"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "", "For Item 5"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 136, "For Item 5"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "221940.0000", "For Item 5"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "2032.961", "For Item 5"); 
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "00172", "For Item 5");
				self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 5");
			endif;
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
			if ediTI.CM_EDIBOLHdrTI.id = "00000001" then
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "00000001", "For BOL 1");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "JPYOK", "For BOL 1");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "AUPKL", "For BOL 1"); 
			elseif ediTI.CM_EDIBOLHdrTI.id = "00000002" then
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "00000002", "For BOL 2");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "JPNAN", "For BOL 2");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "AUPKL", "For BOL 2"); 
			elseif ediTI.CM_EDIBOLHdrTI.id = "00000003" then
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "00000003", "For BOL 3");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "JPYOK", "For BOL 3");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "AUPKL", "For BOL 3"); 
			elseif ediTI.CM_EDIBOLHdrTI.id = "00000004" then
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "00000004", "For BOL 4");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "JPYOK", "For BOL 4");
				self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "AUADL", "For BOL 4"); 
