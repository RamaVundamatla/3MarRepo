    <JadeMethod name="pxyCreateUpdateProxy" id="09fcd788-dd62-4dac-b862-833c98141856">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyJob	: SelfType;
	completedOK		: Boolean;
begin
	proxyJob := inheritMethod();

	self.allHatchLids.copy(proxyJob.allHatchLids);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyJob;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyJob;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setBayId" id="4a2ae848-53e1-45dc-a2b0-ccd87f9676d0">
        <updating/>
        <source>setBayId(_theJobParams: CMIF_VoyageJobParams) updating;
//--------------------------------------------------
// Created:	26 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _theJobParams.myBay &lt;&gt; null then
		self.bayId := _theJobParams.myBay.id;
	elseif _theJobParams.myDeck &lt;&gt; null then
		self.bayId := _theJobParams.myDeck.code; //epr CCMS 1033 28/7/11
	else
		inheritMethod(_theJobParams);	
	endif;
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams"/>
    </JadeMethod>
