// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ld	:CM_LDBoom;
begin
	ld := self.getLaneDevice_Boom(_inBoom);
	
	if ld &lt;&gt; null then
		return ld.myBoom;
	endif;
	
	return null;
epilog

end;</source>
