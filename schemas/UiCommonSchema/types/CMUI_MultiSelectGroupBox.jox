        <source>setupControl(	_headingName : String; 
				_collection : Collection; 
				_displayMethodName : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2009	cnwer1	Initial creation

*/

vars

begin
	if _displayMethodName &lt;&gt; null then
		self.formDisplayEntryMethodName := _displayMethodName;
