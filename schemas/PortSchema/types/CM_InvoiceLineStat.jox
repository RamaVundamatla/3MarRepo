    <JadeMethod name="rateForPrinting" id="21ab61b2-abc8-4bb3-812d-a5a3c6cfaf94">
        <source>rateForPrinting() : String;
// ---------------------------------------------------------------------------
//	Created:		17 April 2003  by Jason Chapman  (cnwjc2)
//	
//	Rate for printing purposes - POE reports.
//
//	Due to changes in rounding we now charge at a higher precision
//
//	Returns rate to 2 d.p. or significant value which ever has the highest number 
//	of d.p.
//---------------------------------------------------------------------------------

vars
	point,
	figure,
	leastSignif	: Integer;
	strRate		: String;
	dpl : Integer;
begin
	
	strRate := self.rate.String;
	point := strRate.pos('.',1);
	
	if point = 0 then
		//return rate.asStringJMTWithPrecision($CM_RateMoney.decimalPlaces, false);
		
		// TFS 36954 MPD 20 Feb 2018
		if self.getMyTerminal &lt;&gt; null then
			dpl := self.getMyTerminal.getConfig(FinancialRateDPlaces).Integer;
		else
			dpl := $CM_RateMoney.decimalPlaces;
		endif;
		
		return rate.asStringJMTWithPrecision(dpl, false);
	endif;
	
	leastSignif := point + 2;	//default is 2 d.p.
	
	//check digits after 2 d.p. for significant digits
	foreach figure in point + 3 to strRate.length do
		if strRate[figure] &lt;&gt; '0' then
			//update least significant digit position
			leastSignif := figure;	
		endif;
	endforeach;
	
	if leastSignif &gt; 13 then // AKB - they can consolidate down to one line, where we calculate teh rate on the fly. This can mean very small numbers.
		leastSignif := 13; // AKB
	endif;
	return strRate[1:leastSignif];

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
