        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="a4b2ebfc-8be4-4d0e-a66c-896a86008148">
        <source>outputAsXML() : String;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*
&lt;client&gt;
&lt;name&gt;JADE Master Terminal&lt;/name&gt;
&lt;site&gt;true&lt;/site&gt;
&lt;num&gt;35&lt;/num&gt;
&lt;terminal&gt;
&lt;name&gt;Terminal One&lt;/name&gt;
&lt;details&gt;1:2:3:4&lt;/details&gt;
&lt;/terminal&gt;
&lt;/client&gt;
*/
vars
	termStr	: String;
	tmpTerm	: DEV_LicenseDtl;

begin

	foreach tmpTerm in self.allLicenseDtls do
		termStr := termStr &amp; tmpTerm.outputAsXML();
	endforeach;

	return self.formatAsXMLPrefix(XMLTag_Client) &amp;
		   self.formatAsXML(XMLTag_ClientName, self.name) &amp;
		   self.formatAsXML(XMLTag_Site, self.hasSiteLicense.String) &amp;
		   self.formatAsXML(XMLTag_IsRealClient, self.isRealClient.String) &amp;
		   self.formatAsXML(XMLTag_Notes, self.notes) &amp;
		   self.formatAsXML(XMLTag_Num, self.numTerminals.String) &amp;
		   termStr &amp;
		   self.formatAsXMLSuffix(XMLTag_Client);

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="11457678-62e3-4ca4-b9db-fe7cb0a046a8">
        <updating/>
        <source>setForCreate(_name : String) updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	licTerm		: DEV_LicenseDtl;

begin

	self.name			:= _name;
	self.numTerminals	:= 1;
	self.hasSiteLicense	:= true;
	
	create licTerm transient;
	licTerm.setForCreate(_name, LicenseType_System, self);

end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9ebd838a-f9e9-4361-a2b4-2cb9fb493a78">
        <updating/>
        <source>setForUpdate(_name : String; _numTerminals : Integer; _siteLicense, _isRealClient : Boolean;
			_notes : String) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.name	:= _name;
	self.numTerminals	:= _numTerminals;
	self.hasSiteLicense	:= _siteLicense;
	self.isRealClient	:= _isRealClient;
	self.notes			:= _notes;

	if self.mySystemLicense &lt;&gt; null then
		self.mySystemLicense.setNameFromClient(_name);
	endif;
	
	if self.myEDILicense &lt;&gt; null then
		self.myEDILicense.setNameFromClient(_name);
	endif;
	
	// ### JIRA 33543 12DEC2024 NAVAB1
	if self.myEWSLicense &lt;&gt; null then
		self.myEWSLicense.setNameFromClient(_name);
	endif;
	
	//17 Jun 2020	NDL	TFS 49569
	if self.mySubscriptionLicense &lt;&gt; null then
		self.mySubscriptionLicense.setNameFromClient(_name);
	endif;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_numTerminals" type="Integer"/>
        <Parameter name="_siteLicense" type="Boolean"/>
        <Parameter name="_isRealClient" type="Boolean"/>
        <Parameter name="_notes" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="3e28e3c2-2346-44da-b4f2-9d4f4b8e1a94">
        <updating/>
        <source>setFromXML(_xml : String) updating;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*
&lt;client&gt;
&lt;name&gt;JADE Master Terminal&lt;/name&gt;
&lt;site&gt;true&lt;/site&gt;
&lt;num&gt;35&lt;/num&gt;
&lt;terminal&gt;
&lt;name&gt;Terminal One&lt;/name&gt;
&lt;details&gt;1:2:3:4&lt;/details&gt;
&lt;realClient&gt;true&lt;/realClient&gt;
&lt;notes&gt;These are some notes&lt;/notes&gt;
&lt;/terminal&gt;
&lt;/client&gt;
*/
vars
	termXML	: String;
	pos		: Integer;
	tmpTerm	: DEV_LicenseDtl;

begin

	self.name			:= _xml.cnEcGetTagValueOfName(XMLTag_ClientName);
	self.hasSiteLicense	:= _xml.cnEcGetTagValueOfName(XMLTag_Site).Boolean;
	self.isRealClient	:= _xml.cnEcGetTagValueOfName(XMLTag_IsRealClient).Boolean;
	self.notes			:=  _xml.cnEcGetTagValueOfName(XMLTag_Notes);
	self.numTerminals	:= _xml.cnEcGetTagValueOfName(XMLTag_Num).Integer;
	
	pos := 1;
	while (pos &gt; 0) do
		termXML := _xml.cnEcGetNextTagValueOfName(XMLTag_Terminal, pos);
		if termXML &lt;&gt; null then
			create tmpTerm transient;
			tmpTerm.setFromXML(termXML, self);
			
			// ### JIRA 33541 13DEC2024 NAVAB1
			if tmpTerm.type = 5 then // HACK
//				delete tmpTerm;
//				continue;
				
				tmpTerm.setTEMPEWS(self);
			endif;
		endif;
	endwhile;

	// ### JIRA 33541 16DEC2024 NAVAB1
	self.createEWSLicense();
end;</source>
        <Parameter name="_xml" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTEMPEWS" id="6aa6363f-efcd-4719-8b51-a7e731bea59f">
        <updating/>
        <source>setTEMPEWS(_detail : DEV_LicenseDtl   ) updating;
/*
Purpose:	

Date		Who		Reason
13 December 2024	navab1	JIRA 33543
*/

vars

begin
	self.myEWSLicense := _detail;
epilog

end;</source>
        <Parameter name="_detail" type="DEV_LicenseDtl"/>
    </JadeMethod>
</Class>
