    <JadeMethod name="resetLstResourceTables" id="762e543f-ab7a-4f59-95fe-12c9d823a48e">
        <source>resetLstResourceTables();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/01/2014	cnwdap1		Initial creation PAR #33337 CCMS PTR 2214 HMS Enhancements
//
vars
	assistant : CMUI_Assistant;
	
begin
	assistant := self.myAssistant;

	self.lstResTypeArriva.clearAllSelected();
	self.lstResTypeShift.clearAllSelected();
	self.lstResTypeDepart.clearAllSelected();
	
	self.lstResTypeArriva.rows := self.lstResTypeArriva.fixedRows;
	self.lstResTypeDepart.rows := self.lstResTypeDepart.fixedRows;
	self.lstResTypeShift.rows := self.lstResTypeShift.fixedRows;
	
	assistant.listTableResouceType(self.lstResTypeArriva);
	assistant.listTableResouceType(self.lstResTypeShift);
	assistant.listTableResouceType(self.lstResTypeDepart);	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="7251a350-2161-48cc-b89c-9bc9900b530f">
        <updating/>
        <source>setColorsFromController(_colorControl : CM_ColorController) updating;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
//--------------------------------------------------
vars

begin
	
	inheritMethod(_colorControl);
	
	self.setColorsForMultiSelectGrpBox(self.mulStevedoreDisc);
	self.setColorsForMultiSelectGrpBox(self.mulStevedoreLoad);	
	self.setColorsForMultiSelectGrpBox( self.mulOperators );	// cnwrl1 28/05/2009 PAR 19672

	self.sptHMSStevedore.backColor := self.backColor;

	self.tblNewDimensions.accessRow(1).backColor := self.colorHeadingColumn;	
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="b7eab705-79ac-4751-af5f-f3f42d8ccec6">
        <updating/>
        <source>setControlsForAddEdit(_copyAsNewVoyage : Boolean) updating;
//--------------------------------------------------------------
//Created: 08 May 2003 By: cnwgd1
//
//11 Mar 2013		PJS		PAR # 31232
//--------------------------------------------------------------
//25/01/17 		cnwns1 	    TFS3214 LNX - Voyage Operations Enhancements 
// 24/02/2017   cnwrh7      TFS3464       #- Voyage definition / voyage status
// 11/04/2017	cnwdap1	    TFS 4050 LNX Job ID Enhancements
// 26/06/2017   cnwrh7  	TFS4551   POL - Voyage Cut -offs default settings
// 15/03/2018	jlgdap1		TFS 37427 PEL1 Voyage Status Enhancements
// 16/03/2018	jlgdap1		TFS 37540 PEl1 Voyage Statuses Pelindo 1 
// 23/04/2018	jlgdap1		TFS 38215 PEL1 OOW Confirmation Changes
// 34/04/2018	jlgdap1		TFS 38214 PEL1 Voyage Status Changes
// 03/06/2020 	cnwma1 		ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 09/03/2022	jlizm1		TFS 52834 SAL file attachments filter by work order
// 27/04/2022	navak20		TFS 53142	Cargo Forecast Formm
vars
	tsNow			  : TimeStamp;
	theDefaultCompany : CM_Bank;
	voyageProcess 	  : CM_VoyageProcess;			// TFS 37427
	statuses 	      : CM_VoyageStatusByPriority;
	currentStatus 	  : Integer;
	stat 			  : CM_VoyageStatus;
	vessel 			  : CM_Vessel;
	vesselData 		  : HMS_VesselData;
	
begin
	
	// This method enables/disabled the controls and sets some defaults only
	// To populate a control with existing voyage data please use method self.displayVoyage();
	
	if self.mode = self.Mode_View then
		self.btnAddDelay.enabled := true;	//26 Sep 2018	NDL	TFS 40628
		self.btnAddMovement.enabled := true;	//26 Sep 2018	NDL	TFS 40628
		self.frmCutoffDataEntry.enabled := false;
		return;
		
	elseif self.mode = self.Mode_Add then
		// ### JIRA 34233 13MAR 2025 NAVAB1
		self.btnCutoffEdit.enabled := false; 
		self.frmCutoffDataEntry.enabled := false;
		self.tblVoyageCutoffs.enabled := false;
		self.ckbOverrideDef.enabled := false;

		self.setEnableObjects(true);
		self.cmbInvoiceStatus.text := Voyage_Invoice_StatStr_NotGen; // PAR 22309 since 2005 this has been Voyage_Invoice_StatStr_NotReq, butu teh 2005 spec says Voyage_Invoice_StatStr_NotGen
		
		if self.grpCellulaVoyage.visible then

			if (not _copyAsNewVoyage) then
				// DEFAULTS
				//theDefaultCompany := self.myTerminal.getConfig(DefCompany).CM_Bank;
				theDefaultCompany := self.myTerminal.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
				if theDefaultCompany &lt;&gt; null then
					if self.cmbBank.findObject(theDefaultCompany) &gt; 0 then
						self.cmbBank.listObject := theDefaultCompany;
					else
						self.cmbBank.listObject := null;
					endif;
				else
					self.cmbBank.listObject := null;
				endif;
				
// PAR 33644				self.ckbPlanned.value := true;
// PAR 33644				self.ckbWorked.value := true;
			//	self.ckbCreateStructu.value := true;   // 31232						
				if self.cmbMoveMapRec.enabled
				and self.cmbMoveMapRec.listCount &gt; 0 then
					self.cmbMoveMapRec.listIndex := 1;
					self.cmbMoveMapRel.listIndex := 1;
				endif;
				
				tblVesselStruct.setValueByName(ETRow_IncludesLOLO,true); // 31232
				
			endif;

			//self.ckbCreateStructu.enabled	:=	true;			// 31232
			self.dateNonPlanned.enabled		:=	false; // (not self.ckbPlanned.value);
			self.timeNonPlanned.enabled		:=	self.dateNonPlanned.enabled;
			//self.cmbStatus.listIndex		:=	self.cmbStatus.findString(0,app.getErrorString(VoyageCmb_Status_Pending_Str));	// TFS 37427
			voyageProcess					:=	self.myTerminal.getDefaultVoyageProcess;										// TFS 37427
			self.cmbProcess.listIndex		:=	self.cmbProcess.findObject(voyageProcess);										// TFS 37427
			if voyageProcess &lt;&gt; null then
				//epr TFS 41523 2/11/18
				self.initComboVoyageStatus(voyageProcess,null);
			endif;																												// TFS 37427
			self.cmbWStopCharging.enabled	:=	true;
		endif;
		
		//only do this for HARBOUR - OK'd by RJS
		if self.shtHMSHarborData.visible then
			tsNow := self.systemToLocalTime(app.actualTimeServer);// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.dateArrival.setDate(tsNow.date());
			self.timeArrival.setTime(tsNow.time());
			// PAR 11156
			if self.myTerminal.getConfig(PrefillVoyageDepartDate).Boolean then
				self.dateDeparture.setDate((tsNow.date + 2));
				self.timeDeparture.setTime(tsNow.time());
			else
				self.dateDeparture.setDate(null);
				self.timeDeparture.text := null;
			endif;
			
			if self.initCopyAsNewVoyage // PAR 36959
			and self.btnCopyVoyage.enabled  // PAR 36959
			and self.myCurrentVessel &lt;&gt; null then // PAR 36959
				if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myHMSVoyageData &lt;&gt; null then
					self.ckbCreateHMSData.value := self.myCurrentVoyage.myHMSVoyageData.allVoyageMovements.size() &gt; 0;		// 21/8/19 MAP TFS45296
				else
					self.ckbCreateHMSData.value := self.myCurrentVessel.hasHarbourDetails(); // PAR 36959
				endif;
			else
				if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myHMSVoyageData &lt;&gt; null then
					self.ckbCreateHMSData.value := self.myCurrentVoyage.myHMSVoyageData.allVoyageMovements.size() &gt; 0;		// 21/8/19 MAP TFS45296
				else
					self.ckbCreateHMSData.value := true;
				endif;
			endif;
			
		//	self.ckbOverrideDef.value := false;		// 27/05/2009 cnwar2 CCMS1040/#19796	//-TFS4551
		//	self.loadRecCutoffsTbl(null);			// 27/05/2009 cnwar2 CCMS1040/#19796			//-TFS4551
			
			if (not _copyAsNewVoyage) then
				//self.cmbPortFrom.setObject(app.myRoot.allPorts.first);									
				//self.cmbPortTo.setObject(app.myRoot.allPorts.first);
				self.cmbPortFrom.setObject(app.myRoot.allActivePorts.first);									
				self.cmbPortTo.setObject(app.myRoot.allActivePorts.first);
			endif;

			self.btnAddDelay.enabled := false;
			self.btnDeleteDelay.enabled := false;
			self.btnEditDelay.enabled := false;		
			self.btnAddMovement.enabled := false;
			self.btnEditMovement.enabled := false;
			self.btnDeleteMove.enabled := false;

			self.optBerth.click(self.optBerth);
			self.cmbMaster.click (self.cmbMaster);
		endif;
		
		self.ckbOverrideDef.value := false;		// 27/05/2009 cnwar2 CCMS1040/#19796	//+TFS4551 always make it false no matter the Harbor licence given or not
		
		// ### JIRA 34233 06MAR 2025 NAVAB1
//		self.loadVoyageCutoffsTbl(null);
		self.createProxyCutoffs(null);
		self.loadVoyageCutoffsToTable(null);	
		
		// TFS 37540 Can only seelct the Voyage Process on Add
		self.cmbProcess.enabled := true;
		
		self.ckbIgnoreCutOff.value := false;	// 31.Aug.2023 navsp1 TFS 57809
	else
		// mode = update

		// ### JIRA 34233 13MAR 2025 NAVAB1
		self.frmCutoffDataEntry.enabled := false;
		self.tblVoyageCutoffs.enabled := true;
		self.ckbOverrideDef.enabled := true;
		
		self.setEnableObjects(true);			

		if self.myCurrentVoyage.getMyVessel() &lt;&gt; null then
			self.cmbVessel.enabled := false;
		else
			self.cmbVessel.enabled := true;									
		endif;
	
		if self.grpCellulaVoyage.visible then
			
		//	self.ckbCreateStructu.enabled := false; // 31232
			if self.myCurrentVoyage.myCellularVoyageStructure &lt;&gt; null then
				// CCMS 1009
			//	self.ckbCreateStructu.enabled := true;			// 31232 
				/* CCMS 1009 they are now able to delete the structures if no planning/loading has taken place.
				if self.myCurrentVoyage.CM_CellularVoyage.allBayVoyagesByOrdinal.isEmpty then
					self.ckbCreateStructu.enabled := true;
				endif;*/
			endif;
			
// PAR 33644			if self.myCurrentVoyage.isNonPlannedVoyage then
			if self.myCurrentVoyage.isHOLDSorSHIP() then
				self.dateNonPlanned.enabled := true;
				self.timeNonPlanned.enabled := true;			
			else
				self.dateNonPlanned.enabled := false;
				self.timeNonPlanned.enabled := false;				
			endif;

			if self.cmbBank.listObject = null then
				//theDefaultCompany := self.myTerminal.getConfig(DefCompany).CM_Bank;
				theDefaultCompany := self.myTerminal.getDefaultCompanyBank();	//17 Apr 2012 NDL	Par 29393
				self.cmbBank.listIndex := self.cmbBank.findObject(theDefaultCompany);
		    endif;				
		endif;

		
		// PAr # 31322
		// now allow changes in structure type irrespective of what is currently selected
		
		/*
		if self.cmbStructureType.text &lt;&gt; StructureTypeNullStr then
			self.cmbStructureType.enabled := false;
		elseif app.getMyUser.canDo(self.myTerminal, PmContainerMod) 
		or app.getMyUser.canDo(self.myTerminal, PmLogsMod) then 
			self.cmbStructureType.enabled := true;
		endif;
		*/
		
		//Only disable if HMSVoyageData has been created
		if self.myCurrentVoyage.myHMSVoyageData &lt;&gt; null then
			//Cannot update here as movements not updated, must be done via the graphical view at this time
			if self.myCurrentVoyage.myHMSVoyageData.voyageStatus = HMS_VoyageIsLocked then
				//Voyage is locked therefore they cannot change date/times berth etc
				self.dateArrival.enabled 	:= false;
				self.timeArrival.enabled 	:= false;
				self.dateDeparture.enabled 	:= false;
				self.timeDeparture.enabled 	:= false;
				self.grpBerthage.enabled 	:= false;				
			endif;
			// cannot update berth here - only update via graphical view
			self.optBerthPref.enabled 	:= false;
			self.optBerth.enabled 		:= false;
			self.cmbBerth.enabled 		:= false;
			self.cmbBerthPref.enabled 	:= false;
		endif;
		
		// TFS 37540 Can't change the Voyage Process once it's been set on Add
		if app.isSpecial then
			self.cmbProcess.enabled := true;
		else
			self.cmbProcess.enabled := false;
		endif;
		// TFS 37540 end
	endif;

	if self.shtHMSHarborData.visible then
		if self.myTerminal.myHarbour = null then
			//Cannot create HMS details as terminal is not associated with a harbour
			self.ckbCreateHMSData.value := false;
			self.ckbCreateHMSData.enabled := false;
		else
		/*  // PAR 36959
			if self.mode = self.Mode_Update
			and self.myCurrentVoyage &lt;&gt; null
			and self.myCurrentVoyage.myHMSVoyageData &lt;&gt; null then
				self.ckbCreateHMSData.enabled := false;
			else
				// PAR 36959 self.ckbCreateHMSData.enabled := true;
				if self.myCurrentVessel &lt;&gt; null then
					self.ckbCreateHMSData.enabled := self.myCurrentVessel.hasHarbourDetails();
				else
					self.ckbCreateHMSData.enabled := true;
				endif;
			endif;
			*/
			 self.ckbCreateHMSData.enabled := false; // PAR 36959
			
			//31 Dec 2019	NDL	TFS 48162 - allow them to turn on create harbour details for voyage under very exacting conditions
			if self.mode = self.Mode_Update
			and self.myCurrentVoyage &lt;&gt; null
			and self.myCurrentVoyage.myHMSVoyageData &lt;&gt; null
			and self.myCurrentVoyage.myHMSVoyageData.allVoyageMovements.isEmpty then
				vessel := self.myCurrentVoyage.myVessel;
				if vessel &lt;&gt; null then
					vesselData := vessel.myHMSVesselData;
					if vesselData.hasHarbourDetails then
						self.ckbCreateHMSData.enabled := true;
					endif;
				endif;
			endif;
			
		endif;
	endif;	

	self.btnCopyVoyage.enabled 		:= false;
	self.btnEditTV.enabled 			:= false;
	self.btnNewTV.enabled 			:= false;	
	self.cmbVoyage.enabled 			:= false;
	self.btnDeleteTV.enabled 		:= false;
	self.btnArchive.enabled 		:= false;	
	self.btnSaveBase.enabled 		:= true;
	self.btnCancelBase.enabled 		:= true;		
	self.btnBayDefinition.enabled 	:= false;
	
	self.btnExchangeSum.enabled := false;  // PAR 35478
	self.btnTranslations.enabled := false;  // PAR 35478
	self.btnCheckList.enabled := false;							// TFS 4793
	self.btnEventTrans.enabled := false;  // PAR 35478
	self.btnEventAlloc.enabled := false;	//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
	self.btnOOWConfirm.enabled := false;			// TFS 38215
	
	self.btnShippingLine.enabled := false;  // PAR 35478
	self.btnVesselDef.enabled := false;  // PAR 35478
	
	self.btnROROEnquiry.enabled := false;	//10 Jul 2013	NDL	Par 31965
	self.btnHoldDef.enabled := false;	//10 Jul 2013	NDL	Par 31965
	self.btnResourcesUsed.enabled 	:= false;	
	self.btnWPOpHrsEdit.enabled 	:= false;	//02 Apr 2012	NDL	Par 29369
	
	self.btnCargoForecast.enabled	:= false;	// 27 April 2022 navak20 TFS 53142
	
	if self.shtHMSHarborData.visible then
		self.setEnableHMSData(self.ckbCreateHMSData.value);
		//self.shtHMSMovements.enabled := false;
		// 11/05/2012 cnwar2 #14987 - instead of disabling sheet, make everything readonly
		self.shtHMSMovements.enabled 	:= true;
		self.tblHMSMovements.readOnly 	:= true;
		self.tblDelays.readOnly 		:= true;
		self.btnAddMovement.enabled		:= false;
		self.btnEditMovement.enabled	:= false;
		self.btnDeleteMove.enabled		:= false;
		self.btnAddDelay.enabled		:= false;
		self.btnEditDelay.enabled		:= false;
		self.btnDeleteDelay.enabled		:= false;
	endif;

	self.btnDocuments.enabled := false; // TFS 52834

//	self.tblRecCutoffs.userInputEnabled := self.ckbOverrideDef.value;															// 27/05/2009 cnwar2 CCMS1040/#19796
	self.btnAddOperator.enabled 		:= self.ckbOverrideDef.value and (self.myTerminal.allReceivalCutoffDefs.size &gt; 0);		// 27/05/2009 cnwar2 CCMS1040/#19796
	
	if self.myTerminal.getConfig(CannotUpdateExternalCode).Boolean then			// TFS 4050
		self.txtExternalCode.enabled := false;									// TFS 4050
	endif;																		// TFS 4050
	
	if self.myTerminal.getConfig(CannotUpdateVoyGrpCode).Boolean then           //03/06/2020 cnwma1 TFS #49400
		self.txtGroupCode.enabled := false;	
	endif;
	
	//19 Mar 2021	NDL	TFS 50977
	if not self.dateNonPlanned.enabled then
		self.dateNonPlanned.text := null;
		self.timeNonPlanned.text := null;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmShipIgnoreCutOffsMaint ) then	//30.Aug.2023 navsp1 TFS 57809
		self.ckbIgnoreCutOff.enabled := false;
		self.ckbIgnoreCutOff.visible := false;
	endif;
	
epilog
	delete statuses;
end;</source>
        <Parameter name="_copyAsNewVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="c0e9fb78-cb7b-457a-8b5c-2d0a23a1f7c3">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbAccessType.style := 2;
	self.cmbBank.style := 2;
	self.cmbBerth.style := 2;
	self.cmbBerthPref.style := 2;
	self.cmbBerthPriority.style := 2;
	self.cmbCatArrive.style := 2;
	self.cmbCatDepart.style := 2;
	self.cmbDefaultColour.style := 2;
	self.cmbInvoiceStatus.style := 2;
	self.cmbLineCompany.style := 2;
	self.cmbLineGroupDebt.style := 2;
	self.cmbMaster.style := 3;
	self.cmbMoveMapRec.style := 2;
	self.cmbMoveMapRel.style := 2;
	self.cmbPaymentType.style := 2;
	self.cmbProcess.style := 2;
	self.cmbShipType.style := 2;
	self.cmbStatus.style := 2;
	self.cmbTidalClassAr.style := 2;
	self.cmbTidalClassDpt.style := 2;
	self.cmbVisitType.style := 3;
	self.cmbVoyOperator.style := 2;
	self.cmbWStopCharging.style := 2;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDateTimeFromHours" id="5d681980-5c02-4bcd-8a40-41307b36163e">
        <source>setDateTimeFromHours(_textbox : TextBox; _date : CMUI_DateMask input; _time : CMUI_TimeMask input);
/*
Purpose:	

Date		Who		Reason
11 March 2025	navab1	JIRA 34233
*/

vars

	hours : Decimal[23,2];
	targetTS, newTS : TimeStamp;
begin

	if self.myProxyCutoff= null then
		return;
	endif;

	hours := _textbox.text.Decimal;
	targetTS := self.getCutoffRelativeToTS(self.myProxyCutoff.defaultRelativeTo);
	
	
	if targetTS &lt;&gt; null then	
		newTS 		:= targetTS.subtractHoursAndMinutes (hours);
		
		_date.setDate(newTS.date);
		_time.setTime(newTS.time);
	endif;

epilog

end;</source>
        <Parameter name="_textbox" type="TextBox"/>
        <Parameter name="_date" type="CMUI_DateMask" usage="input"/>
        <Parameter name="_time" type="CMUI_TimeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDefaultVesselDataLastVisit" id="8be6c4a8-f166-453c-950d-98def90fb647">
        <source>setDefaultVesselDataLastVisit(_lastVoyData : HMS_VoyageData) protected;
//--------------------------------------------------
// Created:	04 August 2005 By: cnwgd1
//30/08/2019 	JLGNS1	ChangeRequest 45926: ASPA - JMT Interface to AR Oracle Stevedores
//--------------------------------------------------
vars
	tmpArrivalMove : HMS_VoyageMovement;
	tmpVoyData	: HMS_VoyageData;
	lastVoyage	: CM_Voyage;
  
begin

	// Prefill voyage details using the data from the last voyage of this vessel...
	
	if self.myCurrentVessel = null
	or self.mode &lt;&gt; self.Mode_Add 
	or self.myHarbour = null then
		return;
	endif;
	
	tmpVoyData := _lastVoyData;
	if tmpVoyData = null then
		// self healing, find the last visit for the vessel
		lastVoyage := self.myHarbour.getVesselsLastVoyage(self.myCurrentVessel.code);
		if lastVoyage &lt;&gt; null then
			tmpVoyData := lastVoyage.myHMSVoyageData;
		endif;
	endif;
	
	// default the from and to ports to that of the last visit
	if tmpVoyData &lt;&gt; null and tmpVoyData.allVoyageMovements.size() &gt; 0 then		// 2/9/19 MAP TFS45926
		self.cmbPortFrom.setObject(tmpVoyData.myPortFrom);
		self.cmbPortTo.setObject(tmpVoyData.myPortTo);
		self.cmbVisitType.cnEcSetObjectIndex(tmpVoyData.myVisitType);
		if tmpVoyData.allVoyageMovements.isNotEmpty then			//ChangeRequest 45926	
			tmpArrivalMove := tmpVoyData.allVoyageMovements.first;
		endif;
	endif;
	
	// default commodity and stevedore to that of the last visit or clear if no visit found
	self.displayCommodityStevedores(tmpVoyData);	

	// default berth to that of the last visits arrival movement		
	if tmpArrivalMove &lt;&gt; null then
		self.cmbBerth.listIndex :=  self.cmbBerth.findObject(tmpArrivalMove.getMyBerth);
		self.optBerth.value := (self.cmbBerth.listIndex &gt; 0);
		self.optBerth.click(self.optBerth);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_lastVoyData" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromLastVisit" id="77df4a1f-e662-46fb-ae9a-f31d16a51a2a">
        <updating/>
        <source>setDefaultsFromLastVisit(_vessel : CM_Vessel) : Boolean updating, protected;
//--------------------------------------------------
// Created:	11 January 2006 By: cnwgd1
//--------------------------------------------------
// 12/10/2011	cnwmh5	#28309 - Change so that if not last voyage still calls initVoyageAllocationSheet
// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 10/09/2019 	JLGNS1	Bug 46446: ADP - RE: JMT Error
// 23/02/2021	navdap1	TFS 50759 PNL Berth orientation specific to a berth
// 10/04/2025	navcs2	MTN-34548 SNO - Error Code 75768 when creating a new voyage
vars
	dwellHrs : Integer;
	now,
	estimatedDeptTime : TimeStamp;
	lastVoyage : CM_Voyage;
	tmpStr :String;
	lloydsNum : String;
	tmpBerth : HMS_Berth;				// TFS 50759
	pref : HMS_BerthPreference;			// TFS 50759
	tmpVDH : HMS_VesselDataHarbour;		// TFS 50759
	fromPref : Boolean;					// TFS 50759
begin
	if _vessel = null
	or self.mode &lt;&gt; self.Mode_Add then
		return false;
	endif;
	
	if self.myHarbour &lt;&gt; null then
		// Running HMS so get vessels last visit to the harbour (not terminal);
		lastVoyage := self.myHarbour.getVesselsLastVoyage(_vessel.code);
	else
		// Not licensed for HMS so get vessels last visit to this terminal
		lastVoyage := _vessel.getLastVoyage(self.myTerminal); 
	endif;

	if lastVoyage = null then
	// Par 15363 - For a vessel with no previous voyages, the caption was not displaying the corect cmbVessel selection 
		tmpStr := _vessel.name;
		self.setCaption(tmpStr &amp; ' - ' &amp; app.getErrorString(Voyage_Definition));
		self.initVoyageAllocationSheet(false);											// 12/10/2011 cnwmh5 #28309
		self.loadTankTable();															// 13/10/2011 cnwmh5 #28444
		self.loadSectionsTable();
		self.loadExternalRampTable();
		
		//13 Apr 2016	NDL	TFS 1790
		lloydsNum := self.txtLloydsNum.text.trimBlanks;
		if lloydsNum = null or lloydsNum = '0' then
			self.txtLloydsNum.text := _vessel.lloydsNumber.stripAlpha;	//Bug 46446
		endif;
	
		return false;
	endif;

	self.allProxyCutoffs.purge(); // ### JIRA 34233 11MAR 2025 NAVAB1
	
	// set reference to last voyage to display last voyage, re-set back to null below
	self.myCurrentVoyage := lastVoyage;
	self.myCopyGCStruct := null;	//10 Jul 2013	NDL	Par 31965
	self.displayVoyage(true);
	self.dateGenLanding.setDate(null); //20 May 2016	NDL	TFS 1980
	
	//13 Apr 2016	NDL	TFS 1790
	lloydsNum := self.txtLloydsNum.text.trimBlanks;
	if lloydsNum = null or lloydsNum = '0' then
		self.txtLloydsNum.text := _vessel.lloydsNumber;
	endif;
	now := self.systemToLocalTime(app.actualTimeServer);// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if lastVoyage.hasDeparted then														// 10/04/2025	navcs2	MTN-34548
		dwellHrs := lastVoyage.arrivedDT.differenceInHours(lastVoyage.departedDT);		// 10/04/2025	navcs2	MTN-34548
	else																				// 10/04/2025	navcs2	MTN-34548
		dwellHrs := lastVoyage.arrivedDT.differenceInHours(now);						// 10/04/2025	navcs2	MTN-34548
	endif;																				// 10/04/2025	navcs2	MTN-34548
	
	estimatedDeptTime := now.changeByXXHours(dwellHrs);

	//epr par 12351 only do this if the config Prefill voyage departure date is true
	if  self.myTerminal.getConfig(PrefillVoyageDepartDate).Boolean then
		self.dateDeparture.setDate(estimatedDeptTime.date());
		self.timeDeparture.setTime(estimatedDeptTime.time());
		
		// 07/04/2010 cnwar2 #23537 - departure date changed, refresh cut-offs
		//cnwmc5 - 13 Nov 2013 - PAR 32610 - was causing new voyages to get really old voyage cut offs if the vessel hadn't been used in a long time..
		//if not self.ckbOverrideDef.value then
			// ### JIRA 34233 06MAR 2025 NAVAB1
//		self.loadRecCutoffsTbl(null);
		//endif;
	endif;
	if self.shtHMSHarborData.visible then
		self.setDefaultsFromVesselData(_vessel.myHMSVesselData, lastVoyage.myHMSVoyageData);
	else
		//Not licenced for HMS
		self.ckbCreateHMSData.visible := false;
	endif;	

	self.loadDimensionsTbl(null, _vessel);
	
	// Clear selected data
	self.setForCopyVoyage();
	
	// TFS 50759 we've defaulted to a berth from a previous visit or the vessel
	// Check if that berth is a preferred berth, and whether the preference orientation
	// matches the orientation of the last voyage. If they do match, use the berth preference
	// If there are no preferred berths, check if the berth is the same as the last voyage's
	// arrival berth, and if so, default to the last voyage's orientation
	tmpBerth := self.cmbBerth.listObject.HMS_Berth;
	tmpVDH := _vessel.myHMSVesselData.allVesselDataForHarbour[self.myHarbour];
	if tmpVDH &lt;&gt; null then
		foreach pref in tmpVDH.allBerthPrefByOrder where pref.getMyBerth = tmpBerth do
			if lastVoyage &lt;&gt; null then 
				if (pref.orientation = OrientStarboardSideTo and lastVoyage.starboardBerthed)
				or (pref.orientation = OrientPortSideTo and not lastVoyage.starboardBerthed) then
					self.optStarboard.value := lastVoyage.starboardBerthed;
					fromPref := true;
				endif;
			endif;
		endforeach;
		if not fromPref and lastVoyage.myHMSVoyageData.getMyBerth = tmpBerth then
			self.optStarboard.value := lastVoyage.starboardBerthed;
		endif;
	endif;
	// TFS 50759
	
	// re-set back to null
	self.myCurrentVoyage := null;
	
	

	self.btnShippingAgent.enabled := self.cmbShippingAgent.listObject &lt;&gt; null;		
	self.btnShippingLine.enabled := self.cmbShippingLine.listObject &lt;&gt; null;					
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromVessel" id="0bb4510e-05fb-4af6-9b81-13fbc34d129e">
        <updating/>
        <source>setDefaultsFromVessel(_vessel : CM_Vessel)updating, protected;
//--------------------------------------------------
// Created:	12 March 2004 By: cnwgd1
//--------------------------------------------------
/****Changes

Date		Name	TFS#			Description
============================================================================
30 Apr 2012	cnwrs1	Par 29395
11 Mar 2013	PJS		PAR #31232
05/03/2019	jlgka1	TFS 37102		STWR - Add isBarges Flag.
10/09/2019 	JLGNS1	Bug 46446: ADP - RE: JMT Error
14/09/2020	jlgdap1	TFS 49887 SNO Auto generation of the voyage code via Hook code doesn't work
16/02/2021	navdap1	TFS 50759 PNL Berth orientation specific to a berth
05/10/2021	jlizm1	TFS 51963 SAL Voyage Request Changes
26/12/2022	navvt20	Defect 56046: Incorrect label on Voyage Definition form
============================================================================*/
vars
	setFromVesselVoyage : Boolean;
	pref : HMS_BerthPreference;				// TFS 50759
begin
	if self.mode &lt;&gt; self.Mode_Add then
		return;
	endif;
	
	if _vessel = null then
		return;
	endif;
	
	setFromVesselVoyage:=self.setDefaultsFromLastVisit(_vessel);
	
	if not setFromVesselVoyage then
		self.txtVesselName.text			:=	_vessel.name;
		self.txtVesselCode.text			:=	_vessel.code;
		self.txtCallSign.text			:=	_vessel.callSign;
		self.txtLloydsNum.text			:=	_vessel.lloydsNumber.stripAlpha;	//Bug 46446
		self.txtCraneClearanc.text		:=	_vessel.craneClearance.asStringJMT;
		self.txtRemarksVessel.text		:=	_vessel.remarks;
		self.picVesselBitmap.picture	:=	_vessel.bitmap;
		self.cmbAccessType.listIndex	:=	self.cmbAccessType.findString(1, app.vesselAccessTypeEnumToStr(_vessel.vesselType));
		self.txtYearBuild.text			:= _vessel.yearOfBuild.asStringJMT;
		self.chkIsBarge.value 			:= _vessel.isBarge; // jlgka1 TFS 37102
		
		if not self.myTerminal.getConfig(VoyageCodeHookTRX).Boolean then // TFS 51963
			if self.shtHMSHarborData.visible then // PAR 22309
				self.txtVoyageCode.text	:=	self.createSystemVoyCode();  // PAR 22309 //&lt;-- applicable to HMS licensed users	
			else
				if self.myTerminal.getConfig(ShipNoVoyageCodeUpdate).Boolean then // PAR 36959
					if self.myTerminal.getConfig(ShowOnlyVoyageCode).Boolean then  // PAR 36959
						self.txtVoyageCode.text	:=	 self.myCurrentVessel.code; // PAR 36959
					else
				
						self.txtVoyageCode.text	:=	 self.myTerminal.getNextVoyageCode(self.myCurrentVessel, self.voyageNumber, app.myPassport); // PAR 36959
					endif;
					
				else
					self.txtVoyageCode.text 		:= _vessel.code;
				endif;
			endif;
		endif;
	else // PAR 22309
		if self.mode = self.Mode_Add then // PAR 22309
			self.cmbInvoiceStatus.text 	:= Voyage_Invoice_StatStr_NotGen;  // PAR 22309
			self.chkIsBarge.value 		:= _vessel.isBarge; // jlgka1 TFS 37102			
			
			if self.txtVoyageCode.text.trimBlanks = null and not self.myTerminal.getConfig(VoyageCodeHookTRX).Boolean then	//23 Nov 2020	NDL	TFS 50389 - Only if it hasn't already been set to something
			
				// TFS 49887 There are a couple of paths that don't default the voyage code to anything
				// So we do hook code / vessel code depending on config settings
				if self.myTerminal.getConfig(ShipNoVoyageCodeUpdate).Boolean then
					if self.myTerminal.getConfig(ShowOnlyVoyageCode).Boolean then
						self.txtVoyageCode.text := self.myCurrentVessel.code;
					else
						self.txtVoyageCode.text := self.myTerminal.getNextVoyageCode(self.myCurrentVessel, self.voyageNumber, app.myPassport);
					endif;
				else
					self.txtVoyageCode.text := _vessel.code;
				endif;
				// TFS 49887 end
				
			endif;
			
			if self.cmbBerthPref.listIndex &gt; 0 then														// TFS 50759
				pref := self.cmbBerthPref.itemObject[self.cmbBerthPref.listIndex].HMS_BerthPreference;	// TFS 50759
				if pref.orientation = OrientStarboardSideTo then										// TFS 50759
					self.optStarboard.value := true;													// TFS 50759
				elseif pref.orientation = OrientPortSideTo then											// TFS 50759
					self.optPort.value := true;															// TFS 50759
				endif;																					// TFS 50759
			endif;																						// TFS 50759
		endif;
	endif;
	
	if _vessel.myDefaultTrade &lt;&gt; null then
		self.cmbTrade.setObject(_vessel.myDefaultTrade);
		self.displayTrade(_vessel.myDefaultTrade);
	endif;
	
	if self.mode = self.Mode_Add then
		if _vessel.structureIncludesLOLO then
			tblVesselStruct.showRowByName(ETRow_IncludesLOLO,false); 
			tblVesselStruct.setValueByName(ETRow_IncludesLOLO,true);
		else
			tblVesselStruct.hideRowByName(ETRow_IncludesLOLO,false); 
			tblVesselStruct.setValueByName(ETRow_IncludesLOLO,false);
		endif;
		
		if _vessel.structureIncludesRORO then
			tblVesselStruct.showRowByName(ETRow_IncludesRORO,false); 
			tblVesselStruct.setValueByName(ETRow_IncludesRORO,true);
		else
			tblVesselStruct.hideRowByName(ETRow_IncludesRORO,false); 
			tblVesselStruct.setValueByName(ETRow_IncludesRORO,false);
		endif;
		
		if _vessel.structureIncludesHolds then
			tblVesselStruct.showRowByName(ETRow_IncludesHolds,false); 
			tblVesselStruct.setValueByName(ETRow_IncludesHolds,true);
		else
			tblVesselStruct.hideRowByName(ETRow_IncludesHolds,false); 
			tblVesselStruct.setValueByName(ETRow_IncludesHolds,false);
		endif;
		
		tblVesselStruct.resetSize;
		
		
		if not _vessel.hasStructuralElementsDefined then
			tblVesselStruct.visible := false;
			//lblStructureNone.visible := false;	// 26 Dec 2022 navvt20 56046
		else
			tblVesselStruct.visible := true;
			//lblStructureNone.visible := false; // 26 Dec 2022 navvt20 56046
		endif;		
		
		// 31232
		
		if self.grpCellulaVoyage.visible then	
			self.shtVesselStruct.enabled:=true;
			// 31232
			// self.grpExtRamps.visible:=self.cmbStructureType.text = CellularStructureROROStr ;  31232
			 self.grpExtRamps.visible:=tblVesselStruct.getValueByName(ETRow_IncludesRORO).Boolean;	// 31232
			
		endif;
	endif;
	
	//epr tfs 39113 8/6/18
	if self.grpCellulaVoyage.visible and _vessel.myDefaultTrade = null then
		self.myAssistant.comboBoxOperator(self.cmbVoyOperator, _vessel.myOperator, null);
	endif;

	if self.shtHMSHarborData.visible then
		if not setFromVesselVoyage then
			self.setDefaultsFromVesselData(_vessel.myHMSVesselData, null);
			
		else
			if _vessel.myHMSVesselData &lt;&gt; null and _vessel.myHMSVesselData.myDefaultShippingLine &lt;&gt; null then
				self.cmbShippingLine.setObject( _vessel.myHMSVesselData.myDefaultShippingLine);
			endif;
			if self.txtVoyageCode.text = null and not self.myTerminal.getConfig(VoyageCodeHookTRX).Boolean then  // TFS 51963
				self.txtVoyageCode.text	:=	self.createSystemVoyCode(); //&lt;-- applicable to HMS licensed users	
			endif;
		endif;
		
	else
		//Not licenced for HMS
		self.ckbCreateHMSData.visible	:=	false;
		
		//14 Jun 2017	NDL	TFS 4815
		if _vessel.myHMSVesselData &lt;&gt; null and _vessel.myHMSVesselData.myDefaultShippingLine &lt;&gt; null then
			self.cmbShippingLine.setObject( _vessel.myHMSVesselData.myDefaultShippingLine);
		endif;

		if not self.myTerminal.getConfig(VoyageCodeHookTRX).Boolean then // TFS 51963
			// CCMS-1075
			if self.myTerminal.getConfig(ShowOnlyVoyageCode).Boolean and
			   self.myCurrentVessel &lt;&gt; null then 
				self.txtVoyageCode.text := self.myCurrentVessel.code;
			// TFS 49887 There are a couple of paths that don't default the voyage code to anything
			// So we do hook code / vessel code depending on config settings
			elseif self.myCurrentVessel &lt;&gt; null then
				self.txtVoyageCode.text := self.myTerminal.getNextVoyageCode(self.myCurrentVessel, self.voyageNumber, app.myPassport);
			// TFS 49887 end
			endif;
		endif;
	endif;
	
	if not setFromVesselVoyage then
		self.loadDimensionsTbl(null, _vessel);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromVesselData" id="c5d4c6b4-2761-4071-989f-30c72a46d882">
        <source>setDefaultsFromVesselData(_hmsVessel : HMS_VesselData; _lastVoyData : HMS_VoyageData)protected;
//--------------------------------------------------
// Created:	12 March 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 03/07/2014   cnwma1		CCMS SFW1328 -HMS Not Available For Entry  
// 16/02/2021	navdap1		TFS 50759 PNL Berth orientation specific to a berth
vars
	tmpPriority : Integer;
	tmpBerth 	: HMS_Berth;
	tmpVDH 		: HMS_VesselDataHarbour;
	obj 		: Object;
	berth 		: HMS_Berth;
	pref 		: HMS_BerthPreference;
begin

	if self.mode &lt;&gt; self.Mode_Add then
		return;
	endif;
	
	if _hmsVessel = null then
		return;
	endif;

	if (not self.shtHMSHarborData.visible) then
		//Not licenced for HMS
		self.ckbCreateHMSData.visible := false;
		return;
	endif;
	cmbBerth.listIndex := -1;  // + dh 1/2/2008 par 15534
	
	self.setDefaultVesselDataLastVisit(_lastVoyData);
	
	// Harbour Details
	self.ckbCoastalVessel.value := _hmsVessel.coastalServiceVessel;	
	self.ckbRequiresTow.value := _hmsVessel.requiresTow;	//21 Aug 2018	NDL	TFS 40347
	self.cmbShipType.listIndex :=  self.cmbShipType.findObject(_hmsVessel.myVesselType);
	self.cmbCountry.setObject(app.myRoot.allCountries[_hmsVessel.countryCode]);
		
	// Remarks
	self.txtRemarkGeneral.text := _hmsVessel.remarksGeneral;
	self.txtPreviousNames.text := _hmsVessel.remarksPreviousNames;
		
	// Vessel characteristics
	self.optPropFixed.value := _hmsVessel.hasFixedProp;
	self.optPropVariable.value := (not self.optPropFixed.value);	
	self.ckbBowThrusters.value := _hmsVessel.hasBowThrust;		
	self.ckbSternThruster.value := _hmsVessel.hasSternThrust;		
	self.ckbHasRamps.value := _hmsVessel.hasRamp;		
	self.ckbHoldTanks.value := _hmsVessel.hasHoldTanks;	
				
	tmpVDH := _hmsVessel.allVesselDataForHarbour[self.myHarbour];

	if tmpVDH &lt;&gt; null then
	
		self.cmbShippingAgent.setObject(tmpVDH.myShippingAgent);		

		self.cmbLineCompany.listIndex :=  self.cmbLineCompany.findObject(tmpVDH.myLineCompany); 	// CNWMA1 4/7/2014   CCMS SFW 1328
		if self.cmbLineCompany.listIndex = -1 and tmpVDH.myLineCompany &lt;&gt; null then				    //CNWMA1 3/7/2014   CCMS SFW 1328
			self.cmbLineCompany.addItemObject(tmpVDH.myLineCompany.description,tmpVDH.myLineCompany);
			self.cmbLineCompany.listIndex := self.cmbLineCompany.findObject(tmpVDH.myLineCompany);
		endif;	
		
		
		
		self.cmbTidalClassAr.listIndex :=  self.cmbTidalClassAr.findObject(tmpVDH.myTidalClassArrival);  //CNWMA1 4/7/2014   CCMS SFW 1328
		if self.cmbTidalClassAr.listIndex = -1 and tmpVDH.myTidalClassArrival &lt;&gt; null then				  //CNWMA1 3/7/2014   CCMS SFW 1328
			self.cmbTidalClassAr.addItemObject(tmpVDH.myTidalClassArrival.description,tmpVDH.myTidalClassArrival);
			self.cmbTidalClassAr.listIndex := self.cmbTidalClassAr.findObject(tmpVDH.myTidalClassArrival);
		endif;	
		
		
		self.cmbTidalClassDpt.listIndex :=  self.cmbTidalClassDpt.findObject(tmpVDH.myTidalClassDeparture);  //CNWMA1 4/7/2014   CCMS SFW 1328
		if self.cmbTidalClassDpt.listIndex = -1 and tmpVDH.myTidalClassDeparture &lt;&gt; null then				  //CNWMA1 3/7/2014   CCMS SFW 1328
			self.cmbTidalClassDpt.addItemObject(tmpVDH.myTidalClassDeparture.description,tmpVDH.myTidalClassDeparture);
			self.cmbTidalClassDpt.listIndex := self.cmbTidalClassDpt.findObject(tmpVDH.myTidalClassDeparture);
		endif;	
		self.loadTidalClassTbl();	
		self.cmbCatArrive.listIndex :=  self.cmbCatArrive.findObject(tmpVDH.myVesselCategoryIn);
		self.cmbCatDepart.listIndex :=  self.cmbCatDepart.findObject(tmpVDH.myVesselCategoryOut);
			
		self.txtRemarksPilot.text := tmpVDH.remarksPilotOnly;
		self.loadBerthPreferences(tmpVDH.allBerthPrefByOrder);	
		self.ckbPilotExempt.value := tmpVDH.isPilotExempt;
		self.ckbVisitConfiden.value := tmpVDH.excludeReport;
		self.txtCrewTieUp.text := tmpVDH.numLCrewTieUp.asStringJMT;
		self.txtCrewLetGo.text := tmpVDH.numLCrewLetGo.asStringJMT;
		self.txtEstTieUpTime.text := tmpVDH.estTieUpTime.asStringJMT;
		self.txtTugsArrive.text := tmpVDH.numTugsIn.asStringJMT;
		self.txtTugsDepart.text := tmpVDH.numTugsOut.asStringJMT;						

		tmpPriority := tmpVDH.berthPriority;
		if tmpPriority &gt;= 2 and tmpPriority &lt;= 4
		or tmpPriority &gt;= 6 and tmpPriority &lt;= 9 then
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, tmpPriority.String);
		elseif tmpPriority = 5 then
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, '5 - Medium');	
		elseif tmpPriority = 10 then
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, '10 - Low');			
		else
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, '1 - High');		
		endif;												
	
		if self.cmbBerth.listObject = null then
			// only set from vessel default is not already set from last visit
			tmpBerth := tmpVDH.getDefaultBerth();
			if tmpBerth &lt;&gt; null then
		// dh 1/2/2008 par 15534 - added the next section so that defaults to pref berth first.
				foreach obj in cmbBerthPref.itemObject do
					pref := obj.HMS_BerthPreference;
					berth := pref.getMyBerth;
					if berth = tmpBerth then
						self.cmbBerthPref.listIndex := self.cmbBerthPref.findObject(pref);
						break;
					endif;
				endforeach;
				if self.cmbBerthPref.listIndex &gt; 0 then
					self.optBerthPref.click(self.optBerthPref);
					pref := self.cmbBerthPref.itemObject[self.cmbBerthPref.listIndex].HMS_BerthPreference;	// TFS 50759
					if pref.orientation = OrientStarboardSideTo then										// TFS 50759
						self.optStarboard.value := true;													// TFS 50759
					elseif pref.orientation = OrientPortSideTo then											// TFS 50759
						self.optPort.value := true;															// TFS 50759
					endif;																					// TFS 50759
				else
					optBerth.value := true;
		// dh 1/2/2008 end of changes		
					self.cmbBerth.listIndex := self.cmbBerth.findObject(tmpBerth);				
					self.cmbBerth.lostFocus(self.cmbBerth);	
				endif;
			endif;
		endif;			
		// PAR #33337 Load default vessel resources				// PAR #33337
		self.displayHMSMovementResources(tmpVDH);				// PAR #33337
	endif;
// dh 1/2/2008 par 15534 changed next line
//	if self.cmbBerthPref.listObject = null then
	if self.cmbBerthPref.listObject = null and self.cmbBerth.listObject = null then
		if self.myHarbour &lt;&gt; null then
			// not berth found so find the default berth for the harbour
			tmpBerth := self.myHarbour.getDefaultBerthForMoveType(HMSMovementTypeArrival);
			if tmpBerth &lt;&gt; null then
				self.cmbBerth.listIndex := self.cmbBerth.findObject(tmpBerth);				
				self.cmbBerth.lostFocus(self.cmbBerth);
			endif;
		endif;
	endif;

	self.cmbShippingLine.setObject(_hmsVessel.myDefaultShippingLine);
	self.doShippingLineClick(self.cmbShippingLine);
	
	self.loadDimensionsTbl(null, _hmsVessel.myVessel);

	
end;</source>
        <access>protected</access>
        <Parameter name="_hmsVessel" type="HMS_VesselData"/>
        <Parameter name="_lastVoyData" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="setEnableHMSData" id="7fa0203f-1926-46c9-b4aa-330fefd2c532">
        <source>setEnableHMSData(_enable : Boolean);
//--------------------------------------------------
// Created:	28 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 30/01/2015	cnwdap1		PAR #35397 CCM SSFW 1394 Voyage Rationalisation - Delays are now not just HMS,
//							so always display the Movements/Delays tab, but show/hide the Movements table 
//							based on value of _enable 
// 09/03/2022	jlizm1		TFS 52834 SAL file attachments filter by work order
// 07/08/2023   navma1		Bug 58088: AAT - Voyage Definition Colour selection
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
vars
	row			: Integer;
	entTableDef : EntTableDef;
	view		: EntTableView;
	entTableRow : EntTableRow;
begin
	self.shtHMSBerthage.enabled		:=	_enable;
	self.shtHMSHarborData.enabled	:=	_enable;
	self.gbxHMSMovements.visible	:=	_enable;					// PAR #35397
	self.cmbPortFrom.enabled		:=	_enable;						
	self.cmbPortTo.enabled			:=	_enable;
	
	if self.mode = self.Mode_View then
		self.txtRemarkGeneral.readOnly	:=	true;
		self.txtRemarksPilot.readOnly	:=	true;
		self.txtRemarksVoyage.readOnly	:=	true;
	else
		self.txtRemarkGeneral.readOnly	:=	(not _enable);		
		self.txtRemarksPilot.readOnly	:=	(not _enable);		
		self.txtRemarksVoyage.readOnly	:=	(not _enable);
	endif;	

	if _enable then
		if self.mode = self.Mode_Add then
			self.shtHMSMovements.enabled		:= false;
			self.btnDocuments.enabled 			:= false; // TFS 52834
		elseif self.mode = self.Mode_Update then
			if self.myCurrentVoyageData = null then
				self.shtHMSMovements.enabled	:= false;
				self.btnDocuments.enabled 		:= false; // TFS 52834
			endif;
		endif;
	endif;	
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_KeyDimensions];
	view		:= entTableDef.allEntTableViews["hmsDimensions"];			// 20/8/19 MAP TFS45926 don't use noHMSDimensions view, all dimensions to be available
	//ccms 1116 epr 20/6/11
	foreach row in 2 to self.tblNewDimensions.rows do
		entTableRow:=self.tblNewDimensions.accessRow(row).itemObject.EntTableRow;
		if entTableRow = null then
			continue;
		endif;
		if not entTableRow.allEntTableViews.includes(view) then
			self.tblNewDimensions.accessRow(row).enabled:=_enable;
		endif;
	endforeach;
	
	if (app.getMyUser().canDo(self.myTerminal, PmShpPaymentType)) then		// 26/6/18 MAP TFS39250
		self.cmbPaymentType.enabled := _enable;
	else
		self.cmbPaymentType.enabled := false;
	endif;
	
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="c7f6dbae-6c72-4978-936e-156465a38d5c">
        <updating/>
        <source>setEnableObjects(_enable : Boolean)updating, protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//-----------------------------------------

/****Changes

Date		Name	TFS#			Description
============================================================================
30/10/2008	consw1	SFW1030 -		Remove unused auto plan flags
19/03/2013	PJS		PAR # 31232
30/0102015	cnwdap1	PAR #35397 		CCMS SFW 1394 Delays no longer HMS delays - check different permissions
17/12/2015  cnwma1  PAR # 37329 	System is not saving ship delays and we have a ship in and working
13/11/2018	jlgka1	TFS 41511 		Fixed bug where General Lading Field enabled even not in Edit or Add Mode.
27/02/2019	jlgzm1	TFS 43383		PNL buttons being disabled incorrectly
09/08/2019	jlgka1 	TFS 45921		PEL1 - Cannot make IMSR after Completing WO Permit Request - Manual Etmal IMSR
08/10/2019	jlgka1 	46918			PEL1 - ~TOP URGENT~ CANNOT CHANGE VOYAGE STATUS IN VOYAGE ENQUIRY.
28/02/2020  cnwma1	Bug 48722: 		STWO - Voyage Status
09/03/2022	jlizm1	TFS 52834		SAL file attachments filter by work order
============================================================================*/
vars
	numControls,
	int:	Integer;
	ctl:	Control;
	cando : Boolean;
begin
	
	self.enableAllControls(_enable);
	tblVesselStruct.enabled := _enable;	// 31232
	
	self.pickColour.enabled			:=	_enable;
	

	
	if self.shtHMSHarborData.visible then
		
		self.txtPreviousNames.readOnly	:=	(not _enable);
		
		if (not app.myCurrentUserCan(self.myTerminal, PmHMSPilotView)) then
			self.txtRemarksPilot.visible := false;
			self.lblPilotSecurity.visible := true;		
		else
			self.lblPilotSecurity.visible := false;		
		endif;
	endif;                                                       // 17/12/2015 cnwma1 PAR #37329
	
	if self.mode = Mode_View 
	and self.myCurrentVoyageData &lt;&gt; null then
		if app.myCurrentUserCan(self.myTerminal, PmHMSVoyageMaint) then
			self.btnAddMovement.enabled		:= true;	// 14/05/2012 cnwar2 #14987
			self.btnEditMovement.enabled	:= false;	// 14/05/2012 cnwar2 #14987
			self.btnDeleteMove.enabled		:= false;	// 14/05/2012 cnwar2 #14987
		endif;
	endif;
	if self.mode = Mode_View														// PAR #35397
	and self.myCurrentVoyage &lt;&gt; null then											// PAR #35397
		if app.myCurrentUserCan(self.myTerminal, PmShpDelaysMaint) then				// PAR #35397
			self.btnAddDelay.enabled 		:= true;								// PAR #35397
			self.btnDeleteDelay.enabled 	:= false;								// PAR #35397
			self.btnEditDelay.enabled 		:= false;								// PAR #35397
		endif;																		// PAR #35397
		if not self.viewModeOnly then												// TFS 43383
			self.btnWPOpHrsEdit.enabled := true;									// TFS 43383
		endif;																		// TFS 43383
	endif;																			// PAR #35397

	
	self.frmtbPOC.setToolbarControlsEnabled(_enable);					

	self.btnDocuments.enabled 		:= true; // TFS 52834
	self.btnDocumentLoad.enabled	    :=	true;//cnwaer 20.02.07
	if self.tblHDocuments.row &gt; 1 then
		self.btnDocumentDelet.enabled := true;
		self.btnDocumentView.enabled := true;
	else
		self.btnDocumentDelet.enabled := false;
		self.btnDocumentView.enabled := false;
	endif;

	self.pilotExemptEnable();	//set cmbPilot enabled according to the checkbox Pilot Exempt
	
	//epr ccms 1116 - 8/6/2011
	self.btnExtRampAdd.enabled:=true;
	self.btnExtRampDelete.enabled:=true;
	self.btnExtRampUpdate.enabled:=true;
	
	self.btnTankAdd.enabled:=true;
	self.btnTankDelete.enabled:=true;
	self.btnTankUpdate.enabled:=true;
	
	self.btnSectionsAdd.enabled:=true;
	self.btnSectUpdate.enabled:=true;
	self.btnSectDelete.enabled:=true;
	
	if self.myTerminal.getConfig(ShipNoVoyageCodeUpdate).Boolean then   // PAR 36155
		if self.txtVoyageCode.text &lt;&gt; "" then // PAR 36959
			self.txtVoyageCode.enabled := false; // PAR 36155
		endif;
	endif;
	
	if self.mode &lt;&gt; self.Mode_View then	//jlgka1 TFS 41511
		self.dateGenLanding.readOnly := not app.myCurrentUserCan(self.myTerminal, PmShpGLDateVoyageMaint); // TFS 4274
		self.btnCutoffEdit.enabled := self.ckbOverrideDef.value; // ### JIRA 34233 13MAR 2025 NAVAB1
		
	endif;//jlgka1 TFS 41511
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnTankAdd.enabled		  := false;
		self.btnTankDelete.enabled    := false;
		self.btnSectionsAdd.enabled	  := false;
		self.btnSectDelete.enabled	  := false;
		self.btnExtRampAdd.enabled    := false;
		self.btnExtRampDelete.enabled := false;
	endif;
	//jlgka1 TFS 45921 --&gt;
	if self.isCmbStatusEmpty then
		self.cmbStatus.enabled := false;
	else
		if self.mode &lt;&gt; self.Mode_View then     //28.02.2020 cnwma1 #48722
			self.cmbStatus.enabled := true;
		endif;
	endif;
	//jlgka1 TFS 45921 &lt;--
end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCopyVoyage" id="d2e30125-f9e2-4026-a04b-4945bbf7bfcc">
        <updating/>
        <source>setForCopyVoyage()updating;
//--------------------------------------------------
// Created:	11 January 2006 By: cnwgd1
//
//11 Mar 2013	PJS		PAR # 31232
//--------------------------------------------------
// Date			Who		Reason
// 04/11/2019	jlgmd1	TFS 47321 - Fixed the External Voyage code being carried over from the old voyage
// 03/06/2020   cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 05/10/2021	jlizm1	TFS 51963 SAL Voyage Request Changes
// 13/03/2023   navdp20 Bug 56861: FR | 53227 - External references are automatically filled
vars

begin

	// CCMS 1009
	if self.mode = self.Mode_View then
		return;
	endif;

	// Clear selected data
	self.txtVoyageCode.text    := null;
	self.txtInwardCode.text    := null;
	self.txtExternalCode.text  := null;		// TFS 47321
	self.txtGroupCode.text     := null;	    //03/06/2020 cnwma1 Tfs #49400
	self.txtImasVoyageNum.text := null;
	self.txtExternalRef.text   := null;    //13/03/2023  navdp20 Bug 56861
	self.tblHMSMovements.rows  := self.tblHMSMovements.fixedRows;						
	self.tblDelays.rows        := self.tblDelays.fixedRows;
	self.displayCargoVoyageExchange(null);

	// set selected defaults
	if self.myCurrentVessel &lt;&gt; null then
		if self.shtHMSHarborData.visible then
			if not self.myTerminal.getConfig(VoyageCodeHookTRX).Boolean then	// TFS 51963
				self.txtVoyageCode.text := self.createSystemVoyCode(); //&lt;-- applicable to HMS licensed users
				
				if self.txtVoyageCode.text = "" then // PAR 36959
					if self.myCurrentVessel &lt;&gt; null then  // PAR 36959
						if self.myTerminal.getConfig(ShowOnlyVoyageCode).Boolean then  // PAR 36959
							self.txtVoyageCode.text := self.myCurrentVessel.code; // PAR 36959
						else						
							self.txtVoyageCode.text := self.myTerminal.getNextVoyageCode(self.myCurrentVessel, self.voyageNumber, app.myPassport); // PAR 36959
						endif;
					endif;
				endif;
			endif;
		else
			// CCMS-1075
			if self.myTerminal.getConfig(ShowOnlyVoyageCode).Boolean and
				self.myCurrentVessel &lt;&gt; null then 
				self.txtVoyageCode.text := self.myCurrentVessel.code;
			endif;
		endif;
		if self.myHarbour &lt;&gt; null then
			self.txtImasVoyageNum.text := self.myHarbour.getVesselVisitCountStr(self.myCurrentVessel.code, null);    
		else
			self.txtImasVoyageNum.text := self.myTerminal.getVesselVisitCount(self.myCurrentVessel.code, null).asStringJMT;    			
		endif;
	endif;

	// PAR # 31232
	//self.setEnableObjectsForVoyageType(false);
	self.handleChangeOfStructure; // 31232
	
	if (not self.shtHMSHarborData.visible) then
		// clear for non HMS systems
		self.dateArrival.text := null;
		self.timeArrival.text := null;
		self.dateDeparture.text := null;
		self.timeDeparture.text := null;
		self.dateArchived.text := null;
		self.timeArchived.text := null;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setHMSEnabled" id="0ca6e2e5-ce8b-44a0-8a1e-89b40d712048">
        <source>setHMSEnabled(_enabled : Boolean);
/*
Purpose:			PAR 36959
Date		Who		Reason
17 Nov 2015	cnwab1	Initial creation
07 Aug 2023 navma1	Bug 58088: AAT - Voyage Definition Colour selection	
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
*/

vars

begin
	self.shtHMSBerthage.visible		:=	_enabled;
	self.gbxHMSMovements.visible 	:= 	_enabled;	
	self.shtHMSHarborData.visible	:=	_enabled;
