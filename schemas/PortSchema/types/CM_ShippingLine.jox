    <JadeMethod name="getDisplayStringForAttribute" id="f5b2ea9f-e5ff-42d6-b467-e28920c332e5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Apr 2014	cnwdb2		PAR #33977  
// 14 Aug 2023 	navhl20 	ChangeRequest 56642: MTN - Invoicing Shipping Line / Debtor Link
// ---------------------------------------------------------------------------

vars

begin
	if _attrName  = ETRow_NotAvailableForEntry then
		return self.isNotAvailableForEntry.String ; 
	elseif _attrName = ETRow_Debtor then 						//14.8.2023 navhl20 #56642
		if self.myDebtor &lt;&gt; null then 
			return self.myDebtor.name ; 
		endif;
		return null;
	elseif _attrName = ETRow_FinancialId then					//04.Mar.24 navsp1 TFS 57177
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.code;
		endif;
		return null;
	endif ; 
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
