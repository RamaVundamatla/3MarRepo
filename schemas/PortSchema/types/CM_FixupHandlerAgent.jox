	twoCharArray.add("VN");	threeCharArray.add("VNM");	threeDigitArray.add("704");	nameArray.add("VIET NAM");
		//VIRGIN ISLANDS (BRITISH)
	twoCharArray.add("VG");	threeCharArray.add("VGB");	threeDigitArray.add("092");	nameArray.add("VIRGIN ISLANDS (BRITISH)");
		//VIRGIN ISLANDS (U.S.)
	twoCharArray.add("VI");	threeCharArray.add("VIR");	threeDigitArray.add("850");	nameArray.add("VIRGIN ISLANDS (U.S.)");
		//WALLIS AND FUTUNA ISLANDS
	twoCharArray.add("WF");	threeCharArray.add("WLF");	threeDigitArray.add("876");	nameArray.add("WALLIS AND FUTUNA ISLANDS");
		//WESTERN SAHARA
	twoCharArray.add("EH");	threeCharArray.add("ESH");	threeDigitArray.add("732");	nameArray.add("WESTERN SAHARA");
		//YEMEN
	twoCharArray.add("YE");	threeCharArray.add("YEM");	threeDigitArray.add("887");	nameArray.add("YEMEN");
		//ZAMBIA
	twoCharArray.add("ZM");	threeCharArray.add("ZMB");	threeDigitArray.add("894");	nameArray.add("ZAMBIA");
		//ZIMBABWE
	twoCharArray.add("ZW");	threeCharArray.add("ZWE");	threeDigitArray.add("716");	nameArray.add("ZIMBABWE");
		//TIMOR-LESTE
	twoCharArray.add("TL");	threeCharArray.add("TLS");	threeDigitArray.add("626");	nameArray.add("TIMOR-LESTE");
		//PALESTINIAN TERRITORIES
	twoCharArray.add("PS");	threeCharArray.add("PSE");	threeDigitArray.add("275");	nameArray.add("PALESTINIAN TERRITORIES");
		//GUERNSEY
	twoCharArray.add("GG");	threeCharArray.add("GGY");	threeDigitArray.add(" ");	nameArray.add("GUERNSEY");
		//ISLE OF MAN
	twoCharArray.add("IM");	threeCharArray.add("IMN");	threeDigitArray.add("833");	nameArray.add("ISLE OF MAN");
		//JERSEY
	twoCharArray.add("JE");	threeCharArray.add("JEY");	threeDigitArray.add(" ");	nameArray.add("JERSEY");
		//ANTARCTICA
	twoCharArray.add("AQ");	threeCharArray.add("ATA");	threeDigitArray.add("010");	nameArray.add("ANTARCTICA");

	create cmif transient;
	
	foreach index in 1 to twoCharArray.size do
		codeISO2 := twoCharArray[index].toUpper;
		codeISO3 := threeCharArray[index].toUpper;
		unNum := threeDigitArray[index].trimBlanks.toUpper;
		countryName := nameArray[index].toUpper[1:25].trimBlanks;
		country := app.myRoot.allCountries.getAtKey( codeISO2 );
		if country = null then
			if _update then
				create pxyCountry transient;
				pxyCountry.setProxy(codeISO2, countryName, codeISO3, unNum, false, null);
				cmif.myProxyCountry := pxyCountry;
				cmif.allRealPorts.clear();
				app.myTrxCA.trxCreateCountry(cmif, country, app.myPassport);
				if not app.myPassport.hasErrors then
					str := "Country Code = " &amp; codeISO2 &amp; " added";
				else
					str := "Failed to add Country Code = " &amp; codeISO2 &amp; " - " &amp; app.myPassport.getErrorsAndWarningsAsString();
				endif;
				delete pxyCountry;
			else
				str := "Country Code = " &amp; codeISO2 &amp; " NOT found";
			endif;
			count := count + 1;
			writeOutputToMyForm(str);
			writeOutputToMyForm(CrLf);
			
		else
			if country.isoCode3.toUpper &lt;&gt; codeISO3 or  country.unNum.toUpper &lt;&gt; unNum or country.description.trimBlanks.toUpper &lt;&gt; countryName then
				str := null;
				if country.isoCode3 &lt;&gt; codeISO3 then
					str :=  "ISO 3 char code : " &amp; country.isoCode3 &amp; " / " &amp; codeISO3; 
				endif;
				if country.unNum &lt;&gt; unNum then
					if str &lt;&gt; null then
						str := str &amp; ", ";
					endif;
					str :=  str &amp; "ISO 3 digit number : " &amp; country.unNum &amp; " / " &amp; unNum; 
				endif;
				if country.description.trimBlanks &lt;&gt; countryName then
					if str &lt;&gt; null then
						str := str &amp; ", ";
					endif;
					str :=  str &amp; "ISO country name : " &amp; country.description &amp; " / " &amp; countryName;
				endif;
				count := count + 1;
				if _update then
					pxyCountry := app.createUpdateProxy(country).CM_Country;
					pxyCountry.setProxy(codeISO2, countryName, codeISO3, unNum, country.isNotAvailableForEntry, null);
					cmif.myProxyCountry := pxyCountry;
					cmif.allRealPorts.clear();
					country.ports.copy(cmif.allRealPorts);
					app.myTrxUA.trxUpdateCountry(cmif, app.myPassport);
					delete pxyCountry;
					if not app.myPassport.hasErrors then
						str := "Country Code '" &amp; codeISO2 &amp; "' updated to standard - changed " &amp; str;
					else
						str := "Country Code '" &amp; codeISO2 &amp; "' updated to standard - changed " &amp; str;
						writeOutputToMyForm(str);
						writeOutputToMyForm(CrLf);
						str := "Failed to update Country Code = " &amp; codeISO2 &amp; " - " &amp; app.myPassport.getErrorsAndWarningsAsString();
					endif;
				else
					str := "Country Code '" &amp; codeISO2 &amp; "' differs from standard - " &amp; str;
				endif;
				writeOutputToMyForm(str);
				writeOutputToMyForm(CrLf);
			endif;
		
		endif;
	endforeach;
	
	if count = 0 then
		str := CrLf &amp; "No Country Code objects found that differ from standard." &amp; CrLf;
	else
		if _update then
			str := CrLf &amp; count.String &amp; " Country 'code'(s) were created or updated." &amp; CrLf;
		else
			str := CrLf &amp; count.String &amp; " Country 'code' values differ from standard." &amp; CrLf;
		endif;
	endif;
	writeOutputToMyForm(str);
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);

epilog

	delete twoCharArray;
	delete threeCharArray;
	delete threeDigitArray;
	delete nameArray;
	delete cmif;
	delete pxyCountry;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRemAddCurrentTodoTasks" id="0f6ecf35-5c64-4c33-894b-87b5b9922116">
        <source>doRemAddCurrentTodoTasks();
/*
Purpose:			
Date		Who		Reason
28 July 2014	cnwab1	Initial creation
*/

vars

	param : String;
	param2 : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		elseif self.parameterArray.size = 2 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;

	
	if not update and not list then
		info := info &amp; "####" &amp; CrLf;
		info := info &amp; "NOTE: to write a copy of the log to file, select the 'File' button and choose a log file. This has to be done each time you run the script." &amp; CrLf;
		info := info &amp; "####" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to CCMS 2390 for Port Otago ONLY." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method removes all current todo tasks from a specified list for onsite cargo and then re adds them." &amp; CrLf;
		info := info &amp; "The specified list of todo tasks is:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "		Requires Dairy Board Cert Admin Fee" &amp; CrLf;
		info := info &amp; "		Requires DB Upgrade" &amp; CrLf;
		info := info &amp; "		Requires Digital Photo" &amp; CrLf;
		info := info &amp; "		Requires Base Wash (POL)" &amp; CrLf;
		info := info &amp; "		Requires External clean (POL)" &amp; CrLf;
		info := info &amp; "		Requires Roof Wash" &amp; CrLf;
		info := info &amp; "		Requires Inspection" &amp; CrLf;
		info := info &amp; "		Requires MPI External Inspect" &amp; CrLf;
		info := info &amp; "		Requires MPI Internal Inspection" &amp; CrLf;
		info := info &amp; "		Requires Warehouse inspection" &amp; CrLf;
		info := info &amp; "		Requires MPI External Clean" &amp; CrLf;
		info := info &amp; "		Requires MPI Wash" &amp; CrLf;
		info := info &amp; "		Requires PTI Repairs" &amp; CrLf;
		info := info &amp; "		Requires Pretripping" &amp; CrLf;
		info := info &amp; "		Requires Repair" &amp; CrLf;
//		info := info &amp; "		Requires DB EDI" &amp; CrLf;
		info := info &amp; "		Requires Steam Clean" &amp; CrLf;
		info := info &amp; "		Requires MPI 6 Sided Inspection" &amp; CrLf;
		info := info &amp; "		Requires MPI 6 Sided Reinspectio" &amp; CrLf;
		info := info &amp; "		Requires Internal Sweep" &amp; CrLf;
		info := info &amp; "		RequiresTemp.Setting" &amp; CrLf;
		info := info &amp; "		Requires Washing" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;

		info := info &amp; "This has the effect of creating new ADD transactions for each todo task." &amp; CrLf;
		info := info &amp; "Existing todo task Add transactions that have been charged will have the invoice line's status set to VOID." &amp; CrLf;
		info := info &amp; "NOTE: Invoice lines can only be voided if their invoice has not been posted. If the invoice has been posted the original todo task Add invoice lines will remain as is." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This script was requested by Port Otago because they were switching from charging for todo tasks on the add, " &amp; CrLf;
		info := info &amp; "    whereas previously they had charged on the complete of the task." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Please only use this script if you know what you are doing." &amp; CrLf;
		info := info &amp; "It is highly recommended that you run in LIST mode first and check that you will be happy with the proposed" &amp; CrLf;
		info := info &amp; "changes, as there is no ability to reverse the changes once applied." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE - will remove and then re-add all current todo tasks. A log output will be made to this screen." &amp; CrLf;
		info := info &amp; "LIST - will not perform any changes to the data, will only log to this screen." &amp; CrLf;
		info := info &amp; "TERMINAL CODE - the code of the terminal to run this script for; e.g. POE" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Example:" &amp; CrLf;
		info := info &amp; "LIST POE" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;

		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRemAddCurrentTodoTasksWork( param, param2);
	

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doRemAddCurrentTodoTasksWork" id="ea478d24-5bdb-43dc-98d2-1107819603ff">
        <source>doRemAddCurrentTodoTasksWork(_param1, _terminal : String) protected;
/*
Purpose:			
Date		Who		Reason
28 July 2014	cnwab1	Initial creation
*/

vars
	str : String;
	aTI : CM_TrackedItem;
	aTerm : CM_Terminal;
	lFile	: File;
	task : CM_ToDoTask;
	taskDesc : CM_ToDoTaskDesc;
	tran, taskTran, addTran : CM_TITransaction;
	invl : CM_InvoiceLine;
	taskCode, trnNum, idx : Integer;
	update : Boolean;
	taskDescStr : String;
	tiTasks : IntegerArray;
	tiTasksDesc : StringArray;
	taskInvLines : CM_InvoiceLineBySeqNumDict;
	
	include : StringArray;
begin
	create include transient;
	
	include.add("Requires Dairy Board Cert Admin Fee");
	include.add("Requires DB Upgrade");
	include.add("Requires Digital Photo");
	include.add("Requires Base Wash (POL)");
	include.add("Requires External clean (POL)");
	include.add("Requires Roof Wash");
	include.add("Requires Inspection");
	include.add("Requires MPI External Inspect");
	include.add("Requires MPI Internal Inspection");
	include.add("Requires Warehouse inspection");
	include.add("Requires MPI External Clean");
	include.add("Requires MPI Wash");
	include.add("Requires PTI Repairs");
	include.add("Requires Pretripping");
	include.add("Requires Repair");
//	include.add("Requires DB EDI");
	include.add("Requires Steam Clean");
	include.add("Requires MPI 6 Sided Inspection");
	include.add("Requires MPI 6 Sided Reinspectio");
	include.add("Requires Internal Sweep");
	include.add("RequiresTemp.Setting");
	include.add("Requires Washing");

	update := _param1 = "UPDATE";
	
	if not update then
		if _terminal &lt;&gt; null then
			str := "Processing in LIST mode for " &amp; _terminal &amp;  CrLf;
		else
			str := "Please enter a terminal ID" &amp; CrLf;
		endif;
	elseif update then
		if _terminal &lt;&gt; null then
			str := "Processing in UPDATE mode for " &amp; _terminal &amp;  CrLf;
		else
			str := "Please enter a terminal ID" &amp; CrLf;
		endif;
	endif;

	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	if _terminal = null then
		return;
	endif;

	aTerm := CM_Root.firstInstance.allTerminals[_terminal];

	if aTerm = null then
		writeOutputToMyForm("'" &amp; _terminal &amp; "' is not a valid terminal Id; script cancelled.");
		writeOutputToMyForm(CrLf);
		return;
	endif;
	
	
	app.myPassport.setMyTerminal(aTerm);
 
	writeOutputToMyForm("CT,ID,DT,TASK,TRAN1,TRAN2, TRAN3,TRNUM,INVL" &amp; CrLf);


	create tiTasks transient;
	create tiTasksDesc transient;
	create taskInvLines transient;

	
	foreach aTI in aTerm.allOnsiteTIsByCargoTypeId do
		if aTI.hasToDoTasks then

			tiTasks.clear();
			tiTasksDesc.clear();
			taskInvLines.clear();
			
			foreach task in aTI.allToDoTasksToDo discreteLock do
				taskDesc := task.toDoTaskDesc;
				if taskDesc &lt;&gt; null then
				
					if not include.includes(taskDesc.description) then // Ignore if not in the official list
						continue;
					endif;
					
					taskTran := null;
					invl := null;
					trnNum := -1;
					addTran := null;
					
					foreach tran in aTI.allTransactions discreteLock do
						if tran.myToDoTask = task then
							taskTran := tran;
							trnNum := tran.type;
							invl := tran.myInvoiceLine;
							
							if tran.type = 96 then
								addTran := tran;
							else
								break;
							endif;

						endif;
					
					endforeach;
					
					if taskTran = null and addTran &lt;&gt; null then
							taskTran := addTran;
							trnNum := addTran.type;
							invl := addTran.myInvoiceLine;
					
					endif;
				
					str :=  aTI.cargoBOLTypeDescr &amp; ","  &amp; aTI.id &amp; ", "  &amp; aTI.receivedDT.date.asStringJMT &amp; ", "  &amp; taskDesc.description &amp; ", "  &amp; taskDesc.trxTypeOnCreation.String &amp; "," &amp; task.toDoTaskDescTrxTypeOnCreate.String &amp; "," &amp; taskTran.String&amp; "," &amp; trnNum.String &amp; ", " &amp; invl.String &amp; CrLf;
					writeOutputToMyForm(str);

					tiTasks.add(taskDesc.code);
					tiTasksDesc.add(taskDesc.description);
					
					if update then
					
						// If Charged VOID the invoice line.
						if invl &lt;&gt; null then
							taskInvLines.add(invl);
						
						endif;
					endif;
					
				else
					str := "NULL TASK DESC" &amp; CrLf;
					writeOutputToMyForm(str);

			
				endif;
			
			endforeach;
			
								
			if update then
				idx := 0;
				
				foreach invl in taskInvLines do
					if invl.invoice &lt;&gt; null
					//and invl.invoice.status = CM_Invoice.INVOICE_POSTED
					and invl.invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759	
					then
						str := aTI.cargoBOLTypeDescr &amp; ","  &amp; aTI.id &amp; ", InvLine " &amp; invl.sequenceNum.String &amp; " cannot be Voided, becuse it's invoice " &amp; invl.invoice.sequenceNum.String &amp; " is POSTED" &amp; CrLf;
						writeOutputToMyForm(str);
						continue;
					endif;
					invl.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
					if invl.voided then
						str := aTI.cargoBOLTypeDescr &amp; ","  &amp; aTI.id &amp; ", InvLine Voided, " &amp; invl.sequenceNum.String &amp; CrLf;
						writeOutputToMyForm(str);
					
					else
						str := aTI.cargoBOLTypeDescr &amp; ","  &amp; aTI.id &amp; ", InvLine NOT Voided, " &amp; invl.sequenceNum.String &amp; CrLf;
						writeOutputToMyForm(str);
					
					endif;

				endforeach;
				
				foreach taskCode in tiTasks do
					idx := idx + 1;
					taskDescStr := tiTasksDesc[idx];
				
					// Remove Task
					app.myTrxUA.trxUpdateTIToDoTaskRemove(aTI,taskCode,app.myPassport);
					if app.myPassport.trxCompletedOK then
						str := aTI.cargoBOLTypeDescr &amp; ","  &amp; aTI.id &amp; ", Task Removed" &amp; CrLf;
						writeOutputToMyForm(str);
					else
						str := aTI.cargoBOLTypeDescr &amp; ","  &amp; aTI.id &amp; ", Task NOT Removed, " &amp; taskDescStr.String &amp; CrLf;
						writeOutputToMyForm(str);
						str := app.myPassport.getAllErrorsAndWarningsAsStr() &amp; CrLf &amp; CrLf;
						writeOutputToMyForm(str);
					endif;
					
					// Add Task
					app.myTrxUA.trxUpdateTIToDoTaskAdd(aTI,taskCode,app.myPassport);
					if app.myPassport.trxCompletedOK then
						str := aTI.cargoBOLTypeDescr &amp; ","  &amp; aTI.id &amp; ", Task Added , " &amp; taskDescStr.String &amp; CrLf;
						writeOutputToMyForm(str);
					else
						str := aTI.cargoBOLTypeDescr &amp; ","  &amp; aTI.id &amp; ", Task NOT Added, " &amp; taskDescStr.String &amp; CrLf;
						writeOutputToMyForm(str);
						str := app.myPassport.getAllErrorsAndWarningsAsStr() &amp; CrLf &amp; CrLf;
						writeOutputToMyForm(str);
					endif;
				endforeach;
			endif;

			
		endif;
	endforeach;

 epilog
	delete include;
delete tiTasks;
delete tiTasksDesc;
delete taskInvLines;

end;</source>
        <access>protected</access>
        <Parameter name="_param1" type="String"/>
        <Parameter name="_terminal" type="String"/>
    </JadeMethod>
    <JadeMethod name="doRemTALocRestrictions" id="0f58dd19-f662-43ad-8369-c4b0fee5a36e">
        <source>doRemTALocRestrictions();
//16 May 2011	cnwdw1	
vars
	param : String;
	param2 : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "
No recognised parameter(s) entered!

This method is relative to Par 27315. 
It will remove all the location restrictions from all the terminal areas as location restrictions are now obsolete
in JMT. Terminals that were created with location restrictions need to have them removed, before the terminal 
area can be deleted.

Parameters:
   LIST - will list ALL the terminal areas that have obsolete location restrictions
   UPDATE - will remove all obsolete location restrictions";

		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRemTALocRestrictionsWork(update);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemTALocRestrictionsWork" id="1fda3000-2395-4093-90dc-a567bb376f9b">
        <source>doRemTALocRestrictionsWork(_update: Boolean) protected;
// Created:	08 April 2011	by cnwvu1
//  
// Puropse:	Script finds old location restrictions in Otago prod system 
//			and deletes them except CM_LocationRestriction if exists.
//			P.s. Location restrictions have been replaced by yard allocations.

vars
	restr	: CM_LocationRestriction;
	locn	: CM_LocationsController;
	termArea: String;
	str		: String;
	objArray: ObjectArray;
	obj		: Object;
	
begin

	create objArray transient;
	
	writeLineOutputToMyForm("Remove Terminal Area Location Restrictions Script started.");
	writeLineOutputToMyForm("Action" &amp;Tab&amp; "Restriction Id" &amp;Tab&amp; "Class name" &amp;Tab&amp; "Oid" &amp;Tab&amp; "Created" &amp;Tab&amp; "Area" &amp;Tab&amp; "Locations");
	
	CM_LocationRestriction.allInstances(objArray, null, true);

	foreach obj in objArray do

		if not obj.isKindOf(CM_LocationRestriction) then
			writeLineOutputToMyForm(" ********************************* object is not location restriction " &amp; obj.class.name);
			continue;
		endif;
		
		restr := obj.CM_LocationRestriction;

		if restr.isKindOf(CM_LocationRestrictLog) then
			continue;
		endif;
		
		str := "";
		foreach locn in restr.allLocationControllers do
			if locn.ident &lt;&gt; "" then
				str := str &amp; locn.ident &amp; ", ";
			endif;
		endforeach;
		// removing the last comma
		if str &lt;&gt; "" then	
			str := str[1:str.length-2];
		endif;
		
		if restr.myTerminalArea &lt;&gt; null then
			termArea := restr.myTerminalArea.id;
		else
			termArea := "";
		endif;
		
		str := "'" &amp; restr.id &amp; "'" &amp;Tab&amp; restr.class.name &amp;Tab&amp; restr.getOidAsString() &amp;Tab&amp; restr.createdTime.shortCurrentLocaleFormat() &amp;Tab&amp; termArea &amp; Tab&amp; str;

		if _update then
			app.myTrxDA.trxDeleteRestrictionLocation(restr, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				writeLineOutputToMyForm("Failed" &amp;Tab&amp; str);
				writeLineOutputToMyForm(app.myPassport.getErrorsAsString());
				return;
			endif;		
			writeLineOutputToMyForm( "Deleted" &amp;Tab&amp; str );
		else
			writeLineOutputToMyForm( "Delete" &amp;Tab&amp; str );
		endif;
	
	endforeach;
epilog
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRemoveZombieRefs" id="558ba8a0-707d-4044-b1b6-2be6cb44f216">
        <source>doRemoveZombieRefs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2021	navndl1	Initial creation	TFS 50761

*/

vars

	param : String;
	param2 : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to TFS 50761 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Historically, 'merged' 'Break Bulk' and 'Bulk' cargo items that had 'stops' still active at the time of merging" &amp; CrLf;
		info := info &amp; "did not get their 'Stop' references cleared correctly prior to the merge." &amp; CrLf;
		info := info &amp; "This resulted in the associated 'Stop' table still having references to stops that were no longer current." &amp; CrLf;
		info := info &amp; "The impact of this was that if a user needed to change the configuration of the stop, the standard validation correctly " &amp; CrLf;
		info := info &amp; "detected that the stop table was in use, and produced an error meaning the config could not be altered" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The Garbage Collect process has been modified to clean these extra stops as part of the normal MTN Housekeeping." &amp; CrLf;
		info := info &amp; "This will occur as a part of normal Garbage Collect procedure, however it may take several iterations to" &amp; CrLf;
		info := info &amp; "complete, and obviously will only occur if the environment has the Gargbage BGP configured and scheduled to run." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides an alternative to waiting for the Garbage collect BGP to clean-up the extra stops references." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will find the Stop (tables) that are effected." &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method will perform teh clean up" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is HIGHLY recommended that you run this method in list mode first to determine which stops are effected and" &amp; CrLf;
		info := info &amp; "to what extent." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "** NOTE " &amp; CrLf;
		info := info &amp; "When run in 'update' mode, locks are required against the individual 'Stop' tables being processed." &amp; CrLf;
		info := info &amp; "It is therefore recommended to only use update when there is relatively little other activity in the environment, so as to" &amp; CrLf;
		info := info &amp; "limit the impact on other users." &amp; CrLf;
		info := info &amp; "A maximum of 20,000 referenecs will be cleaned per Stop table per run. This is to limit the length of the locks." &amp; CrLf;
		info := info &amp; "As a result multiple runs may be required to completely clean up all unnecessary 'stop' references." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list ALL Stop Tab;les effected" &amp; CrLf;
		info := info &amp; "UPDATE - will perform the cleansing of up to 20,000 stop references per Stop Table per run" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRemoveZombieRefsWork( update );
	

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doRemoveZombieRefsWork" id="215168dd-b1e8-4d06-af81-734160e8a267">
        <source>doRemoveZombieRefsWork(	_update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2021	navndl1	Initial creation	TFS 50761

*/

constants

	MilisPerMinute : Integer = 60000;

vars

	stopTable : CM_StopsTable;
	stop : CM_Stops;
	ti : CM_TrackedItem;
	edition : Integer;
	objsToDelete : ObjectSet;
	objsCount : Integer;
	invalidTi: Boolean;
	tryLockCount : Integer;
	moreToDo : Boolean;
	str : String;

begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create objsToDelete transient;
	
	on Exception do app.handleDeletedObject( exception, ti, invalidTi );
	
	foreach stopTable in app.myRoot.allStopsTable discreteLock do
		
		objsToDelete.clear();
		objsCount := 0;
		tryLockCount := 0;
		
		//find the stops we need to delete, i.e. linked to nothing, or linked to zombies.
		//stop when we get to 20,000
		foreach stop in stopTable.allStops discreteLock do
			if _update and objsCount &gt;= 20000 then
				moreToDo := true;
				break;
			endif;
			ti := stop.myTrackedItem;
			if ti = null then
				//should never get this, but if we do, then clean it up too
				objsToDelete.add( stop );
				objsCount := objsCount + 1;
				continue;
			endif;
			edition := ti.edition;
			if invalidTi then
				//should never get this, but if we do, then clean it up too
				invalidTi := false;
				objsToDelete.add( stop );
				objsCount := objsCount + 1;
				continue;
			elseif ti.hasBeenMerged then
				//its a zombie
				objsToDelete.add( stop );
				objsCount := objsCount + 1;
			endif;
		endforeach;
		
		//Actually do the deletes - if we can get the lock.
		if not objsToDelete.isEmpty then
		
			if not _update then
				str :=  "Found " &amp; objsCount.String &amp; " merged stops (" &amp; stopTable.code &amp; ") that need to be cleared" &amp; CrLf;
				writeOutputToMyForm(str);
			elseif _update then
				str := "Attempting to clear " &amp; objsCount.String &amp; " merged stops (" &amp; stopTable.code &amp; ")..." &amp; CrLf;
				writeOutputToMyForm(str);
			
				while tryLockCount &lt; 3 do
					tryLockCount := tryLockCount + 1;
					if tryLock( stopTable, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate ) then
						beginTransaction;
						objsToDelete.purge();
						commitTransaction;
						str :=  "..." &amp; objsCount.String &amp; " merged stops (" &amp; stopTable.code &amp; ") cleared." &amp; CrLf;
						tryLockCount := 0;
						break;
					else
						process.sleep(500); //sleep for a second
					endif;
				endwhile;
				
				if tryLockCount &gt; 0 then
					str :=  "Failed to get lock, data in use. Unable to clear " &amp; objsCount.String &amp; " merged stops in (" &amp; stopTable.code &amp; ") at this time.";
					moreToDo := true;
				endif;
				writeOutputToMyForm(str);
				writeOutputToMyForm(CrLf);
			
			endif;
			
		endif;
		
	endforeach;

	if not _update then
		str := "List Complete." &amp; CrLf;
	elseif _update then
		if moreToDo then
			str :=  "More merged stops remain to be processed. This occurred because there were more than 20,000 items to process" &amp; CrLf;
			str := str &amp; "against one or more of the Stops tables, AND/OR the Stops tables were already in use by another user, and the" &amp; CrLf;
			str := str &amp; "appropriate locks could not be performed at that time." &amp; CrLf;
		else
			str := "All merged stops now successfully cleared." &amp; CrLf;
		endif;
	endif;
	
	writeOutputToMyForm(CrLf);
	writeOutputToMyForm(str);
	
epilog

	delete objsToDelete;
	abortTransaction;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRepairBookingPackAs" id="67c3570d-f65a-455b-812d-36e47182ef08">
        <source>doRepairBookingPackAs();

/*

niceName="Repair 'Pack as' value on EDI created bookings"

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwndl1	Initial creation	Par 27687

*/

vars

	param : String;
	param2 : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 27687 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "There was a situation where the bookings created via EDI can have their 'Pack as' value" &amp; CrLf;
		info := info &amp; "set to '-1' instead of '0'." &amp; CrLf;
		info := info &amp; "While this has no effect on the booking or its processing, it has the potential to be" &amp; CrLf;
		info := info &amp; "confusing for users writing their own Reportwriter reports if they were to explicitly check for zero in this field." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides the ability to find and update bookings whose 'Pack as' value is '-1'." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will find the bookings whose 'Pack as' value is '-1'." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method finds the bookings and changes the 'Pack as' value to '0'" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is highly recommended that you run in list mode first and check that you will be happy with the proposed" &amp; CrLf;
		info := info &amp; "changes, as there is no ability to reverse the changes once applied." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list ALL Booking objects whose 'Pack as' value is '-1'." &amp; CrLf;
		info := info &amp; "UPDATE - will list ALL Booking objects whose 'Pack as' value is '-1' and actually update the value to be '0'." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRepairBookingPackAsWork( update );
	

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doRepairBookingPackAsWork" id="13814008-e7a6-4ab1-b2ab-f765faf21680">
        <source>doRepairBookingPackAsWork( _update : Boolean ) protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwndl1	Initial creation	Par 27687

*/

vars

	iter : Iterator;
	str : String;
	booking : CM_BookingRef;
	invalid : Boolean;
	bookingSet : CM_BookingRefSet;
	term : CM_Terminal;
	termCode : String;

begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	on Exception do app.handleDeletedObject(exception, booking, invalid);
	
	//get a collection of receive ship transactions that are tranships that have their
	//voyage value set to the export voyage instead of their import voyage.
	create bookingSet transient;
	iter := CM_BookingRef.instances.createIterator;
	
	while iter.next( booking ) do
	
		invalid := false;
		if booking.packAs &lt; 0 then	// only want those bookings with 'packAs' value less than 0
			bookingSet.add( booking );	
		endif;
			
	endwhile;	
	
	
	
	if bookingSet.isEmpty then
	
		str := "No Booking objects found with 'Pack as' value incorrectly set to '-1'." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
		
	else
		
		delete iter;
		str := "The following Booking objects were originally created with their 'Pack as' value incorrectly set to '-1'." &amp; CrLf;
		writeOutputToMyForm(str);
		
		on Exception do app.handleDeletedObject(exception, term, invalid);
		on Exception do app.handleDeletedObject(exception, booking, invalid);

		iter := bookingSet.createIterator;
		while iter.next( booking ) do
		
			invalid := false;
			term := booking.myTerminal;
			if invalid then
				continue;
			endif;
			termCode := term.code;
			if invalid then
				continue;
			endif;
			
			if _update then
				str :=  booking.bookingReference &amp; " [" &amp; termCode &amp; "]"
						&amp; " - 'Pack as' attribute UPDATED from: '" &amp; booking.packAs.String
						&amp; "' to: '0'.";
			
				beginTransaction;
					booking.setPropertyValue("packAs",0);
				commitTransaction; 
			
			else
				// we are in list mode, or we are in update mode for an individual cargo item, but not this one.
			
				str :=  booking.bookingReference &amp; " [" &amp; termCode &amp; "]"
							&amp; " - 'Pack as' attribute would be updated from: '" &amp; booking.packAs.String
							&amp; "' to: '0'.";
						
			endif;
			
			writeOutputToMyForm(str &amp; CrLf);
			
		endwhile;
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
		
epilog

	delete iter;
	delete bookingSet;

end;
</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRepairCargoCheck" id="f7c1c46b-feec-4ce3-b1d6-738ea9bef4e4">
        <source>doRepairCargoCheck( _ti : CM_TrackedItem; _tiArray : CM_TIArray input; _packedArray : TimeStampArray input; _unpackedArray : TimeStampArray input ) protected;

/*

Purpose:		Check each item for pack completed transaction but no packedDT or an unpack completed transaction but no unpackDT.
				Update the parameters arrays for each one found.
Parameters:			

Return Value:		


Date		Who		Reason
15/08/2013	cnwjre1	Par  32065 

*/

vars

	ti	: CM_TrackedItem;
	trans	: CM_TITransaction;
	invalid : Boolean;
	str : String;
	
	lastPackedDT,
	lastUnpackedDT	 :TimeStamp;
	updatePackedDT,
	updateUnpackedDT	 :TimeStamp;

begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	on Exception do app.handleDeletedObject(exception, trans, invalid);

	ti := _ti;
	// force object access to trigger invalid exception if any
	ti.edition();
	if invalid then
		return;
	endif;

	lastPackedDT := null;
	lastUnpackedDT := null;
	invalid := false;
	foreach trans in _ti.allTransactions discreteLock do
		// force object access to trigger invalid exception if any
		trans.edition();
		if invalid then
			invalid := false;
			continue;
		endif;
		if trans.isKindOf(CM_PackComplete) then
			lastPackedDT := trans.dateTime;
		elseif trans.isKindOf(CM_UnpackComplete) then
			lastUnpackedDT := trans.dateTime;
		endif;
	endforeach;

	if (ti.packedDT = null and lastPackedDT &lt;&gt; null) or
	   (ti.unpackedDT = null and lastUnpackedDT &lt;&gt; null) then
		_tiArray.add(ti);
		updatePackedDT := null;
		updateUnpackedDT:= null;
		if ti.packedDT = null and lastPackedDT &lt;&gt; null then
			updatePackedDT := lastPackedDT;
		endif;
	    if ti.unpackedDT = null and lastUnpackedDT &lt;&gt; null then
			updateUnpackedDT := lastUnpackedDT;
		endif;
		_packedArray.add(updatePackedDT);
		_unpackedArray.add(updateUnpackedDT);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_packedArray" type="TimeStampArray" usage="input"/>
        <Parameter name="_unpackedArray" type="TimeStampArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRepairCargoPackUnpackDates" id="8aa0520b-8860-400b-9203-ea464193b515">
        <source>doRepairCargoPackUnpackDates();

/*

niceName="Repair Cargo Pack and Unpack dates"

Purpose:	Optional fixup method for 32065 - done here rather than in a patch JadeScript in case some users don't actually want their cargo fixed.

Parameters:			

Return Value:		


Date		Who		Reason
15/08/2013	cnwjre1 Par 32065 keep pack date on unpack, and keep unpack date on pack.
*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 32065 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Cargo that has been packed and unpacked had the 'Packed Date/Time' value cleared" &amp; CrLf;
		info := info &amp; "when the cargo was unpacked, and the 'Unpacked Date/Time value cleared " &amp; CrLf;
		info := info &amp; "when the cargo was packed.  This meant that this cargo does not show up in a " &amp; CrLf;
		info := info &amp; "Selector Query using pack or unpack dates." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will find the cargo with both pack and unpack transactions" &amp; CrLf;
		info := info &amp; "but missing Packed or Unpack Date/Time values, and list the cargo items and dates here." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method finds the same cargo items and update the" &amp; CrLf;
		info := info &amp; "missing cargo Packed and Unpack Date/Times from the transactions." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is highly recommended that you run in list mode first and check that you will be happy with the proposed" &amp; CrLf;
		info := info &amp; "changes, as there is no ability to reverse the changes once applied." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list ALL affected cargo items, and show the changes that would be made to the cargo." &amp; CrLf;
		info := info &amp; "UPDATE - will list ALL affected cargo items and actually update the pack or unpack date/times on the cargo." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRepairCargoPackUnpackDatesWk( update );
	
epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRepairCargoPackUnpackDatesWk" id="6bfb41ae-4ba1-4e2b-841c-287e49fae80e">
        <source>doRepairCargoPackUnpackDatesWk( _update : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15/08/2013	cnwjre1	Par  32065 keep pack date on unpack, and keep unpack date on pack.

*/

vars

	iter	: Iterator;
	tiArray	: CM_TIArray;
	terminal	: CM_Terminal;
	ti : CM_TrackedItem;

	str : String;
	str2	: String;
	termCode : String;
	index	: Integer;
	
	lastPackedDT,
	lastUnpackedDT	: TimeStamp;
	packedArray,
	unpackedArray	: TimeStampArray;

begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create tiArray transient;
	create packedArray transient;
	create unpackedArray transient;
	
	foreach terminal in CM_Root.firstInstance.allTerminals discreteLock do
		
		delete iter;
		iter := terminal.allOnsiteTIsByCargoTypeId.createIterator;
		while iter.next(ti) do
			self.doRepairCargoCheck(ti, tiArray, packedArray, unpackedArray);
		endwhile;
		delete iter;
		iter := terminal.allOffsiteTIsByCargoTypeId.createIterator;
		while iter.next(ti) do
			self.doRepairCargoCheck(ti, tiArray, packedArray, unpackedArray);
		endwhile;
	endforeach;
	
	if tiArray.isEmpty then
	
		str := "No cargo items found with missing Packed Date/Time or Unpacked Date/Time." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
		
	else
		
		str := "The following cargo items had missing Packed Date/Time or Unpacked Date/Time:" &amp; CrLf;
		writeOutputToMyForm(str);

		foreach ti in tiArray do
			index := index + 1;
			lastPackedDT := packedArray[index];
			lastUnpackedDT := unpackedArray[index];
			
			if ti.myTerminal = null then
				termCode := null;
			else
				termCode := " - " &amp; ti.myTerminal.code;
			endif;
			
			if (ti.packedDT = null and lastPackedDT &lt;&gt; null) or
			   (ti.unpackedDT = null and lastUnpackedDT &lt;&gt; null) then
				if ti.packedDT = null and lastPackedDT &lt;&gt; null then
					str2 := " new Packed Date of " &amp; lastPackedDT.String;
				endif;
				if ti.unpackedDT = null and lastUnpackedDT &lt;&gt; null then
					str2 := " new Unpacked Date of " &amp; lastUnpackedDT.String;
				endif;
			endif;
			
			if ( _update  ) then
				// in update mode
				str :=  ti.id &amp; " [" &amp; app.siteEnumToString(ti.site) &amp; termCode &amp; "]" &amp; str2;
			
				// update the dates directly without creating CM_Edit etc as this is a fixup
				beginTransaction;
					if ti.packedDT = null and lastPackedDT &lt;&gt; null then
						ti.setPropertyValue("packedDT", lastPackedDT);
					endif;
					if ti.unpackedDT = null and lastUnpackedDT &lt;&gt; null then
						ti.setPropertyValue("unpackedDT", lastUnpackedDT);
					endif;
				commitTransaction; 
			
			else
				// in list mode
			
				str :=  ti.id &amp; " [" &amp; app.siteEnumToString(ti.site) &amp; termCode &amp; "] would be updated to have" &amp; str2;
						
			endif;
			
			writeOutputToMyForm(str &amp; CrLf);
				
		endforeach;
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
		
epilog

	delete iter;
	delete tiArray;
	delete packedArray;
	delete unpackedArray;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRepairDpRailReleaseTrans" id="71fa70cc-635c-4353-81a3-58c54d82aa79">
        <source>doRepairDpRailReleaseTrans();

/*

niceName="Repair Cargo Duplicate Rail Release Transactions"

Purpose:	Fix script for par 28436 where cargo released by rail ended up with duplicate release transactions, this should cleanup the transactions and void the invoice lines.

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwrd1	Initial creation

*/

vars

	param : String;
	param2 : String;
	update : Boolean;
	list : Boolean;
	info : String;
begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		elseif self.parameterArray.size = 2 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
			elseif param = "LIST" then
				list := true;
			endif;	
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 28436 &amp; 28478." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "There was a situation where the Train Departure process can cause duplicate Rail Release transactions for cargo" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will find the duplicate 'Released - Rail' transactions that were generated" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method finds the same duplicate 'Released - Rail' transactions and logically" &amp; CrLf;
		info := info &amp; "deletes the last 'Released Rail transaction and voids the associated invoice lines." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Both modes can have an optional date parameter , this will limit the results &amp; changes from now back until the specified date." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is highly recommended that you run in list mode first and check that you will be happy with the proposed" &amp; CrLf;
		info := info &amp; "changes, as there is no ability to reverse the changes once applied." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list ALL affected duplicate 'Released - Rail' transactions, and show the changes that would be made to the transaction." &amp; CrLf;
		info := info &amp; "UPDATE - will list ALL affected duplicate 'Released - Rail' transactions it will" &amp; CrLf;
		info := info &amp; "                     also logically delete the duplicate transaction " &amp; CrLf;
		info := info &amp; "                     and mark the associated invoice lines as Void. " &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST DD-MM-YYYY - will list ALL affected duplicate 'Released - Rail' transactions from the current time back until the date entered," &amp; CrLf;
		info := info &amp; "					and show the changes that would be made to the transaction." &amp; CrLf;		
		info := info &amp; "UPDATE DD-MM-YYYY - will list ALL affected duplicate 'Released - Rail' transactions from the current time back until the date entered," &amp; CrLf;
		info := info &amp; "                     also logically delete the duplicate transaction " &amp; CrLf;
		info := info &amp; "                     and mark the associated invoice lines as Void. " &amp; CrLf;	
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST', 'UPDATE', 'LIST DD-MM-YYYY ','UPDATE DD-MM-YYYY'  are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRepairDpRailReleaseTransWork( update, param2 );
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRepairDpRailReleaseTransWork" id="817760f0-53c9-42ff-8264-ce9da6880682">
        <source>doRepairDpRailReleaseTransWork( _update : Boolean; _date : String ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwrd1	Initial creation

*/


vars
	aTI 			: CM_TrackedItem;
	aTerm 			: CM_Terminal;
	aRoot 			: CM_Root;
	aTrain			: CM_Train;
	lastDepDate 	: Date;
	trans			: CM_TITransaction;
	iterator		: Iterator;
	first, second 	: CM_ReleaseRail;
	invLine 		: CM_InvoiceLine;
	date			: Date;
	str 			: String;
	useDate			: Boolean;
	trainInvalid, 
	tiInvalid 		: Boolean;
	trainTerm		: String;
	dateStr 		: String;
begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;

	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	if _date &lt;&gt; null then
		useDate := true;
		dateStr := _date.replaceString('-','/');
		lastDepDate := dateStr.asDateJMT;
		str := 'Processing back to ' &amp; lastDepDate.asStringJMT;
	else
		useDate := false;
		str := 'No Date supplied, processing for all Trains.';
	endif;
		
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	str := "The following cargo objects have duplicate 'Released - Rail' transactions." &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
		
	on Exception do app.handleDeletedObject(exception, aTrain, trainInvalid);	
	on Exception do app.handleDeletedObject(exception, aTI, tiInvalid);	
	
	aRoot := CM_Root.firstInstance;
	
	foreach aTerm in aRoot.allTerminals do
	
		str := "Checking for terminal " &amp; aTerm.code &amp; CrLf;
		writeOutputToMyForm(str);
	
		foreach aTrain in aTerm.allTrainsDepartedReversed do
			if useDate and aTrain.departureDT.date &lt; lastDepDate then
				break;
			endif;
			
			trainTerm := null;
			
			if aTrain.myTerminal &lt;&gt; null then
				trainTerm := aTrain.myTerminal.code;
			endif;

			foreach aTI in aTrain.allTIsReleased do
				
				first := null;
				second := null;
				
				if not  global.isValidObject(aTI) then
					continue;
				endif;
				
				if aTI = null then
					continue;
				endif;
				
				iterator := aTI.allTransactions.createIterator();
				while iterator.back(trans) do
					if trans.isKindOf(CM_ReleaseRail) and not trans.isDeleted then
						if first = null then
							first := trans.CM_ReleaseRail;
						else
							second := trans.CM_ReleaseRail;
							//we have a dupplicate
							//app.writeStatement(' duplicate trans for ti:' &amp; aTI.id &amp; ' train :' &amp; aTrain.code);
							
							str :=  aTI.id &amp; " [" &amp; app.siteEnumToString(aTI.site) &amp; trainTerm &amp; "]"
									&amp; " - 'Train' on '" &amp; aTrain.code &amp; " Released on '" &amp; first.dateTime.asStringJMT;									
							writeOutputToMyForm(str);
							/*
							str := 'Invoice Lines :';
							writeOutputToMyForm(str);
							
							
							foreach invLine in first.allInvoiceLines discreteLock do
								str := "Invoice : '" &amp; invLine.invoice.getDetailForEmail &amp; "' line - '" &amp; invLine.invoiceLineDesc.;
								writeOutputToMyForm(str);
							endforeach;
							*/
							if _update then
								beginTransaction;
								foreach invLine in first.allInvoiceLines discreteLock do
									//invLine.setPropertyValue('status', CM_InvoiceLine.STATUS_VOIDED);
									invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
								endforeach;
								first.setForDelete(null);
								commitTransaction;	
							endif;
							
							writeOutputToMyForm(CrLf);
						endif;
					endif;
				endwhile;
				
				delete iterator;
			endforeach;
			
		endforeach;
		writeOutputToMyForm(CrLf);
	endforeach;
epilog 
	delete iterator;
end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_date" type="String"/>
    </JadeMethod>
    <JadeMethod name="doRepairLostEIRNumbers" id="8c8a4d2d-0d52-4b16-9dd7-97d08152a1b4">
        <source>doRepairLostEIRNumbers();

/*

niceName="Recover lost EIR numbers for released cargo"

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwas3	par 27766

*/

vars

	param : String;	
	update : Boolean;	
	info : String;
	list : Boolean;
begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;	
				list := false;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 27766." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "There was a situation where the EIR number for cargo pieces was lost during their release." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "This method provides the ability to find and update cargo items that have been released since the 1st of March, 2011," &amp; CrLf;
		info := info &amp; "whose EIR number was unintentionally cleared." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will find the cargo objects whose EIR number was cleared during their release." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method will find the cargo objects whose EIR number was cleared during their release" &amp; CrLf;
		info := info &amp; "and change it back to it's last recorded value" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is highly recommended that you run in list mode first and check that you will be happy with the proposed" &amp; CrLf;
		info := info &amp; "changes, as there is no ability to reverse the changes once applied." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list ALL cargo objects whose EIR number was lost during their release." &amp; CrLf;
		info := info &amp; "UPDATE - will list ALL cargo objects whose EIR number was lost during their release and actually update the value to be the last one recorded" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRepairLostEIRNumbersWork( update );
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRepairLostEIRNumbersWork" id="380cd7d4-05aa-4266-8e5f-f57bc27eb516">
        <source>doRepairLostEIRNumbersWork( _update : Boolean ) protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwas3	par 27766

*/

vars

	iter 							: Iterator;	
	reqInvalid,foundReceivedTI, 
	tiInvalid,trInvalid 			: Boolean;	
	relReq 							: CM_RelRequestAssign;
	ti,receivedTI					: CM_TrackedItem;
	tr 								: CM_Transaction;
	trEdit 							: CM_Edit;
	array 							: HugeStringArray;
	receivedSite,site,strTr,
	str,eirNumber 					: String;
	foundSome,foundOne 				: Boolean;
	startDate						: Date;
	terminal 						: CM_Terminal;
	
begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	startDate := "01/03/2011".asDateJMT;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	on Exception do app.handleDeletedObject(exception, relReq, reqInvalid);	
	on Exception do app.handleDeletedObject(exception, ti, tiInvalid);
	on Exception do app.handleDeletedObject(exception, trEdit, trInvalid);
	
	create array transient;	
	
	iter := CM_RelRequestAssign.instances.createIterator;	
		
	while iter.next( relReq ) do		
			
		if relReq.createdTime.date() &lt; startDate or 
			relReq.myTrackedItem = null then
			continue;
		endif;
		
		reqInvalid := false;
		//ti.myTerminal.
		ti := relReq.myTrackedItem;	
			tiInvalid := false;
			
			if ti.eirNumber = null then
					
				if tiInvalid then 
					continue; 
				endif;
				foundOne := false;
				
				foreach tr in ti.allTransactions reversed where tr.isA(CM_Edit) do
					trInvalid := false;
					trEdit := tr.CM_Edit;					
					if trEdit.fieldsValues &lt;&gt; null then
							
						if trInvalid then 
							continue; 
						endif;
						array.clear();
							
						trEdit.fieldsValues.getStrings(array);
						foreach strTr in array reversed do
								
							if strTr.cnContains("eirNumber") and /*strTr[strTr.length()].isNumeric and */strTr.extractNumber() &lt;&gt; null then	
								
								//if not strTr[strTr.length()].isNumeric then   ///it was intentionally set to null	//this is commented out with the risk that there are cases in which someone set the eirnumber to null intentionally
								//if (not strTr[strTr.length()].isNumeric) and 
								//	array.size() = 1 then
								//		foundOne := true;
								//		break;
								//endif;
								
								if not foundSome then
									str := "The following cargo objects had their EIR number incorrectly cleared during their release." &amp; CrLf;
									writeOutputToMyForm(str);
								endif;							
								
								eirNumber := strTr.extractLastNumber().asStringJMT();//since we don't filter case like eirNumber xyz =&gt; null anymore, then we need to extract the numbers properly,without double-reversing them
									
								if ti.myTerminal = null then
									site := app.siteEnumToString(ti.site);
								else
									site := ti.myTerminal.code;
								endif;
								
								foundReceivedTI := false;
								receivedTI := null;
								foreach terminal in app.myRoot.allTerminals do
									receivedTI := terminal.allOnsiteTIsByIdCargoType.getAtKey(ti.id,ti.cargoType);
									if receivedTI &lt;&gt; null and 
									   receivedTI.eirNumber = null and 
									   receivedTI.allPriorTransactions.includes(trEdit)then
										foundReceivedTI := true;			///found the inter-terminal received ti, same one as the one release which we previously found...need to revert it's eir number as well,for it's new terminal
										break;
									endif;
								endforeach;
								
								if foundReceivedTI then
									if receivedTI.myTerminal = null then
										receivedSite := app.siteEnumToString(receivedTI.site);
									else
										receivedSite := receivedTI.myTerminal.code;
									endif;
								endif;
								
								str := "";
								
								if _update then
									str :=  ti.id &amp; " [" &amp; site &amp; "]"	&amp; " - 'EIR Number' attribute REVERTED BACK to: '" &amp; eirNumber &amp; "'.";
										
									beginTransaction;
										ti.setPropertyValue("eirNumber",eirNumber);
									commitTransaction; 
									
									if foundReceivedTI then
										str :=  receivedTI.id &amp; " [" &amp; receivedSite &amp; "]"	&amp; " - 'EIR Number' attribute REVERTED BACK to: '" &amp; eirNumber &amp; "'.";										
										beginTransaction;
											receivedTI.setPropertyValue("eirNumber",eirNumber);
										commitTransaction; 
									endif;
										
								else									
									str := str &amp; ti.id &amp; " [" &amp; site &amp; "]"	&amp; " - 'EIR Number' attribute would be reverted back to: '" &amp; eirNumber &amp; "'.";
									
									if foundReceivedTI then
										str := str &amp; receivedTI.id &amp; " [" &amp; receivedSite &amp; "]"	&amp; " - 'EIR Number' attribute would be reverted back to: '" &amp; eirNumber &amp; "'.";
									endif;
								endif;								
									
								writeOutputToMyForm(str &amp; CrLf);									
									
								foundOne := true;
								foundSome := true;
									
								break;
							endif;
								
						endforeach;					
						if foundOne then
							break;
						endif;
					endif;
						
				endforeach;			
			endif;
				
	endwhile;	
	
	
	if not foundSome then
	
		str := "No cargo objects found with 'EIR Number' value incorrectly cleared." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
		
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
		
epilog

	delete iter;
	delete array;

end;
</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRepairPortCodes" id="372c6d10-2a70-41b6-962c-f674c6ac841e">
        <source>doRepairPortCodes();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Nov 2012	cnwndl1	Initial creation	Par 30772

*/
vars

	param : String;
	update : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		param := self.parameterArray.first.trimBlanks.toUpper;
		if param = "UPDATE" then
			update := true;
		endif;
 	endif;
	
	if not update then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 30772 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is possible that some Port code objects in JMT that were set up prior to 7.7.1 do not have" &amp; CrLf;
		info := info &amp; "the 3 character 'port' code value set up, eventhough the full 5 character country/port" &amp; CrLf;
		info := info &amp; "value is declared correctly. " &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This can result in incomplete lists of available ports, when JMT looks for port objects by port code alone." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method resets the individual 3 character port code value from the 5 character combined country and port code." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE - will check each Port object recorded within in JMT. If it finds the 5 character combined country and port code set," &amp; CrLf;
		info := info &amp; "         but the individual 3 character port code value not set, then the method will correctly populate" &amp; CrLf;
		info := info &amp; "         the 3 character field from the last 3 characters of the 5 character field." &amp; CrLf;   
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'UPDATE' parameter is valid for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRepairPortCodesWork();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRepairPortCodesWork" id="f0a6af3a-6ef0-43b9-8f82-37d35b7b158c">
        <source>doRepairPortCodesWork() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Nov 2012	cnwndl1	Initial creation	Par 30772
04/03/2015	cnwmh5	Tranisent Leak

*/
vars

	port : CM_Port;
	iter : Iterator;
	count : Integer;
	str : String;

begin

	str := "Processing in UPDATE mode :" &amp; CrLf;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	iter := CM_Port.instances.createIterator;
	
	while iter.next( port ) do
		if port.portCode.trimBlanks = null then
			beginTransaction;
			if port.resetNullDisplayCode then
				count := count + 1;
			endif;
			commitTransaction;
		endif; 
			
	endwhile;
	
	if count = 0 then
		str := CrLf &amp; "No ports found that needed resetting." &amp; CrLf;
	else
		str := CrLf &amp; count.String &amp; " port 'code' values reset from country / port code." &amp; CrLf;
	endif;
	writeOutputToMyForm(str);
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);

epilog
	delete iter;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRepairReceiveDateTI" id="10ca1399-5727-4b0b-86fb-5035f4cf2541">
        <source>doRepairReceiveDateTI( _ti : CM_TrackedItem; _tiSet : CM_TISet input; _receiveDates : TimeStampArray input ) protected;

/*

Purpose:		Check each item with no receive date but an edit transaction which clears the receiveDT property
				Update the parameters arrays for each one found.
Parameters:			

Return Value:		


Date		Who		Reason
13/08/2014	cnwjre1	Par 34715

*/

vars

	ti	: CM_TrackedItem;
	trans	: CM_TITransaction;
	found	: Boolean;
	invalid : Boolean;
	oldValue,
	newValue	: String;
	
	createDT,
	receiveDT	: TimeStamp;

begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	on Exception do app.handleDeletedObject(exception, trans, invalid);

	ti := _ti;
	// force object access to trigger invalid exception if any
	ti.edition();
	if invalid then
		return;
	endif;

	if ti.receivedDT &lt;&gt; null then
		return;
	endif;
	if _tiSet.includes(ti) then
		return;
	endif;
	
	createDT := null;
	receiveDT := null;
	invalid := false;
	foreach trans in ti.allTransactions discreteLock do
		// force object access to trigger invalid exception if any
		trans.edition();
		if invalid then
			invalid := false;
			continue;
		endif;
		if trans.isKindOf(CM_Create) then
			createDT := trans.dateTime;
		elseif trans.isKindOf(CM_Receive) then
			receiveDT := trans.dateTime;
		elseif trans.isKindOf(CM_Edit) then
			// look for receiptDT to null and quantity change - other actions such as inter-terminal moves also have an edit to null
			if trans.CM_Edit.getFieldValuesByField(CM_TrackedItem::receivedDT, null, oldValue, newValue) then
				if newValue = "null" then
					if trans.CM_Edit.getFieldValuesByField(CM_TrackedItem::quantity, null, oldValue, newValue) then
						found := true;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	if found then
		if receiveDT = null then
			receiveDT := createDT;
		endif;
		_tiSet.add(ti);
		_receiveDates.add(receiveDT);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_receiveDates" type="TimeStampArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRepairReceivingDates" id="1de257f5-4f45-478c-ab0d-a5cd077fb612">
        <source>doRepairReceivingDates();

/*

niceName="Repair cleared cargo received dates"

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13/08/2014	cnwjre1 Par 34715 fix cleared cargo received dates
*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 34715." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "There was a situation where the 'Received Date' of cargo was incorrectly cleared" &amp; CrLf;
		info := info &amp; "following a Cargo Enquiry bulk edit of the cargo quantity." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will find and list the cargo items with cleared receive dates." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method finds the same cargo items and sets the" &amp; CrLf;
		info := info &amp; "received date from the receive transaction." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is highly recommended that you run in list mode first and check that you will be happy with the proposed" &amp; CrLf;
		info := info &amp; "changes, as there is no ability to reverse the changes once applied." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list ALL affected cargo items, and show the changes that would be made." &amp; CrLf;
		info := info &amp; "UPDATE - will list ALL affected cargo items and actually update the received date." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only 'LIST' and 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRepairReceivingDatesWork( update );
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRepairReceivingDatesWork" id="7719fbba-5052-4c63-8afd-374e97e8d1f2">
        <source>doRepairReceivingDatesWork( _update : Boolean ) protected;

/*

Purpose:		Restore cleared CM_TrackedItem receivedDT	

Parameters:			

Return Value:		


Date		Who		Reason
13/08/2014	cnwndl1	Initial creation	Par 34715
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	iter : Iterator;
	term : CM_Terminal;
	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	str : String;
	str2	: String;
	termCode	 :String;
	index	: Integer;
	receiveDT	: TimeStamp;
	receivedArray	: TimeStampArray;
begin

//	find all cargo

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	writeOutputToMyForm(str);

	str := CrLf &amp; "Checking cargo... " &amp; app.actualTimeServer.asStringJMT &amp; CrLf;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	writeOutputToMyForm(str);

	create tiSet transient;
	create receivedArray transient;
	iter := app.myRoot.allTerminals.createIterator;
	
	foreach term in CM_Root.firstInstance.allTerminals discreteLock do
		
		delete iter;
		iter := term.allOnsiteTIsByCargoTypeId.createIterator;
		while iter.next(ti) do
			self.doRepairReceiveDateTI(ti, tiSet, receivedArray);
		endwhile;
		delete iter;
		iter := term.allOffsiteTIsByCargoTypeId.createIterator;
		while iter.next(ti) do
			self.doRepairReceiveDateTI(ti, tiSet, receivedArray);
		endwhile;
	endforeach;
	
	if tiSet.isEmpty then
	
		str := "No cargo items found with missing Received Date/Time." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
		
	else
		
		str := "The following cargo items had missing Received Date/Time:" &amp; CrLf;
		writeOutputToMyForm(str);

		foreach ti in tiSet do
			index := index + 1;
			receiveDT := receivedArray[index];
			
			if ti.myTerminal = null then
				termCode := null;
			else
				termCode := " - " &amp; ti.myTerminal.code;
			endif;
			
			if ti.receivedDT = null and receiveDT &lt;&gt; null then
				str2 := " new Received Date of " &amp; receiveDT.String;
			endif;
			
			if ( _update  ) then
				// in update mode
				str :=  ti.id &amp; " [" &amp; app.siteEnumToString(ti.site) &amp; termCode &amp; "]" &amp; str2;
			
				// update the dates directly without creating CM_Edit etc as this is a fixup
				beginTransaction;
					if ti.receivedDT = null and receiveDT &lt;&gt; null then
						ti.setPropertyValue("receivedDT", receiveDT);
					endif;
				commitTransaction; 
			
			else
				// in list mode
			
				str :=  ti.id &amp; " [" &amp; app.siteEnumToString(ti.site) &amp; termCode &amp; " " &amp; ti.myCargoType.description &amp; "] would be updated to have" &amp; str2;
						
			endif;
			
			writeOutputToMyForm(str &amp; CrLf);
				
		endforeach;
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);

epilog

	delete iter;
	delete tiSet;
	delete receivedArray;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRepairShipReceivalTrans" id="3a9a70c4-ebc0-4284-9a87-1c63d9539f0d">
        <source>doRepairShipReceivalTrans();

/*

niceName="Repair Tranship 'Ship Receival' Transactions"

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438
08 Jul 2011 cnwjre1 Par 27782 add fix to myVoyageRelivant
*/

vars

	param : String;
	param2 : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		elseif self.parameterArray.size = 2 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Pars 27438 and 27782 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "There was a situation where the 'Export tranship' voyage of the tranship cargo" &amp; CrLf;
		info := info &amp; "could be incorrectly used as the 'voyage' in the 'Received - Ship' trx." &amp; CrLf;
		info := info &amp; "This could occur, if the cargo was originally landed to ground via the Hand Held app in 7.8.2" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will find the 'Received - Ship' transactions that were generated" &amp; CrLf;
		info := info &amp; "for tranship cargo that have been created with the wrong voyage recorded against the transaction." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method finds the same 'Received - Ship' transactions and changes the" &amp; CrLf;
		info := info &amp; "voyage value to be the 'Import tranship' voyage used on the cargo." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If a specific cargo id is included in the parameters when in update mode, then only the" &amp; CrLf;
		info := info &amp; "'Received - Ship' transaction for that cargo id will be updated, enabling selective updating." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is highly recommended that you run in list mode first and check that you will be happy with the proposed" &amp; CrLf;
		info := info &amp; "changes, as there is no ability to reverse the changes once applied." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list ALL affected 'Received - Ship' trx, and show the changes that would be made to the transaction." &amp; CrLf;
		info := info &amp; "UPDATE - will list ALL affected 'Received - Ship' trx and actually update the voyage reference on the transaction." &amp; CrLf;
		info := info &amp; "UPDATE ABCD1234567 - will list ALL affected 'Received - Ship' trx BUT only update cargo whose cargo id matches" &amp; CrLf;
		info := info &amp; "                     the cargo id entered.  I.e. In this case only the cargo with an id of ABCD1234567" &amp; CrLf;
		info := info &amp; "                     would actually get its voyage reference on the transaction updated." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST', 'UPDATE' or 'UPDATE &lt;cargo id&gt;' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doRepairShipReceivalTransWork( update, param2 );
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRepairShipReceivalTransWork" id="14eafb6a-4463-4310-afa5-053e14d67408">
        <source>doRepairShipReceivalTransWork( _update : Boolean; _cargoId : String ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars

	iter : Iterator;
	recShip : CM_ReceiveShip;
	trxSet : CM_TITransactionSet;
	shipReceiveVoyage : CM_Voyage;
	shipReceiveVoyageCode : String;
	ti : CM_TrackedItem;
	firstTrx : CM_TITransaction;
	firstTrxVoyage : CM_Voyage;
	firstTrxVoyageCode : String;
	transVoyageIn : CM_Voyage;
	transVoyageInCode : String;
	transVoyageOut : CM_Voyage;
	transVoyageOutCode : String;
	transVoyage : CM_Voyage;
	invalid : Boolean;
	trx : CM_TITransaction;
	str : String;
	termCode : String;

begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		if _cargoId &lt;&gt; null then
			str := "Processing in UPDATE mode for " &amp; _cargoId &amp; " and LIST for others :" &amp; CrLf;
		else
			str := "Processing in UPDATE mode :" &amp; CrLf;
		endif;
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	on Exception do app.handleDeletedObject(exception, transVoyageIn, invalid);
	on Exception do app.handleDeletedObject(exception, transVoyageOut, invalid);
	
	//get a collection of receive ship transactions that are tranships that have their
	//voyage value set to the export voyage instead of their import voyage.
	create trxSet transient;
	iter := CM_ReceiveShip.instances.createIterator;
	
	while iter.next( recShip ) do
	
		if recShip.imExStatus = TI_IMEX_STATUS_TRANSHIP then	// only want receive ship transactions that are tranships
			
			transVoyage := recShip.getMyVoyage();	// .myVoyageRelivant
			// par 27782, look for myVoyageRelivant of a receive ship set to the export voyage, not the import voyage
			if transVoyage &lt;&gt; null then
				invalid := false;
				ti := recShip.myTrackedItem;
				if ti = null then
					continue;
				endif;
				
				transVoyageOut := ti.myVoyageTranshipExport;
				if invalid then
					continue;
				endif;
				
				if transVoyage = transVoyageOut then
					trxSet.add(recShip);
					continue;
				endif;
			endif;			// end 27782

			shipReceiveVoyage := recShip.getVoyage;
			if shipReceiveVoyage = null then
				continue;
			endif;
		
			// find the first transaction created for this cargo
			invalid := false;
			ti := recShip.myTrackedItem;
			if ti = null then
				continue;
			endif;
			
			firstTrx := ti.allTransactions.first;
			if invalid then
				continue;
			endif;
	
			firstTrxVoyage := firstTrx.getVoyage;
			if firstTrxVoyage = null then
				continue;
			endif;
			
			if firstTrxVoyage &lt;&gt; shipReceiveVoyage then
				// We have one where the original original voyage doesn't match the receival voyage value.  ( This is a candidate )
				transVoyageIn := ti.myVoyageTranshipImport;
				if transVoyageIn = null then
					continue;
				endif;
				transVoyageInCode := transVoyageIn.code;
				if invalid then
					continue;
				endif;
				
				transVoyageOut := ti.myVoyageTranshipExport;
				if transVoyageOut = null then
					continue;
				endif;
				transVoyageOutCode := transVoyageOut.code;
				if invalid then
					continue;
				endif;
				
				shipReceiveVoyageCode := shipReceiveVoyage.code;
				firstTrxVoyageCode :=  firstTrxVoyage.code;
				
				if firstTrxVoyage = transVoyageIn and shipReceiveVoyage = transVoyageOut then
				
					trxSet.add(recShip);

				endif;
			endif;
			
		endif;
			
	endwhile;	
	
	
	
	if trxSet.isEmpty then
	
		str := "No Tranship cargo items found with 'Export' voyage incorrectly recorded on their 'Received Ship' transaction." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
		
	else
		
		delete iter;
		str := "The following Tranship cargo items had their 'Export' voyage incorrectly recorded on their 'Received Ship' transaction" &amp; CrLf;
		writeOutputToMyForm(str);

		iter := trxSet.createIterator;
		while iter.next( trx ) do
		
			invalid := false;
			recShip := trx.CM_ReceiveShip;
			
			ti := recShip.myTrackedItem;
			if ti = null then
				continue;
			endif;
			
			transVoyageIn := ti.myVoyageTranshipImport;
			if transVoyageIn = null then
				continue;
			endif;
			
			transVoyageOut := ti.myVoyageTranshipExport;
			if transVoyageOut = null then
				continue;
			endif;
			
			if ti.myTerminal = null then
				termCode := null;
			else
				termCode := " - " &amp; ti.myTerminal.code;
			endif;
			
			if ( _update and _cargoId = null ) or ( _update and _cargoId = ti.id ) then
				// update ALL                  OR   update only if the cargo id matches 
			
				str :=  ti.id &amp; " [" &amp; app.siteEnumToString(ti.site) &amp; termCode &amp; "]"
						&amp; " - 'Voyage' on '" &amp; recShip.typeString &amp; "' trx UPDATED from: '" &amp; transVoyageOut.code
						&amp; "' to: '" &amp; transVoyageIn.code &amp; "'.  Trx was created: " &amp; recShip.dateTime.asStringJMT;
			
				beginTransaction;
					recShip.setPropertyValue("voyage",transVoyageIn);
					recShip.setPropertyValue("voyageCode",transVoyageIn.code);
					recShip.setPropertyValue("myVoyageRelivant", transVoyageIn);	// 27782
				commitTransaction; 
			
			else
				// we are in list mode, or we are in update mode for an individual cargo item, but not this one.
			
				str :=  ti.id &amp; " [" &amp; app.siteEnumToString(ti.site) &amp; termCode &amp; "]"
							&amp; " - 'Voyage' on '" &amp; recShip.typeString &amp; "' trx would be updated from: '" &amp; transVoyageOut.code
							&amp; "' to: '" &amp; transVoyageIn.code &amp; "'.  Trx was created: " &amp; recShip.dateTime.asStringJMT;
						
			endif;
			
			writeOutputToMyForm(str &amp; CrLf);
				
		endwhile;
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
		
epilog

	delete iter;
	delete trxSet;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_cargoId" type="String"/>
    </JadeMethod>
    <JadeMethod name="doReportOnFutStorage" id="1b08cd83-d236-4465-9db7-ae6665a42a5e">
        <source>doReportOnFutStorage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2019	jlgns1	Initial creation

*/

vars
	param : String;
	list : Boolean;
	info : String;
begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "GO" then
				list := true;
			endif;
		endif;
 	endif;
	
//	if not update and not list then
	if not list then
		info := "No recognized parameter(s) entered!" &amp; CrLf &amp; CrLf;
		info := info &amp; "This method relates to TFS 42264 only." &amp; CrLf &amp; CrLf;
		info := info &amp; "This method does not change data in the system." &amp; CrLf &amp; CrLf;
		info := info &amp; "This method writes to a csv file with details of free storage and future storage charges that mismatch the dates they have been charged for." &amp; CrLf &amp; CrLf;	
		info := info &amp; "Valid Parameters:" &amp; CrLf &amp; CrLf;
		info := info &amp; "GO - Will output to a csv file."&amp; CrLf;
		info := info &amp; "You will be asked where to save the file, the default file name is 'Future_Storage_Report_&lt;Current Date&gt;.csv'" &amp; CrLf &amp; CrLf;
		info := info &amp; "***WARNING, this can take about 10-15 minutes and could affect system performance while running.***";
				
		self.writeOutputToMyForm(info);
		return;
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	self.doReportOnFutStorageWork();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReportOnFutStorageWork" id="998a9e1c-3f65-4d0c-8985-b0d82a8a77fd">
        <source>doReportOnFutStorageWork() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2019	jlgns1	Initial creation

*/


vars

	tItem 			: CM_TrackedItem;
	terminal 		: CM_Terminal;
	trans 			: CM_TITransaction;
	obArr 			: ObjectArray;
	lastTransDays 	: Integer;
	lastTransDate 	: TimeStamp;
	thisTransDays 	: Integer;
	thisTransDate 	: TimeStamp;
	expectedDays 	: Integer;
	obj 			: Object;
	futSto 			: CM_FutureStorage;
	tiDict 			: CM_TIByIdCargoTypeDict;
	opString 		: String;
	file 			: File;
	gldString 		: String;
	invalidVoyage	: Boolean;
	voyage			: CM_Voyage;
	count 			: Integer;
	prog 			: Integer;
	invNo 			: String;
	voyCode 		: String;
	invLine 		: CM_InvoiceLine;
	chunk 			: Integer;
	glDate 			: Date;
	freeStorageDays : Integer;
	locationSt 		: String;
	invLineStatus 	: String;
	str 			: String;
	termCount		: Integer;
	myDlg 			: CMDFileSave;
	processCount 	: Integer;
	processCountSt 	: String;
	root 			: CM_Root;
	iter 			: Iterator;
	actor 			: CM_OfflineFutureActor;
	fsDateProblemStr: String;
	expiryDate		: Date;
	hasCurrentStorage : Boolean;

	
begin
	
	on Exception do app.handleDeletedObject(exception, voyage, invalidVoyage);
	
	
	root := app.myRoot;
	iter := root.allOfflineFutureActorParents.createIterator;
	
	create obArr transient;
	create tiDict transient;
	create file transient;
	
	file.mode := File.Mode_Output;
	
	create myDlg;
	myDlg.fileName := "\Future_Storage_Report_" &amp; app.actualTimeServer.Date.dataDumpFormat &amp; ".csv";
		
	if myDlg.open = 0 then                      // user clicked OK
		create file;
		file.fileName    := myDlg.fileName;     // get selected name
		file.mode        := File.Mode_Append;
        file.allowCreate := true;               // create if not there
        file.open;                              // not mandatory
	else
		writeOutputToMyForm("User clicked cancel, no file created.");
		return;
	endif;
	
	
	
	file.writeLine("ID ,Operator Code ,Operator Description ,Imex ,CargoType Code ,CargoType Description ,Commodity Code ,Commodity Description ,Location ,Rotation "&amp;
					",Landing Date,Free Storage Days ,Last Anniversary on TI, Wrong Anniversary,additional Storage Days,FS Proces Count,Free Storage ,"&amp;
					"Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge ,Charge");	
	
	termCount := app.getMyRoot.allTerminals.size;
	
	foreach terminal in app.getMyRoot.allTerminals do
		
		if termCount &gt; 1 then 
			file.writeLine(terminal.code &amp; "," &amp; terminal.name);
			str := CrLf &amp; CrLf &amp; "Processing " &amp; terminal.code &amp; terminal.name;
			writeOutputToMyForm(str);
		endif;
		tiDict.clear();
		prog := 0;
		
		tiDict.clear;		
		terminal.allOnsiteTIsByIdCargoType.CM_TIByIdCargoTypeDict.copy(tiDict);
		terminal.allOffsiteTIsByIdCargoType.CM_TIByIdCargoTypeRelseDict.copy(tiDict);
		
		count := tiDict.size;
		
		chunk := (count / 10).Integer;
		str := CrLf &amp; "Found " &amp; count.String &amp; " Cargo Items";
		writeOutputToMyForm(str);
	
	
		foreach tItem in tiDict do
			prog := prog + 1;
						
			if chunk &gt; 0 and prog mod chunk = 0 then	
				str := CrLf &amp; (prog / count * 100).Real.roundedUp().String &amp; "% done";
				writeOutputToMyForm(str);	
			endif;
						
					
		invalidVoyage := false;
		gldString := ",No GL";
		glDate := Null.Date;
		freeStorageDays := -1;
		
		if tItem.myVoyage &lt;&gt; null then
			if invalidVoyage then
				break;
			endif;
			voyage := tItem.myVoyage;
			if voyage &lt;&gt; null then
				voyCode := "," &amp; voyage.code;
			else
				voyCode := ",";
			endif;
			//glDate := tItem.generalLandingDate;
			glDate := voyage.generalLandingDate;
			
			gldString := "," &amp; glDate.asStringJMT; 
				
			freeStorageDays := tItem.freeStorageDays;
		endif;	
		
		
		if invalidVoyage then
			continue;
		endif;
		
		
		
		if tItem.allTransactions.size &gt; 0 then
			
			
			
			
			
		
			obArr.clear();
			opString := null;		
			foreach trans in tItem.allTransactions do
				
				if CM_FutureStorage.hasInstance(trans) then
					if trans.superseded then
						continue;
					endif;
					
					if trans.deleted then
						continue;
					endif;
					
					obArr.add(trans);		
				endif;
			endforeach;
			
			if obArr.size &gt; 0 then
				lastTransDays	:= -1;
				lastTransDate.cnEcSetDateAndTime(Null.Date,TimeStartOfDay.Time);
				thisTransDays	:= -1;
				thisTransDate.cnEcSetDateAndTime(Null.Date,TimeStartOfDay.Time);
				expectedDays := -1;
				
				if freeStorageDays &gt; 0 and  glDate &lt;&gt; null.Date then
					expectedDays := obArr.first.CM_FutureStorage.chargeDateTime.Date - glDate;
					if expectedDays = freeStorageDays then
					opString := ",Free Storage Good";
					else 
					opString := ",FreeStorage (Interval " &amp; expectedDays.String &amp; " expected " &amp; freeStorageDays.String  &amp; ")";
					endif;	
				else 	
					opString := ",No Free Storage";
				endif;
				
				
				foreach obj in obArr do
					futSto := obj.CM_FutureStorage;
					thisTransDate := futSto.chargeDateTime;
					thisTransDays := futSto.daysCharged;
					if lastTransDays &gt; 0 then
						expectedDays := (thisTransDate - lastTransDate).TimeStampInterval.cnDays;
						if expectedDays  &lt;&gt; lastTransDays then
							invLine :=  futSto.getInvoiceLine;
							if invLine &lt;&gt; null then
								if invLine.voided then
									invLineStatus := "(void)";
								else
									invLineStatus := "";
								endif;
														
								invNo := " Invoice " &amp; invLine.getInvSequenceNum.String &amp; ""&amp; invLineStatus;
							else
								invNo := " No Invoice ";
							endif;
							opString := opString &amp; "," &amp; lastTransDate.asStringJMT &amp; "(interval " &amp; expectedDays.String &amp; " charge " &amp; lastTransDays.String &amp; invNo &amp; ")";
						endif;
					endif;
					lastTransDate := thisTransDate;
					lastTransDays := thisTransDays;	
					
				endforeach;
				
				//check the last one
				if tItem.releasedDT &lt;&gt; null.TimeStamp then
					futSto := obArr.last.CM_FutureStorage;
					expectedDays := tItem.releasedDT.date  - futSto.chargeDateTime.date;
					lastTransDays := futSto.daysCharged;
					
					invLine :=  futSto.getInvoiceLine;
					if invLine &lt;&gt; null then
						invNo := " Invoice " &amp; invLine.getInvSequenceNum.String;
					else
						invNo := " No Invoice ";
					endif;
					
					
					if expectedDays &gt; futSto.daysCharged then
						opString := opString &amp; "," &amp; futSto.chargeDateTime.asStringJMT &amp; " LAST (interval " &amp; expectedDays.String &amp; " charge " &amp; lastTransDays.String &amp; invNo &amp; ")";
					endif;
				endif;
				hasCurrentStorage := true;
			else	
				hasCurrentStorage := false;
			endif;
		endif;	
		
			locationSt := "offsite";
		processCountSt := ",";
		processCount := 0;
		if  tItem.locationId &lt;&gt; null then
			locationSt := tItem.locationId;	
			root.allOfflineFutureActorParents.startKeyGeq(tItem,iter);
		//	if hasCurrentStorage then
		//		expiryDate := tItem.getFutureStorageAnniversary();
		//	else
		//	
		//		expiryDate := glDate + freeStorageDays;
		//	endif;
			while iter.next(actor) do
				if actor.myParentObject &lt;&gt; tItem then
					break;
				endif;	
			//	if expiryDate &lt;&gt; null then
			//		if  actor.actionTimeStamp.Date &lt;&gt; expiryDate.addDays(1) then
			//			if fsDateProblemStr &lt;&gt; "," then
			//				fsDateProblemStr := fsDateProblemStr &amp; " ";
			//			endif;
			//			fsDateProblemStr := fsDateProblemStr &amp; "FSDate " &amp; actor.actionTimeStamp.Date.addDays(-1).asStringJMT &amp; " is Not TIDate " &amp; expiryDate.asStringJMT; 
			//		endif;
			//	endif;
				
				processCount := processCount + 1;	
			endwhile;
						
			processCountSt := "," &amp; processCount.String;
						
		endif;
		
		fsDateProblemStr := ",";
		if not hasCurrentStorage and processCount &gt; 0 then
		//	if  glDate  +  freeStorageDays &lt;&gt; tItem.plannedDT.Date then
			if  glDate  +  (freeStorageDays -1) &lt;&gt; tItem.plannedDT.Date then	
				fsDateProblemStr := ",Wrong";
				
			endif;
		endif;
		
		if (opString &lt;&gt; "" and opString &lt;&gt; ",No Free Storage" and opString &lt;&gt; ",Free Storage Good") 
		or (tItem.locationId &lt;&gt; null and fsDateProblemStr &lt;&gt; "," ) 
		or (tItem.locationId &lt;&gt; null and processCount &lt;&gt; 1 )
		or (tItem.locationId &lt;&gt; null and tItem.additionalStorageDays &gt; 0 )  then
				file.writeLine('"' &amp; tItem.id &amp; '",' 
								   &amp; tItem.myOperator.code &amp; "," 
								   &amp; tItem.myOperator.description &amp; ","
								   &amp; tItem.getImExStatusString &amp; ","
								   &amp; tItem.cargoTypeCode &amp; ","
								   &amp; tItem.cargoTypeDescr &amp; ","
								   &amp; tItem.commodity &amp; ","
								   &amp; tItem.getCommodityDesc &amp; ","
								   &amp; locationSt 
								   &amp; voyCode 
								   &amp; gldString &amp; ","
								   &amp; freeStorageDays.String &amp; ","
								   &amp; tItem.plannedDT.Date.String 
								   &amp; fsDateProblemStr &amp; ","
								   &amp; tItem.additionalStorageDays.String 
								   &amp; processCountSt  
								   &amp; opString);
		endif;
		endforeach;
	endforeach;
epilog	
	delete iter;
	delete obArr;
	delete tiDict;
	file.close;
	delete file;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetCashReceiptNumbers" id="a5d1f61a-ed61-404b-91f9-17a71802d1c0">
        <source>doResetCashReceiptNumbers();

/*

niceName="Reset Cash Receipt Numbers"

Purpose:			Reset the cash receipt number before going live.

Parameters:			

Return Value:		


Date		Who		Reason
12 Nov 2013	cnwjre1	Initial creation	Par 32972

*/

vars

	param : String;
	param2 : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is for cash module users only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The cash receipt report prints an automatically assigned receipt number" &amp; CrLf;
		info := info &amp; "for each business unit of each terminal." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will show the next cash receipt number for each business unit and terminal." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method resets the next cash receipt number for each business unit and terminal to 1." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is highly recommended that you run in list mode first and check that you will be happy with the proposed" &amp; CrLf;
		info := info &amp; "changes, as there is no ability to reverse the reset once applied." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list the next cash receipt numbers for each business unit and terminal." &amp; CrLf;
		info := info &amp; "UPDATE - will reset the next cash receipt number to 1 for each business unit and terminal." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doResetCashReceiptNumbersWork( update );
	

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doResetCashReceiptNumbersWork" id="a727ab1f-fbc2-47ff-913a-d28a01d5d309">
        <source>doResetCashReceiptNumbersWork( _update : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2013	cnwjre1	Initial creation

*/

vars
	str : String;
	terminal	: CM_Terminal;
	company		: CM_Bank;
	ks 			: CM_KeySeries;
	sk			: CM_SeriesKey;
begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	else
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	foreach terminal in app.myRoot.allTerminals discreteLock do
		foreach company in terminal.companies discreteLock do
			if _update then
				ks := company.keySeries[SN_CashReceipt];
				if ks &lt;&gt; null then
					beginTransaction;
					if global.isValidObject(ks) then
						company.keySeries.remove(ks);
						sk := ks.nextKey;
						if sk &lt;&gt; null then
							delete sk;
						endif;
						delete ks;
					else
						company.keySeries.removeKey(SN_CashReceipt);
					endif;
					commitTransaction;
					str := terminal.name &amp; " " &amp; company.code &amp; " next cash receipt number CLEARED to 1." &amp; CrLf;
					writeOutputToMyForm(str);
				endif;
			else
				str := terminal.name &amp; " " &amp; company.code &amp; " next cash receipt number is ";
				ks := company.keySeries[SN_CashReceipt];
				if ks = null then
					str := str &amp; "1";
				else
					sk := ks.nextKey;
					if sk = null then
						str := str &amp; "1";
					else
						str := str &amp; sk.root.String;
					endif;
				endif;
				str := str &amp; CrLf;
				writeOutputToMyForm(str);
			endif;
		endforeach;
	endforeach;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResetQueryDefinitions" id="96e503cd-edea-495f-8630-b25d75dfdbb9">
        <source>doResetQueryDefinitions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2013	cnwndl1	Initial creation	Par 31295

*/

vars

	param : String;
	update : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
			endif;
		endif;
 	endif;
	
	if not update then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 31295 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "JMT has a 'Query Menu Root' that contains a list of properties that are permitted to be used in the Query Selector." &amp; CrLf;
		info := info &amp; "The list of properties is rebuilt whenever an additional property is made available to the system, and at every major release." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The 'Available' properties for the Column Organiser of the results table on the Query Selector is also kept" &amp; CrLf;
		info := info &amp; "on this object. When a user 'checks' the 'Save as system default' on the column organiser and presses OK, this collection" &amp; CrLf;
		info := info &amp; "is refreshed from the form. If at the time of saving new system defaults via the column organiser, the displayed collection" &amp; CrLf;
		info := info &amp; "on the form is incomplete for some reason, then the new available list will be saved without those members." &amp; CrLf;
		info := info &amp; "Par 31295 would appear to show an instance of this occurring" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This script provides a mechanism to force a complete rebuild of the list manually." &amp; CrLf;
		info := info &amp; "It will typically take about 2 or 3 minutes, and should only be performed when no query activity is occurrring." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE - will force a rebuild of the properties available in the 'Query Menu Root'." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only 'UPDATE' is considered to be a valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doResetQueryDefinitionsWork();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResetQueryDefinitionsWork" id="0850b247-16af-44c4-b824-40034ceb7424">
        <source>doResetQueryDefinitionsWork()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2013	cnwndl1	Initial creation	Par 31295

*/

vars

	str : String;

begin

	str := "Processing rebuild of 'Query Menu Root' Query Selector properties :" &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	app.myRoot.createQueryDefinitionObjects();
	
	beginTransaction;
	if app.myRoot.myQueryMenuRoot &lt;&gt; null then
		app.myRoot.myQueryMenuRoot.resetSelectorColumns(true);
	endif;	
	commitTransaction;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResyncSubTermAndBusUnit" id="60ddba68-4819-41a0-8868-f90682fb619e">
        <source>doResyncSubTermAndBusUnit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2015	cnwndl1	Initial creation	Par 36181

*/

vars

	paramString : String;
	update : Boolean;
	list : Boolean;
	info : String;
	paramsOK : Boolean;
	term : CM_Terminal;
	str : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 2 then
			paramsOK := true;
			paramString := self.parameterArray[1].toUpper;
			term := app.myRoot.allTerminals.getAtKey(paramString);
			if term = null then
				paramsOK := false;
				str := "***** PARAMETER ERROR - first parameter '" &amp; paramString &amp; "' does not resolve to a recognised terminal!" &amp; CrLf &amp; CrLf;
				writeOutputToMyForm(str);
			else
				paramString := self.parameterArray[2].toUpper.trimBlanks;
				if paramString = "UPDATE" then
					update := true;
				elseif paramString = "LIST" then
					list := true;
				else
					str := "***** PARAMETER ERROR - second parameter '" &amp; paramString &amp; "' not a valid action!" &amp; CrLf &amp; CrLf;
					writeOutputToMyForm(str);
					paramsOK := false;
				endif;
				if not term.getConfig(IsSubTerminalsOn).Boolean or not term.getConfig(IsSubTerminalAreaDefined).Boolean then
					paramsOK := false;
					str := "***** PARAMETER ERROR - selected terminal '" &amp; term.code &amp; "' does not use 'Sub Terminals' with 'Defined Sub Terminal Areas'!" &amp; CrLf &amp; CrLf;
					writeOutputToMyForm(str);
				endif;
			endif;
		endif;
 	endif;
	
	if not paramsOK then
		info := "No recognised or invalid parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is ONLY relative to users running with 'Sub Terminals' AND using 'Defined Sub Terminal Areas'." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "When changing the 'selected areas' associated with a 'Sub Terminal Area Definition' or the 'Business Unit' (Bank)" &amp; CrLf;
		info := info &amp; "associated with a Sub-terminal ( that has a Sub Terminal Area Definition ), there is the potential for the update" &amp; CrLf;
		info := info &amp; "to be interupted by an exception at a point where the Sub Terminal changes have been made, but the cargo has not" &amp; CrLf;
		info := info &amp; "yet been updated." &amp; CrLf;
		info := info &amp; "Often this is simply a locking issue related to the large volume of data that is being updated in a single transaction." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "When this occurs, it is likely that some cargo in the defined area (or cargo that is an area that is no longer part of" &amp; CrLf;
		info := info &amp; "the definition ) may not have had its 'Sub Terminal' or 'Business Unit' references updated." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If this occurs, the user will be advised to run this System Supervisors Fixup method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This script provides a mechanism to re-evaluate and rebuild these associations in smaller packets but requires more evaluation." &amp; CrLf;
		info := info &amp; "This extra processing will take longer, to process, usually several minutes, but is not as likely to encounter locking issues." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "2 Parameters must be provided, they must be entered in the correct order and they must be space delimited:" &amp; CrLf;
		info := info &amp; "The parameters are &lt;Terminal code&gt; &lt;action&gt;" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "&lt;Terminal code&gt; - The 'code' value of the terminal that you want to create the data for." &amp; CrLf;
		info := info &amp; "                 				I.e. " &amp; CM_Terminal.firstInstance.code &amp; CrLf;
		info := info &amp; "&lt;action&gt; - The action you wish to perform i.e. either List or UPDATE" &amp; CrLf;
		info := info &amp; "LIST - will list the cargo items need their association rebuilt." &amp; CrLf;
		info := info &amp; "UPDATE - will rebuild the associations." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doResyncSubTermAndBusUnitWork( term, update );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResyncSubTermAndBusUnitWork" id="d6681061-036a-4e61-8488-8ab1ac96c581">
        <source>doResyncSubTermAndBusUnitWork( _term : CM_Terminal; _update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2015	cnwndl1	Initial creation	Par 36181

*/

vars

	str : String;
	tisNeedingReset : CM_TISet;
	ti : CM_TrackedItem;
	locationStr : String;
	errCount : Integer;

begin

	if _update then
		str := "Processing in UPDATE mode for terminal '" &amp; _term.code &amp; "' :" &amp; CrLf;
	else
		str := "Processing in LIST mode for terminal '" &amp; _term.code &amp; "' :" &amp; CrLf;
	endif;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	str := "Collecting data..." &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create tisNeedingReset transient;
	_term.getTIsNeedingSubTermOrBUReset( true, true, tisNeedingReset );
	
	if tisNeedingReset.isEmpty then
		str := "No Cargo was found with incorrect Sub-Terminal or Business Unit settings based on their Yard location." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
		return;
	
	else
		str := tisNeedingReset.size.String &amp; " Cargo Item(s) require their Sub-Terminal and/or Business Unit settings updated based on their Yard location" &amp; CrLf;
		str := str &amp; "and the Sub Terminal Area Definitions." &amp; CrLf;
		writeOutputToMyForm(str);
		writeOutputToMyForm(CrLf);
		
	endif;
	
	if _update then
		app.myPassport.setMyTerminal( _term );
		foreach ti in tisNeedingReset do
			app.myTrxUA.trxUpdSubTermForCargoItem( ti, app.myPassport );
			if app.myPassport.trxCompletedOK then
				str := ti.id &amp; " updated successfully."  &amp; CrLf;
				writeOutputToMyForm(str);
			else
				if ti.isOnSite and ti.myPrimaryActualLocation &lt;&gt; null then
					locationStr := ti.myPrimaryActualLocation.getFullId;
				else
					locationStr := "offsite";
				endif;
				errCount := errCount + 1;
				str := "***** " &amp; ti.id &amp; " " &amp; locationStr &amp; " FAILED to update. "  &amp; CrLf;
				writeOutputToMyForm(str);
				str := "Error was " &amp; app.myPassport.getErrorsAndWarningsAsString  &amp; CrLf;
				writeOutputToMyForm(str);
				app.myPassport.clearErrorsWarnings();
			endif;
		endforeach;
		
		if errCount &gt; 0 then
			writeOutputToMyForm(CrLf);
			str := errCount.String &amp; " Item(s) failed to update. If the errors were locks, consider running this script again." &amp; CrLf;
			writeOutputToMyForm(str);
			writeOutputToMyForm(CrLf);
		endif;
	
	else
		foreach ti in tisNeedingReset do
			if ti.isOnSite and ti.myPrimaryActualLocation &lt;&gt; null then
				locationStr := ti.myPrimaryActualLocation.getFullId;
			else
				locationStr := "offsite";
			endif;
			str := ti.id &amp; " " &amp; locationStr &amp; " requires update."  &amp; CrLf;
			writeOutputToMyForm(str);
		endforeach;
	
	endif;

epilog

	delete tisNeedingReset;

end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetBerthRoot" id="1934d537-f660-4cb7-aaf3-39a6fae9394e">
        <source>doSetBerthRoot();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2012	cnwndl1	Initial creation	Par 29537

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 29537 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Some HMS Berths created between 2007 and 2012 may not have their 'myRoot' reference set, causing them to not always be" &amp; CrLf;
		info := info &amp; "visible through-out the system." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This script provides a mechanism to set the 'myRoot' reference where necessary and correct the visiblity issue for the effected Berths" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE - will set the 'myRoot' reference where necessary and report the results." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only 'UPDATE' is considered to be a valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doSetBerthRootWork();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetBerthRootWork" id="6fb6f512-91f4-4f75-9dd8-8f78052ab45d">
        <source>doSetBerthRootWork() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2012	cnwndl1	Initial creation	Par 29537

*/

vars

	allBerths : HMS_BerthArray;
	updatedBerths : HMS_BerthSet;
	iter : Iterator;
	berth : HMS_Berth;
//	size : Integer;
	str : String;
	count : Integer;

begin

	str := "Processing in UPDATE mode :" &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create allBerths transient;
	create updatedBerths transient;
	
	str := "Collecting data..." &amp; CrLf;
	writeOutputToMyForm(str);

	HMS_Berth.allInstances(allBerths,0,true);
	
	if allBerths.isEmpty then
		str := "No Berth data in the system." &amp; CrLf;
		writeOutputToMyForm(str);
		return;
	endif;
	
	str := "Checking " &amp; allBerths.size.String &amp; " Berths..." &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	iter := allBerths.createIterator;
	while iter.next( berth ) do
		if berth.myRoot &lt;&gt; null then
			continue;
		endif;
		beginTransaction;
		berth.setPropertyValue("myRoot",app.myRoot);
		commitTransaction;
		count := count + 1;
		updatedBerths.add(berth);
	endwhile;
	delete iter;
	
	if count = 0 then
		str := "No Berths were found with an invalid 'myRoot' reference." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
		return;
	else
		str := count.String &amp; " Berth(s) had their 'myRoot' reference populated, they were:" &amp; CrLf;
		writeOutputToMyForm(str);
		writeOutputToMyForm(CrLf);
		foreach berth in updatedBerths do		
			str := "- " &amp; berth.getDisplayString &amp; CrLf; 
			writeOutputToMyForm(str);
		endforeach;
	endif;
	
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog

	delete allBerths;
	delete updatedBerths;
	delete iter;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetupVehicleBookingRoot" id="9cc8dc66-cb64-4a97-a702-769ccaa46aaf">
        <source>doSetupVehicleBookingRoot();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2014	cnwndl1	Initial creation	Par 35342

*/

vars

	param : String;
	update : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
			endif;
		endif;
 	endif;
	
	if not update then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 35342 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Some JMT systems created during 2013 and 2014 may not have the base Vehicle Booking Root data created." &amp; CrLf;
		info := info &amp; "In these systems, adding the Vehicle Booking License will not be enough to enable 'Vehicle Bookings'." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This script provides a mechanism to set the Vehicle Booking Root data where necessary and correct the issue" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE - will set up the data where necessary and report the results." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only 'UPDATE' is considered to be a valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doSetupVehicleBookingRootWork(true);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetupVehicleBookingRootWork" id="6a377a72-dec3-40d7-aae6-eb0e5865a68c">
        <source>doSetupVehicleBookingRootWork( update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2014	cnwndl1	Initial creation	Par 

*/

vars

	str : String;
	count : Integer;
	term : CM_Terminal;
	vbTerm : CM_VehicleBookingTerminal;
	vbRoot : CM_VehicleBookingRoot;

begin

	str := "Processing in UPDATE mode :" &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	if CM_VehicleBookingRoot.firstInstance = null then
		beginTransaction;
		create vbRoot;
		commitTransaction;
		str := "Vehicle Booking Root object created..." &amp; CrLf;
		writeOutputToMyForm(str);
	else
		str := "Vehicle Booking Root object already exists, no action taken." &amp; CrLf;
		writeOutputToMyForm(str);
	endif;
	
	app.setMyVehicleBookingRoot();
	
	str := "Checking each terminal..." &amp; CrLf;
	writeOutputToMyForm(str);
	
	foreach term in CM_Terminal.instances do
		if term.myVehicleBookingTerminal &lt;&gt; null then
			str := "Vehicle Booking Terminal object for '" &amp; term.code &amp; "' already exists, no action taken." &amp; CrLf;
			writeOutputToMyForm(str);
		else
			beginTransaction;
			vbTerm := term.createVehicleBookingTerm();
			commitTransaction;
			str := "Vehicle Booking Terminal object for '" &amp; term.code &amp; "' created..." &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
	endforeach;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowLastUpdate" id="5e4b1cb4-14df-4996-b8fe-171891a282c2">
        <source>doShowLastUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2019	jlgndl1	Initial creation

*/

vars

	param : String;
	list : Boolean;
	info : String;
	schema : Schema;
	vClass : Class;
	meth : Method;
	schemaName : String;
	className : String;
	methodName : String;
	methodError: Boolean;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size &gt; 2 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "LIST" then
				list := true;
			endif;
			schemaName := self.parameterArray[2].trimBlanks;
			schema := rootSchema.getSchema( schemaName );
			if schema &lt;&gt; null then
				className := self.parameterArray[3].trimBlanks;
				vClass := schema.getClass( className );
			endif;
			if vClass &lt;&gt; null and self.parameterArray.size &gt; 3 then
				methodName := self.parameterArray[4].trimBlanks;
				meth := vClass.getMethod( methodName );
				if meth = null then
					methodError := true;
				endif;
			endif;
			
		endif;
 	endif;
	
	if not list or schema = null or vClass = null or methodError then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is for checking the last modified timestamp on a Class or Method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		if list then 
			if schema = null then
				info := info &amp; "Schema '" &amp; schemaName &amp; "' not found" &amp; CrLf;
			elseif vClass = null then
				info := info &amp; "Class '" &amp; className &amp; "' not found within '" &amp; schemaName &amp; "'" &amp; CrLf;
			elseif methodError then
				info := info &amp; "Method '" &amp; methodName &amp; "' not found within '" &amp; className &amp; "'" &amp; CrLf;
			endif;
		endif;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST &lt;schema.name&gt; &lt;class.name&gt; &lt;method.name&gt;" &amp; CrLf;
		info := info &amp; "LIST &lt;schema.name&gt; &lt;class.name&gt;" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "e.g. 'LIST PortSchema CM_TrackedItem isForty'" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only 'List' is considered to be a valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doShowLastUpdateWork( vClass, meth );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowLastUpdateWork" id="da249186-a262-4bea-b566-c7e738d7dcff">
        <source>doShowLastUpdateWork(	_class : Class;
						_meth : Method
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2019	jlgndl1	Initial creation

*/

vars

	info : String;

begin

	if _meth &lt;&gt; null then		
		info := _meth.qualifiedName &amp; " was last modified on " &amp; _meth.cnEcGetModifyTimeStamp.String;
	else
		info := _class.name &amp; " was last modified on " &amp; _class.cnEcGetModifyTimeStamp.String;
	endif;
	
	self.writeOutputToMyForm(info);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_meth" type="Method"/>
    </JadeMethod>
    <JadeMethod name="doSplitInvoice" id="6c476bea-dcd8-4f8d-a481-79fa5c55515e">
        <source>doSplitInvoice();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Decemeber 2012	cnwndl1	Initial creation	Par 30685

*/

vars

	param : String;
	split : Boolean;
	test : Boolean;
	term : CM_Terminal;
	bank : CM_Bank;
	paramInt : Integer;
	inv : CM_Invoice;
	maxLines : Integer;
	info : String;
	
	exampleTerm : CM_Terminal;
	exampleBank : CM_Bank;
	exampleInv : CM_Invoice;
	exampleInvSeqNum : Integer;
	
	listTerminals : Boolean;
	listBUs : Boolean;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		
		param := self.parameterArray.first.trimBlanks.toUpper;
		if param = "SPLIT" then
			split := true;
		elseif param = "TEST" then
			test := true;
		endif;
		
		if self.parameterArray.size &gt;= 2 then
			param := self.parameterArray[2].trimBlanks.toUpper;
			term := app.myRoot.allTerminals.getAtKey( param );
			if term = null and app.myRoot.allTerminals.size = 1 then
				term := app.myRoot.allTerminals.first;
			endif;
		endif;
		
		if self.parameterArray.size &gt;= 3 and term &lt;&gt; null then
			param := self.parameterArray[3].trimBlanks.toUpper;
			bank := term.companies.getAtKey( param );
			if bank = null and term.companies.size = 1 then
				bank := term.companies.first;
			endif;
		endif;
		
		if self.parameterArray.size &gt;= 4 and bank &lt;&gt; null then
			param := self.parameterArray[4].trimBlanks;

			if param.isInteger then
				paramInt := param.Integer;
			endif;
			if paramInt &gt; 0 then
				inv := bank.allInvoices.getAtKey( term, bank, paramInt );
			endif;
		endif;
		
		if self.parameterArray.size &gt;= 5 and inv &lt;&gt; null then
			param := self.parameterArray[5].trimBlanks;
			if param.isInteger then
				paramInt := param.Integer;
				maxLines := paramInt;
			endif;
		endif;
		
 	endif;
	
	if ( not split and not test )
	or inv = null
	or ( inv &lt;&gt; null and ( not inv.status &lt;&gt; CM_Invoice.INVOICE_OPEN and not inv.status &lt;&gt; CM_Invoice.INVOICE_PENDING ) )
	or ( maxLines &gt; 31999 or maxLines &lt; 1 or maxLines &gt; inv.invoiceLines.size )
	then
	
		if self.parameterArray.isEmpty then
			info := info &amp; "** No recognised parameter(s) entered!" &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			
		elseif ( not split and not test ) then
			info := info &amp; "** &lt;action&gt; was not supplied or was not 'SPLIT' or 'TEST'" &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			
		elseif term = null then
			info := info &amp; "** &lt;terminal&gt; not supplied or did not resolve to the 'code' of a terminal in your system" &amp; CrLf;
			listTerminals := true;
			info := info &amp; "" &amp; CrLf;
			
		elseif bank = null then
			info := info &amp; "** &lt;business unit&gt; not supplied or did not resolve to the 'code' of a valid Business in '" &amp; term.code &amp; "'" &amp; CrLf;
			listBUs := true;
			info := info &amp; "" &amp; CrLf;
		
		elseif inv = null then
			info := info &amp; "** &lt;invoice number&gt; not supplied or did not resolve to a valid Invoice for '" &amp; term.code &amp; "' / '" &amp; bank.code &amp; "'" &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			
		elseif ( inv &lt;&gt; null and ( inv.status &lt;&gt; CM_Invoice.INVOICE_OPEN and inv.status &lt;&gt; CM_Invoice.INVOICE_PENDING ) ) then
			info := info &amp; "** &lt;invoice number&gt; resolves to an Invoice that is " &amp; inv.getStatusDescriptionForSelf &amp; ". Invoices must be 'Open' or 'Pending' to be split." &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			
		elseif ( inv &lt;&gt; null and inv.invoiceLines.isEmpty ) then
			info := info &amp; "** &lt;invoice number&gt; resolves to an Invoice that has no invoice lines." &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			
		elseif maxLines &gt; 31999 then
			info := info &amp; "** &lt;max lines/invoice&gt; may not be greater than 31999" &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
		
		elseif maxLines &lt; 1 then
			info := info &amp; "** &lt;max lines/invoice&gt; may not be less than one" &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			
		elseif maxLines &gt; inv.invoiceLines.size then
			info := info &amp; "** &lt;max lines/invoice&gt; may not be more than the total number of lines on the invoice." &amp; CrLf;
			info := info &amp; "** &lt;max lines/invoice&gt; = '" &amp; maxLines.String &amp; "', and Invoice '" &amp; inv.sequenceNum.String &amp; "' only has '" &amp; inv.invoiceLines.size.String &amp; "' lines." &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
		
		endif;
		
		exampleTerm := term;
		if exampleTerm = null then
			exampleTerm := CM_Terminal.firstInstance;
		endif;
		exampleBank := bank;
		if exampleBank = null then
			foreach exampleBank in exampleTerm.companies do
				if exampleBank.allInvoices.isEmpty then
					continue;
				endif;
				break;
			endforeach;
		endif;
		exampleInv := inv;
		if exampleInv = null then
			exampleInv := exampleBank.allInvoices.first;
		endif;
		if exampleInv = null then
			exampleInvSeqNum := 236;
		else
			exampleInvSeqNum := exampleInv.sequenceNum;
		endif;
		
		info := info &amp; "This method is relative to Par 30685 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Within JMT there is no actual limit to the number of invoice lines that you can have on an invoice.  However, from a practical" &amp; CrLf;
		info := info &amp; "point of view, there is a limit of 32000 entries when displaying objects in a table, and tables are used to display invoice lines" &amp; CrLf;
		info := info &amp; "for an invoice. Therefore, the parctical limit is 31999 lines per invoice." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides a mechanism to split a nominated invoice, by creating additional invoice(s) for the same terminal / business unit" &amp; CrLf;
		info := info &amp; "and moving invoice lines from the original invoice to the newly created invoice(s) based on a user nominated maximum number of lines." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Invoices can only be split by this method if the nominated invoice is 'Open' or 'Pending'." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Once you have found an invoice in JMT that you would like to split by this method. You will need to identify the invoice to this method and" &amp; CrLf;
		info := info &amp; "effectively tell the method what you want it to do." &amp; CrLf;
		info := info &amp; "To do use this, you will  need to enter 5 pieces of information into the parameter field above. The parameter information needs to be in the" &amp; CrLf;
		info := info &amp; "correct format, in the correct order, and each piece individually separated from the next by a space character." &amp; CrLf;
		info := info &amp; "The 5 pieces of information in order are: &lt;action&gt; &lt;terminal&gt; &lt;business unit&gt; &lt;invoice number&gt; &lt;max lines/invoice&gt;" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Portions of the Parameter:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "&lt;action&gt; - This must be either 'SPLIT' or 'TEST'.  'TEST' just will check the invoice and tell you what it would do. SPLIT will" &amp; CrLf;
		info := info &amp; "           process the nominated Invoice, creating one or more additional invoices, and move the excess lines from the original" &amp; CrLf;
		info := info &amp; "           invoice to one of the newly created extra invoices." &amp; CrLf;
		info := info &amp; "&lt;terminal&gt; - This must be the 'code' of the terminal that the nominated invoice was created within. I.e. '" &amp; exampleTerm.code &amp;"'" &amp; CrLf;
		info := info &amp; "&lt;business unit&gt; - This must be the 'code' of the business unit that the nominated invoice was created against. I.e. '" &amp; exampleBank.code &amp;"'" &amp; CrLf;
		info := info &amp; "&lt;invoice number&gt; - This must be the 'sequence number' of the nominated invoice. I.e. '" &amp; exampleInvSeqNum.String &amp;"'" &amp; CrLf;
		info := info &amp; "&lt;max lines/invoice&gt; - This is the maximum number of lines to allow on each invoice during the splitting of the invoice.  If the original" &amp; CrLf;
		info := info &amp; "           Invoice has 1000 lines on it and you set the &lt;max lines per invoice&gt; to 400, the original Invoice would be left with 400" &amp; CrLf;
		info := info &amp; "           lines on it, 2 new invoices would be created the first with 400 lines on it and the second with the last 200 lines on it." &amp; CrLf;
		
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The complete parameter entered must contain all 5 pieces of information.  These pieces of information must be space delimited, and must be" &amp; CrLf;
		info := info &amp; "in the following order - " &amp; CrLf;
		info := info &amp; "&lt;action&gt; &lt;terminal&gt; &lt;business unit&gt; &lt;invoice number&gt; &lt;max lines/invoice&gt;" &amp; CrLf;
		info := info &amp; "I.e." &amp; CrLf;
		info := info &amp; "TEST " &amp; exampleTerm.code &amp; " " &amp; exampleBank.code &amp; " " &amp; exampleInvSeqNum.String &amp; " 400" &amp; CrLf;
		
		if listTerminals then
			info := info &amp; "" &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			info := info &amp; "** Valid &lt;terminal&gt; values are:" &amp; CrLf;
			foreach term in app.myRoot.allTerminals do
				info := info &amp; term.code &amp; CrLf;
			endforeach;
			info := info &amp; "" &amp; CrLf;
			
		elseif listBUs then
			info := info &amp; "" &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			info := info &amp; "** Valid &lt;business unit&gt; values for '" &amp; term.code &amp; "' are:" &amp; CrLf;
			foreach bank in term.companies do
				info := info &amp; bank.code &amp; CrLf;
			endforeach;
			info := info &amp; "" &amp; CrLf;
			
		endif;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doSplitInvoiceWork( split, inv, maxLines );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSplitInvoiceWork" id="29b48fc4-a1ca-4b6a-a9ed-a4d328d3c8db">
        <source>doSplitInvoiceWork( _split : Boolean; _inv : CM_Invoice io; _maxLines : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Decemeber 2012	cnwndl1	Initial creation	Par 30685
04/03/2015			cnwmh5	Tranisent Leak
*/
vars

	str : String;
	iter : Iterator;
	totLines : Integer;
	invLine : CM_InvoiceLine;
	invLinesToMove : CM_InvoiceLineBySeqNumDict;
	invLinesToMoveSize : Integer;
	newInvs : Integer;
	remainder : Integer;
	willWould : String;
	currentInv : CM_Invoice;
	pxyInvoice : CM_Invoice;
	theController : CMIF_InvoiceLineMove;
	createdInvs : CM_InvoiceSet;
	failed : Boolean;
	endDate : Date;

begin

	if not _split then
		str := "Processing in TEST mode for " &amp; _inv.sequenceNum.String &amp; ", max line per invoice set to " &amp; _maxLines.String &amp; CrLf;
		willWould := "would";
	else
		str := "Processing in SPLIT mode for " &amp; _inv.sequenceNum.String &amp; ", max line per invoice set to " &amp; _maxLines.String &amp; CrLf;
		willWould := "will";
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	create invLinesToMove transient;
	iter := _inv.invoiceLines.createIterator;
	while iter.next( invLine ) do
		totLines := totLines + 1;
		if totLines &lt;= _maxLines then
			continue;
		endif;
		invLinesToMove.add( invLine );
	endwhile;
	
	str := "Invoice " &amp; _inv.sequenceNum.String &amp; ", currently has " &amp; _inv.invoiceLines.size.String &amp; " lines on it." &amp; CrLf &amp; CrLf;
	writeOutputToMyForm(str);
	
	if not invLinesToMove.isEmpty then
	
		str := "After Splitting, Invoice " &amp; _inv.sequenceNum.String &amp; ", it " &amp; willWould &amp; " be left with " &amp; _maxLines.String &amp; " lines on it." &amp; CrLf;
		writeOutputToMyForm(str);
		
		invLinesToMoveSize := invLinesToMove.size;
		newInvs := invLinesToMoveSize div _maxLines;
		remainder := invLinesToMoveSize mod _maxLines;
		
		if newInvs &gt; 0 then
			str := newInvs.String &amp; " additional Invoice(s), " &amp; willWould &amp; " be created with " &amp; _maxLines.String &amp; " lines on them." &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
		if remainder &gt; 0 then
			str := "Another new invoice " &amp; willWould &amp; " be created with the remaining " &amp; remainder.String &amp; " lines on them." &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
		if _split then
			// we are really going to do this...
			app.myPassport.setMyTerminal(_inv.myTerminal);
			create createdInvs transient;
			
			str := CrLf &amp; "Processing split please wait..." &amp; CrLf &amp; CrLf;
			writeOutputToMyForm(str);
			
			while true do
			
				// gather up the lines to copy across to the new invoice
				create theController transient;
				while true do
					if invLinesToMove.isEmpty then
						break;
					endif;
					invLine := invLinesToMove.first;
					invLinesToMove.remove(invLine);
					theController.allInvoiceLines.add(invLine);
					if theController.allInvoiceLines.size = _maxLines then
						break;
					endif;
				endwhile;
			
				if not theController.allInvoiceLines.isEmpty then
					//create the new invoice to copy lines to
					//and update the lines onto the new invoice.
					app.myTrxCA.trxCreateInvoiceForSplitLines(_inv, currentInv, theController, app.myPassport);
					if not app.myPassport.trxCompletedOK then
						str := "ERROR during create of new invoice for line transfer..." &amp; CrLf;
						writeOutputToMyForm(str);
						str := app.myPassport.getErrorsAndWarningsAsString &amp; CrLf;
						writeOutputToMyForm(str);
						failed := true;
						break;
					endif;
					createdInvs.add( currentInv );	
				endif;
				delete theController;
				
				if invLinesToMove.isEmpty then
					break;
				endif;
				
			endwhile;
			
			if not failed then
				str := "Invoice " &amp; _inv.sequenceNum.String &amp; ", now has " &amp; _inv.invoiceLines.size.String &amp; " lines on it." &amp; CrLf;
				writeOutputToMyForm(str);
				foreach currentInv in createdInvs do
					str := "New Invoice " &amp; currentInv.sequenceNum.String &amp; ", has " &amp; currentInv.invoiceLines.size.String &amp; " lines on it." &amp; CrLf;
					writeOutputToMyForm(str);
				endforeach;
			endif;
			
		endif;
		
	else
		str := "Invoice " &amp; _inv.sequenceNum.String &amp; ", No processing required." &amp; CrLf;
		writeOutputToMyForm(str);
		
	endif;
	
epilog

	delete invLinesToMove;
	delete theController;
	delete createdInvs;
	delete iter;

end;
</source>
        <access>protected</access>
        <Parameter name="_split" type="Boolean"/>
        <Parameter name="_inv" type="CM_Invoice" usage="io"/>
        <Parameter name="_maxLines" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doStraddleStackRowRenumber" id="3b38e851-9610-4844-ad61-5378842c0047">
        <source>doStraddleStackRowRenumber();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwndl1	Initial creation	Par 30521

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 30521 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Straddle stacks use an internal index to refer to the rows and columns in the stack. JMT uses these values within the code to" &amp; CrLf;
		info := info &amp; "uniquely identify positions in the stack. These indicies are not visible to the users." &amp; CrLf;
		info := info &amp; "In some parts of the code, JMT expects these indicies to start at '1' and increment by '1' with no gaps." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Histotrical issues with the maintenance of Grid rows in Straddle stacks means that some Straddle stacks may have gaps" &amp; CrLf;
		info := info &amp; "in their row index sequencing.  Generally this has no detrimental effect on the day to day processing in JMT." &amp; CrLf;
		info := info &amp; "However, if a user attempts to set up a single Yard Allocation to cover an entire Straddle Stack, (where the stack has" &amp; CrLf;
		info := info &amp; "index gaps) the user may experience an error 1311." &amp; CrLf;
		info := info &amp; "Similarly, attempting to insert new grid rows into a stack with index gaps may also generate an error." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This script provides a mechanism to find and reset the internal indicies of any effected Straddle Stacks" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will report any Straddle Stacks that it finds with index gaps." &amp; CrLf;
		info := info &amp; "UPDATE - will find any effected Straddle Stacks, reset their indicies and report the results." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doStraddleStackRowRenumberWork( update );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doStraddleStackRowRenumberWork" id="83557b19-10de-4b80-a72e-e24e85d2a5ab">
        <source>doStraddleStackRowRenumberWork( _update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwndl1	Initial creation	Par 30521

*/

vars

	iter : Iterator;
	ss : CM_StraddleStack;
	termName : String;
	gr : CM_GridRow;
	rowCount : Integer;
	ssArray : ObjectArray;
	obj : Object;
	grArray : ObjectArray;
	newIndex : Integer;
	str : String;

begin

	if not _update then
		str := "Processing in LIST mode :";
	elseif _update then
		str := "Processing in UPDATE mode :";
		
	endif;
	writeBatchOutput(str);
	str := str &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create ssArray transient;

	iter := CM_StraddleStack.instances.createIterator;
	while iter.next ( ss ) do
		if ss.myTerminal = null then
			continue;
		endif;
		termName := ss.myTerminal.code;
		rowCount := 0;
		foreach gr in ss.allGridRows do
			rowCount := rowCount + 1;
			if gr.row &lt;&gt; rowCount then
				if not _update then
					str := termName &amp; " " &amp; ss.id &amp; " has one or more grid row index gaps starting at index " &amp; rowCount.String &amp; CrLf;
					writeOutputToMyForm(str);
				endif;
				ssArray.add( ss );
				break;
			endif;
		endforeach;
		
	endwhile;
	
	if ssArray.isEmpty then
		str := "No index gaps found within any of the Straddle Stacks in this system.";
		writeBatchOutput(str);
		str := str &amp; CrLf;
		writeOutputToMyForm(str);
		return;
		
	elseif not _update then
		str := CrLf &amp; "JMT recommends that you run this script in UPDATE mode to repair the " &amp; ssArray.size.String &amp; " Straddle area(s) that currently have index gaps in this system!"&amp; CrLf;
		writeOutputToMyForm(str);
		return;
		
	elseif _update then
		create grArray transient;
		
		foreach obj in ssArray do
			ss := obj.CM_StraddleStack;
			grArray.clear();
			newIndex := 0;
			termName := ss.myTerminal.code;
			
			foreach gr in ss.allGridRows do
				grArray.add(gr);
			endforeach;
			
			foreach obj in grArray do
				gr := obj.CM_GridRow;
				newIndex := newIndex + 1;
				if gr.row &lt;&gt; newIndex then
					str := termName &amp; " " &amp; ss.id &amp; " grid row '" &amp; gr.label &amp; "' index updated " &amp; gr.row.String &amp; " -&gt; " &amp; newIndex.String;
					writeBatchOutput(str);
					str := str &amp; CrLf;
					writeOutputToMyForm(str);
					beginTransaction;
					gr.setRow(newIndex);
					commitTransaction;
				endif;
			endforeach;
			
		endforeach;
		
	endif;
	
	
epilog

	delete iter;
	delete ssArray;
	delete grArray;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTFS51570CleanUp" id="0e66a3f1-f243-4cbe-96f5-87fabeca0a5b">
        <source>doTFS51570CleanUp();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2021	navndl1	Initial creation	TFS 50910 / 51570

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to TFS 50910 or TFS 51570 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method will remove the Fleet File object (Master object) for every Container (and for every Trailer) that is not currently" &amp; CrLf;
		info := info &amp; "attached to a Generator. Additionally it will also remove it, if it is attached, BUT the Generator is not in the fleet file." &amp; CrLf;
		info := info &amp; "No Generator Fleet file objects will be touched." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "A feature formerly controlled by the Terminal Config 'Auto Link Reefer, Trailer and Generator Master Links' was automatically" &amp; CrLf;
		info := info &amp; "generating Fleet File (Master) records for all trailers, generators and reefers received on site." &amp; CrLf;
		info := info &amp; "These Master objects were then used to record the relationships between Containers (or Trailers) and Generators," &amp; CrLf;
		info := info &amp; "so that when a Container (or Trailer) was received at the 'Road Gate' that was previously released with an attached Generator," &amp; CrLf;
		info := info &amp; "MTN could be aware of the relationship, by looking up the Master objects. This enabled MTN to prefill some additional related" &amp; CrLf;
		info := info &amp; "data on the 'Road Gate' form, saving data entry for the users." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The behaviour of this feature has been amended by TFS 50910 / 51570 so as to be more selective about which Master objects are" &amp; CrLf;
		info := info &amp; "automatically created and how long they are retained." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The old Terminal Config has been renamed to be 'Auto Link/Delink Gen-sets in the Fleet File' to better describe the new behaviour." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The new rules are:" &amp; CrLf;
		info := info &amp; " - MTN no longer auto creates (or deletes) Generator Master Objects or Trailer Master Objects.  These must be added manually." &amp; CrLf;
		info := info &amp; " - MTN now automatically creates a Master Object for a Container only when a Generator (with an existing Master Object) is in the" &amp; CrLf;
		info := info &amp; "      process of being attached to it." &amp; CrLf;
		info := info &amp; " - MTN now automatically deletes the Master Object for a Container only when its 'Attached Generator' (with an existing Master" &amp; CrLf;
		info := info &amp; "      Object) is being detached from it." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This script provides the mechanism to easily get rid of the majority of the old Fleet File (Master Object) data, while keeping the" &amp; CrLf;
		info := info &amp; "data that would have been there if the new rules above had already been in place." &amp; CrLf;
		info := info &amp; "I.e. It will delete all Container Master Objects that do not currently have an associated Generator Master Object, and it will delete" &amp; CrLf;
		info := info &amp; "all Trailer Master Objects that do not currently have an associated Generator Master Object." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - Will list out the Fleet file objects (Master Objects) that would be retained, and it will also provide a count of the number of" &amp; CrLf;
		info := info &amp; "       Master Objects that would be deleted." &amp; CrLf;
		info := info &amp; "UPDATE - Will perform the delete of the Fleet File objects (Master records) in line with the explanation above." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doTFS51570CleanUpWork( update );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTFS51570CleanUpWork" id="f1dcf38d-3657-45ed-b4cc-50a46eba318d">
        <source>doTFS51570CleanUpWork( _update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2021	navndl1	Initial creation	TFS 50910 / 51570

*/

vars

	iter : Iterator;
	str : String;
	master : CM_TIMaster;
	contMastersToDel : CM_TIMasterByCargoTypeIdDict;
	tilcMastersToDel : CM_TIMasterByCargoTypeIdDict;
	keepers : CM_TIMasterByCargoTypeIdDict;
	delCount : Integer;

begin

	if not _update then
		str := "Processing in LIST mode :";
	elseif _update then
		str := "Processing in UPDATE mode :";	
	endif;
	
	writeBatchOutput(str);
	str := str &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create contMastersToDel transient;
	create tilcMastersToDel transient;
	create keepers transient;
	
	str := "Checking Fleet File data..."&amp; CrLf;
	writeOutputToMyForm(str);

	iter := app.myRoot.allTiMasters.createIterator;
	while iter.next ( master ) do
		if master.isContainer then
			if master.allTIMasterAttachees.isEmpty then
				contMastersToDel.add( master );
			else
				keepers.add( master );
			endif;
		elseif master.isGenerator then
			keepers.add( master );
		elseif master.isTILC then
			if master.allTIMasterAttachees.isEmpty then
				tilcMastersToDel.add( master );
			else
				keepers.add( master );
			endif;
		endif;
	endwhile;
	
	if contMastersToDel.isEmpty then
		str := "No Container Masters found that would be deleted" &amp; CrLf;
	else
		str := contMastersToDel.size.String &amp; " Container Masters have been found that would be deleted" &amp; CrLf;
	endif;
	writeOutputToMyForm(str);
	
	if tilcMastersToDel.isEmpty then
		str := "No Trailer/Chassis Masters found that would be deleted" &amp; CrLf;
	else
		str := tilcMastersToDel.size.String &amp; " Trailer/Chassis Masters have been found that would be deleted" &amp; CrLf;
	endif;
	writeOutputToMyForm(str);
	
	if keepers.isEmpty then
		str := "No Masters found that would be kept" &amp; CrLf;
		
	else
		str := keepers.size.String &amp; " Masters have been found that would be kept" &amp; CrLf;
		writeOutputToMyForm(str);
		
		writeOutputToMyForm(CrLf);
		foreach master in keepers do
			if master.isContainer then
				str := "Container " &amp; master.id &amp; " has " &amp; master.allTIMasterAttachees.first.id &amp; " attached to it, so will be kept" &amp; CrLf;
				writeOutputToMyForm(str);
			elseif master.isGenerator then
				str := "Generator " &amp; master.id &amp; " will be kept" &amp; CrLf;
				writeOutputToMyForm(str);
			elseif master.isTILC then
				str := "Trailer " &amp; master.id &amp; " has " &amp; master.allTIMasterAttachees.first.id &amp; " attached to it, so will be kept" &amp; CrLf;
				writeOutputToMyForm(str);
			endif;
		endforeach;
		
	endif;
	
	if not _update then
		return;
		
	elseif _update then
		
		writeOutputToMyForm(CrLf);
		
		foreach master in tilcMastersToDel do
			app.myTrxDA.trxDeleteTIMaster( master, app.myPassport );
			if app.myPassport.noErrors then
				delCount := delCount + 1;
			endif;
		endforeach;
		str := delCount.String &amp; " Trailer Fleet File Master Objects were deleted." &amp; CrLf;
		writeOutputToMyForm(str);
		
		delCount := 0;
		foreach master in contMastersToDel do
			app.myTrxDA.trxDeleteTIMaster( master, app.myPassport );
			if app.myPassport.noErrors then
				delCount := delCount + 1;
			endif;
		endforeach;
		str := delCount.String &amp; " Container Fleet File Master Objects were deleted." &amp; CrLf;
		writeOutputToMyForm(str);
		
	endif;
		
epilog

	delete iter;
	delete contMastersToDel;
	delete tilcMastersToDel;
	delete keepers;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTriggerDataExtrctFrmOids" id="678ec44a-08d2-4d7f-af89-24e24d72dbb5">
        <source>doTriggerDataExtrctFrmOids();
/*

Purpose:			Triggers data extract and runs doTriggerDataExtrctFrmOidsWork to do the work

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
24 November 2025	navpw1	Initial creation JIRA: MTN-36212

*/

vars
	param,
	param2,
	param3,
	outputFilePath,
	filePath,
	info			: String;
	update,
	summary			: Boolean;
	
begin
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 3 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;
			param3 := self.parameterArray[3].trimBlanks.toUpper;
		endif;
		if param = "UPDATE" then
			update := true;
		elseif param = "SUMMARY" then
			summary := true;
		endif;
		if param2 &lt;&gt; null then
			filePath := param2;
		endif;
		if param3 &lt;&gt; null then
			outputFilePath := param3;
		endif;
 	endif;
	
	if (not update and not summary) or filePath = null or outputFilePath = null then
		info := "One or more parameter(s) not recognised or invalid" &amp; CrLf;
		if not update and not summary then
			info := info &amp; " - Expected 'Update' or 'Summary' parameter" &amp; CrLf;
		endif;
		if filePath = null then
			info := info &amp; " - Expected &lt;filePath&gt; parameter" &amp; CrLf;
		endif;
		if outputFilePath = null then
			info := info &amp; " - Expected &lt;outputFilePath&gt; parameter" &amp; CrLf;
		endif;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to MTN-36212." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It provides an alternate method to update the edition on objects and force a data extract" &amp; CrLf;
		info := info &amp; "It is provided so objects editions can be updated to trigger a data extract of that object" &amp; CrLf;
		info := info &amp; "This happens from a provided file of object oids" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "&lt;action&gt; &lt;filePath&gt; &lt;outputFilePath&gt;" &amp; CrLf;
		info := info &amp; "&lt;action&gt; = Either 'UPDATE' or 'SUMMARY'. 'Update' will read the file line by line and update the objects edition if it is not null and 'Summary' will read the file line by line and provide a summary of the oids to be updated" &amp; CrLf;
		info := info &amp; "&lt;filePath&gt; = The path to the file to be used to get a list of objects to update the edition on" &amp; CrLf;
		info := info &amp; "&lt;outputFilePath&gt; = The path to the output file to be used to record, in csv format, which objects have been updated and whether there were errors" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "E.g." &amp; CrLf;
		info := info &amp; "UPDATE C:\temp\update.csv C:\temp\outputFile.csv" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		return;
		
	endif;

	app.mousePointer := MP_HOURGLASS;
	
	self.doTriggerDataExtrctFrmOidsWork(update, summary, filePath, outputFilePath);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doTriggerDataExtrctFrmOidsWork" id="1154b27b-f9b5-40b0-a18b-20f6eb778af7">
        <source>doTriggerDataExtrctFrmOidsWork(_update, _summary : Boolean; _filePath, _outputFilePath : String) protected;
/*

Purpose:			Triggers data extract from the oids contained in an input file and produces an output file containing the following in a csv format: oid, oldEdition, newEdition, errors

Parameters:			_update			Boolean	
					_summary		Boolean	
					_filePath		String	
					_outputFilePath	String	

Return Value:		NONE

Date				Who		Reason
24 November 2025	navpw1	Initial creation JIRA: MTN-36212

*/

constants
	ExpectedSeconds		: Integer = 1;
	BatchSize			: Integer = 10000;
	
vars
	listCount,
	notFoundCount,
	batchCount,
	updatedCount,
	expectedDuration,
	csvCount			: Integer;
	oidStr,
	msg,
	line,
	targetDir,
	csvStr				: String;
	obj					: Object;
	file,
	outputFile			: File;
	csvOutput 			: HugeStringArray;
	batchCountReal		: Real;
	dynaDict			: DynaDictionary;
	iter				: Iterator;
	invalidObject,
	completedOk			: Boolean;
	fileFolder			: FileFolder;
	
begin
	if _update then
		msg := "Processing in UPDATE mode :" &amp; CrLf;
	elseif _summary then
		msg := "Processing in SUMMARY mode :" &amp; CrLf;
	else
		return;
	endif;
	
	self.writeOutputToMyForm(msg);
	self.writeOutputToMyForm(CrLf);
	
	msg := "Updating editions and forcing data extract..." &amp; CrLf;
	
	self.writeOutputToMyForm(msg);
	self.writeOutputToMyForm(CrLf);
	
	targetDir := app.copyFileToAppServer(_filePath); //Upload file to app server as it is faster
	
	create file transient;
	create csvOutput transient;
	
	file.usePresentationFileSystem := false;	// use the appServer file system
	file.fileName := targetDir;
	
	//Check input file is available 
	if (not file.isAvailable) then
		msg := app.getErrorString2(Err_DirectoryNotAvailable, targetDir, app.computerNameAppServer) &amp; CrLf;
		self.writeOutputToMyForm(msg);
		self.writeOutputToMyForm(CrLf);
		return;
		
	endif;
	
	//Check output folder is available 
	create fileFolder transient;
	if (not fileFolder.isValidPathName(targetDir)) then //isValidPathName works even if you specify a file on the end // ### JIRA: MTN-37020 20Jan2026 NAVPW1 - Fixed copy paste error
		msg := app.getErrorString2(Err_DirectoryNotAvailable, targetDir, app.computerNameAppServer) &amp; CrLf;
		self.writeOutputToMyForm(msg);
		self.writeOutputToMyForm(CrLf);
		return;
		
	endif;
	
    file.mode := file.Mode_Input;
	file.endOfLine := null;
    file.openInput(targetDir);
	
	create dynaDict transient;
	dynaDict.setMembership(Object);
	dynaDict.addExternalKey(String, 50, false, false);
	dynaDict.endKeys(false);
	
	while true do
		line := file.readLine(); //Read the next line
		
		if(line = null and file.endOfFile()) then
			break;
		endif;
		
		dynaDict.putAtKey(line, line.asOid);
		
	endwhile;
	
	
	msg := "Summary:" &amp; CrLf;
	self.writeOutputToMyForm(msg);
	self.writeOutputToMyForm(CrLf);
	
	listCount := dynaDict.size;
	
	batchCount := 1;
	
	if listCount &gt; BatchSize then
		batchCountReal := listCount / BatchSize;	//Divide list count by batch size
		batchCount := batchCountReal.Integer;		//Get batch count as integer
		if listCount mod batchCountReal &gt; 0 then	//If listCount mod batchCountReal (Cause we can have half batches) is greater then 0, we need another batch.
			batchCount += 1;
		endif;
		
	endif;
	
	expectedDuration := batchCount * ExpectedSeconds;
	
	if expectedDuration &lt; 60 then
		expectedDuration := 1;
	else
		expectedDuration := expectedDuration div 60; //To get the expectedDuration in minute(s) not seconds
	endif;
	
	msg := listCount.asStringJMT &amp; " Oids to be updated, " &amp; batchCount.asStringJMT &amp; " batches, expected duration " &amp; expectedDuration.String &amp; " minute(s)" &amp; CrLf;
	self.writeOutputToMyForm(msg);
	self.writeOutputToMyForm(CrLf);
	
	listCount := 0;
	
	if not _summary then
		beginTransaction;
	endif;
	
	iter			:= dynaDict.createIterator;
	notFoundCount	:= 0;
	updatedCount	:= 0;
	
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);
	
	while iter.next(obj) do
		iter.getCurrentKeys(oidStr);
		
		if obj = null then
			csvStr := oidStr &amp; Comma &amp; "";
			csvStr &amp;= Comma &amp; "" &amp; Comma &amp; Not_found.String &amp; ":" &amp; app.getErrorString1(Not_found, oidStr);
			csvOutput.add(csvStr);
			notFoundCount += 1;
			listCount += 1;
			continue;
		endif;
		
		obj.edition;
		if invalidObject then
			invalidObject := false;
			csvStr := oidStr &amp; Comma;
			csvStr &amp;= Comma &amp; Comma &amp; Not_found.String &amp; ":" &amp; app.getErrorString1(Not_found, oidStr);
			csvOutput.add(csvStr);
			notFoundCount += 1;
			listCount += 1;
			continue;
		endif;
		
		csvStr := oidStr &amp; Comma &amp; obj.edition.String;
		if not _summary then
			self.updateObjectEdition(obj);	// par 30292
		endif;
		
		csvStr &amp;= Comma &amp; obj.edition.String &amp; Comma;
		csvOutput.add(csvStr);
		updatedCount += 1;
		
		listCount += 1;
		
		if listCount mod BatchSize = 0 and not _summary then
			app.cmsCommitTransaction(app.myPassport);
			beginTransaction;
		endif;
	endwhile;
	
	if not _summary then
		app.cmsCommitTransaction(app.myPassport);
	endif;
	
	msg := "Not Found Count: " &amp; notFoundCount.String &amp; CrLf;
	msg &amp;= "Updated Count: " &amp; updatedCount.String &amp; CrLf;
	self.writeOutputToMyForm(msg);
	self.writeOutputToMyForm(CrLf);
	
	create outputFile transient;
	outputFile.usePresentationFileSystem := true;	// use the thinclient file system
	outputFile.fileName := _outputFilePath;
    outputFile.mode := outputFile.Mode_Output;
	outputFile.openOutput(_outputFilePath);
	
	csvCount := 1;
	foreach csvStr in csvOutput do
		if csvCount = csvOutput.size then
			outputFile.writeString(csvStr);
		else
			outputFile.writeLine(csvStr);
		endif;
		csvCount += 1;
		
	endforeach;
	
	outputFile.close();
	on Exception do null;
	
	msg := "Output file saved to: " &amp; _outputFilePath &amp; CrLf;
	self.writeOutputToMyForm(msg);
	self.writeOutputToMyForm(CrLf);
	
	completedOk := true;
	
epilog
	if file &lt;&gt; null then
		file.purge;
		delete file;
	endif;
	delete outputFile;
	delete csvOutput;
	delete dynaDict;
	delete iter;
	delete fileFolder;
	
	if process.isInTransactionState then
		app.cmsAbortTransaction();
	endif;
	
	if not completedOk then
		msg := "Fixup Script did not run correctly. Please try again!" &amp; CrLf;
		self.writeOutputToMyForm(msg);
		self.writeOutputToMyForm(CrLf);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_summary" type="Boolean"/>
        <Parameter name="_filePath" type="String"/>
        <Parameter name="_outputFilePath" type="String"/>
    </JadeMethod>
    <JadeMethod name="doTruncateEDIinfoXML" id="5c3f5a1a-da4f-4f3b-9156-f71b50743873">
        <source>doTruncateEDIinfoXML();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2021	navndl1	Initial creation	TFS 51718

*/

vars

	param : String;
	param2 : String;
	param3 : String;
	term : CM_Terminal;
	update : Boolean;
	gcDate : Date;
	user : CM_User;
	iter : Iterator;
	userTerminal : CM_UserTerminal;
	info : String;
	now : Date;

begin

	gcDate := null;

	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 3 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;
			param3 := self.parameterArray[3].trimBlanks;
		endif;
		if param = "UPDATE" then
			update := true;
		endif;
		if param2 &lt;&gt; null then
			user := app.getMyUser;
			if user = null then
				info := info &amp; "" &amp; CrLf;
				info := info &amp; "Unable to establish User!!." &amp; CrLf;
				info := info &amp; "" &amp; CrLf;
				self.writeOutputToMyForm(info);
				return;
			endif;
			iter := user.allUserTerminals.createIterator;
			while iter.next( userTerminal )do
				if userTerminal.myTerminal.code.toUpper = param2 then
					term := userTerminal.myTerminal;
					break;
				endif;
			endwhile;
			delete iter;
		endif;
		if param3 &lt;&gt; null then
			gcDate := param3.asDateJMT;
		endif;
 	endif;
	
	if not update or term = null or gcDate = null then
		info := "One or more parameter(s) not recognised or invalid" &amp; CrLf;
		if not update then
			info := info &amp; " - Expected 'Update' parameter" &amp; CrLf;
		endif;
		if term = null then
			info := info &amp; " - Expected &lt;terminal code&gt; parameter" &amp; CrLf;
		endif;
		if gcDate = null then
			info := info &amp; " - Expected &lt;date&gt; parameter" &amp; CrLf;
		endif;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to TFS 51718." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It provides an alternate method to run the Garbage Collection '" &amp; app.getErrorString(Truncate_EDIInfo_XML) &amp; "' option." &amp; CrLf;
		info := info &amp; "It is provided so that a series of extra adhoc runs may be performed in isolation of the normal Garbage" &amp; CrLf;
		info := info &amp; "Collection to 'catch up' the truncating of the XML attribute for historical 'EDI Info Sent' transactions." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The method will run for 20 minutes or until it has truncated all of the XML data for the 'EDI Info Sent' transactions" &amp; CrLf;
		info := info &amp; "earlier than the specified date within the specified Terminal." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is the users responsibility to ensure that the system is otherwise relatively inactive. The running of this method will" &amp; CrLf;
		info := info &amp; "cause performance issues for other users. Similarly it should NOT be run during a period when a BGP is running" &amp; CrLf;
		info := info &amp; "a Garbage Collect, or if another copy of this method is already active." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE &lt;terminal code&gt; &lt;date&gt;" &amp; CrLf;
		info := info &amp; "&lt;terminal code&gt; = The 'code' of the Terminal that you want to run this for." &amp; CrLf;
		info := info &amp; "&lt;date&gt; = The most recent date that you wish to have the 'EDI INFO Sent' transactions truncated for." &amp; CrLf;
		info := info &amp; "         i.e. Transactions dated before and up to this date will have their XML truncated." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "E.g." &amp; CrLf;
		info := info &amp; "UPDATE " &amp; CM_Terminal.firstInstance.code &amp; " " &amp; now.Date.cnEcAddYears( -1 ).asStringJMT &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
		if user &lt;&gt; null and param2 &lt;&gt; null and term = null then
			info := info &amp; "'" &amp; param2 &amp; "' is not a valid terminal code!" &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			info := info &amp; "Valid Terminal codes are:" &amp; CrLf;
			iter := user.allUserTerminals.createIterator;
			while iter.next( userTerminal )do
				info := info &amp; "   " &amp; userTerminal.myTerminal.code.toUpper &amp; CrLf;
			endwhile;
			delete iter;
		endif;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;

	app.mousePointer := MP_HOURGLASS;
	
	self.doTruncateEDIinfoXMLWork( term, gcDate );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTruncateEDIinfoXMLWork" id="2c713d4b-3639-4b82-beb7-39cda83e41c4">
        <source>doTruncateEDIinfoXMLWork( _term : CM_Terminal; _endDate : Date) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2021	navndl1	Initial creation	TFS 51718
20 September 2022 navmv20 ChangeRequest : MTN - Garbage Collection of Release Request
13 Feb 2023 		navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
21 Jul 2023 		navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
11 Aug 2025			navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
*/

vars

	ediInfoSent 		: CM_InfoEDISent;
	edition 			: Integer;
	invalid 			: Boolean;
	tiTrx 				: CM_TITransaction;
	agent 				: CM_DBPurgeAgent;
	startDate 			: Date;
	str 				: String;
	lastProcessedDate 	: Date;
	iter 				: Iterator;
	nextEdiInfoSent 	: CM_InfoEDISent;
	bgpRequest 			: BGP_DatabasePurgeRequest;

begin

	//find the most recent truncated EDI Info Sent object ( or teh next one to be processed, if none have been done in this terminal)
	ediInfoSent := _term.getConfig( LatestTruncatedEDIinfo ).CM_InfoEDISent;
	
	on Exception do app.handleDeletedObject( exception, ediInfoSent, invalid );
	if ediInfoSent &lt;&gt; null then
		edition := ediInfoSent.edition;
		if invalid then
			ediInfoSent := null;
		endif;
	endif;
	if ediInfoSent = null then
		tiTrx := _term.allTITransactionsByTypeDate.getAtKeyGeq( TRANS_TYPE_INFO_EDI_SENT, null );
		if tiTrx &lt;&gt; null and tiTrx.isKindOf( CM_InfoEDISent ) then
			ediInfoSent := tiTrx.CM_InfoEDISent;
			edition := ediInfoSent.edition;
			if invalid then
				ediInfoSent := null;
			endif;
		endif;
	endif;
	
	if ediInfoSent = null then
		str := "No EDI Info Sent transaction(s) found in " &amp; _term.code &amp; " to truncate." &amp; CrLf;
		writeOutputToMyForm(str);
		return;
	endif;	
	on Exception do null;
	
	//get the start date (for our messages to teh user) based on the last edi info processed, or the forst one to be proceesed
	startDate := ediInfoSent.dateTime.Date;
	
	if _endDate &lt;= startDate then
		str := "No 'EDI Info Sent' transaction(s) requiring truncation found in " &amp; _term.code &amp; " before " &amp; _endDate.asStringJMT &amp; CrLf;
		str := str &amp; "Earliest 'EDI Info Sent' transaction available for truncation in " &amp; _term.code &amp; " is on or after " &amp; startDate.cnEcAddDays( 1 ).asStringJMT &amp; CrLf;
		writeOutputToMyForm(str);
		return;
	endif;

	app.isGarbageCollectionProcess := true;
	
	str := "EDI Info Sent transaction(s) truncation initiated..." &amp; CrLf;
	writeOutputToMyForm(str);
	
	str := "Starting with transaction(s) dated " &amp; startDate.asStringJMT &amp; CrLf;
	writeOutputToMyForm(str);
	
	create agent transient;
	create bgpRequest transient;
	bgpRequest.initDatabasePurge(	app.myPassport.myUser, _term, _endDate,
									false, false, false, false, false, false,
									false, false, false, false, false, false, 
									false, false, false, false,
									false, false, false, false,
									false, false, false, false,
									true,	//13 Sep 2021	NDL	TFS 51718
									0,
									false,	// ### TFS 51994 01Oct2021 NAVPW1
									false, //16/09/2022 navmv20 TFS 53403
									false, false, false, false, false, // 13/02/2023 navhl20 #54900[56518]
									false,				//21.7.2023 navhl20 #58158
									false,				//11.08.2025 navhl20 #35650
									false				//navra1 - MTN-35875- 5th Sep 2025-2
									);
									
	agent.purgeDatabase( bgpRequest, _term, _endDate );
	
	//find the most recent truncated EDI Info Sent object
	ediInfoSent := _term.getConfig( LatestTruncatedEDIinfo ).CM_InfoEDISent;
	
	on Exception do app.handleDeletedObject( exception, ediInfoSent, invalid );
	if ediInfoSent &lt;&gt; null then
		edition := ediInfoSent.edition;
		if invalid then
			ediInfoSent := null;
		endif;
	endif;
	if ediInfoSent = null then
		tiTrx := _term.allTITransactionsByTypeDate.getAtKeyGeq( TRANS_TYPE_INFO_EDI_SENT, null );
		if tiTrx &lt;&gt; null and tiTrx.isKindOf( CM_InfoEDISent ) then
			ediInfoSent := tiTrx.CM_InfoEDISent;
			edition := ediInfoSent.edition;
			if invalid then
				ediInfoSent := null;
			endif;
		endif;
	endif;
	
	if ediInfoSent = null then
		str := "'Last' truncated EDI Info Sent transaction unknown." &amp; CrLf;
		writeOutputToMyForm(str);
	else
		iter := _term.allTITransactionsByTypeDate.createIterator;
		iter.startAtObject( ediInfoSent );
		while iter.next( tiTrx ) do
			if tiTrx = ediInfoSent then
				continue;
			endif;
			if tiTrx.isKindOf( CM_InfoEDISent ) then
				nextEdiInfoSent := tiTrx.CM_InfoEDISent;
			endif;
			break;
		endwhile;
		delete iter;
		lastProcessedDate := ediInfoSent.dateTime.Date;
		str := "Truncation of 'EDI Info Sent' transactions in " &amp; _term.code &amp; " is now completed for transactions prior to " &amp; lastProcessedDate.asStringJMT &amp; CrLf;
		writeOutputToMyForm(str);
		if nextEdiInfoSent = null or nextEdiInfoSent.dateTime.date &gt; _endDate then
			str := "No untruncated 'EDI Info Sent' transactions left in " &amp; _term.code &amp; " to process prior to " &amp; _endDate.asStringJMT &amp; CrLf;
			writeOutputToMyForm(str);
		elseif nextEdiInfoSent.dateTime.date &lt; _endDate then
			str := "Additional 'EDI Info Sent' transactions in " &amp; _term.code &amp; " are available to process between " &amp; lastProcessedDate.asStringJMT &amp; " and " &amp; _endDate.asStringJMT &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
	endif;

epilog

	app.isGarbageCollectionProcess := false;
	delete agent;
	delete iter;
	delete bgpRequest;

end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_endDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="doUpdateClassInstancesBulk" id="65a7eab9-20ec-4356-a6d3-28d71b50f851">
        <source>doUpdateClassInstancesBulk();

/*

Purpose:			written for C3 to update every instance of a classes objectEdition so it will be output to DSS again. Date range based on created date

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2014	cnwrd1	Initial creation

*/

vars

	param, param2 , param3, param4: String;
	update : Boolean;
	list : Boolean;
	count : Boolean;
	info : String;
	klass : String;
	startDate: Date;
	endDate: Date;
begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		elseif self.parameterArray.size = 4 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks;			
			param3 := self.parameterArray[3].trimBlanks.toUpper;		
			param4 := self.parameterArray[4].trimBlanks.toUpper;		
		endif;
		
		startDate.setDate(0,0,0);
		if param3.length = 8 then
			startDate.setDate(param3[1:2].Integer, param3[3:2].Integer, param3[5:4].Integer);
		endif;
		
		endDate.setDate(0,0,0);
		if param4.length = 8 then
			endDate.setDate(param4[1:2].Integer, param4[3:2].Integer, param4[5:4].Integer);
		endif;		
		
		if param2 &lt;&gt; null then
			klass := param2;
		endif;

		if param = "UPDATE" then
			update := true;
		elseif param = "LIST" then
			list := true;
		elseif param = "COUNT" then
			count := true;
		endif;
 	endif;
	
	if not startDate.isValid or (not update and not list and not count) then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This special method will update the edition of all the objects of the entered class (and sublcasses) created on or after the first date entered up to the second date entered." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This will result the objects being re-extracted by Data Extract." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "COUNT CLASSNAME &lt;DDMMYYYY&gt; &lt;DDMMYYYY&gt; - Find the objects and advise how many there are that could be updated." &amp; CrLf;
		info := info &amp; "LIST CLASSNAME &lt;DDMMYYYY&gt; &lt;DDMMYYYY&gt;- Find and list ALL  opbjects in date range." &amp; CrLf;
		info := info &amp; "UPDATE CLASSNAME &lt;DDMMYYYY&gt; &lt;DDMMYYYY&gt; - Find ALL objects in date range, and update the edition." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doForceDataExtractWorkByClass( update,klass, list, count, startDate,endDate );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateGCHolds" id="576e238c-2071-4d79-ab49-68ca68ff184f">
        <source>doUpdateGCHolds();

vars

	param : String;
	param2 : String;
	param3 : String;
	update : Boolean;
	info : String;
	user : CM_User;
	iter : Iterator;
	userTerminal : CM_UserTerminal;
	term : CM_Terminal;
	voyage: CM_Voyage;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		elseif self.parameterArray.size = 2 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;			
		elseif self.parameterArray.size = 3 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;
			param3 := self.parameterArray[3].trimBlanks.toUpper;
		endif;
			
		if param = "UPDATE" then
			update := true;
		endif;
		if param2 &lt;&gt; null then
			user := app.getMyUser;
			if user = null then
				info := info &amp; "" &amp; CrLf;
				info := info &amp; "Unable to establish User!!." &amp; CrLf;
				info := info &amp; "" &amp; CrLf;
				self.writeOutputToMyForm(info);
				return;
			endif;
			iter := user.allUserTerminals.createIterator;
			while iter.next( userTerminal )do
				if userTerminal.myTerminal.code.toUpper = param2 then
					term := userTerminal.myTerminal;
					break;
				endif;
			endwhile;
			delete iter;
		endif;
		if param3 &lt;&gt; null and term &lt;&gt; null then
			voyage	:= term.allVoyagesByCode.getAtKeyGeq(param3, null);
			if voyage &lt;&gt; null and voyage.code &lt;&gt; param3  then
				voyage := null;
			endif;

			if voyage = null or not voyage.isGeneralCargoVoyage then
				info := info &amp; "" &amp; CrLf;
				info := info &amp; "Voyage does not have any holds." &amp; CrLf;
				info := info &amp; "" &amp; CrLf;
				self.writeOutputToMyForm(info);
				return;
			endif;
		endif;				
 	endif;
	
	if (not update) or term = null or voyage = null then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is used to update the holds on a voyage to Upper Tween Lower" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "All existing holds are replaced " &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE &lt;Terminal Id&gt; &lt;Voyage&gt;" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doUpdateGCHoldsWork(term, voyage);

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateGCHoldsWork" id="6c944aad-0a02-4e59-963c-7c6bcc34ca9f">
        <source>doUpdateGCHoldsWork(_term: CM_Terminal; _voyage: CM_Voyage) protected;
//
// Changed On	By			Reason
// ----------	---------	---------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
vars
	str: String;
	proxyVoyage : CM_Voyage;
	structure: CM_GeneralCargoVoyageStructure;
	gcLocation : CM_GeneralCargoController;
	hold: Integer;
begin

	str := "Processing in UPDATE mode :" &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	structure := _voyage.myGeneralCargoVoyage;
	
	beginTransaction;
	
		structure.allLocationsByHatchPlace.purge;
		foreach hold in 1 to structure.numberOfHatches do
			create gcLocation persistent;
			//gcLocation.setInternal(structure, hold, PlaceUpper, null);			// PAR #36766
			gcLocation.setInternal(structure, hold, PlaceUpper, null, true, null, null, 0, 1);	// PAR #36766
			create gcLocation persistent;
			//gcLocation.setInternal(structure, hold, PlaceTween, null);			// PAR #36766
			gcLocation.setInternal(structure, hold, PlaceTween, null, false, null, null, 0, 1);	// PAR #36766
			create gcLocation persistent;
			//gcLocation.setInternal(structure, hold, PlaceLower, null);			// PAR #36766
			gcLocation.setInternal(structure, hold, PlaceLower, null, false, null, null, 0, 1);	// PAR #36766
		endforeach;
	
	commitTransaction;
	
	str := CrLf &amp; "Voyage " &amp; _voyage.code &amp; " holds updated to Upper/Tween/Lower";
	writeOutputToMyForm(str);
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="doUpdatePaymentStatusCR" id="0e379dc0-5d2f-4e91-b03f-b8702b339c8e">
        <source>doUpdatePaymentStatusCR();
/*
Purpose:	TFS 42401		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars

	paramString : String;
	paramsOK : Boolean;
	str : String;
	maxSize : Integer;
	
	prefix : String;
	zeroFillLength : Integer;
	start : Integer;
	finish : Integer;
	
	info : String;
	term : CM_Terminal;	
	wo : CM_WorkOrder;
	cr : CM_CashReceipt;
	found : Boolean;
begin

	if self.parameterArray.size = 3 then
		paramsOK := true;
		paramString := self.parameterArray[1].toUpper;
		term := app.myRoot.allTerminals.getAtKey(paramString);
		if term = null then
			paramsOK := false;
			str := "PARAMETER ERROR - first parameter '" &amp; paramString &amp; "' does not resolve to a recognised terminal!" &amp; CrLf;
			writeOutputToMyForm(str);
			return;
		endif;
		
		paramString := self.parameterArray[2].toUpper.trimBlanks;
		wo := term.allWorkOrders.getAtKey(paramString);
		if wo = null then
			paramsOK := false;
			str := "PARAMETER ERROR - second parameter '" &amp; paramString &amp; "' does not resolve to a recognised work order!" &amp; CrLf;
			writeOutputToMyForm(str);
			return;
		endif;
		
		paramString := self.parameterArray[3].toUpper.trimBlanks;
		foreach cr in wo.allCashReceipts	discreteLock do
			if cr.externalInvoiceNumber = paramString then
				found := true;
				break;
			endif;
		endforeach;
		
		if not found then
			paramsOK := false;
			str := "PARAMETER ERROR - third parameter '" &amp; paramString &amp; "' does not resolve to a recognised cash receipt (Estimate)!" &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
		if cr.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED or
			cr.paymentStatus &lt;&gt; CM_CashReceipt.API_RECEIPT_FINAL //11/07/2024	navkc1 CR 64837 Task 64851
			then
			paramsOK := false;
			str := "PARAMETER ERROR - third parameter '" &amp; paramString &amp; "' has to have a current payment status of APPROVED" &amp; CrLf;
			writeOutputToMyForm(str);
		
		endif;

		if not paramsOK then
			str := CrLf &amp; CrLf;
			writeOutputToMyForm(str);
			return;
		endif;
		
	else
		paramsOK := false;
		str := "PARAMETER ERROR - 3 space delimited parameters required. " &amp; self.parameterArray.size.String &amp; " found" &amp; CrLf  &amp; CrLf;
		writeOutputToMyForm(str);
 	endif;
	
	if paramsOK then
		str := "Attempting to process using the following parameters:" &amp; CrLf;
		writeOutputToMyForm(str);
		str := "Terminal - " &amp; term.code &amp; CrLf;
		writeOutputToMyForm(str);
		str := "Work Order - " &amp; wo.id &amp; CrLf;
		writeOutputToMyForm(str);
		str := "Cash Receipt - " &amp; cr.externalInvoiceNumber &amp; CrLf;
		writeOutputToMyForm(str);
			
		if not app.msgBox("Will attempt to run with the listed parameters." &amp; CrLf &amp; "Do you want to continue?","Continue?",MsgBox_Yes_No) = MsgBox_Return_Yes then
			str := "User aborted the run after seeing the parameters ";
			writeOutputToMyForm(str);
			return;
		endif;
	else
	
		info := "No recognised parameter(s) entered, or errors encountered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to TFS 42401 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides a way to update the payment status of a cash receipt to 'manually cancelled'." &amp; CrLf;
		info := info &amp; "The specified cash receipt must have a current payment statu sof 'Approved'." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "ALL 3 Parameters must be provided, they must be entered in the correct order and they must be space delimited:" &amp; CrLf;
		info := info &amp; "The parameters are &lt;Terminal Code&gt; &lt;Work Order Id&gt; &lt;Cash Recipt Estimation Id&gt;" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "&lt;Terminal code&gt; - The 'code' value of the terminal that you want to create the data for." &amp; CrLf;
		info := info &amp; "                 				I.e. " &amp; CM_Terminal.firstInstance.code &amp; CrLf;
		info := info &amp; "&lt;Work Order Id&gt; - The code shown in the 'Work Order #' column of the work order enquiry." &amp; CrLf;		
		info := info &amp; "&lt;Cash Receipt Estimation Id&gt; - The 'Estimation Id' value shown in the macro info of the work order enquiry." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Examples: " &amp; CrLf;
		info := info &amp; "1013 20181200010-A002 1161812000099 " &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		
		return;
		
	endif;

	self.doUpdatePaymentStatusCRWork(	term,wo,cr );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdatePaymentStatusCRWork" id="13de2bb5-6bd0-4b30-8cd4-77cbf5a9dbe0">
        <source>doUpdatePaymentStatusCRWork(_term : CM_Terminal; _workorder : CM_WorkOrder; _cashReceipt : CM_CashReceipt) protected;
/*
Purpose:	TFS 42401		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars
	pxyCashRec : CM_CashReceipt;
	theReturn : Integer;
	err : CM_Error;
	str : String;
begin

	pxyCashRec := app.createUpdateProxy(_cashReceipt).CM_CashReceipt;
	app.myTrxUA.trxUpdateCashRecPaymentStatus(pxyCashRec ,6,app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		str := app.myPassport.getAllErrorsAndWarningsAsStr() &amp; CrLf &amp; CrLf;
	else
		str := "Succesful update of Cash Receipt";
	endif;

	writeOutputToMyForm(str);
epilog
	delete pxyCashRec;


end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_workorder" type="CM_WorkOrder"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="doUpgradeVolumeTotalVolume" id="6c63cdd0-2ada-49a5-99e1-91e0cfe16998">
        <source>doUpgradeVolumeTotalVolume();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2011	cnwndl1	Initial creation	Par 28855

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	count : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
			elseif param = "LIST" then
				list := true;
			elseif param = "COUNT" then
				count := true;
			endif;
		endif;
 	endif;
	
	if not update and not list and not count then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Pars 28836 and 28855 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "In 7.9.2, JMT standardised the use of the various 'Volume' attributes that it uses. (This occurred as part of Par 27868)." &amp; CrLf;
		info := info &amp; "While all newly created cargo conforms to the new 'Volume' definitions, it is possible that some of the pre-existing" &amp; CrLf;
		info := info &amp; "data may incorrectly show a zero 'Total volume', even though its volume is known.  This is because these items have" &amp; CrLf;
		info := info &amp; "had their volume recorded in the field now used to show the child cargo volume." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This special method identifies cargo that has no recorded 'Total Volume', does not have child cargo, BUT does have " &amp; CrLf;
		info := info &amp; "a value in the Cargo volume field. (Cargo volume may not be visible to users dependant on Cargo Type)" &amp; CrLf;
		info := info &amp; "The method then performs an action against this cargo based on the parameter entered." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If this method is run in 'COUNT' mode this method will simply find the affected cargo and advise of the number of items found." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If this method is run in 'LIST' mode the method will find the affected cargo and list the items it would update." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If this method is run in 'UPDATE' mode this method will find the affected cargo and update the 'Total Volume' value based on the" &amp; CrLf;
		info := info &amp; "'Cargo volume' value." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "COUNT - Find the affected cargo and advise how many there are that could be fixed." &amp; CrLf;
		info := info &amp; "LIST - Find and list ALL affected cargo." &amp; CrLf;
		info := info &amp; "UPDATE - Find ALL affected cargo, and update the 'Total Volume' value." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'COUNT', 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doUpgradeVolumeTotalVolumeWork( update, list, count );
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpgradeVolumeTotalVolumeWork" id="602ad325-48a6-4bcc-874b-ab562fe0dcbc">
        <source>doUpgradeVolumeTotalVolumeWork( _update : Boolean; _list : Boolean; _count : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2011	cnwndl1	Initial creation	Par 28855

*/

vars

	allTis : ObjectArray;
	tisToProcess : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	size : Integer;
	str : String;
	count : Integer;
	volume: Decimal[16,4];

begin

	if _count then
		str := "Processing in COUNT mode :" &amp; CrLf;
	elseif _list then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create allTis transient;
	create tisToProcess transient;
	
	str := "Collecting data..." &amp; CrLf;
	writeOutputToMyForm(str);

	CM_TrackedItem.allInstances(allTis,0,true);
	
	str := "Checking " &amp; allTis.size.String &amp; " Cargo items..." &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	iter := allTis.createIterator;
	while iter.next( ti ) do
		if ti.totalVolume &gt; 0 then
			continue;
		endif;
		if ti.volume = 0 then
			continue;
		endif;
		if not ti.allChildren.isEmpty then
			continue;
		endif;
		//  OK we have a ti that is not a parent with totalVolume = zero, but volume has a value.
		tisToProcess.add( ti );
	endwhile;
	delete iter;
	
	if tisToProcess.isEmpty then
		str := "No Cargo items need their 'TotalVolume' value updated." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
	else
		size := tisToProcess.size;
		str := size.String &amp; " Cargo items have 'Total volume' value of zero, but have another 'Cargo volume' value recorded." &amp; CrLf;
		writeOutputToMyForm(str);
	endif;
	
	if _count then
		// nothing more
	elseif _list then
		writeOutputToMyForm(CrLf);
		foreach ti in tisToProcess do
			str := ti.id &amp; " shows Total volume of zero but has a Cargo volume of '" &amp; ti.volume.String &amp; "'";
			writeOutputToMyForm(str &amp; CrLf);
		endforeach;
	
	elseif _update then
		writeOutputToMyForm(CrLf);
			
		foreach ti in tisToProcess do		
			beginTransaction;
			volume := ti.volume;
			if volume &lt; 0 then
				volume := 0;
				ti.setPropertyValue( "volume", volume );
			endif;
			ti.setPropertyValue( "totalVolume", volume);
			commitTransaction;
			
			count := count + 1;
			if count mod 1000 = 0 then
				str := count.String &amp; " items processed, continuing...";
				writeOutputToMyForm(str &amp; CrLf);
			endif;
		
		endforeach;
		
		writeOutputToMyForm(CrLf);
		str := count.String &amp; " Cargo items updated.";
		writeOutputToMyForm(str &amp; CrLf);
		
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog

	delete tisToProcess;
	delete allTis;
	delete iter;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_list" type="Boolean"/>
        <Parameter name="_count" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doVesselDataExtractLoad" id="bfe0bf70-51e0-444a-acf7-f3805c76be73">
        <source>doVesselDataExtractLoad();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/04/2017	cnwdap1		Initial creation TFS 3930 Automate Extract and Load of LNX Vessel data
//
vars
	paramString : String;
	paramsOK : Boolean;
	action : String;
	str : String;
	directoryName : String;
	logName : String;
	info : String;
	folder : FileFolder;
	
begin
	if self.parameterArray.size &gt; 1 then
		paramsOK := true;
		paramString := self.parameterArray[1].trimBlanks;
		action := paramString.toUpper();
		if action &lt;&gt; "EXTRACT" and action &lt;&gt; "LOAD" then
			paramsOK := false;
			str := "PARAMETER ERROR - first parameter '" &amp; paramString &amp; "' must be either EXTRACT or LOAD!" &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
		if self.parameterArray.size &gt; 1 then
			paramString := self.parameterArray[2];
			directoryName := paramString;
			if directoryName[directoryName.length:1] &lt;&gt; "\" then
				directoryName := directoryName &amp; "\";
				create folder transient;
				//folder.usePresentationFileSystem := false;
				folder.fileName := directoryName;
				if not folder.isValidPathName(directoryName) then
					paramsOK := false;
					str := "PARAMETER ERROR - directory name " &amp; directoryName &amp; " is not available on the server";
					self.writeOutputToMyForm(str);
				endif;
			endif;
		endif;

		if not paramsOK then
			str := CrLf &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
	else
		paramsOK := false;
		if self.parameterArray.size &gt; 0 then
			str := "PARAMETER ERROR - must be EXTRACT or LOAD, and then directory / folder name. " &amp; CrLf &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
 	endif;
	
	if paramsOK then
		str := "About to " &amp; action &amp; " all vessel definitions ";
		if action = "EXTRACT" then
			str := str &amp; "to directory / folder " &amp; directoryName;
		elseif action = "LOAD" then
			str := str &amp; "from directory / folder " &amp; directoryName;
		endif;
		if directoryName &lt;&gt; null then
			if action = "EXTRACT" then
				logName	:= directoryName &amp; 'vesselExtractErrors.log';
			elseif action = "LOAD" then
				logName	:= directoryName &amp; 'vesselLoadErrors.log';
			endif;
			str := "The results of the load will be written to log file " &amp; logName;
			writeOutputToMyForm(str &amp; CrLf);
		endif;
	
		str := CrLf;
		writeOutputToMyForm(str);
		
		if not app.msgBox(action &amp; CrLf &amp; "Do you want to continue?","Continue?", MsgBox_Yes_No) = MsgBox_Return_Yes then
			str := "User aborted the run after seeing the options.";
			writeOutputToMyForm(str);
			return;
		endif;
	else
	
		info := "No recognised parameters entered." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides a way to extract all vessel data from JMT, and then load it back " &amp; CrLf;
		info := info &amp; "into a different copy of JMT, which allows copying vessel data from UAT to production, for example." &amp; CrLf;
		info := info &amp; "The extract creates individual XML files for each vessel in the system, and the load takes these" &amp; CrLf;
		info := info &amp; "individual files and loads them" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "For an extract of all vessels from the system, the parameters are: " &amp; CrLf;
		info := info &amp; "	EXTRACT &lt;directory/folder name&gt;" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "For a load of all vessels to the system, the parameters are:" &amp; CrLf;
		info := info &amp; "	LOAD &lt;directory/folder name&gt;" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "&lt;directory/folder name&gt; - The name of the folder on your local PC to which the data is to be extracted" &amp; CrLf;
		info := info &amp; "	or from which the data is to be loaded." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "For an extract, errors are written to an error log named &lt;directory name&gt;\vesselExtractErrors.log" &amp; CrLf;
		info := info &amp; "For a load, errors are written to an error log named &lt;directory name&gt;\vesselLoadErrors.log" &amp; CrLf;
	
		self.writeOutputToMyForm(info);
		
		return;
		
	endif;

	self.doVesselDataExtractLoadWork(action, directoryName, logName);

epilog
	delete folder;
end;</source>
    </JadeMethod>
    <JadeMethod name="doVesselDataExtractLoadWork" id="1fe808e2-1430-4535-80cd-4d904d1c9cbe">
        <source>doVesselDataExtractLoadWork(_action : String; _dirName : String; _logName : String) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/04/2017	cnwdap1		Initial creation TFS 3930 LNX Bulk Vessel Extract and Load
//
vars
	all, count : Integer;
	agent : CM_ExtractLoadAgent;
	vessel : CM_Vessel;
	str : String;
	error : String;
	logFile : File;
	folder : FileFolder;
	fileNode : FileNode;
	xmlFile : File;
	newVessel : CM_Vessel;
	vesselCode : String;
	nullOperator : CM_Operator;
	
begin
	create agent transient;
	create logFile transient;
	//logFile.usePresentationFileSystem := false;
	logFile.openOutput(_logName);
	if not logFile.isAvailable then
		error := "Could not create log file " &amp; _logName &amp; " on the server - terminating";
		return;
	endif;
	
	// extract
	if _action = "EXTRACT" then
		all := app.myRoot.allVesselsByName.size;
		str := " " &amp; CrLf &amp; all.String &amp; " Vessels to Extract" &amp; CrLf;
		self.writeOutputToMyForm(str);
		foreach vessel in app.myRoot.allVesselsByName discreteLock do
			error := agent.extractVesselData(vessel, _dirName);
			count := count + 1;
			if count mod 20 = 0 then
				self.writeOutputToMyForm(CrLf);
				self.writeOutputToMyForm(app.actualTimeServer.asStringJMT &amp; Tab &amp; count.String &amp; " Vessels of " &amp; all.String &amp; " extracted");
			endif;
			if error &lt;&gt; null then
				logFile.writeLine(error);
				self.writeOutputToMyForm(CrLf);
				self.writeOutputToMyForm("Extract for Vessel " &amp; vessel.name &amp; " failed: " &amp; error);
			endif;
		endforeach;
		
	// load
	elseif _action = "LOAD" then
		// go through all files in the supplied directory and load the vessels
		create folder transient;
		//folder.usePresentationFileSystem := false;
		folder.fileName := _dirName;
		if not folder.isAvailable then
			error := "Could not find folder " &amp; _dirName &amp; " on the server - LOAD terminated";
			return;
		endif;
		
		nullOperator := app.myRoot.allOperators[NULL_OPERATOR_CODE];
		all := folder.files.size - 1;		// take one off for the log file
		self.writeOutputToMyForm(app.actualTimeServer.asStringJMT &amp; Tab &amp; "Loading " &amp; all.String &amp; " vessel definitions" &amp; CrLf);
		self.writeOutputToMyForm("Loading " &amp; all.String &amp; " vessel definitions");
		foreach fileNode in folder.files do
			if not fileNode.isKindOf(File) or fileNode.fileName = _logName then
				continue;
			endif;
			
			xmlFile := fileNode.File;
			error := null;
			vesselCode := fileNode.name[1:fileNode.name.length-4];
			newVessel := agent.loadVesselData(xmlFile, vesselCode, nullOperator, error);
			count := count + 1;
			if newVessel = null then
				self.writeOutputToMyForm(error);
				logFile.writeLine(error);
				continue;
			endif;
			
			if count mod 20 = 0 then
				self.writeOutputToMyForm(CrLf);
				self.writeOutputToMyForm(app.actualTimeServer.asStringJMT &amp; Tab &amp; "Processed " &amp; count.String &amp; " vessels of " &amp; all.String &amp; CrLf);
			endif;
		endforeach;
	endif;

	self.writeOutputToMyForm(str);

epilog
	if error &lt;&gt; null then
		self.writeOutputToMyForm(error);
		self.writeOutputToMyForm(CrLf);
	endif;
	delete agent;
	if logFile &lt;&gt; null then
		logFile.close;
	endif;
	delete logFile;
	delete folder;
end;</source>
        <access>protected</access>
        <Parameter name="_action" type="String"/>
        <Parameter name="_dirName" type="String"/>
        <Parameter name="_logName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doWellcarConversion" id="7865e0f0-59fb-406c-aef0-8ac4adf8faf8">
        <source>doWellcarConversion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 35346 / SFW CCMS 1408 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "RAIL wagon conversion. Flat car to Well car" &amp; CrLf;
		info := info &amp; "In 8.3.2, special code was added to allow specifically configured Flat car wagons, to mimic Well car wagons" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This script provides a mechanism to migrate 8.3.2 Flat car wagons that have a stack height of '2' and are declared with a number" &amp; CrLf;
		info := info &amp; "of locations exactly divisible by 4, into Well cars." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The script will identify the prospective wagon classes and process those that:" &amp; CrLf;
		info := info &amp; "- are declared as a 'Flatcar', with a stack height of '2' and a number of locations equal to 4, 8, 12, 16 or 20." &amp; CrLf;
		info := info &amp; "- are currently marked as available." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Having identified the prospects, the 'code' of the existing Wagon Class will be modified, so that the first 3 characters are '832'," &amp; CrLf;
		info := info &amp; "trailing characters will be truncated if required, and they will be marked as unavailable." &amp; CrLf;
		info := info &amp; "A new 'Wellcar' version of the wagon class will then be created." &amp; CrLf;
		info := info &amp; "After the conversion is complete. Wagon visits for these wagons will be created as proper Wellcar objects." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "PLEASE NOTE:" &amp; CrLf;
		info := info &amp; "1/. The existing wagon visits will NOT be converted, and if viewed  in the Rail forms after the conversion, will appear as Flatcars." &amp; CrLf;
		info := info &amp; "    Given Flatcars do not permit some of the stacking rules of Well cars, this could cause unpredictable behaviour." &amp; CrLf;
		info := info &amp; "2/. It is recommended that this coversion be done at a time when there are no wagons on-site (as far as JMT is concerned)." &amp; CrLf;
		info := info &amp; "3/. It is recommended that any 'Pre-noted' wagons are deleted from the 'Null Train' before the conversion and re-created manually" &amp; CrLf;
		info := info &amp; "    after the conversion has completed." &amp; CrLf;
		info := info &amp; "4/. The update mode process is irreversible, it is recommended that a backup of the system be taken before this task is run." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list those Wagon Classes that would be actioned, but NOT update anything." &amp; CrLf;
		info := info &amp; "UPDATE - will perform the update as specified above" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doWellcarConversionWork( update );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWellcarConversionWork" id="83907889-635f-4942-bf66-d176ad37dfb3">
        <source>doWellcarConversionWork( _update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2014	cnwndl1	Initial creation

*/

vars

	wcsArray : ObjectArray;
	wcsToProcess : CM_WagonClassByCodeDict;
	iter : Iterator;
	wc : CM_WagonClass;
	size : Integer;
	str : String;
	count : Integer;
	oldCode : String;
	erroMess : String;

begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create wcsToProcess transient;
	create wcsArray transient;
	
	str := "Collecting data..." &amp; CrLf;
	writeOutputToMyForm(str);

	CM_WagonClass.allInstances(wcsArray,0,true);
	
	str := "Checking " &amp; wcsArray.size.String &amp; " Wagon Class item(s)..." &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	iter := wcsArray.createIterator;
	while iter.next( wc ) do
		if wc.isNotAvailableForEntry then
			continue;
		endif;
		if wc.wagonType &lt;&gt; CM_WagonClass.Wagon_Flatcar then
			continue;
		endif;
		if wc.maxNumInStack &lt; 2 then
			continue;
		endif;
		if not wc.locationIds.size.isOneOf(4,8,12,16,20) then
			continue;
		endif;
		//  OK we have a ti that is not a parent with totalVolume = zero, but volume has a value.
		wcsToProcess.add( wc );
	endwhile;
	delete iter;
	
	if wcsToProcess.isEmpty then
		str := "No Wagon Class items were selected." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
	else
		size := wcsToProcess.size;
		str := size.String &amp; " Wagon Class item(s) have been selected." &amp; CrLf;
		writeOutputToMyForm(str);
	endif;
	
	if not _update then
		writeOutputToMyForm(CrLf);
		foreach wc in wcsToProcess do
			str := wc.code &amp; " would be converted from an 8.3.2 style Flatcar mimicing a Wellcar, to a real Wellcar type Wagon Class.";
			writeOutputToMyForm(str &amp; CrLf);
		endforeach;
	
	elseif _update then
		writeOutputToMyForm(CrLf);
			
		foreach wc in wcsToProcess do		
			oldCode := wc.code;
			if wc.convertToWellcar(erroMess) then
				count := count + 1;
				str := oldCode &amp; " has been created as a Wellcar, and the old version renamed '" &amp; wc.code &amp; "' and made not available.";
				writeOutputToMyForm(str &amp; CrLf);
			else
				str := oldCode &amp; " conversion failed with error = '" &amp; erroMess &amp; "'";
				writeOutputToMyForm(str &amp; CrLf);
			endif;
	
		endforeach;
		
		writeOutputToMyForm(CrLf);
		str := count.String &amp; " Wagon Class item(s) updated.";
		writeOutputToMyForm(str &amp; CrLf);
		
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog

	delete wcsToProcess;
	delete wcsArray;
	delete iter;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="eraseExceptionHandler" id="92e44dfd-5946-4e75-a87e-f7db9db1f17b">
        <source>eraseExceptionHandler(_exception : Exception) : Integer protected ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2019	jlgdi1	TFS# 43985 Initial creation

*/

vars
    msg : String;
	stackDump: CnStackDump;
	
begin
	msg := "Error: " &amp; app.getErrorString(_exception.errorCode) &amp; ". Continuing with next object";

	if msg &lt;&gt; "" then
		app.writeLog(msg,0); 
	endif;
	
	create stackDump transient;
	stackDump.dumpStack(_exception);
	
	app.myPassport.clearErrorsWarnings();
	return Ex_Resume_Next;
	
epilog
	delete stackDump;
end;</source>
        <access>protected</access>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="writeBatchOutput" id="0fe3212b-d78f-46d6-8f27-5650786c2153">
