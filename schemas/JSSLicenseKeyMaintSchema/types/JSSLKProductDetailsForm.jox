    <JadeMethod name="browseForLogo" id="469e6ff5-4f2b-45fc-ada4-ec5c3063c873">
        <source>browseForLogo() protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Browses for an image file on disk.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFile		: File;
	logoImage	: Binary;
	fileFilter	: String;
	
begin
	create theFile transient;
	
	fileFilter	:=	"Bitmap (*.bmp)|*.bmp" &amp;
					"|Icon (*.ico)|*.ico" &amp;
					"|Jpeg (*.jpg)|*.jpg" &amp;
					"|Portable Network Graphics (*.png)|*.png" &amp;
					"|TIFF (*.tif)|*.tif";
	
	if theFile.browseForOpen(true, false, fileFilter) then
		theFile.kind	:=	File.Kind_Binary;
		theFile.openInput(theFile.fileName);
		logoImage		:=	theFile.readBinary(theFile.fileLength());
		picLogo.picture	:=	logoImage;
	endif;
epilog
	delete theFile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="bc0b5082-d017-40e4-9c17-ffc8bf6e5684">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponentForm	: JSSLKComponentDetailsForm;
	
begin
	app.mousePointer	:=	Busy;
	
	create theComponentForm;
	theComponentForm.setComponent(null, self.aMyProduct);
	
	theComponentForm.showModal();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="3db50e12-9046-4f78-8cd5-db304c6518c7">
