    <JadeMethod name="abConvertInvTypeDescriptions" id="0cab4735-237b-4455-9d56-40b94fb959a9">
        <source>abConvertInvTypeDescriptions();
/*
Purpose:			
Date		Who		Reason
19 November 2012	cnwab1	Initial creation
*/

vars
	newDesc : String;
	aCT : CM_CalculationType;
begin
	app.initialize();
		
	beginTransaction;
	foreach aCT in app.myRoot.allCalculationTypesByCode do
		// CCMS QNS 2178
		if aCT.calculationType = INV_CALC_TYPE_VESSEL_TON or
		   aCT.calculationType = INV_CALC_TYPE_VESSEL_TON_QTY1 or
		   aCT.calculationType = INV_CALC_TYPE_VESSEL_TON_RANGE then
			aCT.setPropertyValue("theCalcTypeUnit", INV_CALC_TYPE_UNIT_GRT);
write method.qualifiedName &amp; " Converting Invoice Calculation Type " &amp; aCT.calculationType.String  &amp; " Setting Block Unit to Vessel Dimension GRT";
		endif;

		if not aCT.isStandardCargo() then
			continue;
		endif;
		
		newDesc := app.getInvoiceCalcTypeLabel(aCT.calculationType, true);
		
		if CM_CalculationType::description.name = newDesc then
			continue;
		endif;
		
		aCT.setPropertyValue(CM_CalculationType::description.name, newDesc);
		
write method.qualifiedName &amp; " Converting Standard Cargo Invoice Calculation Type " &amp; aCT.calculationType.String  &amp; " Description From " &amp; aCT.description &amp; " to " &amp; newDesc;
	endforeach;
	commitTransaction;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="abCountClasses" id="ceae4cef-2829-4f3c-a6eb-69703442306e">
        <source>abCountClasses();
// COPY of KPDCOUNTCLASSES which I can never remember




// JMT MTN FORM COUNT STATS CLASSES
vars
	cls : Class;
	pt : PrimType;
	total, totalRoot, totalProps, totalMeths, totalPrimMeths, totalForms, totalControls : Integer;
	mdlTotal, mdlRoot, mdlMeths, mdlPrimMeths : Integer;
	i, n, prevCrPos, totalLOC, loop : Integer;
	oa : ObjectArray;
	o : Object;
	m : Method;
	s : String;
	codeLine	: String;

	releaseSchemas : StringArray;
	agent : DEV_ReleaseExtractAgent;
	
begin
	foreach loop in 1 to 2 do
	
		if loop = 1 then
			create agent transient;
			create releaseSchemas transient;
			agent.getReleaseSchemas(releaseSchemas);
			releaseSchemas.add("JMTUnitTest");
		else
			releaseSchemas.clear();
		endif;

		total := 0;
		totalRoot := 0;
		totalForms := 0;
		totalControls := 0;
		mdlTotal := 0;
		mdlRoot := 0;
		mdlMeths := 0;
		mdlPrimMeths := 0;
		totalProps := 0;
		totalMeths := 0;
		totalPrimMeths := 0;
		totalLOC := 0;
		
		delete oa;
		create oa transient;
	
		Class.allInstances(oa, 0, true);
	
		foreach o in oa do : classLoop
			cls := o.Class;
			if cls.isKindOf(ActiveXGuiClass) or cls.inheritsFrom(ActiveXInterface) then
				continue;
			endif;
	
			if not releaseSchemas.isEmpty and not releaseSchemas.includes(cls.schema.name) then
				continue;
			endif;
			
			if cls.schema.name[1:4] = "Jade" or cls.schema.name[1:4] = "Root" then
				continue;
			endif;
	
			total := total + 1;
			if cls.inheritsFrom(Form) then
				totalForms:=totalForms+1;
			endif;
			if cls.inheritsFrom(Control) then
				totalControls:=totalControls+1;
			endif;
			
			if cls.schema.name = "PortSchema" then
				mdlTotal := mdlTotal + 1;
			endif;
			
			totalProps := totalProps + cls.getPropertyValue("properties").PropertyNDict.size;
	
			foreach m in cls.getPropertyValue("methods").MethodNDict do
				totalMeths := totalMeths + 1;
				
				if cls.schema.name = "PortSchema" then
					mdlMeths := mdlMeths + 1;
				endif;
	
				if not m.isKindOf(JadeMethod) then
					continue;
				endif;
	
				s := m.getPropertyValue("source").String.trimBlanks;
				n := s.length;
				i := 1;
				
				while i &lt; n do
					codeLine := s.scanUntil(Cr, i).trimBlanks;
					if codeLine &lt;&gt; null then
						totalLOC := totalLOC + 1;					
					endif;
					if i = 0 then
						break;
					endif;
					i := i + 1;
				endwhile;
			endforeach;  // method in the class
	
			if cls.superschemaType &lt;&gt; null then
				// subschema copy - don't count as a root class
				continue;
			endif;
			
			totalRoot := totalRoot + 1;
	
			if cls.schema.name = "PortSchema" then
				mdlRoot := mdlRoot + 1;
			endif;
			
		endforeach; // Class in the schemas
	
		oa.clear;
	
		PrimType.allInstances(oa, 0, true);
	
		foreach o in oa do
			pt := o.PrimType;
			
			if not releaseSchemas.isEmpty and not releaseSchemas.includes(pt.schema.name) then
				continue;
			endif;
		
			if cls.schema.name[1:4] = "Jade" or cls.schema.name[1:4] = "Root" then
				continue;
			endif;
	
			foreach m in pt.getPropertyValue("methods").MethodNDict do
				totalPrimMeths := totalPrimMeths + 1;
				
				if pt.schema.name = "PortSchema" then
					mdlPrimMeths := mdlPrimMeths + 1;
				endif;
	
				if not m.isKindOf(JadeMethod) then
					continue;
				endif;
	
				s := m.getPropertyValue("source").String.trimBlanks;
				n := s.length;
				i := 1;
				
				while i &lt; n do
					codeLine := s.scanUntil(Cr, i).trimBlanks;
					if codeLine &lt;&gt; null then
						totalLOC := totalLOC + 1;					
					endif;
					if i = 0 then
						break;
					endif;
					i := i + 1;
				endwhile;
	
			endforeach; // Method in the type
	  
		endforeach; // Primitive type in the schemas
	
		write "------------------------------------------------------------------------";
		if loop = 1 then
			write "Released Schemas";
		else
			write "All Schemas";
		endif;
		write " ";
		
		write "Total classes in all schemas = " &amp; total.String;
		write "Total classes in model = " &amp; mdlTotal.String;
		write "Total forms in all schemas = " &amp; totalForms.String;
		write "Total controls in all schemas = " &amp; totalControls.String;
		write "Total classes (excluding subschema copies) in all schemas = " &amp; totalRoot.String;
		write "Total classes (excluding subschema copies) in model = " &amp; mdlRoot.String;
		write "Total properties in classes in all schemas = " &amp; totalProps.String;
		write "Total methods in classes in all schemas = " &amp; totalMeths.String;
		write "Total methods in model classes = " &amp; mdlMeths.String;
		write "Total primitive methods in all schemas = " &amp; totalPrimMeths.String;
		write "Total primitive methods in model schema = " &amp; mdlPrimMeths.String;
		write "Total methods in all schemas = " &amp; (totalMeths + totalPrimMeths).String;
		write "Total lines of code in all schemas = " &amp; totalLOC.String;

	endforeach;

epilog
	delete oa;
	delete agent;
	delete releaseSchemas;

end;</source>
    </JadeMethod>
    <JadeMethod name="abCreateDebugWebConfig" id="38be4b21-cdb7-4805-b9b5-af195f20799e">
        <source>abCreateDebugWebConfig();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2018	jlgab1	Initial creation

*/

vars

	realConfig,
	proxyConfig		: CM_WebSiteConfig;
	
	name,
	envName			: String;
	
	printer			: CM_PrinterDef;
	
	website,
	downloadFileDirPath,
	downloadFileDirURL	: String;
	downloadFileTimeout : Integer;
	helpFileURL			: String;
	
begin
	app.initialize();
	
	website := "localhost/jadevirtualdirectory";

	name := "WebServiceDebug";
	realConfig := app.myRoot.allWebSiteConfigs[name];
	if realConfig &lt;&gt; null then
		proxyConfig := app.createUpdateProxy(realConfig).CM_WebSiteConfig;
		write "Updating " &amp; name &amp; " " &amp; realConfig.String;
	else
		write "Creating new " &amp; name;
		
		create proxyConfig transient;
		proxyConfig.setAsWebService(true);
	endif;
	
	downloadFileDirPath := "C:/temp";
	downloadFileDirURL := "http://" &amp; website &amp; "/htdocs/downloads";
	helpFileURL := downloadFileDirURL &amp; "/help.pdf";
	
	proxyConfig.setForProxy(	null,						// login,	
								null,						// currentReports,
								null,						// password,	
								null,						// download,
								null,						// info,
								null,						// list,
								null,						// output,
								null,						// criteria,
								null,						// headerIn,
								null,						// headerOut,
								null,						// footer,
								null,						// schema,
								name,
								false,						// isSecure,
								"ADMIN",					// userCode,
								null,						// virtualDirectory,
								null,						// machineName,
								null,						// eventReqStopMaintPage,
								null,						// eventReqStopViewPage,
								null,						// eventNotifyMaintPage,
								null,						// eventNotifyViewPage,
								null,						// prenotesMaintPage,
								null,						// prenotesViewPage,
								30,							// timeout,
								printer,					// printer
								null,						// webApplicationName,
								app.myRoot,
								downloadFileDirPath,		// downloadFileDirPath,
								downloadFileDirURL,			// downloadFileDirURL,
								30,							// downloadFileTimeout,
								helpFileURL,
								null,						// helpFileURL
								null,						// defaultLoggingLevel
								null						// responseTimeout
								);
	
	app.myTrxUA.trxUpdateWebSiteConfig(proxyConfig, realConfig, app.myPassport);
	
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorsAsMsgBox(app.myPassport.allErrors, false);
		return;
	endif;

	
epilog
	delete proxyConfig;

end;</source>
    </JadeMethod>
    <JadeMethod name="abInvoiceCalcTypeDescription" id="ec825fd5-0210-4cbc-9f9e-369093a69923">
        <source>abInvoiceCalcTypeDescription();
/*
Purpose:			
Date		Who		Reason
26 September 2012	cnwab1	Initial creation
*/

vars
	 aCT : CM_CalculationType;
begin
	app.initialize();
		
	foreach aCT in app.myRoot.allCalculationTypesByCode do
		if not aCT.isStandardCargo() then
			continue;
		endif;
		aCT.setPropertyValue(CM_CalculationType::description.name, app.getInvoiceCalcTypeLabel(aCT.calculationType, true));
		write aCT.description &amp; " &gt;&gt;&gt;&gt; " &amp; app.getInvoiceCalcTypeLabel(aCT.calculationType, true);
	endforeach;

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="abJMTHotFixReleases" id="6b37beaa-8e8e-4b3b-9c77-e5ba81a891fa">
        <source>abJMTHotFixReleases();
/*
Purpose:			
Date		Who		Reason
12 June 2013	cnwab1	Initial creation
*/

vars
	rootDir, folderDir, patchDir, patchDateDir : FileFolder;
	rootFiles, folderFiles, patchFiles, patchDateFiles : FileNodeArray;
	fileFolder, ff2, patchContents, patchDateContents : FileNode;
	
	releaseStr, hotfixStr, patchStr, parStr : String;
	releaseDT, hotfixDT, patchDT : TimeStamp;
	
	pos : Integer;
	lFile	: File;
begin
     create lFile transient;
	 
 	lFile.usePresentationFileSystem := true; // only if not shared transient;
    lFile.fileName := "C:\Users\cnwab1\Desktop\abJMTHotFixReleases.csv";
    lFile.open;	
	lFile.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
	create rootDir transient;
	create folderDir transient;
	create patchDir transient;
	create patchDateDir transient;
	
	rootDir.fileName := "F:\Releases";
	rootDir.mask := "*.*";
	rootFiles := rootDir.files();
	
	// RELEASES
	foreach fileFolder in rootFiles discreteLock do
		if fileFolder.name.length = 3 and fileFolder.name.isInteger() then
			releaseStr := fileFolder.name;
			releaseDT := fileFolder.createdTime;
			
			//write fileFolder.fileName &amp; " " &amp; fileFolder.createdTime.String;
			
			folderDir.fileName := fileFolder.fileName &amp; "\Hotfixes";
			folderFiles := folderDir.files();
			// HOTFIXES
			foreach ff2 in folderFiles discreteLock do
			
				if ff2.name[1:3] = fileFolder.name then // Each Hotfix Dir
					patchDir.fileName := ff2.fileName;
					patchFiles := patchDir.files();
					
					pos := ff2.name.pos("_",1);
					hotfixStr := ff2.name[pos + 1:end];
					hotfixDT := ff2.createdTime;
					
					// PATCHES
					foreach patchContents in patchFiles discreteLock do
								//	write patchContents.name ;
						if patchContents.name.pos("_", 1) = 4 then
							
							patchDateDir.fileName := patchContents.fileName &amp; "\JadeMaster";
							patchDateFiles := patchDateDir.files();
							foreach patchDateContents in patchDateFiles discreteLock do
									//write patchDateContents.name &amp; " " &amp; patchDateContents.createdTime.String;
							
								if patchDateContents.name = "JMTInstall.txt" then
							
									pos := patchContents.name.pos("_",1);
									patchStr := patchContents.name[1:pos-1];
									parStr := patchContents.name[pos+4:5];
									patchDT := patchDateContents.lastModifiedTime;
									
    	lFile.writeLine( releaseStr &amp; "," &amp;  hotfixStr &amp; ","  &amp; patchStr &amp; "," &amp; parStr &amp; "," &amp; hotfixStr &amp; "," &amp; patchDT.date.String);


								endif;
							endforeach;
							
						endif;
					endforeach;				
				endif;
			endforeach;			
//			return; // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
		 endif;
	endforeach;
	   lFile.close;
    delete lFile;

end;
</source>
    </JadeMethod>
    <JadeMethod name="abListForms" id="c5e73905-6c87-43dd-87b8-ddc3148f9a57">
        <source>abListForms();
// JMT MTN FORM COUNT STATS CLASSES
vars
	oa : ObjectArray;
	o : Object;
	cls: Class;
	f : Form;
begin
	
		
		delete oa;
		create oa transient;
	
		Class.allInstances(oa, 0, true);
	
		foreach o in oa do : classLoop
			cls := o.Class;
			if not cls.inheritsFrom(Form) then
				continue;
			endif;
			
			if cls.schema.superschema.name &lt;&gt; "UiCommonSchema" then
				if cls.schema.name &lt;&gt; "UiCommonSchema"  then
			
					continue;
				endif;
			endif;

			if cls.abstract then
				continue;
			endif;
				
		//	f := o.Form;
			
			write cls.name &amp; "," &amp; cls.schema.name &amp; "," &amp; cls.schema.superschema.name;
		endforeach;

epilog
	delete oa;

end;</source>
    </JadeMethod>
    <JadeMethod name="abLoadCitiesFromCSV" id="6014e32d-8d7f-4b05-938e-41c7edc83056">
        <source>abLoadCitiesFromCSV();
/*
Purpose:			
Date				Who			Reason
JANUARY 2013		CNWAB1		Initial creation
*/


vars
	file 			: File;
	pxyGlcode,
	glcode : CM_GLCode;
	line,
	code,
	desc			: String;
	stIdx, endIdx			: Integer;
	firstLine 		: Boolean;
	cmdFile			: CMDFileOpen;
	fields			: StringArray;
	root : CM_Root;
	term : CM_Terminal;
	bu : CM_Bank;
begin
	
	create cmdFile transient;
	cmdFile.fileMustExist := true;
	cmdFile.filter := "CSV (*.csv)|*.csv|All files (*.*)|*.*";
	cmdFile.initDir := "C:\Users\cnwab1\SkyDrive\Development\TimeZone4B";
	
	if cmdFile.open &lt;&gt; 0 then
		return;
	endif;

	create file transient;
	file.fileName := cmdFile.fileName;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version	
	file.mode := File.Mode_Input;
	if not file.tryOpen then
		app.msgBox("Could not open file " &amp; file.fileName &amp; " - check file name", "File Error", MsgBox_OK_Only);
		return;
	endif;
	
	create fields transient;
	
	firstLine := true;
	while not file.endOfFile do
		line := file.readLine;
		
		line.replaceChar('"'," ");
		if not firstLine then
			fields.clear();
			line.csvToStringArray(fields, ",");
			
			if fields.size &lt;&gt; 2 then
				write "&gt;&gt;&gt;&gt; Invalid number of fields in line: " &amp; line;
				return;
			endif;
			
				
			
			code := fields[1];
			desc := fields[2];
		
			stIdx := code.pos("(",1);
			if stIdx &gt; 0 then
				code := code[1:stIdx - 1];
			endif;
			stIdx := desc.pos("(",1);
			if stIdx &gt; 0 then
				desc := desc[1:stIdx - 1];
			endif;
			
			code := code.convertToTitleCase();
			desc := desc.convertToTitleCase();
			
			write code &amp; "," &amp; desc;
			endif;
		
		firstLine := false;
	endwhile;

epilog
	delete cmdFile;
	delete fields;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="abLoadGLCodeFromCSV" id="b02f0d8d-e12a-413b-8d01-80e18f5f974f">
        <source>abLoadGLCodeFromCSV();
/*
Purpose:			
Date		Who		Reason
20 November 2012	cnwab1	Initial creation
*/


vars
	file 			: File;
	pxyGlcode,
	glcode : CM_GLCode;
	line,
	code,
	desc			: String;
	colour			: Integer;
	firstLine 		: Boolean;
	cmdFile			: CMDFileOpen;
	fields			: StringArray;
	root : CM_Root;
	term : CM_Terminal;
	bu : CM_Bank;
begin
	app.initialize;
	
	root := CM_Root.firstInstance;
	term := root.allTerminals["BISH"];
	bu := term.getBusinessUnit();
	
	create cmdFile transient;
	cmdFile.fileMustExist := true;
	cmdFile.filter := "CSV (*.csv)|*.csv|All files (*.*)|*.*";
	cmdFile.initDir := "c:\temp";
	
	if cmdFile.open &lt;&gt; 0 then
		return;
	endif;

	create file transient;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := cmdFile.fileName;
	file.mode := File.Mode_Input;
	if not file.tryOpen then
		app.msgBox("Could not open file " &amp; file.fileName &amp; " - check file name", "File Error", MsgBox_OK_Only);
		return;
	endif;
	
	create fields transient;
	
	firstLine := true;
	while not file.endOfFile do
		line := file.readLine;
		if not firstLine then
			fields.clear();
			line.csvToStringArray(fields, ",");
			
			if fields.size &lt;&gt; 2 then
				write "&gt;&gt;&gt;&gt; Invalid number of fields in line: " &amp; line;
				return;
			endif;
			
			code := fields[1];
			desc := fields[2];
			
			write code &amp; Tab &amp; desc;
			
			glcode := bu.glCodes[code];
			if glcode = null then
				create pxyGlcode transient;
			else
				pxyGlcode := app.createUpdateProxy(glcode).CM_GLCode;
			endif;
			
			pxyGlcode.setProxy(null, code, desc, false, null);
			
			if glcode = null then
				app.myTrxCA.trxCreateGLCode(pxyGlcode, glcode, app.myPassport);
			else
				app.myTrxUA.trxUpdateGLCode(pxyGlcode, app.myPassport);
			endif;
				
			if app.myPassport.hasErrorsOrWarnings then
				app.myPassport.inspectModal;
				return;
			endif;
			
			delete pxyGlcode;
		endif;
		
		firstLine := false;
	endwhile;

epilog
	delete cmdFile;
	delete fields;
	delete pxyGlcode;
	app.finalize();
	

end;</source>
    </JadeMethod>
    <JadeMethod name="abLoadHHAppUsage" id="c9b26a62-7c4e-49e1-a211-4b61a3e93c14">
        <source>abLoadHHAppUsage();
/*
Purpose:			
Date				Who			Reason
JANUARY 2013		CNWAB1		Initial creation
16/01/2017			cnwmh5		Change 28 to 32
*/


vars
	file 			: File;
	pxyGlcode,
	glcode : CM_GLCode;
	line,
	code,
	desc			: String;
	stIdx, endIdx			: Integer;
	firstLine 		: Boolean;
	cmdFile			: CMDFileOpen;
	fields, hhforms			: StringArray;
	root : CM_Root;
	term : CM_Terminal;
	bu : CM_Bank;
	formnames : String;
begin
	
	formnames := "MOB_HHGateCheckTruck
MOB_HHLanderVoyageQueue
MOB_HHTruckLoaderSelect
MOB_HHDamageForm
MOB_HHDelaySelect
MOB_HHReeferConnectForm
MOB_HHCargoTasksForm
MOB_HHTruckUnloaderSelect
MOB_HHMoveCargo
MOB_HandHeldUnconnectedReefers
MOB_HHReeferReadingsForm
MOB_HHUnpackFromForm
MOB_HHReeferEnquiryForm
MOB_HHCargoEnquiryForm
MOB_HHCargoGrading
MOB_HHPackForm
MOB_HHLanderTrainWagon
MOB_HHShipLanderVoyage
MOB_HHCargoDiscrepancy
MOB_HHRailPlaceIOForm
MOB_HHCargoIdentifier
MOB_HHCargoStopsForm
MOB_HHCargoSplit
MOB_HandHeldSelectVoyageForm
MOB_HHYardRoadLander
MOB_HH_ITSSelector
MOB_HHReleaseStaging
MOB_HHPackRequest
MOB_HHCargoMerge
MOB_HHRoRoShipLoaderVoyage
MOB_HHRaiseAlertForm
MOB_HHCargoGroupAssignMove";

	create hhforms transient;
	
	formnames.getTokensForDelimiter(CrLf,hhforms);
	
	
//	hhforms.inspectModal;
	
	
	create cmdFile transient;
	cmdFile.fileMustExist := true;
	cmdFile.filter := "CSV (*.csv)|*.csv|All files (*.*)|*.*";
	cmdFile.initDir := "F:\TeamStuff\AndrewBishop\MobileApps";
	
	if cmdFile.open &lt;&gt; 0 then
		return;
	endif;

	create file transient;
	file.fileName := cmdFile.fileName;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version	
	file.mode := File.Mode_Input;
	if not file.tryOpen then
		app.msgBox("Could not open file " &amp; file.fileName &amp; " - check file name", "File Error", MsgBox_OK_Only);
		return;
	endif;
	
	create fields transient;
	
	firstLine := true;
	while not file.endOfFile do
		line := file.readLine;
		
		line.replaceChar('"'," ");
		if not firstLine then
			fields.clear();
			line.csvToStringArray(fields, ",");
			
//			if fields.size &lt;&gt; 32 then
//				write "&gt;&gt;&gt;&gt; Invalid number of fields in line: " &amp; line;
//				return;
//			endif;
			
				
			
			code := fields[1];
			desc := fields[2];
		
			if hhforms.indexOf(desc) &gt; 0 then
//			if desc[1:6] = "MOB_HH" then
			
				write line;
			endif;
		endif;
		firstLine := false;
	endwhile;

epilog
	delete cmdFile;
	delete fields;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="abLoadStorageConfig" id="c94447da-aa3b-4999-a1c5-7cecf54da21b">
        <source>abLoadStorageConfig();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2017	jlgab1	Initial creation

*/

vars
	root : CM_Root;
	iter			: Iterator;
	xmlElement		: JadeXMLElement;
	
	// #### JadeXMLNode
	xmlNodeStorageConfig, xmlNode, xmlCriteriaNode, xmlFutureStorageObjectNode, xmlNodeStorageTrig, xmlNodeStorageTrigObj,xmlNodeCriteria,xmlNodeCriteriaObj,
	xmlQuantityMapNode, xmlAllCriteriaNode, xmlQtyMapNode, xmlAllQtyMaps , xmlAllInvLineMap,xmlInvLineMap, xmlinvLineGroupType :JadeXMLNode;
	
	// #### String
	criDesc, firstDayTimeCutoff, includeFirstDay, includeLastDay, lastDayTimeCutoff, shipReceivalType, shipReleaseType,
	chargeDays, chargedDaysType, chargedDaysWorking, freeDaysType, freeDaysWorking, freeStorageDays, noCharge, noStorageIfNotFullyReceived, 
	receivalDateRule, stopCompletionFreeDays, allowMultiRangeSplit, allowOthersOption, code, color, description, expiryDate, expiryType, stcode,stdescription,
	ccode, cdesc, invLineGrpName, invoiceLineDescStr, calcTypeCode, critTypeStr,critItemCode,critItemValues,critItemPriority,tranMapName,tranMapdesc, vesselCatCode,
	xmlTagStr,xmlNodeStr : String;
	
	// #### Integer
	mappingType, rangeStart,rangeEnd, rangeType, mapValue, invLineGrpType, attributeType,criType, transferTypeInt: Integer;
	
	// #### Boolean
	chargeZero, resetFreeStorageDays, crIsUsed : Boolean;
	
	yaCriteria : CM_YACriteria;
	allCriTypes : CM_YACriteriaTypeArray; 
	realCriType, critType : CM_YACriteriaType;
	qtyMap : CM_QuantityMap;
	qtyRangeMap : CM_QuantityRangeMap;
	calcType : CM_CalculationType;
	bank : CM_Bank;
	realInvLineGroupType : CM_TranMapInvoiceLineGroupType;
	pxyInvLineMapping :CM_TranMapInvoiceLineMapping;
	invoiceLineDesc : CM_InvoiceLineDesc;
	realStorageGroup : CM_TerminalAreaStorageGroup;
	sconfig : CM_StorageConfig;
	pxyStorageDetail : CM_StorageDetail;
	pxyFSM : CM_FutureStorageMapping;
	realCalendar : CM_Calendar;
	pxyStorageTrigger : CM_StorageTrigger;
	transferType: CM_VoyageJobTransferType;
	vesselCategory: HMS_VesselCategory;

// ################
	count 			: Integer;
	err				: CM_Error;
	
	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	proxyStorageConfig, newStorageConfig : CM_StorageConfig;
	proxyStorageDetail, newStorageDetail : CM_StorageDetail;
	proxyFutureStorageMapping, newFutureStorageMapping : CM_FutureStorageMapping;
    triggers : CM_StorageTriggerByType;
	_file : File; 
	_term : CM_Terminal;
	_fileName, a : String;
	
	// ##############################
	
//		proxyStorageDetail, newStorageDetail : CM_StorageDetail;
//	proxyFutureStorageMapping, newFutureStorageMapping : CM_FutureStorageMapping;
	proxyQuantityMap, realQuantityMap : CM_QuantityMap;
	proxyQuantityRange, realQuantityRange : CM_QuantityRangeMap;
	
	// ######################################
	
	
		realInvoiceLineDesc : CM_InvoiceLineDesc;
	proxyTranMapInvoiceLineMapping, realTranMapInvoiceLineMapping : CM_TranMapInvoiceLineMapping;


begin
//	_fileName := "F:\TeamStuff\AndrewBishop\STWO\STWOInvoiceSetupJULY2017\STWOStorageConfiguration.xml";
	_fileName := "F:\TeamStuff\AndrewBishop\STWO\STWOInvoiceSetupJULY2017\BISHStorageAlloc.xml";
	_term := CM_Root.firstInstance.allTerminals["MAP"];
	
    app.initialize();
    
	create _file transient;
	_file.mode := File.Mode_Output; 
	_file.openInput(_fileName);

	if not _file.tryOpen() then
		app.msgBox("Cannot find file","ERROR",MsgBox_OK_Only);
		return;
	endif;
	
	/// ####PROXY ###############################
	/// ########################################
	/// ########################################
	/// ########################################
	/// ########################################
	/// ########################################
	/// ########################################
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	
	create proxyStorageConfig as CM_StorageConfig transient;

	tranMapName		:= null;
	tranMapdesc		:= null;
	root			:= app.myRoot;
	bank := _term.getDefaultCompanyBank();
	
	

	iter := rootElement.childNodes.createIterator;
	while iter.next(xmlNode) do
	
		// STORAGE CONFIG
		xmlElement := xmlNode.JadeXMLElement;
		if xmlElement.tagName = "name" then
			tranMapName := xmlElement.textData.String;
		elseif xmlElement.tagName = "firstDayTimeCutoff" then
			firstDayTimeCutoff := xmlElement.textData.String;
		elseif xmlElement.tagName = "includeFirstDay" then
			includeFirstDay := xmlElement.textData.String;
		elseif xmlElement.tagName = "includeLastDay" then
			includeLastDay := xmlElement.textData.String;
		elseif xmlElement.tagName = "lastDayTimeCutoff" then
			lastDayTimeCutoff := xmlElement.textData.String;
		elseif xmlElement.tagName = "shipReceivalType" then
			shipReceivalType := xmlElement.textData.String;
		elseif xmlElement.tagName = "shipReleaseType" then
			shipReleaseType := xmlElement.textData.String;
		elseif xmlElement.tagName = "allStorageDetails" then
			
			// FOR EACH STORAGE DETAIL
			foreach xmlNodeStorageConfig in xmlElement.childNodes do
				create pxyStorageDetail transient;


				// EACH ATTRIBUTE ON STORAGE DETAIL	
				foreach xmlNode  in xmlNodeStorageConfig.childNodes do
					xmlTagStr := xmlNode.JadeXMLElement.tagName;
					xmlNodeStr := xmlNode.JadeXMLElement.textData;
					
					
					if xmlTagStr = "code" then
						code :=xmlNodeStr.String;
					elseif  xmlTagStr = "color" then
						color := xmlNodeStr.String;
					elseif  xmlTagStr = "description" then
						description := xmlNodeStr.String;
					elseif  xmlTagStr = "chargeDays" then
						chargeDays := xmlNodeStr.String;
					elseif  xmlTagStr = "chargedDaysType" then
						chargedDaysType := xmlNodeStr.String;
					elseif  xmlTagStr = "chargedDaysWorking" then
						chargedDaysWorking := xmlNodeStr.String;
					elseif  xmlTagStr = "freeDaysType" then
						freeDaysType := xmlNodeStr.String;
					elseif  xmlTagStr = "freeDaysWorking" then
						freeDaysWorking := xmlNodeStr.String;
					elseif  xmlTagStr = "freeStorageDays" then
						freeStorageDays := xmlNodeStr.String;
					elseif  xmlTagStr = "noCharge" then
						noCharge := xmlNodeStr.String;
					elseif  xmlTagStr = "noStorageIfNotFullyReceived" then
						noStorageIfNotFullyReceived := xmlNodeStr.String;
					elseif  xmlTagStr = "receivalDateRule" then
						receivalDateRule := xmlNodeStr.String;
					elseif  xmlTagStr = "stopCompletionFreeDays" then
						stopCompletionFreeDays := xmlNodeStr.String;
					elseif  xmlTagStr = "allowMultiRangeSplit" then
						allowMultiRangeSplit := xmlNodeStr.String;
					elseif  xmlTagStr = "allowOthersOption" then
						allowOthersOption := xmlNodeStr.String;
					elseif  xmlTagStr = "expiryDate" then
						expiryDate := xmlNodeStr.String;
					elseif  xmlTagStr = "expiryType" then
						expiryType := xmlNodeStr.String;
					elseif  xmlNode.JadeXMLElement.tagName = "allCriteria" then
							foreach  xmlAllCriteriaNode in xmlNode.childNodes do
								create yaCriteria transient;
								
								foreach  xmlCriteriaNode in xmlAllCriteriaNode.childNodes do 
									xmlTagStr := xmlCriteriaNode.JadeXMLElement.tagName;
									xmlNodeStr := xmlCriteriaNode.JadeXMLElement.textData;
									if xmlTagStr = "myYACriteriaType" then
										critTypeStr :=xmlNodeStr.String;
									elseif xmlTagStr = "priorityValue"then
										critItemPriority := xmlNodeStr.String;
									elseif xmlTagStr = "code"then
										critItemCode := xmlNodeStr.String;
									elseif xmlTagStr = "myYAData"then
										critItemValues :=xmlNodeStr.String.toUpper;
									endif;
								endforeach;
								critType := root.allYACriteriaTypes.getAtKey(critTypeStr.Integer);	//Cargo Type
								yaCriteria.setProxy(critType,critItemValues,critItemCode);
								yaCriteria.setPriorityValue(critItemPriority.asRealJMT);	
							
								yaCriteria.setYardAllocation(pxyStorageDetail);
						    endforeach;
							
					elseif  xmlNode.JadeXMLElement.tagName = "allFutureStorageMappings" then
					
							// FOR EACH FUTURE STORAGE MAPPING
							// EACH &lt;CM_FutureStorageMapping&gt;
							foreach xmlQuantityMapNode in xmlNode.childNodes do
								create pxyFSM transient;
								
								// EACH ATTRIBUTE
								foreach xmlFutureStorageObjectNode in xmlQuantityMapNode.childNodes do
									xmlTagStr := xmlFutureStorageObjectNode.JadeXMLElement.tagName;
									xmlNodeStr := xmlFutureStorageObjectNode.JadeXMLElement.textData;
									
									if  xmlTagStr = "CM_QuantityMap" then
											
											create qtyMap transient;
											pxyFSM.setQuantityMap(qtyMap);
											
											// FOR EACH QUANTITY MAP
											foreach xmlQuantityMapNode in xmlFutureStorageObjectNode.childNodes do
											
												xmlTagStr := xmlQuantityMapNode.JadeXMLElement.tagName;
												xmlNodeStr := xmlQuantityMapNode.JadeXMLElement.textData;
												
												if xmlTagStr = "chargeZero" then
													chargeZero:= xmlNodeStr.Boolean;
													qtyMap.setChargeZero( chargeZero);
												elseif xmlTagStr = "mappingType" then
													mappingType :=xmlNodeStr.Integer;
													qtyMap.setMappingType(mappingType );
												elseif  xmlTagStr = "myCalculationType" then
													calcTypeCode:=xmlNodeStr.String;
													calcType :=root.allCalculationTypesByCode[calcTypeCode];
													qtyMap.setMyCalculationType(calcType);
												elseif  xmlTagStr = "allQuantityRanges" then
														foreach  xmlAllQtyMaps in xmlQuantityMapNode.childNodes do
															create qtyRangeMap transient;
															foreach xmlQtyMapNode in xmlAllQtyMaps.childNodes do
																xmlTagStr := xmlQtyMapNode.JadeXMLElement.tagName;
																xmlNodeStr := xmlQtyMapNode.JadeXMLElement.textData;
																
																if xmlTagStr = "rangeStart" then
																	rangeStart := xmlNodeStr.Integer;
																elseif  xmlTagStr = "rangeEnd" then
																	rangeEnd := xmlNodeStr.Integer;
																elseif  xmlTagStr = "rangeType" then
																	rangeType := xmlNodeStr.Integer;
																elseif  xmlTagStr = "allTMInvoiceLineMappings" then
																	
																	foreach xmlAllInvLineMap in xmlQtyMapNode.childNodes do
																		create pxyInvLineMapping transient;
																		
																		foreach xmlInvLineMap in xmlAllInvLineMap.childNodes do
																			xmlTagStr := xmlInvLineMap.JadeXMLElement.tagName;
																			xmlNodeStr := xmlInvLineMap.JadeXMLElement.textData;
																			if xmlTagStr = "mapValue" then
																				mapValue :=xmlNodeStr.Integer;
																			elseif  xmlTagStr =  "myTMInvoiceLineDesc" then
																				invoiceLineDescStr := xmlNodeStr.String;
																				invoiceLineDesc := bank.invoiceLineDescriptors[invoiceLineDescStr];
																			elseif  xmlTagStr =  "myTransferType" then
																				transferTypeInt := xmlNodeStr.Integer;
																				transferType := app.myRoot.allVoyageJobTransferTypes[transferTypeInt];
																			elseif  xmlTagStr =  "myVesselCategory" then
																				vesselCatCode := xmlNodeStr.String;
																				vesselCategory := app.myRoot.allVesselCategories[vesselCatCode];
																			elseif  xmlTagStr =  "CM_TranMapInvoiceLineGroupType" then 
																				
																				foreach xmlinvLineGroupType in xmlInvLineMap.childNodes do
																					if xmlinvLineGroupType.JadeXMLElement.tagName ="type" then
																						invLineGrpType :=xmlinvLineGroupType.JadeXMLElement.textData.Integer;
																					elseif  xmlinvLineGroupType.JadeXMLElement.tagName ="name" then
																						invLineGrpName :=xmlinvLineGroupType.JadeXMLElement.textData.String;
																					endif;
																				endforeach;
																				realInvLineGroupType := root.allTMInvLineGrpTypes[invLineGrpType];
																			endif;
																		endforeach;
																		
																		pxyInvLineMapping.update(mapValue, invoiceLineDesc, qtyRangeMap, realInvLineGroupType, transferType, vesselCategory, null, null, null);
																	endforeach;
																endif;
															endforeach;
															qtyRangeMap.setProxy(qtyMap,rangeStart,rangeEnd,rangeType);
														endforeach;
													
												endif;
											endforeach;
											qtyMap.setProxy(null,chargeZero,mappingType,calcType,pxyFSM);
											
									elseif  xmlTagStr = "CM_TerminalAreaStorageGroup" then
											foreach  xmlAllCriteriaNode in xmlFutureStorageObjectNode.childNodes do
												xmlTagStr := xmlAllCriteriaNode.JadeXMLElement.tagName;
												xmlNodeStr := xmlAllCriteriaNode.JadeXMLElement.textData;
												if xmlTagStr = "code" then
													stcode :=xmlNodeStr.String;
												elseif  xmlTagStr = "description" then
													stdescription := xmlNodeStr.String;
												endif;
											endforeach;
											
											realStorageGroup := _term.allTerminalAreaStorageGroups[stcode];
											if realStorageGroup &lt;&gt; null then
												pxyFSM.setMyStorageGroup(realStorageGroup);
											else

											endif;
											
									endif;

								endforeach;
								
									pxyFSM.setStorageDetail(pxyStorageDetail);
							endforeach;
					endif;
				endforeach;
				
					pxyStorageDetail.setValues(chargedDaysType.Integer,freeDaysType.Integer,freeStorageDays.Integer,proxyStorageConfig, chargeDays.Integer,
															0,stopCompletionFreeDays.Integer, receivalDateRule.Integer, noStorageIfNotFullyReceived.Boolean ,null, description, -1, -1, -1, -1, null, -1, -1, false, false);
					pxyStorageDetail.setProxy(code, description, "", 0,0,expiryType.Integer, expiryDate.Date, color.Integer, 
														false, 0, 0, null,0, false, false, null, null,false,_term);
			endforeach;
		elseif xmlElement.tagName = "myWorkingDaysCalendar" then
		
			foreach xmlNodeStorageConfig in xmlElement.childNodes do


				// EACH ATTRIBUTE ON STORAGE DETAIL	
				foreach xmlNode  in xmlNodeStorageConfig.childNodes do
					xmlTagStr := xmlNode.JadeXMLElement.tagName;
					xmlNodeStr := xmlNode.JadeXMLElement.textData;
					
					
					if xmlTagStr = "code" then
						ccode :=xmlNodeStr.String;
					elseif  xmlTagStr = "description" then
						cdesc := xmlNodeStr.String;
					endif;
				endforeach;
				
				realCalendar := root.allCalendars[ccode];
				realCalendar := _term.allCalendars[ccode];
				
			endforeach;
		
		
		elseif xmlElement.tagName = "allStorageTriggers" then
            create triggers transient;
			// FOR EACH STORAGE TRIGGER &lt;/CM_StorageTrigger&gt;
			foreach xmlNodeStorageTrig in xmlElement.childNodes do
				create pxyStorageTrigger transient;

				foreach xmlNodeStorageTrigObj in xmlNodeStorageTrig.childNodes do
						xmlTagStr := xmlNodeStorageTrigObj.JadeXMLElement.tagName;
						xmlNodeStr := xmlNodeStorageTrigObj.JadeXMLElement.textData;
						
						if xmlTagStr = "attributeType" then
							attributeType :=xmlNodeStr.Integer;
						elseif  xmlTagStr = "resetFreeStorageDays" then
							resetFreeStorageDays := xmlNodeStr.Boolean;
						endif;
				endforeach;
			
					pxyStorageTrigger.setProxy(attributeType, resetFreeStorageDays, proxyStorageConfig);
                    triggers.add(pxyStorageTrigger);
                    
			endforeach;
		elseif xmlElement.tagName = "allYACriteriaTypes" then
			create allCriTypes transient;
			// FOR EACH CRITERIA TYPE &lt;CM_YACriteriaType&gt;
			foreach xmlNodeCriteria in xmlElement.childNodes do
				foreach xmlNodeCriteriaObj in xmlNodeCriteria.childNodes do
						xmlTagStr := xmlNodeCriteriaObj.JadeXMLElement.tagName;
						xmlNodeStr := xmlNodeCriteriaObj.JadeXMLElement.textData;
						
						if xmlTagStr = "description" then
							criDesc :=xmlNodeStr.String;
						elseif  xmlTagStr = "isUsed" then
							crIsUsed := xmlNodeStr.Boolean;
						elseif  xmlTagStr = "type" then
							criType := xmlNodeStr.Integer;
						endif;
				endforeach;
				realCriType := root.allYACriteriaTypes[criType];
				if realCriType &lt;&gt; null then
					allCriTypes.addExclusive(realCriType);
				endif;
			endforeach;
		endif;
	endwhile;

	proxyStorageConfig.setProxy(allCriTypes,triggers,firstDayTimeCutoff.Time,includeFirstDay.Boolean, includeLastDay.Boolean, 
											_term, shipReceivalType.Integer, shipReleaseType.Integer, realCalendar, null, -1, -1, -1);





proxyStorageConfig.inspectModal;

	
	
	/// ####REAL ################################
	/// ########################################
	/// ########################################
	/// ########################################
	/// ########################################
	/// ########################################
	/// ########################################
	/// ########################################

	beginTransaction;
	if _term.myStorageConfig &lt;&gt; null and _term.myStorageConfig.cnEcIsPersistent then
		newStorageConfig := _term.myStorageConfig;
		delete newStorageConfig;
	endif;

	
	create newStorageConfig persistent;
//	newStorageConfig.setForCreateWholeStructure(proxyStorageConfig, app.myPassport);

	// ### STORAGE CONFIG
	newStorageConfig.setForUpdate(proxyStorageConfig,null);
	newStorageConfig.setPropertyValue("myTerminal", proxyStorageConfig.myTerminal);
	
	
	
	// ### STORAGE DETAILS
	foreach proxyStorageDetail in proxyStorageConfig.allStorageDetails do
		
		
		proxyStorageDetail.setPropertyValue("myStorageConfig", newStorageConfig);
		
		create newStorageDetail;
		newStorageDetail.setForCreate(proxyStorageDetail);
		
	
		// ### FUTURE MAPPINGS
		foreach proxyFutureStorageMapping in proxyStorageDetail.allFutureStorageMappings do
			create newFutureStorageMapping;
			newFutureStorageMapping.setMyStorageGroup(proxyFutureStorageMapping.myStorageGroup); // myStorageGroup is REAL
			newFutureStorageMapping.setStorageDetail(newStorageDetail);
			
			// ### QUANTITY MAP
			create realQuantityMap;
			
			proxyQuantityMap := proxyFutureStorageMapping.myQuantityMap;
//			realQuantityMap.setForCreateFutureStorage(proxyQuantityMap, newFutureStorageMapping);
			
            realQuantityMap.setPropertyValue("myCalculationType", proxyQuantityMap.myCalculationType);
            realQuantityMap.setPropertyValue("mappingType",proxyQuantityMap.mappingType);
            realQuantityMap.setPropertyValue("chargeZero", proxyQuantityMap.chargeZero);
            realQuantityMap.setPropertyValue("myFutureStorageMap", newFutureStorageMapping);
			
			
			
			
			
			// ### QUANTITY RANGES
			foreach proxyQuantityRange in proxyQuantityMap.allQuantityRanges discreteLock do
				create realQuantityRange;
//				realQuantityRange.setForCreateWholeStructure(proxyQuantityRange, realQuantityMap);
                realQuantityRange.setPropertyValue("rangeStart", proxyQuantityRange.rangeStart);
                realQuantityRange.setPropertyValue("rangeEnd", proxyQuantityRange.rangeEnd);
                realQuantityRange.setPropertyValue("rangeType",proxyQuantityRange.rangeType);
                realQuantityRange.setPropertyValue("myQuantityMap", realQuantityMap);
  // TFS 40620             realQuantityRange.allInvoiceLineMaps.clear();
	
	
                foreach proxyTranMapInvoiceLineMapping in proxyQuantityRange.allTMInvoiceLineMappings discreteLock do
                    create realTranMapInvoiceLineMapping;
                    realTranMapInvoiceLineMapping.update(proxyTranMapInvoiceLineMapping.mapValue, 
                                                                            proxyTranMapInvoiceLineMapping.myTMInvoiceLineDesc, // this is REAL
                                                                            realQuantityRange, // this is REAL
                                                                            proxyTranMapInvoiceLineMapping.myTMInvoiceLineGroupType, // this is REAL
																			proxyTranMapInvoiceLineMapping.myTransferType,
																			proxyTranMapInvoiceLineMapping.myVesselCategory, null, null, null);
                                                                            
 //   TFS 40620                realQuantityRange.allInvoiceLineMaps.addNoDuplicates(proxyTranMapInvoiceLineMapping.myTMInvoiceLineDesc, false);
                    
                endforeach;
			endforeach;
			
			
			
			
		endforeach;
	endforeach;

	
	
	
	newStorageConfig.inspectModal;
	
	

	abortTransaction;


epilog
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	delete proxyStorageConfig;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="abSetDebtorTypeDescriptions" id="665cefd9-68ca-41dd-94c1-876ee73a6f81">
        <source>abSetDebtorTypeDescriptions();
/*
Purpose:			
Date		Who		Reason
16 April 2013	cnwab1	Initial creation
*/

vars
	aDT 			: CM_DebtorType;
	message 		: String;
	descriptions 	: StringArray;
	idx 			: Integer;
begin
	
	app.initialize();
	
	create descriptions transient;
	descriptions.add( app.getErrorString(CM_Cargo_Operator) );
	descriptions.add( app.getErrorString(Consignee) );
	descriptions.add( app.getErrorString(CM_Consignor) );
	descriptions.add( app.getErrorString(CM_Ship_Operator) );
	descriptions.add( app.getErrorString(CM_Business_Unit) );
	descriptions.add( app.getErrorString(CM_Customs_Agent) );
	descriptions.add( app.getErrorString(FreightForwarder) );
	
	beginTransaction;
	foreach idx in 1 to 7 do
		aDT := app.myRoot.allDebtorTypes["SDT" &amp; idx.String];
		
		aDT.setPropertyValue("description", descriptions[idx]);
	endforeach;
commitTransaction;
	delete descriptions;
end;
</source>
    </JadeMethod>
    <JadeMethod name="abTextGLCodeExtract" id="3f6419fb-099f-4170-a6b3-41a17030cb74">
        <source>abTextGLCodeExtract();
/*
Purpose:			
Date				Who			Reason
NOV 2012		CNWAB1		Initial creation
*/

vars
	ela		: CM_ExtractLoadAgent;
	file	: File;
begin
	app.initialize();
	
	create ela transient;
	create file transient;
	file.usePresentationFileSystem := true;
	file.allowReplace := true;
	file.openOutput("F:\TeamStuff\AndrewBishop\DohaExtract\glcodes.xml");
	ela.extractGLCodes(file);
epilog
	delete ela;
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="adp29882" id="77c8ae4c-29bf-485e-8da5-c7ee15278c04">
        <source>adp29882(_cmif : CMIF_CalcTypeQuantityHook) : Real;
//26/09/2016 cnwma1 TFS #2723 PAR #38240 ADP -Wrong charge for Cargo with additional manual free days Added(Issue 3)
//23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	newQty : Real;
	transactionDate : TimeStamp;
	theTI : CM_TrackedItem;
	theVoyage,theImpVoyage : CM_Voyage;
	dischargeDays, daysStored, freeDays, graceDays, coveredDays, chargedDays, storageExpiryDays ,newFreeDays: Integer;
	storageDetail	: CM_StorageDetail;
	grossRevenueTonnes, totalWeight, totalVolume : Decimal[12,4]; 
	
	receivedByShip : String;
begin
	newQty := _cmif.origQty;
	
	transactionDate := _cmif.myTransaction.CM_TITransaction.dateTime;
	
	app.invLog("Hook Code for " &amp; _cmif.myTransaction.getTypeString() &amp; " transaction. Original Quantity is " &amp; _cmif.origQty.String, LogINFO.String);
		
	// ### IF ANY NULLS RETURN ORIGINAL QUANTITY
	theTI := _cmif.myTransaction.CM_TITransaction.myTrackedItem;
	if theTI = null then
		app.invLog("TI is null", LogINFO.String);
		return _cmif.origQty;
	endif;
	
	
	totalVolume := theTI.totalVolume;
	
	totalWeight := theTI.totalWeight;
	
	if totalWeight = null and totalVolume = null then
	app.invLog("Weight and Volume both are null, return original quantity " &amp; _cmif.origQty.String, LogINFO.String);
		return _cmif.origQty;
	endif;
	
	app.invLog("Checking received by Ship?", LogINFO.String);
	
	receivedByShip := theTI.receiptTransportMode.String;// = TI_TRANSMODE_SHIP;
		

	theVoyage := theTI.myVoyage;
	app.invLog("Checking if theVoyage = null ", LogINFO.String);
	
	if theVoyage = null then
		return _cmif.origQty;
	endif;
	
	app.invLog("theVoyage.arrivedDT.isValid() ", LogINFO.String);
	
	if not theVoyage.arrivedDT.isValid() then
		return _cmif.origQty;
	endif;
	
		
	/*if not theVoyage.shipExchangeCompleteDT.isValid() then
		return _cmif.origQty;
	endif;
	*/
	app.invLog("theTI.receivedDT.isValid()", LogINFO.String);
	
	if not theTI.receivedDT.isValid() and not theTI.getStatusCode = 'EXP' then
		return _cmif.origQty;
	endif;
	
	if theTI.getFreeStorageDays() &gt; 0 then    //16/11/2016 cnwma1 
		newFreeDays := theTI.getFreeStorageDays();
	else
		newFreeDays := 0;
	endif;
	// ### GET THE CONFIGURED FREE STORAGE DETAIL FOR THIS CARGO ITEM
	storageDetail := theTI.getMatchingFreeStorageDetail( null );
	
	if storageDetail = null then
	
		app.invLog("No storageDetail for " &amp; _cmif.myTransaction.getTypeString() &amp; " transaction", LogINFO.String);
		return _cmif.origQty;
	endif;
	
	app.invLog("StorageDetail free days is  " &amp; storageDetail.freeStorageDays.String &amp; " days for " &amp; _cmif.myTransaction.getTypeString() &amp; " transaction", LogINFO.String);
	
	// ### CALCULATE THE NUMBER OF DAYS FROM VOYAGE ARRIVAL TO CARGO RELEASE: +1 BECAUSE DAYS ARE INCLUSIVE 
	//daysStored := (transactionDate.Date - theVoyage.arrivedDT.date) + 1; //16/11/2016  cnwma1
	if theTI.getStatusCode = 'EXP' then 
		daysStored := (transactionDate.Date - theVoyage.arrivedDT.date) + 1 ;
	//////////////// Tranship////////////////////////////////////////////////////////	// 26/09/2016 cnwma1 TFS #2723 PAR #38240 
	elseif theTI.getStatusCode = 'TSH' then                                     
		app.invLog("Checking if theImpVoyage = null ", LogINFO.String);
		theImpVoyage :=theTI.myVoyageTranshipImport;
		if theImpVoyage &lt;&gt; null then
			if  theImpVoyage.arrivedDT.isValid() then
				app.invLog("theImpVoyage.arrivedDT.isValid() ", LogINFO.String);
				daysStored := (transactionDate.Date - theImpVoyage.arrivedDT.date) + 1 ;
			else
				app.invLog("theImpVoyage.arrivedDT.isInvalid() ", LogINFO.String);
				return _cmif.origQty;
			endif;
		else
			app.invLog("theImpVoyage = null ", LogINFO.String);
			return _cmif.origQty;
		endif;
	////////////// End Tranship /////////////////////////////////////////////////////
	else
		daysStored := (transactionDate.Date - theVoyage.arrivedDT.date) + 1;

	endif;
		
	// ### A MAXIMUM OF 4 DAYS GRACE IS ALLOWED FOR DISCHARGE AFTER THAT STORAGE APPLIES.
	// ### DETERMINE IF GRACE PERIOD HAS BEEN EXCEEDED
	//if theVoyage.shipExchangeCompleteDT.isValid() then //16/11/2016 cnwma1
	if theVoyage.shipExchangeCompleteDT.isValid() and theTI.getStatusCode &lt;&gt; 'TSH' then //16/11/2016 cnwma1
		dischargeDays := theVoyage.shipExchangeCompleteDT.date -  theVoyage.arrivedDT.date;
		app.invLog("Exchange complete - Voyage arrival Date in days is  " &amp; dischargeDays.String &amp; " days for " &amp; _cmif.myTransaction.getTypeString() &amp; " transaction", LogINFO.String);
		
		if dischargeDays &gt; 4 then
			graceDays := 4;
		else
			graceDays := dischargeDays;
		endif;	
	endif;
	
	if theImpVoyage &lt;&gt; null then  //16/11/2016 cnwma1 
		if theImpVoyage.shipExchangeCompleteDT.isValid() and theTI.getStatusCode = 'TSH' then    //30/09/2016 cnwma1  TFS #2723 PAR #38240
			dischargeDays := theImpVoyage.shipExchangeCompleteDT.date -  theImpVoyage.arrivedDT.date;
			app.invLog("Exchange complete - Import Voyage arrival Date in days is  " &amp; dischargeDays.String &amp; " days for " &amp; _cmif.myTransaction.getTypeString() &amp; " transaction", LogINFO.String);
			if dischargeDays &gt; 4 then
				graceDays := 4;
			else
				graceDays := dischargeDays;
			endif;
		endif;
	endif;
	// ### ADJUST FREE STORAGE DAYS TAKING GRACE PERIOD INTO ACCOUNT
	
	freeDays := storageDetail.freeStorageDays + graceDays;
	app.invLog("Free days = " &amp; freeDays.String, LogINFO.String);
	// ### CALCULATE STORAGE DAYS TO BE CHARGED
		
	if theTI.getStatusCode = 'EXP' then    
		chargedDays := daysStored - newFreeDays;
	else
		//chargedDays := daysStored - freeDays; 		/ 26/09/2016 cnwma1 TFS #2723 PAR #38240  //16/11/2016 cnwma1 
		chargedDays := daysStored -(theTI.additionalStorageDays + freeDays);   // 26/09/2016 cnwma1 TFS #2723 PAR #38240 
	endif;
	//## Setting the Free Storage Days correctly for Cargo Enquiry and for Receipt printing
	if dischargeDays &gt; 4 then
		app.invLog("Setting free storage days", LogINFO.String);
		storageExpiryDays:=theTI.receivedDT.Date - theVoyage.arrivedDT.date;
		app.invLog("storageExpiryDays for Cargo Free Storage Expiry Date: " &amp; storageExpiryDays.String, LogINFO.String);
		theTI.setFreeStorageDays(freeDays-storageExpiryDays);
		app.invLog("Free days = " &amp; freeDays.String, LogINFO.String);
		app.invLog("Free storage days updated ", LogINFO.String);
	endif;
	if chargedDays &lt; 0 then
		chargedDays := 0;		
			chargedDays:= newQty.Integer;
	endif;
	// ### DETERMINE GRT
		
	if totalVolume &gt; (totalWeight / 1000) then
		grossRevenueTonnes := totalVolume;
	else
		grossRevenueTonnes := totalWeight / 1000;
	endif;
		
	// ### MULTIPLY CHARGED DAYS BY GRT TO GET NEW QUANTITY
	
	newQty := chargedDays * grossRevenueTonnes;
	
	app.invLog("Grace days = " &amp; graceDays.String, LogINFO.String);
	app.invLog("Original Qty is " &amp; _cmif.origQty.String, LogINFO.String);
	app.invLog("Days Charged is " &amp; chargedDays.String, LogINFO.String);
	app.invLog("Total Weight is " &amp; totalWeight.String, LogINFO.String);
	app.invLog("Total Volume is " &amp; totalVolume.String, LogINFO.String);
	app.invLog("GRT is " &amp; grossRevenueTonnes.String, LogINFO.String);
	app.invLog("Chargable Qty is " &amp; newQty.String, LogINFO.String);
	
	return newQty;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="adpStorageDetailsFix" id="4e515e94-c22c-4cc0-97f7-c9f73af81e71">
        <source>adpStorageDetailsFix();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgma1	Initial creation

*/

vars
 strDesc : String;
 strArr : HugeStringArray;
 str : String;
 comm : CM_Commodity;
 oper : CM_Operator;
 cargoType: CM_CargoType;
 storageDetail : CM_StorageDetail;
 ya : CM_YardAllocation;
 yac : CM_YACriteria;
 yaDesc : String;
 imex : CM_IMEXStatus;
begin

	strDesc :="IMP ,GC, I&amp;S HVLT, CASE, PALT, CRAT, CBDR, MCRY, BOAT, TRLR, CRVN, DRGR, DRRG, SPDR, TANK, MRTG, DRUM, CRDL, STBX, FBDR, BARL, VCLS, BDLS, NMBG, JBBG, &lt;20F, &gt;20F, COWS, CAML, HORS, SHEP, GOAT, R20-, WEAT, BRLY, CORN, MAIZ, RICE, SUGR, SYBN, CMNT, CLNK, IROR, SLAG, SSND, MLSG, GYSM, VGOL, SFOL, PLOL, EDOL, LBOL, FLOL, CSST, BDSD, BDYD, P20+, AOSD, AOYD, WBRN, P20-, BAGS, PCTR, CRGE, M20A, M20C, M40A, M40C, M60A, M60C, UNIT, RT-, UNWT, FRBF, FRCH, PE-, FRDT, FRDK, FRFS, FRFP, FRMN, FRPZ, FRSP, FRVG, FRFR, ICCM, SMLV, APLS, BSCT, CARR, CHSE, CHFP, CHCT, DRPT, DATS, DRFD, EGG, FIG, FRBN, FDSF, GRPE, JUPT, MEDI, MIXF, MIXV, NONF, OILP, ORGE, PICK, PINE, B20-, B20+, C/B-, C/B+, PE+, R20+, RT+, SKID, S20+, S20-, PICS, AOTH, C20-, C20+, C40+, SOAS, BRTS, FLSP, ALMU, CHMT, YACH, FRNT, DRFT, &lt;20H, &gt;20H ADMI, ADSA, AHMM, AAWS, ABSA, BAWA, AKBY, SAHR, ATSC, YAQT, ALJA, AGSA, ALPR, AMIM, ASCO, AMSA, AOPS, BRWL, BINJ, CLRI, CMAA, CSSE, DCCF, EMSR, ENSS, ESTR, ETIS, EVSA, XPCL, FIXX, GAC, GHQQ, GWST, EMFA, GCLS, GENA, GSO, HUDA, INTS, JARL, KANO, KFRJ, KISE, LAMN, LDSA, AGTH, MRSK, MAKS, MICO, MSCA, MEF, MUTA, NPCC, NSGA, NMDC, OCMA, OOCL, POSI, PSAL, QNTC, RHSC, SEMS, SHRF, SOCA, STAL, STAF, TOSC, NAVY, UASC, WWME, WOSA, HUA, AIDA, MOL, COCR, KLE, MSCC, ECL, SAL, GMB, NSS, NYK, COS, EUKO, NMC, RKM, 1001, 1002, 1003, 1004, 1005, 1006, 1007, 1008, 1009, 1010, 1011, 1012, 1013, 1014, 1015, 1016, 1017, 1018, 1019, 1020, 1021, 1022, 1023, 1025, 1026, 1027, 1028, 1029, 1031, 1032, 1033, 1034, 1035, 1036, 1037, 1038, 1040, 1041, 1042, 1043, 1044, 1045, 1046, 1047, 1048, 1049, 1050, 1051, 1052, 1053, 1054, 1055, 1056, 1057, 1058, 1059, 1060, 1061, 1062, 1063, 1064, 1065, 1066, 1067, 1068, 1069, 1070, 1071, 1080, 1081, 1082, 1083, 1084, 1085, 1086, 1087, 1088, 1089, 1090, 1091, 1092, 1093, 1094, 1095, 1097, 1098, 1099, 1100, 1101, MICC, AGIL, MOHI, RASH, GSI, 1102, 1103, 1104, 1105, 1106, 1107, LING, ARA, MAL, 1108, DELM, 1109, HORI, DEUG, ADSO, 1110, FUTT, 111