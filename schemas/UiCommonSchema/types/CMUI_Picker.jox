    <JadeMethod name="txtFilter_keyUp" id="e2aa48f1-282c-4317-ac4d-180f23921113">
        <controlMethod name="TextBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFilter_keyUp(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2024	jlier1	Initial creation

*/

vars
	type,
	remaining		: Integer;
begin
	if self.getTimerStatus(CM_TableViewForm.Timer_TableData_Filter, type, remaining) then
		self.endTimer(CM_TableViewForm.Timer_TableData_Filter);
	endif;
	
	self.beginTimer(500, Timer_OneShot, CM_TableViewForm.Timer_TableData_Filter);

epilog

end;</source>
