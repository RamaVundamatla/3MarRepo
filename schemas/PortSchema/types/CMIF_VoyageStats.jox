    <JadeMethod name="setGraphPointsFromTransactions" id="cadfdd23-540f-4d92-a9c3-e954ac2aa6c9">
        <source>setGraphPointsFromTransactions();
/*
Purpose:	 // PAR 36118		
Date		Who		Reason
24 April 2015	cnwab1	Initial creation
*/

vars
	tmpSheetStats	: CMIF_JobSheetStats;
	js : CM_JobSheet;
begin
	foreach tmpSheetStats in self.allJobSheetStats do
						
		js := tmpSheetStats.myJobSheet;
		
		if js = null then
			continue;
		endif;
	
		if not js.isTransient then // The transient JS is for HOLD moves i.e. not LOLO or RORO
			continue; // is LOLO or RORO
		endif;
		
		tmpSheetStats.setGraphPointsFromTransactions();
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setVoyageStartTime" id="4c39c206-5fa4-4598-9966-f21be867a688">
        <updating/>
        <source>setVoyageStartTime(_value : TimeStamp) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	//15 July 2015	NDL Par 36610
	if _value = null then
		return;
	endif;
	
	if self.voyageStartTime = null or _value &lt; self.voyageStartTime then
		self.voyageStartTime:=_value;
	endif;


epilog

end;</source>
        <Parameter name="_value" type="TimeStamp"/>
    </JadeMethod>
