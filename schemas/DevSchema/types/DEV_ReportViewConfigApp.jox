    <JadeMethod name="tblAttributesData_dblClick" id="2f485c8c-224b-404c-a03a-123ad758f276">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAttributesData_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2023	navkc1	Initial creation

*/

vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;
	
	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
