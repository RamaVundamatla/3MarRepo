    <JadeMethod name="populateCmbICAreas" id="9d77e3b8-30e2-4fab-b58f-7f640abbd097">
        <source>populateCmbICAreas();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2022	navhl20	ChangeRequest 53921: MTN - GC Area Terminal Area Defn Transfer Areas.

*/

vars
	
	icAreaType : CM_TerminalAreaType;
	taSet : CM_TerminalAreaSet;
	ta : CM_TerminalArea;
	iter : Iterator;
	index : Integer;

begin

	self.cmbTerminalArea.clear;
	self.cmbTerminalArea.sorted := true;
	self.cmbTerminalArea.addItem("");
	
	icAreaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_YARD_INTERCHANGE];
	
	create taSet transient;
	iter := self.myTerminal.allTerminalAreas.createIterator;
	while iter.next( ta ) do
		if ta.myType &lt;&gt; icAreaType then
			continue;
		endif;
		taSet.add( ta );
	endwhile;
	
	foreach ta in taSet discreteLock do	
		index := self.cmbTerminalArea.addItem(ta.id);
		self.cmbTerminalArea.itemObject[index] := ta;
	endforeach;

epilog

	delete taSet;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setLocations" id="147718a4-7fec-4218-b462-c25a3fd35b9c">
        <updating/>
        <source>setLocations(_locations:CM_LCSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2022	navhl20	ChangeRequest 53921: MTN - GC Area Terminal Area Defn Transfer Areas.

*/

vars
	location : CM_LocationsController;
	int 	 : Integer; 
begin
	foreach location in _locations do
		if location.CM_IrregularBlockController.getInterChangeArea &lt;&gt; null then
			int := lstAvailArea.addItem(location.ident &amp; Tab &amp; "(" &amp; location.CM_IrregularBlockController.getInterChangeArea.id &amp; ")");    ////16 Aug 2022 navhl20 TFS 53921
		else
			int := lstAvailArea.addItem(location.ident);
		endif;
		lstAvailArea.itemObject[int] := location;
	endforeach;
epilog

end;</source>
        <Parameter name="_locations" type="CM_LCSet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="322b1472-76a5-4ef9-9fe5-aef2ff919ba0">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

