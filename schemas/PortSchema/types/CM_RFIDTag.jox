    <JadeMethod name="addToAlerts" id="54aeddc1-9b9e-4d19-a9cd-8be7b8e23904">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::addToAlerts"/>
        </interfaceImplements>
        <updating/>
        <source>addToAlerts(alert: CM_SystemAlert) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin	
	/*- cnwmd1, CCMS 1871 - No longer required.  app.causeEventForSystemAlertType method is called in CM_SystemAlert::commitAlert()
	if alert.mySystemAlertType &lt;&gt; null then
		//self.myTerminal.causeEvent(alert.mySystemAlertType.type,false,alert); //- cnwmd1, CCMS 1871
		app.causeEventForSystemAlertType(alert, self.myTerminal); 				//+ cnwmd1 CCMS 1871
	endif;
	*/
epilog

end;


</source>
        <Parameter name="alert" type="CM_SystemAlert"/>
    </JadeMethod>
