    <JadeMethod name="dragOver" id="264e2e88-39e4-4ea3-a73e-e66ab03632f3">
        <controlMethod name="Form::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dragOver(win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars

begin
	if app.myMoveController &lt;&gt; null or app.myWagonMoveController &lt;&gt; null then
		self.setFocus();
		self.zOrder(1);
		self.windowState := WindowState_Normal;
	endif;	
end;</source>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
