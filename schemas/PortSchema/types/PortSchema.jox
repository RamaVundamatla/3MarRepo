		return WORK_POINT_TYPE_SHIP;
	elseif _str = self.getErrorString(WORK_POINT_TODO_STR) then
		return WORK_POINT_TYPE_TODO;
	elseif _str = self.getErrorString(WORK_POINT_PACKUNPACK_STR) then
		return WORK_POINT_TYPE_PACKUNPACK;
	elseif _str = self.getErrorString(WORK_POINT_YARD_STR) then
		return WORK_POINT_TYPE_YARD;
	elseif _str = self.getErrorString(WORK_POINT_UNKNOWN_STR)  then
		return WORK_POINT_TYPE_UNKNOWN;
	endif;
epilog

end;</source>
