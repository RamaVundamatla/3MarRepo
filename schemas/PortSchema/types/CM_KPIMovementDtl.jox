    <JadeMethod name="setFromLegs" id="b400392d-683c-452b-9a1b-a03c6e5a197a">
        <updating/>
        <source>setFromLegs(_trackedItem: CM_TrackedItem; _legs: CM_KPIMovementLegDtlArray input) updating;
vars
	firstLeg: CM_KPIMovementLegDtl;
	lastLeg: CM_KPIMovementLegDtl;
	movementLeg, gateLeg: CM_KPIMovementLegDtl;
	shift: CM_Shift;
	visit: CM_VehicleVisitRecord;
	token: Integer;
begin

	// Create Full Movement
	self.terminalId := _trackedItem.myTerminal.code;
	self.cargoId := _trackedItem.id;
	self.cargoType := _trackedItem.myCargoType.abbreviation;
	self.iso := _trackedItem.getISOType;
	if _trackedItem.getISOTypeGroup &lt;&gt; null then
		self.isoGroup := _trackedItem.getISOTypeGroup.code;
	endif;
	self.weight := _trackedItem.totalWeight.Integer;
	self.teu := _trackedItem.getNumTEU.Integer;
	self.operatorId := _trackedItem.myOperator.code;
	self.dischargePort := _trackedItem.dischargePort;
	
	firstLeg := _legs.first;
	lastLeg := _legs.last;
	shift := _trackedItem.myTerminal.getShiftForTimeStampReal(lastLeg.finishTime);
	if shift &lt;&gt; null then
		self.shiftId := shift.code;
	endif;
	self.sourceType := firstLeg.sourceType;
	self.source := firstLeg.source;
	self.targetType := lastLeg.targetType;
	self.target := lastLeg.target;
	self.startTime := firstLeg.startTime;
	self.finishTime := lastLeg.finishTime;
	self.duration := self.startTime.getDifferenceInSeconds(self.finishTime).rounded;

	if self.sourceType = CM_LocationsController.Location_Type_SHIP then
		token := 1;
		self.workPointId := self.source.cnGetToken(token, " ");
	elseif self.targetType = CM_LocationsController.Location_Type_SHIP then
		token := 1;
		self.workPointId := self.target.cnGetToken(token, " ");
	elseif self.sourceType = CM_LocationsController.Location_Type_YARD and
	   self.targetType = CM_LocationsController.Location_Type_YARD then
		self.workPointId := "Yard";
	elseif self.sourceType = CM_LocationsController.Location_Type_RAIL or
	   self.targetType = CM_LocationsController.Location_Type_RAIL then
		self.workPointId := "Rail";
	endif;

	if self.sourceType = CM_LocationsController.Location_Type_VEHICLE then
		// Road job - update source to the Gate
		token := 1;
		visit := self.getTruckVisit(self.source.getNextToken(token));
		if visit &lt;&gt; null then
			self.source := visit.getVisitId &amp; " " &amp; visit.vehicle.code;
			self.sourceType := CM_LocationsController.Location_Type_ROAD;
			self.workPointId := visit.getGateInName.cnEcFindReplace(" ", "_", false);
		endif;
	endif;

	if self.targetType = CM_LocationsController.Location_Type_VEHICLE then
		// Road job - need to add a leg for this road release
		token := 1;
		visit := self.getTruckVisit(self.target.getNextToken(token));
		if visit &lt;&gt; null then
			self.target := visit.getVisitId &amp; " " &amp; visit.vehicle.code;
			self.targetType := CM_LocationsController.Location_Type_ROAD;
			self.workPointId := visit.getGateInName.cnEcFindReplace(" ", "_", false);
		endif;
	endif;
	
	_legs.copy(self.allMovementLegs);

epilog
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_legs" type="CM_KPIMovementLegDtlArray" usage="input"/>
    </JadeMethod>
</Class>
