    <JadeMethod name="getGeneratorTypeComboText" id="d7196d90-9c2d-4e4b-8dcc-e845db887a20">
        <source>getGeneratorTypeComboText( _generatorType: CM_GeneratorType ) : String;
/* ---------------------------------------------------------------------------
Created:	08 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if _generatorType.isNoseMounted then
		return GeneratorType_NoseMounted;
		
	elseif _generatorType.isUnderSlung then
		return GeneratorType_UnderSlung;
		
	else
		return GeneratorType_StandAlone;

	endif;


end;</source>
        <Parameter name="_generatorType" type="CM_GeneratorType"/>
        <ReturnType type="String"/>
    </JadeMethod>
