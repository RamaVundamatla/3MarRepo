//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.top := self.savedTop;
	self.frmToolbarBtns.visible := false;	
	inheritMethod();

end;</source>
    </JadeMethod>
