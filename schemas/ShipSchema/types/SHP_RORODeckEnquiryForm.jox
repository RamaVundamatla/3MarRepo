    <JadeMethod name="tbRoRolDecks_contextMenu" id="4b4a949c-0869-4c99-b530-c44f4bf60d00">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tbRoRolDecks_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	xLeft 	: Real;
	yTop	: Real;
	deck : CM_Deck;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.mnuDeckAudits.visible:=false;
	if table.row &gt; 1 and table.accessRow(table.row) &lt;&gt; null then
		deck:=table.accessRow(table.row).itemObject.CM_Deck;
		self.mnuDeckAudits.visible:= deck.hasAudits; //14 Jan 2021	NDL	TFS 50152
	endif;
	
	self.popupMenu(self.mnuTblContext, xLeft.Integer, yTop.Integer);

	return false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
