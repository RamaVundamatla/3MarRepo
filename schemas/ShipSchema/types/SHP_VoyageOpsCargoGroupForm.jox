    <JadeMethod name="loadPreNoteTable" id="90271016-25c6-4c95-b35b-248ff65570c8">
        <updating/>
        <source>loadPreNoteTable(_startingTI : CM_TrackedItem; 	// 08/12/2022	navkc1	#55409
				 _next : Boolean				// 08/12/2022	navkc1	#55409
				 ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
22 Apr 2022		navnk20		Initial creation TFS 53388
22 Jun 2022		navsrk20	Bug 53887: EUP - Items Cargo Type to be shown instead of Cargo Group Type
12 Jul 2022		navdap1		TFS 53889 EUP Collapsed view not kept when moving or updating cargo
25 Oct 2022		navkc1		Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
08 Nov 2022		navmd1		TFS 55379 Refactor VoyageOpsCG Form
28 Nov 2022	    navkc1		ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
08 Dec 2022		navkc1		ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
16 Jan 2023		navmp20		Bug 56062: EUP - #3, #4 Incorrect Cargo grouping/heading values
20 Apr 2023		navmd1		TFS 56062 Fix Cargo Group Detail headers not updating correctly
*/
vars
	rowIdx, colIdx	 		: Integer;
	ti 						: CM_TrackedItem;
	isHidden 				: Boolean;
 // ### TFS BUG 58853 10JUL2023 NAVAB1	dynaDict 				: DynaDictionary;
	currentVoyage 			: CM_Voyage;
	currentTable 			: CM_FilterTable;
	cmifMonitor 			: CMIF_Monitor;
	noMonitor 				: Boolean;
	idx, totalParts,
	currentPart, site		: Integer;
	maxStr					: String;
	iter					: Iterator;
	tis						: CM_TIByCargoGroupIdDict;
	cgDetails				: CM_CargoGroupDetail;
	cargoGroup				: CM_CargoGroup;
	plus					: Character;
	progressStr				: String;
	
begin
	
	if not self.isInCargoGrouping then
		inheritMethod(_startingTI, _next);
		return;
	endif;

	on Exception do self.handleExceptionVoyage(exception, currentVoyage);
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		currentVoyage.fetchLatest();
	endif;
	
	// Exception handler sets voyage to null if its been deleted
	if currentVoyage = null then
		return;
	endif;
	
	//17Jan2023 navsp1 TFS 56045 / position changed
	currentTable := self.tblPreNote;
	currentTable.clearSort();	
	currentTable.rows := currentTable.fixedRows;
	currentTable.clearAllViewObjects( Any_System_Event );	
	
	// 28/11/2022	navkc1	#55408
	tis := currentVoyage.allNotifiedTIsByCargoGroupId;
	if tis.isEmpty() then return; endif;
	
	self.myCargoGroup := null;
	
	// We're now in our special cargo grouping mode, so lets do things a bit differently
	
	// 28/11/2022	navkc1	#55408 - Copy the cargo group details to dynamic dictionary and have them sorted so they don't get displayed in random order
	/*  // ### TFS BUG 58853 10JUL2023 NAVAB1
	create dynaDict transient;
	dynaDict.setMembership(CM_CargoGroupDetail);
	dynaDict.addMemberKey(CM_CargoGroupDetail::myCargoGroup.name &amp; "." &amp; CM_CargoGroup::id.name, false, true);
	dynaDict.endKeys(true); 
	currentVoyage.allCargoGroupDetails.copy(dynaDict);
	maxStr := dynaDict.size().String;
	*/
	maxStr := currentVoyage.allCargoGroupDtlBySiteCargoGrp.size.String; // ### TFS BUG 58853 10JUL2023 NAVAB1
	
	isHidden := not self.dkcPreNotes.visible;
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		// This should never be a thing, but instead of breaking because we can't show progress, lets just create a dummy one and not link it anywhere
		noMonitor := true;
		create cmifMonitor transient;
	endif;
	totalParts := cmifMonitor.partsInJob;
	currentPart := cmifMonitor.partsDone;
	
	// 28/11/2022	navkc1	#55408
	site := self.getSiteForTable(currentTable);
	plus := J_key_Plus.Character;
	
	// Pre notes are only actual and planned, not Queued
	// When in cargo grouping mode, the display is locked to ACTUAL
	/*if self.displayModePreNote = DISPLAY_MODE_PLAN and ti.myPrimaryPlannedLocation = null then
		continue;
	endif;*/

	
	progressStr := app.getErrorString(Loading_prenotified_cargo);	// Loading Pre-Notified Cargo
 // ### TFS BUG 58853 10JUL2023 NAVAB1	foreach cgDetails in dynaDict as CM_CargoGroupDetail discreteLock where cgDetails.site = site do
	foreach cgDetails in currentVoyage.allCargoGroupDtlBySiteCargoGrp discreteLock where cgDetails.site = site do
		idx += 1;
		cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
		
		if cargoGroup = null or cargoGroup &lt;&gt; cgDetails.myCargoGroup then
			cargoGroup := cgDetails.myCargoGroup;
			rowIdx := 0;
		else
			// Already added this Cargo Group Detail, skip to the next one
			continue;
		endif;
		
		ti := cgDetails.getFirstTIForVoyage(currentVoyage);
		self.loadCargoForTable(ti, rowIdx, currentTable, isHidden, true);
	endforeach;
	
	// Now we find out is there any cargo items has unknown cargo group for this table, add Unknown row if there is.
	iter := tis.createIterator();
	tis.startKeyGeq(null, null, iter);
	iter.next(ti);
	// 28/11/2022	navkc1	#55408
	if ti.myCargoGroup = null then
		rowIdx := currentTable.addItem("");
		if currentTable.getColumnByRowName(ETRow_Id) &lt;&gt; null then
			colIdx := currentTable.getColumnByRowName(ETRow_Id);
			currentTable.accessCell(rowIdx, colIdx).text := " " &amp; app.getErrorString(Unknown);
		endif;
		if currentTable.getColumnByRowName(ETRow_CargoType) &lt;&gt; null then
			colIdx := currentTable.getColumnByRowName(ETRow_CargoType);
			currentTable.accessCell(rowIdx, colIdx).text := app.getErrorString(Unknown_cargo_group);
		endif; 	
		currentTable.accessCell(rowIdx, 1).text := plus &amp; " " &amp; currentTable.accessCell(rowIdx, 1).text;
		currentTable.accessRow(rowIdx).itemObject := ti.myCargoGroup;
		currentTable.accessedRow.backColor := LightYellow;
	endif;
	// 28/11/2022	navkc1	#55408
	
	self.colourTableRows(currentTable);
	
	/* //30/07/2025	navkc1 JIRA MTN 35478
	if self.performRefresh = RefreshCurrentViewOnly then
		currentTable.setCurrentViewObjects();
	endif;
	*/
	self.restoreCollapseState(currentTable);	// TFS 53889
	
epilog
 // ### TFS BUG 58853 10JUL2023 NAVAB1	delete dynaDict;
	delete iter;
	if noMonitor then
		delete cmifMonitor;
	endif;
end;</source>
        <Parameter name="_startingTI" type="CM_TrackedItem"/>
        <Parameter name="_next" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="openWithSavedSettings" id="440a308e-2259-473b-86a1-dff91471aa87">
        <updating/>
        <source>openWithSavedSettings(): Boolean updating;
/*

Purpose:			Default to Hybrid Mode - Refresh Current View only mode to better handle the insane number of TIs EUP want to display

Parameters:			

Return Value:		

Date		Who		Reason
16 November 2022	navkc1	Initial creation Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
28 November 2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
*/

vars

begin
	
	if not inheritMethod() then
		self.btnCargoGrouping.value := true;		
		
		//self.optHybridMode.value := true; //30/07/2025	navkc1 JIRA MTN 35478
		
		self.chkTableCount.value := true;
		self.chkAllowFilter.value := false;
		self.chkAllowMore20.value := true;
		//self.chkAllowPreNote.value := true; //30/07/2025	navkc1 JIRA MTN 35478
		
		//self.optCurrentView.value := true; //30/07/2025	navkc1 JIRA MTN 35478
		
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCargoGroupDetails" id="b9847b6b-b295-4424-99e9-05651e612933">
        <updating/>
        <source>populateCargoGroupDetails(_site : Integer; _cargoGroup : CM_CargoGroup; _columns : EntTableRowArray; 
						_table : CM_DataTable input; _row : Integer io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18 May 2022	navdap1		Initial creation TFS 
// 25/10/2022	navkc1		Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
// 08/11/2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
// 28/11/2022	navkc1		ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
// 10/05/2023	navmd1		TFS 56062 Fix incorrect header values
vars
	detail,
	combinedDtl		: CM_CargoGroupDetail;
	result			: String;
	site			: Integer;
	cell			: JadeTableCell;
	startRow,	
	endRow			: Integer;
	tableRow		: JadeTableRow;
	ti				: CM_TrackedItem;
	cgName			: String;
	currentVoyage	: CM_Voyage;
	obj : Object;
begin
	site := _site;	 
	if site = -1 then
		site := self.getSiteForTable(_table);
	endif;
	
	/* // ### TFS BUG 58853 10JUL2023 NAVAB1
	create combinedDtl transient;
	combinedDtl.initialise(null, site, _cargoGroup, null, null);
*/
	// The current voyage here is not checked for validity, so don't dereference it!
	currentVoyage := self.myCurrentVoyage;
	/* // ### TFS BUG 58853 10JUL2023 NAVAB1
	// some tables may have more than one detail applicable - for instance, on site could have TRUCK and voyage and train details
	foreach detail in _cargoGroup.allCargoGroupDetails discreteLock where detail.site = site do
		if detail.myVoyage &lt;&gt; null and detail.myVoyage &lt;&gt; currentVoyage then
			continue;	// Not our voyage, skip
		endif;
		combinedDtl.combine(detail);
	endforeach;
	*/
	detail := currentVoyage.allCargoGroupDtlBySiteCargoGrp[site,_cargoGroup.id];
	// Try and handle crap data... should we though ?
	if detail = null
	or detail.allAssignedTrackedItems.size = 0 then
		// Something went wrong, return a 0 index
		_row := 0;
		return;
	endif;
	
	result := detail.getAttributeStringForDefArray(_columns);
	if _row &gt; 0 then
		// if cargo group details is already in the table then update the details (mainly quantity)
		cell := _table.accessCell(_row, 1);
		cell.text := cell.text[1:2] &amp; result;	// Leave the existing +/- indiacator as is
	else
		// Otherwise, add a new row
		startRow := _table.fixedRows + 1;
		endRow := _table.rows;
		cgName := _cargoGroup.id;
		
		foreach _row in startRow to endRow where _table.rowVisible[_row] do
			tableRow := _table.accessRow(_row);
			 ti := tableRow.itemObject.CM_TrackedItem;
			
			if ti &lt;&gt; null and not ti.isCargoGroupItem then
				continue;	// Skip TIs
			endif;
			
			// If we hit the 'Unknown Cargo Group' row
			// or the cargo groups ID is 'after' ours, then bail
			if ti = null or ti.id &gt; cgName then
				break;
			endif;
		endforeach;
			
			_table.addItemObjectAt(_cargoGroup, J_key_Plus.Character &amp; " " &amp; result, _row);
			_table.accessedRow.backColor := LightYellow;
		endif;
	
epilog
 // ### TFS BUG 58853 10JUL2023 NAVAB1	delete combinedDtl;
end;</source>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_columns" type="EntTableRowArray"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="restoreCollapseState" id="f3291686-819d-44f3-8aa7-e5f127c60b60">
        <updating/>
        <source>restoreCollapseState(_table : CM_FilterTable input) updating;
//
// Purpose:			Various events cause all tables rows to be shown again, so we need to hide the ones that shouldn't be showing again
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/07/2022	navdap1		Initial creation TFS 53889 EUP Collapsed view not kept when moving or updating cargo
// 22/07/2022	navsrk20	Bug 54242: MTN - Application Program Error in Voyage Operations
// 24/11/2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
// 18Jan2023 	navsp1 		ChangeRequest 56209: MTN - Cargo Group Voyage Ops Form - Expand/Collapse All button refactor
vars
	rowIdx 			: Integer;	
	tblText,
	nextRowTxt		: String;
	startRow,
	endRow			: Integer;
	plus,
	minus			: Character;
begin
	if not _table.visible then
		return;
	endif;
	
	plus := J_key_Plus.Character;
	minus := J_key_Hyphen.Character;
	
	startRow := _table.fixedRows + 1;
	endRow := _table.rows;
	
	foreach rowIdx in startRow to endRow where _table.rowVisible[rowIdx] do
		tblText := _table.accessCell(rowIdx, 1).text;
		if tblText[1:1] = plus then
			
			//25Jan2023 navsp1 TFS 56209
			if rowIdx &lt; endRow + 1	then
				if rowIdx = endRow then
					nextRowTxt := _table.accessCell(rowIdx, 1).text[1:1];
				else
					nextRowTxt := _table.accessCell(rowIdx+1, 1).text[1:1];
				endif;
				if nextRowTxt = plus or nextRowTxt = minus then
					continue;	//	No TIs loaded for cargo group yet, skip
				endif;
				
			endif;
			
			// Pretend we were expanded and now want to collapse again
			_table.accessCell(rowIdx, 1).text := minus;// &amp; tblText[2:end];   //28Dec2022 navsp1 TFS 56054
			
			// then need to 'click' this row
			_table.row := rowIdx;
			_table.column := 1;
			
			self.collapseExpandCargoGroups(_table, false,true); //25Jan2023 navsp1 TFS 56209
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_table" type="CM_FilterTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="9bba3c21-09c9-43a6-b8a5-7cc1eec8904d">
        <updating/>
        <source>setMyCurrentVoyage(_voyage: CM_Voyage) updating;
/*
Purpose:			

Date		Who		Reason
03 July 2023	navab1	// ### TFS  CR 58857 TASK 58967  3JUL2023 NAVAB1 
*/

vars

begin
	if self.myCurrentVoyage &lt;&gt; null then
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_VOYAGE_CARGOGROUP_DETAIL));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_CARGOGROUP_UPDATE)); // ### TFS BUG 58853 04JUL2023 NAVAB1
	endif;
	
	inheritMethod(_voyage);
	
	if self.myCurrentVoyage &lt;&gt; null then
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_VOYAGE_CARGOGROUP_DETAIL), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_CARGOGROUP_UPDATE), Response_Continuous, null); // ### TFS BUG 58853 04JUL2023 NAVAB1
			
	endif;	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="17e65fe7-b32e-4afb-86a5-161b6683f756">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 November 2022	navmd1	Initial creation TFS 55379 Refactor VoyageOpsCG Form

*/

vars
	theDef	: EntTableDef;
	theRow	: EntTableRow;
	idx		: Integer;
	col		:JadeTableColumn;
begin
	if self.isInCargoGrouping then
		// If showing cargo groups, then always make 'Row Number' (#) the first column
		// A bit of a fudge to basically add a 'fixed column' without changes classes from CM_FilterTable
		theDef := app.myController.getEntTableDef(ETDef_LlHeadings);
		theRow := theDef.getEntTableRow(ETRow_RowNumber);
		
		// If we've already included it somewhere, remove it
		_theTable.removeColumnByEntRowName(ETRow_RowNumber);
		
		// Now add '#' as the first column
		_theTable.allTblDataEntRows.insert(1, theRow);
		_theTable.allTblDataColHeadings.insert(1, theRow.getHeading(_theTable.getMyTerminologyCargoBOLType, _theTable.getMyTerminologyTerminal, app.myCurrentLocale));
		_theTable.allTblDataColInputTypes.insert(1, Table.InputType_None);
		_theTable.allTblDataColPropertyNames.insert(1, theRow.name);
		
		_theTable.insertColumn(1);
		col := _theTable.accessColumn(1);
		col.inputType := Table.InputType_None;
		col.width := 0;	// Auto-resize
		_theTable.accessCell(_theTable.fixedRows, 1).text := _theTable.allTblDataColHeadings[1];
	endif;


	inheritMethod(_theTable);
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="406c16ed-e90c-41ae-a19f-59c94b9d0062">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/05/2022	navdap1		Initial creation TFS 53889 EUP Collapsed view not kept when moving or updating cargo
// 08/11/2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
//
vars

begin
	inheritMethod();
	
	if self.btnCargoGrouping.value then
		self.btnCargoGrouping_click(self.btnCargoGrouping);
	endif;
	
	// Force the '#'/RowNumber column to be first
	if self.tblOnship.allTblDataColPropertyNames[1] &lt;&gt; ETRow_RowNumber then
		self.setTableDataFromOrganiser(self.tblOnship);
	endif;
	if self.tblOnsite.allTblDataColPropertyNames[1] &lt;&gt; ETRow_RowNumber then
		self.setTableDataFromOrganiser(self.tblOnsite);
	endif;
	if self.tblOffsite.allTblDataColPropertyNames[1] &lt;&gt; ETRow_RowNumber then
		self.setTableDataFromOrganiser(self.tblOffsite);
	endif;
	if self.tblPreNote.allTblDataColPropertyNames[1] &lt;&gt; ETRow_RowNumber then
		self.setTableDataFromOrganiser(self.tblPreNote);
	endif;
	
	startNotifications();	//20.Mar.24 navsp1 TFS 61223
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startNotifications" id="70c7d4ef-159b-4c43-ae79-ff83e03acb6e">
        <source>startNotifications();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2024	navsp1	Initial creation TFS 61223

*/

vars

begin	
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_CARGOGROUP_DELETE), Response_Continuous, null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="b80b6343-6f10-4d84-a698-114467d9e23a">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2022	navsrk20	Initial creation
25/10/2022	navkc1		Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
28/11/2022	navkc1		ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
05/12/2022	navmd1		TFS 55379 Fix Cargo Group rows not being removed from a table after their detail has been deleted
20/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
*/

vars
 
begin
	
	inheritMethod(eventType, theObject, eventTag); //30/07/2025	navkc1 JIRA MTN 35478
	
epilog
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tableRowChange" id="ce6d4ca1-2dbd-4084-a3bc-9ac1b1deebfe">
        <updating/>
        <source>tableRowChange(_table : CM_DataTable input; _newRow : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 April 2023		navmd1	Initial creation TFS 56062 Fix Cargo Group Detail headers not updating correctly

*/

vars
	obj : CM_Object;
	invalid : Boolean;
begin	
	on Exception do app.handleDeletedObject(exception, obj, invalid);

	self.myCurrentTrackedItem	:= null;
	self.myCurrentContextTbl	:= _table;			// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	
	if _newRow &lt;= _table.fixedRows then
		return;
	endif;
	
	obj := _table.accessRow(_newRow).itemObject.CM_Object;
	if obj &lt;&gt; null then	// Unknown Cargo Group row has no object
		obj.edition;
	endif;
	
	if obj = null or invalid then
		return;
	endif;
	
	if obj.isKindOf(CM_TrackedItem) then
		self.myCurrentTrackedItem := obj.CM_TrackedItem;
	elseif obj.isKindOf(CM_CargoGroupDetail) then
		self.myCurrentTrackedItem := obj.CM_CargoGroupDetail.myCargoGroup;
	endif;

	//moved this down here so we can test self.myCurrentTrackedItem
	//in setEnableObjects
	self.setEnableObjects(_table);	

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7eb73ca6-f886-47e3-af9d-10655c46d4f7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 November 2022 10:18:40.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024869, locale);
	btnCargoGrouping.translateCaption(Xlat_0024870, locale);
	btnExpandAll.translateCaption(Xlat_0024871, locale);
	btnRecalculateCargoGroup.translateCaption(Xlat_0024872, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateCargoGroup" id="0b0f8605-c92b-4bc8-8c25-f186eec20af9">
        <updating/>
        <source>updateCargoGroup(_cargoGroup : CM_CargoGroup) updating;
/*
Purpose:	add in any new TIs for our cargo group detail, possibly just unpacked for instance		

Date		Who		Reason
04 July 2023	navab1	// ### TFS BUG 58853 04JUL2023 NAVAB1
12/04/2024		navkc1 		Bug 63662: FR | 53159 - Cargo Group Overview in Voyage Operations - part II
*/

vars
	ti, rowti : CM_TrackedItem;
	row, cgrow, tirow, startRow, endRow, rowtouse : Integer;
	cgDetail : CM_CargoGroupDetail;
	rowIdx: Integer;
	currentTable : CM_DataTable;
	tableRow : JadeTableRow;
	obj : Object;
	hasOffsite, hasOnsite, hasOnship, hasPrenotes : Boolean;
	firstColText : String;
begin

	foreach cgDetail in _cargoGroup.allCargoGroupDetails  discreteLock do : outerloop
		if cgDetail.myVoyage &lt;&gt; self.myCurrentVoyage then
			continue;
		endif;
		
		if cgDetail.site = TI_SITE_ONSITE then
			currentTable := self.tblOnsite;
			hasOnsite := true;
		elseif cgDetail.site = TI_SITE_OFFSITE then
			currentTable := self.tblOffsite;
			hasOffsite := true;
		elseif cgDetail.site = TI_SITE_ONSHIP then
			currentTable := self.tblOnship;
			hasOnship := true;
		else
			currentTable := self.tblPreNote;
			hasPrenotes := true;
		endif;
	
		currentTable.findObjectInRow(_cargoGroup,cgrow);
		
		if cgrow &gt; currentTable.fixedRows 
		and cgrow &lt;= currentTable.rows then // ### TFS BUG 59900 23AUG2023 NAVAB1
			firstColText := currentTable.accessCell(cgrow,1).text.trimBlankCharacters();
			if firstColText.Character = J_key_Plus.Character then
				continue outerloop;
			endif;
		endif;
		
		
		// In this UI the sorting has been turned off, so need to manually slot in our TIs alphabetically 
		startRow := cgrow + 1;
		endRow := currentTable.rows;
		rowtouse := null; //12/04/2024	navkc1 Bug 63662 - Reset after going to next cg details.
		
		foreach ti in cgDetail.allAssignedTrackedItems  do : outerlopp
			row := 0;
			tirow := 0;
			currentTable.findObjectInRow(ti,tirow);
			if tirow&gt; 0 then // already displayed
				if ti.isChild then // just been packed
					currentTable.removeItem(tirow);
				endif;
				continue;
			endif;

			
			// In this UI the sorting has been turned off, so need to manually slot in our TIs alphabetically 
			foreach row in startRow to endRow where currentTable.rowVisible[row] do
				 rowti := currentTable.accessRow(row).itemObject.CM_TrackedItem;
				if rowti = null then
					continue;
				endif;
				
				if rowti &lt;&gt; null and rowti.isCargoGroupItem then
					rowtouse := row -1;
					break;	// Next CG
				endif;
				
				// If we hit the 'Unknown Cargo Group' row
				// or the cargo groups ID is 'after' ours, then bail
				if ti = null 
				or rowti.id &gt; ti.id then
					rowtouse := row -1;
					break;
				endif;
			endforeach;

			self.loadCargoForTable(ti,rowtouse, currentTable.CM_DataTable, false, true);
			//12/04/2024	navkc1 Bug 63662 - If rowtouse is -1, means the trackeditem is not added to the table. break this loop and continue with the next cg details
			if rowtouse = -1 then
				break;
			endif;
			
		endforeach;
	
	endforeach;
		
	// Last item is packed into a container, means cargo group is empty so remove from UI.
	if not hasOnsite then
		rowIdx := 0;
		currentTable:= self.tblOnsite;
		if currentTable.findObjectInRow(_cargoGroup, rowIdx) then
			currentTable.removeItem(rowIdx);
		endif;
	endif;
	
	//12/04/2024	navkc1 Bug 63662 - Remove cargo group (yellow line) if last cargo is removed from the table
	if not hasOnship then
		rowIdx := 0;
		currentTable:= self.tblOnship;
		if currentTable.findObjectInRow(_cargoGroup, rowIdx) then
			currentTable.removeItem(rowIdx);
		endif;
	endif;
	
	//12/04/2024	navkc1 Bug 63662 - Remove cargo group (yellow line) if last cargo is removed from the table
	if not hasPrenotes then
		rowIdx := 0;
		currentTable:= self.tblPreNote;
		if currentTable.findObjectInRow(_cargoGroup, rowIdx) then
			currentTable.removeItem(rowIdx);
		endif;
	endif;
	
	//12/04/2024	navkc1 Bug 63662 - Remove cargo group (yellow line) if last cargo is removed from the table
	if not hasOffsite then
		rowIdx := 0;
		currentTable:= self.tblOffsite;
		if currentTable.findObjectInRow(_cargoGroup, rowIdx) then
			currentTable.removeItem(rowIdx);
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="a2d722fc-574e-425b-a30b-6b9084e529b1">
        <controlMethod name="Form::userNotify"/>
