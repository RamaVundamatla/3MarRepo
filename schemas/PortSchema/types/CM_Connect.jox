    <JadeMethod name="canUpdateTransaction" id="efd5b895-d57a-4999-bc66-75b67e91c12c">
        <source>canUpdateTransaction(): Boolean;
// ---------------------------------------------------------------------------
// Created:     24 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="bb5183e4-0dba-40cc-9251-9e52d1caa4f8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
	ti	: CM_TrackedItem;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := "Connection to ";
			if self.getOtherTrackedItem() &lt;&gt; null then
				lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
			else
				lDetail := lDetail &amp; " Power";
			endif;
			
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;
						
			return lDetail;
			
		endif;
	
	elseif _attrName = ETRow_ConnectTo then
		ti := self.getOtherTrackedItem();
		if ti &lt;&gt; null then
			return ti.id;
		else
			return null;
		endif;	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="d8d98c31-61cb-43d1-9693-2dd03440fa8f">
        <source>getEnquiryRow(): String ;
// ---------------------------------------------------------------------------
// Created: May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();

	lDetail := lDetail &amp; "Connection to ";
	if self.getOtherTrackedItem() &lt;&gt; null then
		lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
	else
		lDetail := lDetail &amp; " Power";
	endif;
	
	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
