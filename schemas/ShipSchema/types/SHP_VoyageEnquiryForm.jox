    <JadeMethod name="tblDataDisplayColourColumn" id="f00fafc8-a8c2-4974-8e24-55512064973f">
        <source>tblDataDisplayColourColumn(_rowIdx, _colour : Integer);
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	cell : JadeTableCell;
	
begin
	if _rowIdx &gt; self.tblData.fixedRows
	
	and self.colColour &gt; 0 then
		cell := self.tblData.accessCell(_rowIdx, self.colColour);
		cell.text := null;
		cell.backColor := _colour;
	endif;
	
end;</source>
        <Parameter name="_rowIdx" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="f22b7f4b-9e82-4a95-b9dc-4820fd40efdf">
        <source>tblDataDisplayRow(_voyage : CM_Voyage);
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	idx : Integer;
	failedDAC  :CM_DataAccessController;
begin
	if (not _voyage.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return;
	endif;

	str := _voyage.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	idx := self.tblData.addItemObject(_voyage, str);

	self.tblDataDisplayColourColumn(idx, _voyage.colour);
					
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="cb67d1db-0641-4bb0-b03e-f3d42c7964eb">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	self.mnuInspectObj.visible := app.isAllowedToInspect();
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.popupMenu(self.mnuContextTbl, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="e8c6585e-87d2-40a7-8d4c-7bd7a11e1da4">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
//--------------------------------------------------
vars

	msg : String;

begin
	if table.row &lt;= table.fixedRows then
		table.resortTableByColumn(table.column);
		table.colourRows(self.colorRow1, self.colorRow2);		
	else
		//12 May 2017	NDL	TFS 4313
		if self.myCurrentVoyage = null then
			self.setSelectedVoyage(self.tblData.accessRow(self.tblData.row).itemObject.CM_Voyage);
			if self.myCurrentVoyage = null then
				msg := app.getErrorString(PleaseSelectAVoyage);
				app.msgBox(msg,app.getErrorString(Warning),MsgBox_OK_Only);
				return;
			endif;
		endif;
		self.myAssistant.showVoyageDefForm(self.myCurrentVoyage, self.myMasterMenuAction, false, false);
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_keyDown" id="fba2fa96-d814-4d78-b33e-28e788deda8e">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	08 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	theObject : Object;
begin
	if keyCode = J_key_Delete 
	and (not self.frmSearch.visible) then
		self.doDelete();

	elseif shift = 0 then
		theObject := self.tblData.doSearch(keyCode.Character.String, 1);

		if CM_Voyage.hasInstance(theObject) then
			self.setSelectedVoyage(theObject.CM_Voyage);
		endif;	

	endif;		
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="581d3c8b-1e87-41c9-9953-301932a2deb4">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_rowColumnChg(table: Table input) updating;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if table.row &gt; table.fixedRows then
		self.setSelectedVoyage(self.tblData.accessRow(self.tblData.row).itemObject.CM_Voyage);
	else
		self.setSelectedVoyage(null);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
