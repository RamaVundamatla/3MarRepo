    <JadeMethod name="validateDimensionValues" id="67b1e297-70a1-46d3-bdac-a882c6e07211">
        <source>validateDimensionValues();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2013	cnwndl1	Initial creation	Par 32826

*/

vars

begin

	inheritMethod();
	
	if self.overHeight &lt; 0 then
		app.raiseCMException1(XXX_less_than_zero, app.getErrorString(CM_Over_height), null, self);
	endif;
	
	if self.overLengthFront &lt; 0 then
		app.raiseCMException1(XXX_less_than_zero, app.getErrorString(CM_Over_length_front), null, self);
	endif;
	
	if self.overLengthRear &lt; 0 then
		app.raiseCMException1(XXX_less_than_zero, app.getErrorString(CM_Over_length_rear), null, self);
	endif;
	
	if self.overWidthLeft &lt; 0 then
		app.raiseCMException1(XXX_less_than_zero, app.getErrorString(CM_Over_width_left), null, self);
	endif;
	
	if self.overWidthRight &lt; 0 then
		app.raiseCMException1(XXX_less_than_zero, app.getErrorString(CM_Over_width_right), null, self);
	endif;	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateDimensions" id="6d2ae5ef-edeb-4112-836b-b7ae5370fcb1">
        <updating/>
        <source>validateDimensions(pController: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;
/*
Purpose:			Check a container that is having its dimensions changed so it is now over-dimension
					to see if it's over-stowed. If it is, raise a warning so the user is aware of this

Parameters:			

Return Value:		

Date		Who		Reason
16/12/2011	cnwdap1	Initial creation PAR #26619 CCMS SFW 1260 check on change of height whether there is a container above me
*/
vars
	realTI			: CM_TrackedItem;
	topTI 			: CM_TrackedItem;
	planned, queued	: Boolean;
	mode			: String;
	overstowID		: String;

begin
	inheritMethod(pController, _passport);
	
	if not self.isOverHeight or not self.isTransient then
		return;
	endif;
	
	realTI := pController.myRealTrackedItem;
	if realTI = null or realTI.CM_Container.overHeight = self.overHeight then
		return;
	endif;
	
	// check actual location - am I in a voyage slot or a yard grid area?
	topTI := realTI.getPlannedQueuedActualTIOverMe();
	if topTI &lt;&gt; null then
		overstowID := topTI.id;
		if planned or queued then
			mode := "will be";
		else
			mode := "is";
		endif;
		// raise warning - I am overstowed, so can't really change me to be overheight
		app.raiseCMWarning3(Cargo_item_overs_sure_wish_cha, self.id, mode, topTI.id, "Container " &amp; self.id, null, self);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="pController" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateExportBookingForPack" id="febca2ea-61f0-432c-839e-fe3067c8c399">
        <source>validateExportBookingForPack(_bookingRefItem: CM_BookingRefItem input);
/*

Date		Who		Reason
03 October 2016	cnwer1	Initial creation TFS 2526

*/

vars

begin
	if _bookingRefItem = null then
		return;
	endif;
	
	if not _bookingRefItem.myBookingReference.isExportBooking then
		return;
	endif;
	
	inheritMethod(_bookingRefItem);

	
	if _bookingRefItem.isoType &lt;&gt; null and self.isoType &lt;&gt; _bookingRefItem.isoType then
		app.raiseCMException3(Cargo_booking_iso_types,self.id,_bookingRefItem.myBookingReference.bookingReference,
				self.isoType &amp;  "/"
				&amp; _bookingRefItem.isoType , null,null);
	endif;

	if _bookingRefItem.isoTypeGroup &lt;&gt; null and self.isoGroup &lt;&gt; _bookingRefItem.isoTypeGroup then
		app.raiseCMException3(Cargo_booking_isotype_groups,self.id,_bookingRefItem.myBookingReference.bookingReference,self.isoTypeGroup &amp; "/" &amp; _bookingRefItem.isoTypeGroup,null,null);
		
	endif;
	if _bookingRefItem.mySpecialStow &lt;&gt; null and  self.getSpecialStow &lt;&gt; null and   //30/12/2014 cnwma1 PAR #35380
	   self.getSpecialStow &lt;&gt; _bookingRefItem.mySpecialStow then
	   app.raiseCMException3(Cargo_booking_special_stow,self.id,_bookingRefItem.myBookingReference.bookingReference, self.specialStow &amp;  "/"
				&amp;  _bookingRefItem.mySpecialStow.code ,null,null);
	endif;
epilog

end;</source>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem" usage="input"/>
    </JadeMethod>
