    <JadeMethod name="makeMessageDAM" id="054d7ca4-48c6-4555-aedf-dced5ac313ea">
        <source>makeMessageDAM(_camProtocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/07/2019	jlgdap1		Initial creation TFS 45582 SNO COARRI Damage should be same as CODECO Damage
//
vars
	isProduceDAMSeg : Boolean;
	damCode, damDesc : String;
	damageInstance : CM_DamageInstance;

begin
	isProduceDAMSeg := _camProtocol.getProduceDAMSegment();
	
	if not isProduceDAMSeg then
		return;
	endif;
	
	foreach damageInstance in _ti.allDamageInstancesByPos discreteLock do
		//damDesc := "DAMAGED " &amp; damageInstance.description[1:70];
		damDesc := damageInstance.getDescriptionForCamsDAM;	//26 Aug 2019	NDL	TFS 46286
		damCode := damageInstance.getDamageCode;
		//DAM
		self.makeDAMSegment(_camProtocol, _group, '1', damCode, null, null, damDesc);
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageFTX_Damage" id="85383313-3254-4bad-a912-a3cedd56fe12">
        <source>makeMessageFTX_Damage(_camProtocol: CM_CamProtocol; _group: HugeStringArray input; _ti: CM_TrackedItem; _codeSectionSuffix: String) protected;
/*

Purpose:	TI damaged so produce consistent FTX+DAR, also see CM_CamCODECODesc::makeDAMorFTXSegment
			_codeSectionSuffix allows 'switching out' of ZZZ+184 for non-DAM Coarri213
			Originally at inherited-class level.
Parameters:			

Return Value:		

Date		Who		Reason
20/03/2019	jlgsl4	TFS 41786 - SNO - Consistent FTX+DAR and DAM for Coarri/Codeco
16/07/2019	jlgdap1	TFS 45582 SNO COARRI Damage should be the same as CODECO Damage
29/03/2021  cnwma1  Bug 51027: GPHA - Inconsistent FTX+DAR segment between COARRI and CODECO
*/

vars
	code, 
	desc, 
	codeSection    : String;
	produceDAMSeg  : Boolean;
	damageInstance : CM_DamageInstance;
	damDesc, 
	damCode        : String;
	
begin
	desc 		  := self.getAVGradeCodeAndDesc(_ti, code);
	produceDAMSeg := _camProtocol.getProduceDAMSegment();

	if _ti.damaged then
		if produceDAMSeg then
			self.makeFTXSegment(_camProtocol, _group, "DAR", null, code &amp; ":ZZZ:184", desc);
		else
			foreach damageInstance in _ti.allDamageInstancesByPos discreteLock do
				damDesc := "DAMAGED " &amp; damageInstance.description[1:70];
				damCode := damageInstance.getDamageCode;
				
				// FTX+DAR
				self.makeFTXSegment(_camProtocol, _group, "DAR", null, code &amp; ":ZZZ:184", damDesc);
				// FTX+AAI
				if damageInstance.remarks &lt;&gt; null then
					self.makeFTXSegment(_camProtocol, _group, "AAI", null, null, damageInstance.remarks[1:70]);
				endif;
			endforeach;
		endif;
	else
		// FTX+DAR
		self.makeFTXSegment(_camProtocol, _group, "DAR", null, code &amp; ":ZZZ:184", "NOT DAMAGED");
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_codeSectionSuffix" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC" id="9be18fc1-c368-42c0-87eb-04a8c0e2eb45">
        <source>makeMessageLOC(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem) protected;
/*
Purpose: Refactored code

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
// 30 Nov 2017  cnwma1  TFS #7780: SNO - Tranship Discharge needs to use the incoming voyage info
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
// 30 Nov 2017  cnwma1  TFS #7780: SNO - Tranship Discharge needs to use the incoming voyage info
vars
	terminal			:CM_Terminal;
	code, fCode, pCode	:String;
	location			:CM_LocationsController;
begin
	terminal	:= _protocol.terminal;
	
	// LOC+9 - load port
	code 		:= _ti.loadPort.trimRight;
	
	//30.11.2017 cnwma1 TFS #7780
	if _activity = COARRI_SHIPDISCHARGE then
		if _ti.isTranshipItem then
			if _ti.myTranshipDetail &lt;&gt; null then
				if  _ti.myTranshipDetail.importOriginalLoadPort &lt;&gt; null then
					code := _ti.myTranshipDetail.importOriginalLoadPort;
				endif;
			endif;
		endif;
	endif;
	
	fCode 		:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
	
	if fCode = null then
		fCode := code.trimRight;
	endif;

	self.makeLOCSegment (_protocol, _group, '9', fCode, '139', '6', null, null, null);
	
	if _activity = COARRI_SHIPLOAD then
		// LOC+11 - get the discharge port code
		code 	:= _ti.dischargePort;
		pCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if pCode = null then
			pCode := code;
		endif;
		
		pCode := pCode.trimRight;
		
		self.makeLOCSegment (_protocol, _group, '11', pCode, '139', '6', null, null, null);
		
		// LOC+8 - get the destination port code PAR2836 99/115
		code 	:= _ti.destinationPort;
		pCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if pCode = null then
			pCode := code;
		endif;
		
		pCode := pCode.trimRight;
		
		if pCode &lt;&gt; null then
			self.makeLOCSegment (_protocol, _group, '8', pCode, '139', '6', null, null, null);
		endif;
		
		// LOC+147 - setup bay position
		location := _ti.getPrimaryLocation(REAL_MODE);
		
		if location &lt;&gt; null and location.isKindOf(CM_SlotController) and not location.isKindOf(CM_ShipBlockController) then
			self.makeLOCSegment (_protocol, _group, '147', location.CM_SlotController.getStowageId(_ti).trimRight, null, '5', null, null, null);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageNAD_CF" id="48bb012e-3c7e-4c10-9055-d438f4712842">
        <source>makeMessageNAD_CF(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem):String protected;
/*
Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	value, msg	:String;
	foundMatch	:Boolean;
begin
	if _protocol.useContainerOperator_In_NAD_CF then
		value	:= app.myRoot.getXlationForeignOperatorCode( null, _ti.CM_Container.operatorCode.trimBlanks, foundMatch).trimRight;
	else
		value	:= _protocol.camGroup.shippersCode.trimRight;
	endif;
	
	msg := self.makeNADSegment (_protocol, _group, "CF", value, '172', '20');
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_ABT" id="f0a49b57-f41d-43f5-8873-9edfdd2e6bc4">
        <source>makeMessageRFF_ABT(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem):String protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	msg	:String;
begin
	if _activity = COARRI_SHIPLOAD and _ti.customExportEntryNumber.trimRight &lt;&gt; null then
		msg := self.makeRFFSegment (_protocol, _group, "ABT", _ti.getCustExpEntryNoMinusSlash);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
