    <JadeMethod name="cargoADPInterfaceRates" id="c07106c1-9402-4730-9994-d5fcccc88f63">
        <source>cargoADPInterfaceRates(_services : CM_ServiceByNameDict) protected;
// set the initial rates
vars
	lineCount	: Integer;
	service		: CM_Service;
	operator	: CM_Operator;
	start,
	expiry : TimeStamp;
	ignoreEntry : Boolean;
	costValue	: Decimal[8,2];
	costs : DecimalArray;
	debtor : CM_DebtorNode;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
	transients	: ObjectArray;

begin
	create transients transient;

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	// set rates such that a known invoice line value is the lowest or highest 
	create costs transient;
	foreach service in _services do
		debtor := operator.debtor;

		lineCount := lineCount + 1;
		costs.clear();
		costValue := 1.0;	// default value
		if lineCount = 1 then
			costValue := 500.0;		
		elseif lineCount = 2 then
			costValue := 0.10;		
		elseif lineCount = 3 then
			costValue := 110.0;		
		endif;

		costs.add(costValue);
		start.setDate("31/01/2010".Date);
		start.setTime("00:00".Time);
		expiry := null;
		debtorRate := debtor.serviceRates[service];
		if debtorRate = null then
			create debtorRate transient;
			debtorRate.setProxy(service, debtor);
			rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);
			transients.add(debtorRate);
		else
			rateEntry := debtorRate.rateEntries.first;
			self.updateInvoiceRateEntry(debtorRate, rateEntry, start, expiry, ignoreEntry, costs, 0, 0, null,null);
		endif;
		self.assertNoTrxErrorsOrWarnings();
		
		// ### DEFAULT DEBTOR
		costs.clear();
		costValue := 10.0;	// default value
		if lineCount = 1 then
			costValue := 5000.0;		
		elseif lineCount = 2 then
			costValue := 1.10;		
		elseif lineCount = 3 then
			costValue := 1100.0;		
		endif;

		costs.add(costValue);
		
		debtor := app.myRoot.getDefaultDebtor(self.getTerminal);
		debtorRate := debtor.serviceRates[service];
		if debtorRate = null then
			create debtorRate transient;
			debtorRate.setProxy(service, debtor);
			rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);
			transients.add(debtorRate);
		else
			rateEntry := debtorRate.rateEntries.first;
			self.updateInvoiceRateEntry(debtorRate, rateEntry, start, expiry, ignoreEntry, costs, 0, 0, null,null);
		endif;
		self.assertNoTrxErrorsOrWarnings();
	endforeach;


epilog

	if transients &lt;&gt; null then
		transients.purge();
		delete transients;
	endif;
	delete costs;
end;</source>
        <access>protected</access>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
    </JadeMethod>
    <JadeMethod name="cargoDPHInterfaceRates" id="90e60bd7-f212-48b2-9116-f927c897b826">
