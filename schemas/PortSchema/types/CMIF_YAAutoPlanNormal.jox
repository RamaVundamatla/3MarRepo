    <JadeMethod name="isCargoTypeForContents_Match" id="7fd54e1c-6d06-49e3-ba22-f38664ff000d">
        <source>isCargoTypeForContents_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/10/2025	navkc1 JIRA 36148 AAT | RotaBox ISO Type and New Attributes - Yard Allocation

*/

vars

begin
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Do we have a match?
	if _yaData.matches(self.myTrackedItem.getCargoTypeForContents()) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
