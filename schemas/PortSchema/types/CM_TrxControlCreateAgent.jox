    <JadeMethod name="trxCreateStops" id="80dd9a29-b2a6-4550-b15a-141eafeb8990">
        <updating/>
        <source>trxCreateStops(_theTI : CM_TrackedItem input; _theStops : IntegerArray; pIgnoreWarnings : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		This TRX is used to ADD stops to a TI. Duplicates will not be created, but what ever global constant
//				integers are in the passed in array will be created against the TI
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	index		: Integer;
	stopsTable	: CM_StopsTable;
	tiSet		: CM_TISet;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	// do the validation here
	if _theStops.size = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Stops To Create');
	endif;
	
	if not _passport.noErrors() then
		return;		// note that this gets "ignored" in the eplog
	endif;
	
	// cnwrl1 11/05/2009 PAR 19574 - CCMS 1791 - start of coding
	// If the stop is for a stopsTable with requiresInfoType = DeliveryRelease
	// then the TI deliveryRelease must be null.
	foreach index in _theStops do : stops_loop
		stopsTable	:= app.myRoot.allStopsTable[ index ];
		if stopsTable = null or stopsTable.requiresInfoType &lt;&gt; DeliveryRelease then
			continue stops_loop;
		endif;
		if _theTI.deliveryRelease &lt;&gt; null then
			app.raiseCMException3(	WARN_STOP_ADD_CHECK,
									stopsTable.heading.display,
									_theTI.id.display,
									app.getErrorString( Delivery_Release_Number ).display,
									null,
									null );
			return;
		endif;
	endforeach stops_loop;
	
	app.setContinueCMExceptions(false);
	
	create tiSet transient;	 //+ cnwmd1, Par 19903
	tiSet.add( _theTI );
	
	//jlier1 TFS 65868 28/8/24
	if _passport.myStateChangeController &lt;&gt; null then
		_passport.myStateChangeController.initForObjects(tiSet); 
	endif;
	
	beginTransaction;
	//app.myUtilityCA.utlCreateStops(_theTI, _theStops, _passport); //- cnwmd1, Par 19903
	app.myUtilityCA.utlCreateStopsForTIs(tiSet, _theStops, _passport); //+ cnwmd1, Par 19903
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete tiSet;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theStops" type="IntegerArray"/>
        <Parameter name="pIgnoreWarnings" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateStopsForBOLs" id="6f1ad705-5e0b-4819-804a-1637e37638f6">
        <updating/>
        <source>trxCreateStopsForBOLs(_bolInSet : CM_BOLSet; _theStops : IntegerArray; _passport : CM_Passport input) updating;
//---------------------------------------
// Created: Aug 2007 cnwrs1 ccms 1017
//---------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);


	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	// do the validation here
	self.raiseExceptionIfNull(_theStops, 'Stops Array');
	self.raiseExceptionIfNull(_bolInSet, 'Cargo Set');	
	if _theStops.isEmpty() then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Stops To Create');
	endif;
	if _bolInSet.isEmpty() then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Cargo Items selected');
	endif;	
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;
	
	app.setContinueCMExceptions(false);
	beginTransaction;
	
	app.myUtilityCA.utlCreateStopsForBOLs(_bolInSet, _theStops, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
	
end;
</source>
        <Parameter name="_bolInSet" type="CM_BOLSet"/>
        <Parameter name="_theStops" type="IntegerArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateStopsForTIMasts" id="fe5652d9-04a6-4b38-99f4-7e1aeb488156">
        <updating/>
        <source>trxCreateStopsForTIMasts(_tiSet : CM_TIMasterSet; _theStop : CM_StopsTable; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation

*/

vars
	tmpTI : CM_TIMaster;
	int : Integer;
//	tmpStopTable : CM_StopsTable;
	isCEDOStop : Boolean;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);


	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	// do the validation here
	self.raiseExceptionIfNull(_theStop, 'Stops Array');
	self.raiseExceptionIfNull(_tiSet, 'Cargo Set');	
	if _theStop = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Stops To Create');
	endif;
	if _tiSet.isEmpty() then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Cargo Items selected');
	endif;	

	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;
	
	app.setContinueCMExceptions(false);
	beginTransaction;
	
	app.myUtilityCA.utlCreateStopsForTIMasts(_tiSet, _theStop, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_tiSet" type="CM_TIMasterSet"/>
