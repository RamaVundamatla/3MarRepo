    <JadeMethod name="refreshGateAreaRow" id="07ac8b78-fa6d-4676-a0ab-00e77ad29c49">
        <source>refreshGateAreaRow(_row :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table		:CM_DataTable;
	usage		:CM_GateAreaUsage;
	str			:String;
begin 
	table 	:= tblGateAreas;
	usage	:= table.accessRow (_row).itemObject.CM_GateAreaUsage;
	str		:= usage.getAttributeStringForDefArray(table.allTblDataEntRows);
	
	table.setCellText (_row, 1, str);
									
	self.setGateAreaPicture (usage, _row);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="refreshGateAreaRows" id="1ee3941b-9d78-45cd-9c4b-1f8acffc9621">
        <source>refreshGateAreaRows(_gateArea :CM_GateArea) protected;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table			:CM_BaseTable;
	row, rows		:Integer;
	otherGateArea	:CM_GateArea;
begin
	table	:= tblGateAreas;
	rows 	:= table.rows;
	
	foreach row in table.fixedRows + 1 to rows do
		if row = table.row then
			continue;	// current row should already be updated
		endif;
		otherGateArea := table.accessRow (row).itemObject.CM_GateAreaUsage.myGateArea;
		if otherGateArea &lt;&gt; _gateArea then
			continue;	// different gate area
		endif;
		self.refreshGateAreaRow (row);
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gateArea" type="CM_GateArea"/>
    </JadeMethod>
    <JadeMethod name="resetNotifications" id="a6923d07-e6cf-4476-aee0-b8e39d763dcb">
        <source>resetNotifications();
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	// i need to re-register for notes that cause me to update this list displayed
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_GATE_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_GATE_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_GATE_UPDATE), Response_Continuous, null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="332f32f2-ef89-4011-8f8f-6aeabf97ff51">
        <updating/>
        <source>setControlsForAddEdit()updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/02/2010	cnwcs5		par 18061 - RFID prompt
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod;
	
	txtName.readOnly	:= false;
	cmbICArea.enabled	:= true;
	chkEntry.enabled	:= true;
	chkExit.enabled		:= true;
	chkPrompt.enabled	:= true;	// 23/02/2010 cnwcs5 par 18061 
	self.chkBarrierCodes.enabled:=true; //jlier1 TFS 57936 19/5/23
	cmbTroubleIn.enabled			:= false;
	tblGateAreas.userInputEnabled	:= true;
	tblGateLanes.userInputEnabled	:= true;
epilog

end;</source>
