		if ti = null then
			ti := self.allOnsiteTIsByIdCargoType[nextID, _cargoType.id].CM_TrackedItem;
			if ti = null then
				ti := self.myTerminal.allOnsiteTIsByIdCargoType[nextID, _cargoType.id].CM_TrackedItem;
				if ti = null then
					write class.name &amp; "::" &amp; method.name &amp; Tab &amp; ti.String &amp; Tab &amp; nextID &amp; Tab &amp; _cargoType.id.String &amp; Tab &amp; 
						_cargoType.description;
					return nextID;
				endif;
