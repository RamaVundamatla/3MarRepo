	self.deleteTrackedItem(self.getTrackedItem(ContainerId), false);
	container := self.addCargoOpts(ContainerId, /*"2200"*/"2231", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), TI_CargoType_Generator); // TFS 46767 
	
	create tiSet transient; // TFS 46767 - above, need reefer ISO type for generator...
	tiSet.add(container);
	
	beginLoad;
	proxyToDoTask := toDoTaskDesc.pxyCreateUpdateProxy();
	endLoad;
	
	proxyToDoTask.setProxy(	toDoTaskDesc.description,	//pDesc:String;
						toDoTaskDesc.shortDescription,	//pShortDesc:String;
						toDoTaskDesc.sortKey,	//pSortKey:Integer;
						toDoTaskDesc.reportDescription,	//pReportDesc:String;
						toDoTaskDesc.emptyReportColumn,	//pEmptyReportColumn: Integer;
						app.myRoot.allTransactionTypesByDesc["Fueled"],	//_trxTypeOnCompletion : CM_TransactionType;			// 22 Feb 2010 RJS - PAR 22099
						null,	//_trxTypeOnCreation : CM_TransactionType; //cnwrs1 CCMS 1826 29 July 2010
						selectedCargoTypes,	//pAllCargoTypes : Collection;
						toDoTaskDesc.allResourceTypes,	//pAllResourceTypes : Collection;//18 Dec 2009	NDL	CCMS MES 1006
						toDoTaskDesc.requiresWorkOrder,	//_requiresWorkOrder : Boolean;
						toDoTaskDesc.requiredExtraInfo,	//_requiredExtraInfo : String;
						toDoTaskDesc.allAllowedReleaseTerms,	//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
						toDoTaskDesc.allAllowedEditSubTerms,	//_selectedSubTerminals : CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
						TODO_TYPE_GROUP_TI,	//02/11/2022 navds20 TFS #56635[54261]
						null,	//02/11/2022 navds20 TFS #56635[54261]
						null,	//02/11/2022 navds20 TFS #56635[54261]
						toDoTaskDesc.doNotBlockRTL
						);
	
	 app.myTrxUA.trxUpdateToDoTaskDesc(proxyToDoTask, app.myPassport);
	 self.assertNoTrxErrorsOrWarnings();
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];  
		
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	
	// check that TRANS_TYPE_FUELED transaction is created
	tiTrn := container.allTransactions.last;
	self.assertTrue(tiTrn.isKindOf(CM_Fuel));
	assertEqual(tiTrn.id, ContainerId);
	assertEqual(tiTrn.typeString, "Fueled");
	assertEqual(container.CM_Generator.fuelledDT, tiTrn.dateTime);
	delete tiSet;
	
	//setup new todo task desc with TRANS_TYPE_SEALED
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];
	self.deleteToDoTaskDescription(toDoTaskDesc);
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_SEALED);
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode1);
	self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create tiSet transient;
	tiSet.add(container);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];  
		
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	
	// check that TRANS_TYPE_SEALED transaction is created
	tiTrn := container.allTransactions.last;
	self.assertTrue(tiTrn.isKindOf(CM_Seal));
	assertEqual(tiTrn.id, ContainerId);
	assertEqual(tiTrn.typeString, "Sealed");
	assertEqual(container.CM_Container.getSealDT, tiTrn.dateTime);
	delete tiSet;
	
	//setup new todo task desc with TRANS_TYPE_FUMIGATE
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];
	self.deleteToDoTaskDescription(toDoTaskDesc);
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_FUMIGATE);
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode1);
	self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create tiSet transient;
	tiSet.add(container);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];  
		
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	
	// check that TRANS_TYPE_FUMIGATE transaction is created
	tiTrn := container.allTransactions.last;
	self.assertTrue(tiTrn.isKindOf(CM_Fumigation));
	assertEqual(tiTrn.id, ContainerId);
	assertEqual(tiTrn.typeString, "Fumigated");
	assertEqual(container.CM_Container.fumigateDT, tiTrn.dateTime);
	delete tiSet;
	
	//setup new todo task desc with TRANS_TYPE_SWEEP
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];
	self.deleteToDoTaskDescription(toDoTaskDesc);
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_SWEEP);
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode1);
	self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create tiSet transient;
	tiSet.add(container);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];  
		
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	
	// check that TRANS_TYPE_SWEEP transaction is created
	tiTrn := container.allTransactions.last;
	self.assertTrue(tiTrn.isKindOf(CM_Sweep));
	assertEqual(tiTrn.id, ContainerId);
	assertEqual(tiTrn.typeString, "Swept");
	assertEqual(container.CM_Container.sweptDT, tiTrn.dateTime);
epilog
	delete tiSet;
	delete selectedCargoTypes;
	delete proxyToDoTask;
end;</source>
