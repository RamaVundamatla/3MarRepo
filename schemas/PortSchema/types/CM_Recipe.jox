        <Parameter name="_instructions" type="String"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="85617de7-9164-4677-ae5e-7a1d34baf68a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	if _property.name = "allComponentsByCode"
	or _property.name = "allComponentsByOrder"
	or _property.name = "myCargoType"
	then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
