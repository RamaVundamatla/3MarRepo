end;</source>
    </JadeMethod>
    <JadeMethod name="deleteEntity" id="19f2a0f9-1d6a-43e2-926e-8544a5d92dbc">
        <updating/>
        <source>deleteEntity() updating;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity		: CM_MenuUserItem;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	if (not self.listObject.isKindOf(CM_MenuUserItem)) then
		app.msgBox('You may not delete this item','Dissallowed', 0);
		return;
	endif;
	
	menuEntity := self.listObject.CM_MenuUserItem;
	
	if not menuEntity.allChildren.isEmpty then
		app.msgBox('The selected folder still has entries. You may only delete a folder when it is empty', 'Error', 0);
		return;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteMenuUserItem(menuEntity.CM_MenuUserItem, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Delete Entry', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

	self.displayTree(true, null);

end;</source>
    </JadeMethod>
    <JadeMethod name="displayTree" id="adff4ec2-0156-4a95-b167-46286846d569">
        <updating/>
        <source>displayTree(_refresh : Boolean; _callBackMethod : String) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity		: CM_MenuEntity;
	expandLevel		: Integer;
begin
	if self.allMenuRoots.isEmpty then
		return;
	endif;
	
	if CM_MenuRootReportUserTerminal.hasInstance(self.allMenuRoots.first) then
		expandLevel := 3;
	else
		// as expansion is the done lower down
		if self.allMenuRoots.size &gt; 2 then
			expandLevel := 2;
		else
			expandLevel := 3;
		endif;	
	endif;
	
	if _refresh then
		self.getExpandedObjects();
	endif;
	
	self.clear();

	foreach menuEntity in self.allMenuRoots do
		// Par 9715 check if valid object otherwise dont display
		if not global.isValidObject(menuEntity) then
			continue;
		endif;
	
		if _callBackMethod &lt;&gt; null then
			if not self.form.sendMsgWithParams(_callBackMethod, menuEntity).Boolean then
				continue;
			endif;
		endif;
		

		self.addMenuEntity(menuEntity, _callBackMethod, expandLevel);
	endforeach;

	if _refresh then
		self.setExpandedObjects();
	endif;
	
	if self.listCount &gt;= 1 then
		self.listIndex := 1;
	endif;
	
end;</source>
        <Parameter name="_refresh" type="Boolean"/>
        <Parameter name="_callBackMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="getExpandedObjects" id="cadf72b6-ffee-45e0-b780-d6ae48949e55">
        <source>getExpandedObjects();
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx,
	cnt		: Integer;
begin
	self.allExpandedObjects.clear();
	cnt := self.listCount();
	
	foreach idx in 1 to cnt do
		if self.itemExpanded[idx] = true then
			self.allExpandedObjects.add(self.itemObject[idx]);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="getRootOfCurrentEntity" id="fd5f55b2-a2cc-42f5-9dcc-93d14f802316">
        <source>getRootOfCurrentEntity() : CM_MenuRoot;
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity 		: CM_MenuEntity;
begin
	menuEntity := self.itemObject[self.listIndex].CM_MenuEntity;
	if menuEntity.isKindOf(CM_MenuUserItem) then
		return menuEntity.CM_MenuUserItem.getMyMenuRoot();	
	elseif menuEntity.isKindOf(CM_MenuRoot) then
		return menuEntity.CM_MenuRoot; 
	endif;
end;</source>
        <ReturnType type="CM_MenuRoot"/>
    </JadeMethod>
    <JadeMethod name="getTeminalOfCurrentEntity" id="1ea58e46-30de-4add-af88-c2bf5f2d1d39">
        <source>getTeminalOfCurrentEntity() : CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity 		: CM_MenuEntity;
begin

	on Exception do app.invalidObjExHandler(exception, Err_MenusNeedReload);
	
	//PAR 10305 - if no security role set for the user then no items in the list.
	if self.listIndex &gt; 0 then
		menuEntity := self.itemObject[self.listIndex].CM_MenuEntity;
	endif;
	
	if menuEntity &lt;&gt; null then
		return menuEntity.getMyTerminal();	
	else
		return app.getMyTerminalDO_NOT_USE();	
	endif;					

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="isMenuEntityDeprecated" id="8d7123f1-a0cd-42ee-b8d4-fd85afac6632">
        <source>isMenuEntityDeprecated(_menuEntity : CM_MenuEntity) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2013	cnwmc5	Initial creation		PAR 33186

*/

vars

	id : String;
	
begin

	if _menuEntity = null or not _menuEntity.isMenuUserDtl then
		return false;
	endif;
	
	id := _menuEntity.getMenuId();
	
	if id = "_dtl428" then
		if app.myRoot.isDeprecated("8.2.1") then
			return true;
		endif;
	elseif id = "_dtl880" then
		if app.myRoot.isDeprecated("8.2.2") then
			return true;
		endif;
	endif;
	
	return false;
/*
	//cnwmc5 - 18/12/2012 - SFW 1323
	//Gate In/Out - menu item
	if app.myRoot.isDeprecated("8.2.1") then 
		if _menuEntity.isKindOf(CM_MenuUserDtl) and _menuEntity.CM_MenuUserDtl.myMenuDtl.menuId = "_dtl428" then//heading = "Gate In/Out" then
			return true;
		endif;
	endif;
	
	//cnwmc5 - 18 Dec 2013 - PAR 33186
	//General Cargo Voyage Operations - menu item
	if app.myRoot.isDeprecated("8.2.2") then 
		if _menuEntity.isKindOf(CM_MenuUserDtl) and _menuEntity.CM_MenuUserDtl.myMenuDtl.menuId = "_dtl880" then
			return true;
		endif;
	endif;
	
	return false;
	
	*/
epilog

end;</source>
        <Parameter name="_menuEntity" type="CM_MenuEntity"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveEntityToFolder" id="f9697b87-4a40-4670-b898-e3ad7792a99d">
        <updating/>
        <source>moveEntityToFolder(_menuRootSet : CM_MenuEntitySet) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	folderPicker				: CMUI_OrganizeMenu;
	childEntity,
	fromEntity,
	toEntity,
	theParent					: CM_MenuEntity;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	
	fromEntity := self.listObject.CM_MenuEntity;
	
	if fromEntity = null then
		app.msgBox('Please right click on a menu item to move it to a new folder','Nothing selected',0);
		return;
	endif;
	
	if fromEntity.isKindOf(CM_MenuRoot) then
		app.msgBox('You may not move this menu item to a new folder','Error',0);
		return;
	endif;
	
	create folderPicker transient;
	//set up the picker form
	folderPicker.lstBox.allMenuRoots.clear();
	_menuRootSet.copy(folderPicker.lstBox.allMenuRoots);
	self.allExpandedObjects.copy(folderPicker.lstBox.allExpandedObjects);
//??	folderPicker.displayHeadersOnly := true;
	folderPicker.caption := 'Select Folder...';
	folderPicker.showModal;
	if folderPicker.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	toEntity := folderPicker.mySelectedMenuEntity;
	if toEntity = fromEntity then
		app.msgBox('You cannot move a folder into itself.', 'Error', 0);
		return;
	endif;
	//test to see whether the folder that we are moving to is not a child!! This will cause
	//a stack overflow when we go display the tree
	foreach childEntity in fromEntity.allChildren do
		if childEntity = toEntity then
			app.msgBox('You cannot move a menu entity inside one of its child entities','Error',0);
			return;
		endif;
	endforeach;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateReparentMenuUserItem(toEntity, fromEntity.CM_MenuUserItem, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Move Entry', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.displayTree(true,null);	

epilog
	delete folderPicker;	
end;</source>
        <Parameter name="_menuRootSet" type="CM_MenuEntitySet"/>
    </JadeMethod>
    <JadeMethod name="organizeMenu" id="7983ecc2-9490-4264-9029-2d2cc7e3d30e">
        <updating/>
        <source>organizeMenu(_menuRootSet : CM_MenuEntitySet) updating;
// ---------------------------------------------------------------------------
// Created:     05 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	folderPicker				: CMUI_OrganizeMenu;
	fromEntity,
	toEntity,
	theParent					: CM_MenuEntity;
	cnt,
	toSubScript	: Integer;	
begin
		
	create folderPicker transient;
	//set up the picker form
	folderPicker.lstBox.allMenuRoots.clear();
	_menuRootSet.copy(folderPicker.lstBox.allMenuRoots);
	self.getExpandedObjects();
	self.allExpandedObjects.copy(folderPicker.lstBox.allExpandedObjects);
	folderPicker.caption := 'Drag and drop to organise...';
	folderPicker.showModal;

	self.displayTree(true, null);

epilog
	delete folderPicker;	
end;</source>
        <Parameter name="_menuRootSet" type="CM_MenuEntitySet"/>
    </JadeMethod>
    <JadeMethod name="pictureClick" id="be3bd5cb-5d59-4bff-afff-4c170dcf3687">
        <updating/>
        <source>pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity		: CM_MenuEntity;
begin

	if (not listbox.itemHasSubItems(picIndex)) then
		return;
	endif;
	
	self.expandItem(picIndex);
	
	if (not listbox.itemObject[picIndex].isKindOf(CM_MenuEntity)) then
		return;
	endif;
	
	menuEntity := listbox.itemObject[picIndex].CM_MenuEntity;
	//note! We've already changed the itemExpanded property	
	if menuEntity = null or not app.isValidObject(menuEntity) then //par16803
		return;
	endif;
	if listbox.itemExpanded[picIndex] = true then
		listbox.itemPicture[picIndex] := menuEntity.pictureButton;
		listbox.itemPictureType[picIndex] := listbox.ItemPictureType_Open;
	else
		listbox.itemPicture[picIndex] := menuEntity.pictureButtonDown;	//getPictureButtonDown;
		listbox.itemPictureType[picIndex] := listbox.ItemPictureType_Closed;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="renameEntity" id="f8109900-9c4b-4429-ba3b-82d1e657b9ca">
        <updating/>
        <source>renameEntity() updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	heading				: String;
	inputBox			: CMUI_InputBox;
	newHeader,
	pxyHeader			: CM_MenuUserHdr;
	menuEntity			: CM_MenuEntity;
begin
	
	menuEntity := self.listObject.CM_MenuEntity;
	
	if not menuEntity.isKindOf(CM_MenuUserItem) then
		app.msgBox('You may not rename the menu entity', 'Error', 0);
		return;
	endif;
	
	create inputBox transient;
	create pxyHeader transient;
	
//	inputBox.init(app.getErrorString(LBLRenameHeader), app.getErrorString(LBLEnterFolderName), menuEntity.CM_MenuUserItem.heading, 20, TextBox.DataType_AlphaNumeric, false);	// cnwrl1 05/06/2009 PAR 19574 - what it was
	inputBox.init(	app.getErrorString(LBLRenameHeader), app.getErrorString(LBLEnterFolderName),
					menuEntity.CM_MenuUserItem.heading, 20, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
	
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;
	heading := inputBox.txtInput.text;
	if heading = null then
		return;
	endif;
	
	beginTransaction;
		menuEntity.CM_MenuUserItem.setHeading(heading);
	commitTransaction;
	
	self.displayTree(true, null);
	
epilog
	delete pxyHeader;
	
	if inputBox &lt;&gt; null then
		delete inputBox;
	endif;
end;</source>
    </JadeMethod>
