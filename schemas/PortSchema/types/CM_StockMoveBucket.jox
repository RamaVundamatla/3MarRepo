    <JadeMethod name="init" id="01fe9341-3201-457b-a363-a1e242481e35">
        <updating/>
        <source>init(_date : Date; _openingQuantity: Integer; _openingWeight : Decimal; _openingVolume : Real; _parent : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.date				:= _date;
	
	self.openingQuantity	:= _openingQuantity;
	self.openingWeightKgs	:= _openingWeight;
	self.openingVolume		:= _openingVolume;

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_openingQuantity" type="Integer"/>
        <Parameter name="_openingWeight" type="Decimal"/>
        <Parameter name="_openingVolume" type="Real"/>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="product" id="7a82d216-4b2d-4cf7-a49a-f6e1ee0684ec">
        <methodInvocation>mapping</methodInvocation>
        <source>product(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//NB This mapping method is to be used in subclass to return for example:
	//self.mySOHLocation.myProduct.code
	if set then
		app.raiseSetVirtualError(Class.name, method.name);

	else
		_value  := null.String;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="productType" id="bcdd3435-f61f-4f77-b680-0995391c28ce">
        <methodInvocation>mapping</methodInvocation>
        <source>productType(set: Boolean; _value: Integer io) mapping;
//--------------------------------------------------------------
//Created: 09 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	//NB This mapping method is to be used in subclass;
	if set then
		app.raiseSetVirtualError(Class.name, method.name);

	else
		_value  := null;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeTrackedItem_DocketCorrec" id="9481ae4a-ffed-4743-a32e-0d796c5981d8">
        <updating/>
        <source>removeTrackedItem_DocketCorrec( _type : Integer; _moveOut : Boolean; _ti : CM_TrackedItem; _ts : TimeStamp;
			_quantity: Integer; _weight : Decimal; _volume : Decimal; _txn : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2008 by cnwvu1
// ---------------------------------------------------------------------------
vars
	stkMove	: CM_StockMovement;
	
begin

	stkMove := self.allStockMovements[_type];
	if stkMove = null then
		create stkMove as self.getStockMovementClass() persistent;
		stkMove.init(_type, self);
	endif;

	self.adjustQuantity		:= self.adjustQuantity + _quantity;
	self.adjustVolume		:= self.adjustVolume + _volume;
	self.adjustWeightKgs 	:= self.adjustWeightKgs + _weight;

	if _moveOut then
		stkMove.removeTrackedItem_DocketCorrec(_ti, _ts, _quantity, _weight, _volume, _txn);
	else
		stkMove.addTrackedItem_DocketCorrect(_ti, _ts, _quantity, _weight, _volume, _txn);
	endif;
	
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_moveOut" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
</Class>
