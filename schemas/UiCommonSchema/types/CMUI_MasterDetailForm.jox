    <JadeMethod name="addObjectToDetailTable" id="433e15be-1f2f-4555-9db6-bc9b39fb2afb">
        <updating/>
        <source>addObjectToDetailTable( _obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     Developer to re-implement and inheritMethod
//			 
// ----------   ----------  --------------------------------------------------
vars
	backColour,
	rowIdx : Integer;
	tmpTable : CM_DataTable;
	rowArray : EntTableRowArray;
//	newDateCntrl : CMUI_DateBox;
//	newTimeCntrl : CMUI_TimeEntry;
	newTxtBox : CMUI_TextBox;
	newCombo : CMUI_ComboBox;
	assist : CMUI_Assistant;
	cmif		: CMIF_Object;
	cm			:CM_Object;
begin	
	if _obj = null then
		return;
	endif;
	
	tmpTable := self.tblDataDetail;
	rowArray := tmpTable.allTblDataEntRows;
		
	assist := self.myAssistant;
	
	rowIdx := tmpTable.rows+1;
	if _obj.isKindOf(CMIF_Object)then 
		tmpTable.addItemAt(_obj.CMIF_Object.getAttributeStringForDefArray(rowArray), rowIdx);
	else
		tmpTable.addItemAt(_obj.CM_Object.getAttributeStringForDefArray(rowArray), rowIdx);
	endif;
	tmpTable.accessRow(rowIdx).itemObject := _obj;
		
	if rowIdx mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;			
	tmpTable.accessRow(rowIdx).backColor := backColour;	
	

end;
















/// old code /*
/*
	idx			: Integer;
begin
	if _obj = null then
		return;
	endif;
	
	self.resynchObject(_obj);
	idx := _tbl.addItem(self.getDataRowForDef(_obj, _tbl.myEntTableDef));
	_tbl.accessRow(idx).itemObject := _obj;
	if idx mod 2 = 0 then
		_tbl.accessRow(idx).backColor := self.colorRow1;
	else
		_tbl.accessRow(idx).backColor := self.colorRow2;
	endif;
end;
*/</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addObjectToMasterTable" id="ad826286-708a-4eae-b97f-007b1676867c">
        <source>addObjectToMasterTable(_tbl : CM_DataTable input; 
						_obj : CM_Object;
						_numSearched,
						_numFound : Integer;
						_breakOut : Boolean output);
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     Developer to re-implement and inheritMethod
//			 
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	cmifMonitor			: CMIF_Monitor;
	monRtn,
	idx					: Integer;
	lastUpdated			: Decimal [20];
	
begin
	if not CM_Object.hasInstance(_obj) then
		return;
	endif;
	

	idx := _tbl.addItem(self.getDataRowForDef(_obj, _tbl.myEntTableDef));
	_tbl.accessRow(idx).itemObject := _obj;
	

	if _numSearched mod 50 = 0 then
		cmifMonitor := app.myPassport.myCMIFMonitor;
		if cmifMonitor &lt;&gt; null and 
		   (not cmifMonitor.updateProgress(null, _numSearched, _numFound)) then
			_breakOut := true;
		endif;
	endif;
	
end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_numSearched" type="Integer"/>
        <Parameter name="_numFound" type="Integer"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
