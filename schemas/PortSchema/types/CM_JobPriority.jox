    <JadeMethod name="validateMe" id="eb3e489e-ec50-4ac7-b797-71a05a95124b">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:		04 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.craneType = 0 then
		app.raiseCMException2(ERR_INVALID_VALUE, "Crane Type", "Please select a crane type - Single Lift, Twin Lift etc.", null, null);
	endif;
	if self.jobType = 0 then
		app.raiseCMException2(ERR_INVALID_VALUE, "Job Type", "Please select a job type - Discharge, Load etc.", null, null);
	endif;
	if self.priority = 0 then
		app.raiseCMException2(ERR_INVALID_VALUE, "Job Priority", "A priority greater than 0 must be entered", null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
