    <JadeMethod name="doShowCargoEnquiry" id="c3115e71-073a-4fd8-9182-5fa130635e17">
        <source>doShowCargoEnquiry(_trackedItem : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Aug 2023	navlw1	Bug 60046:[60047] FR | 53429 - VBS MTN - Enquiry Screen issues

*/

vars
	tisa		: CM_TIArray;
	selObj 		: Object;
	vbsSlot		: CM_VehicleBookingTimeSlot;
begin
	create tisa transient;
	
	selObj := self.tblData.allSelectedObjects.first;
	if selObj = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst),app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	endif;
	
	if _trackedItem&lt;&gt; null then
		tisa.add(_trackedItem);
	endif;

	self.myAssistant.showCargoEnquiryForTIs(tisa.first, tisa,self.myMasterMenuAction, false);
epilog
	delete tisa;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="83d93991-8621-4042-b0cd-7b847df15b37">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
27 Sep 2022			navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots
14 Oct 2022			navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications
24 Apr 2023 		navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
10 Aug 2023			navlw1	ChangeRequest 59132:[59133] EUP | VBS Audits
*/

vars
	xLeft 			: Real;
	yTop			: Real;
	vehicleBooking 	: CM_VehicleBookingTimeSlot;
begin
	
	self.mnuInspectObject.visible   := false;	
	self.mnuVbsDeleteSlot.visible   := false;
	self.mnuVbsTransferSlot.visible := false;
	self.btnEmailLayout.enabled 	:= false;
	self.mnuSendEmail.enabled	    := false;
	self.mnuVbsCopySlots.enabled    := false;
	self.mnuVbsCopySlots.visible    := true;
	self.mnuContextSep01.visible    := true;
	self.mnuVbsSendLoadNA.visible   := false; //jlier1 TFS 58839 28/6/23
	self.mnuSendToReport.visible	:= false; //jlier1 6/7/23 does nothing
	self.mnuVbsTransferSlot.enabled := false; //07.08.2023 navma1 #59700
	
	vehicleBooking := self.tblData.accessRow(self.tblData.row).itemObject.CM_VehicleBookingTimeSlot;
	
	xLeft := x;
	yTop  := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);

	if vehicleBooking &lt;&gt; null then
		
		if app.isAllowedToInspect then
			self.mnuInspectObject.visible := true;
		endif;	
		
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.mnuVbsDeleteSlot.visible   := true;
			self.mnuVbsTransferSlot.visible := true;
			self.mnuVbsSendLoadNA.visible  := vehicleBooking.canSendLoadNotification and 
											  app.myRoot.getFirstActiveEWSForEndpoint(ETRow_LoadNotification) &lt;&gt; null; //jlier1 TFS  58839 28/6/23
		endif;

		if  app.myCurrentUserCan(self.myTerminal, PmAdmVbsSendEmails) then
			self.mnuSendEmail.visible := true;
			self.mnuSendEmail.enabled := true;
		endif;
		
		if app.myCurrentUserCan(self.myTerminal, PmAdmVbsEmailConfigureMaint) then
			self.btnEmailLayout.enabled := true;
		endif;
		
		if self.enableCopySlot then											//07.08.2023 navma1 #59700
			self.mnuVbsCopySlots.enabled := true;
		endif;
		
		if self.enableTransferSlot then										//07.08.2023 navma1 #59700
			self.mnuVbsTransferSlot.enabled := true;
		endif;
		
		self.mnuAuditsForObject.visible := vehicleBooking.hasAudits; // 10.08.2023 navlw1 tfs #59132:#59133
	endif;
	
	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);
	
	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
