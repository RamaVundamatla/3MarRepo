    <JadeMethod name="typeString" id="a9c8667a-36a6-4be2-9dcd-e48fb5bbcb0c">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(set: Boolean; _value: String io) mapping;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//
// 14 Mar 2013	PJS		PAR #31232
//--------------------------------------------------
vars

begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		
		// 31232
		_value := myVoyage.getVoyageTypeString;
	
	//	_value := app.vesselStructureTypeEnumToStr(self.type);  31232
	endif;
end;</source>
