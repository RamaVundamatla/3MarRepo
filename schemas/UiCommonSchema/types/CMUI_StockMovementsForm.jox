    <JadeMethod name="loadVoyages" id="1529998a-93b4-47d9-b0f3-d9420db93a03">
        <updating/>
        <source>loadVoyages() updating;
//--------------------------------------------------------------
//Created: September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyage : CM_Voyage;
	idx : Integer;
	dac : CM_DataAccessController;
	operatorSet : CM_OperatorSet;

begin
	create operatorSet transient;

	cmbVoyageLocn.clear();	

	tblEntQuery.setValueByName(ETRow_VoyageLocation, null);	
//	self.myFiltLC := null;				
	
	cmbLocation.clear();

	dac := self.getOperatorAccessController;

	foreach voyage in self.myTerminal.allVoyagesByCode do
		if not voyage.canDataAccessGroupAccessSelf(dac, operatorSet) then
			continue;
		endif;
		
		idx := cmbLocation.addItem(self.displayEntryLocation(voyage));
		cmbLocation.itemObject[idx] := voyage;
	endforeach;			
	

	//if cmbLocation.listCount &gt; 0 then  // isValid added to stop error if voyage had been deleted by other user. related to par 9773
	//if cmbLocation.listCount &gt; 0 and app.isValidObject(self.myFiltVoyage) then Par12006
	if cmbLocation.listCount &gt; 0 then
	//Have to check if the filterVoyage is null first then check if it is vaild as the isValidObject returns false not only if it is invalid but
	//also if it is a null.
		if self.myFiltVoyage = null then
			self.myFiltVoyage := cmbLocation.itemObject[1].CM_Voyage;
			//Is valid object moved to here to check for null first. Par12006 04/07/2006
			if app.isValidObject(self.myFiltVoyage) then
				cmbLocation.listObject := self.myFiltVoyage;
				tblEntQuery.setValueByName(ETRow_Location, self.myFiltVoyage.code);
			endif;
		endif;
	else
			tblEntQuery.setValueByName(ETRow_Location, null);
	endif;
		
epilog
	delete operatorSet;
end;</source>
    </JadeMethod>
