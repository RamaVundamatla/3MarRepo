    <JadeMethod name="valVentilationReading" id="c3e034e3-67fe-4137-818e-832be13dcc68">
        <source>valVentilationReading(_ventilationParams : CMIF_VentReading);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	if _ventilationParams.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'tempParams.myContainer', 'myContainer', null);
		return;
	endif;

	if not _ventilationParams.dateTime.isValid then
		app.raiseCMException2(ERR_INVALID_VALUE, "date/time", "Make sure the date and time fields are valid.", 'dateTime',null);
		return;
	endif;
	
	if not _ventilationParams.dateTime.date &lt;= app.actualTimeServer().date then
		app.raiseCMException2(ERR_INVALID_VALUE, "date", "You cannot add a temperature reading later than today.", 'dateTime',null);
		return;
	endif;

epilog

end;</source>
        <Parameter name="_ventilationParams" type="CMIF_VentReading"/>
    </JadeMethod>
