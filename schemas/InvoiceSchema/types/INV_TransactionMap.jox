</source>
    </JadeMethod>
    <JadeMethod name="resetCopy" id="bca37797-8c9f-4134-a6b5-20664fb46245">
        <updating/>
        <source>resetCopy() updating, protected;
// 33535
vars

begin
	if self.modePropertyUpdate = self.ModeProperty_CargoType or
	   self.modePropertyUpdate = self.ModeProperty_ProductGroup or
	   self.modePropertyUpdate = self.ModeProperty_Product then
		self.frmList.visible := false;
	endif;

	self.frmCopy.visible := false;
	self.lstData.enabled := true;
	self.frmToolbar.enabled := true;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetEdit" id="e715f174-dbc8-488d-8610-c8580059b8ac">
        <updating/>
        <source>resetEdit() updating, protected;
// 33535 clear edit frames on invalid item
vars

begin
	self.frmList.visible := false;
	self.frmListMoves.visible := false;
	self.lstData.enabled := true;
	self.frmToolbar.enabled := true;
	self.frmPropQty.visible := false;
	self.frmPropQtyRange.visible := false;
	self.frmDebtors.visible := false;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetReplace" id="b844dde8-2e83-44c0-a72d-5fdb523758d0">
        <updating/>
        <source>resetReplace() updating, protected;
// 33535
vars

begin
