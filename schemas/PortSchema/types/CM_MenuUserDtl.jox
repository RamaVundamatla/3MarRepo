    <JadeMethod name="hasWebReports" id="b1cc8782-adc2-4a23-86fa-71cf21b940a2">
        <source>hasWebReports(): Boolean;
// -------------------------------------------
// Created 01 November 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myMenuItem &lt;&gt; null and self.myMenuItem.isKindOf(CM_QryReport) then
		return self.myMenuItem.CM_QryReport.reportAvailability = CM_QryReport.ReportAvailability_Web or
		self.myMenuItem.CM_QryReport.reportAvailability = CM_QryReport.ReportAvailability_WebAndJMT;
	endif;
	
	return false;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
