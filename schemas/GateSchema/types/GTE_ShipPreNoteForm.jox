    <JadeMethod name="doSave" id="be1b3df1-9ffa-4b19-bc66-5adc24b3dcba">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	cargoBolType	: CM_CargoBOLType;
begin

	cargoBolType	:= self.cmbTiType.listObject.CM_CargoBOLType;
	
	if cargoBolType.isKindOf(CM_BOLType) then 
		return self.savePreNoteBOL(); // added so a general docket can be added to a voyage 12/05 HG
	else
		return self.savePreNote("Cargo");
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblExtraCellInputReady" id="ca1fd6d2-9d68-4380-ac69-bd8e8477fba1">
        <updating/>
        <source>doTblExtraCellInputReady(	_tbl : CM_EntryTable; 
							_inputControl: Control input; 
							_cleft: Real io; 
							_ctop: Real io; 
							_cwidth: Real io; 
							_cheight: Real io	) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
15/04/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	self.myAssistant.GTE_Assistant.mainExtraCellInputReady(_tbl, _inputControl, _cleft, _ctop, _cwidth, _cheight, saveRowHeight, GTE_ReceivalsForm::getFormControl.name);
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable"/>
        <Parameter name="_inputControl" type="Control" usage="input"/>
        <Parameter name="_cleft" type="Real" usage="io"/>
        <Parameter name="_ctop" type="Real" usage="io"/>
        <Parameter name="_cwidth" type="Real" usage="io"/>
        <Parameter name="_cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doTblExtraDblClick" id="8203d836-2413-42fd-b5bc-c93b5f8aad89">
        <updating/>
        <source>doTblExtraDblClick(table: CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     04 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	mainTable		: CM_EntryTable;
	cargoDocketId	: Integer;
	cmb 			: ComboBox;
	tmpObj			: CM_Object;
	bolNo : String;
	imex : Integer;
begin

	cmb := self.cmbTiType;
	if cmb = null or cmb.listObject = null then
		cargoDocketId :=  TI_CargoType_Null;
	else
		tmpObj := cmb.listObject.CM_Object;
		if tmpObj.isKindOf(CM_CargoType) then
			cargoDocketId := tmpObj.CM_CargoType.id;
		elseif tmpObj.isKindOf(CM_BOLType) then
			cargoDocketId := tmpObj.CM_BOLType.id;
		else
			cargoDocketId := TI_CargoType_Null;
		endif;
	endif;
	
	mainTable		:=	self.tblMain;
	bolNo := mainTable.getValueByName(ETRow_BolNumber).String;
	if self.allAttachments &lt;&gt; null then
			self.myAssistant.receival_tblDblClickShpPreNote(table,
												mainTable, 
												self.allAttachments, 
												cargoDocketId, 
												null,
												self.cmbOperator.myObject.CM_Operator,
												self.cmbVoyage.listObject.CM_Voyage,
												bolNo,
												self.cmbDestination.listObject.CM_Port,
												self.cmbDischarge.listObject.CM_Port,
												imex,
												self.cmbConsignor.listObject.CM_ConsigneeConsignor,
												self.cmbConsignee.listObject.CM_ConsigneeConsignor,
												self.cmbCommodity.listObject.CM_Commodity );
	endif;

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
