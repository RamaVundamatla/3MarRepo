    <JadeMethod name="doConnectionTest" id="820f1d16-e825-44e1-baf2-04c73958413b">
        <source>doConnectionTest(_result: String output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API
08 August 2024		navmd1	Grab and use additional headers if we know we're an API Endpoint Def

*/

constants
	TIMEOUT			: Integer = 5000;	// 5 seconds
vars
	conn			: JadeHTTPConnection;
	agent			: CM_APIConsumerAgent;
	sendSuccess		: Boolean;
	resultCode,
	contentLen		: Integer;
	body			: String;
	requestHeaders	: String;
begin
	_result := "Not Implemented";
	
	create conn transient;
	
	conn.url := self.baseEndpoint;
	
	// Set timeouts to something small
	conn.connectTimeout := TIMEOUT;
	conn.receiveTimeout := TIMEOUT;
	conn.sendTimeout	:= TIMEOUT;
	
	if self.isAPIDef then
		create agent transient;
	
		agent.setupFromWebServiceDefinition(self.CM_APIEndpointServiceDef);
		requestHeaders := agent.getAdditionalHeadersForHTTP();
	endif;
	if requestHeaders = null then
		requestHeaders := "Content-Type: text/html; charset=utf8";
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Request Headers: " &amp; requestHeaders, LogDEBUG);
	sendSuccess := conn.sendRequest(JadeHTTPConnection.Verb_GET, requestHeaders, null);
	resultCode := conn.queryStatusCode();
	
	contentLen := conn.queryContentLength();
	conn.readBody(contentLen);
	body := conn.responseBody.StringUtf8.String;
	
	if sendSuccess and resultCode = HttpResponseOK then
		_result := "Response Headers: " &amp; conn.responseHeaders &amp; /*CrLf &amp;*/ "Response Body: &lt;see application log&gt;";
		// The Body is probably too long to include in a message box, so just log it
		app.writeLog(method.qualifiedName &amp; " Response Body: " &amp; body, LogINFO);
		return true;
	endif;
	
	if not sendSuccess and resultCode = 0 then
		_result := "Connection Unsuccessful. Response Code: Connection Timed Out.";
		return false;
	endif;
	
	_result := self.baseEndpoint &amp; CrLf &amp; CrLf &amp; "Connection Attempt Successful. Not Ok result returned." &amp; CrLf &amp; CrLf &amp; "Response Headers: " &amp; conn.responseHeaders &amp; /*CrLf &amp;*/ "Response Body: &lt;see application log&gt;";
	// The Body is probably too long to include in a message box, so just log it
	app.writeLog(method.qualifiedName &amp; " Response Body: " &amp; body, LogINFO);
	
	return false;
epilog	
	delete conn;
	delete agent;
end;</source>
        <Parameter name="_result" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="622c10a1-954f-4200-bdcc-cf670e4814c6">
        <source>getAuditTextForProperty(_property: Property): String;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars
	propName : String;
begin
	propName := _property.name;
	if propName = CM_ExternalWebServiceDef::password.name then
		return self.formatAuditText(propName, "******");			
	else
		return inheritMethod(_property);
	endif;
epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBGPControllerForTerminal" id="4bceae46-4435-4238-a16b-3627be5683ea">
        <source>getBGPControllerForTerminal(_terminal : CM_Terminal) : BGP_ExternalWSController;
/*
Purpose:			

Date		Who		Reason
04 August 2021	navab1	TFS 50669
*/

vars
	bgp : BGP_ExternalWSController;
begin
	
	if self.allExternalBGPControllers.size = 1 then
		return self.allExternalBGPControllers.first;
	endif;
	
	if _terminal = null then // system data
		return self.allExternalBGPControllers.first;
	endif;

	foreach bgp in self.allExternalBGPControllers do
		if bgp.myTerminal = _terminal then
			return bgp;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="BGP_ExternalWSController"/>
    </JadeMethod>
