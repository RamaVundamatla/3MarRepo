    <JadeMethod name="resetSUPassword" id="94f41e48-a9da-4bac-8420-ac4f02614eee">
        <source>resetSUPassword();
/*
Purpose:			
Date		Who		Reason
11 April 2012	cnwab1	Initial creation
*/

vars
	superUser : CM_User;
	passwordBin : Binary;
begin
	app.initialize;

	beginTransaction;
	app.jmtSetSUPW(); // PAR 29802
	commitTransaction;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetSystemAlertType" id="985e4473-dff2-4028-9dd0-28ff33c67b53">
        <source>resetSystemAlertType(_eventType : Integer; _alertName, _alertDescr, _alertArea : String) protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	root			: CM_Root;
	realAlertType,
	proxyAlerType		 : CM_SystemAlertType;
begin
	root := app.myRoot;
	realAlertType := root.allSystemAlertTypes[_eventType];

	if realAlertType = null then
		create proxyAlerType  transient;
		create realAlertType persistent;	
	else
		proxyAlerType := app.createUpdateProxy(realAlertType).CM_SystemAlertType;
	endif;
	
	proxyAlerType.setProxy(_eventType, _alertName, _alertDescr, _alertArea, root, null);
	realAlertType.setForUpdate(proxyAlerType);

epilog
	delete proxyAlerType;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_alertName" type="String"/>
        <Parameter name="_alertDescr" type="String"/>
        <Parameter name="_alertArea" type="String"/>
    </JadeMethod>
    <JadeMethod name="resetSystemAlertTypes" id="2c67616b-1b08-400f-ad87-8cfdcc60cd10">
        <source>resetSystemAlertTypes();
/*
Purpose:			

Return Value:		

Date		Who		Reason
29/08/2006	cnwer1	Initial creation - PAR#xxxx
09/12/2010	cnwcs5	par 24464/ccms MES 1112
17/09/2020	jlgdap1	TFS 49316 MTN Machine Idle Time
03/10/2022  navds21 TFS 50083  MTN Machine Delay Time
*/
vars
	
begin
	beginTransaction;
	
	self.resetSystemAlertType(EVENT_AT_Planned_CEDO_Removed, AT_NAME_Planned_CEDO_Removed, 
								'Alert raised when Planned Containers have their CEDO removed', 
								AlertArea_YardGeneral);
								
	self.resetSystemAlertType(EVENT_AT_PreGateAlert, AT_NAME_PreGateError, 
							'Alert raised for pre-gate road job errors', 
							AlertArea_PreGate);
	
	self.resetSystemAlertType(	EVENT_AT_PreGateFailedAutoPlan,AT_NAME_PreGateFailedAutoplan,
								null,
								AlertArea_PreGate);
	
	self.resetSystemAlertType(EVENT_AT_RTGAlert,AT_NAME_RTGAlert,
								'Alert sent from a RTG machine to controller',
								AlertArea_YardRTG);
	
	self.resetSystemAlertType(EVENT_AT_HandHeldAlert,AT_NAME_HandHeldAlert,
								'Alert sent from a hand held device to controller',
								AlertArea_Gate);
	
	self.resetSystemAlertType(EVENT_AT_FailedAutoPlan,AT_NAME_FailedAutoPlan,
								'Alert sent when a tracked item fails autoplanning',
								AlertArea_YardGeneral);
								
	// ccms JMT 1750 cnwrd1 , 22.12.08
	self.resetSystemAlertType(EVENT_AT_LabourRestriction,AT_NAME_LabourRestriction,
								'Alert sent when Labour Restriction placed on area with current RT Queue Tasks',
								AlertArea_YardGeneral);	
								
	self.resetSystemAlertType(EVENT_VoyagePlanProcessStopAdd, AT_NAME_Planned_CSI_ADDED, //CCMS1884
								'Alert sent when an Inspection Stop is applied to a planned cargo item',
								AlertArea_YardGeneral);	
								
	self.resetSystemAlertType(EVENT_AT_ExternalInterface, AT_NAME_ExternalInterface, 	// CCMS MES 1014
								'Alert raised when a problem with an External Interface is detected',
								AlertArea_YardGeneral);	
	
	self.resetSystemAlertType(EVENT_POWER_OFF_EXCEEDED, AT_NAME_Power_Off_Exceeded, 	//+ cnwmd1 CCMS 1871
								'Alert raised when the power off time has been exceeded.',
								AlertArea_Gate);	

	self.resetSystemAlertType(EVENT_SQL_Native, AT_NAME_SQLNativeAlert,
								'Alert raised when Code Generation for Data Export failed.',
								AlertArea_SQLNative);	

	self.resetSystemAlertType(EVENT_SQL_NativeRT, AT_NAME_SQLNativeRTAlert,
								'Alert raised when Runtime Error occurs during Data Export.',
								AlertArea_SQLNative);
	//cnwrd1 par 25217 CCMS 1170
	self.resetSystemAlertType(EVENT_RTG_WORKZONE, AT_NAME_RTG_Workzone,
								'Alert raised when Item Queued to RTG area with no workzone coverage.',
								AlertArea_YardRTG);								
	// 08/12/2010 cnwcs5 ccms mes 1112/ par 24464 - start
	self.resetSystemAlertType(EVENT_AT_PreNoteStopReqDeleted, AT_NAME_PreNoteStopReqDeleted,
								'Alert raised when a prenote for which cargo update requests have been processed is deleted.',
								AlertArea_PreNote);	
	// 16 Nov 2011	NDL	Par 28697
	self.resetSystemAlertType(EVENT_AT_MTThresholdBreach, AT_NAME_MT_Threshold,
								'Alert raised when the MT Pooling BGP raises an alert for an MT Threshold breach.',
								AlertArea_YardGeneral);	
								
	self.resetSystemAlertType(EVENT_AT_General, AT_NAME_General,
								'Alert raised for general issue.',
								AlertArea_YardGeneral);	
								
	//11 Jan 2012	NDL	Par 28953
	self.resetSystemAlertType(EVENT_AT_FailedAutoPlanRequest, AT_NAME_FailedAutoPlanRequest,
								"Alert type that is raised when a 'Request by type' fails autoplanning.",
								AlertArea_YardGeneral);
	//16 May 2013	NDL	Par 31393							
	self.resetSystemAlertType(EVENT_AT_VehicleBookingUpdate, AT_NAME_VehicleBookingUpd,
								"Alert type that is raised when a 'Vehicle Booking' is made or amended.",
								AlertArea_YardGeneral);
	
	//epr TFS 2327 23/7/16
	self.resetSystemAlertType(EVENT_AT_VGMAlert,AT_NAME_VMGAlert, "Alert type that is raised when VGM details are changed by EDI.",AlertArea_YardGeneral);
	
	//09 Aug 2019	NDL	TFS 44261
	self.resetSystemAlertType(EVENT_AT_INVOICE, AT_NAME_Invoice,
								"Alert type that is raised to highlight issues in the invoicing module.",
								AlertArea_Invoicing);
	
	// 17/09/2020 jlgdap1 TFS 49316
	self.resetSystemAlertType(EVENT_AT_MachineIdleAlert, AT_NAME_MachineIdleAlert,
								"Alert type that is raised when a machine exceeds its specified idle time.",
								AlertArea_YardGeneral);
	// 17/09/2020 jlgdap1 TFS 49316 end
	//Start 20/10/2022 navds21 TFS 50083
	self.resetSystemAlertType(EVENT_AT_MachineDelayAlert, AT_NAME_MachineDelayAlert,
                          "Alert type that is raised when a machine exceeds its specified delay time.",
                          AlertArea_YardGeneral);
	//End 20/10/2022 navds21 TFS 50083
	
	commitTransaction;


epilog

end;</source>
    </JadeMethod>
