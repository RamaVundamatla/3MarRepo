        <updating/>
        <source>button1_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		19 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.drawGridGPS();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
