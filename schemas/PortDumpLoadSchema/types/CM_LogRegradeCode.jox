<Class name="CM_LogRegradeCode">
    <JadeMethod name="importPLXMLReference" id="e1091da7-94d8-4263-9fc6-7ab154edaed2">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_LogRegradeCode::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
