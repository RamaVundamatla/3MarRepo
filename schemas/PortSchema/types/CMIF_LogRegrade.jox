    <JadeMethod name="getDisplay" id="39744779-453d-4f73-86b7-9932b178be96">
        <source>getDisplay() : String;

vars

	display : String;

begin

	display := id &amp; Tab &amp; gradeCode &amp; Tab &amp; length &amp; Tab &amp; type &amp; Tab &amp; treatment &amp; Tab &amp; location;
	return display;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProduct" id="07ed2868-365c-497b-baf9-137274909087">
        <source>getProduct(_passport : CM_Passport input) : CM_Product;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pxyProduct		: CM_ProductLog;
	realProduct		: CM_Product;
	prodCode		: String;
	tmpOperator		: CM_Operator;
		
begin
	prodCode := self.productCode;
	realProduct := self.myOperator.allProducts[TI_CargoType_Log, prodCode];
	
	if realProduct &lt;&gt; null then
		return realProduct;
	endif;
	
	tmpOperator := self.myOperator;

	create pxyProduct transient;
	pxyProduct.setProxyLogProduct(	prodCode,
									self.myOperator, 
									tmpOperator.getLogSpecies(self.species),
									tmpOperator.getLogGrade(self.species, self.gradeCode),
									tmpOperator.getLogType(self.type),
									tmpOperator.getLogTreatment(self.treatment),
									tmpOperator.getLogLength(self.length));

	app.myUtilityCA.utlCreateProduct(pxyProduct, realProduct, _passport);
	
	if _passport.noErrors then
		return realProduct;
	endif;
	
	return null;
	
epilog
	delete pxyProduct;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="init" id="f7f858e6-8ce1-42cb-8a5a-ea16b53cafe4">
        <updating/>
        <source>init(	//_consignor			: String;	//commented ccms 1116, #26786 27/01/2011
		_operator			: CM_Operator;
		_species,
		_grade,
		_treatment,
		_type,
	 	_length 			: String;
	 	_sedMIN, _sedMAX	: Decimal;
	 	_isLogId 			: Boolean;
	 	_regradeCode		: CM_LogRegradeCode;
	 	_allTracked			: CM_TISet) updating;

vars

begin

	//self.consignorCode := _consignor;	// commented by ccms 1116 #26786 27/01/2011
	self.myOperator := _operator;
	self.myRegradeCode := _regradeCode;
	self.gradeCode := _grade;
	self.species := _species;
	self.treatment := _treatment;
	self.type := _type;
	self.length := _length;
	self.sedMin := _sedMIN;
	self.sedMax := _sedMAX;
	self.isLogId := _isLogId;
	_allTracked.copy(self.allTrackedItems);

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_species" type="String"/>
        <Parameter name="_grade" type="String"/>
        <Parameter name="_treatment" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_length" type="String"/>
        <Parameter name="_sedMIN" type="Decimal"/>
        <Parameter name="_sedMAX" type="Decimal"/>
        <Parameter name="_isLogId" type="Boolean"/>
        <Parameter name="_regradeCode" type="CM_LogRegradeCode"/>
        <Parameter name="_allTracked" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="initForDisassembly" id="e771b6c8-b17d-4e30-b0d1-71dd89bd6e9a">
        <updating/>
        <source>initForDisassembly(_newId, _newGrade, _newLength, _newType, _newTreatment, _newMin, _newMax, _newLoc : String;
				   _newLocRef : CM_LocationsController) updating;

vars

begin
	self.isDissasembly := true;
	self.id 		:= _newId;
	self.gradeCode	:= _newGrade;
	self.length		:= _newLength;
	self.type		:= _newType;
	self.treatment	:= _newTreatment;
	self.sedMin		:= _newMin.Decimal;
	self.sedMax		:= _newMax.Decimal;
	self.location	:= _newLoc[1:60];
	self.myLocation := _newLocRef;

end;</source>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_newGrade" type="String"/>
        <Parameter name="_newLength" type="String"/>
        <Parameter name="_newType" type="String"/>
        <Parameter name="_newTreatment" type="String"/>
        <Parameter name="_newMin" type="String"/>
        <Parameter name="_newMax" type="String"/>
        <Parameter name="_newLoc" type="String"/>
        <Parameter name="_newLocRef" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="jasVolume" id="3e22b366-d202-4c0c-a51b-c80b01a592c2">
        <methodInvocation>mapping</methodInvocation>
        <source>jasVolume(set: Boolean; _value: Real io) mapping;

vars
	diameter : Real;
	calLength	: Real;
	calLength2 : Integer;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := global.calcJASVolume(self.sedMean, self.length.Decimal);	//par 25560 01/09/2010
	
	/*
	diameter := self.sedMean;
	calLength := self.length.Decimal;
	if calLength &lt; 6 then
		_value := (diameter.squared * calLength) / 10000;
	else
		calLength2 := calLength.rounded;
		_value := (diameter + (calLength2 - 4)/2).squared * (calLength /1000);	// there is fault, should be 10000 instead of 1000
	endif;
	*/
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="productCode" id="8278b2f0-5d6d-4e72-beb5-349349affa13">
        <methodInvocation>mapping</methodInvocation>
        <source>productCode(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     23 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := app.buildLogProductCode(self.species, self.gradeCode,
									  self.type, self.treatment, self.length);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sedMean" id="c1f7d06c-e169-48c5-983b-de4bce28ff4b">
        <methodInvocation>mapping</methodInvocation>
        <source>sedMean(set: Boolean; _value: Decimal io) mapping;

vars
	difference : Integer;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	difference := (self.sedMax - self.sedMin).Integer;
	_value := self.sedMin;
	if self.sedMin &gt;= 14 and self.sedMin &lt; 40 then
		_value := _value + ((difference div 6) * 2);
	elseif self.sedMin &gt;= 40 then
		_value := _value + ((difference div 8) * 2);
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setWeight" id="ddb7a7d2-60f1-4fb9-adef-b19e907763b8">
        <updating/>
        <source>setWeight(_portionPerJas : Real) updating;
//--------------------------------------------------------------
//Created: 19 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.weight := (self.jasVolume * _portionPerJas).rounded;
end;</source>
        <Parameter name="_portionPerJas" type="Real"/>
    </JadeMethod>
    <JadeMethod name="validate" id="ff783f3c-d181-453f-a2d0-1a10bb0d3aa1">
        <source>validate();

vars

	terminal : CM_Terminal;

begin

	if self.myLocation = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Location', null, null);
		app.raiseCMException(Input_required_field_location, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	terminal := self.myLocation.myTerminal;
	if terminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
	endif;
	
	if terminal.lookupTrackedItem(self.id, TI_CargoType_Log, TI_STATE_NORMAL, null, false).CM_Log &lt;&gt; null then
		app.raiseCMException1(UniqueIdRequired, self.id, null, null);
	endif;
	
	if (not self.isDissasembly) and (self.myRegradeCode = null) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Regrade Reason Code', ETRow_RegradeReason, null);
		app.raiseCMException(Input_required_field_RegReaCde, ETRow_RegradeReason, null); // cnwdb2	PAR 35364
		return;
	endif;
end;</source>
    </JadeMethod>
</Class>
