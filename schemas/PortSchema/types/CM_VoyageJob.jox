    <JadeMethod name="setProxyVoyageJob" id="67c061b9-f9d6-4fca-8144-0fb07f7aa1f4">
        <updating/>
        <source>setProxyVoyageJob(	_craneID,
					_jobNum,
					_remarks,	
					_systemRemarks				: String;
					_isTwinLift					: Boolean;
					_jobType					: Integer;
					_userJobType				: CM_JobType;
					_estimatedTimeToCompleteMins: Integer;
					_actualStartTs,
					_actualEndTs				: TimeStamp;
					_outOfSequenceLoading 		: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	self.jobNum := _jobNum;
	self.id :=  _jobNum;
	self.remarks := _remarks.trimBlanks;
	self.systemRemarks := _systemRemarks.trimBlanks;
	self.craneId := _craneID;
	self.actualStartTs := _actualStartTs;
	self.actualEndTs := _actualEndTs;
	self.isTwinLift := _isTwinLift;
	self.jobType := _jobType;
	if self.jobType = JOB_TYPE_USER then
		self.myUserJobType := _userJobType;
		self.estimatedTimeToCompleteMins := _estimatedTimeToCompleteMins;
	endif;
	self.allowOutOfOrderLoading := _outOfSequenceLoading; //cnwrd1 par 30626 ccms 2209 23.10.12
end;</source>
        <Parameter name="_craneID" type="String"/>
        <Parameter name="_jobNum" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_systemRemarks" type="String"/>
        <Parameter name="_isTwinLift" type="Boolean"/>
        <Parameter name="_jobType" type="Integer"/>
        <Parameter name="_userJobType" type="CM_JobType"/>
        <Parameter name="_estimatedTimeToCompleteMins" type="Integer"/>
        <Parameter name="_actualStartTs" type="TimeStamp"/>
        <Parameter name="_actualEndTs" type="TimeStamp"/>
        <Parameter name="_outOfSequenceLoading" type="Boolean"/>
    </JadeMethod>
