<Class name="CM_DisplayObject" id="cd2ade93-e2a0-4c3c-a6c1-e1f8cbf2302a">
    <superclass name="CM_Transient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allChildDisplayObjeccts" id="51504f86-d699-4612-9883-44177221994d">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CM_DisplayObjectArray"/>
        <Inverse name="myParentDisplayObject"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allDisplayProperties" id="99052e39-7628-4d70-b7a3-96f712f5f378">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CM_DisplayPropertyDict"/>
        <Inverse name="CM_DisplayProperty::myDisplayObject"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myDisplayClass" id="796efd2d-76f0-4e46-80e5-5e96e11dc054">
        <embedded/>
        <type name="Class"/>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myParentDisplayObject" id="5984cf14-82cd-4088-9ef3-3358e715f622">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_DisplayObject"/>
        <Inverse name="allChildDisplayObjeccts"/>
    </ExplicitInverseRef>
    <JadeMethod name="addDisplayProperty" id="42bbcff3-5ed2-46d9-bea3-65c09faafb1c">
        <updating/>
        <source>addDisplayProperty(_property : Property;
					_displayMethod : Method;
					_niceName : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2008	cnwer1	Initial creation

*/

vars
	displayProperty : CM_DisplayProperty;
begin
	displayProperty:=self.allDisplayProperties[_property];
	if displayProperty = null then
		create displayProperty transient;
	endif;
	
	displayProperty.propertyNiceName:=_niceName;
	displayProperty.myDisplayProperty:=_property;
	displayProperty.myDisplayMethod:=_displayMethod;
	displayProperty.myDisplayObject:=self;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_displayMethod" type="Method"/>
        <Parameter name="_niceName" type="String"/>
    </JadeMethod>
</Class>
