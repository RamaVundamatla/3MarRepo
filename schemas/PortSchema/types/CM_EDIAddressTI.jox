    <JadeMethod name="assignValueSpecial" id="997296ae-73b5-4764-ab5f-941995ad57cd">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2025	jlier1	Initial creation 33694

*/

vars
	found : Boolean;
	xlationCode : String;
begin
	if _propName = ETRow_DeliveryPartyCode then
		self.setId(_processedValue.toUpper);
		return true;
	elseif _propName = ETRow_AddressLine1 then
		self.address1:=_processedValue;
		return true;
	elseif _propName = ETRow_AddressLine2 then
		self.address2:=_processedValue;
		return true;
	elseif _propName = ETRow_AddressLine3 then
		self.address3:=_processedValue;
		return true;
	elseif _propName =ETRow_AddressPostCode then
		self.postCode:= _processedValue;
		return true;
	elseif _propName = ETRow_AddressRegion then
		self.region:=_processedValue;
		return true;
	elseif _propName = ETRow_AddressCountry then
		if _xlationOperator &lt;&gt; null then
			xlationCode:=_xlationOperator.getXlationSystemCode_Country(_processedValue.String, found).String;	
		endif;
		if found  then
			self.countryCode := xlationCode;
		else
			self.countryCode:=_processedValue;
		endif;
		return true;
	elseif _propName = ETRow_AddressCity then
		self.city:=_processedValue;
		return true;
	else

		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="89101c46-d1c9-463b-a8d3-598710059277">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2025	jlier1	Initial creation 33694
12 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI

*/

vars

begin
	if _attrName  = ETRow_AddressLine1 then
		return self.address1;
	elseif _attrName = ETRow_AddressLine2 then
		return self.address2;
	elseif _attrName = ETRow_AddressLine3 then
		return self.address3;
	elseif _attrName = ETRow_AddressPostCode then	
		return self.postCode;
	elseif _attrName = ETRow_AddressRegion then
		return self.region;
	elseif _attrName = ETRow_DeliveryPartyCode then
		return self.id;
	elseif _attrName = ETRow_AddressCountry then
		return self.countryCode;
	elseif _attrName = ETRow_AddressCity then
		return self.city;
	elseif _attrName = ETRow_EmailAddress then				//12.11.2025 navlc30 #36357
		return self.emailAddress;
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
