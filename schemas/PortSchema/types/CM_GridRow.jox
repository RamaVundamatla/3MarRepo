    <JadeMethod name="validateForDelete" id="d8b6047d-e0af-424c-b7e4-e2adb7ab5996">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridCntrl	: CM_GridController;
	firstPathFound : CM_ReeferBlock;
	
begin
	
	if self.isInUse then
		app.raiseCMException1(CM_GridRowInUse, self.getLabel, null, null);
	
	endif;
	
	//08 Apr 2021	NDL	TFS 51042
	if self.hasReeferWalkPaths( firstPathFound ) then
		app.raiseCMException2(Colum_not_remov_still_decla_re, self.getLabel, firstPathFound.name, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2fff1f06-6e28-403a-a1a6-5958666672c5">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.row &lt;= 0 then
		app.raiseCMException1(GridArea_RowColumnInvalidNum, 'row', null, null);
	endif;
	
	self.validateLabel();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateLabel" id="a5db98f9-cb2a-4f90-a061-830390d827fa">
        <source>validateLabel() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2009	cnwer1	Initial creation

*/

vars

begin
	inheritMethod();

	if self.label.length &gt; 4 then
		app.raiseCMException2(ERR_INVALID_VALUE,self.label,"Row Label can not be more than 4 characters in length", null, null);	
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
