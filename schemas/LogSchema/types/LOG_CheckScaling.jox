    <JadeMethod name="showThumbnailData" id="4881245f-23ae-4c74-9b21-5971932e3f27">
        <lockReceiver/>
        <updating/>
        <source>showThumbnailData(obj: Object) updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	checkScaleHdr			: CM_LogCheckScaleHdr;
	checkScaleDtl			: CM_LogCheckScaleDtl;
	tbl						: CM_DataTable;
begin
	checkScaleHdr := obj.CM_LogCheckScaleHdr;
	tbl := self.tblThumbData;
	tbl.rows := tbl.fixedRows;
	
	foreach checkScaleDtl in checkScaleHdr.allCheckScaleDtls do
		self.addThumbnailRow(checkScaleDtl);
	endforeach;
	
	
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblThumbData_rowColumnChg" id="7ad8cc0e-5432-4d6a-b611-5a8a1a99ec4b">
