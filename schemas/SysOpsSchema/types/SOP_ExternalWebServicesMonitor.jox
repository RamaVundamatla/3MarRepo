	self.chkRegexSearch.top := self.TopLevel180;		// 14/08/2024	navcs2	Bug 65590
	self.shtInterfaceName.visible := true;
	self.shtInterfaceName.enabled := true;
	self.tblInterfaces.visible := true;
	self.tblInterfaces.enabled := true;
	
	self.shtStatus.visible := true;		// MTN-36569
epilog
	delete terminals;
end;</source>
