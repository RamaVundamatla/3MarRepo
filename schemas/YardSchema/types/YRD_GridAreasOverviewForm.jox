        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dkcSubMainCol_userResize(dockCont: JadeDockContainer input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/07/2011	cnwndl1	Initial creation	par 27890
22/12/2011	cnwdap1	PAR #28064 resize colour legend table
09/01/2013  cnwmc5  PAR #30890 - could resize this to far, and caused a 4030 UE in self.getXMLSettingsForSave
*/
vars

begin

	self.doResize;
	self.frmColLegendTIs.doResize;	// PAR #28064
	
	//cnwmc5 - PAR #30890 - 09/01/2013
	if self.dkcSubMain.width &lt; 50 then
		dockCont.width := dockCont.width - 50;
		self.dkcSubMain.width := 50;
	endif;

epilog

end;</source>
