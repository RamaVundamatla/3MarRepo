    <JadeMethod name="getValueForCargoCalcType" id="3704c1cf-dd10-479a-af23-e4ff1a909a2b">
        <source>getValueForCargoCalcType(_calcType : Integer) : Decimal;
/*

Purpose:		TFS 39236	

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	value : Real;
	wod : CM_WorkOrderDtl;
	lengthOfStay : Decimal [12,2];
begin


	// TFS 42161 - FROM HERE 
	lengthOfStay := self.getInvLengthOfStay();

	if _calcType = INV_CALC_TYPE_WO_ETMAL_DAYS then
			value := lengthOfStay;
	elseif _calcType = INV_CALC_TYPE_WO_ETMAL_HOURS then
			if lengthOfStay = 0 then
				return 0;
			endif;
			value := (lengthOfStay * 24);
			
	elseif _calcType = INV_CALC_TYPE_WO_ETMAL_MINUTES then
			if lengthOfStay = 0 then
				return 0;
			endif;
			
			value := ((lengthOfStay * 24) * 60);
	else
	// TFS 42161 - TO HERE 
		create tiSet transient;
		
		self.getAllTIs( tiSet );
		
		if not tiSet.isEmpty() then
			foreach ti in tiSet	discreteLock do
				if _calcType = INV_CALC_TYPE_UNITY then
					value := value + 1.0;
				elseif (_calcType = INV_CALC_TYPE_QUANTITY or _calcType = INV_CALC_TYPE_WO_CARGOQUANTITY) then // TFS 39236 
					value := value + ti.totalQuantity;
				elseif (_calcType = INV_CALC_TYPE_WEIGHT or _calcType = INV_CALC_TYPE_WO_CARGOWEIGHT) then // TFS 39236 
					value := value + ti.totalWeight;
				elseif _calcType = INV_CALC_TYPE_WEIGHT_TON  then
					value := value + (ti.totalWeight / 1000);
				elseif (_calcType = INV_CALC_TYPE_VOLUME or _calcType = INV_CALC_TYPE_WO_CARGOVOLUME)  then // TFS 39236 
					value := value + ti.totalVolume;
				elseif (_calcType = INV_CALC_TYPE_REVENUE_TONS or _calcType = INV_CALC_TYPE_WO_CARGOREVTONS) then // TFS 39236 
					value := value + ti.freightTons;
			
				endif;
	
			endforeach;
		else // this is for CASH ESTIMATE, there wll not be cargo so use the work order detail
		
			foreach wod in self.allWoDtls	discreteLock do
				value := value +  wod.getValueForCargoCalcType(_calcType);
			endforeach;
			
		endif;	
	endif;




	
	if value = 0 then
		value := 1;
	endif;
	
	return value;
epilog
	delete tiSet;
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWoToCancel" id="d298577f-4e15-4ff3-a1c0-9c02ab455c6e">
        <source>getWoToCancel(): CM_WorkOrder;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Aug 2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces

*/
vars
	woDtl : CM_WorkOrderVoyageDtl;
	wo    : CM_WorkOrder;
begin
	
	if self.allWoDtls.isEmpty then
		return null;
	endif;
	
	woDtl := self.allWoDtls.first.CM_WorkOrderVoyageDtl;
	
	if woDtl.isKindOf(CM_WodHMSRequestCancel) then
		wo := woDtl.CM_WodHMSRequestCancel.myWorkOrderToCancel;	
		return wo;
	endif;
	
	
	return null;
end;</source>
        <ReturnType type="CM_WorkOrder"/>
    </JadeMethod>
