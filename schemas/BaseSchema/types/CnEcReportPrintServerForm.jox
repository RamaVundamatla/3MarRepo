    <JadeMethod name="btnStopStart_click" id="cfd85f63-0496-457b-9fa8-7409f7324197">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStopStart_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		10 August 2000 by cnwdad1
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if btn.value then
		app.myReportAppHandler.doStart();
		btn.caption	:=	self.SERVER_BUTTON_STOP;
	else
		app.myReportAppHandler.doStop();
		btn.caption	:=	self.SERVER_BUTTON_START;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEnableButtons" id="99076b19-28f5-458d-a669-814b143d5811">
        <source>doEnableButtons() protected;
// --------------------------------------------------------------------------------
// Created:		10 August 2000 by cnwdad1
//
// Purpose:		Sets the curently enabled button controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theQueueEntry	: CnEcReportQueueEntry;
	tableRow		: JadeTableRow;

begin
	if tblQueue.cnEcIsRowSelected(tblQueue.row) then
		tableRow		:=	tblQueue.accessRow(tblQueue.row);
		theQueueEntry	:=	tableRow.itemObject.CnEcReportQueueEntry;

		if theQueueEntry &lt;&gt; null then
			btnPause.enabled	:=	(theQueueEntry.printStatus = CNEC_REPORT_PENDING) or (theQueueEntry.printStatus = CNEC_REPORT_PRINTING);
			btnRestart.enabled	:=	(theQueueEntry.printStatus = CNEC_REPORT_PAUSED);
			btnCancel.enabled	:=	(theQueueEntry.printStatus &lt;&gt; CNEC_REPORT_CANCELLED);
		endif;
	else
		btnPause.enabled	:=	false;
		btnRestart.enabled	:=	false;
		btnCancel.enabled	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="a353581c-e64c-48f1-bc72-ecad0da85284">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	self.setTableProperties(tblQueue, 6);
	tblQueue.setCellText(1, 1, self.TABLE_HEADER_SERVER);
	tblQueue.displayCollection(app.myBaseRoot.allReportQueueEntries, true, 0, null);
	self.doEnableButtons();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="036d3ea9-4abb-4409-bfee-8991722ee983">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		10 August 2000 by cnwdad1
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	tblQueue.move(tblQueue.left, tblQueue.top, (self.width - (tblQueue.left * 2) - 8), (self.height - (tblQueue.top + btnClose.height + 43)));
	btnStopStart.move(btnStopStart.left, (tblQueue.top + tblQueue.height + 6), btnStopStart.width, btnStopStart.height);
	btnStatus.move(btnStatus.left, btnStopStart.top, btnStatus.width, btnStatus.height);
	btnPause.move(btnPause.left, btnStopStart.top, btnPause.width, btnPause.height);
	btnRestart.move(btnRestart.left, btnStopStart.top, btnRestart.width, btnRestart.height);
	btnCancel.move(btnCancel.left, btnStopStart.top, btnCancel.width, btnCancel.height);
	btnClose.move(((tblQueue.left + tblQueue.width) - btnClose.width), btnStopStart.top, btnClose.width, btnClose.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="3f653d84-5e77-483a-a5ae-57807c9398ec">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
