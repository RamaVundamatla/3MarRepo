    <JadeMethod name="findFirstUsing" id="0eeefb18-0d44-4060-813d-de7c73a72a25">
        <source>findFirstUsing(_invLineType : CM_InvoiceLineDesc) : CM_InvTypeCargoMultiSurcharge;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2022	navpw1	Initial creation

*/

vars
	surCharge : CM_InvTypeCargoMultiSurcharge;
	
begin
	if _invLineType = null then
		return null;
	endif;
	
	foreach surCharge in self do
		if surCharge.allSelectedInvLineTypes.includes( _invLineType ) then
			return surCharge;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_InvTypeCargoMultiSurcharge"/>
    </JadeMethod>
</CollClass>
