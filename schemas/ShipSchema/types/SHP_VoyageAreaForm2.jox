    <JadeMethod name="doBtnToolBarHAZARD" id="c2cab5b6-0ac6-4a3a-927e-192d751de312">
        <updating/>
        <source>doBtnToolBarHAZARD() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
begin

	if self.displayMode = ShpDisplayMode_ColCodeLoad then
