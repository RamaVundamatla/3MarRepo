vars
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYATemplate" id="1bf5be37-250a-45c3-8304-92c7ff232bf5">
        <source>isYATemplate() : Boolean;
//17 July 2008	cnwdw1	
// A snapshot is never a template
vars

begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="recalculateCriteriaPriorities" id="19b2f9fa-f758-40f0-8669-eb99131e648c">
        <updating/>
        <source>recalculateCriteriaPriorities() updating;

// Created by cnwdvb1 on 08 August 2006

vars

begin
	
	// Do nothing.

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c67db04b-8459-4a09-a7f9-0b2186f37fb7">
        <updating/>
        <source>setForCreate(pProxyObj: CM_YardAllocation) updating;

// Created by cnwdvb1 on 07 August 2006

vars

begin
	
	self.setForUpdate(pProxyObj);

end;</source>
        <Parameter name="pProxyObj" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="setForCreateTemplate" id="66199470-4f2f-4167-8bbe-5699e8bb7b41">
        <updating/>
        <source>setForCreateTemplate(_realAllocation: CM_YardAllocation; _templateGroup : CM_YATemplateGroup) updating;

// Created by cnwdvb1 on 07 August 2006

vars

begin

	// Call set for create which calls update.
	self.setForCreate(_realAllocation);
	
	// Use special clone criteria method.
	self.cloneCriteria(_realAllocation);
	
	// Set the group reference.
	self.myYATemplateGroup := _templateGroup;

end;</source>
        <Parameter name="_realAllocation" type="CM_YardAllocation"/>
        <Parameter name="_templateGroup" type="CM_YATemplateGroup"/>
    </JadeMethod>
</Class>
