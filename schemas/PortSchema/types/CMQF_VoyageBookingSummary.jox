    <JadeMethod name="createPreDefinedSummaryObj" id="1a2dcc71-a517-4ab0-ac04-454db37cccbc">
        <source>createPreDefinedSummaryObj(_dict: Dictionary input);
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	bookingSum			: CMIF_VoyageBookingSummary;
begin
	
	_dict.purge();
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_20General;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_20GeneralDLR;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_20Integral;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_20MT;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_20IntegralDLR;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_40General;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_40GeneralDLR;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_40Integral;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_40MT;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_40IntegralDLR;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_TotalCribs;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_TotalDLR;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_TotalEmpties;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_TotalIntegral;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_ISO;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_TotalGeneral;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_MOVE;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_20GeneralDLR;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_MOVE;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_40GeneralDLR;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_MOVE;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_20IntegralDLR;
	_dict.add(bookingSum);
	
	create bookingSum transient;
	bookingSum.categoryType := CMIF_VoyageBookingSummary.TYPE_MOVE;
	bookingSum.categoryCode := CMIF_VoyageBookingSummary.Category_40IntegralDLR;
	_dict.add(bookingSum);
	
