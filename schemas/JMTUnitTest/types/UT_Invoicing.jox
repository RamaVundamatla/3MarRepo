		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Stop Set,,(Default),(Default) ›,(Default),' &amp; grouping3 &amp; ',UT_GPHAInvLineType3' &amp; CrLf;

	
