        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReleases_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2011	cnwndl1	Initial creation	Par 28366

*/

vars

begin
	if table.row &lt;= table.fixedRows then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	if (win = self.tblReleases) then	// dont allow drop from same table	PAR 7234
		return;
	endif;
	self.tblWorkEntryDrop(table, win, x, y);

epilog

end;</source>
