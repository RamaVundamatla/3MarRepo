<GUIClass name="CMUI_FieldTextBoxControl" id="ddd946ea-2e8d-4c6a-8c0f-cb9d525e5706">
    <superclass name="CMUI_TextBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myFieldFrame" id="0030be92-daef-42c3-afab-e74069f28222">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CMUI_FieldTextBox"/>
        <access>protected</access>
        <Inverse name="CMUI_FieldTextBox::myTextBox"/>
