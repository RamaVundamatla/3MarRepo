    </JadeMethod>
    <JadeMethod name="zFinaliseProgressMonitor" id="bb1e851e-d2fb-412e-88b6-8206c1ece34e">
        <updating/>
        <source>zFinaliseProgressMonitor() protected, updating;

// restore cursor = hourglass, and stop/hide progress bar

begin
	if self.myProgress = null then
		return;
	endif;

	// show final amount
	self.myProgress.updateProgress("Loading data into tables", self.myProgress.partsInJob, self.myProgress.partsDone);

	statusLine.caption := self.myAgent.progressCount.String &amp; " rows found.";

	delete self.myProgress;
	app.myPassport.setMyCMIFMonitor(null);
	
	frmModalDialog.visible := false;					
	app.mousePointer := MousePointer_Default;									
end;</source>
        <access>protected</access>
    </JadeMethod>
