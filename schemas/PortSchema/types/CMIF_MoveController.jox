    <JadeMethod name="setIsTruckUndoLoad" id="330e8448-a1fd-4db4-b2a0-ef2d9361e8dd">
        <updating/>
        <source>setIsTruckUndoLoad() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2018	jlger1	Initial creation 36605

*/

vars

begin
	self.isTruckUndoLoad:=false;
	if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.status = WLE_COMPLETED then
		if self.myTrackedItem &lt;&gt; null
		and self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null 
		and self.myTrackedItem.myPrimaryActualLocation.isVehicle
		and self.myTrackedItem.locationId = self.myWorkListEntry.locationTarget
		then
			self.isTruckUndoLoad:= true;
		endif;
	endif;
	
	
epilog

end;</source>
