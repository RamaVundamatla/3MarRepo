    </JadeMethod>
    <JadeMethod name="validateHMSInvoice1" id="f2c77b99-b351-4c70-895f-5aa897c7f62b">
        <source>validateHMSInvoice1(_invoice : CM_Invoice; _step : Integer);
// original invoice
vars
	invCount	: Integer;
	invLine	: CM_InvoiceLine;
begin
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, 1200.Real, "line 1 quantity");
			self.assertEqualMsg(invLine.lineTotal, 3600.Decimal, "line 1 " &amp; _step.String &amp; " value");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTWaterUsage", "line 1 ILD " &amp; _step.String);
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 1, "Invoice lines");
end;
</source>
