    <JadeMethod name="validateMe" id="d3a08905-df0d-4eab-8240-08a97b57ec00">
        <updating/>
        <source>validateMe(	pComputerName:String;
			pEmailClientName:String;
			pEmailReturnAddress:String;
			pEmailServerName:String;
			pLdapBase:String;
			pLdapHost:String;
			pMyEmailBaseRoot:CnEcEmailRoot)  : String updating, protected;

// This method created by JediMethodGenerator at 15:53:23 on 14 March 2001

vars
	errorMessage	: String;

begin
	// Validation

	if CnEcEmailRoot.firstInstance.myDefaultBaseData = self or CnEcEmailRoot.firstInstance.myDefaultBaseData = null then
		return errorMessage; 
	endif;

	if pComputerName = null then
		errorMessage := errorMessage &amp; 'Computer Name may not be null.  ';
	endif;
	if pEmailClientName = null then
		errorMessage := errorMessage &amp; 'Must declare an Email Client.  ';
	endif;
	if pEmailServerName = null then
		errorMessage := errorMessage &amp; 'Must declare an Email Server.  ';
	endif;
	if pEmailReturnAddress = null then
			errorMessage := errorMessage &amp; 'Must declare an Email Return address.  ';
	endif;
epilog
	return errorMessage;
end;</source>
