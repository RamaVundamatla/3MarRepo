    <JadeMethod name="addWharfRes" id="137d14ef-b3c6-4c8c-a395-00ed722f6a67">
        <source>addWharfRes(_wharfRes : HMS_ResourceForWharf; _movementType : String);
/*
Purpose:	

Date		Who		Reason
05 December 2024	navab1	JIRA 33581
*/

vars

begin
	if _wharfRes &lt;&gt; null then
		if _movementType = HMSMovementTypeArrival then
			if _wharfRes.myArrivalResource &lt;&gt; null then
				self.allConfiguredResource.add(_wharfRes.myArrivalResource);
			endif;
		elseif _movementType = HMSMovementTypeDeparture then
			if _wharfRes.myDepartResource &lt;&gt; null then
				self.allConfiguredResource.add(_wharfRes.myDepartResource);
			endif;
		elseif _movementType = HMSMovementTypeShift then
			if _wharfRes.myShiftResource &lt;&gt; null then
				self.allConfiguredResource.add(_wharfRes.myShiftResource);
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_wharfRes" type="HMS_ResourceForWharf"/>
        <Parameter name="_movementType" type="String"/>
    </JadeMethod>
    <JadeMethod name="consolidateLines" id="d3c82ec8-4b2e-4fd3-9294-c424252f7fdd">
        <source>consolidateLines(inDict: CM_InvoiceLineSet input; outDict: CM_InvoiceLineSet input; _doConsolidate: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders

*/

vars

begin
	inheritMethod(inDict, outDict, _doConsolidate);

epilog

end;</source>
        <Parameter name="inDict" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="outDict" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_doConsolidate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProformaInvLines" id="8d6c9475-e8a5-4945-91f5-0dc7fe8e6fd7">
        <updating/>
        <source>createProformaInvLines(_dict: CM_InvoiceLineBySeqNumDict input; _inTranState: Boolean; _doConsolidate: Boolean) updating;
/*

Purpose:		 // TFS 37454	

Parameters:			

Return Value:		

Date			Who		Reason
13 March 2018	jlgab1	Initial creation
18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	localDict 	: CM_InvoiceLineBySeqNumDict;
	localSet 	: CM_InvoiceLineSet;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	if _dict &lt;&gt; null then
		_dict.purge;
	endif;
	if not self.allProformaInvLines.isEmpty then
		self.allProformaInvLines.purge;

	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);
	endif;
	if self.myVessel = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No Vessel specified, cannot create vessel proforma invoice lines.", LogINFO.String);
		endif;
		return;
	endif;
	
	if self.myBank = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No bank specified, cannot create vessel proforma invoice lines.", LogINFO.String);
		endif;
		return;
	endif;
	
	// ### JIRA 33576 05DEC2024 NAVAB1
	if self.selectedTrxCriteria = null 
	and self.allConfiguredResource.isEmpty
	and self.allCurrentResourceUsed.isEmpty then 
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " There are NO pro forma vessel transaction types configured and no actual resources recorded", LogINFO.String);
		endif;
		return;
	endif;
	
	if _inTranState then
		localDict := app.myUtilityCA.utlCreateProformaInvLinesVess(self,self.myVoyage,app.myPassport);
	else
		localDict := app.myTrxCA.trxCreateProformaInvLinesVess(self, self.myVoyage,app.myPassport);
	endif;

	if app.myPassport.hasErrors then
		return;
	endif;
	
	self.setDebtor();		
	self.setTaxAmountFrom( localDict );
	
	create localSet transient;
	localDict.copy(localSet);
	
	if not localSet.isEmpty then
		self.consolidateLines( localSet, self.allProformaInvLines, _doConsolidate );
	endif;
	
	self.setEstimatedCashCharges();
	
	if _dict &lt;&gt; null then
		self.allProformaInvLines.copy(_dict);
	endif;

epilog
	delete localSet;
	delete localDict; // TFS 45953
end;</source>
        <Parameter name="_dict" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
        <Parameter name="_inTranState" type="Boolean"/>
        <Parameter name="_doConsolidate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getConfiguredLaunchResource" id="bffae7a0-93d1-4ac9-860b-e39204fcecb8">
        <source>getConfiguredLaunchResource(_movementType : String);
/*
Purpose:	

Date		Who		Reason
05 December 2024	navab1	JIRA 33581
*/

vars
	hmsResUsed, pxyResUsed : HMS_ResourceUsed;
	movement : HMS_VoyageMovement;
	found : Boolean;
	wharf : HMS_Wharf;
	berth : HMS_Berth;
	resource : HMS_Resource;
	harbour : HMS_Harbour;
	pilot : HMS_MovementPilotDetails;
	launch : HMS_PilotLaunch;
begin
	if  self.myVoyage.myHMSVoyageData &lt;&gt; null then

		foreach movement in self.myVoyage.myHMSVoyageData.allVoyageMovements do
			if movement.moveType = _movementType then
				found := true;
				break;
			endif;
		endforeach;
		
		if found 
		and movement &lt;&gt; null then
			pilot :=  movement.allMovementPilotDetails.first;
			if pilot = null then
				return;
			endif;
			launch := pilot.myPilotLaunch;
			if launch = null then
				return;
			endif;
			harbour := movement.myHarbour;
			
			resource := launch.getResourceForHarbourMovement(harbour,_movementType); 
			if  resource &lt;&gt; null then
				self.allConfiguredResource.add(resource);			
			endif;	
		endif;
		
	endif;


 

epilog

end;</source>
        <Parameter name="_movementType" type="String"/>
    </JadeMethod>
    <JadeMethod name="getConfiguredLineResource" id="b11cdd8d-fbea-419c-a3c9-5fe22125c273">
        <source>getConfiguredLineResource(_movementType : String);
/*
Purpose:	

Date		Who		Reason
05 December 2024	navab1	JIRA 33581
*/

vars
	hmsResUsed, pxyResUsed : HMS_ResourceUsed;
	movement : HMS_VoyageMovement;
	found : Boolean;
	wharf : HMS_Wharf;
	berth : HMS_Berth;
	resource : HMS_Resource;
	harbour : HMS_Harbour;
	pilot : HMS_MovementPilotDetails;
	line : HMS_LineCompany;
	launch : HMS_PilotLaunch;
begin
	if  self.myVoyage.myHMSVoyageData &lt;&gt; null then

		foreach movement in self.myVoyage.myHMSVoyageData.allVoyageMovements do
			if movement.moveType = _movementType then
				found := true;
				break;
			endif;
		endforeach;
		
		if found 
		and movement &lt;&gt; null then
			line :=  movement.myLineCompany;
			if line = null then
				return;
			endif;
			harbour := movement.myHarbour;
			
			resource := line.getResourceForHarbourMovement(harbour,_movementType); 
			if  resource &lt;&gt; null then
				self.allConfiguredResource.add(resource);			
			endif;	
		endif;
		
	endif;


 

epilog

end;</source>
        <Parameter name="_movementType" type="String"/>
    </JadeMethod>
    <JadeMethod name="getConfiguredPilotResource" id="ef002722-669f-4780-bbc8-84e3e5b4b8e6">
        <source>getConfiguredPilotResource(_movementType : String);
/*
Purpose:	

Date		Who		Reason
05 December 2024	navab1	JIRA 33581
*/

vars
	hmsResUsed, pxyResUsed : HMS_ResourceUsed;
	movement : HMS_VoyageMovement;
	found : Boolean;
	wharf : HMS_Wharf;
	berth : HMS_Berth;
	resource : HMS_Resource;
	harbour : HMS_Harbour;
	pilot : HMS_MovementPilotDetails;
	launch : HMS_PilotLaunch;
begin
	if  self.myVoyage.myHMSVoyageData &lt;&gt; null then

		foreach movement in self.myVoyage.myHMSVoyageData.allVoyageMovements do
			if movement.moveType = _movementType then
				found := true;
				break;
			endif;
		endforeach;
		
		if found 
		and movement &lt;&gt; null then
			pilot :=  movement.allMovementPilotDetails.first;
			if pilot = null 
			or pilot.myPilot = null then
				return;
			endif;
			harbour := movement.myHarbour;
			
			resource := pilot.myPilot.getResourceForHarbourMovement(harbour,_movementType); 
			if  resource &lt;&gt; null then
				self.allConfiguredResource.add(resource);			
			endif;	
		endif;
		
	endif;


 

epilog

end;</source>
        <Parameter name="_movementType" type="String"/>
    </JadeMethod>
    <JadeMethod name="getConfiguredTugResource" id="c7a0b70e-8f65-4fdd-b6dd-d6022e270387">
        <source>getConfiguredTugResource(_movementType : String);
/*
Purpose:	

Date		Who		Reason
05 December 2024	navab1	JIRA 33581
*/

vars
	hmsResUsed, pxyResUsed : HMS_ResourceUsed;
	movement : HMS_VoyageMovement;
	found : Boolean;
	wharf : HMS_Wharf;
	berth : HMS_Berth;
	resource : HMS_Resource;
	harbour : HMS_Harbour;
	pilot : HMS_MovementPilotDetails;
	line : HMS_LineCompany;
	tug : HMS_Tug;
	contractTugCharged, partOfContract : Boolean;
	idx : Integer;
	numTugs, qty : Integer;
begin
	if  self.myVoyage.myHMSVoyageData &lt;&gt; null then

		foreach movement in self.myVoyage.myHMSVoyageData.allVoyageMovements do
			if movement.moveType = _movementType then
				found := true;
				break;
			endif;
		endforeach;
		
		if found 
		and movement &lt;&gt; null then
			harbour := movement.myHarbour;

			numTugs := self.myVoyage.getVesselDefaultTugsForMovemnt(movement);

			if movement.allTugsUsed.size = 0 then
				if numTugs &gt; 0 then
					// ### need a resource so use first tug on harbour with a resource
					foreach tug in harbour.allTugs do : tugLoop
						resource := tug.getResourceForHarbourMovement(harbour,_movementType);
						if resource &lt;&gt; null then
							self.allConfiguredResource.add(resource);			
							break tugLoop;
						endif;
					endforeach;
				endif;
			else
				contractTugCharged := false;
				idx := 0;
				foreach tug in movement.allTugsUsed do
					idx := idx + 1;
					partOfContract := (numTugs &gt;= idx);
			
					if partOfContract and contractTugCharged then
						continue;
					endif;
			
					if partOfContract then
						qty := numTugs;
					else
						qty := movement.allTugsUsed.size - numTugs;
					endif;
					resource := tug.getResourceForHarbourMovement(harbour,_movementType);
					if resource &lt;&gt; null then
						self.allConfiguredResource.add(resource);			
					endif;
			
					if partOfContract then
						contractTugCharged := true;
					else 
						break;
					endif;
				endforeach;

			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_movementType" type="String"/>
    </JadeMethod>
    <JadeMethod name="getConfiguredWharfResource" id="27bca810-c69c-46a9-86f7-2f54faa120a4">
        <source>getConfiguredWharfResource(_movementType : String);
/*
Purpose:	

Date		Who		Reason
05 December 2024	navab1	JIRA 33581
*/

vars
	movement, prevMove, moveToUse : HMS_VoyageMovement;
	found : Boolean;
	wharf : HMS_Wharf;
	berth : HMS_Berth;
	wharfRes : HMS_ResourceForWharf;
	harbour : HMS_Harbour;
begin
	if  self.myVoyage.myHMSVoyageData &lt;&gt; null then

		foreach movement in self.myVoyage.myHMSVoyageData.allVoyageMovements do
			if movement.moveType = _movementType then
		
				// ### JIRA 34271 05MAR2025 NAVAB1 - if departure use the previous movement as this is where it departed FROM.
				if _movementType = HMSMovementTypeDeparture then
					moveToUse := prevMove;
					found := true;
					break;
				endif;
				
				moveToUse := movement;
				found := true;
				break;
			endif;
			prevMove := movement;
		endforeach;
		
		if found 
		and moveToUse &lt;&gt; null then
			berth := moveToUse.getMyBerth();
			if berth &lt;&gt; null then
				wharf := berth.myWharf;
				
				if wharf &lt;&gt; null then
					harbour := wharf.getHarbourReal();
					if harbour &lt;&gt; null then
						wharfRes := wharf.allResourcesForWharf[harbour, wharf, HMS_Wharf.First_Resource];
						self.addWharfRes(wharfRes,_movementType);
						wharfRes := wharf.allResourcesForWharf[harbour, wharf, HMS_Wharf.Second_Resource];
						self.addWharfRes(wharfRes,_movementType);
					endif;
				endif;
				
			endif;	
		endif;
		
	endif;


 

epilog

end;</source>
        <Parameter name="_movementType" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentInvLines" id="de920708-d800-4bec-980d-3ac0395b1a86">
        <updating/>
        <source>getCurrentInvLines() updating;
/*

Purpose:			 // TFS 37454

Parameters:			

Return Value:		

Date			Who		Reason
15 March 2018	jlgab1	Initial creation
18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels

*/

vars

	trx : CM_TITransaction;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	payment	: CM_CashPayment;
	terminal : CM_Terminal;
begin
	
	if self.myVoyage = null then
		return;
	endif;
	
	terminal := self.myVoyage.myTerminal;
	
	foreach invoice in self.myVoyage.allInvoices	discreteLock do
		foreach invLine in invoice.invoiceLines  where invLine.debtor.isCashOnlyDebtor(terminal) do  
			// Only include HMS Resources and Voyage Event
			if not invLine.isVoyageForProforma() then
				continue;
			endif;
			
			if invLine.voided or
			   invLine.lineTotal = 0 then
				if invLine.lineTotal = 0 then // TFS 7311
					// TFS 7311 added logging
					app.invLog("Vessel Invoice Line " &amp; invLine.sequenceNum.String &amp; " ignored - zero value, possibly no RATE", LogINFO.String);
				endif;
				
				continue;
			endif;
			
			self.allCurrentInvLines.add(invLine);
			
			// TFS 37963 if an invoice line is not fully paid then set selectedInvoiced to FALSE 
			//					and we will create a transient invoic eline seperately for the amount OWING.
			// 				See CM_CashInvoiceProformaAgent.allOwingInvoicedLines and selectedOwing
			/* TFS 45953 we only put invoice lines in allCurrentInvLines when needed, no longer control with selectedInvoiced array
			self.selectedInvoiced.add(invLine.isPaidFor());		// initialise selection
			*/
		// TFS 45953 	self.paidInvoiced.add(false);			// 36102, is updated below in updateInvoicedPaid 
			self.invoicedCashCharges := self.invoicedCashCharges + invLine.lineTotal;
		endforeach;
	
	endforeach;
	
			
	// 33885 show existing payments if they exist, regardless of option settings - they can be from a second payment for remaining gate charges
	//	even if partial payments are not allowed
		foreach payment in self.myVoyage.allCashPayments do
		
			// Only include HMS Resources and Voyage Event
			if payment.myInvoiceLine &lt;&gt; null 
			and not payment.myInvoiceLine.isVoyageForProforma() then
				continue;
			endif;
			
			// 35232 skip voided payments
			if payment.voided then
				continue;
			endif;
			
			if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
				continue;
			endif;
	
			self.allCashPayments.add(payment);
			self.cashPayments := self.cashPayments + payment.cashValue;
		endforeach;
	
	self.updateProformaPaid();
	// TFS 45953 	self.updateInvoicedPaid();	


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCurrentResourceUsed" id="90e223d3-6d4e-4474-9551-c3fd137055b2">
        <source>getCurrentResourceUsed();
/*
Purpose:	

Date		Who		Reason
05 December 2024	navab1	JIRA 33576
*/

vars
	hmsResUsed, pxyResUsed : HMS_ResourceUsed;
	movement : HMS_VoyageMovement;

begin
	if  self.myVoyage.myHMSVoyageData &lt;&gt; null then
		foreach movement in self.myVoyage.myHMSVoyageData.allVoyageMovements	discreteLock do
			foreach hmsResUsed in movement.allResourceUsed	discreteLock do
				if  hmsResUsed.myVTMISTransaction &lt;&gt; null then
					if not hmsResUsed.myVTMISTransaction.allInvoiceLines.isEmpty() then
						self.allCurrentResource.addNoDuplicates(hmsResUsed.myResource, false);
						self.allCurrentResourceUsed.addNoDuplicates(hmsResUsed, false); 
					endif;
				elseif hmsResUsed.myResource &lt;&gt; null then
					self.allCurrentResource.addNoDuplicates(hmsResUsed.myResource, false);
					self.allCurrentResourceUsed.addNoDuplicates(hmsResUsed, false); 
				endif;
			endforeach;
		
		endforeach;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getParentConsolidatedCharges" id="2e7fa56c-9d9a-4b60-ba32-dd261b22d54a">
        <source>getParentConsolidatedCharges(_numRows : Integer output; 
							_invoiceLines : ObjectArray input;
							_estimateLines : ObjectArray input;
							_extraLines : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/03/2015	cnwjre1	GPHA 2368 34917 get the parent and all child charges consolidated.
30/10/2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charges - may get here without a TI
*/

vars
	invLine, unpaidInvLine : CM_InvoiceLine;
	invoicedCount,
	estimatedCount,idx,
	extraCount	: Integer;
	invoicePaidFor : Boolean;
	unpaidAmount : Decimal[16,6];
begin

	// current charges
	//if self.myTrackedItem.isParent and									// PAR #36909
	/* // TFS 45953
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isParent and		// PAR #36909
	   not self.allConsolidatedInvLines.isEmpty then
		foreach invLine in self.allConsolidatedInvLines do
			_invoiceLines.add(invLine);
			invoicedCount := invoicedCount + 1;
		endforeach;
	else
	*/
		foreach invLine in self.allCurrentInvLines do
			_invoiceLines.add(invLine);
			invoicedCount := invoicedCount + 1;
			
			// TFS 37963
			invoicePaidFor := invLine.isPaidFor();			
			if not invoicePaidFor then
				unpaidInvLine := invLine.getUnpaidInvLineForProforma(); // TFS 37963
				_invoiceLines.add(unpaidInvLine);
				self.allOwingInvoicedLines.add(unpaidInvLine);
// TFS 45953				idx := self.selectedOwing.size + 1;
// TFS 45953				self.selectedOwing[idx] := true;
				invoicedCount := invoicedCount + 1;
			endif;
			
		endforeach;
	// TFS 45953endif;
	
	// estimated charges
	//if self.myTrackedItem.isParent and									// PAR #36909
	/* // TFS 45953
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isParent and		// PAR #36909
	   not self.allConsolidatedProfInvLines.isEmpty then
		foreach invLine in self.allConsolidatedProfInvLines do
			_estimateLines.add(invLine);
			estimatedCount := estimatedCount + 1;
		endforeach;
	else
	*/
		foreach invLine in self.allProformaInvLines do
			if invLine.manual then		// 36405 get prior manual/extra charge
				_extraLines.add(invLine);
				extraCount := extraCount + 1;
			else
				_estimateLines.add(invLine);
				estimatedCount := estimatedCount + 1;
			endif;
		endforeach;
// TFS 45953	endif;

	// extra charges
		/*  TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty
	foreach invLine in self.allExtraProfInvLines where invLine.trackedItem = self.myTrackedItem do
		_extraLines.add(invLine);
		extraCount := extraCount + 1;
	endforeach;
	*/
	// number of rows to show is max of invoiced, estimated and extra columns content
	_numRows := invoicedCount.max(estimatedCount);
	_numRows := _numRows.max(extraCount);

epilog

end;</source>
        <Parameter name="_numRows" type="Integer" usage="output"/>
        <Parameter name="_invoiceLines" type="ObjectArray" usage="input"/>
        <Parameter name="_estimateLines" type="ObjectArray" usage="input"/>
        <Parameter name="_extraLines" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProformaTransactionCriteria" id="41c0fd10-057d-4a5c-af61-409e4af07133">
        <updating/>
        <source>getProformaTransactionCriteria() updating;
/*

Purpose:			// TFS 37454

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2018	jlgab1	Initial creation

*/

vars

begin
	if self.myVessel = null then
		return;
	endif;
	
	if self.myBank = null then
		return;
	endif;
	
	
	self.selectedTrxCriteria := self.myBank.getVesselProforma(self.myVessel);
	
	if self.selectedTrxCriteria = null then
		self.selectedTrxCriteria := self.myBank.getVesselProformaDefault();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="cfc3f87d-4972-466d-a501-2a0b399d1728">
        <source>getTerminal() : CM_Terminal;
/*

Purpose:			// TFS 37454

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2018	jlgab1	Initial creation

*/

vars

begin
	if self.myVoyage &lt;&gt; null then
		return self.myVoyage.myTerminal;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="90bdaa18-9dc7-4140-aaa4-5bf3cf80e5ee">
        <source>getVoyage() : CM_Voyage;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2018	jlgab1	Initial creation

*/

vars

begin
	return self.myVoyage;
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="151193af-6f54-4bda-803c-5db25aaa8adf">
        <updating/>
        <source>initialise(_myVoyage : CM_Voyage;
		_effDate : Date;
		_includeManual : Boolean;// TFS 45953 18OCT19 this is only ever passed in as false. So removing self.includeManual
		_isInwardGate : Boolean
		) updating;
/*

Purpose:			// TFS 37454

Parameters:			

Return Value:		

Date			Who		Reason
13 March 2018	jlgab1	Initial creation
18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	bank 		: CM_Bank;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
begin

	canLogExtra := app.canLogExtraDetail();		//5.3.2025 navma1 #34141		
	
	if _myVoyage= null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("** CANNOT Create pro forma invoice lines for VOYAGE, voyage is null **", LogINFO.String);
		endif;
		return;
	endif;
		bank := _myVoyage.myDischargeCompany;

	// TFS 45953 as of 18OCT19 this is only set to FALSE so removing - 	self.includeManual := _includeManual;
	self.ignoreProformaForRoadRelease := _isInwardGate;
	self.effectiveDate 				  := _effDate;
	self.allProformaCriteria.clear();
	self.myVoyage 					  := _myVoyage;
	self.myVessel 					  := self.myVoyage.getMyVessel();
	self.myBank 					  := bank;
	
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);
		app.invLog("** Create pro forma invoice lines for VOYAGE " &amp; self.myVoyage.code &amp; " **", LogINFO.String);
		app.invLog(" ", LogINFO.String);
		app.invLog("Find the Estimated Charges", LogINFO.String);
	endif;
	
	if self.myVessel = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No Vessel specified, cannot create vessel proforma invoice lines.", LogINFO.String);
		endif;
		return;
	endif;
	
	if self.myBank = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No bank specified, cannot create vessel proforma invoice lines.", LogINFO.String);
		endif;
		return;
	endif;
	
	self.getProformaTransactionCriteria();
	
	// ### JIRA 33576 05DEC2024 NAVAB1
	self.getCurrentResourceUsed(); 

	
	// ### JIRA 33581 05DEC2024 NAVAB1
	self.getConfiguredWharfResource(HMSMovementTypeArrival);
	self.getConfiguredWharfResource(HMSMovementTypeDeparture);
	self.getConfiguredWharfResource(HMSMovementTypeShift);
	
	self.getConfiguredLaunchResource(HMSMovementTypeArrival);
	self.getConfiguredLaunchResource(HMSMovementTypeDeparture);
	self.getConfiguredLaunchResource(HMSMovementTypeShift);
	
	self.getConfiguredPilotResource(HMSMovementTypeArrival);
	self.getConfiguredPilotResource(HMSMovementTypeDeparture);
	self.getConfiguredPilotResource(HMSMovementTypeShift);
	
	self.getConfiguredLineResource(HMSMovementTypeArrival);
	self.getConfiguredLineResource(HMSMovementTypeDeparture);
	self.getConfiguredLineResource(HMSMovementTypeShift);
	
	self.getConfiguredTugResource(HMSMovementTypeArrival);
	self.getConfiguredTugResource(HMSMovementTypeDeparture);
	self.getConfiguredTugResource(HMSMovementTypeShift);
	
	if self.selectedTrxCriteria = null 
	and self.allConfiguredResource.isEmpty
	and self.allCurrentResourceUsed.isEmpty then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " There are NO pro forma vessel transaction types configured and no actual resources recorded", LogINFO.String);
		endif;
		return;
	endif;
	
	self.myDebtor := self.myVoyage.myDebtor.CM_Debtor;
epilog

end;</source>
        <Parameter name="_myVoyage" type="CM_Voyage"/>
        <Parameter name="_effDate" type="Date"/>
        <Parameter name="_includeManual" type="Boolean"/>
        <Parameter name="_isInwardGate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCashPaymentCreation" id="2842d1a5-2a52-4732-957d-728f7656b82e">
        <updating/>
        <source>setForCashPaymentCreation(_voyage : CM_Voyage; _transInvLine : CM_InvoiceLine) updating;
/*

Purpose:		PELINDO 1 WEB PORTAL ONLY	

Parameters:			TFS 37839
	

Return Value:		

Date		Who		Reason
21 March 2018	jlgab1	Initial creation

*/

vars

begin
			self.initialise(_voyage, null, false, false );
			self.allProformaInvLines.add(_transInvLine);
			self.setEstimatedCashCharges();

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_transInvLine" type="CM_InvoiceLine"/>
    </JadeMethod>
</Class>
