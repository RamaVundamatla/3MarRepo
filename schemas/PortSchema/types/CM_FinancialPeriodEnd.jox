    <JadeMethod name="setForCreateCMS" id="6789e7d0-b30f-4452-a11c-c03706c9278c">
        <updating/>
        <source>setForCreateCMS(_theDates : CM_DateTimeDict; _theBank : CM_Bank input; _desc : String; _default : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aDateTime : CM_DateTime;
	aFPEDate	: CM_FinancialPeriodDateTime;
begin
	if _theDates &lt;&gt; null then
		foreach aDateTime in _theDates do
			if not global.isValidObject(aDateTime) then
				continue;
			endif;
			
			create aFPEDate;
			aFPEDate.setForCreateCMS(aDateTime.dateTime,null,self);
		endforeach;
	endif;	
	self.myBank := _theBank;
	self.description := _desc;
	self.isDefault := _default;
end;</source>
        <Parameter name="_theDates" type="CM_DateTimeDict"/>
        <Parameter name="_theBank" type="CM_Bank" usage="input"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_default" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3e7e52f1-5919-4229-93cb-a19a424f3111">
        <updating/>
        <source>setForUpdate(_pxy : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFPE : SelfType;
begin
	self.description := _pxy.description;

	
	if _pxy.isDefault then
		foreach theFPE in app.myRoot.myRootCompany.allFinancialPeriods do
			if theFPE &lt;&gt; self and theFPE.isDefault then
//				app.myPassport.myTerminal.causeEvent(app.myPassport.myTerminal.getTerminalEvent(EVENT_FINPERIOD_UPDATE),false,theFPE);
				app.myRoot.causeEvent(EVENT_FINPERIOD_UPDATE,false,theFPE);
			endif;

			theFPE.setDefault(false);
		endforeach;
	
		self.isDefault := true;
	else
		self.isDefault := false;
	endif;
	
end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCMS" id="d9564a10-2f05-4354-b492-db333bce241d">
        <updating/>
        <source>setForUpdateCMS(_desc : String; _debtors : CM_DebtorNodeByNameDict) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aDebtor : CM_DebtorNode;
begin
	self.description := _desc;
	
	foreach aDebtor in self.allDebtors do
		aDebtor.setFPE(null);
	endforeach;
	foreach aDebtor in _debtors do
		aDebtor.setFPE(self);
	endforeach;
end;</source>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_debtors" type="CM_DebtorNodeByNameDict"/>
    </JadeMethod>
