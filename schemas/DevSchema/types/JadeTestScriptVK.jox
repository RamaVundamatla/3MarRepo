<Class name="JadeTestScriptVK" id="75d2890e-29ee-4848-a3e0-c640aa3ecf69">
    <superclass name="JadeScript"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="displayClassName" id="67a4c840-c852-4e9c-9e27-150e1338081c">
        <source>displayClassName();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2025	navnk30	Initial creation

*/

constants
	Separator	: String = "::";
vars
	property		: Property;
	klass			: Class;
	klassName		: String;
begin
	klass := CM_TrackedItem.class;
	klassName := klass.name;
	foreach property in klass.cnGetProperties() do
		write klassName &amp; Separator &amp; property.name;
	endforeach;
epilog

end;</source>
    </JadeMethod>
</Class>
