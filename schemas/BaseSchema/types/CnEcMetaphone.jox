<Class name="CnEcMetaphone" id="918a160c-ac9a-4148-957e-953caf2d90cf">
    <superclass name="CnEcStringTransform"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
