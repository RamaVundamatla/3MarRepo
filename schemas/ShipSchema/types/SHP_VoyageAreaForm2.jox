	objs.copy(objset);


//	theENQ := self.doGetSelectorTIs(objset);

	self.myAssistant.SHP_Assistant.showVoyageLoadListForm(self.myCurrentVoyage, objset,  self.myMasterMenuAction);
	
epilog
