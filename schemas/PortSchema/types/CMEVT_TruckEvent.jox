    <JadeMethod name="setTruckSealCheckDetails" id="828d4f01-a760-4233-bbc8-120dbfafbd09">
        <updating/>
        <source>setTruckSealCheckDetails(_pxySealCheckDetails : CM_SealCheckDetailSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars
	any 				: Any;
	obj 				: Object;
	allSealCheckDetails : CM_SealCheckDetailSet;
	pxySealCheckDetail 	: CM_SealCheckDetail;
	realSealCheckDetail : CM_SealCheckDetail;
	
begin

	if self.type &lt;&gt; EVT_TruckSealCheck then
		return;
	endif;
	
	any := self.getExtraData( self.AllSealCheckDetails );
	if any &lt;&gt; null then
		if any.isKindOf( CM_SealCheckDetailSet ) then
			allSealCheckDetails := any.CM_SealCheckDetailSet;
			if not allSealCheckDetails.isEmpty then
				allSealCheckDetails.purge();
			endif;
			delete allSealCheckDetails;
		endif;	
	endif;
	
	if _pxySealCheckDetails = null or _pxySealCheckDetails.isEmpty then
		return;
	endif;
	
	create allSealCheckDetails persistent;
	
	foreach obj in _pxySealCheckDetails do
		pxySealCheckDetail := obj.CM_SealCheckDetail;
		create realSealCheckDetail;
		realSealCheckDetail.setFromProxy(pxySealCheckDetail);
		allSealCheckDetails.add( realSealCheckDetail );
	endforeach;
	
	if allSealCheckDetails.isEmpty then
		delete allSealCheckDetails;
		return;
	endif;
	
	self.setExtraData( self.AllSealCheckDetails, allSealCheckDetails );
	
epilog

end;</source>
        <Parameter name="_pxySealCheckDetails" type="CM_SealCheckDetailSet"/>
    </JadeMethod>
</Class>
