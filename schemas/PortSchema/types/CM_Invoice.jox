    <JadeMethod name="getEstimationsStrings" id="b4647175-e144-43c5-ae38-747e5ba1d501">
        <source>getEstimationsStrings(_separator :String):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Dec 2018	cnwma1	Bug 42441: PEL1 - Missing Estimation ID WSDL 1.2 - Autocollection
23 Jan 2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
*/


vars
  cashRec 		  : CM_CashReceipt;
  invline		  : CM_InvoiceLine;
  cashRecMatched  : ObjectArray;
  str,
  sep 	 		  : String;
  obj     		  : Object;
 begin
	
	if _separator  = null then
		sep := ",";
	elseif _separator = "CrLf" then
		sep := CrLf;
	else
		sep := _separator ;
	endif;
	
	
	//03.01.2019 cnwma1 42441
	create cashRecMatched transient;
	self.findCashReceipts(cashRecMatched);
	if cashRecMatched.isNotEmpty then
		foreach obj in cashRecMatched do
			/*
				14.03.2019 cnwma1 #43549
				Estimation ID assigned to an Auto-collection Invoice, 
				should only take the Estimation ID which Cash Receipt status is still Approved (not Paid).  
			*/
			if obj.CM_CashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED or	
				obj.CM_CashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.API_RECEIPT_FINAL //11/07/2024	navkc1 CR 64837 Task 64851
				then
				continue;
			endif;	
			
			if str &lt;&gt; null then
					
				str := str &amp; sep &amp; obj.CM_CashReceipt.externalInvoiceNumber;
			else
				str := obj.CM_CashReceipt.externalInvoiceNumber;
			endif;
		endforeach;
	endif;
	
	return str;
epilog
	delete cashRecMatched;
end;</source>
        <Parameter name="_separator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExchangeRateForCurrencyCode" id="a3c59738-c39a-4ec0-b210-5cb48d994ccf">
        <source>getExchangeRateForCurrencyCode(_typeCode : String ):Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2018	jlgma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces

*/

vars

	currencyType : CM_CurrencyType;
	rate : CM_CurrencyRate;
	effectiveDT : TimeStamp;

begin

	if _typeCode.trimBlanks = null then
		return 0.0;
	endif;
	
	currencyType := app.myRoot.allCurrencyTypes.getAtKey(_typeCode).CM_CurrencyType;
	
	if currencyType = null then
		return 0.0;
	endif;
	
/*	effectiveDT := self.getRateDateFromStatus();
	
	
	if not effectiveDT.isValid() then
		effectiveDT := self.toDT;
	endif;
	
	if not effectiveDT.isValid() then
		effectiveDT := self.postedDT;
	endif;
	
	if not effectiveDT.isValid() then
		effectiveDT := self.createdTime;
	endif; */
	
	effectiveDT := self.getRateDateForCurrencyCode();	//19 Sep 2018	NDL	TFS 40908
	
	rate := currencyType.getRate( effectiveDT );
	
	if rate = null then
		return 0.0;
	endif;
	
	return rate.rate;

epilog

end;</source>
        <Parameter name="_typeCode" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getExchangeRateForInvCurrCode" id="92d40eba-d7fb-4aa2-a993-3cf9d63020bf">
        <source>getExchangeRateForInvCurrCode() : Decimal;
/*

Purpose:			Gets the exchange rate for the invoice currency code

Parameters:			NONE

Return Value:		Decimal	Representing the exchange rate converted to the invoice currency code

Date		Who		Reason
30 August 2022	navpw1	Initial creation TFS: 54564 (54376)

*/

begin
	if self.myCurrencyType = null then
		return null;
		
	endif;
	
	return self.getExchangeRateForCurrencyCode(self.myCurrencyType.code);
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getExtInvNumberUpper" id="c4c245b8-d016-4555-b606-03c7ebf769af">
        <source>getExtInvNumberUpper() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2023 navmv20 Bug 57023: EUP - inconsistent search behaviour with external number

*/

vars
	extInvNum : String;
begin
	extInvNum:= self.getExternalInvoiceNumber();
	if extInvNum &lt;&gt; null then
		return extInvNum.toUpper();
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExternalFinancialId" id="45b68dd2-5695-4c75-977a-dfc403309157">
        <source>getExternalFinancialId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	str  : String;
begin
	
	
	str := self.externalFinancialId;
	
	if str = null then
		str := self.exportCurrencyCode;
	endif;
	
	return str;
	
epilog

end;</source>
        <ReturnType type="String"/>
