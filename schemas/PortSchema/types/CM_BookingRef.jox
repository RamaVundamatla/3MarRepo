    <JadeMethod name="getVoyageDescription" id="22d580e2-f9f5-4dec-9440-0ec7aaec1569">
        <source>getVoyageDescription() : String;
// ---------------------------------------------------------------------------
// Created:     19 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
	tmpDT : TimeStamp;
begin
	if self.myVoyage = null then
		return null;
	endif;
	
	tmpStr :=  self.myVoyage.vesselCode &amp; " " &amp; self.myVoyage.vesselName.trimBlanks &amp; " - " &amp; self.myVoyage.code;
	
	tmpDT := self.myVoyage.departedDT;
	if tmpDT.isValid() then
		tmpStr := tmpStr &amp; " - " &amp; tmpDT.asStringJMT();
	endif;
	
	return tmpStr;
epilog

end;</source>
