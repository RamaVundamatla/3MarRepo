    <JadeMethod name="getCurrentSettings" id="eba39023-aaee-4680-af52-94a02880494b">
        <updating/>
        <source>getCurrentSettings(_sysColorBackGeneral,
				   _sysColorForeGeneral,
				   _sysColorBackTable,
				   _sysColorForeTable,
				   _userColorBackGeneral,
				   _userColorForeGeneral,
				   _userColorBackTable,
				   _userColorForeTable			: Integer output;
				   _machineCode					: String output;
				   _machineLiftType				: Integer output;
				   _primaryQueueId				: String output;
				   _numberOfQueueEntries		: Integer output;
				   _canChangeQueue				: Boolean output;
				   _canRunSelectorQueries		: Boolean output;
				   _showNumberofQueueEntries	: Boolean output;
				   _portLogo					: Binary output;
				   _state						: Integer output;
				   _lastState					: Integer output;
				   _errorString					: String output;
				   _lastUpdateTs				: TimeStamp output;
				   /*
					Date		Who		Reason			
					20 Aug 2008	cnwdz2	Par 17782 CCMS Otago 1722 - Thin Client RT Changes:
				   */
				   _rtQueueAfterSetdown			: Boolean output) : Boolean updating;

/*

Purpose:			Get all the current settings from the database


Return Value:		True if successful


Date		Who		Reason
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/


vars
	rtnValue		: Boolean;
	dtoColor		: MobileServerRTThin::DTO_Colours;

begin
	self.clearStateObject();
	
	create dtoColor transient;
	
	rtnValue := self.myRTThinClientAgent.getCurrentSettings(dtoColor, self.myStateObj);

	_sysColorBackGeneral	:= dtoColor.sysColorBackGeneral;
	_sysColorForeGeneral	:= dtoColor.sysColorForeGeneral;
	_sysColorBackTable		:= dtoColor.sysColorBackTable;
	_sysColorForeTable		:= dtoColor.sysColorForeTable;
	_userColorBackGeneral	:= dtoColor.userColorBackGeneral;
	_userColorForeGeneral	:= dtoColor.userColorForeGeneral;
	_userColorBackTable		:= dtoColor.userColorBackTable;
	_userColorForeTable		:= dtoColor.userColorForeTable;
	_machineCode			:= dtoColor.machineCode;
	_machineLiftType		:= dtoColor.machineLiftType;
	_primaryQueueId			:= dtoColor.primaryQueueId;
	_numberOfQueueEntries	:= dtoColor.numberOfAvailableQueueEntries;
	_canChangeQueue			:= dtoColor.canChangeQueue;
	_canRunSelectorQueries	:= dtoColor.canRunSelectorQueries;
	_showNumberofQueueEntries	:= dtoColor.showNumberOfQueueEntries;
	_rtQueueAfterSetdown    := dtoColor.rtQueueAfterSetdown;// par 17782 ccms 1722 cnwdz2 21/08/2008
	
	_portLogo				:= dtoColor.portLogo;
	
	_errorString 		:= self.myStateObj.errorString;
	_state 				:= self.myStateObj.guiState;
	_lastUpdateTs		:= self.myStateObj.lastUpdateTs;
	_lastState			:= self.myStateObj.extraInfo;
	
	return rtnValue;
	
	
epilog	
	delete dtoColor;
	
end;</source>
