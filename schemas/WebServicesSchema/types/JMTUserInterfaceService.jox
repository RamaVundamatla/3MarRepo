    <JadeWebServicesMethod name="getSnapshots" id="44d605f7-dc07-44ed-92b0-29f1d347a504">
        <source>getSnapshots(request: WS_SnapshotsRequest) : WS_SnapshotsResponse webService;
/*
Purpose:	

Date		Who		Reason
16 May 2012	cnwdw1	Initial creation
*/
vars
	response: WS_SnapshotsResponse;
	completedOK: Boolean;
	
	agent: CM_KEAAgent;
	item: String;
	now, at: TimeStamp;
	snapshots: CM_KPISnapshotDtlArray;
	snapshot: CM_KPISnapshotDtl;
	items: CM_ObjectSetActual;
	pos: Integer;
	type: String;
	tokens: StringArray;
	ta: CM_TerminalArea;
	voyage: CM_Voyage;
	
	ws_snapshot: WS_KPISnapshotDtl;	
	
	diff : Integer;
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	now := app.actualTimeServer;
	at := request.at.asTimeStampFromWebInterface;
	
	diff := now.cnSecondsDifference(at);
	
	//cnwmc5
	if at.isValid and at.date.year &gt;= 2012 then
		create agent transient;
		create items transient;
		agent.parseSnapshots(request.items, items);
		
		if items.size &gt; 0 then
			create snapshots transient;
			agent.getSnapshots(items, at, app.myPassport.myTerminal, snapshots);
			
			foreach snapshot in snapshots do
				if snapshot.isKindOf(CM_KPIYardSnapshotDtl) then
					create ws_snapshot as WS_KPIYardSnapshotDtl transient;
				elseif snapshot.isKindOf(CM_KPIVoyageSnapshotDtl) then
					create ws_snapshot as WS_KPIVoyageSnapshotDtl transient;
				elseif snapshot.isKindOf(CM_KPITrainSnapshotDtl) then
					create ws_snapshot as WS_KPITrainSnapshotDtl transient;
				elseif snapshot.isKindOf(CM_KPIRoadSnapshotDtl) then
					create ws_snapshot as WS_KPIRoadSnapshotDtl transient;
				endif;
				ws_snapshot.setFrom(snapshot);
				response.allSnapshots.add(ws_snapshot);
			endforeach;
		endif;
	else
		app.raiseCMException1(KEA_ERROR, "Invalid at (" &amp; request.at &amp; ") timestamp. Format should be dd/MM/yyyy HH:mm:ss Current: " &amp; now.String, null, null);
	endif;

	
	completedOK := true;
	return response;

epilog
	delete agent;
	delete items;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_SnapshotsRequest"/>
        <ReturnType type="WS_SnapshotsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getSourceLocationsForOperator" id="52f4c023-1cac-4f98-9811-a953dd6b5fd7">
        <usesRPC>default</usesRPC>
        <source>getSourceLocationsForOperator(operatorId : String) : WS_CodeResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars
	obj			: Object;
	operator	: CM_Operator;
	srcLocation	: CM_Code;
	pxySrcLoc	: WS_Code;
	response	: WS_CodeResponse;
	allLocs		: CM_CodesByCodeDict;
	completedOK	: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	//epr TFS 5535 4/8/17
	operator := app.myPassport.getObjectOfTypeFromOid(operatorId,CM_Operator).CM_Operator;
	
	if operator &lt;&gt; null then
		allLocs := operator.getAllSrcLocn();
		if allLocs &lt;&gt; null then //null can be return from the method
			foreach srcLocation in allLocs discreteLock do
				create pxySrcLoc transient;
				pxySrcLoc.setProxyFromObject(srcLocation);
				response.allCodes.add(pxySrcLoc);
			endforeach;
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getSourceLocationsForOperator</wsdlName>
        <Parameter name="operatorId" type="String"/>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getSourceSubLocations" id="be1d2b70-0f56-4258-bbb0-614a11ff4854">
