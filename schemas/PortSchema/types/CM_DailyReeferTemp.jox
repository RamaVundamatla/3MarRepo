<Class name="CM_DailyReeferTemp" id="35035f5a-99cb-4cdc-95d1-22974dc40114">
    <superclass name="CM_PackTempReading"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Entries in a collection of container temperatures</text>
    <DbClassMap file="transact"/>
    <PrimAttribute name="flags" id="947c00fd-39dc-4147-b33a-98e725c9572f">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="connected" id="0c6c48aa-580c-42ac-be88-7c330a88bfd8">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>connected(set: Boolean; _value: Boolean io) mapping, updating;

constants
	DRT_FLAGS_CONNECTED = #01;
vars
	notConnected : Integer;
begin
	if set then
		if _value then
			self.flags := self.flags.bitAnd(DRT_FLAGS_CONNECTED);	//Turn ON connected
		else
			notConnected := DRT_FLAGS_CONNECTED;
			notConnected := notConnected.bitNot();
			self.flags := self.flags.bitAnd(notConnected);	//Turn OFF the connected
		endif;
	else	 //GetInstVar
		_value := (flags.bitOr(DRT_FLAGS_CONNECTED) &lt;&gt; 0 );
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="displayTempFahrenheit" id="fb7d74d1-c876-43f2-a98e-132df9d38a28">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>displayTempFahrenheit(set: Boolean; _value: Boolean io) updating, mapping;
//
// 11/12/2009	cnwdap1		CCMS MES 1007 reference to myContainer is redundant, should be myReeferProperties now
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

begin
	if set then
		//do nothing
	else
		_value := self.myReeferProperties.myParent.CM_TrackedItem.myOperator.displayTempFahrenheit;	// CCMS 1007
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="earlyTemp" id="02c93d18-54d0-47ef-87ab-744ed5db726d">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>earlyTemp(set: Boolean; _value: Real io) mapping, updating;

vars

begin
	if set then
		self.earlyTemp := _value;
	else
		_value := self.earlyTemp;
	endif;	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="earlyTempFahrenheit" id="ae72ae9f-28d3-44c5-9f3c-338158a9a8bb">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>earlyTempFahrenheit(set: Boolean; _value: Real io) updating, mapping;
//rs 2/12/2003 round all fahreinheit temps
// 11/12/2009	cnwdap1		CCMS MES 1007 reference to myContainer is redundant, should be myReeferProperties now
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin
	if set then
		//temperature is the real deal
	else
		if self.myReeferProperties.myParent.CM_TrackedItem.myOperator.displayTempFahrenheit then
			_value := app.myRoot.convCelsiusToFahrenheit(self.earlyTemp).rounded;
		else
			_value := NULL_TEMPERATURE;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="erase" id="b2e8296a-d575-4bc1-8bdc-773e42ae2621">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//
// 08/12/2009	cnwdap1		CCMS 1007 Temperature readings now attached to CM_ReeferProperties
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars

begin

	exclusiveLock(self);

	if self.myContainer &lt;&gt; null then		// and global.isValidObject(self.myContainer) then - inversed, can't be invalid
		self.myContainer := null;
	endif;
	// CCMS 1007
	if self.myReeferProperties &lt;&gt; null then		// and global.isValidObject(self.myReeferProperties) then
		self.myReeferProperties := null;
	endif;
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
