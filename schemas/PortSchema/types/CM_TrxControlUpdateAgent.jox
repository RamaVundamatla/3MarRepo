    <JadeMethod name="trxUpdateGLCList" id="b03ae423-8670-4a61-8e23-8370e39685d7">
        <updating/>
        <source>trxUpdateGLCList(_glcList : ObjectSet; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	16 May 2008 By Graeme Black cnwgb1 PAR 16483
// Status: Unfinished
// ---------------------------------------------------------------------------
// 25/08/2009	cnwcs5	ccms 1061 - road ops form changes (changed to handle CM_LaneController instead of CM_GateLaneController
vars
	obj 		: Object;
	lane 		: CM_LaneController;
	sendNote 	: Boolean;
	gate 	: CM_Gate;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _glcList = null then
		return;
	endif;
	
	beginTransaction;
	//epr par 32740 15/10/13
	lane :=_glcList.first.CM_LaneController;
	if lane &lt;&gt; null then
		gate:=lane.getGate;
	endif;
	if  gate &lt;&gt; null  then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(gate, true);
	endif;
	
	sendNote := true;
	foreach obj in _glcList do
		lane := obj.CM_LaneController;
			
		app.myUtilityUA.utlUpdateGateLaneDirection(lane, sendNote, _passport);
		
		if _passport.hasErrors then
			break;
		endif;
	endforeach;
	
	if _passport.noErrors and gate &lt;&gt; null then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(gate, false);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_glcList" type="ObjectSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
