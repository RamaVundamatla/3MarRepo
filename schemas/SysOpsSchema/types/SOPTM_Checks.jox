    <JadeMethod name="setupThumbnailDefaults" id="be98d2d0-77e3-4d7f-8e0c-229f7ff23ae2">
        <source>setupThumbnailDefaults();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod();
	
	// Cargo Checks can't be added or deleted - they are system created items, and there's nothing to edit either
	self.myForm.allowAdd 	:= false;
	self.myForm.allowUpdate	:= false;
	self.myForm.allowDelete := false;
	
	//tidies the buttons up
	self.myForm.frmToolbar.positionToolbarControls();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="447a8ba7-4b4d-4987-9150-9bb39bf86748">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	theForm : SOP_TableMaintForm;

begin
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CargoCheckMaintTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Context, false);

	theForm.shtTblInput1.caption := 'Details';
