    <JadeMethod name="doComboToVoyageClick" id="c6226950-384c-47d5-b731-9b36902df793">
        <updating/>
        <source>doComboToVoyageClick()updating;
//--------------------------------------------------
// Created:	20 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	voyage	: String;
begin

	voyage := self.tblActionData.getValueByName(ETRow_ToVoyage).String;
	self.myToVoyage	:= self.myTerminal.lookupVoyage(voyage, null, false).CM_Voyage;
	self.loadDestination();

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboVoyageClick" id="f3b9f38e-3705-4f91-a30e-3bde9433d9fb">
        <updating/>
        <source>doComboVoyageClick()updating, protected;
//--------------------------------------------------
// Created:	20 January 2006 By: cnwgd1
//--------------------------------------------------
vars
begin
	self.clear(CLEAR_ALL);
	self.tblSelection.setValueByControlName(self.cmbVoyage.name, self.cmbVoyage.text);
	self.myVoyage := self.cmbVoyage.listObject.CM_Voyage;
	
	if self.myVoyage &lt;&gt; null and self.myVoyage.myLogVoyageStructure &lt;&gt; null then
		self.cmbDocket.listCollection(myVoyage.allBOLOutByTypeStatusNumDT, true, 0);
		self.cmbLot.listCollection(self.myVoyage.myLogVoyageStructure.allLogLots, true, 0);
	endif;

	self.cmbToVoyage.listIndex := self.cmbToVoyage.findObject(self.myVoyage);
	self.myToVoyage := self.cmbToVoyage.listObject.CM_Voyage;
	if self.myToVoyage &lt;&gt; null then
		self.tblActionData.setValueByName(ETRow_ToVoyage, self.myToVoyage.code);
	endif;	

	self.loadDestination();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadDocket" id="aed4324d-1ecf-48cf-89fe-4a2c9759c15e">
        <source>doLoadDocket() protected;

vars

begin

	if (not self.allDocketLogDef.isEmpty) then
		self.allDocketLogDef.purge;
	endif;

	if self.myBolOut &lt;&gt; null then
		// Process tracked items to determine various log specs.
		self.myBolOut.myExtension.CM_BOLExtLog.getLogLocations(self.allDocketLogDef, CM_LogVoyageController, self.myTerminal);
		self.sortAndDisplay();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadLogIds" id="f9db669a-f3d9-4f4e-806c-5345efd09b21">
        <updating/>
        <source>doLoadLogIds()updating, protected;
//--------------------------------------------------
// Created:	20 January 2006 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
11 Mar 2015	cnwkpd1	PAR #35843 - Make progress bar updates time-based, not object counts
	
*/

vars
	tmpId : String;
	iter : Iterator;
	tmpTI : CM_TrackedItem;
	tmpTable : CM_DataTable;
	tmpDict : CM_TIByIdCargoTypeDict;
	cmifMonitor : CMIF_Monitor;
	tmpPartsInJob, tmpPartsDone : Integer;
	lastUpdate : Decimal[20];
begin

	// CCMS 1083
	
	if self.myVoyage = null then
		return;
	endif;
	
	tmpDict := self.myVoyage.allOnshipTIsByIdCargoType;
	tmpTable := self.tblSelectData;
	tmpId := self.tblSelection.getValueByName(ETRow_Id).String;
	
	if tmpId &lt;&gt; null then
		tmpTI := tmpDict.getAtKey(tmpId, null);
	endif;
	
	if tmpTI &lt;&gt; null then
		tmpTable.addItemObject(tmpTI, tmpTI.getAttributeStringForDefArray(tmpTable.allTblDataEntRows));	
	else
	
		iter := tmpDict.createIterator();
		if tmpId &lt;&gt; null then
			tmpDict.startKeyGeq(tmpId, null, iter);
		endif;

	   	create cmifMonitor transient;
	   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	   	cmifMonitor.myParent := self;
		tmpPartsInJob := tmpDict.size;
		self.pbProgressBar.partsInJob := tmpPartsInJob;
		self.modalDialogShow(null, 'Cancel', null, null, self.myVoyage.myLogVoyageStructure.getDisplayDetails(true), cmifMonitor.message);		
		self.pbProgressBar.visible := true;
				
		while iter.next(tmpTI) do
			
			tmpPartsDone := tmpPartsDone + 1;
			if (app.relativeMachineTime() - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
				if not cmifMonitor.updateProgress('Loading Data', tmpPartsInJob, tmpPartsDone) then
					break;
				endif;
				lastUpdate := app.relativeMachineTime();
			endif;			
			
			if tmpId &lt;&gt; null
			and (not tmpTI.id.startsWith(tmpId)) then
				break;
			endif;
			
			tmpTable.addItemObject(tmpTI, tmpTI.getAttributeStringForDefArray(tmpTable.allTblDataEntRows));
			
		endwhile;
		
	endif;
	
epilog
	delete iter;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadSpecs" id="9f3a4ec3-6384-45f9-885c-a471e7144a89">
        <source>doLoadSpecs() protected;

vars

	lot				: CM_LogLot;
	hatch,
	place			: Integer;
	log				: CM_TrackedItem;
	supplier,
	species,
	grade,
	type,
	treatment,
	placeStr,
	length			: String;
	def				: CMIF_DocketLogDef;
	analysis		: CM_SOHLocation;
	location		: CM_LogVoyageController;
	logProduct		: CM_ProductLog;
	locationSet		: CM_LogVoyageControllerSet;

begin

	if self.myVoyage = null or self.myVoyage.myLogVoyageStructure = null then
		return;
	endif;

	create locationSet transient;
	lot := self.cmbLot.listObject.CM_LogLot;
	if lot = null then
		self.myVoyage.myLogVoyageStructure.allLocationsByHatchPlaceLot.copy(locationSet);
	else
		lot.allLocationsByHatchPlace.copy(locationSet);
	endif;
	
	supplier	:= self.tblSelection.getValueByName(ETRow_Supplier).String;
	species		:= self.tblSelection.getValueByName(ETRow_Species).String;
	grade		:= self.tblSelection.getValueByName(ETRow_Grade).String;
	type		:= self.tblSelection.getValueByName(ETRow_Type).String;
	treatment	:= self.tblSelection.getValueByName(ETRow_Treatment).String;
	length		:= self.tblSelection.getValueByName(ETRow_Length).String;
	placeStr	:= self.tblSelection.getValueByName(ETRow_Place).String;
	hatch		:= self.tblSelection.getValueByName(ETRow_Hatch).Integer;

	place := app.vesselPlaceStrToEnum(placeStr);
			
	foreach location in locationSet do
		if hatch = null or location.hatch = hatch then
			if place = null or location.place = place then
				foreach analysis in location.allProductLocations do
					if analysis.myProduct.isKindOf(CM_ProductLog) and analysis.allTrackedItems.size &gt; 0 then	
						logProduct := analysis.myProduct.CM_ProductLog;
						//(supplier = null or logProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true) = supplier) 
						/*
							Date		  Who		Reason
							3 July 2008	 cnwdz2	    Par17290 - Search results are based on the selected operator.
						*/
						if (supplier = null or supplier.startsWith(logProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true))) and
							(species = null or species.startsWith(logProduct.speciesCode)) and // = species) and
							(grade = null or grade.startsWith(logProduct.gradeCode)) and				// 21/03/2013 cnwar2 #21911
							(type = null or type.startsWith(logProduct.typeCode)) and					// 21/03/2013 cnwar2 #21911
							(treatment = null or treatment.startsWith(logProduct.treatmentCode)) and	// 21/03/2013 cnwar2 #21911
							(length = null or length.startsWith(logProduct.lengthCode)) then			// 21/03/2013 cnwar2 #21911
							foreach log in analysis.allTrackedItems do
								self.allDocketLogDef.logSummary(log.CM_Log);
							endforeach;
						endif;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	
	self.sortAndDisplay();

epilog
	delete locationSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOptDocketClick" id="7e91cd70-8c5a-40e1-9b69-b3bba39ec98e">
        <updating/>
        <source>doOptDocketClick() protected, updating;

vars
begin

	if selection &lt;&gt; DOCKET then

		if self.selection = LOGID then
			// setup results table columns for dockets (middle table)
			self.loadSelectionData(ETDef_TransitTransferSpecs);		
		endif;
			
		selection := DOCKET;
		self.tblSelectData.setTerminologyRelevant(app.myRoot.allBOLTypes[BOLType_Log], self.myTerminal);
		self.tblSelectData.resetColumns(true);
		
		self.tblSelection.showHideRowsByViewName("viewTransitDocket", CM_EntryTable.ShowHideRows, false); 
		self.tblSelection.optimiseHeadingColumn();
		self.tblSelection.adjustHeight(1000);

		//setup move to table (bottom table)
		self.tblActionData.showHideRowsByViewName("viewTransitToID", CM_EntryTable.ShowHideRows, false); 
		self.tblActionData.optimiseHeadingColumn();

		self.setNavigatorHeading('By Docket');			
		self.resetDistances();

		// 10/06/2010 cnwar2 #24417
		/*if self.myVoyage &lt;&gt; null then
			self.doSearch();
		endif;*/
	endif;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOptLogIDClick" id="eb1b62a6-3280-4ce0-92dd-51c8a6271412">
        <updating/>
        <source>doOptLogIDClick() protected, updating;
//--------------------------------------------------
// Created:	20 January 2006 By: cnwgd1
//--------------------------------------------------
vars
str : String;
begin
	if self.selection &lt;&gt; LOGID then

		self.selection := LOGID;

		//setup search table (top table)		
		self.tblSelection.showHideRowsByViewName("viewTransitLogId", CM_EntryTable.ShowHideRows, false); 
		self.tblSelection.optimiseHeadingColumn();
		self.tblSelection.adjustHeight(1000);

		//setup results table (middle table)
		self.loadSelectionData(ETDef_TransitTransferResults);				
		self.tblSelectData.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
		self.tblSelectData.resetColumns(true);
		
		//setup move to table (bottom table)
		self.tblActionData.showHideRowsByViewName("viewTransitToID", CM_EntryTable.ShowHideRows, false); 
		self.tblActionData.optimiseHeadingColumn();
		self.moveToView := "viewTransitToID";				

		self.setNavigatorHeading('By Log ID');			
				
		self.resetDistances();
	
		// 10/06/2010 cnwar2 #24417
		/*if self.myVoyage &lt;&gt; null and self.tblSelection.getValueByName(ETRow_Id) &lt;&gt; null then
			self.doSearch();
		endif;*/
		
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOptSpecsSEDClick" id="1ca3d5b3-6cea-43a2-9dd3-9ed46077fe70">
        <updating/>
        <source>doOptSpecsSEDClick(_forSED : Boolean) protected, updating;
//--------------------------------------------------
// Created:	20 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	reSearch : Boolean;
begin

	if self.selection &lt;&gt; SPECS then

		if self.selection = LOGID then
			// setup results table columns for specs (middle table)
			self.loadSelectionData(ETDef_TransitTransferSpecs);		
		endif;
			
		self.selection := SPECS;
		
		//setup search table (top table)
		self.tblSelection.showHideRowsByViewName("viewTransitSpecs", CM_EntryTable.ShowHideRows, false); 
		self.tblSelection.optimiseHeadingColumn();
		self.tblSelection.adjustHeight(1000);
		
		//setup results table (middle table)
		self.tblSelectData.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
		self.tblSelectData.resetColumns(true);

		self.resetDistances();
		
		//reSearch := self.myVoyage &lt;&gt; null;	// 10/06/2010 cnwar2 #24417
		
	endif;

	if _forSED and self.moveToView &lt;&gt; "viewTransitToSED" then
		//setup move to table (bottom table)
		self.tblActionData.showHideRowsByViewName("viewTransitToSED", CM_EntryTable.ShowHideRows, false); 
		self.tblActionData.optimiseHeadingColumn();
		
		self.tblActionData.setValueByName(ETRow_ToCOperator, app.getErrorString(Greater_Than));
		self.moveToView := "viewTransitToSED";
		self.setNavigatorHeading('By SED');
					
	//elseif self.moveToView &lt;&gt; "viewTransitToSpec" then
	elseif not _forSED and self.moveToView &lt;&gt; "viewTransitToSpec" then	// 21/03/2013 cnwar2 #24244
		//setup move to table (bottom table)
		self.tblActionData.showHideRowsByViewName("viewTransitToSpec", CM_EntryTable.ShowHideRows, false); 
		self.tblActionData.optimiseHeadingColumn();
		
		self.tblActionData.setValueByName(ETRow_ToUOM, BOL_UOM_PIECE_COUNT);		
		self.moveToView := "viewTransitToSpec";		
		self.setNavigatorHeading('By Specs');
							
	endif;

	// 10/06/2010 cnwar2 #24417
	/*if reSearch then
		self.doSearch();
	endif;*/

end;</source>
        <access>protected</access>
        <Parameter name="_forSED" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="61471d6e-081c-421b-8ae2-e94309bfbdff">
        <updating/>
        <source>doResize() updating;

vars
	tmpValue	: Real;
begin
	inheritMethod();
	tmpValue 					:= (self.frmToolbar.height);
	self.grpOptionBtns.top		:= tmpValue;
	self.tblSelection.top 		:= tmpValue + self.grpOptionBtns.height;
	tmpValue					:= self.tblSelection.top + self.tblSelection.height + VerticalSpacing;
	self.tblSelectData.top		:= tmpValue;
	self.tblSelectData.height	:= self.clientHeight - tmpValue - self.tblActionData.height - VerticalSpacing*2;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="a72779a0-a3eb-4845-9434-463969e4fa73">
        <updating/>
        <source>doSave() : Boolean protected, updating;

vars
	tmpTISet			: CM_TISet;
	lot					: CM_LogLot;
	rtnValue,
	hatch,
	place				: Integer;
	placeStr			: String;
	location			: CM_VoyageController;		
	logVoyageController	: CM_LogVoyageController;
	proxyLocation		: CM_LogVoyageController;
	allCMIFBOLS			: CMIF_Array;
	rtnResult			: Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	// Sep 2011 28082 don't allow save for closed etc voyages
	if self.myToVoyage.isClosedStatus() then
		app.msgBox("This voyage status is " &amp; self.myToVoyage.statusDescription &amp; "," &amp; CrLf &amp; "no updates are allowed.", "Error", 0);
		return false;
	endif;

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();	
	
	create allCMIFBOLS transient;
	create tmpTISet transient;
	self.getSelectedTIs(tmpTISet);
	
	if tmpTISet.isEmpty then
		app.addErrorFullPassport(NoItemsSelected, app.getErrorString(NoItemsSelected), null, null, app.myPassport);
		return false;
	elseif app.myPassport.hasErrorsOrWarnings then
		rtnValue := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
		if rtnValue &lt;&gt; IDOK then
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		else
			self.clearErrorWarnings();		
		endif;
	endif;
	
	//get the move to location details
	lot			:= self.cmbToLot.listObject.CM_LogLot;
	hatch		:= self.tblActionData.getValueByName(ETRow_ToHatch).Integer;
	placeStr	:= self.tblActionData.getValueByName(ETRow_ToPlace).String;
	place 		:= app.vesselPlaceStrToEnum(placeStr);		
		
	if self.myToVoyage = null then
	//	app.addErrorFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'To Voyage'), null, null, app.myPassport);
		app.addErrorFullPassport(Input_required_field_toVoy, app.getErrorString(Input_required_field_toVoy), null, null, app.myPassport); // cnwdb2	PAR 35364


	elseif lot = null then
	//	app.addErrorFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'Lot'), null, null, app.myPassport);
		app.addErrorFullPassport(Input_required_field_lot, app.getErrorString(Input_required_field_lot), null, null, app.myPassport); // cnwdb2	PAR 35364		

	elseif hatch = null then
	//	app.addErrorFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'Hatch'), null, null, app.myPassport);
		app.addErrorFullPassport(Input_required_field_hatch, app.getErrorString(Input_required_field_hatchFild), null, null, app.myPassport); // cnwdb2	PAR 35364

	
	elseif placeStr = null then
	//	app.addErrorFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'Place'), null, null, app.myPassport);
		app.addErrorFullPassport(Input_required_field_place, app.getErrorString(Input_required_field_place), null, null, app.myPassport); // cnwdb2	PAR 35364

		
	endif;

	if (not app.myPassport.noErrors) then
		return false;
	endif;

	//get the move to location controller
	location :=  self.myToVoyage.myLogVoyageStructure.getLogVoyController(lot.lotNo, hatch, place);
	if location = null then
		create proxyLocation transient;
		proxyLocation.setProxy(lot, self.myToVoyage.myLogVoyageStructure, hatch, place);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateVoyageController(proxyLocation, location, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog( "Adding Location to Voyage", app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return false;
			
		endwhile;
	
	endif;	
	logVoyageController := location.CM_LogVoyageController;
	
	//batch up the TI's by release dockets		
	self.splitTisByBOL(tmpTISet, allCMIFBOLS);	
	//TRX it...
	
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxTransitTransfer(allCMIFBOLS, logVoyageController, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog( "Processing Transit Transfers", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	rtnResult := true;
	return rtnResult;

epilog
	if allCMIFBOLS &lt;&gt; null then
		allCMIFBOLS.purge();
	endif;
	delete tmpTISet;
	delete allCMIFBOLS;
	delete proxyLocation;
	if not rtnResult then
		if app.myPassport.hasErrorsOrWarnings then
			app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	else
		doSearch();
		return true;
	endif;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="b4ae3602-b2fd-4c53-bc70-8803ce2293fb">
        <updating/>
        <source>doSearch() protected, updating;

vars

begin

	app.mousePointer := MousePointer_HourGlass;	

	self.setButtons(false);
	self.allDocketLogDef.purge;
	self.tblSelectData.rows := 1;
	
	if self.myVoyage &lt;&gt; null then
	
		if self.selection = DOCKET and self.myBolOut &lt;&gt; null then
			self.doLoadDocket();
		elseif self.selection = SPECS then
			self.doLoadSpecs();
		elseif self.selection = LOGID then
			self.doLoadLogIds();			
		endif;
		
		if self.tblSelectData.rows &gt; 1 then
			self.tblSelectData.userInputEnabled := true;
			self.setButtons(true);
		endif;
		
	else
		app.msgBox('You must select a voyage first', 'Error', MsgBox_OK_Only);
	endif;
	
	self.loadDestination();	
	
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblSelectDataClick" id="4c9d465d-a69d-4a02-8f18-39c09ff0fe19">
        <source>doTblSelectDataClick() protected;
// ---------------------------------------------------------------------------
// Created:     08 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpTI				: CM_TrackedItem;
	tmpLocn				: CM_LogVoyageController;
	obj					: Object;
	def					: CMIF_DocketLogDef;
	lot					: CM_LogLot;
	placeStr,
	hatch				: String;
	idx,
	tmpLstCnt,
	place				: Integer;
	
begin
	
	self.tblSelectData.column := 1;
	obj := self.tblSelectData.accessRow(self.tblSelectData.row).itemObject;
	
	if CMIF_DocketLogDef.hasInstance(obj) then
		def := obj.CMIF_DocketLogDef;
	elseif CM_TrackedItem.hasInstance(obj) then
		tmpTI := obj.CM_TrackedItem;
	endif;
	
	if def &lt;&gt; null then
		if CM_LogVoyageController.hasInstance(def.myLocationsController) then
			tmpLocn := def.myLocationsController.CM_LogVoyageController;
		endif;
	elseif tmpTI &lt;&gt; null then
		if CM_LogVoyageController.hasInstance(tmpTI.myPrimaryActualLocation) then
			tmpLocn := tmpTI.myPrimaryActualLocation.CM_LogVoyageController;
		endif;		
	endif;
	
	if tmpLocn = null then
		return;
	endif;
	
	lot		:= tmpLocn.myLogLot;
	hatch	:= tmpLocn.hatch.String;
	place	:= tmpLocn.place;
	placeStr := app.vesselPlaceEnumToStr(place);
	
	tmpLstCnt := self.cmbToLot.listCount;
	foreach idx in 1 to tmpLstCnt do
		if self.cmbToLot.itemObject[idx] = lot then
			self.cmbToLot.listObject := lot;
			self.tblActionData.setValueByName(ETRow_ToLot, lot.lotNo);
			break;
		endif;
	endforeach;

	tmpLstCnt := self.cmbToHatch.listCount;
	foreach idx in 1 to tmpLstCnt do	
		if self.cmbToHatch.itemText[idx] = hatch then
			self.cmbToHatch.listIndex := idx;
			self.tblActionData.setValueByName(ETRow_ToHatch, hatch);
			break;
		endif;
	endforeach;

	tmpLstCnt := self.cmbToPlace.listCount;
	foreach idx in 1 to tmpLstCnt do		
		if self.cmbToPlace.itemText[idx] = placeStr then
			self.cmbToPlace.listIndex := idx;
			self.tblActionData.setValueByName(ETRow_ToPlace, placeStr);
			break;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnload" id="75924404-9eb8-4991-a892-52976da612ab">
        <source>doUnload() protected;

vars

begin

	self.allDocketLogDef.purge;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSelectedTIs" id="c57dbe0a-fdab-4576-97f6-6a0d1fd98dd0">
        <source>getSelectedTIs(_allTrackedItems : CM_TISet input) protected;
//--------------------------------------------------
// Created:	20 January 2006 By: cnwgd1 CCMS 1083
//--------------------------------------------------
vars
	cell		: JadeTableCell;
	def			: CMIF_DocketLogDef;
	resultsTable: CM_DataTable;
	row,
	col			: Integer;
	tmpSubTotal,
	tmpSED,
	tmpNumRequired : Real;
	tmpCOper,
	tmpUOM		: String;
begin
	
	if _allTrackedItems = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null parameter "_allTrackedItems"');
		return;
	endif;
	
	_allTrackedItems.clear;
	resultsTable := self.tblSelectData;
	col := resultsTable.getColumnByRowName(ETRow_Filler);
	
	if col &lt; 1 or col &gt; resultsTable.columns then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Column not found (' &amp; ETRow_Filler &amp; ')');
		return;
	endif;
	
	if self.optLogID.value then
		// the results table will have "CM_TrackedItem" objects displayed (middle table)
		// get the selected TIs from results table (middle table)
		foreach row in 2 to resultsTable.rows do
			cell :=	resultsTable.accessCell(row, col);
			if cell.text.Integer.Boolean = true then
				_allTrackedItems.add(resultsTable.accessRow(row).itemObject.CM_TrackedItem);
			endif;
		endforeach;		
	
	else
		// the results table will have "CMIF_DocketLogDef" objects displayed (middle table)
		if self.optSED.value then
			// get TIs to the value of "Quantity" entered for mean "SED" entered	
			tmpSED := self.tblActionData.getValueByName(ETRow_ToSED).Integer;
			tmpCOper := self.tblActionData.getValueByName(ETRow_ToCOperator).String;
			tmpNumRequired := self.tblActionData.getValueByName(ETRow_ToQuantity).Integer;
			
		elseif self.optSpecs.value then
			// get TIs to the value of "Quantity" entered for the "Unit Of Measure" entered	
			tmpUOM := self.tblActionData.getValueByName(ETRow_ToUOM).String;
			tmpNumRequired := self.tblActionData.getValueByName(ETRow_ToQuantity).Integer;
			
		endif;
		
		// Start from top row to bottom row, no sorting to do.
		foreach row in 2 to resultsTable.rows do
			cell :=	resultsTable.accessCell(row, col);
			if cell.text.Integer.Boolean = true then
				def := resultsTable.accessRow(row).itemObject.CMIF_DocketLogDef;
				if def &lt;&gt; null then
					if def.getTIsToValue(_allTrackedItems, tmpNumRequired, tmpSED, tmpCOper, tmpUOM, tmpSubTotal) then
						// reached the target quantity required
						break;
					endif;
				endif;
			endif;
		endforeach;	
		
		if (not _allTrackedItems.isEmpty)
		and tmpNumRequired &lt;&gt; null
		and tmpSubTotal &lt;&gt; tmpNumRequired then
			app.raiseCMWarning2(LogQtyNotAvailable, tmpSubTotal.String, tmpNumRequired.String, ETRow_Quantity, null,self.myTerminal);		
		endif;
		
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_allTrackedItems" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initComboComparisonOperator" id="6050f64b-2d06-4446-bcbf-d48b0588960c">
        <source>initComboComparisonOperator()protected;
//--------------------------------------------------
// Created:	20 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	cmb : ComboBox;
	row : Integer;
	str	: String;
	tmpCell	: JadeTableCell;
begin
	
	row := self.tblActionData.getRow(ETRow_ToCOperator);

	if (not self.tblActionData.isValidRow(row)) then
		return;
	endif;
	
	tmpCell := self.tblActionData.accessCell(row, self.tblActionData.ColumnValue);
			
//	cmb := tmpCell.cellControl.ComboBox;
//	cmb.style := cmb.Style_DropDownList;
	
	str := app.getErrorString(Greater_Than) &amp; Tab &amp; 
			app.getErrorString(Less_Than) &amp; Tab &amp;
			app.getErrorString(Equal_To);

	tmpCell.comboList := str;
	tmpCell.text := app.getErrorString(Greater_Than);
end;</source>
        <access>protected</access>
    </JadeMethod>
