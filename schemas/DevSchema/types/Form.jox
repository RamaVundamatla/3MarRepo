    <JadeMethod name="getControl" id="0d953fb6-2666-46bf-80f5-f6f3d96f50ff">
        <source>getControl(controlName : String):Control;

// get control by name

vars
	idx, cnt : Integer;
begin
	cnt := controlCount;
	foreach idx in 1 to cnt where controls(idx).name = controlName do
		return controls(idx);
	endforeach;
	return null;
end;</source>
        <Parameter name="controlName" type="String"/>
        <ReturnType type="Control"/>
    </JadeMethod>
</GUIClass>
