    <JadeMethod name="tblList_rowColumnChg" id="1e7c9afe-d628-43a2-a6ef-0ffd92e4ffcc">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblList_rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if table.row &gt; 1 and table.row &lt;= table.rows then
		table.accessRow(table.row).selected := true;
		self.mySelectedTI := table.accessedRow.itemObject.CM_TrackedItem;
		self.selectedRow := table.row;
	endif;

end;</source>
