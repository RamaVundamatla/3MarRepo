    <JadeMethod name="utlUpdateCargoForecast" id="476e4fb7-1e6f-47c7-83be-d8c384d78931">
        <source>utlUpdateCargoForecast(_pxyCargoForecast: CM_CargoForecast; _passport: CM_Passport input);
/*

Purpose:			Utility to update an existing Cargo Forecast from the Proxy object passed in

Parameters:			_pxyCargoForecast	CM_CargoForecast	The proxy object to update the real object from
					_passport			CM_Passport			Passport to use for our Trx that holds errors and other useful data

Return Value:		NONE

Date		Who		Reason
04 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	cancelSave			: Boolean;
	realCargoForecast	: CM_CargoForecast;
	expectedEdition		: Integer;
	voyage				: CM_Voyage;
	obj					: CM_Object;
	
begin
	self.initialiseActivity();

	_pxyCargoForecast.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyCargoForecast.pxyGetRealObjectAndEdition(realCargoForecast, expectedEdition);
	
	if realCargoForecast = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceNote.name, null, null);
		return;
	endif;

	app.myValUA.valCargoForecast(realCargoForecast, _pxyCargoForecast);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCargoForecast);

	if _passport.noErrors and realCargoForecast.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Gate Scan Record', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCargoForecast, true);
	endif;
	
	if _passport.noErrors then
		realCargoForecast.setForUpdate(_pxyCargoForecast);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCargoForecast, false);
	endif;
	
	if _passport.noErrors and _passport.myTerminal &lt;&gt; null then
		if realCargoForecast.myParent &lt;&gt; null then
			self.updateObjectEdition(realCargoForecast.myParent);
			
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_pxyCargoForecast" type="CM_CargoForecast"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCargoGroupOperators" id="8c4e7b64-9ee0-4268-a21d-6226a9203446">
        <source>utlUpdateCargoGroupOperators(_cargoGroup : CM_CargoGroup; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	cargoGroup : CM_CargoGroup;
begin
	self.initialiseActivity();

	_cargoGroup.raiseExceptionIfTransient(method);

	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
