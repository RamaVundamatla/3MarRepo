    <JadeMethod name="create" id="f09bc188-f7f4-405d-84fb-25800bd465da">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     21 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// always only have one column - lanes correspond to rows
	self.numberOfColumns	:= 1;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createInTransitToLocation" id="74a0cf5d-a6c8-4d05-9afb-d7a2e2732f1a">
        <updating/>
        <source>createInTransitToLocation() updating,protected;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy, location	:CM_BlockController;
begin
	if self.myInTransitToLocation &lt;&gt; null then
		return;
	endif;
	
	create proxy transient;	
	proxy.setProxy (self);
	
	create location;

	self.myInTransitToLocation := location;

	location.setForCreate (proxy, self);
	
epilog
	delete proxy;
end;</source>
        <access>protected</access>
    </JadeMethod>
