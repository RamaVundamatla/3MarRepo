    <JadeMethod name="processAttributeDependencies" id="67762a17-f0a1-4e0f-ab81-af4103388de4">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// cnwrs1 Feb 2009 CCMS Messina 1008
// Date			Who		Reason
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars

begin
	inheritMethod(_ediUserDefinedAssist,_strIdentifier, _reset, _xlationOperator);
	if _reset then 
		if self.myEDIData.isKindOf(CM_EDIDataVoyage) then
			_ediUserDefinedAssist.currentVoyageCode := null;
		endif;
	else
		if self.myEDIData.isKindOf(CM_EDIDataVoyage) then
	//		_ediUserDefinedAssist.currentVoyageCode := self.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
			_ediUserDefinedAssist.currentVoyageCode := self.getVoyageCode();
		endif;
		
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.setInwardCode( self.getInwardCode() );	// cnwrl1 11/06/2010 PAR 24299
	endif;
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="025a3db5-0dbe-4672-93f1-123fdc65db36">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// cnwrs1 Feb 2009 CCMS Messina 1008
// 31 July 2018	jlgrh7 TFS 39472 Internal EDI Format for Voyage doesn't allow the entry of Valid Operators
// 01 Aug 2018	jlgrs1 TFS 39472 Internal EDI Format for Voyage doesn't allow the entry of Valid Operators
//
vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setInwardCode( _proxyEDITI.getInwardCode() );				// cnwrl1 15/06/2010 PAR 24299
	
	self.setValidOperatorCodes(_proxyEDITI.allValidOperatorCodes); //TFS39472 
	
	propDict := CM_EDIVoyageTI.getProperties;
	

	foreach prop in propDict do
		if self.canUserSet(prop.name) and
		   prop.name &lt;&gt; CM_EDIVoyageTI::allValidOperatorCodes.name then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
	
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setInwardCode" id="a945befb-c3b5-4874-aa13-2a0aaedb0940">
        <updating/>
        <source>setInwardCode( _value : String ) updating;

/*
Date			Who		Reason
11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
	
vars
	
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	
	// remove the previous non-null value from this collection
	if self.inwardCode &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.inwardCode.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( self.inwardCode.toUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	self.inwardCode	:= _value[ 1 : self.inwardCode.maxLength ];
	if not self.isTransient and
	   self.inwardCode &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if not self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.inwardCode.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.putAtKey( self.inwardCode.toUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPropertyByName" id="12f63651-386d-451c-b6d0-47a2eaa7ab8c">
        <updating/>
        <source>setPropertyByName(_columnName: String; _value: String io): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 23 Feb 2024	navdap1	TFS 62598 EUP | FR - 53824 - Transport Manifest - Shipping Line Code Not Saved in EDI Operations
*/

vars

begin
	if _columnName = ETRow_ShippingLineCode then			// TFS 62598
		self.shippingLineCodeForTI := _value;				// TFS 62598
		self.shippingLineCode := _value;					// TFS 62598
	else
		return inheritMethod(_columnName, _value);
	endif;
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
