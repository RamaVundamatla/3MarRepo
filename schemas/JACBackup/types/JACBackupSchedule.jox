    <JadeMethod name="backupFinished" id="06f7b20c-2075-4641-8f3f-88f56ccab902">
        <updating/>
        <source>backupFinished() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	jacServer: JACServerAppObject;
	subjectStr: String;
begin
	self.createRecur();
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;'Closing current Journal.', LogAlways);
	beginTransaction;
	self.endTS := app.actualTimeServer;// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	commitTransaction;
	jacServer := app.myServerAppObject;

	if self.status = JACBackupComplete then
		beginTransaction;
		app.myDBA.closeCurrentJournal();
		commitTransaction;
		subjectStr := "JACBackup finished for database "&amp;app.dbPath.trimBlanks&amp;" on "&amp;app.dbServerComputerName.trimBlanks&amp;".";
	else
		subjectStr := "JACBackup FAILED for database "&amp;app.dbPath.trimBlanks&amp;" on "&amp;app.dbServerComputerName.trimBlanks&amp;".";
	endif;

	self.sendEmail(jacServer.smtpServer, jacServer.emailAddress, subjectStr, self.finalMessage);
end;</source>
    </JadeMethod>
    <JadeMethod name="backupFinishedNotify" id="e54cbcad-9871-4349-a1d3-f4241c5f2433">
        <source>backupFinishedNotify();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	app.writeLog(class.name&amp;'::'&amp;method.name, LogDebug);
	if app.isSDSSecondaryDB then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifyBackupFinished='&amp;NotifyBackupFinished.String, LogDebug);
		self.sdsCauseEvent(NotifyBackupFinished, true, null);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' causeEvent NotifyBackupFinished='&amp;NotifyBackupFinished.String, LogDebug);
		self.causeEvent(NotifyBackupFinished, true, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="bfbf0e51-1016-4842-ab32-73dedf89f132">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.status := JACBackupScheduled;
end;</source>
    </JadeMethod>
    <JadeMethod name="createRecur" id="6e7d09da-d3d2-41f4-9bff-58d5dd0c56c1">
        <updating/>
        <source>createRecur() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	newSched: JACBackupSchedule;
	currentHour, dailyInc: Integer;
	hourlyInc, minuteInc: Integer;
	theDate: Date;
	theTime: Time;
	idx: Integer;
	newStartTS, tempTS: TimeStamp;
begin
	if self.recur = null or self.recur = "None" then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' No reoccurance create - (' &amp; self.recur.String &amp; ')', LogNormal);
		return;
	endif;

	if self.recur = "Daily" then
		dailyInc := 1;
		hourlyInc := 0;
		minuteInc := 0;
	elseif self.recur = "Weekly" then
		dailyInc := 7;
		hourlyInc := 0;
		minuteInc := 0;
	elseif self.recur =  "Fortnightly"then
		dailyInc := 14;
		hourlyInc := 0;
		minuteInc := 0;
	elseif self.recur = "4-Weekly" then
		dailyInc := 28;
		hourlyInc := 0;
		minuteInc := 0;
	elseif self.recur = "Half-Hourly" then
		dailyInc := 0;
		hourlyInc := 0;
		minuteInc := 30;
	elseif self.recur = "Quarter-Hourly" then
		dailyInc := 0;
		hourlyInc := 0;
		minuteInc := 15;
	elseif self.recur = "Ten-Minutes" then
		dailyInc := 0;
		hourlyInc := 0;
		minuteInc := 10;
	elseif self.recur = "Five-Minutes" then
		dailyInc := 0;
		hourlyInc := 0;
		minuteInc := 5;
	elseif self.recur = "Two-Minutes" then
		dailyInc := 0;
		hourlyInc := 0;
		minuteInc := 2;
	elseif self.recur = "One-Minutes" then
		dailyInc := 0;
		hourlyInc := 0;
		minuteInc := 1;
	elseif self.recur = "Hourly" then
		dailyInc := 0;
		hourlyInc := 1;
		minuteInc := 0;
	elseif self.recur = "2-Hourly" then
		dailyInc := 0;
		hourlyInc := 2;
		minuteInc := 0;
	elseif self.recur = "4-Hourly" then
		dailyInc := 0;
		hourlyInc := 4;
		minuteInc := 0;
	elseif self.recur = "8-Hourly" then
		dailyInc := 0;
		hourlyInc := 8;
		minuteInc := 0;
	elseif self.recur = "12-Hourly" then
		dailyInc := 0;
		hourlyInc := 12;
		minuteInc := 0;
	endif;

	if dailyInc = 0 and
	   hourlyInc = 0 and
	   minuteInc = 0 then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' No reoccurance create - (increments are zero)', LogNormal);
		return;
	endif;
	
	hourlyInc := hourlyInc + (dailyInc * 24);

	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Creating new schedule - incrementing start time by '&amp;hourlyInc.String&amp;' hours '&amp;minuteInc.String&amp;' minutes.', LogNormal);

	// loop until next start time is greater than now
	newStartTS := self.startTS;
	while (newStartTS &lt; app.actualTimeServer) do// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		tempTS := newStartTS.jacBackupAddHours(hourlyInc, minuteInc);
		newStartTS := tempTS;
	endwhile;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;self.startTS.String&amp;' '&amp;newStartTS.String&amp;' '&amp;app.actualTimeServer.String, LogDebug);// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	newSched := app.myServerAppObject.jacBackupScheduleObjects.getAtKey(JACBackupScheduled, newStartTS);
	if newSched &lt;&gt; null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' schedule - already exists for '&amp;newStartTS.String, LogNormal);
		return;
	endif;
	beginTransaction;
	newSched := cloneSelf(false);
	newSched.setMyRoot(self.myRoot);
	newSched.finalMessage := null; // clear out the old final message
	newSched.endTS := null;

	newSched.setStartTS(newStartTS);
	newSched.setStatus(JACBackupScheduled);
	newSched.setRunOnSecondary(false);
	commitTransaction;
	
	app.writeLog(class.name&amp;'::' &amp; method.name&amp;' New schedule created with start time of '&amp;newSched.startTS.String, LogNormal);
end;</source>
    </JadeMethod>
    <JadeMethod name="getStartTS" id="5c54c5ed-02cb-44fc-b76d-e66c01be569e">
        <source>getStartTS():TimeStamp;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.status = JACBackupScheduled then
		return self.startTS;
	else
		return self.actualStartTS;
	endif;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="ba9800f0-262c-48c5-83c0-bc5a16b11459">
        <source>sendEmail(_smtpServer, _emailAddress, _subject, _message: String);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	boundary,i: Integer;
	file: File;
	attachment: CnAttachment;
	smtp: CnSmtpConnection;
	kc: CnKarmaCntrl;
//	cc: CnCntrl;
begin

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Preparing email for ' &amp; _emailAddress &amp; ' via ' &amp; _smtpServer, LogDebug);

    kc := app.myCnKarmaCntrl;    
	if kc = null then
		create kc transient;
	endif;

	create smtp;
	smtp.myCnKarmaCntrl := kc;

	self.beginNotification(smtp, CnSmtpConnection.Completion_Event_Type, Response_Cancel, 0); 

	smtp.name := _smtpServer; 
   
	smtp.sendFrom := _emailAddress;
	smtp.sendTo := _emailAddress;

	smtp.subject := _subject;

	if _message &lt;&gt; null then
		smtp.message := _message;
	endif;
 
	smtp.send; //Connect and send email

	app.doWindowEvents(5000);	// to allow email to be sent ???
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Email sent', LogDebug);

end;</source>
        <Parameter name="_smtpServer" type="String"/>
        <Parameter name="_emailAddress" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
