        <source>utlCreateExternalFinanceClass(_externalFinancialClass : Class) : CM_ExtFinanceIO;
/*
Purpose:		PAR 31601	
Date				Who			Reason
May 2013		CNWAB1		Initial creation
*/
vars
	ioClass : CM_ExtFinanceIO;
	clsCol : ClassColl;
	aFIO : CM_ExtFinanceIO;
	str : String;
begin

	aFIO := _externalFinancialClass.firstInstance().CM_ExtFinanceIO;
	if aFIO = null then
		create aFIO as _externalFinancialClass persistent;
		aFIO.initialise(app.myRoot.myRootCompany, _externalFinancialClass.getNiceName());
	endif;
	
	return aFIO;

epilog

end;</source>
