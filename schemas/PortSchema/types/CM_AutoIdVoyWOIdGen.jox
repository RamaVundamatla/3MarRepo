    </JadeMethod>
    <JadeMethod name="getNextIdForVoyageWO" id="ff01d1d9-5706-4837-9d8d-e5235cd2a158">
        <updating/>
        <source>getNextIdForVoyageWO(  _voyage : CM_Voyage; _workOrderVoyage : CM_WorkOrderVoyage ):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		      Who		       Reason
16/08/2018	jlgndl1	Initial creation	TFS 40249
12/09/2018	jlgdap1	TFS 40817 PEL1 Auto Generated Work Order Number for New Voyage Request
20/09/2021 	jlier1	TFS 51963 - want to be able to generate a voyage code for new voyage before the work order or voyage is created
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars

	now : TimeStamp;
	terminal : CM_Terminal;
	year : Integer;
	lastSeqNum : Integer;
	seqNum : Integer;
	
	yearMonthStr : String;
	voyNum : Integer;		// incremented per new voyage on the terminal in the year
	voyageStr : String;
	zString : String;
	seqNumStr : String;	// incremented per work order in the voyage.
	
	returnStr : String;
	
	inTransactionState : Boolean;
	
begin

	if not self.idStyle = AutoIdStyle_VoyWOPelindo1 then
		//return self.getNextId();  //jlier TFS 51963 16/9/21 - never worked before //1 Sept 2022 navmv20 TFS 54610
		return self.getNextId(null, null); //1 Sept 2022 navmv20 TFS 54610
	endif;
	
	terminal := self.myTerminal;

	now := terminal.systemToLocalTime( app.actualTimeServer );
	year := now.Date.format('yy').Integer;
	yearMonthStr := now.Date.format('yyyMM'); //only used if we are creating the first one, otherwise we get it from the voyages first wo
	
	if _workOrderVoyage &lt;&gt; null then
		zString := _workOrderVoyage.getZvalueForVoyageWOAutoId();
	else
		zString:='0';
	endif;
	//get the number from the existing voyage first otherwise create a new number....
	if _voyage &lt;&gt; null then
		voyNum := _voyage.getYMValueForVoyageWOAutoId( yearMonthStr, zString, lastSeqNum );
	endif;
	if _workOrderVoyage &lt;&gt; null and _workOrderVoyage.isWorkOrderForVoyageRequest then	// TFS 40817
		seqNum := lastSeqNum;															// TFS 40817
	else																				// TFS 40817
		seqNum := lastSeqNum + 1;
	endif;																				// TFS 40817
	seqNumStr := seqNum.String.padZeros( 3 );
	
	if voyNum = 0 then
		inTransactionState := process.isInTransactionState;
		if not inTransactionState then
			beginTransaction;
		endif;
	//	if year.String &lt;&gt; self.lastIdGeneratedYear then
		if now.Date.year &lt;&gt; self.lastGeneratedDate.year then	//23 Jan 2019	NDL	TFS 43018
			// new year, time to reset the counter.
			voyNum := 1;
		else
			voyNum := self.nextSequenceNum.Integer;
		endif;
		self.setLastAndNextValues(	voyNum.String, voyNum + 1, year, now.Date );
		if not inTransactionState then
			commitTransaction;
		endif;
	endif;
	voyageStr := voyNum.String.padZeros( 5 );
	
	returnStr := yearMonthStr &amp; voyageStr &amp; "-" &amp; zString &amp; seqNumStr;
	
	return returnStr;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_workOrderVoyage" type="CM_WorkOrderVoyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValidResetOptions" id="b593a204-d8b1-43fe-97fe-bf5682d48ef7">
        <source>getValidResetOptions(intArray: IntegerArray input; _styleId: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2019	jlgndl1	Initial creation

*/

vars

begin
	if _styleId = AutoIdStyle_VoyWOPelindo1 then
		intArray.add( self.Reset_On_Year_Chg_Int );
		return;
	endif;
	
	intArray.add( self.Reset_On_Overflow_Int );

	if _styleId &gt; 0 then
	
		if _styleId = AutoIdStyle_P_YY_SSS
		or _styleId = AutoIdStyle_YY_SSS
		or _styleId = AutoIdStyle_P_MM_YY_SSS
		or _styleId = AutoIdStyle_P_YY_MM_SSS
		then
			intArray.add( self.Reset_On_Year_Chg_Int );
		endif;
		
		if _styleId = AutoIdStyle_P_MM_YY_SSS
		or _styleId = AutoIdStyle_P_YY_MM_SSS
		then
			intArray.add( self.Reset_On_Month_Chg_Int );
		endif;
	
	endif;


epilog

end;</source>
        <Parameter name="intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_styleId" type="Integer"/>
    </JadeMethod>
