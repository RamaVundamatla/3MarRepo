    <JadeMethod name="drawGraphic" id="0a160e18-a6a1-4e18-85c2-0b4e0934143a">
        <source>drawGraphic();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin

	if self.mode = self.Mode_TIBehaviour then
		self.drawGraphicsTIBehaviour();
	elseif self.mode = self.Mode_Ship then
		self.drawGraphicShip();
	endif;

end;</source>
