    <JadeMethod name="getFreeStorage" id="98866727-6829-4e7c-acfe-136ed761274e">
        <source>getFreeStorage():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
*/

vars
	myOwnershipDetail : CM_OwnershipChangeDetail;
	myTrackedItem : CM_TrackedItem;
	detail : CM_StorageDetail;
begin
	myTrackedItem := self.getMyTrackedItem();
	if myTrackedItem &lt;&gt; null then
		detail:= myTrackedItem.getMatchingFreeStorageDetail(null);
		if detail &lt;&gt; null then
			return detail.freeStorageDays.String;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFreeStorageExpiry" id="02a76c8c-0e16-4389-8020-d696a366178c">
        <source>getFreeStorageExpiry():TimeStamp;
/*

Purpose:			NOT USED VALUE IS STORED ON OBJECT. // ### TFS BUG 64680 17JUNE024 NAVAB1

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
*/

vars
	myOwnershipDetail : CM_OwnershipChangeDetail;
	myTrackedItem,pxyTi : CM_TrackedItem;
	date : Date;
	storageDetail : CM_StorageDetail;
begin
	date := null;
	myTrackedItem := self.getMyTrackedItem();
	if myTrackedItem &lt;&gt; null then
		pxyTi := app.createUpdateProxy(myTrackedItem).CM_TrackedItem;
		if app.myProxyManager &lt;&gt; null then
			app.myProxyManager.deleteProxyLink(pxyTi);
		endif;
		
		pxyTi.setMyOperator(self.myOperatorNew);
		storageDetail:= pxyTi.getMatchingFreeStorageDetail(null);
		if storageDetail &lt;&gt; null then
			pxyTi.setFreeStorageDays(storageDetail.freeStorageDays);
		endif;
		date	:= pxyTi.getFreeStorageExpiryDate();
		
	endif;
	return date.asTimeStamp();
epilog
	delete pxyTi;  //10/09/2023 navmv20 CR 58250 Task 58252
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
