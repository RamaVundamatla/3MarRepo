    <JadeMethod name="setupThumbnailDetails" id="62e750be-00a6-43e2-93b2-267d5157b4eb">
        <updating/>
        <source>setupThumbnailDetails() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2013	cnwrd1	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;
begin
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_MeasurementTypeTbl);


	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_MeasurementTypeMaint);
	theForm.shtTblInput1.visible := true;

	//theForm.btnSetDefault1.caption := 'Default To Machines';


epilog

end;</source>
