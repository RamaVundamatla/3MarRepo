<Class name="WS_RoadExitRequest" id="7fb206c9-5918-4bc2-b3ad-755ac7308159">
    <superclass name="WS_Request"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="batNumber" id="7187f3f3-acd2-4195-a25c-51157505eecd">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The 'BAT number' or 'RFID Tag number' that would uniquely identify
the on-site truck, it he truck registration is not provided.</text>
    </PrimAttribute>
    <PrimAttribute name="truckRegistration" id="9da8b468-a508-4a16-a010-c17de190805f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The truck registration that uniquely identifies
the on-site truck.</text>
    </PrimAttribute>
    <PrimAttribute name="truckState" id="9dbe2f04-f329-44e0-bf8f-175704860037">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The 'State' associated with the truck registration that uniquely identifies
the on-site truck. (In systems that are using 'State' as part of the truck identification)</text>
    </PrimAttribute>
</Class>
