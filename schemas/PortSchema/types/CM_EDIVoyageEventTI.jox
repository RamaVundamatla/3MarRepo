    <JadeMethod name="loadDB" id="cbfba80f-e90d-4326-8d71-e2f1d80dde68">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

	real	: CM_EventTransaction;
	proxy 	: CMEVT_VoyageEvent;
	
begin
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;
	
	proxy := self.createProxy();
	app.myUtilityCA.utlCreateEventTransaction(proxy, real, _passport);
	
epilog

	delete proxy;

end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="dfc266ad-7561-4b34-b645-467da09c05ec">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

begin
	inheritMethod(_proxyEDITI);
	
	self.amount 				:= _proxyEDITI.amount;
	self.chargeable 			:= _proxyEDITI.chargeable;
	self.eventDate 				:= _proxyEDITI.eventDate;
	self.eventTime 				:= _proxyEDITI.eventTime;
	self.remarks 				:= _proxyEDITI.remarks;
	self.voyageEventType 		:= _proxyEDITI.voyageEventType;
	self.voyageEventTypeName	:= _proxyEDITI.voyageEventTypeName;
	self.weight 				:= _proxyEDITI.weight;

epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="c24a1446-2156-4f59-a48b-5b574d1be5cf">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

	rowName,
	measureType		: String;

begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_Weight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="be06e2af-3022-4b49-a032-b43c5fca5546">
        <updating/>
        <source>setVoyageCode(_value: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
	
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="d5dab633-92f5-40f4-a261-4d5b53a3196f">
        <source>verifySelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

	terminal : CM_Terminal;
	eventTypeObj : CM_EventType;
	tmpEventType : CM_EventType;
	voyage : CM_Voyage;
	iter : Iterator;

begin

	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
	endif;
	
	voyage := terminal.lookupVoyage(self.voyageCode, null, false);
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, ETRow_VoyageCode, self);
	endif;
	
	if self.eventDate = null or (not self.eventDate.isValid) then
		app.raiseCMException1(AutoScheduleDateError,"", ETRow_EventDate, self);
	endif;
	
	if self.eventTime = null or (not self.eventTime.isValid) then
		app.raiseCMException1(AutoScheduleDateError,"", ETRow_EventTime, self);
	endif;
	
	if self.voyageEventType = null and self.voyageEventTypeName = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Event_type), ETRow_VoyageEventType, self);
	endif;
	
	eventTypeObj := app.myRoot.allEventTypesByType[self.voyageEventType];
	
	if eventTypeObj = null then
		if self.voyageEventTypeName &lt;&gt; null then
			iter:=app.myRoot.allEventTypesByCategory.createIterator;
			app.myRoot.allEventTypesByCategory.startKeyGeq(CM_EventType.VOYAGE_EVENT,null,iter);
				
			while iter.next(tmpEventType) do
				if tmpEventType.category &lt;&gt; CM_EventType.VOYAGE_EVENT then
					break;
				endif;
				if tmpEventType.name = self.voyageEventTypeName then
					eventTypeObj := tmpEventType;
					break;
				endif;
			endwhile;
		endif;
	endif;
	
	if eventTypeObj = null then
		app.raiseCMException2(ERR_FIELD_TYPE, self.voyageEventType.String, app.getErrorString(Event_type), ETRow_VoyageEventType, self);
	elseif eventTypeObj.category &lt;&gt; CM_EventType.VOYAGE_EVENT then
		app.raiseCMException(Event_type_must_voyage_event, ETRow_VoyageEventType, self);
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
