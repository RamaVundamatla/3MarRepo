<Class name="CMIF_ContractRangeEntry" id="85bdb4e4-e244-4739-bbf1-3e397496cb0a">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ExplicitInverseRef name="allDateRanges" id="2f0bc049-f86e-473a-8ba9-ef7b9cde130b">
        <kind>parent</kind>
        <type name="CMIF_RateEntriesByFromTSToTS"/>
        <access>readonly</access>
        <Inverse name="CMIF_ContractRateEntryDates::myCMIFRangeEntry"/>
    </ExplicitInverseRef>
    <JadeMethod name="createCMIFRateEntryDate" id="9cf536df-4d36-4f70-a6c3-d103d9471f94">
        <updating/>
        <source>createCMIFRateEntryDate(_rate : CM_InvoiceContractRate; _fromTS, _toTS : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
  contractRateEntry : CM_InvoiceContractRateEntry;
  fromTS, toTS : TimeStamp;
  cmifRateEntryDates : CMIF_ContractRateEntryDates;
  allRateEntries : CM_InvContractRateEntryByAmnt;
begin
	foreach contractRateEntry in _rate.allInvoiceContractRateEntries do
		fromTS := contractRateEntry.fromTS;
		toTS := contractRateEntry.toTS;
		if fromTS = _fromTS and toTS = _toTS then
			cmifRateEntryDates := self.allDateRanges[fromTS,toTS];
			if cmifRateEntryDates = null then
				create cmifRateEntryDates transient;
				cmifRateEntryDates.setFromTS(fromTS);
				cmifRateEntryDates.setToTS(toTS);
				self.allDateRanges.add(cmifRateEntryDates);
			endif;
			allRateEntries := cmifRateEntryDates.allInvoiceContractRateEntries;
			if not allRateEntries.includes(contractRateEntry) then
				allRateEntries.add(contractRateEntry);
			endif;
		else
			continue;
		endif;
	endforeach;
	
	if cmifRateEntryDates = null then
		create cmifRateEntryDates transient;
		cmifRateEntryDates.setFromTS(_fromTS);
		cmifRateEntryDates.setToTS(_toTS);
		self.allDateRanges.add(cmifRateEntryDates);
	endif;
epilog
	
end;</source>
        <Parameter name="_rate" type="CM_InvoiceContractRate"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="createCMIFRateEntryDates" id="4eaf68f8-d627-4ed5-bca8-4c2fbb539179">
        <updating/>
        <source>createCMIFRateEntryDates(_rate : CM_InvoiceContractRate) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
  contractRateEntry : CM_InvoiceContractRateEntry;
  fromTS, toTS : TimeStamp;
  cmifRateEntryDates : CMIF_ContractRateEntryDates;
  allRateEntries : CM_InvContractRateEntryByAmnt;
begin
	foreach contractRateEntry in _rate.allInvoiceContractRateEntries do
		fromTS := contractRateEntry.fromTS;
		toTS := contractRateEntry.toTS;
		cmifRateEntryDates := self.allDateRanges[fromTS,toTS];
		if cmifRateEntryDates = null then
			create cmifRateEntryDates transient;
			cmifRateEntryDates.setFromTS(fromTS);
			cmifRateEntryDates.setToTS(toTS);
			self.allDateRanges.add(cmifRateEntryDates);
		endif;
		allRateEntries := cmifRateEntryDates.allInvoiceContractRateEntries;
		if not allRateEntries.includes(contractRateEntry) then
			allRateEntries.add(contractRateEntry);
		endif;
	endforeach;
epilog
	
end;</source>
        <Parameter name="_rate" type="CM_InvoiceContractRate"/>
    </JadeMethod>
</Class>
