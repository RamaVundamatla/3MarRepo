    <JadeMethod name="addLine" id="52775e97-9c71-41ba-a3dc-c9ba1f238bdc">
        <updating/>
        <source>addLine(_label : String; _color : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     Creates a line and returns the line idx to be used when
//				passing in values
// ---------------------------------------------------------------------------
vars
	newLineArray	: PointArray;
	
begin

	create newLineArray transient;
	self.allLinesArray.add(newLineArray);
	self.allGraphLegends.add(_label);
	self.allGraphColors.add(_color);

	return self.allLinesArray.size;
	
end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_color" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addValue" id="49adf2bf-2b05-4d05-9ff4-ddce6db1571a">
        <updating/>
        <source>addValue(_lineIdx, _xValue, _yValue : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	lineArray	: PointArray;
	numLines	: Integer;
	point		: Point;
		
begin

	numLines	:= self.allLinesArray.size();
	if _lineIdx &gt; numLines then
		app.raiseUnexpectedProgramError(class.name, method.name, 'You need to call addLine first');
		return;
	endif;	
	
	lineArray	:= self.allLinesArray[_lineIdx].PointArray;

	point.setX(_xValue);
	point.setY(_yValue);
	lineArray.add(point);
	
end;</source>
        <Parameter name="_lineIdx" type="Integer"/>
        <Parameter name="_xValue" type="Integer"/>
        <Parameter name="_yValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addXAxisLabel" id="d5bab180-0c49-4753-8fe9-100b245348f1">
        <source>addXAxisLabel(_label1, _label2 : String; _value : Integer);
// ---------------------------------------------------------------------------
// Created:     20 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.allXAxisLabels.add(_label1);
	self.allXAxisLabels2.add(_label2);
	self.allXAxisValues.add(_value);

end;</source>
        <Parameter name="_label1" type="String"/>
        <Parameter name="_label2" type="String"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calculateGraphSize" id="1906cb89-f2d1-4b86-85b4-241538ce89fc">
        <updating/>
        <source>calculateGraphSize() updating, protected;
vars
	textHeight	: Real;

begin

	textHeight	:= self.graphLabelHeight;

	self.graphHeight	:=	(self.clientHeight - textHeight - textHeight - 0).Integer;
	self.graphWidth		:=	(self.clientWidth - self.maxScaleLabelWidth - 6).Integer;

	if self.useXAxisLabelLine2 then
		self.graphHeight	:= (self.graphHeight - textHeight).Integer;
	endif;

	if self.isShowLineLegend then
		self.graphWidth	:= (self.graphWidth - self.getLegendWidth() - self.GraphMargin).Integer;
	endif;
		
	// now allow for the margins
	self.graphHeight := self.graphHeight - (self.GraphMargin * 2);
	self.graphWidth	 := self.graphWidth - (self.GraphMargin * 2);
	
	self.xAxisPos 	:= self.graphHeight + textHeight + self.GraphMargin;	// allow for top heading
	self.yAxisPos	:= self.maxScaleLabelWidth + self.GraphMargin;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkData" id="87b9eb41-f28c-4509-80a8-da8597bcb374">
        <updating/>
        <source>checkData():String updating, protected;

vars
	returnValue		: String;
	numberOfLines 	: Integer;
	colorArray		: IntegerArray;
	position		: Integer;
	lineColor		: Integer;
	
begin
	numberOfLines := self.allLinesArray.size();
	
	if numberOfLines = 0 then
		if self.isShowTestData then
			self.clearGraph();
			self.setDefaultsInPainter();
			numberOfLines	:=	self.allLinesArray.size();
		else
			returnValue	:=	"No Data";
			return returnValue;
		endif;
	endif;

//	if (numberOfLines * self.graphLabelHeight) &gt; self.graphWidth then
//		returnValue	:=	"Too Much Data";
//		return returnValue;			
//	endif;
	
	if self.isShowLineLegend then
		if numberOfLines &gt; self.allGraphColors.size() then
			returnValue	:=	"Not enough colors set";
			return returnValue;
		endif;
	
		create colorArray transient;
	
		foreach position in 1 to numberOfLines do
			lineColor	:=	self.allGraphColors[position]; 
			
			if not colorArray.includes(lineColor) then
				colorArray.add(lineColor);
			else
				returnValue	:=	"Color used more than once";
				return returnValue;
			endif;	 
		endforeach;
	endif;  
	
	return returnValue;
epilog
	delete colorArray;	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearGraph" id="43764ef0-e0bb-4046-b267-45e7866c5fd3">
        <updating/>
        <source>clearGraph() updating;

begin
	inheritMethod();
	self.allXAxisLabels.purge();
	self.allXAxisLabels2.purge();
	self.allXAxisValues.purge();
	self.allLinesArray.purge();
	
	self.maxXValue	:= 0;
	self.minXValue	:= 0;

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="b90e941e-c32a-489a-bfc4-6597ec1a0c05">
        <updating/>
        <source>delete() updating;

begin
	self.allLinesArray.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeValue" id="364ea0c3-19e4-4769-94e0-2744bbb550cf">
        <source>doChangeValue(_xValue, _yValue :Integer; pLineNumber:Integer; pPosition:Integer ):Boolean;

vars
	lineArray	: PointArray;
	point		: Point;
	
begin
	if self.allLinesArray.size() &lt; pLineNumber then
		return false;
	endif;
	
	lineArray	:=	self.allLinesArray[pLineNumber].PointArray;
	
	if lineArray.size() &lt; pPosition then
		return false;
	endif;
		
	point := lineArray[pPosition];
	
	point.setX(_xValue);
	point.setY(_yValue);
	
	return true;
end;</source>
        <Parameter name="_xValue" type="Integer"/>
        <Parameter name="_yValue" type="Integer"/>
        <Parameter name="pLineNumber" type="Integer"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="c53d133f-e83d-4324-9962-87a6eb3bd187">
        <updating/>
        <source>drawGraph() updating;

vars
	errorMessage	: String;
	
begin
	inheritMethod();
	
	errorMessage := self.checkData();

	if errorMessage = null then		
		self.autoRedraw	:=	true;
		self.setMaxScaleLength();
		self.calculateGraphSize();
		self.drawYAxis();
		self.drawLines();
		self.drawLegend();
		if self.myLegend &lt;&gt; null then
			self.myLegend.drawGraph();
		endif;

	else
		self.doDataError(errorMessage);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="drawGraphLine" id="b78d4524-a509-4c11-9b7b-aa29558cd1f0">
        <updating/>
        <source>drawGraphLine(pLinePoints : PointArray; pLineNumber : Integer) updating, protected;

vars
	startX						: Real; 
	startY						: Real; 
	endX						: Real; 
	endY						: Real; 
	lineColor					: Integer;
	unitValue					: Real;
	point						: Point;
	firstTime		: Boolean;
		
begin
	
	if pLineNumber &lt;= self.allGraphColors.size() then
		lineColor	:=	self.allGraphColors[pLineNumber];
	else
		lineColor	:=	Black;
	endif;
	
	unitValue		:=	self.graphHeight / self.maxValue;
	self.drawWidth	:=	2;
	
	firstTime := true;
	
	foreach point in pLinePoints do
		//set up x and y
		
		endX := ((point.x - self.minXValue) / (self.maxXValue - self.minXValue)) * self.graphWidth;
		endY := (self.xAxisPos - (point.y * unitValue));

		endX := endX + self.yAxisPos;

		if firstTime then
			firstTime := false;
			startX	:=	endX;
			startY	:=	endY;
			continue;
		endif;
		
		//draw the line here
		self.drawLine(startX, startY, endX, endY, lineColor);
	
		startX	:=	endX;
		startY	:=	endY;
		
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="pLinePoints" type="PointArray"/>
        <Parameter name="pLineNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLegend" id="2b7261c0-5f5a-4e0a-9d08-45f4658a86d5">
        <updating/>
        <source>drawLegend() updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	maxWidth,
	topPos,
	leftPos,
	linePos,
	offset,
	legendWidth	: Real;
	idx,
	tmpColor	: Integer;
	str			: String;

begin
	if (not self.isShowLineLegend) then
		return;
	endif;
	
	maxWidth := self.getMaxLegendWidth();
	
	topPos	:= self.xAxisPos - self.graphHeight + self.GraphLegendSpacing;
	leftPos := self.yAxisPos + self.graphWidth + self.GraphMargin + self.GraphLegendSpacing;
	
	linePos := topPos + self.graphLabelHeight;
	legendWidth := self.getLegendWidth();
	offset := (self.graphLabelHeight / 2);

	self.drawWidth := 2;
	
	foreach str in self.allGraphLegends do
		idx := idx + 1;
		tmpColor := self.allGraphColors[idx];
		self.drawLine(leftPos, linePos + offset, leftPos + self.GraphLegendLineLength, linePos + offset, tmpColor);
		self.drawTextAt(str, leftPos + self.GraphLegendLineLength + self.GraphLegendSpacing, linePos, Black);
		
		linePos := linePos + self.graphLabelHeight;
	endforeach;
	
	leftPos := leftPos - self.GraphLegendSpacing;
	
	self.drawWidth := 1;
	self.drawRectangle(leftPos, topPos, leftPos + legendWidth, linePos, Black); 

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawLines" id="00b08a7a-e1dc-4091-89b7-9682447d504d">
        <updating/>
        <source>drawLines() updating, protected;

vars
	numLines,
	idx			: Integer;
	theLine		: Object;
	
begin
	numLines	:= self.allLinesArray.size();
	
	foreach idx in 1 to numLines do
		theLine	:=	self.allLinesArray[idx];
		self.drawGraphLine(theLine.PointArray, idx);
	endforeach;
	
	self.drawXAxis();	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawXAxis" id="fc005c0b-c983-4032-a05c-cdbfb7ce7328">
        <updating/>
        <source>drawXAxis() updating, protected;

constants
	LabelSpacing	: Integer = 5;
	
vars
	labelHeight,
	startX,
	startY1,
	startY2				: Real; 
	lastX,
	lastEndPos1,
	lastEndPos2,
	textExtent			: Real;
	displayText1,
	displayText2		: String; 
	textColor			: Integer;
	idx					: Integer;
	numLabels1,
	numLabels2,
	numValues,
	tmpValue		: Integer;
	maxXAxisValue,
	numberOfXAxisLabels	: Integer;
	
begin
	textColor := Black;
	labelHeight := self.graphLabelHeight;

	startY1	:=	self.xAxisPos + 2;
	startY2	:=	startY1 + labelHeight;
	
	self.drawTextRotation	:=	0;

	numLabels1	:= self.allXAxisLabels.size();
	numLabels2	:= self.allXAxisLabels2.size();
	numValues	:= self.allXAxisValues.size();
	
	maxXAxisValue := self.allXAxisValues.last;
	
	foreach idx in 1 to numValues do
	
		if idx &lt;= numLabels1 then
			displayText1 := self.allXAxisLabels[idx];
		else
			displayText1 := null;
		endif;
	
		if idx &lt;= numLabels2 then
			displayText2 := self.allXAxisLabels2[idx];
		else
			displayText2 := null;
		endif;
		
		tmpValue := self.allXAxisValues[idx];
		
		startX := ((tmpValue - self.minXValue) / (self.maxXValue - self.minXValue)) * self.graphWidth;
		startX := startX + self.yAxisPos;
		
		if lastX + LabelSpacing &gt; startX then
			continue;
		endif;
		
		self.drawLine(startX, (self.xAxisPos - 4), startX, (self.xAxisPos), Black);		

		if startX &lt; lastEndPos1 and startX &lt; lastEndPos2 then
			continue;
		endif;
		
		if displayText1 &lt;&gt; null and startX &gt;= lastEndPos1 then
			self.drawTextAt(displayText1, startX, startY1, textColor);
			lastEndPos1 := startX + self.getTextExtent(displayText1) + LabelSpacing;
		endif;

		if displayText2 &lt;&gt; null and startX &gt;= lastEndPos2 then
			self.drawTextAt(displayText2, startX, startY2, textColor);
			lastEndPos2 := startX + self.getTextExtent(displayText2) + LabelSpacing;
		endif;
		
	endforeach;

	if self.xAxisHeading &lt;&gt; null then
		textExtent := self.getTextExtent(self.xAxisHeading);
		if textExtent &gt; self.clientWidth then
			startX := 1;
		else
			startX := ((self.clientWidth - textExtent) / 2);
		endif;
		if self.useXAxisLabelLine2 then
			self.drawTextAt(self.xAxisHeading, startX, startY2 + labelHeight, textColor);
		else
			self.drawTextAt(self.xAxisHeading, startX, startY1 + labelHeight, textColor);
		endif;
	endif;
	
	// now draw line across bottom
	self.drawLine(self.yAxisPos,
				self.xAxisPos + 1,
				self.yAxisPos + self.graphWidth,
				self.xAxisPos + 1,
				Black);		

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawYAxis" id="6530c338-a915-42ce-9f96-332ea30ca4ae">
        <updating/>
        <source>drawYAxis() updating, protected;

vars
	textExtent	: Real;
	yMaxValue,
	position	: Integer;
	startX,
	startY,
	txtHeight	: Real;
	displayText	: String;	
	
begin

	displayText := self.yAxisHeading;
	
	if displayText = null then
		startX := 10;
	else
		// Draw the y axis heading
		self.drawTextRotation		:= 90;
		self.drawTextCharRotation	:= 90;
		textExtent := self.getTextExtent(displayText);
		if textExtent &gt; self.graphHeight then
			startY := self.xAxisPos;	// self.graphHeight + self.graphLabelHeight;
		else
			startY := ((self.graphHeight - textExtent) / 2) + self.graphLabelHeight + textExtent;
		endif;
		self.drawTextAt(displayText, 1, startY, Black);

		self.drawTextCharRotation := 0;

		startX := self.graphLabelHeight + 1;
	endif;

	self.drawTextRotation	:=	0;
	
	txtHeight := self.drawTextHeight('0');

	yMaxValue := self.maxValue;
	
	foreach position in 1 to 5 do
		if position = 1 then
			displayText	:=	'0';
			startY		:=	0;
		elseif position = 2 then
			displayText	:=	(yMaxValue * 0.25).Real.String;
			startY		:=	(self.graphHeight *.25);
		elseif position = 3 then
			displayText	:=	(yMaxValue * 0.5).Real.String;
			startY		:=	(self.graphHeight *.50);
		elseif position = 4 then
			displayText	:=	(yMaxValue * 0.75).Real.String;
			startY		:=	(self.graphHeight *.75);
		elseif position = 5 then
			displayText	:=	yMaxValue.String;
			startY		:=	self.graphHeight;
		endif;
		
		startY := self.xAxisPos - startY;
		
		if self.maxValue &gt; 10 then
			displayText	:=	displayText.Integer.String;
		endif;
		
		self.drawTextAt(displayText, startX, startY - (txtHeight / 2), Black);
		
		if self.showHorizontalGridLines then
			self.drawWidth := 1;
			self.drawLine(self.yAxisPos - 4, startY, self.yAxisPos + self.graphWidth, startY, Black);
		else
			self.drawLine(self.yAxisPos - 4, startY, self.yAxisPos, startY, Black);
		endif;
	endforeach;
	
	self.drawWidth := 2;

	// now draw line up left
	self.drawLine(self.yAxisPos - 1,
				self.xAxisPos - self.graphHeight,
				self.yAxisPos - 1,
				self.xAxisPos + 1,
				Black);		

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="fba8e159-8648-4d27-b37c-197c3aae51ca">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;
vars
	idx	: Integer;
begin
	self.graphTitle	:=	self.name &amp; " - Sample data";
	
	idx := self.addLine('2000', Red);
	 
	self.addValue(idx, 1, 10);
	self.addValue(idx, 2, 20);
	self.addValue(idx, 3, 50);
	self.addValue(idx, 4, 30);
	self.addValue(idx, 5, 40);

	idx := self.addLine('2001', Blue);
	
	self.addValue(idx, 1, 20);
	self.addValue(idx, 2, 0);
	self.addValue(idx, 3, 0);
	self.addValue(idx, 4, 25);
	self.addValue(idx, 5, 30);

	idx := self.addLine('2002', Green);
	
	self.addValue(idx, 1, 30);
	self.addValue(idx, 2, 40);
	self.addValue(idx, 3, 15);
	self.addValue(idx, 4, 20);
	self.addValue(idx, 5, 15);
	
	self.transparent := false;
	
	self.addXAxisLabel("January", null, 1); 
	self.addXAxisLabel("February", null, 2);
	self.addXAxisLabel("March", null, 3);
	self.addXAxisLabel("April", null, 4);
	self.addXAxisLabel("May", null, 5);
	
	if self.height &lt; 100 then
		self.height	:=	100;
	endif;
	
	if self.width &lt; 100 then
		self.width	:=	100;
	endif;				
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLegendLabel" id="2e10bf78-d100-4438-b6f2-cd583e6edc3e">
        <updating/>
        <source>setLegendLabel(pColor:Integer) updating, protected;

vars
	lineIndex		: Integer;
	theControl		: Control;
	theLabel		: Label;
	valueString		: String;
	
begin
	lineIndex	:=	self.allGraphColors.indexOf(pColor);
	
	if self.isInPainter() then
		valueString						:=	"Legend Label";
		self.myLegendLabel.foreColor	:=	Black; 
	else
		if lineIndex &lt;&gt; 0 then
			if lineIndex &lt;= self.allGraphLegends.size() then
				valueString	:=	self.allGraphLegends[lineIndex]; 
			else
				valueString	:=	"No legend - "; 		
			endif;
			
			self.myLegendLabel.foreColor	:=	pColor; 
		else
			valueString						:=	"Click on Line for Legends";
			self.myLegendLabel.foreColor	:=	Black; 
		endif;
	endif;	  
	
	self.myLegendLabel.caption	:=	valueString;		
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMaxScaleLength" id="e54ff2da-42ec-4c9b-a853-8ee0e68c7474">
        <updating/>
        <source>setMaxScaleLength() updating, protected;

vars
	theLabel		: Label;
	theLine			: Object;
	position		: Integer;
	numberOfLines,
	numValues		: Integer;
	point			: Point;
	firstTime		: Boolean;
	
begin
	self.maxScaleLabelWidth	:=	0;
	numberOfLines	:= self.allLinesArray.size();
	
	firstTime := true;
	
	foreach position in 1 to numberOfLines do 
		theLine	:=	self.allLinesArray[position];
		
		foreach point in theLine.PointArray do
			if firstTime then
				firstTime := false;
				self.minXValue := point.x;
				self.maxXValue := point.x;
				self.maxValue := point.y;
			else
				if point.x &lt; self.minXValue then
					self.minXValue := point.x;
				endif;
				if point.x &gt; self.maxXValue then
					self.maxXValue := point.x;
				endif;
				if point.y &gt; self.maxValue then
					self.maxValue := point.y;
				endif;
			endif;
		endforeach;
	endforeach;
	
	numValues := self.allXAxisValues.size;
	
	if numValues &gt; 1 then
		self.minXValue := self.minXValue.min(self.allXAxisValues[1]);
		self.maxXValue := self.maxXValue.max(self.allXAxisValues[numValues]);
	endif;
	
	// add 10% on to leave a gap at the top of the graph
	self.maxValue := (self.maxValue * 1.1).roundedUp;
	
	create theLabel transient;
	theLabel.caption		:=	self.maxValue.String;
	self.maxScaleLabelWidth	:=	theLabel.width.Integer;	


epilog
	delete theLabel;	
end;</source>
        <access>protected</access>
    </JadeMethod>
