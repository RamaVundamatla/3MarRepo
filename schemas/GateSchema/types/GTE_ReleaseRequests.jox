    <JadeMethod name="cmbVoyage_change" id="c05ea8fc-873e-4c9d-b9cc-4687de14bebf">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_change(combobox: ComboBox input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 21 January 2019
TFS#		: 41708
Function	:

*** Changes ***
Date		Name	TFS#	Description
26/04/2019	jlgka1	44427	Fixed bug where Bill of Lading is not populated
							upon the selection of the voyage.
****************************************************/
begin
	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then	
		self.populateHeaderBillOfLading(self.tblEntry.getValueByName(ETRow_ReleaseType).Integer);		
		self.populateBOLDetails();
		self.cmbVoyage.lostFocus(cmbVoyage);
	endif;	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbVoyage_lostFocus" id="05336401-da02-47c7-a05d-c398883d4855">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_lostFocus(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 June 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
11/08/2011	cndap1		PAR #27972	Bulk release type no longer translatable, replaced by string constants
									Also moved theDays calculation to the correct place (was accidentally 
									moved out of place by a prevous change)
01/12/2016  cnwma1		TFs #2931	PAR38389 PEN - Problem with Release Request Date field
13/03/2019	jlgka1		TFS 41708 	Call Methods to populate bol.
26/04/2019	jlgka1		44427		Fixed bug where Bill of Lading is not populated
									upon the selection of the voyage.
01/09/2022	navds21		54651		Bug 54651: MTN - Release Request - Changing Voyage doesn't recalculate 'Estimated Required Date / Time'
*/
vars
	requiredDate	: TimeStamp;
	calculatedTS	: TimeStamp;
	theDays			: Integer;
	tmpVoy			: CM_Voyage;
	releaseObj		: CM_BulkRelease;
	isCalcRequired	: Boolean;
	reserveSelection: CM_ReserveSelection;
	reserveDetail	: CM_ReserveDetail;
	tmpBOLIn		: CM_BOLIn;
	currentVoyage	: CM_Voyage;
begin	
	self.tblEntry.setValueByControlName(combobox.name, combobox.text);
	//th2 for PAR 15019 - was on click event - moved to lost focus
	tmpVoy := self.cmbVoyage.listObject.CM_Voyage;
	releaseObj		:=	self.myMasterProxyObject.CM_BulkRelease;
	if tmpVoy = null or releaseObj = null then
		return;
	endif;
	
	//cnwmc5 - 30 July 2013 - PAR 31461
	if tmpVoy &lt;&gt; releaseObj.myVoyage then
		self.cmbDischarge.clear();
		self.cmbDischarge.myVoyage := self.cmbVoyage.listObject.CM_Voyage;
	endif;
	
	self.tblEntry.setValueByName(ETRow_VoyageArrival, tmpVoy.arrivedDT.shortCurrentLocaleFormat);
	self.cmbDischarge.myVoyage := tmpVoy;
	requiredDate := releaseObj.dateEstimatedRequired;

	if self.myTerminal.getConfig(RelReqForceUserEst).Boolean then	//28 Feb 2019	NDL	TFS 42955 - removed by 41708, Reinstated NDL TFS 46192
		//Do nothing, its up to the user to manually enter this date, DO NOT calculate it
	else
		if self.tblEntry.getValueByName(ETRow_EstimatedRequiredDate) = null or self.tblEntry.getValueByName(ETRow_EstimatedRequiredTime) = null then
			if (not tmpVoy.arrivedDT.isValid()) and self.mode = Mode_Add then//no previous value - clear it
				self.tblEntry.setValueByName(ETRow_EstimatedRequiredDate, null);
				self.tblEntry.setValueByName(ETRow_EstimatedRequiredTime, null);
				return;
			endif;
			
			// PAR #27972 moved from below, and translation of bulk release type removed
			//seems to be some sort of buffer for packing releases -probably for POE - should be configurable?
			if self.cmbBRType.text = BR_TYPE_PACKING_STR then
				theDays := -5;
			else
				theDays := -1;
			endif;
			if requiredDate = null or (not requiredDate.isValid()) then
				calculatedTS	:=	tmpVoy.arrivedDT.cnEcAddDays(theDays);
				self.tblEntry.setValueByName(ETRow_EstimatedRequiredDate, calculatedTS.date());
				self.tblEntry.setValueByName(ETRow_EstimatedRequiredTime, calculatedTS.time());
			endif;
		//Start 01/09/2022 navds21 54651
		else 
			if self.cmbBRType.text = BR_TYPE_PACKING_STR then
				theDays := -5;
			else
				theDays := -1;
			endif;
			if requiredDate = null or (not requiredDate.isValid()) then
				calculatedTS	:=	tmpVoy.arrivedDT.cnEcAddDays(theDays);
				self.tblEntry.setValueByName(ETRow_EstimatedRequiredDate, calculatedTS.date());
				self.tblEntry.setValueByName(ETRow_EstimatedRequiredTime, calculatedTS.time());
			endif;
		endif;
		//End 01/09/2022 navds21 54651
	endif;
	
	
	// PAR #27972 moved back to within required date if statemene, so calculatedTS is actually calculated correctly
	/*//seems to be some sort of buffer for packing releases -probably for POE - should be configurable?
	if self.cmbBRType.text = app.getErrorString(BR_TYPE_DESCR_PACKING) then
		theDays := -5;
	else
		theDays := -1;
	endif;*/

	//neet to set BOLIns = null for all reserve selections when voyage is changed.  #24351	04/06/2010
	foreach reserveDetail in releaseObj.allReserveDetails do
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			reserveSelection := reserveDetail.CM_ReserveSelection;
			tmpBOLIn := reserveSelection.myBOLIn;
			if tmpBOLIn &lt;&gt; null and (not tmpVoy.allBOLInByTypeStatusNumDT.includes(tmpBOLIn)) then
				reserveSelection.setMyBOLIn(null);	// BOLIn should be cleared on a reserveSelection, when voyage is changed.
			endif;
		endif;
	endforeach;
	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
		currentVoyage := self.mySelectedObject.CM_BulkRelease.myVoyage;
		if currentVoyage &lt;&gt; tmpVoy then	
			self.mySelectedObject.CM_BulkRelease.setMyVoyage(tmpVoy);			
		endif;		
		
		self.populateHeaderBillOfLading(self.tblEntry.getValueByName(ETRow_ReleaseType).Integer);
		self.populateBOLDetails();
	endif;
	if self.tblEntry.row =self.tblEntry.getRowByName(ETRow_EstimatedRequiredDate) then  // 01/12/2016 cnwma1 TFS #2931
		self.tblEntry.setFocus;
	endif;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="consigneeHasBeenChanged" id="946d87ab-b65b-477f-a82c-0ff57ebbf715">
        <updating/>
        <source>consigneeHasBeenChanged(_newConsignee : CM_ConsigneeConsignor) updating;
/* ---------------------------------------------------------------------------
Created:	30 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	pxyEmailTemplate: CM_EmailTemplate;
	newConsigneeCode: String;

begin

	if _newConsignee &lt;&gt; null then
		newConsigneeCode := _newConsignee.code;
	endif;
	
	pxyEmailTemplate := self.myMasterProxyObject.CM_BulkRelease.myEmailTemplate;
	if pxyEmailTemplate = null then
		self.currentConsigneeCode := newConsigneeCode;
		return;	// there is no any email defaults edited by Email Options
	endif;
	
	// this is commented because it is not nice stop, when clicking another screen in JMT
	/*if _newConsignee = null then	// when null consignee in the cmbConsignee
		if self.myTerminal.getConfig(DefaultConsignorEmail).Boolean then
			app.msgBox("Email Defaults have been entered for the previous consignee. You need to set the Consignee confirm the email defaults.","E-mail Options",null);
			
			return;	// Do nothing. The Carrier is compulsary field. Just wait until a user selects a carrier.
		endif;
	endif;*/

	if self.currentConsigneeCode = newConsigneeCode then
		return;	// do nothing - consignee not changed
	endif;

	self.currentConsigneeCode := newConsigneeCode;
	
	self.showEmailFormForCarrierChanged(pxyEmailTemplate);

end;</source>
        <Parameter name="_newConsignee" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="create" id="783a875d-4051-4f1b-aa90-b9a0d851fa41">
