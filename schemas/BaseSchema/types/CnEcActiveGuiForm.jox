    <JadeMethod name="btnPrint_click" id="4ed59466-5f4e-4eaf-bff6-595fdfef15ba">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrint_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		01 April 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.aMyActiveForm.cnEcPrintMe(true);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSysInfo_click" id="6cc65c99-a349-47e2-932a-73bb571fb00d">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSysInfo_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		15 April 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doShowHideInfo(jadeMask.value);
	self.centreWindow();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="0e711502-a43f-4091-90a1-6de0f8f79dc7">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 April 2006 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	self.cnEcIgnoreSkinAll(true);
	centreWindow();
	grpForm.ignoreSkin		:=	true;
	lblFName.ignoreSkin		:=	true;
	txtFName.ignoreSkin		:=	true;
	lblFSuper.ignoreSkin	:=	true;
	txtFSuper.ignoreSkin	:=	true;
	lblFParent.ignoreSkin	:=	true;
	txtFParent.ignoreSkin	:=	true;
	lblFSchema.ignoreSkin	:=	true;
	txtFSchema.ignoreSkin	:=	true;
	lblFHelpId.ignoreSkin	:=	true;
	txtFHelpId.ignoreSkin	:=	true;
	chkFUseBase.ignoreSkin	:=	true;
	btnFInspect.ignoreSkin	:=	true;
	grpControl.ignoreSkin	:=	true;
	lblCName.ignoreSkin		:=	true;
	txtCName.ignoreSkin		:=	true;
	lblCType.ignoreSkin		:=	true;
	txtCType.ignoreSkin		:=	true;
	lblCParent.ignoreSkin	:=	true;
	txtCParent.ignoreSkin	:=	true;
	lblCSuper.ignoreSkin	:=	true;
	txtCSuper.ignoreSkin	:=	true;
	lblCSchema.ignoreSkin	:=	true;
	txtCSchema.ignoreSkin	:=	true;
	lblCTabIndex.ignoreSkin	:=	true;
	txtCTabIndex.ignoreSkin	:=	true;
	lblCHelpId.ignoreSkin	:=	true;
	txtCHelpId.ignoreSkin	:=	true;
	chkCUseBase.ignoreSkin	:=	true;
	btnCInspect.ignoreSkin	:=	true;
	mumAvi.ignoreSkin		:=	true;
	tblSysInfo.ignoreSkin	:=	true;
	btnContents.ignoreSkin	:=	true;
	btnClose.ignoreSkin		:=	true;
	btnSysInfo.ignoreSkin	:=	true;
	self.getGuiDetails();
	
	if self.aMyActiveForm = null then
		btnFInspect.enabled	:=	false;
		btnContents.enabled	:=	false;
	endif;
	
	if self.aMyActiveControl = null then
		btnCInspect.enabled	:=	false;
	endif;
	
	self.doShowHideInfo(false);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowHideInfo" id="7e0571c2-25d4-42de-9d5a-bdb2b4405eac">
        <updating/>
        <source>doShowHideInfo(pIsShow:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 April 2006 by cnwdad1
//
// Purpose:		Shows or hides the system information.
//
// Parameters:	pIsShow - True if the info is shown, otherwise false if hidden.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	HEIGHT_HIDE		: Integer = 451;
	HEIGHT_SHOW		: Integer = 620;
	HELP_HIDDEN		: String = "Show system information";
	HELP_SHOWN		: String = "Hide system information";
	
begin
	tblSysInfo.visible		:=	pIsShow;
	mumAvi.visible			:=	pIsShow;
	
	if pIsShow then
		tblSysInfo.cnEcPopulate();
		mumAvi.play();
		btnSysInfo.caption		:=	"&lt;&lt;";
		btnSysInfo.bubbleHelp	:=	HELP_SHOWN;
		self.height				:=	HEIGHT_SHOW;
	else
		mumAvi.stop();
		btnSysInfo.caption		:=	"&gt;&gt;";
		btnSysInfo.bubbleHelp	:=	HELP_HIDDEN;
		self.height				:=	HEIGHT_HIDE;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pIsShow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getGuiDetails" id="a419084e-74f5-4e34-939d-a6742138a1a0">
        <source>getGuiDetails() protected;
// --------------------------------------------------------------------------------
// Created:		15 April 2006 by cnwdad1
//
// Purpose:		Gets the GUI details and populates the relevant info textboxes.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formParentObj	: Form;
	
begin
	chkFUseBase.cnEcSet(false);
	chkCUseBase.cnEcSet(false);

	if self.aMyActiveForm &lt;&gt; null then
		formParentObj	:=	self.aMyActiveForm.getFormParent();
		
		txtFName.cnEcSet(self.aMyActiveForm.name);
		txtFSuper.cnEcSet(self.aMyActiveForm.class.getSuperclass().name);
		
		if formParentObj = null then
			txtFParent.cnEcSet("N/A");
		else
			txtFParent.cnEcSet(formParentObj.name);
		endif;
		
		txtFSchema.cnEcSet(self.aMyActiveForm.class.schema.name);
		txtFName.text.cnEcCopyToClipboard();
		txtFHelpId.cnEcSet(self.aMyActiveForm.helpContextId.String);
	endif;
	
	if self.aMyActiveControl &lt;&gt; null then
		txtCName.cnEcSet(self.aMyActiveControl.name);
		txtCType.cnEcSet(self.aMyActiveControl.class.name);
		txtCParent.cnEcSet(self.aMyActiveControl.parent.name);
		txtCSuper.cnEcSet(self.aMyActiveControl.class.getSuperclass().name);
		txtCSchema.cnEcSet(self.aMyActiveControl.class.schema.name);
		txtCTabIndex.cnEcSet(self.aMyActiveControl.tabIndex.String);
		txtCHelpId.cnEcSet(self.aMyActiveControl.helpContextId.String);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setWindows" id="314af3a6-777d-45d4-a99c-89a1bb8d58f1">
        <updating/>
        <source>setWindows(pFormObj:Form; pControlObj:Control) updating;
// --------------------------------------------------------------------------------
// Created:		13 April 2006 by cnwdad1
//
// Purpose:		Sets the references to the active window objects.
//
// Parameters:	pFormObj - A reference to the active Form.
//				pControlObj - A reference to the active Control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyActiveForm		:=	pFormObj;
	self.aMyActiveControl	:=	pControlObj;
end;</source>
        <Parameter name="pFormObj" type="Form"/>
        <Parameter name="pControlObj" type="Control"/>
    </JadeMethod>
</GUIClass>
