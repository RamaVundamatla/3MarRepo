    <JadeMethod name="mnuCargoTestAP_click" id="48f5d757-0a62-4f47-9a5f-043cf1bccc3b">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoTestAP_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
/*	anLC : CM_LocationsController;
	str1,
	str2 : String;
	noSuccesses,
	noErrors	: Integer;
	theTI : CM_TrackedItem;*/
	objArray : CM_ObjectArray;	
begin
	//epr par 19875 10/6/09
	create objArray transient;
	self.getSelectedMenuTIs(objArray);

	// 02 Mar 2012	NDL	Par 29195
	if self.myCurrentDrawingController.allSelectedObjects.size &gt; 1 then
		self.myAssistant.showTestAutoPlan(	self.myTerminal, null, null, self.myCurrentDrawingController.allSelectedObjects, false );
		return;
		
	elseif objArray.size &gt; 1 then
		self.myAssistant.showTestAutoPlan(	self.myTerminal, null, null, objArray, false );
		return;
		
	else
		self.myAssistant.showTestAutoPlan(	self.myTerminal, null, menuItem.userObject.CM_TrackedItem, null, false );
		return;
		
	endif;
	
	/*

	if self.myCurrentDrawingController.allSelectedObjects.size &gt; 1 then
		app.autoPlanTiYATestMulti(self.myTerminal, null, self.myCurrentDrawingController.allSelectedObjects, str1, str2, noSuccesses, noErrors);
		app.msgBoxScroll(str1 &amp; str2, null, null, noSuccesses.String &amp; " planned. " &amp; noErrors.String &amp; " failed to plan.",MsgBox_OK_Only);
		return;
	elseif objArray.size &gt; 1 then
		app.autoPlanTiYATestMulti(self.myTerminal, null, objArray, str1, str2, noSuccesses, noErrors);
		app.msgBoxScroll(str1 &amp; str2, null, null, noSuccesses.String &amp; " planned. " &amp; noErrors.String &amp; " failed to plan.",MsgBox_OK_Only);
		return;
	endif;
	theTI := menuItem.userObject.CM_TrackedItem;
	anLC := self.myCurrentDrawingController.getScenarioAPLocation(theTI);
	
	*/
	

epilog
	delete objArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
