    <DbClassMap file="baserel"/>
    <MemberKey>
        <property name="CnEcReleaseHistoryMaster::processStartTime"/>
    </MemberKey>
    <JadeMethod name="searchForReleases" id="a5c4e226-02dc-41ca-9a88-daf354445ead">
        <executionLocation>server</executionLocation>
        <source>searchForReleases(	pStartTimestamp:TimeStamp;
					pUserName:String;
					pComputerName:String;
					pAllSearchResults:CnEcRelHistoryMasterByTimeDict io) serverExecution;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Searchs the receiver looking for release history objects using the
//				apecified criteria.
//
// Parameters:	pStartTimestamp - The timestamp to start searching from.
//				pUserName - The username to look for (null = all).
//				pComputerName - The computer name to look for (null = all).
//				pAllSearchResults - A collection of release history object that
//					match the search criteria.
//
// Returns:		The collection of release history objects as an IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	releaseMasterObj	: CnEcReleaseHistoryMaster;
	iteratorObj			: Iterator;
	
begin
	pAllSearchResults.clear();
	
	iteratorObj	:=	self.createIterator();
	self.startKeyGeq(pStartTimestamp, iteratorObj);
	
	while iteratorObj.next(releaseMasterObj) do
		if pUserName &lt;&gt; null and releaseMasterObj.processUser &lt;&gt; pUserName then
			continue;
		endif;

		if pComputerName &lt;&gt; null and releaseMasterObj.computerName &lt;&gt; pComputerName then
			continue;
		endif;
		
		pAllSearchResults.add(releaseMasterObj);
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <Parameter name="pStartTimestamp" type="TimeStamp"/>
        <Parameter name="pUserName" type="String"/>
        <Parameter name="pComputerName" type="String"/>
        <Parameter name="pAllSearchResults" type="CnEcRelHistoryMasterByTimeDict" usage="io"/>
    </JadeMethod>
</CollClass>
