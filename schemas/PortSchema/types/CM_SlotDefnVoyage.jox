    </JadeMethod>
    <JadeMethod name="getStowageId" id="6a55b0f2-10a6-4979-8852-b134c265c89b">
        <source>getStowageId(_fortyFoot,_useBayCellTierNumbering:Boolean):String;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs1
//
// Purpose:     Converted from C++. Returns the 40' corrected stowageid of the slot defn.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lBayId, lStowageId: String;
	theBay : CM_BayVoyage;
begin

	theBay := self.myBay.CM_BayVoyage;
	if theBay = null then
		if self.mySlotController = null then 
			app.raiseCMException2(MethodWithNullParam, "CM_SlotDefn::stowageId", "mySlotController","",null);
		endif;
		theBay := self.mySlotController.myBayVoyage;
	
	endif;
	if _fortyFoot then
		if theBay.isAftBay 
		and not theBay.isForwardBay then // PAR 7899 - the middle bay of a triple if aft and fwd, it has its own 40 bay id
			if theBay.myForwardBay &lt;&gt; null then
				lBayId := theBay.myForwardBay.idBay40;
			else
				lBayId := theBay.id;
			endif;
		else
			lBayId := theBay.idBay40;
		endif;
	else
		lBayId := theBay.id;
	endif;
	if _useBayCellTierNumbering = true then
		lStowageId := lBayId &amp; cellId &amp; tierId;
	else
		lStowageId := lBayId &amp; tierId &amp; cellId;
	endif;

	return lStowageId;
	
end;</source>
        <Parameter name="_fortyFoot" type="Boolean"/>
        <Parameter name="_useBayCellTierNumbering" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminalForConfigOption" id="06fc1050-e0d0-4c9c-9397-4ab8168cb08d">
        <source>getTerminalForConfigOption():CM_Terminal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 March 2011	cnwndl1	Initial creation	Par 27203

*/

vars

	voyage : CM_Voyage;
	term : CM_Terminal;
	passport : CM_Passport;

begin

	voyage := self.getVoyage;
	if voyage &lt;&gt; null then
		term := voyage.myTerminal;
	endif;
	
	if term = null then
		passport := app.myPassport;
		if passport &lt;&gt; null then
			term := passport.myTerminal;
		endif;
	endif;

	return term;
		
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
