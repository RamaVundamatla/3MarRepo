    <JadeMethod name="createProperties" id="c33acb4a-53b1-46ff-aaac-d7a161b22eab">
        <source>createProperties();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields
*/

vars
	tmpProp		: CM_QueryProperty;
begin

	inheritMethod();
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Contract Id', CM_InvoiceContract::contractId.name, self.className);
	tmpProp.needToUpperCase := true;
  	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefBankProperty persistent; 
	tmpProp.set('Bank', CM_InvoiceContract::myBusinessUnit.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//debtor name
	create tmpProp as CM_QRefDebtorMethod persistent;
	tmpProp.set('Debtor', CM_InvoiceContract::getDebtor.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateProperty persistent;                                 
	tmpProp.set('Contract From Date', CM_InvoiceContract::fromTS.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateProperty persistent;                                
	tmpProp.set('Contract To Date', CM_InvoiceContract::toTS.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Primary', CM_InvoiceContract::primary.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Active', CM_InvoiceContract::active.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Description', CM_InvoiceContract::description.name, self.className);
	tmpProp.needToUpperCase := true;
  	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrInvLineTypeMethod persistent;
	tmpProp.set('Detail Invoice Line Type', CM_InvoiceContract::getInvoiceLineType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateContractDetail persistent;                          
	tmpProp.set('Detail From Date', CM_InvoiceContract::getFromTSDetls.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateContractDetail persistent;                                 
	tmpProp.set('Detail To Date', CM_InvoiceContract::getToTSDetls.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrCalculationTypeMethod persistent;                                 
	tmpProp.set('Detail Calculation Type', CM_InvoiceContract::getCalculationTypes.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrInvUnitOfMeasureMethod persistent;
	tmpProp.set('Unit Of Measure Code', CM_InvoiceContract::getUomCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrServiceMethod  persistent;
	tmpProp.set('Rate Service', CM_InvoiceContract::getService.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateContractDetail persistent;                                 
	tmpProp.set('Rate Entry From Date', CM_InvoiceContract::getFromTSRateEntry.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateContractDetail persistent;                                
	tmpProp.set('Rate Entry To Date', CM_InvoiceContract::getToTSRateEntry.name,self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//12/11/2023 navmv20 Bug 61113 - start
	create tmpProp as CM_QInvContTypeLookupMethod persistent;                                
	tmpProp.set('Contract Type', CM_InvoiceContract::getContractType.name,self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QAccumTypeLookupMethod persistent;                                
	tmpProp.set('Accumulation Type', CM_InvoiceContract::getAccumulationType.name,self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	self.createMeasurementProperties(CM_QRefMeasureWtsProperty, Type_Weight, 'Volume Based Accumulated Weight', CM_InvoiceContract::getAccumWeight.name, self.className, null);
	self.createMeasurementProperties(CM_QRefMeasureVolsProperty, Type_Volume, 'Volume Based Accumulated Volume', CM_InvoiceContract::getAccumVolume.name, self.className, null);
	
	create tmpProp as CM_QIntArrMethod persistent;                                
	tmpProp.set('Volume Based Accumulated  Quantity', CM_InvoiceContract::getAccumQuantity.name,self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDecArrMethod persistent;                                
	tmpProp.set('Volume Based Accumulated  TEU', CM_InvoiceContract::getAccumTeu.name,self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	//12/11/2023 navmv20 Bug 61113 - end
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="54e5f7fb-baee-42ab-b759-d014254e3661">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars
	qProp	: CM_QueryProperty;
begin
	inheritMethod(_sa);
	
	
	qProp := self.allQueryProperties[CM_InvoiceContract::myTerminal.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_InvoiceContract::myBusinessUnit.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_InvoiceContract::getDebtor.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_InvoiceContract::contractId.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_InvoiceContract::description.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	
	qProp := self.allQueryProperties[CM_InvoiceContract::primary.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

epilog

end;</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
