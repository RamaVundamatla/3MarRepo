    <JadeMethod name="keyDown" id="b0a2fc94-9eac-4947-8d80-b153774c4a9e">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars
	theActiveControl	: Control;
	
begin

	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	if keyCode = J_key_Tab then
		tblSelection.handleFormTab(keyCode, shift, optSpecs, tblSelectData);
		tblActionData.handleFormTab(keyCode, shift, tblSelectData, btnSelectAllT);
		if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	elseif keyCode = J_key_Enter then
		self.doSearch();		
	else
		inheritMethod(keyCode, shift);
	endif;
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="a645bc67-dfb4-4950-880b-ea4503bb9150">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;

vars

begin
	self.myAssistant.comboBoxVoyageCode(self.cmbVoyage, null, false, false);	
	self.myAssistant.comboBoxVoyageCode(self.cmbToVoyage, null, false, false);
	self.initComboComparisonOperator();
	self.initComboUOM();
	
	self.cmbToPlace.addItem(null);
	self.cmbToPlace.addItem(PlaceDeckStr);
	self.cmbToPlace.addItem(PlaceHoldStr);	
	
	self.cmbPlace.addItem(null);
	self.cmbPlace.addItem(PlaceDeckStr);
	self.cmbPlace.addItem(PlaceHoldStr);		
	
	//setup results table (middle table)
	self.loadSelectionData(ETDef_TransitTransferSpecs);		
	self.optDocket.value := true;
	self.doOptDocketClick();
	self.setButtons(false);		
	self.toolbarShowCaptions(self.frmToolbar.showCaptions);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDestination" id="5b72582d-bb80-428d-beed-6ae6c1e6071a">
        <updating/>
        <source>loadDestination() protected, updating;

vars

begin
	if self.myToVoyage &lt;&gt; null and self.myToVoyage.myLogVoyageStructure &lt;&gt; null then
		self.tblActionData.setValueByName(ETRow_ToLot, null);
		self.cmbToLot.listCollection(self.myToVoyage.myLogVoyageStructure.allLogLots, true, 0);
		self.tblActionData.setValueByName(ETRow_ToHatch, null);
		self.tblActionData.setValueByName(ETRow_ToPlace, null);
		self.loadHatchPlace(self.cmbToHatch, self.myToVoyage, false);
		if self.optSED.value then
			self.tblActionData.setValueByName(ETRow_ToCOperator, app.getErrorString(Greater_Than));
		elseif self.optSpecs.value then
			self.tblActionData.setValueByName(ETRow_ToUOM, BOL_UOM_PIECE_COUNT);					
		endif;		
	else
		self.tblActionData.clearValues();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
