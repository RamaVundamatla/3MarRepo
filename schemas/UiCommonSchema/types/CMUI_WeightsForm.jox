    <JadeMethod name="updateScaleWeight" id="f44b8ad9-c24a-4bac-aeb2-c8220641f8e6">
        <updating/>
        <source>updateScaleWeight(_newWeight : Decimal) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2019	jlger1	Initial creation 44965
02 Feb 2021	NDL	TFS 50152 - fix bugs found while testing

*/

vars
	firstReading : Decimal[16,4];
begin
	self.btnUpdate.visible := false;
	self.btnUpdCargo.visible := false;
	self.btnUpdTruck.visible := false;
	self.btnUpdChassis.visible := false;
	self.btnUpdGenny.visible := false;
	self.btnUpdMachine.visible := false;
	
	if self.myWeighBridge &lt;&gt; null and self.myWeighBridge.isSingleReading then
		self.calculate(false,null);
		
	else
		if self.myVehicleVisitRecord &lt;&gt; null then
			firstReading := self.myVehicleVisitRecord.getWeighBridgeWeight(VisitRecord_WeighBridgeIn);
		endif;
		self.btnUpdate.visible := true;
		self.btnUpdate.zOrder(1);
		
		//09 Jul 2019	NDL	TFS 44965
		if  self.myTruck &lt;&gt; null and ( self.myVehicleVisitRecord = null or not self.myVehicleVisitRecord.hasWeighInVVRD ) then	// no previous weighing
			if self.myTruck.locationsController.allTrackedItems.size = 0 then
				self.tblTruckTareW.setValueDefault(_newWeight.String );
			else	
				self.tblCargoTotalW.setValueDefault(( _newWeight - self.myTruck.tareKilos ).String);
				self.tblTruckTareW.setValueDefault( self.myTruck.tareKilos.String );
			endif;
		endif;
		
		if  self.myVehicleVisitRecord &lt;&gt; null and self.myVehicleVisitRecord.hasWeighInVVRD then	// has a previous weighing
			if self.myTruck &lt;&gt; null and self.myTruck.locationsController.allTrackedItems.size = 0 then
				if self.myVehicleVisitRecord.isOnlyReleasingCargo then
					//not loaded yet
					self.tblTruckTareW.setValueDefault( _newWeight.String );
					self.tblCargoTotalW.setValueDefault( '0.0' );
				elseif self.myVehicleVisitRecord.isOnlyReceivingCargo then
					//has been unloaded
					self.tblTruckTareW.setValueDefault( _newWeight.String );
					self.tblCargoTotalW.setValueDefault( (firstReading - _newWeight).String );
				endif;
				
			else
				if self.myVehicleVisitRecord.isOnlyReleasingCargo then
					// has been loaded
					self.tblTruckTareW.setValueDefault(firstReading.String );
					self.tblCargoTotalW.setValueDefault((_newWeight - firstReading ).String);
				elseif self.myVehicleVisitRecord.isOnlyReceivingCargo then
					//not unloaded yet
					self.tblCargoTotalW.setValueDefault(( _newWeight - self.myTruck.tareKilos ).String);
					self.tblTruckTareW.setValueDefault( self.myTruck.tareKilos.String );
				endif;
					
			endif;
		endif;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateTruckTareWeight" id="9cbaa681-79f1-4899-bdb9-989afb31e95c">
        <updating/>
        <source>updateTruckTareWeight( _vehicle : CM_Vehicle; _newTareWeightKgs : Decimal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268
06 April 2020	navhl20 TFS 52777 EUP - INT - Generic API: record-scan
16 July 2022	navmd1	TFS 52777 Tidy up/review code
*/

vars

	pxyVehicle : CM_Vehicle;
	load : Boolean;
	ret : Integer;
	pxyGateScanRecord : CM_GenericGateScanRecord;
begin

	app.cmsBeginLoad( load );
	pxyVehicle := _vehicle.pxyCreateUpdateProxy().CM_Vehicle;
	app.cmsEndLoad( load );
	
	pxyVehicle.setProxy(	pxyVehicle.regNumber,	//pRegNumber : String;
							pxyVehicle.batNumber,	//pBatNumber : String;
							_newTareWeightKgs,	//_tareKilos : Decimal;
							pxyVehicle.maxGrossLadenWeight.Integer,	//_maxGrossLadenWeight : Integer;
							pxyVehicle.carrier,	//pCarrier : CM_Carrier; 
							pxyVehicle.state,	//_state : String;
							pxyVehicle.isNotAvailableForEntry,	//_isNotAvailableEntry : Boolean;
							pxyVehicle.myTerminal	//_terminal : CM_Terminal
							);
	
	while true do
		app.myTrxUA.trxUpdateVehicle( pxyVehicle, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			ret := IDOK;
			self.btnUpdTruck.visible := false;
			break;
			
		else
			ret := app.showErrorWarningDialog(app.getErrorString(CM_Weight), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
	
	endwhile;
	
	// ### TFS 52777 12 APR 2022 NAVHL20
	/*if self.myAssistant.myCurrentGateScanRecord &lt;&gt; null and app.myPassport.noErrors then
		pxyGateScanRecord := app.createUpdateProxy(self.myAssistant.myCurrentGateScanRecord).CM_GenericGateScanRecord;
		if pxyGateScanRecord &lt;&gt; null then
			pxyGateScanRecord.setVehicleVisitRecord(_vehicle.getCurrentVisit());
			app.myTrxUA.trxUpdateGateScanRecord(pxyGateScanRecord, app.myPassport);
		endif;
	endif;*/
	// ### TFS 52777 12 APR 2022 NAVHL20
	
	self.updateGateScanRecord();	// ### TFS 54311 25Oct2022 NAVPW1
	
epilog

	app.cmsEndLoad( load );
	delete pxyVehicle;
    //delete pxyGateScanRecord;
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_newTareWeightKgs" type="Decimal"/>
    </JadeMethod>
</GUIClass>
