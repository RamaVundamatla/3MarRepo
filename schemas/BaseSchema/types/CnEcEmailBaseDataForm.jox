end;</source>
    </JadeMethod>
    <JadeMethod name="updateBaseData" id="e22a93c5-c0a6-4c02-9814-053500a273a4">
        <updating/>
        <source>updateBaseData() updating, protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	emailRootObj	: CnEcEmailRoot;
	baseDataObj		: CnEcEmailBaseData;
	errorMsg		: String;
	
begin
	emailRootObj	:=	CnEcEmailRoot.firstInstance();
	
	if aIsAdminMode then
		baseDataObj	:=	emailRootObj.myDefaultBaseData;
		
		if baseDataObj = null then
			//adding a new one
			errorMsg := self.aMyTA.trxCnEcEmailBaseDataDefault(emailRootObj);
			if errorMsg &lt;&gt; null then
				app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
				return;
			else
				baseDataObj	:=	emailRootObj.myDefaultBaseData;				
			endif;	
		endif;			
		
		//updating with values from the screen
		errorMsg := self.aMyTA.trxCnEcEmailBaseDataUpdate(	baseDataObj,	//pCnEcEmailBaseDataToUpdate : CnEcEmailBaseData io;
															baseDataObj.edition(),	//pRequiredEdition : Integer;
															baseDataObj.computerName,	//pComputerName:String;
															txtClient.text,	//pEmailClientName:String;
															txtReturnAddress.text,	//pEmailReturnAddress:String;
															txtServer.text,	//pEmailServerName:String;
															txtLdapBase.text,	//pLdapBase:String;
															txtLdapHost.text,	//pLdapHost:String;
															emailRootObj	//pMyEmailBaseRoot:CnEcEmailRoot
															);
	
	else
		baseDataObj	:=	emailRootObj.getEmailBaseData(app.computerName());
		
		if baseDataObj = emailRootObj.myDefaultBaseData then
			//adding a new one
			errorMsg := self.aMyTA.trxCnEcEmailBaseDataCreate(	emailRootObj,	//pCnEcEmailRootParent : CnEcEmailRoot io;
																app.computerName(),	//pComputerName:String;
																txtClient.text,	//pEmailClientName:String;
																txtReturnAddress.text,	//pEmailReturnAddress:String;
																txtServer.text,	//pEmailServerName:String;
																txtLdapBase.text,	//pLdapBase:String;
																txtLdapHost.text,	//pLdapHost:String;
																emailRootObj,	//pMyEmailBaseRoot:CnEcEmailRoot;
																baseDataObj	//pCnEcEmailBaseDataNew : CnEcEmailBaseData output
																);			
		else
			//updating an existing one
			errorMsg := self.aMyTA.trxCnEcEmailBaseDataUpdate(	baseDataObj,	//pCnEcEmailBaseDataToUpdate : CnEcEmailBaseData io;
																baseDataObj.edition(),	//pRequiredEdition : Integer;
																app.computerName(),	//pComputerName:String;
																txtClient.text,	//pEmailClientName:String;
																txtReturnAddress.text,	//pEmailReturnAddress:String;
																txtServer.text,	//pEmailServerName:String;
																txtLdapBase.text,	//pLdapBase:String;
																txtLdapHost.text,	//pLdapHost:String;
																emailRootObj	//pMyEmailBaseRoot:CnEcEmailRoot
																);
		endif;
	endif;
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
	else
		unloadForm();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
