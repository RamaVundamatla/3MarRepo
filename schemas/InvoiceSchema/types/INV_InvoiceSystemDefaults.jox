	self.setColorsForEntryTable(self.tblDataEntry);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControllerFromTable" id="a5081410-13fd-49ec-a6b7-c551b5d10e12">
        <updating/>
        <source>setControllerFromTable(_controller : CMIF_InvoiceSystemDefaults input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 19 Mar 2021 cnwma1 ChangeRequest 50925: ASPA - New Total Column in Invoice Form
// 4/11/2022   navcs2 ChangeRequest 54898: EUP - Invoice currency symbol - Euro € 
// 14/11/2022  navcs2 Defect 55399: MTN - Invoice Configuration - 14011 when saving
// 16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
// 23 November 2023 navra1 TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61386/Task - 61389)
// 30 Apr 2024 navnk30 Bug 63894: MTN - Stop Creating Unqualified Audits for invoices Config not showing correct setting
// 11/06/2024 navbk1  Bug 64564: MTN - Invoice Configuration Screen doesn't show correct values
// ---------------------------------------------------------------------------

vars
	tmpNum 	 : String;
	ioObject : CM_ExtFinanceIO;
	tbl      : CM_EntryTable;
	extWebService	: CM_InvoiceAPIServiceDef;
begin
	
	// ###############################
	// ###############################
	// ###############################
	// ###############################
	
	// ### IF YOU HAVE ADDED TO THE FINANCIAL CONFIG YOU MUST ALSO UPDATE SOPTM_Terminal::setControllerFromTable
	
	tbl := self.tblDataEntry;
	
	_controller.invoicePrintRemarks 		:= tbl.getValueByName(InvoicePrintRemarks).Boolean;
	_controller.myCalendar 					:= self.cmbCalendar.listObject.CM_Calendar; 
	_controller.invoiceHMSNoShiftCharge 	:= tbl.getValueByName(ETRow_InvoiceHMSNoShiftCharge).Boolean;
	_controller.cashOnlyInDebtOption 		:= self.cmbDebtAction.listData;
	_controller.invPostWithoutAuditQual 	:= tbl.getValueByName(ETRow_AllowInvPostUnqualAudits).Boolean; 
	_controller.storageConfigType 			:= self.cmbStorConType.listObject.CM_StorageConfigType;				// 02 Nov 2017	NDL	TFS 7032
	//_controller.invoiceRoundLineTotal 	:= tbl.getValueByName(ETRow_InvoiceRoundLineTotal).Boolean;			// 20/8/18 MAP TFS40270     // 19.03.2021 cnwma1 #50925
	_controller.invoiceRoundLineTotal 		:= self.cmbRoundInvLine.listData;									// 19.03.2021 cnwma1 #50925
	_controller.invoiceRoundDownLineTax 	:= tbl.getValueByName(ETRow_InvoiceRoundDownLineTax).Boolean;		// 20/8/18 MAP TFS40272
	_controller.chargeFirstTemperatureOnly  := self.cmbReeferOptions.listIndex = 2;
	_controller.defCompany 					:= self.cmbBUs.listObject.CM_Bank;
	_controller.defDebtor 					:= self.cmbDebtor.listObject.CM_Debtor;
	_controller.exportPath 					:= tbl.getValueByName(ETRow_ExternalExportPath).String;
	_controller.invoiceDeferredCharging     := tbl.getValueByName(ETRow_DeferredCharging).Boolean;				// 11/06/2024 navbk1 #64564

	ioObject := self.cmbFinancialIO.listObject.CM_ExtFinanceIO;
	_controller.financialIOClass		   := ioObject;
	
	//navra1 - TFS 54090(CR 61386/Task - 61389) - 23th Nov 2023 - start
	if ioObject &lt;&gt; null and ioObject .isKindOf(CM_InvoiceAPI) then
		_controller.invoiceAPIOutputMode := tbl.getValueByName(ETRow_InvoiceAPIOutputMode).String;		
		//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term config - start
		/*if self.cmbExtWebService.listObject &lt;&gt; null then
			_controller.externalWebService := self.cmbExtWebService.listObject.CM_InvoiceAPIServiceDef;		
		endif;*/
		//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term config - end
	endif;
	//navra1 - TFS 54090(CR 61386/Task - 61389) - 23th Nov 2023 - end
	
	if _controller.financialIOClass = null then //on new database this may not be setup
		_controller.financialIOClass := CM_DefaultFinanceIO.firstInstance;
	endif;
	_controller.financialsEnabled 		:= tbl.getValueByName(ETRow_FinancialsEnabled).Boolean;
	_controller.firstMonthOfFinYear 	:= tbl.getValueByName(ETRow_FirstMonthFinancialYear).Integer;
	_controller.glPeriod 				:= tbl.getValueByName(ETRow_CurrentGLPeriod).Integer;
	_controller.glYear 					:= tbl.getValueByName(ETRow_CurrentGLYear).Integer;
	_controller.mTsByDebtor				:= tbl.getValueByName(ETRow_MTsByDebtor).Boolean;
	_controller.mTsByDebtorExport 		:= tbl.getValueByName(ETRow_MTsByDebtorExport).Boolean;
	_controller.invoiceMultiTaxRates 	:= tbl.getValueByName(ETRow_InvoiceMultiTaxRates).Boolean;
	if self.cmbCurrency.listIndex &lt;&gt; -1 then																	// 14/11/2022  navcs2 Defect 55399: MTN - Invoice Configuration - 14011 when saving
		_controller.currencySymbol 		:= self.cmbCurrency.itemData[self.cmbCurrency.listIndex].Integer; 		// 4/11/2022   navcs2 ChangeRequest 54898
	endif;																										// 14/11/2022  navcs2 Defect 55399: MTN - Invoice Configuration - 14011 when saving
	_controller.invUseInvoiceCargoAlloc := tbl.getValueByName(ETRow_InvUseInvoiceCargoAlloc).Boolean;	// PAR 35833
	_controller.invInvoicePrintJRW 		:= tbl.getValueByName(ETRow_InvInvoicePrintJRW).String;			// PAR 36180
	_controller.invWOVoyageTranOnAction := tbl.getValueByName(ETRow_InvWOVoyageTranOnAction).Boolean; 	// TFS 42161
	_controller.multiCompany			:= tbl.getValueByName(ETRow_MultiCompany).Boolean;
	_controller.name 					:= tbl.getValueByName(ETRow_ExternalFinancialName).String;
	_controller.financialRateDPlaces    := self.tblDataEntry.getValueByName(ETRow_FinancialRateDPlaces).Integer;
	_controller.invAuditCargoEdits		:= tbl.getValueByName(ETRow_InvAuditCargoEdits).Boolean;		//30.04.2024 navnk30 #63894
	
	tmpNum := tbl.getValueByName(ETRow_NextInvoiceNumber).String;
	if tmpNum.length &gt; 9 then
		_controller.nextInvoiceNumber := tmpNum[1:9].Integer;
	else
		_controller.nextInvoiceNumber := tmpNum.Integer;
	endif;
	_controller.remarks := tbl.getValueByName(ETRow_ExternalFinSysRemarks).String;
	
	_controller.cashProcessingEnabled 	:= tbl.getValueByName(ETRow_CashProcessingEnabled).Boolean;
	_controller.dotMatrixInvoiceRep 	:= tbl.getValueByName(ETRow_DotMatrixInvoiceRep).String;	//14 Nov 2012	NDL	Par 30683
	_controller.autoNormalReefers		:= tbl.getValueByName(ETRow_AutoNormalReefers).Boolean;
	_controller.autoVoidExternalReefers := tbl.getValueByName(ETRow_AutoVoidExternalReefers).Boolean;
	_controller.invShowAllSeparation    := tbl.getValueByName(ETRow_InvShowAllSeparation).Boolean; //16/03/2023  navmv20 TFS 56128 Task 56129
	
end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceSystemDefaults" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="51f5aba1-4de5-4f6b-98e9-2a66d52b8403">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 20 Aug 2024	navnk30	Bug 65567: MTN - Invoice API Consolidation Config
// ---------------------------------------------------------------------------

vars
	
	theTable		: CM_EntryTable;
	idx 			: Integer;
	value 			: Boolean;
	
begin
	inheritMethod();
	
	self.minimumWidth := 550;
	self.minimumHeight := 550;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.cmbCurrency.init();
	self.showToolbar := true;
	self.doCmbReeferOptionsBuild();
	self.doCmbBUsBuild();
	self.doCmbDebtorBuild();
	self.myAssistant.comboBoxFinancialIOClass(self.cmbFinancialIO,null);//PAR 17620 
	//20.08.2024 navnk30 #65567 START
	//self.myAssistant.comboBoxInvAPIOutputMode(self.cmbInvAPIOPMode, CM_InvoiceAPI.CONSMODE_NO_CONS);		//navra1 - TFS 54090(CR 61386/Task - 61389) - 13th Nov 2023
	self.myAssistant.comboBoxInvAPIOutputMode(self.cmbInvAPIOPMode, null);
	//20.08.2024 navnk30 #65567 END
	//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term config - start
	//self.myAssistant.comboBoxInvAPIExtWebService(self.cmbExtWebService, null);			//navra1 - TFS 54090(CR 61386/Task - 61389) - 13th Nov 2023
	//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term config - end
	self.doCmbStorConfigTypeBuild();	//02 Nov 2017	NDL	TFS 7032
	//PAR 17620 self.doCmbFinanceClassBuild();
	self.initTblDataEntry();
	self.doQuery();
	self.doHideShow();
	self.setNavigatorHeading(self.caption);	
	self.showSheets();	//23 July 2012	NDL	Par 29968

	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblDataEntry.userInputEnabled := false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="shouldIShow" id="ba258aae-5a90-4c20-9c5e-694641e16038">
        <source>shouldIShow() : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return true;
	if app.isDevelopmentSystem then
		return true;
	else
		app.msgBox("This screen is unavailable as it is still in development.","Invoice Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showIOClass" id="63bdfde0-4bd5-4c6b-bc8c-19411e41a58d">
        <source>showIOClass(_ioObject : CM_ExtFinanceIO); //CM_ExtFinanceIO
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx, lc : Integer;
	ioObject : CM_ExtFinanceIO;
	c : Class;
begin
	if _ioObject &lt;&gt; null then//	PAR 17620
// PAR 35572		ioObject := self.getObjectFromClass(_ioClass);//	PAR 17620
		ioObject := _ioObject; // PAR 35572
	endif;//	PAR 17620
	if ioObject &lt;&gt; null then//	PAR 17620
//	PAR 17620	if app.myRoot.myRootCompany.ioClasses.includes(_ioClass) then
		if self.cmbFinancialIO.findObject(_ioObject) &gt; 0 then//	PAR 17620
			self.cmbFinancialIO.listObject := _ioObject;//	PAR 17620
		endif;
		
		//navra1 - TFS 54090(CR 61386/Task - 61389) - 13th Nov 2023 - start
		if _ioObject.isKindOf(CM_InvoiceAPI) then		
			self.tblDataEntry.showRowByName(ETRow_ExternalExportPath, false);
			self.tblDataEntry.showRowByName(ETRow_ExtWebService, false);
			self.tblDataEntry.showRowByName(ETRow_InvoiceAPIOutputMode, false);			
		else		
			self.tblDataEntry.showRowByName(ETRow_ExternalExportPath, false);
			self.tblDataEntry.hideRowByName(ETRow_ExtWebService, false);
			self.tblDataEntry.hideRowByName(ETRow_InvoiceAPIOutputMode, false);		
		endif;
		//navra1 - TFS 54090(CR 61386/Task - 61389) - 13th Nov 2023 - end

		self.tblDataEntry.setValueByName(ETRow_FirstMonthFinancialYear,ioObject.firstMonthOfFinYear); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_ExternalExportPath,ioObject.exportPath); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_CurrentGLPeriod,ioObject.glPeriod); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_CurrentGLYear,ioObject.glYear); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_ExternalFinancialName,ioObject.name);  // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_ExternalFinSysRemarks,ioObject.remarks); // PAR 33572
	else
		self.tblDataEntry.setValueByName(ETRow_FirstMonthFinancialYear,null); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_ExternalExportPath,null); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_CurrentGLPeriod,null); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_CurrentGLYear,null); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_ExternalFinancialName,null); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_ExternalFinancialName,null); // PAR 33572
		self.tblDataEntry.setValueByName(ETRow_ExternalFinSysRemarks,null); // PAR 33572
		
	endif;

end;</source>
        <Parameter name="_ioObject" type="CM_ExtFinanceIO"/>
    </JadeMethod>
