    <JadeMethod name="getFromTSDetls" id="6790d243-85de-42d7-965b-c03ec8dba48a">
        <source>getFromTSDetls() : DateArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars
	detail : CM_InvoiceContractDetails;
	dates : DateArray;
begin
	create dates transient;
	
	foreach detail in self.allInvoiceContractDetails discreteLock do
		if dates.indexOf(detail.fromTS.date) = 0 then
			dates.add(detail.fromTS.date);
		endif;
	
	endforeach;
	
	return dates;
epilog

