    <JadeMethod name="lstMethods_dblClick" id="f8100d59-7646-4d47-9ca9-6c44500f6d20">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMethods_dblClick(listbox: ListBox input) updating;

begin
	if listbox.listIndex &lt; 1 or listbox.listIndex &gt; listbox.listCount then
		// belts and braces
		return;
	endif;
	if listbox.itemLevel[listbox.listIndex] = 1 then
		listbox.itemExpanded[listbox.listIndex] := not listbox.itemExpanded[listbox.listIndex];
	else
		self.jtdAddMethodProfile(self.JtdAtEnd);
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
