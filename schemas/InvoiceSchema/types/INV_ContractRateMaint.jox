    <JadeMethod name="tblData_dblClick" id="b2e98bfc-4a78-4a2b-8c94-0b4f6be9c6d3">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details
15 Mar 2023 navmk20		Bug 57096: MTN - Minor UX issue when using contract maintenance
*/

vars

begin
	if table.row &gt; table.fixedRows then
		self.doBtnUpdateClick();			//15.3.2023 navmk20 TFS 57096
		return;
	endif;

	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDisplayRow" id="6697b438-3c75-47b2-9e97-f1bea335f68a">
        <source>tblDisplayRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
*/

vars
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	rate				 : CM_InvoiceContractRate;
	rateEntry			 : CM_InvoiceContractRateEntry;
	service 			: CM_Service;
	contractRangeEntry  : CMIF_ContractRangeEntry; //25/10/2023 navmv20 CR 60503 Task 60505
	contractRangeEntryDates : CMIF_ContractRateEntryDates; //25/10/2023 navmv20 CR 60503 Task 60505
begin
	
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	service := self.cmbService.listObject.CM_Service;
	rate := self.myContractDetails.allInvContractRatesByService[service];
	if rate = null then
		return;
	endif;
	
	//25/10/2023 navmv20 CR 60503 Task 60505 - start
		create contractRangeEntry transient;
		contractRangeEntry.createCMIFRateEntryDates(self.myInvoiceContractRate);
		foreach contractRangeEntryDates in contractRangeEntry.allDateRanges do
			str := contractRangeEntryDates.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			idx := tbl.addItem(str);
			tbl.accessRow(idx).itemObject := contractRangeEntryDates;
		endforeach;
		/*foreach rateEntry in rate.allInvoiceContractRateEntries do
			str := rateEntry.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			idx := tbl.addItem(str);
			tbl.accessRow(idx).itemObject := rateEntry;
		endforeach;*/
	//25/10/2023 navmv20 CR 60503 Task 60505 - end
	
	//31/01/2023	navkc1 Bug 61578
	self.allTransientsToDelete.add(contractRangeEntry);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b1138086-11a3-4fa6-be7c-7596e42afb2b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 14 February 2024 12:14:40.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025616, locale);
	btnAdd.translateBubbleHelp(Xlat_0025716, locale);
	btnAdd.translateCaption(Xlat_0025617, locale);
	btnClose.translateCaption(Xlat_0025618, locale);
	btnCriteria.translateCaption(Xlat_0025619, locale);
	btnNew.translateBubbleHelp(Xlat_0025717, locale);
	btnNew.translateCaption(Xlat_0025620, locale);
	btnRemoveRate.translateBubbleHelp(Xlat_0025718, locale);
	btnRemoveRate.translateCaption(Xlat_0025621, locale);
	btnRemoveRtEnt.translateBubbleHelp(Xlat_0025719, locale);
	btnRemoveRtEnt.translateCaption(Xlat_0025622, locale);
	btnSave.translateBubbleHelp(Xlat_0025720, locale);
	btnSave.translateCaption(Xlat_0025623, locale);
	btnUpdate.translateBubbleHelp(Xlat_0025721, locale);
	btnUpdate.translateCaption(Xlat_0025624, locale);
	chkReceiveRail.translateCaption(Xlat_0025864, locale);
	chkReceiveRoad.translateCaption(Xlat_0025865, locale);
	chkReceiveShip.translateCaption(Xlat_0025866, locale);
	chkVolume.translateCaption(Xlat_0025625, locale);
	grpAccumulateFor.translateCaption(Xlat_0025867, locale);
	grpAmountFrom.translateCaption(Xlat_0025868, locale);
	lblDeriveQuanity.translateCaption(Xlat_0025626, locale);
	lblEnd.translateCaption(Xlat_0025627, locale);
	lblInvoiceLine.translateCaption(Xlat_0025628, locale);
	lblService.translateCaption(Xlat_0025629, locale);
	lblShippingTerm.translateCaption(Xlat_0025630, locale);
	lblStart.translateCaption(Xlat_0025631, locale);
	lblUnitOfmeasure.translateCaption(Xlat_0025632, locale);
	mnuContextMenu.translateCaption(Xlat_0025634, locale);
	mnuInspectObject.translateCaption(Xlat_0025722, locale);
	optAccPeriod.translateCaption(Xlat_0025869, locale);
	optAccVoyage.translateCaption(Xlat_0025870, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="48fb2da5-cf37-497a-9e75-da96c871397f">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars
	cmifRangeEntryDate	: CMIF_ContractRateEntryDates;
begin
	// ### TFS BUG 61268 28NOV2023 NAVAB1
	if self.myRateEntryForm &lt;&gt; null then
		self.myRateEntryForm.unloadForm();
	endif;

	if self.myPxyContractDetails &lt;&gt; null then
		delete self.myPxyContractDetails;
	endif;
	
	//16 October 2023	navmv20	Bug 60893 - start
	delete myCMIFContractRangeEntry;
	
	if self.myParentForm &lt;&gt; null then
		//self.myParentForm.INV_ContractMaint.myContractRateMaint := null;				//14.10.2024 navlc30 #19508
		if self.myParentForm.isKindOf(INV_ContractMaint) then							//14.10.2024 navlc30 #19508
			self.myParentForm.INV_ContractMaint.myContractRateMaint := null;
		elseif  self.myParentForm.isKindOf(INV_ContractEnquiry) then
			self.myParentForm.INV_ContractEnquiry.myContractRateMaintForm := null;
		endif;
	endif;
	//16 October 2023	navmv20	Bug 60893 - end
	
	//31/01/2023	navkc1 Bug 61578
	self.allTransientsToDelete.purge();
	
	inheritMethod(); // ### TFS 57311 24MAR2023 NAVAB1
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateContractDtl" id="38b7c640-1df7-4b26-ba6b-4131609d3bfb">
        <updating/>
        <source>updateContractDtl()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details
02 Mar 2023 navtnr20 Bug 56906: EUP - Minor UX issues when adding contract/contract information
07 Mar 2023 navtnr20 	Bug 56765: EUP - Criteria Priority not being saved
*/

vars
	pxyCon, realCon 		: CM_InvoiceContractDetails;
	terminal				: CM_Terminal;
	bank 					: CM_Bank;
	involeceLine 					: CM_InvoiceLineDesc;
	desc,contractID			: String;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	
	volumeBased	,receiveRoad, receiveShip, receiveRail				: Boolean;
	unitofMeasure : CM_InvoiceUnitOfMeasure;
	shipTerm : CM_InvoiceContractShipTerm;
	calculationType : CM_CalculationType;
	realcontracr : CM_InvoiceContract;
	type, accumulationType : Integer;
	theReturn : Integer;
	priority : Integer;
begin

	if self.myPxyContractDetails = null then
		self.myPxyContractDetails := app.createUpdateProxy(self.myContractDetails).CM_InvoiceContractDetails;	//navtnr20 03-03-2023 TFS 56906
	endif;	
	if self.cmbInvoiceLine.listIndex &lt;&gt; -1 then
		involeceLine := self.cmbInvoiceLine.itemObject[self.cmbInvoiceLine.listIndex].CM_InvoiceLineDesc;
	endif;
	if self.cmbUnitOfMeasure.listIndex &lt;&gt; -1 then
		unitofMeasure := self.cmbUnitOfMeasure.itemObject[self.cmbUnitOfMeasure.listIndex].CM_InvoiceUnitOfMeasure;
	endif;
	if self.cmbShippingTerm.listIndex &lt;&gt; -1 then
		shipTerm := self.cmbShippingTerm.itemObject[self.cmbShippingTerm.listIndex].CM_InvoiceContractShipTerm;
	endif;
	if self.cmbCalculationTypes.listIndex &lt;&gt; -1 then
		calculationType := self.cmbCalculationTypes.itemObject[self.cmbCalculationTypes.listIndex].CM_CalculationType;
	endif;
	scheduleTSstart.setDate(self.mskContractFromStart.text.asDateJMT());
	scheduleTSstart.setTime(self.mskContractFromStartTime.text.asTimeJMT());
	scheduleTSend.setDate(self.mskContractFromEnd.text.asDateJMT());
	scheduleTSend.setTime(self.mskContractFromEndTime.text.asTimeJMT());
	if self.chkVolume.value then
		type := INV_CONTRACT_TYPE_VOLUME_BASED;
	else
		type := INV_CONTRACT_TYPE_STANDARD;
	endif;
	//Start  //15-03-2023 navtnr20 CR 55647 TASK 55696
	receiveRoad := self.chkReceiveRoad.value;
	receiveRail := self.chkReceiveRail.value;
	receiveShip := self.chkReceiveShip.value;
	if self.optAccPeriod.value then
		accumulationType := INV_VOL_BASED_PERIOD;
	else
		accumulationType := INV_VOL_BASED_VOYAGE;
	endif;
	//End  //15-03-2023 navtnr20 CR 55647 TASK 55696
	if self.myPxyContractDetails.myInvoiceContractCriteria &lt;&gt; null then // ### TFS BUG 56765 03MAR2023 NAVTNR20
		priority := self.myPxyContractDetails.myInvoiceContractCriteria.priority; // ### TFS BUG 56765 03MAR2023 NAVTNR20
	endif;
	
	self.myPxyContractDetails.setProxy(null,type,priority, self.localToSystemTime(scheduleTSstart), self.localToSystemTime(scheduleTSend),calculationType , self.myInvoiceContract, involeceLine, self.myCurrentBank,shipTerm,unitofMeasure); // ### BUG 58796 26JUN2023 NAVAB1 'localToSystemTime'
	 if self.myPxyContractDetails.isKindOf(CM_InvoiceContractDtlsVolBased) then		 //15-03-2023 navtnr20 CR 55647 TASK 55696
		self.myPxyContractDetails.CM_InvoiceContractDtlsVolBased.setProxyVolBased(receiveRail,receiveRoad,receiveShip,accumulationType);	 //15-03-2023 navtnr20 CR 55647 TASK 55696
	endif;
	while true do
		app.myTrxUA.trxUpdateInvContractDtl(self.myPxyContractDetails, app.myPassport);
		if app.myPassport.trxCompletedOK then
			realCon := self.myPxyContractDetails;
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Invoic_contra_detail_update_su), app.getErrorString(Message),MsgBox_OK_Only);
			delete self.myPxyContractDetails ;
 // ### TFS BUG 56908 15MAR2023 NAVAB1			self.myPxyContractDetails := app.createUpdateProxy(self.myContractDetails).CM_InvoiceContractDetails;
			self.pxyObjMatchCriteria := null; // ### TFS BUG 56765 03MAR2023 NAVTNR20
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	delete pxyCon;
 // ### BUG 57015 13MAR2023 NAVAB1	delete self.myPxyContractDetails;
end;</source>
    </JadeMethod>
