    <JadeMethod name="getDischAllOverDim" id="1b49503d-e7b7-4c68-9785-1498f1547410">
        <source>getDischAllOverDim() : Integer;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tot 		: Integer;
	attribute	: Attribute;
begin
	attribute := CM_KPIVoyageMoveDtl_Container::numOverdimension;
	
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Discharge, 20, attribute);
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Discharge, 30, attribute);
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Discharge, 40, attribute);
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Discharge, 45, attribute);
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Discharge, 53, attribute);
	
	return tot;
epilog

end;

</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
