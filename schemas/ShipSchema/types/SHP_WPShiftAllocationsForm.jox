    <JadeMethod name="unloadForm" id="03c5a59f-c936-443d-a562-de8b892efb1c">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operatinos Enhancements
// 19/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
//
vars

begin
	if self.listeningForClassNotes then
		self.listeningForClassNotes := false;
		self.endClassNotification( CM_TrackedItem, false, Any_System_Event);

		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Create_Event)); // TFS 42872
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Update_Event)); // TFS 42872
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Delete_Event)); // TFS 42872
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateNewWLE" id="962410a4-7f99-49c5-af38-fcedb8bdc6eb">
        <updating/>
        <source>updateNewWLE(_wle : CM_WorkListEntry io) updating;
/*

Purpose:			Updates the job table with the new wle

Parameters:			

Return Value:		

Date				Who		Reason
19 August 2019		jlgzm1	Initial creation

*/

vars
	voyage : CM_Voyage;
	table : CM_DataTable;
	idx : Integer;
	ctrl : Control;
	invalidObject : Boolean;
	sheet : CMUI_Sheet;
	job : CM_VoyageHoldJob;
begin
	on Exception do app.handleDeletedObject( exception, _wle, invalidObject );
	
	voyage := _wle.job.getMyVoyageObject;
	
	if self.allDisplayedWLEs.includes(_wle) or voyage &lt;&gt; self.myCurrentVoyage then
		// we already haven this one displayed.
		return;
	else
		foreach idx in 1 to self.allocatedTableCount do
			ctrl := self.tblAllocatedGang.getControl(idx);
			if ctrl.isKindOf(CM_DataTable) then
				table := ctrl.CM_DataTable;
				// job is the itemObject for the cloned sheet the cloned table is on
				sheet := table.parent.CMUI_Sheet;
				job := sheet.userObject.CM_VoyageHoldJob;
				if job = _wle.job then
					self.loadVoyageJobTable(job, table, null);
				endif;
			endif;
		endforeach;
		
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="9138d8e2-ee63-4f22-b109-a190c34ca801">
        <updating/>
        <source>updateTI(_ti : CM_TrackedItem io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 17/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 24/10/2109	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	tmpTbl : CM_DataTable;
	idx : Integer;
	voyage : CM_Voyage;
	invalidObject : Boolean;

begin
	on Exception do app.handleDeletedObject( exception, _ti, invalidObject );
	
	voyage := _ti.myVoyage;

	//if not self.allDisplayedTIs.includes(_ti) then									// TFS 3516
	if not self.allDisplayedTIs.includes(_ti) and not _ti.hasBeenMerged then			// TFS 3516
		// we haven't currently got this one displayed.
		if (voyage = self.myCurrentVoyage 
		or _ti.myVoyageTranshipExport = self.myCurrentVoyage 
		or _ti.myVoyageTranshipImport = self.myCurrentVoyage) // TFS 47085
		and not invalidObject then
			// but potentially it should be
			self.updateTIMove(_ti);
		else
			// not one we are interested in anyway
			return;
		endif;
	else
		if (voyage &lt;&gt; self.myCurrentVoyage and (_ti.myVoyageTranshipExport &lt;&gt; self.myCurrentVoyage)) or _ti.hasBeenMerged or invalidObject then
			// voyage is different, or it's been merged, or its been deleted, get rid of it from our tables
			self.removeTI(_ti);
		else
			// just update it in situ.
			self.updateTIMove(_ti);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTIMove" id="1d38c0b9-5794-474f-b752-5b3e4fc54a11">
        <updating/>
        <source>updateTIMove(_ti : CM_TrackedItem io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 20/08/2018	jlgdap1		TFS 39964 PEL1 Hold JOb Ops Loading Changes
// 19/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
// 24/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	idx : Integer;
	ctrl : Control;
	table : CM_DataTable;
	sheet : CMUI_Sheet;
	job : CM_VoyageJob;
	wle : CM_WorkListEntry;

begin
	if _ti.allJobsShipRelease.isEmpty and _ti.allJobsShipReceive.isEmpty then
		if _ti.myVoyage &lt;&gt; self.myCurrentVoyage then	// TFS 47085
			// If we're here and TI is for a different voyage then it is presumably tranship cargo
			// which needs to have a discharge job before it should show up anywhere on the export voyage.
			// If it is not tranship cargo, and is for a different voyage why would we want to display it on this voyage
			if self.allDisplayedTIs.includes(_ti) then	// TFS 47085
				self.removeTI(_ti);						// TFS 47085
			endif;
			return;
		endif;
		// is it on site / prenotified / on ship?
		//if _ti.isPreNote or _ti.isOnSite then							// TFS 39964
		if _ti.isOnSite then											// TFS 39964
			self.updateTIMoveForTable(true, _ti, self.tblOnSite);
		elseif _ti.isOnShip then
			self.updateTIMoveForTable(true, _ti, self.tblOnShip);
		elseif _ti.isPreNote then										// TFS 39964
			self.updateTIMoveForTable(true, _ti, self.tblPreNote);		// TFS 39964
		endif;
	endif;
	
	if _ti.myVoyage &lt;&gt; self.myCurrentVoyage and _ti.myVoyageTranshipExport = self.myCurrentVoyage then	// TFS 47085
		self.updateTIMoveForTable(true, _ti, self.tblTranship);	// TFS 47085
		self.setTranshipVisibility();	// TFS 47085
	endif;
	
	foreach idx in 1 to self.allocatedTableCount do
		ctrl := self.tblAllocatedGang.getControl(idx);
		if ctrl.isKindOf(CM_DataTable) then
			table := ctrl.CM_DataTable;
			// job is the itemObject for the cloned sheet the cloned table is on
			sheet := table.parent.CMUI_Sheet;
			job := sheet.userObject.CM_VoyageJob;
			foreach wle in _ti.allWorklistEntries where wle.job &lt;&gt; null and wle.job = job do	// TFS 42872
				if allDisplayedWLEs.includes(wle) then					// TFS 42872
					self.updateWLEMoveForTable(true, wle, table);		// TFS 42872
				endif;
			endforeach;
			/* tblAllocatedGang now shows wles so don't need to update for ti
			if (job.isDischarge and _ti.allJobsShipReceive.includes(job)) 
			or (not job.isDischarge and _ti.allJobsShipRelease.includes(job)) then
				self.updateTIMoveForTable(true, _ti, table);
			endif;
			*/
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTIMoveForTable" id="40477be7-7764-497b-a6fc-b2be9a1ce6e5">
        <source>updateTIMoveForTable(_update: Boolean; _ti : CM_TrackedItem io; _table : CM_DataTable input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Updates
// 02/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 19/04/2017	cnwdap1		TFS 4087 LNX Incorrect Quantity in Hold Planning
//
vars
	idx : Integer;
	job : CM_VoyageHoldJob;						// TFS 3516

begin
	job := _table.parent.CMUI_Sheet.userObject.CM_VoyageHoldJob;	// TFS 3516
	if _update then
	// should be there
		if _table.findObjectInRow(_ti, idx) then
			// its already there, just refresh it
			//_table.accessCell(idx, 1).text := _ti.getAttributeStringForDefArray(_table.allTblDataEntRows);			// TFS 4087
			_table.accessCell(idx, 1).text := _ti.getAttribStringForDefArrayJob(_table.allTblDataEntRows, job);		// TFS 4087
			self.doColourTableRow(_ti, null, _table, job, idx);			// TFS 3516
		else
			// not there, add it.
			//self.loadCargoForTable(_ti, idx, _table);				// TFS 3516
			self.loadCargoForTable(_ti, idx, _table, null);			// TFS 3516
			self.doColourTableRow(_ti, null, _table, job, idx);			// TFS 3516
		endif;
	else
		// should NOT be there
		if _table.findObjectInRow(_ti, idx) then
			// it is there so remove it
			_table.removeItem(idx);	
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateWLE" id="b68d5594-d705-48b1-b41e-502f2f299159">
        <updating/>
        <source>updateWLE(_wle : CM_WorkListEntry io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 July 2019		jlgzm1	Initial creation Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types

*/

vars
	tmpTbl : CM_DataTable;
	idx : Integer;
	voyage : CM_Voyage;
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject( exception, _wle, invalidObject );
	
	voyage := _wle.job.getMyVoyageObject;
	
	if not self.allDisplayedWLEs.includes(_wle) then
		// we haven't currently got this one displayed.
		return;
	else
		if (voyage &lt;&gt; self.myCurrentVoyage) or invalidObject then
			// voyage is different, or it's been merged, or its been deleted, get rid of it from our tables
			self.removeWLE(_wle);
		else
			// just update it in situ.
			self.updateWLEMove(_wle);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateWLEMove" id="16bf9ec9-e845-47b3-9c0e-053c46e87c22">
        <source>updateWLEMove(_wle : CM_WorkListEntry io) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 July 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types

*/

vars
	idx : Integer;
	ctrl : Control;
	table : CM_DataTable;
	sheet : CMUI_Sheet;
	job : CM_VoyageJob;
begin
	
	foreach idx in 1 to self.allocatedTableCount do
		ctrl := self.tblAllocatedGang.getControl(idx);
		if ctrl.isKindOf(CM_DataTable) then
			table := ctrl.CM_DataTable;
			// job is the itemObject for the cloned sheet the cloned table is on
			sheet := table.parent.CMUI_Sheet;
			job := sheet.userObject.CM_VoyageJob;
			if job = _wle.job then
				self.updateWLEMoveForTable(true, _wle, table);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateWLEMoveForTable" id="9ba76917-2962-4fb1-aaca-bddb9c473eb3">
        <source>updateWLEMoveForTable(_update: Boolean; _wle : CM_WorkListEntry io; _table : CM_DataTable input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 July 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types

*/

vars
	idx : Integer;
	job : CM_VoyageHoldJob;
	rowIdx : Integer;
	str : String;

begin
	job := _table.parent.CMUI_Sheet.userObject.CM_VoyageHoldJob;
	if _update then
	// should be there
		if _table.findObjectInRow(_wle, idx) then
			// its already there, just refresh it
			_table.accessCell(idx, 1).text := _wle.getAttributeStringForDefArray(_table.allTblDataEntRows);
			self.doColourTableRow(null, _wle, _table, job, idx);
		else
			// not there, add it.
			str := _wle.getAttributeStringForDefArray(_table.allTblDataEntRows);
			rowIdx := _table.addItem(str);
			_table.accessRow(rowIdx).itemObject := _wle;
			self.doColourTableRow(null, _wle, _table, job, idx);
		endif;
	else
		// should NOT be there
		if _table.findObjectInRow(_wle, idx) then
			// it is there so remove it
			_table.removeItem(idx);	
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="a9401c0c-92a1-4014-8489-fd089bd08b11">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 28/11/2018	jlgdap1		TFS 42109 PEL1 Hold Job Ops Issue
// 19/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types
// 10/12/2021   navma1		Bug 52539: SAL - Hold Planning Split Work - Delete Job
//
vars
	ti		 : CM_TrackedItem;
	wle 	 : CM_WorkListEntry;
	term     : CM_Terminal;
begin
	term := self.myTerminal;
	
	// handle deletes first
	if eventType = Object_Delete_Event then
		if theObject.isKindOf(CM_TrackedItem) then				// TFS 42872
			// must be the prenote table or the onship table
			self.handleDeletedTI(theObject.CM_TrackedItem, true);
		elseif theObject.isKindOf(CM_WorkListEntry) then		// TFS 42872
			self.handleDeletedWLE(theObject.CM_WorkListEntry);  // TFS 42872
		endif;
		return;
	endif;
	
	if theObject &lt;&gt; null then
		if theObject.isKindOf(CM_TrackedItem) then
			ti := theObject.CM_TrackedItem;
			self.updateTI(ti);
			
		elseif theObject = self.myCurrentVoyage then											// TFS 42872
			if userInfo &lt;&gt; null and userInfo.isKindOf(CM_VoyageWLE) then						// TFS 42872
				wle := userInfo.CM_WorkListEntry;												// TFS 42872
				if eventType = term.getTerminalEvent(WLE_Create_Event) then						// TFS 42872
					if wle.job &lt;&gt; null and wle.job.isKindOf(CM_VoyageHoldJob) and				// TFS 42872
						wle.job.CM_VoyageHoldJob.getMyVoyageObject = self.myCurrentVoyage then	// TFS 42872
						self.updateNewWLE(wle);													// TFS 42872
					endif;
				else
					self.updateWLE(wle);														// TFS 42872
				endif;
			elseif userInfo &lt;&gt; null and userInfo.isKindOf(CM_Voyage) then						//10.12.2021 navma1 #52539
				if eventType = term.getTerminalEvent(WLE_Delete_Event) then
					self.loadCurrentVoyage();
				endif;
			endif;													
			
		elseif theObject.isKindOf(CM_WorkListEntry) then		// TFS 42109
			wle := theObject.CM_WorkListEntry;					// TFS 42872
			ti := theObject.CM_WorkListEntry.myTrackedItem;		// TFS 42109
			if ti &lt;&gt; null then									// TFS 42109
				self.updateTI(ti);								// TFS 42109
			endif;												// TFS 42109
			self.updateWLE(wle);								// TFS 42872
		endif;
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
