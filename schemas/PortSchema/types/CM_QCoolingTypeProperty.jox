    <JadeMethod name="setComboValues" id="5e8bc4b7-c2eb-4452-ad00-dd59b7058055">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//--------------------------------------------------
// Created:	03 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	_combo.clear();

	_combo.addItem(app.coolingTypeENumToString(ContainerAirCooled, false));	
	_combo.addItem(app.coolingTypeENumToString(ContainerWaterCooled, false));		
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.coolingTypeENumToString(_queryOperator.CM_QIntegerLookupEqual.searchValue, false);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.coolingTypeENumToString(_queryOperator.CM_QIntegerLookupNotEqual.searchValue, false);
	endif;


end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="a8e7786e-aedc-4583-a7ea-fb3450c4cd5d">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
//--------------------------------------------------
// Created:	03 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(ContainerAirCooled);
	intArray.add(ContainerWaterCooled);
	
	self.setListTableFromIntConstants(_tbl, _operator, intArray, Container_CoolingType_Constant);	

epilog
	delete intArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="10b53341-7c5d-4d29-9c26-27e9cb84e048">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//--------------------------------------------------
// Created:	03 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;

begin
	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);
	
epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="2bb54028-2045-4d52-a800-8a7cc17a23e6">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	coolType	: Integer;
	
begin

	if _value.String.isInteger then
		return _value;
	endif;
	
	coolType := app.coolingTypeStringToENum(_value.String);
	
	if coolType = ContainerCooledNull and _value &lt;&gt; null then	 //Par 17092	cnwvu1, June 2008
		app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
	endif;
	
	return coolType;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="d89cb777-8ef7-4b73-bc7c-2c0562022b17">
        <source>translateToDisplayValue(_value: Any): String;
//--------------------------------------------------
// Created:	03 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	return app.coolingTypeENumToString(_value.Integer, false);

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="78270242-9c05-42d9-b3ed-b6516e8efd7c">
        <source>translateToSearchValue(_value: Any): Any;
//--------------------------------------------------
// Created:	03 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return app.coolingTypeStringToENum(_value.String);
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
