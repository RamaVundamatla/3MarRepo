    <JadeMethod name="doCmbTermTypeClick" id="d02d13d7-03e7-4a23-883a-f2b28a7b133a">
        <source>doCmbTermTypeClick() protected;
// ---------------------------------------------------------------------------
// Created:     16 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	termType		: CM_TerminologyType;
	termTypeExp		: CM_TerminologyTypeExpression;
	tbl				: CM_EntryTable;
	tmpName			: String;
	
begin
	termType := self.cmbTermType.listObject.CM_TerminologyType;
	
	if (termType = null) or (self.mode &lt;&gt; self.Mode_Add) then //can't change type if updating
		return;
	endif;
	
	tbl := self.tblHdrEntry;
	tmpName := tbl.getValueByName(ETRow_TermHdrName).String;
	self.initEntryTable(tbl, ETDef_TermHdrEnt);
	tbl.setValueByName(ETRow_TermType, termType.name);
	tbl.setValueByName(ETRow_TermHdrName, tmpName);
	
	foreach termTypeExp in termType.allTerminologyTypeExpressions do
		tbl.addAttribute(termTypeExp.expressionDescr, termTypeExp.getExpressionTypeHeading(), Table.InputType_TextBox, CM_TerminologyExpression::userExpression.length-1, true);
	endforeach;
	
	tbl.adjustHeight(300);
	tbl.optimiseHeadingColumn();
	tbl.goToRowByName(ETRow_TermType);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="f1dfe05e-8496-43d1-92bb-74891f5fb946">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     20 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	termDef		: CM_TerminologyDef;
	result		: Integer;
begin
	termDef := self.myCurrentObject.CM_TerminologyDef;
	
	if termDef = null then
		app.msgBox('You must select a terminology definition to delete', 'Noting selected', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteTerminologyDef(termDef, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Terminology Header Delete', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return false;
	endwhile;
	
	return true;
	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="5ffe8146-ba73-43ea-bf0d-37f05cc8af8a">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	assistant		: CMUI_Assistant;
	tmpTermType		: CM_TerminologyType;
begin
	inheritMethod();
	
	assistant := self.myAssistant;	
	if assistant = null then
		return;
	endif;
	
	tmpTermType := self.cmbFiltTermType.listObject.CM_TerminologyType;
	assistant.comboBoxTerminologyTypes(self.cmbFiltTermType, tmpTermType);
	self.tblSearch.setValueByName(ETRow_FiltTermType, self.cmbFiltTermType.text);
	
	tmpTermType := self.cmbTermType.listObject.CM_TerminologyType;
	assistant.comboBoxTerminologyTypes(self.cmbTermType, tmpTermType);
	self.tblHdrEntry.setValueByName(ETRow_TermType, self.cmbTermType.text);
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="6aa812be-92c7-4b5d-ab3a-987bd6109472">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pxyTermHdr,
	newTermHdr			: CM_TerminologyDef;
	result				: Integer;
	ls					: Boolean;
	firstError			: CM_Error;

begin
	app.cmsBeginLoad(ls);
	pxyTermHdr := self.myProxyObject.CM_TerminologyDef;
	
	if pxyTermHdr = null then
		create pxyTermHdr transient;
		self.myProxyObject := pxyTermHdr;	
	endif;
	
	if (not self.setProxiesFromTable(pxyTermHdr)) then
		return false;
	endif;
	
	self.getCargoTypeTerminals(pxyTermHdr);
	
	while true do
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateTerminologyDef(pxyTermHdr, newTermHdr, app.myPassport);
			self.myCurrentObject := newTermHdr;
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateTerminologyDef(pxyTermHdr, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Terminology Header', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		firstError := app.myPassport.allErrorWarnings.first;
		if firstError &lt;&gt; null then
			self.tblHdrEntry.goToRowByName(firstError.fieldName);
		endif;
		
		return false;
	endwhile;
	
	return true;
	
epilog
	
	app.cmsEndLoad(ls);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeTerminals" id="cc023676-c7aa-472d-b075-a1eff8540af6">
        <source>getCargoTypeTerminals(_termDef : CM_TerminologyDef input) protected;
// ---------------------------------------------------------------------------
// Created:     17 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	checked				: String;
	numRows,
	numCols,
	row,
	col					: Integer;
	tbl					: CM_DataTable;
	cargoBOLType		: CM_CargoBOLType;
	terminal			: CM_Terminal;
	pxyCTTerminal		: CM_TerminologyHdr;
begin
	if _termDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminology header passed in is null');
		return;
	endif;
	
	_termDef.raiseExceptionIfNotTransient(method);
	_termDef.allTerminologyHdrs.purge();
	tbl := self.tblTermHdr;
	numRows := tbl.rows;
	numCols := tbl.columns;

	foreach row in 2 to numRows do
		cargoBOLType := tbl.accessRow(row).itemObject.CM_CargoBOLType;
		foreach col in 2 to numCols do
			terminal := tbl.accessColumn(col).itemObject.CM_Terminal;
			
			checked := tbl.accessCell(row, col).text;
			if checked = '1' then
				create pxyCTTerminal transient;
				pxyCTTerminal.setProxy(_termDef, terminal, cargoBOLType);
			endif;
		endforeach;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_termDef" type="CM_TerminologyDef" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="017aab2a-ab96-4bc4-8008-a24d7e945e6e">
