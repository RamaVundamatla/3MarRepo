    <JadeMethod name="splitWleForTodo" id="05b1a975-e89d-456c-a5e1-3bcd7b8beef2">
        <source>splitWleForTodo(_ti : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2023 navhl20 Defect 62239: EUP | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - Job automatically unassigned from Gang

*/

vars
	wle,
	newWle	: CM_WorkListEntry;
begin
	wle := self.workListEntries.first;
	if wle &lt;&gt; null then
		if _ti.totalQuantity &lt;&gt; 0 and _ti.totalQuantity &lt; wle.quantity then
			newWle := wle.cloneSelf(wle.isTransient);
			newWle.setJob(wle.job);
			newWle.setMyTrackedItem(_ti);
			newWle.setLocations(wle.locationSource, _ti.locationId);
			newWle.updateRequest(wle.myRequest);
			wle.setQuantity(wle.quantity - _ti.totalQuantity);
			newWle.setQuantity(_ti.totalQuantity);
		elseif _ti.totalQuantity = wle.quantity then
			wle.setMyTrackedItem(_ti);
			wle.setLocations(wle.locationSource, _ti.locationId);
			wle.setQuantity(_ti.totalQuantity);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="bcbccf28-2947-4a94-b5f3-d1da47d260bc">
        <updating/>
        <source>updateStatus() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Nov 2024	navhl20	Bug MTN-23340 :MTN - Performance issues and locks when completing the Retrospective Pack jobs

*/

vars
	newStatus	:	Integer;
begin

	exclusiveLock(self);
	newStatus := self.getNewStatus();

	if newStatus &lt;&gt; self.status then
		self.status := newStatus;
		self.causeTerminalEvent(self.Event_Mode_Update);
	elseif self.status = JOB_PART_COMPLETE then
		self.causeTerminalEvent(self.Event_Mode_Update);
	endif;
epilog
	unlock(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateTICollections" id="48fd2d50-1083-4dd7-827f-80d8ba1a2d6b">
        <updating/>
        <source>updateTICollections(_trackedItem: CM_TrackedItem; _extra :Any) updating;
/*
Purpose:			
Parameters:			
Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
*/
vars

begin
	inheritMethod(_trackedItem, _extra);
	
	// check to see if we have a job for this todo task already?
	
	if (not app.myPassport.noErrors) then
		return;
	endif;
	
	if (not self.allTrackedItems.includes(_trackedItem)) then
			self.allTrackedItems.add(_trackedItem);	
	endif;

epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_extra" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="f066bd6a-9096-471a-afa0-ade7c743a2d6">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2023 navma1 ChangeRequest 58589[58595]: EUP | LMS Gang API - Endpoint
01 Aug 2023 navhl20 Defect 59621: EUP - Unable to delete Completed Work Order Job
*/

vars
	wle	: CM_WorkListEntry;
begin
	//if self.status = JOB_COMPLETE or self.status = JOB_PART_COMPLETE then			//01.8.2023 navhl20 #59621
	if self.status = JOB_PART_COMPLETE then											//01.8.2023 navhl20 #59621
		app.raiseCMException1(VB_JOB_NO_DELETE, self.jobId &amp; " Status - " &amp; self.statusString, null, null);
		return;
	endif;
	
	/*
	//01.8.2023 navhl20 #59621
	if not self.allCompletedWLEsByDate.isEmpty then
		app.raiseCMException1(VB_JOB_NO_DELETE, self.jobId &amp; " Status - " &amp; self.statusString, null, null);
	endif;*/
	

epilog

end;</source>
    </JadeMethod>
</Class>
