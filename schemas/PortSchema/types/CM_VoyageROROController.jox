    <JadeMethod name="getWLEForTI" id="d8b7c36a-7453-493d-aa0b-1adb21a1e6c2">
        <source>getWLEForTI(_ti: CM_TrackedItem): CM_WorkListEntry;

 // ### TFS 53105 16JUN2022 NAVAB1
vars
	req : CM_Request;
	wle : CM_WorkListEntry;
begin

	foreach req in self.allRequestsDischarge discreteLock do
		wle := req.allWorkListEntries.first;
		if wle.myTrackedItem = _ti then
			return wle;
		endif;
	
	endforeach;
	foreach req in self.allRequestsLoad discreteLock do
		wle := req.allWorkListEntries.first;
		if wle.myTrackedItem = _ti then
			return wle;
		endif;
	
	endforeach;

	return inheritMethod(_ti);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="handleTIBeingErased" id="a4baab03-9010-41e6-9542-719d95c622a5">
        <updating/>
        <source>handleTIBeingErased(_ti : CM_TrackedItem) updating;
/*
Purpose:			
Date		Who		Reason
29 August 2011	cnwab1	Initial creation
*/

vars
	tmpWLE : CM_VoyageWLE;
	req : CM_RORORequest;
	invalidObj : Boolean;
	layout : CM_DeckItemLayout;
	theVoyage : CM_Voyage;
	theTerminal : CM_Terminal;
	otherLC		: CM_VoyageROROController;
begin

	theVoyage := self.myVoyage;
	theTerminal := theVoyage.myTerminal;

	on Exception do app.handleDeletedObject(exception, req, invalidObj);

	req := self.myRORORequestDischarge;
	
	if req &lt;&gt; null then
		req.removeWLE(tmpWLE,_ti);
		if invalidObj then
			return;
		endif;
	endif;

	if not _ti.is20 then											// 27/07/2012 cnwmh5 #30018
		otherLC := self.getOtherLocnControllerFor40TI();
		if otherLC &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(
				theVoyage,
				theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
				otherLC);
		endif;
	endif;
	
	app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								self);
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="hasROB" id="5fcc9bf5-bccb-4341-a0f6-29c0d3737d3d">
        <source>hasROB(_ediProposed : Boolean) : Boolean;
/*
Purpose:  Has Remain On Board, double check has no discharge CC			
Date		Who		Reason
08 February 2012	cnwab1	Initial creation

18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
04 Feb 2013	cnwrs1	Par 31119 include tranship for proposed deck plan
14 Oct 2022 navma1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/
vars
	ti 		: CM_TrackedItem;
	imex	: Integer;
begin
	
	if self.myRORORequestDischarge = null then
		ti := self.allTrackedItems.first;
		if ti &lt;&gt; null then
			imex := ti.getImExStatus();				  //14.10.2022 navma1 #54935
			
			if imex = TI_IMEX_STATUS_REMAINONBOARD   // Remain On Board
			or imex = TI_IMEX_STATUS_TRANSHIP  		 // TRANSHIP  31459
			// PAR 29467 we include imports this because when RoB are colour coded they change to imports, when the colour coding is erased they stay as imports
			or imex = TI_IMEX_STATUS_IMPORT then // Import
				if _ediProposed and	//15 Jan 2013	cnwrs1	Par30951 dont include discharge Imports as ROBs for EDI Proposed 
				   ti.isToBeDischargedHere() then
					return false;
				else
					return true;
				endif;
			endif;
			if _ediProposed and	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed 
			   (imex = TI_IMEX_STATUS_EXPORT or
				ti.isTranshipInbound() or	//04 Feb 2013	cnwrs1	Par 31119 include tranship for proposed deck plan
				ti.isTranshipOutbound()) then	//04 Feb 2013	cnwrs1	Par 31119 include tranship for proposed deck plan
				return true;
			endif;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_ediProposed" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
