    <JadeMethod name="updateSelf" id="c7724a40-1491-49c3-ad98-5db4c1d67fa1">
        <updating/>
        <source>updateSelf(_value: Any; _obj :Object) updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/02/2010	cnwcs5		ccms 1925 / par 22295 - new functions for release summaries
//							I have taken out the code the does not count empty string values
//							and replaced with new Count_Not_Null function
// ---------------------------------------------------------------------------
vars

begin
	if _value.isKindOf (CM_SnapshotField_CountAbstract) then
		self.count 	:= self.count + _value.CM_SnapshotField_CountAbstract.count;
		return;
	endif;
	
	self.count 	:= self.count + 1;
	
	//07 Nov 2013	NDL	Par 32654
	if _obj &lt;&gt; null then
		self.allObjects.addNoDuplicates (_obj, false);	
	endif;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
