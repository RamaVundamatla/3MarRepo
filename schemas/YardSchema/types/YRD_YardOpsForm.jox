/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2023 navdp20  ChangeRequest 57304:[57305] EUP - [Framework] - Add selection counter and Text Filtering on Yard Operation screen
*/

vars

begin
	inheritMethod(_wleArray);
	self.numRows := self.tblWorkEntries.rows-self.tblWorkEntries.fixedRows;
    self.frmModeStatusBar.myFrameCaption.caption := (self.numRows).String &amp; " rows found.";
epilog

end;</source>
