    <JadeMethod name="tblData_dblClick" id="38beb5e4-d256-4275-b4c0-91bf51345825">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58238: UI - Notifications
*/

vars

begin
	if table.row &gt; table.fixedRows then
		self.dobtnUpdate();
		return;
	endif;

	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDisplayRow" id="bd11c43e-36fb-4b87-8ac5-91c2b2a7311d">
        <source>tblDisplayRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
*/

vars
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	ownershipChangeDetail : CM_OwnershipChange;
	theDataLine : String;
begin
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	foreach ownershipChangeDetail in self.myTerminal.allOwnershipChangeOpOld do
		str := ownershipChangeDetail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx := tbl.addItem(str);
		tbl.accessRow(idx).itemObject := ownershipChangeDetail;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="800344af-ab90-4830-a748-8fd48f3c3c6c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 June 2023 12:26:29.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026156, locale);
	btnAdd.translateCaption(Xlat_0026157, locale);
	btnApprove.translateCaption(Xlat_0026158, locale);
	btnAttachment.translateCaption(Xlat_0026159, locale);
	btnAudits.translateCaption(Xlat_0026160, locale);
	btnClear.translateCaption(Xlat_0026161, locale);
	btnClose.translateCaption(Xlat_0026162, locale);
	btnFind.translateCaption(Xlat_0026163, locale);
	btnInvoiceIssus.translateCaption(Xlat_0026164, locale);
	btnRemove.translateCaption(Xlat_0026165, locale);
	btnUpdate.translateCaption(Xlat_0026166, locale);
	lblEnd.translateCaption(Xlat_0026167, locale);
	lblNumber.translateCaption(Xlat_0026168, locale);
	lblStart.translateCaption(Xlat_0026169, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026170, locale);
	mnuContextMenu.translateCaption(Xlat_0026171, locale);
	mnuInspectObject.translateCaption(Xlat_0026172, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="dbf67460-8f9e-4f0e-9aec-fa9414ca9e41">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			

Date		Who		Reason
13 May 2024	navab1	BUG 64115
*/

vars

	cooMaintForm : CMUI_OwnershipChangeMaint; 
	cooDetailForm : CMUI_OwnershipChangeDetail;
begin
	cooMaintForm := self.myMaintForm;
	if cooMaintForm &lt;&gt; null then
		cooDetailForm := cooMaintForm.myDetailForm;
		if cooDetailForm &lt;&gt; null then
			cooDetailForm.unloadForm();
		endif;
		cooMaintForm.unloadForm();
	endif;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
