    <JadeMethod name="updateJob" id="9ae04dc5-87d9-4602-a26d-63f756e2d999">
        <updating/>
        <source>updateJob(_theJob : CM_VoyageJob input; _newRow : Integer) updating;
//--------------------------------------------------------------
//Created: 12 December 2003 By: cnwgd1
//
// 05 Nov 2012	PJS		PAR #30631 
//--------------------------------------------------------------
vars
	idx,foreColour, backColour	: Integer;
	addRemarks, theDataLine		: String;
	theJobTITotals				: CMIF_JobTITotals;
	theTable					: CM_DataTable;
	newRow, remarksRow			: Integer;
					
begin
	
	newRow := _newRow;
	
	theTable := self.tblData;
	theTable.clearAllSelected;
	// find the job and update that line OR add onto the end of the list
	
	theTable.findObjectInRow(_theJob, idx);
	
	if idx &gt; 0 then
		if JadeTableRow.hasInstance(theTable.accessRow(idx+1).itemObject) then
			//remarks row is displayed too
			theTable.removeItem(idx+1);	
		elseif _newRow &lt; idx
		and JadeTableRow.hasInstance(theTable.accessRow(idx-1).itemObject) then
			//this move will split a job and it's remarks from below
			newRow := newRow-1;
		elseif _newRow &gt; idx
		and JadeTableRow.hasInstance(theTable.accessRow(idx+2).itemObject) then
			//this move down will split a job and it's remarks from a
			newRow := newRow+1;
		endif;	
		theTable.removeItem(idx);	
	else
		return;
	endif;	

	create theJobTITotals transient;
	_theJob.getJobTITotals(theJobTITotals);
	theDataLine := theJobTITotals.getAttributeStringForDefArray(theTable.allTblDataEntRows);

	theTable.addItemAt(theDataLine,newRow);
	theTable.accessRow(newRow).itemObject := _theJob;

	_theJob.getRowColour(foreColour, backColour);
	theTable.accessRow(newRow).backColor := backColour;
	theTable.accessRow(newRow).foreColor := foreColour;
	if theTable.accessRow(newRow).backColor = Red then
		theTable.accessRow(newRow).fontBold := true;
	else
		theTable.accessRow(newRow).fontBold := false;				
	endif;
	
	addRemarks := _theJob.getAdditionalRemarks;
	if self.btnRemarks.value and addRemarks &lt;&gt; null then
		theTable.addItemAt(Tab &amp; app.getErrorString(INV_Remarks) &amp; '  ' &amp;  Tab &amp; Tab &amp; addRemarks, newRow+1);	// 30631
		theTable.accessRow(newRow+1).itemObject := theTable.accessRow(newRow);
		theTable.accessCell(newRow+1, 2).foreColor := Red;
		theTable.accessedCell.mergeCells := Table.MergeCells_Merge;
		theTable.accessCell(newRow+1, 4).mergeCells := Table.MergeCells_Merge;
	endif;
		
	theTable.selectObject(_theJob, false);

	//set top row ?
	if newRow &gt; 2
	and (newRow-theTable.topRow) &lt;= 2 then
		theTable.topRow := newRow - 2;
	endif;
	
	if ((6 + (newRow-theTable.topRow)) * theTable.rowHeight[newRow]) &gt; theTable.height then
		theTable.topRow := theTable.topRow + 1;
	endif; 
	
epilog
	delete theJobTITotals;
end;</source>
        <Parameter name="_theJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateJobRemove" id="e80b0ec3-d2cf-46ad-a246-e094567a21b7">
        <updating/>
        <source>updateJobRemove(_theObj : Object) updating;
//--------------------------------------------------------------
//Created: 12 December 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	idx,
	selectedIdx : Integer;
	theTable : CM_DataTable;
	selectedObj : Object;	
begin

	
	
	theTable := self.tblData;
	if (not theTable.findObjectInRow(_theObj, idx)) then
		return;
	endif;

	selectedIdx := theTable.row;		
	selectedObj := theTable.accessRow(selectedIdx).itemObject;
	
	if selectedObj.String = _theObj.String then
		selectedObj := null;
		selectedIdx := -1;
		if selectedIdx &lt;= theTable.fixedRows then
			selectedIdx := theTable.fixedRows+1;
		endif;
	endif;	

	theTable.removeItem(idx);
	if JadeTableRow.hasInstance(theTable.accessRow(idx).itemObject) then
		//remove remarks row
		theTable.removeItem(idx);
	endif;

	if (not theTable.selectObject(selectedObj, false)) then
		theTable.selectRow(selectedIdx, false);
	endif;

	self.doTblDataRowColChange(theTable);
	
	
	
end;</source>
        <Parameter name="_theObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="updateMoveButtons" id="1155b263-377c-42d2-8049-aec772c27e95">
        <source>updateMoveButtons(aJob : CM_VoyageJob);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
begin
	if aJob = null 
	or self.filterWorkPoint = null then
		self.btnTBMoveDown.enabled := false;
		self.btnTBMoveUp.enabled := false;
		self.frmToolbar.positionToolbarControls();
		return;
	endif;
	
	if aJob.myJobSheet = null then
		self.btnTBMoveDown.enabled := false;
		self.btnTBMoveUp.enabled := false;
	else
		if aJob.myJobSheet.allJobsByOrder.first = aJob then
			self.btnTBMoveUp.enabled := false;
			self.btnTBMoveDown.enabled := true;
		elseif aJob.myJobSheet.allJobsByOrder.last = aJob then
			self.btnTBMoveDown.enabled := false;
			self.btnTBMoveUp.enabled := true;
		else
			self.btnTBMoveDown.enabled := true;
			self.btnTBMoveUp.enabled := true;
		endif;
	endif;
	self.frmToolbar.positionToolbarControls();
end;</source>
        <Parameter name="aJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="updateTabCaptions" id="4e74ffd4-66b3-4b42-bab3-ddf307118f0c">
        <source>updateTabCaptions();
//----------------------------------------------------------------
//	Created:	13 September 2005	by Jason Chapman  (cnwjc2)
//
// 05 Nov 2012	PJS		PAR #30631
// 23/08/2016 cnwma1 TFS #2557:SPT - Missing Planned Location on Sequence Sheets- Issue not fixed from previous TFS
//----------------------------------------------------------------
vars
	vjs		: CM_VoyageJobSheet;
	vj		: CM_Job;
	sheet	: CMUI_Sheet;
	jobFin,
	jobPartFin,
	jobUnalloc	: Integer;
	sheetObj	 	: Object;
	workPointObject : CM_Object;
	jobsCount : Integer;
begin
	
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	//self.shtMain.caption := app.getErrorString(All_Jobs) &amp; " (" &amp; self.myCurrentVoyage.allVoyageJobs.size.String &amp; ")"; //30631 //23/08/2016 cnwma1 TFS# 2557
	
	foreach vj in self.myCurrentVoyage.allVoyageJobs do
		if not vj.isKindOf(CM_VoyageROROJob) then      //23/08/2016 cnwma1 TFS# 2557
			if vj.status = JOB_COMPLETE then
				jobFin := jobFin + 1;
			elseif vj.status = JOB_PART_COMPLETE then
				jobPartFin := jobPartFin + 1;
			elseif vj.myJobSheet = null then
				jobUnalloc := jobUnalloc + 1;
			endif;		
			jobsCount :=jobsCount +1;   //23/08/2016 cnwma1 TFS# 2557
		endif;
	endforeach;
	self.shtMain.caption := app.getErrorString(All_Jobs) &amp; " (" &amp; jobsCount.asStringJMT &amp; ")"; //30631  //23/08/2016 cnwma1 TFS# 2557
	
	self.shtCompleteJobs.caption := app.getErrorString1(Complete_Jobs,jobFin.String); // "Complete Jobs (" &amp; jobFin.String &amp; ")";
	self.shtPartComplete.caption := app.getErrorString1(Part_complete_jobs,jobPartFin.String);  //"Part Complete Jobs (" &amp; jobPartFin.String &amp; ")";
	
	if jobUnalloc = 0 then
		if self.fldMain.topSheet &lt;&gt; self.shtUnallocated then
			self.shtUnallocated.visible := false;
		endif;
	endif;
	self.shtUnallocated.caption := app.getErrorString1(Unallocated_Jobs_With_Total,jobUnalloc.String); //"Unallocated Jobs (" &amp; jobUnalloc.String &amp; ")";
		
	//epr par 34802 16/9/14 don't use crane instant id because cranes and workpoints could have the same instance id
	foreach sheetObj in self.allLoadedSheets do
		sheet:=sheetObj.CMUI_Sheet;
		workPointObject:=sheet.userObject.CM_Object;
		vjs:=self.myCurrentVoyage.allJobSheets[workPointObject.IF_VoyageWorkPoint.getID];
		sheet.caption := workPointObject.IF_VoyageWorkPoint.getID &amp; " - " &amp;  workPointObject.IF_VoyageWorkPoint.getDescription;
		if vjs &lt;&gt; null then
			sheet.caption := sheet.caption &amp; " (" &amp; vjs.allJobsByOrder.size.String &amp; ")";
		endif;
	endforeach;
		

end;</source>
    </JadeMethod>
    <JadeMethod name="useDeckingRules" id="a7c73e07-cfb1-42e9-a870-4db0f71c4faf">
        <source>useDeckingRules() : Boolean;
// --------------------------------------------------------------------------------
// Created:		15 November 2010 by cnwjo3
//
// Purpose:		If the terminal we are working in has an
//				RTG then return true.  At the moment
//				only Gdank uses these types of areas
//				par 26193
//
vars
	term : CM_Terminal;
	ta : CM_TerminalArea;
begin
	
	term := self.myTerminal;
	
	if term = null then
		return false;
	endif;
		
	// If we have straddles then do the 'old' way
	foreach ta in term.allTerminalAreas discreteLock do
		if ta.type = TA_TYPE_STRADDLE_STACK then
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="9851367c-c181-4e51-96b6-2c45d11ebad1">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//
// 05 Nov 2012	PJS 	Par #30631
//--------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	selectedIdx,
	theTopRow,
	idx,
	foreColour, 
	backColour 				: Integer;
	theVJob 				: CM_VoyageJob;
	theDataLine 			: String;
	theJobTITotals 			: CMIF_JobTITotals;
	theTable 				: CM_DataTable;
	selectedObj 			: Object;
	theVoyage 				: CM_Voyage;
	jobType					: Integer;
	addRemarks				: String;
	numJobs,
	theTotalRows 			: Integer;
	hideBoomHatch 			: Boolean;
	workPointInterface  	: IF_VoyageWorkPoint;
	prevRunningPlannedTotal : Integer;
	rptCol 					: Integer;
	prevRunningLiftsTotal 	: Integer;
	rltCol 					: Integer;
begin
	theTable := self.tblData;
	selectedIdx := theTable.row;	
	selectedObj := theTable.accessRow(theTable.row).itemObject;	
	theTotalRows:=self.getNumberOfTotalRows;
	hideBoomHatch :=self.btnHideHatchJobs.value;
	if _event = VoyageJob_Delete_Event  or not global.isValidObject(_obj) then // PAR 8229
		if self.myCurrentJob = _obj then
			self.myCurrentJob:=null;
		endif;
		self.updateJobRemove(_obj);
		return;
	elseif _event = EVENT_OOWCREATION_UPDATE then
		self.doOOWQuery(numJobs);
		self.timeLastOOWC := app.actualTimeServer(); // PAR 13077// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _event = JobSheet_Update_Event then
		if CM_Voyage.hasInstance(_obj) then
			theVoyage := _obj.CM_Voyage;
			if theVoyage &lt;&gt; self.myCurrentVoyage then
				return;
			endif;
		else
			return;
		endif;			
	elseif CM_VoyageJob.hasInstance(_obj) then // &lt;&lt;&lt;&lt; UPDATE AND CREATE
		// PAR 13077. When a job is created WLEs are created. If the job is a discharge it will have TIs, 
		//					so the TIs get set on the WLE and the WLEs source and target location strings 
		//					are set, when this happens a job update event is fired.
		// 					IF we have already had a OOWC note i.e. loads of jobs created in one go, the code also fires off a job update event.
		//					Because of the over head, we do not update the running totals during an update. This causes each discharge job's running total to go blank.
		//					So if we have had a OOWC note within the last 3 seconds ignore any update notes.
		if app.actualTimeServer() &lt; self.timeLastOOWC.addSeconds(3) then// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
			return;
		endif;

		theVJob := _obj.CM_VoyageJob;
		if theVJob.myVoyage &lt;&gt; self.myCurrentVoyage then
			return;
		endif;
		
		if theVJob.jobNum = "RORO" then // PAR 26907 782 RORO jobs do not have a jobsheet. The crane is a dummy to allow RTQing to RORO ramp. 791/792 will be different
			return;
		endif;
		
		//epr TFS 830 21/3/17 refactored into own method
		if not self.addCraneSheetForJobSheet(theVJob.myVoyageJobSheet) then
				//check for unallocated sheet
			self.shtUnallocated.visible := true;
		endif;
			
		jobType := self.getJobType();
		if theVJob.isHatchLidJob and hideBoomHatch then
			// Job is hatch lid job but we are hiding them
			self.updateJobRemove(theVJob);
			return;
		endif;

		// insert as per the job sheet, if we are only looking at a particular crane
		if theVJob.myJobSheet &lt;&gt; null then
			
			if jobType = self.JobType_UnallocatedSC then
				// Job is allocated to crane but viewing unallocated
				self.updateJobRemove(theVJob);
				return;
			elseif jobType = self.JobType_CraneSC then
				workPointInterface := self.filterWorkPoint;
				if workPointInterface &lt;&gt; null then
					//job is for different crane than that selected
					if theVJob.myVoyageJobSheet.getMyWorkPointObject.IF_VoyageWorkPoint &lt;&gt; workPointInterface then
						self.updateJobRemove(theVJob);
						return;
					endif;
				endif;
			endif;
			
		elseif jobType = self.JobType_CraneSC then
			// job not allocated to crane but a crane is selected
			self.updateJobRemove(theVJob);
			return;		
		endif;
		if jobType = self.JobType_CompleteSC then
		// job not complete but complete jobs are selected
			if theVJob.status &lt;&gt; JOB_COMPLETE then 
				self.updateJobRemove(theVJob);
				return;	
			endif;
		elseif jobType = self.JobType_PartCompleteSC then
		// job not part complete but complete jobs are selected
			if theVJob.status &lt;&gt; JOB_PART_COMPLETE then
				self.updateJobRemove(theVJob);
				return;	
			endif;
		endif;
		
		// find the job and update that line OR add onto the end of the list
		theTable.findObjectInRow(theVJob,theTopRow);
		if theTopRow &gt; 0 then
			//10 Sep 2014	NDL	Par 33719
			rptCol := theTable.getColumnByRowName(ETRow_TotalPlan);
			if rptCol &gt; 0 then
				prevRunningPlannedTotal := theTable.getCellText( theTopRow, rptCol ).Integer;
			endif;
			rltCol := theTable.getColumnByRowName(ETRow_TotalLifts);
			if rltCol &gt; 0 then
				prevRunningLiftsTotal := theTable.getCellText( theTopRow, rltCol ).Integer;
			endif;
			
			theTable.removeItem(theTopRow);
			//epr 6/7/07 par 14126
			if theTable.rows &gt;= theTopRow and JadeTableRow.hasInstance(theTable.accessRow(theTopRow).itemObject) then
				//remove remarks row
				theTable.removeItem(theTopRow);
			endif;
		endif;
		//epr par 18381 29/10/08
		theTopRow := self.myCurrentVoyage.getOOWJobIndex(jobType,hideBoomHatch, theVJob);
		if theTopRow &lt; 1 then
			theTopRow := theTable.rows - theTotalRows;
		else
			theTopRow := theTopRow + theTable.fixedRows;
		endif;
		
		if theTopRow &lt; theTable.fixedRows or theTopRow &gt; theTable.rows then 
			// probably a create for an unallocated job, so stick it on the bottom
			if theTable.rows = theTable.fixedRows then // no query yet
				theTopRow := theTable.fixedRows + 1;
			else
				theTopRow := theTable.rows - theTotalRows;
			endif;
		endif;
		if theTopRow &lt;= 0 then
			theTopRow := theTable.fixedRows + 1;
		endif;

		create theJobTITotals transient;
		theVJob.getJobTITotals(theJobTITotals);
		theDataLine := theJobTITotals.getAttributeStringForDefArray(theTable.allTblDataEntRows);
		
		theTable.addItemAt(theDataLine,theTopRow);
		theTable.accessRow(theTopRow).itemObject := theVJob;
		idx := theTopRow;
		
		//10 Sep 2014	NDL	Par 33719
		if rptCol &gt; 0 then
			theTable.setCellText( idx, rptCol, prevRunningPlannedTotal.String );
		endif;
		if rltCol &gt; 0 then
			theTable.setCellText( idx, rltCol, prevRunningLiftsTotal.String );
		endif;

		theVJob.getRowColour(foreColour, backColour);
		theTable.accessRow(idx).backColor := backColour;
		theTable.accessRow(idx).foreColor := foreColour;
		if theTable.accessRow(idx).backColor = Red then
			theTable.accessRow(idx).fontBold := true;
		else
			theTable.accessRow(idx).fontBold := false;				
		endif;

		//remarks?
		addRemarks := theVJob.getAdditionalRemarks;
		if self.btnRemarks.value and addRemarks &lt;&gt; null then
			theTable.addItemAt(Tab &amp; app.getErrorString(INV_Remarks) &amp; "  " &amp; Tab &amp; Tab &amp; addRemarks, idx+1);
			theTable.accessRow(idx+1).itemObject := theTable.accessRow(idx);
			theTable.accessCell(idx+1, 2).foreColor := Red;
			theTable.accessedCell.mergeCells := Table.MergeCells_Merge;
			theTable.accessCell(idx+1, 4).mergeCells := Table.MergeCells_Merge;
		endif;
	else
		inheritMethod(_event, _noteobj,_obj);
	endif;

	if (not theTable.selectObject(selectedObj, false)) then
		theTable.selectRow(selectedIdx, false);
	endif;

	self.doTblDataRowColChange(theTable);
	
epilog
	delete theJobTITotals;
	self.updateTabCaptions();
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="a8473771-ac2f-462a-9127-3ca809e4a77d">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	event : Integer;

begin

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	self.userNotificationUpdate(event, theObject.CM_Object, userInfo.CM_Object);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
