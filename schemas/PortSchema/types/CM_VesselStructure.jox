    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="f2c7e010-ccf5-420e-8429-3ba660f75bb4">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input): Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin

	if _property = CM_VesselStructure::myVessel then
		return CM_Vessel::code;
	endif;
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="ad078f24-b04b-4821-bcf4-a11bf6d1957a">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	if _property = CM_VesselStructure::allTanks then
		return ExportAsParent;
	elseif _property = CM_VesselStructure::allSections then
		return ExportAsParent;
	elseif _property = CM_ROROVesselStructure::myVessel then
		return ExportAsChild;
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextSectionCode" id="5d30184f-166e-4ed6-880e-a3d1a7dfe3c8">
        <source>getNextSectionCode() : String;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	idx : Integer;
begin
	idx := self.allSections.size;
	
	idx := idx + 1;
	
	return idx.padLeadingWith("0",2);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSectionByPosition" id="8450ee3b-914b-42e5-a8ce-2c899b8cfa24">
        <source>getSectionByPosition(_pos : Decimal; _variance : Decimal) : CM_VesselSection;
/*
Purpose:			
Date		Who		Reason
28 April 2011	cnwab1	Initial creation
*/

vars
	tmpSect : CM_VesselSection;
	pos : Decimal[12,2];
begin
	pos := _pos - _variance;
	
	tmpSect := self.allSectionsByPosition.getAtKeyGeq(pos);
	
	if tmpSect &lt;&gt; null then
		if tmpSect.position &lt;= (_pos + _variance) then
			return tmpSect;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_pos" type="Decimal"/>
        <Parameter name="_variance" type="Decimal"/>
        <ReturnType type="CM_VesselSection"/>
    </JadeMethod>
