<Class name="CM_InvoiceAPIConsumerWSAgent" id="97db6432-224f-4c70-8ede-5df64da0f2a8">
    <superclass name="CM_APIConsumerAgent"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <Constant name="INV_API_PART_STAT_ERROR" id="153bad84-a26e-4e7e-baae-91ed3544a1a6">
        <source>"Message processed error"</source>
        <type name="String"/>
    </Constant>
    <Constant name="INV_API_PART_STAT_SENT" id="f87f1c94-069d-4459-a2d4-0630072c9021">
        <source>"Message sent, waiting for response"</source>
        <type name="String"/>
    </Constant>
    <Constant name="INV_API_PART_STAT_SUCCESS" id="6fe6d444-baf5-4d23-8ae2-31d9bbebc746">
        <source>"Message processed successful"</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="myEWSActivity" id="8925fe1e-28d6-4ea3-94d3-b923d0e347ab">
        <embedded/>
        <type name="CM_EWSActivityInvoiceAPI"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myInvoice" id="aa216e59-98c9-4e71-bfbd-49c9205ce848">
