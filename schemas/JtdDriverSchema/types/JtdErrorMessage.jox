    <DbClassMap file="Jtd"/>
    <PrimAttribute name="jtdNumber" id="31f89125-c034-4b43-9ed0-a41d3e5e2f07">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="jtdText" id="6893ccbb-37f0-4f79-8381-f4f90b434da9">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="jtdInitializeFromGlbConstant" id="167507e4-87c0-4d3c-8d55-452347caf056">
        <updating/>
        <source>jtdInitializeFromGlbConstant(glbConst : GlobalConstant; baseNum : Integer) updating;

// Assumes that the supplied global constant is of type Integer

begin
	self.jtdNumber := glbConst.valueAsInteger + baseNum;
	self.jtdText := glbConst.text.trimBlanks;
end;</source>
        <Parameter name="glbConst" type="GlobalConstant"/>
        <Parameter name="baseNum" type="Integer"/>
    </JadeMethod>
</Class>
