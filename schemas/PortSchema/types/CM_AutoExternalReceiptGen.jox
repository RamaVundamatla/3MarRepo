    </CompAttribute>
    <JadeMethod name="create" id="b75d1b6a-5e73-4abc-bfb8-3badb4c1181d">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
