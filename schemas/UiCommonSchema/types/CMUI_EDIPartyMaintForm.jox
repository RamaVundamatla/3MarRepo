    <JadeMethod name="hasChangedCoparnRules" id="e4f8f6f0-5eb7-4f62-b264-2b5cb02c14dc">
        <source>hasChangedCoparnRules():Boolean protected;
/*
Date		Who		Reason
22 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
04/07/2013	cnwcs5	par 31942
*/
vars
	
begin
	// has anything been entered on the coparn sheet
	return self.chkDelActioned.value or
			self.chkDelArchived.value or 
			self.chkDelComplete.value or
			self.chkEmailDelErr.value or
			self.chkEmailUpdErr.value or
			self.chkResetComplete.value or
			self.chkUpdActioned.value or
			self.chkUpdArchived.value or
			self.chkUpdCompleted.value or
			self.chkEmailUpdate.value or 
			self.chkEmailDelete.value or
			self.chkUseISOGrpRR.value or
			self.chkCreateGenRR.value or
			self.cmbSubTerminal.listIndex &gt; 0 or
			self.cmbCarrier.listIndex &gt; 0 or
		//	self.cmbReleaseStatus.listIndex &gt; 0 or	//29 Jun 2015	NDL	Par 36543
			self.cmbReleaseType.listIndex &gt; 0 or
			self.cmbVoyage.listIndex &gt; 0 or
			self.cmbDeliveryReaso.listIndex &gt; 0 or
			self.cmbGradeDry.listIndex &gt; 0 or
			self.cmbGradeReefer.listIndex &gt; 0 or 
			self.cmbGenType.listIndex &gt; 0 or
			self.tblActionsCoparn.rows &gt; self.tblActionsCoparn.fixedRows;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
