<Class name="CM_YATypeSubTermRecDateRange" id="be992379-110a-4ee5-a074-8dfb71581790">
    <superclass name="CM_YATypeDateRange"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getTypeName" id="e1ad8c79-0aad-43e5-8ff7-318a819488d4">
        <source>getTypeName(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
