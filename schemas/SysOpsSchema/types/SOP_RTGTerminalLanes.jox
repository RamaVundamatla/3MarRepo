    <JadeMethod name="setupScrollableMain" id="efeff347-53a5-47df-9dc5-97467e5dec63">
        <source>setupScrollableMain();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars

begin
	self.frmScrollablMain.top:=0;
	self.frmScrollablMain.left:=0;
	self.frmScrollingMain.top:=0;
	self.frmScrollingMain.left:=0;
	//self.frmScrollablMain.height:=self.dkcGridArea.height-10;
	//self.frmScrollablMain.width:=self.dkcGridArea.width;
	self.frmScrollablMain.setScrollingFrame(self.frmScrollingMain);
	self.frmScrollablMain.myVLabels.visible:=false;
	self.frmScrollablMain.myHLabels.visible:=false;
	self.frmScrollablMain.labels	:=	CM_BaseForm.ScrollBars_Both;
	self.frmScrollablMain.parentAspect:=Control.ParentAspect_StretchBoth;
	self.frmScrollablMain.setHLabelDetails(5, false);
	self.frmScrollablMain.setVLabelDetails(5, false);
	self.frmScrollablMain.resizeScrollingFrame(2000,2000);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="snapToGrid" id="cfaca648-32a5-4efe-ba3c-c321a75aaca9">
        <source>snapToGrid( _value : Real io) ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars

	totalGridSize : Integer;
	rem, diff : Real;
begin
	totalGridSize:=getTotalGridSize;
	rem:= _value mod totalGridSize;
	if rem &lt;&gt; 0 then
		diff:=totalGridSize - rem;
		if rem &gt; 4 then
			_value:=_value + diff;
		else
			_value:=_value - rem;
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="35b46335-3b26-4480-a702-95c75abcafcb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009711, locale);
	btnCloneRTG.translateCaption(Xlat_0009712, locale);
	btnCloseTestFrm.translateCaption(Xlat_0009713, locale);
	btnZoom.translateCaption(Xlat_0009714, locale);
	frame3.translateCaption(Xlat_0009715, locale);
	lblZoom.translateCaption(Xlat_0009716, locale);
end;</source>
    </JadeMethod>
</GUIClass>
