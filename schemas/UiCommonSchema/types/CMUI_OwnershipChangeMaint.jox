/*
Purpose:			

Date		Who		Reason
24 July 2023	navab1	  CR 58246 TASK 58249 
*/

vars

begin
	if self.myOwnershipChange = null then
		return;
	endif;
	
	app.viewAuditFormModal(self.myOwnershipChange, self.myAssistant.class, self.myTerminal);

epilog

end;</source>
