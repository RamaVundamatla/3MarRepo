<Class name="CMQF_DailyMovements" id="ac66ab86-f9c1-49d7-8c7e-98216bf3b0d7">
    <superclass name="CMQF_FilterReports"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="endDateTime" id="d77afbe8-9944-4740-bdcb-62a6fb434fc2">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="startDateTime" id="1b8eef8d-4a91-4568-a51b-84ba409098ac">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <JadeMethod name="filterForBookingRefs" id="f8c174c9-1783-4e4b-b0f4-3994b477963d">
        <updating/>
        <source>filterForBookingRefs(_allBookingRefs: CM_BookingRefsByRefDups input; _passport: CM_Passport) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
----------   ----------  --------------------------------------------------
*/
vars
	terminal			: CM_Terminal;
	dict				: CM_BookingRefsByOperatorRefVoy;
	iter				: Iterator;
	booking				: CM_BookingRef;
	opCode,
	operatorCodeKey,
	bookingRefKey		: String;
	voyageKey			: CM_Voyage;			
begin
	_allBookingRefs.clear();
	
	if self.myOperator = null then
		return;
	endif;
	opCode := self.myOperator.code;
	
	foreach terminal in self.allTerminals do : terminalLoop
		dict := terminal.allBookingRefsByOperatorRef;
		delete iter;
		iter := dict.createIterator();
		dict.startKeyGeq(opCode, null, null, iter);
		
		while iter.next(booking) do : bookingLoop
			iter.getCurrentKeys(operatorCodeKey, bookingRefKey, voyageKey); // adm 150908 Par 17936 //MTN-35226
			if operatorCodeKey &lt;&gt; opCode  then
				continue terminalLoop;
			endif;
			
			if booking.isComplete then
				continue bookingLoop;
			endif;
			
			_allBookingRefs.add(booking);
		endwhile;	
	endforeach;

epilog
	delete iter;
end;


</source>
        <Parameter name="_allBookingRefs" type="CM_BookingRefsByRefDups" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForReceivals" id="caa448ea-40c3-4073-8045-b73fc38febe4">
        <updating/>
        <source>filterForReceivals(_type : Integer; _allRecievalTrans : CM_TITransactionByDateDict input; _passport: CM_Passport) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	terminal			: CM_Terminal;
	dict				: CM_TITransactionByTypeDateDict;
	iter				: Iterator;
	tiTrans				: CM_TITransaction;
	ti					: CM_TrackedItem;
	typeKey				: Integer;
	dtKey				: TimeStamp;
	
begin
	//_allRecievalTrans.clear();	// 19/05/2008 cnwar2 #16603
	if self.myOperator = null then
		return;
	endif;
	
	foreach terminal in self.allTerminals do : terminalLoop
		
		dict := terminal.allTITransactionsByTypeDate;
		delete iter;
		iter := dict.createIterator();
		// Par 15343
		//dict.startKeyGeq(TRANS_TYPE_REC_ROAD, startDateTime, iter);
		dict.startKeyGeq(_type, startDateTime, iter);
		
		while iter.next(tiTrans) do : transLoop
			iter.getCurrentKeys(typeKey, dtKey); //MTN-35226
			if typeKey &lt;&gt; _type or 
			   dtKey &gt; endDateTime then
				continue terminalLoop;
			endif;
			
			ti := tiTrans.myTrackedItem;
			if ti = null or 
			   ti.myOperator &lt;&gt; self.myOperator then
				continue transLoop;
			endif;
			
			if ti.isKindOf(CM_Container) and		// 01/05/2008 cnwar2 #16603
			   not ti.CM_Container.isEmpty then
				continue transLoop;
			endif;
			
			_allRecievalTrans.add(tiTrans);
		endwhile;
		
	endforeach;

epilog
	delete iter;
end;


</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_allRecievalTrans" type="CM_TITransactionByDateDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForReleaseRequests" id="9531b6b8-6917-47c8-9d68-6a993b5f44fd">
        <updating/>
        <source>filterForReleaseRequests(_allReleaseRequests : CM_BulkReleaseByCodeDict input; _passport: CM_Passport) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
29/11/2011	cnwcs5		CCMS POL 2122 / par 28696
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/
vars
	terminal			: CM_Terminal;
	dict				: CM_BulkReleaseByTypeStCodeDict;
	iter				: Iterator;
	release				: CM_BulkRelease;
	releaseType			: Integer;
	releaseTypes		: IntegerArray;
	typeKey,
	statusKey			: Integer;
	codeKey				: String;
	dtKey				: TimeStamp;
begin 
	_allReleaseRequests.clear();
	
	if self.myOperator = null then
		return;
	endif;
	
	create releaseTypes transient;
	releaseTypes.add(BR_TYPE_ROAD);
	releaseTypes.add(BR_TYPE_RAIL);
	releaseTypes.add(BR_TYPE_PACKING);
	releaseTypes.add(BR_TYPE_SHIP);
	releaseTypes.add(BR_TYPE_UNKNOWN);	// par 28696

	
	foreach terminal in self.allTerminals do : terminalLoop
		dict := terminal.allBulkReleaseByTypeByStByCd;
		delete iter;
		iter := dict.createIterator();
		foreach releaseType in releaseTypes do :releaseTypeLoop
			iter.reset();
			//N.B pending = 0 and active =1. We're going to break out if LARGER than active
			//so as to traverse both status we're interested in
			dict.startKeyGeq(releaseType, BR_PENDING, null, null, iter);
			
			while iter.next(release) do : releaseLoop 
				iter.getCurrentKeys(typeKey, statusKey, codeKey, dtKey); //MTN-35226
				if typeKey &lt;&gt; releaseType or statusKey &gt; BR_ACTIVE then
					continue releaseTypeLoop;
				endif;
				
				if release.myOperator &lt;&gt; self.myOperator then
					continue releaseLoop;
				endif;
				
				_allReleaseRequests.add(release);
			endwhile;	
		endforeach;
	endforeach;

epilog
	delete iter;
end;





</source>
        <Parameter name="_allReleaseRequests" type="CM_BulkReleaseByCodeDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForReleases" id="56041658-a248-4c13-a22a-006b54657d8c">
        <updating/>
        <source>filterForReleases(_type : Integer; _allReleaseTrans : CM_TITransactionByDateDict input; _passport: CM_Passport) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	terminal			: CM_Terminal;
	dict				: CM_TITransactionByTypeDateDict;
	iter				: Iterator;
	tiTrans				: CM_TITransaction;
	ti					: CM_TrackedItem;
	typeKey				: Integer;
	dtKey				: TimeStamp;
	
begin
	//_allReleaseTrans.clear();		// 19/05/2008 cnwar2 #16603
	if self.myOperator = null then
		return;
	endif;
	
	foreach terminal in self.allTerminals do : terminalLoop
		dict := terminal.allTITransactionsByTypeDate;
		delete iter;
		iter := dict.createIterator();
		// Par 15343
		//dict.startKeyGeq(TRANS_TYPE_REL_ROAD, startDateTime, iter);
		dict.startKeyGeq(_type, startDateTime, iter);
		
		while iter.next(tiTrans) do : transLoop
			iter.getCurrentKeys(typeKey, dtKey); //MTN-35226
			//if typeKey &lt;&gt; TRANS_TYPE_REL_ROAD or 
			if typeKey &lt;&gt; _type or 
			   dtKey &gt; endDateTime then
				continue terminalLoop;
			endif;
			
			ti := tiTrans.myTrackedItem;
			if ti = null or 
			   ti.myOperator &lt;&gt; self.myOperator then
			  	continue transLoop;
			endif;
			
			if ti.isKindOf(CM_Container) and		// 01/05/2008 cnwar2 #16603
			   not ti.CM_Container.isEmpty then
				continue transLoop;
			endif;
			
			_allReleaseTrans.add(tiTrans);
		endwhile;
	endforeach;
	
epilog
	delete iter;
end;





</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_allReleaseTrans" type="CM_TITransactionByDateDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForStockLevels" id="18415c6a-0c8c-4e1e-843e-f15587485f04">
        <updating/>
        <source>filterForStockLevels(_allSummaryObjs: CMIF_StockLevelByISOAvailGrade input; _passport: CM_Passport) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	
	terminal			: CM_Terminal;
	opTerm				: CM_OperatorTerminal;
	iter				: Iterator;
	dict				: CM_TIByCargoTypeIdDict;	
	ti					: CM_TrackedItem;
	container			: CM_Container;
	cargoTypeKey		: Integer;
	idKey				: String;
	summaryObj			: CMIF_StockLevelSummary;
begin
	_allSummaryObjs.purge();
	if self.myOperator = null then
		return;
	endif;
	
	foreach terminal in self.allTerminals do : terminalLoop
		opTerm := self.myOperator.allOperatorTerminals[terminal];
		if opTerm = null then
			continue;
		endif;
		dict := opTerm.allOnsiteTIsByCargoTypeId;
		delete iter;
		iter := dict.createIterator();
		dict.startKeyGeq(TI_CargoType_Container, null, iter);
		
		while iter.next(ti) do : tiLoop
			iter.getCurrentKeys(cargoTypeKey, idKey); //MTN-35226
			if cargoTypeKey &lt;&gt; TI_CargoType_Container then
				continue terminalLoop;
			endif;
			
			container := ti.CM_Container;
			
			if not container.isEmpty then
				continue;
			endif;
			//N.B filtering of containers has already been done - we want a summary of the
			//onsite containers for the selected operator
			summaryObj := _allSummaryObjs[container.isoType, container.availabilityGrade];
			if summaryObj = null then
				create summaryObj transient;
				summaryObj.isoType := container.isoType;
				summaryObj.isoTypeDescription := container.isoTypeDesc;
				summaryObj.availabilityGrade := container.availabilityGrade;
				summaryObj.availabilityGradeDescr := container.availabilityGradeDescription;
				_allSummaryObjs.add(summaryObj);
				self.numSearched := self.numSearched + 1;
			endif;
			
			summaryObj.totalSelf(container);
		endwhile;
	endforeach;
	
	
epilog
	delete iter;
end;


</source>
        <Parameter name="_allSummaryObjs" type="CMIF_StockLevelByISOAvailGrade" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
