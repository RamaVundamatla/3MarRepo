    <JadeMethod name="showDetail" id="58944add-5419-4627-b2c5-dccff578115b">
        <source>showDetail(_bgpRequest : BGP_Request input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024

*/
vars
	lDetails	: CMUI_SystemAlertsDetails;	
begin
	
	create lDetails;
	lDetails.centreWindow;	
