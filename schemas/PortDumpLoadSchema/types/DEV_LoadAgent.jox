    <JadeMethod name="loadHarbour" id="cc005707-e2e1-4b8d-b9b6-202da8f08009">
        <source>loadHarbour(_harbourProxy : HMS_Harbour io) :Boolean protected;

vars
	realObject, proxyObject : HMS_Harbour;
	error : CM_Error;
	countError,countOK : Integer;
begin
	if app.myRoot.allHarbours.size &gt; 0 then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_harbourProxy.code&amp;" ERROR: "&amp;"A Harbour already exists.",0);
		return false;
	endif;
	app.isConverting := true;
	realObject := app.myRoot.allHarbours[_harbourProxy.code];
	if realObject = null then
		app.myTrxCA.trxCreateHarbour(_harbourProxy, realObject, app.myPassport);
		beginTransaction;
		realObject.allTerminalsByCode.add(app.getMyTerminalDO_NOT_USE());
		commitTransaction;
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_harbourProxy.code&amp;" ERROR: "&amp;"Harbour already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_harbourProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_harbourProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog
	app.isConverting := false;
end;</source>
        <access>protected</access>
        <Parameter name="_harbourProxy" type="HMS_Harbour" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
