    <JadeMethod name="utlDeleteCodeGroupLogSpecsTree" id="84b51876-3be6-4c41-b6db-c10b39ce39e7">
        <source>utlDeleteCodeGroupLogSpecsTree(_codeGroup : CM_CodeGroup io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2014	cnwmc5	Initial creation

*/

vars
	codeGroup	: CM_CodeGroupLogSpecs;
	
	grade				: CM_LogGrade;
	length				: CM_LogLength;
	species				: CM_LogSpecies;
	treatment			: CM_LogTreatment;
	type				: CM_LogType;
	code,
	codeGrade			: CM_Code;
begin
	self.initialiseActivity();
	
	if not _codeGroup.isKindOf(CM_CodeGroupLogSpecs) then
		app.raiseCMException1(Err_InvalidClass, _codeGroup.class.String, null, null);
		return;
	endif;
	
	codeGroup := _codeGroup.CM_CodeGroupLogSpecs;
	
	foreach code in codeGroup.allCodes do
		if not code.isKindOf(CM_LogSpecies) then
			continue;
		endif;
		
		species := code.CM_LogSpecies;
		
		foreach codeGrade in species.allLogGrades do
			if not codeGrade.isKindOf(CM_LogGrade) then
				continue;
			endif;
			
			grade := codeGrade.CM_LogGrade;
			
			app.myUtilityDA.utlDeleteLogGrade(grade, _passport);
		endforeach;
		
		app.myUtilityDA.utlDeleteLogSpecies(species, _passport);
	endforeach;
	
	foreach length in codeGroup.allLogLengths do
		app.myUtilityDA.utlDeleteLogLength(length, _passport);
	endforeach;
	
	foreach treatment in codeGroup.allLogTreatments do
		app.myUtilityDA.utlDeleteLogTreatment(treatment, _passport);
	endforeach;
	
	foreach type in codeGroup.allLogTypes do
		app.myUtilityDA.utlDeleteLogType(type, _passport);
	endforeach;
	
	app.myUtilityDA.utlDeleteCodeGroup(_codeGroup, _passport);
epilog

end;</source>
        <Parameter name="_codeGroup" type="CM_CodeGroup" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteCodeGroupSrcLocTree" id="861651b6-f0b2-4d2b-91e5-6b3748467209">
        <source>utlDeleteCodeGroupSrcLocTree(_codeGroup : CM_CodeGroup io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2014	cnwmc5	Initial creation

*/

vars
	srcLocCode,
	srcSubLocCode,
	srcSubSubLocCode	: CM_Code;
	
	srcLoc				: CM_SourceLocation;
	srcSubLoc			: CM_SourceSubLocation;
	srcSubSubLoc		: CM_SourceSubSubLocation;
	
begin
	self.initialiseActivity();
	
	foreach srcLocCode in _codeGroup.allCodes do
		if not srcLocCode.isKindOf(CM_SourceLocation) then
			continue;
		endif;
		
		srcLoc := srcLocCode.CM_SourceLocation;
		
		foreach srcSubLocCode in srcLoc.allSubLocations do
			if not srcSubLocCode.isKindOf(CM_SourceSubLocation) then
				continue;
			endif;
			
			srcSubLoc := srcSubLocCode.CM_SourceSubLocation;
			
			foreach srcSubSubLocCode in srcSubLoc.allSubSubLocations do
				if not srcSubSubLocCode.isKindOf(CM_SourceSubSubLocation) then
					continue;
				endif;
				
				srcSubSubLoc := srcSubSubLocCode.CM_SourceSubSubLocation;
				
				app.myUtilityDA.utlDeleteSourceSubSubLocation(srcSubSubLoc, _passport);
			endforeach;
			
			app.myUtilityDA.utlDeleteSourceSubLocation(srcSubLoc, _passport);
		endforeach;
		
		app.myUtilityDA.utlDeleteSourceLocation(srcLoc, _passport);
	endforeach;
	
	app.myUtilityDA.utlDeleteCodeGroup(_codeGroup, _passport);
epilog

end;</source>
        <Parameter name="_codeGroup" type="CM_CodeGroup" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteCommodity" id="a956d52c-70f9-4ecd-9654-53e6caaf4799">
