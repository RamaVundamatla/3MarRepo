    <JadeMethod name="tblAttachments_dragDrop" id="098d1f0f-121d-47ce-8a68-20e889812e06">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAttachments_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti			: CM_TrackedItem;
begin
	ti := app.myDraggedTrackedItem;
	if ti = null then
		return;
	endif;
	
	self.attachmentAdd(ti, false);
end;


</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
