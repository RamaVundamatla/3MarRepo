    <JadeMethod name="doSave" id="dd02639b-4120-4a7c-801b-d77112fda059">
        <updating/>
        <source>doSave() updating ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars
	result : Integer;
	woActionIF : CMIF_WorkOrderAction;
begin


	create woActionIF transient;
	
	self.populateIFObject( woActionIF );

	while true do
		
		app.myTrxCA.trxCreateWorkOrderAction(woActionIF, app.myPassport); 

		if app.myPassport.trxCompletedOK then

			return ;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;


epilog
	delete woActionIF;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowSchedule" id="a9180256-5f98-4585-91d4-476edc3094d5">
        <source>doShowSchedule();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/



vars
	scheduleForm 		: YRD_WorkOrderScheduleForm;
	workOrder,
	realWorkOrder 	: CM_WorkOrder;
	task 			: CM_WorkOrderDtl;
	selObj 			: Object;
begin

	if self.myWorkOrderDtl = null then
		return;
	endif;	
	
	task := self.myWorkOrderDtl;

	realWorkOrder := task.myParent;

	app.mousePointer := MousePointer_HourGlass;
	
	scheduleForm := app.getForm(YRD_WorkOrderScheduleForm.name).YRD_WorkOrderScheduleForm;
	if scheduleForm = null then
		scheduleForm := app.loadForm(YRD_WorkOrderScheduleForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderScheduleForm;
	endif;
	
	if scheduleForm = null then
		return;
	endif;
	
	scheduleForm.centreWindow;
	scheduleForm.setMyTerminal(self.myTerminal);
	//taskForm.initialise(workOrder, YRD_TaskJobSourceForm.Mode_Update, workOrder.getProxyTask(task));
	scheduleForm.set( realWorkOrder );
	scheduleForm.show();
	
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateIFObject" id="e1193937-9f24-4dc6-a43f-3921412bb74c">
        <source>populateIFObject( _woActionIF : CMIF_WorkOrderAction io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwrd1	Initial creation

*/


vars
	result : Boolean;
	numRows,
	idx		: Integer;
	noToAction,
	noAvailable : Integer;
	requestDesc : String;
	woRBT : CM_WorkOrderRequestByType;
begin

	_woActionIF.myWorkOrderDtl := self.myWorkOrderDtl;
	_woActionIF.myWorkOrderSchedule  := self.myWorkOrderSchedule ;
	

	if self.hasRBT then
	// add rbt values
	
	numRows := self.tbRequests.rows - self.tbRequests.fixedRows ;
	foreach idx in 1 to numRows+1 do
		noToAction := self.tbRequests.getCellValueByName( ETRow_RbtToAction,  idx ).Integer;
		woRBT := self.tbRequests.accessRow(idx).JadeTableRow.itemObject.CM_WorkOrderRequestByType;
		noAvailable := self.tbRequests.getCellValueByName( ETRow_RbtLeft,  idx ).Integer;
	
		if woRBT = null then
			//error no object!
			continue;
		endif;
		
		if noToAction &gt; noAvailable then
			// issue too many!		 
			//error
			continue;
		elseif noToAction &gt; 0 then
		//add to IF obj
			_woActionIF.allRBTActionValues.add(noToAction);
			_woActionIF.allRBTObjects.add(woRBT);
		endif;	
	endforeach;
	endif;

	//now add standard data
	
	_woActionIF.numberFromKnownCargo := self.txtAction.text.asIntegerJMT();
	_woActionIF.populateFromAvailable := self.chkAutoPrefill.value;
	

epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForRBTTask" id="c7110747-2d9b-4a40-9c2f-0347ef6a5178">
        <updating/>
        <source>setForRBTTask() updating;

/*

Purpose: setup form for a 1st move with request by type on source

Parameters:			

Return Value:		


Date		Who		Reason
11 Nov 2009	cnwrd1	Initial creation
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	wod : CM_WorkOrderTIDtl;
begin
	wod               :=  self.myWorkOrderDtl;
	self.hasRBT 	  := true;
	self.width 		  := 776;
	self.height		  := 351;
	self.minimumWidth := 776;
	self.borderStyle  := 2;

	// check if we have any to action from standard
 	if(wod.totalUnactioned - wod.getTotalActionedFromRBT() ) = 0 then
		
		self.txtAction.text         := '0';
		self.txtAction.enabled      := false;
		self.chkAutoPrefill.value   := false;
		self.chkAutoPrefill.enabled := false;	
	endif;
 
	self.lUnactioned.caption := wod.getTotalUnactionedFromKnown.asStringJMT;
	// populate RBT groupbox.
	self.lTotalRBT.caption	      := wod.myParent.getTotalRequestedFromRBT().asStringJMT();
	self.lActionedRBT.caption     := wod.getTotalActionedFromRBT().asStringJMT;
	self.lCompleteRBT.caption     := ''; // ?? can i fidn this value?
	self.lTotUnactionedRB.caption := wod.getTotalUnactionedFromRBT().asStringJMT();
	
	self.lTotalActioned.caption   := wod.getTotalActioned().asStringJMT();
	self.lTotalActioned.visible   := true;
	self.lblTotalActioned.visible := true;
	
	// fill table
	self.setRBTTable();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForStandardTask" id="8dd977b2-5771-4d83-b47f-e1c54c60f6f4">
        <updating/>
        <source>setForStandardTask() updating;

/*

Purpose: action work for any standard task (ie. not a 1st task which is a move and has unfullfiled RBT)

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwrd1	Initial creation

*/

vars

begin

// hide the grpActionFromRBT groupbox and shrink the form.

	self.hasRBT := false;

	self.width := 305;
	self.height := 351;
	self.borderStyle := 1;
 
 //self.tbRequests.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromTask" id="715e522c-de8e-4894-a46f-ebfee74d4d2a">
        <updating/>
        <source>setFromTask() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11/11/2009	cnwrd1	Initial creation
16/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
29/09/2021	navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	wod 		: CM_WorkOrderTIDtl;
	workOrder	: CM_WorkOrder;
begin

	if self.myWorkOrderDtl = null then
		return;
	endif;
	
	if not self.myTerminal.isUseYardJobsForCargoWo() then	//29.09.2021 navma1 #51925
		return;
	endif;
	
	wod 		:= self.myWorkOrderDtl;		//29.09.2021 navma1 #51925
	workOrder	:= wod.myParent;			//29.09.2021 navma1 #51925
	
	self.setCaption( app.getErrorString2 (Actionwork_order_task, workOrder.id, wod.getDisplayString(true))); 
	
	
	// set the standard fields/dates
	self.lStartbyDt.caption 	:= wod.startByDT.asStringJMT();
	self.lRequiredByDt.caption  := wod.requiredByDT.asStringJMT();
	self.lTotalReq.caption 		:= workOrder.CM_WorkOrderTI.totalRequired.asStringJMT();
	self.lUnactioned.caption 	:= wod.getTotalUnactionedFromKnown().asStringJMT;
	
	self.lActioned.caption 	:= wod.totalActioned.asStringJMT();
	self.lComplete.caption  := wod.totalComplete.asStringJMT();
	self.lAvailable.caption := wod.allAvailableTIs.size.asStringJMT();
	
	if wod.hasRBTToAction() then //we show the full RBT form
		self.setForRBTTask();
	else
		self.setForStandardTask();
	endif;
	
	if wod.isWorkOrderForNullVoyage 							// TFS 38501
	or wod.isWorkOrderForExportReturn then						// TFS 38501
		self.txtAction.text := wod.allAvailableTIs.size.String;	// TFS 38501
		self.txtAction.readOnly := true;						// TFS 38501
	endif;														// TFS 38501
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setRBTTable" id="4ef290a5-0363-4620-aa1d-f19dd2b7458b">
        <source>setRBTTable();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars
	rbtSet	: CM_WorkOrderRequestByTypeSet;
	rbt 	: CM_WorkOrderRequestByType;
	entDef	: EntTableDef;
	index	: Integer;
	theDataLine : String;
	
	numCols,
	idx		: Integer;
//	tblTI : CM_DataTable;
begin

	entDef	:= app.myController.getEntTableDef(ETDef_RbtAction);
	self.tbRequests.setTblDataEntRowsFromDef(entDef);

	
	//self.tblData.userInputEnabled := false;
	//self.tblData.selectMode := Table.SelectMode_CurrentRow;
	//self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tbRequests.multiSelect := self.tbRequests.MultiSelect_None;
	//self.tblData.stretchWidth := true;
	//self.tblData.stretchHeight := false;
	
	create rbtSet transient;

	self.myWorkOrderDtl.getAllRBTWithUnactioned( rbtSet ) ;
	
	if rbtSet.isEmpty then
		//ooops should have some here...
		return;
	endif;
	
	
	foreach rbt in rbtSet do
		theDataLine := rbt.getAttributeStringForDefArray(tbRequests.allTblDataEntRows);
		self.tbRequests.accessRow(tbRequests.addItem(theDataLine)).itemObject := rbt;
	endforeach;
	 
	// enable and set the to action column
	self.tbRequests.accessColumn( self.tbRequests.getColumnByRowName( ETRow_RbtToAction) ).JadeTableColumn.inputType := Table.InputType_TextNumeric;
	self.tbRequests.accessColumn( self.tbRequests.getColumnByRowName( ETRow_RbtToAction) ).JadeTableColumn.maxLength := 4;

	self.tbRequests.userInputEnabled := true;
	
epilog

	delete rbtSet;
end;</source>
    </JadeMethod>
