    <JadeMethod name="userNotificationAreaUpdate" id="b96c357f-2257-4c36-80b0-85765c605036">
        <updating/>
        <source>userNotificationAreaUpdate(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// PAR 17067 added this sub class method
vars
	anLC : CM_LocationsController;
	nextGC : CM_GridController;
	event,idx		: Integer;
	breakOut, gotException : Boolean;
	aTI : CM_TrackedItem;
	aMove : CM_Move;
	src : String;

begin
	on Exception do app.handleDeletedObject(exception, anLC, gotException);	


	if userInfo.isKindOf(CM_LocationsController) then
		anLC := userInfo.CM_LocationsController;
	endif;
	
	if anLC = null then
		return;
	endif;
	
	if eventType = self.noteTAMove 
	or eventType = self.noteTIUpdate  
	or eventType =  self.myTerminal.getTerminalEvent(EVENT_TI_MOVE_BACKEND) then
		// ###########################
		// Check to see if this location controller is on our form
		self.drawFromNote := true;
		if self.useSelectorObjects then
			foreach aTI in anLC.allTrackedItems do
				self.userNotificationHandleSelector(aTI,breakOut);
			endforeach;
		endif;
		self.drawObject(self.myDrawingFrame, anLC);
		if gotException then
			// Exception handler resumes here if anLC was invalid.
			return;
		endif;
		if anLC.isOKForOverSizedCargo() then
			nextGC := anLC.getNextControllerOfType(CM_GridController).CM_GridController;
			if nextGC &lt;&gt; null then
				self.drawObject(self.myDrawingFrame, nextGC);
				//PAR 18336. Moved this inside the IF 
				if nextGC.is53ft  then
					nextGC := nextGC.getNextControllerOfType(CM_GridController).CM_GridController;
					if nextGC &lt;&gt; null then
						self.drawObject(self.myDrawingFrame, nextGC);
					endif;
				
				endif;
			endif;
		endif;
	endif;
epilog
	self.drawFromNote := false;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
