vars

	yaData : CM_YAData;
	yaDataObjs : CM_YADataObjects;
	obj : Object;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_DwellDays );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataObjects) then
		yaDataObjs := yaData.CM_YADataObjects;
		if not yaDataObjs.isEmpty then
			obj := yaDataObjs.getFirstObject;
		endif;
		if obj &lt;&gt; null then
			return _yaData.includes(obj);
		endif;
	endif;
		
	return false;
	
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
