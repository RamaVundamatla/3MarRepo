    <JadeMethod name="formatResults" id="9ab564c0-afc4-4efe-ac46-00aa77e69f1e">
        <source>formatResults(file : File; delim : String):String;

vars
	smethoddirect		: String;
	smethodindirect		: String;
	sscriptdirect		: String;
	sscriptindirect		: String;
	stranslatablestring	: String;
	ref  				: Feature;
begin
	smethoddirect := '';
	if directMethodRefs.isEmpty = false then
		smethoddirect := directMethodRefs.size.String;
	endif;
	smethodindirect := '';
	if indirectMethodRefs.isEmpty = false then
		smethodindirect := indirectMethodRefs.size.String;
	endif;
	sscriptdirect := '';
	if directScriptRefs.isEmpty = false then
		sscriptdirect := directScriptRefs.size.String;
	endif;
	sscriptindirect := '';
	if indirectScriptRefs.isEmpty = false then
		sscriptindirect := indirectScriptRefs.size.String;
	endif;
	stranslatablestring :=	myTranslatableString.getOidAsString &amp;delim&amp; 
							myTranslatableString.getMySchema.name &amp;delim&amp; 
							myTranslatableString.name &amp;delim&amp; 
							myAgentOLD.allSchemas.includesKey(myTranslatableString.getMySchema.name).Boolean.getYesNo &amp;delim&amp;
							delim&amp;delim&amp; 
//							sscriptdirect &amp;delim&amp; sscriptindirect &amp;delim&amp; 
							smethoddirect &amp;delim&amp; smethodindirect &amp;delim;

	
	foreach ref in directMethodRefs do
		file.writeLine(	stranslatablestring &amp; 'Direct Method' &amp;delim&amp;
						ref.getSchema.name &amp;delim&amp; ref.getSchemaType.name &amp;delim&amp; ref.name);
	endforeach;
	
	foreach ref in indirectMethodRefs do
		file.writeLine(	stranslatablestring &amp;  'Indirect Method' &amp;delim&amp;
						ref.getSchema.name &amp;delim&amp; ref.getSchemaType.name &amp;delim&amp; ref.name);
	endforeach;			

/*	foreach ref in directScriptRefs do
		file.writeLine(	stranslatablestring &amp; 'Direct Script' &amp;delim&amp;
						ref.getSchema.name &amp;delim&amp; ref.getSchemaType.name &amp;delim&amp; ref.name);
	endforeach;

	foreach ref in indirectScriptRefs do
		file.writeLine(	stranslatablestring &amp; 'Indirect Script' &amp;delim&amp;
						ref.getSchema.name &amp;delim&amp; ref.getSchemaType.name &amp;delim&amp; ref.name);
	endforeach;
*/		
	return stranslatablestring;
end;</source>
        <Parameter name="file" type="File"/>
        <Parameter name="delim" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNewformatText" id="a024e3b7-4d65-4d39-8bb5-9a2259f421c0">
        <updating/>
        <source>getNewformatText() updating;

// convert TranslatableText parameterised format to DOS-style (%1, %2 ... ) parameter format

vars
	source 	: String;
	len		: Integer;
	start	: Integer;
	pos		: Integer;
	delim	: Character;
begin
	sourceNewFormat := '';
	parameterCount := 0;
	
	
	source := getTranslatableStringText;
	len := source.length;

	if len = 0 then
		return;
	endif;

	// find start
	start := source.pos('=',1) + 1;
	while start &lt; len and source[start] = ' ' do
		start := start + 1;
	endwhile;
	pos := start;
	
	// parse looking for parameters
	while true do

		if pos &gt; len then
			return;
		endif;
	
		// find first delimiter , may be ' or " 
		source.scanUntil('"' &amp; "'", pos);
			
		if start &lt; pos or pos = 0 then

			zAddParameter;
		endif;
		
		if pos = 0 then return; endif;

		start := pos + 1;


		// find corresponding end delimiter
		pos := source.pos(source[pos], start);
	
//		if pos = 0 then 
			// should never get here - compiler checks there is always a corresponding end quote
//			str := str &amp; source[start:end];
//			return str;
//		endif;

		sourceNewFormat := sourceNewFormat &amp; source[start:pos-start];

		
//		if pos &lt; len then
//			zAddParameter;
//		endif;
	
		pos := pos + 1;
		
	endwhile;

	
	return;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTranslatableStringText" id="a1b306d5-7c66-4c5b-9c37-08330901f965">
        <source>getTranslatableStringText():String;

vars

begin
	return myTranslatableString.getPropertyValue('source').String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="993eb5c9-7601-49fd-b135-1ff9b5f4944d">
        <updating/>
        <source>init(_agent : TranslatableStringMigratnAgent; _ts : TranslatableString; appSchemas : SchemaColl) updating;

vars

begin
	name := _ts.name;
	myTranslatableString := _ts;
	myLSSchema := _agent.allSchemas[_ts.getMySchema.name];
	myAgent := _agent;
	
	// ask translatable string to perform s script and method references analysis, and populate relevant collections
	myTranslatableString.analyseAllRefs(appSchemas, directScriptRefs, indirectScriptRefs, directMethodRefs, indirectMethodRefs);
	
	// set the new format text with DOS style (%1, %2 ...) parameters
	getNewformatText();
	
end;</source>
        <Parameter name="_agent" type="TranslatableStringMigratnAgent"/>
        <Parameter name="_ts" type="TranslatableString"/>
        <Parameter name="appSchemas" type="SchemaColl"/>
    </JadeMethod>
    <JadeMethod name="init2" id="052c8e6a-8e50-49f7-b6ed-4473c414a497">
        <updating/>
        <source>init2(_agent : TranslatableStringMigratnAgent; _ts : TranslatableString; appSchemas : SchemaColl; _constName : String) updating;

// new TranslatableString agent - create heirarchy of schemas, classes and method refs ... the latter need
// to have their source updated 

vars
	features	: FeatureSet;
	feature		: Feature;
	source		: String;
	meth 		: Method; 
	lsSchema	: LSschema;
	lsClass		: LSclass;
	lsMethRef	: LSmethodRef;
begin
	name := _ts.name;
	constName := _constName;
	myTranslatableString := _ts;
	myLSSchema := _agent.allSchemas[_ts.getMySchema.name];
	myAgent := _agent;
	
	// ask translatable string to perform s script and method references analysis, and populate relevant collections
	myTranslatableString.analyseAllRefs(appSchemas, directScriptRefs, indirectScriptRefs, directMethodRefs, indirectMethodRefs);
	
	// set the new format text with DOS style (%1, %2 ...) parameters
	getNewformatText();
	
	create features transient;
	zGetAllRefs(features);
	
	foreach feature in features do
		if feature.isKindOf(Method) then

			meth := feature.Method;

			lsSchema := _agent.allSchemas[meth.schemaType.schema.name]; 
			
			if lsSchema = null then
				app.writeStatement( '&gt;&gt;&gt; Skipping: method reference is outside the application schemas: ' &amp; name &amp; ', method: ' &amp; meth.qualifiedName);
				// skip the reference - not in an application schema
				continue;
			endif;
			
			lsClass := lsSchema.getLSclass(meth.schemaType.name);
			lsMethRef := lsClass.getLSmethodRef(meth, self);
	
		else
			app.writeStatement( '&gt;&gt;&gt; Skipping: not a method: ' &amp; feature.display);
		endif;
	endforeach;
epilog
	delete features;
end;</source>
        <Parameter name="_agent" type="TranslatableStringMigratnAgent"/>
        <Parameter name="_ts" type="TranslatableString"/>
        <Parameter name="appSchemas" type="SchemaColl"/>
        <Parameter name="_constName" type="String"/>
    </JadeMethod>
    <JadeMethod name="migrateToXlatTextMessage" id="11534064-d193-4e61-829d-23fab488e618">
        <source>migrateToXlatTextMessage(defaultLocale : CM_Locale; nextConstantValue : Integer; category : XLAT_Category);

vars
	globalConstant	: GlobalConstant;
	commandLine		: String;
	result			: Integer;
	proxy 			: XLAT_TranslationsAndGCProxy; 
	constantStr		: String;
	xlatTextMessage	: XLAT_TextMessage;
	agent			: CM_TranslationAgent;
	tsName			: String;

begin

	app.writeStatement( 'Migrating ' &amp; myLSSchema.name &amp; '::$' &amp; name &amp; ', value = ' &amp; nextConstantValue.String);
	
	tsName := myTranslatableString.name;
	
	create proxy transient;
	proxy.addText(defaultLocale, sourceNewFormat, null, category);

	// set up the constant definition line to go into the scm file
	constantStr := tsName &amp; ':' &amp; Tab &amp; "Integer = " &amp; nextConstantValue.String &amp; ";" &amp; CrLf &amp;
	Tab &amp; 'documentationText' &amp; CrLf &amp; '`' &amp; proxy.buildXml &amp; '`' &amp; CrLf &amp; CrLf;
	result := global.addConstantsServer(category.constantCategoryName, constantStr, commandLine);
	

	if result = 6041 or result = 6035 then
		// prefix with 'Lit_' and try again
		tsName := 'Lit_' &amp; tsName;
		constantStr := tsName &amp; ':' &amp; Tab &amp; "Integer = " &amp; nextConstantValue.String &amp; ";" &amp; CrLf &amp;
		Tab &amp; 'documentationText' &amp; CrLf &amp; '`' &amp; proxy.buildXml &amp; '`' &amp; CrLf &amp; CrLf;
		result := global.addConstantsServer(category.constantCategoryName, constantStr, commandLine);
	endif;
	
	if result &lt;&gt; 0 then
		app.writeStatement( '*** jadloadb error (add GC): ' &amp; result.String &amp; Tab &amp; tsName &amp; ' : ' &amp; nextConstantValue.String &amp; Tab &amp; myTranslatableString.getMySchema.name);

	endif;
	
	globalConstant := category.getGlobalConstant(tsName);
				
	if globalConstant = null then
		app.writeStatement( '&gt;&gt;&gt; Global constant not created! ' &amp; tsName);
		return;
	endif;
	
	create agent transient;
	
	// Now the constant exists, create corresponding Translatable Text object
	xlatTextMessage	:= agent.trxCreateTranslatableText(category, 0, proxy, globalConstant).XLAT_TextMessage;
	
	// method references to the TranslatableString must be updated via schema file
	
epilog
	delete proxy;
	delete agent;
end;</source>
        <Parameter name="defaultLocale" type="CM_Locale"/>
        <Parameter name="nextConstantValue" type="Integer"/>
        <Parameter name="category" type="XLAT_Category"/>
    </JadeMethod>
    <JadeMethod name="migrateToXlatTextMessageOLD" id="95b7462c-daaf-4efa-9f99-9e6099f03f4e">
        <source>migrateToXlatTextMessageOLD(defaultLocale : CM_Locale; nextConstantValue : Integer; category : XLAT_Category);

vars
	constantName 	: String;
	globalConstant	: GlobalConstant;
	commandLine		: String;
	result			: Integer;
	proxy 			: XLAT_TranslationsAndGCProxy; 
	constantStr		: String;
	xlatTextMessage	: XLAT_TextMessage;
	agent			: CM_TranslationAgent;
	features		: FeatureSet;
	feature			: Feature;
	source			: String;
	tsName			: String;
	pos				: Integer;
	xlatMethodName	: String;
	insertText		: String;
	localRefCount	: Integer;
	meth 			: Method; 
	refCount 		: Integer;
	methCount		: Integer;
	compiler		: JadeCompiler;
	sigChanged		: Boolean;
	usePriorVersion	: Boolean; 
begin

	app.writeStatement( 'Migrating ' &amp; myLSSchema.name &amp; '::$' &amp; name);
	
	tsName := myTranslatableString.name;
	
	create proxy transient;
	proxy.addText(defaultLocale, sourceNewFormat, null, category);

	// set up the constant definition line to go into the scm file
	constantStr := tsName &amp; ':' &amp; Tab &amp; "Integer = " &amp; nextConstantValue.String &amp; ";" &amp; CrLf &amp;
	Tab &amp; 'documentationText' &amp; CrLf &amp; '`' &amp; proxy.buildXml &amp; '`' &amp; CrLf &amp; CrLf;

	result := global.addConstantsServer(category.constantCategoryName, constantStr, commandLine);
	
	if result &lt;&gt; 0 then
		app.writeStatement ('Problems adding global constant using jadloadb. Result: ' &amp; result.String);
		app.writeStatement ('	Input: ' &amp; constantStr);
		app.writeStatement ('	Jadloadb: ' &amp; commandLine);
	endif;
	
	globalConstant := category.getGlobalConstant(tsName);
				
	if globalConstant = null then
		app.writeStatement( '&gt;&gt;&gt; Global constant not created! ' &amp; tsName);
		return;
	endif;
	
	create agent transient;
	
	// Now the constant exists, create corresponding Translatable Text object
	xlatTextMessage	:= agent.trxCreateTranslatableText(category, 0, proxy, globalConstant).XLAT_TextMessage;
	
	create compiler;
	usePriorVersion := false;
	
	// now update the references to the TranslatableString
	create features transient;
	zGetAllRefs(features);
	foreach feature in features do
		if feature.isKindOf(Method) then

			meth := feature.Method;
			app.writeStatement( '&gt;&gt;&gt; Updating TranslatableString reference: ' &amp; meth.qualifiedName &amp;Tab&amp; tsName);

			source	:= meth.getSource;
			
			if source.pos('$' &amp; tsName,1) = null then
				app.writeStatement( '&gt;&gt;&gt; TranslatableString reference not found: ' &amp; meth.qualifiedName &amp;Tab&amp; tsName);
				return;
			endif;

			// create the method name that gets the translated text (depends upon number of parameters)
			xlatMethodName := 'app.getErrorString';
			if parameterCount &gt; 0 then
				xlatMethodName := xlatMethodName &amp; parameterCount.String;
			endif;
			
			insertText := xlatMethodName &amp; '(' &amp; tsName &amp; ')';
	
			// substitute TranslatableString reference(s) with Global Constant references
			while true do
				pos := source.pos('$' &amp; tsName,1);
				if pos = null then break; endif;	// no more
				source := source[1:pos-1] &amp; insertText&amp; source[pos + insertText.length + 1:end];
				localRefCount := localRefCount + 1;
			endwhile;
			
			refCount := refCount + localRefCount;
			
			app.writeStatement( 'Ref count: '&amp; localRefCount.String &amp; 
				  ', TranslatableString: ' &amp; tsName &amp;
				  ', from method: ' &amp; myLSSchema.name &amp; '::' &amp; meth.qualifiedName);
		
			app.writeStatement( CrLf &amp; source);

			// IMPORTANT NOTE - THE FOLLOWING CODE HAS BEEN UNIT TESTED, BUT IS NOT SUPPORTED BY 
			// THE JADE PLANT, AND SHOULD BE VALIDATED IN AN OFFLINE ENVIRONMENT. 
			// ONLY UN-COMMENT AND RUN IN DEV WHEN YOU ARE SURE THERE ARE NO SIDE-EFFECTS.
	
			// update the method source with the substituted values, then recomile
			
			// BUGGER! This worked in Jade 6.0, but not in 6.1 - error deleting LocalVar (system object)
			// Plan b ... See new TranslatableStringMigratnAgent
			
			
			// Commented out for JADE 2022 as compile method now takes additional arguments (and this isn't used any more!)
			/*beginTransaction;
//			meth.setPropertyValue(Method::source.name,source);
			meth.setPropertyValue(Method::source.name,meth.getSource &amp; ' ' );
			compiler.compileMethod(meth, sigChanged, usePriorVersion);
			commitTransaction;*/
			
			
			methCount := methCount + 1;
		else
			app.writeStatement( '&gt;&gt;&gt; Skipping: not a method: ' &amp; feature.display);
		endif;
	endforeach;
epilog
	delete proxy;
	delete agent;
	delete features;
	delete compiler;
end;</source>
        <Parameter name="defaultLocale" type="CM_Locale"/>
        <Parameter name="nextConstantValue" type="Integer"/>
        <Parameter name="category" type="XLAT_Category"/>
    </JadeMethod>
    <JadeMethod name="validate" id="00ef3f90-f0ea-44fc-9a39-cf185b8d2e68">
        <source>validate(errorMessage : String output): Boolean;

vars

begin
	if sourceNewFormat.length &gt; 2046 then
		errorMessage := 'Excessive TranslatableString length - check this is appropriate usage: ' &amp; display;
		return false;
	endif;
	return true;

end;
</source>
        <Parameter name="errorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zAddParameter" id="7400e5c1-6fbc-4c27-9b21-b9cb60aef0c7">
        <updating/>
        <source>zAddParameter() updating;

// add a parameter

begin
	parameterCount := parameterCount + 1;
	sourceNewFormat := sourceNewFormat &amp; '%' &amp; parameterCount.String;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zGetAllRefs" id="73e09c04-30bf-4ba9-9ba4-27e9e6e3116c">
        <source>zGetAllRefs(allRefs : FeatureSet input);

vars
	f : Feature;
begin
	allRefs.clear;
	foreach f in directMethodRefs do
		allRefs.add(f);
	endforeach;
	foreach f in indirectMethodRefs where not allRefs.includes(f) do
		allRefs.add(f);
	endforeach;
	foreach f in directScriptRefs where not allRefs.includes(f) do
		allRefs.add(f);
	endforeach;
	foreach f in indirectScriptRefs where not allRefs.includes(f) do
		allRefs.add(f);
	endforeach;
end;
</source>
        <Parameter name="allRefs" type="FeatureSet" usage="input"/>
    </JadeMethod>
</Class>
