    <JadeMethod name="eprFixReserveTIs" id="e2d18229-d4e3-43a1-a92e-799145f4ccec">
        <source>eprFixReserveTIs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlger1	Initial creation

*/

vars
	terminal : CM_Terminal;
	iter : Iterator;
	br 	: CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	invalidReserveTIs  : ObjectSet;
	measureType : CM_MeasurementType;
str : String;
begin
	measureType:="12054.7".asOid.CM_MeasurementType;
	write "2161.790808".asOid.CM_BulkRelease.code;
	//write "2161.575513".asOid.CM_BulkRelease.getTotalOutstandingByCargoType;
	//write "2161.790808".asOid.CM_BulkRelease.getTotalOutstandingByCargoType(null);
	//	write "2161.790808".asOid.CM_BulkRelease.getTotalsByUnit(true,measureType);
	//	write "2161.790808".asOid.CM_BulkRelease.getTotalsByUnit(false,measureType);
	return;
//	app.initialize;
//	terminal :=app.myRoot.allTerminals["JBL"];
/*	create invalidReserveTIs transient;
	foreach terminal in app.myRoot.allTerminals discreteLock do
		
		delete iter;
		iter := terminal.allBulkReleaseByTypeByStByCd.createIterator;
		terminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_ROAD,BR_ACTIVE,null,null,iter);
		
		while iter.next(br) do
			foreach reserveDetail in br.allReserveDetails do
				if not reserveDetail.isKindOf(CM_ReserveTI) then
					continue;
				endif;
				
				
				
				if reserveDetail.allTrackedItems.size &gt; 1 and 
					reserveDetail.allTrackedItemsReleased.size &gt; 1 then
					str:= str &amp; " " &amp; terminal.code &amp; " " &amp; br.code &amp; " " &amp; reserveDetail.String;
					//invalidReserveTIs.add(reserveDetail);
				endif;
			endforeach;
		endwhile;
	endforeach;
	app.msgBox(str,"test",MsgBox_OK_Only);
	/*beginTransaction;
	invalidReserveTIs.purge;
	commitTransaction;*/
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprFixupVesselAddTier" id="65b68684-ad5c-47b8-94bb-8262d2b9a069">
