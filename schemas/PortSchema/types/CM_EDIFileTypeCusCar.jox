<Class name="CM_EDIFileTypeCusCar" id="c821f2a3-78e5-47ad-941b-36bfcc6844da">
    <superclass name="CM_EDIFileTypeUNEDIFACT"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
