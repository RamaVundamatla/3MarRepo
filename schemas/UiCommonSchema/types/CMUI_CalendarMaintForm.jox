    <JadeMethod name="btnRemDate_click" id="17950811-60c8-44a4-a60a-c4e28efa2c39">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemDate_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	calDate : CM_CalendarDate;
	calDates : CM_CalendarDateSet;
	calendar : CM_Calendar;
	msg : String;
	
begin

	calDate := self.tblDayData.allSelectedObjects.first.CM_CalendarDate;
	
	if calDate = null then
		btnRemDate.enabled := false;
		return;
	endif;
	
	calendar := calDate.myCalendar;
	
	create calDates transient;
	self.tblDayData.allSelectedObjects.copy(calDates);
	
	msg := app.getErrorString1(Lit_Confirm_Delete, app.getErrorString1(Calendar_entries, calDates.size.String) );
	if app.msgBox( msg, app.getErrorString(Calendar), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	foreach calDate in calDates do
		app.myTrxDA.trxDeleteCalendarDate(calDate, app.myPassport);
	endforeach;
	
	self.selectCalendar( calendar );

epilog

	delete calDates;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
