    <JadeMethod name="doMatch" id="d4b1d678-f063-4c54-aa4e-feb70eace88f">
        <updating/>
        <source>doMatch() updating;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
27 Jun 2008	cnwkpd1	PAR #11725 - Rework to use standard dialog frame instead of CMUI_Monitor as 
					the progress bar to stop strange behaviour with maximised MDI chlid forms

*/

vars
	cmifMonitor : CMIF_Monitor;
	result		: Integer;
	
begin
	app.mousePointer := MousePointer_HourGlass;

//	PAR #11725 - Code replaced by standard dialog frame
//	create cmifMonitor transient;
//	create monitorFrm transient;
//	monitorFrm.showMonitor(cmifMonitor, 1, 'Matching Header', 'Cancel', null, null);
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	self.modalDialogShow(null, 'Cancel', null, null, 'Matching Header', null);
	self.pbProgressBar.visible := true;
   	self.updateProgress(cmifMonitor);

	// PAR 20627 - need to allow for warnings here
	while true do

		app.myTrxUA.trxReconcileLogDockets(app.myPassport, cmifMonitor);	
	
		self.frmModalDialog.visible := false;
	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Docket Matching', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			break;
		endif;	
	endwhile;
	
epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete cmifMonitor;
//	monitorFrm.unloadForm();
	self.frmModalDialog.visible := false;
	app.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="37cc9bc0-4dac-499e-b3f8-b7d0163bfb38">
        <updating/>
        <source>doRefresh()updating, protected;
//--------------------------------------------------------------
//Created: 01 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ls	: Boolean;
	rowIdx : Integer;
begin
	inheritMethod();
	app.mousePointer := MousePointer_HourGlass;
	app.cmsBeginLoad(ls);
	
	self.showDocketData();
	self.showHeaderData();
	self.clearDocketEntry();
	self.clearHeaderEntry();

	if self.myCurrentBOL &lt;&gt; null then
		if tblDocketData.findObjectInRow(self.myCurrentBOL, rowIdx) then
			self.selectDocket(rowIdx);					
		endif;
	endif;

	if self.myCurrentBOLOutHdr &lt;&gt; null then
		if tblHeaderData.findObjectInRow(self.myCurrentBOLOutHdr, rowIdx) then
			self.selectHeader(rowIdx);					
		endif;
	elseif self.myCurrentScalingHdr &lt;&gt; null then
		if tblHeaderData.findObjectInRow(self.myCurrentScalingHdr, rowIdx) then
			self.selectHeader(rowIdx);					
		endif;
	endif;

epilog
	app.cmsEndLoad(ls);
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="1e83765f-e354-450c-895f-8c57972285bb">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x, y, tableWidth, docketTableWidth, tableHeight : Real;

begin

	splMain.repositionAfterResize();

	x := Margin_Gap;
	y := Margin_Gap + lblDockets.height;

	tableWidth :=  (self.clientWidth - (( Margin_Gap * 2) + Table_Gap)) / 2;
	tableHeight := self.clientHeight - (82 + btnEditDocket.height + (tblDocketEntry.height * 3) + txtTickets.height );
	
	lblDockets.move(WinLeftMargin, 0, lblDockets.width, lblDockets.height);
	
	x := Margin_Gap + tableWidth + Table_Gap;
	lblTickets.move(x, 0, lblTickets.width, lblTickets.height);

	docketTableWidth := tableWidth - (btnEditDocket.width + Table_Gap);
	y := self.clientHeight - ( 87 + btnEditDocket.height);
	tblDocketEntry.move(Margin_Gap, y, docketTableWidth, tblDocketEntry.height);

	x := Margin_Gap + tableWidth + Table_Gap;
	y := self.clientHeight - ( 87 + btnEditDocket.height);
	tblTicketEntry.move(x, y, docketTableWidth, tblDocketEntry.height);

//	splMain.left := (WinLeftMargin);
//	splMain.width := (self.width - WinLeftMargin - WinRightMargin);
//	splMain.height := (self.height - (btnClose.height * 4) - (Margin_Gap *6) - WinTopMargin - WinBottomMargin);	

//	tblDocketData.cnEcResizeContents();
//	tblHeaderData.cnEcResizeContents();
	tblDocketEntry.cnEcResizeContents();
	tblTicketEntry.cnEcResizeContents();

	btnEditTicket.repositionAfterResize();
	btnSaveTicket.repositionAfterResize();
	btnDeleteTicket.repositionAfterResize();
	btnClose.repositionAfterResize();

	btnAddReceipt.repositionAfterResize(); 
	btnAddRelease.repositionAfterResize(); 	
	btnSplit.repositionAfterResize();	
	btnMatch.repositionAfterResize();	
	btnMerge.repositionAfterResize();	

	x := (Margin_Gap + tableWidth) - btnDeleteDocket.width;
	btnDeleteDocket.move(x, btnDeleteTicket.top, btnDeleteDocket.width, btnDeleteDocket.height);
	btnSaveDocket.move(x, btnSaveTicket.top, btnSaveDocket.width, btnSaveDocket.height);
	btnEditDocket.move(x, btnEditTicket.top, btnEditDocket.width, btnEditDocket.height);

//	splMain.cnEcResizeContents();
//	splDockets.cnEcResizeContents();
//	splTickets.cnEcResizeContents();

//temp measure only see GD	
//-------------------------------------------------------------------
//btnAddRelease.enabled := false;
//--------------------------------------------------------------------			
	
end;</source>
    </JadeMethod>
    <JadeMethod name="docketDelete" id="bc150afd-dc21-432d-9b5e-11fee61011b9">
        <updating/>
        <source>docketDelete() updating;
// -----------------------------------------------------------------------------
// Created:		26 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	msgStr : String;
	rtValue : Boolean;
	tmpBOL	: CM_BOL;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	
	if self.myCurrentBOL = null then
		app.msgBox('Please select Docket to be deleted.','Select Docket', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;	
	endif;
	
	msgStr := 	'Are you sure you want to delete' &amp;CrLf &amp;
				'docket ' &amp; self.myCurrentBOL.number.String &amp; ' ?';

	if app.msgBox(msgStr, 'Docket Delete', MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;

	// delete it here!!!
	tmpBOL := self.myCurrentBOL;
	exclusiveLock(tmpBOL);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteBOL(tmpBOL, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.setCurrentDocketEdition(null);
			self.clearDocketEntry();
			break;
		else
			theResult := app.showErrorWarningDialog('Docket Reconciliation', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="docketEdit" id="2d19866a-761f-48d9-ba79-b8efbfbf6d08">
        <updating/>
        <source>docketEdit() updating;
//--------------------------------------------------------------
//Created: April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	realBOL : CM_BOL;
	obj	: Object;

begin
	
	if self.myCurrentBOL = null then
		app.msgBox('Please select a Docket to be edited.','Select Docket', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;

	realBOL := self.myCurrentBOL;
	self.myAssistant.showDocketMaintForm(realBOL, self.myMasterMenuAction, true, true);		

end;</source>
    </JadeMethod>
    <JadeMethod name="docketSave" id="d667f8af-1e14-4c49-b8d7-3ca3f6526c63">
        <updating/>
        <source>docketSave() updating;
// -----------------------------------------------------------------------------
// Created:		26 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars 
	ls				: Boolean;
	docketNumber 	: String;
	pxyDocket 		: CM_BOL;
	result,
	numTIs,
	pieceCount		: Integer;
	ext				: CM_BOLExtLog;
begin
	if self.myCurrentBOL = null then
		return;
	endif;
	
	if self.myCurrentBOL.edition &lt;&gt; self.docketEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'docket', null, null);
		return;
	endif;
	
	app.cmsBeginLoad(ls);
	sharedLock(self.myCurrentBOL);		
	
	docketNumber 	:= tblDocketEntry.getValueByName(ETRow_DocketNumber).String;
	pieceCount 		:= tblDocketEntry.getValueByName(ETRow_NoLogs).Integer;	
	
	if self.myCurrentBOL.number = docketNumber and self.myCurrentBOL.numItems = pieceCount then
		//no change
		return;
	endif;
	
	ext := self.myCurrentBOL.myExtension.CM_BOLExtLog;
	numTIs := self.myCurrentBOL.numTIs;
	if pieceCount &lt;&gt; numTIs and numTIs &gt; 0 then
		if ext.ticketedAll and ext.percentScaled &lt; 100 then
			if self.myCurrentBOL.myPlannedLocation &lt;&gt; null then
				app.msgBox('Cannot save new piece count as Docket is 100% Ticketed and not 100% Scaled.'
							&amp; CrLf &amp; 'To change piece count please use the Edit option.','Docket Save',
							MsgBox_Stop_Icon + MsgBox_OK_Only);			
				return;
			else
				app.msgBox('Cannot change piece count for Dockets 100% Ticketed and' &amp; CrLf &amp; 
							' not 100% Scaled that have been unloaded to yard location.','Docket Save',
							MsgBox_Stop_Icon + MsgBox_OK_Only);			
				return;			
			endif;
		endif;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	pxyDocket := app.createUpdateProxy(self.myCurrentBOL).CM_BOL;
	
	pxyDocket.setProxyDocketReconcile(docketNumber, pieceCount);

/*
	app.myTrxUA.trxUpdateBOL(pxyDocket, false, app.myPassport);

	if (not app.myPassport.trxCompletedOK) then
		app.showErrorWarningDialog('Docket Update', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	else
		self.clearErrorWarnings();
		self.setCurrentDocketEdition(self.myCurrentBOL);
	endif;
*/

	while true do // par11523
		app.myTrxUA.trxUpdateBOL(pxyDocket, false, null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.setCurrentDocketEdition(self.myCurrentBOL);
			break;
		else
			result := app.showErrorWarningDialog('Docket Update', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);

			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;	
		break;
	endwhile;

epilog
	delete pxyDocket;
	app.mousePointer := MousePointer_Default;	
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="84185f2d-b357-41fa-959d-a3631e73c44e">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Date		Who		Reason
28 April 2017	cnwer1	Initial creation TFS

*/

vars
	xmlString : String;
	hideTransfer : Boolean;
begin
	xmlString:= inheritMethod();
	
	hideTransfer:= self.mnuHideRailTransfers.caption &lt;&gt; app.getErrorString(Hide_inter_termin_rail_transf);
	xmlString := xmlString &amp; 
			global.formatAsXML(self.XML_HideInterRailTransfer, hideTransfer.String);
	
	return xmlString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="e6d93bfc-2543-466a-8124-fa3ef678314a">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 01 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if keyCode = CMUI_Key_F5 then
		// F5 does a refresh of the screen.
		self.doRefresh();
		return;
	endif;
	
	inheritMethod(keyCode, shift);

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
