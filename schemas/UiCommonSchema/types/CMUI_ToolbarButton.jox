        <source>drawButtonNormal() updating;
// ---------------------------------------------------------------------------
// Created:     15 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.backColor := self.origBackColor;
	inheritMethod();
end;</source>
    </JadeMethod>
