    <JadeMethod name="unload" id="3c1c87f3-f52b-43b2-a921-0dc0e3729d8a">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			

Date		Who		Reason
26 July 2023	navab1	 CR 58230 TASK 58232
*/

vars

begin
	// ### TFS BUG 64115 13MAY2024 NAVAB1
	if self.myMaintForm &lt;&gt; null then
		if self.mode = CMUI_OwnershipChangeMaint.Cargo_Review_Mode then
			self.myMaintForm.resetCOOTransferredAmounts(self.myOwnershipChangeDetail);
			self.myMaintForm.displayDetails();
			self.myMaintForm.displayStatus();
		endif;
		self.myMaintForm.myDetailForm := null;
	endif;
	
	inheritMethod();
	
	if self.mode &lt;&gt; CMUI_OwnershipChangeMaint.Cargo_Review_Mode then // ### TFS BUG 64115 13MAY2024 NAVAB1
		delete self.myProxyDetail;
		self.detailsSet.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateSubDetail" id="6bce4811-a8ee-44b1-a711-4992294dfa59">
        <source>updateSubDetail();
/*
Purpose:			

Date		Who		Reason
25 July 2023	navab1	 CR 58230 TASK 58231
*/

vars
	portion : Decimal[23,4];
	cood : CM_OwnershipChangeDetail;
	weight, volume : Decimal[23,4];
	quantity, col : Integer;
	include : Boolean;
	theDataLine : String;
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	cood := self.tblData.accessRow(self.tblData.row).itemObject.CM_OwnershipChangeDetail;
	ti := cood.myTrackedItem;
	ct := ti.myCargoType;
	
	if ct.isBulk() then
		if ct.isBulkByVolume() then
//			weight := cood.transferredWeight;
			volume := self.txtTransferCargoVolume.getConvertedValue().Decimal;
			if volume &lt;= 0 
			or volume &gt; ti.totalVolume then
				app.msgBox(app.getErrorString(Trans_volum_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
				self.txtTransferCargoVolume.setValue(ti.totalVolume);
				self.txtTransferCargoVolume.setFocus();
				return;
			endif;
			
			// ### TFS BUG 64115 13MAY2024 NAVAB1
			portion := volume/ self.totalVolume;
			weight := self.totalWeight * portion;
			
			self.txtTransferCargoWeight.setValue(weight);
		else
			weight := self.txtTransferCargoWeight.getConvertedValue().Decimal;
			
			
//			volume := cood.transferredVolume;
			if weight &lt;= 0 
			or weight &gt; ti.totalWeight then
				app.msgBox(app.getErrorString(Transfer_weight_Should_be_Grea),app.getErrorString(Problem), MsgBox_OK_Only);
				self.txtTransferCargoWeight.setValue(ti.totalWeight);
				self.txtTransferCargoWeight.setFocus();
				return;
			endif;
			
			// ### TFS BUG 64115 13MAY2024 NAVAB1
			portion := weight/ self.totalWeight;
			volume := self.totalVolume * portion;
			
			self.txtTransferCargoVolume.setValue(volume);
				
		endif;
		
		quantity := cood.transferredQuantity;

			
	else
		quantity := self.txtTransferCargoQuantity.text.Integer;
//		weight := cood.transferredWeight;
//		volume := cood.transferredVolume;
		
		
		if quantity &lt;= 0 
		or quantity &gt; ti.totalQuantity then
			app.msgBox(app.getErrorString(Trans_quant_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
			self.txtTransferCargoQuantity.text := ti.totalQuantity.String;
			self.txtTransferCargoQuantity.setFocus();
			return;
		endif;
		
		// ### TFS BUG 64115 13MAY2024 NAVAB1
		portion := quantity/ self.totalQuantity;
		weight := self.totalWeight * portion;
		volume := self.totalVolume * portion;
		
		self.txtTransferCargoWeight.setValue(weight);
		self.txtTransferCargoVolume.setValue(volume);
	
	endif;

	col := self.tblData.getColumnByRowName(ETRow_Include);
	self.tblData.accessCell(self.tblData.row,col);
	include := self.tblData.accessedCell.text = true.cnEcGetTableCheckBoxValue ;
	
	cood.setProxyTransfers(weight, volume, quantity,include);
	theDataLine := cood.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	self.tblData.accessCell(self.tblData.row, 1).text := theDataLine;

	self.displayContentTotals(self.myOwnershipChangeDetail);



epilog

end;</source>
    </JadeMethod>
</GUIClass>
