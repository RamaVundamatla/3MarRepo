<GUIClass name="CMUI_ToDoDamageTask" id="e2927692-8904-45ee-af69-ccccd0629e1f">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>37244 record damage details from to-do task completion</text>
    <ImplicitInverseRef name="myTrackedItem" id="7f88c011-68b5-41b4-9c83-328a0b81767c">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblDamages" id="77739362-5ddf-4ef7-987b-a0f225c1d6bc">
        <embedded/>
        <type name="CM_DamageEntryTbl"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="08e01682-944f-404a-afe3-eb3125367cb3">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
Dec 2015	cnwjre1	37244 record damage details from to-do task completion
04/10/2016	cnwdap1	STWR TFS 2788 Show errors from damages table as system warnings
*/

vars
	result : Integer;									// TFS 2788

begin
	if not self.validateData() then						// TFS 2788
		result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);	// TFS 2788
	endif;												// TFS 2788
	
	app.myPassport.clearErrorsWarnings();				// TFS 2788
	if result = IDOK then								// TFS 2788
		inheritMethod();
	endif;												// TFS 2788

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleWarnings" id="ac2a95f8-99ed-4e40-a827-bf318aa39d5e">
        <updating/>
        <source>handleWarnings(_exObj : Exception; _passport : CM_Passport input) : Integer updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/10/2016	cnwdap1		Initial creation TFS 2788
//
vars

begin
	if _passport = null then
		return Ex_Pass_Back;
	endif;

	if _exObj.isKindOf(CM_Exception) and _exObj.CM_Exception.isWarning then
		_passport.addWarningFull(_exObj.errorCode, _exObj.extendedErrorText, _exObj.CM_Exception.userString, _exObj.CM_Exception.myUserObject, _exObj.CM_Exception.mySubject);
		return Ex_Continue;
	endif;
	
	return Ex_Pass_Back;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="init" id="2847fa85-aa74-46d8-8613-4a4d9d61f46a">
        <updating/>
        <source>init(_ti : CM_TrackedItem)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
Dec 2015	cnwjre1	37244 record damage details from to-do task completion

*/

vars

begin
	self.myTrackedItem := _ti;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="populateTblDamages" id="4dd3e5d5-4564-49e3-9b64-a5967fcefb32">
        <source>populateTblDamages();
//	37244 record damage details from to-do task completion
vars
	size : Integer;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		self.tblDamages.init();				// sets up the row header
		self.tblDamages.initCombos(self.myTrackedItem.IF_DamageDetails);
		self.tblDamages.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
		size := self.myTrackedItem.allDamageInstancesByPos.size;
	endif;
	
	if size = self.tblDamages.rows then
		self.tblDamages.addNewRow();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="278adc49-0992-468e-8b41-847757e97e03">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
Dec 2015	cnwjre1	37244 record damage details from to-do task completion

*/

vars

begin
	inheritMethod();

	self.populateTblDamages();

	if self.myTrackedItem &lt;&gt; null then
		self.setCaption(self.caption &amp; " " &amp; self.myTrackedItem.id);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblDamages_rowColumnChg" id="c7505886-5e49-4b60-8de0-d7585704b173">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDamages_rowColumnChg(table: Table input) updating;

vars

begin
	if table.row = table.rows and table.column = table.columns then
		self.tblDamages.addNewRow();
	endif;

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="50fdd2d7-5029-4be8-ac69-1e177ea294bc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 14 January 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021113, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="c87be689-43a2-43ef-a486-188b0ad59f12">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/10/2016	cnwdap1		Initial creation TFS 2788
//
vars

begin
	app.myPassport.clearErrorsWarnings();
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateData" id="2331e734-d52a-41a3-b7eb-6610960df2d9">
        <updating/>
        <source>validateData() : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/10/2016	cnwdap1		Initial creation TFS 2788
// 22/11/2016  cnwma1		TFS #2944*:PAR38399 STWO - damage recording - cargo quantity
//
vars
	damageInstance : CM_DamageInstance;
	fixed,
	numberRows,
	row : Integer;
	posStr,
	codeStr,
	remarks,
	severityStr : String;
	quantity,
	position,
	severity : Integer;
	damageCode : CM_DamageDefinitionCode;
	damageCodeDict : CM_DamageDefinitionByCodeDict;
	damagePosition : CM_DamagePosition; 
	quantityStr : String;
	quantityInt : Integer;

begin
	on Exception do self.handleWarnings(exception, app.myPassport);
	
	numberRows := self.tblDamages.rows;
	fixed := self.tblDamages.fixedRows;

	damageCodeDict := app.myRoot.allDamageDefinitionCodes;
	foreach row in fixed + 1 to numberRows do
		posStr		:= self.tblDamages.getCellText(row, 1).trimBlanks;
		codeStr		:= self.tblDamages.getCellText(row, 2).trimBlanks.toUpper;
		severityStr	:= self.tblDamages.getCellText(row, 3).trimBlanks;
		quantityStr := self.tblDamages.getCellText(row,4).trimBlanks;
		damagePosition := app.myRoot.allDamagePositionsByCode[posStr]; //Need to do it this way as the combo listObject changes each time a new damage instance is entered.
		
		if quantityStr &lt;&gt; null and quantityStr.isInteger then
			quantityInt := quantityStr.Integer;
		else
			quantityInt := 0;
		endif;
		if posStr = null and codeStr = null and severityStr = null and quantityInt = 0 then
			continue;
		endif;
		
		if posStr = null or codeStr = null or severityStr = null or quantityStr = null then
			app.raiseCMWarning1(Incomplete_Damage_Info, (row - fixed).String, null, null, null);
			continue;
		endif;
		
		if damagePosition = null then
			app.raiseCMWarning1(No_Valid_Damage_Pos, posStr, null, null, null);
			continue;
		endif;
		
		damageCode := damageCodeDict[codeStr];
		if damageCode = null then
			app.raiseCMWarning1(No_Damage_Code_Found, codeStr, null, null, null);
			continue;
		endif;
		
		severity := severityStr.Integer;
		if severity = null then
			app.raiseCMWarning1(Invalid_Damage_Severity, (row - fixed).String, null, null, null);
			continue;
		endif;
		
		//if quantityInt = 0 or quantityInt &gt; 999 then       // 22/11/2016 cnwma1 TFS 2944
		if quantityInt = 0 or quantityInt &gt; 999999999 then    // 22/11/2016 cnwma1 TFS 2944
			app.raiseCMWarning1(Invalid_Damage_Quantity, (row - fixed).String, null, null, null);
			continue;
		endif;
	endforeach;
	
	if app.myPassport.hasErrorsOrWarnings then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
