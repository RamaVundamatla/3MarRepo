    <JadeMethod name="getFirstMatchingTI" id="341ac5a5-413c-4e77-9dd2-800d3fcf3928">
        <updating/>
        <source>getFirstMatchingTI(_lastShipPlanningTI : CMIF_ShipPlanningTI;_doingRowSep : Boolean) : CMIF_ShipPlanningTI updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2009	cnwer1	Initial creation

*/

vars
	theSortTA : String;
	theSortRow,
	theSortCol,
	order: Integer;
	iter : Iterator;
	shipPlanningTI : CMIF_ShipPlanningTI;
begin
	if self.allShipPlanningTIArray.size = 0 then
		return null;
	endif;

	order:=null;
	if self.testRest and _doingRowSep then
			
		if _lastShipPlanningTI &lt;&gt; null then
			theSortTA:=_lastShipPlanningTI.gridTA;
			theSortRow:=_lastShipPlanningTI.myShipPlanningSlotRequest.rowSep;
			if theSortRow = null then
				rowSep := _lastShipPlanningTI.gridOrdRow + self.myCMIF_ShipPlanner.rowsSeperation + 1;
			else
				rowSep :=null;
			endif;
			
		else
			theSortTA:="";
			rowSep:=null;
		endif;
	else
		theSortTA:="";
		rowSep:=null;
	endif;
	theSortCol:=null;
		
	if rowSep &lt;&gt; null then
		iter:=	self.allShipPlanTIsByRowOrder.createIterator;
				
		self.allShipPlanTIsByRowOrder.startKeyGeq(rowSep,order,iter);
		while iter.next(shipPlanningTI) do	
			break;
		endwhile;	
		
		if shipPlanningTI = null then 
			//the row must be to high start from zero
			iter.reset;
			self.allShipPlanTIsByRowOrder.startKeyGeq(0,order,iter);
			while iter.next(shipPlanningTI) do
				return shipPlanningTI;
				break;
			endwhile;	
			
		else
			return shipPlanningTI;
		endif;
	endif;

	return self.allShipPlanningTIArray.first;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_lastShipPlanningTI" type="CMIF_ShipPlanningTI"/>
        <Parameter name="_doingRowSep" type="Boolean"/>
        <ReturnType type="CMIF_ShipPlanningTI"/>
    </JadeMethod>
    <JadeMethod name="getFirstPlannedTIInTA" id="fa8c2dd9-a8f7-4d56-b826-b4216f804dc7">
        <source>getFirstPlannedTIInTA(_currentShipPlanTI : CMIF_ShipPlanningTI): CMIF_ShipPlanningTI;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2009	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	shipPlanningTI : CMIF_ShipPlanningTI;
	
begin

	iter:= self.myForwardTwinCMIFPlanningSR.allShipPlanTIsByTAOrder.createIterator;
	self.myForwardTwinCMIFPlanningSR.allShipPlanTIsByTAOrder.startKeyGeq(_currentShipPlanTI.gridTA,null,iter);
	while iter.next(shipPlanningTI) do
		if shipPlanningTI.myTrackedItem = _currentShipPlanTI.myTrackedItem then
			continue;
		endif;
	
		if shipPlanningTI.gridTA &lt;&gt; _currentShipPlanTI.gridTA then
			break;
		endif;
		
		return shipPlanningTI;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_currentShipPlanTI" type="CMIF_ShipPlanningTI"/>
        <ReturnType type="CMIF_ShipPlanningTI"/>
    </JadeMethod>
    <JadeMethod name="getMatchingTIs" id="196283b7-8993-420f-b973-369e08237571">
        <source>getMatchingTIs();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2009	cnwer1	Initial creation

*/

vars
theTI : CM_TrackedItem;
	iter : Iterator;
	keyPowerType,
	keyTiLength,
	keyTiHeight,
	keyTiWeight,
	keyTiSelStatus,
	keyGridRowOrd,
	keyGridColOrd,
	keyGridStackPos,
	order : Integer;
	keyDischPortCode,
	keyCommGrpCode,
	keyContentsStatus,
	keyTaID,keyTaID2: String;
	failedColourCode,
	matchRest 	: Boolean;
	cmifShipPlanningTI : CMIF_ShipPlanningTI;
	tmpStr : String;
begin
	
	
	
	theTI := self.myCMIF_ShipPlanner.allTrackedItems.getAtKeyGeq(self.dischPortCode, self.contentStatus, self.commGrpCode, self.powerType, self.length, self.height, self.weight, self.selStatus, self.taID, self.gridRowOrd, self.gridColOrd,0,null);
	tmpStr := "NULL";
	if self.mySlotRequest &lt;&gt; null 
	and self.mySlotRequest.mySlotController &lt;&gt; null then
		tmpStr := self.mySlotRequest.mySlotController.getFullId();
	elseif self.myRORORequest &lt;&gt; null 
	and self.myRORORequest.myROROController &lt;&gt; null then
		tmpStr := self.myRORORequest.myROROController.getFullId();

	endif;

	
//	app.writeStatement(tmpStr &amp; "," &amp; dischPortCode &amp; "," &amp; contentStatus &amp; "," &amp; self.commGrpCode &amp; "," &amp; powerType.String 
//								&amp; "," &amp; length.String &amp; "," &amp; height.String);
//	app.writeStatement(theTI.id &amp; "," &amp; theTI.dischargePort &amp; "," &amp; theTI.getContentsStatusDesc(false) &amp; "," &amp; theTI.getCommodityGroup &amp; "," &amp; theTI.getActualLength().String);

		
	if theTI = null and not testHeavies then
		return;
	endif;
	
	iter:=self.myCMIF_ShipPlanner.allTrackedItems.createIterator;
	
	if testHeavies then
		iter.startAtObject(theTI);
		while iter.next(theTI) do
			// ### get the KEYS back for the found TI
			self.myCMIF_ShipPlanner.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2,iter);
			failedColourCode:=not self.tiMatches(keyDischPortCode, keyContentsStatus, keyPowerType, keyTiLength, keyTiHeight);
			if failedColourCode then
				//break;
				continue;
			endif;
			
			if self.tiMatchesWeight(keyTiWeight) then
				matchRest:=false;
				/* WAS
				if self.testCommodityGroup then
					if not self.tiMatchesCommodity(theTI) then
						continue;
					endif;
				elseif self.testOverDim then
					if not self.tiMatchesOverDim(theTI) then
						continue;
					endif;
				elseif self.testHazardous then
					if not self.tiMatchesHazardous(theTI) then
						continue;
					endif;
				elseif self.testWaterCooled then
					if not self.tiMatchesWaterCooled(theTI) then
						continue;
					endif;		
				else
					matchRest:=true;
				endif;
				NOW */
				if not (self.testCommodityGroup() = self.tiMatchesCommodity(theTI)) then
					continue;
				elseif not (self.testOverDim() = self.tiMatchesOverDim(theTI)) then

					continue;
				elseif not (self.testHazardous() = self.tiMatchesHazardous(theTI)) then
					continue;
				elseif not (self.testWaterCooled() = self.tiMatchesWaterCooled(theTI)) then
					continue;
				else
					matchRest:=true;
				endif;
				
				if not self.tiMatchesDLR(theTI) then
					continue;
				endif;
				// add to collection
				
				create cmifShipPlanningTI transient;
				order:=self.allShipPlanTIsByRowOrder.size  + 1;				
				cmifShipPlanningTI.init(theTI,order,keyTaID,keyGridRowOrd,keyGridColOrd,keyGridStackPos,self.testCommodityGroup,self.testHazardous,self.testWaterCooled,self.testOverDim(),matchRest,false,self);
	
			else
				//break and change key
				break;
			endif;	
		
		endwhile;	
	endif;
	
	if failedColourCode then
		return;
	endif;
	
	iter.reset;
	theTI:= self.myCMIF_ShipPlanner.allTrackedItems.getAtKeyGeq(self.dischPortCode, self.contentStatus, self.commGrpCode, self.powerType, self.length, self.height, 0, self.selStatus, self.taID, self.gridRowOrd, self.gridColOrd,0,null);
	
	iter.startAtObject(theTI);
	while iter.next(theTI) do
		// ### get the KEYS back for the found TI
		self.myCMIF_ShipPlanner.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2,iter);
		failedColourCode:=not self.tiMatches(keyDischPortCode, keyContentsStatus, keyPowerType, keyTiLength, keyTiHeight);
		






		if failedColourCode then
		//	break;
		continue;
		endif;

	
		if keyTiWeight &lt;&gt; 0 and self.testHeavies then
		//already done these can break
			break;
		endif;
		matchRest:=false;
		/*
		if self.testOverDim then
			if not self.tiMatchesOverDim(theTI) then
				continue;
			endif;
		elseif self.testHazardous then
			if not self.tiMatchesHazardous(theTI) then
				continue;
			endif;
		elseif self.testWaterCooled then
			if not self.tiMatchesWaterCooled(theTI) then
				continue;
			endif;		
		elseif self.testCommodityGroup() &lt;&gt; theTI.testCommodityGroup() then
			continue;
		else
			matchRest:=true;
		endif;
		*/
//if self.mySlotRequest &lt;&gt; null then
		if self.testCommodityGroup and not self.tiMatchesCommodity(theTI) then
				continue;
		elseif not (self.testOverDim() = self.tiMatchesOverDim(theTI)) then
			continue;
		elseif not (self.testHazardous() = self.tiMatchesHazardous(theTI)) then
			continue;
		elseif not (self.testWaterCooled() = self.tiMatchesWaterCooled(theTI)) then
			continue;
		else
			matchRest:=true;
		endif;
//else
	//matchRest:=true;
//endif;
		if not self.tiMatchesDLR(theTI) then
			continue;
		endif;
		//add to collection
		create cmifShipPlanningTI transient;
		order:=self.allShipPlanTIsByRowOrder.size  + 1;
		cmifShipPlanningTI.init(theTI,order,keyTaID,keyGridRowOrd,keyGridColOrd,keyGridStackPos,self.testCommodityGroup,self.testHazardous,self.testWaterCooled,self.testOverDim(),matchRest,false,self);
	endwhile;


epilog
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="0f2ff418-c7a6-43b7-8aa9-7bb4a2be555a">
        <updating/>
        <source>init(_slotRequest : CM_SlotRequest; _cmifShipPlanningController : CMIF_ShipPlanningController) updating; 
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2008	cnwer1	Initial creation

*/

vars
	dPort : CM_Port;
begin
	self.mySlotRequest:=_slotRequest;
	self.myCMIF_ShipPlanner:=_cmifShipPlanningController;
	
	// ### GET THE REQUEST DATA
	dPort := self.mySlotRequest.getAttrDischargePort(); // PAR 27749
	if dPort &lt;&gt; null then
		self.dischPortCode := dPort.code;
	else
		self.dischPortCode := self.mySlotRequest.dischargePort;
	endif;
	self.commGrpCode := self.mySlotRequest.getAutoLoadPlanCommodityCode();
	
	self.powerType := self.mySlotRequest.getShipPlanningPowerType();
	self.length := self.mySlotRequest.getActualLength().Integer; // 20 40 or 45
	self.height := self.mySlotRequest.getAttrHiCubed().Integer; // zero or one

	if self.testHeavies then // if current job has no slots defined for heavies then ignore
		if self.mySlotRequest.mySlotDefinition.heavy then
			self.weight := CMIF_ShipPlanningController.Req_Weight_Heavy;
		else
			self.weight := CMIF_ShipPlanningController.Req_Weight_Light;
		endif;
	else
		self.weight := 0;
	endif;

	
	if self.mySlotRequest.getAttrEmpty() then
		self.contentStatus := "MT";
	else
		self.contentStatus := "FULL";
	endif;
	
	self.isDLR := self.mySlotRequest.isRehandle();
	
	self.selStatus := 0;
	
	
	self.taID := "";
	self.gridRowOrd := 0;
	self.gridColOrd := 0;
	

	self.getMatchingTIs();

epilog

end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
        <Parameter name="_cmifShipPlanningController" type="CMIF_ShipPlanningController"/>
    </JadeMethod>
    <JadeMethod name="initRORO" id="df47e316-9b01-49ac-bc6d-fbb9436e0edc">
        <updating/>
        <source>initRORO(_slotRequest : CM_RORORequest; _cmifShipPlanningController : CMIF_ShipPlanningController) updating; 
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2008	cnwer1	Initial creation

*/

vars
	dPort : CM_Port;
begin
	self.myRORORequest:=_slotRequest;
	self.myCMIF_ShipPlanner:=_cmifShipPlanningController;
	
	// ### GET THE REQUEST DATA
	dPort := self.myRORORequest.getAttrDischargePort(); // PAR 27749
	if dPort &lt;&gt; null then
		self.dischPortCode := dPort.code;
	endif;
	self.commGrpCode := self.myRORORequest.getAutoLoadPlanCommodityCode();
	
	self.powerType := self.myRORORequest.getShipPlanningPowerType();
	self.length := self.myRORORequest.getActualLength().Integer; // 20 40 or 45
	self.height := self.myRORORequest.getAttrHiCubed().Integer; // zero or one

	/*
	if self.testHeavies then // if current job has no slots defined for heavies then ignore
		if self.myRORORequest.mySlotDefinition.heavy then
			self.weight := CMIF_ShipPlanningController.Req_Weight_Heavy;
		else
			self.weight := CMIF_ShipPlanningController.Req_Weight_Light;
		endif;
	else*/
		self.weight := 0;
	//endif;

	
	if self.myRORORequest.getAttrEmpty() then
		self.contentStatus := "MT";
	else
		self.contentStatus := "FULL";
	endif;
	
	self.isDLR := self.myRORORequest.isRehandle;
	
	self.selStatus := 0;
	
	
	self.taID := "";
	self.gridRowOrd := 0;
	self.gridColOrd := 0;
	

	self.getMatchingTIs();

epilog

end;</source>
        <Parameter name="_slotRequest" type="CM_RORORequest"/>
        <Parameter name="_cmifShipPlanningController" type="CMIF_ShipPlanningController"/>
    </JadeMethod>
    <JadeMethod name="removeNonPlannedTrackedItems" id="e1cd3437-d4a7-4e31-91a1-6d1e0dad8143">
        <source>removeNonPlannedTrackedItems(_plannedTI : CM_TrackedItem);
/*

Purpose:	we now	have the ti which is planned so delete the remaining CMIF_ShipPlanningTIs 
			and iter through all the other slot requests deleting CMIF_ShipPlanningTI with the 
			planned TI

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2009	cnwer1	Initial creation

*/

vars
	shipPlanningTI : CMIF_ShipPlanningTI;
	iter : Iterator;
	nextShipPlanningSlotRequest : CMIF_ShipPlanningSlotRequest;
begin
	iter:=self.myCMIF_ShipPlanner.allCMIF_PlanningSlotRequests.createIterator;
	iter.startAtObject(self);
	while iter.next(nextShipPlanningSlotRequest) do
		shipPlanningTI:=nextShipPlanningSlotRequest.allShipPlanningTIsByTI[_plannedTI];
		if shipPlanningTI = null then
			continue;
		endif;
		if nextShipPlanningSlotRequest = self then
			shipPlanningTI.setFailedForTwinLift(false);
			shipPlanningTI.setMyShipPlanSlotRequest(null);
			nextShipPlanningSlotRequest.allShipPlanningTIsByTI.purge;
			shipPlanningTI.setMyShipPlanSlotRequest(nextShipPlanningSlotRequest);
			continue;
		endif;
		
		
		delete shipPlanningTI;
	endwhile;
epilog
	delete iter;

end;</source>
        <Parameter name="_plannedTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyAftTwinCMIFPlanningSR" id="95e17218-ddb2-4bf6-93ab-082f96b0fde6">
