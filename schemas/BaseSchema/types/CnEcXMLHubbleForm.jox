    <JadeMethod name="btnExport_click" id="0499445c-0a76-4d32-9825-0667c7aa5aa2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExport_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.performExport();
	
	if lblInstruct.caption = "" then 
		lblInstruct.caption := "Export Complete. ";
		
		if txtLog.text &lt;&gt; "" then
			lblInstruct.caption := lblInstruct.caption &amp; CrLf &amp; "Please check '" &amp; txtLog.text &amp; "' for the results of the export.";
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
