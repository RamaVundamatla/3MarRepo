    <JadeMethod name="translateForm" id="c45d2513-2957-48dc-b582-abacabf21e1c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007778, locale);
	btnClose.translateCaption(Xlat_0000493, locale);
	btnJRWViews.translateCaption(Xlat_0000494, locale);
	btnLoadReport.translateCaption(Xlat_0000495, locale);
	btnLoadView.translateCaption(Xlat_0000496, locale);
	btnOpenReport.translateCaption(Xlat_0000497, locale);
	btnOpenView.translateCaption(Xlat_0000498, locale);
	lblReportFile.translateCaption(Xlat_0000499, locale);
	lblView.translateCaption(Xlat_0000500, locale);
end;</source>
    </JadeMethod>
</GUIClass>
