    <JadeMethod name="doAdd" id="438acc7d-d538-4706-8750-33717644ba8b">
        <updating/>
        <source>doAdd() updating, protected;
// 37434 need an Add here as well as in the CMUI_InvoiceFutureStorageMaps form to get the FIRST one created
// 37585 Show table again as it was, with selected Group or ALL
vars

begin
	self.myAssistant.showInvoiceFutureStorageMap(self.myStorageGroup, null, self.myStorageDetail, self.myStorageMapping);
	
	//self.loadStorageTable();						// PAR #27585
	self.cmbGroup_click(self.cmbGroup);				// PAR #27585
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddSub" id="ed8a5c85-2cff-4a3f-ae33-a646a20d2e72">
        <updating/>
        <source>doAddSub() updating, protected;
/*
Purpose:			

Date		Who		Reason
18MAY2023	NAVAB1	TFS CR 58022 TASK 58023
*/

vars
	parentMap : CM_QuantityMap;
begin
	if self.myQuantityRangeMap &lt;&gt; null then
		if self.myStorageMapping &lt;&gt; null then // SUB RANGE this is null for sub range
			parentMap := self.myQuantityRangeMap.myChildQuantityMap;
		endif;
	endif;
	self.myAssistant.showInvoiceFutureStorageSubMap(parentMap, self.myStorageGroup, self.myQuantityRangeMap,null, self.myStorageDetail, self.myStorageMapping);
	self.cmbGroup_click(self.cmbGroup);				// PAR #27585
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="e3590e4f-bfc3-4b0e-91e0-34226f3e0990">
        <updating/>
        <source>doDelete() updating, protected;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/03/2016	cnwdap1		PAR #37585 Allow delete when only default quantity range is present
//
vars
	desc	: String;
	error	: Boolean;
	theReturn : Integer;
begin
	if self.myQuantityRangeMap = null then
		return;
	endif;
	
	// TFS 7496
	if app.msgBox(app.getErrorString1(Please_confirm_deletion,self.myQuantityRangeMap.getFullName()), 
							app.getErrorString(Confirmation),
							MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	
	//if self.myStorageMapping.myQuantityMap.allQuantityRanges.size = 1 then		// PAR #37585
	//	return;																		// PAR #37585
	//endif;																		// PAR #37585
	
	while true do
		app.myTrxDA.trxDeleteInvoiceTMQtyRange(self.myQuantityRangeMap, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.myQuantityRangeMap := null;
			// show the table as it was, for selected group or ALL					// PAR #37585
			//self.loadStorageTable();												// PAR #37585
			self.cmbGroup_click(self.cmbGroup);										// PAR #37585
		else
			global.beep;
			theReturn := app.showErrorWarningDialog(app.getErrorString(Future_storage_mapping), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);

		endif;
		break;
	endwhile;
	
/* PAR 36275
	if self.myStorageMapping = null then
		return;
	endif;

	// ex handler just in case we're deleting this because the data is no good
	desc := "selected item";
	on Exception do app.handleDeletedObject(exception, self.myStorageMapping.myStorageGroup, error);
	desc := self.myStorageMapping.myStorageGroup.code;
	// ask for confirmation of delete
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, desc), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;

	self.doSave(self.Mode_Delete);
	*/
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEdit" id="f0cf4a19-f5b0-4ba2-8da3-88aefdb7637e">
        <updating/>
        <source>doEdit() updating, protected;

vars
	storageGroup	: CM_TerminalAreaStorageGroup;
begin

	if self.myQuantityRangeMap = null then
		return;
	endif;
	
	// 37434 get storage group from combo or from selected item
	storageGroup := self.myStorageGroup;
	if storageGroup = null then
		if self.myStorageMapping &lt;&gt; null then
			storageGroup := self.myStorageMapping.myStorageGroup;
		endif;
	endif;

	if self.myQuantityRangeMap.myQuantityMap.myFutureStorageMap &lt;&gt; null then
		self.myAssistant.showInvoiceFutureStorageMap(storageGroup, self.myQuantityRangeMap, self.myStorageDetail, self.myStorageMapping); // PAR 36275
	else // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
 		self.myAssistant.showInvoiceFutureStorageSubMap(self.myQuantityRangeMap.myQuantityMap, self.myStorageGroup, self.myQuantityRangeMap,self.myQuantityRangeMap, self.myStorageDetail, self.myStorageMapping);
	endif;
	//  show the table again as it was
	self.cmbGroup_click(self.cmbGroup);
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNoMaintPermDisableControls" id="4774cbcd-3108-4589-9ec6-202bcd3611ba">
        <source>doNoMaintPermDisableControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin
	
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.btnAdd.enabled := false;
	self.btnDelete.enabled := false;
	self.btnEdit.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblRowColumnChg" id="8b882c95-5cd3-4c9f-8064-7078cdd0074e">
        <updating/>
        <source>doTblRowColumnChg() updating, protected;

vars
	table	: CM_DataTable;
	qrm : CM_QuantityRangeMap;
begin
	table := self.tblGroups;
	if table.row &gt; table.fixedRows then
		qrm := table.accessRow(table.row).itemObject.CM_QuantityRangeMap;
		self.myQuantityRangeMap := qrm;
		
		self.myStorageMapping := qrm.myQuantityMap.myFutureStorageMap;
		
		// ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
		if self.myStorageMapping = null then
			if qrm.isSubRange() then
				self.myStorageMapping := qrm.myQuantityMap.myParentFinancialObject.CM_QuantityRangeMap.myQuantityMap.myFutureStorageMap;
			endif;
		endif;
		if self.myStorageMapping &lt;&gt; null then // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
			self.myStorageGroup := self.myStorageMapping.myStorageGroup;		// 37434 set it here to allow Add when showing items for All groups
		endif;
	endif;
	
	//19 Dec 2017	NDL	TFS 8095
	self.btnAudits.enabled := self.myQuantityRangeMap &lt;&gt; null and self.myQuantityRangeMap.hasAudits;	//14 Jan 2021	NDL	TFS 50152

	self.btnAddSub.enabled :=  self.myQuantityRangeMap &lt;&gt; null and not self.myQuantityRangeMap.isSubRange(); // ### TFS CR 58022 TASK 58023 31MAY2023 NAVAB1
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="85135b87-3982-421f-b329-d8a9f4c3c266">
        <updating/>
        <source>loadCombos() updating, protected;
// populate storage group and invoice line type combos
vars
	combo	: CMUI_ComboBox;
	calcType			: CM_CalculationType;
	storageGroup		: CM_TerminalAreaStorageGroup;
	invLineDesc			: CM_InvoiceLineDesc;
begin
	combo := self.cmbGroup;
	combo.clear();
	combo.itemObject[combo.addItem(" ALL ")] := null;		// 37434 add an ALL option and show this first
	foreach storageGroup in self.myTerminal.allTerminalAreaStorageGroups do
		combo.itemObject[combo.addItem(storageGroup.code)] := storageGroup;
	endforeach;
	
	if combo.listCount &gt; 0 then
		if combo.listCount = 2 then // TFS 5225
				combo.listIndex := 2; // TFS 5225
		else
			combo.listIndex := 1;
		endif;
		self.myStorageGroup := combo.listObject.CM_TerminalAreaStorageGroup; // PAR 36275
		self.loadStorageTable(); // PAR 36275
	endif;
// PAR 36275 removes code using invoice line types
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadQuantityRangeMap" id="546bd427-fb08-4267-8e78-c7b9d2e4ec0f">
        <source>loadQuantityRangeMap(_qrm : CM_QuantityRangeMap; _mapping	: CM_FutureStorageMapping);
/*
Purpose:			

Date		Who		Reason
31 May 2023	navab1	TFS CR 58022 TASK 58023
*/

vars
	row : Integer;
	table	: CM_DataTable;
	mapping	: CM_FutureStorageMapping;
	qrm, subqrm : CM_QuantityRangeMap;
begin
	qrm := _qrm;
	mapping := _mapping;
	
	table := self.tblGroups;

	if qrm.myChildQuantityMap = null then
		row := table.addItem(mapping.myStorageGroup.code &amp; Tab &amp; qrm.getFullName());
		table.accessRow(row).itemObject := qrm;

	else
		row := table.addItem(mapping.myStorageGroup.code &amp; Tab &amp; qrm.getName());
		table.accessRow(row).itemObject := qrm;
		foreach subqrm in qrm.myChildQuantityMap.allQuantityRanges discreteLock do
			row := table.addItem(Tab &amp; "&gt;&gt;&gt; " &amp;  subqrm.getFullName());
			table.accessRow(row).itemObject := subqrm;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_qrm" type="CM_QuantityRangeMap"/>
        <Parameter name="_mapping" type="CM_FutureStorageMapping"/>
    </JadeMethod>
    <JadeMethod name="loadStorageTable" id="4057a803-22ed-48d9-bf06-4904e15eb04b">
        <updating/>
        <source>loadStorageTable() updating, protected;
// 37343 only show the details for the current group unless 'ALL' groups is selected
vars
	row		: Integer;
	table	: CM_DataTable;
	mapping	: CM_FutureStorageMapping;
	qrm, subqrm : CM_QuantityRangeMap;
begin
	
	self.myQuantityRangeMap := null;
	
	table := self.tblGroups;
	
	table.selectMode := Table.SelectMode_CurrentRow;
	table.rows := 0;
	table.addItem(app.getErrorString(Storage_group)&amp; Tab &amp; app.getErrorString(Invoice_line_mappings));
	table.fixedRows := 1;
 // PAR 36275	if self.myStorageDetail &lt;&gt; null then
 // PAR 36275		foreach mapping in self.myStorageDetail.allFutureStorageMappings do
	if self.myStorageGroup &lt;&gt; null then
	// only show the mappings for the current storage detail
		foreach mapping  in self.myStorageGroup.allFutureStorageMappings discreteLock do
			if mapping.myStorageDetail = self.myStorageDetail then
				foreach qrm in mapping.myQuantityMap.allQuantityRanges discreteLock do
					 // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
					 self.loadQuantityRangeMap(qrm, mapping);
					 /*
					if qrm.myChildQuantityMap = null then
						row := table.addItem(mapping.myStorageGroup.code &amp; Tab &amp; qrm.getFullName());
						table.accessRow(row).itemObject := qrm;

					else
						row := table.addItem(mapping.myStorageGroup.code &amp; Tab &amp; qrm.getName());
						table.accessRow(row).itemObject := qrm;
						foreach subqrm in qrm.myChildQuantityMap.allQuantityRanges discreteLock do
							row := table.addItem(Tab &amp; "&gt;&gt;&gt; " &amp;  subqrm.getFullName());
							table.accessRow(row).itemObject := subqrm;
						endforeach;
					endif;
					*/
				endforeach;
			endif;
		endforeach;
	else
		// for the ALL option, show details for all storage groups
		foreach mapping in self.myStorageDetail.allFutureStorageMappings do
			foreach qrm in mapping.myQuantityMap.allQuantityRanges discreteLock do
				 // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
				 self.loadQuantityRangeMap(qrm, mapping);
				 /*
				row := table.addItem(mapping.myStorageGroup.code &amp; Tab &amp; qrm.getFullName());
				table.accessRow(row).itemObject := qrm;
				*/
			endforeach;
		endforeach;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
