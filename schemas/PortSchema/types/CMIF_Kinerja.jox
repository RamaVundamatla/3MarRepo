    <JadeMethod name="setSTApproachTM" id="f7edd9c0-6df0-4983-ab51-7cc9ec66f1ae">
        <updating/>
        <source>setSTApproachTM(_movement : HMS_Movement):Real updating;
/*

Purpose:			
	1.C	Approach Time ( AT )
		The number of hours a vessel is used during the move from the location of the anchor drop and / or pilot to board the vessel 
		until the tying of the rope at the first line and timer 
		for the exiting vessel to start releasing rope (last rope) until the pilot goes down on the outer threshold
		AT = (tying of rope until pilot goes up) + (Releasing of rope until the pilot goes down)
		&gt;&gt; Pilot Finish Move - Pilot Actual
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
04 Apr 2019	jlggb1	New approach to approach times
*/

vars
	aT : Real;
	
	followingMove : HMS_Movement;
	previousMove : HMS_Movement;
	
begin
	
	if self.isToPhysical(_movement) then //Only real berths get reported on
		aT := self.getATForAMovement(_movement);
		
		previousMove := _movement.myPreviousMovement; //Attach any immediately previous movements to logical berths e.g. SEA or ANCHORAGE
		while previousMove &lt;&gt; null and self.isToLogical(previousMove) do
			aT := aT + self.getATForAMovement(previousMove);
			previousMove := previousMove.myPreviousMovement;
		endwhile;
		
		if self.isLastPhysicalMovement(_movement) then // If there are any following logical movementns that wont be accounted for 
			followingMove := _movement.myNextMovement;
			while followingMove &lt;&gt; null do
				aT := aT + self.getATForAMovement(followingMove);
				followingMove := followingMove.myNextMovement;
			endwhile;
		endif;
	endif;
	
	if self.approachTM = null then
		self.approachTM := aT;
	endif;
	
	return aT;

end;
</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setSTBerthTMAndRealization" id="d4c06bf7-35ef-44e8-a5af-ae9f361260ad">
        <updating/>
        <source>setSTBerthTMAndRealization(_movement : HMS_Movement):Real updating;
/*

Purpose:			
	1.H Berthing Time (BT)
		The number of hours a vessel has been in the mooring since tying of the first line to the dock until releasing of the last line from the dock.
		BT=The total hours one ship from the first mooring rope to the last mooring rope 
		BT=BWT+NOT
		&gt;&gt; Only if wharf is physical  CurrentMove.PilotStartMove - PrevMove.MovementActual
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
21 Jan 2018 cnwma1	Bug 42895: PEL1 - Kinerja Change for fields
*/

vars
	bT : Real;
	servTmMove,
	servTmMoveNext : HMS_MarineServicesTimings;
	moveNext       : HMS_Movement;
	totalTeu       : Real;
	moveTrans      : CM_ObjectArray;
	
begin
	servTmMove := _movement.myMarineServiceTimings;
	
	if servTmMove &lt;&gt; null then
		moveNext := _movement.myNextMovement;
		if moveNext &lt;&gt; null then
			if moveNext.myMarineServiceTimings &lt;&gt; null then
				servTmMoveNext :=  moveNext.myMarineServiceTimings;
					bT:= servTmMove.movementBerthArrival.differenceInHoursReal(servTmMoveNext.movementActualTS);				
					
					//21.01.2019 cnwma1 Bug #42895
					if bT &lt;&gt; null then
						create moveTrans transient;
						moveTrans := self.getTransactionsPerMovement(_movement);
						totalTeu := self.getTotalContainers(moveTrans);
						if totalTeu &lt;&gt; 0 then
							self.realization := totalTeu/bT;
						endif;
					endif;
			endif;
		endif;
	endif;

	if self.berthTM = null then
		self.berthTM := bT;
	endif;
	return bT;
epilog
	delete moveTrans;
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setSTBerthWorkingTM" id="d89dc8af-f2f1-4d22-af42-d14dd508753a">
        <updating/>
        <source>setSTBerthWorkingTM(_movement : HMS_Movement):Real updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Dec 2018	jlgma1	Initial creation
26 Apr 2019 jlggb1  43211 Failure to produce NOT times correctly
10 May 2019 jlggb1  44699 NOT delays while operational 

*/

vars
	bwt,
	bwTMove,
	bwTTmp,
	bwTHold,
	
	idleMove,
	idleTmp,
	idleHold,
	
	eTMove,
	etHold,
	eTTemp,
	
	noTMove,
	noTTmp,
	noTHold 			: Real;
	

	prodctivMove,
	prodctivHold,
	prodctivHoldTmp       : Real;
	
	prodLiqMove,
	prodLiqHold,
	prodLiqHoldTmp       : Real;
	
	prodContMove,
	prodContHold,
	prodContHoldTmp       : Real;
	
	noTTOutTmp1,
	noTTOutTmp2,
	noTOutMove 			: Real;
	
	servTmMove,
	servTmMoveNext,
	servTmMovePrev 		: HMS_MarineServicesTimings;
	
	movePrev,
	moveNext	  		: HMS_Movement;
	
	delayBwT,
	delayIdle,
	delayNoT       		: CM_Delay;

	workingHoldsCnt,
	workingHoldsCntMove : Integer;
	firstOpDelay,
	lastOpDelay,
	delay    			: CM_Delay;
	bwTLen ,
	idleLen,
	noTLen 				: Integer;
	lastDT 				: TimeStamp;
	cargoType           : CM_CargoType;
	moveTrans           : CM_ObjectArray;
begin
	
	write "Start*********************************************************"&amp; _movement.moveType &amp; "********************************************************";
	//Physical Berths only
	if self.isToLogical(_movement) then
		return 0;
	endif;
	
	create moveTrans transient;
	moveTrans 	   := self.getTransactionsPerMovement(_movement);
	servTmMove     := _movement.myMarineServiceTimings;
	moveNext       := _movement.myNextMovement;
	if moveNext &lt;&gt; null then
		servTmMoveNext :=  moveNext.myMarineServiceTimings;
	endif;
	if servTmMoveNext = null then
		return bwt;
	endif;
	
	foreach delayBwT in _movement.getMyVoyage.allDelays do
		bwTLen   := delayBwT.getDescription(true).length;
		bwTHold  := 0;
		idleHold := 0;
		noTHold  := 0; 
		etHold   := 0;
		prodctivHold := 0;
		
		if delayBwT.getDelayTypeGroupDesc = "STARTENDOPR" then //Start of operations on a Hold
			if delayBwT.startDT &gt;= _movement.occursOnDTNEW  and delayBwT.endDT &lt;= servTmMoveNext.pilotStartsMoving then
				write delayBwT.getDescription(true) &amp; Tab &amp; "Start: " &amp; delayBwT.startDT.String &amp; Tab &amp; "End: "   &amp; delayBwT.endDT.String;
				
				/*************BWT******************/
				if self.doesTransactionExistForHold(delayBwT.startDT ,delayBwT.endDT) then
					workingHoldsCnt :=  self.getWHoldsCount(_movement,_movement.occursOnDTNEW,servTmMoveNext.pilotStartsMoving);       //04.03.2019 cnwma1
					write delayBwT.getDescription(true) &amp; Tab &amp;  "HoldCnt :"   &amp; workingHoldsCnt.String;
					bwTTmp  := delayBwT.endDT.differenceInHoursReal(delayBwT.startDT);	
					bwTHold := bwTHold + bwTTmp;
				endif;
				
				/*************Idle******************/
				foreach delayIdle in _movement.getMyVoyage.allDelays discreteLock do
					if delayIdle.getDelayTypeGroupDesc &lt;&gt; "IDLE_DELAY" then 
						continue;
					endif;
					//Check Idle Delay is for the hold we are working
					idleLen := delayIdle.getDescription(true).length;
					if delayIdle.getDescription(true)[idleLen-2:idleLen] &lt;&gt;  delayBwT.getDescription(true)[bwTLen-2:bwTLen]  then 
						continue;
					endif;
					// Add this Idle Delay if it occurs within the time we are working the hold
					if delayIdle.startDT &gt;= delayBwT.startDT and delayIdle.endDT &lt;= delayBwT.endDT then
						idleTmp := delayIdle.endDT.differenceInHoursReal(delayIdle.startDT);	
						idleHold := idleHold + idleTmp;
					endif;
				endforeach;
				
				/*************NOT******************/
				foreach delayNoT in _movement.getMyVoyage.allDelays discreteLock do
					if delayNoT.getDelayTypeGroupDesc &lt;&gt; "NOTOPERATION_DELAY" then
						continue;
					endif;
					// Check NOT delay is for the hold we are working
					noTLen := delayNoT.getDescription(true).length;
					if 	delayNoT.getDescription(true)[noTLen-2:noTLen] &lt;&gt;  delayBwT.getDescription(true)[bwTLen-2:bwTLen]  then 
						continue;
					endif;
					// Add this NOT Delay if it occurs within the time we are working the hold 
					if delayNoT.startDT &gt;= delayBwT.startDT and delayNoT.endDT &lt;= delayBwT.endDT then
						noTTmp := delayNoT.endDT.differenceInHoursReal(delayNoT.startDT);	
						noTHold := noTTmp + noTHold ;
					endif;
				endforeach;
				
				etHold := bwTHold - (idleHold + noTHold);
				write Cr;
				write delayBwT.getDescription(true) &amp; Tab &amp; "Hold Bwt :"   &amp; bwTHold.String;
				write delayBwT.getDescription(true) &amp; Tab &amp; "Hold Not :"   &amp; noTHold.String;
				write delayBwT.getDescription(true) &amp; Tab &amp; "Hold Idle : " &amp; idleHold.String;
				write delayBwT.getDescription(true) &amp; Tab &amp; "Hold ET :    " &amp; etHold .String;
				write Cr;
				
				prodctivHoldTmp   := self.setMainProductivities(moveTrans,CMIF_Kinerja.PRODUKTIVITAS,_movement,delayBwT,delayBwT.startDT,delayBwT.endDT,etHold);
				prodctivHold      :=  prodctivHold + prodctivHoldTmp;
				write delayBwT.getDescription(true) &amp; Tab&amp; "Hold Productvitas : " &amp; prodctivHold.String;
				
				prodLiqHoldTmp   := self.setMainProductivities(moveTrans,CMIF_Kinerja.PROD_LIQUID_BULK,_movement,delayBwT,delayBwT.startDT,delayBwT.endDT,etHold);
				prodLiqHold      :=  prodLiqHold + prodLiqHoldTmp;
				write delayBwT.getDescription(true) &amp; Tab&amp; "Hold Liquid : " &amp; prodLiqHold.String;
				
				prodContHoldTmp   := self.setMainProductivities(moveTrans,CMIF_Kinerja.PROD_CONTAINER,_movement,delayBwT,delayBwT.startDT,delayBwT.endDT,etHold);
				prodContHold      :=  prodContHold + prodContHoldTmp;
				write delayBwT.getDescription(true) &amp; Tab&amp; "Hold Container : " &amp; prodContHold.String;
				
				
			endif;
			
			/*************Out Delay Before******************/
			if noTTOutTmp1 = null then
				foreach delay in _movement.getVoyage.allDelays do 
					if  delay.getDelayTypeGroupDesc &lt;&gt; "STARTENDOPR" then
						continue;
					endif;
					
					//if delay.startDT &gt;= 	servTmMove.movementBerthArrival then
					if delay.startDT &gt;= 	_movement.occursOnDTNEW then
						firstOpDelay := delay;
						write firstOpDelay.getDescription(true) &amp; Tab &amp; "FirstOpsDelay";
						break;
					endif;
		
				endforeach;
				
				if firstOpDelay &lt;&gt; null then
					noTTOutTmp1 :=  servTmMove.movementBerthArrival.differenceInHoursReal(firstOpDelay.startDT); //##### jlggb1 Is this right?
					//noTTOutTmp1 :=  _movement.occursOnDTNEW.differenceInHoursReal(firstOpDelay.startDT);
					write firstOpDelay.getDescription(true) &amp; Tab&amp; "First Out Not" &amp; Tab &amp; noTTOutTmp1.String; 
				endif;
			endif;
			
			/*************Out Delay After******************/
			if noTTOutTmp2 = null then
				lastDT := null;
				foreach delay in _movement.getVoyage.allDelays  do 
					if  delay.getDelayTypeGroupDesc  &lt;&gt; "STARTENDOPR" then
						continue;
					endif;
					//if delay.startDT &lt; servTmMove.movementBerthArrival then
					if delay.startDT &lt; _movement.occursOnDTNEW then
						continue;
					endif;
					
					//if delay.endDT &gt; servTmMoveNext.movementActualTS then
					if delay.endDT &gt; servTmMoveNext.pilotStartsMoving then
						continue;
					endif;
					if lastDT.isValid then
						if lastDT &gt; delay.endDT then
							break;
						endif;
					endif;
					
					lastOpDelay := delay;
					lastDT := lastOpDelay.endDT;
				endforeach;
				
				if lastOpDelay &lt;&gt; null then
					//noTTOutTmp2 :=  lastOpDelay.endDT.differenceInHoursReal(servTmMoveNext.movementActualTS);
					noTTOutTmp2 :=  lastOpDelay.endDT.differenceInHoursReal(servTmMoveNext.pilotStartsMoving);
					write lastOpDelay.getDescription(true) &amp; Tab&amp; "Last Out Not" &amp; Tab &amp; noTTOutTmp2.String; 
				endif;
			endif;
			
		endif;
		eTMove   	 := eTMove   + etHold;
		bwTMove  	 := bwTMove  + bwTHold;
		noTMove  	 := noTMove  + noTHold;
		idleMove 	 := idleMove + idleHold;
		prodctivMove := prodctivMove + prodctivHold;
		prodLiqMove  := prodLiqMove  + prodLiqHold;
		prodContMove := prodContMove + prodContHold;
		
		if workingHoldsCnt &gt;0 then
			self.berthWorkingTM := bwTMove/workingHoldsCnt;
			self.notOperationTM := (noTMove/workingHoldsCnt)+ noTTOutTmp1+noTTOutTmp2; 
			self.idleTM         := idleMove/workingHoldsCnt;
			self.effectiveTM    := eTMove/workingHoldsCnt;					
			self.prodLiquid     := prodLiqHold /workingHoldsCnt;
			self.productivitas  := prodctivMove / workingHoldsCnt;
			//self.prodContainer  := prodContMove / workingHoldsCnt;
			
			if self.prodContainer &gt; 0 and  self.productivitas &gt; 0 then                 //27.02.2019 cnwma1 #43211
				self.productivitas := (self.prodContainer + self.productivitas)/2;
			endif;
		endif;
	endforeach; //bWT Delay
	
	write Cr;
	write Cr;
	if workingHoldsCnt &gt;0 then //jlggb1	9/4/2019 Bug from 43211 ref SC 
		//self.notOperationTM := (noTMove/workingHoldsCnt)+ noTTOutTmp1+noTTOutTmp2; 
		self.prodContainer  := prodContHold / workingHoldsCnt;
	endif;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   Move BT   :  " &amp; Tab &amp; self.berthTM.String;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   Move BWT  :  " &amp; Tab &amp; self.berthWorkingTM.String;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   Move Idle :  " &amp; Tab &amp; self.idleTM.String;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   Move ET   :  " &amp; Tab &amp; self.effectiveTM.String	;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   Move NOT  :  " &amp; Tab &amp; self.notOperationTM.String	;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   Move Hold :  " &amp; Tab &amp; workingHoldsCnt.String	;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   ApproceTM :  " &amp; Tab &amp; self.approachTM.String	;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   Prodcivitas: " &amp; Tab &amp; self.productivitas.String	;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   Prod Liq:    " &amp; Tab &amp; self.prodLiquid.String	;
	write _movement.moveType &amp;Tab&amp; _movement.getMyBerth.description  &amp;Tab &amp; "   Prod Cont:   " &amp; Tab &amp; self.prodContainer.String	;
	write "End*********************************************************"&amp; _movement.moveType &amp; "********************************************************";
	
	return bwt;
epilog
	delete moveTrans;
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setSTPostponeTM" id="a8a369e1-5ccd-48fe-8f61-8ce1855c56d5">
        <updating/>
        <source>setSTPostponeTM(_movement : HMS_Movement):Real updating;
/*

Purpose:
	1.B	Postpone Time ( PT )
		Delayed time which is not beneficial as long as the vessel is at the location of the anchor and / or harbor pool under the whim of the ship / external party.
		PT =TRT-(BT+AT+WT)
		Postpone time includes 
		a.	Waiting time of orders from Ship owner or Cargo owner;
		b.	Waiting time for Cargo loading;
		c.	Waiting time for document ;
		d.	Waiting time for sea tide ;
		e.	Waiting time for water bunker or fueling;
		f.	Waiting time for maintenance ;
		g.	Waiting time for inspection and screening check by other party;
		h.	Waiting time for any other caused by external parties.
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
16 Apr 2019 jlggb1	Clarification from Kevin (Pel1)
*/

vars
	move : HMS_VoyageMovement;
	pt,tmpBT,
	tmpAT,aT,
	bT,
	wTPilot,	
	tmpWTPilot	:Real;
begin
	
	if self.isFirstPhysicalMovement( _movement ) then // 16.4.19 jlggb143211 On arrival of BRD 
		foreach move in self.myVoyage.myHMSVoyageData.allVoyageMovements discreteLock do
			/* 1.H Berthing Time (BT) */
			tmpBT := self.setSTBerthTMAndRealization(move);
			bT    := tmpBT + bT;
			
			/* 1.C	Approach Time ( AT ) */
			tmpAT := self.setSTApproachTM(move);
			aT :=tmpAT + aT;
			
			/*1.A	Waiting Time of pilot */
			tmpWTPilot := self.setSTWaitingPilotTM(move);
			wTPilot := tmpWTPilot + wTPilot;
		endforeach;
		
		/*PT =TRT-(BT+AT+WT)*/
		pt := self.turnRoundTM - (bT + aT + wTPilot);
	endif;	
	
	self.postPoneTM := pt;
	return pt;

epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setSTTurnRoundTM" id="d9c35d7f-e93c-4706-9504-68c15c6f3bd3">
        <updating/>
        <source>setSTTurnRoundTM(_movement : HMS_Movement):Real updating;
/*

Purpose:			
	1.I Turn Round Time ( TRT )
	The number of hours where the vessel stays at the port, Calculated from the arrival of vessel (Time Arrival) at the anchorage area until
	the deportation of the vessel from the location of the anchorage leg or the vessel's pilot has went down.
	&gt;&gt; Only for Deoarture  move.PilotOFFBoard - Voyage.Arrival
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
16 Apr 2019 jlggb1	43211 Changes relating to the arrival of a BRD
*/

vars
	tRT 			  : Real;
begin
	if self.isFirstPhysicalMovement(_movement) then
		tRT:= self.myVoyage.arrivedDT.differenceInHoursReal(self.myVoyage.departedDT);
	endif;
	self.turnRoundTM := tRT;
	return tRT;
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setSTWaitingDermagaTM" id="cebbc83e-36c0-46a2-9b5e-bc3a9e4dd621">
        <updating/>
        <source>setSTWaitingDermagaTM(_movement : HMS_Movement):Real updating;

/*

Purpose:			
	
	1.B	Waiting Time at Dermaga
	The time difference between service request time of the vessel entering waveguide pilot on board (POB) and assignment time of the vessel service in pilot on board (POB).
	Always Zero
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
*/


vars
	wTDermaga	:Real;
begin
	self.waitingDermagaTM   := 0; 
	return wTDermaga;
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setSTWaitingPilotTM" id="01add3a5-ea48-4438-b2b4-30e75ccfb66c">
        <updating/>
        <source>setSTWaitingPilotTM(_movement : HMS_Movement ):Real updating;
/*

Purpose:			
	1.A	Waiting Time of pilot
	The time difference between timing of pilot service assignment on board (POB) with service realization of pilot on board (POB)
	Only for Arrival Moves &gt;&gt; PilotActual - PilotApprove
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
16 Sep 2019 jlggb1  43211 Changes in BRD.
*/


vars
	wTPilot			  :Real;
	hmsMarinrServTime : HMS_MarineServicesTimings;
	move : HMS_Movement;
begin
	if self.isFirstPhysicalMovement( _movement) then
		move := _movement;
		while move &lt;&gt; null and move.moveType &lt;&gt; HMSMovementTypeArrival do
			move := move.myPreviousMovement;
		endwhile;
		if move &lt;&gt; null then
			hmsMarinrServTime := move.myMarineServiceTimings;
			if hmsMarinrServTime &lt;&gt; null then
				wTPilot := hmsMarinrServTime.pilotApprovedTS.differenceInHoursReal(hmsMarinrServTime.pilotActualTS);
			endif;
			if self.waitingPilotTM = null then
				self.waitingPilotTM := wTPilot;
			endif;
		endif;
	endif;

	return wTPilot;
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setSTeTbT" id="1a607e4c-3983-49b0-903b-ff468fbcc41c">
        <updating/>
        <source>setSTeTbT(_movement : HMS_Movement):Real updating;

/*

Purpose:			
	The Working Time section of the Vessel at Berth ( ET/BT )
	Is the comparison of time between the vessel working effectively (Effective Time) with the overall berthing time of the vessel.

	ET/BT=(Efective Time (ET))/(Berthing Time (BT) ) x 100
Parameters:			

Return Value:		

	

Date		Who		Reason
31 October 2018	jlgma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars
	eTbT : Real;
begin
	
	if self.effectiveTM  &gt; 0 and self.berthTM &gt; 0 then
		eTbT := self.effectiveTM /self.berthTM *100;
	endif;
	self.etBT := eTbT;
	
	return eTbT;
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setUTBerthOccupancyRatio" id="4022eb2a-8ae5-4983-9d90-df2bc2f7bda1">
        <updating/>
        <source>setUTBerthOccupancyRatio(_movement : HMS_Movement ;_period : Integer):Real updating;
/*

Purpose:			
	2.A	Berth Occupancy Ratio (BOR)
	Ratio between the amount of usage of each dock available and the time available in a period expressed 
	as a percentage (%) distinguished by the type of dock or mooring:
	
	1)	BOR Jetty (Jt) for docks split over several moorings, the moorings are not affected by the length of the vessel
		BOR jt=(The total berth time of the entire vessel in one period)/(Available time in one period) x 100%
	2)	BOR Continues for berths that are not divided under several continues berths, 
		the mooring is calculated based on the length of the vessel plus 5 meters as the front and rear safety.	
		BOR=((n Call x (~~  LOA+5))x (x ?  Berthing Time))/(Berth length x available time in the periode) x 100%
		OR
		BOR=(Sum ( LOA+5))x (Berthing Time))/(Berth length x available time in one period) x 100%
	3)	BOR Susun Sirih (SS), docks used for betel stacking, the length calculated does not follow the length of the vessel, but follows the length of the dock used.
		BOR SS=(SUM(Width of vessel x Berthing Time))/(Berth Lenght  x Available time in one periode) x 100%
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/


vars
	bOR : Real;
	voyage : CM_Voyage;
begin
	voyage := _movement.getMyVoyage;

	if not _movement.getMyWharf.isLogicalWharf then
		if self.berthTM &gt; 0 and _period &gt; 0 then
			bOR := (((((voyage.myHMSVoyageData.dim_LengthOverall +5) * self.berthTM ) / _movement.getMyBerth.length)/_period )/24)*100;
			write "LOA : " &amp;  voyage.myHMSVoyageData.dim_LengthOverall.String &amp;" Berth TM : " &amp; self.berthTM.String &amp; " Berth Length : "&amp; _movement.getMyBerth.length.String &amp;" Period : " &amp;_period.String; 
		endif;
	endif;

	self.berthOccupancyRatio := bOR;
	return bOR;
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_period" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setUTBerthThroughPut" id="fe0e256b-cbbc-4a76-b07c-7755d191ce0b">
        <updating/>
        <source>setUTBerthThroughPut(_movement : HMS_Movement)updating;
/*

Purpose:			
	2.B	Berth  Through Put  ( BTP )
	The tonnes of goods on a conventional dock or the number of TEU containers at a container wharf in a period 
	that passes every meter (m) available dock (ton / m or teus / m).
	BTP=(Total Ton or Teus in one period )/(Length of Berth available)
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars
	bTPContainer,
	bTPNonContainer	: Real;
	totCargo,totTeu : Real;
	berth 			: HMS_Berth;
	berthLen 		: Integer;
	idxCont,
	idxNonCont      : Integer;
begin
	berth 	 := _movement.getMyBerth;
	berthLen := berth.length;
	
	totTeu := self.getTotalWTAtBerth(_movement,self.BTP_CONTAINER);
	if totTeu &gt; 0 then
		bTPContainer := totTeu/berthLen;
		idxCont := 1;
		write "Berth Length : " &amp; berthLen.String &amp; " BTP  Container: " &amp; bTPContainer.String;
	endif;
	
	
	totCargo := self.getTotalWTAtBerth(_movement,self.BTP_NONCONTAINER);
	if totCargo &gt; 0 then
		bTPNonContainer := (totCargo/1000)/berthLen;
		idxNonCont := 1;
		write "Berth Length : " &amp; berthLen.String &amp; " BTP NON Container: " &amp; bTPNonContainer.String;
	endif;
	
	if idxCont &gt; 0 then
		self.berthThroughPut := bTPContainer;
	endif;
		
	if idxNonCont &gt; 0 then
		self.berthThroughPut := bTPNonContainer;
	endif;
	if idxCont + idxNonCont = 2 then
		self.berthThroughPut := (bTPContainer + bTPNonContainer )/2;
	endif;
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="setUTShedOccupancyRatio" id="818eeb21-b29d-42a7-a45b-762cf52cec26">
        <updating/>
        <source>setUTShedOccupancyRatio():Real updating;
/*

Purpose:			
	2.C	Shed Occupancy Ratio  ( SOR )
	SOR is a ratio between the amount of warehouse space usage calculated in units of ton per day or units of m3 per day 
	and the effective capacity of the buildup available in one period.
	SOR=(Ton?M^3  of Goods x Days (Dwelling Time))/(Effective Stack Capacity  (Ton or M^(3 ) )x periode) x 100%
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
21 Jan 2019 cnwma1	Bug 42895: PEL1 - Kinerja Change for fields
12 Feb 2019 cnwma1	Bug 43211: PEL1 - Kinerja Issues/Changes
*/

vars
	sOR,
	tmpsOR,
	sORTermArea 	: Real;
	termGrp 		: CM_TerminalAreaStorageGroup;
	termArea 		: CM_TerminalArea;
	totWt,tmpWT     : Real;
	cargo    		: CM_TrackedItem;
	cntTermArea 	: Integer;
	lc          	: CM_LocationsController;
	gcMaxCapcity     : Real;
begin
	termGrp := self.myTerminal.allTerminalAreaStorageGroups["Gudang"];
	
	if termGrp &lt;&gt; null then
		foreach termArea in termGrp.allTerminalAreas discreteLock do
			totWt := 0;
			tmpsOR:= 0;
			foreach lc in termArea.allLocationsControllers do
				foreach cargo in lc.allTrackedItems do
					if cargo.isContainer then
						continue;
					endif;
					
					tmpWT := 0;
					
					tmpWT := cargo.totalWeight/1000;
					totWt := totWt + tmpWT;	
				endforeach;
			endforeach;
			
			if totWt &lt;&gt; null then
				cntTermArea := cntTermArea +1;
				tmpsOR 		:= (totWt/ self.getMaxCapcity(termArea)) *100;
				sORTermArea := tmpsOR + sORTermArea;
				write "Term Area : " &amp; termArea.id &amp; " " &amp; "Max Capacity:" &amp;self.getMaxCapcity(termArea).String &amp; " " &amp; 
				      "Total Weight :" &amp; totWt.asStringJMT &amp; " " &amp; "TA SOR : " &amp; tmpsOR.String ;
			endif;
			
		
		endforeach;
	endif;
	
	if sORTermArea &gt; 0 and cntTermArea &gt; 0 then
		sOR := (sORTermArea/cntTermArea) ;
		write "Total Teminal Areas : " &amp; cntTermArea.String &amp; " " &amp; "Total TAs SOR : " &amp;sORTermArea.String;
		write "Final SOR : " &amp; sOR.String;
	endif;
	
	self.shedOccupancyRatio := sOR;
	
	return sOR;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setUTYardOccupancyRatio" id="1276e559-6984-4db5-b878-3155c55b1ae1">
        <updating/>
        <source>setUTYardOccupancyRatio():Real updating;
/*

Purpose:			
	2.E	Yard Occupancy Ratio ( YOR )
	Ratio between the usage of the stacking yard calculated in units of ton per day or m3 per day or TEUs per day 
	with the effective capacity of the stacking yard available in one period.
	YOR=(Ton/M^3/Teus  x Day (dwelling Time))/(Effective Yard capacity in Ton/M^2/Teus x Periode) x100%
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
21 Jan 2019 cnwma1`	Bug 42895: PEL1 - Kinerja Change for fields
12 Feb 2019 cnwma1	Bug 43211: PEL1 - Kinerja Issues/Changes
*/
vars
	termGrp  		: CM_TerminalAreaStorageGroup;
	termArea 		: CM_TerminalArea;
	cargo    		: CM_TrackedItem;
	yOR,
	tmpYorLapangan,
	yorLapangan,
	tmpYorCY,
	yorCY,
	totWt,
	tmpWT,
	tmpTeu,
	totTeu	 		: Real;
	cntTALapangan,
	cntTACy	 		: Integer;
	lc       		: CM_LocationsController;
	gcMaxCapcity	: Real;
	idxLap,idxCy    : Integer;
begin
	termGrp := self.myTerminal.allTerminalAreaStorageGroups["Lapangan"];
	
	if termGrp &lt;&gt; null then
		
		foreach termArea in termGrp.allTerminalAreas discreteLock do
			tmpYorLapangan := 0;
			totWt    	   := 0;
			foreach lc in termArea.allLocationsControllers do
				foreach cargo in lc.allTrackedItems do
					if  cargo.isContainer then
						continue;
					endif;
					tmpWT := 0;
					tmpWT := cargo.totalWeight/1000;
					write "Term Area Yor [Cargo] : " &amp; termArea.id &amp; Tab &amp; "Cargo ID : " &amp; cargo.id &amp; Tab &amp; " Total WT : " &amp;tmpWT.String;
					totWt := totWt + tmpWT ;	
				endforeach;
			endforeach;
			
			
			
			if totWt &lt;&gt; null then
			
				tmpYorLapangan := (totWt/ self.getMaxCapcity(termArea)) *100;
				cntTALapangan := cntTALapangan +1;
				write "Term Area : " &amp; termArea.id &amp; " " &amp; "Max Capacity:" &amp; self.getMaxCapcity(termArea).String &amp; " " &amp; 
				      "Total WT : " &amp; totWt.String &amp; " " &amp; "TA YOR : "     &amp; tmpYorLapangan.String ;
			endif;
			
			yorLapangan := tmpYorLapangan + yorLapangan;
		endforeach;
		
		write "Yor Lapangan : " &amp; Tab &amp; yorLapangan.String;
		
		if cntTALapangan &gt; 0 then
			yorLapangan := yorLapangan/cntTALapangan ;
			if yorLapangan &gt; 0 then
				idxLap := 1;
			endif;
		endif;
	endif;
	
	termGrp := self.myTerminal.allTerminalAreaStorageGroups["CY"];   //12.02.2019 cnwma1 Bug #43211
	
	if termGrp  &lt;&gt; null then
		foreach termArea in termGrp.allTerminalAreas discreteLock do
			tmpYorCY := 0;
			totTeu    := 0;
			foreach lc in termArea.allLocationsControllers do
				foreach cargo in lc.allTrackedItems do
					if not cargo.isContainer then
						continue;
					endif;
					tmpTeu := 0;
					tmpTeu := cargo.CM_Container.getNumTEU;
					
					write "Term Area Yor [Container]: " &amp; termArea.id &amp; Tab &amp; "Cargo ID : " &amp; cargo.id &amp; Tab &amp;  " Total TEU : " &amp;tmpTeu.String;
					totTeu := totTeu + tmpTeu ;	
				endforeach;
			endforeach;
			
			
			if totTeu &lt;&gt; null then
				cntTACy := cntTACy +1;
				tmpYorCY := (totTeu/ self.getMaxCapcity(termArea)) *100;

				write "Term Area : " &amp; termArea.id        &amp; " " &amp; "Max Capacity:" &amp; self.getMaxCapcity(termArea).String &amp; " " &amp; 
				      "Total Teu : " &amp; totTeu.asStringJMT &amp; " " &amp; "TA YOR : "     &amp; tmpYorCY.String ;
					  
			endif;
			yorCY := tmpYorCY + yorCY;
		endforeach;
		
		if cntTACy &gt; 0 then
			yorCY := yorCY/cntTACy ;
			if yorCY &gt; 0 then
				idxCy := 1;
			endif;
		endif;
		
	endif;
		
	if (yorCY + yorLapangan) &gt; 0 then
		yOR := (yorCY + yorLapangan) / (idxCy + idxLap)  ;    //12.02.2019 cnwma1 Bug #43211
	endif;

	
	write "Final YOR TEU : "    &amp; Tab &amp; yOR.String;
	self.yardOccupancyRatio := yOR;
	
	return yOR;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
