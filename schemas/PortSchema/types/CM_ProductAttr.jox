    <JadeMethod name="validateForUpdate" id="e45f60cc-3e27-418f-be2f-294df63518e5">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	
begin
	
	
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Name', 'Name', null);
		app.raiseCMException(Input_required_field_name, 'Name', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.myType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Primative Type', 'Primative Type', null);
		app.raiseCMException(Input_required_field_primType, 'Primative Type', null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.validationType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Validation type', 'validation type', null);
		app.raiseCMException(Input_required_field_validType, 'validation type', null); // cnwdb2	PAR 35364
		return;
	endif;
	
end;</source>
    </JadeMethod>
