    <JadeMethod name="initialise" id="c7b8269c-6494-4ea8-806e-871cd44b4a94">
        <updating/>
        <source>initialise(_parent : CM_FinancialObject; _bank : CM_Bank; _clear : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		02 October 2007 By Andrew Bishop cnwab1
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// Purpose:		
/* Changes

Date		Name	TFS#	Description
============================================================================
09/07/2019	jlgka1	45519	STWO - unable to load invoice allocation map from PROD to UAT.
============================================================================*/
vars
	aQR : CM_QuantityRangeMap;
begin
	//jlgka1 TFS 45519 --&gt;
	if _parent = null then
		return;
	endif;
	//jlgka1 TFS 45519 &lt;--
	if _clear then
		self.allQuantityRanges.purge();
	endif;
	
	if not self.allQuantityRanges.isEmpty() then
		return;
	endif;
	self.myParentFinancialObject := null;
	self.myParentFinancialObject := _parent;
	create aQR;
	aQR.initialise(self, _bank, true);
	// if in transaction map load, app.isInProformaMode is set - save this in app.allReportObjectSet
	if app.isInProformaMode then
		app.allReportObjectSet.add(aQR);
	endif;
	if not self.myParentFinancialObject.isKindOf(CM_QuantityRangeMap) then //09/02/2017 cnwma1 TFS #2901
		self.chargeZero := false;
		self.mappingType := self.MapType_Single;
		self.myCalculationType := null;
	endif;

end;</source>
        <Parameter name="_parent" type="CM_FinancialObject"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
