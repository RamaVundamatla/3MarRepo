    <JadeMethod name="showDecking" id="c11fc2df-da34-431e-863b-50574b219bf5">
        <updating/>
        <source>showDecking(_yaBlock : CM_YABlock; _row: Integer) updating;
//05/02/2009	cnwwc2	
//
vars
	column: Integer;
	tokens: StringArray;
	text: String;
	cell: JadeTableCell;
	optIn, optFilling, optOut: Integer;
	
begin

	column := self.getColumnByRowName(ETRow_Stacking);
	if column = null then
		return; //no stacking column for this screen
	endif;

	create tokens transient;
	cell := self.accessCell(_row, column);
	if _yaBlock = null or not _yaBlock.myTerminalArea.isDeckable then
		cell.text := null;
		cell.picture := null;
		return;
	endif;
	cell.text.asStringArrayByDelimiter(tokens, "/");
	if tokens.size &lt;&gt; 3 then
		return;
	endif;
	
	optIn		 := tokens[1].Integer;
	optFilling	 := tokens[2].Integer;
	optOut 		 := tokens[3].Integer;
 
	if optFilling = DeckingRule_Custom then
		pic1.picture := null;
		pic2.picture := app.myRoot.getConfig(PicYAMDeckCustom).Binary;
		pic3.picture := null;
	else
		if optIn = DeckingRule_Increasing then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckIcrs).Binary;
		elseif optIn = DeckingRule_Decreasing then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckDcrs).Binary;
		elseif optIn = DeckingRule_MiddleOut then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckMO).Binary;
		elseif optIn = DeckingRule_Pyramid then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckPrmd).Binary;
		elseif optIn = DeckingRule_Random then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckRandom).Binary;
		endif;
		
		if optFilling = DeckingRule_Columnwise then
			pic2.picture := app.myRoot.getConfig(PicYAMDeckColW).Binary;
		elseif optFilling = DeckingRule_Tierwise then
			pic2.picture := app.myRoot.getConfig(PicYAMDeckTW).Binary;
		elseif optFilling = DeckingRule_Topup then
			pic2.picture := app.myRoot.getConfig(PicYAMDeckTopup).Binary;
		elseif optFilling = DeckingRule_SideToSide then
			pic2.picture := app.myRoot.getConfig(PicYAMDeckSDS).Binary;
		endif;	
		
		if optOut = DeckingRule_Increasing then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckIcrs).Binary;
		elseif optOut = DeckingRule_Decreasing then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckDcrs).Binary;
		elseif optOut = DeckingRule_MiddleOut then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckMO).Binary;
		elseif optOut = DeckingRule_Pyramid then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckPrmd).Binary;
		elseif optOut = DeckingRule_Random then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckRandom).Binary;
		endif;	
	endif;
	cell.picture := self.framePics.createPictureIndirect(true,true);
	//cell.picture := self.framePics.createPicture(true, true, 32);
	cell.text := null;
	cell.alignment :=  Table.Alignment_Center;
epilog
	delete tokens;
end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateLocationStatistics" id="82fce7ca-cd6e-4208-8c27-b990a6463a0a">
        <updating/>
        <source>updateLocationStatistics(_lStats : CM_LocationStatistics; _row : Integer) updating;

//par 19909 cnwjo3 17/06/2009
//
//Purpose: Update only the cells on the YAM Table and don't expand Yard Allocation

vars
	headingArray : StringArray;
	heading : String;
begin
	create headingArray transient;
	headingArray.add(ETRow_Free20);
	headingArray.add(ETRow_Free30);
	headingArray.add(ETRow_Free40);
	headingArray.add(ETRow_Free45);
	headingArray.add(ETRow_Free53);
	
	headingArray.add(ETRow_PlannedIn20);
	headingArray.add(ETRow_PlannedIn30);
	headingArray.add(ETRow_PlannedIn40);
	headingArray.add(ETRow_PlannedIn45);
	headingArray.add(ETRow_PlannedIn53);
	
	headingArray.add(ETRow_PlannedOut20);
	headingArray.add(ETRow_PlannedOut30);
	headingArray.add(ETRow_PlannedOut40);
	headingArray.add(ETRow_PlannedOut45);
	headingArray.add(ETRow_PlannedOut53);
	
	headingArray.add(ETRow_Projected20);
	headingArray.add(ETRow_Projected30);
	headingArray.add(ETRow_Projected40);
	headingArray.add(ETRow_Projected45);
	headingArray.add(ETRow_Projected53);
	
	headingArray.add(ETRow_QueuedIn20);
	headingArray.add(ETRow_QueuedIn30);
	headingArray.add(ETRow_QueuedIn40);
	headingArray.add(ETRow_QueuedIn45);
	headingArray.add(ETRow_QueuedIn53);
	
	headingArray.add(ETRow_QueuedOut20);
	headingArray.add(ETRow_QueuedOut30);
	headingArray.add(ETRow_QueuedOut40);
	headingArray.add(ETRow_QueuedOut45);
	headingArray.add(ETRow_QueuedOut53);
	
	headingArray.add(ETRow_Total20);
	headingArray.add(ETRow_Total30);
	headingArray.add(ETRow_Total40);
	headingArray.add(ETRow_Total45);
	headingArray.add(ETRow_Total53);
	
	headingArray.add(ETRow_Used20);
	headingArray.add(ETRow_Used30);
	headingArray.add(ETRow_Used40);
	headingArray.add(ETRow_Used45);
	headingArray.add(ETRow_Used53);
	
	foreach heading in headingArray do
		self.setCellValueByName(heading,_row,_lStats.getDisplayStringForAttribute(heading,false));
	endforeach;
	
epilog
	delete headingArray;
end;
</source>
        <Parameter name="_lStats" type="CM_LocationStatistics"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateStats" id="f8a2f0ec-c6c2-4cf2-b2eb-9c2647c2d35d">
        <updating/>
        <source>updateStats(_stats: CM_LocationStatistics) updating;
//21 August 2008	cnwdw1	
//
vars
	yaBlockRow, row: Integer;
	rowString: String;
	column: Integer;
	yaBlock: CM_YABlock;
begin
	if _stats.myParent.isKindOf(CM_YABlock) then
		yaBlock := _stats.myParent.CM_YABlock;
		//par 19909 cnwjo3
		//yaBlockRow := self.removeItemYABlockAt(yaBlock, 0);
		self.findObjectInRow(yaBlock, yaBlockRow);
		
		if yaBlockRow &gt; 0 then
			//par 19909 cnwjo3
			//self.addItemYABlockAt(yaBlock, yaBlockRow);
			
			if _stats &lt;&gt; null then
				self.updateLocationStatistics(_stats, yaBlockRow);
			endif;
			
			self.recalcYATotals(yaBlock.myYardAllocationIn,null);
		endif;
	endif;
end;</source>
        <Parameter name="_stats" type="CM_LocationStatistics"/>
    </JadeMethod>
    <JadeMethod name="updateYABlockOrder" id="fb3aa1aa-4697-4d34-8bdc-25cfd72c6506">
        <updating/>
        <source>updateYABlockOrder(_ya: CM_YardAllocation) updating;
//27 August 2008	cnwdw1	
//
vars
	rowIndex: Integer;
	newBlockOrder: CM_YABlockArray;
	yaBlockGroup: CM_YABlockGroup;
	pxyYA: CM_YardAllocation;
	groupOrder: CM_YABlockGroupArray;
	yaBlock: CM_YABlock;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	self.findObjectInRow(_ya, rowIndex);	
	if rowIndex &gt; 0 then
		pxyYA := app.createUpdateProxy(_ya).CM_YardAllocation;
		if pxyYA = null then
			return;
		endif;
		create newBlockOrder transient;
		rowIndex := rowIndex + 1;
		if self.hasGroups then
			create groupOrder transient;
			while rowIndex &lt;= self.rows and self.isChildRow(rowIndex) do
				if self.isBlockGroupRow(rowIndex) then
					create yaBlockGroup transient;
					yaBlockGroup.setDescription(self.accessRow(rowIndex).itemObject.CM_YABlockGroup.description);
					groupOrder.add(yaBlockGroup);
				else
					yaBlock := self.accessRow(rowIndex).itemObject.CM_YABlock;
					yaBlockGroup.allYABlocksIn.add(yaBlock);
					yaBlockGroup.allYABlocksOut.add(yaBlock);
					newBlockOrder.add(yaBlock);
				endif;
				rowIndex := rowIndex + 1;
			endwhile;
		else
			while rowIndex &lt;= self.rows and self.accessRow(rowIndex).itemObject.isKindOf(CM_YABlock) do
				newBlockOrder.add(self.accessRow(rowIndex).itemObject.CM_YABlock);
				rowIndex := rowIndex + 1;
			endwhile;
		endif;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateYABlockOrder(pxyYA, newBlockOrder, groupOrder, true, true, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(YRD_Msg_YardAllocation), app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	endif;
	
epilog
	if groupOrder &lt;&gt; null then
		groupOrder.purge();
		delete groupOrder;
	endif;
	delete pxyYA;
	delete newBlockOrder;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="d3b271f3-22b9-4491-b806-221c19e95cea">
        <controlMethod name="CM_DataTable::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, clientExecution;
//21 August 2008	cnwdw1	
//17 July 	2017 	jlgns1 TFS 4566:CPL - Users encountered 1309 error at same time in Master Terminal
//
vars
	localEvent : Integer;
    invalidObject : Boolean;
begin

	if userInfo &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, userInfo.Object, invalidObject);
	endif;

	localEvent := self.getTerminal.getEventFromTerminalEvent(eventType);

	if localEvent = EVENT_LOCATION_STATS_CHANGE and userInfo &lt;&gt; null then
		self.updateStats(userInfo.CM_LocationStatistics);
		return;
	endif;
	
	//if localEvent = Event_YardAllocationCreate and not self.isManuallyMaintained then
	if localEvent = Event_YardAllocationCreate then
		if self.mySearchParameters.isMatchingYA( userInfo.CM_YardAllocation ) then
			self.addItemYardAllocation(userInfo.CM_YardAllocation);
		endif;
	endif;
	
	if localEvent = Event_YardAllocationUpdate then
		self.replaceItemYA(userInfo.CM_YardAllocation);
	endif;

	if localEvent = Event_YardAllocationDelete then
		self.removeItemYAAt(userInfo.CM_YardAllocation, 0);
	endif;
	
	if localEvent = EVENT_YA_CP_UPDATE then		//TFS 4566
		self.refreshPriorities();				//TFS 4566
	endif;										//TFS 4566
	
	
	
//	self.drawTableGrid();
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
