    <JadeMethod name="hideShowFrameNoteConfig" id="bb5e2b92-e5e5-43b7-8522-fea41059ba6c">
        <source>hideShowFrameNoteConfig();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/03/2025	navkc1 JIRA Story MTN-34219: MTN | Notification Framework

*/

vars
	index : Integer;
begin
	self.frmNotifications.visible := not self.frmNotifications.visible;
	self.frmNotifications.zOrder(1); //03/04/2025	navkc1 JIRA MTN-34539
	
	// User might just change the value and close it without saving.
	// We want to make sure value are set to what was saved when displaying the frame
	if self.frmNotifications.visible then
		if self.notificationLevel = self.NoteLevelDoNotes then
			self.optDoNotes.value := true;
		elseif self.notificationLevel = self.NoteLevelNoNotesRefresh then
			self.optNoNotesRefresh.value := true;
			
			if self.autoRefreshValue &gt; null then
				index := self.cmbNotiMinutes.findItemData(self.autoRefreshValue);
				if index &gt; null then
					self.cmbNotiMinutes.listIndex := index;
				endif;
			endif;
		elseif self.notificationLevel = self.NoteLevelNoNotes then
			self.optNoNotes.value := true;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="0ccada5f-23a4-43c4-9b1d-c02b15d88148">
        <updating/>
        <source>initFromUserWindow(_userWindow : CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ***************************************************************************
// This is similar to method MobileUISchema::MOB_BaseForm::initFromUserWindow.  
// Changes to this method may also need to be done in that method
// ***************************************************************************

vars
	newTop,
	newLeft	: Real;
	tmpMainForm	: Form;
	tmpWinState	: Integer;

begin 
	if _userWindow = null then
		return;
	endif;
	
	self.frmToolbar.showCaptions := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagToolbarShowCaptions).Boolean;
	self.mnuEnhanced.checked := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_ShowEnhanced).Boolean;
	self.notificationLevel := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_NotificationLevel).Integer; //13/03/2025	navkc1 JIRA Story MTN-34219
	
	//13/03/2025	navkc1 JIRA Story MTN-34219
	if self.notificationLevel = self.NoteLevelDoNotes then
		self.optDoNotes.value := true;
	elseif self.notificationLevel = self.NoteLevelNoNotesRefresh then
		self.optNoNotesRefresh.value := true;
	elseif self.notificationLevel = self.NoteLevelNoNotes then
		self.optNoNotes.value := true;
	endif;
	
	//13/03/2025	navkc1 JIRA Story MTN-34219
	if self.notificationLevel = self.NoteLevelNoNotesRefresh then
		self.autoRefreshValue := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_AutoRefreshValue).Integer;
		// Start Refresh Timer
		if self.autoRefreshValue &gt; 0 then
			self.beginTimer((self.autoRefreshValue * 60000) + app.random(100), Timer_Continuous, self.BaseForm_TimerRefresh); 
		endif;
	endif;

	//54865, AjitM, navam1
	if app.mySSOAgent &lt;&gt; null and app.mySSOAgent.isLoggedInUsingSSO then
		self.mnuFileChangePassword.enabled := false;
	endif;
	
	if (not self.isBaseFormModal) then
	
		tmpWinState := _userWindow.windowState;
	
		if (tmpWinState = WindowState_Normal)
		or (_userWindow.initForStartup and tmpWinState = WindowState_Minimized)
		then
			//if form is sizable set it to users last
			//settings
			//if the form is unsizable it should default
			//to its painter settings or fall to its minimum Height+Width
			//if self.borderStyle = 2 then
			if self.borderStyle = Window.BorderStyle_Sizable then
				self.width	:= _userWindow.width;
				self.height	:= _userWindow.height;
			endif;
			
			newTop	:= _userWindow.top;
			newLeft	:= _userWindow.left;

			// need to ensure that the saved window positions are
			// still visible on the screen
			if newTop &lt; 0 then
				newTop := 0;
			endif;
			if newLeft &lt; 0 then
				newLeft := 0;
			endif;
			
			tmpMainForm := app.mainForm;
			
			if tmpMainForm &lt;&gt; null then
				if newTop &gt;= tmpMainForm.clientHeight - 10
				or newLeft &gt;= tmpMainForm.clientWidth - 10
				then
					newTop := 20;
					newLeft := 20;
				endif;
			endif;

			self.top	:= newTop;
			self.left	:= newLeft;
			
			if tmpWinState = WindowState_Minimized then
				self.windowState := WindowState_Minimized;
			endif;

		elseif tmpWinState = WindowState_Maximized then
			self.windowState := WindowState_Maximized;
	
		else
			self.centreWindow;
		endif;
	else
		self.centreWindow;
	endif;
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initPosition" id="d341854a-dacd-43fc-8227-e45b4dcb87f3">
        <updating/>
        <source>initPosition() updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.isBaseFormModal) then
		if self.openInTiledView() then
			return;
		endif;
	endif;

	if (not app.userSavedWindowSettings) then
		//epr 17/4/07 par 13840 //epr par 35870 17/3/15
		if app.allUserWindows[self.name] &lt;&gt; null and not self.isKindOf(CMUI_Navigator) then
			return;
		else
		//cover my self here if some forms aren't loaded with the app.loadForm method
			if self.openWithSavedSettings then
				return;
			endif;
		endif;
	
		// rs nov 2005 dont open the navigator in the middle of the screen
		if self.isKindOf(CMUI_Navigator) then
			self.top := 1;
			self.left := 1;
		else
		//if not self.isKindOf(CMUI_Navigator) then
			self.centreWindow();
		endif;
	else
		if self.openWithSavedSettings then
			return;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="insertMeasurementType" id="49f3c551-400c-4b29-a9ce-cfb70f1cb4ef">
        <updating/>
        <source>insertMeasurementType(	_tbl : CM_EntryTable io; 
						_entRow : EntTableRow; 
						_measure : CM_MeasurementType;
						_atRow : Integer; 
						_controlId : Integer io;
						_isForEdit : Boolean;
						_currentObj : CM_Object;
						_defaultMeasure : CM_MeasurementType;
						_product : CM_Product	//Par 32055
						) updating;			// PAR #31754
/*
Purpose:			Add a row to the supplied table that mimics the ent table row supplied,
					but adds to it a cloned CMUI_MeasurementTable control. Add this measurement row
					to the forms' collection of transient rows, and remove the actual _entRow from this collection

Parameters:			

Return Value:		

Date		Who		Reason
03/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321
19/06/2013	cnwdap1	PAR #31754 Product Attributes were always just showing the product attribute default measurement
29 Aug 2013	NDL	Par 32055 - set up heading etc based off product when no currentObject available
17/09/2013	cnwdap1	PAR #32426 Was using wrong variable name to find control in allMeasurementControls collection
11/03/2014	cnwdap1	PAR #33603 Correct handling of measurements for different locales - don't use Comma as a delimiter,
					as some locales (e.g. Italian) use this as a decimal separator
21/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - special code for Total Weight and Total Volume - these should use default
					measurement type from cargo type
11 Jul 2016	NDL		TFS 2118 - With system config option "Measurements Show on Separate Lines" Container Enq form showing NON Containers was showing the 
					same measurement type for every line.
*/
vars
	currentObj		: CM_Object;
	newRow			: Integer;
	entRowTrans		: EntTableRowTransient;
	aRow			: Integer;
	jRow			: JadeTableRow;
	controlPrefix	: String;
	rowName			: String;
	rowHeading		: String;
	measureControl	: CMUI_MeasurementTable;
	displayString	: Decimal [23,10];
	originalColor	: Integer;
	originalEnabled	: Boolean;
	measureToUse	: CM_MeasurementType;
	attr			: CM_ProductAttr;
	value			: String;
	heading			: String;
	disableRowEntry : Boolean;
	cargoType		: CM_CargoType;							// PAR #33606
	
begin
	currentObj := _currentObj;
	if _measure = null then
		return;
	endif;
	// is the row we're going to replace even in the table?
	// e.g. length, width, height for containers, overlength, overwidth, overheight for non-containers
	aRow := _tbl.getRowByName(_entRow.name);
	if aRow = null or not _tbl.accessRow(aRow).visible then
		return;
	endif;
	originalColor := _tbl.accessCell(aRow, 2).backColor;
	originalEnabled := _tbl.accessCell(aRow, 2).enabled;
	
	//24 Feb 2014	NDL	Par 33561
	entRowTrans := _tbl.accessRow(aRow).itemObject.EntTableRowTransient;
	if entRowTrans &lt;&gt; null then
		disableRowEntry := (entRowTrans.inputEnabled = false);
		entRowTrans := null;
	endif;
	
	app.getRowHeadingFromMeasure(_entRow, _measure, controlPrefix, rowHeading, rowName);
	
	measureToUse := _measure;
	heading := _entRow.getHeadingUnaltered;
	
	if currentObj &lt;&gt; null then
		displayString := currentObj.getRawMeasurementValue(_entRow.name);
		if displayString = NULL_INTEGER then
			displayString := null;
		endif;
	endif;
	
	//29 Aug 2013	NDL	Par 32055
	if _product &lt;&gt; null then
		attr := _product.getProdAttrFromName(_entRow.name);
		if attr &lt;&gt; null and attr.myMeasurementType &lt;&gt; null then
			if attr.myMeasurementType &lt;&gt; _measure and attr.myMeasurementType &lt;&gt; _defaultMeasure then	
				measureToUse := attr.myMeasurementType;
			endif;
			// 35846 don't rename "Total Weight" from the cargo type/product attributes
			if _entRow.name &lt;&gt; ETRow_TotalWeight then
				heading := attr.displayName;
			endif;
		endif;
		if _product.myCargoType &lt;&gt; null then										// PAR #33606
			cargoType := _product.myCargoType;										// PAR #33606
		elseif currentObj.isKindOf(CM_TrackedItem) then								// PAR #33606
			cargoType := currentObj.CM_TrackedItem.myCargoType;						// PAR #33606
		endif;																		// PAR #33606
		if cargoType &lt;&gt; null then													// PAR #33606
			if _entRow.name = ETRow_TotalWeight then 								// PAR #33606
				if measureToUse = null then		//11 Jul 2016	NDL	TFS 2118
					measureToUse := cargoType.myWeightMeasurementType;					// PAR #33606
					if measureToUse = null then											// PAR #33606
						measureToUse := app.getDefaultMeasurementForType(Type_Weight);	// PAR #33606
					endif;																// PAR #33606
				endif;
			elseif _entRow.name = ETRow_TotalVolume then							// PAR #33606
				if measureToUse = null then		//11 Jul 2016	NDL	TFS 2118
					measureToUse := cargoType.myVolumeMeasurementType;					// PAR #33606
					if measureToUse = null then											// PAR #33606
						measureToUse := app.getDefaultMeasurementForType(Type_Volume);	// PAR #33606
					endif;																// PAR #33606
				endif;
			endif;																	// PAR #33606
		endif;																		// PAR #33606
	endif;
	
	newRow 			:= _tbl.addAttributeAt(rowName, heading, Table.InputType_TextBox, null, true, _atRow);
	entRowTrans 	:= _tbl.accessRow(newRow).itemObject.EntTableRowTransient;
	
	if displayString = null then 
		value := " " &amp; measureToUse.shortName;
	else
		// convert from default measurement type to this measurement type
		value := app.convertMeasurementForDisplay(measureToUse.shortName, displayString) &amp; " " &amp; measureToUse.shortName;
	endif;
	self.getMultiValueConvertedString( displayString, measureToUse, value); // 12 Mar 2014 - split off the stuff below.
	_tbl.setValueByName(rowName, value);
	aRow := _tbl.getRowByName(rowName);
	jRow := _tbl.accessRow(aRow);
	jRow.backColor := self.colorValueColumn;
	// check original cell settings to see if it's read only or disabled
	_tbl.accessCell(aRow, 2).backColor 	:= originalColor;
	_tbl.accessCell(aRow, 2).enabled 	:= originalEnabled;
	
	// create a measurement table control for this row of the table
	//measureControl := self.allMeasurementControls[controlName].CMUI_MeasurementTable;			// PAR #32426
	measureControl := self.allMeasurementControls[rowName].CMUI_MeasurementTable;				// PAR #32426
	// 34367 can find an entry for a different table (e.g. 'volume' from 'General Cargo Info', table 2 and from 'General', table 1
	//	can cause problems in CMUI_MeasurementTable::change so delete and create a new one if found
	if measureControl &lt;&gt; null and
	   measureControl.heading &lt;&gt; _tbl.name then
		self.allMeasurementControls.removeKeyEntry( measureControl.name, measureControl );
		delete measureControl;		// which nulls it for the following test
	endif;
	
	if measureControl = null then
		_controlId := _controlId + 1;
		measureControl := self.tblMeasurement.loadControl(_controlId).CMUI_MeasurementTable;
		measureControl.visible := true;
		measureControl.name := rowName;
		measureControl.setEventMapping("lostFocus", "tblMeasurement_lostFocus");
		measureControl.setEventMapping("gotFocus", "tblMeasurement_gotFocus");
		measureControl.setMeasurementType(measureToUse.measurementType);
		//measureControl.setHeading(_entRow.getHeadingUnaltered);
		measureControl.setHeading(_tbl.name);	//31 Mar 2014	NDL	Par 33356
		self.allMeasurementControls.add(measureControl);
	endif;
	measureControl.setRowName(_entRow.name);
	measureControl.setValues(value);
	_tbl.setControl(aRow, measureControl);
	
	//24 Feb 2014	NDL	Par 33561
	if disableRowEntry then
		_tbl.accessRow(aRow).foreColor := _tbl.foreColor;			// JADE PAR 66229 jlgdap1 04 Sep 2018
		_tbl.accessRow(aRow).enabled := false;
	endif;
	
	// check to see if we need to add this control to the form's collection of transient ent rows,
	// and take the _entRow out of this collection, so it doesn't show in the column organiser
	//epr par 33900 deleting measurement type columns handled on datatable delete now
	
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_entRow" type="EntTableRow"/>
        <Parameter name="_measure" type="CM_MeasurementType"/>
        <Parameter name="_atRow" type="Integer"/>
        <Parameter name="_controlId" type="Integer" usage="io"/>
        <Parameter name="_isForEdit" type="Boolean"/>
        <Parameter name="_currentObj" type="CM_Object"/>
        <Parameter name="_defaultMeasure" type="CM_MeasurementType"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
