    <JadeMethod name="pxyCreateUpdateProxy" id="e61fe5e9-9203-4576-934b-064034eb5d50">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     27 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/11/2009	cnwdap1		CCMS 1007 - Reefer properties moved to CM_ReeferProperties class
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 30/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// ---------------------------------------------------------------------------
vars
	proxyTI		: CM_Container;
	child,
	proxyChild	: CM_TrackedItem;
	proxyCOU	: CM_ClipOnUnit;
	proxyGenerator : CM_Generator;
	completedOK		: Boolean;
	proxyVGM : CM_VGMDetails;					// TFS 4492
	
begin

	proxyTI := inheritMethod();
	
	//if proxyTI failed to be created then exit
	if proxyTI = null then // jlgzm1 tfs41747 11/12/18
		return null;
	endif;
	
	// create a proxy VGM Detaisl object if required			// TFS 4492
	if self.myVGMDetails &lt;&gt; null then							// TFS 4492
		proxyVGM := self.myVGMDetails.pxyCreateUpdateProxy();	// TFS 4492
		proxyVGM.setMyContainer(proxyTI);						// TFS 4492
	endif;														// TFS 4492

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyTI;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401		
		delete proxyTI;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="queuedLocnId40" id="a82bdd78-edb8-4c20-9064-d7811a0f257d">
        <methodInvocation>mapping</methodInvocation>
        <source>queuedLocnId40(set: Boolean; _value: String io) mapping;
//Returns the full location of where this container actually is, if its a 40' location, returns
//"C 2303-041", ie c23031 and c23041 strung together, else returns null
vars
	tmpLC	: CM_LocationsController;
	myLoc 	: CM_StackController;
	sc		: CM_StackController;
	aStr 	: String;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := null;
	tmpLC := self.getPrimaryLocation(QUEUE_MODE);
	if tmpLC = null then
		return;
	endif;
	if not tmpLC.isKindOf(CM_StackController) then
		return;
	endif;
//	if not self.is40 then
	if not self.requiresMoreThan1TwentyLC() then  // PAR 16415 CCMS 1029
		return;
	endif;
	sc := tmpLC.CM_StackController;
	//------------------
	//Return the terminal Area id &amp; a space
	//------------------
	aStr := tmpLC.myTerminalArea.id.trimRight &amp; " ";	
	//------------------
	//Add row label
	//------------------
	aStr := aStr &amp; sc.getRowLabel;
	//------------------
	//Add column label
	//------------------
	aStr := aStr &amp; sc.getColumnLabel(true);
	//------------------
	//Add column label of NEXT position
	//------------------
	aStr := aStr &amp; "-" &amp; sc.myNextController.getColumnLabel(true);
	//------------------
	//Append the height
	//------------------
	aStr := aStr &amp; sc.allTrackedItems.size.String;
	_value := aStr;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="reeferStatus" id="d223c121-b66c-4411-9252-174772f1fada">
        <source>reeferStatus(): String;
//----------------------------------------------------------------
//	Created:	15 September 2003	by Jason Chapman  (cnwjc2)
//	Reefer status for reefer log report
//	No parameters!
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
//----------------------------------------------------------------
vars

begin
	if self.isRehandle then
		return "DLRs";
	elseif self.isExport then
		return "Exports";
	elseif self.isImport or self.isStorage then
		return "Imports and Storage";
	elseif self.isTranshipItem then		// PAR #25021
		return "Tranships";				// PAR #25021
	else
		return "Other";
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
