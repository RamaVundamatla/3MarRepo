    <JadeMethod name="loadDataForFirstTime" id="9fc9a996-d4b3-4115-b745-cf26a0db783f">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 06/08/2012	cnwcs5	par 30136 - EDI BGP split
begin
	inheritMethod();
	
	self.doLoadCombos();
	self.doLoadTasks();
	self.doLoadSchedules();
	self.loadEDIDataTypes (self.lstDataTypes);		// par 30136 Aug 2012
	
	self.beginClassNotification(CM_AutoSchedule, false, EVENT_ALTER_SCHEDULE, Response_Continuous, null);
	self.beginClassNotification(CM_AutoSchedule, false, Any_System_Event,  Response_Continuous, null);
	self.beginTimer(5000, Timer_Continuous, 0);
	
	self.changeButtonStates();
	self.showInitialTask();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadEDIDataTypes" id="84b3ae67-1aa9-465a-96a5-711471069ee4">
        <source>loadEDIDataTypes(_listTable	:CMUI_ListTable)protected;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
// 24 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 15 Jan 2018	jlgrs1	TFS 36636 STW Cargo By Site to be partial loading
vars
	list	:CMUI_ListTableInteger;
	agent	:CM_EDIControllerAgent;
begin
	list	:= self.lstDataTypes;
	
	create agent transient;
	
	list.addItemInteger(EDIDataType_BookingMultiLine, agent.getEDIDisplayStrForType(EDIDataType_BookingMultiLine));
	list.addItemInteger(EDIDataType_ReleaseRequest, agent.getEDIDisplayStrForType(EDIDataType_ReleaseRequest));
	list.addItemInteger(EDIDataType_RequestMultiLine, agent.getEDIDisplayStrForType(EDIDataType_RequestMultiLine));
	list.addItemInteger(EDIDataType_GateDocument, agent.getEDIDisplayStrForType(EDIDataType_GateDocument));
	list.addItemInteger(EDIDataType_CustomStop, agent.getEDIDisplayStrForType(EDIDataType_CustomStop));
	list.addItemInteger(EDIDataType_OperatorStop, agent.getEDIDisplayStrForType(EDIDataType_OperatorStop));
	list.addItemInteger(EDIDataType_Prenote, agent.getEDIDisplayStrForType(EDIDataType_Prenote));
	list.addItemInteger(EDIDataType_Pack, agent.getEDIDisplayStrForType(EDIDataType_Pack));
	list.addItemInteger(EDIDataType_ShipManifest, agent.getEDIDisplayStrForType(EDIDataType_ShipManifest));
	list.addItemInteger(EDIDataType_CargoOnSite, agent.getEDIDisplayStrForType(EDIDataType_CargoOnSite));
	list.addItemInteger(EDIDataType_CargoOnShip, agent.getEDIDisplayStrForType(EDIDataType_CargoOnShip));
	list.addItemInteger(EDIDataType_TrainConsist, agent.getEDIDisplayStrForType(EDIDataType_TrainConsist));				//22.Nov.2023 navsp1 TFS 61165
	list.addItemInteger(EDIDataType_TransportManifest, agent.getEDIDisplayStrForType(EDIDataType_TransportManifest));	//22.Nov.2023 navsp1 TFS 61165	
	list.addItemInteger(EDIDataType_CallOff, agent.getEDIDisplayStrForType(EDIDataType_CallOff));						//22.Nov.2023 navsp1 TFS 61165
epilog

	delete agent;
end;</source>
        <access>protected</access>
        <Parameter name="_listTable" type="CMUI_ListTable"/>
    </JadeMethod>
