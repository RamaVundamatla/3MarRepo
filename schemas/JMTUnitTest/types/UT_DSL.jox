    <JadeMethod name="addBookingItemForContainer" id="577c25b9-322e-4dd0-b553-8b9d03c2150b">
        <source>addBookingItemForContainer(_booking: CM_BookingRef input; _isoType: String; _commodity: String; _number: Integer): CM_BookingRef;
//06 July 2009	cnwdw1	
//
vars
	pxyBooking: CM_BookingRef;
	pxyBookingItem: CM_BRefItemContainer;
begin
	create pxyBookingItem transient;		
	pxyBookingItem.setProxy(TI_CargoType_Container, _commodity, null, null, null, _isoType, _number, 0, 0, 0, NULL_HUMIDITY, NULL_TEMPERATURE, NULL_VENTILATION, 0
							, NULL_CARBON_DIOXIDE, NULL_OXYGEN, false, false, false, null, self.opts.str("ISO Group"), false, null, null, null, CM_BookingRefItem.BASIC_MATCH);		//navra1 - CR 63764/Task 64227 - 23rd May 2024

	pxyBooking := app.createUpdateProxy(_booking).CM_BookingRef;
	pxyBooking.allBookingRefItems.add(pxyBookingItem);
	_booking.allSpecialLifts.copy(pxyBooking.allSpecialLifts);							// 05/03/2014 - cnwmh5

	app.myTrxUA.trxUpdateBookingBulkRel(pxyBooking, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return _booking;
epilog
	delete pxyBooking;
end;</source>
