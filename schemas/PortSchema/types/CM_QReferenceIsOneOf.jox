    <JadeMethod name="allowsSnapShotEdit" id="45b07558-59d3-46d3-a8de-0ea59e770607">
        <source>allowsSnapShotEdit(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2021	navndl1	Initial creation	TFS 50835

*/

vars
	
	object : Object;

begin

	foreach object in self.allSelectionValues do
		if object.isKindOf(CM_EventType) then
			if object.CM_EventType.allowsSnapShotEdit() then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="7c8c0b3d-c543-4175-a124-fe22df3d6c9c">
        <updating/>
        <source>cloneReferences(_targetReceiver : SelfType input) updating;
// ---------------------------------------------------------------------------
// Created:     20 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_targetReceiver);
	self.allSelectionValues.copy(_targetReceiver.allSelectionValues);

end;</source>
        <Parameter name="_targetReceiver" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="537098aa-e59f-4a77-bd66-02caae20bf5a">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		09 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.description := self.Operator_IsOneOf;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="ff5e13b4-29a2-434e-ae1b-f2b446d044ca">
        <source>doMatch(_value: Any): Boolean;
// ---------------------------------------------------------------------------
// Created:     18 June 2003		cnwth2	
//
// Purpose:     		 
/**** Changes ***
   Date			Name		TFS#		Description
   12/09/2018	jlgka1		TFS 40735 	Add Operator Group Code.
// ----------   ----------  ----------	----------------------------------------*/

vars
	yardAllocation 		: CM_YardAllocation;
	yardAllocationDict 	: CM_YAByPriorityDict;
	tiTransactionDict 	: CM_TITransactionByDateOrdDict;
	object 				: Object;
	transactionType 	: CM_TransactionType;
	operatorGroupDict 	: CM_OperatorGroupByCodeDict;
	operatorGroup 		: CM_OperatorGroup;
begin
	if self.allSelectionValues.isEmpty then //Haven't selected any items so assume it's ok.  This is based on existing behaviour from the GUI (a bit backwards but anyhoo).
		return true;
	endif;
	
	//06 Jan 2012	NDL	Par 28889
	if _value &lt;&gt; null then
		if _value.isKindOf(CM_YAByPriorityDict) then
			yardAllocationDict := _value.CM_YAByPriorityDict;
			if yardAllocationDict = null or yardAllocationDict.isEmpty then
				return false;
			else
				foreach yardAllocation in yardAllocationDict discreteLock do
					if self.allSelectionValues.includes(yardAllocation) then
						return true;
					endif;
				endforeach;
				return false;
			endif;
		elseif _value.isKindOf(CM_TITransactionByDateOrdDict) then
			tiTransactionDict := _value.CM_TITransactionByDateOrdDict;
			if tiTransactionDict = null or tiTransactionDict.isEmpty then
				return false;
			else
				foreach object in self.allSelectionValues do
					transactionType := object.CM_TransactionType;
					if tiTransactionDict.includesTrxType(transactionType.trxType) then
						return true;
					endif;
				endforeach;
				return false;
			endif;
		elseif _value.isKindOf(CM_OperatorGroupByCodeDict) then
			operatorGroupDict := _value.CM_OperatorGroupByCodeDict;
			if operatorGroupDict = null or operatorGroupDict.isEmpty then
				return false;
			else
				foreach object in self.allSelectionValues do
					operatorGroup := object.CM_OperatorGroup;
					if operatorGroupDict.includes(operatorGroup) then
						return true;
					endif;
				endforeach;
				return false;
			endif;
		endif;
	endif;
	
	//return true;												//- cnwmd1, CCMS 1067, Par 19710
	return self.allSelectionValues.includes(_value.Object); 	//+ cnwmd1, CCMS 1067, Par 19710


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="589d3ac5-da95-446e-a726-d512d0c79a62">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
// -------------------------------------------
// Created 03 may 2008 by cnwvu1
// -------------------------------------------

vars

begin

	app.raiseCMException1( ERR_QueryForRTMustUseEqualTo, '"'&amp; self.description &amp;'"', null, null);

end;
</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSearchValue" id="60634687-e376-4d06-ba30-577278a7b627">
        <source>getSearchValue(): ObjectSet;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.allSelectionValues;

end;</source>
        <ReturnType type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueAsObjectSet" id="9c554a07-fe9d-4535-b10a-ab686c05c5c6">
        <source>getSearchValueAsObjectSet(_set: ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     Returns a set of objects.  For example a set of CM_Terminals
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/10/2009	cnwjo3		Need to filter what CM_Terminals in the set if User does
//							does not have permission.  par 21231
// ---------------------------------------------------------------------------
vars
	ut : CM_UserTerminal;
	tempSet : ObjectSet;
begin
	create tempSet transient;
	
	self.allSelectionValues.copy(tempSet);

	if tempSet.size &gt; 0 and tempSet.first().isKindOf(CM_Terminal) then
		foreach ut in app.myPassport.myUser.allUserTerminals do
			if tempSet.includes(ut.getMyTerminal) then
				_set.add(ut.getMyTerminal);
			endif;
		endforeach;
	else
		tempSet.copy(_set);
	endif;
epilog
	delete tempSet;
end;</source>
        <Parameter name="_set" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="46a826d3-92e1-4b9e-87c1-ce91df4b910b">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	obj	: Object;
	str	: String;
	
begin

	foreach obj in self.allSelectionValues do
		if obj = null
		or global.isValidObject(obj) then
			if str = null then
				str := _prop.translateToDisplayValue(obj);
			else
				str := str &amp; ', ' &amp; _prop.translateToDisplayValue(obj);
			endif;
		endif;
	endforeach;
	
	return str;

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidForRT" id="a2e06bac-b869-4a7f-ab10-15e0a58647fa">
        <source>isValidForRT(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	//Queries for RT must only use the operations having only one searching value.
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="0b96583e-6e36-4689-9327-f8a25277ce59">
        <updating/>
        <source>setSearchValue(_value: Object) updating;
// -----------------------------------------------------------------------------
// Created:		09 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	self.allSelectionValues.clear;
	if _value &lt;&gt; null then 	// par 18123
		if _value.isKindOf(Collection) then	//17 Jun 2015	NDL	Par 36338
			_value.Collection.copy(self.allSelectionValues);
		elseif _value.isKindOf(Object) then
			self.allSelectionValues.add(_value);
		endif;
	endif;

end;</source>
        <Parameter name="_value" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="5eca942c-ebfd-4e1c-b9cb-202faa6a6749">
        <source>validateForRT( _queryName, _propName : String );
// -------------------------------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
//
// Purpose:	Queries for RT must only use the operations having only one searching value.
//			A set of selected values is not valid for the RT Drivers screen. 
// -------------------------------------------------------------------------------------

vars
	str	: String;
	obj	: Object;
	
begin
	
	foreach obj in self.allSelectionValues do
		if obj.isKindOf( CM_Object ) then
			str := str &amp; obj.CM_Object.auditIdDisplay() &amp; ', ';
		endif;
	endforeach;
	str := str[1 : str.length()-2];		// removing the last comma
	
	//26 Jul 2011	NDL	Par 27890
	//app.raiseCMException1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;' '&amp; str &amp;'"', null, null);
	app.raiseCMWarning1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;' '&amp; str &amp;'"', null, null, null);
	
end;
</source>
        <Parameter name="_queryName" type="String"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
</Class>
