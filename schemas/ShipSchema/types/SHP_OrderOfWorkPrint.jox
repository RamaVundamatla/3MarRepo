    <JadeMethod name="setupForm" id="206705ff-2ad6-4758-a7ef-16b25c4c4564">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Oct 2012	cnwpjs1	Initial creation  PAR # 30631
10 Feb 2017	cnwdap1	TFS 3220 LNX Voyage Operations Enhancements
*/

vars

	reportName : String;

begin

	inheritMethod();
	
	fldSeqSheet.top := grpOrderOfWork.top;
	fldSeqSheet.left := grpOrderOfWork.left;
	fldSeqSheet.stretchToParent := false;
	
	app.mousePointer := MousePointer_Default;
	
	
	self.btnOk.caption := app.getErrorString(INV_Print);	
	self.showPrinterName();
	
	if myParentForm.isKindOf(SHP_OrderOfWorkForm) then
		chkPreview.value := myParentForm.SHP_OrderOfWorkForm.getPrintPreviewSetting;
		chkLidOOW.value := myParentForm.SHP_OrderOfWorkForm.getPrintLidCommentsSetting;
		chkLidSeqSheet.value := myParentForm.SHP_OrderOfWorkForm.getPrintLidCommentsSetting;
		chkHideHatch.value := myParentForm.SHP_OrderOfWorkForm.getHatchJobSetting;
	elseif myParentForm.isKindOf(SHP_HoldJobOpsForm) then
		chkPreview.value := true;
	endif;
	
	self.grpSeqPrint.visible:=false;
	
	doCmbSequenceBuild;
	doCmbSideBuild;
	
	self.doCmbCraneBuildSC();
	self.doJobBuild();
	
	// drawing stuff for seq sheet
	
	create myConfig transient;
	myConfig.setFromPersistentData(app.getMyUser);
	create self.myBayDrawingController transient;
	self.myBayDrawingController.zeroFilleSeqNum := self.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean;
	self.myBayDrawingController.setConfig(myConfig);
	
//	self.useTableInfo := true;		// from CMUI-QueryEnquiry
//	self.useTableSorting := true;
	
	
	self.frmBayPic.left := 0;
	self.frmBayGridArea20.backColor := White;
	self.frmBayGridArea40.backColor := White;
	self.frmBayPic.backColor := White;
	self.frmBayPic.borderStyle := self.frmBayPic.BorderStyle_None;
		
	
	optOOWPrint.value := true;
	handlePrintOption;
	
	//18 Jan 2016	NDL	TFS 3216/3047
	self.populateCmbSendToRep();
	
	reportName := self.myTerminal.getConfig(DefVoyageRep1).String;
	if reportName &lt;&gt; null then
		self.optReport1.caption := reportName;
		self.optReport1.enabled := (self.cmbSendToRep.findStringExact(1,reportName) &gt; 0);
	else
		self.optReport1.visible := false;
	endif;
	
	reportName := self.myTerminal.getConfig(DefVoyageRep2).String;
	if reportName &lt;&gt; null then
		self.optReport2.caption := reportName;
		self.optReport2.enabled := (self.cmbSendToRep.findStringExact(1,reportName) &gt; 0);
	else
		self.optReport2.visible := false;
	endif;
	
	self.handlePrintOption;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showMonitorForPrinting" id="1ad6a3be-790e-4f36-acc1-812cf055e449">
        <updating/>
        <source>showMonitorForPrinting() : CMIF_Monitor updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2004	cnwth2
//
// Purpose:     
//			
// 30 Oct 2012	PJS			PAR # 30631 - moved from Seq sheet form
// ----------   ----------  --------------------------------------------------
vars
	cmifMonitor					: CMIF_Monitor;
	returnValue,
	partsComplete,
	partsInJob					: Integer;
begin
	delete app.myPassport.myCMIFMonitor;
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	self.frmModalDialog.zOrder(1);
	self.modalDialogShow(null, app.getErrorString(Cancel), app.getErrorString(CMUI_Return_Data), null, null, cmifMonitor.message);
	self.lblModalMessage.caption := app.getErrorString(Sequence_Sheet_Report_Progress);

	return cmifMonitor;
end;</source>
        <access>protected</access>
        <ReturnType type="CMIF_Monitor"/>
    </JadeMethod>
    <JadeMethod name="showPrinterName" id="80d9deb2-0752-4e21-9810-5ccd89f3f975">
        <source>showPrinterName();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Oct 2012	cnwpjs1	Initial creation  PAr #30631

*/

vars

begin

	self.picPrinter.bubbleHelp := app.getErrorString1(PRINT_MESS_PT1, app.printer.getPrinterName() ) &amp; Cr &amp;  app.getErrorString(PRINT_MESS_PT2);
	lblPrintName.caption := app.printer.getPrinterName();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0a0a660a-4dab-481f-819a-29b67394c9f3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 February 2017 09:17:13.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018530, locale);
	btnSelectAll.translateBubbleHelp(Xlat_0018531, locale);
	chkHideHatch.translateCaption(Xlat_0018532, locale);
	chkLidOOW.translateCaption(Xlat_0018533, locale);
	chkLidSeqSheet.translateCaption(Xlat_0018534, locale);
	chkPreview.translateCaption(Xlat_0018535, locale);
	frmDrawContainer.translateCaption(Xlat_0018536, locale);
	grpOrderOfWork.translateCaption(Xlat_0018537, locale);
	grpSeqPrint.translateCaption(Xlat_0018538, locale);
	lblCrane.translateCaption(Xlat_0018539, locale);
	lblJob.translateCaption(Xlat_0018540, locale);
	lblPrintName.translateCaption(Xlat_0018541, locale);
	lblSequence.translateCaption(Xlat_0018542, locale);
	lblSide.translateCaption(Xlat_0018543, locale);
	optLargeL.translateCaption(Xlat_0018544, locale);
	optLargeP.translateCaption(Xlat_0018545, locale);
	optNormal.translateCaption(Xlat_0018546, locale);
	optOOWPrint.translateCaption(Xlat_0018547, locale);
	optReport1.translateCaption(Xlat_0021870, locale);
	optReport2.translateCaption(Xlat_0021871, locale);
	optSendToRep.translateCaption(Xlat_0021872, locale);
	optSequenceSheet.translateCaption(Xlat_0018548, locale);
	shtJob.translateCaption(Xlat_0018549, locale);
	shtSequence.translateCaption(Xlat_0018550, locale);
end;</source>
    </JadeMethod>
</GUIClass>
