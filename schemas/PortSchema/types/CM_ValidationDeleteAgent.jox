    <JadeMethod name="valBulkRelease" id="e8df9a36-7509-4c96-ab11-77c8d175b7a0">
        <source>valBulkRelease(
	_obj		: CM_BulkRelease io;
	_passport	: CM_Passport input );
	
/*
Date				Who		Reason
08 September 2009	cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	
begin
	self.raiseExceptionIfNull( _obj, app.getErrorString( Release_request ) );
	
	if not self.exclusiveLockObjectToDelete( _obj ) then
		// toDelete is null, invalid or has already been deleted.
		// most methods seem to have this return removed?
		return;
	endif;
	
	// NOTE: Currently the validateForDelete on CM_BulkRelease does nothing!
	_obj.validateForDelete( _passport );
	
epilog
	
end;
</source>
        <Parameter name="_obj" type="CM_BulkRelease" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
