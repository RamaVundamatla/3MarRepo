    <JadeMethod name="clearInstructions" id="edb19c60-b324-4d38-b66f-e624fe09bb38">
        <updating/>
        <source>clearInstructions(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
16 Dec 2022 navmv20  TFS ChangeRequest 55858 Task 55867 : EUP - Instruction code refactor
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
06 Nov 2023	navnk30	ChangeRequest 60933: EUP - Operational Instructions - CM_TrackedItem Inverse
*/

vars
	instr : CM_InstructionsIssued;
	result : Integer;
	msgString : String;
begin
	if self.txtExternalReference.text = null and self.txtInternalInstructions.text = null and self.cmbInstructions.listIndex = -1 then
		app.msgBox(app.getErrorString(Empty_fields), app.getErrorString(Warning), MsgBox_OK_Only);
		return;
	endif;
	
	//16/12/2022 navmv20 TFS CR 55858 Task 55867 - START
	/*if self.myObject.isKindOf(CM_PreNote) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_BookingRef.bookingReference.String), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_PreNote.myInstructions;
		
	elseif self.myObject.isKindOf(CM_BookingRefItem) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_BookingRefItem.id.String), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_BookingRefItem.myInstructions;
		
	elseif	self.myObject.isKindOf(CM_BulkRelease) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_BulkRelease.code.String ), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_BulkRelease.myInstructions;
	
	elseif	self.myObject.isKindOf(CM_ReserveDetail) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_ReserveDetail.myReserveHeader.code.String ), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_ReserveDetail.myInstructions;
	
	elseif	self.myObject.isKindOf(CM_WorkOrder) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_WorkOrder.id.String ), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_WorkOrder.myInstructions;
	
	elseif	self.myObject.isKindOf(CM_WorkOrderDtl) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_WorkOrderDtl.myParent.id.String ), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_WorkOrderDtl.myInstructions;
	
	elseif	self.myObject.isKindOf(CM_BOL) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_BOL.bolType.String ), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_BOL.myInstructions;
	
	elseif	self.myObject.isKindOf(CM_BOLDtl) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_BOLDtl.myBOL.bolType.String ), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_BOLDtl.myInstructions;
	
	elseif	self.myObject.isKindOf(CM_ToDoTask) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_ToDoTask.toDoTaskDescDesc.String ), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_ToDoTask.myInstructions;
		
	elseif	self.myObject.isKindOf(CM_TrackedItem) then
		if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.CM_TrackedItem.id.String ), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		instr := self.myObject.CM_TrackedItem.myInstructions;
		
	endif;*/
	
	if app.msgBox(app.getErrorString2(Sure_want_remove, msgString, self.myObject.getNiceName()), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	instr := self.myObject.getInstructions();
	//16/12/2022 navmv20 TFS CR 55858 Task 55867 - END
	
	while true do
		app.myTrxDA.trxDeleteInstructionIssued(instr, app.myPassport);
			if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					/*beginTransaction;				//06.11.2023 navnk30 #60933
						if self.myObject.isKindOf(CM_TrackedItem) then
							self.myObject.CM_TrackedItem.setmyInstructions(null);
						endif;
					commitTransaction;
					*/
					self.unloadForm();
					break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Delete_instructio_issued), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			break;
	endwhile;
	if self.myParentForm.isKindOf(CMUI_Instructions) then					//16.10.2023 navnk30 #59946
		self.causeEvent(CMUI_InstructionEntry.InstructionEntryDeleted, true, self.myObject);
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
