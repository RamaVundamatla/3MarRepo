/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2013	cnwrd1	Initial creation

*/

vars

	char         : String;
	idx, len : Integer;
begin
	len := self.length();
	
	foreach idx in 1 to len do
		char :=  self[idx:1];
		if not char.isInteger and not char.isUppercaseAlpha then
			return false;
		endif;
	endforeach;
	return true;
epilog


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertDDMMYYYToDate" id="6bb6007f-b3c0-42b9-ae88-f3c9a967999d">
