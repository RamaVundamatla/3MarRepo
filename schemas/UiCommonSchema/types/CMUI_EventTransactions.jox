epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuildTblTrans" id="0801e3e7-8a5e-4be0-8641-0fcfb470234f">
        <source>doMnuContextBuildTblTrans(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	anObject 	: Object;
	hasObject : Boolean;
begin
	anObject :=  table.accessRow(table.row).itemObject;
	if app.isValidObject(anObject) then
		self.mnuInspectObject.visible := self.mnuInspectObject.userObject &lt;&gt; null and app.isAllowedToInspect();
		self.mnuAudits.visible := self.mnuInspectObject.userObject &lt;&gt; null and self.mnuInspectObject.userObject.CM_Object.hasAudits;	//01 Feb 2021	NDL	TFS 50152
	endif;

	self.mnuColumnOrganiser.visible := true; 
	
	return true;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOpenInvoiceLine" id="cdb7a658-41cf-4f91-ae6e-47e2d0918200">
        <source>doOpenInvoiceLine();
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR

*/

vars
	anObject : Object;
	invLine : CM_InvoiceLine;
begin
	if self.tblCharges.row &gt; self.tblCharges.fixedRows then
		anObject :=self.tblCharges.accessRow(self.tblCharges.row).itemObject;
		self.myAssistant.showInvoiceLineForm(anObject, self.myMasterMenuAction);

	elseif self.tblEvents.row &gt; self.tblEvents.fixedRows then
		anObject :=self.tblEvents.accessRow(self.tblEvents.row).itemObject;
		if anObject.isKindOf(CM_EventTransaction) then
			invLine := anObject.CM_EventTransaction.allInvoiceLines.first;
			
			self.myAssistant.showInvoiceLineForm(invLine, self.myMasterMenuAction);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="498e8a17-daa4-402f-915d-741aa4551f3f">
