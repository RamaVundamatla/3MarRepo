    <JadeMethod name="doQuery" id="bb6aab36-d6bc-4beb-828e-3b1904071a0d">
        <updating/>
        <source>doQuery() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	bank : CM_Bank;

begin

	self.lblRefresh.visible := false;	//12 Dec 2018	NDL	TFS 42060

	self.myCurrentDebtor := self.cmbDebtor.listObject.CM_DebtorNode;
	bank := self.cmbBank.listObject.CM_Bank;
	if bank = null then
		return;
	endif;
	
	if bank &lt;&gt; self.myCurrentBank then
		// clear these as they will be for the prior bank
		self.myCurrentPaymentType := 0;
		self.myCurrentService := null;
		self.myCurrentBank := bank;
//		self.doCmbPaymentTypesBuild(null);
		self.doCmbServicesBuild();
		self.loadLines();
	endif;

	self.doQueryDebtor();
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryDebtor" id="c616ef42-0dc6-4ba3-8a7a-74c438cf43db">
        <updating/>
        <source>doQueryDebtor() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281
19 Oct     2018 cnwma1 ChangeRequest 41281: PEL1 - Payment Method on Services
*/

vars

	theDebtors : CM_DebtorNodeByNameDict;
	dn : CM_DebtorNode;
	invoiceLineDesc : CM_InvoiceLineDesc;
	service : CM_Service;
	paymentType : Integer;
	row : Integer;
	column : Integer;
	count : Integer;
	pd : CMS_Progress;
	ls : Boolean;
	mapTable : Table;
	bank : CM_Bank;
	rdg	: CM_RootDebtorGroup;
	paymentTypeMapping : CM_ServicePayTypeMapping;
	defaultDeb : CM_Debtor;
begin

	bank := self.myCurrentBank;
	rdg := bank.getRootDebtorGroup();

	create theDebtors transient;
	mapTable := self.tblData;

	self.setCaption( app.getErrorString( Service_payment_type_mapping ) &amp; " - " &amp; self.cmbDebtor.text.trimBlanks &amp; " " &amp; bank.code);
	self.setNavigatorHeading(self.caption);
	
	on CM_ProgressException do haltProgress(exception, ls);

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction("Loading Debtors...");

	app.cmsBeginLoad(ls);

	mapTable.columns := 1;
	mapTable.column := 1;
	mapTable.row := 1;
	mapTable.fixedRows := 1;

	if self.myCurrentDebtor &lt;&gt; null then
		if self.myCurrentDebtor.isRDT then          // 19.10.2018 cnwma1 TFS #41281
			theDebtors.add(self.myCurrentDebtor);
		else
			self.myCurrentDebtor.getDebtors(theDebtors);
		endif;
	else
		rdg.getDebtors(theDebtors);
	endif;
	
	defaultDeb := app.myRoot.getDefaultDebtor(null);
	
	if theDebtors.size = 1 then   // 19.10.2018 cnwma1 TFS #41281
		mapTable.columns := theDebtors.size + 1;
	else
		mapTable.columns := theDebtors.size + 2;
	endif;
	
	column := 1;
	pd.progress.partsInJob := theDebtors.size;
	
	// 19.10.2018 cnwma1 TFS #41281
	if theDebtors.includes(defaultDeb) then	 
		column := column +1;
		row := 1;
		mapTable.accessCell(row,column).text := ' '&amp; app.getErrorString(Default);
		mapTable.accessColumn(column).itemObject := defaultDeb;
		foreach service in bank.services where not service.isNotAvailableForEntry do
			row := row + 1;
			
			mapTable.accessRow(row).itemObject := service;
			paymentTypeMapping := bank.getServicePayTypeMapping( service, defaultDeb.CM_Debtor, false );	// the specific one for this debtor only.
			paymentType := service.getPaymentType( defaultDeb.CM_Debtor );

			
			if paymentTypeMapping &lt;&gt; null then
				mapTable.accessCell(row,column).text := app.paymentTypeEnumToString( paymentType );
				mapTable.accessedCell.fontBold := true;
				mapTable.accessedCell.foreColor := Black;
 			else
				mapTable.accessCell(row,column).text := app.paymentTypeEnumToString( paymentType ); 
				mapTable.accessedCell.fontBold := false;
				mapTable.accessedCell.foreColor := DarkGray;
			endif;
			mapTable.accessedCell.itemObject := paymentTypeMapping;
			
		endforeach;
		count := count + 1;
		pd.progress.partsDone := count;
		app.doWindowEvents(0);
	endif;
	// 19.10.2018 cnwma1 TFS #41281
	
	foreach dn in theDebtors do
		if not dn.isKindOf(CM_Debtor) then
			continue;
		endif;
		if not global.isValidObject(dn) then
			continue;
		endif;
		
		column := column + 1;
		row := 1;
		
		// 19.10.2018 cnwma1 TFS #41281
		if dn.isRDT then
			continue;
		endif;
		
		mapTable.accessCell(row,column).text := dn.name;
		mapTable.accessColumn(column).itemObject := dn;
		
		foreach service in bank.services where not service.isNotAvailableForEntry do
			row := row + 1;
			
			mapTable.accessRow(row).itemObject := service;
			
			paymentTypeMapping := bank.getServicePayTypeMapping( service, dn.CM_Debtor, false );	// the specific one for this debtor only.
			paymentType := service.getPaymentType( dn.CM_Debtor );
			
			if paymentTypeMapping &lt;&gt; null then
				mapTable.accessCell(row,column).text := app.paymentTypeEnumToString( paymentType );
				mapTable.accessedCell.fontBold := true;
				mapTable.accessedCell.foreColor := Black;
 			else
				mapTable.accessCell(row,column).text :=  app.paymentTypeEnumToString( paymentType ); 
				mapTable.accessedCell.fontBold := false;
				mapTable.accessedCell.foreColor := DarkGray;
			endif;
			mapTable.accessedCell.itemObject := paymentTypeMapping;
			
		endforeach;

		count := count + 1;
		pd.progress.partsDone := count;
		app.doWindowEvents(0);
	endforeach;
	
	self.doComboDebtorUpdateBuild(theDebtors);
	
	mapTable.row := 1;
	mapTable.column := 1;

	self.setEnableObjects();
	if mapTable.columns &gt; 1 then	
		mapTable.accessColumn(2).width := 100;
	endif;
epilog

	app.cmsEndLoad(ls);
	delete pd;

	delete theDebtors;
end;</source>
    </JadeMethod>
