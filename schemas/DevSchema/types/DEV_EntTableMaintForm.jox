    <JadeMethod name="isReorgPending" id="296a7440-34bb-4cd0-a6dc-fc0e49012ea1">
        <source>isReorgPending() : Boolean;
// -----------------------------------------------------------------------------
// Created:		10 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	isPending : Boolean;
	sch : Schema;
	subs : SchemaColl;
begin
	create subs transient;
	rootSchema.withAllSubschemas(subs);
	foreach sch in subs do
		isPending := sch.needsReorg;
		if isPending then
			break;
		endif;
	endforeach;
epilog
	delete subs;
	return isPending;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="dc820c20-0357-4f83-b87a-41e4afa7dd27">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;

begin

	self.handleMenusForModalDisplay();
	self.setControlDistances();

	self.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;

	create self.myEntTableAgent transient;
	self.myEntTableAgent.myEntTableDataRoot := self.myEntTableDataRoot;
	
	cmbGroup.listCollection(self.myEntTableDataRoot.allEntTableGroups, true, 0);
	
	self.initTables(tblGroup, true);
	self.initTables(tblDef, false);
	self.initTables(tblView, false);
		
	self.disableGroupEdit();
	self.disableDefEdit();
	self.disableViewEdit();
	
	btnCancelGroup.enabled := false;
	btnSaveGroup.enabled := false;
//	self.cmbGroup.top := self.btnAddGroup.top;
	tblGroup.tabKey := J_key_Tab;
	tblDef.tabKey 	:= J_key_Tab;
	tblView.tabKey 	:= J_key_Tab;
	
	self.currentSortKey := 'name';
	
	self.myRowDynaDict.setMembership(EntTableRow);
	self.myRowDynaDict.addMemberKey(currentSortKey, false, false);
	self.myRowDynaDict.endKeys(true);
	self.frmToolbarBtns.left := 2000;
	
	self.caption := self.caption &amp; ' - ' &amp; app.dbPath;
	
	self.resize;
	
	self.btnSort.visible := process.isJLGAB1();
	self.btnLoadFrmGlobCn.enabled := false;
	self.btnUnloadAsScm.enabled := false;
	self.btnSaveToGlobCon.enabled := app.isDevelopmentSystemMain();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mnuGroupDependOn_click" id="8c70f201-c607-40b2-9092-cfef4fd62a8c">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGroupDependOn_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     03 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRow		: Integer;
	dependOnFrm	: DEV_EntTableDependOnForm;
	entTableRow	: EntTableRow;
	
begin

	if self.grpEditEnabled then
		self.saveGroupProxyData();
	endif;

	theRow := tblGroup.row;
	entTableRow := tblGroup.accessRow(theRow).itemObject.EntTableRow;
	
	if entTableRow &lt;&gt; null then
		create dependOnFrm transient;
		
		if self.grpEditEnabled then
			dependOnFrm.viewOnly := false;
		else
			dependOnFrm.viewOnly := true;
		endif;
		
		if dependOnFrm.init(tblGroup.accessCell(theRow, 1).text,
					    entTableRow, self.myCurrentGroup) then
			dependOnFrm.centreWindow;
			dependOnFrm.showModal;
		endif;
	endif;

epilog
	if dependOnFrm &lt;&gt; null then
		delete dependOnFrm;
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuGrpAddRow_click" id="3d880840-f6d9-4a5e-83fb-7306eae99e3d">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGrpAddRow_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 12 Jan 2026  navlc30     JIRA 36954 Story MTN | Highlight Mandatory fields
// ---------------------------------------------------------------------------
vars
	rowName	: String;
	newRow	: EntTableRowProxy;
	idx		: Integer;
	
begin

	read rowName;
	if rowName = null then
		return;
	endif;
	
	if rowName.length &gt;= 27 then
		app.msgBox('Length of name must be smaller than 26 chars - otherwise global constant name too large with ETRow_ prefix','nope',0);
		return;
	endif;
	create newRow transient;
	newRow.setForProxy(rowName, null, null, null, Table.InputType_TextBox, 
//rs1 june 2006				EntTableEntity.InputTypeWeb_TextBox, null, true, null, null, null, null, rowName, null, null);
				//EntTableEntity.InputTypeWeb_TextBox, null, true, null, null, null, null, null, null, null);				// PAR #31155
				//EntTableEntity.InputTypeWeb_TextBox, null, true, null, null, null, null, null, null, null, null);			// PAR #31155 //12.01.2026 navlc30 #36954
				EntTableEntity.InputTypeWeb_TextBox, null, true, null, null, null, null, null, null, null,false,null);					  //12.01.2026 navlc30 #36954
	
	self.allProxyEntTableRows.add(newRow);
	
	// Find the position on the table for the row
	idx := 0;
	foreach idx in 2 to tblGroup.rows do
		if rowName &lt; tblGroup.accessCell(idx, 1).text then
			break;
		endif;
	endforeach;
	
	// add the new row into the correct position on the table.
	
	if idx = 0 then
		idx := tblGroupAddRow(newRow);
	else
		tblGroupAddRowAt(newRow, idx);
	endif;
	
	// set cursor to the new row;
	
	tblGroup.topRow := idx;
	tblGroup.row := idx;
	tblGroup.column := 2;

	self.myEntTableAgent.showAddGlobalConstantMsg(self.myEntTableAgent.RowType, rowName);
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuGrpCntrlProperties_click" id="c608edf2-6e2d-4e13-8674-f5bfd3470cd2">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGrpCntrlProperties_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     28 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow		: Integer;
	cntrlFrm	: DEV_EntTableControlForm;
	entTableRow	: EntTableRow;
	entTableTextBox	: EntTableTextBox;
	
begin

	if self.grpEditEnabled then
		saveGroupProxyData();
	endif;

	theRow := tblGroup.row;
	entTableRow := tblGroup.accessRow(theRow).itemObject.EntTableRow;
	
	if entTableRow &lt;&gt; null then
		create cntrlFrm transient;
		
		if self.grpEditEnabled then
			cntrlFrm.viewOnly := false;
		else
			cntrlFrm.viewOnly := true;
		endif;
		
		if cntrlFrm.init(tblGroup.accessCell(theRow, 1).text,
					     self.inTypeStringToEnum(tblGroup.accessCell(theRow, Col_InputType).text),
					     entTableRow.myEntTableCellControl,
					     entTableRow) then
			cntrlFrm.centreWindow;
			cntrlFrm.showModal;
		else
			// inputType must have changed and is not unhandled so
			// delete the proxy
			if self.grpEditEnabled and entTableRow.myEntTableCellControl &lt;&gt; null then
				delete entTableRow.myEntTableCellControl;
			endif;
		endif;
	endif;

epilog
	if cntrlFrm &lt;&gt; null then
		delete cntrlFrm;
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuGrpDeleteRow_click" id="1545cb66-27f1-49ca-997a-5319062338bb">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGrpDeleteRow_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: EntTableRow;
	
begin


	if tblGroup.row &lt; 1 or tblGroup.row &gt; tblGroup.rows then
		return;
	endif;

	//saveGroupProxyData();
	
	theRow := tblGroup.accessRow(tblGroup.row).itemObject.EntTableRow;
	
	if theRow &lt;&gt; null then
		if app.msgBox('Delete row ' &amp; theRow.getName, 'Please Confirm', MsgBox_OK_Cancel) = MsgBox_Return_OK then
			tblGroup.deleteRow(tblGroup.row);
			self.allProxyEntTableRows.remove(theRow);
			delete theRow;
			//tblGroup.displayCollection(self.allProxyEntTableRows, false, Table.DisplayCollection_Forward, null);
		endif;
	endif;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuShowDefs_click" id="9a0ec005-09d3-451f-9156-fd9556b7eeda">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuShowDefs_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow		: Integer;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;
	str			: String;
		
begin

	theRow := tblGroup.row;
	entTableRow := tblGroup.accessRow(theRow).itemObject.EntTableRow;
	
	if entTableRow &lt;&gt; null then
		foreach entTableDef in entTableRow.allEntTableDefs do
			if str = null then
				str := entTableDef.name;
			else
				str := str &amp; ', ' &amp; entTableDef.name;
			endif;
		endforeach;

		str := 'Defs for ' &amp; entTableRow.name &amp; ' &gt;&gt; ' &amp; str;
		staMain.caption := str;

	else
		staMain.caption := 'Row not found';
	endif;


end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="2c36c347-ef98-425e-97d1-9d90e66c8fe3">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	msgStr	: String;
	
begin

	if self.isDataChanged then
		msgStr := 'You have changed some data but not saved these changes' &amp; CrLf &amp;
				  'to global constants.  These changes will be lost the' &amp; CrLf &amp;
				  'next time that a load data from global constants is' &amp; CrLf &amp;
				  'done and will NOT be distributed.' &amp; CrLf &amp;
				  CrLf &amp;
				  'Do you want to save to global constants now?';
		if app.msgBox(msgStr, 'Warning', MsgBox_Yes_No) = MsgBox_Return_Yes then
			self.doSaveDataToGlobalConstants();
		endif;
	endif;

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resetCurrentGroup" id="fe83e2e4-25e6-49f1-bee0-f701201592fa">
