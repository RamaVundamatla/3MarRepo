    <JadeMethod name="isSnapShotDataMatch" id="cb0e7cfd-5572-4848-8fe0-6c31ff5befa9">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars
	int	: Integer;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	if _criteria.myYAData.isKindOf(CM_YADataInteger) then
		foreach int in _criteria.myYAData.CM_YADataInteger.allValues do
			if app.transportModeENumToString(int) = _propertyValue then
				return true;
			endif;
		endforeach;
	endif;

	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="cb7c20a7-f3a4-462d-85ab-3109d5fe8619">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023	navmk20	Task 57998: JADE - Storage Config - YA Criteria Storage Matching

*/

vars
	receiptTransportMode	: Integer;
	myReceiptTransportMode	: Integer;
	yaData					: CM_YAData;
begin
	
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then
		receiptTransportMode := _tiTrx.myTrackedItem.receiptTransportMode;
	elseif _ti &lt;&gt; null then 
		receiptTransportMode := _ti.receiptTransportMode;
	endif; 
	
	yaData := _criteria.myYAData;
	
	if _criteria.myYAData.isKindOf(CM_YADataInteger) then
		foreach myReceiptTransportMode in _criteria.myYAData.CM_YADataInteger.allValues do
			if myReceiptTransportMode = receiptTransportMode then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
