    <JadeMethod name="isVerifyBeforeDBLoad" id="e6cb347c-4920-4910-ac6a-6f22a84fdc1f">
        <source>isVerifyBeforeDBLoad() : Boolean;
//
// 15 Jan 2018	jlgrs1	TFS 36636 STW Cargo By Site to be partial loading
//
vars

begin
	if self.getMyTerminal.getConfig(EdiCargoByAllowPartial).Boolean then
		return false;
