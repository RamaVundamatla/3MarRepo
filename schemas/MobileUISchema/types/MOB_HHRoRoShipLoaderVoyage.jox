    <JadeMethod name="populateArea" id="11dbd7be-729e-4b2d-9465-4b969710410e">
        <source>populateArea();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2010	cnwndl1	Initial creation	CCMS MES 1077

*/

vars

	beginArea : CM_CraneTransferArea;
	voyage : CM_Voyage;
	theCranes : CM_MachineSet;
	machine : CM_Machine;
	crane : CM_Crane;
	iter : Iterator;
	area : CM_CraneTransferArea;
	index : Integer;
	
	voyageQueue : CM_VoyageQueue;
	subQueue : CM_RadioTelemetryQueue;
	
begin
	
	beginArea := cmbArea.listObject.CM_CraneTransferArea;
	
	self.cmbArea.clear();
	
	self.cmbArea.addItem( self.lblArea.caption );
	
	voyage := cmbVoyage.listObject.CM_Voyage;
	if voyage &lt;&gt; null then

		voyageQueue := voyage.myQueue;
		if voyageQueue &lt;&gt; null then
			if voyageQueue.isCraneQueue then
				crane := voyageQueue.CM_VoyageCraneQueue.crane;
				if crane &lt;&gt; null then
					area := crane.transferArea;
					if area &lt;&gt; null then
						index := cmbArea.addItem( area.id );
						cmbArea.itemObject[index] := area;
					endif;
				endif;
			endif;
		
			foreach subQueue in voyageQueue.allSubQueuesById do
				if subQueue.isCraneQueue then
					crane := subQueue.CM_VoyageCraneQueue.crane;
					if crane &lt;&gt; null then
						area := crane.transferArea;
						if area &lt;&gt; null then
							index := cmbArea.addItem( area.id );
							cmbArea.itemObject[index] := area;
						endif;
					endif;
				endif;
			endforeach;
		endif;
		
	endif; 
	
	if cmbArea.listCount = 2 then
		// i.e. the select area message and one real area object
		cmbArea.listIndex := 2;	// default position.
	endif;
	
	if beginArea &lt;&gt; null then
		cmbArea.listIndex := cmbArea.findObject(beginArea);
	endif;
	
	if cmbArea.listIndex &lt; 1 then
		cmbArea.listIndex := 1;
	endif;
	
	self.setActionButtons();

epilog

	delete theCranes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateVoyages" id="8c387f2f-4306-44d2-8e92-6d4d02bcf33d">
        <source>populateVoyages();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation	CCMS 1077

*/

vars
	
	voyage : CM_Voyage;

begin
		
	self.cmbVoyage.clear();
	
	self.myMobileGenericAgent.setCurrentVoyages();
	
	self.cmbVoyage.addItem(lblVoyage.caption);
	foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
// PAR 33644		if (not voyage.isNonPlannedVoyage) and (not voyage.isNonWorkedVoyage) then
		if voyage.isLOLOorRORO() then
			continue;
		endif;
		if voyage.myShipBlockStack &lt;&gt; null then
			if self.myMobileGenericAgent.myTerminal.getConfig(VesselNameOnVoyageCombo).Boolean then //cnwrd1 nfs 31095
				self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code &amp; Tab &amp; voyage.vesselName )] := voyage;
			else
				self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code)] := voyage;
			endif;
		endif;
	endforeach;
	
	voyage := self.myMobileGenericAgent.myVoyage;
	
	if voyage &lt;&gt; null and cmbVoyage.findObject(voyage) &gt; 0 then
		cmbVoyage.listIndex := cmbVoyage.findObject(voyage);
	elseif cmbVoyage.listCount = 2 then
		cmbVoyage.listIndex := 2;
	else
		cmbVoyage.listIndex := 1;
	endif;
	
epilog

end;</source>
    </JadeMethod>
