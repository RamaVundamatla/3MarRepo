    <JadeMethod name="setForCreate" id="6af3ab55-3d8c-49d4-8b33-e11fd5d3523f">
        <updating/>
        <source>setForCreate(pProxyCamGroup:CM_CamGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pProxyCamGroup.raiseExceptionIfNotTransient(method);
	setForUpdate(pProxyCamGroup);
	self.terminal := pProxyCamGroup.terminal;

end;</source>
        <Parameter name="pProxyCamGroup" type="CM_CamGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d688f314-6870-446b-9086-9eaeae6d88d8">
        <updating/>
        <source>setForUpdate(_proxyCamGroup : CM_CamGroup) updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 june 2008	concms1		par 17268 CAMs messages by freight forwarder
// ---------------------------------------------------------------------------
vars
	max	: String;
begin
	max := ETRow_FacilityCode;
	max := ETDef_CamGroupMaint;
	
	self.code				:= _proxyCamGroup.code;
	self.description		:= _proxyCamGroup.description;
	self.recipient			:= _proxyCamGroup.recipient;
	self.senderCode			:= _proxyCamGroup.senderCode;
	self.shippersCode := _proxyCamGroup.shippersCode;
	self.senderCodeDepot	:= _proxyCamGroup.senderCodeDepot;
	self.facilityCode		:= _proxyCamGroup.facilityCode;
	self.useCallSign		:= _proxyCamGroup.useCallSign;
//	self.useVoyageOperator	:= _proxyCamGroup.useVoyageOperator;
	self.useDailyFileName	:= _proxyCamGroup.useDailyFileName;
	self.maxSealLength		:= _proxyCamGroup.maxSealLength;
	
	self.operators.clear();
	_proxyCamGroup.operators.copy(self.operators);
	
	self.allFreightForwarders.clear;										// par 17268
	_proxyCamGroup.allFreightForwarders.copy (self.allFreightForwarders);	// par 17268

end;</source>
        <Parameter name="_proxyCamGroup" type="CM_CamGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="239cb8a3-63e0-4957-9a79-0d1f79c04bfb">
        <updating/>
        <source>setProxy(pCode, pDescription, pRecipient, pSenderCode, pSenderCodeDepot, pFacilityCode, _shippersCode : String;
	pUseCallSign ,pUseVoyageOperator,pUseDailyFileName : Boolean; pMaxSealLength : Integer;
	pOperators : CM_OperatorByCodeDict; pFreightForwarders : CM_ConsigneeConsignorSet;
	pTerminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 june 2008 concms1		par 17268 - CAMs messages by freight forwarder
// ---------------------------------------------------------------------------
vars

begin
	self.code				:= pCode;
	self.description		:= pDescription;
	self.recipient			:=  pRecipient;
	self.senderCode			:= pSenderCode;
	self.shippersCode := _shippersCode;
	self.senderCodeDepot 	:= pSenderCodeDepot;
	self.facilityCode		:= pFacilityCode;
	self.useCallSign		:= pUseCallSign;
//	self.useVoyageOperator 	:= pUseVoyageOperator;
	self.useDailyFileName 	:= pUseDailyFileName;
	self.terminal			:= pTerminal;
	self.operators.clear;
	self.maxSealLength		:= pMaxSealLength;
	pOperators.copy(self.operators);

	self.allFreightForwarders.clear;						// par 17268
	pFreightForwarders.copy (self.allFreightForwarders);	// par 17268
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pRecipient" type="String"/>
        <Parameter name="pSenderCode" type="String"/>
        <Parameter name="pSenderCodeDepot" type="String"/>
        <Parameter name="pFacilityCode" type="String"/>
        <Parameter name="_shippersCode" type="String"/>
        <Parameter name="pUseCallSign" type="Boolean"/>
        <Parameter name="pUseVoyageOperator" type="Boolean"/>
        <Parameter name="pUseDailyFileName" type="Boolean"/>
        <Parameter name="pMaxSealLength" type="Integer"/>
        <Parameter name="pOperators" type="CM_OperatorByCodeDict"/>
        <Parameter name="pFreightForwarders" type="CM_ConsigneeConsignorSet"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="81d83982-7185-4da6-aff1-12e99f7588ce">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	if self.terminal.camGroups[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="c275c64a-f6ad-467c-9348-978f06352cea">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.protocols.isEmpty = false then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "protocols", null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="5de46499-c650-44f8-97ec-e7c85e6b4a40">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="1688d2b1-a1b6-4777-9c38-9a77fc1bb050">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'code', null, null);
		app.raiseCMException(Input_required_field_code, null, null);


		
	endif;
	if self.shippersCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'shippersCode', null, null);
		app.raiseCMException(Input_required_field_shipsCode, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.maxSealLength &lt; MIN_CAMsMaxSealLength
	or self.maxSealLength &gt; MAX_CAMsMaxSealLength then
		app.raiseCMException4(ERR_ValueOutOfRange, 'Max. Seal Length', self.maxSealLength.String, MIN_CAMsMaxSealLength.String, MAX_CAMsMaxSealLength.String,null, null);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
