    <JadeMethod name="validate" id="2c5b47d1-f443-4682-b650-97d9f5bbb8b5">
        <source>validate();
//05 August 2008	cnwdw1	
//02 June 2009		concms1	Par 19520 - Allow NULL_VOYAGE_CODE to skip validation
//
vars
	pattern: CMIF_YAPattern;
	term : CM_Terminal;
begin
	/* cnwjo3 par 23437 DON'T NEED TO EXIT HERE ANYMORE.  COMMENTING OUT CODE
// par 19520 start
	if self.myCriteriaType.isKindOf (CM_YATypeVoyage) and
		self.pattern = NULL_VOYAGE_CODE then
		return;	// we know it is not a pattern
	endif;
// par 19520 - end
// par 22771 
	if self.myCriteriaType.isKindOf (CM_YATypeOperatorItem) and
		self.pattern = NULL_OPERATOR_CODE then
		return;	// we know it is not a pattern
	endif;
	*/

	if self.myCriteriaType.isKindOf(CM_YATypeTransferType) then		// 28/3/18 MAP TFS37555
		return;
	endif;

	if self.myYAParent &lt;&gt; null then
		if self.myYAParent.isKindOf(CM_YACriteria) then
			if self.myYAParent.CM_YACriteria.myYardAllocation &lt;&gt; null then
				term := self.myYAParent.CM_YACriteria.myYardAllocation.myTerminal;
			endif;
		endif;
	endif;	
	
	create pattern transient;
	pattern.setPattern(self.pattern, CMIF_YAPattern.YAPattern_Wildcard);
	if not pattern.validate(pattern.pattern,term) then
		app.raiseCMException2(ErrInvalidYACriteriaPattern, self.myCriteriaType.description,  self.pattern, null, null);
	endif;
epilog	
	delete pattern;
end;</source>
    </JadeMethod>
</Class>
