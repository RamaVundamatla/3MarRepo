    <JadeMethod name="setParserWarnings" id="8437741f-87a7-4906-ad45-d05017867a25">
        <updating/>
        <source>setParserWarnings( _value : HugeStringArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2017	cnwndl1	Initial creation	TFS 4844

*/

vars

	str : String;
	strValue : String;

begin

	if _value &lt;&gt; null and not _value.isEmpty then
		foreach str in _value do
			if strValue &lt;&gt; null then
				strValue := strValue &amp; Lf;
			endif;
			strValue := strValue &amp; str;
		endforeach;
	endif;

	global.setExtraData(self.allExtraData, self, CM_EDIFileTypeXMLOneStopCust.ParserWarnings, strValue);

epilog

end;</source>
        <Parameter name="_value" type="HugeStringArray"/>
    </JadeMethod>
