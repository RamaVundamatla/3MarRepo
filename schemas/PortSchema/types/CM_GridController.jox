    <JadeMethod name="getNumLCsForTI" id="fcb74b67-7621-4638-a961-22cbf9e4295e">
        <source>getNumLCsForTI(_ti : CM_TrackedItem) : Real;
// ---------------------------------------------------------------------------
// Created:     02 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	numUnits	: Real;
begin
	if _ti = null then
		return 0;
	endif;
	
	numUnits := _ti.getLengthInUnits();
	// numUnits is in 10' units, stackcontoller is 20' unit
	
	if numUnits &gt; 1 then
		return numUnits div 2;
	endif;
	
	return 1;
	
end;</source>
