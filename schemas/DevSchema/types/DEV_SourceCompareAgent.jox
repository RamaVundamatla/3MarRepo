    <JadeMethod name="trxCreateMethod" id="b4d6a96f-b34d-4a31-9509-ce3af2606a4e">
        <source>trxCreateMethod(_methodName,
				_methodDesc,
				_methodSource 	: String;
				_devClass 		: DEV_Class io) protected;
/*

Purpose:			Creates a DEV_Method

Parameters:			_methodName:	String		The method name
					_methodDesc:	String		The methods body/source
					_methodSource:	String		The source of the method (jadeMethodSources etc)
					_devClass:		DEV_Class	The class the method belongs to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devMethod: DEV_Method;
	
begin
	foreach devMethod in _devClass.allMethods do
		if devMethod.name = _methodName then
			devMethod.update(devMethod.methodSignature, devMethod.miscData, _methodDesc, _methodSource, devMethod.documentationTextData);
			return;
		endif;
	endforeach;
	
	devMethod := create DEV_Method(_methodName, _methodDesc, _methodSource, -1, _devClass) transient;

end;</source>
        <access>protected</access>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_methodDesc" type="String"/>
        <Parameter name="_methodSource" type="String"/>
        <Parameter name="_devClass" type="DEV_Class" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxCreateMethodSource" id="b0068d56-3c54-4044-b57c-aa10b45a64f7">
        <source>trxCreateMethodSource(_name,
						_methodSignature, 
						_miscData : String; 
						_devClass : DEV_Class io) : DEV_Method protected;
/*

Purpose:			Creates a DEV_Method

Parameters:			_name:				String		The method name
					_methodSignature:	String		The methods signature
					_miscData:			String		The data we are not interested in but needs to be written out
					_devClass:			DEV_Class	The class the method belongs to

Return Value:		The created DEV_Method

Date		Who		Reason
10 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devMethod : DEV_Method;
	
begin
	if _devClass = null then
	write "Missing Class";
	endif;
	foreach devMethod in _devClass.allMethods do
		if devMethod.name = _name then
			devMethod.update(_methodSignature, _miscData, devMethod.desc, devMethod.methodSource, devMethod.documentationTextData);
			return devMethod;
		endif;
	endforeach;

	devMethod := create DEV_Method(_name, "", "jadeMethodSources", -1, _devClass) transient;
	devMethod.update(_methodSignature, _miscData, devMethod.desc, devMethod.methodSource, devMethod.documentationTextData);
	return devMethod;

end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_methodSignature" type="String"/>
        <Parameter name="_miscData" type="String"/>
        <Parameter name="_devClass" type="DEV_Class" usage="io"/>
        <ReturnType type="DEV_Method"/>
    </JadeMethod>
    <JadeMethod name="trxCreateReference" id="4b1bcbef-354b-4c53-b382-9409d2b4c362">
        <source>trxCreateReference(_referenceName, 
					_referenceType, 
					_miscData,
					_documentationTextData	: String; 
					_devClass 				: DEV_Class io) : DEV_Reference protected;
/*

Purpose:			Creates a DEV_Reference

Parameters:			_referenceName:			String		The name of the reference
					_referenceType:			String		The type of the reference
					_miscData:				String		The data we are not interested in but needs to be written out
					_documentationTextData:	String		The documentation text on the global constant category
					_devClass:				DEV_Class	The class the method belongs to

Return Value:		

Date		Who		Reason
09 November 2021	navpw1	Initial creation TFS: 52202

*/
vars
	devReference : DEV_Reference;
	
begin
	devReference := create DEV_Reference(_referenceName, _referenceType, _miscData, _documentationTextData, -1, _devClass) transient;
	return devReference;
	
end;</source>
        <access>protected</access>
        <Parameter name="_referenceName" type="String"/>
        <Parameter name="_referenceType" type="String"/>
        <Parameter name="_miscData" type="String"/>
        <Parameter name="_documentationTextData" type="String"/>
