    <JadeMethod name="compressedDataToHSD" id="6e439600-66cf-41f0-bb05-a69e9e8cd684">
        <source>compressedDataToHSD(_ediFile : CM_EDIFile; _theLines : HugeStringArray input) protected;
//
// 28 Jul 2015	cnwrs1	Par 36683 since new data is in rawData suport old data (8.3.2) from compressedFilelines
//
vars
	binaryLine : Binary;
	str : String;
begin
	foreach binaryLine in _ediFile.allCompressedFileLines do
		str := binaryLine.uncompressToString();
		_theLines.add(str);
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
