    <JadeMethod name="getProductMinMaxObject" id="e43d9d0f-5d73-441d-8b9d-1f473fa17132">
        <source>getProductMinMaxObject(_cargoType: CM_CargoType; _prod: CM_Product): CM_TerminalAreaProductMinMax;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2022	jlier1	Initial creation 52052

*/

vars

	minMax : CM_TerminalAreaProductMinMax;
	cargoType : CM_CargoType;
	
begin
	if self.myGroup &lt;&gt; null then
		cargoType:=_cargoType;
		if cargoType = null and _prod &lt;&gt; null then
			cargoType:=_prod.myCargoType;
		endif;
		
		minMax:= self.myGroup.allProductMinMax[self.myGroup,cargoType,_prod];	
		if minMax &lt;&gt; null then
			return minMax;
		endif;
	endif;
	
	return inheritMethod(_cargoType, _prod);


epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_prod" type="CM_Product"/>
        <ReturnType type="CM_TerminalAreaProductMinMax"/>
    </JadeMethod>
