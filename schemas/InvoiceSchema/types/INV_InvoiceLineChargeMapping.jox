    <JadeMethod name="doDelete" id="6b9080bc-8a67-4bf1-b2ca-6e8124a483cd">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	realMapping : CM_InvoiceLineChargeMapping;
	theReturn : Integer;
begin
	realMapping := self.myCurrentBank.allInvLineChargeMappings[self.myCurrentInvLineType, self.myCurrentParentObject, self.myCurrentCombinationObject];

	if realMapping = null then	
		return;
	endif;
	while true do
		app.myTrxDA.trxDeleteInvoiceLineChargeMap(realMapping, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Mapping Remove", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

end;</source>
    </JadeMethod>
