    </JadeMethod>
    <JadeMethod name="doSaveDeliveryRequest" id="feb155cf-b218-46c5-8861-37247bd926b5">
        <updating/>
        <source>doSaveDeliveryRequest() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


/****Changes

Date		Name	TFS#			Description
============================================================================
13/08/2009	cnwrd1					Initial creation
08/04/2011	cnwmh5	PAR #27347  	Add cmsEndLoad or endLoad to epilog so 
									that if error occurs it will not leave 
									it in beginLoad state.
03/10/2018	jlgka1	40698			Add "heavyRated" in method call 
									setProxyYardDelivery as a result of changes
									in that method.
30/01/2019	jlgdi1	43131			Added condition check if 'release' is not null before 
									extracting the value of the 'heavyRate' attribute to avoid 1090 error.
03 Nov 2022 navsks20 52721			 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
============================================================================*/
vars
	isoGroup			: String;
	isClean				: Boolean;
	result				: Integer;
	addToRTQ			: Boolean;
	theRealJob			: CM_YardInternalJob;
	theProxyJob			: CM_YardInternalJob;
	theYDRequest		: CM_YardDeliveryRequest;
	theProxyRequest		: CM_YardDeliveryRequest;
	subTerminalObj		: CM_SubTerminal;	// cnwdad1 03/07/2009 - CCMS 1735.
	theTotalReq			: Integer;
	allAvGrades			: IntegerArray;	
	targetLocation		: String;
	sourceLocation		: CM_LocationsController;
	sourceTA			: CM_TerminalArea;
	sourceGO 			: CM_GridObject;
	theID				: String;
	theRemarks			: String;
	theOperatorCode		: String;
	theISOTypeCode		: String;
	loadStateSet		: Boolean;
	bestPick			: Boolean;
	requiredBtDT 		: TimeStamp;
	targetSubTerminal 	: CM_SubTerminal;
	release				: CM_BulkRelease;
	releaseItem 		: CM_ReserveDetail;
	rtQueue				: CM_RadioTelemetryQueue;
	priority			: Integer;
	isHeavyRated 		: Boolean;
	updSubTermObj		: CM_SubTerminal;	//3 Nov 2022 NAVSKS20 TFS 52721
	isAvail 			: Boolean;			//3 Nov 2022 NAVSKS20 TFS 52721
begin
	create allAvGrades transient;
	self.getInfoOffScreen(	allAvGrades,
							theOperatorCode,
							theISOTypeCode,
							targetLocation,
							sourceLocation,
							sourceTA,		// 23098
							sourceGO, //cnwrd1 ccms 2098
							theTotalReq,
							addToRTQ,
							isClean,
							isoGroup,
							theID,
							subTerminalObj,
							theRemarks,
							requiredBtDT,
							targetSubTerminal,
							release,
							releaseItem,
							rtQueue,
							priority,
							bestPick,
							updSubTermObj,	//3.11.2022	NAVSKS20 TFS 52721
							isAvail			//3.11.2022	NAVSKS20 TFS 52721
							);
	sourceLocation := null; //cnwrd1 par 29351 3.4.2012 we dont use this for this type now so we will blank it incase it causes issues later
	if release &lt;&gt; null then
		isHeavyRated := release.getHeavyDuty().asBooleanJMT();
	endif;
	if self.updateMode = self.Mode_Add then
		create theProxyJob transient;
		theProxyJob.setProxyYardDelivery(theID,self.myTerminal);
		theProxyJob.setPriority( priority );
		
		create theProxyRequest transient;
		theProxyRequest.setProxyYardDelivery(	theISOTypeCode,
												theOperatorCode,
												theRemarks,
												targetLocation,
												app.getMyUserCode(),
												isClean,
												bestPick,
												isoGroup,
												theProxyJob,
												allAvGrades,
												theTotalReq,
												subTerminalObj,
												sourceLocation,
												sourceTA,		// 23098
												sourceGO,  //cnwrd1 ccms 2098
												requiredBtDT,
												targetSubTerminal,
												release,
												releaseItem,
												rtQueue,
												null,
												isHeavyRated,
												updSubTermObj,//3.11.2022	NAVSKS20 TFS 52721
												isAvail);	//3.11.2022	NAVSKS20 TFS 52721
		if sourceTA &lt;&gt; null then
			self.allSelectedTAs.add(sourceTA);
			self.allSelectedTAGridObjs.add(sourceGO);
		endif;
		theProxyRequest.setNominatedTAs(self.allSelectedTAs,self.allSelectedTAGridObjs );
		
		theProxyRequest.setMTCommodity();  //cnwrd1 par 26783 18.1.2011 - set a default mt commodity for now REMOVE IF/WHEN we have commodity on the form (7.9.1?)
		
		while true do
			app.myTrxCA.trxCreateYardInternalDeliveryR(theProxyJob, theRealJob, theProxyRequest, theYDRequest, addToRTQ, app.myPassport);
			if app.myPassport.trxCompletedOK then
			
				break;
			else
				if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
					//do show it here, ask Q below.
					result := 1;				
				else
					result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
				endif;
				if result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					// only reprocess the wles that had warnings.
					continue;
				endif;
			endif;
			break;
		endwhile;										
	
	self.myCurrentObject := theRealJob;

	elseif self.updateMode = self.Mode_Update then
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_YardInternalJob) then
			theRealJob := self.myCurrentObject.CM_YardInternalJob;
			theProxyJob :=  app.createUpdateProxy(theRealJob).CM_YardInternalJob; //self.myProxyObject.CM_YardInternalJob;
		
			theYDRequest := theRealJob.allRequests.first.CM_YardDeliveryRequest;
		endif;

		app.cmsBeginLoad(loadStateSet);
		theProxyRequest := theYDRequest.pxyGetProxyObject;
		if theProxyRequest = null then		
			theProxyRequest := theYDRequest.pxyCreateUpdateProxy;
		endif;
		app.cmsEndLoad(loadStateSet);

		theProxyJob.setProxyYardDelivery(theID,self.myTerminal);
		theProxyJob.setPriority( priority );

		theProxyRequest.setProxyYardDelivery(	theISOTypeCode,
												theOperatorCode,
												theRemarks,
												targetLocation,
												app.getMyUserCode(),
												isClean,
												bestPick,
												isoGroup,
												theProxyJob,
												allAvGrades,
												theTotalReq,
												subTerminalObj,
												sourceLocation,
												sourceTA,		// 23098
												sourceGO,
												requiredBtDT,
												targetSubTerminal,
												release,
												releaseItem,
												rtQueue,
												null,
												isHeavyRated,
												updSubTermObj,	//3.11.2022	NAVSKS20 TFS 52721
												isAvail);		//3.11.2022	NAVSKS20 TFS 52721
		
		while true do
			app.myTrxUA.trxUpdateYardInternalDeliveryR(theProxyJob, theProxyRequest, addToRTQ, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
					//do show it here, ask Q below.
					result := 1;				
				else
					result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
				endif;
				if result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					// only reprocess the wles that had warnings.
					continue;
				endif;
			endif;
			break;
		endwhile;																	
	
		self.myCurrentObject := theRealJob;	
	endif;
		
	if app.myPassport.returnCode = Request_failed_auto_plan then
		if app.msgBox(app.getErrorString(Item_faile_auto_plan_wish_vi), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then	// 13/07/2010 cnwmh5 #24966
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
	
	if result = IDOK then
		return true;
	endif;
	
	return false;
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	delete allAvGrades;
	if theProxyJob &lt;&gt; null then
		delete theProxyJob;
	endif;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveMoveRequest" id="e1647f8e-fafb-4036-83c7-17ff4957ea13">
        <updating/>
        <source>doSaveMoveRequest(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation
3  November 2022 		navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
*/

vars
	isoGroup			: String;
	isClean				: Boolean;
	addToRTQ			: Boolean;
	theRealJob			: CM_YardInternalJob;
	//theProxyRequest		: CM_YardDeliveryRequest;
	theTotalReq			: Integer;
	//theAvGradeCode		: Integer;
	allAvGrades			: IntegerArray;
	targetLocation		: String;
	theSourceLocation	: CM_LocationsController;
	theSourceTA			: CM_TerminalArea;
	sourceGO			: CM_GridObject;
	theID				: String;
	theRemarks			: String;
	theOperatorCode		: String;
	theISOTypeCode		: String;
	theYardWorkJobParams	: CMIF_YardWorkJobParams;
	aTermArea			: CM_TerminalArea;
	statusHeld			: Boolean;
	noChecks			: Boolean;
	subTerminalObj		: CM_SubTerminal;		// cnwdad1 03/07/2009 - CCMS 1735.
	requiredBtDT 	: TimeStamp;
	targetSubTerminal 	: CM_SubTerminal;
	release			: CM_BulkRelease;
	releaseItem 	: CM_ReserveDetail;
	rtQueue			: CM_RadioTelemetryQueue;
	priority,			
	result			: Integer;
	bestPick		: Boolean;
	updSubTerm		: CM_SubTerminal;	//3 Nov 2022 NAVSKS20 TFS 52721
	isAvail			: Boolean;			//3 Nov 2022 NAVSKS20 TFS 52721
begin
	// ########################
	// Get Stuff Of The Screen
	create allAvGrades transient;
	
	self.getInfoOffScreen(	allAvGrades,
							theOperatorCode,
							theISOTypeCode,
							targetLocation,
							theSourceLocation,
							theSourceTA,		// 23098
							sourceGO,
							theTotalReq,
							addToRTQ,
							isClean,
							isoGroup,
							theID,
							subTerminalObj,
							theRemarks,							
							requiredBtDT,
							targetSubTerminal,
							release,
							releaseItem,
							rtQueue,
							priority,
							bestPick,
							updSubTerm,	//3 Nov 2022 NAVSKS20 TFS 52721
							isAvail     //3 Nov 2022 NAVSKS20 TFS 52721
							);							
							
							
	noChecks := self.chkNoChecks.getBoolean(); //  tblMain.getValueByName(ETRow_NoChecks).Boolean;
	statusHeld := self.chkStatusHeld.getBoolean(); //  tblMain.getValueByName(ETRow_StatusHeld).Boolean;

	// ########################
	// Stuff it into the Interface Object
	create theYardWorkJobParams transient;
	theYardWorkJobParams.defaultQueueToHeld := statusHeld;
	theYardWorkJobParams.addToQueue := true;
	theYardWorkJobParams.mySourceLocation := theSourceLocation;
	theYardWorkJobParams.mySourceTA := theSourceTA;	// 23098
	aTermArea := self.myTerminal.allTerminalAreas[targetLocation.trimBlanks];
	theYardWorkJobParams.priority := priority;
	
	if aTermArea &lt;&gt; null then
		theYardWorkJobParams.myTargetTA := aTermArea;
		theYardWorkJobParams.myTargetLocation := aTermArea.getLocationsController;
	endif;
	
	theYardWorkJobParams.numToMove := theTotalReq;
	theYardWorkJobParams.overridePlacementRestrictions := noChecks;
	theYardWorkJobParams.typeToCreate := Controller_Strip;
	theYardWorkJobParams.jobId := theID;
	self.allSelectedTIs.copy(theYardWorkJobParams.allSelectedTIs);
	
	//new , CNWRD1
	theYardWorkJobParams.requredByDT := requiredBtDT;
	theYardWorkJobParams.myQueueToAddTo := rtQueue;
	theYardWorkJobParams.isBestPick := bestPick;		// 23098
	
	
	theYardWorkJobParams.remarks := theRemarks; //cnwrd1 par 24961 13.7.2010
	theYardWorkJobParams.mySubTerminalSource := subTerminalObj;   //cnwrd1 par 24961 14.7.2010 set source sub terminal
	
	// ##########################
	// TRX it!
	if self.updateMode = self.Mode_Add then
		while true do
			app.myTrxCA.trxCreateYardInternalJob(theYardWorkJobParams,theRealJob,self.myTerminal, app.myPassport);
			if not app.myPassport.trxCompletedOK then
				result:=app.showErrorWarningDialog('Yard Move Request', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
				if result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				else
					return false;
				endif;
			endif;
			break;
		endwhile;
		self.myCurrentObject := theRealJob;
		
	endif;
	

	return true;
epilog
	delete allAvGrades;
/*	if theProxyRequest &lt;&gt; null then
		delete theProxyRequest;
	endif;*/
	self.mousePointer := Window.MousePointer_Default;
	delete theYardWorkJobParams;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSavePlanOnPickup" id="fd898720-7207-41bd-b6cf-c48c4d643782">
        <updating/>
        <source>doSavePlanOnPickup() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwrd1	Initial creation
03 November 2022		navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
*/

vars
	isoGroup			: String;
	isClean				: Boolean;
	addToRTQ			: Boolean;
	theRealJob			: CM_YardInternalJob;
	theTotalReq			: Integer;
	allAvGrades			: IntegerArray;
	targetLocation		: String;
	theSourceLocation	: CM_LocationsController;
	theSourceTA			: CM_TerminalArea;
	sourceGO			: CM_GridObject;
	theID				: String;
	theRemarks			: String;
	theOperatorCode		: String;
	theISOTypeCode		: String;
	theYardWorkJobParams	: CMIF_YardWorkJobParams;
	aTermArea			: CM_TerminalArea;
	statusHeld			: Boolean;
	noChecks			: Boolean;
	subTerminalObj		: CM_SubTerminal;		// cnwdad1 03/07/2009 - CCMS 1735.
	requiredBtDT 	: TimeStamp;
	targetSubTerminal 	: CM_SubTerminal;
	release			: CM_BulkRelease;
	releaseItem 	: CM_ReserveDetail;
	rtQueue			: CM_RadioTelemetryQueue;
	priority		: Integer;
	bestPick		: Boolean;
	result			: Integer;
	str				: String;
	params 			: CMIF_PlanOnPickup;
	updSubTerm		: CM_SubTerminal;	//3.11.2022	navsks20 TFS 52721
	isAvail			: Boolean;
begin
	// ########################
	// Get Stuff Of The Screen
	create allAvGrades transient;
	
	self.getInfoOffScreen(	allAvGrades,
							theOperatorCode,
							theISOTypeCode,
							targetLocation,
							theSourceLocation,
							theSourceTA,		// 23098
							sourceGO,
							theTotalReq,
							addToRTQ,
							isClean,
							isoGroup,
							theID,
							subTerminalObj,
							theRemarks,							
							requiredBtDT,
							targetSubTerminal,
							release,
							releaseItem,
							rtQueue,
							priority,
							bestPick,
							updSubTerm,	//3.11.2022	navsks20 TFS 52721
							isAvail  	//3.11.2022	navsks20 TFS 52721
							);							
				
	aTermArea := self.myTerminal.allTerminalAreas[targetLocation.trimBlanks];
							
	//noChecks := self.chkNoChecks.getBoolean(); //  tblMain.getValueByName(ETRow_NoChecks).Boolean;
	//statusHeld := self.chkStatusHeld.getBoolean(); //  tblMain.getValueByName(ETRow_StatusHeld).Boolean;

	// ########################
	// Stuff it into the Interface Object
	/*
	create theYardWorkJobParams transient;
	theYardWorkJobParams.defaultQueueToHeld := statusHeld;
	theYardWorkJobParams.addToQueue := true;
	theYardWorkJobParams.mySourceLocation := theSourceLocation;
	theYardWorkJobParams.mySourceTA := theSourceTA;	// 23098
	aTermArea := self.myTerminal.allTerminalAreas[targetLocation.trimBlanks];
	theYardWorkJobParams.priority := priority;
	
	if aTermArea &lt;&gt; null then
		theYardWorkJobParams.myTargetTA := aTermArea;
		theYardWorkJobParams.myTargetLocation := aTermArea.getLocationsController;
	endif;
	
	theYardWorkJobParams.numToMove := theTotalReq;
	theYardWorkJobParams.overridePlacementRestrictions := noChecks;
	theYardWorkJobParams.typeToCreate := Controller_Strip;
	theYardWorkJobParams.jobId := theID;
	self.allSelectedTIs.copy(theYardWorkJobParams.allSelectedTIs);
	
	//new , CNWRD1
	theYardWorkJobParams.requredByDT := requiredBtDT;
	theYardWorkJobParams.myQueueToAddTo := rtQueue;
	theYardWorkJobParams.isBestPick := bestPick;		// 23098
	
	
	theYardWorkJobParams.remarks := theRemarks; //cnwrd1 par 24961 13.7.2010
	theYardWorkJobParams.mySubTerminalSource := subTerminalObj;   //cnwrd1 par 24961 14.7.2010 set source sub terminal
	*/
	
	// ##########################
	

	create params transient;
	params.moveMode := QUEUE_PLAN_ON_PICKUP;
	params.myTargetTA := aTermArea; //self.cmbTermArea.listObject.CM_TerminalArea;
	params.myJob := null;
	params.jobID := theID;
	params.priority := priority;
	params.mySelectedRTQueue := rtQueue;
	params.requiredByDT :=  requiredBtDT;
	params.remarks := theRemarks;

	//params.showWarningWhenNoPlan := false;
	self.allSelectedTIs.copy(params.allTrackedItems);

	while true do
		str := app.myTrxUA.trxUpdateQueuePlanOnPickup(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;	
	
	/*
	// TRX it!
	if self.updateMode = self.Mode_Add then
		app.myTrxCA.trxCreateYardInternalJob(theYardWorkJobParams,theRealJob,self.myTerminal, app.myPassport);
		self.myCurrentObject := theRealJob;
	endif;
	
	if not app.myPassport.trxCompletedOK then
		app.showErrorWarningDialog('Yard Move Request', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	else
		self.clearErrorWarnings();
		//self.unloadForm() // cnwrd1 par 22987 8.3.2010
		return true;
	endif;
	*/
	return true;
	
epilog
	delete allAvGrades;
	self.mousePointer := Window.MousePointer_Default;
	delete params;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveReal" id="51cb76ac-0d27-4624-af2c-469c958da9c6">
        <updating/>
        <source>doSaveReal() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2010	cnwrd1	Initial creation
// cnwrd1 par 22987 8.3.2010
*/

vars
	result : Boolean;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if self.typeToCreate = Depot_Request then
		return self.doSaveDeliveryRequest();

	elseif self.typeToCreate = Controller_Strip then
		return self.doSaveMoveRequest();		
	elseif self.typeToCreate = Plan_On_Pickup then//cnwrd1 par 26734 CCMS 2014 plan on pickup
		return self.doSavePlanOnPickup();		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Invalid_type_create));
		return false;
	endif;

	//if result and self.amInitialisingWithObject  then
	//	self.unload();	
	//endif;
	
	/*if app.myPassport.() then
		self.unloadForm;
	endif;
	*/
	return true;
epilog	
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetCaption" id="c30992f9-530d-4304-b8bd-5158939add46">
        <updating/>
        <source>doSetCaption() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwrd1	Initial creation

