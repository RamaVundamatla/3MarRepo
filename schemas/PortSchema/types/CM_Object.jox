    <JadeMethod name="getAttributeStringForList" id="2a1ec1e9-a098-4bb9-90ff-55c3f78615ea">
        <source>getAttributeStringForList(_list : StringArray) : String;
// ---------------------------------------------------------------------------
// Created:     09 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	attrName	: String;
	tmpStr,
	rtnStr		: String;
	firstTime	: Boolean;

begin

	firstTime := true;
	foreach attrName in _list do
		tmpStr := self.getDisplayStringForAttribute(attrName, true);
		if firstTime then
			firstTime := false;
			rtnStr := tmpStr;
		else
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif; 
	endforeach;

	return rtnStr;
	
end;</source>
        <Parameter name="_list" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
