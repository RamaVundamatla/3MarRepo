    <JadeMethod name="isStackFull" id="b9340dd1-34a2-49b4-b091-aa266dbbac82">
        <source>isStackFull(obj : CMIF_AutoMovePlan input);
/*
 ------------------------------------------------------------------------
Created:			27 November 2001 by cnwdwq1
Purpose:			Test to see if this area can accept the object passed in.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	maxHeight : Integer;
	heightOfThisTI	:	Integer;
	totalInThisStack	:	Integer;
	totalRealInThisStack	:	Integer;
	totalPlanInThisStack	:	Integer;
	totalRealPlanInThisStack	:	Integer;
	totalQueueInThisStack	:	Integer;
	totalRealQueueInThisStack	:	Integer;
	iterStr	:	String;
	locnId	:	String;
begin
	obj.updateController(null);
	iterStr := obj.iteration.String;
	maxHeight := (self.myGridArea.heightOfStack) * 2;

	heightOfThisTI := obj.myTrackedItem.getHeightOfTI;	
	//----------------
	//Test for full in REAL mode FIRST.
	//----------------
	totalInThisStack := self.getStackHeightOfTIs(REAL_MODE, null);
	if totalInThisStack &gt; 0 then 
		totalRealInThisStack := totalInThisStack div 2;
	endif;
	locnId := self.getFullId;
	if totalInThisStack + heightOfThisTI &gt; maxHeight then
		//obj.addVerboseLogEntry(locnId &amp; iterStr &amp; " will be over capacity if this move eventuates.", IsError); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString2(Will_over_capac_this_move_even,locnId, iterStr), IsError, Will_over_capac_this_move_even);
		return;	//Its already full, or us going into it will bust it
	endif;

	if obj.moveMode = REAL_MODE then
		//Return now if we are in real mode.
		obj.updateController(self);
		return;
	endif;
	//--------------------
	//OK, we've validate that there IS space here in this stack in REAL mode. We now have to
	//check the other modes as well
	//--------------------
	totalPlanInThisStack	:= self.getStackHeightOfTIs(PLANNING_MODE, null);
	if totalPlanInThisStack &gt; 0 then 
		totalRealPlanInThisStack := totalPlanInThisStack div 2;
	endif;
	totalQueueInThisStack	:= self.getStackHeightOfTIs(QUEUE_MODE, null);
	if totalQueueInThisStack &gt; 0 then 
		totalRealQueueInThisStack := totalQueueInThisStack div 2;
	endif;
	if totalPlanInThisStack + heightOfThisTI &gt; maxHeight then
		//obj.addVerboseLogEntry(locnId &amp; iterStr &amp; " will be over Planned capacity if this move eventuates.", IsError); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString2(Will_over_plann_capac_this_mov,locnId, iterStr), IsError, Will_over_plann_capac_this_mov);
		return;	//Its already full, or us going into it will bust it
	endif;	
	if totalQueueInThisStack + heightOfThisTI &gt; maxHeight then
		//obj.addVerboseLogEntry(locnId &amp; iterStr &amp; " will be over Queued capacity if this move eventuates.", IsError); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString2(Will_over_queue_capac_this_mov,locnId, iterStr), IsError, Will_over_queue_capac_this_mov);
		return;	//Its already full, or us going into it will bust it
	endif;	
	//-------------------
	//Test to make sure that overall we wont bust it!
	//-------------------
	if totalPlanInThisStack + totalQueueInThisStack + totalInThisStack + heightOfThisTI &gt; maxHeight then
		//obj.addVerboseLogEntry(locnId &amp; iterStr &amp; " will be over capacity if the planned and queued moves plus this move eventuates.", IsError); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString2(Will_over_capac_plann_queue_mo,locnId,iterStr), IsError, Will_over_capac_plann_queue_mo);
		return;	//Its already full, or us going into it will bust it
	endif;	
	//----------------
	//We are happy, we are not full!!
	//----------------
	obj.updateController(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isSuitableForTI" id="10d033f8-9726-4cc6-92c0-1c46b32d2b35">
        <source>isSuitableForTI(control: CMIF_MoveController): Boolean;
/*
 ------------------------------------------------------------------------
Created:			05 October 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin

	if control = null then
		return true;
	endif;
	
	return control.myTrackedItem.isKindOf(CM_Tower);
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
