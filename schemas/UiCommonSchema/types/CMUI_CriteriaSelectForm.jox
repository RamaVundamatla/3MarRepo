    <JadeMethod name="initialiseTable" id="bdff7dd0-1737-4866-8d21-fea266a2d7a4">
        <source>initialiseTable() protected;
/*
Date		Who		Reason
22/02/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	table	:Table;
begin
	table			:= self.tblAvailable;

	table.rows 						:= 0;	
	table.columns 					:= 3;
	table.fixedColumns 				:= 0;
	table.fixedRows 				:= 0;
	table.gridLines 				:= false;
	table.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	table.accessColumn(1).width 	:= 25;
	table.accessColumn(2).width 	:= 120;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
