    <JadeMethod name="listAddListDummy" id="b874cc1a-9448-4570-a46a-418286810fa9">
        <source>listAddListDummy(pTheListbox:ListBox input; pIndex:Integer; pLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		23 July 2002 by cnwdad1
//
// Purpose:		Adds a dummy leaf node to the specified listbox control.
//
// Parameters:	pTheListbox - The listbox control to add the dummy leaf to.
//				pIndex - The position index to add the dummy leaf at.
//				pLevel - The item level of the dummy leaf node.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dummyIndex	: Integer;
	
begin
	dummyIndex	:=	pIndex;
	pTheListbox.addItemAt(self.LISTBOX_DUMMY_LEAF, dummyIndex);
	pTheListbox.itemLevel[dummyIndex]	:=	pLevel;
	pTheListbox.itemData[dummyIndex]	:=	self.LISTBOX_NODE_DUMMY;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listAddListNode" id="d07920d1-948f-45a3-80bf-d1451d05e265">
        <source>listAddListNode(pTheListbox:ListBox input; pName:String; pNodeFlag:Integer; pIndex:Integer; pLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Purpose:		Adds a folder node to the specified listbox control for a directory.
//
// Parameters:	pTheListbox - The listbox control to add the folder to.
//				pName - The name of the directory folder.
//				pNodeFlag - A flag to indicate which JADE node the folder belongs to.
//				pIndex - The position index to add the folder at.
//				pLevel - The item level of the folder node.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dummyIndex	: Integer;
	
begin
	pTheListbox.addItemAt(pName, pIndex);
	pTheListbox.itemLevel[pIndex]	:=	pLevel;
	pTheListbox.itemData[pIndex]	:=	pNodeFlag;
	
	listAddListDummy(pTheListbox, (pIndex + 1), pLevel + 1);
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pNodeFlag" type="Integer"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listDragAndDrop" id="0266f139-0a8a-423e-bf11-648e6ff9a3df">
        <updating/>
        <source>listDragAndDrop(pTheListbox: ListBox input; pXPos: Real; pYPos: Real) updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Processes the drag and drop event for the specified listbox control.
//
// Parameters:	pTheListbox - The listbox control which received the drag and drop event.
//				pXPos - The X coordinate where the drop event occurred.
//				pYPos - The Y coordinate where the drop event occurred.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer			: Integer;
	targetPath			: String;
	nodeType			: Integer;
	targetNodeOption	: Integer;
	isTargetUnix		: Boolean;
	
begin
	if (not self.aAllCutAndPasteObjects.isEmpty()) then
		listPointer	:=	pTheListbox.getListIndex(pXPos, pYPos);
		targetPath	:=	self.listGetQualifiedName(pTheListbox, listPointer);
		nodeType	:=	pTheListbox.itemData[listPointer];
		
		if self.aMyDragFromControl = pTheListbox and self.aDragFromIndex &lt;&gt; 0 then
			if self.aDragFromIndex = listPointer then
				return;		// Can't do drag-drop onto the source of the drag-drop.
			endif;
		endif;
		
		isTargetUnix	:=	false;
		
		if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER or nodeType = self.LISTBOX_NODE_LOCAL_FILE then
			targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_CLIENT;
		elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
			targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_APPSERVER;
			isTargetUnix		:=	self.aIsUnixAppServer;
		elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
			targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_DBSERVER;
			isTargetUnix		:=	self.aIsUnixDbServer;
		else
			return;
		endif;
		
		self.doPasteSelectedNodes(targetPath, targetNodeOption, isTargetUnix);
		self.aDragFromIndex		:=	0;
		self.aMyDragFromControl	:=	null;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pXPos" type="Real"/>
        <Parameter name="pYPos" type="Real"/>
    </JadeMethod>
    <JadeMethod name="listFindParentNode" id="36b27a60-1d72-4e21-9e2f-32f453475ed8">
        <source>listFindParentNode(pTheListbox:ListBox; pStartIndex:Integer):Integer protected;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Purpose:		This method will search backwards through the listbox, and return
//				the parent list item in the list hierarchy.
//
//				The index position of the parent item will be returned.
//
//				If the starting index position (pStartIndex) is 0 or 1, then zero
//				will be returned.  Likewise, if a parent is not found, then a zero
//				will also be returned.
//
// Parameters:	pTheListbox - The listbox control to search.
//				pStartIndex - The starting item index.
//
// Returns:		The item index of the parent.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox	: ListBox;
	entryIndex	: Integer;	// Current list item index.
	entryLevel	: Integer;	// Current list item level.
	childLevel	: Integer;	// Item Level of the child list item.

begin
	theListbox	:=	pTheListbox;
	
	if pStartIndex = 0
	or pStartIndex = 1
	or theListbox.listCount() = 0
	or pStartIndex &gt; theListbox.listCount()
	then
		return 0;
	endif;

	childLevel	:=	theListbox.itemLevel[pStartIndex];
	entryIndex	:=	pStartIndex - 1;

	while (entryIndex &gt; 0) do
		if (not entryLevel &gt; theListbox.listCount()) then
			entryLevel		:=	theListbox.itemLevel[entryIndex];

			if (entryLevel = (childLevel - 1)) then
				// The parent item level should be 1 less than that of it's child.
				return entryIndex;
			endif;
		endif;

		entryIndex	:=	entryIndex - 1;	// We're stepping backwards through the list.
	endwhile;

	return 0;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <Parameter name="pStartIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listGetQualifiedName" id="a8483f4a-ef6b-4c99-a27f-8f8b0eb6b231">
        <source>listGetQualifiedName(pTheListbox:ListBox; pIndex:Integer):String protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		Gets the fully qualified name of the specified listbox at the
//				requested position index, using the "itemFullName" method, and
//				strips out the name of the JADE node.
//
// Parameters:	pTheListbox - The listbox whose qualified name to return.
//				pIndex - The position index of the listbox entry.
//
// Returns:		The fully qualified name of the listbox entry.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/08/2002	cnwdad1		Added ability to handle Unix path names.
// --------------------------------------------------------------------------------
vars
	nodeName		: String;
	nodeType		: Integer;
	colonPosition	: Integer;
	rootPosition	: Integer;
	isUnix			: Boolean;
	
begin
	nodeType	:=	pTheListbox.itemData[pIndex];
	
	if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER
	or nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER
	or nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER
	then
		nodeName		:=	pTheListbox.itemFullName(pIndex);
		
		if nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
			isUnix	:=	self.aIsUnixAppServer;
		elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
			isUnix	:=	self.aIsUnixDbServer;
		endif;
		
		if isUnix then
			nodeName.replaceChar(JSS_SEPARATOR_WIN.Character, JSS_SEPARATOR_UNIX.Character);
			// Because the root directory of a Unix path name is "/", the name in the "itemFullName"
			// (i.e. the part following the node name) will now start with three "/", so we need to
			// strip off the name of the node and the first two "/" from the path.
			
			rootPosition	:=	nodeName.pos(JSS_SEPARATOR_UNIX &amp; JSS_SEPARATOR_UNIX, 1);
			
			if rootPosition = null then
				return null;
			elseif (rootPosition + 1) = nodeName.length() then
				// The path name will end in "//" only for the root path.
				nodeName	:=	JSS_SEPARATOR_UNIX;
			else
				nodeName	:=	nodeName[rootPosition + 2:end];
			endif;
		else
			// We need to strip off the name of the node, so we'll find the colon in the path name,
			// and move back one character to start from the disk drive name.
			
			colonPosition	:=	nodeName.pos(":", 1);
			
			if colonPosition = 0 then
				nodeName	:=	null;
			else
				nodeName	:=	nodeName[(colonPosition - 1):end];
			endif;
		endif;
	else
		nodeName	:=	null;
	endif;
epilog
	return nodeName;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="listLoadJadeNodeNames" id="049e1ca5-2da4-4649-9039-02cc0beaf18e">
        <source>listLoadJadeNodeNames(pTheListbox:ListBox input) protected;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Purpose:		Populates the specified listbox control with the names of all
//				available JADE nodes.
//
// Parameters:	pTheListbox - The listbox control to populate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21/08/2002	cnwdad1		When running a presentation client off an AppServer that
//							is running in single-user mode, there is effectively no
//							Server node to run serverExecution methods, so the method
//							simply runs as clientExecution, and since the FileFolder/
//							File classes default to using the presentation file system,
//							only local directories and files are shown, regardless of
//							which node the user is browsing.  Changed this method so
//							that when a presentation client is running on a single-
//							AppServer, you will see the AppServer node instead of the
//							Database Server node.
// --------------------------------------------------------------------------------
vars
	listPointer				: Integer;
	isSingleUserAppServer	: Boolean;
	
begin
	pTheListbox.clear();
	
	isSingleUserAppServer	:=	false;
	
	if (not app.isMultiUser()) then
		if node.isServerNode() and node.isApplicationServer() then
			isSingleUserAppServer	:=	true;
		endif;
	endif;
	
	// We always want to show the local client node.
	
	listPointer	:=	(pTheListbox.listCount() + 1);
	self.listAddListNode(	pTheListbox,
							app.computerName() &amp; self.LISTBOX_NAME_LOCAL,
							self.LISTBOX_NODE_LOCAL,
							listPointer,
							1);
	pTheListbox.itemPicture[listPointer]	:=	picHolderClient.picture;
	
	// If the client and Application Server nodes are running on the same machine, or if the
	// Application Server and Database Server nodes are running on the same machine, then
	// don't show the Application Server node.  The exception is where a client is a thin
	// client connected to an Application Server that is running in single-user mode, then
	// we will show the Application Server node, as long as the thin client and Application
	// Server nodes are NOT running on the same machine.
	
	if process.isUsingThinClient then
		if self.aIsAllowAppServer then
			if app.computerName() &lt;&gt; app.computerNameAppServer() then
				if app.computerNameAppServer() &lt;&gt; app.dbServerComputerName()
				or isSingleUserAppServer
				then
					listPointer	:=	(pTheListbox.listCount() + 1);
					self.listAddListNode(	pTheListbox,
											app.computerNameAppServer() &amp; self.LISTBOX_NAME_APP_SERVER,
											self.LISTBOX_NODE_APP_SERVER,
											listPointer,
											1);
					pTheListbox.itemPicture[listPointer]	:=	picHolderAppServ.picture;
				endif;
			endif;
		endif;
	endif;
	
	// If the client and Database Server nodes are running on the same machine, or if a client
	// is a thin client connected to an Application Server that is running in single-user mode,
	// then don't show the Database Server node.
	
	if app.computerName() &lt;&gt; app.dbServerComputerName()
	and (not isSingleUserAppServer)
	then
		listPointer	:=	(pTheListbox.listCount() + 1);
		self.listAddListNode(	pTheListbox,
								app.dbServerComputerName() &amp; self.LISTBOX_NAME_DB_SERVER,
								self.LISTBOX_NODE_DB_SERVER,
								listPointer,
								1);
		pTheListbox.itemPicture[listPointer]	:=	picHolderDbServ.picture;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="listLoadNodeDiskDrives" id="6907df47-8977-4ea9-9974-10344e5cb5ee">
        <updating/>
        <source>listLoadNodeDiskDrives(pTheListbox:ListBox input;
						pIndex:Integer;
						pIsDbServer:Boolean;
						pIsAppServer:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad2
//
// Purpose:		Adds the names of all available disk drives to the specified listbox
//				control.  The disk drives are those that are available on the machine
//				where the JADE node is running.
//
// Parameters:	pTheListbox - The listbox control to populate.
//				pIndex - The position index of the parent listbox folder.
//				pIsDbServer - If true, then we're after the disk drives on the
//					machine where the Database Server node is running.
//				pIsAppServer - If true, then we're after the disk drives on the
//					machine where the Application Server node is running.
//
//				******************************************************************
//				* NOTE:	If both pIsDbServer and pIsAppServer are false, then the *
//				*		local JADE client node is assumed.
//				******************************************************************
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theContainer	: JSSFMFolder;
	theFileNode		: JSSFMFileNode;
	theListbox		: ListBox;
	listPointer		: Integer;
	nodeType		: Integer;
	nodeLevel		: Integer;
	isNotEmpty		: Boolean;
	
begin
	theListbox	:=	pTheListbox;
	
	create theContainer transient;
	
	if pIsDbServer then
		isNotEmpty	:=	self.doFetchDiskDrivesServer(theContainer);
		nodeType	:=	self.LISTBOX_NODE_DB_SERVER_FOLDER;
	else
		isNotEmpty	:=	self.doFetchDiskDrivesClient(theContainer, pIsAppServer);
		
		if pIsAppServer then
			nodeType	:=	self.LISTBOX_NODE_APP_SERVER_FOLDER;
		else
			nodeType	:=	self.LISTBOX_NODE_LOCAL_FOLDER;
		endif;
	endif;
	
	if isNotEmpty then
		self.listRemoveAllChildNodes(theListbox, pIndex);
		listPointer		:=	pIndex + 1;
		nodeLevel		:=	theListbox.itemLevel[pIndex] + 1;
		
		foreach theFileNode in theContainer.allFileNodes reversed do
			self.listAddListNode(theListbox, theFileNode.pathName, nodeType, listPointer, nodeLevel);
		endforeach;
	endif;
epilog
	delete theContainer;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pIsDbServer" type="Boolean"/>
        <Parameter name="pIsAppServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listMouseDown" id="e3d36cf4-5f28-4f3d-b0b3-4548f3eebf86">
        <updating/>
        <source>listMouseDown(pTheListbox: ListBox input; pButtonId: Integer; pXPos: Real; pYPos: Real) updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Processes the mouseDown event for the specified listbox control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	actualXPos	: Real;
	actualYPos	: Real;
	listPointer	: Integer;
	
begin
	if pButtonId = Window.MouseButton_Left then
		listPointer		:=	pTheListbox.getListIndexText(pXPos, pYPos);
		
		if listPointer &lt;&gt; JSS_NULL_INDEX then
			self.aIsLeftMouseDown	:=	true;
			self.aDragFromIndex		:=	0;
			self.aMyDragFromControl	:=	null;
			self.aMyMenuList		:=	pTheListbox;
			self.aMyMenuTable		:=	null;
		endif;
		
	elseif pButtonId = Window.MouseButton_Right then
		self.menuEnableForList(pTheListbox);
		
		actualXPos	:=	pXPos;
		actualYPos	:=	pYPos;
		
		self.getRelativeWindowPosition(pTheListbox, actualXPos, actualYPos);
		popupMenu(mnuFile, actualXPos.Integer, actualYPos.Integer);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pButtonId" type="Integer"/>
        <Parameter name="pXPos" type="Real"/>
        <Parameter name="pYPos" type="Real"/>
    </JadeMethod>
    <JadeMethod name="listMouseMove" id="f589c83d-532e-43a5-91d1-8a47548a0d3a">
        <updating/>
        <source>listMouseMove(pTheListbox: ListBox input; pButtonId: Integer; pXPos: Real; pYPos: Real) updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Processes the mouseMove event for the specified listbox control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	nodeType	: Integer;
	
begin
	if pButtonId = Window.MouseButton_Left and self.aIsLeftMouseDown then
		listPointer		:=	pTheListbox.getListIndexText(pXPos, pYPos);
		
		if listPointer &lt;&gt; JSS_NULL_INDEX then
			if self.dragMode &lt;&gt; Form.DragMode_Drag then
				if self.aMyDragFromControl = pTheListbox and self.aDragFromIndex &lt;&gt; 0 then
					if self.aDragFromIndex = listPointer then
						return;		// Can't do drag-drop onto the source of the drag-drop.
					endif;
				endif;
				
				nodeType		:=	pTheListbox.itemData[listPointer];
				
				if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER
				or nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER
				or nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER
				then
					self.dragMode			:=	Form.DragMode_Drag;
					self.aDragFromIndex		:=	listPointer;
					self.aMyDragFromControl	:=	pTheListbox;
					self.menuCopyCut(false);
				endif;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pButtonId" type="Integer"/>
        <Parameter name="pXPos" type="Real"/>
        <Parameter name="pYPos" type="Real"/>
    </JadeMethod>
    <JadeMethod name="listMouseUp" id="338e1f0b-8f87-436b-8950-9e9866a74a73">
        <updating/>
        <source>listMouseUp() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Processes the mouseUp event for the specified listbox control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aIsLeftMouseDown then
		self.aIsLeftMouseDown	:=	false;
		self.dragMode			:=	Form.DragMode_None;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="listOpenBasePath" id="d27252ec-5af3-4a97-8e2d-2c3061ab3361">
        <source>listOpenBasePath(pTheListbox:ListBox input; pIsDbServer:Boolean; pIsAppServer:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		29 July 2002 by cnwdad1
//
// Purpose:		If any Base Path names have been specified to restrict access to
//				specific directories, then upon initialization of this form, we'll
//				open up the listbox's folder tree for each of those paths.  This
//				feature is not relevent to JADE client nodes since users cannot
//				specify Base Paths for a client node.
//
// Parameters:	pTheListbox - The listbox control whose folders to open.
//				pIsAppServer - If true, the Base Path is on the JADE Application
//					Server node.
//				pIsDbServer - If true, the Base Path is on the JADE Database
//					Server node.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox		: ListBox;
	nodeName		: String;
	basePathName	: String;
	allPathNames	: HugeStringArray;
	listPointer		: Integer;
	
begin
	theListbox	:=	pTheListbox;
	
	// Set up the node options.
	
	if pIsDbServer then
		nodeName		:=	app.dbServerComputerName() &amp; self.LISTBOX_NAME_DB_SERVER;
		allPathNames	:=	self.aAllPathNamesDbServer;
	elseif pIsAppServer then
		nodeName		:=	app.computerNameAppServer() &amp; self.LISTBOX_NAME_APP_SERVER;
		allPathNames	:=	self.aAllPathNamesAppServer;
	endif;
	
	if allPathNames.isEmpty() then
		return;
	endif;
	
	// Find the node folder, and if neccessary open it by invoking the pictureClick event.
	
	listPointer	:=	theListbox.findStringExact(1, nodeName);
	
	if listPointer = JSS_NULL_INDEX then
		return;
	endif;
	
	if (not theListbox.itemExpanded[listPointer]) then
		theListbox.pictureClick(theListbox, listPointer, ListBox.PictureClick_ItemPicture);
	endif;
	
	// Now traverse the path name tree to open each directory folder in the path.
	
	foreach basePathName in allPathNames do
		self.listOpenNodePath(pTheListbox, basePathName, listPointer);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pIsDbServer" type="Boolean"/>
        <Parameter name="pIsAppServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listOpenFolderNode" id="51e1caa2-e36a-4694-a509-ffc45399cfcc">
        <source>listOpenFolderNode(	pTheListbox:ListBox input;
					pIndex:Integer;
					pIsDbServer:Boolean;
					pIsAppServer:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		When a user clicks on the folder or +/- in the listbox tree, this
//				method will open up that folder and load any child folders/leaves.
//
// Parameters:	pTheListbox - The listbox control that was clicked.
//				pIndex - The position index of the folder that was clicked.
//				pIsDbServer - If true, the directory represented by the folder is
//					on the JADE Database Server node.
//				pIsAppServer - If true, the directory represented by the folder is
//					on the JADE Application Server node.
//
//				******************************************************************
//				* NOTE:	If both pIsDbServer and pIsAppServer are false, then the *
//				*		local JADE client node is assumed.
//				******************************************************************
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox		: ListBox;
	theContainer	: JSSFMFolder;
	theNode			: JSSFMFileNode;
	pathName		: String;
	listPointer		: Integer;
	parentLevel		: Integer;
	nodeLevel		: Integer;
	folderNodeType	: Integer;
	isAppServer		: Boolean;
	
begin
	theListbox		:=	pTheListbox;
	self.listRemoveAllChildNodes(theListbox, pIndex);
	parentLevel		:=	theListbox.itemLevel[pIndex];
	pathName		:=	self.listGetQualifiedName(theListbox, pIndex);
	
	create theContainer transient;
	
	if pIsDbServer then
		self.doFetchSubdirectoriesServer(pathName, theContainer);
		folderNodeType	:=	self.LISTBOX_NODE_DB_SERVER_FOLDER;
	elseif pIsAppServer then
		isAppServer		:=	true;
		self.doFetchSubdirectoriesClient(pathName, theContainer, isAppServer);
		folderNodeType	:=	self.LISTBOX_NODE_APP_SERVER_FOLDER;
	else
		isAppServer		:=	false;
		self.doFetchSubdirectoriesClient(pathName, theContainer, isAppServer);
		folderNodeType	:=	self.LISTBOX_NODE_LOCAL_FOLDER;
	endif;
	
	if theContainer.allFileNodes.isEmpty() then
		listPointer	:=	(pIndex + 1);
		theListbox.addItemAt(self.LISTBOX_DUMMY_LEAF, listPointer);
		theListbox.itemLevel[listPointer]	:=	(parentLevel + 1);
		theListbox.itemData[listPointer]	:=	self.LISTBOX_NODE_DUMMY;
	else
		listPointer		:=	pIndex + 1;
		nodeLevel		:=	parentLevel + 1;
		
		foreach theNode in theContainer.allFileNodes reversed do
			self.listAddListNode(theListbox, theNode.fileName, folderNodeType, listPointer, nodeLevel);
		endforeach;
	endif;
epilog
	delete theContainer;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pIsDbServer" type="Boolean"/>
        <Parameter name="pIsAppServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listOpenNodePath" id="9ea9b29c-b2d4-4e95-ab4a-79bdc7953720">
        <source>listOpenNodePath(pTheListbox:ListBox; pFilePath:String; pRootNodePointer:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2002 by cnwdad1
//
// Purpose:		This method does the donkey work for the "listOpenBasePath" method.
//
// Parameters:	pTheListbox - The listbox whose folder to open.
//				pFilePath - The name of the directory represented by the listbox folder.
//				pRootNodePointer - The position index of the upper-most parent
//					listbox entry for the relevant JADE node.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2005	cnwad1		PAR #46.
// --------------------------------------------------------------------------------
vars
	theListbox			: ListBox;
	filePath			: String;
	driveName			: String;
	pathName			: String;
	nodeName			: String;
	nameLength			: Integer;
	filePathLength		: Integer;
	nodeSeparator		: String;
	startPosition		: Integer;
	separatorPosition	: Integer;
	nodePointer			: Integer;
	startPointer		: Integer;
	listPointer			: Integer;
	listItemCount		: Integer;
	isNodeFound			: Boolean;
	parentLevel			: Integer;
	childLevel			: Integer;
	
begin
	filePath			:=	pFilePath;
	filePathLength		:=	filePath.length();
	theListbox			:=	pTheListbox;
	listItemCount		:=	theListbox.listCount();
	nodeSeparator		:=	theListbox.nameSeparator;
	
	// Find the disk drive node and open its folder.
	
	separatorPosition	:=	filePath.pos(":", 1);
	
	if separatorPosition = 0 then
		return;
	endif;
	
	driveName		:=	filePath[1:separatorPosition];
	parentLevel		:=	theListbox.itemLevel[pRootNodePointer];
	startPointer	:=	pRootNodePointer + 1;
	isNodeFound		:=	false;
	
	foreach listPointer in startPointer to listItemCount do
		childLevel	:=	theListbox.itemLevel[listPointer];
		
		if childLevel &lt;= parentLevel then
			break;
		endif;
		
		if theListbox.itemText[listPointer] = driveName then
			theListbox.pictureClick(theListbox, listPointer, ListBox.PictureClick_ItemPicture);
			isNodeFound	:=	true;
			break;
		endif;
	endforeach;
	
	if (not isNodeFound) then
		return;
	endif;
	
	// Find the root node, then we'll work our way down the tree from there.
	
	startPosition		:=	1;
	separatorPosition	:=	filePath.pos(nodeSeparator, startPosition);
	
	if separatorPosition = 0 then
		return;
	else
		listItemCount	:=	theListbox.listCount();
		nameLength		:=	separatorPosition - startPosition;
		nodeName		:=	filePath[startPosition:nameLength];
		isNodeFound		:=	false;
		
		foreach nodePointer in 1 to listItemCount do
			if theListbox.itemLevel[nodePointer] = 2 then
				if theListbox.itemText[nodePointer] = nodeName then
					isNodeFound	:=	true;
					break;
				endif;
			endif;
		endforeach;
		
		if (not isNodeFound) then
			return;
		endif;
		
		if (not theListbox.itemExpanded[nodePointer]) then
			theListbox.pictureClick(theListbox, nodePointer, ListBox.PictureClick_ItemPicture);
		endif;
		
		// We've made sure the root node is open, now traverse the tree of sub-nodes.
		
		startPosition	:=	separatorPosition + 1;
		
		while true do
			separatorPosition	:=	filePath.pos(nodeSeparator, startPosition);
			
			if separatorPosition = 0 then
				nodeName	:=	filePath[startPosition:end];
			else
				nameLength	:=	separatorPosition - startPosition;
				nodeName	:=	filePath[startPosition:nameLength];
			endif;
			
			while true do
				listPointer	:=	theListbox.findStringExact(nodePointer, nodeName);
				
// cnwdad1 20/04/2005 - PAR #46.
//				if listPointer = 0 then
				if listPointer = JSS_NULL_INDEX then
					nodePointer	:=	0;
					return;
				else
					pathName	:=	self.listGetQualifiedName(theListbox, listPointer).toUpper();
					
					if pathName = filePath[1:pathName.length()] then
						nodePointer	:=	listPointer;
						break;
					endif;
				endif;
			endwhile;
			
			if (not theListbox.itemExpanded[nodePointer]) then
				theListbox.pictureClick(theListbox, nodePointer, ListBox.PictureClick_ItemPicture);
				theListbox.listIndex	:=	nodePointer;
				theListbox.click(theListbox);
			endif;
			
			if separatorPosition = 0 then
				return;
			endif;
			
			startPosition	:=	separatorPosition + 1;
			
			if startPosition &gt; filePathLength then
				break;
			endif;
		endwhile;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pRootNodePointer" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listPictureClick" id="5d6e53fc-2429-40a1-9f1b-7ab862ebb34b">
        <updating/>
        <source>listPictureClick(pTheListbox:ListBox input; pPicIndex:Integer; pTheTable:Table input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad2
//
// Purpose:		Processes the pictureClick event for the specified listbox control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dummyLevel		: Integer;
	dummyIndex		: Integer;
	nodeType		: Integer;
	isDbServer		: Boolean;
	isAppServer		: Boolean;
	
begin
	if pTheListbox.itemExpanded[pPicIndex] then
		// Remove the child nodes, add a child dummy node, and close the parent node.
		
		dummyIndex	:=	pPicIndex + 1;
		dummyLevel	:=	pTheListbox.itemLevel[pPicIndex] + 1;
		
		listRemoveAllChildNodes(pTheListbox, pPicIndex);
		pTheListbox.addItemAt(self.LISTBOX_DUMMY_LEAF, dummyIndex);
		pTheListbox.itemLevel[dummyIndex]		:=	dummyLevel;
		pTheListbox.itemData[dummyIndex]		:=	self.LISTBOX_NODE_DUMMY;
		pTheListbox.itemExpanded[pPicIndex]		:=	false;
		
		self.tableLoadDirectoryContents(pTheTable, pTheListbox);
	else
		// We're opening the node, so we'll load it's child nodes.
		self.getServiceInterfaceSettings();
		nodeType	:=	pTheListbox.itemData[pPicIndex];
		
		if nodeType = self.LISTBOX_NODE_LOCAL then
			isDbServer	:=	false;
			isAppServer	:=	false;
			self.listLoadNodeDiskDrives(pTheListbox, pPicIndex, isDbServer, isAppServer);
			
		elseif nodeType = self.LISTBOX_NODE_LOCAL_FOLDER then
			isDbServer	:=	false;
			isAppServer	:=	false;
			self.listOpenFolderNode(pTheListbox, pPicIndex, isDbServer, isAppServer);
			
		elseif nodeType = self.LISTBOX_NODE_APP_SERVER then
			isDbServer	:=	false;
			isAppServer	:=	true;
			self.listLoadNodeDiskDrives(pTheListbox, pPicIndex, isDbServer, isAppServer);
			
		elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
			isDbServer	:=	false;
			isAppServer	:=	true;
			self.listOpenFolderNode(pTheListbox, pPicIndex, isDbServer, isAppServer);
			
		elseif nodeType = self.LISTBOX_NODE_DB_SERVER then
			isDbServer	:=	true;
			isAppServer	:=	false;
			self.listLoadNodeDiskDrives(pTheListbox, pPicIndex, isDbServer, isAppServer);
			
		elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
			isDbServer	:=	true;
			isAppServer	:=	false;
			self.listOpenFolderNode(pTheListbox, pPicIndex, isDbServer, isAppServer);
			
		endif;
		
		pTheListbox.itemExpanded[pPicIndex]	:=	true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pPicIndex" type="Integer"/>
        <Parameter name="pTheTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="listRemoveAllChildNodes" id="f1be7552-4162-4071-a009-7016b70effee">
        <source>listRemoveAllChildNodes(pTheListbox:ListBox input; pParentIndex:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		30 May 2002 by cnwdad1
//
// Purpose:		Removes all leaf nodes from a tree hierarchy in a listbox.
//
// Parameters:	pTheListbox - The listbox who's node to close.
//				pParentIndex - The index of he parent item whose subitems are to
//					be removed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parentIndex	: Integer;
	parentLevel	: Integer;
	entryCount	: Integer;
	childLevel	: Integer;
	childIndex	: Integer;
	
begin
	parentIndex	:=	pParentIndex;
	entryCount	:=	pTheListbox.listCount();
	parentLevel	:=	pTheListbox.itemLevel[parentIndex];
	
	if parentIndex &lt; entryCount then	// If parent is last, it couldn't have any children.
		childIndex	:=	parentIndex + 1;
		
		// Must use "listCount" here because the size of the list
		// items will be changing as list entries are removed.
		
		while childIndex &lt;= pTheListbox.listCount() do
			childLevel	:=	pTheListbox.itemLevel[childIndex];
			
			if childLevel &lt;= parentLevel then
				break;
			endif;
			
			pTheListbox.removeItem(childIndex);
		endwhile;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pParentIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listRemoveDirectory" id="aa48902c-7f50-45f2-aa77-1e92b3155036">
        <source>listRemoveDirectory(pTheListbox:ListBox input; pDirectoryName:String) protected;
// --------------------------------------------------------------------------------
// Created:		17 July 2002 by cnwdad1
//
// Purpose:		Removes a folder from the specified listbox control.  The folder
//				represents the specified directory.
//
// Parameters:	pTheListbox - The listbox control from which to remove the folder.
//				pDirectoryName - The name of the folder (directory) to remove.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nodeName		: String;
	theListbox		: ListBox;
	listPointer		: Integer;
	childLevel		: Integer;
	parentPointer	: Integer;
	parentLevel		: Integer;
	childPointer	: Integer;
	listCount		: Integer;
	checkName		: String;
	
begin
	nodeName	:=	pDirectoryName.toUpper();
	theListbox	:=	pTheListbox;
	listCount	:=	theListbox.listCount();
	
	foreach listPointer in 1 to listCount do
		checkName	:=	self.listGetQualifiedName(theListbox, listPointer).toUpper();
		
		if checkName = null then
			continue;
		endif;
		
		if checkName = nodeName then
			parentPointer	:=	self.listFindParentNode(theListbox, listPointer);
			parentLevel		:=	theListbox.itemLevel[parentPointer];
			childLevel		:=	theListbox.itemLevel[listPointer];
			
			// We need to refresh the corresponding tables before removing the list item.
			
			if listPointer = theListbox.listIndex then
				if theListbox = lstDirTop then
					self.initializeTable(tblFilesTop);
				elseif theListbox = lstDirBottom then
					self.initializeTable(tblFilesBottom);
				endif;
			endif;
			
			self.listRemoveAllChildNodes(theListbox, listPointer);
			theListbox.removeItem(listPointer);
			
			// Now that the list item has been deleted, the parent pointer may no longer
			// have any child nodes, so we'll work out whether or not we have to add
			// the dummy node.
			
			if parentPointer = theListbox.listCount() then
				// The parent is now the last item in the list, so we'll add the dummy.
				self.listAddListDummy(theListbox, (parentPointer + 1), (childLevel));
			else
				childPointer	:=	parentPointer + 1;
				
				if theListbox.itemLevel[childPointer] &lt;&gt; childLevel then
					// The parent now has no children, so we'll add the dummy.
					self.listAddListDummy(theListbox, (parentPointer + 1), (childLevel));
				endif;
			endif;
			
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pDirectoryName" type="String"/>
    </JadeMethod>
    <JadeMethod name="listRenameDirectory" id="2fe255a5-70d5-4840-af22-6950be229887">
        <source>listRenameDirectory(pTheListbox:ListBox input; pOldPathName:String; pNewPathName:String) protected;
// --------------------------------------------------------------------------------
// Created:		17 July 2002 by cnwdad1
//
// Purpose:		Changes the name of a folder in the specified listbox.
//
// Parameters:	pTheListbox - The listbox control containing the folder to rename.
//				pOldPathName - The original folder name.
//				pNewPathName - The new folder name.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	oldNodeName		: String;
	newNodeName		: String;
	directoryName	: String;
	theListbox		: ListBox;
	listPointer		: Integer;
	listCount		: Integer;
	checkName		: String;
	namePosition	: Integer;
	
begin
	oldNodeName		:=	pOldPathName.toUpper();
	newNodeName		:=	pNewPathName;
	theListbox		:=	pTheListbox;
	listCount		:=	theListbox.listCount();
	
	foreach listPointer in 1 to listCount do
		checkName	:=	self.listGetQualifiedName(theListbox, listPointer).toUpper();
		
		if checkName = oldNodeName then
			// Strip out the directory name from the whole path name.
			
			namePosition	:=	newNodeName.reversePos(JSS_SEPARATOR_WIN) + 1;
			
			if namePosition &gt; 1 and namePosition &lt;= newNodeName.length then
				directoryName	:=	newNodeName[namePosition:end];
				theListbox.itemText[listPointer]	:=	directoryName;
			endif;
			
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pOldPathName" type="String"/>
        <Parameter name="pNewPathName" type="String"/>
    </JadeMethod>
    <JadeMethod name="listUpdateWithNewDirectory" id="9789dcc2-b83a-4816-848e-56bca3848966">
        <source>listUpdateWithNewDirectory(pTheListbox:ListBox input; pDirectoryName:String) protected;
// --------------------------------------------------------------------------------
// Created:		18 July 2002 by cnwdad1
//
// Purpose:		When a new directory is created, this method will add a folder to
//				the specified listbox control to represent it.
//
// Parameters:	pTheListbox - The listbox control to add the folder to.
//				pDirectoryName - The name of the new directory/folder.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parentDirectory		: String;
	nameLength			: Integer;
	theListbox			: ListBox;
	listPointer			: Integer;
	listCount			: Integer;
	checkName			: String;
	nodeName			: String;
	nodeIndex			: Integer;
	nodeType			: Integer;
	nodeLevel			: Integer;
	
begin
	parentDirectory	:=	pDirectoryName.trimBlanks().toUpper();
	nameLength		:=	parentDirectory.reversePos(JSS_SEPARATOR_WIN);
	
	if nameLength &lt;= 0 then
		return;
	else
		parentDirectory	:=	parentDirectory[1:(nameLength -1)];
		nodeName		:=	pDirectoryName.trimBlanks()[(nameLength + 1):end];
		theListbox		:=	pTheListbox;
		listCount		:=	theListbox.listCount();
		
		foreach listPointer in 1 to listCount do
			checkName	:=	self.listGetQualifiedName(theListbox, listPointer).toUpper();
			
			if checkName = parentDirectory
			and theListbox.itemExpanded[listPointer]
			then
				nodeIndex	:=	listPointer + 1;
				nodeType	:=	theListbox.itemData[listPointer];
				nodeLevel	:=	theListbox.itemLevel[listPointer] + 1;
				
				// If the folder/directory contains no files or other directories, then the
				// folder node will have a single dummy leaf node, so we must remove it.
				
				if nodeIndex &lt;= listCount then
					if theListbox.itemLevel[nodeIndex] = nodeLevel
					and theListbox.itemData[nodeIndex] = self.LISTBOX_NODE_DUMMY
					then
						theListbox.removeItem(nodeIndex);
					endif;
				endif;
				
				// Now add the new directory to the folder node.
				
				self.listAddListNode(theListbox, nodeName, nodeType, nodeIndex, nodeLevel);
				
				break;
			endif;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
        <Parameter name="pDirectoryName" type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="cd28b7a2-af05-4960-938b-1913da97d1b4">
        <controlMethod name="Form::load"/>
