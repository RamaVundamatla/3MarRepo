    <JadeMethod name="setTotalAmount" id="b99a7339-53f2-434b-9c92-0cc231f290ca">
        <updating/>
        <source>setTotalAmount() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2024
ADO -  CR 63369 TASK 63371 
*/

vars

	charge : CM_Charge;
	taxStr : String;
	lineAmount : Decimal[23,4];
begin

	self.totalAmount := self.lineTotal; // MAPPING METHOD
	self.totalRate := self.zzGetRate();
	
	 // ### TFS BUG 63997 07MAY2024 NAVAB1
	self.calculationTypeDesc := self.zzGetCalcTypeDesc();
	self.calculationTypeType := self.zzGetCalcType();

	if self.invoice &lt;&gt; null 
	and self.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
		self.invoice.setTotalAmount(self.totalAmount);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTotalAndTaxForResync" id="886c083a-f05d-4528-9af9-66b326f020ff">
        <updating/>
        <source>setTotalAndTaxForResync() updating;
/*
Purpose:	re calcualte the static number data, then adjust the static data on the invoice, but just for this line. For performance.

Date		Who		Reason
19 November 2024	navab1	JIRA 33347
*/

vars
	taxAmount, lineAmount, rateAmount, chargeTaxValue, taxValue : Decimal[23,4];
	charge : CM_Charge;
begin
	// keep current values
	taxAmount := self.taxTotal;
	lineAmount := self.totalAmount;
	rateAmount := self.totalRate;
	
	// recalc new values
// ### JIRA 33479 27NOV2024 NAVAB1	self.setTotalAmount();
	self.totalAmount := self.lineTotal; // MAPPING METHOD
	self.totalRate := self.zzGetRate();
	
	// calculate the tax value, not the tax rate or description etc, they have not changed.
	foreach charge in self.charges discreteLock do
		chargeTaxValue := (charge.total  * (charge.taxRate / 100));
		taxValue := taxValue +  chargeTaxValue;
	endforeach;
	
	// reset tax on line
	self.setTaxTotals(self.totalAmount + taxValue);
	self.setTaxValue(taxValue);
	
	// Adjust the invoice totals
	self.invoice.setTotalAmount(lineAmount * -1); // take off the old value
	self.invoice.setTotalAmount(self.totalAmount); // add in the new value

	self.invoice.setTaxValue(taxAmount * -1); // take off the old value
	self.invoice.setTaxValue(taxValue); // add in the new value

	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTotalAndTaxWithAdjustment" id="856ce992-cf7f-466d-99df-5632962d2b41">
        <updating/>
        <source>setTotalAndTaxWithAdjustment() updating;
/*
Purpose:	

Date		Who		Reason
01 September 2025	navab1	JIRA 35790
*/

vars

begin
	self.setTotalAndTaxForResync();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTrackedItem" id="3dddcfd2-14dc-4a87-b901-7ea43c59c27e">
        <updating/>
        <source>setTrackedItem(_ti: CM_TrackedItem) updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------
// 30/08/2017	cnwdap1		TFS 6879 DPH Correct invoice creation when resyncing after cargo allocation mapping
// 16/01/2023 	navvt20		TFS CR 55625 Task 55658: Jade - Contract Id TRX
vars

begin
	self.trackedItem := _ti;
	if _ti &lt;&gt; null then
		self.trackedItemId 		:= _ti.id;
		// TFS 6690 don't set these fields if we already set them from the transaction
		if self.trackedItemQuantity = null then							// TFS 6879
			self.trackedItemQuantity := _ti.getChargeQuantity();
		endif;															// TFS 6879
		if self.trackedItemVolume = null then							// TFS 6879
			self.trackedItemVolume 	:= _ti.getChargeVolume();
		endif;															// TFS 6879
		if self.trackedItemWeight = null then							// TFS 6879
			self.trackedItemWeight 	:= _ti.getChargeWeight();
		endif;															// TFS 6879
		if self.trackedItemLength = null then							// TFS 6879
			self.trackedItemLength := _ti.length; // PAR 31615
		endif;															// TFS 6879
	else
		self.trackedItemId 		:= null;
		self.trackedItemQuantity := 0;
		self.trackedItemVolume 	:= 0;
		self.trackedItemWeight 	:= 0;
		self.trackedItemLength := 0; // PAR 31615
		//self.setContractId(null);// 16 Jan 2022 navvt20 TFS 55658 // ### TFS CR 55648 TASK 56818 15MAR2023 NAVAB1		//navra1 - 13th March 2024 - BUG 62681
	endif;		
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
