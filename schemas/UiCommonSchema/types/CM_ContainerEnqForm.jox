    <JadeMethod name="canAccessCargoMenu" id="2557d8ec-184c-47d3-82ed-c7dc4a966a19">
        <source>canAccessCargoMenu() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     20 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 08/09/2008	concms1	par17884/ccms 1742 Job requests intyerim solution
vars

begin
	return self.canUpdate or
		((not app.myRoot.getConfig(UseInterimJobRequestForm).Boolean or				// par 17884
			app.getMyUser.canDo (self.myTerminal, PmJobRequestView) or				// par 17884
		 app.getMyUser.canDo (self.myTerminal, PmShowToDoMenuInViewMode)) and		// par 17884
			(self.canAccessTodoTasksAddRemove or									// par 17884
			self.canAccessTodoTasksComplete ))										// par 17884
			or app.getMyUser.canUpdateStops(self.myTerminal);						// par 29440 cnwrd1 				

end;</source>
