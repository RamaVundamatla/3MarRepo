    <JadeMethod name="doCreateTableOrganisor" id="806c7319-a821-4bcf-b173-96587680c918">
        <updating/>
        <source>doCreateTableOrganisor() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars

	entTableDef			: EntTableDef;
	column				: String;
	entTableRow			: EntTableRow;
	queryProp			: CM_QueryProperty;
	pos					: Integer;
	header				: EntTableRowHeader;
	columnName			: String;									// PAR #31155
	revPos				: Integer;									// PAR #31155
	measure				: String;									// PAR #31155
	selectorMode		: Integer;									// PAR #31486
	selectorType		: Integer;	//29 Mar 2019	NDL	TFS 44100
	
begin
	self.tblResults.disallowColumnSorter := true;
	
	tblResults.allTblDataEntRows.purge();
	delete tblResults.myEntTableDef;
	
	if tblResults.myEntTableDef = null then
		create entTableDef transient;

		foreach column in allColumns do

			create entTableRow transient;
			entTableRow.allEntTableDefs.add(entTableDef);
			
			if column.isMeasurementType then								
				pos := column.pos("_", 1);									
				revPos := column.reversePos("_");							
				measure := column[revPos+1:end];							
				columnName := column[pos+1:revPos-pos-1];					
			else															
				measure := null;											
				columnName := column;										
			endif;															
				
			queryProp := self.myQDef.allQueryProperties[columnName];		
			if queryProp &lt;&gt; null then
				if queryProp.canBeViewed(app.myPassport) then 
					if measure &lt;&gt; null then													
						entTableRow.setHeading (queryProp.niceName &amp; Space &amp; measure);		
					else																	
						entTableRow.setHeading (queryProp.niceName);
					endif;																	
					// this originally use control name as a way to store the original column name unaltered 
					entTableRow.setOriginalColumnName(column);
					create header transient;
					entTableRow.setMyTransientHeader(column, header);
					if measure &lt;&gt; null then																				
						entTableRow.setMeasurementType(app.myRoot.allMeasurementTypesByShortName[measure].shortName);
					endif;																							
					pos := allVisibleColumns.indexOf(column); 
					if pos &gt; 0 then
						self.tblResults.allTblDataEntRows.atPut(pos,entTableRow);					endif;
				endif;
			endif;
		endforeach;

		self.tblResults.setMyEntTableDef (entTableDef);
	endif;
	
	if self.myQDef &lt;&gt; null then
		selectorMode := self.myQDef.mode;
		selectorType := self.myQDef.type;
	endif;

	self.tblResults.showSelectorColumnOrganiserFrm(self.myTerminal,self.myCurrentCargoBOLType, self.myMasterMenuAction, selectorMode, selectorType);
	
epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="doFilter" id="9ad0aeaf-323e-4979-b640-4ec6eb51c2b4">
        <updating/>
        <source>doFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars
	findText	: String;
	tbl : CMUI_ListTable;
	rowIndex : Integer;
	colIndex : Integer;
	checkBoxColumn : Integer;
	checkText : String;
	length : Integer;
begin
	findText := txtArgFind.text.trimBlanks.toUpper();
	length := findText.length;
	tbl:= self.tblArgument;
	
	if findText = null then
		self.doClearFilter();
		return;
	endif;
	
	if findText = "" then
		self.doClearFilter();
		return;
	else
		self.btnClear.enabled := true;
	endif;
	
	checkBoxColumn := tbl.getChkBoxColumn;

	foreach rowIndex in 1 to tbl.rows do
		if tbl.accessRow( rowIndex ).visible then
			foreach colIndex in 1 to tbl.columns where colIndex &lt;&gt; checkBoxColumn do
				checkText := tbl.accessCell( rowIndex, colIndex ).text.trimBlanks.toUpper();
				if checkText.pos(findText,1) &gt; 0 then
					break;
				endif;
			endforeach;
			if checkText.pos(findText,1) &gt; 0 then
				tbl.accessRow(rowIndex).visible	:= true;
			else
				tbl.accessRow(rowIndex).visible	:= false;
			endif;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandle1066AfterCancel" id="60776115-8211-4d34-bbef-f859361225fa">
        <source>doHandle1066AfterCancel(_exc : Exception) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars

	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = 1066 then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

epilog

	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRemoveQueryLine" id="8690b136-0523-4a5e-9e86-e6d1ac08c55a">
        <source>doRemoveQueryLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars
	idx		: Integer;
	crit	: CM_SelectorCriteriaLine;	
	
begin

	idx := self.tblCriteria.row;
	if idx = 0 or not self.tblCriteria.accessRow(idx).selected then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, app.getErrorString(CMUI_Selector_Line), app.getErrorString(Delete)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	crit := self.tblCriteria.accessRow(idx).itemObject.CM_SelectorCriteriaLine;
	if not self.validateCriteriaLineRemoval(crit) then
		return;
	endif;

	delete crit;
	self.tblCriteria.removeItem(idx);
	self.tblCriteria.accessedRow:=null;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveQry" id="06f9f7d3-a2a2-4c39-9e6d-95f10c260eec">
        <updating/>
        <source>doSaveQry(_isSaveAs : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries

*/

vars
	pxyUserQuery,
	realUserQuery 		: CM_MenuUserQuery;
	ls					: Boolean;
	visibleColums		: StringArray;
	totalRows,
	row					: Integer;
	criteriaHolder		: CM_QueryCriteriaLineHolder;
	criteriaLine		: CM_SelectorCriteriaLine;
	parentMenuEntity	: CM_MenuRootQuery;
	theResult			: Integer;
	
begin
	realUserQuery := self.myCurrentQuery;
	
	// Save(Update)
	if not _isSaveAs and realUserQuery = null then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(Query), app.getErrorString(Update)), app.getErrorString(CMUI_Nothing_Selected), 0);
		return;
	endif;
	
	create visibleColums transient;
	
	// Save As 
	if _isSaveAs then
		create pxyUserQuery transient;
	// Save(Update)
	else
		app.cmsBeginLoad(ls);
		pxyUserQuery := realUserQuery.pxyCreateUpdateProxy();
		realUserQuery.allVisibleColumns.copy(visibleColums);
	endif;
	
	parentMenuEntity := app.myRoot.myQueryMenuRoot;
	
	pxyUserQuery.setProxy(self.txtQryName.text, self.txtQryDescription.text, app.getMyUser().code, self.myQDef.mode, parentMenuEntity, self.myTerminal, visibleColums);
	criteriaHolder := self.myCriteriaLineHolder;
	pxyUserQuery.allCriteriaLineHolders.purge();
	pxyUserQuery.allCriteriaLineHolders.add(criteriaHolder);
	
	totalRows := self.tblCriteria.rows;
	
	foreach row in 1 to totalRows do
		criteriaLine := self.tblCriteria.accessRow(row).itemObject.CM_SelectorCriteriaLine;
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endforeach;
	
	while true do
		// Save As
		if _isSaveAs then
			app.myTrxCA.trxCreateSelectorQuery(pxyUserQuery, 0, parentMenuEntity, realUserQuery, app.myPassport);
		// Save(Update)
		else
			app.myTrxUA.trxUpdateSelectorQuery(pxyUserQuery, parentMenuEntity, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Save As
			if _isSaveAs then
				app.msgBox(app.getErrorString1(Query_successfully, "saved"), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
				// Rebuild the selector query combobox, then set it to one created
				self.myAssistant.comboBoxUserQuery(self.cmbSelectorQuery,null,self.queryMode,false);
				self.cmbSelectorQuery.listIndex := self.cmbSelectorQuery.findObject(realUserQuery);
			// Save(Update)
			else
				app.msgBox(app.getErrorString1(Query_successfully, "updated"), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
				realUserQuery := pxyUserQuery.pxyGetRealObject();
			endif;
			
			break;
		else
			if _isSaveAs then
				theResult := app.showErrorWarningDialog('Selector Query', app.myPassport, ErrWarnMode_Update);
			else
				theResult := app.showErrorWarningDialog('Selector Query', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			endif;
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;
	
	// This is deleted when form is unload;
	create criteriaHolder transient;
	
	realUserQuery.allCriteriaLineHolders.first().cloneReferences(true, criteriaHolder);
	self.myCriteriaLineHolder := criteriaHolder;
	
epilog
	if not _isSaveAs then
		app.cmsEndLoad(ls);
	endif;
	delete pxyUserQuery;
	delete visibleColums;
end;</source>
        <Parameter name="_isSaveAs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectorClick" id="e4cef877-67fe-49be-8cd2-a02d640b2d64">
        <updating/>
        <source>doSelectorClick(_cmb : ComboBox)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
08/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
*/
vars
	menuEntity			: CM_MenuEntity;
	transCrit,persistentCrit,criteriaLine,tmpCrit		: CM_SelectorCriteriaLine;
	tmpProp				: CM_QueryProperty;
	tmpOperator			: CM_QueryOperator;
	persistentCritHolder,
	criteriaHolder		: CM_QueryCriteriaLineHolder;
	tblSheet			: JadeTableSheet;
	idx : Integer;
	firstRow : Integer;
	row : Integer;
	tbl : CM_DataTable;
begin
	tbl := self.tblCriteria;
	self.tblCriteria.columns := 1;
	self.tblCriteria.rows := 0;
	
	//08/09/2023	navkc1	CR 60429 Task 60445
	self.txtQryName.text := null;
	self.txtQryDescription.text := null;
	
	if _cmb.getCurrentItemObject() = null then
		self.myCriteriaLineHolder.allCriteriaLines.purge();
		self.getXMLSettingsForSetup(true);
	endif;
	menuEntity := _cmb.listObject.CM_MenuEntity;
	
	if _cmb.getCurrentItemObject() = null then
		return;
	endif;
	
	if (not menuEntity.isKindOf(CM_MenuUserQuery)) then
		self.myQDef := _cmb.listObject.CM_QueryDefinition;
	else
		self.myCurrentQuery := menuEntity.CM_MenuUserQuery;
		self.myQDef := app.myRoot.allQueryDefinitionObjects[self.myCurrentQuery.getType, queryMode];
		foreach persistentCritHolder in self.myCurrentQuery.allCriteriaLineHolders do
				self.myCriteriaLineHolder.allCriteriaLines.purge();
				foreach persistentCrit in persistentCritHolder.allCriteriaLines do
					tmpCrit := persistentCrit.cloneSelf(true);
					tmpProp := tmpCrit.myQueryProperty.cloneSelf(true);
					tmpCrit.myQueryProperty.cloneReferences(tmpProp);
					tmpOperator := tmpCrit.myQueryOperator.cloneSelf(true);
					tmpCrit.myQueryOperator.cloneReferences(tmpOperator);
					
					create transCrit transient;
					transCrit.set(tmpProp, tmpOperator, tmpCrit.isUnavailableAtRunTime);
					transCrit.setMyCriteriaLineHolder(self.myCriteriaLineHolder);	
					idx := tbl.addItemObject(transCrit,transCrit.getDescriptionString);
					tbl.accessRow(idx).itemObject := transCrit;
					tbl.accessRow(idx).backColor := tmpCrit.getPerformanceColour;
					endforeach;
		endforeach;
		//08/09/2023	navkc1	CR 60429 Task 60445
		self.txtQryName.text := self.myCurrentQuery.heading;
		self.txtQryDescription.text := self.myCurrentQuery.description;
	endif;
end;</source>
        <Parameter name="_cmb" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen" id="928e2cf9-ce28-4956-a53e-f057a2c0155e">
        <updating/>
        <source>doSendToScreen(_form :CM_BaseForm input;_coll :Collection; _mode :Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
*/

vars
	criteria : CM_QueryCriteriaLineHolder;
begin
	app.mousePointer := Busy;
	
	_form.show();
	if self.isQryFromToParent then
		create criteria transient;
		self.myCriteriaLineHolder.cloneReferences(true, criteria);
		if _form.isKindOf(CMUI_CargoReview) then
			_form.CMUI_CargoReview.doSetQueryCriteriaFromDialog(self.myQDef, criteria); //12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
		endif;
	else
		_form.displaySelectorResults(_coll, _mode);
	endif;
	
epilog
	app.mousePointer := Idle;
	
end;</source>
        <access>protected</access>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_GetFirstTerm" id="c76bdcac-b9d0-4828-8d90-76158555bbfa">
        <source>doSendToScreen_GetFirstTerm(_collAll, _collSelected :Collection):CM_Terminal protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
16 February 2023  navmv20	TFS 55649 Task 56228: UI - Selector Dialog for Contracts
*/
vars
	iter 			:Iterator;
	firstObj		:Object;
	invalidObject	:Boolean;
	firstTerminal	:CM_Terminal;
begin
		iter := _collAll.createIterator;

	on Exception do app.handleDeletedObject(exception, firstObj, invalidObject);
	
	while iter.next(firstObj) do
		invalidObject := false;
		
		if CM_Invoice.hasInstance(firstObj) then
			firstTerminal := firstObj.CM_Invoice.myTerminal;
		elseif CM_InvoiceLine.hasInstance(firstObj) then
			firstTerminal := firstObj.CM_InvoiceLine.getTerminal();
		elseif CM_InvoiceContract.hasInstance(firstObj) then 	//17/02/2023 navmv20 TFS 55649 Task 56228
			firstTerminal := self.myParentTerminal;	 //17/02/2023 navmv20 TFS 55649 Task 56228
		endif;
		
		if not invalidObject then		// make sure we check at least one valid object
			break;
		endif;
	endwhile;
	
	if firstTerminal = null then
		firstTerminal := app.getMyTerminalDO_NOT_USE();
	endif;
	
	return firstTerminal;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_collAll" type="Collection"/>
        <Parameter name="_collSelected" type="Collection"/>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="doTblSelectorContMenu" id="d75a015b-df52-48d6-b6ab-87149090ac69">
        <updating/>
        <source>doTblSelectorContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblResults;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="evaluateUpDown" id="8c4b9a6c-1943-4c0d-bed7-34fc6622583e">
        <source>evaluateUpDown() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars
	criteriaLine : CM_SelectorCriteriaLine;
begin
	self.btnDown.enabled := false;	
	self.btnUp.enabled := false;	
		
	criteriaLine := self.tblCriteria.accessRow(self.tblCriteria.row).itemObject.CM_SelectorCriteriaLine;
	
	if criteriaLine = null or not self.tblCriteria.accessRow(self.tblCriteria.row).selected then
		return;
	endif;
	
	if self.tblCriteria.rows = self.tblCriteria.fixedRows + 1 then
		return; // There is only one row, so can't move up or down
	elseif self.tblCriteria.row = self.tblCriteria.rows then
		self.btnUp.enabled := true;
	elseif self.tblCriteria.row = self.tblCriteria.fixedRows + 1 then
		self.btnDown.enabled := true;
	else
		self.btnDown.enabled := true;	
		self.btnUp.enabled := true;
	endif;

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="executeQueries" id="95d27e75-e0dc-4f4e-b011-7315160fe040">
        <updating/>
        <source>executeQueries() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars
	cmifMonitor				: CMIF_Monitor;
	returnValue 			: Integer;
	tbl						: CM_DataTable;
	obj : Any;
	startTime : TimeStamp;	
	endTime : TimeStamp;	
	timeInterval : TimeStampInterval;	
begin

	startTime := app.actualTimeAppServer;	

	tbl := self.tblCriteria;
   	if self.queryLineChanged then
		returnValue := app.msgBox(app.getErrorString(CMUI_Selector_Check_Line) &amp; Cr &amp; app.getErrorString(Add) &amp;'?', app.getErrorString(CMUI_Selector_Add_Changed_Line), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		
		if returnValue = MB_YES then
			if (not self.addCriteriaLine()) then //adding line could fail
				return;
			endif;
			//so user can see added line before query executes - is this too ugly?
			self.doWindowEvents(0);
		elseif returnValue = MB_CANCEL then
			return;
		endif;
	endif;

	self.queryLineChanged := false;	
	on Exception do self.doHandle1066AfterCancel(exception); 
																// some objects are registered for notes and some are not...
	
	on Exception do null;

	
	
	delete app.myPassport.myCMIFMonitor;
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	self.frmModalDialog.zOrder(1);	
	self.modalDialogShow(null, app.getErrorString(Cancel),null ,app.getErrorString(CMUI_Return_Data) , app.getErrorString(CMUI_Retreiving_Data), cmifMonitor.message);

	returnValue := self.executeQuery();
	self.displayResults();
		
	endTime := app.actualTimeAppServer;	
	timeInterval := endTime - startTime;
	
epilog
	endLoad;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="executeQuery" id="7ef2ba76-4cd1-4783-af46-c7b8b45b5abc">
        <updating/>
        <source>executeQuery() : Integer protected,updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars
	startTime			: TimeStamp;
	criteriaLineHolder  : CM_QueryCriteriaLineHolder;
	idx : Integer;
	obj : Object;
begin

		
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	self.lblModalMessage.caption := 'Retrieving items';
	self.lblModalMessage.refreshNow();		
	
	startTime := app.actualTimeServer;
	app.lockKeeperNotifyStartActivity(startTime, method, null, 'Selector criteria: ' &amp; self.myCriteriaLineHolder.getFullDescription(), app.myPassport);
	
	
	self.myEnqController.myCriteriaLineHolder := self.myCriteriaLineHolder;

	self.myEnqController.doQuery(self.myQDef);


epilog
	app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	
	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		return app.myPassport.myCMIFMonitor.monitorReturnValue;	
	else
		return null;
	endif;
	delete criteriaLineHolder;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getModeDescription" id="92d45379-e4bc-446f-99bb-752c10c09bbb">
        <source>getModeDescription(_cargoBOLType : Integer) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars
	theCargoType				: CM_CargoType;
	theCargoBOLType				: CM_CargoBOLType;
	str							: String;
begin
	if _cargoBOLType = CM_QueryDefinition.Invoice_Query_Mode then
		str := app.getErrorString(CM_Invoice_GC);
	elseif _cargoBOLType = CM_QueryDefinition.InvoiceLine_Query_Mode then
		str := app.getErrorString(Invoice_line);
	else
		theCargoType := app.myRoot.allCargoTypesById[_cargoBOLType];
		if theCargoType &lt;&gt; null then
			str := theCargoType.description;
		endif;
	endif;
	
	return str &amp; ' ' &amp; app.getErrorString(Mode);

end;</source>
        <access>protected</access>
        <Parameter name="_cargoBOLType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="29af2e8c-b6c1-4d06-9321-30589aec8f6e">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars
	xmlStr,theXML : String;
	mode : String;
	entTableRow : EntTableRow;
	criteLineHolderXML : String;
begin
	
	theXML := inheritMethod();

	if self.myQDef &lt;&gt; null then
		mode := self.myQDef.mode.String;
	endif;
	if self.cmbSelectorQuery.listIndex = 1 then
		criteLineHolderXML:= self.myCriteriaLineHolder.getXMLStringForSave;
	endif;
	theXML := theXML &amp; global.formatAsXML(self.XMLTag_Criteria &amp; self.queryMode.String, criteLineHolderXML);
	theXML := theXML &amp; global.formatAsXML(self.XMLTag_Selector, cmbSelectorQuery.text);
	theXML := theXML &amp; criteLineHolderXML;
	return theXML;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="b925feba-2f12-40e2-9527-83c0dfc03e61">
        <updating/>
        <source>getXMLSettingsForSetup(_check : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue, entName : String;
	pos : Integer;
	entRowName : EntTableRow;
	criteriaLine			: CM_SelectorCriteriaLine;
	idx	: Integer;
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	
	if self.firstTime then
		theXMLValue :=theXML.cnEcGetTagValueOfName(self.XMLTag_Selector);
		self.cmbSelectorQuery.listIndex := self.cmbSelectorQuery.findString(1,theXMLValue);
	endif;
	theXMLValue:= theXML.cnEcGetTagValueOfName(self.XMLTag_Criteria &amp; self.queryMode.String);
	if theXMLValue &lt;&gt; null then
		if not self.firstTime then
			createDefaultCriteriaLines();
			return;
		endif;
		self.myCriteriaLineHolder.createCriteriaLinesFromXML(global.formatAsXML(self.XMLTag_Criteria &amp; self.queryMode.String,  theXMLValue),self.myQDef);
		//default the terminal to self terminal
		if self.queryMode = CM_QueryDefinition.InvoiceLine_Query_Mode then
			criteriaLine:=self.myCriteriaLineHolder.findCriteriaByName(CM_InvoiceLine::myTerminal.name);
		else
			criteriaLine:=self.myCriteriaLineHolder.findCriteriaByName(CM_Invoice::myTerminal.name);
		endif;
	
		if _check then
			foreach criteriaLine in self.myCriteriaLineHolder.allCriteriaLines discreteLock do
				idx := self.tblCriteria.addItem(criteriaLine.getDescriptionString);
				self.tblCriteria.accessRow(idx).itemObject := criteriaLine;
				self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
			endforeach;
		endif;
	elseif theXMLValue = null and self.cmbSelectorQuery.listIndex = 1 then
		self.createDefaultCriteriaLines();
	endif;
end;</source>
        <Parameter name="_check" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadAttrCombo" id="79f42ff6-f089-43f1-b304-0c2b52a098e1">
        <source>loadAttrCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/

vars
	qProp	: CM_QueryProperty;
	terminology : String;	
	theCargoBOLType : CM_CargoBOLType;
	index : Integer;	
begin
	self.cmbAttribute.clear();
	self.frmArgument.visible := false;
	if self.myQDef &lt;&gt; null then
		theCargoBOLType := app.myRoot.getCargoBOLTypeForId(self.myQDef.mode);
	
	foreach qProp in self.myQDef.allQueryProperties discreteLock do			
		if not qProp.canBeViewed(app.myPassport) then
			continue;
		endif;

		if not qProp.propertyAvailableInCombo() then
			continue;
		endif;
		
		if qProp.propertyName = CM_TrackedItem::mySubTerminal.name then
			if not app.isSubTerminalsLicensed then
				continue;
			endif;
		endif;
	
		terminology := app.getTerminologyAlternate(theCargoBOLType, null, qProp.niceName , CM_TermExpressionSingular, qProp.niceName) ;
		index := self.cmbAttribute.addItem(terminology);
		self.cmbAttribute.itemObject[index] := qProp;
		self.cmbAttribute.itemBackColor[index] := qProp.getPerformanceColour;	
	endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="46e56772-d7a2-45c9-b48f-46904ba842a1">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
*/
vars
	defaultCargoType			: Integer;
	ls							: Boolean;
	criteriaHolder				: CM_QueryCriteriaLineHolder;
	tblSheet					: JadeTableSheet;
begin
	inheritMethod();
	
	if self.isBaseFormModal then
		self.clipControls := false;
	endif;
	
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	if self.myAssistant.myTerminal = null then
		self.myAssistant.myTerminal := self.myTerminal;
	endif;
	self.firstTime := true;
	if not self.isQryFromToParent then //12/09/2023	navkc1	CR 60429 Task 60445
		self.doSelectorClick(self.cmbSelectorQuery);
		self.createDefaultCriteriaLines();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadOperationCombo" id="61a95698-5a89-42de-bf19-1f195ad0542e">
        <updating/>
        <source>loadOperationCombo(_qProp : CM_QueryProperty) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/
vars
	qOperator	: CM_QueryOperator;
	idx			: Integer;
begin

	cmbOperator.clear;
	foreach qOperator in _qProp.allAllowedOperators discreteLock do
		idx := cmbOperator.addItem(qOperator.description);
		cmbOperator.itemObject[idx] := qOperator;
	endforeach;
	
	qOperator := _qProp.getDefaultOperator;
	cmbOperator.listObject := qOperator;
	cmbOperator.text := qOperator.description;

end;</source>
        <access>protected</access>
        <Parameter name="_qProp" type="CM_QueryProperty"/>
    </JadeMethod>
    <JadeMethod name="loadSelectorModes" id="b469e297-9c9b-44c6-914f-15d080beb34d">
        <updating/>
        <source>loadSelectorModes()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/
vars
	cmb						: CMUI_ComboBox;
	qDefDict				: CM_QueryDefinitionByModeDict;
	qDef					: CM_QueryDefinition;
	idx,
	keepIdx					: Integer;
begin
	cmb := self.cmbSelectorQuery;
	cmb.sorted	:= true;			
	cmb.clear();
	
	cmb.addItem("");
	qDefDict := app.myRoot.allQueryDefinitionObjects;
	
	foreach qDef in qDefDict do		
		if qDef.type &lt;&gt; self.queryMode then	
			continue;									
		endif;											
		idx := cmb.addItem(qDef.modeDescription);
		cmb.itemObject[idx] := qDef;
	endforeach;	
	cmb.listObject := self.myQDef;
	self.cmbSelectorQuery_click(cmb);
end;</source>
    </JadeMethod>
