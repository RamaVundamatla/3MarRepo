vars

begin
	self.frmRatesOR.visible := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRateRemoveClick" id="b636cf55-2c35-4fff-ae39-9d5ca29542b0">
        <source>doBtnRateRemoveClick();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;
	col,row : Integer;
begin
	theTable := self.tblRatesOR;
	col := theTable.getColumnByRowName(ETRow_NewRate);
	row := theTable.row;
	self.txtRateOR.text := "";
	self.tblRatesOR.setCellText(row, col, "");

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRateSaveClick" id="753e488e-beb9-4d72-b509-e511aab7a8e7">
        <updating/>
        <source>doBtnRateSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theController : CMIF_ChargesController;
	pxyCharges : CM_ChargeByServiceRateOvrdDict;
	index:                  Integer;
	theService:             CM_Service;
	currentlyOverridden:          Boolean;
	rateCurrent, rateNew:                Real;
	strrateNew:             String;
	chargeCount, theReturn :            Integer;
	theTable : CM_DataTable;
	rowSt, rowEnd: Integer;
	aCharge, pxyCharge : CM_Charge;
	isReinstateRate : Boolean;
begin
	// ### Get all the rates off the table
	create theController transient;
	create pxyCharges transient;
	foreach aCharge in self.allORCharges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		theController.allCharges.add(pxyCharge);
	endforeach;

	theController.allCharges.copy(pxyCharges);
	
	theTable := self.tblRatesOR;

	theTable.column := 1;
	rowSt := theTable.fixedRows + 1;
	rowEnd := theTable.rows;
	
	foreach index in rowSt to rowEnd do
		theService := theTable.accessRow(index).itemObject.CM_Service;
		rateCurrent := theTable.getCellValueByName(ETRow_CurrentRate,index).asRealJMT;
		currentlyOverridden := theTable.getCellValueByName(ETRow_Overridden,index).convertToBoolean(); 
		chargeCount := theTable.getCellValueByName(ETRow_Charges,index).Integer; 
		strrateNew := theTable.getCellValueByName(ETRow_NewRate,index);
		if strrateNew = "" then
			isReinstateRate := true;
		else
			isReinstateRate := false;
			rateNew	:=	strrateNew.asRealJMT();
		endif;
		
		self.setProxyCharge(theController.allCharges, theService, rateCurrent, currentlyOverridden, chargeCount, rateNew, isReinstateRate);
	endforeach;
	
	theController.allCharges.clear;
	pxyCharges.copy(theController.allCharges);

	
	// ### Update in TRX
	if not theController.allCharges.isEmpty then
		while true do
			app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
			if app.myPassport.trxCompletedOK then
				global.beep;
				self.frmRatesOR.visible := false;
				
				// ### TFS BUG 62926 02APR2024 NAVAB1 - have turned off NOTES for big rate changes, for performance, quicker to refresh.
				if theController.allCharges.size &gt;= 1000 then
					self.doQuery();
				endif;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Charges_Update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			
			break;
		endwhile;
	endif;
epilog
	foreach pxyCharge in theController.allCharges do 
		delete pxyCharge;
	endforeach;
	
	delete theController;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRateSetClick" id="2d55aa8f-da5f-4a4f-ba76-80b4dbf19a27">
