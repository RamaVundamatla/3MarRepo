<CollClass name="UM_UnitTestResultByClassMethod" id="9419ac47-d0c5-4e5e-bade-dda10ed5edb6">
    <loadFactor>66</loadFactor>
    <memberType name="UM_UnitTestResult"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="UM_UnitTestResult::myClassMethod"/>
        </keyPath>
        <property name="UM_UnitTestClassMethod::className"/>
    </MemberKey>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="UM_UnitTestResult::myClassMethod"/>
        </keyPath>
        <property name="UM_UnitTestClassMethod::methodName"/>
    </MemberKey>
    <JadeMethod name="containsBadData" id="544a9971-1346-49dd-9e86-ce617cf3e6b2">
        <source>containsBadData():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2021	navndl1	Initial creation	TFS 

*/

vars

	iter : Iterator;
	obj : Object;
	edition : Integer;
	invalid : Boolean;

begin

	on Exception do app.handleDeletedObject(exception, obj, invalid );

	iter := self.createIterator;
	while iter.next( obj ) do
		edition := obj.edition;
		if invalid then
			break;
		endif;
	endwhile;
	
	return invalid;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
