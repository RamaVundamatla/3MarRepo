    <JadeMethod name="setForm" id="6c39b7b1-271f-4f4f-99da-55e949b5712b">
        <updating/>
        <source>setForm(pFormObj:CnEcHtmlFormTag) updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Set a reference to the the receiver's owning form tag object.
//
// Parameters:	pTheForm - The form tag object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myForm &lt;&gt; pFormObj then
		self.myForm	:=	pFormObj;
	endif;
end;</source>
        <Parameter name="pFormObj" type="CnEcHtmlFormTag"/>
    </JadeMethod>
</Class>
