    <JadeMethod name="getCollectionForSearch" id="71834c6b-a7d5-419c-9ff2-abfe19484b94">
        <source>getCollectionForSearch() : CM_FaultsByReportedTS;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	// first collection check if machine &lt;&gt; null 
	if self.filterMachine &lt;&gt; null then
		return self.filterMachine.allFaults;

	
	elseif self.filterFaultType &lt;&gt; null then
		//fault type
		return self.filterFaultType.allFaults;
	
	elseif self.filterStatus &lt;&gt; null then
	//fault status 
		return self.filterStatus.allFaults;
	else
		return self.myTerminal.allFaults;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_FaultsByReportedTS"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfItemsForLoad" id="e0fcd6d7-52da-4c84-a88a-6667239640aa">
        <source>getNumberOfItemsForLoad(): Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	allFaults 	: CM_FaultsByReportedTS;
begin

	allFaults:=getCollectionForSearch;
	if allFaults &lt;&gt; null then
		return allFaults.size;
	else
		return null;
	endif;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="bacc2416-7bd9-4d5c-bea1-f2baa3d3f489">
        <updating/>
        <source>includeObject(_fault: CM_Fault; _passport: CM_Passport): Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	
	if self.filterMachine &lt;&gt; null and _fault.myMachine &lt;&gt; self.filterMachine then
		return false;
	endif;
	
	if self.filterMachineType &lt;&gt; null and _fault.myMachine.getMachineType &lt;&gt; self.filterMachineType then
		return false;
	endif;
		
	if self.filterFaultType &lt;&gt; null and _fault.myFaultType &lt;&gt; self.filterFaultType then
		return false;
	endif;
		
	if self.filterStatus &lt;&gt; null and _fault.myFaultStatus &lt;&gt; self.filterStatus then
		return false;
	endif;
		
	if self.filterUser &lt;&gt; null then
		if _fault.myReportedByUser &lt;&gt; null then
			if _fault.myReportedByUser &lt;&gt; self.filterUser then
				return false;
			endif;
		elseif _fault.myEnteredByUser &lt;&gt; null then
			if _fault.myEnteredByUser &lt;&gt; self.filterUser then
				return false;
			endif;
		endif;
	
	endif;
		
	
	if self.filterFromTS.isValid and _fault.reportedTS &lt; self.filterFromTS then
		return false;
	endif;

	return inheritMethod(_fault, _passport);


epilog

end;</source>
        <Parameter name="_fault" type="CM_Fault"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
