    <JadeMethod name="getNumOnsiteNonPlannedTIs" id="3797102d-0b90-43f9-a616-b78255345351">
        <source>getNumOnsiteNonPlannedTIs() : Integer;
// ---------------------------------------------------------------------------
// Created:		16 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
		theTI : CM_TrackedItem;
		idx : Integer;
		plannedToShip : Boolean;
begin

	foreach theTI in self.allOnsiteTIsByCargoTypeId discreteLock do : tiLoop
		//plannedToShip := theTI.hasFutureMoveLoad(PLANNING_MODE); 
		//cnwjo3 par 26028
		plannedToShip := theTI.hasFutureMoveLoadForVoyage(PLANNING_MODE,self); 
		if plannedToShip then
			idx := idx + 1;
		endif;
	endforeach;

	return idx;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
