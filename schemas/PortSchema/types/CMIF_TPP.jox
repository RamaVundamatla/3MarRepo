    <JadeMethod name="setMyInvoiceLine" id="5b088dc0-7de0-40a5-aa52-fa0a957a1be4">
        <updating/>
        <source>setMyInvoiceLine(invLine : CM_InvoiceLine)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlger1	Initial creation

*/

vars
	glCodeObj 	: CM_GLCode;
	str: String;
begin
	self.myInvoiceLine:=invLine;
	
	if self.myInvoiceLine = null then
		return;
	endif;
	
	self.myInvoice 		:= self.myInvoiceLine.invoice;
	self.myTerminal		:=self.myInvoice.myTerminal;
	if self.myTerminal &lt;&gt; null then
		self.termCode		:=self.myTerminal.code;
	endif;
	self.myVoyage  		:= self.myInvoice.myVoyage;
	glCodeObj:=self.myInvoiceLine.getGLCode;
	if glCodeObj &lt;&gt; null then
		self.glCode:=glCodeObj.code;
	endif;
	if self.myInvoice.pendingDT.isValid then
		self.month:=self.myInvoice.pendingDT.Date.month.padLeadingWith("0",2);
		self.year:= self.myInvoice.pendingDT.Date.year.String;
	endif;

	str := self.myInvoiceLine.getServiceName;		// 14/11/19 MAP TFS47348
	if str.pos(Comma, 1) &gt; 0 then
		str := DoubleQuote &amp; str &amp; DoubleQuote;
	endif;
	self.serviceName := str;

	str := self.myInvoice.bank.code;				// 14/11/19 MAP TFS47348
	if str.pos(Comma, 1) &gt; 0 then
		str := DoubleQuote &amp; str &amp; DoubleQuote;
	endif;
	self.businessUnit := str;

	//str := self.myInvoice.externalFinancialId;	// 14/11/19 MAP TFS47348
	str := self.myInvoice.getExternalFinancialId();	//08/12/2025	navkc1 JIRA 36262
	if str.pos(Comma, 1) &gt; 0 then
		str := DoubleQuote &amp; str &amp; DoubleQuote;
	endif;
	self.externalInvoiceNbr := str;
epilog

end;</source>
        <Parameter name="invLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="tPPHelper" id="5a17f6c4-5801-4811-9bbc-009a7ed89575">
        <source>tPPHelper(_obj : Object ; _field : String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jan 2019	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars
	invoice 	 : CM_Invoice;
	invLine 	 : CM_InvoiceLine;
	ti      	 : CM_TrackedItem;
	tiTrans 	 : CM_TITransaction;
	str     	 : String;
	transferType : Integer;
	wharf        : HMS_Wharf;
	berth        : HMS_Berth;
	voyage       : CM_Voyage;
	hmsVoyage    : HMS_VoyageData;
	cargoType    : CM_CargoType;
	uomBarrang   : String;
	hmsRes       : HMS_ResourceUsed;
	hmsVslType   : HMS_VesselType;
	vessel       : CM_Vessel;
	country		 : CM_Country;
begin
	if _obj.isKindOf(CM_Invoice) then
		invoice := _obj.CM_Invoice;
		voyage := invoice.myVoyage;
	elseif _obj.isKindOf(CM_InvoiceLine) then
		invLine := _obj.CM_InvoiceLine;
		invoice := invLine.invoice;
		voyage := invoice.myVoyage;
	endif;
	
	if voyage &lt;&gt; null then
		if self.getBerth &lt;&gt; null then
			wharf := self.getWharf;
		endif;
		berth := self.getBerth;
		if voyage.myHMSVoyageData &lt;&gt; null then
			hmsVoyage  := voyage.myHMSVoyageData;
			hmsVslType := hmsVoyage.myVesselType; 
		endif;
		
		if voyage.getMyVessel &lt;&gt; null then
			vessel :=  voyage.getMyVessel;
		endif;
		
		
		if _field = "vesselType" then
			if hmsVslType &lt;&gt; null then
				str := hmsVslType.description;
			endif;
		endif;
		
		if _field = "voyageCode" then
			str := voyage.code;
		endif;
		
		if _field = "vesselName" then
			if vessel &lt;&gt; null then
				str := vessel.name;
			endif;
		endif;
	endif;
	
	if hmsVoyage &lt;&gt; null then
			if _field = "countryID" then
				country := hmsVoyage.getMyCountry();		// 21/8/19 MAP TFS46194
				if country &lt;&gt; null then
					str := country.description;
				endif;
			endif;
			if _field = "routeType" then
				str := self.getRouteType();
			endif;
			if _field = "quantityKappal" then
				str :=  hmsVoyage.dim_GrossRegTonnes.String;
			endif;
	endif;
		
	/*&gt;&gt; Constants  Mapping*/
	if _field = "unit_GRT" then
		str := "GRT";
	endif;
	
	if _field = "counter" then
		str := "1";
	endif;
	
	if _field = "flag" then
		str := invoice.sequenceNum.String;
	endif;
	
	/*&gt;&gt; Start Invoice  Mapping*/
	if invoice &lt;&gt; null then
		if _field = "externalInvoiceNbr" then
			str := invoice.exportCurrencyCode;
		endif;
		
		if _field = "businessUnit" then
			str := invoice.bank.code;
		endif;
		
		if _field = "year" then
			if invoice.pendingDT.isValid then
				str := invoice.pendingDT.Date.year.String;
			endif;
		endif;
		
		if _field = "serviceCode" then
			str := invoice.narration;
		endif;
		
		if _field = "month" then
			if invoice.pendingDT.isValid then
				str := invoice.pendingDT.Date.month.padLeadingWith("0",2);
			endif;
		endif;
		
		if _field = "termCode" then
			str := invoice.myTerminal.code;
		endif;
		
		if _field = "currency" then
			//jlier1 TFS 51963 15/10/21
			if invoice.bank.code.toUpper.cnContains("DOM") then
				str := "IDR";
			else
				str := "USD"; 
			endif;
		endif;
		
		if wharf &lt;&gt; null then
			if _field = "wharfCode" then
				str := berth.externalReference3;
			endif;
			
			if _field = "wharfName" then
				str := wharf.description;
			endif;
		endif;
		if berth &lt;&gt; null then
			if _field = "berthName" then
				str := berth.description;
			endif;
			
			if _field = "berthCode" then
				str := berth.externalReference4;
			endif;
		endif;
		
		if _field = "originPort" then
			str := Space;
		endif;
	endif;
	/*&gt;&gt; End  Invoice  Mapping*/
	
	/*&gt;&gt; Start Invoice Line Mapping*/
	if invLine &lt;&gt; null then
		if invLine.myTransactionTI &lt;&gt; null then
			tiTrans := invLine.myTransactionTI;
			if tiTrans.myTrackedItem &lt;&gt; null then
				ti := tiTrans.myTrackedItem;
				if ti.myCargoType &lt;&gt; null then
					cargoType := ti.myCargoType;
				endif;
			endif;
			
			if tiTrans.isKindOf(CM_ReleaseShip)  then
				transferType := tiTrans.CM_ReleaseShip.transferType;
			elseif tiTrans.isKindOf(CM_ReceiveShip) then
				transferType := tiTrans.CM_ReceiveShip.transferType;
			endif;
		
		elseif invLine.myTransactionHMS &lt;&gt; null then
				if invLine.myTransactionHMS.myResourceUsed &lt;&gt; null then
					hmsRes := invLine.myTransactionHMS.myResourceUsed;
					
					if _field = "productionCode" then
						str := hmsRes.code;
					endif;
				endif;
		endif;
		if _field = "amount" then
			str := invLine.lineTotal.String;
		endif;
		
		if _field = "productionQty"  then
			str := invLine.quantity.String;
		endif;
		if _field = "quantityBarrang"   then
			if cargoType.isBreakBulkMulti then
				str := invLine.myTransactionTI.totalQuantity.String;
			elseif cargoType.isBulkMulti then
				str := (invLine.myTransactionTI.totalWeight/1000).String;
			elseif cargoType.isContainer then
				str := "1";
			endif;
		endif;
		
		if _field = "transferType" then
			str := app.vesselAccessTypeEnumToStr(transferType);
		endif;
		
		if _field = "serviceName" then
			str := invLine.getServiceName;
		endif;
		
		
		/*&gt;&gt; Start Tracked Item Mapping*/
		if ti &lt;&gt; null then
			if _field = "contentStatus" then
				str := ti.contentsStatusCode;
			endif;
			
			if _field = "isoType" then
				if ti.isContainer then
					str := ti.CM_Container.isoType;
				endif;
			endif;
			
			if _field = "imex" then
				str := ti.getImExStatusString();
			endif;
			
			if _field = "commodity" then
				str := ti.getCommodityDesc;
			endif;
		endif;
		/*&gt;&gt; End Tracked Item Mapping*/
		
		/*&gt;&gt; Start Cargo Type Mapping*/
		if cargoType &lt;&gt; null then
			if _field = "cargoType" then
				str := cargoType.description;
			endif;
			if cargoType.abbreviation = "HW" or 
				cargoType.abbreviation = "VEHICLE"	then // Hewan
				if _field = "codeHewanMobil" then
					str := cargoType.abbreviation;
				endif;
				
				if _field = "nameHewanMobil" then
					str := cargoType.description;
				endif;
			elseif cargoType.abbreviation = "CONT" then
				if _field = "isoType" then
					if ti &lt;&gt; null then
						str := ti.isoTypeDesc ;
					endif;
				endif;
			endif;
			
			if cargoType.isBulkByWeight then
				uomBarrang := "Ton";
			endif;
			
			if _field = "uOM" then
				str := uomBarrang;
			endif;
		endif;
	endif;
	/*&gt;&gt; End Cargo Type Mapping*/
	
	//str := str.removeCommas;
	if str.pos(Comma, 1) &gt; 0 then
		str := DoubleQuote &amp; str &amp; DoubleQuote;		// 14/11/19 MAP TFS47348
	endif;

	return str;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
