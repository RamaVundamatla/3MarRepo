    <JadeMethod name="getFinishTimeLocalTZ" id="386e5f34-edad-42f6-9208-424ca3324c55">
        <source>getFinishTimeLocalTZ(): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.finishTS);
epilog

end;</source>
