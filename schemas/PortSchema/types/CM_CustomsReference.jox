    <JadeMethod name="validateForCreate" id="d0f81c45-2db7-4506-8d05-eedd0dc44d81">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 November 2022	navpw1	Initial creation TFS: 55215
08 April 	2024	navlw1 	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode

*/

begin
	self.validateForUpdate();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0fe2a171-a0f2-4e55-ae5a-9f427bced785">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 November 2022	navpw1	Initial creation TFS: 55215
08 April 	2024	navlw1 	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode
*/

begin
	if self.myTrackedItem = null then
		app.raiseCMException(Input_required_field_trakedItm, null, null);
	endif;
	
	if self.referenceType = null then
		app.raiseCMException(Input_requir_refere_type_field, null, null);
	endif;
	
	if self.referenceNumber = null then
		app.raiseCMException(Input_requir_refere_number_fie, null, null);
	endif;
	// navlw1 #63566
	if self.positionNumber = null then
		app.raiseCMException(Input_requir_pos_num_fie, null, null);
	endif;
end;</source>
    </JadeMethod>
</Class>
