    <JadeMethod name="setProxyFromObject" id="6d3b7974-d232-491d-89e3-dd94d53892ce">
        <updating/>
        <source>setProxyFromObject(_trackedItem : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023	navcs2	ChangeRequest 57557: [57396]: EUP - INB/MOB - New Scanning App - JADE
04 Sep 2023 jlier1  TFS  60152
16 Nov 2023 namva1	ChangeRequest 58350: EUP | Sorting Method info displayed in Job Lander, Cargo Lander WEB
23 Nov 2024 navbk1  Bug 62600: EUP - Cargo Scanning App Showing Sub Type Instead of Commodity
15 Oct 2024 navhl20 ChangeRequest 14791: EUP | 53856 - New Scanning App - Unpack mode issue
*/

vars
	sortingMethod : CM_SortingMethod;
	cargoGrp	  : CM_CargoGroup;
	parent		  : CM_TrackedItem;
begin
	if _trackedItem = null then
		return;
	endif;

	self.id := _trackedItem.id;
	self.uid := _trackedItem.getOidAsString;
	parent := _trackedItem.myParent;							//15.10.2024 navhl20 #14791
	if parent &lt;&gt; null then										//15.10.2024 navhl20 #14791
		self.parentUid := parent.getOidAsString();
	endif;
	self.markNumber := _trackedItem.markNumber;
	self.cargoType := _trackedItem.cargoTypeDescr;
	self.cargoSubType := _trackedItem.getCargoSubTypeCode;
	self.commodity := _trackedItem.commodity;					//23.02.2024 navbk1 #62600
	
	self.grammage:=_trackedItem.getGrammage.asStringJMT;
	self.grade:=_trackedItem.getGrade;
	self.rollingLength:=_trackedItem.getRollingLength.asStringJMT;
	self.diameter:=_trackedItem.getDiameter.asStringJMT;
	self.dimensions:=_trackedItem.getDimensionsDisplay;
	self.totalWeight:=_trackedItem.getTotalWeightDisplay();
	
	cargoGrp := _trackedItem.myCargoGroup;
	if cargoGrp &lt;&gt; null then
		self.groupId		:= cargoGrp.id;  					//jlier1 TFS 59876 21/8/23
		self.groupLocation  := cargoGrp.getAllLocations( null );
	endif;
	
	self.itemised := _trackedItem.itemised;						//16.11.2023 navma1 #58350
	
	sortingMethod := _trackedItem.mySortingMethod;				//16.11.2023 navma1 #58350
	if sortingMethod &lt;&gt; null then								//16.11.2023 navma1 #58350
		self.sortingMethodCode := sortingMethod.code;
		self.sortingMethodDesc := sortingMethod.description;
	endif;
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
