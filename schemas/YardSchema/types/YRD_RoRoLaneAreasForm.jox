    <JadeMethod name="doMnuStopClick" id="09c34f7b-3970-420b-bbdc-e5b87babcc07">
        <updating/>
        <source>doMnuStopClick( menuItem : MenuItem input ) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
// ---------------------------------------------------------------------------
	
vars
	result		: Integer;
	lTI			: CM_TrackedItem;
	stopsTable	: CM_StopsTable;
	tiSet		: CM_TISet;
//	lStops		: IntegerArray;
//	lTI			: CM_TrackedItem;
	
begin
	// just maintains the last ti selected
	lTI := menuItem.userObject.CM_TrackedItem;
	
	self.myAssistant.showStopsForm_TI (lTI, null, app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012

	// refresh table
	self.showExtraInfoForObject( lTI );

	return;
	
/*	app.mousePointer	:= Busy;						// cnwrl1 27/01/2010 PAR 21889
	
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	// cnwrl1 27/01/2010 PAR 21889 - start of coding
	// NOTE: This reproduces the release 7.7.3 behaviour - ie it only handles the last TrackedItem clicked on.
	create tiSet transient;
	stopsTable	:= app.myRoot.allStopsTable[ menuItem.index ];
	while true do : update_TrackedItems
		self.myAssistant.contextMenuTIsStop( stopsTable, lTI, tiSet );
		
		if app.myPassport.noErrors then
			self.clearErrorWarnings();
			return;
		endif;
		result	:= app.showErrorWarningDialog(	app.getString( EWD_Cannot_Continue, app.getString( HeadingSaved ) ),
												app.myPassport,
												ErrWarnMode_Add + ErrWarnMode_CanAckWarnings );
		if app.myPassport.noErrors and result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue update_TrackedItems;
		endif;
		self.setAllErrorWarnings( app.myPassport );	// copies errors to this form and shows in err/warnings window
		return;
	endwhile update_TrackedItems;
	
	// refresh table
	self.showExtraInfoForObject( lTI );*/
	// cnwrl1 27/01/2010 PAR 21889 - end of coding
	
	/* cnwrl1 28/01/2010 PAR 21889 - what it was
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	create lStops transient;
	create tiSet transient;			// cnwrl1 12/05/2009 PAR 19574 - CCMS 1791
	
	lStops.add(menuItem.index);
//	if lTI.getStopByID(menuItem.index) = null then	// cnwrl1 14/12/2009 PAR 21889 - what it was
	if not lTI.isStopSet( menuItem.index ) then
		// cnwrl1 12/05/2009 PAR 19574 - CCMS 1791 - start of coding
		tiSet.add( lTI );
		app.myTrxCA.trxCreateStopsForTIs( tiSet, lStops, app.myPassport );
//		app.myTrxCA.trxCreateStops(lTI, lStops, aOK, app.myPassport);	what it was
		// cnwrl1 12/05/2009 PAR 19574 - CCMS 1791 - end of coding
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog('Grid Area Form', app.myPassport, ErrWarnMode_Add);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	else
//		stopTable := lTI.getStopByIDAsAtDate(menuItem.index).myStopsTable;	// cnwrl1 11/01/2010 PAR 21889 - what it was
		stopTable := lTI.getStopByIDAsAtDate( menuItem.index, null ).myStopsTable;
		if stopTable.requiresInfo then
			self.processStopInfo(lTI, stopTable, lStops);
		else
			app.myTrxDA.trxDeleteStops(lTI, lStops, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog(app.getErrorString(Cargo_Enquiry), app.myPassport, ErrWarnMode_Update);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	endif;
	
	menuItem.checked := not menuItem.checked;
	//refresh table
	self.showExtraInfoForObject(lTI);
	
epilog
	delete lStops;
	delete tiSet;
	mousePointer := MousePointer_Default;
end;
	cnwrl1 28/01/2010 PAR 21889 - end of what it was */
	
epilog
	delete tiSet;
	app.mousePointer	:= Idle;
	
end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskAdd" id="0b70b644-61b2-47a9-99fe-ea6333862054">
        <updating/>
        <source>doMnuTaskAdd(menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lTI	: CM_TrackedItem;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskAdd(lTI, menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	//refresh table
	self.showExtraInfoForObject(lTI);

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskComplete" id="3da58fb1-c11c-4c39-b2e4-1b461d3be2c0">
        <updating/>
        <source>doMnuTaskComplete(menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lTI	: CM_TrackedItem;
	realTiSet : CM_TISet;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuTaskComplete then
		return;
	endif;
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[menuItem.index];
	
	create realTiSet transient;
	realTiSet.add(lTI);

	//+cnwml2 MSL CCMS 1017	
	create pxyTiSet transient;
	
	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( menuItem.index, pxyTiSet, lTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	//refresh table
	self.showExtraInfoForObject(lTI);
	
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskRemoveClick" id="1ebef86b-158c-43de-b232-f2e585af434c">
        <updating/>
        <source>doMnuTaskRemoveClick(_menuItem : MenuItem input) updating;
//----------------------------------------------------------------
//	Created:	August 2005	by Russell Sargent  (cnwrs1)
//----------------------------------------------------------------

vars

	lTI		: CM_TrackedItem;
	answer	: Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	lTI := _menuItem.userObject.CM_TrackedItem;
	if lTI = null or 
	   _menuItem = self.mnuTaskRemove then
		return;
	endif;

	answer := app.msgBox(app.getErrorString(TaskRemoveConfirm), app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_No then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskRemove(lTI, _menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Remove_Task), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuUnplanClick" id="e3f714ef-be51-448e-9b4e-ce8c89c2e6fa">
        <updating/>
        <source>doMnuUnplanClick(_menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _menuItem.helpKeyword = self.UnplanMenu_TypeMain then
		return;
	endif;
	if _menuItem.helpKeyword = self.UnplanMenu_TypeRehandle then
		 return;
	endif;
	
	if _menuItem.userObject.isKindOf(CM_TrackedItem) then	//16 Feb 2011	NDL PAR 27006
	
		if _menuItem.userObject.CM_TrackedItem.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then 
			self.doUnqueueTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpContextId = TI_FutureMoveOverstow));
		else
			self.doUnplanTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpKeyword = self.UnplanMenu_TypeLoad));
		endif;
		
	elseif _menuItem.userObject.isKindOf(CM_FutureMove) then //16 Feb 2011	NDL PAR 27006
		self.doUnqueueTIbyFM(_menuItem.userObject.CM_FutureMove);
	
	endif;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegend" id="1eeda43f-1f2f-4078-9803-813c7c772e6a">
        <source>doNotesForLegend(_startNote : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	idx, numRows : Integer;
	theTable : Table;
begin
	theTable := self.frmColLegendTIs.myLegendTable;
	numRows := theTable.rows;
	foreach idx in 2 to numRows do
		anObject := theTable.accessRow(idx).itemObject;
		if anObject &lt;&gt; null then
			if _startNote then
				self.beginNotification(anObject, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			else
				self.endNotification(anObject, EVENT_CODE_COLOUR_CHANGE);
			endif;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_startNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegendStartStop" id="a23caa1a-c562-4932-a426-92da50dca34e">
        <updating/>
        <source>doNotesForLegendStartStop(_theIndex : Integer; _ydc : YRD_RoRoLaneDrawingController) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.doNotesForLegend(false);
	if (not self.frmColLegendTIs.displayCodesForMode(_ydc.viewMode, _ydc.myDrawingAttrController)) then
		// could not find any codes/colours in controller so display them all
		self.frmColLegendTIs.doChangeViewMode(_theIndex);
	endif;
	self.doNotesForLegend(true);

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_ydc" type="YRD_RoRoLaneDrawingController"/>
    </JadeMethod>
    <JadeMethod name="doProcessMoveLog" id="db4099e9-85a8-4f17-9a47-5ea6531322aa">
        <source>doProcessMoveLog() protected;
// --------------------------------------------------------------------------------
// Created:		04 November 2008 by cnwdad1
//
// Purpose:		Processes queued Movement Logs and their corresponding statistics.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	movementLogObj	: CMIF_MovementLogController;
	
begin
	create movementLogObj transient;
	
	// Keep processing Movement Logs until there are none left to do.
	
	while movementLogObj.processMovementLog() do
	endwhile;
epilog
	delete movementLogObj;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRebuildStats" id="cfae5489-27d4-4850-a589-988cc01fa438">
        <source>doRebuildStats(_yaEntityObj:CM_YAEntity) protected;
// --------------------------------------------------------------------------------
// Created:		04 November 2008 by cnwdad1
//
// Purpose:		Rebuilds the statistics for the specified yard Allocation entity.
//
// Parameters:	_yaEntityObj - A reference to the Yard Allocation entity who's
//				statistics we want to rebuild.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockSetObj	: CM_YABlockSet;
	blockObj	: CM_YABlock;
	arrayObj	: ObjectArray;
	termAreaSet : CM_TerminalAreaSet;
begin
	if _yaEntityObj = null then
		return;
	endif;
	
	create termAreaSet transient;
	create blockSetObj transient;
	
	if _yaEntityObj.isKindOf(CM_YABlock) then
		blockSetObj.add(_yaEntityObj.CM_YABlock);
	else
		foreach blockObj in _yaEntityObj.CM_YardAllocation.allYABlocksIn do
			blockSetObj.add(blockObj);
		endforeach;
	endif;
	
	app.myTrxUA.trxCalcLocationStats(termAreaSet, blockSetObj, arrayObj, app.myPassport);
epilog
	delete blockSetObj;
	delete termAreaSet;
end;</source>
        <access>protected</access>
        <Parameter name="_yaEntityObj" type="CM_YAEntity"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="de7e7c6f-2e77-4cc4-b5fa-ef743286614d">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpController	: YRD_RoRoLaneDrawingController;
	anObj : Object;
	tmpVM : Integer;
begin


	foreach anObj in self.allDrawingControllers do
		tmpController := anObj.YRD_RoRoLaneDrawingController;
		
		tmpVM := tmpController.viewMode;
		
		if tmpVM &lt;&gt; 0 then
			tmpController.setViewMode(tmpVM);
		else
			tmpController.setViewMode(VIEW_VOYAGE);
		endif;
		tmpController.drawSelf(true);
	endforeach;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="2d703abc-fb8f-4a43-873d-422b31871a2b">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	anObj : Object;
	cdb : YRD_ContainerGridAreaDockBar;
begin

	inheritMethod();
	
	foreach anObj in self.allDockBars do
		cdb := anObj.YRD_ContainerGridAreaDockBar;
		cdb.cnEcResizeContents();
		if cdb.myDrawingFrame &lt;&gt; null then
//			cdb.myDrawingFrame.parent.top := YRD_TrailerDrawingController.LABEL_WIDTH + 1;
//			cdb.myDrawingFrame.parent.left := YRD_TrailerDrawingController.LABEL_WIDTH + 1;
		endif;
	endforeach;

	self.frmStatusLine.doResize();
	self.setLastColumnMaxWidth(self.tblGridAreaInfo);
	self.doResizeColumnWidths(self.tblGridAreaInfo, true);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doRestrictionOpenLabour" id="8204c4da-a7a9-48dd-b4d4-4e082ee54e7c">
        <source>doRestrictionOpenLabour(_ta : CM_TerminalArea)protected;
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
