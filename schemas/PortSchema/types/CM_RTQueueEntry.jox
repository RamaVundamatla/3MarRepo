    <JadeMethod name="getDetailForRemoteQuery" id="4dd8f635-f41d-4c82-b84b-66cef5768e6f">
        <source>getDetailForRemoteQuery(_type : String) : String;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars

	theId,
	jobDtl,
	workListDtl	: String;
	

begin
	if self.myWorkListEntry = null then		// or not global.isValidObject(self.myWorkListEntry) then
		return null;
	endif;
	theId 		:= self.getOidString();
	jobDtl 		:= self.myJob.getDetailForRemoteQuery(_type);
	workListDtl := self.myWorkListEntry.getDetailForRemoteQuery(_type);
	return theId &amp; ',' &amp; jobDtl &amp; ',' &amp; workListDtl;

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDirectorOrPickupTask" id="004ad38c-da53-4ecd-a086-69c2d0b126b3">
        <source>getDirectorOrPickupTask() : CM_RTQueueTask;

/*

Purpose:			Get either the first Pickup task from the receiver, or if there is
					none, then the Director task.
					Used from getTwinCarryFlag to get the source location for this entry

Parameters:			None

Return Value:		Matching task, if there is one


Date		Who		Reason
25 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
30 Oct 2009	cnwer1	PAR 20701 - CCMS 1063 - IMVs want to see tasks that they can twin carry - need to also get move tasks which is what imvs work
14 Dec 2010 cnwer1 PAR 26550 - handle overstow tasks where more than one set have been created
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming

*/

vars
	setdownTask,
	task			: CM_RTQueueTask;
	invalid			: Boolean;
	
begin
	setdownTask := self.getFirstUncompletedTaskOfType(TASK_SETDOWN);
	if setdownTask &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, setdownTask, invalid);		// PAR #27142
		task := setdownTask.getPreviousTask;
	endif;

	//cnwrd1 par 25681 18.11.2010 multi machine director moves - moved this above director task as a move should take priority, otherwise the IMV displays the director task when it also has a move.
	// epr par 30/10/09 20701 
	if task = null then
		
		task := self.findTaskOfType(TASK_MOVE,NULL_INTEGER);
	endif;
	
	// If there is no Pickup task, then look for an unactioned Director task
	if task = null then
		
		task := self.findTaskOfType(TASK_DIRECTOR, NULL_INTEGER);
	endif;

	
	if task = null and self.isPlanOnPickup then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		task := self.findTaskOfType(TASK_PICKUP, NULL_INTEGER);
	endif;
	
	if task = null and self.isBreakBulkGenericMaster then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		task := self.findTaskOfType(TASK_BREAKBULK, NULL_INTEGER);
	endif;
	
	return task;
	
	
epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getDirectorOrSetDownTask" id="a61c54ba-d769-4012-983e-416e2bed1a45">
        <source>getDirectorOrSetDownTask() : CM_RTQueueTask;

/*

Purpose:			Get either the first SetDown task from the receiver, or if there is
					none, then the unactioned Director task.
					Used from getTwinCarryFlag to get the target location for this entry

Parameters:			None

Return Value:		Matching task, if there is one


Date		Who		Reason
25 February 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
30 Oct 2009	cnwer1	PAR 20701 - CCMS 1063 - IMVs want to see tasks that they can twin carry - need to also get move tasks which is what imvs work
*/

vars
	task			: CM_RTQueueTask;

begin
	task := self.getFirstUncompletedTaskOfType(TASK_SETDOWN);
	
	
	// If there is no Pickup task, then look for an unactioned Director task
	if task = null then
		task := self.findTaskOfType(TASK_DIRECTOR, NULL_INTEGER);
	endif;
	
	// epr par 30/10/09 20701 
	if task = null then
		
		task := self.findTaskOfType(TASK_MOVE,NULL_INTEGER);
	endif;
	
	return task;
	
	
epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getFinalTargetLocation" id="1f7c2931-6555-49e2-b0fa-aa2ec7aba86d">
        <source>getFinalTargetLocation() : CM_LocationsController;
/*

Purpose:		Returns the final target location i.e. with multiple rt queue entries this will get the final target destination	

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2010	cnwer1	Initial creation
16 Oct 2024 navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
*/

vars
	qdFutureMove : CM_FutureMoveQueued;
	wle			 : CM_WorkListEntry;
begin
	
	wle := self.myWorkListEntry;
	
	if wle = null then
		return null;
	endif;
	
	if wle.myFutureMove = null then
		return null;
	endif;
	
	qdFutureMove := wle.myFutureMove.CM_FutureMoveQueued;
	
	if qdFutureMove.allLocationsControllers.isEmpty then     //16.10.2024 navma1 #MTN-33090
		return null;
	endif;
	
	return qdFutureMove.allLocationsControllers.first;
	
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getFirstUncompletedTask" id="b5099387-c19d-45e8-9605-0a7f7a7b83bf">
        <source>getFirstUncompletedTask() : CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Apr 2010	cnwer1	Initial creation
04 May 2023 navma1	Bug 57849: MSL - Slowness Issues

*/

vars
	task 		: CM_RTQueueTask;
	invalidTask	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, task, invalidTask);	// 22/03/2011 cnwar2 #27223
	
	foreach task in self.allTasks discreteLock do
		
		invalidTask := false;
		task.edition;
		
		if invalidTask then													//04.05.2023 navma1 #57849
			continue;
		endif;
		
		if task.status &lt;&gt; TASK_COMPLETE then
			return task;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getFirstUncompletedTaskOfType" id="4507c18f-72db-4dfc-8f5b-9a6514c6f56e">
        <source>getFirstUncompletedTaskOfType(_type : Integer) : CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Dec 2010	cnwer1	Initial creation
16 Oct 2024 navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
*/

vars
	task 		: CM_RTQueueTask;
	invalidTask	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, task, invalidTask);	// 22/03/2011 cnwar2 #27223

	foreach task in self.allTasks discreteLock do
		invalidTask := false;
		
		task.edition;
		if invalidTask then													//16.10.2024 navma1 #MTN-33090
			continue;
		endif;
		if task.status &lt;&gt; TASK_COMPLETE and task.taskType =_type then
			return task;
		endif;
	endforeach;
	
	return null;

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getJobCrane" id="929344de-9359-4079-a214-a9b413bff4ab">
        <source>getJobCrane() : CM_Crane;
//If we have a voyage job, then this returns a reference to the crane object
//associated with it
vars

begin
	if not self.myJob.isKindOf(CM_VoyageJob) then
		return null;
	endif;
	return self.myJob.CM_VoyageJob.getJobCrane();	
end;</source>
        <ReturnType type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="getJobWorkPoint" id="b26c2259-77c6-476c-a3e8-3ed32ef407ee">
        <source>getJobWorkPoint():CM_WorkPoint;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2012	cnwndl1	Initial creation	Par 30039

*/

vars

	obj : CM_Object;

begin

	if not self.myJob.isKindOf(CM_VoyageJob) then
		return null;
	endif;
	
	obj :=  self.myJob.CM_VoyageJob.getWorkPointObject();
	if obj &lt;&gt; null and obj.isKindOf(CM_WorkPoint) then
		return obj.CM_WorkPoint;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="getLastRTQueueEntry" id="5f9712c2-7f75-4f5f-a16d-f63aa0670479">
        <source>getLastRTQueueEntry() : CM_RTQueueEntry;
/*

Date		Who		Reason
19 February 2015	cnwer1	Initial creation PAR 35702

*/

vars

