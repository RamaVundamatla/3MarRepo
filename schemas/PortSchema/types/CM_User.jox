    <JadeMethod name="delete" id="45557eb8-85a0-438e-96bc-3a3b6ad17bb3">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     14 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	audit : CM_AuditObject;
begin
	self.allSubSystemStateObjects.purge;
	
	//15 Jan 2016	NDL	Par 37388
	self.allUserCargoTypes.purge(); // These are actually CM_UserConfigCargoType objs
									//whihc config the Crago Enquiry sheets

// cnwrs1 june 2006 was missing
	foreach audit in self.allAuditObjectChangesByMe do
		// Tell the audit that it's subject is about to be deleted
		audit.subjectBeingDeleted();
		// Null the reference back to us
		audit.setSubject(null);
	endforeach;
end;</source>
    </JadeMethod>
