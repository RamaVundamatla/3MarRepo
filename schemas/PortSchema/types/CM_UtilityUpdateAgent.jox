    </JadeMethod>
    <JadeMethod name="utlUpdateWagonSeal" id="ba1912dc-f109-4484-ba37-0e65821f31de">
        <updating/>
        <source>utlUpdateWagonSeal( _moveController : CMIF_WagonMoveController; pxyWagonSeal : CM_WagonSeal input; pRealWagonSeal : CM_WagonSeal io; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	newWagonSeal : CM_WagonSeal;
	trxType : Integer;
	wagon : CM_Wagon;
	inward : Boolean;
	wagonTrx : CMEVT_WagonTransaction;
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;

	self.initialiseActivity();

	self.raiseExceptionIfNull(pxyWagonSeal, 'Wagon Seal');
	
	app.myValUA.valWagonSeal( pxyWagonSeal );
	
	if pRealWagonSeal &lt;&gt; null then
	
		wagon := pRealWagonSeal.myWagonVisit;
		if wagon &lt;&gt; null and not wagon.confirmed then
			inward := true;
		endif;
	
		exclusiveLock(pRealWagonSeal);
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(pRealWagonSeal, true);
			//Think if an Update of a seal as a delete then an add
			wagonTrx := wagon.createTransaction( effectiveDate, EVT_WagonSealDelete, pRealWagonSeal, null, null, inward, null, null, null);
		endif;
		
		pRealWagonSeal.setForUpdate( pxyWagonSeal );
			
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(pRealWagonSeal, false);
		endif;
		
		if _passport.noErrors then
			if pRealWagonSeal.getSealValueAsString.trimBlanks = null and pRealWagonSeal.previousSeal.trimBlanks = null then
				//Seal has been removed, and replaced with nothing, really delete it.
				delete pRealWagonSeal;
			else
				// seal has been replaced with this one
				wagon.createTransaction(effectiveDate, EVT_WagonSealAdd, pRealWagonSeal, null, null, inward, null, null, null);
			endif;
		endif;
		
	else
	
		wagon := pxyWagonSeal.myWagonVisit;
		if wagon &lt;&gt; null and not wagon.confirmed then
			inward := true;
		endif;
		
		create newWagonSeal persistent;
		newWagonSeal.setForCreate( pxyWagonSeal );
		newWagonSeal.setMyWagonVisit( pxyWagonSeal.myWagonVisit );
		
		pRealWagonSeal := newWagonSeal;
		
		if _passport.noErrors then	
			wagon.createTransaction( effectiveDate, EVT_WagonSealAdd, pRealWagonSeal, null, null, inward, null, null, null);
		endif;
		
	endif;
	
	

epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="pxyWagonSeal" type="CM_WagonSeal" usage="input"/>
        <Parameter name="pRealWagonSeal" type="CM_WagonSeal" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonTrackedItems" id="0c000baf-6f6a-4c44-b98a-c64aac78e8a6">
        <updating/>
        <source>utlUpdateWagonTrackedItems(_proxyWagon:CM_Wagon input; _tiArray : CM_TIArray input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		Pass in a wagon and an array of TIs and it will put them on the wagon in the order that they are in the array
//				NOTE if the wagon class can handle a height greater than 1 it will fill up the bottom row first then the 2nd and so on
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 July 2002	DWQ	Transient move controller was being created inside loop, and no epilog to ever delete!
//											Massive resource leak.
// -------------------------------------------------------------------------

vars
	realWagon:CM_Wagon;
	expectedEdition:Integer;
//	aTIWagonPosition	: CMIF_TIWagonPosition;
	lTIArray	: CM_TIArray;
	aTI : CM_TrackedItem;
	lMoveControl : CMIF_MoveController;
	thePosition, theWagonHeight, theWagonLength, theContainerLength : Integer;
	wagMoveController : CMIF_WagonMoveController;
begin

	self.initialiseActivity();

	_proxyWagon.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	app.myValUA.valWagon(_proxyWagon);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_proxyWagon.pxyGetRealObjectAndEdition(realWagon, expectedEdition);
	
	if realWagon = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Wagon.name, null, null);
		return;
	endif;

	exclusiveLock(realWagon);

	if _passport.noErrors and realWagon.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Wagon', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWagon, true);
	endif;
	
	if _passport.noErrors then
	
		//26 Feb 2021	NDL	TF S50837
		create wagMoveController transient;
		wagMoveController.autoSetEffectiveTimeStamp();

		realWagon.setForUpdate( wagMoveController, _proxyWagon);
		
		create lMoveControl transient;	//Only need to create one of these.

		foreach aTI in _tiArray do

			if aTI = null then
				continue;
			endif;
			theContainerLength := aTI.getLengthInUnits.Integer; // 10 foot units
			
			if theContainerLength = null then
				continue;
			endif;
			thePosition:= realWagon.getNextFreeWagonPosition(aTI,null,null,0,false);	// 06 Oct 2009	NDL	Par 20842 Param chg	&amp; //10 May 2010	NDL Par 24064

			if thePosition &lt;&gt; null then
				lMoveControl.setMyTrackedItem(aTI);
				lMoveControl.isSystemMove := true;
				lMoveControl.setMyToPrimaryLocation(realWagon.allLocationsControllersArray[thePosition]);
				app.myUtilityUA.utlUpdateMoveTrackedItem(lMoveControl, _passport);
				if (not _passport.noErrors) then
					break;
				endif;
			else
				app.setContinueCMExceptions(false);
				app.raiseCMException(Err_Insufficient_Locns, null, null);
				return;
			endif;		
		endforeach;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWagon, false);
	endif;

epilog

	delete lMoveControl;
	delete wagMoveController;

end;</source>
        <Parameter name="_proxyWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonWellDef" id="e98917a1-cca6-4549-8948-05b7f418c1b1">
        <source>utlUpdateWagonWellDef(pProxyWagonWellDef : CM_WagonWellDefinition; _passport : CM_Passport input);
