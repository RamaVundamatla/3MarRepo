	self.deleteContainer("THRS1110104");
	self.deleteContainer("THRS1110105");
	self.deleteContainer("THRS1110106");
	self.deleteContainer("THRS1110107");
	self.deleteContainer("THRS1110108");
	self.deleteContainer("THRS1110109");
	self.deleteContainer("THRS1110110");
	self.deleteContainer("THRS1110111");
	self.deleteContainer("THRS1110112");
	self.deleteContainer("THRS1110113");
	self.deleteContainer("THRS1110114");
	self.deleteContainer("THRS1110115");
	self.deleteContainer("THRS1110116");
	
	self.deleteContainer("THRS1110301");
	self.deleteContainer("THRS1110302");
	self.deleteContainer("THRS1110303");
	self.deleteContainer("THRS1110304");
	self.deleteContainer("THRS1110305");
	self.deleteContainer("THRS1110306");
	self.deleteContainer("THRS1110307");
	self.deleteContainer("THRS1110308");
	self.deleteContainer("THRS1110309");
	self.deleteContainer("THRS1110310");
	self.deleteContainer("THRS1110311");
	self.deleteContainer("THRS1110312");
	self.deleteContainer("THRS1110313");
	self.deleteContainer("THRS1110314");
	self.deleteContainer("THRS1110315");
	self.deleteContainer("THRS1110316");
	
	self.deleteContainer("THRS1110501");
	self.deleteContainer("THRS1110502");
	self.deleteContainer("THRS1110503");
	self.deleteContainer("THRS1110504");
	self.deleteContainer("THRS1110505");
	
	self.deleteStopsTable(997);
	
	self.deleteTerminalArea("UT_WASHTA");
	self.deleteTerminalArea("UT_REPAIRTA");
	self.deleteTerminalArea("UT_PRETRIPTA");
	
	self.deleteToDoTasks("UT_Wash");
	self.deleteToDoTasks("UT_Repair");
	self.deleteToDoTasks("UT_Pretrip");
	self.deleteToDoTasks("UT_PTIRepair");
	self.deleteToDoTasks("UT_Survey");
	
	self.deleteOperator("UTTH");
	
	

epilog

end;</source>
        <access>protected</access>
