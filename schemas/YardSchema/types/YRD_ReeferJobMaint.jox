    <JadeMethod name="clickSelection" id="229f5ae6-1589-426f-b33c-49990162733b">
        <source>clickSelection();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	if self.optByGridArea.value then
		if self.grpJobs.top &lt;&gt; 220 then
			self.grpSelection.height := 213;
			self.grpJobs.top := 220;
			self.grpJobs.height := self.grpJobs.height - 138;
		endif;
	else
		if self.grpJobs.top &lt;&gt; 81 then
			self.grpSelection.height := 75;
			self.grpJobs.top := 81;
			self.grpJobs.height := self.grpJobs.height + 138;
		endif;
	endif;

	self.cmbGridTermArea.visible := self.optByGridArea.value;
	self.lblSelect.visible := self.optByGridArea.value;
	self.tblReeferWalkBlocks.visible := self.optByGridArea.value;
	
	if self.optByTerminal.value then
		self.cmbGridTermArea.listIndex := -1;
	endif;
	
	self.doClickCmbGriddedArea();

epilog

end;</source>
    </JadeMethod>
