    <JadeMethod name="setForCreate" id="f8824272-1243-48ed-b68d-0901f9a10a65">
        <updating/>
        <source>setForCreate(_idx : Integer; _rowArea : GC_RowArea) updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.row	:= _idx;
	self.myGridArea := _rowArea;
	self.label := _rowArea.label;
end;</source>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_rowArea" type="GC_RowArea"/>
    </JadeMethod>
</Class>
