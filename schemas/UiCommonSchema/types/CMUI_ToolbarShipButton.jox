<GUIClass name="CMUI_ToolbarShipButton" id="5cfc90a5-b294-488a-b384-4cbb5cae86ad">
    <superclass name="CMUI_JadeMask"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myUserToolbar" id="8876fec0-9734-464c-960c-c146da1448d1">
        <embedded/>
        <type name="CM_MenuUserToolbar"/>
    </ImplicitInverseRef>
    <JadeMethod name="mouseUp" id="d777e5bc-2736-4d32-829d-1054aaf4734d">
        <updating/>
        <source>mouseUp(jadeMask: JadeMask input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(jadeMask, button, shift, x, y);
	if button &lt;&gt; 1 then
		return;
	endif;
	self.myParent.sendMsgWithParams("doBtnToolBarMouseUp",jadeMask);
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
