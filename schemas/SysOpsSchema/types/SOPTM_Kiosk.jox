    <JadeMethod name="doSave" id="94fa0e7c-e280-406b-9b3c-5cae56276fbb">
        <updating/>
        <source>doSave(): Boolean updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation
07 August 2023	jlizm1	TFS 59548 Kiosk maintenance locales

*/
vars
	theForm 		: SOP_TableMaintForm;
	tbl				: CM_EntryTable;
	pxyKiosk 		: CM_Kiosk;
	locale 			: CM_Locale;
	selectedLocales	: CM_LocaleArray;
	
begin
	theForm := self.myForm;
	tbl 	:= theForm.tblInput1;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Kiosk transient;
		endif;
		if theForm.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	if self.termsAndConditionsChanged then
		if app.msgBox(app.getErrorString(UnsavedChangesInView), app.getErrorString(ConfirmCancelHeading), MsgBox_Yes_No) = MsgBox_Return_No then
			return false;
		endif;
	endif;

	locale:=theForm.cmbLocale.listObject.CM_Locale;
	
	create selectedLocales transient;
	
	theForm.mulSelect1.getSelected(selectedLocales);
	
	pxyKiosk := theForm.myProxyObject.CM_Kiosk;
	pxyKiosk.setProxy(	tbl.getValueByName(ETRow_Code).String,
						tbl.getValueByName(ETRow_Description).String,
						tbl.getValueByName(ETRow_MachineName).String,
						theForm.myTerminal,
						locale,
						selectedLocales,
						tbl.getValueByName(ETRow_NoPassengersEnabled).Boolean,
						tbl.getValueByName(ETRow_MaxPassengersAllowed).Integer,
						tbl.getValueByName(ETRow_SecurityEmailAddresses).String,
						tbl.getValueByName(ETRow_AllowEditTransport).Boolean,
						tbl.getValueByName(ETRow_TrailerTypeEnabled).Boolean); //jlier1 TFs 59547 3/8/23
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateKiosk(pxyKiosk, theForm.myCurrentObject, app.myPassport);
	else
		app.myTrxUA.trxUpdateKiosk(pxyKiosk, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK;
	
epilog
	delete selectedLocales;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTCXlat" id="467f771b-c602-46ad-8127-06acc30b2f0d">
        <updating/>
        <source>doSaveTCXlat() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
0911ugust 2023		jlizm1	Initial creation TFS 595489Kiosk maintenance terms and conditions

*/

vars
	theForm 	: SOP_TableMaintForm;
	locale 		: CM_Locale;
	pxyKiosk	: CM_Kiosk;
	pxyTC 		: CM_KioskTermsAndConditions;
	pxyXlat		: CM_KioskTranslation;
	text		: String;
	
	
begin
	theForm := self.myForm;
	locale := theForm.cmbLocale2.listObject.CM_Locale;
	
	if locale = null then
		return;
	endif;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Kiosk transient;
			pxyKiosk := theForm.myProxyObject.CM_Kiosk;
			
			create pxyTC transient;
			pxyKiosk.setProxyTermsAndConditions(pxyTC);
			
		endif;
		if theForm.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return;
		endif;
	else
		pxyKiosk := theForm.myProxyObject.CM_Kiosk;
		if pxyKiosk.myTermsAndConditions = null then
			create pxyTC transient;
			pxyKiosk.setProxyTermsAndConditions(pxyTC);
		else
			pxyTC := pxyKiosk.myTermsAndConditions;
		endif;
	endif;
	
	pxyXlat := pxyTC.allTermsAndConditions[locale.localeId];
	
	text := theForm.txtTranslation.text.trimBlanks;
	
	if pxyXlat = null then
		if text = "" then
			return;
		endif;
		
		create pxyXlat transient;
		pxyTC.addTermsAndConditions(pxyXlat);
	endif;
	
	if text = "" then
		pxyTC.removeTermsAndConditions(pxyXlat);
		delete pxyXlat;
		return;
	endif;
	
	pxyXlat.setProxy(locale.localeId, text);
	
epilog

end;</source>
    </JadeMethod>
