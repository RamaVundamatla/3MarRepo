			// this update is out of date.
			self.agentSetError("The Report Definition has been changed by another process.  Please refresh the Report and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pReportDefinitionObj.updateMe(	pReportName,
											pReportCategoryObj,
											pReportDescription,
											pFormName,
											pPrinterName,
											pCopies,
											pIsLocalAllowed,
											pPaperSize,
											pOrientation,
											pMarginTop,
											pMarginBottom,
											pMarginLeft,
											pMarginRight,
											pParameterArray);
	endif;

