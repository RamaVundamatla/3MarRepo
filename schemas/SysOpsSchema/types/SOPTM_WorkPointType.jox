    <JadeMethod name="doSave" id="ea80296c-7017-41cb-8e61-78195aa8dfee">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description				: String;
	type					: Integer;
	isNotAvailForEntry,
	isSystemType			: Boolean;
	pxyWPT,
	newWPT					: CM_WorkPointType;
	terminal				: CM_Terminal;
	allWorkPoints			: CM_WorkPointSet;
begin
	theForm 			:= self.myForm;
	tbl 				:= theForm.tblInput1;
	
	code 				:= tbl.getValueByName(ETRow_Code).String;
	description 		:= tbl.getValueByName(ETRow_Description).String;
	type 				:= app.getWorkPointTypeInt(tbl.getValueByName(ETRow_Type).String);
	isNotAvailForEntry 	:= tbl.getValueByName(ETRow_NotAvailForEntry).Boolean;
	isSystemType 		:= tbl.getValueByName(ETRow_IsSystemType).Boolean;
	terminal			:= self.myForm.myTerminal;
	
	create allWorkPoints transient;
	theForm.mulSelect1.getSelected(allWorkPoints);
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_WorkPointType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyWPT := theForm.myProxyObject.CM_WorkPointType;
	pxyWPT.setProxy(code, description, isNotAvailForEntry,type,isSystemType,allWorkPoints,terminal);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateWorkPointType(pxyWPT, newWPT, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateWorkPointType(pxyWPT, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog
	delete allWorkPoints;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
