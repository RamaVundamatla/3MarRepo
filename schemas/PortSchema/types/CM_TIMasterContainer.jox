    <JadeMethod name="getDefaultTareWeight" id="31f6cd37-7672-41d2-a4ad-f06cd8473820">
        <source>getDefaultTareWeight(): Decimal;
// ---------------------------------------------------------------------------
// Created:     18 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	range		:CM_ContRange;
	type		:CM_ISOType;
	tareWeight	:Decimal[14,4];
begin
/*	The tare weight for a container defaults to (in the following order:
		- the tare weight from the CM_ContRange
		- the tare weight from the ISO type
*/
	range := app.myRoot.lookupContainerRange(self.id);
		
	if range &lt;&gt; null then
		tareWeight	:= range.tareKilos;
	endif;
	
	if tareWeight = null then
		// keep looking - ISO type
		type	:= self.getISOTypeObject;
		
		if type &lt;&gt; null then
			tareWeight := type.tareKilos;
		endif;
	endif;
	
	return tareWeight;		
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="242599db-16ca-4d68-9266-4cb8eec04a34">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20/08/2008	cnwrd1	Initial creation
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
12/03/2013	cnwadp1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/

vars
	tmpStr : String;
	invalidOperatorNew : Boolean;
	operatorNew		: CM_Operator;
	row, type		: String;					// PAR #31155
begin

	if _attrName = ETRow_CoolingTypeTxt then
		return self.getCoolingTypeDesc();
	elseif _attrName = ETRow_IsoTypeGroup then		// PAR 21705
		return self.getISOTypeGroup();				// PAR 21705
	elseif _attrName = ETRow_MaxWeight then
		return self.maxKilos.asStringWeightJMT();			 // cnwrd1 ccms JMT 1060 Imp Measurements
	elseif _attrName = ETRow_VoltageTypeTxt then
		return self.getVoltageTypeDesc();

	elseif _attrName = ETRow_MyOperatorTxt then
		operatorNew := self.myOperatorNew;
		if operatorNew &lt;&gt; null then
			//07/02/2011 cnwdz2 26874 start
			on Exception do app.handleDeletedObject(exception, operatorNew, invalidOperatorNew);
			tmpStr :=  operatorNew.code;
			if invalidOperatorNew then
				return '';
			endif;
			return tmpStr; 			
			//return self.myOperatorNew.code;		
			//26874 end			
		else
			return '';
		endif;
		
	elseif _attrName.isMeasurementType then									// PAR #31155
		_attrName.getRowNameMeasureType(row, type);							// PAR #31155
		return self.getMeasurementStringForAttrib(row, type, _short);		// PAR #31155
		
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getISOTypeGroup" id="156f2ac6-c473-488e-a008-b6844b856eeb">
        <source>getISOTypeGroup() : String;
/* ---------------------------------------------------------------------------
Created:     24 November 2009 by cnwrs2

Purpose:     PAR 21705 - 
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpISOType	: CM_ISOType;
begin

	tmpISOType := self.getISOTypeObject();
	if tmpISOType &lt;&gt; null then
		if tmpISOType.myISOTypeGroup &lt;&gt; null then
			return tmpISOType.myISOTypeGroup.code;
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
