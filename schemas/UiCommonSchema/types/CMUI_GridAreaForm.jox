    <JadeMethod name="setDisplayMode" id="d9644142-4e60-4af9-a9e8-cf47e4381465">
        <updating/>
        <source>setDisplayMode(_mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use transient CM_DataContainer instead of arrays
//							to pass data around.
// ---------------------------------------------------------------------------

vars
	dataContainer : CM_DataContainer;
	idx : Integer;
	numberOfColumns : Integer;
	theSDFs : ObjectArray;
	theSDF : CMUI_ScrollableDrawingFrame;
	theObject : Object;
begin
	if _mode &gt; 0 then
		create theSDFs transient;
		theSDFs.add(self.sdf01);
		theSDFs.add(self.sdf02);
		theSDFs.add(self.sdf03);
		self.frmStatusLine.displayMode := _mode;
		
		foreach theObject in theSDFs do
			theSDF := theObject.CMUI_ScrollableDrawingFrame;
			
			if theSDF.displayMode &lt;&gt; _mode then
				theSDF.displayMode := _mode;
				theSDF.drawSelf();
		
			endif;
		endforeach;

		if self.tblGridAreaInfo.userObject &lt;&gt; null then
			if self.tblGridAreaInfo.userObject.isKindOf(CM_LocationsController) then
				self.tblGridAreaInfo.rows := 0;

				create dataContainer transient;
				dataContainer.displayMode := _mode;
				self.tblGridAreaInfo.userObject.CM_LocationsController.getExtraInfo(dataContainer);
									
				// sgp 18 June 2003 : use same method to display here as do when changing between rows 
				numberOfColumns := self.getNumberOfColumns;
				self.showExtraInformation(dataContainer, self.tblGridAreaInfo, false,
						self.mnuGridBigFont.checked, numberOfColumns, self.getNumberOfColsForData,
						self.getNumberOfColsForHeader, self.getNumberOfColsForIcon,
						self.getNumberOfColsForLabel);

			endif;			
		endif;

	endif;

epilog
	delete theSDFs;
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setInitialiseWithObject" id="f2aa85b3-5b43-41bc-b49e-475409b067f3">
        <updating/>
        <source>setInitialiseWithObject(anObject : CM_GridArea) updating;
// ---------------------------------------------------------------------------
