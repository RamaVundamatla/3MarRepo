    <JadeMethod name="getTaxRateForLine" id="d5b80219-f0db-4dd1-9de9-d1651546161d">
        <source>getTaxRateForLine(_debtor : CM_Debtor; _effectiveDate : TimeStamp) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2017	jlgab1	Initial creation

*/

vars

	taxCode : String;
	theBank : CM_Bank;
	service : CM_Service;
begin
	theBank := self.getBank();
	
	service := self.services.first;
