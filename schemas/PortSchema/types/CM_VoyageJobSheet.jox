    <JadeMethod name="setForCreate" id="bf8aaf84-12ee-4d67-bcdc-3ffbd961fe5e">
        <updating/>
        <source>setForCreate(	_voyage : CM_Voyage; 
				_crane : String;
				_workPoint : CM_WorkPoint) updating;
// ---------------------------------------------------------------------------
// Created:			16 May 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.crane := _crane;
	self.myWorkPoint:=_workPoint;
	self.myVoyage := _voyage;
end;</source>
