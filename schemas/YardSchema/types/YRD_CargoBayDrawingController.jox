    <JadeMethod name="doDFContextMenu" id="db569c02-aa15-4b53-b938-8cd092d08dbe">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFContextMenu(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		10 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myGridOverviewForm &lt;&gt; null then
		return self.myGridOverviewForm.doDFContextMenu(frame, conwin, mouse, x, y);
	elseif self.myYardGridAreaForm &lt;&gt; null then
		return self.myYardGridAreaForm.doDFContextMenu(frame, conwin, mouse, x, y);
	endif;
	
	return false;

end;</source>
