	thousandSeparator,
	tmpStr	: String;
begin
	thousandSeparator := app.getMyLocaleInfoJMT().numericInfo.thousandSeparator;
	
	tmpStr := self;
	tmpStr.replaceChar(thousandSeparator.Character, " ");
	tmpStr := tmpStr.cnEcRemoveSubstring(" ");

	return tmpStr.Integer64;
end;</source>
        <ReturnType type="Integer64"/>
    </JadeMethod>
