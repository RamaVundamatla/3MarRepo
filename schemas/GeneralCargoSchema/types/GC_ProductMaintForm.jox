    <JadeMethod name="hideCloneOptions" id="46b831f2-5988-4922-8c1d-546e04ecb577">
        <source>hideCloneOptions();
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.btnCloneCodes.visible := true;
	self.frmDetailsTop.enabled := false;	
	self.frmDetailsBottom.enabled := true;
	self.cmbCloneAttr.visible := true;
	self.lblCloneAttr.visible := true;
//	self.btnCancel.visible := true;
//	self.btnSave.visible := true;
	if (not self.isCloningCodes) then
		self.btnCloneProduct.enabled := true;
		self.frmDetailsTop.enabled := true;	
	endif;
	self.frmCloneProduct.visible := false;
	
		
end;</source>
    </JadeMethod>
    <JadeMethod name="hideEditCodes" id="28401ef9-81a9-41d6-a99d-2daa569b64a2">
        <source>hideEditCodes();
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	code		: CM_ProductAttributeCode;
begin

	code := self.tblCodeData.accessRow(self.tblCodeData.row).itemObject.CM_ProductAttributeCode;
	self.frmEditCode.visible := false;
	self.tblAttributes.visible := true;
	self.frmDetailsTop.enabled := true;
//	self.btnCancel.enabled := true;
//	self.btnSave.enabled := true;
	self.btnCloneProduct.enabled := true;
	//load the any new codes into the cmbCode
	self.loadCodes(self.myCurrentProdAttr);
	
	if code &lt;&gt; null and self.myCurrentProdAttr.allCodes.includes(code) then
		self.myCurrentProdAttr.setMyCode(code);
		self.cmbCode.listObject := code;
		self.tblAttributes.setCellText(self.tblAttributes.row, self.tblAttributes.getColumnByRowName(ETRow_ColumnCode), code.code);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="includeObject" id="46cb3b02-536f-444c-a0a8-6498af8f2a4c">
        <updating/>
        <source>includeObject(_pro: CM_Product; _passport: CM_Passport): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if (self.filterCode = null or self.filterCode.pos(_pro.code, 1) = 1) and
	   (self.filterDescription = null or self.filterDescription.toUpper.pos(_pro.description.toUpper, 1) = 1) and
	   (self.myFilterHandlingType = null or self.myFilterHandlingType = _pro.myHandlingType) and
	   (self.myFilterOperator = null or self.myFilterOperator = _pro.myOperator) and
	   (self.myFilterCargoType = null or self.myFilterCargoType = _pro.myCargoType) then	
	   
		return true;
	endif;

	return false;

end;</source>
        <Parameter name="_pro" type="CM_Product"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="727c4c6e-e225-4e4d-a3e3-d24529cab4b9">
        <updating/>
