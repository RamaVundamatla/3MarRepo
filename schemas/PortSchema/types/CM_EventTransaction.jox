    <JadeMethod name="getExtraInfo" id="5bde79d5-686e-4ef5-9036-6d9d40131ae5">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;

//05 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	block : CM_DataContainerBlock;

	lString : String;
begin

	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Event_type), DC_Label, 1, self);
	block.addNewItem(self.myEventType.name, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Transaction_date), DC_Label, 1, self);
	block.addNewItem(self.systemToLocalTime(self.dateTime).asStringJMT(), DC_Data, 1, self);//05 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Terminal), DC_Label, 1, self);
	block.addNewItem(self.myTerminal.code, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(User), DC_Label, 1, self);
	block.addNewItem(self.userCode, DC_Data, 1, self);
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getHours" id="13f0b35f-79bf-46fc-8f5c-b24783c1badc">
        <source>getHours() : Real;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 20 September 2022
TFS#		: 54850
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	diffTimeStamp 	: Real;
	startTimeStamp	: TimeStamp;
	endTimeStamp	: TimeStamp;
begin
	startTimeStamp 	:= self.getStartTS();
	endTimeStamp	:= self.getEndTS();
	diffTimeStamp	:= startTimeStamp.differenceInHoursReal(endTimeStamp);
	
	return diffTimeStamp.Integer;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
