    <JadeMethod name="doSetDebtorNodeController" id="701c90f7-3c1c-4ac1-90dd-001acb84a5df">
        <updating/>
        <source>doSetDebtorNodeController(_debtorNodeController: CMIF_DebtorNode input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 09/08/2018	jlgdap1	TFS 40092 PEl1 Adding Changes to Debtors
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
vars
	idx, numRows : Integer;
	theBank : CM_Bank;
	pxyDebtorNode : CM_DebtorNode;
	ls : Boolean;
	aClass : Class;
	anObj : Object;
	rdg, rootRDG : CM_RootDebtorGroup;
begin
	theBank := app.myRoot.myRootCompany;
	rdg := theBank.getRootDebtorGroup();	
	
	self.myCarriersMultiSelectBox.getSelected(_debtorNodeController.allCarriers); //+ cnwmd1, CCMS 1067, Par 19913

	foreach anObj in self.lstPropFour.allSelectedObjects do
		_debtorNodeController.allSpecialReleaseTxnTypes.add(global.getTiTxnTypeForClass(anObj.Class));
	endforeach;
	
	// cnwjk3 PAR 18434 - Date - 06/11/2008
	_debtorNodeController.isPurchaseOrderMandatory := self.tblProperties.getValueByName(ETRow_IsPurchaseOrderMandatory).Boolean;
	
	_debtorNodeController.billingAddress := self.tblProperties.getValueByName(ETRow_Address).String;
	_debtorNodeController.decfinName := self.tblProperties.getValueByName(ETRow_PostingNumber).String;
	_debtorNodeController.isSuspended := self.tblProperties.getValueByName(ETRow_IsSuspended).Boolean;
	_debtorNodeController.isZeroRated := self.tblProperties.getValueByName(ETRow_IsZeroRated).Boolean;
	_debtorNodeController.badDebtor := self.tblProperties.getValueByName(ETRow_BadCredit).Boolean;
	_debtorNodeController.myBank := theBank;
	_debtorNodeController.myTermsOfTrade := self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade;
	
	_debtorNodeController.myParentDebtorNode := null;
	if self.cmbDebtorParent.listIndex &lt; 0 then
		_debtorNodeController.myParentDebtorNode := rdg;
	else
		_debtorNodeController.myParentDebtorNode := self.cmbDebtorParent.listObject.CM_DebtorNode;
	endif;

	if self.updateMode = self.UpdateMode_New then
		if self.modePropertyNew = self.MODEPROPERTY_DEBTOR then
			create pxyDebtorNode as CM_Debtor transient;
		else
			create pxyDebtorNode as CM_DebtorGroup transient;
		endif;
	else
		app.cmsBeginLoad(ls);
		pxyDebtorNode := app.createUpdateProxy(self.myCurrentDebtorNode).CM_DebtorNode;
		app.cmsEndLoad(ls);
	endif;
	
	_debtorNodeController.myPxyDebtorNode := pxyDebtorNode; 
	pxyDebtorNode.setProxySuspend(_debtorNodeController.isSuspended);
	_debtorNodeController.name := self.tblProperties.getValueByName(ETRow_Name40).String;
	_debtorNodeController.purchaseOrderCode := self.tblProperties.getValueByName(ETRow_PurchaseOrderNumber).String;
	_debtorNodeController.remarks := self.tblProperties.getValueByName(ETRow_Remarks).String;
	
	//pxyDebtorNode.setProxy(_debtorNodeController.name);								// TFS 40092
	pxyDebtorNode.setProxy(_debtorNodeController.name, _debtorNodeController.code);		// TFS 40092

epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="3ad14596-78fa-494c-96e5-74ca9478bce9">
        <updating/>
        <source>doUpdate() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		Update the current debtor or group
//
// ---------------------------------------------------------------------------

vars
	form	: INV_DebtorMaintenanceForm;
begin
	// 28218 CCMS 2120 Oct 2011
	create form transient;
	form.centreWindow;
	form.myDebtorNode := self.myCurrentDebtorNode;
	form.updateMode := self.UpdateMode_Update;
	if self.myCurrentDebtorNode.isKindOf(CM_Debtor) then
		form.debtorType := self.MODEPROPERTY_DEBTOR;
	else
		form.debtorType := self.MODEPROPERTY_GROUP;
	endif;
	form.show;

	/*
	self.setUpdateMode(self.UpdateMode_Update);
	self.modePropertyNew := null;
	if self.myCurrentDebtorNode.isKindOf(CM_Debtor) then
		self.modePropertyUpdate := self.MODEPROPERTY_DEBTOR;
	else
		self.modePropertyUpdate := self.MODEPROPERTY_GROUP;
	
	endif;
	self.showPropertyFrame(null, null,PROPHEIGHT);
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="doUserNote" id="ace0d9a8-88be-4367-b24d-83cdd60fd4a2">
        <updating/>
        <source>doUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 08/06/2023	navdap1		TFS 58321 EUP - Duplicate debtor entry when created through REST
vars
	event : Integer;
	theDebtor : CM_DebtorNode;
	idx,idy,level, idxSt, idxEnd, newIdx : Integer;
	filterText : String;
	
begin
	inheritMethod(eventType, theObject, eventTag, userInfo);

//	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	event := eventType;
	theDebtor := userInfo.CM_DebtorNode;
	filterText := self.txtFilterBox.text;
	
	if event = EVENT_DEBTORNODE_DELETE then
		idx := self.lstData.findObject(theDebtor);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			if self.updateMode = self.UpdateMode_Delete or self.lstData.listIndex = -1 then	// if the form that caused delete, or a form had item selected and item deleted by another form	
				self.lstData.listIndex := idx - 1;		 // set index to previous item in list. 
				self.doLstDataClick(self.lstData);  // call click to highlight new item and set appropriate data
				self.updateMode := 0;				// in case of more than one form and other form conducts a delete (dont want form not doing delete to change selected index)
			endif; 
		endif;
		return;
	endif;
	
	if event = EVENT_DEBTORNODE_CREATE then
		if theDebtor.name.toUpper.pos(filterText, 1) &lt; 1 and filterText &lt;&gt; "" then //If we are filtering and the new debtor does not match
			return;
		endif;
		
		// TFS 58321 check if the debtor has already been added to the list 
		// (consignee/consignor and operator setForUpdate methods both do 
		// EVENT_DEBTORNODE_UPDATE notifications for a new debtor through the Post Customer API)
		idx := self.lstData.findObject(theDebtor);
		if idx &gt; 0 then
			// nothing to do, the debtor has already been loaded
			return;
		endif;
		// TFS 58321 end
		
		// ## insert the new debtor by finding the group then insert under that.
		idx := self.lstData.findObject(theDebtor.myParentDebtorNode);
		if idx &gt; 0 then
			level := self.lstData.itemLevel[idx] + 1;
						
			// ## insert alphabetically under parent.
			idxSt := idx + 1;
			idxEnd := self.lstData.listCount();
			
			newIdx := idxEnd + 1; 	// insert at end of list if insert position not reset by foreach  HJG

			foreach idy in idxSt to idxEnd do
				if self.lstData.itemLevel[idy] = level then
					if self.lstData.itemText[idy] &gt; theDebtor.name then
						newIdx := idy;
						break;
					endif;	
				elseif self.lstData.itemLevel[idy] &lt; level then
					newIdx := idy;
					break;
				endif;
			endforeach;		
			
//			theDebtor.loadListSubAt(self.lstData,level,newIdx);
			self.objLoadListAt(theDebtor,level,newIdx);

			self.lstData.listIndex := newIdx;
			
//			if self.updateMode = self.UpdateMode_New then  // if form that called update - change selected index   HJG
//				self.doLstDataClick(self.lstData);  // call click to highlight new item and set appropriate data 
//				self.updateMode := 0;			// in case of more than one form so a debtor will not be selected if another user updates  
//			endif;
						
		endif;
	elseif event = EVENT_DEBTORNODE_UPDATE then
		if (self.myCurrentDebtorNode = theDebtor 
			or theDebtor = app.myRoot.myRootCompany.rootDebtor) 
		and theDebtor.isKindOf(CM_Debtor) then
			
			if self.myCurrentDebtorNode = theDebtor then
				self.msgPropTwo.setSelected(theDebtor.CM_Debtor.consignors);
			endif;
			
			//epr par 15516 5/12/07
			if theDebtor = app.myRoot.myRootCompany.rootDebtor and self.myCurrentDebtorNode.isKindOf(CM_Debtor) then
				self.loadOperators(self.myCurrentDebtorNode.CM_Debtor);
				self.loadCustomsAgents(self.myCurrentDebtorNode.CM_Debtor);
				self.loadDebtorTypes(self.myCurrentDebtorNode.CM_Debtor); // CP ccms 1047 2 May 2008 cnwgb1
			else
				self.loadOperators(theDebtor.CM_Debtor);
				self.loadCustomsAgents(theDebtor.CM_Debtor);
				self.loadDebtorTypes(theDebtor.CM_Debtor); // CP ccms 1047 2 May 2008 cnwgb1
			endif;
		endif;
		self.loadDebtorRegister(self.txtFilterBox.text.toUpper());
//		idx := self.lstData.findObject(theDebtor);
//		if idx &gt; 0 then
//			self.lstData.itemText[idx] := theDebtor.getListName() ;
//		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="load" id="56365f2b-a835-4aa1-9ef0-1b3102c0b60c">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2009	cnwmd1	Initial creation

*/

vars

begin
	//+ cnwmd1, CCMS 1067, Par 19913 - Note: References are required to be set before setupForm is implemented.
	create self.myCarriersSheet transient;
	self.addControl(self.myCarriersSheet);
	self.myCarriersSheet.parent := self.fldProperties;
	self.myCarriersSheet.name := "shtCarriers";
	create self.myCarriersMultiSelectBox transient;
	self.addControl(self.myCarriersMultiSelectBox);
	self.myCarriersMultiSelectBox.parent := self.myCarriersSheet;
	self.myCarriersMultiSelectBox.name := "msgCarriers";
	self.myCarriersMultiSelectBox.paint(self.myCarriersMultiSelectBox); //To build the controls
	
	inheritMethod;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCarriers" id="9f4f876e-014d-4826-8fe1-d35ffb14e918">
        <source>loadCarriers(_theDebtor : CM_Debtor);

vars
	carriers	: ObjectSet;
	allAvailableCarriers : ObjectSet;
	o			: Object;
	aCarrier	: CM_Carrier;
begin
	create carriers transient;
	if app.myRoot.myRootCompany.rootDebtor &lt;&gt; _theDebtor then
		app.myRoot.allCarriers.copy(carriers);
	else
		_theDebtor.allCarriers.copy(carriers);
	endif;
	
	create allAvailableCarriers transient;
	foreach o in carriers do
		if o.isKindOf(CM_Carrier) then
			aCarrier := o.CM_Carrier;
			//if the carrier has not been assigned to any other Debtors or if the carrier's debtor is VoidDebtor (weird I know)
			//or the carrier's debtor is the same as the one we are editing then add to the allAvailableCarriers list
			if aCarrier.myDebtor = null or aCarrier.myDebtor.isKindOf(CM_VoidDebtor) or aCarrier.myDebtor = _theDebtor then
				allAvailableCarriers.add(aCarrier);
			endif;
		endif;
	endforeach;
	
	self.myCarriersMultiSelectBox.setAvailable(allAvailableCarriers,true);
	self.myCarriersMultiSelectBox.setSelected(_theDebtor.allCarriers);
epilog
	delete carriers;
	delete allAvailableCarriers;
end;</source>
        <Parameter name="_theDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="loadCustomsAgents" id="386c499e-4688-4600-8a33-cdb5bb7011d3">
        <source>loadCustomsAgents(_theDebtor : CM_Debtor);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// dh - changes for par 14447 - will now also call this when mode is "New", so _debtor will be null.
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3

vars
	ops : ObjectSet;
	aCA : CM_CustomsAgent;
begin
		create ops transient;
		if _theDebtor &lt;&gt; null then 		// dh 20/11/2007 par 14447
			_theDebtor.allCustomsAgents.copy(ops);
		endif;							// dh 20/11/2007 par 14447
		foreach aCA in 	app.myRoot.allCustomsAgents do
			if aCA.myDebtor = null then
				ops.add(aCA);
			endif;
		endforeach;	

epilog
	delete ops;
end;</source>
        <Parameter name="_theDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="loadDebtorRegister" id="194ca38b-54bf-4371-b7a9-8f7d34a6f595">
        <updating/>
        <source>loadDebtorRegister(_filterText : String) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Date		Who		Reason
// 19 July 2022		navpw1	Bug: 53979 EUP - Text Filter in Debtor register
// ---------------------------------------------------------------------------

vars
	currentIndex:      Integer;
	theBank : CM_Bank;
	rdg, rootRDG : CM_RootDebtorGroup;
	showRoot : Boolean;
	
begin
	theBank := app.myRoot.myRootCompany;
	rdg := theBank.getRootDebtorGroup();
	currentIndex := self.lstData.listIndex;

	self.lstData.clear;
	//self.objLoadList(rdg, 1);
	showRoot := self.objLoadList(rdg, 1, _filterText); // ### TFS 53979 26July2022 NAVPW1
	self.lstData.itemExpanded[1] := true;

	// ### TFS 53979 26July2022 NAVPW1
	if not showRoot then
		self.txtFilterBox.foreColor := Red;
		self.txtFilterBox.bubbleHelp := app.getErrorString(UiNo_Items_Found);
	else
		self.txtFilterBox.foreColor := self.getSystemColor(Color_WindowText);
		self.txtFilterBox.bubbleHelp := app.getErrorString(Ui_Search_Filter);
	endif;
	// ### TFS 53979 26July2022 NAVPW1
	
	if global.isValidObject(self.myCurrentDebtorNode) then
		currentIndex := self.lstData.findObject(self.myCurrentDebtorNode);
	endif;

	if currentIndex &lt; 1 or currentIndex &gt; self.lstData.listCount then
		currentIndex := 1;
	endif;

	self.lstData.listIndex := currentIndex;
	self.myCurrentDebtorNode := self.lstData.itemObject[currentIndex].CM_DebtorNode;
	self.myCurrentDebtorParent := self.myCurrentDebtorNode.myParentDebtorNode;
	self.lstData.itemExpanded[currentIndex] := true;
	self.objSetEnableObjects(self.myCurrentDebtorNode,self.viewOnly);

end;</source>
        <Parameter name="_filterText" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDebtorTypes" id="8b504e38-f807-4258-9dee-95710a1559e1">
        <source>loadDebtorTypes( _debtor : CM_Debtor);
// ---------------------------------------------------------------------------
// Created:	02 May 2008 By Graeme Black cnwgb1 CP CCMS 1047 Par 16666
// Load the multi-select group of the debtors
// ---------------------------------------------------------------------------
vars
	aDebtorType : CM_DebtorType;
	allUserDebtorTypes : ObjectSet;
begin
		create allUserDebtorTypes transient;
		foreach aDebtorType in app.myRoot.allDebtorTypes do
			if not aDebtorType.isSystemGenerated() then
				allUserDebtorTypes.add(aDebtorType);
			endif;
		endforeach;
		self.msgPropSix.setAvailable(allUserDebtorTypes,true);
		delete allUserDebtorTypes;
		
		if _debtor &lt;&gt; null then
			self.msgPropSix.setSelected(_debtor.allDebtorTypes);
		else
			self.msgPropSix.setSelected(null);
		endif;
epilog
	delete allUserDebtorTypes;	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="loadOperators" id="f48e8722-5b92-478c-9739-2f468beefa77">
        <source>loadOperators(_theDebtor : CM_Debtor);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ops : ObjectSet;

begin
		create ops transient;
		_theDebtor.operators.copy(ops);
		if app.myRoot.myRootCompany.rootDebtor &lt;&gt; _theDebtor then
			app.myRoot.myRootCompany.rootDebtor.operators.copy(ops);
		endif;
		self.msgPropThree.setAvailable(ops,true);
		
		self.msgPropThree.setSelected(_theDebtor.operators);
epilog
	delete ops;
end;</source>
        <Parameter name="_theDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="loadTransactionTypes" id="ef4dd307-8a69-4513-9eee-9304240179a0">
        <source>loadTransactionTypes();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	transAvail		: IntegerArray;
	idx		: Integer;	
	tmpName : String;
	aClass : Class;
	aTran : Integer;
begin
	self.lstPropFour.rows := 0;
	self.lstPropFour.allSelectedObjects.clear;
	self.lstPropFour.bubbleHelp := "These are 'special' release transactions for this debtor." &amp; Cr &amp; "If the tracked item being released is a reefer" 
						&amp; Cr &amp; "container for the selected debtor then" &amp; Cr &amp; "the ticked transaction types will be created.";
	aClass := global.getTiTxnClassForType(TRANS_TYPE_ReeferFlatRate, true);
	tmpName := aClass.getNiceName();
	idx := self.lstPropFour.addItemObject(tmpName,aClass);

	aClass := global.getTiTxnClassForType(TRANS_TYPE_ReeferDaily, true);
	tmpName := aClass.getNiceName();
	idx := self.lstPropFour.addItemObject(tmpName,aClass);

	self.lstPropFour.accessColumn(2).width := self.lstPropFour.clientWidth - self.lstPropFour.accessColumn(1).width;

	if self.myCurrentDebtorNode.isKindOf(CM_Debtor) then
		foreach aTran in self.myCurrentDebtorNode.CM_Debtor.allSpecialReleaseTxnTypes do
			aClass := global.getTiTxnClassForType(aTran, true);
			self.lstPropFour.addSelectedObject(aClass);
		endforeach;
	endif;
epilog
end;</source>
    </JadeMethod>
