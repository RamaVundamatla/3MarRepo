<GUIClass name="TestForm" id="9154d2b8-7c30-4edd-ba26-dd8d094f5446">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="btnClose" id="8b11bc8f-6185-47a6-8d9a-3e5db12b8479">
        <embedded/>
        <type name="JadeMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mskTest" id="d7e90e09-530e-4629-b875-21f5720e8e4e">
        <embedded/>
        <type name="JadeEditMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblTest" id="35d02ce4-c290-4023-86b7-f6658f9e2974">
        <embedded/>
        <type name="Table"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnClose_click" id="0aa0d688-2d41-47b6-be05-d69c2513c595">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		21 September 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="aa17689c-f163-4d42-9a2f-d26035d0a466">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		21 September 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.centreWindow();
	self.tableInitialize();
end;</source>
    </JadeMethod>
    <JadeMethod name="tableInitialize" id="21c941c3-a6c2-41d2-a390-c065d192bdee">
        <source>tableInitialize() protected;
// --------------------------------------------------------------------------------
// Created:		19 September 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	columnObj	: JadeTableColumn;
	
begin
	tableObj				:=	tblTest;
	tableObj.columns		:=	2;
	tableObj.rows			:=	10;
	tableObj.selectMode		:=	Table.SelectMode_CurrentRow;
	tableObj.tabKey			:=	J_key_Tab;
	
	columnObj				:=	tableObj.accessColumn(1);
	columnObj.inputType		:=	Table.InputType_EditMask;
	columnObj.editMask		:=	"R9999:99[0-59]";
	columnObj.alignment		:=	Table.Alignment_Center;
	
	columnObj				:=	tableObj.accessColumn(2);
	columnObj.alignment		:=	Table.Alignment_Center;
	columnObj.cellControl	:=	mskTest;
	
	mskTest.automaticCellControl	:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
