    <JadeMethod name="setReloadDate" id="3cf5b5e7-3507-4c3f-a75b-e7c5e1aa4928">
        <updating/>
        <source>setReloadDate(objectArray : ObjectArray) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 January 2019
TFS#		: 42014
Function	: Set reloadDate from the earliest loaded date 
			  based on the seleted File, otherwise use the
			  from date parameter as the reloadDate.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	ediData 	: CM_EDIData;
	object		: Object;
	searchTable	: CM_EntryTable;
begin
	searchTable	:= self.tblSearch;
	
	if searchTable.getValueByName(ETRow_FilterFromDate) &lt;&gt; null then
		self.reloadDate := self.filterFromDate;
		return;
	endif;
	foreach object in objectArray do
		ediData := object.CM_EDIData;
		
		if ediData = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
		endif;
		if ediData.processDate &lt; self.reloadDate or self.reloadDate = null  then
			self.reloadDate := ediData.processDate;
		endif;
	endforeach;
end;</source>
        <Parameter name="objectArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="cc8826d3-1cd1-47e5-89a1-18bf5a8596fa">
        <source>setStatus();

vars
	ediData : CM_EDIData;
	ediTI : CM_EDITrackedItem;
begin
	if self.myCurrentObject = null 
	or not app.isSpecial() then
		return;
	endif;
	
	ediData := self.myCurrentObject.CM_EDIData;
	beginTransaction;
	ediData.setStatus(CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	foreach ediTI in ediData.allEDITrackedItems do //cnwgb1 PAR 23419 7.7.2010
		ediTI.setStatus(CM_EDIFile.EDI_STATUS_UNPROCESSED);
	endforeach;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="d81ed991-686c-4c22-bcb2-bbc4ffa57570">
        <updating/>
        <source>setTableDataFromOrganiser(_table: CM_DataTable input) updating;
/*
Purpose:		actually do the column organiser when its for the tblEDITI	

Date				Who		Reason
08 December 2006	cnwer1	Initial creation - PAR#11700
04 March 2013		cnwcs5	par 31087 - table is passed as parameter so no need to iterate through tblEDITI clones
									  - we already know which one we want. Also use zSetXMLStrForTblColumns to save of XML
*/
vars

begin
	if _table =  self.tblData then
		inheritMethod(_table);
	
	elseif _table.name = self.tblEDITI.name then	// par 31087 March 2013
		// the column organisor form has already setup all the columns for the table
		app.mousePointer := MP_HOURGLASS;
		
		self.showEDITIs(_table);
	
		if not app.isDevelopmentSystem then
			_table.accessColumn(_table.columns).visible := false;	//hide the last column (hasChanged column)
		endif;
		
		self.zSetXMLStrForTblColumns (_table, false, self.xmlStrTblEDITI);	// par 31087 March 2013
			
		self.myDisplayedEDIData 	:= self.myCurrentObject.CM_EDIData;
		self.ediTIDataNeedsRefresh 	:= false;
	endif;	

epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblFindReplace" id="968b2a34-8c8b-4e3d-9275-30ede4dbbd88">
        <source>setTblFindReplace(_table : Table input);
//----------------------------------------------------------------
//	Created:	06 September 2003	by Jason Chapman  (cnwjc2)
// _table parameter passed in for MES1011 20320 cnwgb1 30.9.09 
//----------------------------------------------------------------
vars
	row,col		: Integer;
	comboIndex : Integer;
	text : String;
	msg : String;
begin
	if _table.rows &gt; _table.fixedRows then
		row	:=	_table.row;
		col	:=	_table.column;
		text :=  _table.accessCell(1, col).text;	//04 Jul 2016	NDL	TFS 2261
		self.tblFindReplace.setValueByName(ETRow_Column,text);
		
		//04 Jul 2016	NDL	TFS 2261- Make this sucker unselectable- you can't update it via this means, it is just a mapping method. 
		comboIndex := self.cmbColumns.findStringExact(1,text);
		if comboIndex &gt; 0 and self.cmbColumns.itemEnabled[comboIndex] = false then
			self.tblFindReplace.setValueByName(ETRow_Column,null);
			row := 0;
			_table.accessColumn(col).enabled := false;
			msg := app.getErrorString2(Not_updat_indiv_colum_editi_up, text, self.shtEDIDetails.caption);
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		endif;
		
		if row &gt; 1 then
			self.tblFindReplace.setValueByName(ETRow_Find, _table.accessCell(row, col).text);
		else
			self.tblFindReplace.setValueByName(ETRow_Find,"");
		endif;
		
		self.tblFindReplace.setValueByName(ETRow_FullWordOnly, 1);
	endif;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblFindReplaceForCol" id="de20b8bf-b7d2-4103-9925-046146e8c5da">
        <source>setTblFindReplaceForCol(_table: CM_DataTable input; _propName: String);
//----------------------------------------------------------------
//	Created:	01 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intCol		: Integer;
	prName		: String;
begin
	//table row should already be set
	//just find the column number
	if _table = self.tblFileLine then
		return;
	elseif self.isAnEDITITable( _table ) then
		intCol := _table.allTblDataColPropertyNames.indexOf(_propName);
		if intCol &gt; 0 then
			if intCol &lt;=  _table.columns then // TFS 40417
				_table.column := intCol;
				self.setTblFindReplace(_table);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTblForObject" id="3a45e39e-02bc-4daa-beb5-7ff64388e73a">
        <source>setTblForObject(_tbl : CM_EntryTable input; _entDef : EntTableDef; _ediData: CM_EDIData) protected;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
vars
	entRow			: EntTableRow;
	value			: String;
	port			: CM_Port;
	operator		: CM_Operator;
	cargoType : CM_CargoType;
begin
	if _entDef = null then
		return;
	endif;
	
	foreach entRow in _entDef.allEntTableRows do
		value := _ediData.getDisplayStringForAttribute(entRow.name, false);
		
		_tbl.setValueByName(entRow.name, value);
		
		if entRow.name = ETRow_DDate then
			_tbl.setValueByName(ETRow_DDate, value.Date);
		elseif entRow.name = ETRow_ADate then
			_tbl.setValueByName(ETRow_ADate, value.Date);
		elseif entRow.name = ETRow_DTime then
			_tbl.setValueByName(ETRow_DTime, value.Time);
		elseif entRow.name = ETRow_ATime then
			_tbl.setValueByName(ETRow_ATime, value.Time);
		elseif entRow.name = ETRow_ShipperDesc then
			_tbl.setValueByName(ETRow_ShipperDesc, value.String);
		elseif entRow.name = ETRow_ToPort then
			//port := app.myRoot.allPorts[value.String];
			port := app.myRoot.allPorts[value.String];
			if port &lt;&gt; null then
//				self.cmbToPort.text := port.code &amp; Tab &amp; port.description;
				self.cmbToPort.setObject(port);
				_tbl.setValueByName(ETRow_ToPort, self.cmbToPort.text);		// cnwdad1 31/08/2010 - PAR #25547.
			else
				self.cmbToPort.setObject(null);
				_tbl.setValueByName(ETRow_ToPort, null);					// cnwdad1 31/08/2010 - PAR #25547.
			endif;
		elseif entRow.name = ETRow_FromPort then
			//port := app.myRoot.allPorts[value.String];
			port := app.myRoot.allPorts[value.String];
			if port &lt;&gt; null then
//				self.cmbFromPort.text := port.code &amp; Tab &amp; port.description;
				self.cmbFromPort.setObject(port);
				_tbl.setValueByName(ETRow_FromPort, self.cmbFromPort.text);	// cnwdad1 31/08/2010 - PAR #25547.
			else
				self.cmbFromPort.setObject(null);
				_tbl.setValueByName(ETRow_FromPort, null);					// cnwdad1 31/08/2010 - PAR #25547.
			endif;
		elseif entRow.name = ETRow_Operator then
			operator := app.myRoot.allOperators[value.String];
			self.cmbOperator.setIndexFromObject(operator);
		elseif entRow.name = ETRow_OperatorCode then
			operator := app.myRoot.allOperators[value.String];
			self.cmbOperator.setIndexFromObject(operator);
		elseif entRow.name = ETRow_Site then
			if self.cmbSite.findString(1,value) &gt; 0 then
				self.cmbSite.text := value;
			endif;
		elseif entRow.name = ETRow_CargoTypes then
			cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(value);
			self.cmbCargoType.setIndexFromObject(cargoType);
		endif;
	endforeach;
	
	_tbl.cnEcResizeContents();
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entDef" type="EntTableDef"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="ee218d6d-5640-4700-b595-f3bc0389fb84">
        <updating/>
        <source>setupContextMenuItems(_conwin: Window input) updating;
// -------------------------------------------------------------------------
// Created:     23 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
// 18/10/2012	cnwcs5		par 30501 - 
// 07/08/2013	cnwcs5		CCMS POL 2221 / par 32094(2)
// 24 Oct 2013	cnwrs1		Par 32843 code 4
// 15 Dec 2014	cnwkpd1		PAR #34713 - Changes for .NET EDI Integration
// 05 Dec 2017	jlgrs1		TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
// 20 Mar 2018	jlgrs1		TFS 37484 - QNS Allow DB Loading of Bay Plan files
// 03 Nov 2019	jlgns1		TFS	3827 XLAT_FormCaptions need to be sorted out
// 14 Oct 2022	navsj20		ChangeRequest 55084: EUP - EDI Administration Usability Requirements
// 21 Aug 2023	navmd1		TFS 59024 Handle JSON messages
// 05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
vars
	subMenu, cloneMaster, 
	menuItem				: MenuItem;
	ediBayPlan				: CM_EDIDataBayPlan;
	voyage					: CM_Voyage;
	canMaintain, releaseRequest, 
	canReload, isEDITITable,
	isEnabled				: Boolean;
	obj, currentObject		: Object;
	tiTable 				: CM_DataTable;
	status					: Integer;
	gotException : Boolean;
	canCancel, canRevoke	: Boolean; 	//14.10.2022	navsj20	TFS 55084
begin
	inheritMethod(_conwin);

	isEDITITable	:= self.isAnEDITITable( _conwin ); 								// cnwgb1 29.9.09 MES 1011 Par 20320
	//canMaintain		:= app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	//14305 permission Maintenance	//17.10.2022	navsj20	TFS 55084
	currentObject	:= self.myCurrentObject;
	canMaintain := app.myCurrentUserCan(self.myTerminal, self.permissionMaint) 
					and (currentObject = null or currentObject.CM_EDIData.status &lt;&gt; CM_EDIFile.EDI_STATUS_CANCELLED);	//14.10.2022	navsj20	TFS 55084
	self.mnuTblVShowHideData.visible 	:= true;	
	
	self.mnuEDILineJump.visible 		:= false;
	self.mnuEdiEditAdd.visible 			:= false;
	self.mnuEdiEditDelete.visible 		:= false;
	self.mnuEdiEditFindReplace.visible 	:= false;
	self.mnuEDISortByCol.visible 		:= false;
	
	self.mnuExtractDB.visible 			:= false;
	self.mnuDBLoad.visible 				:= false;
	self.mnuQueuedForBGP.visible 		:= false;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
	self.mnuDelete.visible 				:= false;
	self.mnuEditFile.visible 			:= false;
	self.mnuEdiXML.visible				:= false;	// PAR #34713
	self.mnuEdiJSON.visible				:= false;
	self.mnuExtractFile.visible 		:= false;
	self.mnuVerify.visible 				:= false;
	self.mnuLoadNew.visible 			:= false;
	self.mnuReload.visible 				:= false;
	self.mnuMakeActual.visible 			:= false;
	self.mnuTranshipSummary.visible		:= false;
	self.mnuCreateCargo.visible			:= false;
	self.mnuLoadAs.visible 				:= false;
	self.mnuRemoveOthers.visible 		:= false;
	self.mnuRemoveOthers.enabled		:= false;
	self.mnuSep3.visible				:= false;		// cnwrl1 18/06/2010 PAR 24461
	self.mnuSep2.visible				:= false;
	self.mnuSep1.visible				:= false;
	self.mnuEdiEditViewFile.visible		:= false;
	self.mnuEdiFindTI.visible			:= false;
	self.mnuSetStatus.visible			:= false;
	self.mnuAuditData.visible 			:= true; // TFS 2734
	self.mnuAuditTI.visible 			:= false;		// par 30501
	self.mnuEDICompare.visible			:= false;		// par 32094
	self.mnuEDIIgnore.visible			:= false;		// par 32094
	self.mnuEDIProcess.visible			:= false;		// par 32094
	self.mnuCancel.visible				:= false;		//14.10.2022	navsj20	TFS 55084
	self.mnuRevoke.visible				:= false;		//14.10.2022	navsj20	TFS 55084
	//turn on/off as required
	if _conwin = self.tblData or ( _conwin = self.tblEDIDetails and self.mode = self.Mode_View ) then
		if app.isSpecial then
			//testing option
			self.mnuCreateCargo.visible				:= true;
			self.mnuCreateCargo.caption				:= "DEV ONLY :: Create Cargo";
			self.mnuSetStatus.visible 				:= true;
			self.mnuSetStatus.caption				:= "DEV ONLY :: ReSet Status";
			self.mnuTblVInspectObject.userObject	:= null;
		endif;

		self.mnuDelete.visible 				:= canMaintain;
		self.mnuVerify.visible 				:= canMaintain;
		self.mnuDBLoad.visible 				:= canMaintain;
		self.mnuQueuedForBGP.visible 		:= canMaintain;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
		self.mnuExtractDB.visible 			:= true; // TFS 2734
		self.mnuExtractFile.visible			:= true; // TFS 2734;
		self.mnuRemoveOthers.visible 		:= canMaintain;
		self.mnuLoadNew.visible 			:= canMaintain;
		self.mnuReload.visible 				:= canMaintain;
		self.mnuMakeActual.visible 			:= canMaintain;
		self.mnuLoadAs.visible				:= canMaintain;
		self.mnuLoadTOLDischList.visible	:= canMaintain;
		self.mnuLoadMSKLoadList.visible 	:= canMaintain;
		self.mnuLoadMSCLoadList.visible 	:= canMaintain;
		self.mnuLoadPONLoadList.visible 	:= canMaintain;
		self.mnuLoadTranship.visible 		:= canMaintain;
		self.mnuSep3.visible				:= canMaintain;		// cnwrl1 18/06/2010 PAR 24461
		self.mnuSep2.visible				:= canMaintain;
		self.mnuSep1.visible				:= canMaintain;
		self.mnuEdiEditFindReplace.visible	:= canMaintain;
// TFS 2734		self.mnuAuditData.visible 			:= canMaintain;
		
		self.mnuExtractDB.enabled 			:= true;
		self.mnuDelete.enabled 				:= false;
		self.enableMnuEditFile( false );	//Par150461
		self.mnuExtractFile.enabled			:= false;
		self.mnuVerify.enabled 				:= false;
		self.mnuDBLoad.enabled 				:= false;
		self.mnuQueuedForBGP.enabled 		:= false;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
		self.mnuLoadNew.enabled 			:= true;
		self.mnuReload.enabled				:= false;
		self.mnuMakeActual.enabled 			:= false;
		self.mnuLoadAs.enabled				:= false;
		
		// may as well tranlast caption instead of assuming english
		self.mnuLoadAs.translateCaption(Xlat_0007384, app.myCurrentLocale);	// par 30501 october 2012
		
		self.mnuLoadTOLDischList.enabled 	:= true;
		self.mnuAuditData.enabled 			:= false;
		self.mnuAuditTI.visible 			:= false;
		
		if self.tblData.allSelectedObjects.isEmpty() then
			//make them select something
		else
			if self.tblData.allSelectedObjects.size &gt; 1 then
				self.mnuLoadNew.enabled				:= false;
				self.mnuDelete.enabled				:= true;
				self.mnuExtractDB.enabled			:= false;
				self.mnuLoadTOLDischList.enabled	:= false;
				self.mnuDBLoad.enabled				:= true;
				self.mnuQueuedForBGP.enabled 		:= true;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
				
				canReload := true;
				canCancel := true;	//17.10.2022	navsj20	TFS 55084
				canRevoke:= true;	//17.10.2022	navsj20	TFS 55084
				on Exception do app.handleDeletedObject (exception, obj, gotException);	//24 Oct 2013	cnwrs1		Par 32843 code 4
				foreach obj in self.tblData.allSelectedObjects do
					//START 14.10.2022	navsj20	TFS 55084
					if not obj.CM_EDIData.canBeCancelled() then
						canCancel := false;
					endif;
					if not obj.CM_EDIData.canBeRevoked() then
						canRevoke := false;
					endif;
					//END 14.10.2022  navsj20  TFS 55084
					if obj.CM_EDIData.myEDIFile = null then // ediFileArray.size &lt;&gt; 1 then // ccms1117 cnwrs1 29 Apr 2010
						canReload := false;
						//break;			//14.10.2022	navsj20	TFS 55084
					endif;
				endforeach;
				on Exception do null;
				self.mnuReload.enabled 			:= canReload;	
				//START 20.10.2022	navsj20	TFS 55084
				if currentObject.CM_EDIData.canBeCancelled() then
					self.mnuCancel.visible := canCancel;
					self.mnuCancel.enabled := canCancel and app.getMyUser.canDo(self.myTerminal, PmAdmEDICancel);
				endif;
				if currentObject.CM_EDIData.canBeRevoked() then
					self.mnuRevoke.visible := canRevoke;
					self.mnuRevoke.enabled := canRevoke and app.getMyUser.canDo(self.myTerminal, PmAdmEDIRevoke);
					if canRevoke then
						self.mnuDBLoad.enabled := false;
						self.mnuQueuedForBGP.enabled := false;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
						self.mnuReload.enabled := false;
						self.mnuVerify.enabled := false;
						self.mnuMakeActual.enabled := false;
					endif;
				endif;
				self.mnuDBLoad.enabled			:= not canRevoke;		//17.10.2022	navsj20	TFS 55084	
				self.mnuQueuedForBGP.enabled := not canRevoke;			//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
				//END 20.10.2022  navsj20  TFS 55084
			elseif currentObject &lt;&gt; null and CM_EDIData.hasInstance(currentObject) then	
				self.mnuDBLoad.enabled 			:= true;
				self.mnuQueuedForBGP.enabled 	:= true;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
				self.mnuDelete.enabled 			:= true;
				self.mnuAuditData.enabled 		:= true;
				if currentObject.CM_EDIData.myEDIFile &lt;&gt; null then // ediFileArray.size = 1 then // ccms1118 cnwrs1 29 Apr 2010
					self.mnuReload.enabled		:= true;
				endif;
				//START 14.10.2022	navsj20	TFS 55084
				if currentObject.CM_EDIData.canBeCancelled() then
					self.mnuCancel.visible := true;
					self.mnuCancel.enabled := app.getMyUser.canDo(self.myTerminal, PmAdmEDICancel);
				endif;
				if currentObject.CM_EDIData.canBeRevoked() then
					self.mnuRevoke.visible := true;
					self.mnuRevoke.enabled := app.getMyUser.canDo(self.myTerminal, PmAdmEDIRevoke);
					self.mnuDBLoad.enabled := false;
					self.mnuQueuedForBGP.enabled := false;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
					self.mnuReload.enabled := false;
					self.mnuVerify.enabled := false;
					self.mnuMakeActual.enabled := false;
				endif;
				//END 14.10.2022  navsj20  TFS 55084

				// cnwrl1 04/09/2009 PAR 20320 - MES 1011 New Messina Messages
				// release request is true only if the currectly selected object is a CM_EDIDataReleaseRequest
				// this is used to turn off the extract selected option.
				releaseRequest					:= currentObject &lt;&gt; null and currentObject.isKindOf( CM_EDIDataReleaseRequest );
				self.mnuExtractFile.enabled		:= true and not releaseRequest;
				self.mnuVerify.enabled 			:= true;
				
				if currentObject.isKindOf(CM_EDIDataBayPlan) then
					ediBayPlan := currentObject.CM_EDIDataBayPlan;
					
					voyage := ediBayPlan.getVoyageFromCode(ediBayPlan.voyageCode);
					
					if voyage &lt;&gt; null and 
					/* PAR 33644
					(voyage.isNonPlannedVoyage or 
						voyage.isNonWorkedVoyage)  and voyage.isNonPlannedOrNotCellularRORO then	// PAR 21745 CCMS MES 1031 - We treat RORO/Planned voyages as Planned
						NOW */
					voyage.isHOLDSorSHIP() then	
						
						self.mnuRemoveOthers.enabled := true;
					else
						if self.myTerminal.getConfig(EDICanRemovePlanned).Boolean then
							self.mnuRemoveOthers.enabled := true;
						endif;
						
						if ediBayPlan.myBayPlanController &lt;&gt; null and
						   ediBayPlan.myBayPlanController.ediStatus = CM_EDIFile.EDI_STATUS_DBLOADED then
							self.mnuMakeActual.enabled 	:= true;
						endif;
					endif;
					
				elseif currentObject.isKindOf(CM_EDIDataGeneric)  then
					self.mnuVerify.enabled 		:= false;
					self.mnuDBLoad.enabled 		:= false;
					self.mnuQueuedForBGP.enabled := false;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
					self.mnuMakeActual.enabled 	:= false;
						
					if currentObject.isKindOf(CM_EDIDataGenCSV)  then
						self.mnuLoadAs.enabled				:= true;
						self.mnuLoadAs.caption				:= "Load CSV As";
						self.mnuLoadPONLoadList.visible 	:= canMaintain;
						self.mnuLoadTOLDischList.visible 	:= canMaintain;
						self.mnuLoadMSKLoadList.visible 	:= canMaintain;
						self.mnuLoadMSCLoadList.visible 	:= canMaintain;
						self.mnuLoadTranship.visible 		:= canMaintain;
						
					elseif currentObject.isKindOf(CM_EDIDataGenXML) then
						self.mnuLoadAs.enabled 				:= true;
						self.mnuLoadAs.caption 				:= "Load XML As";
						self.mnuLoadPONLoadList.visible 	:= false;
						self.mnuLoadTOLDischList.visible 	:= false;
						self.mnuLoadMSKLoadList.visible 	:= false;
						self.mnuLoadMSCLoadList.visible 	:= false;
						self.mnuLoadTranship.visible 		:= false;
					endif;
				
				elseif currentObject.isKindOf (CM_EDIDataReleaseRequest) or	// par 32094
				   currentObject.isKindOf (CM_EDIDataRequestMultiLine) or	// par 32094
				   (currentObject.isKindOf (CM_EDIDataGateDoc) and currentObject.CM_EDIDataGateDoc.hasReleaseReq()) then	// par 32094
					self.mnuEDICompare.enabled	:= not (currentObject.CM_EDIData.status = CM_EDIFile.EDI_STATUS_DBLOADED);
					self.mnuEDICompare.visible	:= true;
					
				elseif currentObject.isKindOf(CM_EDIDataTranship) then
					self.mnuTranshipSummary.visible := true;
				endif;
			else
				app.writeStatement( "Current Object is null!");
			endif;
		endif;
		
	elseif isEDITITable or _conwin = self.tblFileLine then
		// cnwrl1 05/11/2009 PAR 16883 - make sure a valid row is selected for the insert and delete options.
		self.mnuEdiEditAdd.visible			:= canMaintain and _conwin.CM_DataTable.row &gt; _conwin.CM_DataTable.fixedRows;
		self.mnuEdiEditDelete.visible		:= canMaintain and _conwin.CM_DataTable.row &gt; _conwin.CM_DataTable.fixedRows;
		self.mnuEdiEditFindReplace.visible	:= canMaintain;
		self.mnuSep2.visible				:= canMaintain;
		self.mnuRemoveOthers.visible		:= canMaintain;
		
		self.enableMnuEditFile( true );						//Par15046
		
		if isEDITITable then								// par 30501 oct 2012
			tiTable				:= _conwin.CM_DataTable;	// par 30301 oct 2012
			menuItem			:= self.mnuAuditTI;			// par 30501 oct 2012
			menuItem.visible 	:= true;					// par 30501 oct 2012
			menuItem.userObject	:= tiTable;					// par 30501 oct 2012
			
			if tiTable.allSelectedObjects.size = 1 then 	// par 30501 oct 2012
				menuItem.enabled := canMaintain;
			else
				menuItem.enabled := false;
			endif;
		endif;
		
		self.mnuSep1.visible 			:= isEDITITable and canMaintain;
		self.mnuEDISortByCol.visible 	:= isEDITITable;
		
		if currentObject.isKindOf(CM_EDIDataBayPlan) then
			ediBayPlan 	:= currentObject.CM_EDIDataBayPlan;
			voyage 		:= ediBayPlan.getVoyageFromCode(ediBayPlan.voyageCode);
			//only non-planned
// PAR 33644			if voyage &lt;&gt; null and voyage.isNonPlannedVoyage then
			if voyage &lt;&gt; null and voyage.isHOLDSorSHIP() then
				self.mnuRemoveOthers.enabled := (_conwin = self.tblEDITI);
			endif;
			
		elseif CM_EDIDataCustomStop.hasInstance(currentObject) then
			self.mnuEdiEditViewFile.visible	:= (_conwin = self.tblEDITI);
			self.mnuEdiFindTI.visible 		:= (_conwin = self.tblEDITI);
			
		elseif CM_EDIDataOperatorStop.hasInstance(currentObject) then //par 18587
			self.mnuEdiFindTI.visible 		:= (_conwin = self.tblEDITI); //par 18587
			
		elseif currentObject.isKindOf (CM_EDIDataReleaseRequest) then	// par 32094
			if isEDITITable then
				tiTable 	:= _conwin.CM_DataTable;
				obj			:= null;
				status		:= null;
				isEnabled	:= canMaintain;
				
				if canMaintain then
					on Exception do app.handleDeletedObject (exception, obj, gotException);	//24 Oct 2013	cnwrs1		Par 32843 code 4
					foreach obj in tiTable.allSelectedObjects do
						status := obj.CM_EDITrackedItem.status;
						
						if status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
							isEnabled := false;
							
							break;
						endif;
					endforeach;
					on Exception do null;
				endif;
				
				self.mnuEDIIgnore.visible		:= canMaintain;
				self.mnuEDIIgnore.enabled		:= isEnabled;
				self.mnuEDIIgnore.userObject	:= tiTable;
				
				isEnabled	:= canMaintain;
				
				if canMaintain then
					on Exception do app.handleDeletedObject (exception, obj, gotException);	//24 Oct 2013	cnwrs1		Par 32843 code 4
					foreach obj in tiTable.allSelectedObjects do
						status := obj.CM_EDITrackedItem.status;
						
						if status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X and status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
							isEnabled := false;
							
							break;
						endif;
					endforeach;
					on Exception do null;
				endif;
				
				self.mnuEDIProcess.visible		:= canMaintain;
				self.mnuEDIProcess.enabled		:= isEnabled;
				self.mnuEDIProcess.userObject	:= tiTable;
			endif;
		endif;
		
		if isEDITITable then // MES 1011 29.9.09 cnwgb1	Par 20320
			tiTable := _conwin.CM_DataTable; 
			
			self.mnuTblVInspectObject.userObject := tiTable.accessRow(tiTable.row).itemObject;
		else
			//This is the preexisting code line Still applies if this is the tblFileLine table
			self.mnuTblVInspectObject.userObject := self.tblEDITI.accessRow(self.tblEDITI.row).itemObject;
		endif;
		
	elseif _conwin = self.tblEDITIError or _conwin = self.tblFileError then
		self.mnuEDILineJump.visible := true;
		self.mnuSep2.visible 		:= true and canMaintain;
	endif;
	
	cloneMaster := self.mnuTblVCloneTop;	// par 30501 october 2012
	
	self.zCloneMenu(cloneMaster, self.mnuSep1, false);

	self.zCloneMenu(cloneMaster, self.mnuAuditData, false);
	self.zCloneMenu(cloneMaster, self.mnuAuditTI, false);
	self.zCloneMenu(cloneMaster, self.mnuEdiEditViewFile, false);
	self.zCloneMenu(cloneMaster, self.mnuEDIProcess, false);	
	self.zCloneMenu(cloneMaster, self.mnuEDIIgnore, false);
	self.zCloneMenu(cloneMaster, self.mnuEDISortByCol, false);
	self.zCloneMenu(cloneMaster, self.mnuEdiFindTI, false);
	self.zCloneMenu(cloneMaster, self.mnuRemoveOthers, false);
	self.zCloneMenu(cloneMaster, self.mnuEDICompare, false);	
	self.zCloneMenu(cloneMaster, self.mnuExtractFile, false);
	self.zCloneMenu(cloneMaster, self.mnuExtractDB, false);

	self.zCloneMenu(cloneMaster, self.mnuSep2, false);
	
	self.zCloneMenu(cloneMaster, self.mnuDelete, false);	// cnwrl1 17/06/2010 PAR 24461
	self.zCloneMenu(cloneMaster, self.mnuSep3, false);		// cnwrl1 17/06/2010 PAR 24461
	
	self.zCloneMenu(cloneMaster, self.mnuTranshipSummary, false);
	self.zCloneMenu(cloneMaster, self.mnuMakeActual, false);
	self.zCloneMenu(cloneMaster, self.mnuDBLoad, false);
	self.zCloneMenu(cloneMaster, self.mnuQueuedForBGP, false);		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
	self.zCloneMenu(cloneMaster, self.mnuVerify, false);
	self.zCloneMenu(cloneMaster, self.mnuCancel, false);	//17.10.2022	navsj20	TFS 55084
	self.zCloneMenu(cloneMaster, self.mnuRevoke, false);	//17.10.2022	navsj20	TFS 55084
	
	subMenu := self.zCloneMenu(cloneMaster, self.mnuLoadAs, false);
	
	self.zCloneMenu(cloneMaster, self.mnuLoadNew, false);
	self.zCloneMenu(cloneMaster, self.mnuReload, false);
	self.zCloneMenu(cloneMaster, self.mnuEdiXML, false);
	self.zCloneMenu(cloneMaster, self.mnuEdiJSON, false);
	self.zCloneMenu(cloneMaster, self.mnuEditFile, false);
	
	//special menu
	self.zCloneMenu(cloneMaster, self.mnuCreateCargo, false);
	self.zCloneMenu(cloneMaster, self.mnuSetStatus, false);
	
	//mnuLoadAs submenu
	self.zCloneMenu(subMenu, self.mnuLoadTOLDischList, true);
	self.zCloneMenu(subMenu, self.mnuLoadMSKLoadList, true);
	self.zCloneMenu(subMenu, self.mnuLoadMSCLoadList, true);
	self.zCloneMenu(subMenu, self.mnuLoadPONLoadList, true);
	self.zCloneMenu(subMenu, self.mnuLoadTranship, true);
	
	//add in ediFileFormats to choose from
	if currentObject &lt;&gt; null and CM_EDIData.hasInstance(currentObject) then
		self.buildMenuFileFormats(subMenu, currentObject.CM_EDIData);
	endif;

	//and others
	self.zCloneMenu(cloneMaster, self.mnuEdiEditFindReplace, false);
	self.zCloneMenu(cloneMaster, self.mnuEdiEditDelete, false);
	self.zCloneMenu(cloneMaster, self.mnuEdiEditAdd, false);
	
	self.zCloneMenu(cloneMaster, self.mnuEDILineJump, false);
end;</source>
        <Parameter name="_conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupFindReplace" id="d6553ac2-35ea-4733-bb40-af17cb28e58b">
        <source>setupFindReplace();
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	row,
	col,
	intRow		: Integer;
	strTag,
	colHeader	: String;
	tags		: StringArray;
	def			: EntTableDef;
	index : Integer;
	tiTable : CM_DataTable;
	
	etDef : EntTableDef;
	etRow : EntTableRow;
	comboIndex : Integer;
	
	rowHeight 					: Integer;
	rowNumber				: Integer;
	totalRowNumber 	: Integer;
begin
	if self.isDataSheetDisplayed(index) then //cnwgb1 30.9.09 MES 1011 PAR 20320 Handle cloned tables
		tiTable := self.tblEDITI.getControl(index);
		col := tiTable.column;
		row := tiTable.row;
		
		def := app.myController.getEntTableDef(ETDef_DataFindReplace);
		self.tblFindReplace.setEntTableDef(def, null, 'entTableDefSetupWarning');
		
		self.cmbColumns.clear;
		self.cmbColumns.sorted := false;
		foreach colHeader in tiTable.allTblDataColHeadings do
			self.cmbColumns.addItem(colHeader);
		endforeach;
		
		//04 Jul 2016	NDL	TFS 2261 - Make this sucker unselectable- you can't update it via this means, it is just a mapping method. 
		if tiTable.myDataClass = CM_EDILoadListTI then
			etDef := app.myController.getEntTableDef(ETDef_EDITILoadList);
			if etDef &lt;&gt; null then
				etRow := etDef.getEntTableRow(ETRow_VoyageCode);
				if etRow &lt;&gt; null then
					comboIndex := self.cmbColumns.findStringExact(1,etRow.getRawHeadingValue);
					if comboIndex &gt; 0 then
						self.cmbColumns.itemEnabled[comboIndex] := false;
					endif;
				endif;
			endif;
		endif;
		
		self.tblFindReplace.setValueByName(ETRow_Column, tiTable.accessCell(1, col).text);
		self.tblFindReplace.setValueByName(ETRow_Find, tiTable.accessCell(row, col).text);
		self.tblFindReplace.setValueByName(ETRow_FullWordOnly, 1);
		tblFindReplace.resetHeight ;																																		//+TFS3302
		self.frmFindReplace.height  :=tblFindReplace.height+frmToolbarBtns.height;										//+TFS3302
		tblMultiReplace.height :=tblFindReplace.height;																								//+TFS3302				
		
	elseif self.fldDetail.topSheet = self.shtEDIFile then
		def := app.myController.getEntTableDef(ETDef_FileFindReplace);
		self.tblFindReplace.setEntTableDef(def, null, 'entTableDefSetupWarning');
		create tags transient;
		
		foreach intRow in 1 to self.tblFileLine.rows do
			strTag := self.tblFileLine.accessCell(intRow, self.COLUMN_DATA).text[1:3]; //par17172 cnwrs1 July 2008
			if not tags.includes(strTag) then
				tags.add(strTag);
			endif;
		endforeach;
		
		self.cmbTags.clear;
		foreach strTag in tags do		
			self.cmbTags.addItem(strTag);		
		endforeach;
	endif;
   
epilog
	delete tags;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2590c06e-4e94-4ef4-96e0-7c131543838a">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		19 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 20/07/2010	cnwcs5	par 24670 - notifications not received if search has not been done
// 05 Jun 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
//18 Jan 2017	cnwrs1	TFS 3137 - resize the find/replace form when show captions is on

vars
	errMsg		: XLAT_Translation;
	
begin
	inheritMethod();

	self.useNumRowsShown := true;

	self.setCaption(app.getErrorString(EDI_Operations));
	errMsg := app.zGetUntranslatedText(XLAT_Exceptions, EDI_Operations);
	if errMsg &lt;&gt; null then
		self.helpKeyword := HelpFile_SearchString &amp; errMsg.text;
	endif;
	
	self.mnuTblVShowHideData.visible := true;
	if self.isDataTableVisible then
		self.mnuTblVShowHideData.caption := app.getErrorString(Hide_Data_Table);
	else
		self.mnuTblVShowHideData.caption := app.getErrorString(Show_Data_Table);
	endif;
	self.myAssistant.comboBoxSite(self.cmbSite, null);
	self.mnuMakeXlation.visible := false;
	self.btnDeleteTV.visible := true;
	self.btnLoadFile.visible := true;
	self.setControls();
	
	//th2 - set from user window now
	//self.sptMain.setLeftToRightRatioAndResize(50);
	self.btnHideWarnings.bubbleHelp :=self.btnHideWarnings.caption;
	self.hideVerifyErrors();
	self.sptFile.setLeftToRightRatioAndResize(35);
	
	self.frmLoadFile.top := 100;
	self.frmFindReplace.zOrder(1);
	self.doResize();
	// make multiselect
	self.tblData.selectMode := Table.SelectMode_Multiple;
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;

	self.resetNotifications;	// cnwcs5 20/07/2010 par 24670

	self.minimumHeight := 400;
	self.minimumWidth := 400;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTblDataForFileType" id="1ca6897b-0c29-4d4e-b7b9-9831569c161f">
        <updating/>
        <source>setupTblDataForFileType(_fileType: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	intCol : Integer;
begin

	
	self.setMyDataClassForFileType(_fileType);
	self.tblData.setTblDataEntRowsFromDef(self.getTblDataDef());


end;</source>
        <Parameter name="_fileType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showDataForCurrentObject" id="23bbf062-0028-4a22-b59c-65f2042c5fd6">
        <updating/>
        <source>showDataForCurrentObject(_verifying: Boolean) updating;
//----------------------------------------------------------------
//	Created:	29 August 2003	by Jason Chapman  (cnwjc2)
//	Rewritten	25 Setptember 2009 cnwgb1 for CCMS 1011 PAR 20320
//	This method loads the table or tables to show the EDITrackedItems.
//  Each table has a Dynadict of a particular subclass of EDITrackedItem 
//  These are selectively loaded from the EDIData.allTrackedItems collaction
//----------------------------------------------------------------
// 14/10/2009	cnwcs5	par 20836 - re-parent verify errors table
// 07/08/2012	cnwcs5	par 30136 - 
// 05/09/2012	cnwcs5	par 29842 - performance.  use external keys for table dynadictionary
// 04/03/2013	cnwcs5	par 31087 - dont update EDEF for table if it has not changed
// 28 may 2013	cnwcs5	Fix eception when no columns but entTableDef has not changed
// 11 Oct 2016	cnwrs1	TFS 2774/2795 PAR38277 EDI Operations Error display can be incorrect
// 02 Apr 2025	navdap1	MTN-14781 CPL | Increase BOL Field Length
vars
	ediData			: CM_EDIData;
	dict			: CM_EDITIById;		// par 29842
	tiDefNames 		: StringArray;		// EntTableDefs for the possible EDITrackedItems
	tiClasses 		: ClassColl;		// Valid EDITRackedItems for this EDIData type
	ediTIClass 		: Class;
	index 			: Integer;
	ediTi 			: CM_EDITrackedItem;
	table 			: CM_DataTable;
	entTableDef 	: EntTableDef;
	xml 			: String;
	dataTIs,
	dd				: DynaDictionary;	// par 29842 Sep 2012
	ediAgent 		: CMUI_EDIAgent;
	iter 			: Iterator;
	hideWarnings 	: Boolean;
	objArray		: CM_ObjectArray;
begin
	if self.myCurrentObject = null then
		self.tblEDITI.getControl(0).rows 	:= 1;
		self.myDisplayedEDIData 			:= null;
		
		self.hideVerifyErrors();	// par 20836
		return;
	endif;
	
	if (self.myDisplayedEDIData = self.myCurrentObject) and not self.ediTIDataNeedsRefresh then
		return;
	endif;

	if not CM_EDIData.hasInstance(self.myCurrentObject) then
		return;
	endif;
	
	self.ediTIDataNeedsRefresh := false;
	
	if not _verifying then
		self.hideVerifyErrors();	// par 20836
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doWindowEvents(0);
	
	create tiDefNames transient; // cnwgb1 22.9.09 PAR 20320
	create tiClasses transient;
	
	ediData := self.myCurrentObject.CM_EDIData;
	
	ediData.getMyTIDisplayDefNames( tiDefNames ); //cnwgb1 22.9.09 PAR 20320
	ediData.getEDITITypes( tiClasses );
	
	create dataTIs transient;
	dataTIs.setMembership(CM_EDITrackedItem);
	dataTIs.addExternalKey(String,30,false,true); //class name
	dataTIs.addExternalKey(String,35,false,false); //id			// MTN-14781
	dataTIs.endKeys(true);
	
	//07.Jun.2023 navsp1 TFS 58054 &gt;&gt;&gt;&gt;
	create objArray transient;
	ediData.getAllEDITrackedItems(objArray);
		
	foreach ediTi in objArray as CM_EDITrackedItem do
		dataTIs.putAtKey(ediTi.class.name,ediTi.id,ediTi);	
	endforeach;
	//07.Jun.2023 navsp1 TFS 58054 &lt;&lt;&lt;&lt;
		
	/*foreach ediTi in ediData.allEDITrackedItems do
		dataTIs.putAtKey(ediTi.class.name,ediTi.id,ediTi);	
	endforeach;*/
	
	iter:=dataTIs.createIterator;	
	
	// For each of the Data tabs set the correct EntTable Def and initialise the dynadicts for each table
	index := 0;
	
	foreach ediTIClass in tiClasses do	
		table 		:= self.tblEDITI.getControl(index);
		if table = null then
			continue;
		endif;	
		table.rows 	:= 1;
		
		// 16 Mar 2012	NDL	Par 29104
		entTableDef := app.myController.getEntTableDef(tiDefNames[index+1]);
		
		if table.columns = 0 or						// cnwcs5 May 2013
			entTableDef &lt;&gt; table.myEntTableDef then	// par 31087 March 2013
			// if the table is already setup using the same ETDEF then there is no need to change anything
			xml := self.getExistingXmlFor( table, entTableDef );
			
			if xml &lt;&gt; null then	//has user defined column preferences	
				table.setTblDataEntRowsFromXML(entTableDef,xml);
			else	// no changes saved
				table.setTblDataEntRowsFromDef(entTableDef);
			endif;
		endif;
		
		table.tabKey 	:= J_key_Tab;
		dd				:= table.myDynaDict;	// par 29842 Sep 2012
		
		if not dd.isEmpty then
			dd.clear;
			dd.clearKeys;
		else
			self.ediTIDynaDictFirstUse := false;
		endif;
		
		table.setMyDataClass(tiClasses[index+1]);
		dd.addMemberKey(CM_EDITrackedItem::id.name, false, true);
		dd.endKeys(true);
		
		
		dataTIs.startKeyGeq(ediTIClass.name,null,iter);
	
		while iter.next(ediTi) do
			
			if ediTi.class &lt;&gt; ediTIClass then
				break;
			endif;
			table.myDynaDict.add(ediTi);
		endwhile;
		
		
		table.tabKey := J_key_Tab;
			
		if not app.isDevelopmentSystem then
			table.accessColumn(table.columns).visible := false;	//hide the last column (hasChanged column)
		endif;
		
		//17 Feb 2016	NDL	Par 37544
		if entTableDef &lt;&gt; null and entTableDef.name = ETDef_EDITIPrenote then
			if not app.isCargoGroupEnabled then
				table.hideColumnByColPropertyName(ETRow_CargoGroupId);
			endif;
		endif;
		
		index := index+1;
	endforeach;
	
	// Copy the EDITracked Items to the dicts for the correct tabs
	dict := ediData.allEDITrackedItems;
	
	// par 29842 - smal optimisation where we have only one sheet
	table := self.tblEDITI;
	
	if tiClasses.size = 1 then
		//dict.copy (table.myDynaDict);
		
		self.showEDITIs (table);
	else
		
		// Display the contents of the dicts for each tab.
		index := 0;
		
		foreach ediTIClass in tiClasses do
			table 		:= self.tblEDITI.getControl(index);
			if table = null then
				continue;
			endif;
			self.showEDITIs(table);	// par 29842 Sep 2012
			
			index := index+1;
		endforeach;
	endif;
	
	// if we have changed displaying an EDIData then must clear out any errors from old EDIData
	if self.myDisplayedEDIData &lt;&gt; self.myCurrentObject.CM_EDIData then
		app.myPassport.clearErrorsWarnings;
	endif;
	self.myDisplayedEDIData := self.myCurrentObject.CM_EDIData;
	self.tblEDITIError.clearGraphics();
	if self.myCurrentObject.isKindOf(CM_EDIData) then	// par 27392 13 Apr 2011
	
		ediData := self.myCurrentObject.CM_EDIData;
		
		// if we have errors and they are lost display update message 
		if ediData.needToGenerateTransientErrors then
			self.showVerifyErrors_Message;
		else
			self.initTblEDITIError();	//28.May.24 navsp1 TFS 64293
			// try and display any errors that if there are any
			create ediAgent transient;
			hideWarnings := btnHideWarnings.value; // TFS 40335
			ediAgent.showVerifyErrors(ediData, self.tblEDITIError, hideWarnings, app.myPassport);
		endif;
	endif;	
epilog
	delete ediAgent;
	delete tiDefNames;
	delete tiClasses;
	delete dataTIs;
	delete iter;						//21.11.2022 navma1 #55424
	delete objArray;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_verifying" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showEDIComparisonForm" id="4e5d2956-e40b-45f0-94c0-faf22fb7c1d0">
        <source>showEDIComparisonForm(_table :CM_DataTable input)protected;
/*
Date		Who		Reason
29 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094
// 05 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
*/
vars
	row		:Integer;
	obj		:Object;
	ediTI	:CM_EDITrackedItem;
	ediData	:CM_EDIData;
	form	:CMUI_EDICompareReleaseForm;
begin
	row := _table.row;
	
	if row &lt;= _table.fixedRows then
		return;
	endif;
	
	obj := _table.accessRow(row).itemObject;
	
	if obj.isKindOf(CM_EDIDataReleaseRequest) or
	   obj.isKindOf(CM_EDIDataRequestMultiLine) or	
	   (obj.isKindOf(CM_EDIDataGateDoc) and obj.CM_EDIDataGateDoc.hasReleaseReq()) then
		ediData := obj.CM_EDIData;
		
	elseif obj.isKindOf (CM_EDITrackedItem) then
		ediTI 	:= obj.CM_EDITrackedItem;
		ediData := ediTI.myEDIData;
	
	else
		return;
	endif;
	
	if ediData = null then
		return;
	endif;
	
	form := app.loadForm (CMUI_EDICompareReleaseForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_EDICompareReleaseForm;
	
	form.myEDIData := ediData;
	
	form.show;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showEDITIs" id="8198e4f7-f7aa-4cd0-8751-36a1459739f9">
        <updating/>
        <source>showEDITIs( _table :CM_DataTable input) updating, protected;
/*
Purpose: Loads the EDITrackedItems out of the Dynadict and puts them in the table and colours them

Parameters:	_index determines which item tab we are loading 

Date		Who		Reason
Prehistory
27/9/2009   cnwgb1  CCMS MSL 1011 Added parameter for multiple cloned ediTI tables
14/3/2012	cnwgb1	PAR 29267 Colours wrong on a deck Stowage advice
05/09/2012	cnwcs5	par 29842 - performance.  removed resynchObject (has no effect). use local variables.  add row to table once we have data not before.
21/02/2013	cnwmh5	#29916 - Remove checking for duplicates.
25/07/0213	cnwcs5	CCMS POL 2221 / par 32094 - FIX UP STATII - Refectoring - coloring of skipped items
11 Nov 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
02 Mar 2018	jlgrs1	TFS 37419 - QNS Sundry
09 Dec 2022 navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
*/
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	str, 
	localPort	 : String;
	numRows,
	tmpNumItems,
	idx			 : Integer;				// par 29842 Sep 2012
	obj			 : Object;
	ls, 
	hideFrm, 
	gotException : Boolean;
	ediData 	 : CM_EDIData;			// par 27392 13 Apr 2011
    ediTI, 
	lastEdiTI	 : CM_EDITrackedItem; 	// cnwgb1 29267 14.3.2012
	columns		 : EntTableRowArray;	// par 29842 Sep 2012
	progressInt	 : TimeStampInterval;
	progressTS   : TimeStamp;
	exOccurred   : Boolean;
	terminal     : CM_Terminal;
	loadingStr	 : String;
	isDevelopment: Boolean;
begin

	on Exception do self.handle14051Error(exception, self.tblData, exOccurred);	//25 Nov 2014	NDL	Par 35248
	
	progressTS := app.actualTimeAppServer();// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support	//19.11.2025 navhl20 #36492
	hideFrm    := (not frmModalDialog.visible);
	terminal   := self.myTerminal;												//21.11.2022 navma1 #55424
	
	if terminal &lt;&gt; null then
		localPort	:= terminal.getConfig(PortDestCode).String.trimBlanks;		//21.11.2022 navma1 #55424
	endif;
	
	self.numItemsShown	:= 0;
	tmpNumItems			:= 0;
	numRows				:= _table.myDynaDict.size;
	
	_table.clearAllData();

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;
	
	self.modalDialogShow(null, app.getErrorString (Cancel), null, null,
							   app.getErrorString (Loading_data_into_table),
							   app.getErrorString2 (Loading_X_of_Y, tmpNumItems.String, numRows.String));
	
	self.modalDialogProgressBar(numRows);
	
	app.cmsBeginLoad(ls);
		
	self.progressStart(numRows, null, null, null, app.getErrorString (Loading_data_into_table));

	on Exception do app.handleDeletedObject (exception, obj, gotException);	// par 29842 Sep 2012
	
	columns 		:= _table.allTblDataEntRows;							// par 29842 Sep 2012
	loadingStr		:= app.getErrorString(Loading);							//21.11.2022 navma1 #55424
	isDevelopment	:= app.isDevelopmentSystem;								//19.11.2025 navhl20 #36492
	
	foreach obj in _table.myDynaDict do
		
        ediTI 	:= obj.CM_EDITrackedItem; 	// par 29842 optimistic //cnwgb1 29267 14.3.2012 The loop cannot get this far if obj isn't a CM_EDITrackedItem		
		str		:= ediTI.getAttributeStringForDefArray(columns);	// par 29842 Sep 2012
		
		if str = null or gotException then	// par 29842 Sep 2012
			gotException	:= false;		// par 29842 Sep 2012
			continue;
		endif;
      
		if isDevelopment then
			str := str &amp; Tab &amp; obj.getOidString;		// Add the OID
		endif;
		
		// i don't know why but it seems more efficient to add the empty row and then set the text than adding the row with text
		idx := _table.addItem ('');																// par 29842 Sep 2012
		
		_table.accessCell(idx, 1).text 		:= str;
		if exOccurred then
			break;
		endif;
		_table.accessRow(idx).itemObject	:= obj;

		if ediData = null then																		// par 29842 Sep 2012
			// everything for same edi data so just do this for first one
			ediData 	:= ediTI.myEDIData;															// par 29842 Sep 2012
			//localPort	:= ediData.ediConfig.myTerminal.getConfig(PortDestCode).String.trimBlanks;	// par 29842 Sep 2012   //21.11.2022 navma1 #55424
		endif;																						// par 29842 Sep 2012
			
		self.setColoursForEDITrackedItem (ediData, ediTI, null, _table.accessedRow);
		
		tmpNumItems	:= tmpNumItems + 1;
		
	// cnwdad1 27/05/2010 - PAR #24304.
		progressInt := app.actualTimeAppServer() - progressTS;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support		//19.11.2025 navhl20 #36492

		if progressInt.getMilliseconds &gt;= ProgressBarRefresh then
			self.modalDialogUpdateInfo(loadingStr &amp; " " &amp; tmpNumItems.String &amp; " of " &amp; numRows.String);					//21.11.2022 navma1 #55424
			self.pbProgressBar.partsDone := tmpNumItems;
			
			self.frmModalDialog.refreshNow;
			self.btnModalDefault.doWindowEvents(0);
			
			if self.modalDialogReturnValue = self.ModalDialogReturn_Default then 	// Cancel
				break;
			endif;	
			progressTS := app.actualTimeAppServer();// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support		//19.11.2025 navhl20 #36492
		endif;
		
		lastEdiTI := ediTI;
	endforeach;
	
	self.modalDialogUpdateInfo(app.getErrorString2 (Loading_X_of_Y, tmpNumItems.String, numRows.String));
	self.pbProgressBar.partsDone := tmpNumItems;
	self.frmModalDialog.refreshNow;
	self.btnModalDefault.doWindowEvents(0);
	self.numItemsShown := tmpNumItems;

	_table.resort();	
epilog
	app.cmsEndLoad(ls);
	
	if hideFrm then
		self.frmModalDialog.visible := false;
	endif;
	
	progressFinish;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showFileLoadErrors" id="bece818d-fa0d-40bd-998f-ca1ffd48b1fe">
        <source>showFileLoadErrors(_passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//6/07/2018 	JLGNS1	Bug 39173: MSL - Roro baplie not entirely loaded - HIGH PRIORITY
// 16/08/2023	navmd1	TFS 59811 Handle JSON parsing errors a bit better
vars
	idx			: Integer;
	errIdx		: Integer;	
	err			: CM_Error;
	str			: String;
	binaryLine	: Binary;
	theLines 	: HugeStringArray;
	errSet		: CM_ErrorSet;
begin
	if self.myEDIFileInError = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'file errors with no current file');
		return;
	endif;
	
	// trx call clears errors/warnings, so save them off
	create errSet transient;
	_passport.moveErrorsToSet(errSet);
	
	//show the messages
	self.initTblFileLine();

	create theLines transient;
//	self.myEDIFileInError.myEDIFileType.rawDataToHSA(self.myEDIFileInError, theLines);	//Bug 39173
	app.myTrxCA.trxRawDataToHSA(self.myEDIFileInError,_passport,theLines);				//Bug 39173
	
	foreach str in theLines do
		idx	:=	self.tblFileLine.addItem((idx + 1).String &amp; Tab &amp; str); //par 17172 cnwrs1 July 2008
		
		self.tblFileLine.accessCell(idx, self.COLUMN_SEQ).inputType := Table.InputType_None; //par17172
		self.tblFileLine.accessCell(idx, self.COLUMN_DATA).inputType := Table.InputType_TextBox; //par17172
	endforeach;
	
	self.initTblFileError();
	
	// restore previous edi errors/warnings
	_passport.addErrorsFromSet(errSet);
	errSet.clear();
	
	foreach err in _passport.allErrorWarnings do
		idx 										:= self.tblFileError.addItem(err.text);
		self.tblFileError.accessRow(idx).itemObject := err;
		errIdx 										:= err.fieldName.Integer;
		
		if errIdx &gt; 0 and errIdx &lt;=  self.tblFileLine.rows then
			self.tblFileLine.accessRow(errIdx).backColor := LightRed;
		endif;
	endforeach;
	
	self.tblFileError.cnAdjustColumnWidths();
	self.tblFileLine.accessColumn(COLUMN_SEQ).width := 50; //par17172
epilog
	delete theLines;
	if errSet &lt;&gt; null then
		errSet.purge();
		delete errSet;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideFindReplace" id="be17bb9c-cbaf-4a8e-8f11-47e206fea94d">
        <source>showHideFindReplace(_forceHide: Boolean);
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin
	if _forceHide then
		self.frmFindReplace.visible	:=	false;
	else
		self.frmFindReplace.visible	:=	(not self.frmFindReplace.visible);
	endif;
	
	if self.frmFindReplace.visible then
		self.initFrmFindReplace();
		self.setupFindReplace();
		self.btnShowFindRepl.caption		:=	"Hide Find/Replace";
		self.btnShowFindRepl.bubbleHelp		:=	"Hide Find/Replace";
		self.mnuEdiEditFindReplace.caption	:=	"Hide &amp;Find/Replace";
	else
		self.btnShowFindRepl.caption		:=	"Show Find/Replace";
		self.btnShowFindRepl.bubbleHelp		:=	"Show Find/Replace";
		self.mnuEdiEditFindReplace.caption	:=	"Show &amp;Find/Replace";
	endif;
end;</source>
        <Parameter name="_forceHide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideLoadNewFile" id="1cd62907-e018-4f8c-91a3-48e7683ff944">
        <source>showHideLoadNewFile(_show : Boolean);
/*
----------   ----------  --------------------------------------------------
Created:	01 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
16 Aug 2023  navmd1	     TFS 59811 Enable transform of .json messages
*/
vars
	existingType		: CM_EDIFileType;
begin
	if _show then
		//need to reload types as user defined type may be 
		//added or deleted 0- try to re-select existing if it exists
		existingType := self.cmbLoadAsType.listObject.CM_EDIFileType;
		self.loadEDIFileTypes(self.cmbLoadAsType, null);
		if self.cmbLoadAsType.findObject(existingType) &gt; 0 then
			self.cmbLoadAsType.listObject := existingType;
		endif;
		
		self.lblTransformAs.visible := false;
		self.cmbTransformAs.visible := false;
		
		if self.txtFileName.text.endsWith__(".json") and
			(app.isSpecial or app.isInternalEnvironment(true))
		then
			self.lblTransformAs.visible := true;
			self.cmbTransformAs.visible := true;
			self.cmbTransformAs.text := self.myEDIAgent.transformFor;
		endif;
		
	endif;
	
	self.frmLoadFile.parent := self;
	self.frmLoadFile.zOrder(1);
 	self.frmLoadFile.visible := _show;
	self.sptMain.enabled := not _show;
	
end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showThumbDetail" id="731ce835-bd08-4b8a-9e49-1ab9d188279e">
        <updating/>
        <source>showThumbDetail(obj: Object) updating;
// ---------------------------------------------------------------------------
/* Created:		19 June 2003  by Jason Chapman  (cnwjc2)

Date		Who		Reason
20 Mar 2023 navra1 	TFS 57124 - A cancelled EDI should not be editable, if the current 
								item is cancelled, disable the edit button
19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
08 Aug 2023 navra1  TFS 59666 - EUP - CallOff fields not available in the column organiser
// ---------------------------------------------------------------------------*/

vars
	entDef							: EntTableDef;
	ediTbl							: CM_EntryTable;
	ediData							: CM_EDIData;
	intRow							: Integer;
	idCode							: String;
	index 							: Integer;
	fieldsForCallOffRoad 			: StringArray;		//navra1 - TFS 59666 - 8th Aug 2023
begin
	if self.fldDetail.topSheet &lt;&gt; self.shtEDIDetails then	//PAR13395 cnwvu1
		self.btnPrintTV.enabled 	:= true;
	else
		self.btnPrintTV.enabled 	:= false;//incase enabled from previous verify
	endif;	
	

	
	ediTbl	:= self.tblEDIDetails;
	if global.isValidObject(self.myCurrentObject) and 
	   CM_EDIData.hasInstance(self.myCurrentObject) then
		ediData := self.myCurrentObject.CM_EDIData;
	else
		if CM_EDIData.hasInstance(obj) then
			ediData := obj.CM_EDIData;
		else
			return;
		endif;
		self.myCurrentObject := ediData;
	endif;

	if ediData.status = CM_EDIFile.EDI_STATUS_CANCELLED then		//navra1 - TFS 57124 - 20th Mar 2023
		self.btnEditTV.enabled := false;							//navra1 - TFS 57124 - 20th Mar 2023
	else															//navra1 - TFS 57124 - 20th Mar 2023
		self.btnEditTV.enabled := true;								//navra1 - TFS 57124 - 20th Mar 2023
	endif;															//navra1 - TFS 57124 - 20th Mar 2023

	entDef := self.getTblDetailDef;
	
	ediTbl.setEntTableDef(entDef, null, 'entTableDefSetupWarning');
	
	self.setTblForObject(ediTbl, entDef, ediData);
	
	idCode := ediTbl.getValueByNameIfVisible(ETRow_VoyageCode).String;
	if idCode = null then
		idCode := self.cmbFiltEdiType.text;
	endif;

	create fieldsForCallOffRoad transient;									//navra1 - TFS 59666 - 8th Aug 2023
	fieldsForCallOffRoad.add("Vehicle");									//navra1 - TFS 59666 - 8th Aug 2023
	fieldsForCallOffRoad.add("Vehicle Booking External Number");			//navra1 - TFS 59666 - 8th Aug 2023
	fieldsForCallOffRoad.add("Vehicle Booking Slot Type");					//navra1 - TFS 59666 - 8th Aug 2023

	foreach intRow in 1 to ediTbl.rows do
		ediTbl.accessRow(intRow).backColor := White;

		//navra1 - TFS 59666 - 8th Aug 2023 - start
		if obj.isKindOf(CM_EDIDataCallOff) and obj.CM_EDIDataCallOff.transportationMode &lt;&gt; "Road" then
			if fieldsForCallOffRoad.includes(ediTbl.accessRow(intRow).itemObject.EntTableRowTransient.getHeadingUnaltered()) then
				ediTbl.accessRow(intRow).visible := false;
			endif;
		endif;
		//navra1 - TFS 59666 - 8th Aug 2023 - end
	endforeach;
	
	if ediTbl.isRowVisible(ETRow_SendTime) then
		intRow := ediTbl.getRowByName(ETRow_SendTime);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_UpdatedTime) then
		intRow := ediTbl.getRowByName(ETRow_UpdatedTime);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_CreatedTime) then			//06.Jun.2023 navsp1 TFS 58054
		intRow := ediTbl.getRowByName(ETRow_CreatedTime);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_FileName) then				//06.Jun.2023 navsp1 TFS 58054
		intRow := ediTbl.getRowByName(ETRow_FileName);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_Items) then				//06.Jun.2023 navsp1 TFS 58054
		intRow := ediTbl.getRowByName(ETRow_Items);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_Status) then				//06.Jun.2023 navsp1 TFS 58054
		intRow := ediTbl.getRowByName(ETRow_Status);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_FileVersion) then			//06.Jun.2023 navsp1 TFS 58054
		intRow := ediTbl.getRowByName(ETRow_FileVersion);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;

	if ediTbl.isRowVisible(ETRow_NodeName) then           	//06.Jun.2023 navsp1 TFS 58054
		intRow := ediTbl.getRowByName(ETRow_NodeName);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_UserCode) then				//06.Jun.2023 navsp1 TFS 58054
		intRow := ediTbl.getRowByName(ETRow_UserCode);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_CreatedTime) then 			//06.Jun.2023 navsp1 TFS 58054	&gt;&gt;&gt;&gt;
		intRow := ediTbl.getRowByName(ETRow_CreatedTime);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_Status) then
		intRow := ediTbl.getRowByName(ETRow_Status);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;

	if ediTbl.isRowVisible(ETRow_Items) then
		intRow := ediTbl.getRowByName(ETRow_Items);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_ManifestType) then
		intRow := ediTbl.getRowByName(ETRow_ManifestType);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;
	
	if ediTbl.isRowVisible(ETRow_ManifestNumber) then
		intRow := ediTbl.getRowByName(ETRow_ManifestNumber);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;	
	
	if ediTbl.isRowVisible(ETRow_TransportStatus) then
		intRow := ediTbl.getRowByName(ETRow_TransportStatus);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;	
	
	if ediTbl.isRowVisible(ETRow_Receiver) then
		intRow := ediTbl.getRowByName(ETRow_Receiver);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;	
	
	if ediTbl.isRowVisible(ETRow_Sender) then
		intRow := ediTbl.getRowByName(ETRow_Sender);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;	
	
	if ediTbl.isRowVisible(ETRow_Guid) then
		intRow := ediTbl.getRowByName(ETRow_Guid);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;													//06.Jun.2023 navsp1 TFS 58054	&lt;&lt;&lt;&lt;
	
	if ediTbl.isRowVisible(ETRow_ContainerNumberText) then		//19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		intRow := ediTbl.getRowByName(ETRow_ContainerNumberText);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;

	if ediTbl.isRowVisible(ETRow_PortOfOrigin) then			//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
		intRow := ediTbl.getRowByName(ETRow_PortOfOrigin);
		ediTbl.accessRow(intRow).foreColor := ColorGreyDark;
		ediTbl.disableRow(intRow);
	endif;	

	self.setEDIDataCaptions( ediData.getEDIDataType() ); //cnwgb1 Par 20920 12.10.09
	
	if self.mode = self.Mode_View and self.myCurrentObject = obj and self.isDataSheetDisplayed(index) then
		//epr par 37090 2/11/15
		self.showDataForCurrentObject(false);
	endif;

epilog
	delete fieldsForCallOffRoad;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="6b927873-0a68-41f3-ae63-cea9ce0d167b">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		19 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 1410/2009	cnwcs5		par 20836	
// 07/12/2011	cnwcs5		CCMS POL 2122 / 28696 - clear errors table
vars
	index 	: Integer;
begin 
	// Mohammad 4/4/2007 par#13435
	if self.mode = self.Mode_View and self.isDataSheetDisplayed(index) then //cnwgb1 MES 1011 29.9.09 PAR 20320
	
	else 
		self.fldDetail.topSheet := self.shtEDIDetails;
		self.hideVerifyErrors;	// par 20836
	endif;
	
	self.showThumbDetail(obj);
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showVerifyErrors" id="ee0d4454-46e5-4d8a-8554-7e18cc3dd351">
        <updating/>
        <source>showVerifyErrors(_ediData: CM_EDIData input) updating;	//par 27392 13 Apr 2011
//----------------------------------------------------------------
//	Created:	03 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 13/07/2011	cnwcs5	par26557 - highlight error line for booking items
//								 - use local variables instead of repeated getPropertyValue calls
// 25/10/2012	cnwcs5	par 28376 - tidy up of show/hide warnings
// 20/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2)
vars
	table	: CM_DataTable;	
	ediUIAgent :  CMUI_EDIAgent;
begin
	table := self.tblEDITIError;		 
	
	self.initTblEDITIError();	
	
	self.sptData.showRightControl(35, true);
	self.btnPrintTV.enabled		:= true;	
		
	//epr TFS 2606 moved error loading to CMUI_EDIAgent
	create ediUIAgent transient;
	ediUIAgent.showVerifyErrors(_ediData,table,self.btnHideWarnings.value,app.myPassport);
		
	table.cnAdjustColumnWidths();				 
	
epilog
	self.fldDetail.topSheet := self.shtEDIData.getControl(0); //cnwgb1 PAR 20320 (I know it doesn't do anything different)
	self.locateFileLine(false); //epr TFS 2744
	delete ediUIAgent;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showVerifyErrors_Message" id="fb8c8f47-f3bb-4d40-8d01-f1c2674f8463">
        <updating/>
        <source>showVerifyErrors_Message()updating, protected;
/*
Date		Who		Reason
07 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	table	: CM_DataTable;	
begin
	table := self.tblEDITIError;		 
	

	self.initTblEDITIError();
	
	self.sptData.showRightControl(35, true);
	
	self.btnPrintTV.enabled		:= true;
		
	table.autoRedraw 	:= true;
	table.drawFontSize	:= 20;
	table.drawFontBold	:= true;
	table.drawTextAlign	:= Table.DrawTextAlign_Center;
	
	table.drawTextIn (app.getErrorString (EDIFORM_VERIFY_MSG), table.clientWidth * .1, table.clientHeight * .1, 
						table.clientWidth * .9, table.clientHeight * .9, Grey);
	
	table.cnAdjustColumnWidths();	
	
	table.tag							:= self.NEED_TO_VERIFY;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWithCollection" id="246c6d7f-ad55-4ed7-8f72-bd39e0c5d6bb">
        <updating/>
        <source>showWithCollection(_coll: ObjectArray; _doEdit: Boolean) updating;
/*

Date		Who		Reason
19 Oct 2015	cnwer1	Initial creation PAR 37090
12 Dec 2024 navsp1  MTN-33487 EUP - Message is not selected when accessing via EDI Message Administration
*/

vars
	obj			: Object;
	numItems : Integer;
	breakOut	: Boolean;	
	tblData		: CM_DataTable;
begin
	
	app.mousePointer := MousePointer_HourGlass;
	self.amInitialisingInEditMode	:= _doEdit;
	self.amInitialisingWithObject 	:= false;
	
	self.show();
	self.myCurrentObject 	:=_coll.first;
	

	foreach obj in _coll do
		self.addObjectToTable(obj, numItems, breakOut);
		if breakOut then
			break;
		endif;
	endforeach;	
	
	self.zHideSearcher();
	tblData := self.tblData;											//MTN-33487
	if tblData.rows &gt; 1 then
		tblData.row := 2;
		tblData.accessRow(2).selected:=true;
		tblData.allSelectedObjects.add(tblData.accessedRow.itemObject);	//MTN-33487
		self.zTblDataSelectRow(tblData.row);
		if _doEdit then
			self.btnEditTV.click(self.btnEditTV);
		endif;
	endif;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_coll" type="ObjectArray"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="346f6555-41ca-40e3-82ac-05a2bd93a84f">
        <updating/>
        <source>showWithObject(_object :CM_Object; _thumbnailOnly: Boolean; _doEdit: Boolean) updating;
/*
Date		Who		Reason
14 Feb 2013	cnwcs5	Initial creation - par 31086
*/
vars

begin
	inheritMethod(_object, _thumbnailOnly, _doEdit);
	
	if _object.isKindOf (CM_EDIData) then
		// set myDataClass
		self.myDataClass	:= _object.class;
		self.showThumbnailData(_object);		// 33375, wasn't being done from loadDataForFirstTime so do it here to get the data showing
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
