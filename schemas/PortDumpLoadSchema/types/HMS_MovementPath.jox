<Class name="HMS_MovementPath">
    <JadeMethod name="exportPDXMLMyCollections" id="87fc766a-7b0d-45b8-bdc8-95be8bbb7b43">
        <source>exportPDXMLMyCollections(_file:File; _objArray:ObjectArray io; _property:Property; _object:Object);

vars
	obj: HMS_PathSegment;
begin
	if _property.name = HMS_MovementPath::allPathSegments.name then
		_file.writeLine('&lt;'&amp;HMS_MovementPath::allPathSegments.name&amp;'&gt;');
		foreach obj in self.allPathSegments do
			_file.writeLine('&lt;class&gt;' &amp; obj.class.name &amp; '&lt;/class&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; obj.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;HMS_MovementPath::allPathSegments.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="c8fba610-fb7a-484c-b581-ca123b7a5c3b">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars

begin
	inheritMethod(_name, _collectionsBlock);
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLMyCollections" id="193dec66-4c77-4d84-9496-fcf3b0179555">
        <updating/>
        <source>importPLXMLMyCollections(_collectionsBlock: String) updating;

vars
	pathSegment: HMS_PathSegment;
	pathSegmentBlock, nameBlock, theCode: String;
	blockLength, pos: Integer;
begin
//write class.name&amp;'::'&amp;method.name&amp;' _collectionsBlock='&amp;_collectionsBlock;
	pathSegmentBlock := _collectionsBlock.cnEcGetTagValueOfName('allPathSegments');
	if pathSegmentBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;

//write class.name&amp;'::'&amp;method.name&amp;' pathSegmentBlock='&amp;pathSegmentBlock;
	pos := 1;
	blockLength := pathSegmentBlock.length;
	while pos &lt; blockLength do
		theCode := pathSegmentBlock.cnEcGetNextTagValueOfName('description', pos);
//write class.name&amp;'::'&amp;method.name&amp;' theCode='&amp;theCode;
		if pos &lt; 1 then
			break;
		endif;
		
		if theCode = null then
			continue;
		endif;
		pathSegment := app.getMyHarbour().allPathSegments[theCode];
		if pathSegment &lt;&gt; null then
			self.allPathSegments.add(pathSegment);
//write class.name&amp;'::'&amp;method.name&amp;' add='&amp;pathSegment.String;
		endif;
	endwhile;
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="4720a281-4a90-48d1-8a69-246790fd6e57">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = HMS_MovementPath::myHarbour.name then
		return app.getMyHarbour();
	elseif _name = HMS_MovementPath::myRegionFrom.name then
		return app.getMyHarbour().allRegions[_theCode];
	elseif _name = HMS_MovementPath::myRegionTo.name then
		return app.getMyHarbour().allRegions[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
