    <JadeMethod name="tblDataDisplayRow" id="dbc39869-aadf-48b1-844b-e71a455fa731">
        <updating/>
        <source>tblDataDisplayRow(table: Table input; obj: Object):String updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Oct 2023	navma1 		ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
// 18 Apr 2024  annamth     Task 63752: Jade - CM_Datable Workers
// ---------------------------------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;
	strObj		: CM_StringWithString;
begin
	
	if not obj.isKindOf(CM_Object) then
		return null;
	endif;
	
	/*
	31.10.2023 navma1 #60920
	canUserAccessSelf is already been called before at CM_EnquiryController"::includesObject()
	
	if (not obj.CM_Object.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	*/
	// 04 Apr 2024  annamth     CR 61540 - //navra1 - TFS 63751/Task 63980 - 1st May 2024
	/*
	if app.myRoot.isAsynchronousMethodEnabled() then
		if self.tblData.allTblDataObjDict &lt;&gt; null then
			strObj := self.tblData.allTblDataObjDict.getAtKey(obj.getOidString).CM_StringWithString;
		endif;
	endif;
	if strObj &lt;&gt; null then
		return strObj.strString;
	else
		return obj.CM_Object.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	endif;
	
	*/
	
	//navra1 - TFS 63751/Task 63752 - 13th May 2024
	if self.tblData.allTblDataObjDict &lt;&gt; null then
		strObj := self.tblData.allTblDataObjDict.getAtKey(obj.getOidString).CM_StringWithString;
		if strObj &lt;&gt; null then
			return strObj.strString;		
		endif;
	endif;
	
	//we we didnt return yet for some reason, try to get the str the normal way
	return obj.CM_Object.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
