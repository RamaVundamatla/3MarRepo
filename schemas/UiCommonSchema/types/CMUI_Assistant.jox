    <JadeMethod name="setLogTypeComboObjects" id="b8cfab66-e8f3-43b8-9eb6-49e1d68e83cb">
        <source>setLogTypeComboObjects(_grade : CM_LogGrade;
			_type : CM_LogType;
			_treatment : CM_LogTreatment;
			_length : CM_LogLength;
			_table : CM_EntryTable input; 
			_gradeCmb : CMUI_ComboLogGrade input; 
			_typeCmb : CMUI_ComboLogType input; 
			_treatmentCmb : CMUI_ComboLogTreatment input; 
			_lengthCmb : CMUI_ComboLogLength input			
			);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2009	cnwmh5	Initial creation #21813

*/

vars

begin

	_typeCmb.setObjectAndGrade(_type, _grade);
	_table.setValueByControlName(_typeCmb.name, _typeCmb.text);
	_treatmentCmb.setObjectAndGrade(_treatment,_grade);
	_table.setValueByControlName(_treatmentCmb.name, _treatmentCmb.text);
	_lengthCmb.setObjectAndGrade(_length,_grade);
	_table.setValueByControlName(_lengthCmb.name, _lengthCmb.text);
	
epilog

end;</source>
        <Parameter name="_grade" type="CM_LogGrade"/>
        <Parameter name="_type" type="CM_LogType"/>
        <Parameter name="_treatment" type="CM_LogTreatment"/>
        <Parameter name="_length" type="CM_LogLength"/>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_gradeCmb" type="CMUI_ComboLogGrade" usage="input"/>
        <Parameter name="_typeCmb" type="CMUI_ComboLogType" usage="input"/>
        <Parameter name="_treatmentCmb" type="CMUI_ComboLogTreatment" usage="input"/>
        <Parameter name="_lengthCmb" type="CMUI_ComboLogLength" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLogs" id="a6448518-5e1a-4270-84b8-bca3ac23b3bf">
        <source>setLogs(pAllAttachments : CMIF_InOutAttachmentArray; pTable : CM_EntryTable io; pAddAttachRow : Integer);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx,
	tmpRow			: Integer;
	intFaceAttach	: CMIF_InOutAttachment;
	
begin

	// clear any existing attachment(s)
	pTable.rows := pAddAttachRow;

	idx := 0;
	foreach intFaceAttach in pAllAttachments do
		idx := idx + 1;
		tmpRow := pTable.addAttribute('ATTACH' &amp; idx.String, 'Attachment (' &amp; idx.String &amp; ')', Table.InputType_None, 0, false);
		pTable.setValue(tmpRow, intFaceAttach.id);
	endforeach;

end;</source>
        <Parameter name="pAllAttachments" type="CMIF_InOutAttachmentArray"/>
        <Parameter name="pTable" type="CM_EntryTable" usage="io"/>
        <Parameter name="pAddAttachRow" type="Integer"/>
    </JadeMethod>
