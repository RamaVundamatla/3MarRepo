        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hasResDetAlreadyAssigned" id="5750cb53-a1ac-4485-acda-0113b33fe32c">
        <source>hasResDetAlreadyAssigned( _reserveDetail : CM_ReserveDetail ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2017	cnwndl1	Initial creation	TFS 3514

*/

vars

	iter : Iterator;
	lc : CM_LocationsController;
	wc : CM_WagonController;

begin

	iter := self.allLocationsControllers.createIterator;
	while iter.next( lc ) do
		if not lc.isWagon then
			continue;
		endif;
		wc := lc.CM_WagonController;
		if wc.hasResDetAlreadyAssigned( _reserveDetail ) then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
