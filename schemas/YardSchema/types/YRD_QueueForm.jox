    <JadeMethod name="viewITSMessage" id="59727251-c0c1-4fd0-8ed0-7ce025490e17">
        <source>viewITSMessage();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	#cnwdz2	 par21593

*/

vars
	messageForm : CMUI_ITSMessageQueueForm;
	machine	: CM_Machine;
	interfaceObj : CM_ITSInterfaceDefinition;
begin
	messageForm := app.loadForm(CMUI_ITSMessageQueueForm, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							self.myMasterMenuAction).CMUI_ITSMessageQueueForm;	
	if messageForm = null then
		return;
	endif;
	
	self.getCurrentMachine(machine);
	if machine = null then
		return;
	endif;
	
	
	interfaceObj := machine.myITSInterfaceLoggedOn;
	if	interfaceObj = null then
		return;
	endif;
	
	messageForm.myInterface := interfaceObj;
	messageForm.myMachine := machine;
	messageForm.caption := "Message Queue for Interface " &amp;  interfaceObj.name;
	messageForm.show;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="viewITSQueueEntryForMachine" id="81683ba2-ae4c-458c-8f65-3a9afd7dcec3">
        <source>viewITSQueueEntryForMachine(_machine : CM_Machine);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	#cnwdz2	 par21593

*/

vars
	messageForm : CMUI_ITSMachineQueueEntryForm;
begin
	messageForm := app.loadForm(CMUI_ITSMachineQueueEntryForm, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							self.myMasterMenuAction).CMUI_ITSMachineQueueEntryForm;	
	if messageForm = null then
		return;
	endif;
	
	messageForm.myMachine := _machine;
	messageForm.caption := "Queue Entries for Machine " &amp; _machine.id;
	messageForm.show;	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
</GUIClass>
