    <JadeMethod name="setAllControlsByName" id="c8dd5530-a2a2-49e8-8594-f04329b9b159">
        <source>setAllControlsByName();
// ---------------------------------------------------------------------------
// Created:     18 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	numControls	: Integer;
	cntrl		: Control;
begin
	self.allControlsByName.clear();

	numControls := self.controlCount;
	foreach idx in 1 to numControls do
		cntrl := self.controls(idx);
		self.allControlsByName.add(cntrl);
	endforeach;
end;</source>
