    <JadeMethod name="populateBlanks" id="4688bcd9-43a7-4890-b1f2-f22aa204325d">
        <updating/>
        <source>populateBlanks() updating;
 // ### TFS 50421 17SEP2021 NAVAB1
vars
	root : CMUI_Root;
	table : CM_DataTable;
	button : CMUI_ToolbarIcon;
	dataline : String;
	idx : Integer;
	temppic : Picture;
	icon : CMUI_IconFile;
	key : Binary;
	foundEN, foundDIS : Boolean;
begin
	app.mousePointer := Form.MousePointer_HourGlass;

	root := CMUI_Root.firstInstance;
	
	table := self.tblData;
	

	foreach idx in table.fixedRows + 1 to table.rows do
	
		button := table.accessRow(idx).itemObject.CMUI_ToolbarIcon;
		
		foundEN := false;
		foundDIS := false;
		
		foreach icon in root.allIconFilesByName do
		
			if icon.icon = button.enabledIconOld then
				table.accessCell(idx,2).text := icon.name;
				table.accessCell(idx,11).picture := icon.icon;
				table.accessedCell.alignment := Table.Alignment_Center_Top;
				table.accessRow(idx).height := 40;
				foundEN := true;
				
				beginTransaction;
					button.enabledIconNameDisk := icon.name;
					button.myEnabledIconFile := icon;
				commitTransaction;

			endif;
			if icon.icon = button.disabledIconOld then
				table.accessCell(idx,1).text := icon.name;
				table.accessCell(idx,10).picture := icon.icon;
				table.accessedCell.alignment := Table.Alignment_Center_Top;
				table.accessRow(idx).height := 40;
				foundDIS := true;
				beginTransaction;
					button.disabledIconNameDisk := icon.name;
					button.myDisabledIconFile := icon;
				commitTransaction;			endif;
			
			if foundDIS and foundEN then
				break;
			endif;
		endforeach;
		
	endforeach;
	app.mousePointer := Form.MousePointer_Default;

end;
</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="cc4ba6ce-fbe2-465c-b5e5-730dc0a7fb20">
        <updating/>
        <source>populateTable() updating;
 // ### TFS 50421 17SEP2021 NAVAB1
vars
	root : CMUI_Root;
	table : CM_DataTable;
	button : CMUI_ToolbarIcon;
	dataline : String;
	idx : Integer;
	temppic : Picture;
	icon : CMUI_IconFile;
	key : Binary;
	
	forms : StringArray;
	form : String;
begin
	app.mousePointer := Form.MousePointer_HourGlass;
	
	create forms transient;
	

	root := CMUI_Root.firstInstance;
	
	table := self.tblData;
	
	table.rows := table.fixedRows;
	
	root := CMUI_Root.firstInstance;
	
	self.btnLoadIcons.caption := "Load Disk Icons (" &amp; root.allIconFilesByName.size.String &amp; ")";
	self.btnLoadButtons.caption := "Reload Buttons (" &amp; root.allToolbarIcons.size.String &amp; ")";
	
	foreach button in root.allToolbarIcons do
	
		if button.disabledIconOld = null and button.enabledIconOld = null then
			continue;
		endif;
		
		if forms.indexOf(button.formName) = 0 then
		
			forms.add(button.formName);
		endif;
	
		dataline := 
			button.disabledIconNameDisk &amp; Tab &amp;
			button.enabledIconNameDisk &amp; Tab &amp; 

			button.iconNameUI &amp; Tab &amp; 
			button.schema  &amp; Tab &amp; 
			button.formName &amp; Tab &amp; 
			button.buttonName &amp; Tab &amp; 
			button.caption;
			
		idx := table.addItemObject(button, dataline);
		
		table.accessCell(idx,8).picture := button.disabledIconOld;
		table.accessedCell.alignment := Table.Alignment_Center_Top;
		table.accessRow(idx).height := 33;
		
		table.accessCell(idx,9).picture := button.enabledIconOld;
		table.accessedCell.alignment := Table.Alignment_Center_Top;

		// ### NEW ENABLED KEY
		table.accessCell(idx,11).picture := button.enabledIconNew;
		table.accessedCell.alignment := Table.Alignment_Center_Top;
		
		// ### NEW DISABLED KEY
		table.accessCell(idx,10).picture := button.disabledIconNew;
		table.accessedCell.alignment := Table.Alignment_Center_Top;
		
		// ### DISK ENABLED KEY
		if global.isValidObject( button.myToolbarButton) then // button.myEnabledIconFile &lt;&gt; null then
		
			table.accessCell(idx,13).picture := button.myToolbarButton.picture; //  myEnabledIconFile.icon;
		else	
			write"INVALID: " &amp;  button.iconNameUI;
		endif;
		// ### DISK DISABLED KEY
		if global.isValidObject( button.myToolbarButton) then // button.myDisabledIconFile &lt;&gt; null then
			table.accessCell(idx,12).picture := button.myToolbarButton.pictureDisabled; // myDisabledIconFile.icon;
		endif;

	endforeach;
	
/*	
	foreach form in forms do
		write form;
	endforeach;
	*/
epilog
	delete forms;
	app.mousePointer := Form.MousePointer_Default;

end;
</source>
    </JadeMethod>
    <JadeMethod name="populateTableForm" id="184136bd-fac3-4208-b2d8-6a2ce7d841ed">
        <updating/>
        <source>populateTableForm() updating;
 // ### TFS 50421 17SEP2021 NAVAB1
vars
	root : CMUI_Root;
	table : CM_DataTable;
	button : CMUI_ToolbarIcon;
	dataline : String;
	idx : Integer;
	temppic : Picture;
	icon : CMUI_IconFile;
	key : Binary;
	
	forms : StringArray;
	form : String;
begin
	app.mousePointer := Form.MousePointer_HourGlass;
	
	create forms transient;
	

	root := CMUI_Root.firstInstance;
	
	table := self.tblData;
	
	table.rows := table.fixedRows;
	
	self.btnLoadIcons.caption := "Load Disk Icons (" &amp; root.allIconFilesByName.size.String &amp; ")";
	self.btnLoadButtons.caption := "Reload Buttons (" &amp; root.allToolbarIcons.size.String &amp; ")";
	
	foreach button in root.allToolbarIconsSub do
	
		if button.disabledIconOld = null and button.enabledIconOld = null then
			continue;
		endif;
		
		if forms.indexOf(button.formName) = 0 then
		
			forms.add(button.formName);
		endif;
	
		dataline := 
			button.disabledIconNameDisk &amp; Tab &amp;
			button.enabledIconNameDisk &amp; Tab &amp; 

			button.iconNameUI &amp; Tab &amp; 
			button.schema  &amp; Tab &amp; 
			button.formName &amp; Tab &amp; 
			button.buttonName &amp; Tab &amp; 
			button.caption;
			
		idx := table.addItemObject(button, dataline);
		
		table.accessCell(idx,8).picture := button.disabledIconOld;
		table.accessedCell.alignment := Table.Alignment_Center_Top;
		table.accessRow(idx).height := 33;
		
		table.accessCell(idx,9).picture := button.enabledIconOld;
		table.accessedCell.alignment := Table.Alignment_Center_Top;

		// ### NEW ENABLED KEY
		table.accessCell(idx,11).picture := button.enabledIconNew;
		table.accessedCell.alignment := Table.Alignment_Center_Top;
		
		// ### NEW DISABLED KEY
		table.accessCell(idx,10).picture := button.disabledIconNew;
		table.accessedCell.alignment := Table.Alignment_Center_Top;
		
		// ### DISK ENABLED KEY
		if global.isValidObject( button.myToolbarButton) then // button.myEnabledIconFile &lt;&gt; null then
		
			table.accessCell(idx,13).picture := button.myToolbarButton.picture; //  myEnabledIconFile.icon;
		elseif button.disabledIconNew &lt;&gt; null then
					table.accessCell(idx,13).picture := button.disabledIconNew;
		else	
			write"INVALID: " &amp;  button.iconNameUI;
		endif;
		// ### DISK DISABLED KEY
		if global.isValidObject( button.myToolbarButton) then // button.myDisabledIconFile &lt;&gt; null then
			table.accessCell(idx,12).picture := button.myToolbarButton.pictureDisabled; // myDisabledIconFile.icon;
		endif;

	endforeach;
	
/*	
	foreach form in forms do
		write form;
	endforeach;
	*/
epilog
	delete forms;
	app.mousePointer := Form.MousePointer_Default;

end;
</source>
    </JadeMethod>
