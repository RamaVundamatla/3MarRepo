    <JadeMethod name="auditId" id="8507040c-cb67-4eba-af03-362ca4f35c6d">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2018	jlgmp6	Initial creation	TFS37718

*/

vars
	auditid, extRef : String;
begin
	auditid  := self.sequenceNum.String;
	
	extRef := self.getExternalInvoiceNumber();
	
	if extRef &lt;&gt; null and extRef &lt;&gt; self.sequenceNum.String then
		auditid := auditid &amp; " (" &amp; extRef &amp; ")";
	endif;
	
	return  auditid;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
