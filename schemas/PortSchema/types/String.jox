// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	trimmedFilename : String;
	f : FileFolder;

begin
	trimmedFilename := self.trimBlanks;
	if trimmedFilename = null then
		return false;
	endif;
	
	create f transient;
	f.allowCreate := false;
	f.fileName := trimmedFilename;
	f.usePresentationFileSystem := true;
	
	return f.isAvailable;
	
epilog
	if f &lt;&gt; null then
		delete f;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMeasurementType" id="0f407774-1924-4f46-918f-50576c53a4c8">
        <source>isMeasurementType() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	if self.length &gt; 5 and self[1:6].isOneOf(Prefix_Density, Prefix_Displacement, Prefix_Linear, Prefix_Volume, Prefix_Weight) then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRealJMT" id="134831df-7300-4314-be6e-ab0ea177e715">
        <source>isRealJMT() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/10/2017	jlgdap1		Initial creation TFS 7204 STWR Problems with reals in non-standard locales
//
constants
	JMTDecimalSeparator = ".";
	JMTThousandSeparator = ",";
vars
	decimalSeparator,
	thousandSeparator,
	tmpStr	: String;
	
begin
	decimalSeparator := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	thousandSeparator := app.getMyLocaleInfoJMT().numericInfo.thousandSeparator;
	
	tmpStr := self;
