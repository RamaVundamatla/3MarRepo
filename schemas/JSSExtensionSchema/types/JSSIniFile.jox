    <DbClassMap file="jssxs_formatted_file"/>
    <ExplicitInverseRef name="allIniSections" id="80904aa2-e8bd-4897-93d7-9216d677991e">
        <kind>parent</kind>
        <type name="JSSIniSectionDict"/>
        <access>readonly</access>
        <Inverse name="JSSIniSection::myIniFile"/>
    </ExplicitInverseRef>
    <PrimAttribute name="fileName" id="ed1c62ac-4497-4674-99e9-91b282911d12">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="createSection" id="22046d65-7c7d-4ce3-9d4b-76a1719d4096">
        <source>createSection(pSectionName:String):JSSIniSection;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniSection	: JSSIniSection;

begin
	on Exception do global.jssXHandlerDuplicate(exception);

	create iniSection transient;
	iniSection.set(pSectionName);
	iniSection.setIniFile(self);
	return iniSection;
end;</source>
        <Parameter name="pSectionName" type="String"/>
        <ReturnType type="JSSIniSection"/>
    </JadeMethod>
    <JadeMethod name="deleteIniSection" id="bab936b7-7f05-47b3-ba1e-a8f34ce62738">
        <source>deleteIniSection(pSectionName:String);
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniSection	: JSSIniSection;

begin
	iniSection	:=	self.allIniSections[pSectionName];

	if iniSection &lt;&gt; null then
		if app.setProfileString(self.fileName, pSectionName, ProfileRemoveSection, "") then
			delete iniSection;
		endif;
	endif;
end;</source>
        <Parameter name="pSectionName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyValue" id="f8291efc-4b7b-4b1f-9a43-e3c04a2fa882">
        <source>getKeyValue(pSectionName:String; pKeyName:String; pDefaultValue:String):String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return app.getProfileString(self.fileName, pSectionName, pKeyName, pDefaultValue);
end;</source>
        <Parameter name="pSectionName" type="String"/>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="27539eb0-5504-483a-8523-0777cb56ff6b">
        <updating/>
        <source>set(pFileName:String) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.fileName &lt;&gt; pFileName then
		self.fileName	:=	pFileName;
	endif;
end;</source>
        <Parameter name="pFileName" type="String"/>
    </JadeMethod>
</Class>
