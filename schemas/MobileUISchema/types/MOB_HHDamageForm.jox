    <JadeMethod name="handleBtnOne" id="22fc4f43-c7b2-4a06-9603-5959e88f2527">
        <updating/>
        <source>handleBtnOne() updating, protected;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	if self.btnOne.caption = app.getErrorString(Edit) then
		self.setForEdit();
	elseif self.btnOne.caption = app.getErrorString(Save) then
		if somethingChanged then
			if self.doSave() then
				//  37244 from to do task completion
				if self.myToDoTaskDesc &lt;&gt; null then
					self.getSessionAgent.setMyProxy(null);		// delete the proxy TI
					self.unloadForm();
				else
					somethingChanged := false;
					self.displayDamages();
				endif;
			endif;
		//  37244 from to do task completion, if no change just exit
		elseif self.myToDoTaskDesc &lt;&gt; null then
			if self.doSave() then	//18 Apr 2016	NDL	TFS 1863
				self.getSessionAgent.setMyProxy(null);		// delete the proxy TI
				self.unloadForm();
			endif;
		endif;
	endif;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
