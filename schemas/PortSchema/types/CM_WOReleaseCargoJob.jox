    <JadeMethod name="canBeIncludedOnWOO" id="403a1d56-8a6f-4886-a7da-1837860cf623">
        <source>canBeIncludedOnWOO(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2023	navma1	ChangeRequest 56738: EUP | Stop Including Work Order Jobs in Work order operation screen
27 Nov 2023 navhl20 ChangeRequest 61506: EUP | Ship Operations in DD - [54176.010] - [Release] Work Order Detail Grouping
18 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
*/

vars
	transport : Integer;
	wo		  : CM_WorkOrderTIDtl;
begin
	
	wo := self.myWODtl;
	
	if wo &lt;&gt; null then
		transport  := wo.getTransport();
	endif;
	
	if transport = TI_TRANSMODE_SHIP then
		if self.status &lt;&gt; JOB_COMPLETE then		//18.01.2024 navhl20 #62066
			return true	;
		else
			return false;
		endif;
	endif;
	
	return app.isSpecial = true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyJobs" id="0c2ec790-79dd-4cfe-a6dd-692f5f577d1a">
        <source>getAllVoyJobs(): CM_JobArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes

*/

vars

begin
	return self.allVoyageJobs;
epilog

end;</source>
        <ReturnType type="CM_JobArray"/>
    </JadeMethod>
    <JadeMethod name="getHolds" id="b3ffc3ed-1621-4f71-b313-fdd1cb0f488b">
        <source>getHolds():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
10 Feb 2025	navhl20 Bug MTN-34023: EUP | 54176 - Ship operations in Delivery Dispatch screen - remaining issues
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle				: CM_WorkListEntry;
	str,
	hold			: String;
	invalidObject,
	byType			: Boolean;
	voyage			: CM_Voyage;
	plannedHold		: String;
	job				: CM_VoyageWorkPointJob;
	wod				: CM_WodRelease;
	req				: CM_HoldRequest;
	lc				: CM_LocationsController;
	wleArr			: CM_WLEArray;
begin
	on Exception do app.handleDeletedObject(exception, wle, invalidObject);
	
	wod := self.getWorkOrderDtl().CM_WodRelease;
	if wod &lt;&gt; null and wod.myReleaseRequest &lt;&gt; null then
		byType := wod.myReleaseRequest.releaseByType;
	endif;
	
	if not byType then
		voyage := self.getMyVoyage();

		plannedHold := self.plannedLocation; 			//26/08/2024	navkc1 CR 63588 Task 63589
		
		create wleArr transient; 
		self.workListEntries.copy(wleArr);				//06.03.2025 navma1 #MTN-34179	
		
		foreach wle in wleArr discreteLock do			//06.03.2025 navma1 #MTN-34179
			invalidObject := false;
			wle.edition;
			
			if invalidObject then
				continue;
			endif;
			
			hold := wle.locationTarget;
			if hold = null then
				hold := plannedHold;
			endif;
			
			if hold &lt;&gt; null and hold.cnContains(voyage.code) then
				if str = null then
					str := str &amp; hold;
				elseif not str.cnContains(hold) then
					str := str &amp; Comma &amp; hold;
				endif;
			endif;
			
			if hold = null then								//13.02.2025 navhl20 #340234
				if wle.myTrackedItem = null then
					continue;
				endif;
				
				lc := wle.myTrackedItem.myPrimaryPlannedLocation;
				
				if lc = null then
					continue;
				endif;
				
				if lc.isGeneralCargoController or lc.isShipBlockStack then
					hold := lc.getFullId();
					if str = null then
						str := str &amp; hold;
					elseif not str.cnContains(hold) then
						str := str &amp; Comma &amp; hold;
					endif;
				endif;
			endif;
		endforeach;
	else
		if self.getAllVoyJobs().isNotEmpty then												//10.02.2025 navhl20 #34023	//06.03.2025 navma1 #MTN-34179
			foreach job in self.allVoyageJobs as CM_VoyageWorkPointJob discreteLock do		//06.03.2025 navma1 #MTN-34179
				req := job.allRequests.first.CM_HoldRequest;
				if req &lt;&gt; null and req.myHoldControllerLoad &lt;&gt; null then
					hold := req.myHoldControllerLoad.getFullId();
				endif;
				if hold &lt;&gt; null then
					if str = null then
						str := str &amp; hold;
					elseif not str.cnContains(hold) then
						str := str &amp; Comma &amp; hold;
					endif;
				endif;
			endforeach;
		else																//10.02.2025 navhl20 #34023
			
			create wleArr transient; 
			self.workListEntries.copy(wleArr);				//06.03.2025 navma1 #MTN-34179	
		
			foreach wle in wleArr discreteLock do			//06.03.2025 navma1 #MTN-34179
				invalidObject := false;
				wle.edition;
				
				if invalidObject then
					continue;
				endif;
				
				if wle.myTrackedItem = null then
					continue;
				endif;
				
				lc := wle.myTrackedItem.myPrimaryPlannedLocation;
				
				if lc = null then
					continue;
				endif;
				
				if lc.isGeneralCargoController or lc.isShipBlockStack then
					hold := lc.getFullId();
					if str = null then
						str := str &amp; hold;
					elseif not str.cnContains(hold) then
						str := str &amp; Comma &amp; hold;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	return str;
epilog
	delete wleArr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getType" id="62a92de4-4fe3-4f70-af67-07d592196a1a">
        <source>getType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023	navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS

*/

vars
	wod 	 : CM_WorkOrderTIDtl;
	transStr : String;
begin
	wod := self.myWODtl;
	
	if wod &lt;&gt; null then
		transStr := app.transportModeENumToString(wod.CM_WodRelease.transport);
		return 'Load' &amp;Space &amp; transStr;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isJobMatchingMode" id="a5668b7f-9e6d-4de4-b6f5-634752ded488">
        <source>isJobMatchingMode(_mode: Integer): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jun 2023	navhl20	ChangeRequest 58765: EUP - Delivery Dispatch – Allocation List - Rail
03 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	wod 		: CM_WorkOrderTIDtl;
	tranport	: Integer;
begin
	
	wod := self.myWODtl;					 //25.02.2025 navma1 #MTN-34075
	
	if wod &lt;&gt; null then
		
		tranport := wod.CM_WodRelease.transport;
		
		if tranport      = TI_TRANSMODE_ROAD then
			return _mode = 1;				//YRD_WorkOrderOperation.Mode_ROAD
		elseif tranport  = TI_TRANSMODE_RAIL then
			return _mode = 2;				//YRD_WorkOrderOperation.Mode_RAIL
		elseif tranport  = TI_TRANSMODE_SHIP then			//03.10.2023 navhl20 #60033
			return _mode = 3;				//YRD_WorkOrderOperation.Mode_SHIP
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRBTAllocated" id="379363c1-3be0-4118-95dd-8034040f5e61">
        <source>isRBTAllocated(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request

*/

vars
	wodDtl		: CM_WodRelease;
	myRR		: CM_BulkRelease;
begin
	if self.myWODtl &lt;&gt; null then
		wodDtl := self.myWODtl.CM_WodRelease;
		if wodDtl.getTransport() = TI_TRANSMODE_SHIP and wodDtl.myReleaseRequest &lt;&gt; null then
			myRR := wodDtl.myReleaseRequest;
			if myRR.releaseByType then
				if self.allVoyageJobs.isNotEmpty() then
					return true;
				endif;
			endif;
		endif;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRelByType" id="ca2c8e29-cab9-4894-bda3-e7214a798bd6">
        <source>isRelByType(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2024	navhl20	ChangeRequest 63857: EUP - Bulk Load ship in retrospective mode

*/

vars
	wod : CM_WodRelease;
begin
	wod := self.getWorkOrderDtl().CM_WodRelease;
	if wod &lt;&gt; null and wod.myReleaseRequest &lt;&gt; null then
		return wod.myReleaseRequest.releaseByType;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
