<Class name="WS_ReportRunResponse" id="0647fc7e-9172-41d8-8932-bb14effe651c">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="reportOutput" id="08ba0345-4265-45da-ba6b-f627e9f7543f">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="reportOutputFileURL" id="29dd3031-62b8-42fe-8883-e2d1627e72c4">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <CompAttribute name="reportOutputFileURLs" id="75ec3500-e8af-4c97-bf00-d96bf4cab0fb">
        <type name="HugeStringArray"/>
    </CompAttribute>
    <CompAttribute name="reportOutputs" id="8226e6fc-5fad-4640-9445-c1087ca962bb">
        <type name="HugeStringArray"/>
    </CompAttribute>
    <JadeMethod name="delete" id="88e76060-ac03-4335-ba08-91ef8ee05380">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars

begin
	self.reportOutputs.purge();			//08.01.2026 navma1 #MTN-36897
	reportOutputFileURLs.purge();		//08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setReportOutputFromAgent" id="93c6e452-bb00-4e2d-abae-65c60169adfd">
        <updating/>
        <source>setReportOutputFromAgent(agent : WebService_ReportAgent input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Sep 2008	cnwkao1	Initial creation - based on JMTReportOutputDtl::doUpdateValues. Might need looking at...
21 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
					Rework to use files for report content, not embedded HTML
17/08/2018	jlgdap1	TFS 40030 PEL1 Multiple Estimates and Invoices
*/

vars

begin
	self.reportOutputFileURL := agent.reportOutputFileURL;
	self.reportOutput := agent.reportOutputFileURL;
	
	self.reportOutputFileURLs.add(agent.reportOutputFileURL);		// TFS 40030
	self.reportOutputs.add(agent.reportOutputFileURL);				// TFS 40030
epilog

end;</source>
        <Parameter name="agent" type="WebService_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
