*/

vars

begin
	if self.doValidation() then 

		inheritMethod();
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidation" id="5aefb54e-fc84-4eca-a737-f8d91f77db18">
        <source>doValidation():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars
	pxyshelf, currentshelf : CM_RackShelfController;
	rack : CM_IrregularBlockController;
	type : Integer;
	num : Integer;
	msg : String;

begin

	type := self.cmbType.listData;
	if type &lt;&gt; GC_ShelfLocation and type &lt;&gt; GC_GroundLocation and type &lt;&gt; GC_RackLocation then
		msg := app.getErrorString(Invalid_location_type);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbType.setFocus();
		return false;
	endif;

	if self.txtName.text = null then
		msg := app.getErrorString(Must_enter_name);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtName.setFocus();
		return false;
	endif;
	
	if type = GC_RackLocation then
		num := self.txtNumShelves.text.Integer;
		if num &lt; 1 then
			msg := app.getErrorString2(Must_have_at_least, app.getErrorString(GC_RackLocation), app.getErrorString(GC_ShelfLocation) );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			self.txtNumShelves.setFocus();
			return false;
		endif;
	endif;
		
	if self.myBlockController &lt;&gt; null and self.myBlockController.isShelf() then
		currentshelf := self.myBlockController.CM_RackShelfController;
		rack := currentshelf.myLocation;
		
		foreach pxyshelf in rack.allSubLocations discreteLock do
			if pxyshelf = currentshelf then
			continue;
			endif;
			
			if pxyshelf.ident = txtName.text then
		msg := app.getErrorString1(Duplicate_code_must_unique,txtName.text);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtName.setFocus();
				return false;
			endif;
		endforeach;
		
	endif;
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCmbICAreas" id="453b40c6-627d-4ec0-bb40-9f01b3d2a4eb">
        <source>populateCmbICAreas();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	icAreaType : CM_TerminalAreaType;
	taSet : CM_TerminalAreaSet;
	ta : CM_TerminalArea;
	iter : Iterator;
	index : Integer;

begin

	self.cmbICArea.clear;
	self.cmbICArea.sorted := true;
	self.cmbICArea.addItem("");
	
	icAreaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_YARD_INTERCHANGE];
	
	create taSet transient;
	iter := self.myTerminal.allTerminalAreas.createIterator;
	while iter.next( ta ) do
		if ta.myType &lt;&gt; icAreaType then
			continue;
		endif;
		taSet.add( ta );
	endwhile;
	
	foreach ta in taSet discreteLock do	
		index := self.cmbICArea.addItem(ta.id);
		self.cmbICArea.itemObject[index] := ta;
	endforeach;

epilog

	delete taSet;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbType" id="624cd4b9-b6d4-455c-8e51-433fe4e51bb4">
        <source>populateCmbType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	index : Integer;

begin

	self.cmbType.clear;
	
	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(SOP_GCSubLocationListForm) then
		index := self.cmbType.addItem( app.getErrorString(GC_ShelfLocation) );
		self.cmbType.itemData[index] := GC_ShelfLocation;
		
		self.cmbType.listIndex := self.cmbType.findStringExact( 1, app.getErrorString(GC_ShelfLocation) );
	else
		index := self.cmbType.addItem( app.getErrorString(GC_GroundLocation) );
		self.cmbType.itemData[index] := GC_GroundLocation;
		index := self.cmbType.addItem( app.getErrorString(GC_RackLocation) );
		self.cmbType.itemData[index] := GC_RackLocation;
		
		self.cmbType.listIndex := self.cmbType.findStringExact( 1, app.getErrorString(GC_GroundLocation) );
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateData" id="0908e251-3044-4804-90f2-fd9b857911a0">
        <source>populateData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	weight : CM_MeasurementType;
	weightType : String;

begin

	weight := app.getDefaultMeasurementForType(Type_Weight);

	if self.myBlockController = null then
		self.cmbType.setFocus();
		self.txtName.text := null;
		self.txtDefCapacity.text := null;
		self.txtYACapacity.text := null;	//22 Jul 2020	NDL	TFS 49775
		self.txtNumShelves.text := null;
		self.clrColour.setColor( self.getSystemColor(Window.Color_3DFace) );
		self.cmbICArea.listIndex := -1;
	else
		self.txtName.text := self.myBlockController.ident;
		self.cmbType.enabled := false;
		self.cmbType.listIndex := self.cmbType.findStringExact( 1, self.myBlockController.getLocationTypeString );
		self.txtDefCapacity.text := self.myBlockController.defaultCapacity.asStringJMT;
		self.txtYACapacity.text := self.myBlockController.getYACapacity.asStringJMT;	//22 Jul 2020	NDL	TFS 49775
		self.txtNumShelves.text := self.myBlockController.allSubLocations.size.asStringJMT;
		self.clrColour.setColor( self.myBlockController.getColour );
		self.cmbICArea.listIndex := self.cmbICArea.findObject( self.myBlockController.getInterChangeArea );
		if weight &lt;&gt; null then																					
			weightType := weight.shortName;																		
			self.txtMaxWeight.setValues(app.convertMeasurementForDisplay(weightType, self.myBlockController.maximumWeight) &amp; Space &amp; weightType);	
		endif;
	endif;
	
	self.showHideControls();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setLocationProxy" id="ac247319-157c-4a43-afb3-d693627a9d1d">
        <updating/>
        <source>setLocationProxy( _blockCont : CM_IrregularBlockController; _term : CM_Terminal; _callingForm : CM_BaseForm ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2013	cnwndl1	Initial creation	Par 32308
*/

vars

begin

	self.myBlockController := _blockCont;
	if _term &lt;&gt; null then
		self.setMyTerminal( _term );
	else
		if _blockCont &lt;&gt; null then
			self.setMyTerminal( _blockCont.myTerminal );
		endif;
	endif;
	
	if self.myTerminal = null then
		self.setMyTerminal( app.getMyTerminalDO_NOT_USE );
	endif;
	
	self.setParentForm(_callingForm);

epilog

end;</source>
        <Parameter name="_blockCont" type="CM_IrregularBlockController"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_callingForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f75e2c32-a9e6-40bc-8b46-63611a235287">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

begin

	inheritMethod();
	
	self.btnCancel.caption := app.getErrorString(Close);
	
	self.populateCmbType();
	self.populateCmbICAreas();
	
	self.txtMaxWeight.setup(Type_Weight, self.backColor);
	self.txtMaxWeight.tabKey := J_key_Tab;
	
	self.populateData();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideControls" id="715c5272-32ab-4715-ae2e-95e273d1ec0f">
        <source>showHideControls() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	mode : String;

begin

	mode := self.cmbType.text;
	self.lblName.visible := true;
	self.txtName.visible := true;
	self.lblColour.visible := true;
	self.clrColour.visible := true;
	self.lblICArea.visible := true;
	self.cmbICArea.visible := true;
	self.lblDefCapacity.visible := true;
	self.txtDefCapacity.visible := true;
	self.lblMaxWeight.visible := true;
	self.txtMaxWeight.visible := true;
	
	self.lblNumShelves.visible := false;
	self.txtNumShelves.visible := false;
	self.btnShelves.visible := false;
	
	
	if mode = app.getErrorString(GC_ShelfLocation) then
		// nothing extra
	elseif mode = app.getErrorString(GC_GroundLocation) then
		// nothing extra
	elseif mode = app.getErrorString(GC_RackLocation) then
		self.lblNumShelves.visible := true;
		self.txtNumShelves.visible := true;
		self.lblNumShelves.enabled := ( self.myBlockController = null );
		self.txtNumShelves.enabled := ( self.myBlockController = null );
		self.lblDefCapacity.visible := false;
		self.txtDefCapacity.visible := false;
		self.lblMaxWeight.visible := false;
		self.txtMaxWeight.visible := false;
		self.btnShelves.visible := ( self.myBlockController &lt;&gt; null );
	else
		self.lblName.visible := false;
		self.txtName.visible := false;
		self.lblColour.visible := false;
		self.clrColour.visible := false;
		self.lblICArea.visible := false;
		self.cmbICArea.visible := false;
		self.lblDefCapacity.visible := false;
		self.txtDefCapacity.visible := false;
		self.lblMaxWeight.visible := false;
		self.txtMaxWeight.visible := false;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d91c9bf4-3340-497b-9562-a0a456c98d4c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 July 2020 16:05:50.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006972, locale);
	btnShelves.translateCaption(Xlat_0019289, locale);
	clrColour.translateBubbleHelp(Xlat_0019290, locale);
	lblColour.translateCaption(Xlat_0019291, locale);
	lblDefCapacity.translateCaption(Xlat_0019292, locale);
	lblICArea.translateCaption(Xlat_0019293, locale);
	lblMaxWeight.translateCaption(Xlat_0019294, locale);
	lblName.translateCaption(Xlat_0006973, locale);
	lblNumShelves.translateCaption(Xlat_0019295, locale);
	lblType.translateCaption(Xlat_0019296, locale);
	lblYACapacity.translateCaption(Xlat_0023975, locale);
end;</source>
    </JadeMethod>
</GUIClass>
