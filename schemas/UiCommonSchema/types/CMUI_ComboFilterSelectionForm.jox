    </JadeMethod>
    <JadeMethod name="rePopulate" id="1b28a0f3-9e4f-4728-b8eb-256b15e07b07">
        <source>rePopulate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwndl1	Initial creation

*/

vars

	size : Integer;
	index : Integer;
	itemObject : Object;
	itemText : String;

begin

	self.cmbSelect.clear();
	
	size := self.myRelatedCombo.listCount;
	foreach index in 1 to size do
		itemObject := self.myRelatedCombo.itemObject[index];
		itemText := self.myRelatedCombo.itemText[index];
		self.cmbSelect.itemObject[ self.cmbSelect.addItem(itemText) ] := itemObject;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyRelatedCombo" id="4be7d43e-5539-43ea-b31d-ef2f57e84e2a">
        <updating/>
        <source>setMyRelatedCombo( _form : CM_BaseForm; _combo : CMUI_ComboBox; _comboLabel : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwndl1	Initial creation

*/

vars

begin

	self.myRelatedForm := _form;
	self.myRelatedCombo := _combo;
	self.comboLabel := _comboLabel[1:30];

epilog

end;</source>
        <Parameter name="_form" type="CM_BaseForm"/>
        <Parameter name="_combo" type="CMUI_ComboBox"/>
        <Parameter name="_comboLabel" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fc1e7723-34a1-418f-8a58-7b54a3bb53d9">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwndl1	Initial creation	Par 36789

*/

vars

	msg : String;

begin

	if self.comboLabel &lt;&gt; null then
		self.caption := self.comboLabel;
	endif;

	self.handleMenusForModalDisplay();

	self.grpMain.borderStyle := 0;
	self.grpMain.top := 1;
	self.grpMain.left := 1;
	self.width := 410;
	self.height := 262;

	if self.myRelatedCombo = null then
		msg := "Must call 'setMyRelatedCombo' populated with a valid combo before doing a 'show' (" &amp; method.qualifiedName &amp; ")" ;
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		self.doCancel();
		return;
	endif;
	
	self.rePopulate();
	
	if self.myRelatedCombo.listObject &lt;&gt; null then
		self.cmbSelect.listIndex := self.cmbSelect.findObject( self.myRelatedCombo.listObject );
	elseif self.myRelatedCombo.listIndex &gt; 0 then
		self.cmbSelect.listIndex := self.myRelatedCombo.listIndex;
	endif;
	
	inheritMethod();
	
	self.centreWindow;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bf925946-45cc-4e05-9be9-0e29077cb20e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 August 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020795, locale);
	btnFilter.translateCaption(Xlat_0020796, locale);
	chkSensitive.translateCaption(Xlat_0020797, locale);
	lblFilter.translateCaption(Xlat_0020798, locale);
	lblSelect.translateCaption(Xlat_0020799, locale);
end;</source>
    </JadeMethod>
</GUIClass>
