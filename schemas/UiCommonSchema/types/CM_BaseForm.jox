    <JadeMethod name="hideClonedMenuItems" id="341e3ecb-313d-49d1-99a1-ae88afd9935e">
        <source>hideClonedMenuItems(_master :MenuItem) protected;
/*
Date		Who		Reason
01 Nov 2012	cnwcs5	Initial creation - par 30475
*/
vars
	index	: Integer;
	clone	: MenuItem;
begin
	index := 1;
	clone := _master.getMenuItem(index);
	
	while clone &lt;&gt; null do
		clone.visible := false;
		
		index := index + 1;
		
		clone := _master.getMenuItem(index); 
	endwhile;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_master" type="MenuItem"/>
    </JadeMethod>
