    <JadeMethod name="doMatch" id="ec40ea6e-43a1-4b07-a021-505af8761777">
        <source>doMatch(_value: Integer): Boolean;
//-----------------------------------------------------------------------
//	Created:	11 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	return _value &gt;= searchValue;

epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="Boolean"/>
