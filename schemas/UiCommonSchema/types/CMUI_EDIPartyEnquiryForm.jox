epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="4050da69-4562-42e3-a9dc-c3fcb5941297">
        <updating/>
        <source>doQuery() updating;
/*
Date				Who		Reason
17 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
16/10/2012			cnwcs5	par 30483 - 
*/
vars
	terminal	:CM_Terminal;
	party		:CM_EDIParty;
	str			:String;
	idx			:Integer;
	table		:CM_DataTable;
begin
	terminal 	:= self.myTerminal;
	table		:= self.tblData;
	table.rows	:= table.fixedRows;
	
	self.doNotableClear;
	
	foreach party in terminal.allEDIParties do
		self.doQueryAddItem (table, party);
	endforeach;
	
	// default is for nothing to be selected
	table.row := table.fixedRows;			// par 30483 Oct 2012
	table.clearAllSelected;					// par 30483 Oct 2012
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="0b257e84-bb0b-4511-8203-586e80f4fbd2">
        <updating/>
        <source>doQueryAddItem(_table :CM_DataTable input; _party :CM_EDIParty)updating, protected;
/*
Date		Who		Reason
17 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	str	:String;
	idx	:Integer;
begin
	str := _party.getAttributeStringForDefArray(_table.allTblDataEntRows);
	idx := _table.addItemObject(_party, str);
	
	self.doNotableAdd (_party);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_party" type="CM_EDIParty"/>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="a9b1b188-c103-4ecb-91d8-a5bcb13f0552">
        <updating/>
        <source>doSystemNotification(_event: Integer; _party: CM_EDIParty; _tag: Integer) updating;
/*
Date		Who		Reason
17 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
16 Oct 2012	cnwcs5	par 30483 - clear/update macro info
*/
vars
	table		:CM_DataTable;
	row			:Integer;
	isSelected	:Boolean;		// par 30483 Oct 2012
	invalid : Boolean;
	str : String;
begin
	on Exception do app.handleDeletedObject(exception, _party, invalid);
	str := _party.description;
	if invalid then
		return;
	endif;
	table := self.tblData;

	if _event = Object_Delete_Event or _event = Object_Update_Event then
		
		table.findObjectInRow(_party, row);
	
		if row &lt;= table.fixedRows then
			// timing hole
			return;
		endif;
		
		isSelected := (row = table.row);	// par 30483 Oct 2012
		
		if _event = Object_Delete_Event then
			table.removeItem(row); 
			self.doNotableRemove (_party);
		else
			table.setCellText (row, 1, _party.getAttributeStringForDefArray(table.allTblDataEntRows));
		endif;
		
		if isSelected then						// par 30483 Oct 2012
			table.row := table.fixedRows;		// par 30483 Oct 2012
			table.clearAllSelected;				// par 30483 Oct 2012
			
			self.doTblDataRowColChange (table);	// par 30483 Oct 2012	
			
			self.showNumberOfItems (table);		// par 30483 Oct 2012
		else
			self.doTblDataRowColChange (table);	// par 30483 Oct 2012	
		endif;
		
		
	elseif _event = Object_Create_Event then 
		if _party.myTerminal &lt;&gt; self.myTerminal then
			return;
		endif;
		
		self.doQueryAddItem (table, _party);
		
		if table.allSelectedObjects.size = 0 then	// par 30483 Oct 2012
			self.showNumberOfItems (table);			// par 30483 Oct 2012
		else										// par 30483 Oct 2012
			self.showSelectedCount(table.allSelectedObjects.size, table.rows-table.fixedRows);// par 30483 Oct 2012
		endif;										// par 30483 Oct 2012
	endif;
epilog

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_party" type="CM_EDIParty"/>
        <Parameter name="_tag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="54fc1d17-d98f-4b24-8419-e0540420bce2">
        <updating/>
