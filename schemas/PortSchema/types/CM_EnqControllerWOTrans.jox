    <JadeMethod name="doDateSearch" id="70774661-0b17-406e-8261-931b26c41fe7">
        <updating/>
        <source>doDateSearch() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Dec 2022	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
14 Aug 2023 navhl20 ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions
23 Aug 2023 navhl20 Defect 59984: MTN - Filtering wrong data on the selector for the work order transaction mode
19 Jun 2024 navhl20 Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
*/

vars
	iteratorObj		: Iterator;
	transObj		: CM_WOTransaction;
	keyTimeStamp	: TimeStamp;
	keyType			: Integer;
	breakOut		: Boolean;
	passport		: CM_Passport;
	str,todoDesc	: String;
	strArr			: StringArray;
	transType		: CM_TransactionType;
begin
	passport := app.myPassport;
	
	iteratorObj	:=	myTerminal.allWOTransByDateTime.createIterator();
	self.myTerminal.allWOTransByDateTime.startKeyGeq(self.startDateTime, iteratorObj);
	
	while iteratorObj.next(transObj) do
		iteratorObj.getCurrentKeys(keyTimeStamp);
		
		if (self.endDateTime &lt;&gt; null and keyTimeStamp &gt; self.endDateTime) then
			break;
		endif;
		
		if self.includesObject(transObj, breakOut, passport) then
			self.addObjectToSet(transObj);
		endif;
			
		if breakOut or self.breakOutOfSearch then
			break;
		endif;
	endwhile;
epilog
	delete strArr;
	delete iteratorObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQuery" id="9affcd75-4493-4ae3-b892-020ec2bd06c5">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 December 2022	navhl20 ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
14 Aug 2023 navhl20 ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions
*/

vars
	now			: TimeStamp;
	crit		: CM_SelectorCriteriaLine;
	termSet		: CM_TerminalSet;
	ut			: CM_UserTerminal;
	tranType	: CM_TransactionType;
	term		: CM_Terminal;
	desc, 
	idSearchOp  : String;
	state 	    : Integer;
	days        : Integer;
begin

	self.reset();
	now := app.actualTimeServer();
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_WOTransaction::dateTime.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateEquals) then
			self.startDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateGreaterThan) then
			self.startDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime := now;
		elseif crit.myQueryOperator.isKindOf(CM_QDateLessThan) then
			self.endDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
			self.startDateTime := null;
		elseif crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.startDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.endDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf (CM_QDateDayEquals) then  
			if crit.myQueryOperator.getSearchValue() &lt;&gt; null then
				days := crit.myQueryOperator.getSearchValue().Integer;
				self.startDateTime.setDate( app.actualTimeServer.date.addDays(-days));
				self.startDateTime.setTime('00:00:00:000'.Time);
			else
				self.startDateTime :=  app.actualTimeServer;
				self.startDateTime.setTime('00:00:00:000'.Time);
			endif;
		endif;
	endif;
	
	create termSet transient;	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_WOTransaction::myTerminal.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
	else
		foreach ut in app.myPassport.myUser.allUserTerminals do
			termSet.add(ut.getMyTerminal);
		endforeach;
	endif;

	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_WOTransaction::getTransactionType.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(self.transactionTypes);
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_WOTransaction::getTodoTaskDesc.name, _qDef.className];				//14.8.2023 navhl20 #59284[59664]
	if crit &lt;&gt; null and 
	  crit.myQueryOperator.isKindOf(CM_QStringIsOneOf) then
		self.myTodoTask.clear();
		crit.myQueryOperator.getSearchValue().StringArray.copy(self.myTodoTask);
	endif;
	
	foreach term in termSet discreteLock do
		self.myTerminal := term;
		self.doSearch();
	endforeach;
	
	
epilog
	endLoad;
	delete termSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="0b1ebce4-a4cb-4461-82f8-f7a9047efcd6">
        <updating/>
        <source>doSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 December 2022	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars

begin
	self.doDateSearch();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reset" id="c2209829-6ae1-4526-8bb9-daa35e11eef3">
        <updating/>
        <source>reset() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 December 2022	navhl20	Initial creation

*/

vars

begin
	inheritMethod();
	
	self.myTerminal := null;
	self.startDateTime := null;
	self.endDateTime := null;
	self.transactionTypes.clear();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="9ef158f1-b7aa-4297-8ab3-4b9f03df61df">
        <updating/>
