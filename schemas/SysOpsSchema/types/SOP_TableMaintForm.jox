//-----------------------------------------------------------------------
//	Created:	03 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	obj			: Object;
	movement	 : HMS_VoyageMovement;
begin
// ***	this code should be moved into the doTblData1DblClick method SOP_TableMaintItem subclass
	obj := tblData1.accessRow(tblData1.row).itemObject;
	if obj &lt;&gt; null and obj.isKindOf (HMS_VoyageMovement) then
		movement := obj.HMS_VoyageMovement;
		
		// PAR 16389 - changes for Voy Comod Planning - but also correct method so only shows
		// if user can show the screen
		if app.myCurrentUserCan(self.myTerminal, PmHMSMovementsView) then
			self.myAssistant.showVoyageMovementsForm(movement, null, app.myCurrentUserCan(self.myTerminal, PmHMSMovementsMaint), movement.getMyVoyage.myTerminal , null);
		endif;
		/*
		if app.getMyUser.canDo(self.myTerminal, PmHMSMovementsMaint) then
			self.myAssistant.showVoyageMovementsForm(movement, null, true, movement.getMyVoyage.myTerminal , null);
		else
			self.myAssistant.showVoyageMovementsForm(movement, null, false, movement.getMyVoyage.myTerminal, null);	
		endif;
		*/
		return;
	endif;

	// Par 19803 concms1 june 2009
	if self.myCurrentTableItem = null then
		return;
	endif;
	
	self.myCurrentTableItem.doTblData1DblClick;
	
epilog	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
