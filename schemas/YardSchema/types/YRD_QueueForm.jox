    <JadeMethod name="getColumnIndex" id="e110c5eb-f6d2-4921-bb96-234a70441974">
        <source>getColumnIndex( _row : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwer1	Initial creation

*/

vars

	idx : Integer;
begin
	if self.tblQEntries.getEntRowColumnByRowName(_row,idx) &lt;&gt; null then
		return idx;
	endif;
	
	return null;
epilog

