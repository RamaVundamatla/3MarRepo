    <JadeMethod name="convertBaseToTarget" id="8d8a5b95-7489-41ee-a8cb-0464214c1148">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.DYNES then
		convertedMeasure	:=	pMeasure * 100000;

	elseif pUnitTo = self.KILOGRAMS_FORCE then
		convertedMeasure	:=	pMeasure / 9.80665;

	elseif pUnitTo = self.KILONEWTONS then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.KIPS then
		convertedMeasure	:=	pMeasure / 4448.222;

	elseif pUnitTo = self.MEGANEWTONS then
		convertedMeasure	:=	pMeasure / 1000000;

	elseif pUnitTo = self.NEWTONS then
		convertedMeasure	:=	pMeasure;

	elseif pUnitTo = self.POUNDALS then
		convertedMeasure	:=	pMeasure / 0.138255;

	elseif pUnitTo = self.POUNDS_FORCE then
		convertedMeasure	:=	pMeasure / 4.448222;

	elseif pUnitTo = self.STHENES then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.TONNES_FORCE then
		convertedMeasure	:=	pMeasure / 9806.65;

	elseif pUnitTo = self.TONS_UK_FORCE then
		convertedMeasure	:=	pMeasure / 9964.016;

	elseif pUnitTo = self.TONS_US_FORCE then
		convertedMeasure	:=	pMeasure / 8896.443;
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of force to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="ada6cb5c-2926-4f0c-b4b9-1d99046cb9c5">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.DYNES then
		convertedMeasure	:=	self.measure / 100000;

	elseif pUnitFrom = self.KILOGRAMS_FORCE then
		convertedMeasure	:=	self.measure * 9.80665;

	elseif pUnitFrom = self.KILONEWTONS then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.KIPS then
		convertedMeasure	:=	self.measure * 4448.222;

	elseif pUnitFrom = self.MEGANEWTONS then
		convertedMeasure	:=	self.measure * 1000000;

	elseif pUnitFrom = self.NEWTONS then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.POUNDALS then
		convertedMeasure	:=	self.measure * 0.138255;

	elseif pUnitFrom = self.POUNDS_FORCE then
		convertedMeasure	:=	self.measure * 4.448222;

	elseif pUnitFrom = self.STHENES then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.TONNES_FORCE then
		convertedMeasure	:=	self.measure * 9806.65;

	elseif pUnitFrom = self.TONS_UK_FORCE then
		convertedMeasure	:=	self.measure * 9964.016;

	elseif pUnitFrom = self.TONS_US_FORCE then
		convertedMeasure	:=	self.measure * 8896.443;
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of force to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="4f5bb92b-068e-4512-9f04-c6573a51a054">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.DYNES);
	pAllUnits.add(self.KILOGRAMS_FORCE);
	pAllUnits.add(self.KILONEWTONS);
	pAllUnits.add(self.KIPS);
	pAllUnits.add(self.MEGANEWTONS);
	pAllUnits.add(self.NEWTONS);
	pAllUnits.add(self.POUNDALS);
	pAllUnits.add(self.POUNDS_FORCE);
	pAllUnits.add(self.STHENES);
	pAllUnits.add(self.TONNES_FORCE);
	pAllUnits.add(self.TONS_UK_FORCE);
	pAllUnits.add(self.TONS_US_FORCE);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="5272ed85-d484-4aba-8318-f2fa298e2ac0">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.DYNES then
		return "Dynes";
	elseif pUnit = self.KILOGRAMS_FORCE then
		return "Kilograms Force";
	elseif pUnit = self.KILONEWTONS then
		return "Kilonewtons";
	elseif pUnit = self.KIPS then
		return "Kips";
	elseif pUnit = self.MEGANEWTONS then
		return "Meganewtons";
	elseif pUnit = self.NEWTONS then
		return "Newtons";
	elseif pUnit = self.POUNDALS then
		return "Poundals";
	elseif pUnit = self.POUNDS_FORCE then
		return "Pounds Force";
	elseif pUnit = self.STHENES then
		return "Sthenes";
	elseif pUnit = self.TONNES_FORCE then
		return "Tonnes Force";
	elseif pUnit = self.TONS_UK_FORCE then
		return "Tons (UK) Force";
	elseif pUnit = self.TONS_US_FORCE then
		return "Tons (US) Force";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Force to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
