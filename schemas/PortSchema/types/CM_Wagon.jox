    <JadeMethod name="getIsDamaged" id="4ba896df-a849-4a56-9b5a-69e2097092ff">
        <source>getIsDamaged() : Boolean;
/*
Purpose:			

Date		Who		Reason
27 June 2023	navab1	 BUG 58868
*/

vars
	damage : CM_DamageInstance;
	repaired, damaged : Integer;
begin
	foreach damage in self.allDamageInstanceByPos discreteLock do
			if damage.status = DamageStatusRepaired then
				repaired += 1;
			else
				damaged += 1;
			endif;
	
	endforeach;
	
	return damaged &gt; 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
