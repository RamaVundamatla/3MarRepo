    <JadeMethod name="getOutgoingVoyageStatus" id="5f66b764-600a-49b9-afa1-e1858425ddf4">
        <source>getOutgoingVoyageStatus(_voyage: CM_Voyage): CM_VoyageStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin
	if self.status.Integer = 2 then	
		return app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IDepAppIPN );
	else
		//return app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IApprovalReject );
	endif;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_VoyageStatus"/>
    </JadeMethod>
    <JadeMethod name="getValidCurrentStatuses" id="90fd5d11-1e6d-43cf-b186-ed170fb7633f">
        <source>getValidCurrentStatuses(_validStatuses: IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin
	_validStatuses.add( Voyage_Status_IDepReqIPN );
