    <JadeMethod name="setupThumbnailDetails" id="bde9505c-24e4-43ca-bab6-384013e710fb">
        <source>setupThumbnailDetails();
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
begin
	
	self.setupThumbnailDetails_Code();
	
	self.myForm.initTblInput(myForm.tblInput1, ETDef_CodeMaintColour); // AKB2002JUNE
	
	self.myForm.shtMultiSelect1.visible := true;
	self.myForm.shtMultiSelect2.visible := true;
	self.myForm.shtMultiSelect3.visible := true;
	
	self.myForm.iniSheetMultiSelect();
	self.myForm.shtMultiSelect1.caption := app.getErrorString(Type_GC);
	self.myForm.shtMultiSelect1.cnEcResizeContents();
	self.myForm.mulSelect1.formDisplayEntryMethodName := 'displayEntryLogType';	
	self.myForm.mulSelect1.setAvailable(myObject.CM_LogGrade.getAvailableTypesForGrade(), true);
	self.myForm.mulSelect1.setSelected(myObject.CM_LogGrade.allLogTypes);

	self.myForm.shtMultiSelect2.caption := app.getErrorString(TreatmentTitle);
	self.myForm.shtMultiSelect2.cnEcResizeContents();
	self.myForm.mulSelect2.formDisplayEntryMethodName := 'displayEntryLogTreatment';
	self.myForm.mulSelect2.setAvailable(myObject.CM_LogGrade.getAvailableTreatmentsForGrade(), true);
	self.myForm.mulSelect2.setSelected(myObject.CM_LogGrade.allLogTreatments);
	
	self.myForm.shtMultiSelect3.caption := app.getErrorString(Length_Title);
	self.myForm.shtMultiSelect3.cnEcResizeContents();
	self.myForm.mulSelect3.formDisplayEntryMethodName := 'displayEntryLogLength';
	self.myForm.mulSelect3.setAvailable(myObject.CM_LogGrade.getAvailableLogLengthsForGrade(), true);
	self.myForm.mulSelect3.setSelected(myObject.CM_LogGrade.allLogLengths);

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="582a87df-004f-4bbc-9c15-02d6724b1839">
        <updating/>
        <source>showThumbnail(_obj: CM_LogGrade) updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.setupThumbnailDetails();
	self.myForm.sptThumbEdit.enabled := true;

	self.myForm.tblInput1.enabled := true;

	self.myForm.tblInput1.clearValues;
	self.myForm.tblInput1.setValueByName(ETRow_Code, _obj.code);
	self.myForm.tblInput1.setValueByName(ETRow_Description, _obj.description);
	self.myForm.tblInput1.setValueByName(ETRow_Colour, _obj.colour);
	self.myForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, _obj.notAvailableForEntry);
	self.myForm.tblInput1.setValueByName(ETRow_MinSED, _obj.minSED);
	self.myForm.tblInput1.setValueByName(ETRow_MaxSED, _obj.maxSED);
	self.myForm.tblInput1.setValueByName(ETRow_MinMeanSED, _obj.minMeanSED);
	self.myForm.tblInput1.setValueByName(ETRow_MaxMeanSED, _obj.maxMeanSED);
	

end;</source>
        <Parameter name="_obj" type="CM_LogGrade"/>
    </JadeMethod>
</Class>
