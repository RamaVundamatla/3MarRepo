    <JadeMethod name="delete" id="17386f67-a6b1-4653-9e4a-8157b73d2ae5">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 Jul 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	// Need to delete any associated transients we have created
	self.allLCsByGridPos.purge();
	self.allTIsByGridPos.purge();
	self.allGridLocationsByLCoid.purge();
	
	
epilog

end;</source>
