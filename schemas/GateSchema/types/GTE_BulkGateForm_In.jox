    <JadeMethod name="doBuildGateCombo" id="7c463413-1760-4ffa-9a1f-cfb9d56eb031">
        <source>doBuildGateCombo() protected;

/*
Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	gate 		: CM_Gate;
	gateArea 	: CM_GateArea;
	gateAreaUsage : CM_GateAreaUsage;
begin
	// For now, we are assuming one A-gate per terminal 
	self.cmbGate.clear();
	foreach gate in self.myTerminal.allGates do
		if gate.hasPGateAreas_IN then
			gateAreaUsage := gate.allGateAreas_IN.first();
			if gateAreaUsage &lt;&gt; null then
				gateArea := gateAreaUsage.myGateArea;
				if gateArea &lt;&gt; null then
					self.cmbGate.addItemObject(gate.name, gate);
				endif;
			endif;
		endif;
	endforeach;
	
	if self.myTerminal.allGates.size() &gt; 0 then	
		self.setDefaultGate();																		
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCargoTypesClick" id="f0ddb35b-6840-43ae-89b0-19f0d2840bfc">
        <updating/>
        <source>doCargoTypesClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2016	cnwns1	Initial creation
22/05/2018	jlgdap1	TFS 38501 PEL1 Voyage Work Orders - new parameter for pickerWindowForObject
26 Oct 2023 navhn30 Bug 58092: MTN - 1090 when Gating Bulk cargo in
*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	tmpTI			: CM_TrackedItem;
	itTI			: CM_TrackedItem;
	iter 			: Iterator;
	cargoTypeID 	: Integer;
	vbsts			: CM_VehicleBookingTimeSlot;
	locCont			: CM_LocationsController;
	allPotentialTIs : CM_TISet;
	allPotentialPNs : CM_TISet;
	allpotentialsCombined : ObjectArray;
	selectedObj 	: Object;
begin

create allPotentialPNs transient;
create allPotentialTIs transient;
	cargoTypeID := self.cmbCargoTypes.listObject.CM_CargoType.id;

	
	iter:=self.myTerminal.allNotifiedTIsByCargoTypeId.createIterator;
	self.myTerminal.allNotifiedTIsByCargoTypeId.startKeyGeq(self.cmbCargoTypes.listObject.CM_CargoType.id,null,iter);
	
	while iter.next(itTI) do
		if itTI.cargoType &lt;&gt; cargoTypeID then
			break;
		endif;
		
		allPotentialPNs.add(itTI);
		
	endwhile;
	delete iter;
	
	
	
	if self.allowGateInByCargoID then
		iter:=self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
		self.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(self.cmbCargoTypes.listObject.CM_CargoType.id,null,iter);
		while iter.next(itTI) do
			if itTI.cargoType &lt;&gt; cargoTypeID then
				break;
			endif;
			locCont := itTI.myPrimaryActualLocation;
			if locCont &lt;&gt; null and (not locCont.isYardLocation() 				// 26.10.23  navhn30  #58092
				or locCont.isVehicle 
				or locCont.isMachineController)
			then
				continue;
			endif;	
			allPotentialTIs.add(itTI);
		endwhile;
		delete iter;
	endif;
	
		
	if allPotentialTIs.isEmpty and allPotentialPNs.isEmpty then
		app.msgBox(app.getErrorString(NoCargoSelected),app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);		
		return;
	elseif ( allPotentialTIs.size + allPotentialPNs.size ) = 1 then
		if allPotentialPNs.isEmpty then
			tmpTI := allPotentialTIs.first;
		else
			tmpTI := allPotentialPNs.first;
		endif;
	else
		create allpotentialsCombined transient;
		
		allPotentialPNs.copy(allpotentialsCombined);
		allPotentialTIs.copy(allpotentialsCombined);
		
		//self.myAssistant.pickerWindowForObject(allpotentialsCombined,false,selectedObj, self);		// TFS 38501
		self.myAssistant.pickerWindowForObject(allpotentialsCombined,false,selectedObj, self, false);	// TFS 38501
		tmpTI := selectedObj.CM_TrackedItem;
	endif;
	if tmpTI = null then
		return;
	endif;
	self.myBulkGateAgent.setDirection(tmpTI.isNotified);
	self.setDirectionLabel(self.myBulkGateAgent.cargoDirection);

	self.getVisitDetails(tmpTI,true);		
	self.doVvrAssocToVbtsStandard(vbsts);	
	self.setTxtPinToNullOrVbsId();
	
	self.cmbCargoTypes.enabled := false;
	
	self.txtPIN.enabled := false;
	
epilog
	delete allpotentialsCombined;
	delete allPotentialTIs;
	delete allPotentialPNs;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCashOnlyValidation" id="420a0158-6b58-4f38-b404-68b2e76ef1c2">
        <source>doCashOnlyValidation(_vvr : CM_VehicleVisitRecord input; _allProformaLines : ObjectSet input) : Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/05/2017	cnwdap1		Initial creation TFS 4111 PKT Cash validation before gating in a truck
//
vars
	result : Integer;

begin
	while true do
		//could have got warnings must clear this
		_allProformaLines.clear;
		app.myValUA.valCashCollectionForVVR(_vvr, true, true, _allProformaLines, app.myPassport);
		
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			else
				return false;
			endif;
		endif;
		break;
	endwhile;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_allProformaLines" type="ObjectSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeGate" id="8bd1a0cf-42eb-4852-a3ac-47f87d1403e6">
        <source>doChangeGate(_gate: CM_Gate) protected;

/*
Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

Everytime the gate combo is changed, we need to update the gate lanes and enable/disable gate lane combo
depending on whether or not the gate has lanes.  Might as well push all programmatic changes through this method.

*/

vars
begin
	self.cmbGate.listObject := _gate;
	self.myBulkGateAgent.setGate(_gate);
	self.onGateChange();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="doCmbDriverDisplayEntry" id="ee7c6c63-eaf4-42a4-9b7d-1349e8995c53">
        <source>doCmbDriverDisplayEntry(_obj : Any):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
19 June 2024	jlizm1	TFS 63908 Allow duplicate driver names
*/

vars
	driver : CM_DriverDetails;
begin
    driver:=_obj.CM_DriverDetails;
	if driver = null then
		return null;
	endif;
	
	if driver.myTerminal &lt;&gt; self.myTerminal then
		return null;
	endif;
	
	if self.myTerminal.getConfig(KnownTruckDriverRequired).Boolean
	and driver.code &lt;&gt; driver.name then
		return driver.code &amp; " " &amp; driver.name;
	else
		return driver.code;
	endif;
end;
</source>
        <Parameter name="_obj" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doCmbRegNoClick" id="da319337-612b-488a-ad68-1a7ad23c34fb">
