	self.type := proxyJob.type;
	self.myTerminal := _theTerminal;
	self.selectedTIs.clear();
	proxyJob.selectedTIs.copy(self.selectedTIs);
	self.selectionMacro := proxyJob.selectionMacro;
end;</source>
