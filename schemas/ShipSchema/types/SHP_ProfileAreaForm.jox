    <JadeMethod name="updateKPIStats" id="a044ceac-c5d5-4074-b61f-be49c20efd42">
        <updating/>
        <source>updateKPIStats() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		24 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theReturn : Integer;
begin
	if self.myCurrentVoyage = null then
		return false;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateVoyageKPIStats(self.myCurrentVoyage,true, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Voyage KPI Stats", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateStats" id="54cd0feb-362f-4601-a627-14b55c9ae4f1">
        <updating/>
        <source>updateStats() updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 May 2005 by cnwrs2
//
// Purpose:   Updates the stats from a EVENT_WLE_COMPLETE note
// ---------------------------------------------------------------------------
vars
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	delete self.myVoyageStats; // stats for holds have transient job sheets and need to be removed on refresh
	setCurrentVoyage(self.myCurrentVoyage);
	
//	self.myVoyageStats.getStats(true);
	self.showCraneMoves();
	// PAR 36118self.showTableStats(); 
	self.showTableStatsAB(); //PAR 36118
	
	
epilog
	// belts &amp; braces to ensure no locks are left behind
	endLoad;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateWLEStats" id="f35676af-0a85-494b-9b2f-58c5ffec7f0d">
        <source>updateWLEStats(_voyageWLE : CM_VoyageWLE) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2011	cnwer1	Initial creation CCMS 1241 par 28101

*/

vars
	shpProfileArea : SHP_ProfileArea;
	bay : CM_BayVoyage;
	column : SHP_BayColumn;
	invalidObj : Boolean;
begin
	if _voyageWLE = null then
		return;
	endif;
	
	//14 Mar 2013	NDL	Par 29206
	on Exception do app.handleDeletedObject( exception, _voyageWLE, invalidObj );
	
	bay:=_voyageWLE.getBay;
	
	// 31977 refresh the column if a bay, refresh the TODO if using voyage stats, so that RORO WLE completion also updates the totals on-screen.
	//if bay = null then
	//	return;
	//endif;
	
	if bay &lt;&gt; null then
		shpProfileArea:=self.myCurrentSDF.allGridAreasByColumnRow.first.SHP_ProfileArea;
		if shpProfileArea &lt;&gt; null then
			column:=shpProfileArea.getGridColumnByLabel(bay.id).SHP_BayColumn;
			if column &lt;&gt; null then
				shpProfileArea.drawSpecialBayUncompleted(column);
			endif;
		endif;
	endif;
	// 31977 do this independently of the bay test
	if self.myVoyageStats &lt;&gt; null then
		shpProfileArea:=self.myCurrentSDF.allGridAreasByColumnRow.first.SHP_ProfileArea;
		if shpProfileArea &lt;&gt; null then
			shpProfileArea.drawSpecialAfterTotalTodo(self.myVoyageStats.movesIncomplete, shpProfileArea.totalX+10);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyageWLE" type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="33644ebc-e6dc-4869-af14-a0977f7397fe">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 17/08/2011	cnwcs5	CCMS MES 1033 RORO KPI
// 08/11/2012	cnwcs5	par 30519 - delay notifications
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	event		: Integer;
begin

	if eventType = EVENT_WLE_COMPLETE and theObject = self.myCurrentVoyage then
		self.updateStats();
		
		if userInfo.isKindOf(CM_VoyageWLE) then
			self.updateWLEStats(userInfo.CM_VoyageWLE);
		endif;
		
		return;
	endif;
	
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if event = EVENT_WEBCAM_ONE_UPDATE then
		if self.frmWebCam.visible then
			self.showWebCamPicture();
		endif;
	elseif event = EVENT_KPISHIPMOVEUPDATE then
		// ### NOTE: This note will only be received if the BGP LockKeeper is running
		self.showMoveStatsByJS();
		self.showBayStats();
		self.showRORODecksStats();
		self.showROROMovesStats();
		
	elseif event = Voyage_Update_Event then
		self.updateStats();
		self.showTimings();
		
	elseif event = EVENT_VOYAGE_BERTHING_CHANGED then
		self.flipH := not theObject.CM_Voyage.starboardBerthed; // flip if port berthed
		self.sdf01.drawInReverse := self.flipH;
		self.doDrawGridArea();
		
	elseif event = EVENT_DELAY_CREATE or event = EVENT_DELAY_UPDATE or event = EVENT_DELAY_DELETE then
		// clear the delay table - if it is not currently visible it will be re-loaded when they go to that sheet
		self.tblDelays.rows := self.tblDelays.fixedRows;
		
		if self.fldMain.topSheet = self.shtDelays then
			// we need to actually do the load
			self.showDelaysStats ();
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
