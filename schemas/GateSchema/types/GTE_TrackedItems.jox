    <JadeMethod name="btnCargoEnq_click" id="f96238ee-42a6-4cd3-aa74-0810b5b91d50">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCargoEnq_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aTI : CM_TrackedItem;
begin
	if self.tblListAll.row &lt;= self.tblListAll.fixedRows then
		return;
	endif;
	
	aTI := self.tblListAll.accessRow(self.tblListAll.row).itemObject.CM_TrackedItem;
	self.myAssistant.showCargoEnquiryForm(aTI, self.myMasterMenuAction, true, false);		
end;</source>
