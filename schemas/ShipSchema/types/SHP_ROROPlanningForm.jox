    <JadeMethod name="repositionAllBackFrames" id="45598329-4eef-43ed-82d7-9039485fd48d">
        <source>repositionAllBackFrames();
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	backFrame : Frame;
	obj : Object;
	offsetY : Integer;
	backFrameTop : Real;
	newLeft : Real;
begin

	backFrameTop := self.frmDeck.myDrawingFrame.top + self.frmDeck.top + 1;
	newLeft := self.frmDeck.myDrawingFrame.left + 1;
	newLeft := newLeft + self.frmDeck.left;
	
	foreach obj in self.myROROPlanDrawController.allBackFrames do
		backFrame := obj.Frame;
		if backFrame.visible = false then
			continue;
		endif;
		
		backFrame.move(newLeft,backFrameTop ,self.frmDeck.myDrawingFrame.width, self.frmDeck.myDrawingFrame.height);
		backFrame.zOrder(0);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCaptionForModesGetView" id="85a086b2-b870-4cfd-b19c-7e10e14964e2">
        <source>setCaptionForModesGetView(_theMode : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpString, theString : String;
begin
	if self.myCurrentVoyage &lt;&gt; null then
		theString := self.myCurrentVoyage.code &amp; " - " &amp; self.myCurrentVoyage.vesselName &amp; " (" &amp; self.myCurrentVoyage.starboardBerthedRWD() &amp; ") -";
		
		self.setNavigatorHeading(self.myCurrentVoyage.code.trimBlanks &amp; " " &amp; self.myCurrentVoyage.vesselName); // NAVIGATOR 31110
	endif;
	if _theMode = ShpDisplayMode_Actual then
		theString := theString &amp; " " &amp; app.getErrorString1(DeckView_Actual, app.getViewModeString(VIEW_DISPORT)) ; 
		
	elseif _theMode = ShpDisplayMode_Defn then 
		theString := theString &amp; " " &amp;app.getErrorString(DeckView_Definition) ; 
		
	elseif _theMode = ShpDisplayMode_Proposed then 
		theString := theString &amp; " " &amp; app.getErrorString1(DeckView_Proposed, app.getViewModeString(VIEW_DISPORT)) ; 

	elseif _theMode = ShpDisplayMode_ColCodeDisch then 
		if self.modeWork = WorkMode_Job then
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewDischargeJob) ; 
// PAR 31073			theString := theString &amp; " " &amp; $SHP_DISCHARGE &amp; $SHP_JOB &amp; $SHP_Mode &amp;  $SHP_By_Discharge_Port;
			
		elseif self.modeWork = WorkMode_Plan then
		
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewDischargePlanning) ; 
// PAR 31073 			theString := theString &amp; " " &amp; $SHP_DISCHARGE &amp;  $SHP_PLANNING &amp; $SHP_Mode &amp;  $SHP_By_Discharge_Port;
			
		elseif self.modeWork = WorkMode_CustomSeq then
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewDischargeCustom) ; 
		
			// PAR 31073 theString := theString &amp; " " &amp; $SHP_DISCHARGE &amp;  $SHP_CUSTOM_SEQUENCING &amp; $SHP_Mode &amp;  $SHP_By_Discharge_Port;
			
		else
		
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewDischargeCC) ; 
			// PAR 31073 theString := theString &amp; " " &amp; $SHP_DISCHARGE &amp; $SHP_COLOUR_CODING &amp; $SHP_Mode &amp;  $SHP_By_Discharge_Port;
		endif;
		
		if self.myROROPlanDrawController.modeViewSubSub = ShpDisplayModeSub_ExportsShow then
		
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewDischargeCCShowExports) ; 
		else
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewDischargeCCHideExports) ; 
		endif;

	elseif _theMode = ShpDisplayMode_ColCodeLoad then 
	/* PAR 31073
		// PAR 23426
		if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.useVoyageAllocations then
			tmpString := app.getErrorString(Allocations);
		else
			tmpString := $SHP_By_Discharge_Port;
		endif;
		*/
		if self.modeWork = WorkMode_Job then
			// PAR 31073 theString := theString &amp; " " &amp; $SHP_LOAD &amp; $SHP_JOB &amp; $SHP_Mode &amp; tmpString;
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewLoadJob) ; 
			
		elseif self.modeWork = WorkMode_Plan then
			// PAR 31073 theString := theString &amp; " " &amp; $SHP_LOAD &amp;  $SHP_PLANNING &amp; $SHP_Mode &amp;  tmpString;
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewLoadPlanning) ; 
		
		elseif self.modeWork = WorkMode_CustomSeq then
		
		
			// PAR 31073 theString := theString &amp; " " &amp; $SHP_LOAD &amp;  $SHP_CUSTOM_SEQUENCING &amp; $SHP_Mode &amp;  tmpString;
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewLoadCustom) ; 
			
		else
			// PAR 31073 theString := theString &amp; " " &amp; $SHP_LOAD &amp; $SHP_COLOUR_CODING &amp; $SHP_Mode &amp; tmpString;
			theString := theString &amp; " " &amp; app.getErrorString(DeckViewLoadCC) ; 
		endif;
	endif;

	return theString;	

end;</source>
        <Parameter name="_theMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
