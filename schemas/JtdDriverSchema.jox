    <Function name="jtdGetMemoryStatusExThinClient" id="1cc7431e-cdff-4d43-8093-7fc209622920">
        <entrypoint>GlobalMemoryStatusEx</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="kernel32"/>
        <source>// Allocate 256 bytes in which memory information will be returned. This
// needs to be at least the size of a Windows MEMORYSTATUS structure. At
// the time of writing (11 Sept 2001), the Win32 documentation says this
// structure holds 8 4-byte elements, so 256 bytes is plenty of room.

jtdGetMemoryStatusExThinClient(b : Binary[256] io)
is GlobalMemoryStatusEx in kernel32 presentationClientExecution;</source>
        <Parameter name="b" type="Binary" length="256" usage="io"/>
    </Function>
    <Function name="jtdGetMemoryStatusLocalMachine" id="f1280019-829e-456e-a78c-d664925b49c9">
