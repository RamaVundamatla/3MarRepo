    <JadeMethod name="ediVerify" id="b970914c-42b6-49d5-9b27-fdff831020fd">
        <source>ediVerify(_ediFile: CM_EDIFile);
//17 December 2008	cnwdw1	
//
vars
	ediAgent: CM_EDIControllerAgent;
	ediData: CM_EDIData;
	result : Boolean;
begin
	create ediAgent transient;
	ediAgent.setTerminal(self.getTerminal());
	ediData := _ediFile.ediData;
	result := ediAgent.verifyEdiData(ediData);
//	self.assertTrueMsg(result, _ediFile.fileName);	// let the calling method decide what is allowed - and why compare reult to a file name?
	/////self.assertNoTrxErrorsOrWarnings();	// let the calling method decide what is allowed - eg verify warnings might be OK
										// If this is the case then pass through as expected errors
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	delete ediAgent;
end;</source>
