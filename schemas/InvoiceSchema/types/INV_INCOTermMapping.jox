    <JadeMethod name="setupForm" id="f65ede78-77c8-4369-9c3e-a81a9d3ef5ce">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57991 Task 57992: EUP - INCO Terms Mapping

*/

vars

begin
	inheritMethod();
	self.handleMenusForModalDisplay();
	self.loadMsgInvoiceTypes();
	self.doCmbChargesBuild(self.cmbCharge);
	if self.mode then
		self.populateINCOMapping();
		self.msgInvlistTypes.setSelected(self.myINCOMapping.allInvoiceLineTypes);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5582d12f-b399-4cbb-8a39-ff144413bf99">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 May 2023 18:08:20.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026034, locale);
	btnClose.translateCaption(Xlat_0026035, locale);
	btnSave.translateCaption(Xlat_0026036, locale);
	lblcharge.translateCaption(Xlat_0026037, locale);
	msgInvlistTypes.translateCaption(Xlat_0026038, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateINCOMapping" id="f6b5f3dd-57c2-424d-9d57-dfbcc2d5cae9">
        <updating/>
        <source>updateINCOMapping()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57991 Task 57992: EUP - INCO Terms Mapping

*/

vars
	charge,debtor : CM_DebtorType;
	pxyINCOMapping,
	realINCOMapping:CM_InvoiceINCOMapping;
	//myShippingTerm : CM_InvoiceContractShipTerm;
	bank : CM_Bank;
	allInvoice : CM_InvoiceLineDescSet;
	ild : CM_InvoiceLineDesc;
	theReturn : Integer;
begin
	pxyINCOMapping := app.createUpdateProxy(self.myINCOMapping).CM_InvoiceINCOMapping;
	if self.cmbCharge.listIndex &lt;&gt; -1 then
		charge := self.cmbCharge.itemObject[self.cmbCharge.listIndex].CM_DebtorType;
	endif;
	bank := self.myCurrentBank;
	debtor := app.myRoot.allDebtorTypes.first;
	create allInvoice transient;
	
	//ild := bank.invoiceLineDescriptors.first;
	self.msgInvlistTypes.getSelected(allInvoice);
	
	//create pxyShippingTermMapping transient;
	pxyINCOMapping.setProxy(pxyINCOMapping.myINCOTerm,charge,allInvoice);

		while true do
		app.myTrxUA.trxUpdateinvoiceINCOMapping(pxyINCOMapping, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.unloadForm();
			//self.myParentForm.INV_ShippingTermMaint.setProxyShippingItem(realShippingTermMapping);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_inco_mapping_updated), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	delete pxyINCOMapping;
	delete allInvoice;
end;</source>
    </JadeMethod>
</GUIClass>
