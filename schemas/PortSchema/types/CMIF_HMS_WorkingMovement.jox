    <JadeMethod name="init_MoveTidalClass" id="b143130e-7e14-4a2f-87f7-31e765688a25">
        <updating/>
        <source>init_MoveTidalClass():HMS_TidalClass updating;

vars
	voyageData : HMS_VoyageData;
begin
	// Returns initialise value for 'DEFAULT TIDAL CLASS FOR A MOVEMENT'
	if self.myClonedVoyage&lt;&gt;null then
		voyageData := self.myClonedVoyage.myHMSVoyageData;
	else
		voyageData := self.myWorkingVoyage.myHMSVoyageData;
	endif;

	if moveType=HMSMovementTypeDeparture then
		if voyageData.myTidalClassDept&lt;&gt;null then
			return voyageData.myTidalClassDept;
		else
			return voyageData.myTidalClass;
		endif;
	else
		return voyageData.myTidalClass;
	endif;
end;</source>
        <ReturnType type="HMS_TidalClass"/>
    </JadeMethod>
    <JadeMethod name="init_NumLinesCrewReqd" id="2b33a696-0db7-45af-8ab8-fa2d87571d19">
        <updating/>
        <source>init_NumLinesCrewReqd():Integer updating;

vars
	voyageData : HMS_VoyageData;
begin
	// Returns initialise value for 'NUMBER OF LINES CREW REQUIRED'
	if self.requiresMarineServices = false then
		return 0;
	endif;
	
	if self.myClonedVoyage&lt;&gt;null then
		voyageData := self.myClonedVoyage.myHMSVoyageData;
	else
		voyageData := self.myWorkingVoyage.myHMSVoyageData;
	endif;

	if self.moveType = HMSMovementTypeDeparture then
		return voyageData.numLCrewLetGo.Integer;
	else
		return voyageData.numLCrewTieUp.Integer;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
