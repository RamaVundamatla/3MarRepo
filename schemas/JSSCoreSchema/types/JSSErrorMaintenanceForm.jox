    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="89c00a32-0649-439f-b50f-a3c7808c79cb">
        <updating/>
        <source>doFormUpdate(pIsDelete:Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theConstant	: Constant;
	
begin
	if not self.doFormValidate(pIsDelete) then
		return false;
	endif;
	
	theConstant	:=	lstConstant.listObject.Constant;
	
	beginTransaction;
	// Use "setPropertyValue" because the "text" property is read-only.
	theConstant.setPropertyValue("text", txtText.text.trimBlanks());
	commitTransaction;
	
	return inheritMethod(pIsDelete);
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="7c5432a8-b011-4819-8009-d77f1ffcfc31">
        <updating/>
        <source>doRefresh() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.loadSchemaList();
	self.doFormInitialize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findNextAvailableExceptionCode" id="822d2238-3583-4b21-9e8f-12717ad7c0d3">
        <source>findNextAvailableExceptionCode():Integer protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	exceptionCode		: Integer;
	allExceptionCodes	: IntegerArray;
	theCoreSchema		: Schema;
	allSubschemas		: SchemaColl;
	theSubschema		: Schema;
	listPointer			: Integer;
	codeCount			: Integer;
	
begin
	theCoreSchema	:=	rootSchema.getSchema(JSSCoreSchema.name);
	
	create allSubschemas transient;
	theCoreSchema.allSubschemas(allSubschemas);
	
	create allExceptionCodes transient;
	self.getSchemaExceptionCodes(theCoreSchema, allExceptionCodes);
	
	foreach theSubschema in allSubschemas do
		self.getSchemaExceptionCodes(theSubschema, allExceptionCodes);
	endforeach;
	
	allExceptionCodes.jssSort(false);
	codeCount	:=	0;
	
	foreach exceptionCode in allExceptionCodes do
		codeCount	:=	codeCount + 1;
		
		if codeCount &lt; exceptionCode then
			return codeCount;
		endif;
	endforeach;
	
	// If we got past the return within the array loop, then there are no gaps
	// within the list of exception codes, so we'll just add one to the end.
	
	exceptionCode	:=	exceptionCode + 1;
	
	return exceptionCode;
epilog
	delete allSubschemas;
	delete allExceptionCodes;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSchemaExceptionCodes" id="7ece4a66-de14-4b60-a506-42574775936b">
        <source>getSchemaExceptionCodes(pTheSchema:Schema; pAllExceptionCodes:IntegerArray io) protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCategory		: ConstantCategory;
	allConstants	: ConstantNDict;
	theConstant		: Constant;
	listPointer		: Integer;
	
begin
	theCategory	:=	self.findExceptionConstantCategory(pTheSchema);
	
	if theCategory = null then
		return;
	endif;
	
	allConstants	:=	theCategory.getConstants();
	
	foreach theConstant in allConstants do
		pAllExceptionCodes.add(theConstant.valueAsInteger);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSchema" type="Schema"/>
        <Parameter name="pAllExceptionCodes" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadConstantList" id="1c56f95a-61b1-4af3-bc60-bff8cd76bc6e">
        <source>loadConstantList() protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSchema		: Schema;
	theListbox		: ListBox;
	theCategory		: ConstantCategory;
	allConstants	: ConstantNDict;
	theConstant		: Constant;
	listPointer		: Integer;
	
begin
	theListbox		:=	lstConstant;
	theListbox.clear();
	txtText.text	:=	null;
	theSchema		:=	cmbSchema.listObject.Schema;
	
	if theSchema = null then
		return;
	endif;
	
	theCategory	:=	self.findExceptionConstantCategory(theSchema);
	
	if theCategory = null then
		return;
	endif;
	
	allConstants	:=	theCategory.getConstants();
	
	foreach theConstant in allConstants do
		listPointer	:=	theListbox.addItem(theConstant.name &amp; " (" &amp; theConstant.valueAsInteger().String &amp; ")");
		theListbox.itemObject[listPointer]	:=	theConstant;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSchemaList" id="0b6f2c93-8a65-450b-88aa-f78ff0ed1eb2">
        <source>loadSchemaList() protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCombobox		: ComboBox;
	theCoreSchema	: Schema;
	listPointer		: Integer;
	
begin
	theCombobox		:=	cmbSchema;
	theCombobox.clear();
	theCoreSchema	:=	rootSchema.getSchema(JSSCoreSchema.name);
	
	listPointer	:=	theCombobox.addItem(theCoreSchema.name);
	theCombobox.itemObject[listPointer]	:=	theCoreSchema;
	theCombobox.itemLevel[listPointer]	:=	1;
	
	self.loadSubschemas(theCoreSchema);
	
	theCombobox.itemExpanded[listPointer]	:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSubschemas" id="3700e721-7b7c-4f44-9058-a9b419ec496b">
        <source>loadSubschemas(pTheSchema:Schema) protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCombobox		: ComboBox;
	allSubschemas	: SchemaNDict;
	theSubschema	: Schema;
	parentPointer	: Integer;
	insertPointer	: Integer;
	parentLevel		: Integer;
	childLevel		: Integer;
	
begin
	theCombobox		:=	cmbSchema;
	parentPointer	:=	theCombobox.findObject(pTheSchema);
	insertPointer	:=	parentPointer + 1;
	parentLevel		:=	theCombobox.itemLevel[parentPointer];
	childLevel		:=	parentLevel + 1;
	
	create allSubschemas transient;
	pTheSchema.getSubschemas(allSubschemas);
	
	foreach theSubschema in allSubschemas reversed do
		theCombobox.addItemAt(theSubschema.name, insertPointer);
		theCombobox.itemObject[insertPointer]	:=	theSubschema;
		theCombobox.itemLevel[insertPointer]	:=	childLevel;
		
		self.loadSubschemas(theSubschema);
	endforeach;
epilog
	delete allSubschemas;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSchema" type="Schema"/>
    </JadeMethod>
    <JadeMethod name="lstConstant_click" id="3d02b165-180a-4f46-b117-8298e7040a1f">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstConstant_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
