    <JadeMethod name="setForCreate" id="b0048f6a-eecc-4662-be5f-dcbc25dd1859">
        <updating/>
        <source>setForCreate(_ti: CM_TrackedItem; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     01 November 2002		cnwth2	
//
// Purpose:     The cargoType of a breakBulk generic is set at birth to be TI_BreakBulk_Type
//				so we need to override this and set it to self.myProduct.myCargoType
//			 
// ----------   ----------  --------------------------------------------------
// 12/10/2009	cnwdap1		PAR #21139 Colour attribute added
// 04/08/2010	cnwdap1		PAR #25296 Update unsplitQuantity, unsplitVolume, unsplitWeight (setForUpdate already does these)
// 03/12/2013	cnwdap1		PAR #33019 CCMS DPH 2285 Correct handling of colour validation and updating
// 11/05/2022	jlika1		TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
vars
	theCargoType 	: CM_CargoType;
	bb				: CM_BreakBulkGeneric;
begin
	//TH2 add 2nd June - problem where real TI cargo type was still = 3 at this point!?!
	//resulting in stops that were inappropriate for the cargo type to be applied
	if self.cargoType &lt;&gt; _ti.cargoType then
		self.cargoType := _ti.cargoType;
	endif;
	//inherit first so the product reference etc. is set
	inheritMethod(_ti, _passport);
	// dh par 17686 added the following:
	if self.myCargoType &lt;&gt; null
	and self.myCargoType.isDynamicallyCreated 
	and _ti.myPrimaryActualLocation &lt;&gt; null then
		self.myPrimaryActualLocation := _ti.myPrimaryActualLocation;
	endif;
		
	if self.myProduct &lt;&gt; null and self.myProduct.myCargoType &lt;&gt; null then
		self.cargoType := self.myProduct.myCargoType.id;
	endif;
	
	bb := _ti.CM_BreakBulkGeneric;

	self.widthString 	:= bb.widthString;
	self.heightString	:= bb.heightString;
	self.lengthString 	:= bb.lengthString;
	
	self.width			:= bb.width;
	self.height			:= bb.height;
	self.length			:= bb.length;
	
//	self.setQVW(bb.quantity, bb.volume, bb.weight);
	
	self.type			:= bb.type;
	//self.colour		:= bb.colour;					// PAR #33019
	self.setColourSorted(bb.colour);					// PAR #33019
	
	self.unsplitQuantity	:= bb.unsplitQuantity; 		// PAR #25926  	
	self.unsplitVolume		:= bb.unsplitVolume;		// PAR #25926	 	
	self.unsplitWeight		:= bb.unsplitWeight;		// PAR #25926	   
	
	
	if bb.myPalletDetailsTI &lt;&gt; null then
		self.setMyPalletTiDetails(	bb.myPalletDetailsTI.heatTreated,	//_heatTreated : Boolean;
									bb.myPalletDetailsTI.storeOnPallets,	//_storeOnPallets : Boolean;
									bb.myPalletDetailsTI.getPalletTypeObj	//_myPalletType :	CM_PalletType
									);
	//16 Jan 2020	NDL	TFS 48246 - New rule, always create a pallet details for 'cargo able to be stored on a pallet'
	elseif self.myPalletDetailsTI = null  and self.isPalletByDefault then
		self.setMyPalletTiDetails(	false,	//_heatTreated : Boolean;
									false,	//_storeOnPallets : Boolean;
									null	//_myPalletType :	CM_PalletType
									);

	endif;
	
	// jlika1 TFS 53316 --&gt;
	//self.diameter		:= bb.diameter;
	self.setDiameter(bb.getDiameter().Decimal); 			// ### TFS 54021 29June2022 NAVPW1
	//self.grade			:= bb.grade;
	self.setGrade(bb.getGrade()); 							// ### TFS 54021 29June2022 NAVPW1
	//self.grammage		:= bb.grammage;
	self.setGrammage(bb.getGrammage().Decimal); 			// ### TFS 54021 29June2022 NAVPW1
	//self.rollingLength	:= bb.rollingLength;
	self.setRollingLength(bb.getRollingLength().Decimal); 	// ### TFS 54021 29June2022 NAVPW1
	// jlika1 TFS 53316 &lt;--
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateActual" id="7f40b354-d594-4eac-87cb-4845e023d541">
        <updating/>
        <source>setForUpdateActual(_pxyTI: CM_BreakBulkGeneric; _tiUpdateCntrlr: CMIF_TIUpdateController input; _passport: CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 September 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 12/10/2009	cnwdap1		PAR #21139 Colour attribute added
// 25/03/2010	cnwdap1		PAR #23300 Unsplit values were not being set on update
// 03/12/2013	cnwdap1		PAR #33019 CCMS DPH 2285 Correct validation and updating of colour
// 11/05/2022	jlika1		TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
vars

begin
	
	
	self.heightString 		:= _pxyTI.heightString;
	self.widthString 		:= _pxyTI.widthString;
	self.lengthString 		:= _pxyTI.lengthString;
	self.type				:= _pxyTI.type;
	//self.colour			:= _pxyTI.colour;			// PAR #33019
	self.setColourSorted(_pxyTI.colour);				// PAR #33019
	self.unsplitQuantity	:= _pxyTI.unsplitQuantity;	//PAR #23300 
	self.unsplitVolume		:= _pxyTI.unsplitVolume;	//PAR #23300 
	self.unsplitWeight		:= _pxyTI.unsplitWeight;	//PAR #23300

	if _pxyTI.myPalletDetailsTI &lt;&gt; null then
		self.setMyPalletTiDetails(	_pxyTI.myPalletDetailsTI.heatTreated,	//_heatTreated : Boolean;
									_pxyTI.myPalletDetailsTI.storeOnPallets,	//_storeOnPallets : Boolean;
									_pxyTI.myPalletDetailsTI.getPalletTypeObj	//_myPalletType :	CM_PalletType
									);
	
	//21 Jan 2020	NDL	TFS 48248 - New rule, always create a pallet details for 'cargo able to be stored on a pallet'
	elseif self.myPalletDetailsTI = null and self.isPalletByDefault then
		self.setMyPalletTiDetails(	false,	//_heatTreated : Boolean;
									false,	//_storeOnPallets : Boolean;
									null	//_myPalletType :	CM_PalletType
									);
		
	endif;
	
	// jlika1 TFS 53316 --&gt;
	//self.diameter		:= _pxyTI.diameter;
	self.setDiameter(_pxyTI.getDiameter().Decimal); 			// ### TFS 54021 29June2022 NAVPW1
	//self.grade			:= _pxyTI.grade;
	self.setGrade(_pxyTI.getGrade());							// ### TFS 54021 29June2022 NAVPW1
	//self.grammage		:= _pxyTI.grammage;
	self.setGrammage(_pxyTI.getGrammage().Decimal); 			// ### TFS 54021 29June2022 NAVPW1
	//self.rollingLength	:= _pxyTI.rollingLength;
	self.setRollingLength(_pxyTI.getRollingLength().Decimal);	// ### TFS 54021 29June2022 NAVPW1
	// jlika1 TFS 53316 &lt;--
	
	inheritMethod(_pxyTI, _tiUpdateCntrlr, _passport);
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_BreakBulkGeneric"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
