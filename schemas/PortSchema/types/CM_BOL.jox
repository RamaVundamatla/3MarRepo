    <JadeMethod name="created" id="e44e0343-e6b3-448c-80dd-e09787402d9e">
        <updating/>
        <source>created(_passport : CM_Passport input) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		11 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 15 Dec 2022  navma1		Defect 55852: MTN - 1090 exception while loading a Ship Manifest and BOL via EDI
//----------------------------------------------------------------------
vars
	txnParams 	: CMIF_TITransactionController;
	trans 		: CM_BOLTransaction;
begin
	create txnParams transient;
	txnParams.type 		:= TRANS_TYPE_BOLCREATED;
	txnParams.noCharge := false; // TFS 3844 changed to false
	txnParams.userId 	:= _passport.userCode;
	txnParams.dateTime 	:= app.serverTimestampAtTrxStart;
	
	trans := self.createTransaction(txnParams, _passport).CM_BOLTransaction;
	
	if trans &lt;&gt; null then		//15.12.2022 navma1 #55852	
		trans.createCharge();	//06 Nov 2019	NDL	TFS 47100
	endif;
	
epilog
	delete txnParams;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="dae467a9-a90f-4a2d-9ec0-176494c56bb1">
        <updating/>
        <source>delete() updating;
// cnwrs1 june 2006 was missing
vars
	
	//15 Jul 2016	NDL	TFS 2329
	iter : Iterator;
	cmqfV : CMQF_VoyageGeneralCargoSummary;
begin

	//15 Jul 2016	NDL	TFS 2329
	iter := CMQF_VoyageGeneralCargoSummary.instances.createIterator;
	while iter.next(cmqfV) do
		if cmqfV.allBOLs.includes(self) then
			cmqfV.allBOLs.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="detachTI" id="893caca4-1ecb-4ed4-8c7a-e2bcb3c08ffa">
        <updating/>
        <source>detachTI(pChild : CM_TrackedItem input) updating;
//--------------------------------------------------------------
//Created: 04 February 2002 By: cnwgd1
//--------------------------------------------------------------
// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
vars

begin
	exclusiveLock(self);

	if pChild = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "No tracked item passed in", null, null);		
		return;
	endif;

	pChild.detachFromBOL(self);
	
	self.updateObjectEdition(self);	// par 30292
	
end;</source>
        <Parameter name="pChild" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="detachTIs" id="07015dfb-b6ac-4492-bb6e-c3ac4d0fd83f">
        <updating/>
        <source>detachTIs() updating;
//   Description : Removes all childen from the parents
//                 lists of associated child items.
vars
	aChild : CM_TrackedItem;
begin

	//-----------------
	// Iterate through the children, clearing reference
	// to the parent object... 
	//-----------------
	while self.allTrackedItems.size &gt; 0 do
		aChild := self.allTrackedItems.last();
		self.detachTI(aChild);
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="detailsIncludeCargoType" id="6d10d3ba-33ec-4aa2-8086-3c66f1ce81e5">
