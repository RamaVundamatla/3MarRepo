        <source>mnuInvoiceShow_click(menuItem: MenuItem input) updating;
/*
Purpose:			

Date		Who		Reason
28MAY2021	NAVAB1	TFS 51219
*/

vars
	table : Table;
	anObject : Object;
	invoice	: CM_Invoice;
	event : CMEVT_LocationActivity;
begin

	table := self.tblLocActivity;
	if table.row &gt; table.fixedRows then
		anObject := table.accessRow(table.row).itemObject;
		if anObject.isKindOf(CMEVT_LocationActivity) then
			event := anObject.CMEVT_LocationActivity;
			
			if event.allInvoiceLines.isEmpty() then
				return;
			endif;
			
			invoice := event.allInvoiceLines.first.invoice;
		endif;
		if invoice &lt;&gt; null then
			self.myAssistant.showInvoiceLineForm(invoice, self.myMasterMenuAction);
		endif;
	endif;
end;</source>
