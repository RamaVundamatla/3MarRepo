    <JadeMethod name="erase" id="b3473c1e-1813-4db2-a8c4-6b303f43baec">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			 // TFS 39618

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2019	jlgab1	Initial creation

*/

vars

begin
	if self.isTransient() then
		if self.myEmailTemplate &lt;&gt; null then
			self.myEmailTemplate.erase(NORMAL_ERASE);
		endif;
	endif;

	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="75c0207b-05e2-471c-a3a9-74dd6549a0b9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2019	jlgsl4	TFS39618

*/

vars

begin
	if _attrName = ETRow_EmailOptions then
		if self.myEmailTemplate &lt;&gt; null then
			return self.myEmailTemplate.subject;
		else
			return app.getErrorString(Not_Set);
		endif;
	elseif _attrName = ETRow_Id then	//01 Aug 2018	NDL	TFS 39900
			return self.id.asStringJMT;			
	elseif _attrName = ETRow_InvoiceProcess then
		return self.myInvoiceProcess.description;
	elseif _attrName = ETRow_Colour then
		return self.colour.display;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusColour" id="dc2399cd-e1d2-4984-8422-29d8a4813414">
        <source>getStatusColour() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2022	navmv20	Task 55549: UI - Add colour to Invoice List combo box and status column

*/

vars	
	invProcess : CM_InvoiceProcess;
	invStatus  : CM_InvoiceStatus;
begin
	invProcess := self.myInvoiceProcess;
	if invProcess &lt;&gt; null and invProcess.allStatuses &lt;&gt; null then
		invStatus := invProcess.allStatuses[self.id];
		if invStatus &lt;&gt; null then
			return invStatus.colour;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processStatus" id="77d248c3-58f7-49a3-8968-0b23219e2f9c">
        <updating/>
        <source>processStatus(_invoice : CM_Invoice input) updating;
/*

Purpose:	Replicates CM_Invoice::setForUpdateStatus functions	

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2018	jlgsl4	TFS 39618 - LNX - Invoice Approved Status
16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma

*/

vars
	email 			: CM_InvStatusDefaultEmail;
	emailController	: CMIF_EmailTemplateController;
	invoice 		: CM_Invoice;
	debtorInvType : CM_DebtorInvType;
	package			: CM_PackageInvoice;
	task			: CM_AutoTask;
	schedule		: CM_AutoSchedule;
	request			: BGP_Request;
	emailRequest	: BGP_EmailSendRequest;
	user			: CM_User;
	requests		: ObjectArray;

begin

	if app.isInProformaMode then		//16.10.2019 cnwma1 #46974
		return;
	endif;
	
	if app.isJMTUnitTest then
		return;
	endif;
	
	if app.isGarbageCollectionProcess then
		return;
	endif;
	
	if _invoice.isTransient then
		return;
	endif;
	
	if self.myEmailTemplate &lt;&gt; null and self.myEmailTemplate.toAddresses &lt;&gt; null then
		create email transient;
		create emailController transient;
		email.setEmailController(emailController);
		email.setFromEmailTemplate(self.myEmailTemplate);
	
		invoice := _invoice;
		 // TFS 39618 PATCH 1 if email.toAddresses &lt;&gt; null then
			invoice.emailNotify(email, false, null);
		 // TFS 39618 PATCH 1 endif;
	endif;
	
	 // ### JIRA 35468 31JUL2025 NAVAB1
	if _invoice.runPackages then
		if _invoice.isPostedDraft then
			debtorInvType := _invoice.debtor.allDebtorInvTypes[_invoice.invoiceType];
			if debtorInvType &lt;&gt; null then
				create requests transient;
				foreach package in debtorInvType.allPackageInvoices do
					foreach task in package.allTasks do
						schedule := task.allAutoSchedules.first;
						app.runEventScheduleInvoice(schedule, _invoice, requests);
					endforeach;
				endforeach;
			endif;
		
		endif;
	endif;
epilog
	delete requests;
	delete email;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="4f2d5770-57ee-4552-9dd6-5227dd405fbb">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jan 2019	jlgsl4	TFS39618

*/

vars

	pxyStatus : CM_InvoiceStatus;
	pxyEmailTemplate : CM_EmailTemplate;
	completedOK : Boolean;

begin
	pxyStatus := inheritMethod();
	
	if self.myEmailTemplate &lt;&gt; null then
		pxyEmailTemplate := self.myEmailTemplate.pxyCreateUpdateProxy();
		pxyEmailTemplate.setMyParent(pxyStatus);
	endif;
	pxyStatus.myInvoiceProcess := self.myInvoiceProcess;
	pxyStatus.myRoot := self.myRoot;
	
	completedOK := true;
	return pxyStatus;

epilog
	if not completedOK then
		delete pxyStatus;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setColour" id="2253ee3c-214e-4a37-8ad6-76d299a89e86">
        <updating/>
        <source>setColour(colour: Integer)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2022	navtnr20	 CR 55298 TASK 55547: Write upgrade script to set new colour attribute on CM_InvoiceStatus

*/

vars

begin
	self.colour := colour;
epilog

end;</source>
        <Parameter name="colour" type="Integer"/>
