    <JadeMethod name="calculateColourPercent" id="4de97c3c-9bc8-400c-893e-21bb9b9b2744">
        <source>calculateColourPercent(colourCounts : CM_ColourCountDict io) protected;
// Convert the raw count of each colour into a percentage of the total
vars
	total, percentTotal : Integer;
	colourCount : CM_ColourCount;
begin
	foreach colourCount in colourCounts do
		total := total + colourCount.count;
	endforeach;

	foreach colourCount in colourCounts do
		colourCount.percent := ((colourCount.count / total) * 100).Integer;
		percentTotal := percentTotal + colourCount.percent;
	endforeach;
	
	// make sure all adds up to 100%
	if total &gt; 0 and percentTotal &lt;&gt; 100 then
		colourCounts.first.percent := colourCounts.first.percent + 100 - percentTotal;
	endif;
	
end;
</source>
        <access>protected</access>
        <Parameter name="colourCounts" type="CM_ColourCountDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="canDisplayYardAllocation" id="d4794717-8e6f-4286-8357-20672eb11db6">
        <source>canDisplayYardAllocation(_yardAllocation : CM_YardAllocation) : Boolean protected;
//28 May 2008	cnwdw1	
// Is it ok to display this allocation?
vars
	selectedYardAllocation : CM_YardAllocation;
begin
	selectedYardAllocation := self.getSelectedYardAllocation();
	return selectedYardAllocation = _yardAllocation or 
		(not self.isNewYardAllocation and selectedYardAllocation = null);
end;</source>
        <access>protected</access>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
