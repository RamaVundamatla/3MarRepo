    <JadeMethod name="trxUnAssignWleFromWagon" id="45f1a19c-4d7f-4b39-8a64-4858154e7acd">
        <updating/>
        <source>trxUnAssignWleFromWagon(_wlesToUnassign : CM_WLEArray input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwndl1	Initial creation CCMS 1094

*/

vars

	wle : CM_WorkListEntry;
	
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _wlesToUnassign = null then
		self.raiseExceptionIfNull(_wlesToUnassign, app.getErrorString(Release_request));
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	beginTransaction;

	foreach wle in _wlesToUnassign do
		app.myUtilityUA.utlUnAssignWleFromWagon(wle.CM_YardWLE, _passport);
		if _passport.hasErrors then
			return;
		endif;
		//process.isCCMS1935; 	//12 May 2010 NDL	Otago CCMS 1935 testing... //cnwrd1 par 24169 11/6/2010
		// if unassigning, should un queue as well.
		app.myUtilityUA.utlUpdateWLEUnqueue(wle, _passport);
		if _passport.hasErrors then
			return;
		endif;
		
	endforeach;

epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_wlesToUnassign" type="CM_WLEArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUndeleteTITransaction" id="07e0d8bd-85fe-4609-82be-01347e7130ee">
        <updating/>
        <source>trxUndeleteTITransaction(_txn : CM_TITransaction input; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	12 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityUA.utlUndeleteTITransaction(_txn, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUndoReleaseByTypeAssign" id="1c378722-8c53-470b-a7ec-63cf1d9b6ed6">
        <updating/>
        <source>trxUndoReleaseByTypeAssign(_wle : CM_WorkListEntry input;
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
17 March 2014	cnwer1	Initial creation PAR  33718 - on Road Ops there is an undo for when the incorrect chassis are assigned to a release by type and moved onto the truck
													- can be done for any ti which is release by type and prior location is in the yard
													

*/

vars
	ti  : CM_TrackedItem;
	lc,
	priorLocation : CM_LocationsController;
	wle ,
	inChassisWLE : CM_WorkListEntry;
	inChassis : CM_TILC;
	hasChassis : Boolean;
begin
		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	self.raiseExceptionIfNull(_wle,"No Work List Entry");
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _wle.myTrackedItem = null then
		//can not unassign as there is no cargo assigned
		//doesn't have a ti so nothing to do
		app.raiseCMException(Cannot_unassign_no_cargo,null,null);
		return;
	endif;
	
	
	if  not _wle.isReleaseByType then
		//can not unassign as this is not a release by type
		app.raiseCMException(Cannot_unassign_not_release,null,null);
		return;
	endif;
	
	ti:= _wle.myTrackedItem;
	priorLocation:=ti.getPriorLocationLC();
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	//epr found Testing 842 have unqueue ti first
	app.myUtilityUA.utlUpdateWLEUnqueue(_wle, _passport);
	
	//unassign wle
	_wle.unassignTI();
	if _passport.hasErrors then
		return;
	endif;
	
	
	if  priorLocation &lt;&gt; ti.myPrimaryActualLocation then
		if _wle.isReceipt then
			lc :=_wle.getRoadReceiptLC();
			//if ti.myPrimaryActualLocation = 
			//receipt move if not on truck or the receival chassis
		else
		   //release move if on truck or on receival chassis
			lc:=_wle.getRoadReleaseLC();
		endif;
		
		if  ti.myPrimaryActualLocation  = lc then
			ti.moveToPriorLocation(_passport);
		endif;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	//epr 20/5/14
	_wle.job.rebuildStatus();
	app.myEventManager.createSingleObjInfoNoteEvt(_wle, _wle.getMyTerminal.getTerminalEvent(WLE_Update_Event), _wle);
	
	if _wle.isChassisToRelease then		
		inChassis:=_wle.job.CM_RoadJob.getChassis(true,hasChassis);
		if  inChassis &lt;&gt; null then
		
			foreach wle in _wle.job.workListEntries where wle.isReceipt do
				if wle.myTrackedItem = inChassis then
					inChassisWLE:=wle;
					break;
				endif;					
			endforeach;
			if inChassisWLE &lt;&gt; null then
				inChassisWLE.setStatus(WLE_UNACTIONED);
				app.myEventManager.createSingleObjInfoNoteEvt(inChassisWLE, inChassisWLE.getMyTerminal.getTerminalEvent(WLE_Update_Event), inChassisWLE);		// PAR #23794
			endif;
		endif;
		foreach wle in _wle.job.workListEntries where wle.isReleaseToChassis do
			lc:=_wle.getRoadReleaseLC();
			ti :=wle.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if  ti.myPrimaryActualLocation  = lc then
				ti.moveToPriorLocation(_passport);
				
			endif;
		endforeach;
	endif;
	
	//epr TFS 5597 2/8/17 
	if _wle.isAnyAmount and _wle.isAnyId then	
		if _passport.hasErrors then
			return;
		endif;
		wle:=_wle;
		delete wle;	
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
