    <JadeMethod name="trxResetTruckLocation" id="d04be823-82bf-43fc-96e4-5fa01894a88a">
        <updating/>
        <source>trxResetTruckLocation(_truck : CM_Vehicle input; _passport : CM_Passport input) updating;
/*

Date		Who		Reason
02 March 2017	cnwer1	Initial creation TFS

*/

vars

begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	self.raiseExceptionIfNull(_truck, 'Truck');
	
	if _truck.myPrimaryActualLocation = null then
		return;
	endif;
	
	//only reset if truck has a location and road jobs is empty
	if not _truck.allRoadJobs.isEmpty then
		return;
	endif;
	beginTransaction;

	_truck.resetLocationController(_passport);

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_truck" type="CM_Vehicle" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxResyncSnapshotCharge" id="52880179-1ebe-44bd-b9f7-96e938f41110">
        <updating/>
        <source>trxResyncSnapshotCharge(_snapshotBroker : CM_SnapShotServiceBroker; _snapshotData : CM_SnapshotData; _passport : CM_Passport input) updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlResyncSnapshotCharge(_snapshotBroker, _snapshotData, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_snapshotBroker" type="CM_SnapShotServiceBroker"/>
        <Parameter name="_snapshotData" type="CM_SnapshotData"/>
