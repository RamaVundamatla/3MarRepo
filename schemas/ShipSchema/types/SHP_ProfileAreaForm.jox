    <JadeMethod name="getMaxWidth" id="a461a370-5619-49a5-88b2-fd5af277aafa">
        <source>getMaxWidth() : Integer;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	myGridArea : CMUI_GridArea;
	theCol : CMUI_GridColumn;
begin
	myGridArea := self.sdf01.allGridAreasByRowColumn.first;
	
	if myGridArea &lt;&gt; null then
		theCol := myGridArea.allGridColumns.last;
		if theCol &lt;&gt; null then
			return (theCol.x2 + 100).Integer;
		endif;
	endif;
	
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalColour" id="e4cf56f5-0404-4654-8bf1-7b9fa9cb9d81">
        <source>getTotalColour(_idx : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		24 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	rgb, idx : Integer;
begin
	rgb := 253;
	
	foreach idx in 1 to _idx do
		rgb := rgb - 14;
	endforeach;
	
	if rgb &lt; 0 then
		rgb := 0;
	endif;
	return app.convertRGBToColor(rgb,rgb,rgb);

end;</source>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
