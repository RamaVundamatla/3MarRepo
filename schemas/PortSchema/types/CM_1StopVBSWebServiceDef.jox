    <JadeMethod name="getDisplayStringForAttribute" id="9ac431bc-7672-4721-bcd6-06a359526fb5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2021	navpw1	Initial creation TFS: 52268

*/

begin
	if _attrName = ETRow_WebServiceType then
		return ExternalWebService1StopVBS;
	elseif _attrName = ETRow_BaseEndPointGateEvent then
		return self.baseEndPointGateEvent;
	elseif _attrName = ETRow_ClientID then
		return self.cid;
	elseif _attrName = ETRow_SenderCode then
		return self.senderCode;
	elseif _attrName = ETRow_BaseEndPointSlots then
		return self.baseEndPointBookingSlots;
	elseif _attrName = ETRow_AuthKey then
		return self.authKey;
	elseif _attrName = ETRow_CustomerId then
		return self.customerCode;
	elseif _attrName = ETRow_FacilityId then
		return self.facilityId;
	elseif _attrName = ETRow_Terminal and self.myTerminal &lt;&gt; null then
		return self.myTerminal.name;
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
