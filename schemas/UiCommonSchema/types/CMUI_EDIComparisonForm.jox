    <JadeMethod name="loadAvailableAndSelectedFields" id="d883d9b5-c09d-4395-bc6c-de3cb1abe229">
        <source>loadAvailableAndSelectedFields()protected;
/*
Date		Who		Reason
31 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	collA, collS	:EntTableRowArray;
	etRow			:EntTableRow;
	groupbox		:CMUI_MultiSelectGroupBox;
	xml, value,
	keyValue		:String;
	userWindow		:CM_UserWindow;
	lastPos			:Integer;
begin
	create collA transient;
	
	self.getAllAvailableFields (collA);
	
	groupbox := self.grpSelect;
	
	groupbox.setAvailable (collA, true);
	
	userWindow := self.myUserWindow;
	
	if userWindow = null then
		return;
	endif;
	
	xml := userWindow.xmlInfo;
	
	if xml = null then
		return;
	endif;
	
	// now find any rows that are to be ignored for the purposes of the comparison
	create collS transient;
	
	value := xml.cnEcGetTagValueOfName((CMUI_MultiSelectGroupBox.XMLTag_ListTable &amp; self.grpSelect.name));
	
 	if value &lt;&gt; null then
 		value := value.trimCharacters(CrLf);

		lastPos := 1;
		
		while true do
			keyValue := value.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
			
			if keyValue = null then
				break;
			endif;
			
			// keyValue contains the ETRow name - not ideal flickng through the array like I know but it should have relatively few items
			foreach etRow in collA do
				if etRow.name = keyValue then
					collS.add (etRow);
					break;
				endif;
			endforeach;
			
			if lastPos = 0 then
				break;
			endif;			
		endwhile;
		
		self.grpSelect.setSelected(collS);
 	endif;
	
epilog
	delete collA;
	delete collS;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataTable" id="e0e000cb-4d6a-42b1-a3ae-fd99fcf76b2f">
        <updating/>
        <source>loadDataTable()updating, protected;
/*
Date		Who		Reason
31 July 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 05 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
*/
vars
	ediData	:CM_EDIData;
	tempEdiData : CM_EDIData;
	table	:CM_DataTable;
	ediTI : CM_EDITrackedItem;
	selectedRow,
	status, cols	:Integer;
	str		:String;
	dd		:DynaDictionary;
	lastMode, lastRelease	:String;
	gotException	:Boolean;
	ediTIColl : CM_EDITIById;
	ediTIHdr : CM_EDIRequestHeaderTI;
	tempEDIReleaseRequestTI : CM_EDIReleaseRequestTI;
begin	
	on Exception do app.handleDeletedObject (exception, ediData, gotException);
	
	ediData := self.myEDIData ;
	
	if ediData = null then
		// should never happen
		return;
	endif;
	
	table 		:= self.tblData;
	
	if self.isEditMode then
		selectedRow :=table.accessedRow.row;
	endif;
	
	table.rows	:= table.fixedRows;

	// lock EDI data before we do anything else - don't want it disappearing on us
	self.sharedLock (ediData);
	
	if gotException	then
		// ediData has been deleted - we should have got a notification (lets pretend we did)
		self.handleNotification (Object_Delete_Event, ediData, null);
		return;
	endif;

	// copy EDI TIs in mode/release id/cargo type/iso type/iso group order
	create dd transient;
	create ediTIColl transient;
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			ediTIColl.add(ediTI);
		elseif ediTI.isKindOf(CM_EDIRequestDetailTI) then
			if tempEdiData = null then
				tempEdiData := ediData.cloneSelf(true);
			endif;
			ediTIHdr := ediTI.CM_EDIRequestDetailTI.findMyEDITIHeader();
			if ediTIHdr = null then
				continue;
			endif;
			create tempEDIReleaseRequestTI transient;
			tempEDIReleaseRequestTI.setupFromRelReqMultiLine(ediTIHdr, ediTI.CM_EDIRequestDetailTI);
			ediTIColl.add(tempEDIReleaseRequestTI);
		endif;
	endforeach;
	self.getEDITrackedItemsInOrder(ediTIColl, dd);
	
	self.loadEDITrackedItems(dd);
	
	// make sure we don't hold locks - espceially if there is nothing to dislay
	self.unlock (ediData);
	
	if table.rows &lt;= table.fixedRows then
		// nothing was shown - so unload form
		app.msgBox(app.getErrorString (EDI_COMPARE_NODATA), self.caption, MsgBox_OK_Only);
		self.unloadForm;
	endif;
epilog
	delete dd;
//	ediTIColl.purge();
//	delete ediTIColl;
	// make sure we dont hold locks - if we got an exception
	self.unlock (ediData);
	
	if self.isEditMode then
		self.tblData.accessRow(selectedRow);
		self.tblData.selectRow (selectedRow, false);
	endif;
end;</source>
        <access>protected</access>
