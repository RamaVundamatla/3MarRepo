    <JadeMethod name="handleNotification" id="370bea15-5c65-4d79-8653-4aa1c5552f1d">
        <updating/>
        <source>handleNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 November 2016	cnwns1	Initial creation
30 Mar 2022      	navhl20 TFS 52777 EUP - INT - Generic API: record-scan
12 July 2022		navmd1	TFS 52777 Tidy up/review code
25/02/2025			naviv1	JIRA-29374- EUP | Transaction Instrumentation - Gate
14 Jan 2026 		navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	invalid 				: Boolean;
	edition 				: Integer;
	theVVR  				: CM_VehicleVisitRecord;
	theVVRD 				: CM_VehicleVisitRecordDetail;
	gateScanRecord 			: CM_GenericGateScanRecord;
	detailsChangedVehicle	: Boolean;
begin
	
	if _theObject = null then 
		return;
	endif;
		
	on Exception do app.handleDeletedObject(exception,_theObject,invalid);
	
	edition := _theObject.edition;
	if invalid then
		return;
	endif;	
	
	//Start TFS 52777
	if _theObject.isKindOf(CM_GenericGateScanRecord) then
		gateScanRecord := _theObject.CM_GenericGateScanRecord;
		if gateScanRecord.myTerminal &lt;&gt; self.myTerminal and self.myAssistant.allAssociatedDevices[gateScanRecord.deviceId] = null then
			return;
		endif;
		if _eventType = Object_Create_Event or _eventType = Object_Update_Event then
			if not self.clearingForm then
				self.myAssistant.populateScanData(true, false, detailsChangedVehicle, self.txtRegno, null, null, null, null,
					null, null, self.txtWeightOUT, gateScanRecord);
			endif;
			return;
		endif;
	endif;
	//End TFS 52777
	
	if not _theObject.isA(CM_VehicleVisitRecordDetail) then
		return;
	endif;
	
	if _theObject.getMyTerminal() &lt;&gt; self.getMyTerminal() then
		return;
	endif;
	
	theVVRD := _theObject.CM_VehicleVisitRecordDetail;
	theVVR := theVVRD.myVehicleVisitRecord;
	
	if not	theVVR.isBulkGateVVR then
		return;
	endif;
	
	if theVVR.hasBulkGateOut() or theVVR.hasBeenCanceled() then
		self.updateTable(theVVR,false);
	else
		self.updateTable(theVVR,true);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="cb895de4-5c1a-4d6e-b061-df60b32c5225">
        <updating/>
        <source>handleNotifications(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) protected,updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 November 2016	cnwns1	Initial creation
30 Mar 2022      	navhl20 TFS 52777 EUP - INT - Generic API: record-scan
12 July 2022		navmd1	TFS 52777 Tidy up/review code
18 October 2022		navpw1	TFS: 54311 - Added user notifications for Generic API: record-scan
25/02/2025			naviv1	JIRA-29374- EUP | Transaction Instrumentation - Gate
14 Jan 2026 		navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)

*/

vars
	invalid 				: Boolean;
	edition 				: Integer;
	theVVR  				: CM_VehicleVisitRecord;
	theVVRD 				: CM_VehicleVisitRecordDetail;
	gateScanRecord 			: CM_GenericGateScanRecord;
	detailsChangedVehicle	: Boolean;
begin
	
	if (_theObject = null or _userInfo = null) or (_eventType &lt;&gt; EVENT_GATESCAN_CREATE and _eventType &lt;&gt; EVENT_GATESCAN_UPDATE) then
		return;
	endif;
		
	if _theObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,_theObject,invalid);
		
		edition := _theObject.edition;
		if invalid then
			return;
		endif;
		
		on Exception do null;
	endif;
	
	if _userInfo &lt;&gt; null then
		invalid := false;
		on Exception do app.handleDeletedObject(exception,_userInfo.Object,invalid);
		
		edition := _userInfo.Object.edition;
		if invalid then
			return;
		endif;
		
		on Exception do null;
	endif;
	
	//Start TFS 52777
	if _userInfo.isKindOf(CM_GenericGateScanRecord) then
		gateScanRecord := _userInfo.CM_GenericGateScanRecord;
		
		if gateScanRecord.myTerminal &lt;&gt; self.myTerminal and self.myAssistant.allAssociatedDevices[gateScanRecord.deviceId] = null then
			return;
		endif;
		
		if _eventType = EVENT_GATESCAN_CREATE or _eventType = EVENT_GATESCAN_UPDATE then
			if not self.clearingForm then
				self.myAssistant.populateScanData(true, false, detailsChangedVehicle, self.txtRegno, null, null, null, null,
					null, null, self.txtWeightOUT, gateScanRecord);
			endif;
			return;
		endif;
	endif;
	//End TFS 52777
	
	if not _theObject.isA(CM_VehicleVisitRecordDetail) then
		return;
	endif;
	
	if _theObject.getMyTerminal() &lt;&gt; self.getMyTerminal() then
		return;
	endif;
	
	theVVRD := _theObject.CM_VehicleVisitRecordDetail;
	theVVR := theVVRD.myVehicleVisitRecord;
	
	if not	theVVR.isBulkGateVVR then
		return;
	endif;
	
	if theVVR.hasBulkGateOut() or theVVR.hasBeenCanceled() then
		self.updateTable(theVVR,false);
	else
		self.updateTable(theVVR,true);
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleSpecialDevNoConn" id="c7fb2ec7-dfc9-4e26-ae61-862f6d5d988d">
        <updating/>
        <source>handleSpecialDevNoConn(_connectionException : ConnectionException) : Integer updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2021	navndl1	Initial creation	TFS 51575

*/

vars

begin

	if _connectionException.errorCode = 31004	//Connection failed to connect
	or _connectionException.errorCode = 31001	//Connection no target host name specified
	then
		executeWhen JMTDevelopmentEnvironment;
		if self.myOtherWeightIntController &lt;&gt; null and self.myOtherWeightIntController.testMode &gt; 0 then
			self.myOtherWeightIntController.diagnosticLog(method.qualifiedName&amp;" No Connection - generating Dev Env Test Data");
			self.myOtherWeightIntController.generateDevTestData();
			return Ex_Resume_Next;
		endif;
		endExecuteWhen;
	endif;
	
	return Ex_Pass_Back;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_connectionException" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="a0f52f8f-10fc-4cc7-a86d-bd1a27198b98">
