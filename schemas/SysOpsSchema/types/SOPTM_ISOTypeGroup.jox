    <JadeMethod name="doDelete" id="579d9709-42da-4f74-a14b-f0d4dc0bd1bb">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     02 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.myTrxDA.trxDeleteISOTypeGroup(pObj.CM_ISOTypeGroup, app.myPassport);

end;</source>
