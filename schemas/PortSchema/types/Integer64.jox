    <JadeMethod name="stringWithLeadingZeros" id="0759b8d5-8840-4a0f-9a7e-b0871f9e23e8">
        <source>stringWithLeadingZeros(digits : Integer) : String;
//
//18 Dec 2015	cnwrs1	Par 37340 Cams is crashing with 4013 error (Result of expression overflows Integer precision)
//

vars
	
begin
	return self.padLeadingWith("0", digits);
	
