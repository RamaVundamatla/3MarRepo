        <source>setFormObject(_obj: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2023	jlier1	Initial creation 56856

*/

vars

begin
	if _obj = null then
		return;
	endif;
	
	if _obj.isKindOf(CM_Invoice) then	
		self.filterInvoice:=_obj.CM_Invoice;
	endif;
epilog

end;</source>
