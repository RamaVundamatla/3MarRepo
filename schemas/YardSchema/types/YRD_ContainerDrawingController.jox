    <JadeMethod name="getSelectedObjectsXYs" id="6df7dc46-ef92-45fa-8887-932ba3d50e22">
        <updating/>
        <source>getSelectedObjectsXYs(_xys: IntegerArray input) updating;
// ---------------------------------------------------------------------------
// Created:		02 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	key1, key2 : Point;
	extra : Integer;
begin
	_xys.clear;
	
	foreach anObject in self.allSelectedObjects do
		self.allGridObjects.findObjectInDictGetXY(anObject,key1, key2);	
		extra := 0;
		/* PAR 25634
		if anObject.isKindOf(CM_Container) then
			if anObject.CM_Container.is40 then
				extra := key2.x - key1.x + 2;
			endif;
		endif;
		*/
		_xys.add(key1.x);
		_xys.add(key1.y);
		_xys.add(key2.x + extra);
		_xys.add(key2.y);
	endforeach;
end;</source>
        <Parameter name="_xys" type="IntegerArray" usage="input"/>
    </JadeMethod>
