    <JadeMethod name="jtdCmdSetProfile" id="b5688537-7c64-4297-8f84-b322d1aad5cd">
        <updating/>
        <source>jtdCmdSetProfile(param : String) updating, protected;

begin
	self.jtdAllMethodProfilesRun.clear;
	
	app.jtdMyContext.jtdSetDriverProfile(param);

	self.jtdSetState(self.jtdState, self.statusLine.caption);
	self.jtdSetProfileBubbleHelp;

	// send a ping to let controllers know about our new profile
	system.causeEvent(app.jtdMyContext.jtdPingResponseEventNumber, true,
		self.jtdGetPingResponseString);
end;</source>
