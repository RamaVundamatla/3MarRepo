    <JadeMethod name="setup" id="f8684443-f915-4447-8323-548894c17c78">
        <updating/>
        <source>setup(_debtor : CM_Debtor; _invLineType : CM_InvoiceLineDesc; _code : String) updating;
// for transient instances, from maintenance
vars

begin
	self.myInvoiceLineType := _invLineType;
	self.myDebtor := _debtor;
	self.otherCode := _code;
end;
</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_code" type="String"/>
