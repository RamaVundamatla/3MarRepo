<Class name="Reference">
    <JadeMethod name="cnEcIsReference" id="719e3de9-f995-455d-b89f-4e11a3062646">
        <source>cnEcIsReference(): Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a
//				reference object.
//
// Parameters:	None
//
// Returns:		True if the receiver is a reference, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
