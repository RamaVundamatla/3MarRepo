    <JadeMethod name="btnLoadFile_click" id="be093200-8a7b-4003-aae3-6e1b925c068d">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLoadFile_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2024	navsp1	Initial creation

*/

begin
	app.mousePointer	:=	Busy;
	
	if self.txtFileName.text = null then	//MTN-33537	
		if self.getNewHSCodeFile() then		//MTN-33537
			self.doLoadNewFile(false);		//MTN-33537
		endif;								//MTN-33537
	else
		self.doLoadNewFile(false);
	endif;
	
epilog
	
	app.mousePointer	:=	Busy;
end;</source>
