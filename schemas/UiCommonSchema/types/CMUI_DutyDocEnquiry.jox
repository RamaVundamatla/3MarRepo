    <JadeMethod name="doDelete" id="a82ca516-394c-412d-96c3-253a927652c9">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189
06 August   2014    cnwma1  PAR 34408 Credit Customer current charges
*/

vars

	dutyDoc 					: CM_Object;
	theReturn 					: Integer;
	bulkRelease 				: CM_BulkRelease;  		 
	tis							: CM_TISet;		   		 
	ti							: CM_TrackedItem; 	 	 
	invoice						: CM_Invoice;	   		 
	invoiceLine, pxyInvoiceLine : CM_InvoiceLine;		 
	invoiceStatus				: CMIF_InvoiceStatus;	 
	duty						: CM_DutyDoc;			 
	txn 						: CM_TITransaction; 	 
	txnSet 						: CM_TITransactionSet;   
	invoiceLineSet 				: CM_InvoiceLineSet;  
	dutyDocItem,pxyDocItem		: CM_DutyDocItem;
begin
	//inheritMethod();
	if self.tblData.allSelectedObjects.isEmpty then
		return false;
	endif;
	
	dutyDoc := self.tblData.allSelectedObjects.first.CM_Object;
	duty :=dutyDoc.CM_DutyDoc;

	create tis transient;
	// void All Invoice Lines for the dutydoc Items
	duty.getTIsFor(duty.allDutyDocItems, tis);	
		foreach ti in tis   do
			create txnSet transient;
			create invoiceLineSet transient;
			txnSet := ti.getTransOfType(TRANS_TYPE_DUTY_CHARGE);
				foreach txn in txnSet do
					if txn.myInvoiceLine &lt;&gt; null then
				        if  txn.myInvoiceLine.trackedItem = ti and txn.myInvoiceLine.voided=false then
							invoiceLineSet.addNoDuplicates(txn.myInvoiceLine,false);
						endif;
					endif;
				endforeach;
				//invoiceLine := invoiceLineSet.first;
				foreach invoiceLine in invoiceLineSet do
					if invoiceLine &lt;&gt; null and invoiceLine.status &lt;&gt; 1 then
						create invoiceStatus transient;
						pxyInvoiceLine := invoiceLine.pxyGetProxyObject();
						if pxyInvoiceLine = null then
							pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
						endif;
					invoiceStatus.allInvoiceLines.add(pxyInvoiceLine);
					invoiceStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;
					app.myTrxUA.trxUpdateInvoiceStatus(invoiceStatus, app.myPassport);
					 delete pxyInvoiceLine;
					 delete invoiceStatus;
						if app.myPassport.trxCompletedOK then
							// Clear errors/warnings from form and err/warnings window
							self.clearErrorWarnings();
						endif;
					endif;
				endforeach;
		endforeach;
		
		// Delete all DutyDocItems
		foreach dutyDocItem in duty.allDutyDocItems do
			pxyDocItem := dutyDocItem.pxyGetProxyObject();
				if pxyDocItem = null then
					beginLoad;
						pxyDocItem := app.createUpdateProxy(dutyDocItem).CM_DutyDocItem;
					endLoad;
				endif;
				pxyDocItem.setProxyDutyDoc(null);
				pxyDocItem.setDutyItemValue();
				app.myTrxUA.trxUpdateDutyDocItem( pxyDocItem, app.myPassport );      
				if not app.myPassport.trxCompletedOK then
					app.showErrorWarningDialog('Delete Duty Doc Item', app.myPassport, ErrWarnMode_Update);
					self.setAllErrorWarnings(app.myPassport);	
				else
					self.clearErrorWarnings();
				endif;
				delete pxyDocItem;
		endforeach;
	  // Void All invoice lines for the Extra Charges   // cnwma1 31/07/2014 PAR 34408
	   // Non Cargo Charges
	if duty.dutyDeposit = 0 then
		foreach invoice in duty.getMyDebtor.allInvoices where invoice.isVoided = false and invoice.invoiceType.description="Non Cargo Charges" do
				foreach invoiceLine in invoice.invoiceLines where invoiceLine.voided = false and invoiceLine.remarks =duty.id do
						create invoiceStatus transient;
							pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
							invoiceStatus.allInvoiceLines.add(pxyInvoiceLine);
							invoiceStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;
							app.myTrxUA.trxUpdateInvoiceStatus(invoiceStatus, app.myPassport);
							delete invoiceStatus;
							delete pxyInvoiceLine;
							if app.myPassport.trxCompletedOK then
								// Clear errors/warnings from form and err/warnings window
								self.clearErrorWarnings();
							endif;
				endforeach;
		endforeach;
	endif;
	
	// Delete Release Request  // cnwma1 31/07/2014 PAR 34408
	bulkRelease := self.myTerminal.getBulkReleaseFromCode(duty.id);
	if bulkRelease &lt;&gt; null then
		app.myTrxDA.trxDeleteBulkRelease(bulkRelease, app.myPassport);
	endif;
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorWarningDialog('Delete Release', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	else
		self.clearErrorWarnings();
	endif;
	
	while true do
		app.myTrxDA.trxDeleteCMObject(dutyDoc,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	return true;

epilog
		if invoiceStatus &lt;&gt; null then
			invoiceStatus.allInvoiceLines.purge;
		endif;
		delete pxyInvoiceLine;
		delete invoiceStatus;
		delete invoiceLineSet;
		delete txnSet;
		delete tis;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="f0e2956a-cba7-4766-85f2-8d0e7447d016">
        <updating/>
        <source>doPrint() updating;
