    <JadeMethod name="finalize" id="154e3ccb-6ed6-48a6-8eba-063293ea5eae">
        <updating/>
        <source>finalize() updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02 Jul 2008	cnwkpd1		PAR #17408 - handle invalid login event
// 31/08/2010	cnwdad1		PAR #20064.
// 21 Nov 2019	jlgrs1	TFS 47654 cleanup CM_AlternativeDict reference
// ---------------------------------------------------------------------------
vars
	obj	: Object;
	cls	: Class;
	invalidEvent		: Boolean;
	
begin
	if process.isInTransactionState then
		// should never happen but done here as
		// some peer schema stuff assumes that
		// it would never be called in trx state
		abortTransaction;
	endif;

	self.endNotificationForSubscriber(self);

	on Exception do null global;
	on LockException do null global;
	on DeadlockException do null global;

	delete self.myTrxCA;
	delete self.myTrxUA;
	delete self.myTrxDA;

	delete self.myUtilityCA;
	delete self.myUtilityUA;
	delete self.myUtilityDA;

	delete self.myValCA;
	delete self.myValUA;
	delete self.myValDA;
	
	delete self.myQAFilter;
	delete self.myQASelector;
	delete self.myQASimple;
	
	delete self.myAA;
	delete self.myEventManager;
	
	delete self.alertManager;
	delete self.myProxyManager;
	
	delete self.myFileManager;
	delete self.myHMSRvTide;
	
	delete self.myTestRecorderAgent;

	// deliberately obtuse for security reasons
	if self.myCheckerObject &lt;&gt; null then
		if not app.isSDSSecondaryDB() then	//cnwrs1 nov 2005 make JMTTerminal work on SDSsecondary
			delete self.myCheckerObject;
		endif;
	endif;
	
	if self.myLogFile &lt;&gt; null then
		self.exitLogFile();
	endif;
	
	if self.myPassport &lt;&gt; null and self.myPassport.myEventLogin &lt;&gt; null and not self.isWebApp then
		on Exception do app.handleDeletedObject(exception, self.myPassport.myEventLogin, invalidEvent);	// PAR #17408
		if self.myPassport.myEventLogin.myEventLogout = null then
			// have not recorded logoff event so do now
			self.myPassport.doLogoff();
		endif;
	endif;
	
	delete self.myPassport;
	delete self.myHookAgent;
	delete self.myYAAgent;
	

	if self.allTITransClassNames &lt;&gt; null then
		self.allTITransClassNames.purge();
	endif;
	
	delete self.allTITransClassNames;
	delete self.myLocaleInfoJMT;		// cnwdad1 31/08/2010 - PAR #20064.
	delete self.myTimeZoneHelper;
	delete self.myAlternateDict;
	
	delete self.mySSOAgent; 	//20.07.2022 navam1 #52824
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="finalizeODBCServer" id="854edf99-9840-4dbc-b8e7-b1ee504c1b3c">
