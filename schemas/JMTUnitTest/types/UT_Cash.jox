	self.deleteContainer("REEF4077447");
	cargo := self.addContainerAtLocation("REEF4077447", self.myOperator, "4332", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);

	// ### 40 EMPTY
	self.deleteContainer("MTMU8099001");
	cargo := self.addContainerAtLocation("MTMU8099001", self.myOperator, "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("MTMU8099002");
	cargo := self.addContainerAtLocation("MTMU8099002", self.myOperator, "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("MTMU8099003");
	cargo := self.addContainerAtLocation("MTMU8099003", self.myOperator, "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("MTMU8099004");
	cargo := self.addContainerAtLocation("MTMU8099004", self.myOperator, "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
