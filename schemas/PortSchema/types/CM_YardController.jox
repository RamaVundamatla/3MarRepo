    <JadeMethod name="getRelativeLocationCell" id="7f67826f-52bb-47a6-9de2-4fa4ee19b18d">
        <source>getRelativeLocationCell( _yardCells : CM_YALocationCellArray io; _relativeHeight : Real; _offSet : Real ):CM_YALocationCell;

/*

Purpose:		Find the 'cell' that is represented in the stack at
				the position clicked...	

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	numInStack : Integer;
	heightOfOne : Real;
	pos : Integer;
	cell : CM_YALocationCell;
	topOfCell : Real;

begin

	numInStack := self.allYAYardLocationCells.size;

	if numInStack = 0 then
		return null;
	endif;
	
	heightOfOne := _relativeHeight / numInStack;
	
	foreach pos in 1 to numInStack do
		cell := self.allYAYardLocationCells[pos];
		topOfCell := heightOfOne * pos;
		if cell.isAvailForMultiMove then
			_yardCells.add(cell);
		endif;
		if _offSet &lt;= topOfCell then
			return cell;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_yardCells" type="CM_YALocationCellArray" usage="io"/>
        <Parameter name="_relativeHeight" type="Real"/>
        <Parameter name="_offSet" type="Real"/>
        <ReturnType type="CM_YALocationCell"/>
    </JadeMethod>
    <JadeMethod name="getRestrictionsDesc" id="c641f291-52ef-405f-9e1f-8f3258fab391">
        <source>getRestrictionsDesc(mode : Integer) : String;

vars

begin

	if mode = NULL_RESTRICTION then
		return self.allLabourRestrictions.getAllCodes();
	elseif mode = LABOUR_RESTRICTION then
		return self.allLabourRestrictions.getAllCodes();
	elseif mode = LOCATION_RESTRICTION then
		return self.myLocationRestriction.id;
	else //oops this should never happen
		app.setContinueCMExceptions(false);
	//	app.raiseCMException(ERR_INVALID_MODE, null, null);
		app.raiseCMException1( Invalid_move_mode_passed, method.qualifiedName, null, null );	//13 Apr 2021	NDL	TFS 50906
		return null;	
	endif;

	return null;
end;</source>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
