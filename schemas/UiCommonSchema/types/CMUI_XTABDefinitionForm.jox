    <JadeMethod name="doBtnDeleteDefn" id="b6d0facb-d5f8-40f1-86a0-df75ec13af6a">
        <updating/>
        <source>doBtnDeleteDefn() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.lstSavedDisplays.listObject = null then
		// nothing selected to delete.
		app.msgBox(	app.getErrorString1( CMUI_YA_NO_DELETE_ITEM, app.getErrorString( XTAB_SummaryDefinition ) ),
					app.getErrorString( Error ),
					MsgBox_OK_Only );
		return;
	endif;
	
	// check if really want to delete it and make them select Yes.
	if not self.confirmDelete(	app.getErrorString( XTAB_SummaryDefinition ),
								self.lstSavedDisplays.listObject.CM_OutputFormat_XTAB.name.display ) then
		return;
	endif;
	
	// Ok so do the required deletion.
	if self.doDeleteXTAB() then
		// remove entry we have just deleted
		self.lstSavedDisplays.removeItem( lstSavedDisplays.listIndex );
		// and refresh the screen correctly.
		self.myQueryDefinition	:= null;			// force the property table to be refreshed.
		self.doSelectXTAB;
		self.zClearProxyDetails;
		self.tblProperties.clearAllSelected;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnHideDetails" id="fc538549-fa87-47b6-ba26-1a64d7962a87">
        <updating/>
        <source>doBtnHideDetails() updating, protected;

// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	oldHeight		: Integer;
	oldWidth		: Integer;
	
begin
	if self.windowState = self.WindowState_Maximized then
		self.windowState := self.WindowState_Normal;
	endif;
	
	oldHeight 						:= self.jdbSavedDisplays.height.Integer;
	oldWidth				 		:= self.jdbSavedDisplays.width.Integer;
	self.jdbRight.visible			:= false;
	self.jdbProperties.visible		:= false;
	self.clientHeight				:= oldHeight;
	self.clientWidth 				:= oldWidth;
	self.minimumHeight				:= 400;
	self.minimumWidth				:= 360;
	self.height						:= self.minimumHeight;
	self.width						:= self.minimumWidth;
	self.frmMain.width				:= self.clientWidth;
	self.btnRunDefn.left			:= self.btnShowDetails.left;
	
	// make certain buttons invisible/visible but still enabled via the context menu.
	enableDisableCtrsForHideShow( false );
	
	self.doResize;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnNewDefn" id="c01560b6-aadc-4d11-be34-8dc8a4363a50">
        <updating/>
        <source>doBtnNewDefn(_createProxy : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	index		: Integer;
begin
	// if creating a new one then the user will need the form expanded,
	// except when this form is first opened it will be minimised later.
	if self.btnShowDetails.visible then
		self.doBtnShowDetails;
	endif;
	
	// if the last entry was not saved and it has not been made persistent then remove the entry in the listbox.
	if not self.btnSaveAsDefn.enabled then
		self.removeDummyListEntry;
	endif;
	
	self.zClearProxyDetails();			// cnwrl1 22/06/2009 PAR 19993
	self.myCurrentXTAB	:= null;
	self.clearErrorWarnings();
	self.formMode		:= Mode_Add;

	if self.myProxyXTAB &lt;&gt; null then
		delete self.myProxyXTAB;
	endif;
	
	
	if _createProxy then
		// create proxy for new item
		self.createProxyForNewXTAB;		// refactored code into this method so could be re-implemented
		// add proxy into tree (alphabetically)
		index										:= self.lstSavedDisplays.addItem( self.myProxyXTAB.name );
		self.lstSavedDisplays.itemObject[ index ]	:= self.myProxyXTAB;
		self.lstSavedDisplays.listIndex				:= index;
	endif;
	
		
	// display proxy
	self.myQueryDefinition	:= null;			// force the property table to be refreshed.
	self.displayXTABDefinition( self.myProxyXTAB );
	self.txtName.setFocus;

	// With latest version confirm that the object can be edited.
	self.zSetControls;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_createProxy" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnRunDefn" id="4c056321-7901-4c1c-b384-f42a239da9af">
        <updating/>
        <source>doBtnRunDefn()protected, updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/12/2009	cnwcs5		par 21848 - remove workaround code
// ---------------------------------------------------------------------------
vars
	proxyFormat	: CM_OutputFormat_XTAB; 
	
begin
	// NOTE: This method is reimplemented in the modal version of this form, becareful what you do here!
	
	if self.myProxyXTAB &lt;&gt; null then
		proxyFormat			:= self.myProxyXTAB;
		// reset myProxyXTAB so does not get deleted when form is closed if doing btnRunDefn.
		self.myProxyXTAB	:= null;
	elseif self.myCurrentXTAB &lt;&gt; null then
		proxyFormat := self.myCurrentXTAB.cloneSelf (true);
	endif;
	
	if proxyFormat = null then
		return;
	endif;
	
//	if zValidationPAR19043( proxyFormat ) then
//		return;
//	endif;
	
	if not self.myChildCollection.isEmpty then
		self.myAssistant.showXTABDisplayForm( proxyFormat, self.myCurrentXTAB, self.currentXTABEdition, self.myChildCollection, self.isVoyageCCMode ); // PAR 21746
	else
		self.myAssistant.showXTABDisplayForm( proxyFormat, self.myCurrentXTAB, self.currentXTABEdition, self.myCollection, self.isVoyageCCMode );
	endif;
	self.unloadForm;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnSaveAsCancel" id="0d5bb6b3-6097-4273-b03f-12749c7589cc">
