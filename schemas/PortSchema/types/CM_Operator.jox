        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars
	cargoEntity : CMIF_RefBizunitScoped;
begin

	if _opsViewTable.isKindOf(CMIF_RefBizunitScoped) then
		cargoEntity := _opsViewTable.CMIF_RefBizunitScoped;
		cargoEntity.tableName := cargoEntity.Ref_bizunit_scoped;
		
		cargoEntity.gkey := cargoEntity.generateFullGKey(self, "");
	
		cargoEntity.id := self.code;
		cargoEntity.name := self.description;
