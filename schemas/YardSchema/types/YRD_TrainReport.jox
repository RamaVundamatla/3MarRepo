    <JadeMethod name="setSelectedProfiles" id="ea699156-b188-45aa-a72a-283b02d79f7e">
        <source>setSelectedProfiles(_strProfiles: StringArray input);
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_strProfiles.clear;
	if self.chkPrintCargoOP.value then
		_strProfiles.add('By Operator');
	endif;
	
	if self.chkPrintCargoWAG.value then
		_strProfiles.add('By Wagon');
	endif;
	
	if self.chkPrintCargoCON.value then
		_strProfiles.add('By Consignee');
	endif;
end;</source>
        <Parameter name="_strProfiles" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="889e4ae6-a4d4-41d1-a682-8fe4cfef7188">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     05 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	defaultTrain : CM_Train;
	parentForm	 : CM_BaseForm;
begin

	inheritMethod();
	
	app.mousePointer := MousePointer_Default;
	self.handleMenusForModalDisplay();
	
	self.btnOk.caption := app.getErrorString(INV_Print);	
	self.showPrinterName();
	
	defaultTrain := self.myDefaultTrain;
	
	if defaultTrain &lt;&gt; null then
		lblTrainName.caption := defaultTrain.code &amp; " " &amp; defaultTrain.scheduledArrivalDT.asStringJMT() &amp; " (" &amp; defaultTrain.getConfirmedStatus(true) &amp; ")";
	endif;
	
	parentForm := self.myParentForm;
	
	if parentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(YRD_TrainForm) then
			self.chkPrintTrains.visible 	:= false;
		elseif parentForm.isKindOf(YRD_TrainEnquiry) then
			self.chkPrintTrains.visible 	:= true;
			self.chkPrintTrains.zOrder(1);
			self.chkPrintWagons.visible	 	:= false;
			self.chkPrintStats.visible 		:= false;
			self.chkPrintTrans.visible 		:= false;
			self.chkPrintWarnings.visible   := false;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showPrinterName" id="a85bd42b-8d0f-4e6c-88e2-0b24b5d4267b">
        <source>showPrinterName();
// ---------------------------------------------------------------------------
// Created:     07 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.picPrinter.bubbleHelp := app.getErrorString1(PRINT_MESS_PT1, app.printer.getPrinterName() ) &amp; Cr &amp;  app.getErrorString(PRINT_MESS_PT2);
	lblPrintName.caption := app.printer.getPrinterName();
	// "Current Printer is '" &amp; app.printer.getPrinterName() &amp; "'." &amp; Cr &amp; "Double click for printer options...";
epilog

end;</source>
