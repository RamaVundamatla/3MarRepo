    <JadeMethod name="moveField" id="1b8f75d5-9cf2-40de-8142-70e042452ed2">
        <updating/>
        <source>moveField(pIsRight: Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentFieldNo	: Integer;
	newFieldNo		: Integer;
	
begin
	currentFieldNo := self.getCurrentFieldNumber();
	
	if pIsRight then
		// move one field to the right
		newFieldNo := currentFieldNo + 1; 
		// check for wrapping of fields
		if self.formatString = "1" and newFieldNo = 3 then
			newFieldNo := 1;
		elseif self.formatString = self.FORMAT2 and newFieldNo = 4 then
			newFieldNo := 1;
		endif;
	else
		// move one field to the left
		newFieldNo := currentFieldNo - 1; 
		// check for wrapping of fields
		if self.formatString = "1" and newFieldNo = 0 then
			newFieldNo := 2;
		elseif self.formatString = "2" and newFieldNo = 0 then
			newFieldNo := 3;
		endif;
	endif;
	
	self.selectFieldNumber(newFieldNo);
end;</source>
        <access>protected</access>
        <Parameter name="pIsRight" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processArrowKey" id="f54dcffd-b81f-4dba-829b-6f68c0fa8316">
        <updating/>
        <source>processArrowKey(pKeyCode: Integer io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.checkAllSelected();
	inheritMethod(pKeyCode);
	
	if (pKeyCode = JSS_KEY_ARROWUP) then
		self.alterField(true);
		pKeyCode	:=	0;
	endif;
	
	if (pKeyCode = JSS_KEY_ARROWDOWN) then
		self.alterField(false);
		pKeyCode	:=	0;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pKeyCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processNumberKey" id="2735408c-8f3f-4f0c-8bc3-abd6b8104463">
        <updating/>
        <source>processNumberKey(pKeyCode: Integer io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	originalTime	: Time;
	fieldNumber		: Integer;
	modValue		: Integer;
	newTextValue	: Integer;
	keyPressed		: Integer;

begin
	self.checkAllSelected();
	
	if (pKeyCode &gt;= J_key_0 and pKeyCode &lt;= J_key_9) then
		keyPressed	:=	pKeyCode - J_key_0;
	elseif (pKeyCode &gt;= JSS_KEY_PAD0 and pKeyCode &lt;= JSS_KEY_PAD9) then		// Check numeric keypad.
		keyPressed	:=	pKeyCode - JSS_KEY_PAD0;
	endif;
	
	originalTime	:=	self.getTime();
	fieldNumber		:=	self.getCurrentFieldNumber();
	
	if fieldNumber = 1 then
		// hour value
		modValue	:=	24;
	elseif fieldNumber = 2 then
		// minute value
		modValue	:=	60;
	else
		// second value
		modValue	:=	60;
	endif;
	
	if selLength = 2 then
		// replace the whole selected area		
		newTextValue	:=	keyPressed;
		
		if newTextValue &lt; modValue then
			self.selText	:=	newTextValue.String;
		endif;
	else
		// add onto the end of the current text
		newTextValue	:=	(self.selText.Integer * 10) + (keyPressed);
		
		if newTextValue &lt; modValue then
			self.selText	:=	newTextValue.String.padLeadingZeros(2);
		else
			newTextValue	:=	keyPressed;
			self.selText	:=	newTextValue.String;
		endif;
	endif;
	
	self.thinClientUpdate();
	
	if self.getTime() &lt;&gt; originalTime then
		//setTime(getTime());
	endif;
	
	self.selectFieldNumber(fieldNumber);
end;</source>
        <access>protected</access>
        <Parameter name="pKeyCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setFormatString" id="09d537dd-5ed0-467a-b254-e045f0480213">
        <updating/>
        <source>setFormatString(pFormatString:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Sets the format to use for the time.
//
// Parameters:	pFormatString - The time format.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.formatString &lt;&gt; pFormatString then
		self.formatString	:=	pFormatString;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFormatString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTime" id="877bc912-3ac3-4d7e-b363-3512022202dd">
        <updating/>
        <source>setTime(pTime:Time) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Sets the receiver's current time value.
//
// Parameters:	pTime - The time value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 26/11/2002	cnwdad1		If the time setting is either null or is not valid,
//							then the control's time will be reset to midnight.
// 23/01/2003	cnwdad1		Reset the isChanged flag which is used to determine whether
//							to invoke the firstChange event method.
// --------------------------------------------------------------------------------
vars
	timeValue	: Time;
	
begin
	timeValue	:=	pTime;
	
	if self.formatString = self.FORMAT1 then
		if timeValue.isValid() then
			self.text	:=	CrLf &amp; pTime.format(self.TIME_FORMAT_1) &amp; CrLf;
		else
			self.text	:=	CrLf &amp; "00:00" &amp; CrLf;
		endif;
		
	elseif formatString = self.FORMAT2 then
		if timeValue.isValid() then
			self.text	:=	CrLf &amp; pTime.format(self.TIME_FORMAT_2) &amp; CrLf;
		else
			self.text	:=	CrLf &amp; "00:00:00" &amp; CrLf;
		endif;
		
	endif;
	
	self.scrollVertPos	:=	1;
	self.isChanged		:=	false;
end;</source>
        <Parameter name="pTime" type="Time"/>
    </JadeMethod>
    <JadeMethod name="thinClientUpdate" id="c5c946a3-4a7c-4bc2-98a8-228b375dbbbe">
        <source>thinClientUpdate() protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Kludge to force Thin Client to update the selText at the application
//				server.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	selectedText	: String;
	
begin
	// Kludge to force Thin Client to update the selText at the application server.
	selectedText	:=	self.selText;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="4267deb8-5c66-48c4-9775-e74e63807685">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Allow for CrLf and ':' characters.
	self.dataType		:=	TextBox.DataType_AlphaNumeric;
	self.selectionStyle	:=	TextBox.SelectionStyle_Hide;
	self.scrollBars		:=	Window.ScrollBars_Vertical;
	self.scrollVertical	:=	true;
	self.alignment		:=	TextBox.Alignment_Center;
	
	// Set default value.
	if self.formatString = self.FORMAT1 then
		self.text	:=	CrLf &amp; "00:00" &amp; CrLf;
		
	elseif self.formatString = self.FORMAT2 then
		self.text	:=	CrLf &amp; "00:00:00" &amp; CrLf;
	
	else
		self.formatString	:=	self.FORMAT2;
		self.text	:=	CrLf &amp; "00:00" &amp; CrLf;
		
	endif;		
	
	self.scrollVertPos	:=	1;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
