    <JadeMethod name="addChild" id="7a8f8bad-325a-44c3-9499-701938deca00">
        <updating/>
        <source>addChild() updating;
/*
----------   ----------  --------------------------------------------------
Created:	22 May 2007 By cnwth2

Changed On  Changed By  Reason
18/02/2013	cnwcs5		Minor local variable changes	
----------  ----------  --------------------------------------------------
*/
vars
	pxyRelease	: CM_BulkRelease;
	pxyChild	: CM_ReserveSelection;
begin
	pxyRelease	:= self.myMasterProxyObject.CM_BulkRelease;
	
	if not pxyRelease.releaseByType then
		self.showTISearcher();
		//app.msgBox(app.getErrorString(Cannot_Add_RequestLine), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create pxyChild transient;
	pxyChild.setMyHeader(pxyRelease);
	pxyChild.setPxyDefaults();
	
	self.saveUserEntry();
	self.loadTree();
	self.selectObject(pxyChild);
end;


</source>
    </JadeMethod>
    <JadeMethod name="addNew" id="4b85597b-3663-4bcc-a420-0282f00b03e4">
        <updating/>
        <source>addNew() updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
		
	delete self.myMasterProxyObject;
	create self.myMasterProxyObject as CM_BulkRelease transient;
	
	self.setDefaultsForNewMaster(self.myMasterProxyObject.CM_BulkRelease);
	
	
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="664fd175-d968-49f9-babc-0c5d654c0f8a">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
31/08/2023		jlizm1		TFS 59568 Add instructions to release lines
*/
vars
	toolbar		: CMUI_Toolbar;
begin
	

	inheritMethod();
	
	self.frmToolbar.addButton(self.btnInstruction, CMUI_Toolbar.Control_Alignment_Left);
	self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	self.frmToolbar.addFrame(self.frmCloseOnSave, CMUI_Toolbar.Control_Alignment_Left); // PAR 16942 cnwgb1 20 June 2008
	toolbar := self.frmSearchToolbar;
	toolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearch, CMUI_Toolbar.Control_Alignment_Left);
	

	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnInstruction_click" id="cf01949b-d6c5-46f2-aa9a-b6be230595e1">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnInstruction_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 August 2023		jlizm1	Initial creation TFS 59568 Add instructions to release lines
14 May	  2024		navnk30	ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial

*/

vars

begin
	//if self.mySelectedObject.isKindOf(CM_ReserveDetail) then		//14.05.2024 navnk30 #63607
		self.myAssistant.showInstructionEntryForm(self.mySelectedObject, self);
	//endif;														//14.05.2024 navnk30 #63607
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildLstTreeMenu" id="14266400-b65b-4b99-bb92-b023880ff251">
        <updating/>
        <source>buildLstTreeMenu(_selectedObj : CM_Object;  _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpMenu : MenuItem;
	count : Integer;
begin
	inheritMethod(_selectedObj, _conwin, _mouse, _x, _y);
	if CM_ReserveSelection.hasInstance(_selectedObj) then
		self.mnuEnquireCargo.visible:=true;
	
	endif;
	
	if CM_ReserveDetail.hasInstance(_selectedObj) then
		if _selectedObj.CM_ReserveDetail.myReserveDetailActions &lt;&gt; null then
			self.mnuActsApplied.userObject := _selectedObj.CM_ReserveDetail.myReserveDetailActions;
			self.mnuActsApplied.visible := true;
		endif;
	
	endif;
	
	if self.mode &lt;&gt; self.Mode_View then
	
		self.mnuStopsToApply.caption := "Maintain Stops to Apply ";	//16 Sep 2016	NDL	TFS 2646 / 2001
		self.mnuTasksToApply.caption := "Maintain Tasks To Apply ";	//16 Sep 2016	NDL	TFS 2646 / 2001
	
		if CM_BulkRelease.hasInstance(_selectedObj) then
			if self.btnAddChild.enabled then//allow adding only if release by type
				self.mnuAddChildItem.caption := app.getErrorString(Add_Request_Line);
				self.mnuAddChildItem.visible := true;
			endif;
		elseif CM_ReserveSelection.hasInstance(_selectedObj) then
			self.mnuRemoveItem.caption := app.getErrorString(Remove_Request_Line);
			self.mnuRemoveItem.visible := true;
			
			
		elseif  CM_ReserveDetail.hasInstance(_selectedObj) then
			self.mnuRemoveItem.caption := app.getErrorString(Remove_cargo_item);
			self.mnuRemoveItem.visible := true;	
			//16 Sep 2016	NDL	TFS 2646 / 2001
			if CM_ReserveTI.hasInstance( _selectedObj ) then
				if _selectedObj.CM_ReserveTI.getTI &lt;&gt; null then
					self.mnuStopsToApply.userObject := _selectedObj.CM_ReserveTI;
					self.mnuTasksToApply.userObject := _selectedObj.CM_ReserveTI;
					self.mnuStopsToApply.caption := self.mnuStopsToApply.caption &amp; _selectedObj.CM_ReserveTI.getTI.id &amp; "...";	
					self.mnuTasksToApply.caption := self.mnuTasksToApply.caption &amp; _selectedObj.CM_ReserveTI.getTI.id &amp; "...";	
					self.mnuStopsToApply.visible := true;	
					self.mnuTasksToApply.visible := true;	
				endif;
			endif;
		
		elseif CM_TrackedItem.hasInstance(_selectedObj) and ( not _selectedObj.CM_TrackedItem.isOffSite  ) then	//07 Dec 2012	NDL	Par 30815
			self.mnuRemoveItem.caption := app.getErrorString(Remove_cargo_item);
			self.mnuRemoveItem.visible := true;	
		
		//16 Sep 2016	NDL	TFS 2646 / 2001
		elseif CM_CargoType.hasInstance(_selectedObj) then
			count := self.getReserveTis( null );
			if count &gt; 0 then
				self.mnuStopsToApply.caption := self.mnuStopsToApply.caption &amp; " ( " &amp; self.lstTree.text &amp; " x" &amp; count.String &amp;" Items)...";	
					self.mnuTasksToApply.caption := self.mnuTasksToApply.caption &amp; " ( " &amp; self.lstTree.text &amp; " x" &amp; count.String &amp;" Items)...";	
				self.mnuStopsToApply.visible := true;	
				self.mnuTasksToApply.visible := true;
			endif;
			
		endif;
		
	elseif CM_BulkRelease.hasInstance(_selectedObj) and _selectedObj.CM_BulkRelease.type = BR_TYPE_RAIL then
		tmpMenu := self.zCloneMenu(self.mnuLstTree, self.mnuOutwardRail, true);
		self.buildMenuRailLines(tmpMenu);
		
	endif;
	self.mnuCloseOnSave.visible := true;

end;


</source>
        <Parameter name="_selectedObj" type="CM_Object"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildMenuRailLines" id="fba80cae-c516-439a-930a-9f7e84078060">
        <updating/>
        <source>buildMenuRailLines(_tmpMenu : MenuItem) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ioTypeStr		: String;
	idx				: Integer;
	rail			: CM_TerminalArea;
	subMenu,tmpSubMenu			: MenuItem;
	railway			: CM_Rail;
	railIO			: CM_RailJSInOut;
	railIORake		: CM_RailJSInOutRake;
	
	menuMaster		: MenuItem;
	ioType 			: Integer;
begin

	ioType := Rail_JSIO_Type_Out;
	
	
	menuMaster := _tmpMenu; //self.mnuOutwardRail.description.asOid.MenuItem;
	tmpSubMenu := self.zCloneMenu(menuMaster,self.mnuOutwardRailSub, true); 
	self.mnuOutwardRailSub.visible := true;
	tmpSubMenu.visible := false;

	ioTypeStr := app.railRakeTypeEnumToString(ioType);

	foreach railIO in self.myTerminal.myRailJobSheet.inouts do
		if railIO.outwards = ioType then
			foreach railIORake in railIO.inoutRakes do
//				idx := idx + 1;
				subMenu := self.zCloneMenu(menuMaster, tmpSubMenu, true); 
				
				if railIORake.myRail &lt;&gt; null then
					subMenu.caption := ioTypeStr &amp; ' ' &amp; railIORake.myRail.id;
				else
					subMenu.caption := ioTypeStr;				
				endif;
				subMenu.userObject := railIORake;
				subMenu.enabled := true;
				subMenu.visible := true;
				tmpSubMenu := subMenu;
			endforeach;
		endif;
	endforeach;

//	menuMaster.helpKeyword := idx.String;
	
end;</source>
        <access>protected</access>
        <Parameter name="_tmpMenu" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="carrierHasBeenChanged" id="5c6459fc-b6f6-4c78-a130-5a9000ee00cd">
        <updating/>
        <source>carrierHasBeenChanged(_newCarrier : CM_Carrier) updating, protected;
/* ---------------------------------------------------------------------------
Created:	29 April 2009	by cnwvu1

Purpose:	Par 19427. Email defaults can be stored persistently on the bulk release.
			When changing the carrier, we have to replace all addreses according to
			the new carrier, however, saving all other email info:
			as subject, body, included fields etc.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	emailTemplate	: CM_EmailTemplate;
	bulkRelease		: CM_BulkRelease;
	newCarrierId	: String;
	
begin

	if _newCarrier = null then	// null carrier in the cmbCarrier
		return;	// Do nothing. The Carrier is compulsary field. Just wait until a user selects a carrier.
	endif;

	newCarrierId := _newCarrier.code;
	
	if self.currentCarrierId = newCarrierId then
		return;	// do nothing - carrier not changed
	endif;

	self.currentCarrierId := newCarrierId;
	
	emailTemplate := self.myMasterProxyObject.CM_BulkRelease.myEmailTemplate;
	if emailTemplate = null then
		return;	// there is no any email defaults edited by Email Options
	endif;

	self.showEmailFormForCarrierChanged(emailTemplate);
	
end;</source>
        <access>protected</access>
        <Parameter name="_newCarrier" type="CM_Carrier"/>
    </JadeMethod>
