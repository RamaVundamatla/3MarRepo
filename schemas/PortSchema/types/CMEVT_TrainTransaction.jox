    <JadeMethod name="convertForCCMS1405" id="853a51f9-735e-40b6-891a-33ecbab4c9aa">
        <source>convertForCCMS1405() : CMEVT_TrainTransaction protected;
/*

Date		Who		Reason
04 December 2014	cnwer1	Initial creation PAR

*/

vars
	i : CM_InvoiceLine;
	t			: CMEVT_TrainTransaction;
begin
	if not self.isKindOf(CMEVT_TrainArrival) and not self.isKindOf(CMEVT_TrainDeparture) then
		return null;
	endif;
	
	t:=self.cloneSelfAs(CMEVT_TrainTransaction,false).CMEVT_TrainTransaction;		
	t.setPropertyValue(CMEVT_TrainTransaction::myTrain.name,self.myTrain);
	t.setPropertyValue(CM_EventTransaction::myTerminal.name,self.myTerminal);
	t.setPropertyValue(CM_EventTransaction::myEventType.name,self.myEventType);
	t.setPropertyValue(CM_EventTransaction::myDebtor.name,self.myDebtor);
	foreach i in self.allInvoiceLines do
		i.setMyTransactionEvent(t);
	endforeach;	
	
	
	return t;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CMEVT_TrainTransaction"/>
    </JadeMethod>
    <JadeMethod name="delete" id="b863081d-8034-4bd1-add0-2bf7e0fdf340">
        <updating/>
        <source>delete() updating;
/*

Date		Who		Reason
11 December 2014	cnwer1	Initial creation PAR

*/

vars

begin
	
	self.resetAuditsDuringDelete();	//01 Jan 2021	NDL	TFS 50152
	
	if not self.isTransient then
		if self.myTrain &lt;&gt; null then
			self.myTrain.causeEvent(EventTransaction_Delete_Event,false,self);	
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="7ffc5f2f-62c8-4b9d-8262-12fbb1623136">
        <source>getDebtor(): CM_Debtor;
/*

Date		Who		Reason
02 May 2017	cnwer1	Initial creation TFS 4232

*/

vars
	debtor : CM_Debtor;
begin
	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor;
	endif;
	
	if self.myTrain &lt;&gt; null then
		debtor :=self.myTrain.getDebtor();
	endif;
	
	if debtor &lt;&gt; null then
		return debtor;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="83e2df81-54e6-4973-bd14-3c51441333f0">
        <source>getDescription(): String;
/*

Date		Who		Reason
03 December 2014	cnwer1	Initial creation PAR

*/

vars
	trainDesc, mess : String;
begin
	if self.myTrain &lt;&gt; null then
		trainDesc:=self.myTrain.code;//getCodeDateString;
	endif;
	
	// ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1
	if self.myToDoTask &lt;&gt; null then
		mess := " (" &amp; app.getErrorString(Todo_task) &amp; " - " &amp;  self.myToDoTask.toDoTaskDescDesc &amp; ")";
	endif;	
	
	if self.type = EVT_TrainArrive then
		return app.getErrorString1(Train_arrived, trainDesc) &amp; mess; // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1
	elseif self.type = EVT_TrainDepart then
		return app.getErrorString1(Train_departed_terminal, trainDesc) &amp; mess; // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="7ae4b960-fbe7-4287-89b2-896a809632ac">
        <source>getDisplayID(): String;
//
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
vars

begin
	if self.myTrain &lt;&gt; null then
		return self.myEventType.name&amp;' '&amp;self.myTrain.code;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="39e9290f-49bc-44b7-b342-d3a0e52e29c2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2009	cnwndl1	Initial creation	Par 21519
23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events
*/

vars

begin

	if _attrName = ETRow_Train  then
		if self.myTrain &lt;&gt; null then
			return self.myTrain.getCodeDateString;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Description then
		return self.getDescription();
	
	elseif _attrName = ETRow_WagonNumber  then
		return null;
		
	elseif _attrName = ETRow_Id  then
		return null;
		
	elseif _attrName = ETRow_InWard  then
		return null;
		
	elseif _attrName = ETRow_SourceLocation then
		return null;
		
	elseif _attrName = ETRow_TargetLocation then
		return null;
		
	elseif _attrName = ETRow_EndDateTime then	
		if dateTimeEnd &lt;&gt; null then
			return self.systemToLocalTime(self.dateTimeEnd).asStringJMT;
		endif;
		
		return "";
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
