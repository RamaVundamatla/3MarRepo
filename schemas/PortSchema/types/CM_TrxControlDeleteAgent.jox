    <JadeMethod name="trxDeleteWagons" id="f9c3baf8-e8b9-422c-98ad-e2412a675048">
        <updating/>
        <source>trxDeleteWagons(_wagons:CM_WagonSet input; _isTrainConsistVerify : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     September 2009 ANDREW BISHOP
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwdad1		PAR #25120, changed to use new utility method to
//							delete the set of Wagons, instead of calling a
//							utility method to delete one wagon at a time.
// 22/11/2011	cnwdap1		PAR #28732 Don't call the utility method to delete a
//							set of wagons for every wagon in the set, otherwise we
//							end up trying to delete them more than once.......
// ---------------------------------------------------------------------------

vars
	 aWagon : CM_Wagon;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// Start the transaction
	beginTransaction;

	app.setContinueCMExceptions(true);
	foreach aWagon in _wagons  discreteLock do
		app.myValDA.valWagon(aWagon, _isTrainConsistVerify);
	endforeach;
	app.setContinueCMExceptions(false);
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	
	// PAR #28723 utlDeleteWagons deals with a set of wagons, deleting them all.
	// So don't call this for every wagon in the set, because they've already all been deleted after the first one
	//foreach aWagon in _wagons discreteLock do
	app.myUtilityDA.utlDeleteWagons(_wagons, _isTrainConsistVerify, _isTrainConsistVerify, true, _passport);
	if _passport.hasErrorsOrWarnings() then
		return;
	endif;
	//endforeach;
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wagons" type="CM_WagonSet" usage="input"/>
        <Parameter name="_isTrainConsistVerify" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
