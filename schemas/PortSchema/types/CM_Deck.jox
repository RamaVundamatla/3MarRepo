    </JadeMethod>
    <JadeMethod name="setForUpdateLayers" id="ba9b5303-ba2a-43e3-8215-5eb8fed605c6">
        <updating/>
        <source>setForUpdateLayers(_proxyDeck : CM_Deck input; _passport : CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	pxyDeckLayout, realDeckLayout : CM_DeckLayout;
	pxyDeckLayerLayout, realDeckLayerLayout : CM_DeckLayerLayout;
	pxyDeckItemLayout, realDeckItemLayout : CM_DeckItemLayout;
	realDeckLocn : CM_ROROLocnDefn;
	realDeckLane : CM_ROROLaneDefn;
	delObjs : ObjectArray;
begin
	realDeckLayout := self.myDeckLayout;
	pxyDeckLayout := _proxyDeck.myDeckLayout;
	
	if _proxyDeck.myDeckLayout = null then
		return;
	endif;
	
	create delObjs transient;
	
	if realDeckLayout = null then
		// ### DECK
		if pxyDeckLayout = null then
			create pxyDeckLayout transient;
			pxyDeckLayout.setProxy(self.code, self.description,self.remarks, self);
		endif;
		pxyDeckLayout.setMyDeck(self);
			
		app.myUtilityCA.utlCreateDeckLayout(pxyDeckLayout,realDeckLayout , app.myPassport); 
	
		// ### join pxy and real
		app.myProxyManager.createProxyLink(realDeckLayout, pxyDeckLayout);
	else
	
	
		// DECK LAYERS to delete
		foreach realDeckLayerLayout in realDeckLayout.allDeckLayerLayouts discreteLock do
			if not realDeckLayerLayout.isDefinable() then // PAR 27749 ignore OOTL, GC and Colour Coding Layers
				continue;
			endif;
			
			pxyDeckLayerLayout := realDeckLayerLayout.pxyGetProxyObject();
			// IF the real obj has no proxy then delete it.
			if pxyDeckLayerLayout = null then
				delObjs.add(realDeckLayerLayout);
			endif;
		endforeach;
		delObjs.purge;
	endif;
	
	
	// DECK LAYERS to create or update
	foreach pxyDeckLayerLayout in pxyDeckLayout.allDeckLayerLayouts discreteLock do
		realDeckLayerLayout := pxyDeckLayerLayout.pxyGetRealObject();
		if realDeckLayerLayout = null then
			app.myUtilityCA.utlCreateDeckLayerLayout(pxyDeckLayerLayout, realDeckLayerLayout, false, _passport);  // PAR 28330
			// ### join pxy and real
			app.myProxyManager.createProxyLink(realDeckLayerLayout, pxyDeckLayerLayout);
	
			foreach pxyDeckItemLayout in pxyDeckLayerLayout.allDeckItemLayouts  discreteLock do
				create realDeckItemLayout;
				realDeckItemLayout.setForCreate(pxyDeckItemLayout);
				
			endforeach;

		else
			if realDeckLayerLayout.isDefinable() then // PAR 27749 ignore OOTL, GC and Colour Coding Layers
				app.myUtilityUA.utlUpdateDeckLayerLayout(pxyDeckLayerLayout, _passport);
			endif;
		endif;
	endforeach;
		
	realDeckLayout.matchOrderOfLayers(pxyDeckLayout.allDeckLayerLayouts);

	// DECK LOCNS &amp; SLOTS to delete. Delete these if the graphic is gone since they are auto generated by the 'quick' drawing option
	delObjs.clear();
	foreach realDeckLocn in self.allROROLocnDefnByOrdinal discreteLock do
		// this will be null if graphic has been deleted in utlUpdateDeckLayerLayout etc
		if realDeckLocn.myLayout = null then
			delObjs.add(realDeckLocn);
		endif;
	endforeach;
	delObjs.purge;
	
	// DECK LANES to delete. Delete these if the graphic is gone since they are auto generated by the 'quick' drawing option
	delObjs.clear();
	foreach realDeckLane in self.allROROLaneDefnByOrdinal discreteLock do
		// this will be null if graphic has been deleted in utlUpdateDeckLayerLayout etc
		if realDeckLane.myLayout = null then
			delObjs.add(realDeckLane);
		endif;
	endforeach;
	delObjs.purge;

	
	// ### RELABEL ALL THE CONTAINER POSITIONS and LANES
	self.setLabelsOnAllLocations();
	self.setLabelsOnAllLanes();
epilog
	if pxyDeckLayout &lt;&gt; null and pxyDeckLayout.myDeck = self then
		delete pxyDeckLayout;
	endif;
	delete delObjs;

end;</source>
        <access>protected</access>
        <Parameter name="_proxyDeck" type="CM_Deck" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLabelsOnAllLanes" id="ae247253-4000-4388-af9b-77c303d6f457">
        <source>setLabelsOnAllLanes();
/*
Purpose:			
Date		Who		Reason
21 Apr 2011	cnwab1	Initial creation
25 May 2011 cnwer1  PAR 27618 1310 exception of lane code in allDeckItems dict
*/

vars
	allStateData : CM_StateDataDict;

	tmpLane : CM_ROROLaneDefn;
	tmpLayout : CM_DeckItemLayout;
	roroAutoGenerateStartEnd, ord : Integer;
	roroDeckLabelPrefix,
	roroRotatedLabel,
	roroSubDeckLabelPrefix	:String;
	roroLaneLabelPrefix	:String;
	roroLaneNumberLength	: Integer;
	roroLaneCodeIsZeroFilled: String;
	objs : ObjectSet;
	obj : Object;
	laneDict : CM_RORODeckItemByOrd1Ord2;
//	tmpVessel : CM_Vessel;
	newCode, codePart : String;
	newOrd, ord1, ord2 : Integer;
	duplicateDeckItem : CM_DeckItem;
begin
	/* PAR 28971
	tmpVessel := self.getVessel();
	
	if tmpVessel  &lt;&gt; null then
		allStateData:= tmpVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	*/
	allStateData := self.getAllStateDataObject(); // PAR 28971
	
	global.getExtraData(allStateData,RoRoDeckLabelPrefix,roroDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoSubDeckLabelPrefix,roroSubDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoLaneLabelPrefix,roroLaneLabelPrefix);
	global.getExtraData(allStateData,RoRoLaneNumberLength,roroLaneNumberLength);
	if roroLaneNumberLength = 0 then
		roroLaneNumberLength := 1;
	endif;
	global.getExtraData(allStateData,RoRoLaneCodeIsZeroFilled,roroLaneCodeIsZeroFilled);

	global.getExtraData(allStateData,RoRoAutoGenerateStartEnd,roroAutoGenerateStartEnd);



	create objs transient;
	create laneDict transient;
	self.allROROLaneDefnByOrdinal.copy(objs);
	
	// ### renumber out of the way
	ord := 900000;
	foreach obj in objs discreteLock do
		tmpLane := obj.CM_ROROLaneDefn;
		while true do : ordLoop
			ord := ord + 1;
			if self.allROROLaneDefnByCode[ord.String] = null then
				tmpLane.setOrdinal(ord);
			//	tmpLane.setCode(ord.String,false);
				break ordLoop;
			endif;
		endwhile;
	endforeach;

	// ### sort by physical order
	foreach tmpLane in self.allROROLaneDefnByOrdinal discreteLock do
		tmpLayout := tmpLane.myLayout;
		
		if tmpLayout = null then
			continue;
		endif;
		
		tmpLayout.getOrdinalsForSorting(roroAutoGenerateStartEnd, ord1, ord2);
		
		laneDict.putAtKey(ord1, ord2, tmpLane);
	endforeach;

	
	
	
	// ### generate new code
	newOrd := 0;
	foreach obj in laneDict discreteLock do
		tmpLane := obj.CM_ROROLaneDefn;
		
		// ### ordinal
		newOrd := newOrd + 1;
		tmpLane.setOrdinal(newOrd);
		
		//20 Jul 2016	NDL	TFS 2371
		if tmpLane.code.length &gt;= 8 and tmpLane.code[1:8] = CM_Deck.AUTOLANE
		and  tmpLane.myLayout.code.length &gt;= 8 and tmpLane.myLayout.code[1:8] = CM_Deck.AUTOLANE
		then
			// we need to fully process this one
		else
			duplicateDeckItem:= self.allDeckItems[newCode];
			if duplicateDeckItem &lt;&gt; null and duplicateDeckItem &lt;&gt; tmpLane then
				if duplicateDeckItem.isKindOf(CM_ROROLocnDefn) then
					newOrd:=self.allROROLocnDefnByOrdinal.last.CM_ROROLocnDefn.ordinal + 1;
					tmpLane.setOrdinal(newOrd);
				endif;
			endif;
			
			tmpLane.setCode(tmpLane.myLayout.code,false);	//20 Jul 2016 NDL	TFS 2371
			continue;
		endif;
		
		// ### code
		codePart := roroDeckLabelPrefix;
		codePart := codePart &amp; self.code;
		if self.isSubDeck() then
			codePart := codePart &amp; roroSubDeckLabelPrefix;
		endif;
		codePart := codePart &amp; roroLaneLabelPrefix;
		
		if roroLaneCodeIsZeroFilled.Boolean then
			newCode := codePart &amp; tmpLane.ordinal.padLeadingWith("0",roroLaneNumberLength) ;
		else
			newCode := codePart &amp; tmpLane.ordinal.String;
		endif;
		
		//epr par 27618 25/5/11 theres a duplicate will get a 1310 exception
		duplicateDeckItem:= self.allDeckItems[newCode];
		if duplicateDeckItem &lt;&gt; null and duplicateDeckItem &lt;&gt; tmpLane then
			//this is because there is a locn defn with the same code shouldn't be a lane because we have already offset by 90000 in above block off code
			
			if duplicateDeckItem.isKindOf(CM_ROROLocnDefn) then
				//get the last deck item and its ordinal + 1 for the new ordinal
				newOrd:=self.allROROLocnDefnByOrdinal.last.CM_ROROLocnDefn.ordinal + 1;
				tmpLane.setOrdinal(newOrd);
				//have the code part pad the ordinal if neccesary
				if roroLaneCodeIsZeroFilled.Boolean then
					newCode := codePart &amp; tmpLane.ordinal.padLeadingWith("0",roroLaneNumberLength) ;
				else
					newCode := codePart &amp; tmpLane.ordinal.String;
				endif;
			endif;
		endif;
		
		
//		tmpLane.setCode(newCode);
//		tmpLane.myLayout.setCode(newCode);
		tmpLane.setCode(newCode,true);	//20 Jul 2016 NDL	TFS 2371
		
	endforeach;
epilog
	delete objs;
	delete laneDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="setLabelsOnAllLocations" id="7f90ecf5-54b7-4df2-b69f-4392c14af4dc">
        <source>setLabelsOnAllLocations();
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars
	allStateData : CM_StateDataDict;

	tmpLocn : CM_ROROLocnDefn;
	tmpLayout : CM_DeckItemLayout;
	roroAutoGenerateStartEnd, ord : Integer;
	roroDeckLabelPrefix,
	roroRotatedLabel,
	roroSubDeckLabelPrefix	:String;
	roroLocationNumberLength	: Integer;
	roroLocationCodeIsZeroFilled: String;
	
	objs : ObjectSet;
	obj : Object;
	locnDict : CM_RORODeckItemByOrd1Ord2;
	tmpVessel : CM_Vessel;
	newCode : String;
	newOrd, ord1, ord2 : Integer;
begin
/*PAR 28971
	tmpVessel := self.getVessel();
	
	if tmpVessel  &lt;&gt; null then
		allStateData:= tmpVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	*/
	
	allStateData := self.getAllStateDataObject(); // PAR 28971
	
	global.getExtraData(allStateData,RoRoDeckLabelPrefix,roroDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoSubDeckLabelPrefix,roroSubDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoLocationNumberLength,roroLocationNumberLength);
	if roroLocationNumberLength = 0 then
		roroLocationNumberLength := 1;
	endif;
	global.getExtraData(allStateData,RoRoLocationCodeIsZeroFilled,roroLocationCodeIsZeroFilled);
	global.getExtraData(allStateData,RoRoRotatedLabel,roroRotatedLabel);

	global.getExtraData(allStateData,RoRoAutoGenerateStartEnd,roroAutoGenerateStartEnd);



	create objs transient;
	create locnDict transient;
	self.allROROLocnDefnByOrdinal.copy(objs);
	
	// PAR 27528 
	ord := 900000;
	// ### renumber out of the way
	foreach obj in objs discreteLock do
		tmpLocn := obj.CM_ROROLocnDefn;
		
		while true do : ordLoop
			ord := ord + 1;
			if self.allROROLocnDefnByCode[ord.String] = null then
				tmpLocn.setOrdinal(ord);
				if not tmpLocn.labelManuallyChanged then // PAR 27749
					tmpLocn.setCode(ord.String,true);
				endif;
				break ordLoop;
			endif;
		endwhile;
	endforeach;

	// ### sort by physical order
	foreach tmpLocn in self.allROROLocnDefnByOrdinal discreteLock do
		tmpLayout := tmpLocn.myLayout;
		
		if tmpLayout = null then
			continue;
		endif;
		
		tmpLayout.getOrdinalsForSorting(roroAutoGenerateStartEnd, ord1, ord2);
		
		locnDict.putAtKey(ord1, ord2, tmpLocn);
	endforeach;

	// ### generate new code
	newOrd := 0;
	foreach obj in locnDict discreteLock do
		tmpLocn := obj.CM_ROROLocnDefn;
		newOrd := newOrd + 1;		
		
		// PAR 29088
		while true do : codeLoop
			// ### code
			newCode := self.buildLocationCode(roroDeckLabelPrefix, roroSubDeckLabelPrefix, roroRotatedLabel, null,roroLocationCodeIsZeroFilled.Boolean, tmpLocn.isVerticalOrientation(), false,roroLocationNumberLength, newOrd);
			if self.allDeckItems[newCode] &lt;&gt; null then
				newOrd := newOrd + 1;
			else
				break codeLoop;
			endif;
		endwhile;
		// ### ordinal
		tmpLocn.setOrdinal(newOrd);

		
		// PAR 29088 newOrd := newOrd + 1;
		// PAR 29088tmpLocn.setOrdinal(newOrd);
		// ### code
		// PAR 29088 newCode := self.buildLocationCode(roroDeckLabelPrefix, roroSubDeckLabelPrefix, roroRotatedLabel, null,roroLocationCodeIsZeroFilled.Boolean, tmpLocn.isRotated(), false,roroLocationNumberLength, newOrd);
		
		/* PAR 27749
		newCode := roroDeckLabelPrefix;
		newCode := newCode &amp; self.code;
		if self.isSubDeck() then
			newCode := newCode &amp; roroSubDeckLabelPrefix;
		endif;
		if roroLocationCodeIsZeroFilled.Boolean then
			newCode := newCode &amp; tmpLocn.ordinal.padLeadingWith("0",roroLocationNumberLength) ;
		else
			newCode := newCode &amp; tmpLocn.ordinal.String;
		endif;
		if tmpLocn.isRotated() then
			newCode := newCode &amp; roroRotatedLabel;
		endif;
		*/
		if not tmpLocn.labelManuallyChanged then // PAR 27749
			tmpLocn.setCode(newCode,true);

		endif;
	endforeach;
epilog
	delete objs;
	delete locnDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="setOrdinal" id="acd933e3-2d05-4b43-b548-ce43f5a8ba2f">
        <updating/>
        <source>setOrdinal(idx : Integer) updating;
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if idx &lt;&gt; 0 and self.ordinal &lt;&gt; idx then
		self.ordinal := idx;
	endif;
epilog

end;</source>
        <Parameter name="idx" type="Integer"/>
    </JadeMethod>
