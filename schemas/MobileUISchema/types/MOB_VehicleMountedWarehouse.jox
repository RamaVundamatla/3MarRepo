    <JadeMethod name="doPickupDriverInitiatedMove" id="59e5c46f-bbd8-43a5-823c-18b076c6a168">
        <updating/>
        <source>doPickupDriverInitiatedMove() protected, updating;
/*

Date		Who		Reason
19 August 2014	cnwer1	Initial creation PAR

*/

vars
	ti : CM_TrackedItem;
	result : Boolean;
begin
	ti:=self.getSelectedDirectorCargo;
	if ti = null then
		return;
	endif;
	result :=app.myVMAgent.doPickupDriverInitiatedMove(ti,self.getCargoQuantity(),self.getCargoWeight());
	
	if result then
		self.enableAllControls();
		self.frmDirector.visible:=false;
		self.showWorkingTasks(false);
	endif;	
epilog

