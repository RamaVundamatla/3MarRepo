    <JadeMethod name="askAboutRollback" id="5ba62c73-c3bf-4e08-bcc3-5d50fe74909f">
        <updating/>
        <source>askAboutRollback() updating;

vars
	dba:JadeDatabaseAdmin;
begin
	if rollbackTime &lt;&gt; null then
		if app.msgBox("Do you want to roll back the user database to "&amp;rollbackTime.time.String&amp;"?", "Database Rollback", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			on Exception do handleRollbackExceptions(exception);
			while canRollBack do
				exceptionOccurred:=false;
				setStatus("Rolling back the database...");
				create dba transient;
				// jlgmd1 27/08/2018 - TFS 40386 Jade 2016 Changes
				//GJtdCommonSchema.firstInstance._clearAllBuffers;
				//app.atcgClearAllBuffersServer;
				dba.sendMsg("initiateDatabaseRollback");
				if exceptionOccurred then
					if app.msgBox("An exception has occurred."&amp;CrLf&amp;CrLf&amp;"Retry or cancel the rollback?", "Rollback Error Retry", MsgBox_Exclamation_Mark_Icon + MsgBox_Retry_Cancel) = MsgBox_Return_Retry then
						continue;
					else
						break;
					endif;
				endif;
				system.causeEvent(1147, true, "ClearBuffers");  // tell AtcgRecordApp to clear buffers
				rollbackTime:=null;
				setStatus("Database rollback complete");
				break;
			endwhile;
		endif;
	endif;
epilog
	delete dba;
end;</source>
    </JadeMethod>
    <JadeMethod name="btnGenerate_click" id="b89fbdf6-b44d-4257-b3f4-c708e744b951">
