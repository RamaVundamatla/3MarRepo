    <JadeMethod name="setupTableMoveNoSplitTarget" id="cbc35de2-5770-4a18-82cf-76ab13ec11ab">
        <source>setupTableMoveNoSplitTarget() protected;
/*

Date		Who		Reason
31 July 2014	cnwer1	Initial creation PAR 34682 CCMS 2404

*/

vars
	row :Integer;
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	i : Integer;
begin
	entTableDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTMoveDetails];
	self.myMoveTableDetails.initDecorator(self.myMoveTableDetails.myTerminal,self.myMoveTableDetails.myTable,entTableDef);
	
	entTableRow:=app.myVMAgent.getMyRTVehicleConfig.myVisibleTaskFields.allEntTableRows.first;
	self.myMoveTableDetails.addNewEntRowWithData(entTableRow,null);
	
	row := self.myMoveTableDetails.addNewEntRowWithData(entTableDef.getEntTableRow(ETRow_TargetID),null);
	if row &gt; 0 then
		self.myMoveTableDetails.myTable.accessRow(row).visible:=false;
	endif;
	self.myMoveTableDetails.insertRowAfterEntRow(ETRow_TargetID,null,self.btnRejectTask.clientHeight);
	row := self.myMoveTableDetails.addNewEntRowWithData(entTableDef.getEntTableRow(ETRow_TotalQuantity),null);
	if row &gt; 0 then
		self.myMoveTableDetails.myTable.accessRow(row).visible:=false;
	endif;
	row := self.myMoveTableDetails.addNewEntRowWithData(entTableDef.getEntTableRow(ETRow_CargoID),null);
	if row &gt; 0 then
		self.myMoveTableDetails.myTable.accessRow(row).visible:=false;
	endif;
	i:=0;
	foreach entTableRow in app.myVMAgent.getMyRTVehicleConfig.myVisibleTaskFields.allEntTableRows do
		i:=i+1;
		if i = 1 then
			continue;
		endif;
		self.myMoveTableDetails.addNewEntRowWithData(entTableRow,null);	
		
	endforeach;
	
	self.btnRejectTask.zOrder(1);
	self.btnRejectTask.parent:=self.frmMoveEntry;
	self.btnRejectTwin.zOrder(1);
	self.btnRejectTwin.parent:=self.frmMoveEntry;
	self.btnSwap.zOrder(1);
	
	
	self.tblMoveEntry.fitColumnWidth(2,0);
	self.frmMoveEntry.height:=self.frmGraphic.clientHeight;
	self.tblMoveEntry.scrollBars:=Table.ScrollBars_None;
	self.frmMoveEntry.scrollBars:=Picture.ScrollBars_Vertical;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTandemLiftLabels" id="4df8e943-a50a-493b-acbf-fadd5da2fda0">
        <source>setupTandemLiftLabels(_firstEntry, _twinEntry : DTO_RTQueueEntry; _firstCargoId, _secondCargoId : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	#cnwdz2	27732 

*/

vars
	firstEntryLc,
	secondEntryLc		: CM_LocationsController;
	firstEntryStackPos,
	secondEntryStackPos : Real;
	tmpTA				: CM_GridArea;
	firstCargoId,
	secondCargoId		: String;
begin
	//27/06/2011 cnwdz2 27732		
	if _firstCargoId &lt;&gt; null and _secondCargoId &lt;&gt; null then
		self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID, _firstCargoId);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TandemID, _secondCargoId);
	else	
		firstEntryLc := _firstEntry.getLocationSource;
		if firstEntryLc = null or (not firstEntryLc.isKindOf(CM_GridController)) then
			return;
		endif;
		
		//tmpTA := firstEntryLc.getMyTerminalArea().CM_GridArea;
		//if tmpTA &lt;&gt; null and tmpTA.isKindOf(CM_ForkLiftStack) then
		secondEntryLc := _twinEntry.getLocationSource;
		if firstEntryLc = secondEntryLc then
			firstEntryStackPos := firstEntryLc.CM_GridController.getActualStackPositionOfTI(_firstEntry.getTI);
			secondEntryStackPos := firstEntryLc.CM_GridController.getActualStackPositionOfTI(_twinEntry.getTI);			
			firstCargoId  := self.myMoveTableDetails.getDataForEntRowName(ETRow_CargoID).String;
			secondCargoId := self.myMoveTableDetails.getDataForEntRowName(ETRow_TandemID).String;
			if firstEntryStackPos &gt; secondEntryStackPos then						
				self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID, firstCargoId &amp; " (" &amp; app.getErrorString(TandemLift_Top) &amp; ")");
				self.myMoveTableDetails.addDataForEntRowName(ETRow_TandemID, secondCargoId &amp; " (" &amp; app.getErrorString(TandemLift_Bottom) &amp; ")");
			elseif secondEntryStackPos &gt; firstEntryStackPos then
				self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID, firstCargoId &amp; " (" &amp; app.getErrorString(TandemLift_Bottom) &amp; ")");
				self.myMoveTableDetails.addDataForEntRowName(ETRow_TandemID, secondCargoId &amp; " (" &amp; app.getErrorString(TandemLift_Top) &amp; ")");
			endif;
		endif;		
		//endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_firstEntry" type="DTO_RTQueueEntry"/>
        <Parameter name="_twinEntry" type="DTO_RTQueueEntry"/>
        <Parameter name="_firstCargoId" type="String"/>
        <Parameter name="_secondCargoId" type="String"/>
    </JadeMethod>
