    <JadeMethod name="load" id="d9412db5-663a-4c72-95bd-bdf4c0ac595f">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:

Parameters:	

Return Value:

Date		Who		Reason
12 February 2024	navra1	Initial creation for CR 61910/Task 62303 - EUP | API Create default package to run on invoice updating status to POSTED

*/

vars
	hasInvoiceAPIInvoice 	: Boolean;
	hasPostedPendingInvoice : Boolean;
	invoice					: CM_Invoice;
	theTable				: CM_EntryTable;
begin	
	inheritMethod();
	
	
	
	foreach invoice in self.allInvoices do
		if invoice.getMyInvoiceProcess().isKindOf(CM_InvoiceProcessInvoiceAPI) and not invoice.isNSWFinancialSystem then //jlier1 MTN-34357 20/3/25
			
			hasInvoiceAPIInvoice := true;
			if invoice.status = CM_Invoice.INVOICE_POSTED_PENDING then
				if invoice.allEWSInvoiceAPIActivities.last &lt;&gt; null then
					if invoice.allEWSInvoiceAPIActivities.last.myExtWebserviceDef.isNSWInvoiceAPIDef then
						continue;
					endif;
				endif;
				hasPostedPendingInvoice := true;
			endif;			
		endif;
	endforeach;
	
	if not hasInvoiceAPIInvoice then
		return;	//no special changes to this screen if we dont have any InvoiceAPI invoices
	endif;
	
	theTable := self.tblInvProperties;
	
	//do not allow the user to keep posting(exporting) while waiting for a response, ie. in POSTED_PENDING status
	if hasPostedPendingInvoice then
		theTable.setValueByName(ETRow_Export, false);
		theTable.disableRowByName(ETRow_Export);
	else	//if there are no POSTED_PENDING invoices selected make sure the user is forced to Export the invoice, unless he is a PmInvoiceAdmin
		theTable.setValueByName(ETRow_Export, true);
		theTable.disableRowByName(ETRow_Export);
		if app.myCurrentUserCan(self.myTerminal, PmInvoiceAdmin) then
			theTable.enableRowByName(ETRow_Export);
		endif;
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="5416005e-9081-4c09-8ea6-fa29795f1543">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
15/01/2023	navkc1 ChangeRequest 59145 Task 61332: UI - Invoice Post
10/06/2024  navrv30 Bug 64251: EUP - Invoice API message not formatted correctly when sent again
*/

vars
	todayDate	: Date;
	todayTS		: TimeStamp;
	theTable	: CM_EntryTable;
begin
	inheritMethod();
	
	theTable := self.tblInvProperties;
	
	if not self.myCurrentInvoice.toDT.isValid then
		todayTS := app.actualTimeServer();
		todayDate := self.systemToLocalTime(todayTS).date();
		
		if self.isCreditNote then
			self.mskCNEndDate.setDate(todayDate);
			theTable.setValueByControlName(self.mskCNEndDate.name, self.mskCNEndDate.text);
		else
			
			self.mskEndDate.setDate(todayDate);
			theTable.setValueByName(ETRow_EndDate, self.mskEndDate.text);
			//15/01/2023	navkc1 ChangeRequest 59145 Task 61332 - Invoice Date to be the same as End Date by default
			self.mskInvoiceDate.setDate(todayDate);
			theTable.setValueByName(ETRow_InvoiceDate, self.mskInvoiceDate.text);
		endif;
	else
		// ### TFS BUG 63885 29APR2024 NAVAB1
		if self.newStatus = CM_Invoice.INVOICE_POSTED then
			if self.myCurrentInvoice.toDT.isValid() then
				self.mskEndDate.setDate(self.myCurrentInvoice.toDT.date);
			endif;
			// 10/06/2024  navrv30 Bug 64251
			if self.myCurrentInvoice.invoiceDate.isValid() then
				self.mskInvoiceDate.setDate(self.myCurrentInvoice.invoiceDate.date);
			endif;			
			
		endif;

	endif;
	
	// ### TFS BUG 63885 29APR2024 NAVAB1
	if self.newStatus = CM_Invoice.INVOICE_POSTED then
			theTable.enableRowByName(ETRow_EndDate);
			theTable.enableRowByName(ETRow_InvoiceDate);   // 10/06/2024  navrv30 Bug 64251
	endif;
			
	self.calculateDueDate(null); //15/01/2023	navkc1 ChangeRequest 59145 Task 61332
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mskDueDate_lostFocus" id="2d5a70e7-0c43-4339-b809-696c0978f08f">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
