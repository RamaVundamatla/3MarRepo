		btn.caption 	:= app.getString(Show_completed_jobs);
		btn.bubbleHelp	:= app.getString(Show_completed_jobs);
	else
		btn.caption 	:= app.getString(Hide_completed_jobs);
		btn.bubbleHelp	:= app.getString(Hide_completed_jobs);
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;
