    <JadeMethod name="setStatus" id="c325c16a-1e23-4262-aab3-e7c76458aa17">
        <updating/>
        <source>setStatus(_status:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		27 May 2009 by cnwdad1
//
// Purpose:		Sets the status of the receiver.
//
// Parameters:	_status - The new status.  Refer to the BookingReferenceStatus
//					category of Global Constants.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _status = BOOKING_REF_ACTIVE
	or _status = BOOKING_REF_ARCHIVED
	or _status = BOOKING_REF_CLOSED
	or _status = BOOKING_REF_PENDING
	then
		self.status	:=	_status;
	elseif _status = -1 then					//no status				//+cnwml2 PAR23021
		app.raiseCMException2(Unexpected_Value, app.getString(BookingRef) &amp; " " &amp; app.getString(Status), "null", null, null);
	else																//+cnwml2 PAR23021
		//app.raiseCMException2(Unexpected_Value, app.getString(BookingRef) &amp; " " &amp; app.getString(Status), _status.String, null, null);
		app.raiseCMException2(Unexpected_Value, app.getString(BookingRef) &amp; " " &amp; app.getString(Status), app.bookingRefStatusEnumToString(_status), null, null);
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStatusClosed" id="d0ef36a6-6e41-406c-aac1-4fd6a9de4a10">
        <updating/>
        <source>setStatusClosed(_isSplit : Boolean) updating;

/*

Date		Who		Reason
27 May 2009	cnwkpd1	PAR #19785 - CCMS SFW 1079 - Booking Reference Status changes
					Renamed from setStatusCompleted
					
*/

vars

begin
	if not _isSplit then								//only change status if it is a Roll //+cnwml2 PAR20173 SFW CCMS 1091
		self.setStatus(BOOKING_REF_CLOSED);
	else
		self.setStatus(self.status);					//set to force sending of update notification of source booking
	endif;
	
end;
</source>
        <Parameter name="_isSplit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTranshipToPort" id="0afbaf8c-3932-454c-9541-0cd614aca29c">
        <updating/>
        <source>setTranshipToPort(_transhipPort : CM_Port; _propogateToCargo : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/

vars

	ti : CM_TrackedItem;
	pxyTI : CM_TrackedItem;
	tiUpdateCntrlr : CMIF_TIUpdateController;

begin

	if self.myTranshipToPort &lt;&gt; _transhipPort then
		self.myTranshipToPort := _transhipPort;
		
		//07 Sep 2012	NDL	Par 29684
		if _propogateToCargo and _transhipPort &lt;&gt; null then
			self.raiseExceptionIfTransient(method);
			tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
			foreach ti in self.allTIs discreteLock do
				if ( ti.isPreNote or ti.isOnSite ) and ti.myTranshipToPort &lt;&gt; _transhipPort then
					pxyTI := ti.pxyCreateUpdateProxy();
					pxyTI.setTranshipToPort( _transhipPort );
					ti.setForUpdate(pxyTI, tiUpdateCntrlr, null, false, app.myPassport);
					delete pxyTI;										
				endif;
			endforeach;
		endif;
		
	endif;
	
epilog

	delete tiUpdateCntrlr;
	delete pxyTI;
		
end;</source>
        <Parameter name="_transhipPort" type="CM_Port"/>
        <Parameter name="_propogateToCargo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="ad79bcc9-b45e-4b89-bdf5-5f3f98604913">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//21/09/2016	CNWMA1	TFS #2675 PAR #38206 POL - Bookings window - Audit trail menu Audit window
// ---------------------------------------------------------------------------
vars
	propName	: String;

begin

	propName := _property.name;
	
	if propName = CM_BookingRef::temperatureInFahrenheit.name then
		return false;
	endif;
	
	// 30/04/2009 cnwar2 #19538 - audited off the bookingRefItem
	if propName = CM_BookingRef::temperature.name then
		return false;
	endif;
	if propName = CM_BookingRef::humidity.name then
		return false;
	endif;
	if propName = CM_BookingRef::ventilation.name then
		return false;
	endif;
	
	//cnwjo3 par 19592
	if propName = CM_BookingRef::isoType.name then
		return false;
	endif;
	
	//cnwjo3 par 19592
	if propName = CM_BookingRef::myISOType.name then
		return false;
	endif;
	
	if propName = CM_BookingRef::quantity.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif; 		
	if propName = CM_BookingRef::myProduct.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;
	if propName = CM_BookingRef::weight.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;
	
	if propName = CM_BookingRef::allBookingRefDiscreps.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;
	
	if propName = CM_BookingRef::allBookingRefItems.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;

	if propName = CM_BookingRef::allExtraData.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;
	
	if propName = CM_BookingRef::allOverriddenWarnings.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206;
		return false;
	endif;
	
	if propName = CM_BookingRef::allReceivalRequests.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;
	if propName = CM_BookingRef::allTIHazards.name then   //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;
	
	if propName = CM_BookingRef::isMultiItemBookingRef.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;
	

	if propName = CM_BookingRef::productQuantity.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;
	
	
	if propName = CM_BookingRef::totalWeightMap.name then //21/09/2016 cnwma1 TFS #2675 PAR #38206
		return false;
	endif;
	
	//21 Oct 2011	NDL	Par 28092
	if propName = CM_BookingRef::cargoType.name or propName = CM_BookingRef::cargoTypeDescr.name
		or propName = CM_BookingRef::myCargoType.name then  //21/09/2016 cnwma1 TFS #2675 PAR #38206
		if self.isMultiItemBookingRef then
			return false;
		endif;
	endif;
	
	
	return inheritMethod(_rootClass, _property);
end;</source>
