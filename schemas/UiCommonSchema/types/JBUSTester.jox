    <JadeMethod name="btnOpenClose_click" id="7cc6f092-448a-4c3b-a4dd-ba3afd63bebe">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOpenClose_click(btn: Button input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if btn.caption = "Open" then
		self.openConnection;
	elseif btn.caption ="Close" then
		self.closeConnection;
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
