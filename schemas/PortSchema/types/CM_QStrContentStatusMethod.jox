<Class name="CM_QStrContentStatusMethod" id="2f47c6fd-158e-4d61-b21d-97a4297fd7ca">
    <superclass name="CM_QStringLookupMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmsmap"/>
    <JadeMethod name="setComboValues" id="3b75f430-218a-4cd5-addd-f8cc0870ae79">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 Jan 2025			navcs2	MTN-33832 CUX | Selector queries based on Onboard fields - changes required

*/
vars
	stat,
	statIndex		: CM_ContentsStatus;
	statDict		: CM_ContentsStatusByCodeDict;
begin
	_combo.clear();
	statDict := app.myRoot.allContentsStatuses;
	
	foreach stat in statDict discreteLock do
		_combo.itemObject[_combo.addItem(stat.description)] := stat;
		if CM_QStringLookup.hasInstance(_queryOperator) or CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
			if _queryOperator.isKindOf(CM_QStringLookup) and _queryOperator.CM_QStringLookup.selectionValue = stat.description then
				statIndex := stat;
			elseif _queryOperator.isKindOf(CM_QStringLookupNotEqual) and _queryOperator.CM_QStringLookupNotEqual.selectionValue = stat.description then
				statIndex := stat;
			endif;
		endif;
	endforeach;

	if statIndex &lt;&gt; null then
		_combo.listObject := statIndex;
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="089c5659-6f7d-42ac-9f5c-3c6865cdb61d">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 Jan 2025			navcs2	MTN-33832 CUX | Selector queries based on Onboard fields - changes required

*/
vars

begin
	if _value.isKindOf (CM_ContentsStatus) then	
		if _value &lt;&gt; null then
			return _value.CM_ContentsStatus.description;
		else
			return null;
		endif;
	endif;
	
	return _value.String;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="ff4a3840-3007-42d6-9b38-e095c5c5d8f9">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 Jan 2025			navcs2	MTN-33832 CUX | Selector queries based on Onboard fields - changes required

*/

vars
	invalidObj 		: Boolean;
	object			: CM_ContentsStatus;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		endif;

		if _value.isKindOf(CM_ContentsStatus) then
			object := _value.CM_ContentsStatus;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.description;
	endif;
	
	return returnVal;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
