<Class name="CM_Factory" id="3d38970e-6254-4f01-93b8-9574c3525d08">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testProduct"/>
    <ExplicitInverseRef name="allProductCheeses" id="a242e118-b104-4ec0-ae14-96f982f9c46b">
        <type name="CM_ProductCheeseById"/>
        <access>readonly</access>
        <Inverse name="CM_ProductCheese::myFactory"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allProductMilks" id="550a1893-4e2f-47d7-8cad-d0547c1cfc6a">
        <type name="CM_ProductMilkById"/>
        <access>readonly</access>
        <Inverse name="CM_ProductMilk::myFactory"/>
    </ExplicitInverseRef>
    <PrimAttribute name="id" id="40735d4d-f093-4996-bdb8-a777a590a416">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="analyzeFatness" id="2fd68402-18b2-4c81-ad0c-792296a619f4">
        <source>analyzeFatness();
/* ---------------------------------------------------------------------------
Created:	02 September 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cheese	: CM_ProductCheese;
	milk	: CM_ProductMilk;
	
begin


	foreach cheese in self.allProductCheeses do
		cheese.writeMyProductFatness();
	endforeach;

	
	foreach milk in self.allProductMilks do
		milk.writeMyProductFat();
	endforeach;
	
end;</source>
    </JadeMethod>
</Class>
