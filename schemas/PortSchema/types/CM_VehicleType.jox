    <JadeMethod name="setForCreate" id="aa1b6acd-3a59-4fe0-9c0a-46952e640387">
        <updating/>
        <source>setForCreate(_proxyVehicleType : CM_VehicleType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	_proxyVehicleType.raiseExceptionIfNotTransient(method);
	
	self.myDutyDocRoot := _proxyVehicleType.myDutyDocRoot;
	self.setForUpdate(_proxyVehicleType);
epilog

end;</source>
        <Parameter name="_proxyVehicleType" type="CM_VehicleType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b2bc4d95-7a8c-4e36-9beb-6d3fc6f48f40">
