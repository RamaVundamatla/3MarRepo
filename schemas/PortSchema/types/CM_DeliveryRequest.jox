    <JadeMethod name="getId" id="7e1c9c9a-4759-47bd-9e2f-d7e90d2bcbd9">
        <source>getId() : String;

vars
	str		: String;
begin
	//epr par 32408 10/9/13 changes for break-bulk and chassis 
	if self.operatorCode = null 
	and self.myOperatorGroup &lt;&gt; null then
		str := self.myOperatorGroup.code &amp; "'";
	else
		str := self.operatorCode.trimBlanks;	
	endif;

	if self.isoType &lt;&gt; null then
			return str &amp; ' ' &amp; self.isoType;
		endif;
	if self.isoGroup &lt;&gt; null then
		return str &amp; ' ' &amp; self.isoGroup;
	endif;
	if self.myCargoType &lt;&gt; null then
		str :=str &amp; ' ' &amp; self.myCargoType.abbreviation;
	else
		return app.getErrorString(GeneralCargo);	
	endif;
	
	if self.myTILCType &lt;&gt; null then
		str :=str &amp; ' ' &amp; self.myTILCType.code;
	endif;
	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIds" id="f9560373-abb1-466e-9de2-49f67f1d4550">
        <source>getIds(pStringArray : StringArray input);
// ---------------------------------------------------------------------------
// Created:			16 May 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
	array : HugeStringArray;
begin
	create array transient;
	pStringArray.clear;
	if self.ids = null then
		return;
	endif;
	self.ids.getStrings(array);
	foreach str in array do
		if str = null then
			return;
		endif;
		pStringArray.add(str);
	endforeach;
epilog
	delete array;
end;</source>
        <Parameter name="pStringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getIdsAsString" id="ecef7526-6345-4c45-8308-cb9608b8b31c">
        <source>getIdsAsString() : String;

vars
	numStrs, i : Integer;
	str, longStr : String;
	array : HugeStringArray;
begin

	create array transient;
	if self.ids = null then
		return null;
	endif;
	self.ids.getStrings(array);
	foreach str in array do
		if str = null then
			continue;
		endif;
		longStr := longStr &amp; str &amp; ', ';
	endforeach;
	longStr := longStr[1 : longStr.length-2];	//Chop off trailing ', '
	return longStr;
epilog
	delete array;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
