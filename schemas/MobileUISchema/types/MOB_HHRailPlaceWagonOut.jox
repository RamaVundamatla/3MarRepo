    <JadeMethod name="isWagonConfirmed" id="1efe1625-f60d-4a62-8809-5cdc1b82e046">
        <source>isWagonConfirmed(_wagon : CM_Wagon): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	wagon : CM_Wagon;
	
begin

	if _wagon = null then
		wagon := cmbWagon.listObject.CM_Wagon;
	else
		wagon := _wagon;
	endif;
	
	if wagon &lt;&gt; null then
		return wagon.confirmedOutwards;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateAllDynaWagons" id="c7314712-fa8b-4301-a5b8-b4016254443a">
        <source>populateAllDynaWagons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	train : CM_Train;
	iter : Iterator;
	wagon : CM_Wagon;
	idReversed : Boolean;
	id : String;
	
begin
	
	self.allDynaWagons.clear;
	train := self.myMobileGenericAgent.myCurrentTrain;
	
	if train = null then
		return;
	endif;
	
	iter := train.allWagonsByIdOutward.createIterator;
	
	idReversed := self.isIdReversed;
	
	while iter.next(wagon) do
		if idReversed then
			id := wagon.id.reverse;
		else
			id := wagon.id;
		endif;
		self.allDynaWagons.putAtKey(id,wagon);
	endwhile;

epilog

	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFormCaption" id="c53d8abd-6cd0-46ce-a867-5df901f143df">
        <updating/>
        <source>setFormCaption(_wagon: CM_Wagon) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	string : String;
	
begin

	if _wagon = null then
		string := app.getErrorString1(Outward_wagon,null);
	else
		string := app.getErrorString1(Outward_wagon,_wagon.id);
	endif;
	
	self.caption := string;

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
