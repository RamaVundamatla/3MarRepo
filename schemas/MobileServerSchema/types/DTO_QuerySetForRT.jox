<Class name="DTO_QuerySetForRT" id="32318b74-fe89-4319-bca1-c22f2ebf6d1a">
    <superclass name="DTO_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mobileServer"/>
    <PrimAttribute name="description" id="bcb4d4ef-6d63-44c9-a912-7b0feaa96b0b">
        <length>61</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <CompAttribute name="queriesDescriptionArray" id="8bf63a20-3ef9-4b14-8d41-bf85f7579294">
        <type name="StringArray"/>
    </CompAttribute>
    <CompAttribute name="queriesSelectorOidArray" id="2268dac5-0c27-4faa-b63e-38ee36598cd6">
        <type name="StringArray"/>
    </CompAttribute>
    <JadeMethod name="setFromPersistent" id="4ccc4b9c-e365-4f10-ac3b-5f59a66f3403">
        <updating/>
        <source>setFromPersistent( _querySet: CM_SelectorQueryAccess ) updating;
// -------------------------------------------
// Created	21 April 2008 by cnwvu1
// -------------------------------------------

vars
	query : CM_MenuUserQuery;

begin

	inheritMethod( _querySet );
	
	self.description	:= _querySet.description;
	
	foreach query in _querySet.allSelectedQueries do
		self.queriesDescriptionArray.add( query.heading );
		self.queriesSelectorOidArray.add( query.getOidString() );
	endforeach;
	
end;
</source>
        <Parameter name="_querySet" type="CM_SelectorQueryAccess"/>
    </JadeMethod>
</Class>
