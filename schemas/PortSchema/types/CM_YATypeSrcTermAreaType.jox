    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="4164d420-515c-42b5-a96d-40da54a70f99">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
begin
	app.myRoot.allTerminalAreaTypes.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="4c770ec7-4d89-4d8e-9321-5de0bc886a67">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="85274ada-8183-44f7-bba6-9ef52cd77a74">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin
	return dataObj.CM_TerminalAreaType.description;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="a375bb5c-52ae-4363-827b-b3051c8882ee">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	areaType: CM_TerminalAreaType;
begin
	foreach areaType in app.myRoot.allTerminalAreaTypes do
		objects[areaType.getYAIdentifier] := areaType;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="361fc18b-0b45-47e1-a01d-74dc7ba98ea6">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "Source Terminal Area Type";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="fb2234d8-e6f9-4cde-b564-207db205a107">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return _cmifAutoPlan.isSrcTermAreaType_Match(_yaData);


end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="ac3cc7f5-a4e4-4613-8ae1-3e64096c5b20">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2023	navmk20	Task 57998: JADE - Storage Config - YA Criteria Storage Matching

*/

vars
	terminalAreaType	: CM_TerminalAreaType;
	terminalArea	: CM_TerminalArea;
	yaData			: CM_YAData;
	myTrackedItem	: CM_TrackedItem;
	transaction : CM_TITransaction;
	terminal : CM_Terminal;
	locn : String;
	location : CM_LocationsController;
	height : Integer;
	matches : Boolean;
begin

	transaction := _tiTrx;
	if transaction &lt;&gt; null then
	
		terminal := transaction.myTerminal;
		if terminal &lt;&gt; null then
			locn := transaction.getLocationStr();
			if locn &lt;&gt; null then
				terminal.findLocationFromString(locn, true, location, height);
				if location &lt;&gt; null then
					terminalArea := location.myTerminalArea;
				endif;
			endif;
		endif;
	endif;


	if terminalArea = null then
		if _tiTrx &lt;&gt; null then
			myTrackedItem := _tiTrx.myTrackedItem;
			if myTrackedItem &lt;&gt; null then
				terminalArea := myTrackedItem.myTerminalArea; 
			endif;
		elseif _ti &lt;&gt; null then
			terminalArea := _ti.myTerminalArea;
		endif;
	endif;
	
	if terminalArea &lt;&gt; null then
		terminalAreaType := terminalArea.myType;
	endif;
		
	yaData := _criteria.myYAData;
	
	if yaData.CM_YADataObjects.matchesStorage(terminalAreaType) then
		return true;
	endif;
	
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
