    <JadeMethod name="createDocMethod" id="a40bb7e3-047e-4a43-b230-6723c8d073d6">
        <source>createDocMethod(pMethodObj:Method; pAlias:String):CnEcDocModelMethod;
// --------------------------------------------------------------------------------
// Created:		01 November 2002 by cnwdad2
//
// Purpose:		Create a Documentation property object, and return it to the caller.
//
// Parameters:	pMethodObj - The Method object to be represented by the Documentation
//					method object.
//				pAlias - The alias name of the method.
//
// Returns:		The newly created object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/01/2003	cnwdad1		Added support for an alias of the receiver's name.
// 12/03/2003	cnwdad1		Added check for duplicate methods.
// --------------------------------------------------------------------------------
vars
	docMethodObj	: CnEcDocModelMethod;
	
begin
	if self.allDocMethods[pMethodObj.name] &lt;&gt; null then
		CnEcBaseSchemaException.raise_(CNEC_X_03002, "Duplicate method: " &amp; pMethodObj.name);
	endif;
	
	if self.isTransient() then
		create docMethodObj transient;
	else
		create docMethodObj;
	endif;
	
	docMethodObj.updateMe(pMethodObj, pAlias, self);
	
	return docMethodObj;
end;</source>
        <Parameter name="pMethodObj" type="Method"/>
        <Parameter name="pAlias" type="String"/>
        <ReturnType type="CnEcDocModelMethod"/>
    </JadeMethod>
    <JadeMethod name="createDocProperty" id="52c20ae8-955b-4cb2-a269-84e4a751105e">
        <source>createDocProperty(pPropertyObj:Property; pAlias:String):CnEcDocModelProperty;
// --------------------------------------------------------------------------------
// Created:		01 November 2002 by cnwdad2
//
// Purpose:		Create a Documentation property object, and return it to the caller.
//
// Parameters:	pPropertyObj - The Property object to be represented by the Documentation
//					property object.
//				pAlias - The alias name of the property.
//
// Returns:		The newly created object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/01/2003	cnwdad1		Added support for an alias of the receiver's name.
// 12/03/2003	cnwdad1		Added check for duplicate properties.
// --------------------------------------------------------------------------------
vars
	docPropertyObj	: CnEcDocModelProperty;
	
begin
	if self.allDocMethods[pPropertyObj.name] &lt;&gt; null then
		CnEcBaseSchemaException.raise_(CNEC_X_03003, "Duplicate property: " &amp; pPropertyObj.name);
	endif;
	
	if self.isTransient() then
		create docPropertyObj transient;
	else
		create docPropertyObj;
	endif;
	
	docPropertyObj.updateMe(pPropertyObj, pAlias, self);
	
	return docPropertyObj;
end;</source>
        <Parameter name="pPropertyObj" type="Property"/>
        <Parameter name="pAlias" type="String"/>
        <ReturnType type="CnEcDocModelProperty"/>
    </JadeMethod>
    <JadeMethod name="setSuperclassAlias" id="6b82e016-2950-461e-a255-ba5aa432fd0d">
        <updating/>
        <source>setSuperclassAlias(pAlias:String) updating;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad1
//
// Purpose:		Sets the superclass alias name for the receiver.
//
// Parameters:	pAlias - The alias of the receiver's superclass.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.superclassAlias	:=	pAlias;
end;</source>
        <Parameter name="pAlias" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="ca856e4b-4531-4dd4-88d5-bd6f4915437f">
        <updating/>
        <source>updateMe(pTheClass:Class; pAlias:String; pDocSchemaObj:CnEcDocModelSchema) updating;
// --------------------------------------------------------------------------------
// Created:		01 November 2002 by cnwdad2
//
// Purpose:		Update the receiver's details.
//
// Parameters:	pTheClass - The class which this Documentation Class object represents.
//				pAlias - The alias name of the class.
//				pDocSchemaObj - The owner of this Documentation Class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/01/2003	cnwdad1		Added support for an alias of the receiver's name.
// --------------------------------------------------------------------------------
begin
	self.alias			:=	pAlias;
	self.myClass		:=	pTheClass;
	self.className		:=	pTheClass.name;
	self.myDocSchema	:=	pDocSchemaObj;
end;</source>
        <Parameter name="pTheClass" type="Class"/>
        <Parameter name="pAlias" type="String"/>
        <Parameter name="pDocSchemaObj" type="CnEcDocModelSchema"/>
    </JadeMethod>
</Class>
