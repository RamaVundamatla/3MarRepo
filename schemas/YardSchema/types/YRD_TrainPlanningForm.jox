    <JadeMethod name="doTransitWagons" id="28bd3e61-77e2-4c56-b507-1e9a57bd5b9a">
        <updating/>
        <source>doTransitWagons(mnuItem : MenuItem; _status : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwndl1	Initial creation

*/

vars

	theReturn : Integer;
	wagon : CM_Wagon;
	wagonSet : CM_WagonSet;
	tmpStr : String;
	
begin

	wagon := mnuItem.userObject.CM_Wagon;
	
	create wagonSet transient;
	
	if wagon &lt;&gt; null then
		wagonSet.add(wagon);
	else
		self.getSelectedWagons(wagonSet, null);
	endif;
	
	if warnedOfNoSelectedData(wagonSet,app.getErrorString(Wagon) ) then
		return;
	endif;
	
	foreach wagon in wagonSet do
		if tmpStr = null then
			tmpStr := wagon.id;
		else
			tmpStr := tmpStr &amp; ", " &amp; wagon.id;
		endif;
	endforeach;
	
	if _status = TI_IMEX_STATUS_REMAINONBOARD then
		if app.msgBox(app.getErrorString1(Please_Confirm_Intransit, tmpStr), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	elseif _status = TI_IMEX_STATUS_EXPORT then
		if app.msgBox(app.getErrorString1(Please_Confirm_Not_Intransit, tmpStr), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWagonInTransit(wagonSet, _status, app.myPassport); // TI_IMEX_STATUS_TRANSIT
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
		
epilog

	delete wagonSet;
	
end;</source>
        <Parameter name="mnuItem" type="MenuItem"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUnqueueTI" id="4552b8fa-0d29-45f9-94fc-19c356d50196">
        <updating/>
        <source>doUnqueueTI(_theTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	idx : Integer;
	lTI	: CM_TrackedItem;
	aStr : String;
	lResult : Integer;
	lMoveControl : CMIF_MoveController;
	lTransferArea : CM_TerminalArea;
	lQEntry : CM_RTQueueEntry;
	result	: Integer;
begin
	mousePointer := MousePointer_HourGlass;	
	
	if _theTI = null then
		app.msgBox(app.getErrorString(Please_Select_A_Tracked_Item),"Unqueuing", MsgBox_OK_Only +MsgBox_Information_Icon);
		return;
	endif;
	
	create lMoveControl transient;
	lMoveControl.setMoveMode(QUEUE_MODE);
	lMoveControl.setMyTrackedItem(_theTI);
	lMoveControl.setMyWorkListEntry(_theTI.allWorklistEntries.last);
	
	while true do
		app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog 
	if lMoveControl &lt;&gt; null then
		delete lMoveControl;
	endif;
	mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doWagonColorCode" id="6539d2cb-f5de-4290-af9c-38eff1eeaa8d">
        <source>doWagonColorCode(_wagon: CM_Wagon);
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	wagonColl : ObjectSet;
	
begin
	create wagonColl transient;
	
	if _wagon = null then
		self.getSelectedWagons(wagonColl, null);
	else
		wagonColl.add(_wagon);
	endif;
	
	self.myAssistant.YRD_Assistant.showColorCodeWagons(wagonColl, self.myMasterMenuAction);

	
epilog
	delete wagonColl;
end;

</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
