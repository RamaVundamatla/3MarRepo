    <JadeMethod name="cmbExtraInfo_lostFocus" id="7f6c946d-a005-4ed6-9c61-108ed1eba8df">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbExtraInfo_lostFocus(combobox: ComboBox input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 24 January 2024
TFS#		: 62140
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if combobox.text = EXTRA_INFO_LOCATION_CHECK then
		self.chkRequired.value := true;
		self.chkRequired.enabled := false;
	else 
		if self.myProxyCargoCheckItem = null then
			self.chkRequired.value := false;
		endif;
		self.chkRequired.enabled := true;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
