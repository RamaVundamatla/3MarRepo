    <JadeMethod name="auditId" id="bef45934-598f-4027-82ee-eb6ec1347fb2">
        <source>auditId(): String;
/*

Purpose:			The ID for the Audits

Parameters:			NONE

Return Value:		String	Returns the audited objects oid so we can find all the audits for a particular note if required

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	if self.myInvoice &lt;&gt; null then
		return self.myInvoice.sequenceNum.String;
	else
		return null;
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
