    <JadeMethod name="setCreditNoteFromInvoice" id="f92e30d4-8ca6-4127-8f4d-595d00b042e7">
        <updating/>
        <source>setCreditNoteFromInvoice(_debtor : CM_Debtor; _invoiceType : CM_InvoiceDesc; _status : Integer; _billingAddress : CM_Address; _fromDT : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/07/2023		navkc1	Bug 58995

*/

vars
	now	: TimeStamp;
begin
	self.debtor := _debtor;
	self.setInvoiceType(_invoiceType);
	self.status := _status;
	self.setMyBillingAddress(_billingAddress);
	self.fromDT := _fromDT;
	self.toDT := null;
	self.prependDT := null;
	self.pendingDT := null;
	self.postedDT := null;
	
	if self.invoiceType.hasDebtorSeparationAccrual(self.debtor) or self.invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
		self.toDT   := app.myRoot.myRootCompany.getPeriodEndDateInitialise(_debtor, self.invoiceType, now, true);
	endif;
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_billingAddress" type="CM_Address"/>
        <Parameter name="_fromDT" type="TimeStamp"/>
    </JadeMethod>
