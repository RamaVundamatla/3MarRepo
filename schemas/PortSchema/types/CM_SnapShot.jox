<Class name="CM_SnapShot" id="59163313-5055-4948-8b90-c646f3932b68">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>This class is the superclass for all SnapShot classes. These are used to store
a view (a set of properties) of a particular object at a particular point in time</text>
