    <JadeMethod name="doSelection" id="4b75ce87-7bd9-43cd-8744-aab9cf205ccc">
        <updating/>
        <source>doSelection() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2008	cnwjk3	CCMS 1032

*/

vars
	pnt : CMUI_GridPoint;
begin
	foreach pnt in self.allGridPointsByRow do
		if not self.myGridArea.allSelectedPoints.includes(pnt) then
			self.myGridArea.allSelectedPoints.add(pnt);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="59a0d911-dbb9-4fab-b4b1-24fe3872f6c0">
        <updating/>
        <source>drawSelf(pFrame: CMUI_Frame) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	
vars
	caption : String;
	xPoint : Real;
	theFrame : CMUI_Frame;
begin
	theFrame:=self.getGridFrame();
	
	xPoint := ((x2 - x1) /2);
	xPoint := x1 + xPoint;
	
	if self.label[1:1] &lt;&gt; "_" then	//system label
		caption := self.label;
	endif;
	
	//	pFrame.drawTextAt(self.label, self.x1, TopTextMargin, Black);
	//only draw if readonly other wise this gets called on column select which is triggered before lost focus and wipes the text field
	if self.txtLabel = null or (self.txtLabel &lt;&gt; null and  self.txtLabel.readOnly) then
		//self.drawTxtLabels(self.txtLabel,self.label,xPoint,Black);
		self.drawTxtLabels(self.txtLabel,caption,xPoint,Black);	//14 Feb 2011	NDL	Par 24181
	endif;
	if self.label40ftold &lt;&gt; null and (self.txt40ftLabel = null or (self.txt40ftLabel &lt;&gt; null and self.txt40ftLabel.readOnly)) then
		self.drawTxtLabels(self.txt40ftLabel,self.label40ftold,x2,Blue);
	endif;
	if self.txt40ftLabel &lt;&gt; null then
		self.txt40ftLabel.visible:=self.label40ftold &lt;&gt; null;
	endif;
end;</source>
        <Parameter name="pFrame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="drawTxtLabels" id="b396eca4-7313-4c94-973e-eccf7241273c">
        <updating/>
        <source>drawTxtLabels(_txtBox : CMUI_TextBox io; _text : String; _xPoint : Real; _txtColour : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwer1	Initial creation

*/

	
vars
	xPoint,
	xPoint2: Real;
	txtWidth : Integer;
	pFrame: CMUI_Frame;
	theTxtColour : Integer;
	labelTxtbox : CMUI_TextBox;
	theForm : Form;
begin
	pFrame:=self.getGridFrame;

	
	if _text = "_" then	//system label
		return;
	endif;
	txtWidth:=pFrame.getTextExtent(_text.trimBlanks);
	xPoint:=_xPoint - (txtWidth/2);
	txtWidth:=txtWidth + 3;
	if _txtBox = null then
		create _txtBox transient;
	else
		_txtBox.text:=_text;
		_txtBox.width:=txtWidth+ 3;
		return;
	endif;

	_txtBox.parent:=pFrame;
	_txtBox.top:=self.TopMargin;
	_txtBox.left:=xPoint;
	_txtBox.width:=txtWidth+ 3;

	_txtBox.borderStyle:=Control.BorderStyle_None;
	_txtBox.height:=pFrame.getTextHeightForWidth(_text,txtWidth);
	_txtBox.userObject:=self;
	_txtBox.text:=_text;
	_txtBox.foreColor:=_txtColour;
	_txtBox.selectionStyle:=TextBox.SelectionStyle_SelectAllAlways;

	theForm:=pFrame.form;
	theForm.addControl(_txtBox);
	_txtBox.autoTab:=false;
	_txtBox.tabIndex:=_txtBox.getInstanceIdForObject(_txtBox).Integer;
	_txtBox.setEventMapping(TextBox::mouseDown.name,SOP_TerminalAreaDefForm::txtLabelMouseDown.name);
	_txtBox.setEventMapping(TextBox::lostFocus.name,SOP_TerminalAreaDefForm::txtLabelLostFocus.name);
	_txtBox.setEventMapping(TextBox::gotFocus.name,SOP_TerminalAreaDefForm::txtLabelGotFocus.name);
epilog
	if _txtBox &lt;&gt; null then
		self.enableTxtLabel(false,_txtBox);	
		_txtBox.zOrder(1);
	endif;

end;</source>
        <Parameter name="_txtBox" type="CMUI_TextBox" usage="io"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_xPoint" type="Real"/>
        <Parameter name="_txtColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="enableTxtLabel" id="459f59c0-2aaa-4cd0-a94e-8c3e583c5d89">
        <source>enableTxtLabel(_enable : Boolean; _txtBox : CMUI_TextBox input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2009	cnwer1	Initial creation

*/

vars

begin
	if _txtBox &lt;&gt; null then
		_txtBox.readOnly:=not _enable;
		if not _enable then
			_txtBox.backColor:=_txtBox.parent.backColor;
			
		else
			_txtBox.backColor:=White;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
        <Parameter name="_txtBox" type="CMUI_TextBox" usage="input"/>
    </JadeMethod>
