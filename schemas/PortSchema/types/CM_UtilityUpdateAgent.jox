    <JadeMethod name="utlUpdateDutyDocItem" id="762d89eb-8c71-4060-ba89-b77483e500d6">
        <source>utlUpdateDutyDocItem(_proxyDutyDocItem : CM_DutyDocItem input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwndl1	Initial creation	Par 30901
31 July     2014    cnwma1 PAR 34408 Credit Customer current charges
*/

vars

	realDutyDocItem : CM_DutyDocItem;
	expectedEdition : Integer;
	ti : CM_TrackedItem;
	controller : CMIF_TiTransactionResync;
	
begin

	self.initialiseActivity();

	_proxyDutyDocItem.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyDutyDocItem.pxyGetRealObjectAndEdition(realDutyDocItem, expectedEdition);
	
	if realDutyDocItem = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DutyDocItem.name, null, null);
		return;
	endif;

	app.myValUA.valCM_Object( _proxyDutyDocItem,_passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realDutyDocItem);

	if _passport.noErrors and realDutyDocItem.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Duty Doc', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDutyDocItem, true);
	endif;
	
	if _passport.noErrors then
		realDutyDocItem.setForUpdate(_proxyDutyDocItem);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDutyDocItem, false);
	endif;
	
	//22 Apr 2013	NDL	Par 31424
	if _passport.noErrors then
		ti := realDutyDocItem.getMyTrackedItem;
		if ti &lt;&gt; null and not ti.allTransactions.isEmpty then
			create controller transient;
			controller.setForFullResyncOf(ti);
			controller.force := true;			
			//app.myUtilityUA.utlUpdateResyncTrans( controller, _passport );  // 31-JUL-2014 cnwma1 PAR 34408 Credit Customer current charges
		endif;
	endif;
	
epilog

	delete controller;

end;</source>
        <Parameter name="_proxyDutyDocItem" type="CM_DutyDocItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
