    <JadeMethod name="getMyVbsProcessForm" id="7b471e8e-06ac-4f19-a3a1-a16938354994">
        <source>getMyVbsProcessForm(_terminal : CM_Terminal; _masterMenuAction : CMUI_MenuAction) : Form;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023	navlw1	Initial Initial creation tfs 53902 : EUP - VBS MTN - [6] - Selector Query and JRW

*/

vars
	vbProcess : CM_VBSProcess;
	form : Form;
begin
	vbProcess := _terminal.getMyVBSProcess();
	if vbProcess &lt;&gt; null and vbProcess.isVbsSlotValidation then
		form := app.loadForm(CMUI_VehicleBookingEnqForm, self.class, false, false, true, _terminal, _masterMenuAction);
	else
		// stand process
		form := app.loadForm(CMUI_VehicleBookingDayView, self.class, false, false, true, _terminal, _masterMenuAction);
	endif;
	return form;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="getOperatorFromCombo" id="e1637625-275c-447e-b8c2-7c010d770313">
        <source>getOperatorFromCombo(_code : String) : CM_Operator;
// ccms1031 cnwrs1 Aug 2006
//Used now that we have a string array in the operator combo, instead of
//using the listObject of the combo control
vars
	code : String;
	int : Integer;
begin
	
	if _code = null then
		return null;
	endif;

	int := 1;
	
	//Get string to left of tab character. If no tab then code
	//will remain the same as pCode
	code := _code.scanUntil(Tab, int);
	code := code.trimRight;
	return app.myRoot.allOperators[code];
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
