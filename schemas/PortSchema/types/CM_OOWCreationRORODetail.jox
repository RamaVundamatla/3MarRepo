    <JadeMethod name="getTotalItems" id="20adbd77-2acf-40c4-aee1-b89055ac9765">
        <source>getTotalItems() : Integer;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	dTotal : Integer;
begin
	dTotal := (self.discIMP20 + self.discDLR20  + self.discSOB20 +  self.loadDLR20 + self.loadEXP20  + self.loadSOB20);
	dTotal := dTotal + (self.discIMP40 + self.discDLR40 + self.discSOB40 +  self.loadDLR40 + self.loadEXP40 + self.loadSOB40);
	dTotal := dTotal + self.discGC + self.loadGC;
	
	return dTotal;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="incrementYourOrder" id="c7c3775f-d544-449b-9460-e4824b0ae3dd">
        <updating/>
        <source>incrementYourOrder(_push: SelfType input; _up: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	num, nextNum : Integer;
	nextPushUp : SelfType;
begin
	if _push = null then
		return;
	endif;
	num := _push.order;
	nextNum := num + 1;

	nextPushUp := self.myROROStructure.allOOWCreations.getAtKeyGeq(nextNum);

	if nextPushUp &lt;&gt; null then
		if nextPushUp.order = nextNum then
			_push.incrementYourOrder(nextPushUp, _up);
		else
			if _up then
				_push.order := nextNum;
			else
				_push.order := num;
			endif;
		endif;
	else
		if _up then
			_push.order := nextNum;
		else
			_push.order := num;
		endif;
	endif;
	if _up then
		self.order := num;
	else
		self.order := nextNum;
	endif;

epilog

end;</source>
        <Parameter name="_push" type="SelfType" usage="input"/>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDischarge" id="55e7c8cd-f438-4ad0-88d1-6007a9552a33">
        <source>isDischarge() : Boolean;
vars

begin
	if self.discDLR20 &lt;&gt; null then
		return true;
	elseif self.discIMP20 &lt;&gt; null then
		return true;
	elseif self.discDLR40 &lt;&gt; null then
		return true;
	elseif self.discIMP40 &lt;&gt; null then
		return true;
	elseif self.discGC &lt;&gt; null then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLoad" id="3011a58b-d44f-4141-902a-aff76accd194">
        <source>isLoad() : Boolean;
vars

begin
	if self.loadDLR20 &lt;&gt; null then
		return true;
	elseif self.loadEXP20 &lt;&gt; null then
		return true;
	elseif self.loadREF20 &lt;&gt; null then
		return true;
	elseif self.loadSOB20 &lt;&gt; null then
		return true;
	elseif self.loadDLR40 &lt;&gt; null then
		return true;
	elseif self.loadEXP40 &lt;&gt; null then
		return true;
	elseif self.loadREF40 &lt;&gt; null then
		return true;
	elseif self.loadSOB40 &lt;&gt; null then
		return true;
	elseif self.loadGC &lt;&gt; null then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSOB" id="6fb2f5d2-e12f-4939-95d0-9dfdf96e7514">
        <source>isSOB() : Boolean;
vars

begin
	if self.discSOB20 &lt;&gt; null then
		return true;
	elseif self.discSOB40 &lt;&gt; null then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="a0f6b0c8-cadc-4588-8a98-e77d46d6d44e">
        <updating/>
        <source>setDetails(_deck : CM_DeckVoyage; _order : Integer; _is40 : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
		
	if _deck = null then
		return;
	endif;
	
	self.id := _deck.code;
	self.order := _order;
	self.myROROStructure := _deck.myVoyageStructure;
	self.myDeck:=_deck;
	
epilog

end;</source>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_order" type="Integer"/>
        <Parameter name="_is40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setJobs" id="93b543ab-8028-4ea3-a1be-ed9f3f3a075b">
        <updating/>
        <source>setJobs() updating;
// ---------------------------------------------------------------------------
// Created:		08 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aReq : CM_RORORequest;
	aWLE : CM_WorkListEntry;
	done, notDone : Real;
begin
	self.allJobs.clear;
	foreach aReq in self.allRORORequests discreteLock do
		if aReq.myJob = null then // PAR 15565
			continue;
		endif;
		self.allJobs.addNoDuplicates(aReq.myJob.CM_VoyageJob, false);
		foreach aWLE in aReq.allWorkListEntries discreteLock do
			aWLE.CM_VoyageWLE.getLiftTotals(done, notDone);
		endforeach;
	endforeach;
	
	self.numberOfLifts := (done + notDone);
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyROROVoyageStructure" id="2ae2e994-18a7-4640-b57f-162951b71f0d">
        <updating/>
        <source>setMyROROVoyageStructure(_roroStructure: CM_ROROVoyageStructure) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	
	self.myROROStructure:=_roroStructure;
epilog

end;</source>
