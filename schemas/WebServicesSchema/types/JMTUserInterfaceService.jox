    <JadeWebServicesMethod name="setUserLocale" id="75d4048b-6961-4722-9ca5-2ae460df0c71">
        <source>setUserLocale(localeId : String) : WS_Response webService;
/*

Purpose:			To set user locale

Parameters:			locale Id

Return Value:		

Date			Who		Reason
29 June 2017	cnwam15	Initial creation TFS #5193 Set user's locale

*/

vars
