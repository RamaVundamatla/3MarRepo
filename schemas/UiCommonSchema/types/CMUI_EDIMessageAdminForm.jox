//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="03f11658-5945-4bb6-8f17-d136ca0f8001">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.doPrintOutTable(self.tblData, self.caption, true, true, true, false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="05a78534-59bb-4982-ada1-5e228051b311">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/12/2011	cnwcs5		CCMS POL 2122 / par 28696 - allow for &gt; 1 data type per file type
//10 Nov 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar - dont add CrLf when doing writline
//14 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
//06 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
//17 May 2024	naviv1	TFS 63310 - EUP | FR 54871 Search EDI Message on Vessel Behaviour Not Clear
// ---------------------------------------------------------------------------

vars
	idStr				: String;
	vessel				: CM_Vessel;
	voyageStr			: String;
	table				: CM_DataTable;
	dateStart			: Date;
	dateEnd				: Date;
	voyage				: CM_Voyage;
	ediDataTypeColl		: CM_ObjectSet;
	ediFileTypeColl		: CM_ObjectSet;
	ediStatusColl		: CM_ObjectSet;
	dataTypeColl		: IntegerArray;
	statusColl			: IntegerArray;
	resultsColl			: CM_ObjectSet;
	obj					: Object;
	ls					: Boolean;
	exOccurred : Boolean;
begin
	on Exception do self.handle14051Error(exception, self.tblData, exOccurred);	//25 Nov 2014	NDL	Par 35248
	self.mousePointer := Window.MousePointer_HourGlass;
	// start by clearing the table
	table		:= self.tblData;
	table.rows	:= table.fixedRows;
	// cancel notifications
	self.doNotableClear;
	// get parameters for query
	dateStart 	:= self.txtQDateStart.getDate; 
	dateEnd		:= self.txtQDateEnd.getDate;
	idStr		:= self.txtId.text.trimBlanks();
//	voyage		:= self.cmbVoyage.listObject.CM_Voyage;		// cnwrl1 04/06/2010 PAR 24299 - what it was
	
	// attempt to find the voyage from the supplied voyagecode including archived ones.
	voyageStr	:= self.txtVoyageCode.text.trimBlanks();
	voyage		:= self.myTerminal.lookupVoyage( voyageStr, null, true );
	
	self.filterStartDate	:= dateStart;
	self.filterEndDate		:= dateEnd;
	self.myFilterVoyage		:= voyage;
	self.filterOperatorCode := null; // 8 Nov 2022 navvt20 TFS 55084
	self.filterVesselName   := null; // 8 Nov 2022 navvt20 TFS 55084
	//START 14.10.2022	navsj20	TFS 55084
	self.filterCargoETA 	:= self.txtCargoExpDate.getDate;
	self.filterCargoGroupId	:= self.txtCargoGroupId.text.trimBlanks;
	self.filterEDIAction	:= self.txtEDIAction.text.trimBlanks;
	self.filterMessageID	:= self.txtMessageId.text.trimBlanks;
	self.filterMessageNumber:= self.txtMessageNumber.text.trimBlanks;
	if self.cmbCargoOperator.listObject &lt;&gt; null then
		self.filterOperatorCode	:= self.cmbCargoOperator.listObject.CM_Operator.code;
	endif;
	self.filterReceiptMode	:= self.cmbReceiptTransMode.text;
	self.filterVBSNumber	:= self.txtVbsExtReference.text.trimBlanks;
	//START  7 November 2022 navvt20 TFS 55084
	if self.cmbVesselName.listObject &lt;&gt; null then
		vessel := self.cmbVesselName.listObject.CM_Vessel;
		self.filterVesselName := vessel.name;
	elseif self.txtVesselName &lt;&gt; null then		//17-May-2024 naviv1 #63310
		self.filterVesselName := self.txtVesselName.text;
	endif;
	//END 7 November 2022 navvt20 TFS 55084
	self.filterVoyageETA 	:= self.txtVoyageETA.getDate;
	//END 14.10.2022  navsj20  TFS 55084
	
	self.filterMessageType := self.txtFiltMessType.text;
	self.filterSender := self.txtSender.text;
	
	self.filterVoyageCode := null;
	if self.cmbVoyageCode.listObject &lt;&gt; null then
		voyage := self.cmbVoyageCode.listObject.CM_Voyage;
		self.filterVoyageCode := voyage.code;
	endif;	 
	
	self.filterVehicle := self.txtVehicle.text;
	
	if self.myFilterVoyage &lt;&gt; null and self.chkExcludeDepart.value and self.myFilterVoyage.hasDeparted then
		app.msgBox(app.getErrorString(Not_query_which_exclu_depar_vo), app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	
	dataTypeColl 	:= self.allFilterEDIDataTypes; 
	ediFileTypeColl	:= self.allFilterEDIFileTypes;	
	statusColl		:= self.allFilterStatuses;
	
	dataTypeColl.clear;
	ediFileTypeColl.clear;
	statusColl.clear;
	
	// work out which edi types to filter by
	self.mulQFileType.getSelected (ediFileTypeColl);
	
	// work out which data types to filter by
	create ediDataTypeColl transient;
	self.mulQDataType.getSelected (ediDataTypeColl);
	
	if ediDataTypeColl.isEmpty and		// no data types selected
		ediFileTypeColl.isEmpty then	// no file types selected
		// select all available data types
		self.allDummyEDIDataTypeObjects.copy (ediDataTypeColl);
	endif;
	
	foreach obj in ediDataTypeColl do
		dataTypeColl.add (obj.CM_Association.asInteger);
	endforeach;
	
	if dataTypeColl.isEmpty then
		// get the integer values for data  type associated with the file type
		// all collections are keyed on data type so we need these
			
		foreach obj in ediFileTypeColl do
			obj.CM_EDIFileType.getAllEDIDataTypes (dataTypeColl);	// par 28696
		endforeach;
	endif;

	// work out which edi statuses we need to filter by
	create ediStatusColl transient;
	self.mulQStatus.getSelected (ediStatusColl);
	
	foreach obj in ediStatusColl do
		statusColl.add (obj.CM_Association.asInteger);
	endforeach;
	
	self.progressStart (0, app.getErrorString (Cancel), null, null, app.getErrorString(SearchingForData));
	
	// we collect the candidate objects first and then display them in the table
	create resultsColl transient;
	
	//we don't want to be in load state while we go through the collection
	//Jade will lock the dict and we'll be open to dead locks if members are deleted
	ls := process.isInLoadState;
	app.cmsEndLoad(ls);
	
	// The order here is important, attempt to filter by the smallest collection or quickest filter criteria.
	// If the Id or voyage are specified then we will be using different collections so check these first,
	// else if the filter status is specified, then we will use the status dict,
	// because we can then use both status and date as keys in the dictionary.
	// cnwrl1 02/06/2010 PAR 24299 - start of coding
//	if not statusColl.isEmpty then				// cnwrl1 02/06/2010 PAR 24299 - what it was
	if voyageStr &lt;&gt; null then
		self.doQuery_Voyage( ediFileTypeColl, dataTypeColl, statusColl, voyageStr, idStr, voyage, dateStart, dateEnd, resultsColl );
	elseif idStr &lt;&gt; null then
		self.doQuery_Id( ediFileTypeColl, dataTypeColl, statusColl, idStr, voyage, dateStart, dateEnd, resultsColl );
	elseif not statusColl.isEmpty then
	// cnwrl1 02/06/2010 PAR 24299 - end of coding
		// If filter status is specified, then use status dict
		self.doQuery_Status (ediFileTypeColl, dataTypeColl, statusColl, voyage, dateStart, dateEnd, resultsColl);
	elseif dateStart &lt;&gt; null or dateEnd &lt;&gt; null then 
		// If from or to date is specified, and not status, then use date dict
		self.doQuery_Date (ediFileTypeColl, dataTypeColl, voyage, dateStart, dateEnd, resultsColl);
	else
		self.doQuery_Type (ediFileTypeColl, dataTypeColl, voyage, resultsColl);
	endif;

	if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
		// someone has clicked the cancel button during the query
		return;
	endif;
	
	// now we are ready to load our table
	self.progressStart (resultsColl.size, app.getErrorString (Cancel), null, null, app.getErrorString(LoadingDataIntoView));

	foreach obj in resultsColl do
		self.progressUpdate;
		
		if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
			// someone clicked the cancel button
			break;
		endif;
		
		self.doQueryAddItem (obj.CM_EDIData);
		if exOccurred then
			return;
		endif;
	endforeach;
	// sort table before coloring
	if table.sortColumn[1] &lt;&gt; null then
		table.resort;
	endif;
	// set the row colours
	table.colourRows(self.colorRow1,self.colorRow2);
	
	inheritMethod();
	
epilog
	self.progressFinish;
	self.mousePointer := Window.MousePointer_Default;
	
	delete ediDataTypeColl;
	delete ediStatusColl;
	delete resultsColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="ea6c48bd-746c-42e7-bba3-1190c4ec9ff1">
        <source>doQueryAddItem(_object :CM_EDIData) protected;
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;
	str		:String;
	dac		:CM_DataAccessController;
	index	:Integer;
begin
	table := self.tblData;
	
	if not _object.canUserAccessSelf(null, dac, app.myPassport) then
		return;
	endif;
	
	str 	:= _object.getAttributeStringForDefArray(table.allTblDataEntRows);	
	index	:= table.addItemObject (_object, str);
	
	self.doNotableAdd (_object);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="doQuery_CheckCancel" id="fc7fb6dc-a23d-4aba-ae28-72fac333d539">
        <source>doQuery_CheckCancel(_count :Integer io):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     05 May 2010 by cnwcs5
// Purpose:     Check if user has clicked cancel button
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	NUMBER = 500;	// number of collection entries to process
					// before checking cancel button
vars

begin
	_count := _count + 1;
			
	if _count mod NUMBER = 0 then
		self.btnModalDefault.doWindowEvents (0);
	endif;
	
	if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_count" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQuery_Date" id="51bba756-a58e-469a-957d-bd470473a34e">
        <source>doQuery_Date(_ediFileTypeColl :CM_ObjectSet; _dataTypeColl :IntegerArray; _voyage :CM_Voyage; _dateStart, _dateEnd :Date;
				_coll :Collection input)protected;
// ---------------------------------------------------------------------------
// Created:     21 April 2010 by cnwcs5
// Purpose:     Do query when no status selected but start date or end date HAS been specified
// Parameters:  _ediFileTypeColl	- edi file types to be included
//				_dataTypeColl		- data types associated with edi file types to be included (keys)
//				_voyage				- only this voyage
//				_dateStart			- date to start from (could be null)
//				_dateEnd			- date to stop (could be null)
//				_coll				- result set
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	size		: Integer;
	count		: Integer;
	type		: Integer;
	dict		: CM_MemberKeyDictionary;
	iter		: Iterator;
	ediData		: CM_EDIData;
	
begin
	dict := self.myTerminal.myEdiConfig.allEDIDatasByDateStatus;
	iter := dict.createIterator;
	
	foreach type in _dataTypeColl do : typeLoop
		// position iterator at start date 
		dict.startKeyGeq(type, _dateStart, null, iter);	
		
		while iter.next(ediData) do
			// Check for break conditions - ediDataType is the primary key for all dictionary types
			if ediData.ediDataType &lt;&gt; type then
				break;
			endif;			
			// We can break if we have passed the end date (if it is specified)
			if _dateEnd &lt;&gt; null and
				ediData.processDate &gt; _dateEnd then
				break;
			endif;
			// pass null in typeColl/statusColl parameter cos we know we don't need to check it from here
			if self.doIncludeObject(ediData, _voyage, null, _ediFileTypeColl, _dateStart, _dateEnd) then
				_coll.add (ediData);
				size := size + 1;
				if size &gt; JadeTableRowLimit then
					// too many object to load into the table
					return;
				endif;
			endif;
						
			if self.doQuery_CheckCancel (count) then
				return;	// user clicked cancel on the progress dialog
			endif;		
		endwhile;
	endforeach;
epilog
	delete iter;			// leaking transients - cnwrl1 02/06/2010 PAR 24299
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediFileTypeColl" type="CM_ObjectSet"/>
        <Parameter name="_dataTypeColl" type="IntegerArray"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dateStart" type="Date"/>
        <Parameter name="_dateEnd" type="Date"/>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQuery_Id" id="ee54e395-c6b2-4440-94e0-b7875868436b">
        <source>doQuery_Id(
	_ediFileTypeColl	: CM_ObjectSet;
	_dataTypeColl		: IntegerArray;
	_statusColl			: IntegerArray;
	_id					: String;
	_voyage				: CM_Voyage;
	_dateStart			: Date;
	_dateEnd			: Date;
	_coll				: Collection input ) protected;
	
/*
Purpose:		Do query when an Id is selected (can be a partial Id) and will be matched on the EDITrackedItems,
				start date and/or end date and/or voyage might have been specified
				
Parameters:		_ediFileTypeColl	- edi file types to be included (can be empty)
				_dataTypeColl		- data types associated with edi file types to be included (can be empty)
				_status	Coll		- status to filter by (can be empty)
				_id					- Id string to be used can be a partial Id.
				_voyage				- only this voyage (could be null)
				_dateStart			- date to start from (could be null)
				_dateEnd			- date to stop (could be null)
				_coll				- result set
				
Return Value:	nothing

Date			Who		Reason
02 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 25 Mar 2018	jlgrs1	TFS 44010 EDI Message Admin not working with changes for TFS 43312
*/

vars
	size			: Integer;
	count			: Integer;
	idLength		: Integer;
	ediTrackedItem	: CM_EDITrackedItem;
	ediData			: CM_EDIData;
	dict			: CM_MemberKeyDictionary;
	iter1			: Iterator;
	
	iter2			: Iterator;
	ediReleaseReqTI : CM_EDIReleaseRequestTI;
	
begin
	idLength	:= _id.length();
	dict		:= self.myTerminal.myEdiConfig.allEDITrackedItemsByIdStatus;
	iter1		:= dict.createIterator;
	dict.startKeyGeq(_id, iter1);
	
	while iter1.next( ediTrackedItem ) do : edi_loop
		if ediTrackedItem.id.toUpper[ 1 : idLength ] &lt;&gt; _id then
			break edi_loop;
		endif;
		
		// make sure match other conditions selected.
		ediData	:= ediTrackedItem.myEDIData;
		// Because can easily already selected this EDIData check this first.
		if _coll.includes( ediData ) then
			continue edi_loop;
		endif;
		
		// check the Data Type for this EDITrackedItem
		if _dataTypeColl.isNotEmpty and not _dataTypeColl.includes( ediData.ediDataType ) then
			continue edi_loop;
		endif;
		
		if self.doIncludeObject( ediData, _voyage, _statusColl, _ediFileTypeColl, _dateStart, _dateEnd ) then
			_coll.add( ediData );
			size := size + 1;
			if size &gt; JadeTableRowLimit then
				// too many object to load into the table
				return;
			endif;
		endif;
		
		if self.doQuery_CheckCancel( count ) then
			return;	// user clicked cancel on the progress dialog
		endif;
	endwhile edi_loop;
	
	//19 Mar 2012	NDL	Par 29263	-	to allow query of 'releaseRequestNumber' in lieu of ID value on CM_EDIReleaseRequestTI's.
	if _dataTypeColl.includes( EDIDataType_ReleaseRequest ) and _id &lt;&gt; null then
		
		dict := self.myTerminal.myEdiConfig.allEDIRelReqTiByRelNumStatus;
		iter2 := dict.createIterator;
		dict.startKeyGeq( _id, null, iter2 );
		
		while iter2.next( ediReleaseReqTI ) do
			
			if ediReleaseReqTI.releaseRequestNumber.toUpper[ 1 : idLength ] &lt;&gt; _id then
				break;
			endif;
			
			// make sure match other conditions selected.
			ediData	:= ediReleaseReqTI.myEDIData;
			// Because can easily already selected this EDIData check this first.
			if _coll.includes( ediData ) then
				continue;
			endif;
			
			if self.doIncludeObject( ediData, _voyage, _statusColl, _ediFileTypeColl, _dateStart, _dateEnd ) then
				_coll.add( ediData );
				size := size + 1;
				if size &gt; JadeTableRowLimit then
					// too many object to load into the table
					return;
				endif;
			endif;
			
			if self.doQuery_CheckCancel( count ) then
				return;	// user clicked cancel on the progress dialog
			endif;
		endwhile;
		
	endif;
	
epilog
	delete iter1;
	delete iter2;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediFileTypeColl" type="CM_ObjectSet"/>
        <Parameter name="_dataTypeColl" type="IntegerArray"/>
        <Parameter name="_statusColl" type="IntegerArray"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dateStart" type="Date"/>
        <Parameter name="_dateEnd" type="Date"/>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQuery_Status" id="fdc5cc15-2544-4dbf-a371-eaf93f04462e">
        <source>doQuery_Status(_ediFileTypeColl :CM_ObjectSet; _dataTypeColl :IntegerArray;_statusColl :IntegerArray; _voyage :CM_Voyage; _dateStart, _dateEnd :Date;
				_coll :Collection input)protected;
// ---------------------------------------------------------------------------
// Created:     21 April 2010 by cnwcs5
// Purpose:     Do query when at least one status has been selected
// Parameters:  _edFileTypeColl		- edi file types to be included
//				_status	Coll	- status to filter by
//				_voyage
//				_dateStart		- date to start from (could be null)
//				_dateEnd
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	size		: Integer;
	count		: Integer;
	type		: Integer;
	status		: Integer;
	dict		: CM_MemberKeyDictionary;
	iter		: Iterator;
	ediData		: CM_EDIData;
	
begin
	dict := self.myTerminal.myEdiConfig.allEDIDatasByStatusDate;
	iter := dict.createIterator;
	
	foreach type in _dataTypeColl do : typeLoop
	
		foreach status in _statusColl do
			dict.startKeyGeq(type, status, _dateStart, iter);	
	
			while iter.next(ediData) do
				// Check for break conditions - ediDataType is the primary key for all dictionary types
				if ediData.ediDataType &lt;&gt; type then
					break;
				endif;			
				// We can break if we have passed the current status
				if ediData.status &lt;&gt; status then
					break;
				endif;
				// If using status and ToDate, then can break if we have passed the date
				if _dateEnd &lt;&gt; null then
					if ediData.processDate &gt; _dateEnd then
						break;
					endif;
				endif;
				// pass null in status and data type parameters cos we know we don't need to check it from here
				if self.doIncludeObject(ediData, _voyage, null, _ediFileTypeColl, _dateStart, _dateEnd) then
					_coll.add (ediData);
					size := size + 1;
					if size &gt; JadeTableRowLimit then
						// too many object to load into the table
						return;
					endif;
				endif;
						
				if self.doQuery_CheckCancel (count) then
					return;	// user clicked cancel on the progress dialog
				endif;		
			endwhile;
		endforeach;
	endforeach;
epilog
	delete iter;			// leaking transients - cnwrl1 02/06/2010 PAR 24299
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediFileTypeColl" type="CM_ObjectSet"/>
        <Parameter name="_dataTypeColl" type="IntegerArray"/>
        <Parameter name="_statusColl" type="IntegerArray"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dateStart" type="Date"/>
        <Parameter name="_dateEnd" type="Date"/>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQuery_Type" id="81cdde47-e33d-41da-8fae-ca2a12c448b0">
        <updating/>
        <source>doQuery_Type(_ediFileTypeColl :CM_ObjectSet; _dataTypeColl :IntegerArray; _voyage :CM_Voyage; _coll :Collection input)updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 April 2010 by cnwcs5
// Purpose:     Do query when status and dates have not been selected
// Parameters:  _typeColl		- edi file types to be included
//				_voyage
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	size			: Integer;
	count			: Integer;
	ediDataType		: Integer;
	dict			: CM_MemberKeyDictionary;
	iter			: Iterator;
	ediData			: CM_EDIData;
	
begin
	dict := self.myTerminal.myEdiConfig.allEDIDatasByTypeNumber;
	iter := dict.createIterator;

	foreach ediDataType in _dataTypeColl do : typeLoop
		
		dict.startKeyGeq(ediDataType, null, iter);	

		while iter.next(ediData) do 
			// Check for break conditions - ediDataType is the primary key for all dictionary types
			if ediData.ediDataType &lt;&gt; ediDataType then 
				break; 
			endif;		 
			// we will not be using this method if the data or status parameters have been
			// set so we can pass null in status and date parameters and they wont be checked in includeObject
			if self.doIncludeObject(ediData, _voyage, null, _ediFileTypeColl, null, null) then
				_coll.add (ediData); 
				size := size + 1;
				if size &gt; JadeTableRowLimit then
					// too many object to load into the table
					return;
				endif;
			endif;
						
			if self.doQuery_CheckCancel (count) then
				return;	// user clicked cancel on the progress dialog
			endif;		
		endwhile;
	
	endforeach;
epilog
	delete iter;			// leaking transients - cnwrl1 02/06/2010 PAR 24299
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediFileTypeColl" type="CM_ObjectSet"/>
        <Parameter name="_dataTypeColl" type="IntegerArray"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQuery_Voyage" id="63e9a9d3-0ebb-493a-8d22-3dca5d9506f8">
        <source>doQuery_Voyage(
	_ediFileTypeColl	: CM_ObjectSet;
	_dataTypeColl		: IntegerArray;
	_statusColl			: IntegerArray;
	_voyageCode			: String;
	_id					: String;
	_voyage				: CM_Voyage;
	_dateStart			: Date;
	_dateEnd			: Date;
	_coll				: Collection input ) protected;
	
/*
Purpose:		Do query when a VoyageCode is selected (can be a partial VoyageCode),
				start date and/or end date and/or voyage might have been specified
				this query is done over both EDITrackedItem and EDIData instances.
				
Parameters:		_ediFileTypeColl	- edi file types to be included (can be empty)
				_dataTypeColl		- data types associated with edi file types to be included (can be empty)
				_status	Coll		- status to filter by (can be empty)
				_voyageCode			- VoyageCode string to be used can be a partial VoyageCode.
				_id					- Id string to be used can be a partial Id.
				_voyage				- only this voyage (could be null)
				_dateStart			- date to start from (could be null)
				_dateEnd			- date to stop (could be null)
				_coll				- result set
				
Return Value:	nothing

Date			Who		Reason
03 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/

vars
	size			: Integer;
	count			: Integer;
	type			: Integer;
	status			: Integer;
	voyageLength	: Integer;
	idLength		: Integer;
	ediTrackedItem	: CM_EDITrackedItem;
	ediData			: CM_EDIData;
	ediTIset		: CM_EDITISet;
	iter1			: Iterator;
	iter2			: Iterator;
	dict2			: CM_MemberKeyDictionary;
	includeRelReq	: Boolean;
	
begin

	//19 Mar 2012	NDL	Par 29263
	if _dataTypeColl.includes( EDIDataType_ReleaseRequest ) then
		includeRelReq := true;
	endif;
	
	// first check all of the relevant EDITrackedItems obtained from CM_EDIConfig method.
	create ediTIset transient;
	self.myTerminal.myEdiConfig.getMatchingEDITIsForVoyageCode( _voyageCode, ediTIset, self.chkExcludeDepart.value );
	idLength		:= _id.length();
	voyageLength	:= _voyageCode.length();
	iter1			:= ediTIset.createIterator;
	
	while iter1.next( ediTrackedItem ) do : ediTI_loop
		// since the collection returned from getMatchingEDITIsForVoyageCode only
		// returns valid EDITrackedItems already matched by VoyageCode just need
		// to make sure they match the other conditions selected.
		ediData	:= ediTrackedItem.myEDIData;
		// Because can easily already selected this EDIData check this first.
		if _coll.includes( ediData ) then
			continue ediTI_loop;
		endif;
		
		if idLength &lt;&gt; null then
			if includeRelReq and ediTrackedItem.isKindOf(CM_EDIReleaseRequestTI) then	//19 Mar 2012	NDL	Par 29263
				if ediTrackedItem.CM_EDIReleaseRequestTI.releaseRequestNumber.toUpper[ 1 : idLength ] &lt;&gt; _id then
					continue ediTI_loop;
				endif;
			elseif ediTrackedItem.id.toUpper[ 1 : idLength ] &lt;&gt; _id then
				continue ediTI_loop;
			endif;
		endif;
		
		// check the Data Type for this EDITrackedItem
		if _dataTypeColl.isNotEmpty and not _dataTypeColl.includes( ediData.ediDataType ) then
			continue ediTI_loop;
		endif;
		
		// do not include the voyage as this has already been correctly checked
		if self.doIncludeObject( ediData, null, _statusColl, _ediFileTypeColl, _dateStart, _dateEnd ) then
			_coll.add( ediData );
			size := size + 1;
			if size &gt; JadeTableRowLimit then
				// too many object to load into the table
				return;
			endif;
		endif;
		
		if self.doQuery_CheckCancel( count ) then
			return;	// user clicked cancel on the progress dialog
		endif;
	endwhile ediTI_loop;
	
	// now check all of the EDIData instances for the relevant VoyageCode
	// this will be mainly BayPlans and LoadLists
	dict2 := self.myTerminal.myEdiConfig.allEDIDatasByStatusDate;
	iter2 := dict2.createIterator;
	
	foreach type in _dataTypeColl do : type_loop
		
		foreach status in _statusColl do : status_loop
			dict2.startKeyGeq( type, status, _dateStart, iter2 );
			
			while iter2.next( ediData ) do : ediData_loop
				// Check for break conditions - ediDataType is the primary key for all dictionary types
				if ediData.ediDataType &lt;&gt; type then
					break ediData_loop;
				endif;
				// We can break if we have passed the current status
				if ediData.status &lt;&gt; status then
					break ediData_loop;
				endif;
				// If using status and ToDate, then can break if we have passed the date
				if _dateEnd &lt;&gt; null then
					if ediData.processDate &gt; _dateEnd then
						break ediData_loop;
					endif;
				endif;
				
				// Because can easily already selected this EDIData check this first.
				if _coll.includes( ediData ) then
					continue ediData_loop;
				endif;
				
				// if attempt to match on the VoyageCode which can be a partial VoyageCode
				if ediData.getVoyageCode.toUpper[ 1 : voyageLength ] &lt;&gt; _voyageCode then
					continue ediData_loop;
				endif;
				
				if idLength &lt;&gt; null then
					// see if this EDIData contains a match on the partial or full Id supplied
					ediTrackedItem	:= ediData.allEDITrackedItems.getAtKeyGeq( _id );
					if ediTrackedItem &lt;&gt; null then
						if includeRelReq and ediTrackedItem.isKindOf(CM_EDIReleaseRequestTI) then	//19 Mar 2012	NDL	Par 29263
							if ediTrackedItem.CM_EDIReleaseRequestTI.releaseRequestNumber.toUpper[ 1 : idLength ] &lt;&gt; _id then
								continue ediData_loop;
							endif;
						elseif ediTrackedItem.id.toUpper[ 1 : idLength ] &lt;&gt; _id then
							continue ediData_loop;
						endif;
					endif;
				endif;
				
				// pass null in voyage and status parameters cos we know we do not need to check it from here
				if self.doIncludeObject( ediData, null, null, _ediFileTypeColl, _dateStart, _dateEnd ) then
					_coll.add( ediData );
					size := size + 1;
					if size &gt; JadeTableRowLimit then
						// too many object to load into the table
						return;
					endif;
				endif;
				
				if self.doQuery_CheckCancel( count ) then
					return;	// user clicked cancel on the progress dialog
				endif;
			endwhile ediData_loop;
			
		endforeach status_loop;
		
	endforeach type_loop;
	
epilog
	delete ediTIset;
	delete iter1;
	delete iter2;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediFileTypeColl" type="CM_ObjectSet"/>
        <Parameter name="_dataTypeColl" type="IntegerArray"/>
        <Parameter name="_statusColl" type="IntegerArray"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dateStart" type="Date"/>
        <Parameter name="_dateEnd" type="Date"/>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doReprocess" id="ed5d0d4b-4bb2-4b29-8167-e38f07377a1f">
        <updating/>
        <source>doReprocess() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02 Aug 2012	cnwcs5		par 30136 - change usage of loadEDIDb _ediData parameter
// 02 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// ---------------------------------------------------------------------------
vars
	passport	:CM_Passport;
	ediData		:CM_EDIData;
	cmifMonitor	:CMIF_Monitor;
	valid		:Boolean;
begin
	return;
	passport 	:= app.myPassport;
	ediData 	:= self.getSelectedEDIData;
	
	if ediData = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
	endif;
	
	if not ediData.isKindOf (CM_EDIDataCustomStop) and not ediData.isKindOf (CM_EDIDataOperatorStop) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Cannot reprocess this EDI Data Type');
	endif;
	
	self.createCMIFMonitor (passport);
	
	passport.clearErrorsWarnings();
		
	app.mousePointer := MP_HOURGLASS;

	valid := true;

	self.progressStart (0, null, null, null, "DB Reprocessing EDI data.");
	self.pbProgressBar.partsDone := 0;
	
	if self.tryLock(ediData, Share_Lock, Session_Duration, LockTimeout_Immediate) then
		if ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS and
			ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL and
			ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED then 
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid status for EDI Data reprocess');
		endif;
		// first reset the status and marke all ediTIs as unprocessed
		app.myTrxUA.trxResetEDIDataForReprocess (ediData, passport);
		// if no errors continue with verify/load
		if passport.allErrorWarnings.size = 0 then
			// now verify and load
			if self.myEDIControllerAgent.verifyEdiData(ediData) then
				passport.warningsAcknowledged 	:= true;
				app.mousePointer 				:= MP_HOURGLASS;
				// passing false in the _mergeCargo parameter as merge does not apply to customers/operator stops
				self.myEDIControllerAgent.loadEdiDb(null, ediData, false);
			endif;
		endif;
	else
		// did not get lock
// 02 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
			app.raiseCMException(Objects_locked, null, ediData);
	endif;
	
	self.progressFinish;
	
	if passport.hasErrors then
		self.showVerifyErrors (app.getErrorString (EDIData_Failed_To_Verify2), self.mnuLoadToDB.caption);
	else
		self.clearErrorWarnings();
		self.staStatusBar.caption := app.getErrorString(DBLoadSuccessful);
	endif;

epilog
	self.unlock(ediData);
	self.progressFinish;	// just in case
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
	app.mousePointer := MP_DEFAULT;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="15489a27-dc69-4e22-888f-49a0cb7c0ec8">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//// 14 Oct 2022 	navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
//   04 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
// ---------------------------------------------------------------------------
vars
	
begin
	inheritMethod();
	
	self.txtQDateStart.setDate (app.actualTimeServer.Date);// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtQDateEnd.setDate (null);
	self.txtId.text			:= null;				// cnwrl1 03/06/2010 PAR 24299
	self.txtVoyageCode.text	:= null;				// cnwrl1 03/06/2010 PAR 24299
	
	self.mulQDataType.selectAllItems;
	self.mulQFileType.selectAllItems;
	self.mulQStatus.selectAllItems;
	
	//START 14.10.2022	navsj20	TFS 55084
	self.txtMessageId.text := null;
	self.cmbCargoOperator.listIndex := -1;
	self.txtCargoGroupId.text := null;
	self.txtMessageNumber.text := null;
	self.cmbVesselName.listIndex := -1;
	self.txtVbsExtReference.text := null;
	self.cmbReceiptTransMode.listIndex := -1;
	self.txtVoyageETA.text := null;
	self.txtCargoExpDate.text := null;
	self.txtEDIAction.text := null;
	//END 14.10.2022  navsj20  TFS 55084
	
	//jlika1 TFS 60232 --&gt;
	self.txtFiltMessType.text := null;
	self.txtSender.text := null;
	self.cmbVoyageCode.listIndex := -1;
	self.txtVehicle.text := null;
	//jlika1 TFS 60232 &lt;--
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="8579b813-872e-4daa-9796-d3c52cdd7e1b">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2024 navrv30 Bug 64621: MTN - EDI Message Administration - EDI Load form issue
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;
	status	:CMUI_StatusLine;
	
	tmpControl	: Control;
	numControls,
	i			: Integer;
	tmpParent	: Window;
	
	currentHeight	: Real;
	newHeight		: Real;
	heightDiff		: Real;
begin
	inheritMethod();

	// is the status bar is visible make sure it does not cover the horizontal scroll bar on the table
	status 	:= self.staStatusBar;
	table 	:= self.tblData;
	
	if status.visible then
		table.height := table.parent.Control.clientHeight - status.height;
	endif;
	
	currentHeight := self.frmLoadFileTool.height;
	
	// set whether show captions is set
	self.frmLoadFileTool.showCaptions := self.frmToolbar.showCaptions;

	// get the new height
	newHeight := self.frmLoadFileTool.height;
	
	// get the difference in heights
	heightDiff := newHeight - currentHeight;
	
	// check so if initial load resizes correclty
	if heightDiff = 0 and optAutoType.top &lt; self.frmLoadFileTool.height then
		heightDiff := 17;		
	endif;
	
	// read through the controls and if parent is frmLoadFile then update top by heightDiff
	numControls := self.controlCount;
	
	foreach i in 1 to numControls do
		tmpControl := self.controls(i);
		tmpParent := tmpControl.parent;
		if tmpParent.name &lt;&gt; self.frmLoadFile.name or tmpControl.isKindOf(CMUI_Toolbar)then
			continue;
		endif;
		
		// add heightDiff to controls top
		tmpControl.top := tmpControl.top + heightDiff;
		
	endforeach;
	
	// change frmLoadFile height by the difference
	self.frmLoadFile.height := self.frmLoadFile.height + heightDiff;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRetranslate" id="28635f4b-59d7-4711-9169-8277fe61587d">
        <updating/>
        <source>doRetranslate() updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2010	cnwcs5	par 24298 - multiselect functions
//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
// ---------------------------------------------------------------------------
vars
	coll		: CM_EDIDataByDateStatusDict;
	ediData 	: CM_EDIData;
	ediFile 	: CM_EDIFile;
	passport	: CM_Passport;
	count, size, countNotOK,
	countOK		: Integer;
	strCaption	: String;
begin
	self.staStatusBar.caption 	:= null;	// just in case
	passport 					:= app.myPassport;

	coll := self.getAllSelectedEDIData;
		
	size := coll.size;
	
	if size = 0 then
		return;	// nothing to do
	endif;
	
	self.progressStart (size, app.getErrorString(Cancel), null, null, app.getErrorString (Retranslating_EDI_file));
	
	self.frmModalDialog.visible := true;

	foreach ediData in coll do
		count	:= count + 1;
		
		if ediData = null then	// should not happen
			app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
		endif;
		
		ediFile := ediData.myEDIFile;			// cnwrl1 08/06/2010 PAR 24299

		if ediFile = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediFile object');	
		endif;
		
		// cnwrl1 08/06/2010 PAR 24299 - start of coding
		if ediFile.myEDIFileType = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'ediFile.myEDIFileType = null');	
		endif;
		// cnwrl1 08/06/2010 PAR 24299 - end of coding
		
		if ediData.isKindOf (CM_EDIDataGeneric)then
			// menu item should have been disabled - this form does not handle generic
			continue;
		endif;
		
		// update the progress bar and check to see if they have clicked cancel
		self.modalDialogUpdateInfo(app.getErrorString2 (Processing_X_of_Y, count.String, size.String));
		self.pbProgressBar.partsDone := count;
		self.frmModalDialog.refreshNow;
		self.btnModalDefault.doWindowEvents(null);	// did someone press the cancel button
		
		if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
			// Cancel button was pressed
			break;		
		endif;
		
		passport.clearErrorsWarnings();
		
		self.myEDIControllerAgent.reloadEDIFileForTerminal(ediFile, ediData, passport);	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
		
		if passport.allErrorWarnings.size = 0 then
			// Clear errors/warnings from form and err/warnings window		
			countOK := countOK + 1;
		else
			countNotOK := countNotOK + 1;
			
			if size = 1 then
				// we had errors - only show if we are not multi-select
				app.showErrorWarningDialog(self.mnuRetranslateFile.caption, passport, ErrWarnMode_AddUpdate);
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
		endif;
		self.clearErrorWarnings();
	endforeach;
	// now display result
	strCaption := self.mnuRetranslateFile.caption;
	
	self.staStatusBar.caption := app.getErrorString3 (X_of_Y_Sucessful, strCaption, countOK.String, size.String);
	
	if size &gt; 1 and countNotOK &lt;&gt; 0 then
		// multi-select had some errors - show message.  if there was only one item being processed we would have 
		// shown the errors already if there were any
		app.msgBox (app.getErrorString3 (X_of_Y_Items_ErrorsWarnings, strCaption, countNotOK.String, size.String),
					strCaption, MsgBox_OK_Only);
	endif;
epilog
	delete coll;
	self.progressFinish;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRevoke" id="8427c97f-8b28-4be2-bbec-dc5f3e100661">
        <updating/>
        <source>doRevoke() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/


vars
	ediData		: CM_EDIData;
	passport	: CM_Passport;
	allErrorEdiData : ObjectArray;
	coll		: CM_EDIDataByDateStatusDict;
	cmifMonitor	: CMIF_Monitor;
	count, countOK, countNotOK,
	size		: Integer;
	invalidObject	:Boolean;
	strCaption		:String;
begin
	self.staStatusBar.caption := null;
	passport					:= app.myPassport;
	
	coll := self.getAllSelectedEDIData();
	
	size := coll.size;
	
	if size = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Nothing selected');	
	endif;
	
	// arm exception handler
	on Exception do app.handleDeletedObject (exception, ediData, invalidObject);
	
	app.mousePointer 	:= MP_HOURGLASS;
	// clear out any old stuff
	passport.clearErrorsWarnings();
	// the monitor will handle updating the progress bar
	cmifMonitor := self.createCMIFMonitor (passport);
	// show the progress dialog
	self.progressStart (size, app.getErrorString(Cancel), null, null, app.getErrorString (XLAT_Revoking_EDIData));
	
	create allErrorEdiData transient;
	
	foreach ediData in coll do 
		count 			:= count + 1;
		invalidObject	:= false;	
		
		if ediData.isKindOf (CM_EDIDataGeneric)then
			// menu item should have been disabled - this form does not handle generic
			continue;
		endif;
		
		if ediData = null or ediData.edition &lt; 0 then	// will cause exception if ediData is deleted
			continue;
		endif;

		if invalidObject then
			continue;
		endif;
		
		if not ediData.canBeRevoked() then
			continue;
		endif;
		// update the progress dialog	
		self.lblModalMessage.caption := (app.getErrorString2 (Revoking_X_of_Y, count.String, size.String));
		self.pbProgressBar.partsDone := count;
		self.frmModalDialog.refreshNow;
		self.btnModalDefault.doWindowEvents(null);	// did someone press the cancel button
		
		if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
			// Cancel button was pressed
			break;		
		endif;
		
		app.myTrxUA.trxSetEDIDataStatus(ediData, CM_EDIFile.EDI_STATUS_REVOKED);

		// check for errors 
		if passport.allErrorWarnings.size = 0 then
			countOK := countOK + 1; 
		else
			allErrorEdiData.add(ediData);
			countNotOK := countNotOK + 1; 
			if size = 1 then
				// Direct them to old form if there was only one item being verified
			//	self.showVerifyErrors (app.getErrorString (EDIData_Failed_To_Verify2), self.mnuRevoke.caption);
			endif;
		endif;
		
		
	endforeach;
	
	// now display result
	strCaption := self.mnuRevoke.caption;
	
	self.staStatusBar.caption := app.getErrorString3 (X_of_Y_Sucessful, strCaption, countOK.String, size.String);
	
	
	
epilog
	self.clearErrorWarnings();	// always clear out
	self.progressFinish;		// just to make sure
	delete cmifMonitor;			// will reset passport value
	delete coll;
	delete allErrorEdiData;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="b25bc595-11ef-49a6-84af-928fbadb4fae">
        <source>doSelectAll();
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
