    <JadeMethod name="doCmbCountryBuild" id="20d44ed3-3e32-4d1b-a97f-d123ab346979">
        <source>doCmbCountryBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars

	country : CM_Country;
	iter : Iterator;
	index : Integer;

begin

	self.cmbAddrCountry.clear();
	
	iter := app.myRoot.allCountries.createIterator;
	while iter.next( country ) do
		index := self.cmbAddrCountry.addItem( country.isoCode3 &amp; " - " &amp; country.description );
		self.cmbAddrCountry.itemObject[index] := country;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbEntityTypesBuild" id="d8cc7f31-40ad-4378-b18c-3363b8f6106e">
        <updating/>
        <source>doCmbEntityTypesBuild() protected, updating;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 01 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
vars
	cmb		: ComboBox;
begin
	cmb := self.cmbEntType;
	cmb.clear;
	
	cmb.itemData[cmb.addItem("Carrier")] := Entity_Carrier;
	cmb.itemData[cmb.addItem("Consignor")] := Entity_Consignor;
	cmb.itemData[cmb.addItem("Customs Agent")] := Entity_CustomsAgent;
	cmb.itemData[cmb.addItem("Debtor Type")] := Entity_DebtorType;
	cmb.itemData[cmb.addItem("Operator")] := Entity_Operator;
	cmb.itemData[cmb.addItem("Contacts")] := Entity_Contacts; //epr par 35304 2/12/14
	cmb.itemData[cmb.addItem("Stevedores")] := Entity_Stevedore;		// TFS 44554
	cmb.itemData[cmb.addItem("Shipping Line")] := Entity_ShippingLine;		// Jun 01, 2022 navak20 TFS 53204
	
	cmb.listIndex := 1;
	self.doEntityTypeChange();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbTaxCountryBuild" id="7c7b8ff1-ab87-4c85-9866-818870e7a8fc">
        <source>doCmbTaxCountryBuild() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2023	navra1	Initial creation for 57086

*/

vars
	cmb		: CMUI_ComboBox;
	dict	: CM_CountryByCodeDict;
	country : CM_Country;

begin	
	cmb := self.cmbTaxCountry;
	cmb.clear;
	cmb.addItem("");
	dict := app.myRoot.allCountries;
	
	foreach country in dict do
		cmb.addItem(country.description);
		cmb.itemObject[cmb.newIndex] := country;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbTermsTradeBuild" id="f20f777f-fbc5-482c-8ebc-5b5db5a584e9">
        <source>doCmbTermsTradeBuild() protected;

vars
	dict		: CM_InvTermsOfTradeByCode;
	invTerm		: CM_InvoiceTermsOfTrade;
	cmb			: CMUI_ComboBox;
begin
	cmb := self.cmbTerms;
	cmb.clear;
	cmb.addItem("");
	dict := app.myRoot.myRootCompany.allInvoiceTermsOfTrade;
	foreach invTerm in dict do
		cmb.addItem(invTerm.description);
		cmb.itemObject[cmb.newIndex] := invTerm;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteDebtorAddress" id="ab5ed0dc-1adc-46d5-8893-6cfa1d6245d7">
        <updating/>
        <source>doDeleteDebtorAddress()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars
	address 	: CM_Address;
	theReturn   : Integer;
begin

	address := self.myCurrentDebtorAddress;
	
	if address = null then
		app.msgBox(app.getErrorString1(Please_Select_An, app.getErrorString(Address)) &amp; ".", app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete,  address.description),app.getErrorString(Confirm_Delete),
					MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	while true do
	 	app.myTrxDA.trxDeleteDebtorAddress(address, app.myPassport);
		 
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return ;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Company_Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return ;
		endif;
		break;
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEntityAdd" id="6ea5702e-aafa-45dc-b179-c3af01197f21">
        <updating/>
        <source>doEntityAdd(_all : Boolean) updating, protected;
// add all selected entities, or all entities if the parameter is true
vars

	row		: Integer;
	obj		: Object;
	ia		: IntegerArray;
	fromTable,
	toTable	: CM_DataTable;
begin
	create ia transient;

	fromTable := self.tblAvailEnts;
	toTable := self.tblSelectedEnts;
	foreach row in fromTable.fixedRows + 1 to fromTable.rows do
		if _all or
		   fromTable.accessRow(row).selected then
			obj := fromTable.accessRow(row).itemObject;
			toTable.addItemObject(obj, self.getEntityText(obj, false));
			self.addSelectedEntity(obj);
			ia.add(row);
		endif;
	endforeach;

	if ia.size = 0 then
		return;
	endif;
	
	foreach row in ia reversed do
		fromTable.removeItem(row);
	endforeach;
	
	self.setChanged();
	self.recolourTable(fromTable);
	self.sortTable(toTable);
	self.showCurrentEntities();
epilog
	delete ia;
end;</source>
        <access>protected</access>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEntityRemove" id="6281e7a5-6075-4623-ab86-bf448ca71997">
        <updating/>
        <source>doEntityRemove(_all : Boolean) updating, protected;
// remove all selected entities, or all entities if the parameter is true
vars

	row		: Integer;
	obj		: Object;
	ia		: IntegerArray;
	fromTable,
	toTable	: CM_DataTable;
begin
	create ia transient;

	fromTable := self.tblSelectedEnts;
	toTable := self.tblAvailEnts;
	foreach row in fromTable.fixedRows + 1 to fromTable.rows do
		if _all or
		   fromTable.accessRow(row).selected then
			obj := fromTable.accessRow(row).itemObject;
			toTable.addItemObject(obj, self.getEntityText(obj, true));
			self.removeSelectedEntity(obj);
			ia.add(row);
		endif;
	endforeach;

	if ia.size = 0 then
		return;
	endif;
	
	foreach row in ia reversed do
		fromTable.removeItem(row);
	endforeach;

	self.setChanged();
	self.recolourTable(fromTable);
	self.sortTable(toTable);
	self.showCurrentEntities();

epilog
	delete ia;
end;</source>
        <access>protected</access>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEntityTypeChange" id="52d619f3-b371-4a16-b0fb-5530a735a675">
        <updating/>
        <source>doEntityTypeChange() updating, protected;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 01 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
vars
	indx		: Integer;
	entityType	: Integer;
begin
	indx := self.cmbEntType.listIndex;
	if indx &lt; 1 then
		return;
	endif;
	
	entityType := self.cmbEntType.itemData[indx];
	if entityType = Entity_Carrier then
		self.loadCarriers();
	elseif entityType = Entity_Consignor then
		self.loadConsignees();
	elseif entityType = Entity_CustomsAgent then
		self.loadCustomsAgents();
	elseif entityType = Entity_DebtorType then
		self.loadDebtorTypes();
	elseif entityType = Entity_Operator then
		self.loadOperators();
	elseif entityType = Entity_Contacts then //epr par 35304 2/12/14
		self.loadContacts();
	elseif entityType = Entity_Stevedore then		// TFS 44554
		self.loadStevedores();						// TFS 44554
	elseif entityType = Entity_ShippingLine then	// Jun 01, 2022 navak20 TFS 53204
		self.loadShippingLine();
	endif;
	
	self.recolourTable(self.tblAvailEnts);
	self.recolourTable(self.tblSelectedEnts);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doILTCompanySelect" id="93e83418-1fdf-4eb0-be05-bf6285ff8673">
        <updating/>
        <source>doILTCompanySelect() protected, updating;

vars
	row		: Integer;
	extCode,
	str		: String;
	obj		: Object;
	proxyDebtor	: CM_Debtor;
	coy		: CM_Bank;
	invLineType	: CM_InvoiceLineDesc;
	debtorIlt	: CM_DebtorInvLineType;
	broke : Boolean;
begin
	self.myILTFilterCompany := self.cmbILTBU.listObject.CM_Bank;
	proxyDebtor := self.myProxyDebtorNode.CM_Debtor;
	
	self.tblILT.rows := self.tblILT.fixedRows;
	foreach obj in self.allUserBUs do
		coy := obj.CM_Bank;
	//	if self.myILTFilterCompany = null or		// &lt;all&gt; // 03 Apr 2017	NDL	TFS 3940 - option removed
		if coy = self.myILTFilterCompany then
			foreach invLineType in coy.invoiceLineDescriptors where not invLineType.isNotAvailableForEntry do
				debtorIlt := proxyDebtor.allDebtorInvLineTypes[invLineType];
				if debtorIlt = null then
					extCode := null;
				else
					extCode := debtorIlt.otherCode;
				endif;
				str := coy.mailingName &amp; " (" &amp; coy.terminal.code &amp; ")" &amp; Tab &amp; invLineType.narration &amp; Tab &amp; extCode;
				row := self.tblILT.addItemObject(invLineType, str);
				if row = 0 then	//03 Apr 2017	NDL	TFS 3940
					// 32000 exception limit hit, user will have already been notified.
					broke := true;
					break;
				endif;
				self.tblILT.accessCell(row, 3).inputType := Table.InputType_TextBox;
				self.tblILT.accessCell(row, 3).enabled := true;
			endforeach;
			if broke then		//03 Apr 2017	NDL	TFS 3940
				break;
			endif;
		endif;
	endforeach;
	self.tblILT.columnWidth[2] := (self.tblILT.width * .6).Integer;	// leave space for the 3rd 'External Code' column
	
	self.recolourTable(self.tblILT);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doITCompanySelect" id="104977d7-59cd-4ad5-b987-f0c351b98298">
        <updating/>
        <source>doITCompanySelect() protected, updating;

vars
	typeStr,
	str		: String;
	obj		: Object;
	coy		: CM_Bank;
	proxyDebtor	: CM_Debtor;
	invType	: CM_InvoiceDesc;
	debtorInvType	: CM_DebtorInvType;
	row : Integer;
	broke : Boolean;
begin
	self.myITFilterCompany := self.cmbITBU.listObject.CM_Bank;
	proxyDebtor := self.myProxyDebtorNode.CM_Debtor;
	
	self.tblIT.rows := self.tblIT.fixedRows;
	foreach obj in self.allUserBUs do
		coy := obj.CM_Bank;
	//	if self.myITFilterCompany = null or		// &lt;all&gt; // 03 Apr 2017	NDL	TFS 3940 - option removed
		 if coy = self.myITFilterCompany then
			foreach invType in coy.invoiceTypes where not invType.isNotAvailableForEntry do
				debtorInvType := proxyDebtor.allDebtorInvTypes[invType];
				if debtorInvType = null then
					typeStr := Tab &amp; Tab;
				else
					typeStr := Tab &amp; app.getYesBlank(debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode) &amp; Tab &amp; debtorInvType.getPackageDetails();
				endif;
				str := coy.mailingName &amp; " (" &amp; coy.terminal.code &amp; ")" &amp; Tab &amp; invType.description &amp; typeStr;
				row := self.tblIT.addItemObject(invType, str);
				if row = 0 then	//03 Apr 2017	NDL	TFS 3940
					// 32000 exception limit hit, user will have already been notified.
					broke := true;
					break;
				endif;
			endforeach;
			if broke then		//03 Apr 2017	NDL	TFS 3940
				break;
			endif;
		endif;
	endforeach;

	self.recolourTable(self.tblIT);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doInvTypeEdit" id="694b771d-b43d-4ceb-a55d-57024fc84f71">
        <updating/>
        <source>doInvTypeEdit() updating, protected;

vars
	row		: Integer;
	invType	: CM_InvoiceDesc;
	form	: INV_DebtorInvoiceTypeMaint;
begin
	row := self.tblIT.row;
	if row &lt;= self.tblIT.fixedRows or
	   row &gt; self.tblIT.rows then
		return;
	endif;
	
	invType := self.tblIT.accessRow(row).itemObject.CM_InvoiceDesc;
	//form := app.loadForm(INV_DebtorInvoiceTypeMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).INV_DebtorInvoiceTypeMaint;
	create form transient;
	if form = null then
		return;
	endif;
	form.centreWindow();
	form.myInvoiceType := invType;
	form.myDebtor := self.myProxyDebtorNode.CM_Debtor;
	form.myParentForm := self;
	form.show();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRestoreInvTypesAndLineTypes" id="e1bd275a-5f48-4554-a1ed-49183a9faced">
        <source>doRestoreInvTypesAndLineTypes(_invTypes, _invLineTypes : CM_ObjectArray io);
//
// Purpose:			Reconnect saved debtor invoice type and linvoice line types to the current proxy debtor
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/10.2019	jlgdap1		Initial creation TFS 46813 JMT Cannot add invoice package to debtor
//
vars
	debtor : CM_Debtor;
	invType, existingInvType : CM_DebtorInvType;
	invLineType, existingInvLineType : CM_DebtorInvLineType;
	obj : Object;
	thingsToDelete : ObjectArray;
	packageInvoice : CM_PackageInvoice;
	found : Boolean;

begin
	if self.myProxyDebtorNode = null or not self.myProxyDebtorNode.isKindOf(CM_Debtor) then	
		return;
	endif;
	
	create thingsToDelete transient;
	debtor := self.myProxyDebtorNode.CM_Debtor;
	foreach obj in _invTypes do
		invType := obj.CM_DebtorInvType;
		
		// do we have one of these?
		existingInvType := debtor.allDebtorInvTypes[invType.myInvoiceType];
		if existingInvType &lt;&gt; null then
			// Yes? - need to update it
			existingInvType.setup(debtor, existingInvType.myInvoiceType, invType.defaultDebtorRefTo);
			existingInvType.allPackageInvoices.clear;
			foreach packageInvoice in invType.allPackageInvoices do
				existingInvType.allPackageInvoices.add(packageInvoice);
			endforeach;
			// and then add the one we have to the list of things we can get rid of
			thingsToDelete.add(invType);
		else
			// No? - need to add it
			invType.setPropertyValue(CM_DebtorInvType::myDebtor.name, debtor);
		endif;
	endforeach;
	// Did we delete any?
	foreach invType in debtor.allDebtorInvTypes do
		found := false;
		foreach obj in _invTypes do
			existingInvType := obj.CM_DebtorInvType;
			if existingInvType.myInvoiceType = invType.myInvoiceType then
				found := true;
			endif;
		endforeach;
		if not found then
			thingsToDelete.add(invType);
		endif;
	endforeach;
	
	foreach obj in _invLineTypes do
		invLineType := obj.CM_DebtorInvLineType;
		
		// do we have one of these?
		existingInvLineType := debtor.allDebtorInvLineTypes[invLineType.myInvoiceLineType];
		if existingInvLineType &lt;&gt; null then
			// Yes? - need to update it
			existingInvLineType.setup(debtor, existingInvLineType.myInvoiceLineType, invLineType.otherCode);
			// and then add the one we have to the list of things we can get rid of
			thingsToDelete.add(invLineType);
		else
			// No? - need to add it
			invLineType.setPropertyValue(CM_DebtorInvType::myDebtor.name, debtor);
		endif;
	endforeach;
	// Did we delete any?
	foreach invLineType in debtor.allDebtorInvLineTypes do
		found := false;
		foreach obj in _invLineTypes do
			existingInvLineType := obj.CM_DebtorInvLineType;
			if existingInvLineType.myInvoiceLineType = invLineType.myInvoiceLineType then
				found := true;
			endif;
		endforeach;
		if not found then
			thingsToDelete.add(invLineType);
		endif;
	endforeach;
	
epilog
	thingsToDelete.purge;
	delete thingsToDelete;
end;</source>
        <Parameter name="_invTypes" type="CM_ObjectArray" usage="io"/>
        <Parameter name="_invLineTypes" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="7cd8b66e-5a1f-49a2-b88d-c95f2f9afeb0">
        <updating/>
        <source>doSave() : Boolean updating, protected;
/*
13 Oct 2023 navma1	Bug 60675: MTN - Error 4 when saving a new debtor
*/
vars

	theReturn				: Integer;
	debtorNodeController	: CMIF_DebtorNode;
	realDN					: CM_DebtorNode;
begin
	create debtorNodeController transient;
	self.doSetDebtorNodeController(debtorNodeController);
	
	while true do
		if self.updateMode = self.UpdateMode_New then
			app.myTrxCA.trxCreateDebtorNode(debtorNodeController, realDN, app.myPassport);
		else
			app.myTrxUA.trxUpdateDebtorNode(debtorNodeController, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			delete debtorNodeController.myPxyDebtorNode;
			return true;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Debtor_Register), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
		break;
	endwhile;

	return false;
epilog
	
	/*
	13.10.2023 navma1 #60675
	if debtorNodeController.myPxyDebtorNode &lt;&gt; null then 	// JLGAB1 862.000
		delete debtorNodeController.myPxyDebtorNode;		// JLGAB1 862.000
	endif; 													// JLGAB1 862.000
	*/
	
	debtorNodeController.allDebtorTerminalDetails.purge(); // ### TFS 52237 27OCT2021 NAVAB1
	delete debtorNodeController;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDebtorAddress" id="691a2f33-9fcb-4e8e-8768-2bf5c7983bf0">
        <updating/>
        <source>doSaveDebtorAddress(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
16 Jun 2022 jlika1	TFS 53679 - Delivery Party
02 Sep 2022 navkc1	ChangeRequest 54564(54372.020): Alternate address for Debtor
01 May 2023	navra1	TFS 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
*/

vars
	realAddress,
	pxyAddress	: CM_Address;
	debtor,
	pxyDebtor	: CM_Debtor; 
	code,
	description,
	address1,
	address2,
	address3,
	region,
	postCode,
	countryCode,
	countryName	: String;
	ls,
	isDefault,
	isAlt		: Boolean;
	theReturn   : Integer;
	city 		: String;					//navra1 - TFS 57086 - 1st May 2023
	email 		: String;					//navra1 - TFS 57086 - 1st May 2023
begin
	code 		:= self.txtAddrCode.text;
	description := self.txtAddrDescription.text;
	address1	:= self.txtAddrAdr1.text;
	address2	:= self.txtAddrAdr2.text;
	address3	:= self.txtAddrAdr3.text;
	region		:= self.txtAddrRegion.text;
	postCode	:= self.txtAddrPostCode.text;
	city		:= self.txtCity.text;				//navra1 - TFS 57086 - 1st May 2023
	email 		:= self.txtEmail.text;				//navra1 - TFS 57086 - 1st May 2023	
	
	if self.cmbAddrCountry.listObject &lt;&gt; null then
		countryCode := self.cmbAddrCountry.listObject.CM_Country.code;
	endif; 
	
	if self.myDebtorNode &lt;&gt; null and self.myDebtorNode.isKindOf(CM_Debtor) then
		debtor := self.myDebtorNode.CM_Debtor;
	endif;
	isDefault := self.chkDefultAddess.value;
	
	isAlt	  := self.chkAltAddress.value;	// 02/09/22	navkc1	#54564(54372.020)
	
	if self.myCurrentDebtorAddress &lt;&gt; null then
		realAddress := self.myCurrentDebtorAddress;
		pxyAddress  := app.createUpdateProxy(realAddress).CM_Address;
	else
		create pxyAddress transient;
	endif;
	pxyAddress.setProxy(code,
							description,
							address1,
							address2,
							address3,
							region,
							postCode,
							countryCode,
							city,						//navra1 - TFS 57086 - 1st May 2023
							email,						//navra1 - TFS 57086 - 1st May 2023
							null,
							isDefault,
							isAlt,		// 02/09/22	navkc1	#54564(54372.020)
							debtor);

							
	while true do
		if realAddress = null then
			app.myTrxCA.trxCreateDebtorAddress(pxyAddress,realAddress, app.myPassport);
		else
			app.myTrxUA.trxUpdateDebtorAddress(pxyAddress,realAddress, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.btnAddrSave.enabled := false;
			pxyDebtor := debtor.pxyGetProxyObject();
			app.cmsBeginLoad(ls);
			app.myProxyManager.deleteProxyLink(pxyDebtor);
			delete self.myProxyDebtorNode;
			self.myProxyDebtorNode := debtor.pxyCreateUpdateProxy();
			return true;
		else
			theReturn := app.showErrorWarningDialog("Debtor Address", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	
	endwhile;
	
	
	return false;
epilog
	app.cmsEndLoad(ls);
	delete pxyAddress;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveInvTypesAndLineTypes" id="8977a8d7-98b6-443d-b8c6-0ed25ca77e4b">
        <source>doSaveInvTypesAndLineTypes(_invTypes, _invLineTypes : CM_ObjectArray io);
//
// Purpose:			Save off all debtor invoice types and invoice line types so we can reattach them to a newly
//					created proxy (after cash terminal updates have been done)
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/10/2019	jlgdap1		Initial creation TFS 46813 JMT Cannot add invoice package to debtor
//
vars
	invType : CM_DebtorInvType;
	invLineType : CM_DebtorInvLineType;
	obj : Object;

begin
	// save off all debtor invoice types and invoice line types
	foreach invType in self.myProxyDebtorNode.CM_Debtor.allDebtorInvTypes do
		_invTypes.add(invType);
	endforeach;
	foreach invLineType in self.myProxyDebtorNode.CM_Debtor.allDebtorInvLineTypes do
		_invLineTypes.add(invLineType);
	endforeach;
	
	// now null their debtor to remove them from the proxy's collections
	foreach obj in _invTypes do
		obj.CM_DebtorInvType.setPropertyValue(CM_DebtorInvType::myDebtor.name, null);
	endforeach;
	foreach obj in _invLineTypes do
		obj.CM_DebtorInvLineType.setPropertyValue(CM_DebtorInvLineType::myDebtor.name, null);
	endforeach;
epilog

end;</source>
        <Parameter name="_invTypes" type="CM_ObjectArray" usage="io"/>
        <Parameter name="_invLineTypes" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSetDebtorNodeController" id="8d3cc52a-10e5-4059-8429-babf42860413">
        <updating/>
        <source>doSetDebtorNodeController(_debtorNodeController: CMIF_DebtorNode input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/09/17 	jlgns1 	TFS 6921 1201 : ADP Kernel stack overflow
08/08/18	jlgdap1 TFS 40092 PEL1 Adding Changes to Debtors
08/08/18 	cnwma1	ChangeRequest 40092: PEL1 - Adding Changes to Debtors
30/05/19	jlgdap1	TFS 44554 AAT Stevedore Data Access
08/10/19	jlgdap1	TFS 46813 JMT cannot add invoice package to debtor
25/02/2019	cnwma1	Bug 48503: JMT - Error 1086 when updating Debtor Groups
01 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
17 Aug	2022	navpw1	TFS: 54564 (54374) - EUP - Inv Config - DB Changes
1  May 	2023	navra1   TFS 57086  - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
28 Aug 2023		navra1	TFS 60064 - MTN - Org Code saves as Interterminal Code and vice versa
*/
vars
	theBank 				: CM_Bank;
	ls						: Boolean;
	rdg	 		 			: CM_RootDebtorGroup;
	row 		 			: Integer;
	term 		 			: CM_Terminal;
	debtor,
	pxyDebtor				: CM_Debtor;
	invTypes,
	invLineTypes 			: CM_ObjectArray;			// TFS 46813
	
	debtorTerminalDetail 	: CMIF_DebtorTerminalDetail;
	paymenttype 			: Integer;
	usescash 				: Boolean;
	currencyType 			: CM_CurrencyType; 			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	locale 					: CM_Locale; 				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	currencyTypeCode, 
	localeDescription,
	defaultInvoiceJRW 		: String; 					// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	interTerminalCode		: String;					//navra1 - TFS 57086 - 1st May 2023
	orgCode					: String;					//navra1 - TFS 57086 - 1st May 2023
begin
	theBank := app.myRoot.myRootCompany;
	rdg 	:= theBank.getRootDebtorGroup();
	
	if self.debtorType = DebtorType_Debtor then
		self.allSelectedCarriers.copy(_debtorNodeController.allCarriers);
		self.allSelectedConsignors.copy(_debtorNodeController.allConsignors);
		self.allSelectedCustomsAgents.copy(_debtorNodeController.allCustomsAgents);
		self.allSelectedDebtorTypes.copy(_debtorNodeController.allDebtorTypes);
		self.allSelectedOperators.copy(_debtorNodeController.allOperators);
		self.allSelectedContacts.copy(_debtorNodeController.allContacts); 
		self.allSelectedStevedores.copy(_debtorNodeController.allStevedores);	
		self.allSelectedShippingLine.copy(_debtorNodeController.allShippingLines);		// Jun 1, 2022 navak20 TFS 53204
		
		if	self.chkReefDaily.value = true then
			_debtorNodeController.allSpecialReleaseTxnTypes.add(TRANS_TYPE_ReeferDaily);
		endif;
		if self.chkReefFlatRate.value = true then
			_debtorNodeController.allSpecialReleaseTxnTypes.add(TRANS_TYPE_ReeferFlatRate);
		endif;
		
		_debtorNodeController.longName:= self.txtDebLongName.text;
	endif;
	// 31272 limit lengths
	_debtorNodeController.isPurchaseOrderMandatory := self.chkPOMandatory.value;
	_debtorNodeController.billingAddress 		   := self.txtAddress.text;
	_debtorNodeController.decfinName 			   := self.txtAcctCode.text[1:40];
	_debtorNodeController.externalReference 	   := self.txtExternalRef.text;
	_debtorNodeController.isSuspended 			   := self.chkSuspended.value;
	_debtorNodeController.isZeroRated 			   := self.chkZeroRated.value;
	_debtorNodeController.badDebtor 			   := self.chkBadCredit.value;
	_debtorNodeController.myBank 				   := theBank;
	_debtorNodeController.myTermsOfTrade 		   := self.cmbTerms.listObject.CM_InvoiceTermsOfTrade;
	_debtorNodeController.myParentDebtorNode 	   := null;
	
	if  self.myDebtorNode &lt;&gt; null and self.myDebtorNode.isRootDebtorGroup() then		//TFS 6921
		//We never want to set parent on root node										//TFS 6921
	else																				//TFS 6921
		if self.cmbParent.listIndex &lt; 0 then
			_debtorNodeController.myParentDebtorNode := rdg;
		else
			_debtorNodeController.myParentDebtorNode := self.cmbParent.listObject.CM_DebtorNode;
		endif;
	endif;
	
	_debtorNodeController.myPxyDebtorNode := self.myProxyDebtorNode;
	self.myProxyDebtorNode.setProxySuspend(_debtorNodeController.isSuspended);

	_debtorNodeController.name 					   := self.txtDebtorName.text[1:100];	// TFS 40092
	_debtorNodeController.code 					   := self.txtCode.text;				//08.8.2018 cnwma1 TFS #340092
	_debtorNodeController.purchaseOrderCode 	   := self.txtPurchaseOrdNo.text[1:10];
	_debtorNodeController.remarks 				   := self.txtRemarks.text;
	_debtorNodeController.doDebtorInvoiceTypes     := true;
	_debtorNodeController.doDebtorInvoiceLineTypes := true;
	_debtorNodeController.additionalInformation1   := self.txtAddInfo1.text.trimBlanks;	//26 Mar 2018	NDL	TFS 37559
	_debtorNodeController.additionalInformation2   := self.txtAddInfo2.text.trimBlanks;	//26 Mar 2018	NDL	TFS 37559
	_debtorNodeController.taxNumber				   := self.txtTaxNumber.text.trimBlanks;			//navra1 - TFS 57086 - 1st May 2023
	_debtorNodeController.taxCountry			   := self.cmbTaxCountry.listObject.CM_Country;		//navra1 - TFS 57086 - 1st May 2023
	
	
	//17 July 2012	NDL	Par 29968
 // ### TFS 52237 27OCT2021 NAVAB1	_debtorNodeController.allCashOnlyTerminals.clear();
 // ### TFS 52237 27OCT2021 NAVAB1	if app.isCashOnlyEnabled then
		foreach row in self.tblTermConfig.fixedRows + 1 to self.tblTermConfig.rows do
			term := self.tblTermConfig.accessCell(row,1).itemObject.CM_Terminal;
//			if term &lt;&gt; null and self.myDebtorNode &lt;&gt; null then // UPDATING
//				app.myTrxUA.trxUpdateTermDrPaymentType(self.myDebtorNode.CM_Debtor, term, self.tblTermConfig.accessCell(row, 3).comboIndex - 1, app.myPassport);
//			endif; // ### TFS 52237 27OCT2021 NAVAB1


			usescash := self.tblTermConfig.getCellText(row,2).Integer.Boolean;
//			if usescash then
//				_debtorNodeController.allCashOnlyTerminals.add( term );
//			endif;
			
			paymenttype := self.tblTermConfig.accessCell(row, 3).comboIndex - 1;
			
			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			currencyTypeCode 	:= self.tblTermConfig.accessCell(row, 4).text;
			currencyType 		:= app.myRoot.allCurrencyTypes[currencyTypeCode];
			localeDescription 	:= self.tblTermConfig.accessCell(row, 5).text;
			
			if localeDescription = app.getErrorString(None) then //Set to null if set to none makes lookup faster
				localeDescription := null;
			endif;
			
			locale 				:= app.myRoot.allLocales.getLocaleByDescription(localeDescription);
			defaultInvoiceJRW	:= self.tblTermConfig.accessCell(row, 6).text;
			
			if defaultInvoiceJRW = app.getErrorString(None) then //Set our default invoice jrw to null if it is set to none
				defaultInvoiceJRW := null;
			endif;
			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			
			create debtorTerminalDetail transient;
			debtorTerminalDetail.setPaymentType(paymenttype);
			debtorTerminalDetail.setMyTerminal(term);
			debtorTerminalDetail.setCashOnly(usescash);
			
			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			debtorTerminalDetail.setDefaultInvoiceJRW(defaultInvoiceJRW);
			debtorTerminalDetail.setMyLocale(locale);
			debtorTerminalDetail.setMyCurrencyType(currencyType);
			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			
			//navra1 - TFS 57086 - 1st May 2023 - start
			//navra1 - TFS 60064 - 28th Aug 2023
			orgCode := self.tblTermConfig.accessCell(row, 7).text;
			debtorTerminalDetail.setOrgCode(orgCode);

			interTerminalCode := self.tblTermConfig.accessCell(row, 8).text;
			debtorTerminalDetail.setInterTerminalCode(interTerminalCode);
			//navra1 - TFS 60064 - 28th Aug 2023
			//navra1 - TFS 57086 - 1st May 2023 - end
			
			_debtorNodeController.allDebtorTerminalDetails.add(debtorTerminalDetail);
		endforeach;
		
		if self.myDebtorNode.isKindOf(CM_Debtor) then                          // 25.02.2020 cnwma1 #48503
			if self.myDebtorNode &lt;&gt; null and self.myDebtorNode.edition() &lt;&gt; self.myProxyDebtorNode.edition() then		// 19/8/19 MAP TFS45577
				debtor 	  := self.myDebtorNode.CM_Debtor;
				pxyDebtor := debtor.pxyGetProxyObject();
				create invTypes transient;										// TFS 46813
				create invLineTypes transient;									// TFS 46813
				self.doSaveInvTypesAndLineTypes(invTypes, invLineTypes);		// TFS 46813
				app.cmsBeginLoad(ls);
				app.myProxyManager.deleteProxyLink(pxyDebtor);
				delete self.myProxyDebtorNode;
				self.myProxyDebtorNode := debtor.pxyCreateUpdateProxy();
				self.doRestoreInvTypesAndLineTypes(invTypes, invLineTypes);		// TFS 46813
				_debtorNodeController.myPxyDebtorNode := self.myProxyDebtorNode;
			endif;
		endif;
 // ### TFS 52237 27OCT2021 NAVAB1	endif;

	self.myProxyDebtorNode.setProxy(_debtorNodeController.name, _debtorNodeController.code);	// TFS 40092

epilog
	app.cmsEndLoad(ls);
	delete invTypes;			// TFS 46813
	delete invLineTypes;		// TFS 46813
end;</source>
        <access>protected</access>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSortByColumn" id="7adc7786-07be-4590-9df6-60937229808f">
        <source>doSortByColumn(_table : CM_DataTable input) protected;

vars

begin
	
	if _table.row &gt; _table.fixedRows then
		return;
	endif;

	if _table.sortColumn[1] &gt; 0 then
		_table.accessCell(1,_table.sortColumn[1]).fontBold := false;
	endif;

	_table.resortTableByColumn(_table.column);

	_table.accessCell(1,_table.column).fontBold := true;
	_table.colourRows (self.colorRow1, self.colorRow2);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblITLRowColChg" id="04044cce-5a57-422c-b102-424b7d2a34b1">
        <updating/>
        <source>doTblITLRowColChg() updating, protected;

vars
	row,
	col		: Integer;
	code	: String;
	invLineType	: CM_InvoiceLineDesc;
	dilt	: CM_DebtorInvLineType;
begin
	row := self.tblILT.row;
	col := self.tblILT.column;
	if col &lt;&gt; 3 then
		return;
	endif;
	invLineType := self.tblILT.accessRow(row).itemObject.CM_InvoiceLineDesc;
	dilt := self.myProxyDebtorNode.CM_Debtor.allDebtorInvLineTypes[invLineType];
	code := self.tblILT.accessCell(row, col).text.trimBlanks();
	if code = null and
	   dilt &lt;&gt; null then
		delete dilt;
	endif;
	if code &lt;&gt; null then
		if dilt = null then
			create dilt transient;
			dilt.setup(self.myProxyDebtorNode.CM_Debtor, invLineType, code);
		else
			dilt.setOtherCode(code);
		endif;
	endif;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="15fcf3c7-1b4b-40ee-a3ec-e774e7c9c40a">
        <updating/>
        <source>doUserNotify(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating, protected;

vars
	row			: Integer;
	str1,
	str2		: String;
	tblObj,
	invType		: CM_InvoiceDesc;
	debtorInvType	: CM_DebtorInvType;
begin
	// _eventType is 277, _userInfo is a CM_InvoiceDesc
	if _eventType = Event_InvoiceUpdate then
		invType := _userInfo.CM_InvoiceDesc;
		// find in table and update the text
		foreach row in self.tblIT.fixedRows+1 to self.tblIT.rows do
			tblObj := self.tblIT.accessRow(row).itemObject.CM_InvoiceDesc;
			if tblObj = invType then
				debtorInvType := self.myProxyDebtorNode.CM_Debtor.allDebtorInvTypes[invType];
				if debtorInvType &lt;&gt; null then
					str1 := app.getYesBlank(debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode);
					str2 := debtorInvType.getPackageDetails();
				endif;
				self.tblIT.accessCell(row, 3).text := str1;
				self.tblIT.accessCell(row, 4).text := str2;
				break;
			endif;
		endforeach;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="duplicateProxyException" id="eb1e9f97-2dd9-455e-be75-63280e580aa0">
        <source>duplicateProxyException(exObj : Exception; hadException : Boolean output) : Integer protected;
// when two or more copies of this form are run for the same debtor
// the new copies get a ProxyAlreadyExists exception - just close down the extra forms
vars

begin

	if exObj.errorCode = ProxyAlreadyExists then
		hadException := true;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="hadException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="enableDisableAddressDetails" id="865ade73-d068-423b-be74-fdee3136b1a4">
        <source>enableDisableAddressDetails(_value : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
22 Sept 2022	navkc1	ChangeRequest 54564(54372.020): Alternate address for Debtor
1st May 2023	navra1	TFS 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
*/

vars

begin
	self.chkDefultAddess.enabled     := _value;
	self.chkAltAddress.enabled		 := _value; //02/09/22	navkc1	#54564(54372.020)
	self.cmbAddrCountry.enabled 	 := _value;
	self.txtAddrCode.enabled         := _value;
	self.txtAddrDescription.enabled  := _value;
	self.txtAddrAdr1.enabled         := _value;
	self.txtAddrAdr2.enabled         := _value;
	self.txtAddrAdr3.enabled         := _value;
	self.txtAddrRegion.enabled       := _value;
	self.txtAddrPostCode.enabled     := _value;
	self.txtCity.enabled			 := _value;				//navra1 - TFS 57086 - 1st May 2023
	self.txtEmail.enabled			 := _value;				//navra1 - TFS 57086 - 1st May 2023

epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEntityText" id="6c4a5134-13fa-45c2-b30f-14fcef168f01">
        <updating/>
        <source>getEntityText(obj : Object; _includeDebtor : Boolean) : String updating, protected;
// return the string to populate the selected entity table, for agent, consignor, operator etc
// for the available table, the _includeDebtor parameter is true (3 columns) and for the selected table, false (2 columns)
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------------------
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 02 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
vars
	debtorName,
	text	: String;
	carrier	: CM_Carrier;
	consign	: CM_ConsigneeConsignor;
	agent	: CM_CustomsAgent;
	debtorType : CM_DebtorType;
	oper	: CM_Operator;
	debtor	: CM_Debtor;
	stevedore : CM_Stevedore;				// TFS 44554
	shippingLine : CM_ShippingLine;			// Jun 2, 2022 navak20 TFS 53204
begin
	if obj.isKindOf(CM_Carrier) then
		carrier := obj.CM_Carrier;
		text := carrier.code &amp; Tab &amp; carrier.description;
		if _includeDebtor then
			text := text &amp; Tab;
		endif;
	elseif obj.isKindOf(CM_ConsigneeConsignor) then
		consign := obj.CM_ConsigneeConsignor;
		text := consign.code &amp; Tab &amp; consign.description;
		if _includeDebtor then
			if consign.debtor = null then
				debtorName := null;
			else
				debtorName := consign.debtor.name;
			endif;
			text := text &amp; Tab &amp; debtorName;
		endif;
	elseif obj.isKindOf(CM_CustomsAgent) then
		agent := obj.CM_CustomsAgent;
		text := agent.code &amp; Tab &amp; agent.name;
		if _includeDebtor then
			if agent.myDebtor = null then
				debtorName := null;
			else
				debtorName := agent.myDebtor.name;
			endif;
			text := text &amp; Tab &amp; debtorName;
		endif;
	elseif obj.isKindOf(CM_DebtorType) then
		debtorType := obj.CM_DebtorType;
		text := debtorType.code &amp; Tab &amp; debtorType.description;
		if _includeDebtor then
			if debtorType.myDefaultDebtor = null then
				debtorName := null;
			else
				debtorName := debtorType.myDefaultDebtor.name;
			endif;
			text := text &amp; Tab &amp; debtorName;
		endif;
	elseif obj.isKindOf(CM_Operator) then
		oper := obj.CM_Operator;
		text := oper.code &amp; Tab &amp; oper.description;
		if _includeDebtor then
			if oper.debtor = null then
				debtorName := null;
			else
				debtorName := oper.debtor.name;
			endif;
			text := text &amp; Tab &amp; debtorName;
		endif;
	elseif obj.isKindOf(CM_EmailAddress2) then
		text := obj.CM_EmailAddress2.name; //epr par 35304 2/12/14
		
	elseif obj.isKindOf(CM_Stevedore) then							// TFS 44554
		stevedore := obj.CM_Stevedore;								// TFS 44554
		text := stevedore.code &amp; Tab &amp; stevedore.description;		// TFS 44554
		if _includeDebtor then										// TFS 44554
			if stevedore.myDebtor = null then						// TFS 44554
				debtorName := null;									// TFS 44554
			else													// TFS 44554
				debtorName := stevedore.myDebtor.name;				// TFS 44554
			endif;													// TFS 44554
			text := text &amp; Tab &amp; debtorName;						// TFS 44554
		endif;														// TFS 44554
	
	// Jun 2, 2022 navak20 TFS 53204 Start
	elseif	obj.isKindOf(CM_ShippingLine) then					
		shippingLine := obj.CM_ShippingLine;						
		text := shippingLine.code &amp; Tab &amp; shippingLine.description;		
		if _includeDebtor then										
			if shippingLine.myDebtor = null then						
			else													
				debtorName := shippingLine.myDebtor.name;				
			endif;													
			text := text &amp; Tab &amp; debtorName;						
		endif;														
	// Jun 2, 2022 navak20 TFS 53204 end
	endif;

	return text;
end;
</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
        <Parameter name="_includeDebtor" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadCarriers" id="f950b86f-2e23-47b3-ab81-99100c3900c5">
        <source>loadCarriers() protected;

vars
	carriers	: ObjectSet;
	dynaDict	: DynaDictionary;
	iter		: Iterator;
	obj			: Object;
	carrier		: CM_Carrier;
begin
	create carriers transient;
	if app.myRoot.myRootCompany.rootDebtor &lt;&gt; self.myDebtorNode then
		app.myRoot.allCarriers.copy(carriers);
	else
		self.myDebtorNode.CM_Debtor.allCarriers.copy(carriers);
	endif;
	create dynaDict transient;
	dynaDict.setMembership(CM_Carrier);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.addMemberKey("code", false, true);
	dynaDict.endKeys(true);
	
	// own and unattached carriers
	foreach obj in carriers do
		carrier := obj.CM_Carrier;
		if carrier.myDebtor = null or 
		   carrier.myDebtor.isKindOf(CM_VoidDebtor) or
		   carrier.myDebtor = self.myDebtorNode then
			if self.allSelectedCarriers.includes(carrier) then
				continue;
			endif;
			dynaDict.add(carrier);
		endif;
	endforeach;
	
	self.lblAvail.caption := app.getErrorString(Available_Carriers);
	self.tblAvailEnts.rows := self.tblAvailEnts.fixedRows;
	self.tblAvailEnts.row :=1;
	self.tblAvailEnts.text:=(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Name) &amp; Tab &amp; app.getErrorString(INV_Debtor));
	self.tblAvailEnts.clearAllSelected();
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		carrier := obj.CM_Carrier;
		self.tblAvailEnts.addItemObject(carrier, carrier.code &amp; Tab &amp; carrier.description &amp; Tab);
	endwhile;

	self.lblSelected.caption := app.getErrorString(Selected_Carriers);
	self.tblSelectedEnts.rows := self.tblSelectedEnts.fixedRows;
	self.tblSelectedEnts.clearAllSelected();
	foreach carrier in self.allSelectedCarriers do
		self.tblSelectedEnts.addItemObject(carrier, carrier.code &amp; Tab &amp; carrier.description);
	endforeach;

epilog
	delete carriers;
	delete iter;
	delete dynaDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadConsignees" id="86b65c2b-acaf-4725-b853-fba4bb253b0c">
        <source>loadConsignees() protected;

vars
	debtorName	: String;
	dynaDict	: DynaDictionary;
	iter		: Iterator;
	consign		: CM_ConsigneeConsignor;
	obj			: Object;

begin
	create dynaDict transient;
	dynaDict.setMembership(CM_ConsigneeConsignor);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.addMemberKey("code", false, true);
	dynaDict.endKeys(true);

	// all consignees/ors
	app.myRoot.allConsigneeConsignors.copy(dynaDict);

	self.lblAvail.caption := app.getErrorString(Available_Consignors);
	self.tblAvailEnts.rows := self.tblAvailEnts.fixedRows;
	self.tblAvailEnts.row :=1;
	self.tblAvailEnts.text:=(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Name) &amp; Tab &amp; app.getErrorString(INV_Debtor));
	self.tblAvailEnts.clearAllSelected();
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		consign := obj.CM_ConsigneeConsignor;
		if self.allSelectedConsignors.includes(consign) then
			continue;
		endif;
		if consign.debtor = null then
			debtorName := null;
		else
			debtorName := consign.debtor.name;
		endif;
		self.tblAvailEnts.addItemObject(consign, consign.code &amp; Tab &amp; consign.description &amp; Tab &amp; debtorName);
	endwhile;
	
	self.lblSelected.caption := app.getErrorString(Selected_Consignors);
	self.tblSelectedEnts.rows := self.tblSelectedEnts.fixedRows;
	self.tblSelectedEnts.clearAllSelected();
	foreach consign in self.allSelectedConsignors do
		self.tblSelectedEnts.addItemObject(consign, consign.code &amp; Tab &amp; consign.description);
	endforeach;

epilog
	delete dynaDict;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadContacts" id="290bf3c9-ed3a-4d30-8373-ab489fe7b3e7">
        <source>loadContacts() protected;
/*

Date		Who		Reason
28 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	contact : CM_EmailEntity;
	iter : Iterator;
	obj : Object;
begin
	self.lblAvail.caption := app.getErrorString(Available_contacts);
	self.tblAvailEnts.rows := self.tblAvailEnts.fixedRows;
	self.tblAvailEnts.row :=1;
	self.tblAvailEnts.text:=(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Email) &amp; Tab &amp; app.getErrorString(INV_Debtor));
	self.tblAvailEnts.clearAllSelected();
	iter := app.myRoot.allEmailEntities.createIterator;
	app.myRoot.allEmailEntities.startKeyGeq(Email_Address,null,iter);
	while iter.next(contact) do
		if contact.type &lt;&gt; Email_Address then
			break;
		endif;
		
		if self.allSelectedContacts.includes(contact) then
			continue;
		endif;
		self.tblAvailEnts.addItemObject(contact, contact.name &amp; Tab &amp;contact.getEmailAddress);

	endwhile;
	
	self.lblSelected.caption := app.getErrorString(Selected_contacts);
	self.tblSelectedEnts.rows := self.tblSelectedEnts.fixedRows;
	self.tblSelectedEnts.clearAllSelected();
	foreach obj in self.allSelectedContacts do
		contact := obj.CM_EmailEntity;
		self.tblSelectedEnts.addItemObject(contact, contact.name);
	endforeach;
	
epilog

	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCustomsAgents" id="779f4f2b-5dac-4f5c-a52d-11f9f14b516e">
        <source>loadCustomsAgents() protected;

vars
	debtorName	: String;
	dynaDict	: DynaDictionary;
	iter		: Iterator;
	agent	 	: CM_CustomsAgent;
	obj			: Object;
begin
	create dynaDict transient;
	dynaDict.setMembership(CM_CustomsAgent);
	dynaDict.addMemberKey("name", false, true);
	dynaDict.addMemberKey("code", false, true);
	dynaDict.endKeys(true);

	// own and unattached customs agents 
	if self.myDebtorNode &lt;&gt; null then
		self.myDebtorNode.CM_Debtor.allCustomsAgents.copy(dynaDict);
	endif;
	foreach agent in 	app.myRoot.allCustomsAgents do
		if agent.myDebtor = null then
			dynaDict.add(agent);
		endif;
	endforeach;

	self.lblAvail.caption := app.getErrorString(Available_Customs_Agents);
	self.tblAvailEnts.rows := self.tblAvailEnts.fixedRows;
	self.tblAvailEnts.row :=1;
	self.tblAvailEnts.text:=(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Name) &amp; Tab &amp; app.getErrorString(INV_Debtor));
	self.tblAvailEnts.clearAllSelected();
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		agent := obj.CM_CustomsAgent;
	    if self.allSelectedCustomsAgents.includes(agent) then
			continue;
		endif;
		if agent.myDebtor = null then
			debtorName := null;
		else
			debtorName := agent.myDebtor.name;
		endif;
		self.tblAvailEnts.addItemObject(agent, agent.code &amp; Tab &amp; agent.name &amp; Tab &amp; debtorName);
	endwhile;

	self.lblSelected.caption := app.getErrorString(Selected_Customs_Agents);
	self.tblSelectedEnts.rows := self.tblSelectedEnts.fixedRows;
	self.tblSelectedEnts.clearAllSelected();
	foreach obj in self.allSelectedCustomsAgents do
		agent := obj.CM_CustomsAgent;
		self.tblSelectedEnts.addItemObject(agent, agent.code &amp; Tab &amp; agent.name);
	endforeach;

epilog
	delete dynaDict;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDebtorTypes" id="1719d3a7-2098-41c7-bbd8-80772ae51976">
        <source>loadDebtorTypes() protected;

vars
	debtorName	: String;
	dynaDict	: DynaDictionary;
	iter		: Iterator;
	debtorType  : CM_DebtorType;
	obj			: Object;

begin
	create dynaDict transient;
	dynaDict.setMembership(CM_DebtorType);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.addMemberKey("code", false, true);
	dynaDict.endKeys(true);

	// all user debtor types
	foreach debtorType in app.myRoot.allDebtorTypes where not debtorType.isNotAvailableForEntry do
		if not debtorType.isSystemGenerated() then
			dynaDict.add(debtorType);
		endif;
	endforeach;

	self.lblAvail.caption := app.getErrorString(Available_Debtor_Types);
	self.tblAvailEnts.rows := self.tblAvailEnts.fixedRows;
	self.tblAvailEnts.row :=1;
	self.tblAvailEnts.text:=(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Name) &amp; Tab &amp; app.getErrorString(INV_Debtor));
	self.tblAvailEnts.clearAllSelected();
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		debtorType := obj.CM_DebtorType;
		if self.allSelectedDebtorTypes.includes(debtorType) then
			continue;
		endif;
		if debtorType.myDefaultDebtor = null then
			debtorName := null;
		else
			debtorName := debtorType.myDefaultDebtor.name;
		endif;
		self.tblAvailEnts.addItemObject(debtorType, debtorType.code &amp; Tab &amp; debtorType.description &amp; Tab &amp; debtorName);
	endwhile;

	self.lblSelected.caption := app.getErrorString(Selected_Debtor_Types);
	self.tblSelectedEnts.rows := self.tblSelectedEnts.fixedRows;
	self.tblSelectedEnts.clearAllSelected();
	foreach obj in self.allSelectedDebtorTypes do
		debtorType := obj.CM_DebtorType;
		self.tblSelectedEnts.addItemObject(debtorType, debtorType.code &amp; Tab &amp; debtorType.description);
	endforeach;

epilog
	delete dynaDict;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadOperators" id="dad121a8-3d10-4f99-97ec-26b44683aa35">
        <source>loadOperators() protected;

vars
	debtorName	: String;
	dynaDict	: DynaDictionary;
	iter		: Iterator;
	oper		: CM_Operator;
	obj			: Object;

begin
	create dynaDict transient;
	dynaDict.setMembership(CM_Operator);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.addMemberKey("code", false, true);
	dynaDict.endKeys(true);

	// own operators plus unattached operators
	if self.myDebtorNode &lt;&gt; null then
		self.myDebtorNode.CM_Debtor.operators.copy(dynaDict);
	endif;
	if app.myRoot.myRootCompany.rootDebtor &lt;&gt; self.myDebtorNode then
		app.myRoot.myRootCompany.rootDebtor.operators.copy(dynaDict);
	endif;
		
	self.lblAvail.caption := app.getErrorString(Available_Operators);
	self.tblAvailEnts.rows := self.tblAvailEnts.fixedRows;
	self.tblAvailEnts.row :=1;
	self.tblAvailEnts.text:=(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Name) &amp; Tab &amp; app.getErrorString(INV_Debtor));
	self.tblAvailEnts.clearAllSelected();
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		oper := obj.CM_Operator;
		if self.allSelectedOperators.includes(oper) then
			continue;
		endif;
		if oper.debtor = null then
			debtorName := null;
		else
			debtorName := oper.debtor.name;
		endif;
		self.tblAvailEnts.addItemObject(oper, oper.code &amp; Tab &amp; oper.description &amp; Tab &amp; debtorName);
	endwhile;

	self.lblSelected.caption := app.getErrorString(Selected_Operators);
	self.tblSelectedEnts.rows := self.tblSelectedEnts.fixedRows;
	self.tblSelectedEnts.clearAllSelected();
	foreach oper in self.allSelectedOperators do
		self.tblSelectedEnts.addItemObject(oper, oper.code &amp; Tab &amp; oper.description);
	endforeach;

epilog
	delete dynaDict;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadShippingLine" id="7f270654-482f-4a30-a2ec-5ebf493f6308">
        <source>loadShippingLine() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/06/2022	navak20		ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 09-06-2023 	navtnr20 	Bug 58470: EUP | Debtor link - Shipping line
//
vars
	debtorName	: String;
	dynaDict	: DynaDictionary;
	iter		: Iterator;
	shippingLine 	: CM_ShippingLine;
	obj			: Object;
	
begin
	create dynaDict transient;
	dynaDict.setMembership(CM_ShippingLine);
	dynaDict.addMemberKey(CM_ShippingLine::code.name, false, true);
	dynaDict.addMemberKey(CM_ShippingLine::description.name, false, true);
	dynaDict.endKeys(true);

	// own and unattached stevedores
	if self.myDebtorNode &lt;&gt; null then
		self.myDebtorNode.CM_Debtor.allShippingLines.copy(dynaDict);
	endif;
	foreach shippingLine in app.myRoot.allShippingLines do
		if shippingLine.myDebtor = null 
		or shippingLine.myDebtor.isKindOf(CM_VoidDebtor) then // navtnr20 07-06-2023 58470
			dynaDict.add(shippingLine);
		endif;
	endforeach;

	self.lblAvail.caption := app.getErrorString(Available_ShippppingLine);
	self.tblAvailEnts.rows := self.tblAvailEnts.fixedRows;
	self.tblAvailEnts.clear;
	self.tblAvailEnts.row :=1;
	self.tblAvailEnts.text:=(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Description) &amp; Tab &amp; app.getErrorString(INV_Debtor));
	self.tblAvailEnts.clearAllSelected();
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		shippingLine := obj.CM_ShippingLine;
	    if self.allSelectedShippingLine.includes(shippingLine) then
			continue;
		endif;
		if shippingLine.myDebtor = null then
			debtorName := null;
		else
			debtorName := shippingLine.myDebtor.name;
		endif;
		self.tblAvailEnts.addItemObject(shippingLine, shippingLine.code &amp; Tab &amp; shippingLine.description &amp; Tab &amp; debtorName);
	endwhile;

	self.lblSelected.caption := app.getErrorString(Selected_ShippingLine);
	self.tblSelectedEnts.rows := self.tblSelectedEnts.fixedRows; 	
	self.tblSelectedEnts.clearAllSelected();
	foreach obj in self.allSelectedShippingLine do
		shippingLine := obj.CM_ShippingLine;
		self.tblSelectedEnts.addItemObject(shippingLine, shippingLine.code &amp; Tab &amp; shippingLine.description);
	endforeach;

epilog
	delete dynaDict;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadStevedores" id="b9b01cb5-5d7b-45c6-82f9-6bd1498db176">
        <source>loadStevedores() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	debtorName	: String;
	dynaDict	: DynaDictionary;
	iter		: Iterator;
	stevedore 	: CM_Stevedore;
	obj			: Object;
	
begin
	create dynaDict transient;
	dynaDict.setMembership(CM_Stevedore);
	dynaDict.addMemberKey(CM_Stevedore::description.name, false, true);
	dynaDict.addMemberKey(CM_Stevedore::code.name, false, true);
	dynaDict.endKeys(true);

	// own and unattached stevedores
	if self.myDebtorNode &lt;&gt; null then
		self.myDebtorNode.CM_Debtor.allStevedores.copy(dynaDict);
	endif;
	foreach stevedore in app.myRoot.allStevedores do
		if stevedore.myDebtor = null then
			dynaDict.add(stevedore);
		endif;
	endforeach;

	self.lblAvail.caption := app.getErrorString(Available_Stevedores);
	self.tblAvailEnts.rows := self.tblAvailEnts.fixedRows;
	self.tblAvailEnts.clear;
	self.tblAvailEnts.row :=1;
	self.tblAvailEnts.text:=(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Description) &amp; Tab &amp; app.getErrorString(INV_Debtor));
	self.tblAvailEnts.clearAllSelected();
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		stevedore := obj.CM_Stevedore;
	    if self.allSelectedStevedores.includes(stevedore) then
			continue;
		endif;
		if stevedore.myDebtor = null then
			debtorName := null;
		else
			debtorName := stevedore.myDebtor.name;
		endif;
		self.tblAvailEnts.addItemObject(stevedore, stevedore.code &amp; Tab &amp; stevedore.description &amp; Tab &amp; debtorName);
	endwhile;

	self.lblSelected.caption := app.getErrorString(Selected_Stevedores);
	self.tblSelectedEnts.rows := self.tblSelectedEnts.fixedRows;
	self.tblSelectedEnts.clearAllSelected();
	foreach obj in self.allSelectedStevedores do
		stevedore := obj.CM_Stevedore;
		self.tblSelectedEnts.addItemObject(stevedore, stevedore.code &amp; Tab &amp; stevedore.description);
	endforeach;

epilog
	delete dynaDict;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateBusinessUnitCombos" id="87d8960f-ae96-40ac-b65a-02ae826ab039">
        <updating/>
        <source>populateBusinessUnitCombos() updating, protected;

vars
	str		: String;
	bank	: CM_Bank;
	term	: CM_Terminal;
	userTerminals	: CM_TerminalByCodeDict;
begin
	self.cmbILTBU.clear();
	self.cmbITBU.clear();
	create userTerminals transient;
	app.getMyUser().getTerminals(userTerminals);

//	str := "&lt;" &amp; app.getErrorString(CM_LIT_ALL) &amp; "&gt;";
	str := "&lt;" &amp; app.getErrorString(Select_business_unit) &amp; "&gt;";	//03 Apr 2017	NDL	TFS 3940
	self.cmbILTBU.addItem(str);
	self.cmbITBU.addItem(str);
	foreach term in userTerminals do
		foreach bank in term.companies where (not bank.isSuspended) and (bank.isBusinessUnit) do
			str := bank.code &amp; " - " &amp; bank.mailingName &amp; " (" &amp; term.code &amp; ")";
			self.cmbILTBU.itemObject[self.cmbILTBU.addItem(str)] := bank;
			self.cmbITBU.itemObject[self.cmbITBU.addItem(str)] := bank;
			self.allUserBUs.add(bank);
		endforeach;
	endforeach;
	
	self.cmbILTBU.listIndex := 1;
	self.cmbITBU.listIndex := 1;
	
	self.doITCompanySelect();
	self.doILTCompanySelect();
epilog
	delete userTerminals;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateEntities" id="6d69d82a-7abb-4461-9859-e7dabd0c6c12">
        <updating/>
        <source>populateEntities() updating, protected;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/05/5019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 01 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

vars
	debtor		: CM_Debtor;
	carrier		: CM_Carrier;
	consign		: CM_ConsigneeConsignor;
	agent		: CM_CustomsAgent;
	debtorType	: CM_DebtorType;
	oper		: CM_Operator;
	stevedore	: CM_Stevedore;				// TFS 44554
	shippingLine : CM_ShippingLine;			// Jun 1, 2022 navak20 TFS 53204
begin
	if self.myDebtorNode = null then
		return;
	endif;
	debtor := self.myDebtorNode.CM_Debtor;
	foreach carrier in debtor.allCarriers do
		self.allSelectedCarriers.add(carrier);
	endforeach;
	
	foreach consign in debtor.consignors do
		self.allSelectedConsignors.add(consign);
	endforeach;

	foreach agent  in debtor.allCustomsAgents do
		self.allSelectedCustomsAgents.add(agent);
	endforeach;

	foreach debtorType in debtor.allDebtorTypes do
		self.allSelectedDebtorTypes.add(debtorType);
	endforeach;

	foreach oper in debtor.operators do
		self.allSelectedOperators.add(oper);
	endforeach;
	
	foreach stevedore in debtor.allStevedores do		// TFS 44554
		self.allSelectedStevedores.add(stevedore);		// TFS 44554
	endforeach;											// TFS 44554
	
	foreach shippingLine in debtor.allShippingLines do		//Jun 1, 2022 navak20 TFS 53204
		self.allSelectedShippingLine.add(shippingLine);		
	endforeach;
	
	 //epr par 35304 2/12/14
	debtor.allContacts.copy(self.allSelectedContacts); 
	
	self.showCurrentEntities();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateForm" id="2077be57-00f2-4fb6-9223-2970221698b0">
        <updating/>
        <source>populateForm() updating, protected;


//13/09/17 jlgns1 TFS 6921 1201 : ADP Kernel stack overflow
//08/08/2018  cnwma1	ChangeRequest 40092: PEL1 - Adding Changes to Debtors
//1/5/2023  	navra1   TFS 57086  - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
vars
	txnType	: Integer;
begin
	if self.myDebtorNode &lt;&gt; null then 						//TFS 6921
		if not self.myDebtorNode.isRootDebtorGroup() then	//TFS 6921
			self.doBuildComboParents();						//TFS 6921
		endif;												//TFS 6921
	else													//TFS 6921
		self.doBuildComboParents();							//TFS 6921
	endif;													//TFS 6921
	
	if self.myDebtorNode = null then
		return;
	endif;

	self.txtDebtorName.text := self.myDebtorNode.name;
	self.txtRemarks.text := self.myDebtorNode.remarks;
	self.chkZeroRated.value := self.myDebtorNode.isZeroRatedTax;
	self.chkBadCredit.value :=  self.myDebtorNode.badDebtor;
	self.chkSuspended.value := self.myDebtorNode.isSuspended;
	self.chkPOMandatory.value := self.myDebtorNode.isPurchaseOrderMandatory;
	if self.debtorType = DebtorType_Debtor then
		self.txtDebLongName.text:= self.myDebtorNode.CM_Debtor.longName;
		self.txtCode.text       := self.myDebtorNode.CM_Debtor.code ;    			//08.8.2018 cnwma1 TFS #340092
		self.txtAddress.text := self.myDebtorNode.CM_Debtor.getBillingAddressString();
		self.txtAcctCode.text := self.myDebtorNode.CM_Debtor.decfinName;
		self.txtExternalRef.text := self.myDebtorNode.CM_Debtor.externalReference;
		self.txtPurchaseOrdNo.text := self.myDebtorNode.CM_Debtor.purchaseOrderCode;
		if self.cmbTerms.findObject(self.myDebtorNode.CM_Debtor.myTermsOfTrade) &gt; 0 then
			self.cmbTerms.listObject := self.myDebtorNode.CM_Debtor.myTermsOfTrade;
		else
			self.cmbTerms.listObject := null;
		endif;		
		foreach txnType in self.myDebtorNode.CM_Debtor.allSpecialReleaseTxnTypes do
			if txnType = TRANS_TYPE_ReeferDaily then
				self.chkReefDaily.value := true;
			elseif txnType = TRANS_TYPE_ReeferFlatRate then
				self.chkReefFlatRate.value := true;
			endif;
		endforeach;
		self.txtAddInfo1.text:= self.myDebtorNode.CM_Debtor.additionalInformation1;	//22 Mar 2018	NDL	TFS 37559
		self.txtAddInfo2.text:= self.myDebtorNode.CM_Debtor.additionalInformation2;	//22 Mar 2018	NDL	TFS 37559
		self.txtTaxNumber.text			:= self.myDebtorNode.taxNumber;							//navra1 - TFS 57086 - 1st May 2023		
		if self.cmbTaxCountry.findObject(self.myDebtorNode.myTaxCountry) &gt; 0 then				//navra1 - TFS 57086 - 1st May 2023
			self.cmbTaxCountry.listObject := self.myDebtorNode.myTaxCountry;					//navra1 - TFS 57086 - 1st May 2023
		else																					//navra1 - TFS 57086 - 1st May 2023
			self.cmbTaxCountry.listObject := null;												//navra1 - TFS 57086 - 1st May 2023
		endif;																					//navra1 - TFS 57086 - 1st May 2023
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateShtDebtorAddresses" id="7630d3bb-89a6-445e-90ce-d1dc6b625e3a">
        <source>populateShtDebtorAddresses();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
02 Sept 2022	navkc1	ChangeRequest 54564(54372.020): Alternate address for Debtor
*/

vars
	iter	 : Iterator;
	address  : CM_Address;
	index	 : Integer;
begin
	self.tblAddrDetails.clear();
	
	self.tblAddrDetails.columns := 4;
	self.tblAddrDetails.fixedColumns := 0;
	self.tblAddrDetails.rows := 1;
	self.tblAddrDetails.fixedRows := 1;
	self.tblAddrDetails.selectMode := Table.SelectMode_CurrentRow;
	
	//self.tblAddrDetails.setCellText(1,1, app.getErrorString(Id) &amp; Tab &amp; app.getErrorString(Description) &amp; Tab &amp; app.getErrorString(Default) );
	self.tblAddrDetails.setCellText(1,1, app.getErrorString(Id) &amp; Tab &amp; app.getErrorString(Description) &amp; Tab &amp; app.getErrorString(Default) &amp; Tab &amp; app.getErrorString(Alternate) ); // 02/09/22	navkc1	#54564(54372.020)
	
	if self.tblAddrDetails.sortColumn[1] &gt; 0 then
		self.tblAddrDetails.accessRow(1).fontBold := false;
		self.tblAddrDetails.accessCell(1, self.tblAddrDetails.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myDebtorNode &lt;&gt; null then
		iter := self.myDebtorNode.CM_Debtor.allAddressesByCode.createIterator;
		
		while iter.next( address ) do
		
			//index := self.tblAddrDetails.addItem( address.code &amp; Tab &amp; address.description &amp; Tab &amp; address.isDefault.getYesNo() );
			index := self.tblAddrDetails.addItem( address.code &amp; Tab &amp; address.description &amp; Tab &amp; address.isDefault.getYesNo() &amp; Tab &amp; address.isAlternative.getYesNo() ); // 02/09/22	navkc1	#54564(54372.020)
			self.tblAddrDetails.accessRow(index).itemObject := address;
		endwhile;
	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="recolourTable" id="216d1e9c-83a9-4ba2-9c6f-e8cfc15ee486">
        <updating/>
        <source>recolourTable(_table : Table input) updating, protected;

vars
	idx,
	startRow,
	endRow		: Integer;
begin
	startRow	:= _table.fixedRows + 1;
	endRow		:= _table.rows;
	
	// re-colour
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			_table.accessRow(idx).backColor := self.colorRow1;
		else
			_table.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeSelectedEntity" id="79bc9a22-6665-4d15-ad3b-9f0f306f90d2">
        <updating/>
        <source>removeSelectedEntity(_obj : Object) updating, protected;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 01 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

vars

begin
	if _obj.isKindOf(CM_Carrier) then
		self.allSelectedCarriers.remove(_obj.CM_Carrier);
	elseif _obj.isKindOf(CM_ConsigneeConsignor) then
		self.allSelectedConsignors.remove(_obj.CM_ConsigneeConsignor);
	elseif _obj.isKindOf(CM_CustomsAgent) then
		self.allSelectedCustomsAgents.remove(_obj);
	elseif _obj.isKindOf(CM_DebtorType) then
		self.allSelectedDebtorTypes.remove(_obj);
	elseif _obj.isKindOf(CM_Operator) then
		self.allSelectedOperators.remove(_obj.CM_Operator);
	elseif _obj.isKindOf(CM_EmailAddress2) then //epr par 35304 2/12/14
		self.allSelectedContacts.remove(_obj);
	elseif _obj.isKindOf(CM_Stevedore) then 			// TFS 44554
		self.allSelectedStevedores.remove(_obj);		// TFS 44554
	elseif	_obj.isKindOf(CM_ShippingLine) then			// Jun 1, 2022 navak20 TFS 53204
		self.allSelectedShippingLine.remove(_obj);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setChanged" id="167070f1-d5d4-4d46-808b-30a9319b7c11">
        <updating/>
        <source>setChanged() updating, protected;

vars

begin
	self.isFormChanged := true;
	self.btnSave.enabled := true;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fbf5f920-f7e3-45cf-8839-ffef0bf38cf0">
        <updating/>
        <source>setupForm() updating;
//08/08/2018    cnwma1	ChangeRequest 40092: PEL1 - Adding Changes to Debtors
//22/07/2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
//1/5/2023		navra1	CR 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
vars
	hadException,
	ls		: Boolean;
begin
	on Exception do duplicateProxyException(exception, hadException);

	if self.myDebtorNode = null then
		if self.debtorType = DebtorType_Debtor then
			create self.myProxyDebtorNode as CM_Debtor transient;
			self.caption := self.caption &amp; " - New Debtor";
		elseif self.debtorType = DebtorType_Group then
			create self.myProxyDebtorNode as CM_DebtorGroup transient;
			self.caption := self.caption &amp; " - New Debtor Group";
		endif;
	else
		self.caption := self.caption &amp; " - " &amp; self.myDebtorNode.name;
		app.cmsBeginLoad(ls);
		if self.debtorType = DebtorType_Debtor then
			self.myProxyDebtorNode := app.createUpdateProxy(self.myDebtorNode).CM_Debtor;
		elseif self.debtorType = DebtorType_Group then
			self.myProxyDebtorNode := app.createUpdateProxy(self.myDebtorNode).CM_DebtorGroup;
		endif;
		app.cmsEndLoad(ls);
	endif;
	
	if hadException then	// second form for same debtor - just close this one
		unloadForm();
		return;
	endif;
	
	if self.debtorType = DebtorType_Debtor and
	   self.myProxyDebtorNode &lt;&gt; null then
		self.beginNotification(self.myProxyDebtorNode.CM_Debtor, Event_InvoiceUpdate, Response_Continuous, 0);
	endif;

	inheritMethod();
	
	if self.debtorType = DebtorType_Group then
		// hide much of the form
		self.lblAcctCode.visible := false;
		self.lblAddress.visible := false;
		self.txtAcctCode.visible  := false;
		self.lblCode.visible      := false;  //08.8.2018 cnwma1 TFS #340092
		self.txtCode.visible      := false;  //08.8.2018 cnwma1 TFS #340092
		self.txtAddress.visible := false;
		self.txtRemarks.top := self.txtAddress.top;
		self.lblRemarks.top := self.lblAddress.top;
		self.lblTerms.visible := false;
		self.cmbTerms.visible := false;
		self.lblPO.visible := false;
		self.txtExternalRef.visible := false;
		self.lblExternalRef.visible := false;
		self.txtPurchaseOrdNo.visible := false;
		self.grpRelTrans.visible := false;
		self.lblFlatRate.visible := false;
		self.chkReefFlatRate.visible := false;
		self.lblReefDaily.visible := false;
		self.chkReefDaily.visible := false;
		self.lblAddInfo1.visible := false;	//22 Mar 2018	NDL TFS 37559
		self.txtAddInfo1.visible := false;	//22 Mar 2018	NDL TFS 37559
		self.lblAddInfo2.visible := false;	//22 Mar 2018	NDL TFS 37559
		self.txtAddInfo2.visible := false;	//22 Mar 2018	NDL TFS 37559		
		self.cmbTaxCountry.visible := false;	//navra1 - TFS 57086 - 1st May 2023
		
		self.lblPOMandatory.top := lblTerms.top;
		self.chkPOMandatory.top := lblTerms.top + 2;
		self.lblZeroRated.top := self.lblPOMandatory.top + 28;
		self.chkZeroRated.top := self.chkPOMandatory.top + 28;
		self.lblSuspended.top := self.lblZeroRated.top + 28;
		self.chkSuspended.top := self.chkZeroRated.top + 28;
		self.lblBadCredit.top := self.lblSuspended.top + 28;
		self.chkBadCredit.top := self.chkSuspended.top + 28;
		
		self.shtEntities.visible := false;
		self.shtInvLineTypes.visible := false;
		self.shtInvTypes.visible := false;
		self.shtTermConfig.visible := false;		//17 Jul 2012	NDL Par 29968
		self.shtDebtorAddresses.visible	:= false;   //22.07.2019 cnwma1 TFS #45577
		self.btnAddrSave.enabled        := false;   //22.07.2019 cnwma1 TFS #45577
		
		
		self.fldDetails.height 		:= self.txtRemarks.top + self.txtRemarks.height + 33;
		self.btnSave.top 	   		:= self.fldDetails.top + self.fldDetails.height + 44;        //22.07.2019 cnwma1 TFS #45577
		self.btnCancel.top 	   		:= self.btnSave.top;
		self.height			   		:= btnSave.top + self.btnSave.height + 44;
		self.lblLongName.visible	:= false;
		self.txtDebLongName.visible := false; //epr par 35304 2/12/14
		
		//08.8.2018 cnwma1 TFS #340092
		self.lblName.top 	   := self.lblCode.top;
		self.txtDebtorName.top := self.lblCode.top;
		self.lblParent.top     := self.lblName.top+33;
		self.cmbParent.top 	   := self.lblName.top +33;
		self.fldDetails.top    := self.cmbParent.top +33;
		self.btnCancel.top     := self.fldDetails.top + self.fldDetails.height +33;
		self.btnSave.top       := self.fldDetails.top + self.fldDetails.height +33;
	 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1	self.height            := self.height-22; was clipping the buttons at the bottom.
	else
		self.setupTables();
		self.doCmbTermsTradeBuild();
		self.doCmbEntityTypesBuild();
		self.doCmbCountryBuild();			//22.07.2019 cnwma1 TFS #45577
		self.doCmbTaxCountryBuild();			//navra1 - TFS 57086 - 1stMay 2023
		self.populateBusinessUnitCombos();
		self.populateShtDebtorAddresses();    //22.07.2019 cnwma1 TFS #45577
		self.btnAddrSave.enabled        := false;   //22.07.2019 cnwma1 TFS #45577
		//self.btnAddrNew.enabled         := false;
		self.btnAddrUpdate.enabled      := false;
		self.btnAddrDelete.enabled      := false;
		self.enableDisableAddressDetails(false);
		self.shtDebtorAddresses.enabled := self.myDebtorNode &lt;&gt; null;		// 9/8/19 MAP TFS45577
		if self.myDebtorNode &lt;&gt; null then
			self.btnAddrNew.enabled			:= self.myDebtorNode.CM_Debtor.allAddressesByCode.size() &lt; 9;		// 9/8/19 MAP TFS45577
		endif;
	endif;

	self.populateForm();
	
	
	//epr CCMS 2369 1/12/14
	if (not app.myCurrentUserCan(self.myTerminal, PmAdmDebtorregisterMaint)) then
		self.enableAllControls(false);
		self.btnCancel.enabled:=true;
	endif;
epilog
	app.cmsEndLoad(ls);	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTables" id="6f4363a5-87f6-47cd-bd0f-fa07b368cc25">
        <updating/>
        <source>setupTables() updating, protected;

vars
	row		: Integer;
begin
	// table headings
	self.tblAvailEnts.selectMode := Table.SelectMode_Row; // or SelectMode_WholeRows;	?
	self.tblAvailEnts.selectionType := CM_BaseTable.SelectionType_Row;	// single row selection
	self.tblAvailEnts.multiSelect := CM_BaseTable.MultiSelect_Simple;
	row := self.tblAvailEnts.fixedRows;
	self.tblAvailEnts.addItemAt(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Name) &amp; Tab &amp; app.getErrorString(INV_Debtor), row);
	self.tblAvailEnts.accessRow(row).fontBold := true;
	self.tblAvailEnts.sortColumn[1]:=2;

	self.tblSelectedEnts.selectMode := Table.SelectMode_WholeRows;	
	self.tblSelectedEnts.selectionType := CM_BaseTable.SelectionType_Row;	// single row selection
	self.tblSelectedEnts.multiSelect := CM_BaseTable.MultiSelect_Simple;
	row := self.tblSelectedEnts.fixedRows;
	self.tblSelectedEnts.addItemAt(app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Name), row);
	self.tblSelectedEnts.accessRow(row).fontBold := true;

	row := self.tblIT.fixedRows;
	self.tblIT.selectMode := Table.SelectMode_Row;
	self.tblIT.selectionType := CM_BaseTable.SelectionType_Row;	// single row selection
	self.tblIT.multiSelect := CM_BaseTable.MultiSelect_None;
	self.tblIT.addItemAt(app.getErrorString(CM_Business_Unit) &amp; Tab &amp; app.getErrorString(Invoice_type) &amp; Tab &amp;
						 app.getErrorString(Default_Ref) &amp; Tab &amp; app.getErrorString(Packages), row);
	self.tblIT.accessRow(row).fontBold := true;

	row := self.tblILT.fixedRows;
	self.tblILT.selectMode := Table.SelectMode_Row;
	self.tblILT.selectionType := CM_BaseTable.SelectionType_Row;	// single row selection
	self.tblILT.multiSelect := CM_BaseTable.MultiSelect_None;
	self.tblILT.addItemAt(app.getErrorString(CM_Business_Unit) &amp; Tab &amp; app.getErrorString(Invoice_line_type) &amp; Tab &amp;
						  app.getErrorString(External_code), row);
	self.tblILT.accessRow(row).fontBold := true;
	
	self.tblITSummary.readOnly := true;
	self.tblITSummary.gridLines := false;
	self.tblITSummary.rows := 0;
	
	//17 July 2012	NDL	Par 29968
 // ### TFS 52237 27OCT2021 NAVAB1	if app.isCashOnlyEnabled then
		self.tblTermConfig.rows := 1;
		//self.tblTermConfig.columns := 3;				// 9/4/18 MAP TFS37731
		//self.tblTermConfig.columns := 6;				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
		self.tblTermConfig.columns := 8;				//navra1 - TFS 57086 - 1st May 2023
		self.tblTermConfig.fixedRows := 1;
		self.tblTermConfig.fixedColumns := 1;
		//Overrides/Fixes CM_EntryTable::windowCreated - jadeCol.width := (self.width / 2).Integer; Which makes the fixed column half the table size, which means we have to scroll across
		//self.tblTermConfig.accessColumn(1).width := 150; // ### TFS 54564 (54374) 17Aug2022 NAVPW1
		self.tblTermConfig.accessColumn(1).width := 140; //navra1 - TFS 57086 - 1st May 2023
		self.tblTermConfig.selectMode := Table.SelectMode_Row;
		self.tblTermConfig.selectionType := CM_BaseTable.SelectionType_Row;	// single row selection
		self.tblTermConfig.multiSelect := CM_BaseTable.MultiSelect_None;
		self.tblTermConfig.accessColumn(2).inputType := Table.InputType_CheckBox;
		self.tblTermConfig.accessCell(1,1).inputType := Table.InputType_None;
		//self.tblTermConfig.setCellText(1,1,app.getErrorString(Terminal) &amp; Tab &amp; app.getErrorString(Cash_only) &amp; Tab &amp; app.getErrorString(Payment_type));
		//self.tblTermConfig.setCellText(1,1,app.getErrorString(Terminal) &amp; Tab &amp; app.getErrorString(Cash_only) &amp; Tab &amp; app.getErrorString(Payment_type) &amp; Tab &amp; app.getErrorString(Currency) &amp; Tab &amp; app.getErrorString(Info_Locale) &amp; Tab &amp; app.getErrorString(Invoice_report)); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
		self.tblTermConfig.setCellText(1,1,app.getErrorString(Terminal) &amp; Tab &amp; app.getErrorString(Cash_only) &amp; Tab &amp; app.getErrorString(Payment_type) &amp; Tab &amp; app.getErrorString(Currency) &amp; Tab &amp; app.getErrorString(Info_Locale) &amp; Tab &amp; app.getErrorString(Invoice_report) &amp; Tab&amp; app.getErrorString(Org_Code) &amp; Tab &amp; app.getErrorString(Interterminal_code)); // navra1 - TFS 57086 - 2nd May 2023
		self.tblTermConfig.accessRow(1).fontBold := true;
 // ### TFS 52237 27OCT2021 NAVAB1	endif;
	

	create self.allSelectedCustomsAgents transient;
	create self.allSelectedDebtorTypes transient;
	
	self.populateEntities();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showCurrentAddress" id="595456e4-0291-4e8f-8946-4b4c865d4cd1">
        <updating/>
        <source>showCurrentAddress(_address : CM_Address)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
02 Sept 2022	navkc1	ChangeRequest 54564(54372.020): Alternate address for Debtor
1  May 2023		navra1	TFS 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
*/

vars

begin
	
	clearCurrentAddress();
	if _address &lt;&gt; null then
		self.txtAddrCode.text 			:= _address.code;
		self.txtAddrDescription.text 	:= _address.description;
		self.txtAddrAdr1.text			:= _address.addr1;
		self.txtAddrAdr2.text			:= _address.addr2;
		self.txtAddrAdr3.text			:= _address.addr3;
		self.txtAddrRegion.text      	:= _address.region;
		self.txtAddrPostCode.text    	:= _address.postCode;
		self.chkDefultAddess.value      := _address.isDefault;
		self.chkAltAddress.value		:= _address.isAlternative;		// 02/09/22	navkc1	#54564(54372.020)		
		self.txtCity.text				:= _address.city;												//navra1 - TFS 57086 - 1st May 2023
		self.txtEmail.text				:= _address.email;												//navra1 - TFS 57086 - 1st May 2023	
		
		if _address.countryCode &lt;&gt; null then
			self.cmbAddrCountry.listIndex := self.cmbAddrCountry.findObject( _address.getCountry() );
		endif;
		
		self.myCurrentDebtorAddress := _address;
		
		btnAddrDelete.enabled := true;
		btnAddrUpdate.enabled := true;
		btnAddrNew.enabled    := self.myDebtorNode.CM_Debtor.allAddressesByCode.size() &lt; 9;
		
	endif;
epilog

end;</source>
        <Parameter name="_address" type="CM_Address"/>
    </JadeMethod>
    <JadeMethod name="showCurrentEntities" id="ebb32ed9-4ce3-4281-bd68-038ba677d69f">
        <updating/>
        <source>showCurrentEntities() updating, protected;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------
// 30/05/2019		jlgdap1		TFS 44554 AAT Stevedore Data Access
// 01 June 2022		navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 17 August 2022	navpw1		TFS: 54564 (54374) - EUP - Inv Config - DB Changes
//1 May 2023		navra1		TFS 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID

vars
	colour,
	row						: Integer;
	text					: String;
	obj						: Object;
	carrier					: CM_Carrier;
	consign					: CM_ConsigneeConsignor;
	agent					: CM_CustomsAgent;
	debtorType				: CM_DebtorType;
	oper					: CM_Operator;
	stevedore				: CM_Stevedore;					// TFS 44554
	terminal				: CM_Terminal;
	drTerm					: CM_DebtorTerminal;
	isCashOnly				: Boolean;
	paymentType				: Integer;
	currencyType 			: CM_CurrencyType; 				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	locale 					: CM_Locale; 					// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	jRWRepresentationAgent 	: CMUI_JRWRepresentationAgent; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	jrwReport,
	jrwView 				: CMUI_JRWEntityRepresentation; // ### TFS 54564 (54374) 17Aug2022 NAVPW1
	currencyTypeCodes,
	localeDescriptions,
	defaultInvoiceJRW,
	invoiceJRWs 			: String; 						// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	orgCode					:	String;								//navra1 - TFS 57086 - 1st May 2023
	interTerminalCode		:	String;								//navra1 - TFS 57086 - 1st May 2023
begin
	self.tblCurrentEnts.rows := 0;
	colour := self.colorRow1;
	self.tblCurrentEnts.sortAscending := true;	//	cnwmp6 PAR 36875 6/4/16
	self.tblCurrentEnts.sortColumn[1] := 1;
		
	text := app.getErrorString(Carrier);
	foreach carrier in self.allSelectedCarriers do
		row := self.tblCurrentEnts.addItem(text &amp; ": " &amp; carrier.description &amp; " (" &amp; carrier.code &amp; ")");
		self.tblCurrentEnts.accessRow(row).backColor := colour;
	endforeach;
	
	text := app.getErrorString(CM_Consignor);
	foreach consign in self.allSelectedConsignors do
		row := self.tblCurrentEnts.addItem(text &amp; ": " &amp; consign.description &amp; " (" &amp; consign.code &amp; ")");
		self.tblCurrentEnts.accessRow(row).backColor := colour;
	endforeach;

	text := app.getErrorString(CM_Customs_Agent);
	foreach obj in self.allSelectedCustomsAgents do
		agent := obj.CM_CustomsAgent;
		row := self.tblCurrentEnts.addItem(text &amp; ": " &amp; agent.name &amp; " (" &amp; agent.code &amp; ")");
		self.tblCurrentEnts.accessRow(row).backColor := colour;
	endforeach;

	text := app.getErrorString(Debtor_type);
	foreach obj in self.allSelectedDebtorTypes do
		debtorType := obj.CM_DebtorType;
		row := self.tblCurrentEnts.addItem(text &amp; ": " &amp; debtorType.description &amp; " (" &amp; debtorType.code &amp; ")");
		self.tblCurrentEnts.accessRow(row).backColor := colour;
	endforeach;

	text := app.getErrorString(Operator);
	foreach oper in self.allSelectedOperators do
		row := self.tblCurrentEnts.addItem(text &amp; ": " &amp; oper.description &amp; " (" &amp; oper.code &amp; ")");
		self.tblCurrentEnts.accessRow(row).backColor := colour;
	endforeach;
	
	text := app.getErrorString(Contact); //epr par 35304 2/12/14
	foreach obj in self.allSelectedContacts do
		row := self.tblCurrentEnts.addItem(text &amp; ": " &amp; obj.CM_EmailAddress2.name);
		self.tblCurrentEnts.accessRow(row).backColor := colour;
	endforeach;
	
	// TFS 44554 start
	text := app.getErrorString(Stevedore);
	foreach obj in self.allSelectedStevedores do
		row := self.tblCurrentEnts.addItem(text &amp; ": " &amp; obj.CM_Stevedore.description &amp; " (" &amp; obj.CM_Stevedore.code &amp; ")");
		self.tblCurrentEnts.accessRow(row).backColor := colour;
	endforeach;
	// TFS 44554 end
	
	// TFS 53204 Start navak20
	text := app.getErrorString(ShippingLine);
	foreach obj in self.allSelectedShippingLine do
		row := self.tblCurrentEnts.addItem(text &amp; ": " &amp; obj.CM_ShippingLine.description &amp; " (" &amp; obj.CM_ShippingLine.code &amp; ")");
		self.tblCurrentEnts.accessRow(row).backColor := colour;
	endforeach;
	// TFS 53204 End
	
	//17 July 2012	NDL	Par 29968
 // ### TFS 52237 27OCT2021 NAVAB1	if app.isCashOnlyEnabled then
		if self.myProxyDebtorNode.isKindOf(CM_Debtor) then
			// 31302 only do once at the start
			if self.tblTermConfig.rows &gt; self.tblTermConfig.fixedRows then
				return;
			endif;
			
			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			//Populate Currency Type Codes
			currencyTypeCodes := app.getErrorString(None) &amp; Tab; //Add default None to list of options in case user wants to unset their currency type
			
			//Get and populate a list of currency codes for combo box below
			foreach currencyType in  app.myRoot.allCurrencyTypes do
				currencyTypeCodes &amp;= currencyType.code &amp; Tab;
			endforeach;
			
			currencyTypeCodes := currencyTypeCodes.stripTrailingChar(Tab); //Strip trailing Tab from string as it is not needed
			
			//Populate Locales
			localeDescriptions := app.getErrorString(None) &amp; Tab; //Add default None to list of options in case user wants to unset their locale
			
			//Get and populate a list of locales for combo box below
			foreach locale in  app.myRoot.allLocales do
				localeDescriptions &amp;= locale.localeDescription &amp; Tab;
			endforeach;
			
			localeDescriptions := localeDescriptions.stripTrailingChar(Tab); //Strip trailing Tab from string as it is not needed
			
			//Populate Invoice Report Names
			invoiceJRWs := app.getErrorString(None) &amp; Tab; //Add default None to list of options in case user wants to unset their invoice report jrw
			
			create jRWRepresentationAgent transient; //Create a JRW Represetnation Agent
			jRWRepresentationAgent.loadJRWRepresentationObjects(); //Load the Representation Objects
			
			jrwView := jRWRepresentationAgent.allJRWViews[CM_InvoiceView].CMUI_JRWEntityRepresentation; //Find the JRW View we're interested in. Which is CM_InvoiceView
			
			if jrwView &lt;&gt; null then //If we have found the JRW View then loop
				foreach jrwReport in jrwView.allJRWRepresentationEntities do 
					//Loop through all reports for view and looks for reports in the directories below and adds them to our string for the combo box below
					if jrwReport.reportsOn("allInvoices") then
						invoiceJRWs &amp;= jrwReport.name &amp; Tab;
					elseif jrwReport.reportsOn("allReportInvoiceSummaries") then
						invoiceJRWs &amp;= jrwReport.name &amp; Tab;
					endif;
				endforeach;
			endif;
			
			invoiceJRWs := invoiceJRWs.stripTrailingChar(Tab); //Strip trailing Tab from string as it is not needed
			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			
			foreach terminal in app.myRoot.allTerminals do
 // ### TFS 52237 27OCT2021 NAVAB1				if terminal.isCashOnlyEnabled then 
					isCashOnly 			:= false;
					paymentType			:= null;
					currencyType 		:= null; // ### TFS 54564 (54374) 17Aug2022 NAVPW1
					locale				:= null; // ### TFS 54564 (54374) 17Aug2022 NAVPW1
					defaultInvoiceJRW 	:= null; // ### TFS 54564 (54374) 17Aug2022 NAVPW1
					orgCode 			:= null; 		//navra1 - TFS 57086 - 1st May 2023
					interTerminalCode 	:= null; 		//navra1 - TFS 57086 - 1st May 2023
					
					if self.myDebtorNode &lt;&gt; null and self.myDebtorNode.isKindOf(CM_Debtor) then
						drTerm := terminal.allDebtorTerminals.getAtKey( self.myDebtorNode.CM_Debtor );
					endif;
					if drTerm &lt;&gt; null then
						isCashOnly 			:= drTerm.isCashOnly;
						paymentType 		:= drTerm.paymentType;
						currencyType 		:= drTerm.myCurrencyType;		// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						locale				:= drTerm.myLocale;				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						defaultInvoiceJRW	:= drTerm.defaultInvoiceJRW;	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						orgCode				:= drTerm.orgCode;						//navra1 - TFS 57086 - 1st May 2023
						interTerminalCode	:= drTerm.interTerminalCode;			//navra1 - TFS 57086 - 1st May 2023
					endif;

					row := self.tblTermConfig.addItem( terminal.code &amp; Tab &amp; isCashOnly.Integer.String);
					self.tblTermConfig.accessCell(row, 3).inputType := Table.InputType_ComboBox;
					self.tblTermConfig.accessCell(row, 3).comboList := app.getErrorString(PaymentType_NoneStr) &amp; Tab &amp; app.getErrorString(PaymentType_AutoCollectionStr) &amp; Tab &amp; app.getErrorString(PaymentType_PrePayStr) &amp; Tab &amp; app.getErrorString(PaymentType_PostPayStr);
					self.tblTermConfig.accessCell(row, 3).text := app.paymentTypeEnumToString(paymentType);
					self.tblTermConfig.accessCell(row,1).itemObject := terminal;
					
					// ### TFS 54564 (54374) 17Aug2022 NAVPW1
					//Setup Currency Type Code
					self.tblTermConfig.accessCell(row, 4).inputType := Table.InputType_ComboBox;
					self.tblTermConfig.accessCell(row, 4).comboList := currencyTypeCodes;
					if currencyType &lt;&gt; null then
						self.tblTermConfig.accessCell(row, 4).text := currencyType.code;
					else
						self.tblTermConfig.accessCell(row, 4).text := app.getErrorString(None);
					endif;
					
					//Setup Locale Code
					self.tblTermConfig.accessCell(row, 5).inputType := Table.InputType_ComboBox;
					self.tblTermConfig.accessCell(row, 5).comboList := localeDescriptions;
					if locale &lt;&gt; null then
						self.tblTermConfig.accessCell(row, 5).text := locale.localeDescription;
					else
						self.tblTermConfig.accessCell(row, 5).text := app.getErrorString(None);
					endif;
					
					//Setup Invoice Report
					self.tblTermConfig.accessCell(row, 6).inputType := Table.InputType_ComboBox;
					self.tblTermConfig.accessCell(row, 6).comboList := invoiceJRWs;
					if defaultInvoiceJRW &lt;&gt; null then
						self.tblTermConfig.accessCell(row, 6).text := defaultInvoiceJRW;
					else
						self.tblTermConfig.accessCell(row, 6).text := app.getErrorString(None);
					endif;
					// ### TFS 54564 (54374) 17Aug2022 NAVPW1
					
					if not terminal.isCashOnlyEnabled then  // ### TFS 52237 27OCT2021 NAVAB1
						self.tblTermConfig.accessCell(row,2).enabled := false; // ### TFS 52237 27OCT2021 NAVAB1
					endif;
					
					//navra1 - TFS 57086 - 1st May 2023 - start
					self.tblTermConfig.accessCell(row, 7).inputType := Table.InputType_TextBox;
					self.tblTermConfig.accessCell(row, 7).text		:= orgCode;				
					
					self.tblTermConfig.accessCell(row, 8).inputType := Table.InputType_TextBox;
					self.tblTermConfig.accessCell(row, 8).text		:= interTerminalCode;					
					//navra1 - TFS 57086 - 1st May 2023 - end
 // ### TFS 52237 27OCT2021 NAVAB1				endif;
			endforeach;
		endif;
 // ### TFS 52237 27OCT2021 NAVAB1	endif;

epilog
	delete jRWRepresentationAgent; // ### TFS 54564 (54374) 17Aug2022 NAVPW1
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showITSummary" id="3639f011-5d5a-44ca-94e2-2c3b90554f2d">
        <updating/>
        <source>showITSummary() updating, protected;

vars
	first	: Boolean;
	row		: Integer;
	str		: String;
	invType	: CM_InvoiceDesc;
	debtorInvType	: CM_DebtorInvType;
	packageInvoice	: CM_PackageInvoice;
	report			: CM_ReportTemplate;
begin
	row := self.tblIT.row;
	if row &lt;= self.tblIT.fixedRows then
		return;
	endif;
	
	invType := self.tblIT.accessRow(row).itemObject.CM_InvoiceDesc;
	debtorInvType := self.myProxyDebtorNode.CM_Debtor.allDebtorInvTypes[invType];
	self.tblITSummary.readOnly := true;
	self.tblITSummary.gridLines := false;
	self.tblITSummary.rows := 0;
	if debtorInvType = null then
		return;
	endif;
	if debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode then
		str := "Default Debtor Reference to Translated Voyage Code";
		row := self.tblITSummary.addItem(str);
		self.tblITSummary.accessRow(row).backColor := self.colorRow1;
	endif;
	foreach packageInvoice in debtorInvType.allPackageInvoices do
		str := packageInvoice.description &amp; " Invoice Package Details:";
		row := self.tblITSummary.addItem(str);
		self.tblITSummary.accessRow(row).backColor := self.colorRow1;
		str := "Email to: " &amp; packageInvoice.myEmailTemplate.getAllToAddressesOrNames(false);
		row := self.tblITSummary.addItem(str);
		self.tblITSummary.accessRow(row).backColor := self.colorRow1;
		
		str := "Email bcc: " &amp; packageInvoice.myEmailTemplate.getAllBCCAddressesOrNames(false);
		row := self.tblITSummary.addItem(str);
		self.tblITSummary.accessRow(row).backColor := self.colorRow1;
	
		str := "Email cc: " &amp; packageInvoice.myEmailTemplate.getAllCCAddressesOrNames(false);
		row := self.tblITSummary.addItem(str);
		self.tblITSummary.accessRow(row).backColor := self.colorRow1;
		str := "Reports: ";
		first := true;
		foreach report in packageInvoice.allReportTemplates do
			if first then
				str := str &amp; report.description;
			else
				str := str &amp; ", " &amp; report.description;
			endif;
			first := false;
		endforeach;
		row := self.tblITSummary.addItem(str);
		self.tblITSummary.accessRow(row).backColor := self.colorRow1;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sortTable" id="c558e0f5-737c-4c1f-abe1-44626270e2fe">
        <updating/>
        <source>sortTable(_table : CM_DataTable input) updating, protected;
// sort given table (either available or selected entities) by name/description (column 2) then
//  code (column 1)
begin
	_table.sortAscending := true;
	
	_table.sortColumn[1]	:= 2;
	_table.sortAsc[1]	:= true;
	_table.sortCased[1]	:= false;
	_table.sortColumn[2]	:= 1;
	_table.sortAsc[2]	:= true;
	_table.sortCased[2]	:= false;
	
	_table.resort;

	self.recolourTable(_table);
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblAddrDetails_click" id="13c97cbc-d278-45cc-93e4-72ebeaeee16b">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAddrDetails_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2019	jlgma1	Initial creation

*/

vars
	address : CM_Address;
	index   : Integer;
begin
	btnAddrSave.enabled := false;
	index := self.tblAddrDetails.row;
	if index &gt; 1 then
		address := self.tblAddrDetails.accessRow(index).itemObject.CM_Address;
	endif;
	if address &lt;&gt; null then
	
		self.myCurrentDebtorAddress := address;
		showCurrentAddress(address);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
