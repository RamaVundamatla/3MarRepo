    <JadeMethod name="includeObject" id="9dac3c20-7771-400b-956d-b58fe22cc36e">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_MTGrade.isNotAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="5f615b89-7626-47d3-b5e6-fbb16f58e106">
        <source>initShtMultiSelect();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
13 October 2010	cnwndl1	Initial creation	Par 23991
08/05/2025		navlw1	JIRA-34582: MTN | Filtering order Issue in system Admin Table as terminal collection cannot be re-ordered

*/

vars

	theForm	: SOP_TableMaintForm;

begin

	inheritMethod();
	
	theForm := self.myForm;
	
	self.setupMultiSelect1(app.getErrorString(Allowed_release_terminals), app.myRoot.allTerminals, SOP_TableMaintForm::displayEntryTerminal.name);
	theForm.mulSelect1.setVisibleButtons(true,true,false); // navlw1 08/05/2025 #JIRA-34582
	theForm.mulSelect1.myBaseForm	:= theForm;
	theForm.mulSelect1.mySelectedListBox.sorted := false;
	
	if app.isSubTerminalsLicensed then
		theForm.mulSelect2.setVisibleButtons(true,true,false); // navlw1 08/05/2025 #JIRA-34582
		self.setupMultiSelect2(app.getErrorString(Allowed_edit_terminals), app.myRoot.allSubTerminals, SOP_TableMaintForm::displayEntrySubTerminal.name);
		theForm.mulSelect2.myBaseForm	:= theForm;
		theForm.mulSelect2.mySelectedListBox.sorted := false;
	endif;

epilog

end;</source>
    </JadeMethod>
