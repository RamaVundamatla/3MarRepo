<GUIClass name="GTE_FindAndExit" id="61f57b65-801f-4d9f-ae76-d8b1771fca13">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lblResult" id="465690c1-c889-46e2-9888-82b11d9a1562">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblVVToGateOut" id="22524991-460d-4c7d-9a3b-8a1a5a3bb842">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtVVRtoGateOut" id="0f76e334-c251-43c6-b03a-9b2588dc9d32">
