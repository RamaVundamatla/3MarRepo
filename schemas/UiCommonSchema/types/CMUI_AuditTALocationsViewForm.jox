    <JadeMethod name="getExtraExtraInfo" id="cd36dc26-a8a4-47d3-9735-14ee20d45d2f">
        <source>getExtraExtraInfo(_dataContainer: CM_DataContainer; _audit :CM_AuditTALocations);
// ---------------------------------------------------------------------------
// Created:     08 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	etDef		: EntTableDef; 
	etRow		: EntTableRow;
	block		: CM_DataContainerBlock;
	terminal	: CM_Terminal;
	locale		: CM_Locale;
begin
	etDef 		:= app.myController.getEntTableDef (ETDef_AuditTATblData);
	terminal	:= self.myTerminal;
	locale		:= app.myCurrentLocale;
	
	// terminal area
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (app.getErrorString(TerminalArea), DC_Label, 1, null);
	block.addNewItem (_audit.getSubjectIdString, DC_Data, 1, null);
	
	// audit type
	etRow := etDef.getEntTableRow (ETRow_AuditType);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_audit.getDisplayStringForAttribute (ETRow_AuditType, false), DC_Data, 1, null);
	
	// date/time
	etRow := etDef.getEntTableRow (ETRow_DateTime);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_audit.getDisplayStringForAttribute (ETRow_DateTime, false), DC_Data, 1, null);

	// user code
	etRow := etDef.getEntTableRow (ETRow_UserCode);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_audit.getDisplayStringForAttribute (ETRow_UserCode, false), DC_Data, 1, null);
	
	// user name
	etRow := etDef.getEntTableRow (ETRow_UserName);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_audit.getDisplayStringForAttribute (ETRow_UserName, false), DC_Data, 1, null);

	// update type
	etRow := etDef.getEntTableRow (ETRow_UpdateType);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_audit.getDisplayStringForAttribute (ETRow_UpdateType, false), DC_Data, 1, null);
	
	// update mode
	etRow := etDef.getEntTableRow (ETRow_UpdateMode);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_audit.getDisplayStringForAttribute (ETRow_UpdateMode, false), DC_Data, 1, null);

	// locations
	etRow := etDef.getEntTableRow (ETRow_Locations);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_audit.getDisplayStringForAttribute (ETRow_Locations, false), DC_Data, 1, null);
	
	// details
	etRow := etDef.getEntTableRow (ETRow_Details);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_audit.getDisplayStringForAttribute (ETRow_Details, false), DC_Data, 1, null);	

	// comments
	etRow := etDef.getEntTableRow (ETRow_Comment);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_audit.getDisplayStringForAttribute (ETRow_Comment, false), DC_Data, 1, null);
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_audit" type="CM_AuditTALocations"/>
    </JadeMethod>
