    <JadeMethod name="xCreateCargoForCash" id="c593d004-0c3c-4415-a711-b117908f41a6">
        <updating/>
        <source>xCreateCargoForCash() updating;

/*	NOTE: For this to work with a different terminal, it needs a harbour (any one will do), a crane called CRN1, debtor Cash Debtor 1 as a cash-only debtor, 
			the user used to run this (typically UnitTest) needs security to create BOLs (set all access is simplest).
		To get useful invoice lines from this also needs the transaction map set up for Import &amp; Export Release - Ship and Move at a minimum.
		OLDER VERSION _ use uCreateCashCargo instead
		THIS WAS uCreateCargoForCash

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2012	cnwjre1	Initial creation

*/

vars

begin
	// clear the cash debtor values
	self.zClearCashDebtor("Cash Debtor 1");
	self.zClearCashDebtor("Cash Debtor 2");
	self.zClearCashDebtor("Cash Debtor 3");
	self.zClearCashDebtor("Cash Debtor 4");
	
	// create import and export cargo for John's Terminal cash usage
	self.createCargoForCash();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="zClearCashDebtor" id="b5e418db-392f-4e74-8179-d6af03c1f7a6">
        <source>zClearCashDebtor(_name : String) protected;

vars

	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
begin
	// clear the cash debtor values
	terminal := CM_Root.firstInstance.allTerminals["JT1"];
	debtor := CM_Root.firstInstance.myRootCompany.debtors[_name];
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	
	beginTransaction;

	debtorTerminal.allCashPayments.purge();
	debtorTerminal.allCashReceipts.purge();
	debtorTerminal.allCashCredits.purge();
	debtorTerminal.allConsolidatedCashTrx.purge();
	debtorTerminal.setConsolidatedBalance();
	
	commitTransaction;

end;
</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="zPurgeCashDebtor" id="ea5d2fa0-2b23-41c7-9f62-7cb295c24e83">
        <source>zPurgeCashDebtor(_debtorTerminal : CM_DebtorTerminal io) protected;

/*

Purpose:			Delete all invoice and cash data for the given debtor

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2012	cnwjre1	Initial creation

*/

vars
	debtor		: CM_Debtor;
	invoice		: CM_Invoice;
begin
	if _debtorTerminal = null then
		return;
	endif;
	
	debtor := _debtorTerminal.myDebtor;
	
	beginTransaction;


	_debtorTerminal.allCashPayments.purge();
	_debtorTerminal.allCashReceipts.purge();
	_debtorTerminal.allCashCredits.purge();
	_debtorTerminal.allConsolidatedCashTrx.purge();
	_debtorTerminal.setConsolidatedBalance();

	foreach invoice in debtor.allInvoices do
		invoice.zDeleteLine();
	endforeach;
	
	commitTransaction;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_debtorTerminal" type="CM_DebtorTerminal" usage="io"/>
    </JadeMethod>
</Class>
