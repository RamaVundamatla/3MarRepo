    </PrimAttribute>
    <PrimAttribute name="messageStatus" id="d94301ec-ebe8-4ba5-b9a4-3d025971944d">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="otherParty" id="37786599-2989-44cf-b485-d68640721858">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="ownership" id="b887b59b-cdeb-4498-a7b8-b5bb0ad597e2">
        <length>5</length>
