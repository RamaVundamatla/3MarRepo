<GUIClass name="CMUI_ComboShippingAgent" id="46e11677-f7a9-4951-914d-ffdc6e773454">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isDisplayByName" id="ec3fd3b9-6280-497a-b061-57f39c5f19db">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="953b17df-0d6b-464f-9df9-14295d591766">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _agent : CM_ShippingAgent; lstIndex: Integer): String updating, clientExecution;
//--------------------------------------------------
// Created:	17 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpPassport : CM_Passport;
	failedDAC  :CM_DataAccessController;
begin
	if _agent = null then
		return null;
	endif;

	if _agent.notAvailableForEntry then
		if self.myObject &lt;&gt; _agent then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	tmpPassport := app.myPassport;
	if tmpPassport &lt;&gt; null and
	   (not _agent.canUserAccessSelf(null, failedDAC, tmpPassport)) then
		return null;
	endif;
		
	if self.isDisplayByName then
		return _agent.description &amp; ' - (' &amp; _agent.code &amp; ')';
	else
		return _agent.code &amp; Tab &amp; _agent.description;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_agent" type="CM_ShippingAgent"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="95920476-9afb-49fd-ac65-cee9ee6dc611">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	17 December 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	return app.myRoot.allShippingAgentsByCode;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
