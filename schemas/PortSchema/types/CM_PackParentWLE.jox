    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getChildren" id="96dec017-e4cc-4ab1-9675-5fd7b4c52746">
        <source>getChildren(_childColl: CM_TISet input);
// -----------------------------------------------------------------------------
// Created:		27 July 2009 by consw1
//
// Purpose:		Get the cargo that is going to be packed into containers
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	wodPack : CM_WodPack;
	
begin
	wodPack := self.getWorkOrderTIDtl();
	
	if wodPack &lt;&gt; null then
		wodPack.allPackingTIs.copy(_childColl);
	endif;
	
epilog

end;</source>
        <Parameter name="_childColl" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="66a41097-ef62-455d-84e2-a47a9fbf88d8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Jul 2009	cnwrd1	Initial creation
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	rtStr : String;
begin

	if _attrName = ETRow_WorkEntry then
		rtStr := "Pack Parent";
		return rtStr;
	elseif _attrName = ETRow_RadioTelemetry then
		return '';
	elseif _attrName = ETRow_Remarks then			//29.09.2021 navma1 #51925
		if self.getWorkOrderTIDtl&lt;&gt; null then
			if self.getWorkOrderTIDtl.myParent &lt;&gt; null then
				return self.getWorkOrderTIDtl.myParent.remarks;
			endif;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
	

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
