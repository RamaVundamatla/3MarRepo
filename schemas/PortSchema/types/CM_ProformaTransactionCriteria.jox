    <JadeMethod name="doObjectVolatilityConversion" id="81be2253-7844-45cf-8bbd-2f18a954345b">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2019	jlgzm1	Initial creation TFS 7286 Additional stable collections required to improve performance

*/

vars
	criteria : CM_ProformaTransactionCriteria;
begin
	inheritMethod(_converter, _logIndent);
	
	_converter.doChangeVolatilityOfObject(self.allCriteria, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allProformaTransactionUnits, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allTransactionTypes, _logIndent);

epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaForType" id="325a2562-cce3-442b-8d37-17c291fc271d">
        <source>getCriteriaForType( _critType : CM_YACriteriaType ):CM_YACriteria;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

	criteria : CM_YACriteria;
	invalidObj : Boolean;

begin

	on Exception do app.handleDeletedObject(exception, criteria, invalidObj);

	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType = _critType then
			//if not self.myBank.allSelectedProformaQueryProps.includes( criteria.myYACriteriaType.getTypeName ) then
			if not self.myBank.allSelectedProformaQueryProps.includes( criteria.myYACriteriaType.description ) then	//09 Oct 2013	NDL	Par 32456
				return null;
			endif;
			return criteria;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_critType" type="CM_YACriteriaType"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="getJadeCode" id="e8bb0727-9705-4f19-be59-dc9b837140f0">
        <source>getJadeCode() : String;
// ---------------------------------------------------------------------------
// Created:     19/02/2015	cnwjre1	34917 GPHA CCMS 2368
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myHookCode = null then
		return null;
	endif;
	return self.myHookCode.getCurrentJadeCode();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="33c79c0b-2263-4509-a70a-a38d426235bd">
        <source>getTableDisplay( _critTypeArray : CM_YACriteriaTypeArray ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation

*/

vars

	critType : CM_YACriteriaType;
	criteria : CM_YACriteria;
	dataString : String;
	retValue : String;

begin
	
	foreach critType in _critTypeArray do
		dataString := " ";
		criteria := self.getCriteriaForType( critType );    
		if criteria &lt;&gt; null then
			dataString := critType.getDataDisplay( criteria.myYAData );
		endif;
		if retValue = null then
			retValue := dataString;
		else
			retValue := retValue.trimBlanks &amp; Tab &amp; dataString;
		endif;
	endforeach;
	
	return retValue.trimBlanks;

epilog

end;</source>
        <Parameter name="_critTypeArray" type="CM_YACriteriaTypeArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransactionList" id="2cf197e5-2d42-41d4-94bd-f1740ded6085">
        <source>getTransactionList():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation

*/

vars

	retValue : String;
	tType : CM_TransactionType;

begin

	foreach tType in self.allTransactionTypes do
		if retValue = null then
			retValue := tType.description;
		else
			retValue := retValue &amp; ", " &amp; tType.description;
		endif;
	endforeach;
	
	return retValue;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnitDetailsForTrxType" id="331b11b4-08cb-4179-891c-3205edac8a12">
        <source>getUnitDetailsForTrxType( _trxType : CM_TransactionType ):CM_ProformaTransactionUnit;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

	proformaTrxUnit : CM_ProformaTransactionUnit;

begin

	if _trxType = null then
		return null;
	endif;
	
	proformaTrxUnit := self.allProformaTransactionUnits.getAtKey(_trxType);
	
	return proformaTrxUnit;

epilog

end;</source>
        <Parameter name="_trxType" type="CM_TransactionType"/>
        <ReturnType type="CM_ProformaTransactionUnit"/>
    </JadeMethod>
    <JadeMethod name="matches" id="f7f22bcf-aba9-4118-b8bb-a64094f41f4c">
        <source>matches( _ti : CM_TrackedItem ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Jul2012	cnwndl1	Initial creation
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
23 Oct 2024	navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	criteria	 : CM_YACriteria;
	cmifAutoPlan : CMIF_YAAutoPlan;
	criteriaType : CM_YACriteriaType;
	canLogExtra	 : Boolean;			//25.02.2025 navah1	#34141	
begin

	if _ti = null then
		return false;
	endif;
	
	canLogExtra := app.canLogExtraDetail();					//25.02.2025 navah1	#34141	
	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI( _ti );

	foreach criteria in self.allCriteria discreteLock do
		if canLogExtra then									//25.02.2025 navah1	#34141	
			app.invLog("Checking criteria " &amp; criteria.code, LogTRACE.String);
		endif;
		criteriaType := criteria.myYACriteriaType;				//05.10.2022 navma1 #52967
		if criteriaType &lt;&gt; null and not self.myBank.allSelectedProformaQueryProps.includes( criteriaType.description ) then	//09 Oct 2013	NDL	Par 32456 //05.10.2022 navma1 #52967
			if canLogExtra then								//25.02.2025 navah1 #34141
				app.invLog(" not in Cash Config Transaction Selection", LogTRACE.String); 	
			endif;
			continue;
		endif;
		if not criteria.isProformaDataMatch( cmifAutoPlan ) then	// copy of isCMIFAutoPlanDataMatch with logging
			return false;
		endif;
	endforeach;
	
	return true;

epilog

	delete cmifAutoPlan;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5489827f-18af-48fb-95bf-73ed4be75220">
        <source>pxyCreateUpdateProxy(): SelfType;
// 34917 added to handle hook code
vars
	proxy 	: CM_ProformaTransactionCriteria;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	if self.myHookCode &lt;&gt; null then
		proxy.myHookCode := self.myHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	completedOK := true;
	return proxy;
epilog
	if not completedOK then
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recalculateCriteriaPriorities" id="838c582d-7cee-475a-b252-65396ae30a16">
        <updating/>
        <source>recalculateCriteriaPriorities() updating;
// derive the priority from the data
vars
	criteriaObj			: CM_YACriteria;
	priorityTotal		: Integer;
	
begin
	priorityTotal	:=	0;
	
	foreach criteriaObj in self.allCriteria do
		priorityTotal	:=	priorityTotal + criteriaObj.calculateInvoicePriority().Integer;
	endforeach;
	
	
	self.priority := priorityTotal;
end;
</source>
    </JadeMethod>
    <JadeMethod name="replaceTransactionUnits" id="96722667-92fe-45ab-857e-8a4aa4b97b8b">
        <updating/>
        <source>replaceTransactionUnits( pxyUnits : CM_ProformaTransactionUnitDict ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

	pxy : CM_ProformaTransactionUnit;
	unit : CM_ProformaTransactionUnit;

begin

	if not allProformaTransactionUnits.isEmpty then
		self.allProformaTransactionUnits.purge;
	endif;

	if pxyUnits &lt;&gt; null and not pxyUnits.isEmpty then
		foreach pxy in pxyUnits do
			create unit persistent;
			unit.setForUpdate(pxy);
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="pxyUnits" type="CM_ProformaTransactionUnitDict"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8090c5c0-ac04-4e11-8796-22ec12eb03e4">
        <updating/>
        <source>setForCreate( _proxy : CM_ProformaTransactionCriteria ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation

*/

vars

begin

	self.setForUpdate( _proxy );

epilog

end;</source>
        <Parameter name="_proxy" type="CM_ProformaTransactionCriteria"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="906ef7b5-bf65-45bb-9dba-93c79f0519a8">
        <updating/>
        <source>setForUpdate(  _proxy : CM_ProformaTransactionCriteria ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation
20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
*/

vars

	sortValue	: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	pxyCriteria: CM_YACriteria;
	criteria : CM_YACriteria;
	pxyHookLink	: CM_HookLink;

begin

	self.priority := _proxy.priority;
	self.type	 := _proxy.type; // TFS 37453
	
	self.allTransactionTypes.clear();
	if _proxy.allTransactionTypes &lt;&gt; null and not _proxy.allTransactionTypes.isEmpty then
		_proxy.allTransactionTypes.copy( self.allTransactionTypes );
	endif;
	if self.allCriteria &lt;&gt; null and not self.allCriteria.isEmpty then
		self.allCriteria.purge();
	endif;
	
	// 34917 add hook code
	if _proxy.myHookCode &lt;&gt; null then
		pxyHookLink	:= _proxy.myHookLink;
		
		if pxyHookLink &lt;&gt; null then
			// need to set to the new persistent object
			pxyHookLink.setLinkObject(self);
		endif;
		
		if self.myHookCode = null then
			create self.myHookCode persistent;
			self.myHookCode.setForCreate(_proxy.myHookCode);
		else
			self.myHookCode.setForUpdate(_proxy.myHookCode);
		endif;
	else
		delete self.myHookCode;
	endif;
	
	sortValue	:=	0;
	foreach pxyCriteria in _proxy.allCriteria do

		create criteria persistent;
		criteria.setForCreate(	pxyCriteria );		
		criteria.setPriorityValue(2 ^ sortValue);
		self.allCriteria.add(criteria);

		sortValue		:=	sortValue + 1;
	endforeach;
	self.recalculateCriteriaPriorities();
	
	self.myBank := _proxy.myBank;
	self.myVessel := _proxy.myVessel; // TFS 37453
	
	self.allEventTypes.clear(); // TFS 37453
	if _proxy.allEventTypes &lt;&gt; null then
		_proxy.allEventTypes.copy(self.allEventTypes);
	endif;
	self.allHMSResources.clear(); // TFS 37453
	if _proxy.allHMSResources &lt;&gt; null then
		_proxy.allHMSResources.copy(self.allHMSResources);
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_ProformaTransactionCriteria"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="853490c5-8f5e-4cbc-9dd6-548e3f8bb71c">
        <updating/>
        <source>setProxy(	_criterias: CMIF_Array;
			_selectedTrxTypes : CM_TransactionTypeByType;
			_priority : Integer;
			_myBank : CM_Bank;
			_jadeCode : String;
			_userCode :String; 
			_vessel : CM_Vessel;
			_events : CM_EventTypeByNameDict;
			_resources : HMS_ResourceByTypeDict;
			_type : Integer
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	cmif : CMIF_Object;
	cmifCriteria : CMIF_YACriteriaPriority;
	passedInPxyCriteria: CM_YACriteria;
	pxyCriteria: CM_YACriteria;
	data : Any;

begin

	self.priority := _priority;
	self.type := _type;
	
	// 34917 hook code
	if _jadeCode &lt;&gt; null or _userCode &lt;&gt; null then	// from 35992 testing
	
		if _vessel = null then
			if self.myHookCode &lt;&gt; null then
				self.myHookCode.setForProxy(self.getOidAsString, app.myRoot.allHookTypes[HookType_CashProForma]);
				self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
			else
				create self.myHookCode transient;
				self.myHookCode.setForProxy(self.getOidAsString, app.myRoot.allHookTypes[HookType_CashProForma]);
				self.myHookCode.createProxyHookLinkForParent(HookType_CashProForma, self);
				self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
			endif;
		else
			if self.myHookCode &lt;&gt; null then
				self.myHookCode.setForProxy(self.getOidAsString, app.myRoot.allHookTypes[HookType_VesselProforma]);
				self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
			else
				create self.myHookCode transient;
				self.myHookCode.setForProxy(self.getOidAsString, app.myRoot.allHookTypes[HookType_VesselProforma]);
				self.myHookCode.createProxyHookLinkForParent(HookType_VesselProforma, self);
				self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
			endif;
		
		endif;
	endif;
	
	self.allTransactionTypes.clear();
	if _selectedTrxTypes &lt;&gt; null and not _selectedTrxTypes.isEmpty then
		_selectedTrxTypes.copy( self.allTransactionTypes );
	endif;
	if self.allCriteria &lt;&gt; null and not self.allCriteria.isEmpty then
		self.allCriteria.purge();
	endif;
	
	if _criterias&lt;&gt; null then
		foreach cmif in _criterias do
			if not cmif.isKindOf(CMIF_YACriteriaPriority) then
				continue;
			endif;
			cmifCriteria := cmif.CMIF_YACriteriaPriority;
			if cmifCriteria = null then
				continue;
			endif;
			passedInPxyCriteria := cmifCriteria.myProxy.CM_YACriteria;
			if passedInPxyCriteria &lt;&gt; null then
				data := passedInPxyCriteria.myYAData.getDataValue();
				create pxyCriteria transient;
				pxyCriteria.setProxy(	passedInPxyCriteria.myYACriteriaType,
										data,
										passedInPxyCriteria.code
										);
				self.allCriteria.add(pxyCriteria);
			endif;
		endforeach;
	endif;
	
	self.myBank := _myBank;
	
	self.myVessel := _vessel;
	
	self.allEventTypes.clear();
	if _events &lt;&gt; null then
		_events.copy(self.allEventTypes);
	endif;
	self.allHMSResources.clear();
	if _resources &lt;&gt; null then
	_resources.copy(self.allHMSResources);
	endif;


epilog

end;</source>
        <Parameter name="_criterias" type="CMIF_Array"/>
        <Parameter name="_selectedTrxTypes" type="CM_TransactionTypeByType"/>
        <Parameter name="_priority" type="Integer"/>
        <Parameter name="_myBank" type="CM_Bank"/>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_events" type="CM_EventTypeByNameDict"/>
        <Parameter name="_resources" type="HMS_ResourceByTypeDict"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
