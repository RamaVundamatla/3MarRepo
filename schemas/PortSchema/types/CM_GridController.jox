    </JadeMethod>
    <JadeMethod name="getFullIdTI" id="8500b3d1-07f5-497c-8ac6-b1baebd8b978">
        <source>getFullIdTI(_ti: CM_TrackedItem): String;
//----------------------------------------------------------------
//	Created:	12 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	tmpStr	: String;
begin

	tmpStr := self.getID();
//	changed due to inherited method being changed.  
//	tmpStr := inheritMethod(_ti); 
	
	if self.myGridArea &lt;&gt; null then
		tmpStr := self.myGridArea.id &amp; " " &amp; tmpStr; 
	endif;

	if not self.myGridArea.use40ftIds then
		return tmpStr; 
	endif;
	if  (_ti.isAttributeTrue(TI_Attrib_IsForty) or _ti.isOverSizedContainer) then
		return self.getFullId40(); 
	else
		return tmpStr; 
	endif;
	
epilog	
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
