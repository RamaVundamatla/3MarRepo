<Class name="CMEVT_SplitRollBooking" id="6630a4cb-f5b1-4a55-85b2-bf8b10e15246">
    <superclass name="CM_EventTransaction"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="transact"/>
    <ExplicitInverseRef name="myNewBookingReference" id="9d17c925-d2c5-43bb-93b9-5bfaf2eb1a0a">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_BookingRef"/>
        <access>readonly</access>
        <Inverse name="CM_BookingRef::allSplitRollEventsAsNew"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myOldBookingReference" id="eb50bd5f-7743-4bef-9bac-e6150cc53b6b">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_BookingRef"/>
        <access>readonly</access>
        <Inverse name="CM_BookingRef::allSplitRollEventsAsOld"/>
    </ExplicitInverseRef>
    <PrimAttribute name="remarks" id="9a4d9e12-cfac-4ff5-9d88-da31ef38a34f">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDescription" id="b91dbe70-cf83-4a0c-8ec9-59863568b0bc">
        <source>getDescription(): String;

/*

Purpose:	Get the roll / split text to return for the old / new booking		

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2009	cnwmh5	Initial creation

*/

vars

	oldBookingObj, newBookingObj	: CM_BookingRef;
	
	oldBooking, newBooking				: String;
	oldVoyage, newVoyage				: String;
	oldDischargePort, newDischargePort 	: String;
	
	tmpStr 								: String;
	
begin
	
	// get the old details
	oldBookingObj := self.CMEVT_SplitRollBooking.myOldBookingReference;
	if oldBookingObj &lt;&gt; null then
		oldBooking := oldBookingObj.bookingReference;
		oldVoyage := oldBookingObj.voyageCode;
		oldDischargePort := oldBookingObj.dischargePort;
	endif;
	
	// get the new details
	newBookingObj := self.CMEVT_SplitRollBooking.myNewBookingReference;
	if newBookingObj &lt;&gt; null then
		newBooking := newBookingObj.bookingReference;
		newVoyage := newBookingObj.voyageCode;
		newDischargePort := newBookingObj.dischargePort;
	endif;
	
	// get the text to return
	if self.isRolledBookingEvent then
		tmpStr := app.getErrorString6(Booking_Rolled_From_To, oldBooking, oldVoyage, oldDischargePort, 
			newBooking, newVoyage, newDischargePort);
	else
		tmpStr := app.getErrorString6(Booking_Split_From_To, oldBooking, oldVoyage, oldDischargePort, 
			newBooking, newVoyage, newDischargePort);
	endif;
	
	//12 Mar 2013	NDl	Par 31279
	if remarks &lt;&gt; null then
		tmpStr := tmpStr &amp; " (" &amp; self.remarks &amp; ")";
	endif;
	
	// return the text
	return tmpStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e52b68d0-610b-4f88-9563-ede97947d59f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04/11/2009	cnwmh5	Initial creation   PAR20767

*/

vars

begin

	// get details if ErrorText attribute
	if _attrName = ETRow_ErrorText then
		return self.getDescription();
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isRolledBookingEvent" id="f582d49a-60be-4573-93fc-8d9541a895df">
        <source>isRolledBookingEvent() : Boolean;

/*

Purpose:		Return true if rollling booking rather 
				than spliting	

Parameters:			

Return Value:		


Date		Who		Reason
04/11/2009	cnwmh5	Initial creation  PAR20767

*/

vars

begin
	return self.type = EVT_RollBooking;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBookingReferences" id="475ccdba-fa4b-4106-b0b6-784a562d8585">
        <updating/>
        <source>setBookingReferences(_oldRef, _newRef :CM_BookingRef; _remarks : String) updating;

vars

begin

	self.remarks := _remarks;	//12 Mar 2013	NDL	Par 31279
	
	myOldBookingReference	:= _oldRef;
	myNewBookingReference	:= _newRef;
	
end;
</source>
        <Parameter name="_oldRef" type="CM_BookingRef"/>
        <Parameter name="_newRef" type="CM_BookingRef"/>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCMIF" id="45f8c18f-80cf-46d2-85ce-52dfb474719b">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_SplitRollBookingCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars

begin
	
	self.setBookingReferences(_cmifEventTrx.myOldBookingReference, _cmifEventTrx.myNewBookingReference, _cmifEventTrx.remarks);
	
	inheritMethod(_eventType, _cmifEventTrx);

epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_SplitRollBookingCtrl"/>
    </JadeMethod>
</Class>
