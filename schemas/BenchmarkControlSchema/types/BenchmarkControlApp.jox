    <JadeMethod name="setSession" id="4f0b5873-69d3-4a8a-be70-8a82e40309b2">
        <updating/>
        <source>setSession(session:Integer; driveLetter,envid,runid,controlPort,product,rapHost:String; appServers:Integer) updating;

vars
	bc:BmkControlSession;
begin
	bc:=global.allBmkControls[session];
	bc.setParamsShort(driveLetter,envid,runid,controlPort,product,rapHost,appServers);
end;</source>
