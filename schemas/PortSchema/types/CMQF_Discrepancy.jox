    <JadeMethod name="initiateFilterObjects" id="40d638ff-3769-40d0-8817-9a2b935a1a77">
        <updating/>
        <source>initiateFilterObjects(_collection : CM_TITransactionSet input)updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 November 2008
//
// Implemented version:  7.7.1 CCMS1765 PAR18532
// 
//----------------------------------------------------------------------
vars
	startTS,
	endTS		: TimeStamp;
	terminal 	: CM_Terminal;
	txnType : Integer;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	
begin
	//Get all edit transactions and find out if they include a seal change.
	self.initFields(); 
	
	//Set the time/date range.
	self.setDefaultStartEndDates(startTS, endTS);

	if self.getMyVoyage &lt;&gt; null then
		voyage := self.getMyVoyage;
		if not voyage.archived then
			foreach txnType in self.allTxnTypes do
				voyage.getTITxnsByTypeFromTIs(txnType, 
											  true,
											  true,
											  true,
											  true,
											  startTS, 
											  endTS, 
											  CMQF_FilterReports::checkStatusIncludesObject.name, 
											  self, 
											  _collection);
			endforeach;
			
		endif;
	else
		foreach terminal in self.allTerminals do : terminalLoop
			foreach txnType in self.allTxnTypes do
				terminal.getTITxnsForTypeAll(txnType, startTS, endTS, CMQF_FilterReports::checkStatusIncludesObject.name, self, _collection);
			endforeach;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_collection" type="CM_TITransactionSet" usage="input"/>
    </JadeMethod>
</Class>
