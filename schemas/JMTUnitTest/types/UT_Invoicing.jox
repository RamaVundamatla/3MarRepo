    <JadeMethod name="createTermsOfTrade" id="e980e309-767d-44a7-9a5f-3358049f20d2">
        <source>createTermsOfTrade(_code : String; _desc : String; _dueRule : Integer; _dueDays : Integer) : CM_InvoiceTermsOfTrade;
/*
Purpose - 	
Who - NAVAB1
Date - 10SEP2025
ADO - JIRA 35899
*/


vars
	code	: String;
	description	: String;
	term	: CM_Terminal;
	terms, pxyTerms	: CM_InvoiceTermsOfTrade;
	dueRule,
	dueDays				: Integer; 
begin

	term := self.getTerminal();
	// suppress delete warnings
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.clearErrorsWarnings();
	terms := app.myRoot.myRootCompany.allInvoiceTermsOfTrade[_code];
	if terms &lt;&gt; null then
		app.myTrxDA.trxDeleteInvTermsOfTrade(terms, app.myPassport);
	endif;	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.clearErrorsWarnings();

	app.myPassport.setWarningsIgnored(false);
	// Test Create
	create pxyTerms transient;
	code := _code;
	description := _desc;
	dueRule := _dueRule;
	dueDays := _dueDays;												
	pxyTerms.setProxy(code, description, dueDays, dueRule);
	
	app.myTrxCA.trxCreateInvTermsOfTrade(pxyTerms, terms, app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in TERMS CREATION &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(terms.description,_desc, "Terms description, add");
	self.assertEqualMsg(terms.dueRule, _dueRule, "Terms due rule, add");	
	self.assertEqualMsg(terms.dueDays, _dueDays, "Terms due days, add");	

	return terms;
epilog

	app.myPassport.setWarningsIgnored(false);
	delete pxyTerms;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_dueRule" type="Integer"/>
        <Parameter name="_dueDays" type="Integer"/>
        <ReturnType type="CM_InvoiceTermsOfTrade"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage" id="e5c3c65b-f99e-43f9-b5f0-b3baa1e045a7">
        <updating/>
        <source>createVesselVoyage(_voyage : String; _vessel : String; _operator :CM_Operator) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	
begin
	deleteVoyage("UTSTOR1");
	deleteVessel("UTINVTEST1");
	vessel := addVesselCellular("UTINVTEST1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.addVesselDefnReefer40(vessel);
	voyage1 := addVoyageWithContainerStructur("UTSTOR1", "UTINVTEST1", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	return voyage1;
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage3" id="82a446b2-5b6a-4f95-b28e-5c199b139706">
        <updating/>
        <source>createVesselVoyage3() : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	Simple vessel for HMS invoicing
// ---------------------------------------------------------------------------

vars
	vesselCode,
	voyCode	 :String;
	opCode	: String;
	voyage	: CM_Voyage;
	vessel	: CM_Vessel; 
	berth	: HMS_Berth;
	
begin
	vesselCode := "UTINVVSL3";
	voyCode := "UTINVVOY3";

	deleteVoyage(voyCode);
	deleteVessel(vesselCode);
	
	opCode		:=	self.getProfileSetting(UT_Profile.P_OPERATOR).asString();	
	vessel	:=	self.addVesselGeneralCargo(	vesselCode,
											self.getOperator(opCode),
											10);
	self.assertNotNullMsg(vessel, "Add vessel " &amp; vesselCode &amp; " failed!");
	berth := self.getTerminal().myHarbour.allBerths.last;
	
	voyage	:=	self.addVoyageWithGeneralCargoStruc(voyCode,
													vesselCode,
													vessel.myOperator.code,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(),
													10);
	self.assertNotNullMsg(voyage, "Add voyage " &amp; voyCode &amp; " failed!");

	return voyage;
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage4" id="81b56421-01b1-4bb1-be56-e24d7014d031">
        <updating/>
        <source>createVesselVoyage4(_vesselCode : String; _voyageCode : String; _arrive : TimeStamp; _depart : TimeStamp) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// copy of createVesselVoyage3 with specific vessel/voyage code, arrive and depart dates
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	Simple vessel for HMS invoicing
// ---------------------------------------------------------------------------

vars
	vesselCode,
	voyCode	 : String;
	opCode	: String;
	voyage	: CM_Voyage;
	vessel	: CM_Vessel; 
	berth	: HMS_Berth;
	
begin
	vesselCode := _vesselCode;	// "UTINVVSL4";
	voyCode := _voyageCode;		// "UTINVVOY4";

	deleteVoyage(voyCode);
	deleteVessel(vesselCode);
	
	opCode		:=	self.getProfileSetting(UT_Profile.P_OPERATOR).asString();	
	vessel	:=	self.addVesselGeneralCargo(	vesselCode,
											self.getOperator(opCode),
											10);
	self.assertNotNullMsg(vessel, "Add vessel " &amp; vesselCode &amp; " failed!");
	berth := self.getTerminal().myHarbour.allBerths.last;
	
	voyage	:=	self.addVoyageWithGCStructDates(voyCode,
													vesselCode,
													vessel.myOperator.code,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(),
													10,
													_arrive,
													_depart);
	self.assertNotNullMsg(voyage, "Add voyage " &amp; voyCode &amp; " failed!");

	return voyage;
epilog

end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_arrive" type="TimeStamp"/>
        <Parameter name="_depart" type="TimeStamp"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage5" id="a4cf529d-1c02-48cf-8a7f-8c52e948bba8">
        <updating/>
        <source>createVesselVoyage5() : CM_Voyage updating;
/*
Purpose:			
Date				Who			Reason
DECEMBER 2014		NAVAB1		Initial creation
*/

vars

	voyage1						: CM_Voyage;
	vessel						: CM_Vessel; 
	harbourBerthPreference 		: HMS_BerthPreferenceVesselData;
	harbourBerthPrefArray		: ObjectArray;
	harbour						: HMS_Harbour;
	berth						: HMS_Berth;
	wharf						: HMS_Wharf;
	term						: CM_Terminal;
	bank 						: CM_Bank;
	adate 						: Date;
begin
	deleteVoyage("UTHMSBERTH");
	deleteVessel("UTHMSBERTHV");
	
	term 	:= self.getTerminal();
	harbour := term.myHarbour;
	berth   := harbour.allBerths["W1"];
	wharf   := berth.myWharf;

	create harbourBerthPrefArray transient;
	create harbourBerthPreference transient;
	harbourBerthPreference.setProxy(1403.0, 1253.0, 1203.0, 1, berth, app.myPassport);

	harbourBerthPrefArray.add(harbourBerthPreference);
		
	berth := harbour.allBerths["W2"];

	create harbourBerthPreference transient;
	
	harbourBerthPreference.setProxy(1403.0, 1253.0, 1203.0, 1, berth, app.myPassport);

	harbourBerthPrefArray.add(harbourBerthPreference);
	self.opts.addAssoc("HarbourPrefrencesArray", harbourBerthPrefArray);
	
	vessel := addVesselCellular("UTHMSBERTHV", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	/* FOR HMS INVOICE TESTING ADD IN SOME DEFAULT RESOURCES
	LEAVE ALONE - SEE ANDREW
	vhd := vessel.myHMSVesselData.allVesselDataForHarbour[harbour];
	if vhd &lt;&gt; null then
		rtfm := vhd.allMovementResourcesByMovement.first;
		if rtfm = null then
			beginTransaction;
			create rtfm;
			rtfm.setPropertyValue("movementType",HMSMovementTypeArrival);
			vhd.allMovementResourcesByMovement.add(rtfm);
			commitTransaction;
		
		endif;
		
		if rtfm&lt;&gt; null then
			beginTransaction;
			rtfm.allResourceTypes.add("5965.332".asOid.HMS_ResourceType);
			rtfm.allResourceTypes.add("5965.330".asOid.HMS_ResourceType);
			rtfm.allResourceTypes.add("5965.329".asOid.HMS_ResourceType);
			commitTransaction;
		endif;
	endif;
	*/
	
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.opts.addAssoc("dischargeCompany", bank);
	
	adate := adate.cnEcAddDays(-3); // 3 days ago

	self.opts.addAssoc("dateArrival", adate);
	adate := adate.addDays(2); // 1 day a go
	self.opts.addAssoc("dateDeparture", adate);

	
	voyage1 := addVoyageWithContainerStructur("UTHMSBERTH", "UTHMSBERTHV", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	return voyage1;
epilog
	self.opts.purge();
	if harbourBerthPrefArray &lt;&gt; null then	//18.03.2025 navma1
		harbourBerthPrefArray.purge;
		delete harbourBerthPrefArray;
	endif;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage6" id="53d0f713-e91a-4803-b286-2b7ba4bd465d">
        <updating/>
        <source>createVesselVoyage6() : CM_Voyage updating;
/*
Purpose:			
Date				Who			Reason
DECEMBER 2014		NAVAB1		Initial creation
16 Jul 2019	jlgsl4	TFS 44957 - PEL1 - include movement pilot details in voyage-movement UT
*/

vars

	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
		harbourBerthPreference 		: HMS_BerthPreferenceVesselData;
	harbourBerthPrefArray		: ObjectArray;
		harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	term		: CM_Terminal;
	bank : CM_Bank;
	adate : Date;
	shiftTS : TimeStamp;
	realMovementPilotDetails : HMS_MovementPilotDetails; // TFS 44957
	pilot : HMS_Pilot; // TFS 44957
begin
	deleteVoyage("UTHMSBERTH");
	deleteVessel("UTHMSBERTHV");
	
	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths["W1"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W1 does not exist on harbour " &amp; harbour.description &amp; ".");
	
	wharf := berth.myWharf;


	
	create harbourBerthPreference transient;
	create harbourBerthPrefArray transient;
	harbourBerthPreference.setProxy(1403.0, 1253.0, 1203.0, 1, berth, app.myPassport);
	harbourBerthPrefArray.add(harbourBerthPreference);
	
	berth := harbour.allBerths["W2"];

	create harbourBerthPreference transient;
	
	harbourBerthPreference.setProxy(1403.0, 1253.0, 1203.0, 1, berth, app.myPassport);

	harbourBerthPrefArray.add(harbourBerthPreference);
	self.opts.addAssoc("HarbourPrefrencesArray", harbourBerthPrefArray);

	
	
	vessel := addVesselCellular("UTHMSBERTHV", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.opts.addAssoc("dischargeCompany", bank);
	
	adate := adate.cnEcAddDays(-13); // 13 days ago

	self.opts.addAssoc("dateArrival", adate);
	adate := adate.addDays(12); // 1 day a go
	self.opts.addAssoc("dateDeparture", adate);

	
	voyage1 := addVoyageWithContainerStructur("UTHMSBERTH", "UTHMSBERTHV", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	adate := adate.addDays(-8); // 9 days a go
	shiftTS.setDate(adate);
	berth := harbour.allBerths["W2"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W2 does not exist on harbour " &amp; harbour.description &amp; ".");
	
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	pilot := self.createPilotWithResource(harbour); // --&gt; TFS 44957
	beginTransaction;
	create realMovementPilotDetails persistent;
	realMovementPilotDetails.setMyPilot(pilot);
	voyage1.getMovementShift(1).allMovementPilotDetails.add(realMovementPilotDetails); // add pilot to first shift
	commitTransaction; // &lt;-- TFS 44957

	return voyage1;
epilog
	self.opts.purge();

	harbourBerthPrefArray.purge();
	delete harbourBerthPrefArray;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage7" id="95eebb9f-9115-496b-a3e7-e45c6fe72902">
        <updating/>
        <source>createVesselVoyage7() : CM_Voyage updating;
/*
Purpose:			
Date				Who			Reason
DECEMBER 2014		NAVAB1		Initial creation
*/

vars

	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
		harbourBerthPreference 		: HMS_BerthPreferenceVesselData;
	harbourBerthPrefArray		: ObjectArray;
		harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	term		: CM_Terminal;
	bank : CM_Bank;
	adate : Date;
	atime : Time;
	shiftTS, tmpTS : TimeStamp;
begin
	deleteVoyage("UTHMSBERTH");
	deleteVessel("UTHMSBERTHV");
	
	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths["W1"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W1 does not exist on harbour " &amp; harbour.description &amp; ".");
	
	wharf := berth.myWharf;


	
	create harbourBerthPreference transient;
	create harbourBerthPrefArray transient;
	harbourBerthPreference.setProxy(1403.0, 1253.0, 1203.0, 1, berth, app.myPassport);
	harbourBerthPrefArray.add(harbourBerthPreference);
	
	berth := harbour.allBerths["W2"];

	create harbourBerthPreference transient;
	
	harbourBerthPreference.setProxy(1403.0, 1253.0, 1203.0, 1, berth, app.myPassport);

	harbourBerthPrefArray.add(harbourBerthPreference);
	
	
	berth := harbour.allBerths["UTNOCHARGE"];

	create harbourBerthPreference transient;
	
	harbourBerthPreference.setProxy(1403.0, 1253.0, 1203.0, 1, berth, app.myPassport);

	harbourBerthPrefArray.add(harbourBerthPreference);

	
	self.opts.addAssoc("HarbourPrefrencesArray", harbourBerthPrefArray);

	
	
	vessel := addVesselCellular("UTHMSBERTHV", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.opts.addAssoc("dischargeCompany", bank);
	
	adate.setDate(22,10,2014);
	adate.setDate(22,10,2014);	atime.setTime(8,10,00,00); 	tmpTS.setDate(adate);	tmpTS.setTime(atime);
	self.opts.addAssoc("dateArrival", adate);
	self.opts.addAssoc("tsArrival", tmpTS);
	adate.setDate(17,1,2015);
	adate.setDate(17,1,2015);	atime.setTime(14,40,00,00); 	tmpTS.setDate(adate);	tmpTS.setTime(atime);
	self.opts.addAssoc("dateDeparture", adate);
	self.opts.addAssoc("tsDeparture", tmpTS);

	
	voyage1 := addVoyageWithContainerStructur("UTHMSBERTH", "UTHMSBERTHV", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	
	// ### SHIFT 1
	adate.setDate(29,10,2014);	atime.setTime(07,00,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["UTNOCHARGE"];
	assertTrueMsg(berth &lt;&gt; null, "Berth UTNOCHARGE does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	// ### SHIFT 2
	adate.setDate(29,10,2014);	atime.setTime(14,00,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["UTNOCHARGE"];
	assertTrueMsg(berth &lt;&gt; null, "Berth UTNOCHARGE does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	// ### SHIFT 3
	adate.setDate(1,11,2014);	atime.setTime(16,40,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["W2"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W2 does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	// ### SHIFT 4
	adate.setDate(20,11,2014);	atime.setTime(16,00,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["W2"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W2 does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	// ### SHIFT 5
	adate.setDate(27,11,2014);	atime.setTime(13,24,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["W2"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W2 does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	// ### SHIFT 6
	adate.setDate(19,12,2014);	atime.setTime(7,30,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["W2"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W2 does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	// ### SHIFT 7
	adate.setDate(22,12,2014);	atime.setTime(12,30,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["W2"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W2 does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	// ### SHIFT 8
	adate.setDate(24,12,2014);	atime.setTime(13,55,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["W2"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W2 does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	// ### SHIFT 9
	adate.setDate(9,1,2015);	atime.setTime(12,0,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["UTNOCHARGE"];
	assertTrueMsg(berth &lt;&gt; null, "Berth UTNOCHARGE does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);
	
	// ### SHIFT 10
	adate.setDate(16,1,2015);	atime.setTime(10,45,00,00); 	shiftTS.setDate(adate);	shiftTS.setTime(atime);
	berth := harbour.allBerths["W2"];
	assertTrueMsg(berth &lt;&gt; null, "Berth W2 does not exist on harbour " &amp; harbour.description &amp; ".");
	self.addHarbourMovementShift(shiftTS, voyage1, berth);

	return voyage1;
epilog
	self.opts.purge();

	harbourBerthPrefArray.purge();
	delete harbourBerthPrefArray;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage8" id="fb613a10-5533-4490-993d-a38e632de5f0">
        <updating/>
        <source>createVesselVoyage8() : CM_Voyage updating;
/*
Purpose:			
Date				Who			Reason
DECEMBER 2014		NAVAB1		Initial creation
*/

vars

	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	harbourBerthPreference 		: HMS_BerthPreferenceVesselData;
	vhd : HMS_VesselDataHarbour;
	rtfm : HMS_ResourceTypeForMovement;
	harbourBerthPrefArray		: ObjectArray;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	term		: CM_Terminal;
	bank : CM_Bank;
	adate : Date;
	atime	 :Time;
	ts		: TimeStamp;
begin
	deleteVoyage("UTHMSBERTH");
	deleteVessel("UTHMSBERTHV");
	
	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths["W1"];
	wharf := berth.myWharf;


	
	create harbourBerthPrefArray transient;
	create harbourBerthPreference transient;
	harbourBerthPreference.setProxy(1403.0, 1253.0, 1203.0, 1, berth, app.myPassport);

	harbourBerthPrefArray.add(harbourBerthPreference);
	
	
	berth := harbour.allBerths["W2"];

	create harbourBerthPreference transient;
	
	harbourBerthPreference.setProxy(1403.0, 1253.0, 1203.0, 1, berth, app.myPassport);

	harbourBerthPrefArray.add(harbourBerthPreference);
	self.opts.addAssoc("HarbourPrefrencesArray", harbourBerthPrefArray);

	vessel := addVesselCellular("UTHMSBERTHV", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.opts.addAssoc("dischargeCompany", bank);
	
	// arrived 1 day ago at 00:55 and left 1 day ago at 22:50 (times to match the original problem report)
	adate := adate.cnEcAddDays(-1); // 1 day ago
	ts.setDate(adate);
	ts.setTime("00:55".Time);
	self.opts.addAssoc("tsArrival", ts);
	ts.setDate(adate);			//  still 1 day ago
	ts.setTime("22:50".Time);
	self.opts.addAssoc("tsDeparture", ts);

	
	voyage1 := addVoyageWithContainerStructur("UTHMSBERTH", "UTHMSBERTHV", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	return voyage1;
epilog
	self.opts.purge();
	harbourBerthPrefArray.purge;
	delete harbourBerthPrefArray;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="deleteCleanup" id="2916d96c-4e9f-465f-9995-d90ba906d54d">
        <source>deleteCleanup();
/*
Purpose - 	// ### NAVAB1 04MAR2024 - fixing UTs, delete everything.
Who - NAVAB1
Date - 04MAR2024
ADO -Fixing UTs
*/

constants
	Ref					: String = "56995";
	UT_Debtor1 			: String = "UT_" &amp; Ref &amp; "_Debtor2";
	UT_InvoiceDesc 		: String = "UT_" &amp; Ref &amp; "_InvoiceDesc";
	UT_BlockStackId 			: String = Ref &amp; "2B1";
	UT_VesselId					: String = "UT_" &amp; Ref &amp; "_VESS00008";
	UT_VoyageId					: String = "UT_" &amp; Ref &amp; "_VOY00008";
	UT_CalculationTypeCode		: String = "UT_" &amp; Ref;
	UT_GlCode					: String = "UT_" &amp; Ref &amp; "_GLCode";
	UT_InvoiceLineDesc			: String = "UT_" &amp; Ref &amp; "_InvoiceLnDescSur";
	UT_OperatorCode				: String = "UTSU";
	UT_TrackedItem1				: String = "UT" &amp; Ref &amp; "011";
	UT_TrackedItem2				: String = "UT" &amp; Ref &amp; "012";
	UT_TrackedItem3				: String = "UT" &amp; Ref &amp; "021";
	UT_TrackedItem4				: String = "UT" &amp; Ref &amp; "022";
	
vars
	debtor1									: CM_Debtor;
	now							: TimeStamp;
begin
	/*
	** Cleanup
	*/
	now := app.actualTimeServer;
	
	self.deleteContainer(UT_TrackedItem1);
	self.deleteContainer(UT_TrackedItem2);
	self.deleteContainer(UT_TrackedItem3);
	self.deleteContainer(UT_TrackedItem4);
	
	self.deleteOperator(UT_OperatorCode);
	
	debtor1 := app.myRoot.myRootCompany.debtors[UT_Debtor1];
	self.deleteDebtor(debtor1);
	
	self.deleteInvoiceType(UT_InvoiceDesc);

	// delete voyage
	self.deleteVoyage(UT_VoyageId);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselId);
	
	//Terminal
	self.deleteTerminalArea(UT_BlockStackId);
	
	self.deleteCalculationType(UT_CalculationTypeCode,FORCED_ERASE);
	self.deleteService(UT_InvoiceLineDesc);
	self.deleteInvoiceGLCode(UT_GlCode);
	self.deleteInvoiceLineType(UT_InvoiceLineDesc, FORCED_ERASE);
epilog

end;</source>
    </JadeMethod>
