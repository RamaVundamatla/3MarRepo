    <JadeMethod name="btnColorSave_click" id="dfcb8553-3e7b-4592-870b-a9735ca8b40f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnColorSave_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	bool : Boolean;
begin
		
	self.xmlColourPlanned := self.clrPlanned.backColor;
	self.xmlColourNonPlanned := self.clrNonPlanned.backColor;
	self.xmlColourOnShip := self.clrOnShip.backColor;
	bool := false;
// check first to see if any other table uses the "planningStateLoadList" 
	if self.tblData.allTblDataColPropertyNames.includes(ETRow_PlanningStateLoadList) or 
			self.tblPlanned.allTblDataColPropertyNames.includes(ETRow_PlanningStateLoadList) or
			self.tblTranShip.allTblDataColPropertyNames.includes(ETRow_PlanningStateLoadList) or
			self.tblTBA.allTblDataColPropertyNames.includes(ETRow_PlanningStateLoadList) or // TFS 45590
			self.tblDLR.allTblDataColPropertyNames.includes(ETRow_PlanningStateLoadList) then
		bool := true;
	endif;
// If tblAll is the only table using this "planningStateLoadList" property then we will load 
// only the tblAll. Otherwise all the tables must be reloded or it will result in color coading inconsistency.
	if bool then 
		self.doRefresh();
	elseif fldMain.topSheet = self.shtAll then
		self.tblAll.rows := self.tblAll.fixedRows;
		self.displayAllTable();
	endif;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
