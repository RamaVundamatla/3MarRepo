    <JadeMethod name="doCmbBankBuild" id="522e8d7d-ff1b-4970-9fe3-3e3dd6f0c674">
        <source>doCmbBankBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	
begin

	self.cmbBank.clear();	// Filter
	self.cmbBankMaint.clear();  //  Maint frame
	
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		self.cmbBank.addItem(company.code);
		self.cmbBank.itemObject[ self.cmbBank.newIndex] := company;
		self.cmbBankMaint.addItem(company.code);
		self.cmbBankMaint.itemObject[self.cmbBankMaint.newIndex] := company;
	endforeach;
	
	if currentBU &lt;&gt; null then
		self.cmbBank.listObject := currentBU;
	endif;
	
epilog
	delete businessUnits;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbJobTitleBuild" id="2aa6a18a-4a42-46d4-a7ee-5981502dac64">
        <source>doCmbJobTitleBuild( _obj : CM_InvoiceSignoffUser );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	index : Integer;

begin

	cmbJobTitle.clear;
	cmbJobTitle.sorted := false;

	cmbJobTitle.addItem( " " );
	cmbJobTitle.addItem( app.getErrorString( Finance_manager ) );
	cmbJobTitle.addItem( app.getErrorString( Finance_GAmanager ) );
	cmbJobTitle.addItem( app.getErrorString( Manager ) );
	cmbJobTitle.addItem( app.getErrorString( Custome_care_associa_manager ) );
	
	if _obj &lt;&gt; null and _obj.userJobTitle &lt;&gt; null then
		index := cmbJobTitle.findStringExact(1,_obj.userJobTitle);
		if index &lt; 1 then
			index := cmbJobTitle.addItem( _obj.userJobTitle );
		endif;
		cmbJobTitle.listIndex := index;
	else
		cmbJobTitle.listIndex := -1;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_InvoiceSignoffUser"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="bed6b782-710d-452b-a44f-515d976475a8">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	theReturn : Integer;
begin
 
	while true do
 
 	 	app.myTrxDA.trxDeleteInvoiceSignoff(self.myCurrentObject.CM_InvoiceSignoffUser, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return true;
		else
			theReturn := app.showErrorWarningDialog( app.getErrorString(Invoice_signoff_user), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
