    <JadeMethod name="cmbDebtor_lostFocus" id="cbe1da2b-a5fa-4073-8fda-4c0c0dee1ec0">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDebtor_lostFocus(combobox: ComboBox input) updating;
//	make sure the table 'debtor' row reflects the debtor combo selection
vars
	debtor	: CM_Debtor;
begin
	debtor := self.cmbDebtor.listObject.CM_Debtor;
	if debtor &lt;&gt; null then
		self.tblAgents.setValueByName(ETRow_MyDebtor, debtor.name);
	endif;
end;
</source>
