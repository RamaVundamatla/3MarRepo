    <JadeMethod name="cashTestSplitReceipt" id="7d3a3423-0f42-4d68-8a80-d6259da84bbf">
        <updating/>
        <source>cashTestSplitReceipt(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, gate out a single item with storage is due and with two part payments.
				Storage charges are in more than one invoice line.
				The payments from the two receipts are split over the last invoice line.
Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	After par 33885, modified Aug 2016 to use the BOL cash receipt create
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	effectiveTS,
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	cashReceipt1 : CM_CashReceipt;
	cashReceipt2 : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	cashToPay,
	cashTotal	 : Decimal[23,6];// [16,4]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	truckOut : CM_Vehicle;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	customsAgent	: CM_CustomsAgent;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents	: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	storagedetail : CM_StorageDetail;
	freestorageexpires : Date;
	freestoragedays : Integer;
	objsToDelete : ObjectSet;
begin
	msg := method.name;
	
	truckOut := _truckOut;
	//Now create onsite cargo that will be gated out by truck.
	cargoId := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, true, 25);

	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");
	
	storagedetail := onsiteTi.getMatchingFreeStorageDetail( null ); // TFS 45953 for testing
	freestorageexpires := onsiteTi.getFreeStorageExpiryDate; // TFS 45953 for testing
	freestoragedays := onsiteTi.getFreeStorageDays(); // TFS 45953 for testing
	

	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);
	now := app.actualTimeServer;
	effectiveDate := now.date - 2;
	effectiveTS := now.addDays(-2);

	create allAgents transient;
	agent := self.createProformaAgent(effectiveTS, onsiteTi);
	allAgents.add(agent);
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;		// should be 860

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	
	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on site cargo not created...");

	foreach cashPayment in cashReceipt1.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, msg &amp; " Cash Payment Pro Forma for on site cargo not created...");

	self.assertTrueMsg(not onsiteTi.allCashPayments.isEmpty, msg &amp; " Pro Forma not on On Site Cargo...");

	delete agent;
	allAgents.clear();
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);

	// de-select the current lines (should be paid)
	agent.allCurrentInvLines.clear(); // TFS 45953
// TFS 45953	foreach invLine in agent.allCurrentInvLines do
// TFS 45953		agent.setSelected(false, false, invLine);
// TFS 45953	endforeach;
	// de-select the proforma lines except the last (partially paid)
 // TFS 45953	agent.allProformaInvLines.purge();
	create objsToDelete transient; // TFS 45953
	foreach invLine in agent.allProformaInvLines do
		count := count + 1;
		if count &gt; 2 then
			break;
		endif;
		 // TFS 45953 agent.setSelected(true, false, invLine);
		objsToDelete.add(invLine); // TFS 45953
		agent.allProformaInvLines.remove(invLine); // TFS 45953
	endforeach;
	objsToDelete.purge(); // TFS 45953
	delete objsToDelete; // TFS 45953

	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;		// should be 80

	cashReceipt2 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, msg &amp; " Cash Receipt 2 for on site cargo not created...");

	// Clear all the stops
	self.deleteStops(onsiteTi);

	vvrOut := createVVR( truckOut, onsiteTi );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	count := 0;
	foreach cashPayment in onsiteTi.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Cargo Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 or count = 2 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		elseif count = 3 then
			self.assertEqualMsg(cashPayment.cashValue, 100.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		elseif count = 4 then
			self.assertEqualMsg(cashPayment.cashValue, 720.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		elseif count = 5 then
			self.assertEqualMsg(cashPayment.cashValue, 80.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 5, msg &amp; " Cargo cash payments");

	count := 0;
	foreach cashPayment in cashReceipt1.allCashPayments do
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Receipt 1 Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 or count = 2 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt 1 Cash payment value ");
		elseif count = 3 then
			self.assertEqualMsg(cashPayment.cashValue, 100.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt 1 Cash payment value ");
		else
			self.assertEqualMsg(cashPayment.cashValue, 720.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt 1 Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 4, msg &amp; " Receipt 1 cash payments");
	
	count := 0;
	foreach cashPayment in cashReceipt2.allCashPayments do
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Receipt 2 Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 then
			self.assertEqualMsg(cashPayment.cashValue, 80.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt 2 Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 1, msg &amp; " Receipt 2 cash payments");

	cashInvoice := cashReceipt1.myCashInvoice;
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
		if count = 1 or count = 2 then
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT9", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		elseif count = 3 then
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT10", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 100.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		else	
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT11", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 800.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		endif;
	endforeach;
	assertEqualMsg(count, 4, msg &amp; " Receipt invoice lines");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_truckOut" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="createBOLCargoForCash" id="e8d08dba-2a07-4c66-b0ad-956948373108">
        <updating/>
        <source>createBOLCargoForCash(_terminalId : String; _extraMoves : Boolean; _connectReefers : Boolean) protected, updating;
// cnwjre1
/*	
	Create cargo for cash module testing, in nominated terminal for nominated voyage and cargo operator
	with known transactions and existing charges.  Cargo is containers with child cargo.
*/
vars
	terminalId	: String;
	bolId		: String;
	terminal	: CM_Terminal;
	passTerm	: CM_Terminal;
	appBank		: CM_Bank;
	bs 			: CM_TerminalArea;
	operator	: CM_Operator;
	ti			: CM_TrackedItem;
	containers	: CM_TISet;
	voyage : CM_Voyage;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
	now : Date;
	resetIsFull : Boolean;
	resetBS : CM_BlockStack;

begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	// save app/passport attributes for current terminal
	passTerm := app.myPassport.myTerminal;
	appBank := self.myBank;

	terminalId := _terminalId;
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminalId);
	terminal := self.getTerminal();
	app.myPassport.setPropertyValue("myTerminal", terminal);
	self.myBank := terminal.getDefaultCompanyBank();
	
	operator := self.getOperator("MSC");
	
	voyage := self.createTargetVesselVoyage(terminal, "JMT CASH", "JCASH002", operator);
	
	self.myOperator := operator;
	create containers transient;
	
	self.createBOLCashCargo(terminalId, voyage, containers);
	
	// optionally move all cargo around to get an extra charge
	if _extraMoves then
		self.opts.addAssoc("Terminal", terminalId);
		bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("UTBOLBS3");
		resetIsFull := bs.isKindOf(CM_BlockStack) and bs.CM_BlockStack.isFull;
		if resetIsFull then
			resetBS := bs.CM_BlockStack;
			beginTransaction;
			resetBS.setPropertyValue(CM_BlockStack::isFull.name, false);
			commitTransaction;
		endif;

		foreach ti in containers do
			self.move(ti, bs);
		endforeach;
	endif;
	
	tranDate := now - 10;
	tranTS.setDate(tranDate);
	// back-date transactions 10 days to get storage charges
	foreach ti in containers do
		foreach tran in ti.allTransactions do
			tranTS.setDate(tranDate);
			tranTS.setTime(tran.dateTime.time);
		
			beginTransaction;
			tran.setPropertyValue("dateTime", tranTS);
			commitTransaction;
		endforeach;
		// back-date received and move dates for reefer connection
		beginTransaction;
		ti.setReceivedDT(tranTS);
		ti.setPropertyValue("moveDT", tranTS);
		commitTransaction;
	endforeach;

	// optionally connect all reefers for reefer daily charge - do after back-dating transactions so it works
	if _connectReefers then
		foreach ti in containers do
			if ti.isReefer then
				self.updateTIConnection(ti, false, true, tranTS, null);
			endif;
		endforeach;
	endif;
	
epilog
	delete containers;
	// restore app/passport current terminal attributes
	app.myPassport.setPropertyValue("myTerminal", passTerm);
	self.myBank := appBank;
	self.myOperator := null;
	if resetIsFull and resetBS &lt;&gt; null then
		beginTransaction;
		resetBS.setPropertyValue(CM_BlockStack::isFull.name, true);
		commitTransaction;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_terminalId" type="String"/>
        <Parameter name="_extraMoves" type="Boolean"/>
        <Parameter name="_connectReefers" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createBOLCargoScenario1" id="d65ac986-ec1f-4763-9a15-19aa0424264a">
        <updating/>
        <source>createBOLCargoScenario1(_terminalId : String; _voyage : CM_Voyage; _containers : CM_TISet input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17/02/2015	create on-site cargo directly
//				One container with a BOL, four children with no BOL.
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
// ---------------------------------------------------------------------------

constants
	BlockStack = "UTBOLBS2";
vars
	terminalId,
	bolId,
	id			: String;
	bs: CM_BlockStack;
	packTIs	: CM_TIArray;
	wh: CM_IrregularBlockArea;
	cargoType: CM_CargoType;
	product	: CM_Product;
	location: CM_LocationsController;
	voy : CM_Voyage;
	parent : CM_TrackedItem;
	child1,
	child2,
	child3,
	child4	: CM_TrackedItem;
	realBOL	: CM_BOL;
	pxyBOL : CM_BOLIn;
	pxyBOLItem : CM_BOLDtl;
	subTerminal : CM_SubTerminal;
	ti          : CM_TrackedItem;
begin
	voy := _voyage;
	bolId := "MSCUAR751015";
	terminalId := _terminalId;
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminalId);

	// create an actual BOL for this cargo
	// get the subterminal
	subTerminal := self.getSubTerminal(null);

	create pxyBOL transient;	
	pxyBOL.setProxy(bolId, voy, self.myOperator, null, 4, BOLType_GeneralBillOfLading, self.getTerminal, subTerminal, null, null, null, false, null, null, null,
																																						null);	//13/07/2022 navgm20 Tfs 54095
	// BOL weight is 13784
	pxyBOL.setPropertyValue("weightNet", 13784.Decimal);
	pxyBOL.setPropertyValue("weightGross", 13784.Decimal);
	
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL, TI_CargoType_Container, "GENL", "colour", "mark", 4, 5, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL(pxyBOL, realBOL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	bs:= self.getTerminalArea(BlockStack).CM_BlockStack;

	// scenario 1 - 1 20ft FCL container with 4 children, 1 BOL for container only
	self.opts.addAssoc(UTTI_BOL, bolId);
	self.opts.addAssoc(UTTI_VoyageCode, voy.code);
	id := "MSCU3439518";
	self.deleteContainer(id);
	parent := self.addContainerAtLocation( id, self.myOperator, "22G0", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	self.opts.addAssoc("TotalWeight", parent.getTareWeight().Integer);
	self.updateTI(parent);		// set the total weight to the tare weight so that packing the children gets the total correct
	_containers.add(parent);

	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	location := wh.allLocationsControllers.first;

	// child 1, break-bulk, spare parts
	cargoType := self.getCargoType("GENERAL");
	product := cargoType.allProducts[null, "SPARE PARTS"];
	
	id := "MSCU3439518-1";
	self.deleteCargo(id, cargoType);
	child1 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.opts.removeAssoc("TotalWeight");
	self.opts.removeAssoc(UTTI_BOL);
	self.opts.addAssoc("TotalWeight", 1224);	// first two children
	self.opts.addAssoc("TotalQuantity", 120);	// first two children
	self.opts.addAssoc("Commodity", "US20");	// for all children
	self.opts.addAssoc("Voyage", voy);		// for all children
	self.updateTI(child1);
	self.assertLocationHasTI(location, child1);

	// child 2, break-bulk, personal effects
	cargoType := self.getCargoType("GENERAL");
	product := cargoType.allProducts[null, "PERSONAL"];
	id := "MSCU3439518-2";
	self.deleteCargo(id, cargoType);
	child2 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.updateTI(child2);		// set the same total weight
	self.assertLocationHasTI(location, child2);

	// child 3, vehicle, saloon
	cargoType := self.getCargoType("VEHICLE");
	product := cargoType.allProducts[null, "SALOON"];
	id := "MSCU3439518-3";
	self.deleteCargo(id, cargoType);
	child3 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.opts.removeAssoc("TotalWeight");
	self.opts.removeAssoc("TotalQuantity");
	self.opts.addAssoc("TotalWeight", 5667);
	self.updateTI(child3);
	self.assertLocationHasTI(location, child3);

	// child 4, vehicle, mini
	cargoType := self.getCargoType("VEHICLE");
	product := cargoType.allProducts[null, "MINI"];
	id := "MSCU3439518-4";
	self.deleteCargo(id, cargoType);
	child4 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.updateTI(child4);		// set the same total weight
	self.assertLocationHasTI(location, child4);

	// pack all children
	create packTIs transient;
	packTIs.add(child1);
	packTIs.add(child2);
	packTIs.add(child3);
	packTIs.add(child4);
	self.packContainer(parent.CM_Container, packTIs);
	self.packCompleteContainer(parent.CM_Container);
	self.assertEqualMsg(parent.numChildren, 4, "Container " &amp; parent.id &amp; " children incorrect");

epilog

	if pxyBOL &lt;&gt; null then   // 28.09.2017 cnwma1
		if pxyBOLItem &lt;&gt; null then
			delete pxyBOLItem;
		endif;
		delete pxyBOL;
	endif;
	delete packTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_terminalId" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_containers" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createBOLCargoScenario2a" id="273d6a1f-b6a3-4c80-8394-96b2ad2a7b15">
        <updating/>
        <source>createBOLCargoScenario2a(_terminalId : String; _voyage : CM_Voyage; _containers : CM_TISet input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17/02/2015	create on-site cargo directly
//				One container with four children in two BOLs
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
// ---------------------------------------------------------------------------

constants
	BlockStack = "BS2";
vars
	terminalId,
	bolId1,
	bolId2,
	id			: String;
	bs: CM_BlockStack;
	packTIs	: CM_TIArray;
	wh: CM_IrregularBlockArea;
	cargoType: CM_CargoType;
	product	: CM_Product;
	location: CM_LocationsController;
	voy : CM_Voyage;
	parent : CM_TrackedItem;
	child1,
	child2,
	child3,
	child4	: CM_TrackedItem;
	realBOL1,
	realBOL2	: CM_BOL;
	pxyBOL : CM_BOLIn;
	pxyBOLItem : CM_BOLDtl;
	subTerminal : CM_SubTerminal;

begin
	voy := _voyage;
	bolId1 := "MSCUAR743956";
	bolId2 := "MSCUAR743955";

	terminalId := _terminalId;
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminalId);

	// create two actual BOLs for this cargo
	// get the subterminal
	subTerminal := self.getSubTerminal(null);

	create pxyBOL transient;	
	pxyBOL.setProxy(bolId1, voy, self.myOperator, null, 4, BOLType_GeneralBillOfLading, self.getTerminal, subTerminal, null, null, null, false, null, null, null,
																																						null);	//13/07/2022 navgm20 Tfs 54095
	// BOL weight is 15008
	pxyBOL.setPropertyValue("weightNet", 15008.Decimal);
	pxyBOL.setPropertyValue("weightGross", 15008.Decimal);
	
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL, TI_CargoType_Container, "GENL", "colour", "mark", 4, 5, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL(pxyBOL, realBOL1, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyBOLItem;
	delete pxyBOL;
	
	create pxyBOL transient;	
	pxyBOL.setProxy(bolId2, voy, self.myOperator, null, 4, BOLType_GeneralBillOfLading, self.getTerminal, subTerminal, null, null, null, false, null, null, null,
																																							null);	//13/07/2022 navgm20 Tfs 54095
	// BOL weight is 13784
	pxyBOL.setPropertyValue("weightNet", 15008.Decimal);
	pxyBOL.setPropertyValue("weightGross", 15008.Decimal);
	
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL, TI_CargoType_Container, "GENL", "colour", "mark", 4, 5, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL(pxyBOL, realBOL2, null, app.myPassport);
	delete pxyBOLItem;
	delete pxyBOL;
	self.assertNoTrxErrorsOrWarnings();

	bs:= self.getTerminalArea(BlockStack).CM_BlockStack;

	// scenario 2 - 1 20ft FCL container with 4 children, 2 BOLs
	self.opts.addAssoc(UTTI_VoyageCode, voy.code);
	id := "MSCU1938879";
	self.deleteContainer(id);
	parent := self.addContainerAtLocation( id, self.myOperator, "22G0", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	self.opts.addAssoc("TotalWeight", parent.getTareWeight().Integer);
	self.updateTI(parent);		// set the total weight to the tare weight so that packing the children gets the total correct
	_containers.add(parent);

	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	location := wh.allLocationsControllers.first;

	// child 1, vehicle, mini, first BOL
	cargoType := self.getCargoType("VEHICLE");
	product := cargoType.allProducts[null, "MINI"];
	
	id := "WAUJC68E94A115367";
	self.deleteCargo(id, cargoType);
	child1 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.opts.addAssoc(UTTI_BOL, bolId1);
	self.opts.removeAssoc("TotalWeight");
	self.opts.addAssoc("TotalWeight", 4288);	// first two children
	self.opts.addAssoc("Voyage", voy);		// for all children
	self.opts.addAssoc("Commodity", "US20");	// for all children
	self.updateTI(child1);
	self.assertLocationHasTI(location, child1);

	// child 2, vehicle, saloon, first BOL
	cargoType := self.getCargoType("VEHICLE");
	product := cargoType.allProducts[null, "SALOON"];
	id := "1NXBR32E54Z286978";
	self.deleteCargo(id, cargoType);
	child2 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.updateTI(child2);		// set the same total weight
	self.assertLocationHasTI(location, child2);

	// child 3, break-bulk, spare parts second BOL
	cargoType := self.getCargoType("GENERAL");
	product := cargoType.allProducts[null, "SPARE PARTS"];
	id := "MSCU1938879-1";
	self.deleteCargo(id, cargoType);
	child3 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);

	self.opts.removeAssoc(UTTI_BOL);
	self.opts.addAssoc(UTTI_BOL, bolId2);
	self.opts.removeAssoc("TotalWeight");
	self.opts.addAssoc("TotalQuantity", 5);
	self.opts.addAssoc("TotalWeight", 2144);
	self.updateTI(child3);
	self.assertLocationHasTI(location, child3);

	// child 4, vehicle, mini second BOL
	cargoType := self.getCargoType("VEHICLE");
	product := cargoType.allProducts[null, "MINI"];
	id := "5NMSG13D67H063624";
	self.deleteCargo(id, cargoType);
	child4 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.opts.removeAssoc("TotalQuantity");
	self.opts.removeAssoc("TotalWeight");
	self.opts.addAssoc("TotalWeight", 4288);
	self.updateTI(child4);
	self.assertLocationHasTI(location, child4);

	// pack all children
	create packTIs transient;
	packTIs.add(child1);
	packTIs.add(child2);
	packTIs.add(child3);
	packTIs.add(child4);
	self.packContainer(parent.CM_Container, packTIs);
	self.packCompleteContainer(parent.CM_Container);
	self.assertEqualMsg(parent.numChildren, 4, "Container " &amp; parent.id &amp; " children incorrect");

epilog
	
	if pxyBOL &lt;&gt; null then   // 28.09.2017 cnwma1
		if pxyBOLItem &lt;&gt; null then
			delete pxyBOLItem;
		endif;
		delete pxyBOL;
	endif;
	delete packTIs;
end;</source>
        <access>protected</access>
