    <JadeMethod name="stackVertical" id="c0f00a6e-e5ea-44e9-b8a5-936627369a17">
        <updating/>
        <source>stackVertical(_allControls : ObjectArray; _gap : Integer) updating;
/*
Stacks all controls vertically under self 


Date		Who		Reason
12 April 2016	cnwer1	Initial creation PAR

*/

vars
	control : Control;
	obj : Object;
	currentTop : Real;
begin

	currentTop:=self.top + self.clientHeight;
	
	foreach obj in _allControls do
		control:=obj.Control;
		
		if not control.visible then
			continue;
		endif;
		
		control.top := currentTop + _gap;
		
		currentTop:=control.top + control.height;		// clientHeight;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_allControls" type="ObjectArray"/>
        <Parameter name="_gap" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateBubbleHelp" id="9a6aac4f-a17a-4bcd-a40b-4785f142af28">
        <updating/>
        <source>translateBubbleHelp(_id : Integer; _locale : CM_Locale) updating;

vars
	translation	: XLAT_Translation;
begin
	/*if _locale = null then
		return;
	endif;*/
	// An appropriate translation is provided or nothing happens
	// and the default bubbleHelp text from Painter is displayed.
	//translation	:= _locale.getTranslatedText(XLAT_FormCaptions, _id);
	translation := app.zGetTranslatedText(XLAT_FormCaptions, _id);

	if translation &lt;&gt; null then
	//	bubbleHelp := translation.text;
		self.setBubbleHelpForTranslation(translation.text);
	endif;
end;
</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="translateCaption" id="9fa4bb9a-edf0-40cd-99d3-80236822b435">
