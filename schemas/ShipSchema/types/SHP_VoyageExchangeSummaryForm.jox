    <JadeMethod name="doRefresh" id="f77b4107-bbeb-49ad-979c-3c3b47bcca50">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	theVoyage : CM_Voyage;
	theCraneId : String; 
	theTotalJobs, theTotalJobsDone, theTotalMoves, theTotalMovesDone : Integer;
	theVoyageJS : CM_VoyageJobSheet;
	aCrane : CM_Machine;
	rowColor1,
	rowColor2,
	idx		: Integer;
begin
	inheritMethod();
	app.mousePointer := Window.MousePointer_HourGlass;
	self.tblExchange.rows := self.tblExchange.fixedRows;
		
	if self.myCurrentVoyage = null then
		app.msgBox('Please select a voyage and ty again.', 'Select Voyage', MsgBox_Stop_Icon  + MsgBox_OK_Only);	
		self.cmbVoyage.setFocus();
		return;
	endif;
	
	theVoyage := self.myCurrentVoyage;
	
	rowColor1	:= self.colorRow1;
	rowColor2	:= self.colorRow2;
	
	foreach theVoyageJS in theVoyage.allJobSheets do
		
		if theVoyageJS.crane = null then
			continue;
		endif;		
		theVoyage.getCraneStatistics(theVoyageJS.crane.trimBlanks, theTotalJobs, theTotalJobsDone, theTotalMoves, theTotalMovesDone);
		
		idx := self.tblExchange.addItem(theVoyageJS.crane.trimBlanks &amp; Tab &amp;
										theTotalJobsDone.String &amp; "/" &amp; theTotalJobs.String &amp; Tab &amp;
										theTotalMovesDone.String &amp; "/" &amp; theTotalMoves.String);
		
		if idx mod 2 = 0 then
			self.tblExchange.accessRow(idx).backColor := rowColor1;
		else
			self.tblExchange.accessRow(idx).backColor := rowColor2;
		endif;
		
	endforeach;

	//Added to show a refresh has occurred on the Exchange Sheet 26082003
	self.lblRefreshTime.caption := 	'Last updated: ' &amp; self.systemToLocalTime(app.actualTimeServer).shortCurrentLocaleFormat();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="2e752166-3b82-4036-83d8-4ad34a76d255">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	02 August 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTop : Real;
begin
	inheritMethod();
	tmpTop := VerticalSpacing;
	self.lblVoyage.top := tmpTop;
	self.cmbVoyage.top := tmpTop;
	tmpTop := (tmpTop+cmbVoyage.height+VerticalSpacing);
	self.tblExchange.top := tmpTop;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTableExchange" id="d79a7f76-c4ce-4fda-8409-2e573a6340c2">
        <updating/>
        <source>initTableExchange()updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	
	self.tblExchange.setDistanceFromBottom(self.lblRefreshTime.height + VerticalSpacing);
	self.tblExchange.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblExchange.rows := 1;
	self.tblExchange.accessCell(1,1).text := "Crane" &amp; Tab &amp; "Jobs" &amp; Tab &amp; "Moves";
	
	self.setColorsForTable(self.tblExchange);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="e8f81007-6aae-4d6f-9c2f-caad69a79a1a">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	02 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	if self.myCurrentVoyage &lt;&gt; null then
		self.cmbVoyage.setObject(self.myCurrentVoyage);
	endif;
		
	self.setMyCurrentVoyage(self.cmbVoyage.listObject.CM_Voyage);
	self.doResize();
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="060e4afa-2266-4816-ac0f-93b48b05035b">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage)updating;
//--------------------------------------------------
// Created:	02 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myCurrentVoyage := _voyage;
	self.endTimer(Timer_Refresh);				

	if self.myCurrentVoyage &lt;&gt; null then
		//Not required for nonplanned or non-worked voyages so disable button and hide caption.	
//		if (self.myCurrentVoyage.isNonPlannedVoyage) 
//		or (self.myCurrentVoyage.isNonWorkedVoyage) then
//			self.tblExchange.rows := self.tblExchange.fixedRows;
//			self.lblRefreshTime.caption := CaptionNonPlanned;
		//else
		if self.isFirstActivateComplete then	
			self.doRefresh();
			self.beginTimer(60000, Timer_OneShot, Timer_Refresh);
		endif;
	else
		self.tblExchange.rows := self.tblExchange.fixedRows;
		self.lblRefreshTime.caption := 'Please select a voyage to view';
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6435ebb0-d5d8-47be-b211-dd270a618b02">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	02 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_None;	
	self.showToolbar := false;
	self.initTableExchange();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="60f0cd37-7535-4b1e-8687-88bb926c4b6f">
        <updating/>
        <source>showWithObject(_voyage : CM_Voyage)updating;
//--------------------------------------------------
// Created:	02 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myCurrentVoyage := _voyage;
	self.show();
	
	self.doRefresh();
	
	self.doWindowEvents(0);	//timer doesn't work otherwise
	self.beginTimer(60000, Timer_OneShot, Timer_Refresh);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="1f808478-3b71-4ed0-9ed8-1aecb6a127a7">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
//--------------------------------------------------
// Created:	02 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if eventTag = Timer_Refresh then
		self.doRefresh();
	endif;
	self.beginTimer(60000, Timer_OneShot, Timer_Refresh);
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ad2b8ae0-0d1b-4e75-b436-d488c02763b0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006785, locale);
	lblRefreshTime.translateCaption(Xlat_0003682, locale);
	lblVoyage.translateCaption(Xlat_0003683, locale);
end;</source>
    </JadeMethod>
</GUIClass>
