    <JadeMethod name="unlockObject" id="d25ae26b-1e4c-4b08-a208-8413e4f61df5">
        <updating/>
        <source>unlockObject(obStr : String) updating;

vars
	object : Object;
	time   : Time;
begin
	object := obStr.asOid;
	if object &lt;&gt; null then
		unlock(object);
		sl_status.caption := time.String &amp; ' ' &amp; obStr &amp; ' unlocked';
		v_objectNumber := v_objectNumber + 1;
	else
		sl_status.caption := time.String &amp; ' ' &amp; obStr &amp; ' invalid';
	endif;
	colourBackground;
end;
</source>
        <Parameter name="obStr" type="String"/>
    </JadeMethod>
</GUIClass>
