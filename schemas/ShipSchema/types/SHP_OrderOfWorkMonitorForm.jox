    </JadeMethod>
    <JadeMethod name="doPrint" id="fc9590bf-4f87-4ce4-aedb-9bdc5ff92ad0">
        <updating/>
        <source>doPrint() updating;
/*

Date		Who		Reason
29 March 2017	cnwer1	Initial creation TFS

*/
constants
	Margin = 10;
vars
	tmpJadeReport  : JadeReport;
	headerForm : CMUI_ReportLine;
	footerForm 	: CM_GenericTablePrint;
	thePageWidth, thePageHeight : Integer;
	now	: TimeStamp;
	printTable : CM_DataTable;
	clonedControls : ObjectSet;
	newIdx,
	i 			: Integer;
	newFrameTable,
	frmTable 	: Frame;
	clonedTable,
	table 		: CM_DataTable;
	
	controlArray : CnEcControlArray;
	control , clonedControl : Control;
	cmifJobSheetStats : CMIF_JobSheetStats;
begin
	
	create headerForm transient;
	create footerForm transient;
	headerForm.initReport;
	headerForm.lblTitle01.caption := "Order of Work Monitor"; //self.caption;
	headerForm.lblTitle03.caption :=   self.myVoyageStats.myVoyage.getDisplayDetails(false) ; 
	headerForm.lblTitle02.caption :=  app.getErrorString(Arrival);
	headerForm.lblTitle04.caption := self.myVoyageStats.myVoyage.arrivedDT.asStringJMT  ;
	

	headerForm.lblPrintedBy.caption := null;
	headerForm.lblPrintedBylbl.caption := null;
	//headerForm.initReportForPortrait(); Print_Portrait
	headerForm.initReportForLandscape();
	
	app.printer.setMargins(Print_Landscape,5,5,Margin,Margin);
	app.printer.setHeader(headerForm.frHeader);

	app.printer.suppressDialog := true;
	app.printer.documentType := Print_A4;
	
	now:=app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	footerForm.frFooter.width := app.printer.pageWidth;
	footerForm.lblTheUser.caption := app.getMyUserCode;
	footerForm.lblTheDatePrinted.caption := self.systemToLocalTime(now).asStringJMT;	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	app.printer.setFooter(footerForm.frFooter);
	
	create tmpJadeReport transient;
	tmpJadeReport.description := self.caption;
	app.printer.setReport(tmpJadeReport);

	thePageWidth:= app.printer.pageWidth  ;
	create controlArray transient;
	create clonedControls transient;
	//need a new cloned index start from whats already there + 1
	i := 1;
	newIdx := self.myVoyageStats.allJobSheetStats.size + 1;
	foreach cmifJobSheetStats in self.myVoyageStats.allJobSheetStats discreteLock do
		
		if i  &gt; 1 then
			app.printer.newPage();
		endif;
		
		frmTable:= self.frmStage.getControl(((i).String &amp; self.frmStage.tabIndex.String).Integer).CMUI_Frame;
		controlArray.clear;
		newFrameTable:= frmTable.loadControl(((newIdx).String &amp; self.frmStage.tabIndex.String).Integer).Frame;
		newFrameTable.alignContainer:= Frame.AlignContainer_None;
		clonedControls.add(newFrameTable);
		
		frmTable.cnEcGetAllChildControls(controlArray, true);
		foreach control in controlArray where control.parent = frmTable do
			clonedControl:=control.loadControl(((newIdx).String &amp; control.tabIndex.String).Integer);
			clonedControls.add(clonedControl);
			clonedControl.parent:=newFrameTable;
			
			clonedControl.visible:=true;	
			if clonedControl.isKindOf(Label) then
				clonedControl.Label.caption:= control.Label.caption;
				clonedControl.width:=clonedControl.getTextExtent(clonedControl.Label.caption);
			endif;

		endforeach;
		newFrameTable.width:=thePageWidth;
		newFrameTable.left:=0;
		newFrameTable.refreshNow;
		newFrameTable.transparent:=true;
		app.printer.printActive(newFrameTable); 
		
	
		table:=self.tblStage.getControl(((i).String &amp; self.tblStage.tabIndex.String).Integer).CM_DataTable;
		clonedTable:= table.loadControl(((newIdx).String &amp; self.tblStage.tabIndex.String).Integer).CM_DataTable;
		clonedTable.setMyEntTableDef(table.myEntTableDef);
		self.cloneTable(clonedTable,table,cmifJobSheetStats,true);
		clonedTable.width:=thePageWidth;
		clonedControls.add(clonedTable);
		
		clonedTable.resetHeight();
		app.printer.printActive(clonedTable); 
		newIdx:=newIdx+ 1;
		i:=i + 1;
		
	endforeach;
	
	
	app.printPreview(tmpJadeReport, true);
epilog
	clonedControls.purge;
	delete clonedControls;
	delete controlArray;
	delete headerForm;
	delete footerForm;
end;</source>
    </JadeMethod>
