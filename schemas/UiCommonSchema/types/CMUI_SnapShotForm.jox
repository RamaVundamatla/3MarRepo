    <JadeMethod name="create" id="4ec4aa30-d793-4205-bcbb-0feeb42e981a">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//03 Jan 2019	NDL	TFS 42729
vars

begin

	self.permissionView  := PmAdmSnapShotEditView;
	self.permissionMaint := PmAdmSnapShotEditMaint; // TFS 2198

	self.helpFileName := HelpFile_Voyage;
	self.setCaption("Snap Shots Enquiry"); // TFS 40336
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="10e22d32-2fb1-49fa-a7b5-ef0e84f8e865">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
/*

Purpose:			TFS 40336

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2018	jlgab1	Initial creation

*/

vars
	objs : ObjectSet;
	obj : Object;
	tran : CM_TITransaction;
	snap : CM_SnapShot;
	evtTrans : CM_EventTransaction;
begin
	self.allSnapShots.clear();
	
	if _resultCollection = null then
		return;
	endif;
	
	create objs transient;
	
	_resultCollection.copyNoDups(objs);
	
	foreach obj in objs 	discreteLock do
	//	if not obj.isKindOf(CM_TITransaction) then
	//		continue;
	//	endif;
		
		//22 Feb 2021	NDlTFS 50835
		if obj.isKindOf(CM_TITransaction) then
			tran := obj.CM_TITransaction;
			snap := tran.mySnapShot;
		elseif obj.isKindOf(CM_EventTransaction) then
			evtTrans := obj.CM_EventTransaction;
			snap := evtTrans.mySnapShot;
		else
			continue;
		endif;
		
		if snap &lt;&gt; null then
			self.allSnapShots.add(snap);
		endif;
	endforeach;
	
	self.summaryCode := "ITEMSELECTOR"; // TFS 40336
epilog
	delete objs;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAddCargoItem" id="37dce25a-f0c7-4506-8f68-fc000d3abd09">
        <updating/>
        <source>doAddCargoItem(_operator: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	newSnap,
	pxySnapShot	: CM_TISnapShot;
	changeStr	: String;
	chgReason	: CM_MessageUser;
	theReturn	: Integer;
	inputBox	: CMUI_InputBox;
	bckColour,
	rowIdx		: Integer;
begin

	create inputBox transient;
//	inputBox.init('', app.getErrorString(LBLEnterReasonForAdd), "", 0, TextBox.DataType_AlphaNumeric, true);	// cnwrl1 05/06/2009 PAR 19574 - what it was
	inputBox.init(	'', app.getErrorString(LBLEnterReasonForAdd),
					"", 0, TextBox.DataType_AlphaNumeric, TextBox.Case_None, true, false);
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;

	changeStr := inputBox.txtInput.text;
	create chgReason transient;
	chgReason.setForCreate("Create", changeStr, null, false, null, app.myPassport.myUser.code);
	
	create pxySnapShot transient;
	pxySnapShot.setProxyForSummary(_operator, self.myVoyage, self.is40, self.summaryCode);	
	
	while true do
		app.myTrxCA.trxCreateSnapShotUser(pxySnapShot, newSnap, chgReason, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.mySummaryItem.allSnapShots.add(newSnap);
			rowIdx := self.tblData.addItemObject(newSnap, newSnap.getAttributeStringForDefArray(self.tblData.allTblDataEntRows));
			if not self.isFromItemSelector() then // TFS 40336
				bckColour := newSnap.getDisplayRowColour();
				if bckColour &gt; 0 then
					self.tblData.accessRow(rowIdx).backColor := bckColour;
				endif;
			endif;
			self.armNotesForObject(newSnap);

			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog("Update Snap Shot", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	delete chgReason;
	delete pxySnapShot;
	if inputBox &lt;&gt; null then
		delete inputBox;
	endif;
	
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="doHideCargoItems" id="4c3378cf-c6ba-4230-9097-7ed247c9fe0b">
        <updating/>
        <source>doHideCargoItems() updating;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//  RBarr 14/7/2006 Or show items currently hidden
//----------------------------------------------------------------
vars
	ssSet		: CM_SnapShotSet;
	changeStr	: String;
	chgReason	: CM_MessageUser;
	theReturn	: Integer;
	inputBox	: CMUI_InputBox;
begin

	if self.tblData.allSelectedObjects.isEmpty then
		
		return;
	endif;

	create inputBox transient;
//	inputBox.init('', app.getErrorString(LBLPleaseEnterReasonForChange), "", 0, TextBox.DataType_AlphaNumeric, true);	// cnwrl1 05/06/2009 PAR 19574 - what it was
	inputBox.init(	'', app.getErrorString(LBLPleaseEnterReasonForChange),
					"", 0, TextBox.DataType_AlphaNumeric, TextBox.Case_None, true, false);
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;

	changeStr := inputBox.txtInput.text;
	create chgReason transient;
	chgReason.setForCreate("Update", changeStr, null, false, null, app.myPassport.myUser.code);
	
	create ssSet transient;
	self.tblData.allSelectedObjects.copy(ssSet);
	
	while true do
		app.myTrxUA.trxUpdateSnapShotHide(ssSet, chgReason, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog("Update Snap Shot", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	delete ssSet;
	
	if inputBox &lt;&gt; null then
		delete inputBox;
	endif;
	
end;</source>
    </JadeMethod>
