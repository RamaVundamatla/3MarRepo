<Class name="CM_QStrStevedoreMethod" id="88167934-1520-4dd2-a0e9-a355cab3d6ec">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="52487d30-d6d6-4d83-877b-8c452a7b6739">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	operator : CM_QStringIsOneOf;

begin
	if self.isTransient then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="49631844-a22f-487a-89c8-63fec056c8e5">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars

begin
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbStevedore';
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
