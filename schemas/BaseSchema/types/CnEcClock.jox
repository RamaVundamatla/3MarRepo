    <JadeMethod name="paint" id="14c8b7c5-30e4-4973-96c3-130b90904744">
        <updating/>
        <source>paint(cntrl: BaseControl input) updating;

begin
	if self.isInPainter() then
		self.clearSelf();
		self.buildSelf();
	else
		self.buildSelf();
	endif;
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHour" id="cf5a27dc-9a5a-4a75-8c00-22ae996e12b4">
        <updating/>
        <source>setHour(value : Integer) updating;

begin
	if value.String.length = 2 then
		self.hour := value.String;
	elseif value.String.length = 1 then
		self.hour := "0" &amp; value.String;
	elseif value.String.length = 0 then
		self.hour := "00";
	endif;	
end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMin" id="ea603dd6-be2c-43d3-81b6-904047cf7c2e">
        <updating/>
        <source>setMin(value : Integer) updating;

begin
	if value.String.length = 2 then
		self.min := value.String;
	elseif value.String.length = 1 then
		self.min := "0" &amp; value.String;
	elseif value.String.length = 0 then
		self.min := "00";
	endif;	
end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSec" id="92284308-9a15-4852-aa5a-ce23bf607152">
        <updating/>
        <source>setSec(value : Integer) updating;

begin
	if value.String.length = 2 then
		self.sec := value.String;
	elseif value.String.length = 1 then
		self.sec := "0" &amp; value.String;
	elseif value.String.length = 0 then
		self.sec := "00";
	endif;	
end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTime" id="9df6f513-085c-4341-a9c8-100e9e94a659">
        <updating/>
        <source>setTime(time : Time)updating;

begin
	self.setHour(time.format("HH").Integer);
	self.setMin(time.format("mm").Integer);
	self.setSec(time.format("ss").Integer);
end;</source>
        <Parameter name="time" type="Time"/>
    </JadeMethod>
    <JadeMethod name="setTimeDisplay" id="4ff6480c-d052-4464-9814-61377cc0d92a">
        <updating/>
        <source>setTimeDisplay() updating;

begin
end;</source>
    </JadeMethod>
    <JadeMethod name="setTimer" id="04b632f6-0d65-46b5-ad8d-9b78c0393784">
        <updating/>
        <source>setTimer() updating;

vars
	refreshIntervalSeconds : Integer;
	
begin
	if self.refreshInterval &gt; 0 then
		if not self.isShowSeconds and self.refreshInterval &lt; 60 then
			self.refreshInterval := 60;
		endif;
		
		refreshIntervalSeconds := self.refreshInterval * 1000;
		beginTimer(refreshIntervalSeconds, Timer_OneShot, self.REFRESH_TIME);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="1e9192d6-d84b-4373-9bd9-fc38ece3889a">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

vars
	time : Time;
	
begin
	if eventTag = self.REFRESH_TIME then
		self.setTime(time);
		self.setTimeDisplay();
		self.displayTime();
	endif;		
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
