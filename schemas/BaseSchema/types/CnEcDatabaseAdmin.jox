    <JadeMethod name="backupAllDatabaseFiles" id="7b365338-9138-4cdb-b5f5-c03359c0208a">
        <updating/>
        <source>backupAllDatabaseFiles() updating;
// --------------------------------------------------------------------------------
// Created:		21 July 2001 by cnwdad1
//
// Purpose:		Backup all database files.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	BACKUP_ERROR			: String = "Database Backup Failed";
	BACKUP_COMPLETE			: String = "Database Backup Complete";

vars
	jadeDatabaseAdminObj	: JadeDatabaseAdmin;
	allDroppedFiles			: DbFileArray;
	dbFileObj				: DbFile;
	messageTitle			: String;
	taskMessage				: String;
	isArchivalRecovery		: Boolean;

begin
	create jadeDatabaseAdminObj transient;
	jadeDatabaseAdminObj.enableProgressEvents(1);
	create allDroppedFiles transient;

	if global.cnEcIsValidServerDirectory(self.backupDirectory) then
		jadeDatabaseAdminObj.backupAllDbFiles(	self.backupDirectory,
												self.isIncludeSystemFiles,
												self.isVerifyFiles,
												self.isCompressFiles,
												self.isOverwriteFiles,
												self.isQuiesce,
												allDroppedFiles);
		
		// If we're performing a hot backup, then we should also backup all log
		// files since the last backup.

		isArchivalRecovery	:=	app.getProfileString(app.getIniFileName(),
													"PersistentDb",
													"EnableArchivalRecovery",
													"false").Boolean;
		
		if (not self.isQuiesce) and isArchivalRecovery then
			self.backupAllLogFiles(jadeDatabaseAdminObj);
		endif;
		
		// The database backup completed without exceptions.
		
		messageTitle	:=	BACKUP_COMPLETE;
		taskMessage		:=	"Database files backed up.";
	else
		messageTitle	:=	BACKUP_ERROR;
		taskMessage		:=	"The Backup Directory (" &amp; backupDirectory &amp; ") is not available.";
	endif;
epilog
	if process.isInExceptionState then
		// A fatal exception has occurred during the backup, the activated
		// exception handler aborted the current action - report the failure.
		messageTitle	:=	BACKUP_ERROR;
	endif;

	// Report missing files (a missing file is only valid if it has never been created).

	if (allDroppedFiles.cnEcIsNotEmpty()) then
		taskMessage	:=	taskMessage &amp; CrLf &amp; CrLf &amp; "The following files were not backed up :" &amp; CrLf;
		
		foreach dbFileObj in allDroppedFiles do
			taskMessage	:=	taskMessage &amp; dbFileObj.name &amp; ".dat" &amp; CrLf;
		endforeach;
	endif;

	delete jadeDatabaseAdminObj;
	delete allDroppedFiles;

	self.cnEcLog(messageTitle &amp; ": " &amp; taskMessage);
end;</source>
    </JadeMethod>
    <JadeMethod name="backupAllLogFiles" id="aa73b5c4-f429-418f-b89a-b193515b4302">
        <updating/>
        <source>backupAllLogFiles(pJadeDatabaseAdminObj:JadeDatabaseAdmin) updating;
// --------------------------------------------------------------------------------
// Created:		21 July 2001 by cnwdad1
//
// Purpose:		Backup all audit log files.
//
// Parameters:	pJadeDatabaseAdminObj - The JADE DB Admin object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	logDirectory			: String;
	startingLog				: Integer;
	currentLog				: Integer;
	logIndex				: Integer;
	
begin
	startingLog		:=	app.myBaseRoot.lastBackedUpLog;
	
	if startingLog &lt; 0 then
		startingLog	:=	1;
	endif;

	logDirectory	:=	pJadeDatabaseAdminObj.getCurrentLogDirectory();
	currentLog		:=	pJadeDatabaseAdminObj.getCurrentLogNumber();

	pJadeDatabaseAdminObj.closeCurrentJournal();		// Switch to a new log file to release the current one.
	
	foreach logIndex in startingLog to currentLog do
		pJadeDatabaseAdminObj.backupLog(logIndex,
										logDirectory,
										self.backupDirectory,
										self.isVerifyFiles,
										self.isCompressFiles,
										self.isOverwriteFiles);
	endforeach;
	
	self.updateLastLogFileNumber(currentLog);
end;</source>
        <Parameter name="pJadeDatabaseAdminObj" type="JadeDatabaseAdmin"/>
    </JadeMethod>
    <JadeMethod name="create" id="89c06865-f3d5-4fd7-a5e6-c1833be94753">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		21 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myBaseRoot	:=	CnEcBaseRoot.firstInstance();
	
	self.backupDirectory	:=	app.getProfileString(app.getIniFileName(),
													CNEC_INI_SECTION_BASESCHEMA,
													CNEC_INI_BACKUP_DIRECTORY,
													CNEC_INI_DEFAULT_BACKUP_DIR);
end;</source>
    </JadeMethod>
    <JadeMethod name="setBackupDirectory" id="4d66f5cc-e2b2-49dc-93dc-2cb78abfee58">
        <updating/>
        <source>setBackupDirectory(pDirectoryName:String) updating;
// -----------------------------------------------------------------------------
// Created:		12 November 2001 by cnwdad1
//
// Purpose:		Set the name of the backup directory.
//
// Parameters:	pDirectoryName - The directory name.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.backupDirectory	:=	pDirectoryName;
end;</source>
        <Parameter name="pDirectoryName" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateLastLogFileNumber" id="eeb1bf2e-4291-40af-9a50-3f7b677e6c55">
        <updating/>
        <source>updateLastLogFileNumber(pLogNumber:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 July 2001 by cnwdad1
//
// Purpose:		Set the log number of the last known audit log file.
//
// Parameters:	pLogNumber - The log file number.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	
begin
	errorMessage	:=	app.myBaseAgent.trxBaseRootLastLogUpdate(app.myBaseRoot, 0, pLogNumber);
	
	if errorMessage &lt;&gt; null then
		self.cnEcLog("Backup Error: " &amp; errorMessage);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pLogNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="c5bfd549-8d12-4736-9470-6d39740ba955">
        <updating/>
        <source>updateMe(	pBackupDirectory:String;
			pIsIncludeSystemFiles:Boolean;
			pIsVerifyFiles:Boolean;
			pIsCompressFiles:Boolean;
			pIsOverwriteFiles:Boolean;
			pIsQuiesce:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		21 July 2001 by cnwdad1
//
// Purpose:		Update the rceiver's property values.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.backupDirectory &lt;&gt; pBackupDirectory then
		self.backupDirectory		:=	pBackupDirectory;
	endif;
	
	if self.isIncludeSystemFiles &lt;&gt; pIsIncludeSystemFiles then
		self.isIncludeSystemFiles	:=	pIsIncludeSystemFiles;
	endif;
	
	if self.isVerifyFiles &lt;&gt; pIsVerifyFiles then
		self.isVerifyFiles			:=	pIsVerifyFiles;
	endif;
	
	if self.isCompressFiles &lt;&gt; pIsCompressFiles then
		self.isCompressFiles		:=	pIsCompressFiles;
	endif;
	
	if self.isOverwriteFiles &lt;&gt; pIsOverwriteFiles then
		self.isOverwriteFiles		:=	pIsOverwriteFiles;
	endif;
	
	if self.isQuiesce &lt;&gt; pIsQuiesce then
		self.isQuiesce				:=	pIsQuiesce;
	endif;
end;</source>
        <Parameter name="pBackupDirectory" type="String"/>
        <Parameter name="pIsIncludeSystemFiles" type="Boolean"/>
        <Parameter name="pIsVerifyFiles" type="Boolean"/>
        <Parameter name="pIsCompressFiles" type="Boolean"/>
        <Parameter name="pIsOverwriteFiles" type="Boolean"/>
        <Parameter name="pIsQuiesce" type="Boolean"/>
    </JadeMethod>
</Class>
