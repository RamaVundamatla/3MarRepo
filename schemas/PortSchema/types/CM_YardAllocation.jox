    <JadeMethod name="getCriteriaNotIncluded" id="386ad1b9-f26a-4cf3-9084-a582f0e60ad4">
        <source>getCriteriaNotIncluded( _coll : CM_YACriteriaTypeArray; _excludeTrxTypes : IntegerArray ) : CM_YACriteriaType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/12/2017	jlgndl1	Initial creation	TFS 8095
02/12/2019	jlgdap1	TFS 47755 STWO JMT ignores full/empty on transaction when resynchronising
*/

vars

	yaCrit : CM_YACriteria;

begin

	foreach yaCrit in self.allCriteria do
		if _excludeTrxTypes.includes( yaCrit.myYACriteriaType.type ) then
			continue;
		endif;
		// TFS 47755 ignore boolean ya types where the option is set to "N/A"
		if yaCrit.myYACriteriaType.isBooleanType 
		and yaCrit.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_EITHER then
			continue;
		endif;
		// TFS 47755 end
		if not _coll.includes(yaCrit.myYACriteriaType) then
			return yaCrit.myYACriteriaType;
		endif;
	endforeach;

	return null;

epilog

end;</source>
        <Parameter name="_coll" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_excludeTrxTypes" type="IntegerArray"/>
        <ReturnType type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaOfType" id="1d688a9e-efed-4c06-9e06-710b024f9706">
        <source>getCriteriaOfType(_criteriaType: CM_YACriteriaType): CM_YACriteria;

/*

Purpose:		Get criteria for given type

Parameters:			

Return Value:		


Date			Who		Reason
18 August 2008	consw1	SFW1030 - Promoted method from sub-class CM_RailAllocation

*/

vars
	criteria		: CM_YACriteria;
begin
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType = _criteriaType then
			return criteria;
		endif;
	endforeach;

	return null;
end;</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaOfTypeValue" id="c116e68d-3ddd-4cde-a1d1-201cc66d3f22">
        <source>getCriteriaOfTypeValue( _typeValue : Integer ) : CM_YACriteria;

/*

Purpose:		Get criteria for with given type value.

Parameters:		Type value.  e.g. YACriteriaType_ImexStatus

Return Value:		


Date			Who		Reason
19 August 2008	consw1	Initial creation

*/

vars
	criteria : CM_YACriteria;
	
begin

	return self.allCriteriaByType[_typeValue]; // AKB2010MAY
	
/*	
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = _typeValue then
			return criteria;
		endif;
	endforeach;

	return null;
	*/
end;</source>
        <Parameter name="_typeValue" type="Integer"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaString" id="be6f3912-a455-46e6-8b06-e7e3ed9acc9a">
        <source>getCriteriaString() : String;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	returnValue	: String;
	yacObj		: CM_YACriteria;
	
begin
	on Exception do self.xInvalidObjectDisplayHandler(exception);
	
	foreach yacObj in self.allCriteria do
		if returnValue = null then
//			returnValue	:=	yacObj.code &amp; " - " &amp; yacObj.myYACriteriaType.getDataDisplay(yacObj.myYAData);
			returnValue	:=	yacObj.getListDisplay();
		else
//			returnValue	:=	returnValue &amp; Cr &amp; yacObj.code &amp; " - " &amp; yacObj.myYACriteriaType.getDataDisplay(yacObj.myYAData);
			returnValue	:=	returnValue &amp; Cr &amp; yacObj.getListDisplay();
		endif;
	endforeach;
	
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionWithLocations" id="fa809e02-0d1d-4893-aa67-fa11bb987649">
        <source>getDescriptionWithLocations(_includeCode : Boolean) : String;
//
// cnwrs1 jan 2008 supply a summary description of the allocation and the locations it covers
//                 the locations are difficult to supply a from to location as it may not be contiguise 
//                 so we supply the first location and the last location and ignore the gap controllers 
//					eg CHIL EXPS 40' (A 2703 to 3110)
vars
	str : String;
	yc : CM_YardController;
	firstYCId, lastYCId : String;
	ta : CM_TerminalArea;
begin
	firstYCId := null;
	lastYCId := null;
	if _includeCode then // PAR 19484
		if str = null then
			str := self.code;
		else
			str := str &amp; CrLf &amp;self.code;
		endif;
	endif;
	
	foreach ta in self.allTerminalAreas discreteLock do// PAR 19484
		firstYCId := null;// PAR 19484
		lastYCId := null;// PAR 19484
		
		foreach yc in self.allYardControllers reversed, discreteLock where yc.myTerminalArea  = ta do //par 15561 Jan 2008
			if yc.isKindOf(CM_GapController) then
				continue;
			endif;
			if firstYCId = null then
				firstYCId := yc.terminalAreaId&amp;' '&amp;yc.ident; // first location id in list
			endif;
			lastYCId := yc.ident; // last location id in list
		endforeach;

		if firstYCId &lt;&gt; null or lastYCId &lt;&gt; null then
			if str = null then
				str := firstYCId &amp; ' to ' &amp; lastYCId;
			else
				str := str &amp; ", " &amp; firstYCId &amp; ' to ' &amp; lastYCId;
			endif;
		endif;
		
	endforeach;
	return str;
end;
</source>
        <Parameter name="_includeCode" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayForInUseValidation" id="cf26df61-fcc5-4eeb-a20f-a5d6be855cb0">
        <source>getDisplayForInUseValidation():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2012	cnwndl1	Initial creation	Par 30767

*/

vars

	tempStr : String;

begin

	if self.myTerminal &lt;&gt; null then
		tempStr :=	app.getString( Terminal ) &amp; Space &amp; self.myTerminal.code &amp; ' / ';
	endif;

	
	tempStr :=	tempStr &amp; self.code &amp; " [" &amp; app.getErrorString(YardAllocation) &amp; "]";
	

epilog

	return tempStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayForYAMTableColumn" id="95102f3e-83ca-408a-8304-10ee4c9ab61a">
