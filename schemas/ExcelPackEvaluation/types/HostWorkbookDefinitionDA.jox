<Class name="HostWorkbookDefinitionDA" id="1117bdb9-bf08-4f43-8b0d-3335e3046fc0">
    <superclass name="HostWorkbookInterface"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ImplicitInverseRef name="myTransientExtractOptions" id="ed278ff0-f74a-4ad7-b731-501eff4f54c6">
        <embedded/>
        <type name="WorkbookExtractOptions"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myXLWorkbookDefinitionDA" id="f4faaaae-b888-4da1-82b8-40b4487da27d">
        <embedded/>
        <type name="ExcelInterfacePackage::ExcelWorkbookDefinitionDA"/>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="84c9ad01-bdc5-42f4-ba59-c3846bf0b835">
        <updating/>
        <source>create() updating;

vars

begin
	app.writeStatement( method.qualifiedName);
	create self.myXLWorkbookDefinitionDA transient;
		
	self.myXLWorkbookDefinitionDA.setMyControllingAppsDA(self);
	self.myXLWorkbookDefinitionDA.setMyControllingAppsContext(appContext);
		
	self.myXLWorkbookDefinitionDA.setMyControllingAppsTargMethod(HostWorkbookDefinitionDA::xlFinished);
	self.myXLWorkbookDefinitionDA.setMyControllingAppsWiz2Method(HostWorkbookDefinitionDA::xlShowExtractOptionsForm);
	self.myXLWorkbookDefinitionDA.setMyControllingAppsStoreMeth(HostWorkbookDefinitionDA::xlGetDataExtractOptionsToSave);
	self.myXLWorkbookDefinitionDA.setMyControllingAppsCancelMeth(HostWorkbookDefinitionDA::xlWorkbookDefinitionCancel);
	self.myXLWorkbookDefinitionDA.setMyControllingAppsDataMethod(HostWorkbookDefinitionDA::xlGetTestData);
	self.myXLWorkbookDefinitionDA.setMyControllingAppsShowMethod(HostWorkbookDefinitionDA::xlShowForm);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMaintainAllWorkbooks" id="2d91ae32-84ab-4ebf-991c-f248150fdfb9">
        <source>doMaintainAllWorkbooks();

vars
	

begin
	self.myXLWorkbookDefinitionDA.doMaintainWorkbook();
end;</source>
    </JadeMethod>
    <JadeMethod name="doMaintainSpecificWorkbooks" id="1b5fc05e-5013-4885-85f4-211b62d69cf7">
        <source>doMaintainSpecificWorkbooks(reportName, reportType : String; reportObject : Object);

vars
	
	
begin 
	self.myXLWorkbookDefinitionDA.setAssociatedObjectName(reportName);
	self.myXLWorkbookDefinitionDA.setAssociatedObjectType(reportType);
	self.myXLWorkbookDefinitionDA.setMyAssociatedObject(reportObject);
		
	self.myXLWorkbookDefinitionDA.doMaintainWorkbook();
end;</source>
        <Parameter name="reportName" type="String"/>
        <Parameter name="reportType" type="String"/>
        <Parameter name="reportObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="xlFinished" id="d39f3937-829c-48d5-b73f-cf4a1333321f">
        <updating/>
        <source>xlFinished(pNull : String) updating;

vars

begin
	app.writeStatement( method.qualifiedName);
	delete self;
end;</source>
        <Parameter name="pNull" type="String"/>
    </JadeMethod>
    <JadeMethod name="xlGetDataExtractOptionsToSave" id="2d308f0d-1294-476e-9f82-f61a1269d0f3">
        <updating/>
        <source>xlGetDataExtractOptionsToSave(pExtractOptions : Object; isSaving : Boolean) : Object updating;

vars
	extractOptions : WorkbookExtractOptions;

begin
	extractOptions := pExtractOptions.WorkbookExtractOptions;
	
	if isSaving then
		if extractOptions = null then
			create extractOptions persistent;
		endif;
	
//		extractOptions.minPrice := self.myTransientExtractOptions.minPrice;
		delete self.myTransientExtractOptions;
	endif;
	
	return extractOptions;
end;</source>
        <Parameter name="pExtractOptions" type="Object"/>
        <Parameter name="isSaving" type="Boolean"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="xlGetTestData" id="cc37f200-9a0e-45e9-b574-7d4a0a4e59f9">
        <source>xlGetTestData(hsa: ExcelHugeStringArray io; excelExtOption: WorkbookExtractOptions; associatedObjType: String; associatedObjName: String; associatedObj: Object; testMode: Boolean);

vars

begin
	xlGetData(hsa, excelExtOption, associatedObjType, associatedObjName, associatedObj);
end;</source>
        <Parameter name="hsa" type="ExcelInterfacePackage::ExcelHugeStringArray" usage="io"/>
        <Parameter name="excelExtOption" type="WorkbookExtractOptions"/>
        <Parameter name="associatedObjType" type="String"/>
        <Parameter name="associatedObjName" type="String"/>
        <Parameter name="associatedObj" type="Object"/>
        <Parameter name="testMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xlShowExtractOptionsForm" id="796c3ab1-6758-4acb-934b-00fe209e38ce">
        <updating/>
        <source>xlShowExtractOptionsForm(pAssocObjType : String; pAssocObjName : String; pAssocObj : Object; pWBExtractOptions : Object) updating;

vars
	form : HostExtractOptionsEditForm;

begin
	app.writeStatement( method.qualifiedName);

	if self.myTransientExtractOptions = null then
		create self.myTransientExtractOptions transient;
		if pWBExtractOptions &lt;&gt; null then
//			self.myTransientExtractOptions.minPrice := pWBExtractOptions.HostExtractOptions.minPrice;
		else
//			self.myTransientExtractOptions.minPrice := 0;
		endif;
	endif;
	
	create form transient;
	form.myExcelWorkbookDefinitionDA := self.myXLWorkbookDefinitionDA;
	form.assocName := pAssocObjName;
	form.assocType := pAssocObjType;
	
	form.myWorkbookDefinitionDA := self;
	
	form.show();

end;</source>
        <Parameter name="pAssocObjType" type="String"/>
        <Parameter name="pAssocObjName" type="String"/>
        <Parameter name="pAssocObj" type="Object"/>
        <Parameter name="pWBExtractOptions" type="Object"/>
    </JadeMethod>
    <JadeMethod name="xlWorkbookDefinitionCancel" id="90107ee0-f579-4141-ab9e-dbcb314dc9ce">
        <updating/>
        <source>xlWorkbookDefinitionCancel(pNull : String) updating;

vars

begin
	app.writeStatement( method.qualifiedName);
	delete self.myTransientExtractOptions;
end;</source>
        <Parameter name="pNull" type="String"/>
    </JadeMethod>
</Class>
