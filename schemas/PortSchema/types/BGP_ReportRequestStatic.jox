vars

begin
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="d65a6186-fa2c-4987-91ee-4a2830cff059">
        <updating/>
        <source>setForProxy(_filter			: CMQF_FilterReports;
			_profileName		: String; 
			_destination		: Integer;
			_extraDetail		: CM_ExtraDetail;
			_printerName		: String;
			_outputType		: Integer) updating;

// cnwdvb1 12 December 2002 

vars

begin
//return self.myMenuUserReport.name.trimBlanks();

	self.myExtraDetail := _extraDetail;
	self.myFilter := _filter;

	if self.myFilter &lt;&gt; null then
		self.myFilter.jrwProfileName := _profileName;
	endif;
	// Don't need report def here. Using report template inverse.
//	self.myReportDef		:= _reportDef;
	self.outputType			:= _outputType;
	self.outputDestination	:= _destination;
	self.printerName		:= _printerName;
	

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_profileName" type="String"/>
        <Parameter name="_destination" type="Integer"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_outputType" type="Integer"/>
    </JadeMethod>
