    <JadeMethod name="translateForm" id="a62d6ffd-da07-49ab-85a2-4ca1a3f1f8b2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 15:45:21.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022919, locale);
	btnAlloc.translateBubbleHelp(Xlat_0003014, locale);
	btnAlloc.translateCaption(Xlat_0003023, locale);
	btnCancelFrm.translateCaption(Xlat_0006631, locale);
	btnCraneShifts.translateBubbleHelp(Xlat_0021868, locale);
	btnCraneShifts.translateCaption(Xlat_0021869, locale);
	btnHideHatchJobs.translateBubbleHelp(Xlat_0006633, locale);
	btnHideHatchJobs.translateCaption(Xlat_0006634, locale);
	btnJobTimes.translateBubbleHelp(Xlat_0003015, locale);
	btnJobTimes.translateCaption(Xlat_0003024, locale);
	btnLashInfo.translateCaption(Xlat_0003025, locale);
	btnOOWConfirm.translateBubbleHelp(Xlat_0022274, locale);
	btnOOWConfirm.translateCaption(Xlat_0022275, locale);
	btnOOWCreation.translateBubbleHelp(Xlat_0018526, locale);
	btnOOWCreation.translateCaption(Xlat_0018527, locale);
	btnOOWMonitor.translateBubbleHelp(Xlat_0021950, locale);
	btnOOWMonitor.translateCaption(Xlat_0021951, locale);
	btnOStowCheck.translateBubbleHelp(Xlat_0006635, locale);
	btnOStowCheck.translateCaption(Xlat_0006636, locale);
	btnPlanGuide.translateBubbleHelp(Xlat_0018528, locale);
	btnPlanGuide.translateCaption(Xlat_0018529, locale);
	btnPrnFrame.translateCaption(Xlat_0006637, locale);
	btnRemarks.translateBubbleHelp(Xlat_0016709, locale);
	btnRemarks.translateCaption(Xlat_0016710, locale);
	btnTBEdit.translateBubbleHelp(Xlat_0003016, locale);
	btnTBEdit.translateCaption(Xlat_0003026, locale);
	btnTBLoadToOps.translateBubbleHelp(Xlat_0003001, locale);
	btnTBLoadToOps.translateCaption(Xlat_0003002, locale);
	btnTBMoveDown.translateBubbleHelp(Xlat_0003006, locale);
	btnTBMoveDown.translateCaption(Xlat_0003009, locale);
	btnTBMoveUp.translateBubbleHelp(Xlat_0003017, locale);
	btnTBMoveUp.translateCaption(Xlat_0003027, locale);
	btnTBNew.translateBubbleHelp(Xlat_0003018, locale);
	btnTBNew.translateCaption(Xlat_0003028, locale);
	btnTBPosition.translateBubbleHelp(Xlat_0003007, locale);
	btnTBPosition.translateCaption(Xlat_0003010, locale);
	btnTBRenumber.translateBubbleHelp(Xlat_0003008, locale);
	btnTBRenumber.translateCaption(Xlat_0003011, locale);
	chkHideHatchJob.translateCaption(Xlat_0006638, locale);
	chkPrnLidComment.translateCaption(Xlat_0006639, locale);
	lblLoadingJobs.translateCaption(Xlat_0003003, locale);
