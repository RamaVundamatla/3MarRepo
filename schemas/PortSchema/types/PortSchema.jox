    <JadeMethod name="cmsAbortTransaction" id="0d642337-f2ab-4406-aa1e-ca7fe4e52f54">
        <updating/>
        <source>cmsAbortTransaction() updating;
begin
	abortTransaction;
	self.commitAlert();
	self.beginLoadCount := 0;
end;</source>
