    <JadeMethod name="addDiscrepancy" id="0e5b0c7a-ee1a-4e69-ad5d-94faa41200f3">
        <source>addDiscrepancy(_trackedItem: CM_TrackedItem io; _newQuantity: Integer);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Nov 2013	cnwdw1	Initial creation
17 May 2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
*/
vars

	totalWeight				: Decimal[14,4];
	cargoWeight : Decimal[14,4];
	tareWeight : Decimal[14,4];

begin

	// 10/06/2016 cnwmh5
	totalWeight := _trackedItem.totalWeight;
	if self.opts.includesKey("Weight") then
		totalWeight := self.opts.dec("Weight");
	endif;

	app.myTrxUA.trxBreakBulkOverage(_trackedItem, self.class.name, _newQuantity, totalWeight, cargoWeight, tareWeight, self.opts.str("Reason"), false, false, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
			
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_newQuantity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addDutyDoc" id="b801ac2a-0751-4594-9634-904dfdc86092">
        <source>addDutyDoc(_ticket: String; _type: String; _status: Integer; _consignee: String; _freightForwarder: String; _voyage: CM_Voyage; _dutyDeposit: Decimal) : CM_DutyDoc;
/*
10 January 2013	cnwdw1	Initial creation
*/
vars
	pxyDutyDoc, dutyDoc: CM_DutyDoc;
begin

	self.deleteDutyDoc(_ticket);
	
	create pxyDutyDoc transient;
	
	pxyDutyDoc.setProxy(app.myDutyDocRoot.allDutyDocTerminalRoots[self.getTerminal],
						_ticket,
						_type,
						null,
						self.getFreightForwarder(_freightForwarder),
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						"CIF",
						null,
						_status,
						_dutyDeposit,
						null,
						null,
						null,
						null,
						null,
						_voyage,
						self.getConsignee(_consignee),
						null,
						null
						);
	app.myTrxCA.trxCreateDutyDoc(pxyDutyDoc, dutyDoc, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return dutyDoc;	
epilog
	delete pxyDutyDoc;
	

end;</source>
