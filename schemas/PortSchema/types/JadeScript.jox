    <JadeMethod name="createYATypes" id="30267d74-0181-4227-82d4-627bb80f0701">
        <source>createYATypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2024	chandla	Initial creation
22 Jan 2025	navhn30  Story MTN-33826: CUX | MAFI Fields Missing from Yard Allocations - Jade changes and testing

*/

vars
	proxyObj					: CM_YACriteriaType;
	receiveCarrierObj			: CM_YATypeReceiveCarrier;
	onboardDamagedObj			: CM_YATypeOnboardDamaged;
	onboardIsHazardousObj		: CM_YATypeOnboardIsHazardous;
	onboardHazardoussObj		: CM_YATypeOnboardHazardous;
	onboardIsReeferObj			: CM_YATypeOnboardIsReefer;
	onboardFreightForwardObj	: CM_YATypeOnboardFreightFwdr;
	onboardStopsObj				: CM_YATypeOnboardStops;
	onboardCommodityObj			: CM_YATypeOnboardCommodity;
	onboardContentsStatusObj	: CM_YATypeOnboardContentsStatus;
	onboardISOTypeObj			: CM_YATypeOnboardISOType;
	
	
	
begin
beginTransaction;

	app.initialize();
	if CM_YATypeReceiveCarrier.instances.isEmpty() then									//02.04.2024 navlc30 #56071
		create proxyObj as CM_YATypeReceiveCarrier transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_ReceiveCarrier);
		create receiveCarrierObj;
		receiveCarrierObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	// 22.01.25	  navhn30	MTN-33826	start
	if CM_YATypeOnboardDamaged.instances.isEmpty then
		create proxyObj as CM_YATypeOnboardDamaged transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_OBIsDamaged);
		create onboardDamagedObj as CM_YATypeOnboardDamaged;
		onboardDamagedObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	if CM_YATypeOnboardIsHazardous.instances.isEmpty then 
		create proxyObj as CM_YATypeOnboardIsHazardous transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_OBIsHazardous);
		create onboardIsHazardousObj as CM_YATypeOnboardIsHazardous;
		onboardIsHazardousObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;

	if CM_YATypeOnboardHazardous.instances.isEmpty then
		create proxyObj as CM_YATypeOnboardHazardous transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_OBHazards);
		create onboardHazardoussObj as CM_YATypeOnboardHazardous;
		onboardHazardoussObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	if CM_YATypeOnboardIsReefer.instances.isEmpty then 
		create proxyObj as CM_YATypeOnboardIsReefer transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_OBIsReefer);
		create onboardIsReeferObj as CM_YATypeOnboardIsReefer;
		onboardIsReeferObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	if CM_YATypeOnboardFreightFwdr.instances.isEmpty then 
		create proxyObj as CM_YATypeOnboardFreightFwdr transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_OBFreightFwd);
		create onboardFreightForwardObj as CM_YATypeOnboardFreightFwdr;
		onboardFreightForwardObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	if CM_YATypeOnboardStops.instances.isEmpty then 
		create proxyObj as CM_YATypeOnboardStops transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_OBStops);
		create onboardStopsObj as CM_YATypeOnboardStops;
		onboardStopsObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;

	if CM_YATypeOnboardCommodity.instances.isEmpty then
		create proxyObj as CM_YATypeOnboardCommodity transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_OBCommodity);
		create onboardCommodityObj as CM_YATypeOnboardCommodity;
		onboardCommodityObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	if CM_YATypeOnboardContentsStatus.instances.isEmpty then 
		create proxyObj as CM_YATypeOnboardContentsStatus transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_OBContStatus);
		create onboardContentsStatusObj as CM_YATypeOnboardContentsStatus;
		onboardContentsStatusObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	if CM_YATypeOnboardISOType.instances.isEmpty then 
		create proxyObj as CM_YATypeOnboardISOType transient;
		proxyObj.setProxy(proxyObj.getTypeName,true,YACriteriaType_OBISOType);
		create onboardISOTypeObj as CM_YATypeOnboardISOType;
		onboardISOTypeObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	// 22.01.25	  navhn30	MTN-33826 end
	
commitTransaction;

epilog

	
end;	</source>
    </JadeMethod>
