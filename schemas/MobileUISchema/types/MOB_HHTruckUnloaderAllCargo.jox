    <JadeMethod name="isCargoUnloaded" id="b68efacb-084f-47e5-81d3-6efb47ccc612">
        <source>isCargoUnloaded(_trackedItem : CM_TrackedItem; _receival : CMGTE_Receival) : Boolean;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 13 May 2019
TFS#		: 43259
Function	: Check if the Cargo is fully unloaded in the Vehicle.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	trackedItem : CM_TrackedItem;
begin
	if _receival &lt;&gt; null then
		if _receival.myVehicleVisitRecord &lt;&gt; null then
			if _receival.myVehicleVisitRecord.myRoadJob &lt;&gt; null then
				if _receival.myVehicleVisitRecord.myRoadJob.myVehicle &lt;&gt; null then
					if _receival.myVehicleVisitRecord.myRoadJob.myVehicle.locationsController &lt;&gt; null then
						if _receival.myVehicleVisitRecord.myRoadJob.myVehicle.locationsController.allTrackedItems &lt;&gt; null then
							foreach trackedItem in _receival.myVehicleVisitRecord.myRoadJob.myVehicle.locationsController.allTrackedItems do
								if trackedItem.id = _trackedItem.id then
									return false;
								endif;
							endforeach;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	return true;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_receival" type="CMGTE_Receival"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
