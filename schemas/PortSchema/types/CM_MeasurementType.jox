    <JadeMethod name="removeDecimalZeros" id="263b9470-e2d9-42d3-9438-2e9fb3b2bedc">
        <source>removeDecimalZeros(_value : String) : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	pos 	: Integer;
	dec 	: Integer;
	decSep 	: String;

begin
	decSep  := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	dec 	:= self.getDecimalPrecision;
	pos		:= _value.pos(decSep, 1);
	// no decimal separator found - just return supplied value
	if pos = null then
		return _value;
	endif;
	// this measure has no decimal places - remove all trailing zeros and the decimal place
	if dec = null then
		return _value[1:pos-1];
	endif;
	// remove any trailing zeros more than the decimal precision allowed
	if _value.length &gt; pos+dec then
		return _value[1:pos+dec];
	else
		return _value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ed88de0d-2a88-4f8e-8f21-8943883c5242">
        <updating/>
        <source>setForCreate(_pxyMeasure : SelfType) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
22/08/2014	cnwdap1	PAR #33235 Update query definition properties for new measurement type
*/
vars

begin
	self.setForUpdate(_pxyMeasure);
	self.myRoot := app.myRoot;
	
	self.updateQueryDefinitions(self.isDisplay and self.isAvailableForEntry, false, false, null);	// PAR #33235
epilog

end;</source>
        <Parameter name="_pxyMeasure" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="21821db9-9ad8-41f8-af36-245e6586e86b">
        <updating/>
        <source>setForUpdate(_pxyMeasure : SelfType) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
22/08/2014	cnwdap1	PAR #33235 Update query definitions for this measurement type if required
25/09/2022	navkc1	Bug 54961: PRP - Error 1310 when creating new measurement types
31/10/2022	navmd1	TFS 55266 Only try and set the previous measurement types default flag to false if it actually exists
14/11/2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type

*/
vars
	measure	 		: CM_MeasurementType;
	oldCode			: String;							// PAR #33235
	wasDisplayed,	 									// PAR #33235
	wasAvailable,										// PAR #33235
	nowDisplayed,										// PAR #33235
	nowAvailable	: Boolean;							// PAR #33235
	cargotype		: CM_CargoType;						// TFS#52718
	systemSubType 	: CM_Product;						// TFS#52718
	prodAttr 		: CM_ProductAttr;					// TFS#52718
begin
	// reset isDefault on any other measurements if I've been set to default
	//if self.myRoot &lt;&gt; null and not self.isDefault and _pxyMeasure.isDefault then	// navkc1	28/09/2022	#54961
	if not self.isDefault and _pxyMeasure.isDefault then							// navkc1	28/09/2022	#54961
		//measure := app.getDefaultMeasurementForType(self.measurementType); 		// navkc1	28/09/2022	#54961
		measure := app.getDefaultMeasurementForType(_pxyMeasure.measurementType);	// navkc1	28/09/2022	#54961
		if measure &lt;&gt; null then
			measure.setIsDefaultToFalse();
		endif;
		
		//navsp1 28MAR22 TFS#52718 - START
		// fix up system product type measurement types
		foreach cargotype in app.myRoot.allCargoTypesById do
			if cargotype.mySystemProductType &lt;&gt; null then
				systemSubType := cargotype.mySystemProductType;
				// decide which references to update
				if self.isWeight then
					if systemSubType.getMyWeight &lt;&gt; null 
					and systemSubType.getMyWeight.myMeasurementType &lt;&gt; self then
						prodAttr := systemSubType.getMyWeight;
						prodAttr.setMyMeasurementType(self);
					endif;
				elseif self.isVolume then
					if systemSubType.getMyVolume &lt;&gt; null
					and systemSubType.getMyVolume.myMeasurementType &lt;&gt; self then
						prodAttr := systemSubType.getMyVolume();
						prodAttr.setMyMeasurementType(self);
					endif;						
				elseif self.isDensity then
					if systemSubType.getMyDensity &lt;&gt; null 
					and systemSubType.getMyDensity.myMeasurementType &lt;&gt; self then
						prodAttr := systemSubType.getMyDensity();
						prodAttr.setMyMeasurementType(self);
						endif;				
				elseif self.isLinear then					
					if systemSubType.getMyHeight &lt;&gt; null
					and systemSubType.getMyHeight.myMeasurementType &lt;&gt; self then
						prodAttr := systemSubType.getMyHeight();
						prodAttr.setMyMeasurementType(self);
					endif;
					if systemSubType.getMyWidth &lt;&gt; null
					and systemSubType.getMyWidth.myMeasurementType &lt;&gt; self then
						prodAttr := systemSubType.getMyWidth();
						prodAttr.setMyMeasurementType(self);
					endif;
					if systemSubType.getMyLength &lt;&gt; null
					and systemSubType.getMyLength.myMeasurementType &lt;&gt; self then
						prodAttr := systemSubType.getMyLength();
						prodAttr.setMyMeasurementType(self);
					endif;
				elseif self.isStowageFactor then					
					if systemSubType.getMyStowageFactor() &lt;&gt; null
					and systemSubType.getMyStowageFactor.myMeasurementType &lt;&gt; self then
						prodAttr := systemSubType.getMyStowageFactor();
						prodAttr.setMyMeasurementType(self);
					endif;					
				endif;
				//Note : Not found any displacement reference to update				
			endif;
		endforeach;
		//navsp1 28MAR22 TFS#52718 - END
		
	endif;
	
	if self.shortName &lt;&gt; _pxyMeasure.shortName then																	// PAR #33235
		oldCode := self.shortName;																					// PAR #33235
	endif;																											// PAR #33235
	wasDisplayed := self.isDisplay &lt;&gt; _pxyMeasure.isDisplay and self.isDisplay;										// PAR #33235
	wasAvailable := self.isAvailableForEntry &lt;&gt; _pxyMeasure.isAvailableForEntry and self.isAvailableForEntry;		// PAR #33235
	nowDisplayed := self.isDisplay &lt;&gt; _pxyMeasure.isDisplay and not self.isDisplay;									// PAR #33235
	nowAvailable := self.isAvailableForEntry &lt;&gt; _pxyMeasure.isAvailableForEntry and not self.isAvailableForEntry;	// PAR #33235
	
	self.conversionRate 		:= _pxyMeasure.conversionRate;
	self.format			 		:= _pxyMeasure.format;
	self.isAvailableForEntry 	:= _pxyMeasure.isAvailableForEntry;
	self.isDefault			 	:= _pxyMeasure.isDefault;
	self.isDisplay 				:= _pxyMeasure.isDisplay;
	self.isSystemType 			:= _pxyMeasure.isSystemType;
	self.shortName				:= _pxyMeasure.shortName;
	self.formatPrecision		:= _pxyMeasure.formatPrecision;			//15.11.2022 navma1 #55381
	// keys
	self.measurementType 		:= _pxyMeasure.measurementType;
	self.name				 	:= _pxyMeasure.name;
	
	// PAR #33235 if myRoot is set, this is an update - update query definitions									// PAR #33235
	if self.myRoot &lt;&gt; null then																						// PAR #33235
		self.updateQueryDefinitions(	nowDisplayed or nowAvailable, 												// PAR #33235
										oldCode &lt;&gt; null, 															// PAR #33235
										wasDisplayed or wasAvailable, 												// PAR #33235
										oldCode	);																	// PAR #33235
	endif;																											// PAR #33235
epilog

end;</source>
        <Parameter name="_pxyMeasure" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFormatPrecision" id="ed3de3be-eaee-4741-ac76-90305b4019e8">
        <updating/>
        <source>setFormatPrecision(_formatPrecision : Integer)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type
*/

vars

begin
	self.formatPrecision := _formatPrecision;
epilog

end;</source>
        <Parameter name="_formatPrecision" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIsDefaultToFalse" id="3215c81b-294d-4d68-b0af-b31ca28d9d86">
