    <JadeMethod name="getWagon" id="ce41f5fd-9cd6-4e59-850a-0dbd3db62a16">
        <source>getWagon():CM_Wagon;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jun 2023	navhl20	ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail
21 Jul 2023 navhl20 Defect 59250: MTN - Wrong wagon id is shown on the delivery dispatch screen
*/

vars
	wod 	: CM_WorkOrderTIDtl;
	train	: CM_Train;
	wagon	: CM_Wagon;
	ti		: CM_TrackedItem;
begin
	
	wod := self.myWODtl;

	if wod = null then
		return null;
	endif;
	
	if wod.isKindOf(CM_WodReceive) then
		train := wod.CM_WodReceive.myTrain;
	elseif wod.isKindOf(CM_WodRelease) then
		train := wod.CM_WodRelease.myTrain;
	endif;
	
	if train = null then
		return null ;
	endif;
	
	ti := wod.allSelectedTIs.first;							//20.7.2023 navhl20 #59250
	
	if ti &lt;&gt; null and ti.wagon &lt;&gt; null then					//20.7.2023 navhl20 #59250
		wagon := train.allWagonsByIdInward[ti.wagon];
		if wagon = null then
			wagon := self.myTerminal.getWagonForToday(ti.wagon);
		endif;
	endif;
	
	if wagon = null then									//20.7.2023 navhl20 #59250
		wagon := train.allWagonsByIdInward.first;
	endif;
	
	return wagon;
epilog

end;</source>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getWagonEntry" id="dd6e1eda-cb55-494c-93fa-b6edef1375ee">
        <source>getWagonEntry(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2023	navhl20	ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail

*/

vars
	wagon	: CM_Wagon;
begin
	wagon := self.getWagon;
	
	if wagon = null then
		return null;
	endif;
	
	if not wagon.confirmed then
		return null;
	endif;
	return wagon.getReceiptTimeStamp().asStringJMT;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isInGrpCriteria" id="b47fb83c-c480-4e76-a187-1c9c7f19129b">
        <source>isInGrpCriteria(_crit : Integer):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue

*/

vars
	wo				: CM_WorkOrder;
	grpMethod		: CM_WorkOrderJobGroupMethod;
begin
	wo := self.getWorkOrder();
		
	if wo &lt;&gt; null and wo.isKindOf(CM_WorkOrderTI) then
		grpMethod := wo.CM_WorkOrderTI.myWorkOrderJobGroupMethod;
	endif;
	
	if grpMethod &lt;&gt; null then
		return grpMethod.allGroupingCriteria.includes(_crit);
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_crit" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isJobTypeMatching" id="164b1db0-1a85-411e-bb03-1f08985459f6">
