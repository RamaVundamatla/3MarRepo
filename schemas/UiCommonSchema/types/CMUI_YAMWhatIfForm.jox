    <JadeMethod name="setColorsFromController" id="ef2289dd-385d-4e98-8354-7a1e028a78d5">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColor	:=	self.backColor;
	
	self.dkbQuery.backColor		:=	tmpBackColor;
	self.dkbResults.backColor		:=	tmpBackColor;
	self.dkcMain.backColor		:=	tmpBackColor;

	
	
	
end;</source>
