    <JadeMethod name="getStartDateTime" id="1a70384c-b97d-486f-ba14-4ea72df67b2a">
        <source>getStartDateTime(_calcType : Integer) : TimeStamp;
// This storage transaction is linked to previous transactions. They will either be another storage transaction or they will be a receive transaction.
// If it is a receive transaction then the days between the 2 transactions are inclusive, else if it is another storage transaction they are
// not inclusive.
//	Oct 2012 split out original and new code for free storage days
//26 Jul 2019	NDL	TFS 45574
vars
	ltimestamp	: TimeStamp;
	storageConfig	: CM_StorageConfig;

begin
	if self.myTerminal = null then
		return self.dateTime;
	endif;
	
	storageConfig := self.myTerminal.myStorageConfig;
//	if storageConfig = null then
//		ltimestamp := self.getStartDateTimeNoConfig(_calcType);
//	else
		ltimestamp := self.getStartDateTimeFromConfig(storageConfig, _calcType);
//	endif;
	
	return ltimestamp;
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStartDateTimeFSD" id="763822e8-d39d-46c4-bb5f-72c2d65e6b5b">
        <source>getStartDateTimeFSD(_calcType : Integer; _storageConfig : CM_StorageConfig) : TimeStamp;
// This storage transaction is linked to previous transactions. They will either be another storage transaction or they will be a receive transaction.
// If it is a receive transaction then the days between the 2 transactions are inclusive, else if it is another storage transaction they are
// not inclusive.
//	Oct 2012 split out original and new code for free storage days
//26 Jul 2019	NDL	TFS 45574
vars
	ltimestamp	: TimeStamp;

begin
//	if _storageConfig = null then
//		ltimestamp := self.getStartDateTimeNoConfig(_calcType);
//	else
		ltimestamp := self.getStartDateTimeFromConfig(_storageConfig, _calcType);
//	endif;
	
	return ltimestamp;
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStartDateTimeFromConfig" id="73773cec-89f1-48dc-ba61-d161e0335f50">
        <source>getStartDateTimeFromConfig(_config : CM_StorageConfig; _calcType : Integer) : TimeStamp protected;
/*

Purpose:		CCMS 1295 free storage days, use the storage config settings


Return Value:		

Date		Who		Reason
14/05/2020 cnwma1 Bug 49282: MTN - Error 1090 When calculating storage
09/06/2023	navkc1	CR 58007 Task 58006: JADE - Storage Config - Unit Tests
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/
vars
	ltimestamp		 : TimeStamp;
	lDate			 : Date;
	myOperator, 
	itsOperator 	 : CM_Operator;
	myDebtor, 
	itsDebtor   	 : CM_Debtor;
	includeFirstDay,
	goExclusive,
	isExportMT, 
	isStorageMT, 
	doExportMT, 
	doStorageMT, 
	invalid 		 : Boolean;
	dateOption		 : Integer;
	startTransaction : CM_TITransaction;
	storageDetail 	 : CM_StorageDetail;
	canLogExtra		 : Boolean;							//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141

	storageDetail := self.myTrackedItem.getMatchingFreeStorageDetail(null); //29/02/2023	navkc1 CR 61899 Task 61901
	
	if storageDetail &lt;&gt; null then
		includeFirstDay := storageDetail.includeFirstDay;
	elseif _config &lt;&gt; null then
		includeFirstDay := _config.includeFirstDay;
	endif;
	
	if self.startTransaction &lt;&gt; null then
		// ### The storage transaction is linked to a previous transaction, this is either a storage transaction or typically a receival transaction.
		// ### If you specify a receival transaction in the pro forma configuration it will create one and use that, with todays date; 
		// ### however if a receival transaction of that class already exists it will use the real transaction.
		// ### so beware if your cargo has for example a receive road and the proforma says to create a receive ship.
		// ### It will use the pro forma receive ship with todays date as the start of storage.
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " storage startTransaction = " &amp; self.startTransaction.String, LogTRACE.String);
		endif;
		if self.startTransaction.isKindOf(CM_Storage) then
		
			if not self.startTransaction.isCharged then
				// this is the first noCharge free storage CM_Storage (if any)
				// from 31932 revision, skip the checking below - doesn't apply to this case - and just use the startTransaction dateTime
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " non-charged storage startTransaction, use its dateTime=" &amp; self.startTransaction.dateTime.String, LogTRACE.String);
				endif;
				return self.startTransaction.dateTime;
			endif;

			// CCMS 1410 this means that we check the operators debtor, we are inclusive if they are different
			//   only applies to charged interim storage transactions (typically weekly/monthly from background run, or from
			//	   storage trigger/operator changes etc)
			doStorageMT := self.myTerminal.getConfig(MTsByDebtor).Boolean;
			doExportMT := self.myTerminal.getConfig(MTsByDebtorExport).Boolean;
			
			if doStorageMT or doExportMT then
				goExclusive := false;
				myOperator := app.myRoot.allOperators[self.operatorCode.trimBlanks];
				itsOperator := app.myRoot.allOperators[self.startTransaction.operatorCode.trimBlanks];
				
				if myOperator &lt;&gt; null and itsOperator &lt;&gt; null then
					myDebtor := myOperator.debtor;
					itsDebtor := itsOperator.debtor;
					isStorageMT := (self.startTransaction.imExStatus = TI_IMEX_STATUS_STORAGE and self.startTransaction.contentsStatus = TI_CONTENTS_STATUS_EMPTY);
					isExportMT := (self.startTransaction.imExStatus = TI_IMEX_STATUS_EXPORT and self.startTransaction.contentsStatus = TI_CONTENTS_STATUS_EMPTY);
					// to exclude the box also needs to be a storage empty at the time of the prev trans (otherwise include)

					if myDebtor = itsDebtor 
					and ((doStorageMT
					and isStorageMT)
					or (doExportMT
					and isExportMT))
					then
						goExclusive := true;
					endif;
				endif;

				// this is the first noCharge free storage CM_Storage (if any)
				if (not self.startTransaction.isCharged) then
					goExclusive := false;
				endif;
 
				if goExclusive and
				   self.startTransaction.isDaysOnSiteCharge() then		// TFS 1746

					lDate := self.startTransaction.dateTime.date + 1;
					ltimestamp := self.startTransaction.dateTime;
					ltimestamp.setDate(lDate);
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog(method.qualifiedName &amp; " storage startTransaction, doStorageMT=" &amp; doStorageMT.String &amp; " doExportMT=" &amp; doExportMT.String &amp; " goExclusive=true, use dateTime+1=" &amp; ltimestamp.String, LogTRACE.String);
					endif;
					return ltimestamp;
				else
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog(method.qualifiedName &amp; " storage startTransaction, doStorageMT=" &amp; doStorageMT.String &amp; " doExportMT=" &amp; doExportMT.String &amp; " goExclusive=false, use dateTime=" &amp; self.startTransaction.dateTime.String, LogTRACE.String);
					endif;
					return self.startTransaction.dateTime;
				endif;
			else 		// ### NO to MTsByDebtor
				if (not self.startTransaction.isCharged) then
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog(method.qualifiedName &amp; " not doStorageMT or doExportMT, storage startTransaction not charged, use dateTime=" &amp; self.startTransaction.dateTime.String, LogTRACE.String);
					endif;
					return self.startTransaction.dateTime;
				else
					if self.startTransaction.isDaysOnSiteCharge() then				// TFS 1746
						lDate := self.startTransaction.dateTime.date + 1;
						ltimestamp := self.startTransaction.dateTime;
						ltimestamp.setDate(lDate);
						if canLogExtra then	//27.02.2025 navah1	#34141
							app.invLog(method.qualifiedName &amp; " not doStorageMT or doExportMT, storage startTransaction is charged AND DAYS ONSITE, use dateTime+1=" &amp; ltimestamp.String, LogTRACE.String);
						endif;
						return ltimestamp;
					else
						if canLogExtra then	//27.02.2025 navah1	#34141
							app.invLog(method.qualifiedName &amp; " not doStorageMT or doExportMT, storage startTransaction charged, use dateTime=" &amp; self.startTransaction.dateTime.String, LogTRACE.String);
						endif;
						return self.startTransaction.dateTime;
					endif;
				endif;
			endif;
		else		// self.startTransaction is something other than CM_Storage (e.g. receive/release)
			invalid := true;
			startTransaction := self.startTransaction;
			if startTransaction &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, startTransaction, invalid);
				invalid := false;
				ltimestamp := startTransaction.dateTime;
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " non-storage startTransaction, use dateTime=" &amp; ltimestamp.String, LogTRACE.String);
				endif;
			endif;
			
			if invalid then		// .startTransaction is either null or invalid
				ltimestamp := self.myTrackedItem.creationTime;
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " non-storage invalid startTransaction, use ti creationTime=" &amp; ltimestamp.String, LogTRACE.String);
				endif;
			endif;
			// use calculation type or config option for ship start option
			if _calcType = INV_CALC_TYPE_DAYSINCE_SHIP_ST then
				dateOption := Voyage_Ship_Exchange_Start;
			elseif _config &lt;&gt; null then
				if  self.startTransaction &lt;&gt; null and self.startTransaction.isKindOf(CM_ReceiveShip) then // TFS 3119
					dateOption := _config.shipReceivalType;
					//09/06/2023	navkc1	CR 58007 Task 58006
					//storageDetail := self.myTrackedItem.getMatchingFreeStorageDetail(null);
					if storageDetail &lt;&gt; null then
						dateOption := storageDetail.shipReceivalType;
					endif;
				endif;
			endif;
			ltimestamp := self.getCargoStartTimeFSD(dateOption, ltimestamp);
			// config include first day option, by default the start date is not used
			//  this option is used here for the case where there are no free days, otherwise it is only used in the free storage date calculation
			//if _config &lt;&gt; null and  _config.includeFirstDay then   //14.05.2020 cnwma1 #49282
			if includeFirstDay then //29/02/2023	navkc1 CR 61899 Task 61901
				ltimestamp := ltimestamp.addDays(-1);
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; "  non-storage startTransaction, config includeFirstDay, use days-1=" &amp; ltimestamp.String, LogTRACE.String);
				endif;
			endif;

			return ltimestamp;
		endif;
	else				// self.startTransaction is null
		ltimestamp := self.myTrackedItem.creationTime;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; "  no startTransaction, use ti creationTime=" &amp; ltimestamp.String, LogTRACE.String);
		endif;
		// use calculation type or config option for ship start option
		if _calcType = INV_CALC_TYPE_DAYSINCE_SHIP_ST then
			dateOption := Voyage_Ship_Exchange_Start;
		elseif _config &lt;&gt; null then
			dateOption := _config.shipReceivalType;
			//09/06/2023	navkc1	CR 58007 Task 58006
			//storageDetail := self.myTrackedItem.getMatchingFreeStorageDetail(null);
			if storageDetail &lt;&gt; null then
				dateOption := storageDetail.shipReceivalType;
			endif;
		endif;
		ltimestamp := self.getCargoStartTimeFSD(dateOption, ltimestamp);
		// config include first day option
		//  this option is used here for the case where there are no free days, otherwise it is only used in the free storage date calculation
		//if _config &lt;&gt; null and  _config.includeFirstDay then  //14.05.2020 cnwma1 #49282
		if includeFirstDay then //29/02/2023	navkc1 CR 61899 Task 61901
			ltimestamp := ltimestamp.addDays(-1);
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; "  no startTransaction, config includeFirstDays, days-1=" &amp; ltimestamp.String, LogTRACE.String);
			endif;
		endif;

		return ltimestamp;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_config" type="CM_StorageConfig"/>
        <Parameter name="_calcType" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStartTransaction" id="2220b1f2-2c3d-447a-a24d-30605923b49d">
        <source>getStartTransaction(): CM_TITransaction;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return self.startTransaction;

epilog

end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="isCreatedByBGP" id="cf0834d2-9bfa-49b6-9b71-fa59cbff94c7">
        <source>isCreatedByBGP() : Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	user 	: CM_User;
	aTask : CM_AutoTask;
	invalidUser : Boolean;
begin

	aTask := self.myTerminal.myRoot.allAutoTasks.getAtKeyGeq(BGP_StorageProcessorRequest.name,null);
	
	on Exception do app.handleDeletedObject(exception,user,invalidUser);
//not checking key
	if aTask &lt;&gt; null then
		user:=aTask.myUser;
		if user &lt;&gt; null then
			if user.code = self.userId then
				return true;
			endif;
			if invalidUser then
				invalidUser:=false;
			endif;
		endif;
	endif;
	
	return false;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDaysOnSiteCharge" id="35a3ffd0-2784-4708-ae5d-9020867e1219">
        <source>isDaysOnSiteCharge() : Boolean;
// 37718 // TFS 1746 return true if this storage transaction has any invoice lines of calculation type 'Days Onsite At nn:nn'
//	since the proccessing of these is different from all other storage calc types
vars
	result	: Boolean;
	invLine	: CM_InvoiceLine;
begin
	result := false;
	foreach invLine in self.allInvoiceLines do
		if invLine.invoiceLineDesc.myCalculationType &lt;&gt; null and
		   invLine.invoiceLineDesc.myCalculationType.calculationType = INV_CALC_TYPE_DAYS_ONSITE_AT then
			result := true;
			break;
		endif;
	endforeach;
	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageWorkOrder" id="ea246fd1-9bd7-4151-ae34-28dd3d648b3a">
        <source>isStorageWorkOrder() : Boolean;
/*

Purpose:		PEL1 cargo work orders are PREPAY, this means that a cash receipt is turned into an invoice, 
						actual invoicing for those transactions do not occur. So storage transactions are created on the cargo
						that are NOCHARGE = true, but those storage transactions also have a reference to the work order detail
						This way the nocharge does not create an invoice line and the myWorkOrderDtl means that we shoudl still include in the 
						linked storage transaction logic

Parameters:	// TFS 43405 JLGAB1		

Return Value:		

Date		Who		Reason
26 March 2019	jlgab1	Initial creation

*/

vars

begin
	if self.myWorkOrderDtl &lt;&gt; null  then// TFS 43405 JLGAB1
		if self.myWorkOrderDtl.isWorkOrderForRelease ()
		or self.myWorkOrderDtl.isWorkOrderForReleaseExtension() then // TFS 43405 JLGAB1
			
			return self.noCharge;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageVisitRelevant" id="80778eb4-9ba7-41d2-a9ec-15977ad305d4">
        <source>isVoyageVisitRelevant(): Boolean;

vars

begin
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForQrmEnquiry" id="a64bafd1-1599-4c1d-9fc8-bf3378969132">
        <updating/>
        <source>setForQrmEnquiry( 	_ti : CM_TrackedItem;
					_startTrx : CM_TITransaction;
					_dateTime : TimeStamp
					) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08/04/2019	jlgndl1	Initial creation	TFS 43405
29/04/2019	jlgdap1	TFS 43405 Allow for Cargo Alocation tran maps - needs a myTerminal reference here
*/

vars

begin

	self.type := TRANS_TYPE_STORAGE;
	self.setMyTrackedItem( _ti, null );
	self.setStartTransaction( _startTrx );
	self.updateDateTime( _dateTime );
	self.myTerminal := _ti.myTerminal;			// jlgdap1 29/04/2019 TFS 43405

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_startTrx" type="CM_TITransaction"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="e16520f9-cc6b-4a0e-a092-333daf9c9dd8">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;

vars

begin

	inheritMethod(_tiTransCntrl, _passport);
	if _tiTransCntrl.isKindOf(CMIF_StorageTransController) then
		if  _tiTransCntrl.CMIF_StorageTransController.originalCompanyCode &lt;&gt; null then
			companyCode	:= _tiTransCntrl.CMIF_StorageTransController.originalCompanyCode; // adm 070709 Par 17883
		endif;
		// Mar 2013 31371 set this up before creating invoice lines where the quantity uses this
		self.setStartTransaction(_tiTransCntrl.CMIF_StorageTransController.startTransaction);
		self.setLocation(_tiTransCntrl.CMIF_StorageTransController.location);	//15 Mar 2016	NDL	TFS 1407
		
		//epr TFS 2884 11/1/16
		if _tiTransCntrl.isReceiveShip and self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myCargoType.allowDuplicates and self.myTrackedItem.myCargoType &lt;&gt; null then
			if self.voyage &lt;&gt; null then
				self.myVoyageRelivant := self.voyage;
			endif;
		endif;
	endif;

end;
</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLocation" id="19902387-b785-4b97-a336-cadc4f36016c">
