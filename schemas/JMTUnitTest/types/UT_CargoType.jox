    <JadeMethod name="tTestFindPartial12" id="5129feb6-2e06-4255-9f74-16ebfbca7b55">
        <source>tTestFindPartial12();
//
/// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// 10 Sep 2019	cnwrs1	TFS 46030
// 27 May 2022	navdap1	Changes to Cargo Enquiry to allow Logs to be found when state is Deleted
//
constants
	VESSEL_CODE		: String = "UTMTREL";
	VOYAGE_CODE		: String = "UTMTREL100";
	CargoId1 = "PUKE";
	CargoId2 = "#691";
vars
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	cargoId : String;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	operator : CM_Operator;
	idx : Integer;
	state : Integer;
	site : Integer;
	foundTIs : CM_TISet;
	cargoTypeCount : Integer;
	stateCount : Integer;
	searchReversed : Boolean;
	containerEnqSearch : Boolean;
	bs			: CM_BlockStack;					// 24/01/2017 cnwmh5
	lc			: CM_LocationsController;			// 25/01/2017 cnwmh5
	commodity : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	searchReversed := true;
	containerEnqSearch := false;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteVoyage(VOYAGE_CODE);
	self.deleteVessel(VESSEL_CODE);
	vesselObj := self.addVesselCellular(VESSEL_CODE, operator);
	voyageObj := self.addVoyageWithContainerStructur(VOYAGE_CODE, VESSEL_CODE, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyageObj);
	self.assertNotNull(vesselObj);
	
	// 24/01/2017 cnwmh5 - Set up block stack ann set in opts
	bs := self.addBlockStack("BSTFP", 99, null);	
	self.assertNotNull(bs);	
	
	create foundTIs transient;
	foreach cargoType in CM_CargoType.instances do
		if cargoType.id &gt; 10 then
			break;
		endif;
		cargoTypeCount := cargoTypeCount + 1;
		foreach idx in 1 to TI_STATE_MAX - 1 do
			if idx = TI_STATE_EDI or
			   idx = TI_STATE_ARCHIVED or
			   idx = TI_STATE_MERGED or
			   idx = TI_STATE_TRANSFER or
			   idx = TI_STATE_TRANSFER_FROM or
			   idx = TI_STATE_TRANSFER_TO or
			   idx = TI_STATE_GHOST then
				continue;
			endif;
			if cargoTypeCount = 1 then
				stateCount := stateCount + 1;
			endif;
			state := idx;
			site := app.stateToSite(state);
			
			// 25/12/2017 cnwmh5
			if state = TI_STATE_ONSHIP then
				lc := voyageObj.getNextFreeSlotLCByDischargeCC(false);
			else
				lc :=  bs.myLocationsController;
			endif;
			
			cargoId := CargoId1&amp;idx.String&amp;cargoType.id.String&amp;CargoId2;
			ti := self.getTrackedItem(cargoId).CM_TrackedItem;
			self.deleteTrackedItem(ti, true);
			self.assertIsDeleted(ti);
			if cargoType.allCommodities.size &gt; 0 then
				commodity := cargoType.allCommodities.first.code;
			else
				commodity := null;
			endif;
			ti := self.createTrackedItem(cargoId, cargoType.id, commodity, operator, false, lc);
			beginTransaction;
			ti.setPropertyValue("state", state);
			ti.setPropertyValue("site", site);
			ti.setPropertyValue(CM_TrackedItem::myVoyage.name, voyageObj);
			ti.updateCollections();
			commitTransaction;
			cargoId := CargoId2&amp;idx.String&amp;cargoType.id.String&amp;CargoId1;
			ti := self.getTrackedItem(cargoId).CM_TrackedItem;
			self.deleteTrackedItem(ti, true);
			self.assertIsDeleted(ti);
			if cargoType.allCommodities.size &gt; 0 then
				commodity := cargoType.allCommodities.first.code;
			else
				commodity := null;
			endif;
			ti := self.createTrackedItem(cargoId, cargoType.id, commodity, operator, false, lc);
			state := idx;
			site := app.stateToSite(state);
			beginTransaction;
			ti.setPropertyValue("state", state);
			ti.setPropertyValue("site", site);
			ti.setPropertyValue(CM_TrackedItem::myVoyage.name, voyageObj);
			ti.updateCollections();
			commitTransaction;
			
		endforeach;
	endforeach;
	foreach cargoType in CM_CargoType.instances do
		if cargoType.id &gt; 10 then
			break;
		endif;
		foreach idx in 1 to TI_STATE_MAX - 1 do
			if idx = TI_STATE_EDI or
			   idx = TI_STATE_ARCHIVED or
			   idx = TI_STATE_MERGED or
			   idx = TI_STATE_TRANSFER or
			   idx = TI_STATE_TRANSFER_FROM or
			   idx = TI_STATE_TRANSFER_TO or
			   idx = TI_STATE_GHOST then
				continue;
			endif;
			state := idx;
			site := app.stateToSite(state);
			cargoId := CargoId1&amp;idx.String&amp;cargoType.id.String&amp;CargoId2;
			foundTIs.clear;
			self.getTerminal.findAllCargoStartsWithId(cargoId, cargoType.id, state, null, searchReversed, containerEnqSearch, foundTIs);
			
			self.assertEqualMsg(foundTIs.size, 1, "there should be 1");
			foundTIs.clear;
			self.getTerminal.findAllCargoStartsWithId(cargoId, cargoType.id, 0, null, searchReversed, containerEnqSearch, foundTIs);
			
			if  state = 6 then
				if cargoType.id = TI_CargoType_Log then
					self.assertEqualMsg(foundTIs.size, 1, "there should be 1");
				else
					self.assertEqualMsg(foundTIs.size, 0, "there should be 0");
				endif;
			else
				self.assertEqualMsg(foundTIs.size, 1, "there should be 1");
			endif;
			foundTIs.clear;
			self.getTerminal.findAllCargoStartsWithId("PUKE", cargoType.id, state, null, searchReversed, containerEnqSearch, foundTIs);
			
			self.assertEqualMsg(foundTIs.size, 2, "there should be 2");
			foundTIs.clear;
			self.getTerminal.findAllCargoStartsWithId("PUKE", 0, state, null, searchReversed, containerEnqSearch, foundTIs);
			
			self.assertEqualMsg(foundTIs.size, cargoTypeCount*2, "there should be "&amp;(cargoTypeCount*2).String);
		endforeach;
		foundTIs.clear;
		self.getTerminal.findAllCargoStartsWithId("PUKE", cargoType.id, 0, null, searchReversed, containerEnqSearch, foundTIs);
		
		if cargoType.id = TI_CargoType_Log then
			self.assertEqualMsg(foundTIs.size, 14, "there should be "&amp;(stateCount*2).String);
		else
			self.assertEqualMsg(foundTIs.size, 12, "there should be "&amp;(stateCount*2).String);
		endif;
//		self.assertEqualMsg(foundTIs.size, stateCount*2, "there should be "&amp;(stateCount*2).String);
	endforeach;
	foundTIs.clear;
	self.getTerminal.findAllCargoStartsWithId("PUKE", 0, 0, null, searchReversed, containerEnqSearch, foundTIs);
	
	self.assertEqualMsg(foundTIs.size, 108, "there should be "&amp;(cargoTypeCount*stateCount*2).String);
//	self.assertEqualMsg(foundTIs.size, cargoTypeCount*stateCount*2, "there should be "&amp;(cargoTypeCount*stateCount*2).String);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete foundTIs;
end;
</source>
