    <JadeMethod name="pxyCreateUpdateProxy" id="56a708e2-e80f-4e21-ba18-1857376f550c">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyOperator	: CM_Operator;
	pxyOpTerm,
	opTerm		: CM_OperatorTerminal;
	pxyState	: CM_StateObject;
	completedOK		: Boolean;
begin

	pxyOperator := inheritMethod();

	pxyOperator.debtor	:= self.debtor;
	
	if pxyOperator.notRailIds = null then
		create pxyOperator.notRailIds transient;
		if self.notRailIds &lt;&gt; null then
			self.notRailIds.clone(pxyOperator.notRailIds);
		endif;
	endif;

	if pxyOperator.notRoadIds = null then
		create pxyOperator.notRoadIds transient;
		if self.notRoadIds &lt;&gt; null then
			self.notRoadIds.clone(pxyOperator.notRoadIds);
		endif;
	endif;

	self.allCodeGroups.copy(pxyOperator.allCodeGroups);
	self.allEmailAddresses.copy(pxyOperator.allEmailAddresses);	//01 Sep 2009	NDL	Par 20521
	
	foreach opTerm in self.allOperatorTerminals do
		pxyOpTerm := opTerm.pxyCreateUpdateProxy();
		pxyOpTerm.init(pxyOperator, opTerm.myTerminal);
	endforeach;
	
	if self.myStateObject &lt;&gt; null then
		pxyState 	:= self.myStateObject.pxyCreateUpdateProxy();
		pxyOperator.myStateObject := pxyState;
	endif;
	
	self.allOperatorGroups.copy(pxyOperator.allOperatorGroups);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyOperator;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyOperator;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="selectBookingRefTIs" id="add9f3c0-edd3-4033-a52f-1bf31d617f40">
        <source>selectBookingRefTIs(pTerminal : CM_Terminal; pVoyageCode : String; pReceiveDT : TimeStamp) : Integer;

vars
	br 			: CM_BookingRef;
	checkVoyage,
	checkReceipt : Boolean;
	voyage 		: CM_Voyage;
	ti 			: CM_TrackedItem;
	opTerm		: CM_OperatorTerminal;
	ls			: Boolean;

begin

	opTerm := self.getOperatorTerminal(pTerminal, false);
	
	if opTerm = null then
		return 0;
	else
		app.cmsBeginLoad(ls);
		sharedLock(opTerm);
		return opTerm.selectBookingRefTIs(pVoyageCode, pReceiveDT);
	endif;

epilog
	app.cmsEndLoad(ls);

end;</source>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="pVoyageCode" type="String"/>
        <Parameter name="pReceiveDT" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
