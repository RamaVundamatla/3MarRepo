    <JadeMethod name="handleNoteForBoxcarCargo" id="faac7d8e-4b29-47d0-a22f-02f0954ece28">
        <updating/>
        <source>handleNoteForBoxcarCargo(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	ti : CM_TrackedItem;
	lc : CM_BoxcarWagonController;
	rowIndex : Integer;
	str : String;
	isInLc : Boolean;

begin

	// only want to do this if we have the form built for a boxcar
	if self.myStartupObject = null then
		return;
	endif;
	if not CM_BoxcarWagonController.hasInstance( self.myStartupObject) then
		return;
	endif;
	//And the object we are being notified of is cargo
	if not theObject.isKindOf(CM_TrackedItem) then
		return;
	endif;
	
	ti := theObject.CM_TrackedItem;
	lc := self.myStartupObject.CM_BoxcarWagonController;

	if not CM_TrackedItem.hasInstance( ti) then
		// its been deleted, just clear it from the table.
		self.tblData.findObjectInRow(ti,rowIndex);
		if rowIndex &gt; 0 then
			self.tblData.removeItem(rowIndex);
		endif;
		return;
	endif;
	
	if self.displayMode = DISPLAY_MODE_ACTUAL then
		isInLc := lc.allTrackedItems.includes(ti);
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		isInLc := lc.allQueuedFutureMoves.containsTI(ti);
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		isInLc := lc.allPlannedFutureMoves.containsTI(ti);
	endif;
	
	if not isInLc then
		//shouldn't be in table.
		self.tblData.findObjectInRow(ti,rowIndex);
		if rowIndex &gt; 0 then
			self.tblData.removeItem(rowIndex);
		endif;
		return;
	
	else
		//should be in the table
		self.tblData.findObjectInRow(ti,rowIndex);
		str := self.tblDataDisplayRow(self.tblData, ti);
		if rowIndex &gt; 0 then
			self.tblData.removeItem(rowIndex);
			self.tblData.addItemObjectAt(ti, str, rowIndex);
		else
			rowIndex := self.tblData.addItemObject(ti, str);
		endif;
		self.tblDataShowDataSpecial(rowIndex, ti);
	endif;
	
	

epilog

end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleTblDataDblClick" id="23b6a7de-61e4-4f69-ac89-84ea1d7e4256">
