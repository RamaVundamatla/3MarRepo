    <JadeMethod name="updateItem" id="a746d63b-bc85-430e-aa19-a7b7080c0929">
        <updating/>
        <source>updateItem() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmifAttach			: CMIF_InOutAttachment;
	row					: Integer;
	table				: CM_DataTable;
	strLC,
	strTA		: String;
begin
	cmifAttach := self.tblAll.accessRow(self.tblAll.row).itemObject.CMIF_InOutAttachment;
	if cmifAttach = null then
		app.msgBox('Please select an item to update first','Error',0);
		return false;
	endif;
	table := self.tblAll;
	if not self.validateItemInput() then
		return false;
	endif;
	
	if not self.setFromItemFromTable(cmifAttach) then
		return false;
	endif;
	//remove row and re-insert item
	row := table.cnEcFindObjectRowNo(cmifAttach);
	table.removeItem(row);
	
	if cmifAttach.myTerminalArea &lt;&gt; null then 
		strLC := cmifAttach.myTerminalArea.id;
	endif;
	
	if cmifAttach.myLocationsController &lt;&gt; null then 
		strTA := cmifAttach.myLocationsController.getID;
	endif;

	
	self.tblAll.addItemAt(cmifAttach.id &amp; Tab &amp;
							cmifAttach.operatorCode &amp; Tab &amp;
							cmifAttach.myCargoType.description &amp; Tab &amp;
							strLC &amp; Tab &amp;
							strTA,
							row);
	
	self.tblAll.accessRow(row).itemObject := cmifAttach;
	self.tblItem.clearHasChanged();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateItemCount" id="9d3bf178-1763-43bd-92e6-d6021fdadfa5">
        <source>updateItemCount() protected;
// --------------------------------------------------------------------------------
// Created:		18 November 2005 by cnwdad1
//
// Purpose:		Updates the count of table entries.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aNumberOfItems &gt; 0 then
		lblItemCount.caption	:=	(tblAll.rows - 1).cnEcNumberFormat() &amp;
								" of " &amp;
								self.aNumberOfItems.cnEcNumberFormat() &amp;
								" entered.";
	else
		lblItemCount.caption	:=	(tblAll.rows - 1).cnEcNumberFormat() &amp;
								" item(s) entered.";
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateItemInput" id="cc42ef31-d2d3-4096-8972-545c2199cc4d">
        <source>validateItemInput() : Boolean;
// ---------------------------------------------------------------------------
// Created:     18 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 15/10/2009	cnwmh5		PAR 20989	Change so checks to see if sub type required
vars
	currentAttach,
	attach			: CMIF_InOutAttachment;
	idStr			: String;
	tbl				: CM_EntryTable;
	cargoType		: Integer;
	cargoTypeRef		: CM_CargoType;
	
begin
	tbl := self.tblItem;
	
	if self.cmbCargoType.listObject = null then
		app.msgBox('You must select a cargo type.','Insufficient input', MsgBox_Exclamation_Mark_Icon);	
		tbl.goToRowByName(ETRow_CargoType);
		return false;
	endif;
	
	// 15/10/2009 cnwmh5 #20989
	//if self.cmbCargoType.listObject.CM_CargoType.id &gt; TI_CargoType_Max then
	if self.cmbCargoType.listObject.CM_CargoType.id &gt; TI_CargoType_Max and not self.cmbCargoType.listObject.CM_CargoType.isSubCargoTypeRequired = null then
		if self.cmbProduct.listObject = null then
			app.msgBox(app.getErrorString(Must_selec_cargo_subtype_userD),'Error', MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endif;
	
	idStr := self.tblItem.getValueByName(ETRow_Id).String;
	
	if idStr = null then
		app.msgBox('You must enter an ID.','Insufficient input', MsgBox_Exclamation_Mark_Icon);	
		tbl.goToRowByName(ETRow_Id);
		return false;
	endif;
	
	if app.getMyUser().canDo(self.myTerminal, Mod_GeneralCargo) then
		cargoType := self.cmbCargoType.listObject.CM_CargoType.id;
	else
		cargoType := TI_CargoType_LCL;
	endif;
	
	currentAttach := self.tblAll.accessRow(self.tblAll.row).itemObject.CMIF_InOutAttachment;
	
	cargoTypeRef := self.cmbCargoType.listObject.CM_CargoType;
	foreach attach in self.aAllAttachments do
		if attach.id.trimBlanks.toUpper = idStr.trimBlanks.toUpper and
		   attach &lt;&gt; currentAttach then
		   if cargoTypeRef = null or (not cargoTypeRef.allowDuplicates and attach.cargoType = cargoTypeRef.id) then
				app.msgBox('An item with this ID has already been entered.','Item already exists', MsgBox_Exclamation_Mark_Icon);	
				tbl.goToRowByName(ETRow_Id);
				return false;
			endif;
		endif;
	endforeach;
	
	if self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType, idStr] &lt;&gt; null then
		app.msgBox('An item with this ID already exists in this terminal.','Item already exists', MsgBox_Exclamation_Mark_Icon);	
		tbl.goToRowByName(ETRow_Id);
		return false;
	endif;
	
	if self.aMyMasterTI = null then
		// we are not creating a child item so need to check that
		// a valid location has been entered (for child items the 
		// location will come from the parent.
		
		if not self.isFromShipPreNote then 	// if is from GTE_ShipPreNote then these fields are not displayed (it will be going onto a ship)
			if self.cmbTerminalArea.listObject = null and self.aMyTerminalArea = null  then
				app.msgBox('You must select a terminal area for the item.','Insufficient input', MsgBox_Exclamation_Mark_Icon);
				tbl.goToRowByName(ETRow_TerminalArea);
				return false;
			endif;
			
			if self.cmbLC.listObject = null and self.aMyLocationsController = null then
				app.msgBox('You must select a row or location for the item.', 'Insufficient input', MsgBox_Exclamation_Mark_Icon);
				tbl.goToRowByName(ETRow_Row);
				return false;
			endif;
		else
			if self.cmbVoyage.listObject = null then 
				app.msgBox('You must select a Voyage for the item.','Insufficient input', MsgBox_Exclamation_Mark_Icon);
				tbl.goToRowByName(ETRow_Voyage);
				return false;
			endif;
		endif;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
