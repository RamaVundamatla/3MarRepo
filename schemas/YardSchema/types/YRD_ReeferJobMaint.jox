    <JadeMethod name="doClickCmbGriddedArea" id="9272869b-68e1-423a-8c3d-8585a36cdcec">
        <source>doClickCmbGriddedArea();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	`Tfs 49581

*/

vars

	ta : CM_TerminalArea;
	reeferBlock: CM_ReeferBlock;
	rowIndex : Integer;

begin

	self.tblReeferWalkBlocks.rows := 1;
	ta := self.cmbGridTermArea.listObject.CM_TerminalArea;
	if ta = null then
		if self.optByTerminal.value then 
			self.doClickReeferWalkTable();
		endif;
		return;
	endif;
	
	foreach reeferBlock in ta.allReeferBlocks do
		rowIndex := self.tblReeferWalkBlocks.addItem( reeferBlock.name );
		self.tblReeferWalkBlocks.accessRow( rowIndex ).itemObject := reeferBlock;
	endforeach;
	
epilog

	self.doClickReeferWalkTable();

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickJobsTable" id="5da901b3-54da-4014-972e-ff8dfe262dcb">
        <source>doClickJobsTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	rowIndex : Integer;
	reeferJob : CM_YardActivity;

begin

	self.txtDate.setDate( null );
	self.txtDate.enabled := false;
	self.txtTime.setTime( null );
	self.txtTime.enabled := false;
	self.btnUpdateTime.enabled := false;
	self.btnDeleteJob.enabled := false;
	
	rowIndex := self.tblReeferJobs.row;
	if rowIndex &gt; self.tblReeferJobs.fixedRows then
		reeferJob := self.tblReeferJobs.accessRow( rowIndex ).itemObject.CM_YardActivity;
	endif;
	if reeferJob = null then
		return;
	endif;
	
	self.txtDate.setDate( reeferJob.getActionTimeDateLocalTZ.Date );
	self.txtDate.enabled := true;
	self.txtTime.setTime( reeferJob.getActionTimeDateLocalTZ.Time );
	self.txtTime.enabled := true;
	self.btnUpdateTime.enabled := true;
	self.btnDeleteJob.enabled := true;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickReeferWalkTable" id="8f5cefa4-8b9a-4822-ac27-b3349125f080">
        <source>doClickReeferWalkTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	reeferBlock: CM_ReeferBlock;
	rowIndex : Integer;
	yardActivities : CM_YardActivityArray;
	yardActivityType : Integer;
	includeFutureActivity : Boolean;
	yardActivity : CM_YardActivity;
	ti : CM_TrackedItem;
	str : String;

begin

	self.tblReeferJobs.rows := 1;
	
	
	rowIndex := self.tblReeferWalkBlocks.row;
	if rowIndex &gt; self.tblReeferWalkBlocks.fixedRows then
		if self.tblReeferWalkBlocks.accessRow( rowIndex ).selected then
			reeferBlock := self.tblReeferWalkBlocks.accessRow( rowIndex ).itemObject.CM_ReeferBlock;
		endif;
	endif;
	if reeferBlock = null and not self.optByTerminal.value then
		return;
	endif;
	
	includeFutureActivity := self.optAllJobs.value;
	if self.optAlarmType.value then
		yardActivityType := CM_YardActivity.ReeferAlarm;
	elseif self.optConnJob.value then
		yardActivityType := CM_YardActivity.ReeferConnect;
	elseif self.optDisconJob.value then
		yardActivityType := CM_YardActivity.ReeferDisconnect;
	elseif self.optMonJob.value then
		yardActivityType := CM_YardActivity.ReeferMonitor;
	else
		yardActivityType := 0;
	endif;

	create yardActivities transient;
	
	if self.optByTerminal.value then	//self.myTerminal.allYardActions	
		self.myTerminal.getReeferJobs( 	yardActivityType,	//_yardActivityType : Integer; 
										includeFutureActivity,	//_includeFutureActivity : Boolean;
										yardActivities	//_yardActivities : CM_YardActivityArray input
										);
	else
		reeferBlock.getReeferJobs( 	yardActivityType,	//_yardActivityType : Integer; 
									includeFutureActivity,	//_includeFutureActivity : Boolean;
									yardActivities	//_yardActivities : CM_YardActivityArray input
									);
	endif;
								
	foreach yardActivity in yardActivities do
		str := yardActivity.getAttributeStringForDefArray(self.tblReeferJobs.allTblDataEntRows);
		rowIndex := self.tblReeferJobs.addItem( str );
		self.tblReeferJobs.accessRow( rowIndex ).itemObject := yardActivity;
	endforeach;

epilog

	self.doClickJobsTable();
	delete yardActivities;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteJob" id="28c16f4d-d48d-49bf-a392-9f65d4e5d673">
        <source>doDeleteJob();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	rowIndex : Integer;
	reeferJobs : CM_YardActivityDict;
	msg : String;

begin

	if self.tblReeferJobs.allSelectedObjects.isEmpty then
		app.msgBox( app.getErrorString(Reefer_not_selected), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	create reeferJobs transient;
	self.tblReeferJobs.allSelectedObjects.copy( reeferJobs );
	msg := app.getErrorString1( Lit_Confirm_Delete, app.getErrorString1(Selected_reefer_jobs, reeferJobs.size.asStringJMT ) );
	if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No  ) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	app.myTrxDA.trxDeleteYardActivity( reeferJobs, app.myPassport );
	
	self.doClickReeferWalkTable();

epilog

	delete reeferJobs;

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateJobActionTS" id="c9fe028c-5a89-477f-aee0-7f69c7f25a51">
        <source>doUpdateJobActionTS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	rowIndex : Integer;
	reeferJobs : CM_YardActivityDict;
	newRawActionTS : TimeStamp;
	newConvertedActionTS : TimeStamp;
	theReturn : Integer;
	interval : TimeStampInterval;

begin
	if self.tblReeferJobs.allSelectedObjects.isEmpty then
		app.msgBox( app.getErrorString(Reefer_not_selected), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	create reeferJobs transient;
	self.tblReeferJobs.allSelectedObjects.copy( reeferJobs );
	
	newRawActionTS.setDate( self.txtDate.getDate );
	newRawActionTS.setTime( self.txtTime.getTime );
	
	newConvertedActionTS := self.myTerminal.localToSystemTime( newRawActionTS );
	if newConvertedActionTS &gt; app.actualTimeAppServer then
		interval := newConvertedActionTS - app.actualTimeAppServer;
		if interval.inDaysAndPartOf &gt; 1 then
			if app.msgBox( app.getErrorString( Datet_more_than_hours_futur_su ), app.getErrorString(Continue), MsgBox_Yes_No  ) &lt;&gt; MsgBox_Return_Yes then
				return;
			endif;
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxUpdYardActivityActionTime( reeferJobs, newConvertedActionTS, app.myPassport );
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog( app.getErrorString(Update_reefer_job), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		return;
	endwhile;
	
	self.doClickReeferWalkTable();

epilog

	delete reeferJobs;

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="c0cad0d5-912c-4457-928f-c00544ce91e3">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	xmlStr : String;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.tblReeferJobs.getXmlStrForColumns(true);
	
	return xmlStr;

epilog

end;</source>
