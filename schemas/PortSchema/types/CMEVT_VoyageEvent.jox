    <JadeMethod name="validateUpdate" id="0276f24a-ad40-4b25-a96e-044b536d7032">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2019	jlgns1	Initial creation
23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events

*/

vars

begin
	inheritMethod(_passport);
	
	
	if self.myEventType.isFromToDateTimeRequired then	
		if self.dateTimeEnd = null or (not self.dateTimeEnd.isValid) then//Should be caught by the UI but we check just in case
			app.raiseCMException1(ERR_INVALID_TIMESTAMP,app.getErrorString(End) ,null,null);
		endif;
		if self.dateTimeEnd &lt; self.dateTime then
			app.raiseCMException2(ERR_Invalid_Datetime_Before,app.getErrorString(End),app.getErrorString(Start),null,null);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
