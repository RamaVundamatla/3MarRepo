    <JadeMethod name="comboVoyageObjectReports" id="f4db65e7-034a-412e-8531-46ff8e9d3e27">
        <source>comboVoyageObjectReports( _combo : ComboBox input; _selectedRepName : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2017	cnwndl1	Initial creation	TFS 3216/3047

*/

vars

	show : Boolean;
	repAvailableDict : CM_QryReportDict;
	qryRep : CM_QryReport;
	filterClassName : String;
	validFilters : StringArray;
	class : Class;
	schema : Schema;
	subs: ClassColl;
	iter : Iterator;

begin

	_combo.clear();

	//Local copy of every available report
	create repAvailableDict transient;
//	CM_QryReportSystem.instances.copy( repAvailableDict );
//	CM_QryReportUser.instances.copy( repAvailableDict );
	
	//27 Feb 2017	NDL	TFS 3578
	iter := CM_QryReportSystem.instances.createIterator;
	while iter.next( qryRep ) do
		if qryRep.menuId = null then
			// these are temp copies waiting to be printed in the BGP.
			continue;
		endif;
		repAvailableDict.addNoDuplicates( qryRep, false );
	endwhile;
	delete iter;
	iter := CM_QryReportUser.instances.createIterator;
	while iter.next( qryRep ) do
		if qryRep.menuId = null then
			continue;
		endif;
		repAvailableDict.addNoDuplicates( qryRep, false );
	endwhile;
	delete iter;
	
	schema := currentSchema.superschema; // PortSchema
	class := schema.getClass("CMQF_VoyageSummary");
	create subs transient;
	class.getSubclasses( subs );
	
	create validFilters transient;
	validFilters.add( CMQF_VoyageSummary.name );
	foreach class in subs do
		validFilters.add( class.name );
	endforeach;
	
	foreach qryRep in repAvailableDict discreteLock do
		if qryRep.jrwViewName &lt;&gt; "CM_VoyageView" then
			continue;
		endif;
		filterClassName :=  qryRep.filterClassName;
		if filterClassName = null or not validFilters.includes( filterClassName ) then
			continue;
		endif;
		_combo.itemObject[_combo.addItem(qryRep.reportName)] := qryRep;
	endforeach;
	
	if _selectedRepName &lt;&gt; null then
		_combo.listIndex := _combo.findStringExact(1,_selectedRepName);
	endif;

epilog

	delete repAvailableDict;
	delete validFilters;
	delete subs;
	delete iter;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_selectedRepName" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboXlationSystemCode" id="dc7e93cc-c1fa-4328-97c7-a28a20915825">
        <source>comboXlationSystemCode( _combo : CMUI_ComboBox input; _type : Integer; _terminal : CM_Terminal; _operator : CM_Operator; _cargoType : CM_CargoType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jan 2023	jlier1	Initial creation 56291
07 Jun 2023	jlika1	TFS 58320 58319 | Jade work for Translations
07 Jun 2023	navpw1	TFS: 57813 (58438) - Added System Codes for Sorting Methods Xlation Type
12 Jun 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
08 Nov 2023	jlika1	TFS 61129 61013 CUX | Cargo Priority - EDI Translation

*/

vars
	cargoSubTypes : CM_ProductByCargoTypeCodeDict;
	product : CM_Product;
	voyage : CM_Voyage;
	iter : Iterator;
	keyCode : String;
	codeFirst : Boolean;
	str : String;
	operTerm : CM_OperatorTerminal;
	oper : CM_Operator;
begin
	_combo.clear;
	
	if _type = XLATION_TYPE_CARGOTYPE_BYOP then
		_combo.listCollection(app.myRoot.allCargoTypesById, false, null);
	elseif _type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
		
		if _cargoType &lt;&gt; null then
			create cargoSubTypes transient;
			iter:=_cargoType.allProducts.createIterator;
			//get all the products with no operator
			while iter.next(product) do
				keyCode:=iter.getCurrentKey(1).String;	
				if keyCode &lt;&gt; null then
					break;
				endif;
				cargoSubTypes.add(product);
			endwhile;
			//get the ones just for the operator
			if _operator &lt;&gt; null then
				_cargoType.allProducts.startKeyGeq(_operator.code,null,iter);
				while iter.next(product) do
					keyCode:=iter.getCurrentKey(1).String;	
					if _operator &lt;&gt; null then
						if keyCode &lt;&gt; _operator.code then
							break;
						endif;
					endif;
					cargoSubTypes.add(product);
				endwhile;
			endif;
			
			_combo.listCollection(cargoSubTypes, false, null);
		endif;
	elseif _type = XLATION_TYPE_CARRIER_BYOP then
		_combo.listCollection(app.myRoot.allCarriers, false, null);
	
	elseif _type = XLATION_TYPE_COMMODITY_BYOP then
		_combo.listCollection (app.myRoot.allCommodities, false, null);
		
	elseif _type = XLATION_TYPE_CONSIGNEE_BYOP then
		_combo.listCollection (app.myRoot.allConsigneeConsignors, false, null);
			
	elseif _type = XLATION_TYPE_CUSTOMSAGENT then
		_combo.listCollection (app.myRoot.allCustomsAgents, false, null);
	
	elseif _type = XLATION_TYPE_INSTRUCTTERMINAL then
		if _terminal &lt;&gt; null then
			_combo.listCollection(_terminal.allInstructionTypes, false, null);
		endif;
		
	elseif _type = XLATION_TYPE_ISOTYPE_BYOP then
		_combo.listCollection (app.myRoot.allISOTypes, false, null);
		
	elseif _type = XLATION_TYPE_MTGRADE_BYOP then
		_combo.listCollection (app.myRoot.allAvailabilityGrades, false, null);
		
	elseif _type = XLATION_TYPE_OPERATOR or _type = XLATION_TYPE_OPERATOR_BYOP then
		_combo.listCollection (app.myRoot.allOperators, false, null);
		
	elseif _type = XLATION_TYPE_PORT_BYOP then
		_combo.listCollection (app.myRoot.allActiveDestinations, false, null);
		
	elseif _type = XLATION_TYPE_SHIPINGAGENT_BYOP then
		_combo.listCollection (app.myRoot.allShippingAgentsByCode, false, null);
		
	elseif _type = XLATION_TYPE_SHIPPINGLINE then
		_combo.listCollection (app.myRoot.allShippingLines, false, null);
		
	elseif _type = XLATION_TYPE_SHIPPINGLINE_BYOP then
		_combo.listCollection (app.myRoot.allShippingLines, false, null);
	// ### TFS 57813 (58438) 07Jun2023 NAVPW1
	elseif _type = XLATION_TYPE_SORTINGMETHD_BYOP then
		_combo.listCollection (app.myRoot.allSortingMethods, false, null);
	// ### TFS 57813 (58438) 07Jun2023 NAVPW1
	elseif _type = XLATION_TYPE_TERMINAL_BYOP then
		_combo.listCollection (app.myRoot.allTerminals, false, null);
		
	elseif _type = XLATION_TYPE_TRAILER_TYPE then
		_combo.listCollection (app.myRoot.allTILCTypes, false, null);
		
	elseif _type = XLATION_TYPE_VESSEL or _type = XLATION_TYPE_VESSEL_BYOP then	
		_combo.listCollection (app.myRoot.allVessels, false, null);
		
	elseif _type = XLATION_TYPE_VESSEL_TYPE then	//11 Sep 2018	NDL	TFS 40778
		_combo.listCollection (app.myRoot.allVesselTypes, false, null);
		
	elseif _type = XLATION_TYPE_VOYAGETERMINAL then
		if _terminal &lt;&gt; null then
			codeFirst:= app.myRoot.getConfig(EdiXlationDisplayOrder).Boolean;
			iter := _terminal.allVoyagesNew.createIterator;
	
			while iter.next(voyage) do 
				// do not display voyages that have departed before this time yesterday.
				if voyage.hasDepartedWithGracePeriod( -24 ) then
					continue;
				endif;
				
				if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
					continue;
				endif;
				
				keyCode:=iter.getCurrentKey(1).String;
							
				// keyCode could be voyage code or inwardCode
				if codeFirst then
					str := keyCode &amp; ' ['&amp; voyage.description.trimBlanks &amp; ']';
				else
					str := voyage.description.trimBlanks &amp; ' [' &amp; keyCode &amp; ']';
				endif;
				
				_combo.addItemObject (str, voyage);
			endwhile;
		endif;
		
	elseif _type = XLATION_TYPE_VEHICLE_MAKE then									// TFS 3734
		_combo.listCollection(app.myDutyDocRoot.allVehicleMakes, false, null);		// TFS 3734
	elseif _type = XLATION_TYPE_WORKPOINT then //epr TFS 42095 22/11/18
		if  _terminal &lt;&gt; null then
			_combo.listCollection(_terminal.allWorkPointsByCode,false,null);
		endif;
	elseif _type = XLATION_TYPE_COUNTRYTERMINAL then
		_combo.listCollection(app.myRoot.allCountries,false,null); //jlier1 TFS 54846 30/9/22
	elseif _type = XLATION_TYPE_CUSTPRIORITY_BYOP then
		_combo.listCollection(app.myRoot.allCustomerPriorities,false,null);
	elseif _type = XLATION_TYPE_OPERATOR_BYTERM then						//TFS 63842
		if _terminal &lt;&gt; null then											//TFS 63842
			iter := _terminal.allOperatorTerminals.createIterator;			//TFS 63842
			while iter.next(operTerm) do									//TFS 63842
				oper := operTerm.myOperator;								//TFS 63842
				_combo.itemObject[_combo.addItem(oper.code)] := oper;		//TFS 63842
			endwhile;														//TFS 63842
		endif;																//TFS 63842
	endif;																	//TFS 63842

epilog
	delete iter;
	delete cargoSubTypes;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="comboboxCommByCommGroup" id="5c2224a3-f4d6-4119-b9aa-587946270e6b">
        <source>comboboxCommByCommGroup(_cmb : ComboBox input; _commodityGroup : CM_CommodityGroup; _commodity : CM_Commodity);
// ---------------------------------------------------------------------------
// Created:     05 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _commodityGroup = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.sorted := false;
	_cmb.listCollection(_commodityGroup.allCommodities, true, 0);
	
	if _commodity &lt;&gt; null then
		_cmb.text := self.displayEntryCommodity(_commodity);
		_cmb.listObject := _commodity;
	endif;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_commodityGroup" type="CM_CommodityGroup"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="comboboxSysSubType" id="1e41e065-4e50-40f6-bbaf-40e3b88f9738">
        <updating/>
        <source>comboboxSysSubType(_product : CM_Product; _cargoType : CM_CargoType; _type : String; _combobox : CMUI_ComboBox io; _table : CM_EntryTable io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwmh5	Initial creation

*/

vars
	prodAttr 		: CM_ProductAttr;
	attributeCode	: CM_ProductAttributeCode;
	product			: CM_Product;
	
	str				: String;
	row 			: Integer;
begin
	
	product := _product;
	str := null	;
	
	// clear combobox
	_combobox.clear();
	_combobox.visible := false;

	// set the cargoType based on the object passed in
	if product = null then
		if _cargoType &lt;&gt; null then
			product := _cargoType.mySystemProductType;
		endif;
	endif;
	
	if product = null then
		return;
	endif;

	prodAttr := product.getProdAttrFromName(ETRow_MyType);
	str := _type;
	
	row := _table.getRowByName(ETRow_MyType);
		
	if prodAttr &lt;&gt; null and prodAttr.validationType = "Code" then
		if _type = "|~~NULL~~|" then
			str := null;
		endif;
		_table.accessCell(row, CM_EntryTable.ColumnValue).cellControl := _combobox;	
		_combobox.listCollection(product.myType.allCodes, true, ComboBox.DisplayCollection_Forward);
		attributeCode := product.myType.allCodes[str];
		if attributeCode &lt;&gt; null then
			str := attributeCode.code &amp; ' - ' &amp; attributeCode.description;
		endif;
	else
		_table.accessCell(row, CM_EntryTable.ColumnValue).cellControl := null;
		_table.accessedCell.inputType := CM_EntryTable.InputType_TextBox;
		if str = "|~~NULL~~|" then
			str := prodAttr.getDefaultValueString(ETRow_MyType);
		endif;
	endif;
	
epilog

	if _table &lt;&gt; null then
		_table.setValueByName(ETRow_MyType, str);
	endif;
	
end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_combobox" type="CMUI_ComboBox" usage="io"/>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="4d79d3ce-10cd-4af6-abd1-3a69acd63953">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     20 June 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 July 2022	navmd1		TFS 52777 Tidy up/review code
// ---------------------------------------------------------------------------
vars
	dict	: DynaDictionary;
	size	: Integer;
begin
	create self.allOtherTerminalAreas transient;
	
	self.consigneeConsignorCmbOrdDescr := app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean;
	self.portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	
	// TFS 52777 Hold a collection of either Weighbridges or Scan Readers by deviceId
	dict := self.allAssociatedDevices;
	
	dict.setMembership(CM_Object);
	
	size := CM_WeighBridgeObj::deviceId.length.max(CM_ScanReaderObj::deviceId.length) - 1;
	dict.addExternalKey(String, size, true, true);
	
	dict.endKeys(true);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="damageTableLostFocus" id="bd7b15b6-27eb-4755-82fc-22b70afd860b">
        <source>damageTableLostFocus(_table : CM_EntryTable input; _saveHeight : Real io; _tblDamage : CM_DamageEntryTbl input);
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	theRow,
	idx		: Integer;
	str		: String;
	obj		: Object;

begin
	theRow := _table.getRowByControlName(_tblDamage.name);

	if (theRow &gt;_table.fixedRows) and (theRow &lt;= _table.rows) then
		_table.accessRow(theRow).height := _saveHeight.Integer;
		_tblDamage.height := _saveHeight.Integer;
		_saveHeight := 0;		// set to 0 so that can use in pTable.cellInputReady;
		_table.scrollBars := Table.ScrollBars_Both;
		
		_table.setValue(theRow, _tblDamage.getLostFocusDescr());
	endif;
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_saveHeight" type="Real" usage="io"/>
        <Parameter name="_tblDamage" type="CM_DamageEntryTbl" usage="input"/>
    </JadeMethod>
