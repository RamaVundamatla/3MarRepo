    <PrimAttribute name="aError" id="498a328b-d72d-4e40-b850-aec439ff6d37">
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="aIsFormChanged" id="383a559c-82fa-4a4c-b001-903fd1420ee6">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="aObjectEdition" id="d03addc7-4e1d-49ff-9c21-38f28bef1d5a">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="cnEcAskToSaveChanges" id="5ea089b9-bf76-41f1-ab90-b44577687fdc">
        <source>cnEcAskToSaveChanges():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		27 March 2006 by cnwdad1
//
// Purpose:		Asks the user whether to save or discard unsaved changes.
//
// Parameters:	None
//
// Returns:		True if the changes should be saved, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userResponse	: Integer;
	
begin
	userResponse	:=	app.msgBox(	"You have unsaved changes that will be lost - do you wish to continue ?",
									self.caption &amp; " - Window Closing",
									MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
	
	if userResponse = MsgBox_Return_Yes then
		return true;
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsUnloadCheckUsed" id="3faec63c-9f40-4926-80f1-7f958d41be0b">
        <source>cnEcIsUnloadCheckUsed():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		27 March 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether or not to check for unsaved
//				changes when the form is closed.  By default, this is NOT used.
//
//				This method should be re-implemented where neccessary to use the
//				query unload checks.
//
// Parameters:	None
//
// Returns:		True if the unload check is used, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcResetFormChangedFlag" id="63ccd8f0-7c95-402d-95af-785c81c4dc91">
        <updating/>
        <source>cnEcResetFormChangedFlag() updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 March 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aIsFormChanged	:=	false;
	self.resetFirstChange();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="firstChange" id="33d4d64f-d07f-4610-8301-a53d5ac599b4">
        <controlMethod name="Form::firstChange"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>firstChange(cntrl: Control input) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.cnEcIsUnloadCheckUsed() then
		self.aIsFormChanged	:=	true;
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="d52832e0-bcfc-47f3-89c5-5dd141fbc6b0">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		23 November 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod(keyCode, shift);
	self.cnEcKeyDown(keyCode, shift);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="b2a24ccb-4129-4e64-9407-4ad823594af3">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		28 February 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.ignoreSkin	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="63e1e6ef-6bff-4810-bca5-472fd6c4f278">
        <controlMethod name="Form::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseDown(button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		20 February 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if shift.cnEcIsShiftKey() then
		self.cnEcShowControlForPos(x, y);
	endif;
end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="7bd5defb-280b-4352-bb3a-430d73e4f86d">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.cnEcIsUnloadCheckUsed() and self.aIsFormChanged then
		if not self.cnEcAskToSaveChanges() then
			cancel	:=	1;
		endif;
	endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resynchObjectAndSetEdition" id="c398e2c3-32ae-4f82-9170-25614398b317">
        <updating/>
        <source>resynchObjectAndSetEdition(pResynchObj:Object) updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 August 2001 by cnwdad2
//
// Purpose:		Resynchronizes the target object and stores its edition.
//
// Parameters:	pResynchObj - The object for which to resynch and store the edition.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
/*
	Use of "resynchObject" is preferable to "resynch" as it uses an object that
	is already	resident in cache (self) to resynchronize another object.  This
	is preferable to sending resynch to the object to be resynchronized, as if
	it is not in cache, it will have to be fetched from the server to dispatch
	the resynch method, whereupon it will be marked as obsolete.  If the object
	passed to resynchObject is not in cache, it does nothing.
*/
begin
	if pResynchObj = null then
		self.aObjectEdition	:=	0;
	else
		self.aObjectEdition	:=	pResynchObj.edition();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pResynchObj" type="Object"/>
    </JadeMethod>
</GUIClass>
