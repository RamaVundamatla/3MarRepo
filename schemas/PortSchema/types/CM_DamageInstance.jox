    <JadeMethod name="updateDamageLocationToDeleted" id="0988038d-19dc-4905-ba61-e237d963a6ee">
        <updating/>
        <source>updateDamageLocationToDeleted(_realTI : CM_TrackedItem) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 April 2019
TFS#		: 44287
Function	:

*** Changes ***
Date			Name		TFS#		Description
// 27/09/2023	navcs2		ChangeRequest 60695: EUP | FR 54536 - Damage and Repair - Transaction Changes
****************************************************/
vars
	damageLocation  : CM_DamageLocation;
	trackedItem	 	: CM_TrackedItem;
begin
	trackedItem := _realTI;
	if trackedItem &lt;&gt; null then
		//see if there is  an existing damage trx matching this one.
		damageLocation := self.myDamageLocationTrx;									// 27/09/2023	navcs2	ChangeRequest 60695
		if damageLocation &lt;&gt; null then
			damageLocation.setForDelete("User deleted the damage entry " &amp; self.getAuditText());
		endif;
	endif;
end;</source>
        <Parameter name="_realTI" type="CM_TrackedItem"/>
    </JadeMethod>
