<Class name="CM_YATypeRepairActivity" id="fe559bf1-b8ae-4cda-80b2-6f1c4f2d9043">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="d467a0ac-9289-416f-9de6-9892c0ac09a8">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
/*
Purpose - 	
Who - NAVAB1
Date - 14AUG2024
ADO - CR 65144 TASK 65396
*/

vars
	repairedReason : CM_RepairReason;
begin
	foreach repairedReason in _terminalObj.allRepairReasons do
		if not repairedReason.isNotAvalableForEntry then
			_allCriteriaValues.add(repairedReason);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="d9376a61-5e7b-4370-9471-b4137c488706">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
/*
Purpose - 	
Who - NAVAB1
Date - 14AUG2024
ADO - CR 65144 TASK 65396
*/


vars

begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
epilog

end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionWithData" id="049f8dc1-0af1-4f5d-854f-b3e38c0c32ff">
        <source>getDescriptionWithData(_dataObj: CM_YAData): String;
/*
Purpose - 	
Who - NAVAB1
Date - 14AUG2024
ADO - CR 65144 TASK 65396
*/


vars

begin
	return self.description &amp; ": " &amp; self.getDataDisplay(_dataObj);	
epilog

end;</source>
        <Parameter name="_dataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="669a38d6-0f7a-4ae7-af59-9038514f6caa">
        <source>getDisplay(dataObj: Object): String;
/*
Purpose - 	
Who - NAVAB1
Date - 14AUG2024
ADO - CR 65144 TASK 65396
*/


vars

begin
	return dataObj.CM_RepairReason.code;
epilog

end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="e2860a1c-a683-42e2-89fd-6612a4824607">
        <source>getObjects(objects: ObjectLongNameDict input);
/*
Purpose - 	
Who - NAVAB1
Date - 14AUG2024
ADO - CR 65144 TASK 65396
*/



vars
	repairreason: CM_RepairReason;
	terminal: CM_Terminal;
begin
	terminal	:=	app.getMyTerminalDO_NOT_USE;
	foreach repairreason in terminal.allRepairReasons do
		objects[repairreason.getYAIdentifier] := repairreason;
	endforeach;
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
