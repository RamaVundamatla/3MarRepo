    <JadeMethod name="tAddSatView" id="1ecf16d1-2b10-4e6c-b5fa-b6d68c282aa3">
        <source>tAddSatView();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2014	cnwma1	Initial creation

*/

constants
	SatViewName ="UT_SATView";
	NewSatName ="UT_SATUP";
vars
	proxyAreaView : CM_TerminalAreaView; 
	areaView : CM_TerminalAreaView;
begin
	
	self.deleteSatelliteView(NewSatName);
	create proxyAreaView transient;
	proxyAreaView.setTerminal(self.getTerminal);
	proxyAreaView.setName(SatViewName);

	
	app.myTrxCA.trxCreateTerminalAreaView(proxyAreaView, areaView, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Rename Satellite View
	app.myTrxUA.trxRenameTerminalAreaView(areaView,NewSatName,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(areaView.name,NewSatName);
	

		
	
epilog
	delete proxyAreaView;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAttachPhotoToTA" id="55f4e596-f816-476d-962f-6bab22086a25">
        <source>tAttachPhotoToTA() : CM_TerminalArea;
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456

Date		Who		Reason
20 Nov 2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars

	result: CM_Photo;
	photoDesc : String;
	photo : Binary;
	resourcesForm : PictureResourcesForm;
	
	blockStack: CM_BlockStack;
    thumbPhoto : Binary;                                        //MTN-36650
begin
	deleteTerminalArea("UT_PHOTO");
	blockStack := addBlockStack("UT_PHOTO", 99999999, null);
	assertTrueMsg(blockStack &lt;&gt; null, "Failed to add blockstack");
	assertEqualMsg(blockStack.maxCapacity,99999999, "Max capacity not 99999999");

	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	photo := resourcesForm.picExamplePhoto.picture;
	thumbPhoto  := self.createThumbnailContent(photo);          //MTN-36650
    
	result := self.addTerminalAreaPhoto(blockStack, photoDesc, photo);
	
	self.assertEqual(result.description, "a photo descrption for TerminalArea");
	self.assertEqual(result.getPhotoContent(), photo);
	self.assertEqual(result.getThumbnailContent(), thumbPhoto); //MTN-36650
	
	self.assertTrue(blockStack.allAttachments.size &gt; 0);
	self.assertTrue(blockStack.allAttachments.includes(result));
	self.assertTrue(blockStack.numAttachments(CM_Attachment.Type_Photo) = 1);
	
	return blockStack;
	
	
epilog
	delete resourcesForm;
	
end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="tAutoDirectRelease" id="e4a53823-0e91-4dc3-887a-9b350c3e2992">
        <source>tAutoDirectRelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2018	jlgndl1	Initial creation	TFS 38897

*/

vars

	ta : CM_TerminalAreaMaster;
	bs : CM_BlockStack;
	voyage : CM_Voyage;
	cont : CM_Container;
	rebar : CM_BreakBulkGeneric;
	splitRebar : CM_BreakBulkGeneric;
	transType : CM_TransactionType;

begin

	//Create a Block stack set up as a direct release area that auto releases as soon as the cargo is moved to it., and adds an extra 
	// user defined release transaction to the cargo as it goes off-site.

	//clean-up then setup
	self.autoDirectReleaseSetupCleanup( true, ta, voyage, transType );
	bs := ta.CM_BlockStack;
	
	if voyage.myShipBlockStack.allTrackedItems.first.isContainer then
		cont := voyage.myShipBlockStack.allTrackedItems.first.CM_Container;
		rebar := voyage.myShipBlockStack.allTrackedItems.last.CM_BreakBulkGeneric;
	else
		cont := voyage.myShipBlockStack.allTrackedItems.last.CM_Container;
		rebar := voyage.myShipBlockStack.allTrackedItems.first.CM_BreakBulkGeneric;
	endif;
	
	//plan both to the Direct Release Block Stack created above.
	self.movePlanned( cont, bs.myLocationsController );
	self.movePlanned( rebar, bs.myLocationsController );
	
	self.assertTrueMsg( not cont.allPlannedFutureMoves.isEmpty, "Container has not planned to the direct release area." );
	self.assertTrueMsg( not rebar.allPlannedFutureMoves.isEmpty, "Rebar has not planned to the direct release area." );
	
	self.opts.purge();
	self.opts.addAssoc( "SetWorkListEntry", cont.allWorklistEntries.first );
	self.opts.addAssoc( "NonCraneVoyageMove", true );
	self.move( cont, bs.myLocationsController );
	
	self.assertTrueMsg( cont.isOffSite, "Container is not offsite." );
	self.assertTrueMsg( cont.allTransactions.includesTrxType( transType.trxType ), "Container is missing its user defined release transaction." );
	self.assertTrueMsg( cont.allTransactions.includesTrxType( TRANS_TYPE_REL_ROAD ), "Container is missing its road release transaction." );
	self.assertTrueMsg( cont.myPrimaryActualLocation = null, "Container is not really offsite." );
	
	self.opts.purge();
	self.opts.addAssoc( "TotalQuantity", 5.Integer );
	self.opts.addAssoc( "SetWorkListEntry", rebar.allWorklistEntries.first );
	self.opts.addAssoc( "NonCraneVoyageMove", true );
	self.move( rebar, bs.myLocationsController );
	
	splitRebar := rebar.allSplitChildrenTis.first.CM_BreakBulkGeneric;
	self.assertTrueMsg( splitRebar &lt;&gt; null, "First 5 Rebar has not split off." );
	self.assertTrueMsg( splitRebar.isOffSite, "Split rebar is not offsite." );
	self.assertTrueMsg( splitRebar.allTransactions.includesTrxType( transType.trxType ), "Split Rebar is missing its user defined release transaction." );
	self.assertTrueMsg( splitRebar.allTransactions.includesTrxType( TRANS_TYPE_REL_ROAD ), "Split Rebar is missing its road release transaction." );
	self.assertTrueMsg( splitRebar.myPrimaryActualLocation = null, "Split rebar is not really offsite." );
	
	self.opts.purge();
	self.opts.addAssoc( "NonCraneVoyageMove", true );
	self.move( rebar, bs.myLocationsController );
	self.assertTrueMsg( rebar.isOffSite, "Rebar is not offsite." );
	self.assertTrueMsg( rebar.allTransactions.includesTrxType( transType.trxType ), "Rebar is missing its user defined release transaction." );
	self.assertTrueMsg( rebar.allTransactions.includesTrxType( TRANS_TYPE_REL_ROAD ), "Rebar is missing its road release transaction." );
	self.assertTrueMsg( rebar.myPrimaryActualLocation = null, "Rebar is not really offsite." );
	
	//clean-up only
	self.autoDirectReleaseSetupCleanup( false, ta, voyage, transType );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoReleaseRelReqAutoBBLK" id="51df271d-9641-4a29-b990-210fc813d490">
        <source>tAutoReleaseRelReqAutoBBLK();
/*
Purpose:	Cargo that is assigned to a release by ID release request, that is moved in real mode to a release transfer area that has auto release set to true, 
			are updated on the release request Items Delivered and other details.	
			Break bulk cargo that is split should update the assigned and delivered details on the release request.
			
			This test assigns all of the cargo to the release request and then moves it in 2 parts.

Date		Who		Reason
02NOV2021	NAVAB1	TFS 51936
*/
constants
	BLOCKSTACK = "UT_BSAB";
	AUTOREL =  "UT_AUTOAB";
	BBLK_1 = "BBLK2111011";
	BBLK_2 = "BBLK2111012";
	DEBTOR = "UT_DEBTOR_AB";
	OPERATOR = "UTAB";
	RELREQ = "UTRELAB-BBLK";
	CARGOTYPE = "UTABBB";
vars
	autorel, blockStack: CM_BlockStack;
	ti1, ti2, ti3 : CM_TrackedItem;
	operator : CM_Operator;
	debtor1		: CM_Debtor;
	tis : CM_TISet;
	relreq : CM_BulkRelease;
	ctype : CM_CargoType;
	voyage : CM_Voyage;
	deltodate : String;
begin

	
	self.deleteDebtor(DEBTOR);
	self.deleteOperator(OPERATOR);
	self.deleteCargo(BBLK_1, CARGOTYPE);
	self.deleteCargo(BBLK_2, CARGOTYPE);
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea(AUTOREL);
	
	self.opts.purge;
	self.opts.addAssoc("AllowDuplicateId", true);
	ctype := self.addCargoType(CARGOTYPE,false);

	debtor1 := self.addDebtor(DEBTOR, PaymentType_PostPay).CM_Debtor;
	self.assertNotNullMsg(debtor1,"Debtor Create Failed");
	
	operator := self.addOperator(OPERATOR, "Empty Pool Party Test Operator 1", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(operator,"Operator Create Failed");

	// Create a release transfer area that has auto release set to true
	autorel := self.addReleaseTransAreaAuto(AUTOREL).CM_BlockStack;
	assertTrueMsg(autorel &lt;&gt; null, "Failed to add auto release area " &amp; AUTOREL);
	assertEqualMsg(autorel.maxCapacity, 99, "Max capacity not 99");
	
	// Create a block stack
	blockStack := self.addBlockStack(BLOCKSTACK, 99, null).CM_BlockStack;
	assertTrueMsg(blockStack &lt;&gt; null, "Failed to add block stack " &amp; BLOCKSTACK);
	assertEqualMsg(blockStack.maxCapacity, 99, "Max capacity not 99");
	
	// Create some cargo move to the block stack
	voyage := self.getVoyage(NULL_VOYAGE_CODE);

	ti1 := self.addCargoBreakBulkAtLocation(BBLK_1, ctype, 1000, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(ti1 &lt;&gt; null, "'" &amp; BBLK_1 &amp; "' on site cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80);
	self.updateTI( ti1 );

	ti2 := self.addCargoBreakBulkAtLocation(BBLK_2, ctype, 1000, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(ti1 &lt;&gt; null, "'" &amp; BBLK_2 &amp; "' on site cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 160);
	self.updateTI( ti1 );
	
	
	// Create a road release request by ID and attach the containers
	create tis transient;
	tis.add(ti1);
	tis.add(ti2);
	
	
	self.opts.purge;
	self.opts.addAssoc("Operator", OPERATOR);
	self.opts.addAssoc("Voyage", ti1.myVoyage);
	self.opts.addAssoc("TotalRequested", 1000);
	
	relreq := self.addReleaseById(RELREQ, BR_TYPE_ROAD, tis);
	assertNotNullMsg(relreq, "Release Request no created!");
	self.assertTrueMsg(relreq.allTrackedItemsAssigned.includes(ti1), ti1.String &amp; " should be Assigned");	
	self.assertTrueMsg(relreq.allTrackedItemsAssigned.includes(ti2), ti2.String &amp; " should be Assigned");	
	self.assertTrueMsg(relreq.totalRequested = 2000, RELREQ &amp; " should be be for 2000");	
	
	
	// Move the cargo in 2 parts
	// Move 500 to the auto release transfer area
	self.opts.purge;
	self.opts.addAssoc("TotalQuantity", 500);
	move(ti1, autorel);
	
	// Check for a new TI created by the split
	ti3 := ti1.allSplitChildrenTis.first;
	self.assertTrueMsg(ti3 &lt;&gt; null, "Split move did not work");
	
	// Move rest (500) to the auto release transfer area
	move(ti1, autorel);
	
	
	// The auto release sends the TI offsite and should update it the release request as delivered.
	self.assertTrueMsg(ti1.isOffSite(),ti1.id.String &amp; " should be OFFSITE");
	self.assertTrueMsg(ti3.isOffSite(),ti3.id.String &amp; " should be OFFSITE");
	self.assertTrueMsg(relreq.allTrackedItemsReleased.includes(ti3), ti3.id &amp; " should be Delivered");	
	self.assertTrueMsg(relreq.allTrackedItemsReleased.includes(ti1), ti1.id &amp; " should be Assigned");	
	self.assertTrueMsg(relreq.allTrackedItemsAssigned.includes(ti2), ti2.id &amp; " should be Assigned");	
	self.assertTrueMsg(ti3.deliveryRelease = RELREQ, "Delivery Release should be " &amp; RELREQ);
	
	deltodate:= relreq.getTotalReleasedDisplay();
	assertTrueMsg(deltodate = "1000", "The quantity delivered on "&amp; RELREQ &amp; " Should be 1000");
	
	deltodate:= relreq.getTotalOutstandingDisplay();
	assertTrueMsg(deltodate = "1000", "The quantity outstanding on "&amp; RELREQ &amp; " Should be 1000, it is " &amp; deltodate);
	
	
epilog
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoReleaseRelReqAutoBBLKSPLT" id="a9ecac10-3718-490b-9051-ba28ee2ca58f">
        <source>tAutoReleaseRelReqAutoBBLKSPLT();
/*
Purpose:	Cargo that is assigned to a release by ID release request, that is moved in real mode to a release transfer area that has auto release set to true, 
			are updated on the release request Items Delivered and other details.	
			Break bulk cargo that is split should update the assigned and delivered details on the release request.
			
			This test assigns part of the cargo to the release request and then moves that amount in 2 parts.

Date		Who		Reason
04NOV2021	NAVAB1	TFS 52328
*/
constants
	BLOCKSTACK = "UT_BSAB";
	AUTOREL =  "UT_AUTOAB";
	BBLK_1 = "BBLK2111011";
	BBLK_2 = "BBLK2111012";
	DEBTOR = "UT_DEBTOR_AB";
	OPERATOR = "UTAB";
	RELREQ = "UTRELAB-BBLKS";
	CARGOTYPE = "UTABBB";
vars
	autorel, blockStack: CM_BlockStack;
	ti1, ti2, ti3, ti4 : CM_TrackedItem;
	operator : CM_Operator;
	debtor1		: CM_Debtor;
	tis : CM_TISet;
	relreq : CM_BulkRelease;
	ctype : CM_CargoType;
	voyage : CM_Voyage;
	deltodate : String;
begin

	
	self.deleteDebtor(DEBTOR);
	self.deleteOperator(OPERATOR);
	self.deleteCargo(BBLK_1, CARGOTYPE);
	self.deleteCargo(BBLK_2, CARGOTYPE);
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea(AUTOREL);
	
	self.opts.purge;
	self.opts.addAssoc("AllowDuplicateId", true);
	ctype := self.addCargoType(CARGOTYPE,false);

	debtor1 := self.addDebtor(DEBTOR, PaymentType_PostPay).CM_Debtor;
	self.assertNotNullMsg(debtor1,"Debtor Create Failed");
	
	operator := self.addOperator(OPERATOR, "Empty Pool Party Test Operator 1", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(operator,"Operator Create Failed");

	// Create a release transfer area that has auto release set to true
	autorel := self.addReleaseTransAreaAuto(AUTOREL).CM_BlockStack;
	assertTrueMsg(autorel &lt;&gt; null, "Failed to add auto release area " &amp; AUTOREL);
	assertEqualMsg(autorel.maxCapacity, 99, "Max capacity not 99");
	
	// Create a block stack
	blockStack := self.addBlockStack(BLOCKSTACK, 99, null).CM_BlockStack;
	assertTrueMsg(blockStack &lt;&gt; null, "Failed to add block stack " &amp; BLOCKSTACK);
	assertEqualMsg(blockStack.maxCapacity, 99, "Max capacity not 99");
	
	// Create some cargo move to the block stack
	voyage := self.getVoyage(NULL_VOYAGE_CODE);

	ti1 := self.addCargoBreakBulkAtLocation(BBLK_1, ctype, 1000, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(ti1 &lt;&gt; null, "'" &amp; BBLK_1 &amp; "' on site cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80);
	self.updateTI( ti1 );

	ti2 := self.addCargoBreakBulkAtLocation(BBLK_2, ctype, 1000, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(ti1 &lt;&gt; null, "'" &amp; BBLK_2 &amp; "' on site cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 160);
	self.updateTI( ti1 );
	
	
	// Create a road release request by ID and attach the containers
	create tis transient;
	tis.add(ti1);
	tis.add(ti2);
	
	
	self.opts.purge;
	self.opts.addAssoc("Operator", OPERATOR);
	self.opts.addAssoc("Voyage", ti1.myVoyage);
	
	// The cargo is 1000 each, but the release is for only 750 of each
	self.opts.addAssoc("TotalRequested", 750);
	
	relreq := self.addReleaseById(RELREQ, BR_TYPE_ROAD, tis);
	assertNotNullMsg(relreq, "Release Request no created!");
	self.assertTrueMsg(relreq.allTrackedItemsAssigned.includes(ti1), ti1.String &amp; " should be Assigned");	
	self.assertTrueMsg(relreq.allTrackedItemsAssigned.includes(ti2), ti2.String &amp; " should be Assigned");	
	self.assertTrueMsg(relreq.totalRequested = 1500, RELREQ &amp; " should be be for 1500");	
	
	
	// Move the cargo in 2 parts
	// Move 500 to the auto release transfer area
	self.opts.purge;
	self.opts.addAssoc("TotalQuantity", 500);
	move(ti1, autorel);
	
	// Check for a new TI created by the split
	ti3 := ti1.allSplitChildrenTis.first;
	self.assertTrueMsg(ti3 &lt;&gt; null, "First Split move did not work");
	
	// Move part of what is left (250) to the auto release transfer area
	self.opts.purge;
	self.opts.addAssoc("TotalQuantity", 250);
	move(ti1, autorel);
	// Check for a new TI created by the split
	ti4 := ti1.allSplitChildrenTis.last;
	self.assertTrueMsg(ti4 &lt;&gt; null, "Second Split move did not work");
	
	// The auto release sends the TI offsite and should update it the release request as delivered.
	self.assertTrueMsg(ti1.isOnSite(),ti1.id.String &amp; " should be ONSITE");
	self.assertTrueMsg(ti1.totalQuantity = 250,ti1.id.String &amp; " should have a quantity of 250");
	self.assertTrueMsg(ti3.isOffSite(),ti3.id.String &amp; " should be OFFSITE");
	self.assertTrueMsg(relreq.allTrackedItemsReleased.includes(ti3), ti3.id &amp; " should be Delivered");	
	self.assertTrueMsg(relreq.allTrackedItemsReleased.includes(ti4), ti4.id &amp; " should be Delivered");	
	self.assertTrueMsg(relreq.allTrackedItemsAssigned.includes(ti2), ti2.id &amp; " should be Assigned");	
	self.assertTrueMsg(ti3.deliveryRelease = RELREQ, "Delivery Release should be " &amp; RELREQ);
	
	deltodate:= relreq.getTotalReleasedDisplay();
	assertTrueMsg(deltodate = "750", "The quantity delivered on "&amp; RELREQ &amp; " Should be 750");
	
	deltodate:= relreq.getTotalOutstandingDisplay();
	assertTrueMsg(deltodate = "750", "The quantity outstanding on "&amp; RELREQ &amp; " Should be 750");
	
	
epilog
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoReleaseRelReqAutoCont" id="57c0a025-f268-47e7-9258-3153bf7c68b9">
        <source>tAutoReleaseRelReqAutoCont();
/*
Purpose:	Cargo that is assigned to a release by ID release request, that is moved in real mode to a release transfer area that has auto release set to true, 
			are updated on the release request Items Delivered and other details.		

Date		Who		Reason
02NOV2021	NAVAB1	TFS 51936
*/
constants
	BLOCKSTACK = "UT_BSAB";
	AUTOREL =  "UT_AUTOAB";
	CONT_ID1 = "WONU2111011";
	CONT_ID2 = "WONU2111012";
	DEBTOR = "UT_DEBTOR_AB";
	OPERATOR = "UTAB";
	RELREQ = "UTRELAB";
vars
	autorel, blockStack: CM_BlockStack;
	ti1, ti2 : CM_TrackedItem;
	operator : CM_Operator;
	debtor1		: CM_Debtor;
	tis : CM_TISet;
	relreq : CM_BulkRelease;
begin

	
	self.deleteDebtor(DEBTOR);
	self.deleteOperator(OPERATOR);
	self.deleteContainer(CONT_ID1);
	self.deleteContainer(CONT_ID2);
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea(AUTOREL);

	debtor1 := self.addDebtor(DEBTOR, PaymentType_PostPay).CM_Debtor;
	self.assertNotNullMsg(debtor1,"Debtor Create Failed");
	
	operator := self.addOperator(OPERATOR, "Empty Pool Party Test Operator 1", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(operator,"Operator Create Failed");

	// Create a release transfer area that has auto release set to true
	autorel := self.addReleaseTransAreaAuto(AUTOREL).CM_BlockStack;
	assertTrueMsg(autorel &lt;&gt; null, "Failed to add auto release area " &amp; AUTOREL);
	assertEqualMsg(autorel.maxCapacity, 99, "Max capacity not 99");
	
	// Create a block stack
	blockStack := self.addBlockStack(BLOCKSTACK, 99, null).CM_BlockStack;
	assertTrueMsg(blockStack &lt;&gt; null, "Failed to add block stack " &amp; BLOCKSTACK);
	assertEqualMsg(blockStack.maxCapacity, 99, "Max capacity not 99");
	
	// Create 2 containers move to the block stack
	ti1 := self.addContainerOpts(CONT_ID1, "2200", "APPL", operator);	
	ti2 := self.addContainerOpts(CONT_ID2, "2200", "APPL", operator);		
	move(ti1, blockStack);
	move(ti2, blockStack);
	
	
	// Create a road release request by ID and attach the containers
	create tis transient;
	tis.add(ti1);
	tis.add(ti2);
	
	
	self.opts.purge;
	self.opts.addAssoc("Operator", OPERATOR);
	self.opts.addAssoc("Voyage", ti1.myVoyage);
	
	relreq := self.addReleaseById(RELREQ, BR_TYPE_ROAD, tis);
	assertNotNullMsg(relreq, "Release Request no created!");
	self.assertTrueMsg(relreq.allTrackedItemsAssigned.includes(ti1), ti1.String &amp; " should be Assigned");	
	self.assertTrueMsg(relreq.allTrackedItemsAssigned.includes(ti2), ti2.String &amp; " should be Assigned");	
	
	// Move to the auto release transfer area
	move(ti1, autorel);
	
	
	// The auto release sends the TI offsite and shoudl update it the release request as delivered.
	self.assertTrueMsg(ti1.isOffSite(),ti1.id.String &amp; " should be OFFSITE");
	self.assertTrueMsg(relreq.allTrackedItemsReleased.includes(ti1), ti1.String &amp; " should be Delivered");	
	self.assertTrueMsg(relreq.allTrackedItemsAssigned.includes(ti2), ti2.String &amp; " should be Assigned");	
	self.assertTrueMsg(ti1.deliveryRelease = RELREQ, "Delivery Release shoudl be " &amp; RELREQ);

epilog
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRMGMaxHeightValidation" id="ffb26f5b-3fa4-4bb6-8749-2a8e9312c869">
        <updating/>
        <source>tCheckRMGMaxHeightValidation() updating;

/*

Purpose:		Test that for a RMG Area that validates over height correctly	

Parameters:			

Return Value:		


Date			Who		Reason
01 August 2011	cnwmh5	Initial creation

*/
constants
	
	RMGAreaId			: String = "UTMHRMGA1";
	ContainerId1		: String = "UTMHQR00001";
	ContainerId2		: String = "UTMHQR00002";
	ContainerId3		: String = "UTMHQR00003";
	ContainerId4		: String = "UTMHQR00004";
	ContainerId5		: String = "UTMHQR00005";
	YAId				: String = "UTMHYA3";
	
vars

	rmgArea				: CM_RTGArea;
	container1			: CM_Container;
	container2			: CM_Container;
	container3			: CM_Container;
	container4			: CM_Container;
	operator			: CM_Operator;
	lc					: CM_LocationsController;
	ya					: CM_YardAllocation;
	gate				: CM_Gate;
	
	locations			: CM_LCArray;
	
begin

	self.disableAllYA(true);
	
	// setup any default values
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	self.assertNotNull(gate);
	
	// create the rmg area
	self.opts.purge;
	self.opts.addAssoc("MaxHeight", 24.0);
	self.deleteTerminalArea(RMGAreaId);
	rmgArea := self.addRMGArea(RMGAreaId, 3, 3, 4);
	self.assertNotNull(rmgArea);
	
	// create a yard allocation for queuing of container3
	self.deleteYA(YAId);
	create locations transient;
	locations.add(rmgArea.allLocationsControllers.last.CM_YardController);
	ya := self.addYA1(YAId, null, null, locations);
	self.assertNotNull(ya);
	
	// ok lets create some containers. container4 should cause a max height error (85207)
	self.opts.purge;
	self.opts.addAssoc("IsForcedMove", false);
	lc := rmgArea.getLC("010001");
	
	self.deleteContainer(ContainerId1);
	container1 := self.addContainerAtLocation(ContainerId1, operator, "2200", "GENL", 3, lc);
	self.assertNotNull(container1);
	self.assertNoTrxErrorsOrWarnings();
	
	self.deleteContainer(ContainerId2);
	container2 := self.addContainerAtLocation(ContainerId2, operator, "2200", "GENL", 3, lc);
	self.assertNotNull(container2);
	self.assertNoTrxErrorsOrWarnings();
	
	self.deleteContainer(ContainerId3);
	container3 := self.addContainerAtLocation(ContainerId3, operator, "2200", "GENL", 3, lc);
	self.assertNotNull(container3);
	self.assertNoTrxErrorsOrWarnings();

	self.deleteContainer(ContainerId4);
	//self.expectTrxError(Move_FullReplacementText);
	self.expectTrxError(Locati_height_access_restri_fu);	//12 Sep 2012	NDL	Par 30346
	container4 := self.addContainerAtLocation(ContainerId4, operator, "2200", "GENL", 3, lc);
	self.assertNotNull(container4);
	//self.assertTrxError(Move_FullReplacementText);
	self.expectTrxError(Locati_height_access_restri_fu);	//12 Sep 2012	NDL	Par 30346
	
	// clear expected trx errors
	self.clearExpectedTrxErrors();
	
	// create container4 so we can queue / plan it
	self.deleteContainer(ContainerId4);
	lc := rmgArea.getLC("010002");
	container4 := self.addContainerAtLocation(ContainerId4, operator, "2200", "GENL", 3, lc);
	self.assertNotNull(container4);
	self.assertNoTrxErrorsOrWarnings();
		
	// right queue the containers.  container4 should cause a max height error (85027)
	lc := rmgArea.getLC("010003");
	
	self.moveQueued(container1, lc);
	self.moveQueued(container2, lc);
	self.moveQueued(container3, lc);
	//self.expectTrxError(Move_FullReplacementText);
	self.expectTrxError(Locati_height_access_restri_fu);	//12 Sep 2012	NDL	Par 30346
	self.moveQueued(container4, lc);
	//self.assertTrxError(Move_FullReplacementText);
	self.expectTrxError(Locati_height_access_restri_fu);	//12 Sep 2012	NDL	Par 30346
	
	self.clearExpectedTrxErrors();
		
	// right plan the containers.  container4 should cause a max height error (85027)
	self.unqueueTI(container1);
	self.unqueueTI(container2);
	self.unqueueTI(container3);
	self.unqueueTI(container4);
	
	self.movePlanned(container1, lc);
	self.movePlanned(container2, lc);
	self.movePlanned(container3, lc);
	//self.expectTrxError(Move_FullReplacementText);
	self.expectTrxError(Locati_height_access_restri_fu);	//12 Sep 2012	NDL	Par 30346
	self.movePlanned(container4, lc);
	//self.assertTrxError(Move_FullReplacementText);
	self.expectTrxError(Locati_height_access_restri_fu);	//12 Sep 2012	NDL	Par 30346
	
	self.clearExpectedTrxErrors();
	
	// ok time for mixed.  Physical, planned, queued, then queue container4.  Should cause a max height error (85027)
	self.unplanTI(container1);
	self.unplanTI(container2);
	self.unplanTI(container3);
	self.unplanTI(container4);
	
	lc := rmgArea.getLC("020001");
	self.move(container1, lc);
	self.moveQueued(container2, lc);
	self.movePlanned(container3, lc);
	
	//self.expectTrxError(Move_FullReplacementText);
	self.expectTrxError(Locati_height_access_restri_fu);	//12 Sep 2012	NDL	Par 30346
	self.moveQueued(container4, lc);
	//self.expectTrxError(Move_FullReplacementText);
	self.expectTrxError(Locati_height_access_restri_fu);	//12 Sep 2012	NDL	Par 30346
	self.movePlanned(container4, lc);
	//self.assertTrxError(Move_FullReplacementText);
	self.expectTrxError(Locati_height_access_restri_fu);	//12 Sep 2012	NDL	Par 30346
	
	self.clearExpectedTrxErrors();
	
epilog

	self.deleteYA(YAId);
	self.disableAllYA(false);

	delete locations;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTAMachineProxy" id="1ab6e75c-2c62-4bba-8186-bb7bdf87ad49">
        <source>tCheckTAMachineProxy();
// jlgmd1
/*	cnwkpd1

Purpose:			Check proxy code for Terminal Areas with Machines allowed

Date		Who		Reason
23 Apr 2012	cnwkpd1	PAR #29471 - Problem with leaked proxies for a Terminal Area

*/

constants
	StraddleId		= "UTS2";
	QueueId			= "UTQ1";
	
vars
	bs1, 
	bs2,
	pxyBS			: CM_BlockStack;
	q1				: CM_RadioTelemetryQueue;
	straddle		: CM_Machine;
	tas				: StringArray;
	ls				: Boolean;
	
begin
	// Create new bloackstacks
	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"X", 100, null);
	bs2 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"Y", 100, null);

	// Set up machine rule between them to be Straddle
	self.addMachineRule(bs1, bs2, RTMoveMethod_23);
	
	// Create RT Queue for Blockstack
	q1 := self.addQueue(QueueId, bs2, null, false);

	// Create straddle to allow in the areas
	create tas transient;
	tas.add(bs1.id);
	tas.add(bs2.id);
	
	opts.addAssoc("WeightDifference", 500);
	opts.addAssoc("WeightMaxLift", 20000);
	straddle := self.addStraddleTwin(StraddleId, 92, tas, q1.id);
	
	// Check that there is no proxy hanging around for the Machine
	self.assertNull(app.myProxyManager.getProxyObject(straddle));

	// Now proxy the TA
	app.cmsBeginLoad(ls);
	pxyBS := bs1.pxyCreateUpdateProxy();
	app.cmsEndLoad(ls);
	
	// Delete the proxy, then check the Machine proxy has gone (if one was actually created)
	delete pxyBS;
	
	self.assertNull(app.myProxyManager.getProxyObject(straddle));
	
	// Unit Test Leak Check will also find any leaked proxies, which is also a valid test
			
epilog
	delete tas;
	delete pxyBS;
	app.cmsEndLoad(ls);
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCheckTAUtilizationRORO" id="ce50f671-edc3-4f85-9214-95986a10115d">
        <source>tCheckTAUtilizationRORO();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2025	navkc1 JIRA 35624 MSL | Terminal Utilization RoRo - Unit Tests

*/

constants
	RoroLaneID		= "UTROROUTIL1";
	CARSID			= "UTROROCAR";
	TRUCKID			= "UTROROT";
	CGTYPE			= "UTROROCAR1";
vars
	
	roroLane		: CM_RoRoLaneArea;
	terminalArea	: CM_TerminalArea;
	ti				: CM_TrackedItem;
	cargoType		: CM_CargoType;
	totalItemsSum,
	totalItems,
	num				: Integer;
	expectedSummary,
	expected1,
	expected2,
	expected3,
	actualSummary,
	actual1,
	actual2,
	actual3,
	tiid			: String;
	vvr				: CM_VehicleVisitRecord;
	allTis			: CM_TISet;
	qryAgent		: CMIF_SpaceUtilisationQryAgent;
	term			: CM_Terminal;
	summaryTA,
	kpiTA			: CM_KPITerminalArea;
	lc,
	firstLC,
	secondLC,
	thirdLC				: CM_LocationsController;
	emptyLength,
	emptyLengthSum,
	occupiedLength,
	occupiedLengthSum,
	fullLength,
	fullLengthSum,
	carLength,
	capacityTotalLengthSum,
	capacityTotalLength,
	capacityUsedLengthSum,
	capacityUsedLength,
	totalTILengthSum,
	totalTILength		: Decimal[16,4];
	emptyLengthSumPC,
	emptyLengthPC,
	capacityLengthSumPC,
	capacityLengthPC,
	occupiedLengthSumPC,
	occupiedLengthPC,
	fullLengthSumPC,
	fullLengthPC		: Decimal[12,0];
	
begin
	//return;
	
	/* ===========================
	Set up data - Terminal Area
	==============================*/
	
		terminalArea := self.getTerminalArea(RoroLaneID);
		
		if terminalArea &lt;&gt; null then
			self.deleteTerminalArea(RoroLaneID);
		endif;
		
		roroLane := self.addROROArea(RoroLaneID, 3, 500);
		
		self.assertNotNullMsg(roroLane, "Failed to create RoRo Lane");
	
	/* ===========================
	Get Locations controllers
	==============================*/
	
		num := null;
		foreach lc in roroLane.allLocationsControllers do
			num += 1;
			
			if num = 1 then
				firstLC := lc;
			elseif num = 2 then
				secondLC := lc;
			elseif num = 3 then
				thirdLC := lc;
			endif;
		endforeach;
	
	/* ===========================
	Get Terminal
	==============================*/
	
		term := self.getMyTerminal();
	
	/* ===========================
	Create Cargo Type
	==============================*/
		self.opts.purge();
		self.opts.addAssoc("TrackAs", ProductType_Vehicle);
		cargoType := self.addCargoType(CGTYPE, false);
	
	
	/* ===========================
	Get in Cars
	==============================*/
	
		create allTis transient;
		carLength := 50; // in M
		foreach num in 1 to 3 do
			self.deleteVehicle(TRUCKID);
			
			tiid := CARSID &amp; num.String;
			
			self.deleteTrackedItem(tiid, true);
			
			vvr := self.gateInGC(TRUCKID, null, TRUCKID, tiid, cargoType.abbreviation, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), null, self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()),1);
			self.workVehicle(vvr);
			
			ti := self.getTrackedItem(tiid);
			if num = 1 or num = 2 then
				beginTransaction;
					ti.setLength(carLength*100); // in CM
				commitTransaction;
				
				self.moveCargo(ti, null, firstLC, app.myPassport);
			elseif num = 3 then
				
				beginTransaction;
					ti.setLength(carLength*100); // in CM
				commitTransaction;
				
				self.moveCargo(ti, null, secondLC, app.myPassport);
			endif;
			self.roadExit(vvr);
		endforeach;
	
	/* ===========================
	Do Query on Terminal Space
	==============================*/
	
		create qryAgent transient;
		qryAgent.init();
		qryAgent.myTerminal := term;
		qryAgent.setAgentsBooleans(true, false, false, false, false, false, false, true, true, false, false);
		qryAgent.allQryCargoTypes.add(cargoType);
		qryAgent.allQryTerminalAreas.add(roroLane);
		qryAgent.doQuery();
	
	
	/* ===========================
	Test the number of locations we have
	We have a RORO Lane Area with 3 lanes. 
	Each lanes should have it's own location, hence expecting 3
	==============================*/
	
		self.assertTrueMsg(qryAgent.allKPITerminalAreas.size() = 3, "Should have 3 items, 1 for each roro lanes");
	
	/* ===========================
	Get the actual output
	==============================*/
		num := null;
		
		// We need a Summary line too
		create summaryTA transient;
		summaryTA.clearSummaryData(app.getErrorString(Summary));
		
		foreach kpiTA in qryAgent.allKPITerminalAreas as CM_KPITerminalArea do
			num += 1;
			
			if num = 1 then
				actual1 := kpiTA.getDisplayLine();
			elseif num = 2 then
				actual2 := kpiTA.getDisplayLine();
			elseif num = 3 then
				actual3 := kpiTA.getDisplayLine();
			endif;
			
			// Add it to Summary line
			summaryTA.addToSummaryLine(kpiTA, true);
		endforeach;
		
		actualSummary := summaryTA.getDisplayLineSummaryRORO();
		
	/* ===========================
	Test Actual VS Expected output for Lane 1
	Lane is 500m long
	Here we have 2 cars in the lane
	Each car is 50m length
	==============================*/
	
		capacityTotalLength := 500.00;
		capacityTotalLengthSum += capacityTotalLength;
		
		totalItems := firstLC.numTIs;
		totalItemsSum += totalItems;
		
		totalTILength := totalItems * carLength;
		totalTILengthSum += totalTILength;
		
		emptyLength := capacityTotalLength - totalTILength;
		emptyLengthSum += emptyLength;
		
		emptyLengthPC := ((emptyLength / capacityTotalLength) * 100).roundedTo(2);
		
		occupiedLength := totalTILength;
		occupiedLengthSum += occupiedLength;
		
		occupiedLengthPC := ((occupiedLength / capacityTotalLength) * 100).roundedTo(2);
		
		fullLength := totalTILength;
		fullLengthSum += fullLength;
		
		fullLengthPC := ((fullLength / capacityTotalLength) * 100).roundedTo(2);
		
		capacityUsedLength := totalTILength;
		capacityUsedLengthSum += capacityUsedLength;
		
		capacityLengthPC := ((totalTILength/capacityTotalLength) * 100).roundedTo(2);
		
		expected1 := firstLC.getFullId() &amp; Tab &amp; totalItems.asStringJMT() &amp; Tab &amp; totalTILength.asStringJMT() &amp; Tab &amp; emptyLength.asStringJMT() &amp; Tab &amp; emptyLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; occupiedLength.asStringJMT() &amp; Tab &amp; occupiedLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; fullLength.asStringJMT() &amp; Tab &amp; fullLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp;  capacityUsedLength.asStringJMT() &amp; Tab &amp; capacityTotalLength.asStringJMT() &amp; Tab &amp; capacityLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; "66";
		self.assertTrueMsg(actual1 = expected1, "Actual 1 and Expected 1 should be the same." &amp; CrLf &amp; "Actual 1: " &amp; actual1 &amp; CrLf &amp; "Expected 1:" &amp; expected1);
		
	/* ===========================
	Test Actual VS Expected output for Lane 2
	Lane is 500m long
	Here we have 1 cars in the lane
	Each car is 50m length
	==============================*/
		capacityTotalLength := 500.00;
		capacityTotalLengthSum += capacityTotalLength;
		
		totalItems := secondLC.numTIs;
		totalItemsSum += totalItems;
		
		totalTILength := totalItems * carLength;
		totalTILengthSum += totalTILength;
		
		emptyLength := capacityTotalLength - totalTILength;
		emptyLengthSum += emptyLength;
		
		emptyLengthPC := ((emptyLength / capacityTotalLength) * 100).roundedTo(2);
		
		occupiedLength := totalTILength;
		occupiedLengthSum += occupiedLength;
		
		occupiedLengthPC := ((occupiedLength / capacityTotalLength) * 100).roundedTo(2);
		
		fullLength := totalTILength;
		fullLengthSum += fullLength;
		
		fullLengthPC := ((fullLength / capacityTotalLength) * 100).roundedTo(2);
		
		capacityUsedLength := totalTILength;
		capacityUsedLengthSum += capacityUsedLength;
		
		capacityLengthPC := ((totalTILength/capacityTotalLength) * 100).roundedTo(2);
		
		expected2 := secondLC.getFullId() &amp; Tab &amp; totalItems.asStringJMT() &amp; Tab &amp; totalTILength.asStringJMT() &amp; Tab &amp; emptyLength.asStringJMT() &amp; Tab &amp; emptyLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; occupiedLength.asStringJMT() &amp; Tab &amp; occupiedLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; fullLength.asStringJMT() &amp; Tab &amp; fullLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp;  capacityUsedLength.asStringJMT() &amp; Tab &amp; capacityTotalLength.asStringJMT() &amp; Tab &amp; capacityLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; "74";
		self.assertTrueMsg(actual2 = expected2, "Actual 2 and Expected 2 should be the same." &amp; CrLf &amp; "Actual 2: " &amp; actual2 &amp; CrLf &amp; "Expected 2: " &amp; expected2);
		
	/* ===========================
	Test Actual VS Expected output for Lane 3
	Lane is 500m long
	Here we have 0 cars in the lane
	==============================*/
		capacityTotalLength := 500.00;
		capacityTotalLengthSum += capacityTotalLength;
		
		totalItems := thirdLC.numTIs;
		totalItemsSum += totalItems;
		
		totalTILength := totalItems * carLength;
		totalTILengthSum += totalTILength;
		
		emptyLength := capacityTotalLength - totalTILength;
		emptyLengthSum += emptyLength;
		
		emptyLengthPC := ((emptyLength / capacityTotalLength) * 100).roundedTo(2);
		
		occupiedLength := totalTILength;
		occupiedLengthSum += occupiedLength;
		
		occupiedLengthPC := ((occupiedLength / capacityTotalLength) * 100).roundedTo(2);
		
		fullLength := totalTILength;
		fullLengthSum += fullLength;
		
		fullLengthPC := ((fullLength / capacityTotalLength) * 100).roundedTo(2);
		
		capacityUsedLength := totalTILength;
		capacityUsedLengthSum += capacityUsedLength;
		
		capacityLengthPC := ((totalTILength/capacityTotalLength) * 100).roundedTo(2);
		
		expected3 := thirdLC.getFullId() &amp; Tab &amp; totalItems.asStringJMT() &amp; Tab &amp; totalTILength.asStringJMT() &amp; Tab &amp; emptyLength.asStringJMT() &amp; Tab &amp; emptyLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; occupiedLength.asStringJMT() &amp; Tab &amp; occupiedLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; fullLength.asStringJMT() &amp; Tab &amp; fullLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp;  capacityUsedLength.asStringJMT() &amp; Tab &amp; capacityTotalLength.asStringJMT() &amp; Tab &amp; capacityLengthPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; "82";
		self.assertTrueMsg(actual3 = expected3, "Actual 3 and Expected 3 should be the same." &amp; CrLf &amp; "Actual 3: " &amp; actual3 &amp; CrLf &amp; "Expected 3:" &amp; expected3);
		
	/* ===========================
	Test Summary line
	==============================*/
		
		emptyLengthSumPC := ((emptyLengthSum / capacityTotalLengthSum) * 100).roundedTo(2);
		occupiedLengthSumPC := ((occupiedLengthSum / capacityTotalLengthSum) * 100).roundedTo(2);
		fullLengthSumPC := ((fullLengthSum / capacityTotalLengthSum) * 100).roundedTo(2);
		capacityLengthSumPC := ((totalTILengthSum/capacityTotalLengthSum) * 100).roundedTo(2);
		
		expectedSummary := app.getErrorString(Summary) &amp; Tab &amp; totalItemsSum.asStringJMT() &amp; Tab &amp; totalTILengthSum.asStringJMT() &amp; Tab &amp; emptyLengthSum.asStringJMT() &amp; Tab &amp; emptyLengthSumPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; occupiedLengthSum.asStringJMT() &amp; Tab &amp; occupiedLengthSumPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; fullLengthSum.asStringJMT() &amp; Tab &amp; fullLengthSumPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp;  capacityUsedLengthSum.asStringJMT() &amp; Tab &amp; capacityTotalLengthSum.asStringJMT() &amp; Tab &amp; capacityLengthSumPC.asStringJMTWithPrecision(2, false) &amp; Tab &amp; "222";
		self.assertTrueMsg(actualSummary = expectedSummary, "Actual Summary and Expected Summary should be the same." &amp; CrLf &amp; "Actual Summary: " &amp; actualSummary &amp; CrLf &amp; "Expected Summary:" &amp; expectedSummary);
epilog
	
	if roroLane &lt;&gt; null then
		self.deleteTerminalArea(RoroLaneID);
	endif;
	
	if allTis &lt;&gt; null then
		foreach ti in allTis do
			self.deleteTrackedItem(ti.id, true);
		endforeach;
		
		delete allTis;
	endif;
	
	delete summaryTA;
	delete qryAgent;
	
	self.deleteCargoType(CGTYPE);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTerminalAreaId" id="f809fb77-eb02-4302-ad12-fd8f94d1a238">
        <source>tCheckTerminalAreaId();
// cnwns1
// Feb 2014 cnwjre1
//	test 33418 change of terminal area id, validation and processing
vars
	blockStack,
	blockStack2,
	blockStack3	: CM_BlockStack;
begin
	// create a block stack
	blockStack := self.addBlockStack("UT_BLKST", 5, null);
	assertTrueMsg(blockStack &lt;&gt; null, "Failed to add blockstack");
	assertEqualMsg(blockStack.maxCapacity, 5, "Max capacity not 5");
	
	// update it, the id should not be checked
	self.updateBlockStack(blockStack, 10);
	
	// update it with id change
	self.deleteTerminalArea("UT_BXXST");
	self.opts.addAssoc("Id", "UT_BXXST");
	self.updateBlockStack(blockStack, 10);
	
	self.assertEqualMsg(blockStack.id, "UT_BXXST", "Changed block stack id");
	self.assertEqualMsg(blockStack.swapStack.id, "SWAP_UT_BXXST", "Changed swap stack id");
	self.assertEqualMsg(blockStack.myLocationsController.ident, "UT_BXXST", "Changed location controller id");
	
	// change it back
	self.opts.purge();
	self.opts.addAssoc("Id", "UT_BLKST");
	self.updateBlockStack(blockStack, 5);
	self.assertEqualMsg(blockStack.id, "UT_BLKST", "Changed block stack id 2");
	self.assertEqualMsg(blockStack.swapStack.id, "SWAP_UT_BLKST", "Changed swap stack id 2");
	self.assertEqualMsg(blockStack.myLocationsController.ident, "UT_BLKST", "Changed location controller id 2");
	
	// create a conflicting block stack UT_BXXST
	blockStack2 := self.addBlockStack("UT_BXXST", 5, null);
	assertTrueMsg(blockStack2 &lt;&gt; null, "Failed to add blockstack 2");

	self.expectTrxError(ERR_INVALID_VALUE);
	// update it with id change which should now error
	self.opts.addAssoc("Id", "UT_BXXST");
	self.updateBlockStack(blockStack, 10);
	
	self.expectedTrxErrors.clear();
	self.expectTrxError(ERR_INVALID_CHARACTERS);
	// add and change with invalid characters
	blockStack3 := self.addBlockStack("UT_*&amp;KST", 5, null);
	self.opts.purge();
	self.opts.addAssoc("Id", "UT_!@KST");
	self.updateBlockStack(blockStack, 5);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTerminalAreaInUse" id="35923659-cda3-4614-bcab-c3c7f396ecd7">
        <source>tCheckTerminalAreaInUse();

/*

Purpose:		Check if a terminal area is in use

Date			Who		Reason
09/04/2014		cnwmh5	Initial creation

*/

vars

	ta							: CM_GridArea;
	ta1							: CM_GridArea;
	pxyTA						: CM_GridArea;
	cmifTA						: CMIF_TerminalArea;
	taMaster					: CM_Object;
	taType						: CM_TerminalAreaType;
	
	loadState					: Boolean;

begin

	ta1 := self.addStraddleStack("UTMHSSG", 5, 5, 3);
	self.assertNotNull(ta1);

	ta := self.addStraddleStack("UTMHSSH", 5, 5, 3);
	self.assertNotNull(ta);
	
	taType := ta.myType;
	create taMaster as taType.getTAClassToCreate transient;
	
	app.cmsBeginLoad(loadState);
	pxyTA := ta.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	pxyTA.setGridAreaProxy(ta1.id, ta.comment, ta.myType.type, ta.numberOfRows, ta.numberOfColumns, ta.heightOfStack, 
		ta.actAsReleasePoint.Boolean, ta.myTerminal, ta.autoRestrictionsEnabled, ta.isStockControlled, ta.hideFromOverView, 
		ta.defaultDeckingStartType, ta.noAccessLeft, ta.noAccessRight, ta.isSnapToBackend, ta.isAlignRight, ta.isSnapStrictGrid, 
		ta.allAssociatedInterchangeAreas, ta.myDefaultInterchangeArea, ta.use40ftIds, ta.useSideAccessRules, 
		ta.leftLabel, ta.rightLabel, ta.topLabel, ta.bottomLabel);
	
	create cmifTA as CMIF_GridArea transient;
	cmifTA.myPxyTerminalArea		:= pxyTA;
	cmifTA.myTerminal 				:= self.getTerminal();
	cmifTA.taType 					:= pxyTA.myType.type;
	cmifTA.myPxyTerminalAreaMaster	:= taMaster.CM_TerminalAreaMaster;
	cmifTA.myTerminalAreaMaster 	:= cmifTA.myPxyTerminalAreaMaster.pxyGetRealObject;
	cmifTA.id 						:= pxyTA.id;
	cmifTA.stockControlled 			:= pxyTA.isStockControlled;
	cmifTA.actAsReleasePoint  		:= pxyTA.actAsReleasePoint.Boolean;
	cmifTA.comment 					:= pxyTA.comment;
	cmifTA.hideFromOverview			:= pxyTA.hideFromOverView;
	cmifTA.autoRestrictionsEnabled 	:= pxyTA.autoRestrictionsEnabled;
	///cmifTA.deckingOption 		:= self.cmbRowDir.getCurrentItemData();
	cmifTA.height					:= pxyTA.heightOfStack;
	cmifTA.numRows 					:= pxyTA.numberOfRows;
	cmifTA.numColumns				:= pxyTA.numberOfColumns;
	cmifTA.colour 					:= ta.myLayoutGraphic.fillColour;
	cmifTA.CMIF_GridArea.use40ftIds	:= pxyTA.use40ftIds;

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(ERR_INVALID_VALUE);
	app.myTrxUA.trxUpdateTerminalAreaInUse(cmifTA, DeckingLevel_Null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	app.cmsEndLoad(loadState);
	
	delete pxyTA;
	delete cmifTA;
	delete taMaster;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckUse40ftIdsCreated" id="c720435a-a10b-44b3-8049-456d3924b0c8">
        <source>tCheckUse40ftIdsCreated();

/*

Purpose:		Checks to see that if use40ftIds then the location controller id40ft is created correctly.

Parameters:			

Return Value:		


Date			Who		Reason
26 August 2011	cnwmh5	Initial creation

*/
constants
	
	RTGAreaId				: String = "UTMHRTG1";
	RMGAreaId				: String = "UTMHRMG1";
	GriddedBlockStackId		: String = "UTMHGBS1";
	StraddleStackId			: String = "UTMHSS1";

vars

	rtgArea					: CM_RTGArea;
	rmgArea					: CM_RTGArea;
	gbs						: CM_ForkLiftStack;
	straddleStack			: CM_StraddleStack;
	lc						: CM_LocationsController;

	failingLC				: HugeStringArray;
	
	str						: String;
	str2					: String;
	
begin

	// set the opts
	self.opts.purge;
	self.opts.addAssoc("use40ftIds", true);
	
	create failingLC transient;
	
	// create the rtg area
	self.deleteTerminalArea(RTGAreaId);
	rtgArea := self.addRTGArea(RTGAreaId, 3, 5, 4);
	self.assertNotNull(rtgArea);

	failingLC.clear();
	if rtgArea.use40ftIds then
		foreach lc in rtgArea.allLocationsControllers do
			if lc.isKindOf(CM_GridController) then
				if lc.CM_GridController.id40ft = null then
					failingLC.add(rtgArea.String &amp; Tab &amp; rtgArea.id &amp; Tab &amp; lc.CM_GridController.name &amp; Tab &amp; 
						lc.CM_GridController.ident &amp; Tab &amp; lc.CM_GridController.row.String &amp; Tab &amp; 
						lc.CM_GridController.column.String);
				endif;
			endif;
		endforeach;
		
		str2 := null;
		foreach str in failingLC do
			str2 := str2 &amp; str &amp; CrLf;		
		endforeach;
		
		if str2 &lt;&gt; null then
			app.writeStatement(str2);
		endif;
		
		self.assertNull(str2);
	endif;
	
	// create the rmg area
	self.deleteTerminalArea(RMGAreaId);
	rmgArea := self.addRTGArea(RMGAreaId, 3, 5, 4);
	self.assertNotNull(rmgArea);

	failingLC.clear();
	if rmgArea.use40ftIds then
		foreach lc in rmgArea.allLocationsControllers do
			if lc.isKindOf(CM_GridController) then
				if lc.CM_GridController.id40ft = null then
					failingLC.add(rmgArea.String &amp; Tab &amp; rmgArea.id &amp; Tab &amp; lc.CM_GridController.name &amp; Tab &amp; 
						lc.CM_GridController.ident &amp; Tab &amp; lc.CM_GridController.row.String &amp; Tab &amp; 
						lc.CM_GridController.column.String);
				endif;
			endif;
		endforeach;
		
		str2 := null;
		foreach str in failingLC do
			str2 := str2 &amp; str &amp; CrLf;		
		endforeach;
		
		if str2 &lt;&gt; null then
			app.writeStatement(str2);
		endif;
		
		self.assertNull(str2);
	endif;
	
	// create the gridded block stack area
	self.deleteTerminalArea(GriddedBlockStackId);
	gbs := self.addForkLiftStack(GriddedBlockStackId, 3, 5, 4);
	self.assertNotNull(gbs);

	failingLC.clear();
	if gbs.use40ftIds then
		foreach lc in gbs.allLocationsControllers do
			if lc.isKindOf(CM_GridController) then
				if lc.CM_GridController.id40ft = null then
					failingLC.add(gbs.String &amp; Tab &amp; gbs.id &amp; Tab &amp; lc.CM_GridController.name &amp; Tab &amp; 
						lc.CM_GridController.ident &amp; Tab &amp; lc.CM_GridController.row.String &amp; Tab &amp; 
						lc.CM_GridController.column.String);
				endif;
			endif;
		endforeach;
		
		str2 := null;
		foreach str in failingLC do
			str2 := str2 &amp; str &amp; CrLf;		
		endforeach;
		
		if str2 &lt;&gt; null then
			app.writeStatement(str2);
		endif;
		
		self.assertNull(str2);
	endif;
	
	// create the straddle stack area
	self.deleteTerminalArea(StraddleStackId);
	straddleStack := self.addStraddleStack(StraddleStackId, 3, 5, 4);
	self.assertNotNull(straddleStack);

	failingLC.clear();
	if straddleStack.use40ftIds then
		foreach lc in straddleStack.allLocationsControllers do
			if lc.isKindOf(CM_GridController) then
				if lc.CM_GridController.id40ft = null then
					failingLC.add(straddleStack.String &amp; Tab &amp;straddleStack.id &amp; Tab &amp; lc.CM_GridController.name &amp; Tab &amp; 
						lc.CM_GridController.ident &amp; Tab &amp; lc.CM_GridController.row.String &amp; Tab &amp; 
						lc.CM_GridController.column.String);
				endif;
			endif;
		endforeach;
		
		str2 := null;
		foreach str in failingLC do
			str2 := str2 &amp; str &amp; CrLf;		
		endforeach;
		
		if str2 &lt;&gt; null then
			app.writeStatement(str2);
		endif;
		
		self.assertNull(str2);
	endif;
	
	
epilog

	delete failingLC;

end;</source>
    </JadeMethod>
    <JadeMethod name="tChkLabRestrcitionReason" id="e451056b-b006-4c53-a2fc-b41f1649485a">
        <source>tChkLabRestrcitionReason();

/*

Purpose:		Create a labour restriction that has no Reason

Date			Who		Reason
16 August 2011	cnwmh5	Initial creation

*/
constants

	ForkLiftStackId			: String = "UTMDHGBS1";
	LabourRestrictionId1	: String = "UTMDHLR1";
	LabourRestrictionId2	: String = "UTMDHLR2";
	
vars

	gbs						: CM_ForkLiftStack;
	pxyLabRestriction1		: CM_LabourRestriction;
	pxyLabRestriction2		: CM_LabourRestriction;
	labourRestriction		: CM_LabourRestriction;
		
	lcArray					: CM_LCArray;

begin
	
	self.deleteTerminalArea(ForkLiftStackId);
	gbs := self.addForkLiftStack(ForkLiftStackId, 3, 4, 4);
	self.assertNotNull(gbs);
	
	create lcArray transient;
	gbs.allLocationsControllers.copy(lcArray);
	
	// create a labour restriction
	create pxyLabRestriction1 transient;
	pxyLabRestriction1.setProxy(Red,					// Colour
							   app.getMyUserCode(),		// User code
							   null, 					// comment
							   null,					// hours
							   null, 					// days
							   null,					// reason
							   lcArray,					// location controllers
							   LabourRestrictionId1,	// labour Restriction id
							   false,					// ignore lights
							   app.myPassport.myOrganisation, // organisation
							   null,					// email entity
							   null,					//_emails : CM_EmailAddressByAddressDict;
							   gbs);					// terminal area
							   
	self.assertNotNull(pxyLabRestriction1);

	// create the labour restriction
	app.myTrxCA.trxCreateRestrictionLabour(pxyLabRestriction1, labourRestriction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(labourRestriction);
	
	// delete the labour restriction
	app.myTrxDA.trxDeleteRestrictionLabour(labourRestriction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete lcArray;
	delete pxyLabRestriction1;
	delete pxyLabRestriction2;

end;
</source>
    </JadeMethod>
    <JadeMethod name="tCloseGCAreaStatus" id="8a0f060e-537b-4f36-8af0-08ed0c86c398">
        <source>tCloseGCAreaStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/05/2014	cnwma1	Initial creation

*/
constants
	GCAREA ="GC50";
	YANAME= "GC50YA";
vars
	gcArea 				: CM_IrregularBlockArea;
	allAllocationsObj	: CM_YardAllocationSet;
	theTerminalArea 	: CM_TerminalArea;
	aProxyTest : CM_AutoPlanTests;
	theInterfaceTA : CMIF_ConfigTerminalArea;
		locations : CM_LCArray;
		ya: CM_YardAllocation;
begin

	self.deleteTerminalArea(GCAREA);
	gcArea := self.addGeneralCargoArea(GCAREA,
									   "UT General Cargo Area",
									   10,
									   6,
									   100,
									   null,
									   null);
	self.assertNotNull(gcArea);
	
	self.addGCRackOrGround(gcArea,3,4,3,4,"GR1");
	assertEqual(gcArea.allLocationsControllers.first.status,0);
	
	create locations transient;
	locations.add(gcArea.allLocationsControllers.first.CM_YardController);
	
	self.deleteYA(YANAME);
	ya := self.addYA1WithFill(YANAME, YACriteriaType_OperatorItem,self.getOperator("APL").code, locations, YAFillOption_InOrder, YAFillOption_FIFO,false);
	assertFalse(ya.isDisabled);
	
	create allAllocationsObj transient;

	app.myTrxUA.trxSetControllerStatusWithYA(LC_Status_Closed,gcArea.allLocationsControllers.first,gcArea.allLocationsControllers.first.edition,allAllocationsObj,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	assertEqual(gcArea.allLocationsControllers.first.status,1);
	
	theTerminalArea := gcArea;
	
	beginLoad;
	aProxyTest := theTerminalArea.autoPlanTest.pxyCreateUpdateProxy();
	endLoad;
	
	create theInterfaceTA transient;
	theInterfaceTA.autoPlanApStackDirection := 1;
	theInterfaceTA.autoPlanApStackDirectionOut := 2;
	theInterfaceTA.autoPlanNumRowsMachineSep := 10;
	
	app.myTrxUA.trxUpdateConfigTA(theTerminalArea,aProxyTest,theInterfaceTA,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	

	
epilog
	endLoad;
	delete allAllocationsObj;
	delete theInterfaceTA;
	delete aProxyTest;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDeletePhoto" id="9f692e14-c133-4f87-b7c6-82a33e78fbc0">
        <source>tDeletePhoto();
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456
*/

vars
	ta: CM_TerminalArea;
	result: CM_Attachment;
begin
	ta := self.tAttachPhotoToTA();
	result := ta.allAttachments.getAtKey(CM_Attachment.Type_Photo).CM_Photo;
	self.deleteTerminalAreaPhoto(ta,result.getLoadTimeStamp());
	self.assertTrue(ta.allAttachments.size = 0);
	self.assertIsDeleted(result);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tExportPhoto" id="8590624e-f989-4c66-bbd5-c38cec9f63bb">
        <source>tExportPhoto();
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456
*/

vars
	ti: CM_TerminalArea;
	result: CM_Photo;
	file : File;
	fileName : String;
	photo : Binary;
begin
	fileName := self.getTempDirectory() &amp; "tmp.jpg";
	ti := self.tAttachPhotoToTA();
	result := ti.allAttachments.getAtKey(CM_Attachment.Type_Photo).CM_Photo;
	result.extractToFile(fileName);
	create file transient;
	file.fileName := fileName;
	self.assertTrue(file.tryOpen());
	file.close();
	
	photo := app.loadPicture(fileName);
	self.assertEqual(result.getPhotoContent(), photo);
	
	file.purge();
	
epilog
	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tFindLocation" id="00512d19-4dbb-4f0e-a7e6-f49a18e5d6d2">
        <source>tFindLocation();
// cnwndl1
// cnwdw1
// Test Find Location for various TAs

vars
	ta: CM_TerminalArea;
	lc		: CM_LocationsController;
	strs	: StringArray;
	height 	: Integer;
begin
	deleteTerminalArea("UTRORO");
	ta := addROROArea("UTRORO",  4, 100);
