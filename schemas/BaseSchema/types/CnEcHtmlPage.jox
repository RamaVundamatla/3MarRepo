    <DbClassMap file="basehtml"/>
    <ExplicitInverseRef name="myBody" id="551dc1db-6d0c-4c96-9526-35aeaff383e8">
        <kind>parent</kind>
        <embedded/>
        <type name="CnEcPageBody"/>
        <access>readonly</access>
        <Inverse name="CnEcPageBody::myPage"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myHead" id="1e659eda-a9d7-40c4-b4a2-de8a2c058c82">
        <kind>parent</kind>
        <embedded/>
        <type name="CnEcPageHead"/>
        <access>readonly</access>
        <Inverse name="CnEcPageHead::myPage"/>
    </ExplicitInverseRef>
    <JadeMethod name="buildTagBody" id="df2609f0-b154-45fe-9075-a469b1430259">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return inheritMethod() &amp; self.myHead.getHtml() &amp; self.myBody.getHtml();
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="aa84b418-f303-4911-8f7d-74cfcfb96515">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	headObj		: CnEcPageHead;
	bodyObj		: CnEcPageBody;
	
begin
	create headObj transient;
	self.myHead	:=	headObj;
	
	create bodyObj transient;
	self.myBody	:=	bodyObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="71348e7c-8a4a-43a5-bc88-f52abafcef31">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myHead;
	delete self.myBody;
end;</source>
    </JadeMethod>
    <JadeMethod name="getHtml" id="1daefbf1-d9a0-413f-9feb-949db685acc8">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;HTML&gt;' &amp; CrLf &amp; self.buildTagBody() &amp; '&lt;/HTML&gt;';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
