						if prenoteEDITI &lt;&gt; null then
							prenoteEDITI.weightCertifiedName := _msgHelper.currentSubItem;
						endif;
					endif;
					if nad1_1Function = CM_EDIPrenoteTI::weightCertifiedReference.name then
