    <JadeMethod name="showStopsForm_BOL" id="02f34f7f-f84e-4b5f-a25e-1a404caec816">
        <source>showStopsForm_BOL(_bol :CM_BOLIn; _bolColl :Collection; _canUpdate :Boolean):Integer;
// ---------------------------------------------------------------------------
// Created:     15 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl					: CM_EntryTable;
	frm					: CMUI_StopsForm_BOL;
	menuAction 			: CMUI_MenuAction;
begin
	if _bol = null then
		app.msgBox(	app.getString( CannotUpdateStopNothingSelectd ),
					app.getString( Please_Select_Cargo_Items ),
					MsgBox_Stop_Icon + MsgBox_OK_Only );
		return IDCANCEL;
	endif;
	
	frm := app.loadForm(CMUI_StopsForm_BOL, CMUI_Assistant, false, false, false, self.myTerminal, menuAction).CMUI_StopsForm_BOL;
	
	if frm = null then
		// should not happen
		return IDCANCEL;
	endif;
	// set references on form being displayed for bols for which stops are to be maintained
	frm.setMyTerminal(self.myTerminal);	
	_bolColl.copy (frm.allBOLs);

	frm.myBOL		:= _bol;
	frm.canUpdate	:= _canUpdate;
	
	frm.showModal;
epilog
	return frm.modalResult;
end;</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_bolColl" type="Collection"/>
        <Parameter name="_canUpdate" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
