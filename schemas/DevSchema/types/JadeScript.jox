SALC, 3000, 3001, 1297, 1298, WESC, HTRC, 1299, JERE, EWOW, 3002, 3003, 3004, 3005, 3006, TPAE, 3007, UTS, 3008, MAJI, OGAS, 3009, 3010, 3011, 3012, 3013, 3015, 3014, ELTL, EOFC, DGGT, 3016, 3017, TALM, 3018, 3019, RFIF, BUCO, EQUI, AMAC, IRSH, 3020, 3021, 3022, 3023, 3024, 3025, 3026, 3027, 3028, PACF, 3029, 3030, 3031, AHEM, ZETA, CNIA, 3032, 3033, GDCA, ADNO, ADNS, GSEC, 3034, 3035, 3036, ROBT, NAFE, 3037, 3038, 3039, 3040, 3041, NICO, 3042, THOM, 3043, 3044, ESES, 3045, GMSA, 3046, 3048, 3047, 3049, 3050, 3051, 3052, 3053, 3054, 3056, 3055, 3057, 3058, 3059, 3060, XIAM, AJMI, 3063, 3062, 3061, 3064, FPIC, 3065, 3066, 3067, 3068, 3069, ENGM, 3071, TOCL, 3072, BSAC, BDP, CPW, DSC, DGL, DSV, ECFA, ECUL, ELF, FSC, FWL, FSL, GAVA, GLDN, HLNC, KNGL, OCNH, OSD, PNRG, RFS, SNTA, TMSS, UGFS, BRSM, NIMR, TAWA, 3075, 3076, 3077, 3078, 3079, CPEC, 3080, 3081, 3082, EPMD, STRA, EAGL, 3083, INME, ASGT, AMOS, 3084, 3085, QEAC, SGSA, ESCA, 3086, VMG, 3087, 3088, CF06, 5001, 5002, 5003, 5004, 5005, 5006, 5007, 5008, 5009, 5010, DESC, 3089, 3090, 3091, 3092, 3093, CCC, CAPE, 3094, 3095, 3096, 3097, 3098, 3099, 5244, 5255, 3100, 3101, 3102, 3103, WASI, ASM, 3104, 3105, 3106, 3107, PIFZ, BJSC, ACI, 3108, 3109, 3110, 6010, ARI, 3111, 3112, 3113, RACI, PORC, 3114, 5099, 3115, 3116, BSIB, SLSL, 3117, EMMA, MDML, 3118, 3119, DPAD, GPRS, DCGT, 3120, 3121, 3122, 3123, SSGT, 3124, IMS, 3125, 6035, SADO, 3126, 3127, 3128, MDOF, 3129, 3130, 3131, ADNT, ADSS, AFAF, ASCP, ASIG, ARTS, AEAG, DECP, DIMR, EWPS, FSLT, GSME, HMHA, INNW, KHRU, MKAN, MOGH, MUMR, NAES, OAST, SEBU, STGS, SMRS, TMCC, ZKMR, FPT, DBMS, 3132, GFTF, HBGT, 5252, 3133, 3134, 5165, TSPA, ADNH, SIGT, MEFJ, MARC, MMES, MLMR, MMWE, AMMT, OSML, SEOF, SACG, SSTH, SCCN, TIDT, TTSI, NTAT, ZMI, FMSV, KGT, RFCN, 3135, 3136, 3137, 3138, 6038, DGPT, 3139, DYMO, 3140, 3142, 3143, 3144, 3145, 3146, 3147, 3148, 3141, EIEC, 3149, 3150, 3151, VIOL, 3152, TECH, 3153, 3154, 3155, 3156, 3157, 3158, SOSB, 3159, 3160, 3161, 3162, 3163, CWSL, 3164, 3165, 3166, HANU, 3167, 3168, 3169, 3170, SSFL, 3171, 3172, 3173, 3174, 3175, 3176, 3177, 3178, 3179, 3180, 3181, 3182, 6077, 5032, MSS, 3183, OMVE, 3184, CCCL, ORMA, BEOF, 3185, 3186, 3187, 3188, 3189, 3190, ACC, 3191, 3192, 3193, 3194, 3195, MTC, GSM, AJSP, ANCC, SHIC, SUMI, BLSH, 3196, 3197, 3198, 3199, PRPL, 3200, 3201, ZIPL, CBIE, FPTL, DIAM, RMTF, TRIM, 6012, FENC, GTPC, NMWM, AASF, SWCM, GTGC, KGCP, DNTR, NOTS, MMET, SPCN, SIGS";
	ya := "11750.5".asOid.CM_YardAllocation;
	//strDesc:=ya.description;
	create strArr transient;
	strDesc.csvConvert(strArr, ",");
	beginTransaction;
	foreach str in strArr do
			foreach cargoType in CM_CargoType.instances do
				if cargoType.abbreviation.toUpper = str.trimBlanks.toUpper then
					if cargoType &lt;&gt; null then
						foreach  yac in ya.CM_YardAllocation.allCriteriaByType do 
							if yac.code = "Cargo Type" then
								if not yac.myYAData.CM_YADataObjects.allObjects.includes(cargoType) then
									yac.myYAData.CM_YADataObjects.allObjects.add(cargoType);
								endif;
							endif;
						endforeach;
						yac := null;
						break;
					endif;
				endif;
			endforeach;
			foreach oper  in CM_Operator.instances do
				if  oper.code.toUpper = str.trimBlanks.toUpper then
					if oper &lt;&gt; null then
						foreach  yac in ya.CM_YardAllocation.allCriteriaByType do 
							if yac.code = "Operator (" then
								if not yac.myYAData.CM_YADataObjects.allObjects.includes(oper) then
									yac.myYAData.CM_YADataObjects.allObjects.add(oper);
								endif;
							endif;
						endforeach;
						yac := null;
						break;
					endif;
				endif;
			endforeach;
			foreach imex  in CM_IMEXStatus.instances do
				if  imex.abbreviation.toUpper = str.trimBlanks.toUpper then
					if imex &lt;&gt; null then
						foreach  yac in ya.CM_YardAllocation.allCriteriaByType do 
							if yac.code = "IMEX Statu" then
								if not yac.myYAData.CM_YADataObjects.allObjects.includes(imex ) then
									yac.myYAData.CM_YADataObjects.allObjects.add(imex);
								endif;
							endif;
						endforeach;
						yac := null;
						break;
					endif;
				endif;
			endforeach;
			foreach comm in CM_Commodity.instances do
				if  comm.code.toUpper = str.trimBlanks.toUpper then
					if comm &lt;&gt; null then
						foreach  yac in ya.CM_YardAllocation.allCriteriaByType do 
							if yac.code = "Commodity" then
								if not yac.myYAData.CM_YADataObjects.allObjects.includes(comm ) then
									yac.myYAData.CM_YADataObjects.allObjects.add(comm);
								endif;
							endif;
						endforeach;
						yac := null;
						break;
					endif;
				endif;
			endforeach;		 
		comm := null ;
		cargoType := null;
		oper := null;
		yaDesc := ya.CM_StorageDetail.getDefaultDescription();
		ya.setPropertyValue("description",yaDesc);
		yaDesc := null;
		imex :=null;
endforeach;
commitTransaction;
epilog
delete strArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="amendQuqntity" id="6884a1f5-738a-4a1a-a8c9-516b54e97405">
        <source>amendQuqntity(_cmif : CMIF_CalcTypeQuantityHook) : Real;
/*
Date		Who		Reason
21-05-2019	jlgsh3	Initial creation
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	voyageEvent : CMEVT_VoyageEvent;
	hmsVessel : HMS_VesselData;
	grt : Integer;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	origQty : Real;
	newQty : Real;
	
begin
	app.invLog("Logging for Hook Code - Event Dockage Vessel GRT*Days - START", LogINFO.String);
	if not _cmif.myTransaction.isKindOf(CMEVT_VoyageEvent) then
		app.invLog("Event Dockage - no Voyage Event", LogINFO.String);
		return _cmif.origQty;
	endif;	
	
	app.invLog("Event Dockage - calculate new qauntity", LogINFO.String);
	origQty := _cmif.origQty;
	app.invLog("Original Quantity- No Voyage Event", LogINFO.String);
	
	voyageEvent := _cmif.myTransaction.CMEVT_VoyageEvent;
	if voyageEvent = null then
		app.invLog("Event Dockage - No Voyage Event", LogINFO.String);
		return origQty;
	endif;
	//voyageEvent.n
	voyage := voyageEvent.myVoyage;
	if voyage = null then
		app.invLog("Event Dockage - No Voyage found", LogINFO.String);
		return origQty;
	endif;
	
	vessel := voyageEvent.myVoyage.myVessel;
	if vessel = null then
		app.invLog("Event Dockage - No HMS Vessel found", LogINFO.String);
		return origQty;
	endif;
	
	hmsVessel := vessel.myHMSVesselData;
	
	if hmsVessel = null then
		app.invLog("Event Dockage - No HMS Data found", LogINFO.String);
		return origQty;
	endif;
	
	grt := hmsVessel.dim_GrossRegTonnes;
	
	newQty := grt.Real * origQty;
	
	app.invLog("Logging for Hook Code - Event Dockage Vessel GRT*Days - FIN", LogINFO.String);
		
	
	return newQty;
end;	
</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="amendRate" id="7359407d-9ffb-46ad-bee1-347c3af58d2f">
        <source>amendRate( _cmif : CMIF_CalcTypeRateHook) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 December 2016	cnwma1	Initial creation
2.	Handling Shifts in JMT
	SCT Discharge /Load Operations are handled in 4 shifts:
	1st Shift: 08.00 - 13.59
	2nd Shift: 14.00 - 19.59
	3rd Shift: 20.00 - 01.59
	4rt Shift: 02.00- 07.59
	
	One of the examples for Shift Rates is below,
	
	4th shift: +30%
	All shifts Sunday: +30%
	1st and 2nd Shift Holidays: +50%
	3rd and 4th Shift Holidays: +100%
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	theCalcType : CM_CalculationType;
	newRate,extraRate : Real;
	transDt : Date;
	allCalendarDates : CM_CalendarDatesByDateTimedict;
	isHoliday		 : Boolean;
	shift			 : String;
	transTime		: Time;
begin
	newRate := _cmif.origRate;
		
	theCalcType := app.myRoot.allCalculationTypesByCode["SCT2"];    //Replace With the name of the Calc Type
		
	if theCalcType = null then	
		app.invLog("Invalid CalculationType Used", LogINFO.String);
		return newRate;
	endif;

	if theCalcType.myCalendarType1 &lt;&gt; null then
		create allCalendarDates transient;
		
		app.invLog("Invalid CalculationType Used"&amp;_cmif.myTransaction.createdTime.date.asTimeStamp.String, LogINFO.String);
		
		theCalcType.myCalendarType1.getAllCalendarDatesForDay( _cmif.myTransaction.createdTime.Date, allCalendarDates);
		
		app.invLog("CalculationType Calendar USed =" &amp;theCalcType.myCalendarType1.description, LogINFO.String);
		
		if allCalendarDates.size &gt;0 then
			isHoliday := true;
		else
			isHoliday := false;
		endif;
	endif;
	
	app.invLog("IsHoliday =" &amp;isHoliday.asStringJMT, LogINFO.String);

	transTime := _cmif.myTransaction.createdTime.Time;
	
	app.invLog("Transaction Time =" &amp;transTime.asStringJMT, LogINFO.String);
	
	if transTime &gt;="08:00".Time and transTime &lt;="13:59".Time then
		shift :="1st";
	elseif transTime &gt;="14:00".Time and transTime &lt;="19:59".Time then
		shift :="2nd";
	elseif transTime &gt;="20:00".Time and transTime &lt;="01:59".Time then
		shift :="3rd";
	else
		shift := "4th";
	endif;
	app.invLog("Transaction Shift =" &amp;shift, LogINFO.String);
	app.invLog("Transaction Day =" &amp;transDt.dayName.toUpper, LogINFO.String);
	
	if isHoliday then  // if it's Holiday and exist inside SCT calender
		
		if shift ="1St" then
			extraRate:=0;
			extraRate :=newRate *.5;   //50%
			newRate := newRate +extraRate;
			
		elseif shift="4th" then
			extraRate:=0;
			extraRate := newRate;   //100%;
			newRate := newRate +extraRate;
		else
			newRate := newRate;
		endif;
	else
		if transDt.dayName.toUpper ="SUNDAY" then //Sunday Normal Day
			extraRate:=0;
			extraRate :=newRate *.3;   //30% Normal Sunday
			newRate := newRate + extraRate;
		else
			//Noraml Working Days not Sunday
			if shift ="2nd" then
				extraRate:=0;
				newRate := newRate + extraRate;
			elseif shift ="4nd" then
				extraRate:=0;
				extraRate := newRate *.3; //30% Normal
				newRate := newRate + extraRate;
			else
				newRate :=newRate;
			endif;
			
		endif;
	endif;

	return newRate ;
epilog
	delete allCalendarDates;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeRateHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="ar_changeID" id="319bd580-b36e-46f3-8778-83b6a0ced649">
        <source>ar_changeID();

/*
Date			Who		Reason
18 March 2009	cnwar2	Initial creation

*/

vars
	tiUpdateCntrl : CMIF_TIUpdateController;
	ti			  : CM_Container;
	
begin
	app.initialize;
	
	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, 'SUPERUSER', null);
	tiUpdateCntrl.transactionType := TRANS_TYPE_EDIT;
	
	ti := '2367.5464138'.asOid.CM_Container;
	beginTransaction;
	ti.changeId('MWCU6112451', tiUpdateCntrl, app.myPassport);
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ar_ediFileAddDelimiters" id="85b77629-458a-478f-9d2e-1ec9533e623f">
        <source>ar_ediFileAddDelimiters();

/*
Date			Who		Reason
29 January 2010	cnwar2	Initial creation

*/
vars
	fIn, fOut 	: File;
	s			: String;
	
begin
	create fIn transient;
	create fOut transient;
	fIn.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	fOut.mode := File.Mode_Output; // 26/2/16  cnwns1 PAR 36286 unicode version
	fIn.fileName 	:= "C:\temp\IFTMCS_7.edi";
	fOut.fileName 	:= "C:\temp\IFTMCS_7_OUT.edi";
	
	while not fIn.endOfFile do
		s := fIn.readLine();
		s := s &amp; "'";
		fOut.writeLine(s);
	endwhile;
	
epilog
	fIn.close;
	fOut.close;
	delete fIn;
	delete fOut;
end;</source>
    </JadeMethod>
    <JadeMethod name="ar_entTblAndErrorChanges" id="03731d19-036f-4010-8b0b-148d49873f9f">
        <source>ar_entTblAndErrorChanges();
/*
Date			Who		Reason
26 August 2010	cnwar2	Initial creation

*/

vars
	tempStr				: String;
	entTblAgent			: EntTableAgent;
	tmpArray			: StringArray;
	translationAgent	: CM_TranslationAgent;
	
begin
	app.initialize();
	
	create translationAgent transient;
	create entTblAgent transient;
	create tmpArray transient;
	
	// Translable messages
	tmpArray.add('Machin_cannot_lift_cargo_type');
	translationAgent.trxLoadSpecificErrors(tmpArray);
	
	// EntTable changes
	entTblAgent.myEntTableDataRoot	:= app.myRoot.myEntTableDataRoot;
	tmpArray.clear();
	tmpArray.add('ETRow_FileType');		// new rows must come before def
	tmpArray.add('ETRow_DataType');
	tmpArray.add('ETDef_EDIFileAll');
	entTblAgent.trxUpdateFromConstant( tmpArray );
	
	return;
	
	write Machin_cannot_lift_cargo_type;
	write ETRow_FileType;
	write ETRow_DataType;
	write ETDef_EDIFileAll;
	
epilog
	delete translationAgent;
	delete entTblAgent;
	delete tmpArray;
end;</source>
    </JadeMethod>
