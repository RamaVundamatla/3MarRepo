    <JadeMethod name="convertNull" id="76deeb5d-9de6-4ad1-93a4-3ca13f3b7154">
        <source>convertNull(_value : Any):Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2018	jlgma1	Initial creation

*/

vars

begin
	if _value = null then
		return Space;
	else
		return _value;
	endif;
	 
epilog

end;</source>
