    <JadeMethod name="buildHatchsMenu" id="ddfabf16-98da-4243-b27c-49483c28ec95">
        <source>buildHatchsMenu() protected;

vars

	hatch		: CM_GeneralCargoController;
	idx			: Integer;
	lCaption	: String;
	mnuChild	: MenuItem;

begin
	
	idx := 2;
	while true do
		mnuChild := self.mnuLoadSub.getMenuItem(idx);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
		idx := idx + 1;
	endwhile;
	
	if self.myCurrentGCVoyage = null then
		return;
	endif;
	
	idx := 1;
	foreach hatch in self.myCurrentGCVoyage.allLocationsByHatchPlace discreteLock, reversed do
		idx := idx + 1;
		lCaption := hatch.getFullId();
		mnuChild := self.mnuLoadSub.getMenuItem(idx); 
		if mnuChild = null then
			mnuChild := self.mnuLoadSub.loadMenu(idx); // Clone menu
			mnuChild.caption := lCaption;
			mnuChild.visible := true;
			mnuChild.enabled := true;
			mnuChild.userObject := hatch;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildMnuTasksAdd" id="9cf840c4-be49-449e-8de9-f07cfdfc54ea">
        <source>buildMnuTasksAdd(_menuMaster: MenuItem input; _theTI : CM_TrackedItem input) protected;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars
	task				: CM_ToDoTask;
	taskDesc			: CM_ToDoTaskDesc;
	mnuChild,mnuMaster	: MenuItem;
	itemEnabled			: Boolean;
	idx : Integer;
	taskDict		: CM_ToDoTaskDescByCode;
begin
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to add any tasks
		_menuMaster.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that can be set
	mnuMaster := _menuMaster;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Add Tasks";
	if taskDict.isEmpty then
		self.mnuTasksAddSub.visible := true;		
		self.mnuTasksAddSub.caption := "No Tasks";
	else
		self.mnuTasksAddSub.visible := false;				
	endif;
	
	idx := 2;
	while true do
		mnuChild := self.mnuTasksAddSub.getMenuItem(idx);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
		idx := idx + 1;
	endwhile;
	
	idx := 1;
	foreach taskDesc in taskDict do
		idx := idx+1;
		itemEnabled := true;
		
		foreach task in _theTI.allToDoTasksToDo do
			if task.toDoTaskDesc = taskDesc then
				itemEnabled := false;
			endif;
		endforeach;

		if taskDesc.description = null then 
			itemEnabled := false;
		endif;
		
		// DVB added to screen for cargo type.
		if itemEnabled and not taskDesc.isAvailableForCargoType(_theTI.cargoType) then
			continue;
		endif;

		//keep cloning until all tasks represented
		mnuChild := self.mnuTasksAddSub.getMenuItem(idx);
		if mnuChild = null then
			mnuChild := self.mnuTasksAddSub.loadMenu(idx); // Clone menu								
			mnuChild.caption := taskDesc.description;
			mnuChild.visible := true;
			mnuChild.enabled := itemEnabled;
			mnuChild.helpKeyword := taskDesc.description;
			mnuChild.userObject := taskDesc;
		endif;
	endforeach;

epilog
	delete taskDict;

end;</source>
        <access>protected</access>
        <Parameter name="_menuMaster" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildMnuTasksComplete" id="b2b925f0-e82a-40b7-bfd7-97ce68925a99">
        <source>buildMnuTasksComplete(_menuMaster: MenuItem input; _theTI : CM_TrackedItem input) protected;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars
	task				: CM_ToDoTask;
	taskDesc			: CM_ToDoTaskDesc;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex			: Integer;
	itemEnabled			: Boolean;
	idx : Integer;
	taskDict		: CM_ToDoTaskDescByCode;
begin

	taskDict := app.myPassport.myUser.getToDoTasksCompleteForTerm(self.myTerminal);
	if taskDict.isEmpty then
		// no permission to complete any tasks
		_menuMaster.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := _menuMaster;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Complete Tasks";
	if taskDict.isEmpty then
		self.mnuTasksCompleteSub.visible := true;	
		self.mnuTasksCompleteSub.caption := "No Tasks";
	else
		self.mnuTasksCompleteSub.visible := false;		
	endif;
	
	idx := 2;
	while true do
		mnuChild := self.mnuTasksCompleteSub.getMenuItem(idx);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
		idx := idx + 1;
	endwhile;
	
	idx := 1;
	//show todos that can be completed
	foreach taskDesc in taskDict do
		idx := idx + 1;		
		itemEnabled := false;
		
		foreach task in _theTI.allToDoTasksToDo do
			if task.toDoTaskDesc = taskDesc then
				itemEnabled := true;
			endif;
		endforeach;

		//keep cloning until all tasks represented
		mnuChild := self.mnuTasksCompleteSub.getMenuItem(idx);
		if mnuChild = null then
			mnuChild := self.mnuTasksCompleteSub.loadMenu(idx); // Clone menu										
			mnuChild.caption := taskDesc.description;
			mnuChild.visible := true;
			mnuChild.enabled := itemEnabled;
			mnuChild.helpKeyword := taskDesc.description;
			mnuChild.userObject := taskDesc;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_menuMaster" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildMnuTasksRemove" id="3b03f6b8-1da5-4398-a613-da0c3f93f8d8">
        <source>buildMnuTasksRemove(_menuMaster: MenuItem input; _theTI : CM_TrackedItem input) protected;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars
	task				: CM_ToDoTask;
	taskDesc			: CM_ToDoTaskDesc;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex			: Integer;
	itemEnabled			: Boolean;
	idx : Integer;
	taskDict		: CM_ToDoTaskDescByCode;
begin
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to remove any tasks
		_menuMaster.visible := false;
		return;
	endif;


	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := _menuMaster;//self.mnuCargoTaskComplete;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Remove Tasks";
	if taskDict.isEmpty then
		self.mnuTasksRemoveSub.visible := true;	
		self.mnuTasksRemoveSub.caption := "No Tasks";
	else
		self.mnuTasksRemoveSub.visible := false;
	endif;
	
	idx := 2;
	while true do
		mnuChild := self.mnuTasksRemoveSub.getMenuItem(idx);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
		idx := idx + 1;
	endwhile;
	
	idx := 1;

	//show todos that can be completed
	foreach taskDesc in taskDict do
		idx := idx + 1;		
		itemEnabled := false;
		
		foreach task in _theTI.allToDoTasksToDo do
			if task.toDoTaskDesc = taskDesc then
				itemEnabled := true;
			endif;
		endforeach;

		//keep cloning until all tasks represented
		mnuChild := self.mnuTasksRemoveSub.getMenuItem(idx);
		if mnuChild = null then
			mnuChild := self.mnuTasksRemoveSub.loadMenu(idx); // Clone menu												
			mnuChild.caption := taskDesc.description;
			mnuChild.visible := true;
			mnuChild.enabled := itemEnabled;
			mnuChild.helpKeyword := taskDesc.description;
			mnuChild.userObject := taskDesc;
		endif;
	endforeach;

epilog
	delete taskDict;
end;</source>
        <access>protected</access>
        <Parameter name="_menuMaster" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkImexStatus" id="37ee4118-c94b-4a64-902a-fe571e97c660">
        <source>checkImexStatus(_ti : CM_TrackedItem) : Boolean protected;
//
// Changed On 	By			Reason
// ----------	--------	---------------------------------------
// 20/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars

	imex : Integer;
	isImport, isExport	: Boolean;	// PAR #23645 CCMS 1116

begin

	// Let everything through.
	if self.chkImports.value and self.chkExports.value then
//	if self.btnImport.value and self.btnExport.value then
		return true;
	endif;
	imex := _ti.getImExStatus();
	//isExport := _ti.isExport;		// PAR #23645 CCMS 1116							// PAR #25021
	isExport := _ti.isExport or _ti.isTranshipOutbound;		// PAR #23645 CCMS 1116	// PAR #25021
	//isImport := _ti.isImport;		// PAR #23645 CCMS 1116							// PAR #25021
	isImport := _ti.isImport or _ti.isTranshipInbound;		// PAR #23645 CCMS 1116	// PAR #25021
	
	//if self.chkImports.value and imex = TI_IMEX_STATUS_IMPORT then		// PAR #23645 CCMS 1116
	if self.chkImports.value and isImport then								// PAR #23645 CCMS 1116
		return true;
	//elseif self.chkExports.value and imex = TI_IMEX_STATUS_EXPORT then	// PAR #23645 CCMS 1116
	elseif self.chkExports.value and isExport then							// PAR #23645 CCMS 1116
		return true;
	endif;
	
	return false;
	
	

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
