    <JadeMethod name="buildSelf" id="5060e2b7-29dd-41e8-abc2-84b87e765fac">
        <updating/>
        <source>buildSelf() updating;

vars

begin
	createButton(prevMonthButton, 0, "&lt;");
	prevMonthButton.tabIndex := tabIndex + 1;
	createLabel(monthLabel, prevMonthButton.width, clientWidth() * MonthLabelWidthRatio);
	createButton(nextMonthButton, monthLabel.left + monthLabel.width, "&gt;");
	nextMonthButton.tabIndex := tabIndex + 2;
	createButton(prevYearButton, nextMonthButton.left + nextMonthButton.width, "&lt;");
	prevYearButton.tabIndex := tabIndex + 3;
	createButton(nextYearButton, clientWidth() - prevYearButton.width, "&gt;");
	nextYearButton.tabIndex := tabIndex + 4;
	createLabel(yearLabel, prevYearButton.left + prevYearButton.width, nextYearButton.left - prevYearButton.left - prevYearButton.width);
// cnwdad1 17/08/2000 - Refer to the "createTable" method for details about this change.
//	createTable(monthTable, prevMonthButton.height);
	self.createTable(self.prevMonthButton.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="a13d31df-e9b9-4616-a9e4-aef1b545d750">
        <updating/>
        <source>click(cntrl: CnEcCalendar input) updating;

vars

begin
	inheritMethod(cntrl);
end;</source>
        <Parameter name="cntrl" type="CnEcCalendar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="cb588ea2-4751-4494-855d-cc941e2456bd">
        <updating/>
        <source>create() updating;

vars
	today : Date;

begin
	isBuilt			:=	false;
	changeType		:=	self.ChangeType_None;
	dayNameLength	:=	3;
	borderStyle		:=	Window.BorderStyle_Single;
	show3D			:=	Control.Show3D_Use3D;
	transparent		:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="createButton" id="ee8514e9-2b85-4a2b-805f-884dee490ddd">
        <updating/>
        <source>createButton(btn : CnEcCalendarButton io; btnLeft : Real ; btnCaption : String) updating;

vars

begin
	if btn = null then
		create btn transient;
		btn.parent	:=	self;
		form.addControl(btn);

		if isInPainter() then
			btn.actualEnabled	:=	false;
		endif;
	endif;

	btn.left			:=	btnLeft;
	btn.height			:=	clientHeight() / (NumOfRows + 1);
	btn.width			:=	clientWidth() / ButtonWidthRatio;
	btn.caption			:=	btnCaption;
	btn.foreColor		:=	foreColor;
	btn.fontName		:=	fontName;
	btn.fontSize		:=	fontSize;
	btn.fontBold		:=	fontBold;
	btn.fontItalic		:=	fontItalic;
	btn.fontUnderline	:=	fontUnderline;
	btn.fontStrikethru	:=	fontStrikethru;
end;</source>
        <Parameter name="btn" type="CnEcCalendarButton" usage="io"/>
        <Parameter name="btnLeft" type="Real"/>
        <Parameter name="btnCaption" type="String"/>
    </JadeMethod>
    <JadeMethod name="createLabel" id="3ae5f8ee-b62b-47fb-bbea-15432b8d783f">
        <updating/>
        <source>createLabel(lbl : CnEcCalendarLabel io; lblLeft : Real; lblWidth : Real) updating;

vars
	today : Date;

begin
	if lbl = null then
		create lbl transient;
		lbl.parent	:=	self;
		form.addControl(lbl);

		if isInPainter() then
			lbl.actualEnabled	:=	false;
		endif;

		lbl.borderStyle	:=	Window.BorderStyle_Single;
		lbl.alignment	:=	self.Alignment_Center_Middle;

		if lbl = monthLabel then
			lbl.caption	:=	today.monthName;
		else
			lbl.caption	:=	today.year.String;
		endif;
	endif;

	lbl.left			:=	lblLeft;
	lbl.height			:=	clientHeight() / (NumOfRows + 1);
	lbl.width			:=	lblWidth;
	lbl.backColor		:=	backColor;
	lbl.foreColor		:=	foreColor;
	lbl.fontName		:=	fontName;
	lbl.fontSize		:=	fontSize;
	lbl.fontBold		:=	fontBold;
	lbl.fontItalic		:=	fontItalic;
	lbl.fontUnderline	:=	fontUnderline;
	lbl.fontStrikethru	:=	fontStrikethru;
end;</source>
        <Parameter name="lbl" type="CnEcCalendarLabel" usage="io"/>
        <Parameter name="lblLeft" type="Real"/>
        <Parameter name="lblWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="createTable" id="ce058f03-a497-4029-9068-9a00cdb61df1">
        <updating/>
        <source>createTable(tblTop : Real) updating;
// cnwdad1 17/08/2000 - Previous signature was: createTable(tbl : CnEcCalendarTable io; tblTop : Real) updating;

vars
	today	: Date;
	count	: Integer;
	tbl		: CnEcCalendarTable;

begin
// cnwdad1 17/08/2000.
// From JADE 5.1, the value of usage IO parameters are only copied back
// to the parameter of the calling method once the invoked method (i.e.
// this method) has finished executing and returns to the caller.  Thus,
// by creating the "monthTable" via the IO parameter, subsequent method
// calls by this method (that referenced the control) were causing 1090
// exceptions.  Therefore, we'll explicity create it here.  Also removed
// the table as an IO parameter (this was unnecessary anyway).
//	if tbl = null then
//		create tbl transient;				// cnwdad1 17/08/2000.
		create self.monthTable transient;	// cnwdad1 17/08/2000.
		tbl	:=	self.monthTable;			// cnwdad1 17/08/2000.
		
		tbl.parent	:=	self;
		form.addControl(tbl);

		if isInPainter() then
			tbl.actualEnabled	:=	false;
		endif;

		tbl.rows			:=	NumOfRows;
		tbl.columns			:=	DaysOfWeek;
		tbl.fixedRows		:=	tbl.rows;
		tbl.fixedColumns	:=	tbl.columns;
		tbl.alignment		:=	Table.Alignment_Center;
		tbl.borderStyle		:=	Window.BorderStyle_None;
		tbl.readOnly		:=	true;
		tbl.tabStop			:=	false;
		tbl.allowResize		:=	3; // None
		tbl.showDays(today);
		tbl.selectDay(today);
//	endif;

	tbl.top		:=	tblTop;
	tbl.width	:=	clientWidth();
	tbl.height	:=	clientHeight() - tblTop;
	count		:=	tbl.rows - 1;

	while count &gt; 0 do
		tbl.rowHeight[count]	:=	(tbl.height / tbl.rows).rounded; 
		count					:=	count - 1;
	endwhile;

	tbl.rowHeight[tbl.rows]	:=	tbl.height.Integer - (tbl.rows - 1) * (tbl.height / tbl.rows).rounded;
	count					:=	tbl.columns - 1;

	while count &gt; 0 do
		tbl.columnWidth[count]	:=	(tbl.width / tbl.columns).rounded; 
		count					:=	count - 1;
	endwhile;

	tbl.columnWidth[tbl.columns]	:=	tbl.width.Integer - (tbl.columns - 1) * (tbl.width / tbl.columns).rounded;
	monthTable.accessMode			:=	0;
	tbl.foreColor					:=	foreColor;

	if tbl.fontName &lt;&gt; fontName then	// Workaround for the bug in Painter that causes paint events in a loop
		tbl.fontName	:=	fontName;
	endif;

	tbl.fontSize		:=	fontSize;
	tbl.fontBold		:=	fontBold;
	tbl.fontItalic		:=	fontItalic;
	tbl.fontUnderline	:=	fontUnderline;
	tbl.fontStrikethru	:=	fontStrikethru;
end;</source>
        <Parameter name="tblTop" type="Real"/>
    </JadeMethod>
    <JadeMethod name="date" id="d1ece6e4-34b6-4366-85c9-39bdb9b06a93">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>date(set: Boolean; value: Date io) mapping, updating;
vars

begin
	if set and isTransient() and date &lt;&gt; value then
		if date &lt;&gt; null then
		 	if date.month &lt;&gt; value.month or date.year &lt;&gt; value.year then
				monthTable.showDays(value);
			endif;
		endif;

		monthTable.selectDay(value);
		monthLabel.caption	:=	value.monthName;
		yearLabel.caption	:=	value.year.String;
		date				:=	value;

		if changeType = ChangeType_None then
			changeType	:=	ChangeType_Script;
		else
			click(self);		
		endif;

		changeType	:=	ChangeType_None;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Date" usage="io"/>
    </JadeMethod>
    <JadeMethod name="paint" id="783ec038-323d-4e52-ad4a-6e425fc9e7af">
        <updating/>
        <source>paint(cntrl: CnEcCalendar input) updating;

vars
	today : Date;
begin
	inheritMethod(cntrl);

	if isInPainter() then
// cnwdad1 17/08/2000.
// When the control was loading in the painter, it kept trying to rebuild
// itself in a loop.  Before build the control for the first time, now
// setting the "isBuilt" flag, then actually doing it.
//		buildSelf;							// cnwdad1 17/08/2000.
		if not self.isBuilt then			// cnwdad1 17/08/2000.
			self.isBuilt	:=	true;		// cnwdad1 17/08/2000.
			self.buildSelf();				// cnwdad1 17/08/2000.
		endif;								// cnwdad1 17/08/2000.

	elseif not isBuilt then
		self.buildSelf();
		isBuilt	:=	true;

		if self.defaultDate.isValid() then
			date	:=	self.defaultDate;	//today;
		else
			date	:=	today;
		endif;
	endif;
end;</source>
        <Parameter name="cntrl" type="CnEcCalendar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="e0b6cfa2-b1ec-4f73-9418-da04ba94fa17">
        <updating/>
        <source>refresh() updating;

begin
	inheritMethod;

	if not isInPainter() then
		self.buildSelf();
		monthTable.selectDay(date);
	endif;
end;</source>
    </JadeMethod>
