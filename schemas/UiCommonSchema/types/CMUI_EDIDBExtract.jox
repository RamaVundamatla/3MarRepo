    <JadeMethod name="cmbVoyage_lostFocus" id="bf19d911-4017-4343-a3bc-9f1c0d8d4cb3">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_lostFocus(_combo: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	self.tblDetail.setValueByControlName(_combo.name, _combo.text);
	
	if self.origValueStr &lt;&gt; _combo.text then	
		self.myVoyage := self.myAssistant.getVoyageFromCombo(_combo.text);
	endif;
end;</source>
