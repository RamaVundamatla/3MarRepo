    <JadeMethod name="netDuration" id="abdd6503-a714-4847-83d1-b682a0d2bd55">
        <methodInvocation>mapping</methodInvocation>
        <source>netDuration(set: Boolean; _value: Integer io) mapping;
/*
Purpose:	Mapping method for net duration (gross duration less delays)				

Date		Who		Reason
05 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars

begin
	if set then
		// set code here
		app.raiseSetVirtualError (self.class.name, method.name);
	else
		// get code here
		_value := self.grossDuration - self.delayDuration;
		
		if _value &lt; 0 then
			_value := 0;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateForDelay" id="1a87a0af-8453-4c0b-be68-1861f41cf18e">
        <updating/>
        <source>updateForDelay(_delay :CM_Delay)updating;
/*
Purpose:		Work out net lift duration 			
Parameters:			
Return Value:		

Date		Who		Reason
05 Apr 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars
	tsStart, tsEnd,
	delayStart, delayEnd,
	now						:TimeStamp;
	duration				:Integer;
begin
	tsStart 	:= self.startTS;
	tsEnd		:= self.finishTS;
	delayStart	:= _delay.startDT;
	delayEnd	:= _delay.endDT;
	
	if delayEnd = null then
		delayEnd := now;
	endif;
	
	if delayEnd &lt;= tsStart or
		delayStart &gt;= tsEnd then
		// delay does not span this lift/move/session
		return;
	endif;
	
	// only count that part of the delay that spans the lift/move
	if delayStart &lt; tsStart then
		delayStart := tsStart;
	endif;
	
	if delayEnd = null or delayEnd &gt; tsEnd then
		delayEnd := tsEnd;
	endif;
	
	// at this time if there are overlapping delays we will count the delay duration twice.
	// user gets a warning if they enter delays that overlap for a given machine
	duration := delayEnd.getDifferenceInSeconds (delayStart).Integer;
	
	self.delayDuration := self.delayDuration + duration;
	
	self.allDelays.add (_delay);
epilog

end;</source>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
</Class>
