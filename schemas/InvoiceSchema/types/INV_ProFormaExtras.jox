    <JadeMethod name="doBuildInvLineTypes" id="81956caf-9a15-4768-b3ba-44ea2c81283f">
        <source>doBuildInvLineTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2017	cnwma1	TFS 3852 ADP - Negative Invoice Rate Lines;
28 Jan 2019	NDL	TFS 42940
*/

vars

	theCombo : CMUI_ComboBox;
	anInvLineType : CM_InvoiceLineDesc;
	invLineGroup : CM_InvoiceLineDescGroup;
	
	coll : CM_InvoiceLineDescByNarrDict;
	
begin

	theCombo := self.cmbInvLineType;
	theCombo.clear;
	theCombo.sorted := true;
	
// TFS 45953	if self.myProformaAgent&lt;&gt; null then // TFS 44275
// TFS 45953		invLineGroup := self.myProformaAgent.myBank.getConfig( ProXtraInvLineGrp ).CM_InvoiceLineDescGroup;
// TFS 45953	else
	if self.myTrackedItem &lt;&gt; null then // TFS 44275
		invLineGroup := self.myTrackedItem.companyOid.getConfig( ProXtraInvLineGrp ).CM_InvoiceLineDescGroup; // TFS 44275
	endif;
	
	if invLineGroup &lt;&gt; null then
		coll := invLineGroup.lineDescriptions;
		if coll.isEmpty then
			coll := null;
		endif;
	endif;
	if coll = null then
// TFS 45953		if self.myProformaAgent&lt;&gt; null then // TFS 44275
// TFS 45953			coll := self.myProformaAgent.myBank.invoiceLineDescriptors;
// TFS 45953		else
		if self.myTrackedItem &lt;&gt; null then // TFS 44275
			coll := self.myTrackedItem.companyOid.invoiceLineDescriptors; // TFS 44275
		endif;
	endif;
	
	if self.myVoyage &lt;&gt; null then // TFS 37454
		foreach anInvLineType in coll where not anInvLineType.isNotAvailableForEntry do
				if anInvLineType.isVoyageCalcTypeForProforma() then
					if anInvLineType.services.isNotEmpty() then // TFS 44275
						theCombo.addItemObject(anInvLineType.narration.String, anInvLineType);
					endif;
				endif;
		endforeach;
	
	else
		foreach anInvLineType in coll where not anInvLineType.isNotAvailableForEntry do
				if anInvLineType.isCargoCalcType() then
					if anInvLineType.services.isNotEmpty() then // TFS 44275
						theCombo.addItemObject(anInvLineType.narration.String, anInvLineType);
					endif;
				endif;
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="0cd0f2d6-3358-4008-ab06-530449b71bca">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Aug 2012	cnwndl1	Initial creation
18 Apr 2017	cnwma1	TFS 3852 ADP - Negative Invoice Rate Lines
04 Oct 2017	jlgdap1	TFS 7204 STWR Correct real handling for non-standard locales
06 Jul 2018 cnwma1	Bug 39294: PKT - Clinker Return Process
15 Jan 2020 cnwma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT - ##336278##
*/

vars

	index 		  : Integer;
	change	      : Real;
	lineTotal	  : Decimal[23,6];
	agent	  	  : CM_CashInvoiceProformaAgent;
	charge 		  : CM_Charge;
	transInvLine  : CM_InvoiceLine;
	drTerm  	  : CM_DebtorTerminal;
	proxyPayment  : CM_CashPayment;
	qty			  : Real;
begin
	if self.myCashReceipt &lt;&gt; null then // TFS 44275 New Cash Collection Screen
		if self.myCashPayment &lt;&gt; null then
			delete self.myCashPayment;
			self.myCashPayment := null;
		endif;
	
		drTerm := self.myCashReceipt.myDebtorTerminal;
		if drTerm = null or not drTerm.isCashOnly then
			app.raiseCMException(Not_cash_only_no_receipt,null,self);
			return;
		endif;

		if self.optQuantity.value then
			if self.txtQtyManual.text &lt;&gt; null and self.cmbInvLineType.listIndex &lt;&gt; -1 then
				
				proxyPayment := self.myCashReceipt.createProxyManualPayment(self.cmbInvLineType.listObject.CM_InvoiceLineDesc,
																			self.txtQtyManual.text.asRealJMT,
																			0,
																			self.txtNarration.text,
																			self.myTrackedItem,
																			false,
																			false);  //16.01.2020 cnwma1 #48298
			endif;
			
		elseif self.optFinancial.value then
			if self.txtFinancial.text &lt;&gt; null and self.cmbInvLineType.listIndex &lt;&gt; -1 then
				drTerm := self.myCashReceipt.myDebtorTerminal;
				if drTerm = null or not drTerm.isCashOnly then
					app.raiseCMException(Not_cash_only_no_receipt,null,self);
					return;
				endif;
				proxyPayment := self.myCashReceipt.createProxyManualPayment(self.cmbInvLineType.listObject.CM_InvoiceLineDesc,
																			1,
																			self.txtFinancial.text.asRealJMT, 
																			self.txtNarration.text,
																			self.myTrackedItem,
																			true,
																			false); //16.01.2020 cnwma1 #48298
			endif;
		
		endif;
	endif;
	
	inheritMethod();

epilog
end;
</source>
    </JadeMethod>
