    <JadeMethod name="translateForm" id="18fd24b8-92b4-4037-8c23-e1743e88a4ad">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 October 2016 09:05:33.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006206, locale);
	btnHealthCheck.translateBubbleHelp(Xlat_0021400, locale);
	btnHealthCheck.translateCaption(Xlat_0021401, locale);
	btnProfConfig.translateCaption(Xlat_0020321, locale);
	btnProfInvoice.translateCaption(Xlat_0020322, locale);
	shtMain.translateCaption(Xlat_0018041, locale);
end;</source>
    </JadeMethod>
</GUIClass>
