    <JadeMethod name="voyageColourCoding_44224" id="daf51693-8d80-4ee2-8fd6-30ede2dd2a4d">
        <source>voyageColourCoding_44224();
/*

Purpose:	Voyage Colour Coding 50282		

Date		Who		Reason
01/06/2021	navmh5  Initial creation

*/

constants
	
	VoyageId				: String = "MESDAI200001";
	CraneId					: String = "CRN1";
		
vars
	
	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	operator				: CM_Operator;
	voyageDischJob			: CM_VoyageJob;
	tmpLoadCC				: CMIF_LoadColorCode;
	voyage					: CM_Voyage;
	slot					: CM_SlotController;
	ti						: CM_Container;
	
	slotsFrom				: CM_SlotControllerArray;
	
begin
	
	app.initialize();
	
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	operator := self.getOperator("MSL");
	self.assertNotNull(operator);
	
	// delete voyage job via tracked item
	ti := self.getTrackedItem("JLG44224A01").CM_Container;
	//self.assertNotNull(ti);
	
	self.loadAllJobsToOps(voyage, false);
	if ti &lt;&gt; null then
		if not ti.allJobsShipReceive.isEmpty then
			foreach voyageDischJob in ti.allJobsShipReceive discreteLock where not voyageDischJob.isJobComplete do
				self.deleteVoyageJob(voyage, voyageDischJob.craneId, voyageDischJob.jobNum);
			endforeach;
		endif;
	endif;
	
	// clear colour coding from slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.unmarkSlotsAsLoadJob(slotsFrom);
	
	// delete the Slot Request discharge
	beginTransaction;
	foreach slot in slotsFrom discreteLock do
		if slot.mySlotRequestDischarge &lt;&gt; null and not slot.mySlotRequestDischarge.isComplete then
			slot.eraseSlotRequest(slot.mySlotRequestDischarge);
			//slot.clearSR();
		endif;
	endforeach;
	commitTransaction;
	
	// delete tracked item
	if (ti &lt;&gt; null) then
		self.deleteTrackedItem(ti, false);
	endif;
	
	// create tracked item on ship
	ti := self.addContainerOnShip("JLG44224A01", operator, "2200", "GEN", null, voyage, "USJAX", "031082").CM_Container;
	
	// colour code the discharge slots
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	self.assertNotNull(voyageDischJob);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
	
epilog

	delete slotsFrom;

end;</source>
    </JadeMethod>
    <JadeMethod name="xCountInstances" id="de873dbd-39ef-452e-90b8-6efa3a7f9c17">
