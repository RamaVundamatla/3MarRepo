vars
	allocation : CM_StockOrderAllocation;
begin

	if self.mode &lt;&gt; Mode_View then
		app.msgBox(app.getErrorString(LVO_AllocateRowCheck), 'Error', MsgBox_OK_Only);
		return;
	endif;

	if table.row &gt; table.fixedRows then
		allocation := table.accessRow(table.row).itemObject.CM_StockOrderAllocation;
		if allocation &lt;&gt; null then
			self.txtAllocRowSpecs.text := 'Specifications: ' &amp; allocation.mySOHLocation.myProduct.code;
		endif;
	endif;
	
end;</source>
