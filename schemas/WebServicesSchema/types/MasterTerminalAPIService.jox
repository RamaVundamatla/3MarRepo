    <ImplicitInverseRef name="allRegexPatterns" id="243c8000-f062-47bf-9b32-ae1ea61daffe">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
