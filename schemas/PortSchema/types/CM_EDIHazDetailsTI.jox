    <JadeMethod name="verifySelf" id="86310187-2a68-4cea-b1e4-ab9f159bbeeb">
        <source>verifySelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
08 January  2025    navsp1  MTN-19916 MTN - Hazard Packing Group Behaviour is incorrect 
*/

vars

	tiHaz : CM_TIHazard;

begin

	create tiHaz transient;
	tiHaz.setPxyFromEDI( self );
	tiHaz.validateTIHazard( self.getMyTerminal );
	if self.packingGroup.length &gt; 5 then															//MTN-19916
		app.raiseCMWarning1(Max_Length_PackGroup_Exceeded, self.packingGroup, null, null, null);	//MTN-19916
	endif;																							//MTN-19916
epilog

	delete tiHaz;

end;</source>
    </JadeMethod>
</Class>
