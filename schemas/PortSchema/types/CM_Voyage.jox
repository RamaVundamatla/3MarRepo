    <JadeMethod name="hasDeparted" id="da5c6d8a-838a-42fb-8220-aa9a55376846">
        <source>hasDeparted(): Boolean;
//----------------------------------------------------------------
//	Created:	20 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Is after estimated departure time

vars
	now : TimeStamp;
begin

	now := app.actualTimeServer();
	
	if self.departedDT &lt;&gt; null
	and self.departedDT.cnEcIsLessThanOrEqual(now) then
		return true;
	endif;
	
	return false;	
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasDepartedWithGracePeriod" id="73fb8883-4459-4606-ac56-3782fe24b4c7">
        <source>hasDepartedWithGracePeriod( _gracePeriod : Integer ) : Boolean;

/*
Purpose:	This method will return true if the voyage departure date is
			less than today plus or minus the supplied grace period in hours.

Date				Who		Reason
05 November 2009	cnwrl1	Initial creation as part of PAR 20599
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
	
vars
	tmpCheckDT		: TimeStamp;
	
begin
	if self.departedDT = null then
		// if has not yet departed then it is false.
		return false;
	endif;
	
	// so has departed check if the depart date is less than today plus / minus grace period.
	tmpCheckDT	:= app.actualTimeServer();						// today// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tmpCheckDT	:= tmpCheckDT.changeByXXHours( _gracePeriod );		// plus / inus grace period
	
	return self.departedDT &lt; tmpCheckDT;
	
epilog
	
end;
</source>
        <Parameter name="_gracePeriod" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasEventOfType" id="98c6f163-3297-4385-bc8b-ef5a6555bbba">
        <source>hasEventOfType(_eventType : CM_EventType) : Boolean;
/*
Purpose:			
Date		Who		Reason
03 February 2017	cnwab1	Initial creation
*/

vars
	event : CM_EventTransaction;
begin
	foreach event in self.allEventTransactionsByDateTime discreteLock do
		if event.myEventType = _eventType then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasExportMAFIClearedOfStops" id="fee6f721-9443-4ba6-af35-9f45b91d62d2">
        <source>hasExportMAFIClearedOfStops() : Boolean;
/*

Purpose:			Find if there are any unqueued onsite export MAFIs that have been cleared of all stops

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2022	jlizm1	Initial creation TFS 54702 CUX MAFI Auto Queueing
07 Dec 2023	jlika1	TFS 61189 61441 RTL - Remove existing Queue Export Config
*/

vars
	iter 	: Iterator;
	ti 		: CM_TrackedItem;
	
begin
	if self.myTerminal = null then // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1	
		 return false;
	endif;

	iter := self.allOnsiteTIsByCargoTypeId.createIterator;
	while iter.next(ti) do
		if ti.isMAFI and ti.isExport then
			if ti.myPrimaryPlannedLocation = null and ti.myPrimaryQueuedLocation = null then
				if not ti.CM_TILC.hasStopsForOnboardTIs() then
					return true;
				endif;
			endif;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasGroundPlacedExpROROCont" id="9f034aa9-4477-456c-a198-615e3053ecf3">
        <source>hasGroundPlacedExpROROCont() : Boolean;
/*

Purpose:			Return true if there are any export containers in the yard not loaded on a MAFI
					Only for exclusively RORO voyages

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2022	jlizm1	Initial creation TFS 54702 CUX MAFI Auto Queueing

*/

vars
	iter : Iterator;
	ti  : CM_TrackedItem;
	
begin
	if self.myTerminal = null // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1
	or not self.myTerminal.getConfig(QueueGroundExportRORO).Boolean then // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1		
		return false;
	endif;

	if self.myROROStructure = null or self.myCellularVoyageStructure &lt;&gt; null then
		return false;
	endif;
	
	iter := self.allOnsiteTIsByCargoTypeId.createIterator();
	self.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, "", iter);
	
	while iter.next(ti) do
		if not ti.isContainer then
			break;
		endif;
		
		if ti.isExport and not ti.isOnMAFI then
			return true;
		endif;
	endwhile;
	
	return false;
	
epilog
	delete iter;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasHmsMovement" id="61286c90-bfef-4366-a998-63c17dd2b11d">
        <source>hasHmsMovement():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars

begin
	
	if self.myHMSVoyageData &lt;&gt; null then
		if not self.myHMSVoyageData.allVoyageMovements.isEmpty then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasHoldJobSheet" id="b0213f06-feb0-4cd2-9954-d450dbdfc6f2">
        <source>hasHoldJobSheet() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		Returns true if voyage has a hold job sheet

Date				Who		Reason
19 August 2019		jlgzm1	Initial creation TFS 42872 Direct Delivery Between HOLD Voyages and Rail

*/

vars
	jobSheet : CM_VoyageJobSheet;
begin
	foreach jobSheet in self.allJobSheets where jobSheet.isVoyageHoldJobSheet do
		return true;
	endforeach;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasLoadJobs" id="038fa275-f040-4270-8208-50754edb7a19">
        <source>hasLoadJobs(): Boolean;
//----------------------------------------------------------------
