    <JadeMethod name="doFormLoad" id="43f4e34f-bd1e-4dbf-95e5-6e0a62dba96a">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
