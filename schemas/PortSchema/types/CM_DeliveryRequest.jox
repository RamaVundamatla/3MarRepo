    <JadeMethod name="getNominatedTA" id="899ceaba-7400-4239-81be-7fef7e54eb0d">
        <source>getNominatedTA() : CM_TerminalArea;
// 05/02/2010	cnwjre1	CCMS 1101 
vars
	ta,tmpta	 	: CM_TerminalArea;
	taList 			: CM_TerminalAreaArray;
	posn 			: Integer;
	bs,
 	taComp 			: CM_BlockStack;
	cmifRequest		:		CMIF_YAAutoPlan;
	agent  			: CM_YAAutoplanAgent;
begin

	create taList transient;
	/*
	
	//for ccms 1935...  cnwrd1 par 24169 10/6/2010
		
	1st get the TA's in order according to user selection or fifo	
	*/
	
	// if we are fifo then we want to work on ordered block stacks first then other areas
	if self.isFIFO then
		//first order the blockstacks
		foreach ta in self.allTerminalAreas do  : taLoop
		
			if not ta.isKindOf(CM_BlockStack) then
				continue;  //will add these to the end of the list later.
			endif;
			
			bs := ta.CM_BlockStack;
			
			if taList.isEmpty then
				taList.add(bs); //1st so just add
				continue;
			else
				foreach tmpta in taList do : listSort
					taComp := tmpta.CM_BlockStack;
					
					if taComp.effectiveFIFODate &lt; bs.effectiveFIFODate then
						continue listSort;
					else
						posn := taList.indexOf(taComp);
						taList.insert(posn, bs);
						continue taLoop;
					endif;				
				endforeach listSort;
			
				if not taList.includes(bs) then
					taList.add(bs); //must be newer than the last so add
				endif;
			endif;			
		endforeach taLoop;
		
		//now we need to add the non block stacks to the list.
		foreach ta in self.allTerminalAreas do   		
			if not ta.isKindOf(CM_BlockStack) then
				taList.add(ta);
			endif;		
		endforeach;
	else
		self.allTerminalAreas.copy ( taList);
	endif;
	
	//return taList.first;
	/* now step through and find the next free cargo item that matches our request*/	
	
	if app.myYAAgent = null then
		app.initialiseForStartAutoPlan(app.myPassport);
		if 	app.myYAAgent = null then
			return null;
		endif;
	endif;
	
	
	agent := app.myYAAgent;
	
	cmifRequest := agent.myCurrentCMIFYAAutoPlan;

	if cmifRequest = null or not global.isValidObject(cmifRequest) then
		create cmifRequest as  CMIF_YARequest transient;
		agent.setCurrentYAAutoPlan(cmifRequest);
	elseif not cmifRequest.isKindOf(CMIF_YARequest) then
		create cmifRequest as  CMIF_YARequest transient;
		agent.setCurrentYAAutoPlan(cmifRequest);
	else
		cmifRequest.clear();
	endif;	
	
	cmifRequest.CMIF_YARequest.initializeFromDeliveryRequest(self.myTerminal, self);

	
	foreach ta in taList where ta &lt;&gt; null do
		//do we have one available?
		if ta.hasAvailableMatchingTI(cmifRequest.CMIF_YARequest) then
			return ta;
		endif;
	endforeach;
	
	return null;
	
epilog 
	delete taList;
end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
