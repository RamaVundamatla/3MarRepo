	inheritMethod(form);

	form.myCurrentMapProduct := self.myProductMap;
	form.myCurrentMapProdGrp := form.myCurrentMapProduct.myProductGroupMap;
	form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
	form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;
/*
	form.myCurrentMapProduct := self.myProductMap;
	form.myCurrentMapProdGrp := self.myProductMap.myProductGroupMap;
	form.myCurrentMapTIService := self.myProductMap.myProductGroupMap.myCargoTypeMap;
	form.myCurrentMapTM := self.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap;

*/

	form.myTMCProduct := self;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
