    <JadeMethod name="txtMain_dblClick" id="9cd04e53-6b5e-4641-ae44-1921412c7c25">
        <controlMethod name="TextBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtMain_dblClick(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars
	textboxObj : TextBox;
	
begin
	app.mousePointer	:=	Busy;
	textboxObj := textbox;
	self.selectFile(textboxObj);
	
	if textbox.parent = self.shtImport then
		self.assessMainCodeImportFile();
	endif;
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
