    <JadeMethod name="getResultAsString" id="212aab89-06e6-4403-a973-d4a662283e36">
        <source>getResultAsString() : String;

/*

Purpose:		Return Ignored, Pass, or Fail as string		

Parameters:			

Return Value:		


Date			Who		Reason
20 October 2011	cnwmh5	Initial creation

*/

vars
	result			: String;
begin
	if self.ignored then
		result := "IGNORED";
	elseif self.passed then
		result := "PASS";
	else
		result := "FAIL";
	endif;
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTeamName" id="e6cbbb80-151f-4bd0-a4d8-f0249d04702f">
        <source>getTeamName() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
06 December 2024		navmd1	Initial creation

*/

vars

begin
	if self.testClass = null then
		return null;
	endif;
	
	return currentSchema.getClass(self.testClass).sendTypeMsg(UT_DSL::assignedTeam.name).String;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
