    <JadeMethod name="addToolbarControls" id="3563f74d-ca35-4f3a-b026-5fa133f826fe">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnNewQueue, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSuspend, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFullTask, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPin, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addFrame(self.frmDisplayOptions, CMUI_Toolbar.Control_Alignment_Right);	// jlgmd1 24/08/2020 TFS 49961 PRP - Hide Sub Queue Tasks
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);	

end;</source>
        <access>protected</access>
    </JadeMethod>
