    <JadeMethod name="utlUpdatePilotSurcharge" id="a2deac46-cb16-460a-86da-ca7948a70916">
        <updating/>
        <source>utlUpdatePilotSurcharge(_pxyPilotSurcharge : CM_InvTypePilotSurcharge input; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharges
//
vars
	realPilotSurcharge : CM_InvTypePilotSurcharge;
	beforeAuditText, afterAuditText : String;

begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyPilotSurcharge, " Proxy is Null" );
	
	realPilotSurcharge := _pxyPilotSurcharge.pxyGetRealObject.CM_InvTypePilotSurcharge;
	if realPilotSurcharge = null then
		self.raiseExceptionIfNull(_pxyPilotSurcharge, " Real is Null" );
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_pxyPilotSurcharge, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	beforeAuditText := realPilotSurcharge.getAuditText();
	
	realPilotSurcharge.setForUpdate(_pxyPilotSurcharge);
	
	afterAuditText := realPilotSurcharge.getAuditText();
	app.myAA.auditUpdateTrx(realPilotSurcharge, beforeAuditText, afterAuditText);
epilog

end;</source>
        <Parameter name="_pxyPilotSurcharge" type="CM_InvTypePilotSurcharge" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePort" id="2460470a-f5ad-46b9-b8a9-3e8159e09e45">
        <source>utlUpdatePort(pProxyPort:CM_Port; _makeActive : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Aug 2009		JMN			added code to make port active - needed for import
// ---------------------------------------------------------------------------
vars
	cancelSave :Boolean;
	realPort:CM_Port;
	expectedEdition:Integer;
	eventStr : String;
	codeChanged:Boolean;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();

	pProxyPort.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyPort.pxyGetRealObjectAndEdition(realPort, expectedEdition);
	
	if realPort = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Port.name, null, null);
		return;
	endif;

	app.myValUA.valPort(realPort, pProxyPort);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realPort);

	if _passport.noErrors and realPort.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Port', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPort, true);
	endif;
	
	if _passport.noErrors then
		if realPort.colour &lt;&gt; pProxyPort.colour then
			codeChanged := true;
		endif;
		realPort.setForUpdate(pProxyPort);
		if _makeActive then
			realPort.setIsActive(_makeActive);
		endif;
	endif;

	if _passport.noErrors then
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realPort.code  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realPort.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realPort.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realPort, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyPort" type="CM_Port"/>
        <Parameter name="_makeActive" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
