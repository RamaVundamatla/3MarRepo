    <JadeMethod name="setForUpdate" id="490626d6-8c16-485b-8f4d-a1cd087a2465">
        <updating/>
        <source>setForUpdate( _proxy : CM_VehicleBookingTimeSlot ) updating;
/*

Purpose:			Set for Update method - Updates attributes and references with new values on a persistent obejct from a proxy

Parameters:			_proxy	CM_VehicleBookingTimeSlot	Proxy object to set our values from

Return Value:		NONE

Date		Who		Reason
05 Apr 2013	cnwndl1	Initial creation	Par 31393
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
31 Aug 2022 navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
24 Apr 2023 navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
29 May 2023 navma1	Bug 58195: FR - EUP 53429 - BR - VBS changes MTN - null object reference.
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
09/08/2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry
26 Aug 2024 navcs2	Bug 62476: MTN - CM_VehicleBookingTimeSlot allTiIds collection not updating
*/

vars
	tiId					: String;
	ti						: CM_TrackedItem;
	now						: TimeStamp;
	tsInt					: TimeStampInterval;
	hrs						: Integer;
	type					: String;
	currentVoyages			: CM_VoyageSet;
	voyage					: CM_Voyage;
	timeSlotItemsToDelete	: ObjectSet;
	pxyVBSItem, 
	newRealVBSItem,
	vbsItemLoop				: CM_VehicleBookingTimeSlotItem;		// 26 Aug 2024 navcs2	Bug 62476
	terminal				: CM_Terminal;
	vbsProcess 				: CM_VBSProcess;
	isAdvanced				: Boolean;
begin
	terminal 						:= _proxy.myVehicleBookingTerminal.myTerminal;
	vbsProcess 						:= terminal.getMyVBSProcess;							// 26 Aug 2024 navcs2	Bug 62476
	
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then							// 26 Aug 2024 navcs2	Bug 62476
		isAdvanced := true;																	// 26 Aug 2024 navcs2	Bug 62476
	endif;																					// 26 Aug 2024 navcs2	Bug 62476
	
	// bare slot attributes
	self.bookingTSstart 			:= _proxy.bookingTSstart;
	self.bookingTSend 				:= _proxy.bookingTSend;
	self.myVehicleBookingTerminal 	:= _proxy.myVehicleBookingTerminal;
	
	//booked attributes
	self.includesDelivery			 := _proxy.includesDelivery;
	self.includesPickUp 			 := _proxy.includesPickUp;
	
	self.myVBTimeSlotType := _proxy.myVBTimeSlotType;
	
	if self.myCarrier &lt;&gt; _proxy.myCarrier then
		//special validation to stop carrier changes by lowly users near the slots due time.
		if _proxy.myCarrier &lt;&gt; null   and 
			not self.includesDelivery and 
			not self.includesPickUp   and 
			self.myVBTimeSlotType.myVBSProcess.code = CM_VBSProcess.VBS_STANDARD_CODE then												//24.4.2023 navhl20 #57716[57718]
				app.raiseCMException2( Must_select_least_one_of, app.getErrorString(PickingUp), app.getErrorString(Delivering), null, null );
				return;
		endif;
		
		tsInt 	:= self.getBookInAdvanceTimeInterval(hrs,type);
		now 	:= app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		if not app.getMyUser.canDo(null, PmCmpTerminalMaint) then
			if self.bookingTSstart &lt; now + tsInt then
				app.raiseCMException2(Vehic_sched_booki_must_made_le, hrs.String, type, null, null );
				return;
			endif;
		endif;
	endif;
	
	//20 Mar 2015	NDL	Par 35882 - Allow ability to send Email of VBS booking changes
	if self.myCarrier &lt;&gt; _proxy.myCarrier then
		if _proxy.myCarrier = null then
			//about to clear the existing carrier so unbook
			self.doEmailForUnbook( self.myCarrier );
		elseif self.myCarrier = null then
			//currently not booked, and about to book the new carrier value
			self.doEmailForBook( _proxy.myCarrier );
		else
			//about to clear the existing carrier so unbook AND replace with the new carrier, so bbok too.
			self.doEmailForUnbook( self.myCarrier );
			self.doEmailForBook( _proxy.myCarrier );
		endif;
	endif;
	
	self.myCarrier			:= _proxy.myCarrier;
	self.mySubCarrier		:= _proxy.mySubCarrier;			// 31/08/2022 navcs2 #53899
	self.myDriver			:= _proxy.myDriver;
	self.myVehicle			:= _proxy.myVehicle;
	self.remarks			:= _proxy.remarks;
	
	self.preGateInCheck		:= _proxy.preGateInCheck;		// 31/08/2022 navcs2 #53899
	self.preGateOutCheck	:= _proxy.preGateOutCheck;		// 31/08/2022 navcs2 #53899
	self.kioskCheck			:= _proxy.kioskCheck;			// 31/08/2022 navcs2 #53899	
	self.creationMethod		:= _proxy.creationMethod;		// 30/06/2023 jlizm1 53901			//14.07.2023 navma1 #59136
	self.myTILCType			:= _proxy.myTILCType;			// 09/08/2024	navcs2	ChangeRequest 63797
	
	// ### TFS 53899 21Feb2023 NAVPW1
	if _proxy.id = null and self.id = null then
		self.id := self.myVehicleBookingTerminal.generateNextVBSTimeslotId();
	else
		self.id := _proxy.id;
	endif;
	
	if _proxy.externalReference = null then
		if _proxy.pxyGetRealObject() = null then
			self.externalReference := self.myVehicleBookingTerminal.generateNextVBSExternalRefId();
		else
			self.externalReference := null;
		endif;
	else
		self.externalReference := _proxy.externalReference;
	endif;
	// ### TFS 53899 21Feb2023 NAVPW1

	//The proxy has a list (string array) of the cargo ids. This string array is not populated on the real object.
	foreach ti in self.allBookedTrackedItems discreteLock do
		//remove those that are no longer included
		if not _proxy.allTiIds.includes(ti.id) then
			ti.setVehicleBookingTimeslot( null );
		endif;
	endforeach;
	

	if not isAdvanced then																			// 26 Aug 2024 navcs2	Bug 62476
		
		create currentVoyages transient;	
	
		//12.11.2024 navma1 Moved inside the if statment , no need to do it for Advanced process 
		if terminal &lt;&gt; null then
			terminal.getAllCurrentVoyages( currentVoyages, true, false, false );					
		endif;
		foreach tiId in _proxy.allTiIds do
			ti := null;
			
			//look for pre-notified being delivered
			// 14/10/2022 navcs2 #53899 
			if terminal &lt;&gt; null then
				ti := terminal.lookupTrackedItem(tiId, TI_CargoType_Null, TI_STATE_NOTIFIED, null, false);
			endif;
			
			if ti &lt;&gt; null and ti.id &lt;&gt; tiId then
				ti := null;
			endif;
			
			//look for on-site cargo to pick-up
			if ti = null then
				// 14/10/2022 navcs2 #53899 
				if terminal &lt;&gt; null then
					ti := terminal.lookupTrackedItem(tiId, TI_CargoType_Null, TI_STATE_NORMAL, null, false);
				endif;
			endif;
			
			if ti &lt;&gt; null and ti.id &lt;&gt; tiId then
				ti := null;
			endif;
			
			if ti = null then
			//19 May 2015	NDL	Par 35930
				//nothing found on-site, look for cargo on a current voyage that is an import
				foreach voyage in currentVoyages do
					ti := voyage.lookupTrackedItem(tiId, TI_CargoType_Null, false);
					if ti &lt;&gt; null and ti.id = tiId and ti.isImport then
						break;
					else
						ti := null;
					endif;
				endforeach;
			endif;
			
			if ti &lt;&gt; null and ti.id = tiId and not self.allBookedTrackedItems.includes( ti ) then
				ti.setVehicleBookingTimeslot( self );
			endif;
		
		endforeach;
	endif;																								// 26 Aug 2024 navcs2	Bug 62476
	
	//used booking attributes
	self.myVehicleVisitRecord := _proxy.myVehicleVisitRecord;
	
	//Pre-conversion code.  //01 Oct 2014 NDL CCMS 2399
	// ### TFS 53899 22Feb2023 NAVPW1 - Commented Code
	/*if _proxy.id = null then
		//NEW inversed collections rely on 'id' as the key.
		self.id := null;
		self.allBookingRefs.clear();
		self.allBulkReleases.clear();
		
	else
		self.id := _proxy.id;
		self.allBookingRefs.clear();
		if _proxy.allBookingRefs &lt;&gt; null and not _proxy.allBookingRefs.isEmpty then
			_proxy.allBookingRefs.copy( self.allBookingRefs );
		endif;
		self.allBulkReleases.clear();
		if _proxy.allBulkReleases &lt;&gt; null and not _proxy.allBulkReleases.isEmpty then
			_proxy.allBulkReleases.copy( self.allBulkReleases );
		endif;
	endif;*/
	// ### TFS 53899 22Feb2023 NAVPW1 - Commented Code
	
	// ### TFS 53899 22Feb2023 NAVPW1
	self.allBookingRefs.clear();
	if _proxy.allBookingRefs &lt;&gt; null and not _proxy.allBookingRefs.isEmpty then
		_proxy.allBookingRefs.copy( self.allBookingRefs );
	endif;
	
	self.allBulkReleases.clear();
	if _proxy.allBulkReleases &lt;&gt; null and not _proxy.allBulkReleases.isEmpty then
		_proxy.allBulkReleases.copy( self.allBulkReleases );
	endif;
	// ### TFS 53899 22Feb2023 NAVPW1
	
	
	create timeSlotItemsToDelete transient;
	self.allVehicleBookingItems.copy(timeSlotItemsToDelete); 
	
	foreach pxyVBSItem in _proxy.allVehicleBookingItems discreteLock do
		newRealVBSItem := app.myProxyManager.getRealObject(pxyVBSItem).CM_VehicleBookingTimeSlotItem;
		if newRealVBSItem = null then
			app.myUtilityCA.utlCreateVBSTimeSlotItem(pxyVBSItem, newRealVBSItem, self, app.myPassport);
		else
			timeSlotItemsToDelete.remove(pxyVBSItem.pxyGetRealObject);
			app.myUtilityUA.utlUpdateVBSTimeSlotItem(pxyVBSItem,  app.myPassport);
		endif;
			
		if  app.myPassport.hasErrors() or newRealVBSItem = null then
			return;
		endif;
		
		if  newRealVBSItem.myBooking &lt;&gt; null then
			self.allBookingRefs.addNoDuplicates( newRealVBSItem.myBooking,false);
		endif;
		
		if newRealVBSItem.myBulkRelease &lt;&gt; null then
			self.allBulkReleases.addNoDuplicates( newRealVBSItem.myBulkRelease, false);
		endif;
			
		if newRealVBSItem.myTrackedItem &lt;&gt; null then
			if isAdvanced then
				newRealVBSItem.myTrackedItem.setVehicleBookingTimeslot(self);
			else
				self.allTiIds.add( newRealVBSItem.myTrackedItem.id);
			endif;
		endif;
		
	endforeach;		
epilog
	if timeSlotItemsToDelete &lt;&gt; null then			//29.05.2023 navma1 #58195
		timeSlotItemsToDelete.purge;
		delete timeSlotItemsToDelete;
	endif;
	delete currentVoyages;
	
end;</source>
        <Parameter name="_proxy" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateTransferSlots" id="957f35b1-bdcb-491e-86a8-355c6b78d4b0">
        <updating/>
        <source>setForUpdateTransferSlots(_startTimeSlot, _endTimeSlot : TimeStamp; _remarks : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots

*/

vars

begin
	self.bookingTSstart := _startTimeSlot;
	self.bookingTSend := _endTimeSlot;
	self.remarks := _remarks;
epilog

end;</source>
        <Parameter name="_startTimeSlot" type="TimeStamp"/>
