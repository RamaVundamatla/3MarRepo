        <source>valStopOverriddenReason(
	_realStopOverriddenReason	: CM_StopOverridenReason input;
	_proxyStopOverriddenReason	: CM_StopOverridenReason input );

/*
Date			Who		Reason
20 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	self.raiseExceptionIfNull( _proxyStopOverriddenReason, app.getString( Stop_Overridden_Reason ) &amp; ' Proxy' );
	self.raiseExceptionIfNull( _realStopOverriddenReason, app.getString( Stop_Overridden_Reason ) &amp; ' Real' );
	
	_proxyStopOverriddenReason.raiseExceptionIfNotProxy( method );
	
	if _realStopOverriddenReason.code = _proxyStopOverriddenReason.code then
		_proxyStopOverriddenReason.validateForUpdate();
	else
		_proxyStopOverriddenReason.validateForCreate();
	endif;
	
epilog
	
end;
</source>
