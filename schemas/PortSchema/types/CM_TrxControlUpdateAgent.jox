    <JadeMethod name="trxLocationActivityNeedsRecalc" id="e6eabda0-8f93-4c51-90b7-fc4a568f2ec9">
        <updating/>
        <source>trxLocationActivityNeedsRecalc( _la : CMEVT_LocationActivity input; _reCalcBalanceSet : CMEVT_LocationActivityByDate input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	self.initialiseActivityWithPassport(_passport, method);

