    <JadeMethod name="getPhotoByIndex" id="2503d21c-c30e-4e4b-8d60-aa97856869df">
        <source>getPhotoByIndex(_index :Integer):CM_Photo;
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61455
*/

vars
	attachment 	: CM_Attachment;
	count 		: Integer;
begin
	foreach attachment in self.allAttachments where attachment.type = CM_Attachment.Type_Photo do
		if attachment.isKindOf (CM_Photo) then
			// always will be but lets not get exceptions in report writer :-)
			count := count + 1;
		
			if count = _index then		
				return attachment.CM_Photo;
			endif;
		endif;
	endforeach;
	
	return null;
epilog
	
end;</source>
