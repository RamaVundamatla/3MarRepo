    <JadeMethod name="cloneMySelf" id="2ed7254a-b386-4f85-91a4-1ca88347fa66">
        <source>cloneMySelf(_newStructure : CM_ROROVesselStructure; 
			_clearCode : Boolean; 
			_copy : Boolean): CM_DeckVessel;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Mar 2011	cnwer1	Initial creation
16 May 2011 cnwer1	27486 changes to method signature of CM_DeckVesselSub::cloneMySelfSub
*/

vars
	aDeck, newDeck : CM_DeckVessel;
	newSubDeck,
	subDeck : CM_DeckVesselSub;
begin
	newDeck := self.cloneSelf(_copy);
	
	if _clearCode then
		newDeck.code:=null;
	endif;
	newDeck.setMyROROStructure(_newStructure);

	self.cloneMySelfSuper(newDeck, _copy);

	foreach aDeck in self.allSubDecks discreteLock do
		subDeck := aDeck.CM_DeckVesselSub;
	
		newSubDeck := subDeck.cloneMySelfSub(newDeck, false,  _copy);
	
	endforeach;
	
	return newDeck;
epilog

end;</source>
        <Parameter name="_newStructure" type="CM_ROROVesselStructure"/>
        <Parameter name="_clearCode" type="Boolean"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_DeckVessel"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelfForVoyage" id="a245f112-2ad7-42aa-b107-f6155d9c743a">
        <source>cloneMySelfForVoyage(	_newStructure : CM_ROROVoyageStructure;
						_transient : Boolean): CM_DeckVoyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	aDeck		 :CM_Deck;
	subDeck 	: CM_DeckVesselSub;
	newSubDeck	: CM_DeckVoyageSub;
	newDeck : CM_DeckVoyage;
begin
	newDeck := self.cloneSelfAs(CM_DeckVoyage,_transient).CM_DeckVoyage;
	

	//newDeck.code:=null;

	newDeck.setMyVoyageStructure(_newStructure);

	self.cloneMySelfSuper(newDeck, _transient);

	foreach aDeck in self.allSubDecks discreteLock do
		subDeck := aDeck.CM_DeckVesselSub;
	
		newSubDeck := subDeck.cloneMySelfSubForVoyage(newDeck, _transient);
	
	endforeach;
	
	return newDeck;
epilog

end;</source>
        <Parameter name="_newStructure" type="CM_ROROVoyageStructure"/>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="delete" id="5a71067b-cfcb-46eb-af9d-0128f5ff2034">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwer1	Initial creation

*/

vars

begin
	if not  self.isTransient then
		if self.myROROStructure &lt;&gt; null then
			self.myROROStructure.causeEvent(EVENT_VESSEL_DECK_DELETE,false,self);
		endif;

	endif;
	
epilog	

end;</source>
    </JadeMethod>
