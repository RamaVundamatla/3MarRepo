    <JadeMethod name="validateCommon" id="55c8d28d-4ede-40b6-b359-4ea877fa598b">
        <source>validateCommon();
/*

Purpose:			Check that the proxy looks OK

Parameters:			

Return Value:		

Date			Who		Reason
20 April 2010	conkc1	Initial creation
*/
vars
	
begin	
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "column name", null, null);
		app.raiseCMException(Input_required_field_colName, null, null); // cnwdb2	PAR 35364
	endif;
	//if self.myDataDumpExtractClass = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "DataDumpExtractClass", null, null);
	//endif;
	
	if self.myDataDumpFeature = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "DataDumpFeature", null, null);
		app.raiseCMException1(Input_required_field_dtaDmpFet,self.name, null, null); // TFS 2930  // cnwdb2	PAR 35364

	endif;

	if self.myDataDumpSQLDataType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "DataDumpSQLDataType", null, null);
		app.raiseCMException1(Input_required_field_dtaDmpSQL,self.name, null, null); // TFS 2930

	endif;

epilog

end;</source>
    </JadeMethod>
