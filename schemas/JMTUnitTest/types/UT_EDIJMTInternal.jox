    <JadeMethod name="tCargoOnSiteAction" id="d07be99b-3335-4413-b138-31d77a05e856">
        <source>tCargoOnSiteAction();
//
// 15 Jan 2018	jlgrs1	TFS 36636 STW Cargo By Site to be partial loading
//
constants
	USER_DEF_NAME : String = "JMTInternalCargo";
	CONTAINERID : String = "SARG1234543";
	BREAKBULK : String = "BB01";
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	operator : CM_Operator;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	ti : CM_TrackedItem;
begin
	self.setTerminalConfig(EdiCargoByAllowPartial, true);
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	ti := self.getTrackedItem(BREAKBULK);
	if ti &lt;&gt; null then
		beginTransaction;
		ti.erase(NORMAL_ERASE);
		commitTransaction;
//		self.deleteTrackedItem(ti, true);
	endif;
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
//	container := self.addContainer(CONTAINERID, operator, "4102", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargoOnSite xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargoOnSite.xsd"&gt;
	&lt;AllCargoOnSite&gt;
		&lt;CargoOnSite&gt;
			&lt;directDelivery/&gt;
			&lt;hasRadio/&gt;
			&lt;isNew/&gt;
			&lt;isWeightCertified/&gt;
			&lt;preSlung/&gt;
			&lt;selfPropelled/&gt;
			&lt;wet/&gt;
			&lt;certificate1Expiry/&gt;
			&lt;certificate2Expiry/&gt;
			&lt;docsCleared/&gt;
			&lt;docsReceived/&gt;
			&lt;docsReturned/&gt;
			&lt;docsSent/&gt;
			&lt;expiryDate/&gt;
			&lt;cargoWeight&gt;33000&lt;/cargoWeight&gt;
			&lt;height/&gt;
			&lt;length/&gt;
			&lt;overHeight/&gt;
			&lt;overLengthBack/&gt;
			&lt;overLengthFront/&gt;
			&lt;overWidthLeft/&gt;
			&lt;overWidthRight/&gt;
			&lt;tareWeight&gt;33000&lt;/tareWeight&gt;
			&lt;totalWeight&gt;33000&lt;/totalWeight&gt;
			&lt;vent/&gt;
			&lt;volume/&gt;
			&lt;weight&gt;33000&lt;/weight&gt;
			&lt;width/&gt;
			&lt;availabilityGrade/&gt;
			&lt;carbonDioxide/&gt;
			&lt;contentsStatus/&gt;
			&lt;doors/&gt;
			&lt;humidity/&gt;
			&lt;oxygen/&gt;
			&lt;parentCargoTypeCode/&gt;
			&lt;quantity/&gt;
			&lt;receiptTransportMode/&gt;
			&lt;site&gt;1&lt;/site&gt;
			&lt;totalQuantity/&gt;
			&lt;year/&gt;
			&lt;temperature/&gt;
			&lt;alternativeId/&gt;
			&lt;bol/&gt;
			&lt;bookingRef/&gt;
			&lt;breakBulkType/&gt;
			&lt;carType/&gt;
			&lt;cargoGroupId/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
