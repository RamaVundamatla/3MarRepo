    <JadeMethod name="create" id="c6186372-9477-48c1-acba-8526d4b0d55f">
        <updating/>
        <source>create(_pattern, _replacement: String; _caseInsensitive: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 January 2024		navmd1	Initial creation TFS 57278 Refactor string manipulation post JADE2022

*/

vars

begin
	create self.myRegexPattern transient;
	self.myRegexPattern.setIgnoreCase(_caseInsensitive).compile(_pattern);
	
	self.replacementText := _replacement;
	
epilog

end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_replacement" type="String"/>
        <Parameter name="_caseInsensitive" type="Boolean"/>
    </JadeMethod>
