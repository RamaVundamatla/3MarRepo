    <JadeMethod name="doControlEvent" id="141c49fa-0e04-4dee-b3cf-cd6c27c813b1">
        <updating/>
        <source>doControlEvent(_control: Control) updating;

// cnwdvb1 14 January 2003 

vars

	new, old	: Integer;

begin

	if _control = self.multiDetail.myAddSelectedBtn or _control = self.multiDetail.myRemoveSelectedBtn then
		new := self.multiDetail.mySelectedListBox.listCount;
		old := self.multiDetail.myAvailableListBox.listCount;
		self.tblNewHeader.setValueByName(ETRow_NewNumItems, new);
		self.tblOldHeader.setValueByName(ETRow_OldNumItems, old);
	endif;
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doLoadDockets" id="251550a4-f35c-4694-a86f-34e9a336fccb">
        <source>doLoadDockets(_selectedTicket : CM_LogScalingHdr) protected;

// cnwdvb1 26 November 2002 
vars

	index : Integer;
begin

	self.tblOldHeader.setValueByName(ETRow_OldDocketNumber, _selectedTicket.bolNumber);
	index := self.cmbOldSupplier.findString(1, _selectedTicket.operatorCode);
	if index &lt;&gt; 0 then
		self.tblOldHeader.setValueByName(ETRow_OldSupplier, _selectedTicket.operatorCode);
	endif;
	self.tblOldHeader.setValueByName(ETRow_OldNumItems, _selectedTicket.allLogScalingDtls.size);

	index := self.cmbNewSupplier.findString(1, _selectedTicket.operatorCode);
	if index &lt;&gt; 0 then
		self.tblNewHeader.setValueByName(ETRow_NewSupplier, _selectedTicket.operatorCode);
	endif;
	self.cmbNewSupplier.listIndex := index;
	
end;</source>
        <access>protected</access>
        <Parameter name="_selectedTicket" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="11d0f217-b300-4317-918b-7dc6b9841141">
        <updating/>
        <source>doResize() updating;
// -------------------------------------------
// Created 09 October 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.splitter.visible then
		self.splitter.top 	:= self.frmToolbar.height;
	endif;
	inheritMethod();


end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="d5fbd6d6-b9e0-41b7-a5da-a81f942afe21">
        <updating/>
        <source>doSave() protected, updating;

// cnwdvb1 26 November 2002 
// 10/12/2014  cnwdb2	PAR 35364

vars

	detail 			: CM_LogScalingDtl;
	newHdr, brand	: CM_LogScalingHdr;
	array			: ObjectArray;
	iter			: Iterator;
	newDocket,
	tmpStr, 
	supplierCode	: String;
	numItems		: Integer;
	result			: Integer;


begin

	on Exception do self.xHandler(exception, app.myPassport);
	app.mousePointer := MousePointer_HourGlass;	
	newDocket	:= self.tblNewHeader.getValueByName(ETRow_NewDocketNumber).String;
	supplierCode:= self.tblNewHeader.getValueByName(ETRow_NewSupplier).String;
	numItems	:= self.tblNewHeader.getValueByName(ETRow_NewNumItems).Integer;
	if newDocket = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'New docket number', ETRow_NewDocketNumber, null);
		app.raiseCMException(Input_required_field_nwDocNum, ETRow_NewDocketNumber, null);

		return;
	endif;
	if	supplierCode = null then
		tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, "Supplier");
	//	app.raiseCMException1(REQUIRED_FIELD, 'New ' &amp; tmpStr, ETRow_NewSupplier, null);
		app.raiseCMException1(Input_required_field_new, tmpStr, ETRow_NewSupplier, null); // cnwdb2	PAR 35364
		return;
	endif;
	create array transient;
	self.multiDetail.getSelected(array);
	
	if array.size = 0 then
		app.raiseCMException(NoItemsSelected,null, null);
		return;
	endif;
	
	if array.size &lt;&gt; numItems then
		app.raiseCMException2(VB_COUNT_MISMATCH, 'items in the list', 'No. Items', ETRow_NewNumItems, null);
		return;
	endif;
	
	if array.size = self.myOldLogScalingHdr.allLogScalingDtls.size then
		app.raiseCMException(UseDeleteFunction, null,null);
		return;
	endif;
	
	create newHdr transient;
	newHdr.setProxy(newDocket, supplierCode, null, self.myOldLogScalingHdr.inputDateTime, self.myTerminal);
	iter := array.createIterator;
	while iter.next(detail) do
		detail.setProxy(detail.logID, detail.conditionCode, detail.minSED, detail.maxSED, newHdr, detail.scalerCode);
	endwhile;
	self.myOldLogScalingHdr.createScalingExtra(newHdr);
	
	while true do
		app.myTrxCA.trxCreateLogScalingSplit(self.myOldLogScalingHdr, newHdr, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog('Scaling Data Split', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog
	delete array;
	delete iter;
	delete newHdr;
	app.mousePointer := MousePointer_Default;		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initForm" id="95ab4e00-789b-4efa-a56c-e47154a41b75">
        <updating/>
        <source>initForm(_selectedTicket : CM_LogScalingHdr) updating;

// cnwdvb1 25 November 2002 

vars

	entTableDef : EntTableDef;
	cargoType	: CM_CargoBOLType;
begin

	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	cargoType 			:= app.myRoot.allBOLTypes[BOLType_Log];
	
	self.tblNewHeader.setTerminologyRelevant(cargoType, self.myTerminal);
	entTableDef := app.myController.getEntTableDef(ETDef_NewDocketHeader);
	self.tblNewHeader.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.tblNewHeader.resetSize();

	self.tblOldHeader.setTerminologyRelevant(cargoType, self.myTerminal);
	entTableDef := app.myController.getEntTableDef(ETDef_OldDocketHeader);
	self.tblOldHeader.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.tblOldHeader.resetSize();
	
	self.multiDetail.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.multiDetail.formDisplayEntryMethodName := 'displayDetail'; 
	self.multiDetail.availableHeading := 'Old Ticket';
	self.multiDetail.selectedHeading := 'New Ticket';
	self.multiDetail.multiSelect := ListBox.MultiSelect_Extended;
	self.multiDetail.myBaseForm	:= self;
	
	self.cmbNewSupplier.listCollection(app.myRoot.allOperators, true, 0);
	
	multiDetail.setAvailable(_selectedTicket.allLogScalingDtls, true);
	self.doLoadDockets(_selectedTicket);
	self.myOldLogScalingHdr := _selectedTicket;
	self.tblOldHeader.userInputEnabled := false;
	self.tblNewHeader.setFocus();
	self.tblNewHeader.moveFirst();
	self.multiDetail.setTabIndex();

	self.multiDetail.cnEcResizeContents();
	self.resize();

end;</source>
        <Parameter name="_selectedTicket" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="b3c38a73-9d23-449d-bc4c-438a9a9e66d3">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars
	theActiveControl	: Control;
	
begin

	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	if keyCode = J_key_Tab then
		self.tblNewHeader.handleFormTab(keyCode, shift, self.btnCancelBase, self.multiDetail);
		if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	endif;

	inheritMethod(keyCode, shift);
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="64136fa6-0cc6-47b6-97dd-ff8b3645a304">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.multiDetail.backColor	:= self.backColor;
	
	self.setColorsForEntryTable(self.tblNewHeader);
	self.setColorsForEntryTable(self.tblOldHeader);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d1bee172-d559-4c0d-9805-fd2f1b0befbb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006340, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="xHandler" id="71b7d6c2-5360-405f-a943-236893e24b08">
        <source>xHandler(exObj : Exception; _passport : CM_Passport input) : Integer;

// cnwdvb1 26 November 2002 

vars
	index : Integer;
	obj   : Object;

begin

	if exObj.isKindOf(CM_Exception) then
		if exObj.CM_Exception.isWarning then
			app.addWarningFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
			return Ex_Continue;
		endif;
		
		app.addErrorFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
		
		if exObj.continuable then
			return Ex_Continue;
		endif;
	endif;

	return Ex_Pass_Back;
	
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
