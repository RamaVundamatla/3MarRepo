    <JadeMethod name="getInvoiceLineType" id="b91cc688-040a-4468-bb58-250669c9c22b">
        <source>getInvoiceLineType() : String;
/*
Purpose:			

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	detail : CM_InvoiceContractDetails;
	objset : ObjectSet;
	invLineTypeStr : String;
	invLineTypeObj : CM_InvoiceLineDesc;
begin
	create objset transient;
	foreach  detail in self.allInvoiceContractDetails discreteLock do
		if detail.myInvoiceLineType &lt;&gt; null
		and not objset.includes (detail.myInvoiceLineType) then
			objset.add(detail.myInvoiceLineType);
		endif;
	endforeach;
	
	foreach invLineTypeObj in objset as CM_InvoiceLineDesc do
		if invLineTypeStr = null then
			invLineTypeStr := invLineTypeObj.narration;
		else
			invLineTypeStr := invLineTypeStr &amp; "," &amp; invLineTypeObj.narration;
		endif;
	endforeach;
	return invLineTypeStr;
epilog
	delete objset;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getService" id="06b6dc8a-8905-4389-bbf9-95fc715504d7">
        <source>getService() : String;
/*
Purpose:			

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	detail : CM_InvoiceContractDetails;
	rate : CM_InvoiceContractRate;
	objset : ObjectSet;
	serviceCsv : String;
	serviceObj : CM_Service;
begin
	create objset transient;
	foreach  detail in self.allInvoiceContractDetails discreteLock do
		foreach rate in detail.allInvoiceContractRates do
			if rate.myService &lt;&gt; null
			and not objset.includes(rate.myService) then
				objset.add(rate.myService);
			endif;
		endforeach;
	endforeach;
	
	foreach serviceObj in objset as CM_Service do
		if serviceCsv = null then
			serviceCsv := serviceObj.name;
		else
			serviceCsv := serviceCsv &amp; "," &amp; serviceObj.name;
		endif;
	endforeach;
	return serviceCsv;
epilog
	delete objset;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
