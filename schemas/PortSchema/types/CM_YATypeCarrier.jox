    <JadeMethod name="getDisplay" id="74a09a86-f462-4ec7-bee5-7628bf815910">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin
	return dataObj.CM_Carrier.code;
end;</source>
