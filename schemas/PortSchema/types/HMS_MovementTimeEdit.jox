<Class name="HMS_MovementTimeEdit" id="3b12c6e5-5de3-43b8-ac24-cb81b636e323">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <JadeMethod name="createPropertyChanges" id="8c243ba9-7b18-45aa-a867-bf705bc1d1b9">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	desc,
	oldStr,
	newStr : String;
	tmpDT : TimeStamp;
	propertyChange : HMS_PropertyChange;
	fromPMovement : HMS_VoyageMovement;
	fromWMovement : CMIF_HMS_WorkingMovement;
begin

	// Status has changed from planned to actual
	
	inheritMethod(_cmifTrans);
	
	fromWMovement := _cmifTrans.myWorkingMovement;
	fromPMovement := _cmifTrans.myProxyHMSObject.HMS_VoyageMovement;
	
	if fromWMovement &lt;&gt; null then
		tmpDT := fromWMovement.occursOnDT;
	elseif fromPMovement &lt;&gt; null then
		tmpDT := fromPMovement.occursOnDTNEW;	
	else
		return;
	endif;
	
	if self.myMovement.occursOnDTNEW &lt;&gt; tmpDT then
		
		create propertyChange;
		
		oldStr := self.myMovement.occursOnDTNEW.shortCurrentLocaleSystemUTC();	// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
	 	newStr := tmpDT.shortCurrentLocaleSystemUTC();
		
		//oldStr := self.myVoyageMovement.moveDTActual.Date.format('dd/MM/yy') &amp; ", " &amp; self.myVoyageMovement.moveDTActual.Time.currentLocaleFormatJMT();
	 	//newStr := fromMovement.moveDTActual.Date.format('dd/MM/yy') &amp; ", " &amp; fromMovement.moveDTActual.Time.currentLocaleFormatJMT();	 	
		
		/*if fromMovement.moveStatus = MovementStatus_ConfirmedPlan then
		  	desc := "Movement PLAN CONFIRMED time changed";
	  	elseif fromMovement.moveStatus = MovementStatus_Actual then
		  	desc := "Movement ACTUAL time changed";
		elseif fromMovement.moveStatus = MovementStatus_Planned then		  
		  	desc := "Movement PLANNED time changed";
		else*/
		  	desc := "Movement time changed";				  
		//endif;

	  	propertyChange.set(self, desc, oldStr, newStr);		  	
		  					  
	endif;
	
	/*if fromMovement.myPersistentMovement &lt;&gt; null then //must be an edit 
		if self.myVoyageMovement.moveDTPlanned &lt;&gt; fromMovement.moveDTPlanned then
			create propertyChange;
			if fromMovement.moveStatus = MovementStatus_ConfirmedPlan then
				desc := "Movement PLAN CONFIRMED time changed";
			else
				desc := "Movement PLANNED time changed";
			endif;
			oldStr := self.myVoyageMovement.occursOnDT.shortCurrentLocaleFormat();
		 	newStr := fromMovement.occursOnDT.shortCurrentLocaleFormat();
			//oldStr := self.myVoyageMovement.moveDTPlanned.Date.format('dd/MM/yy') &amp; ", " &amp; self.myVoyageMovement.moveDTPlanned.Time.currentLocaleFormatJMT;
		 	//newStr := fromMovement.moveDTPlanned.Date.format('dd/MM/yy') &amp; ", " &amp; fromMovement.moveDTPlanned.Time.currentLocaleFormatJMT;  			 	
		  	propertyChange.set(self, desc, oldStr, newStr);
		endif;		
	endif;*/	  	
  	
end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="e09a901d-3751-43fa-835d-f7ed4a534535">
        <updating/>
        <source>setTypeDetails() updating, protected;

vars

begin
	// Set type and typeString
	type:=TRANS_TYPE_EditMovementTime;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="701768b2-0a35-4347-8e53-837ca02bd983">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myVoyageMovement = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Movement', 'Null', null, null);
		return false;
	endif;	

	if _transController.myWorkingMovement = null
	and _transController.myProxyHMSObject = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Movement', 'Null', null, null);
		return false;
	endif;
	return rtnValue;				
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
