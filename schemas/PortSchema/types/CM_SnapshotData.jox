    <JadeMethod name="getDisplayStringForAttribute" id="262367fe-63a8-4de7-a7e6-5b31adeb7654">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwndl1	Initial creation	CCMS 1023
17/02/2010			cnwcs5	use property instead of method for number of items
*/

vars
	str	:String;
begin

	if _attrName = ETRow_RunDate then
		return self.systemToLocalTime(self.runDateTime).Date.asStringJMT;	// 13/7/16 cnwmp6 TFS 488 - Multi timezone support
		
	elseif _attrName = ETRow_RunTime then
		return self.systemToLocalTime(self.runDateTime).Time.asStringJMT;	// 13/7/16 cnwmp6 TFS 488 - Multi timezone support
		
	elseif _attrName = ETRow_RunDateTime then
		return self.systemToLocalTime(self.runDateTime).asStringJMT;	// 13/7/16 cnwmp6 TFS 488 - Multi timezone support
		
	elseif _attrName = ETRow_ResultsName then
		return self.name;
		
	elseif _attrName = ETRow_User then
		if self.myUser = null then
			return null;
		else
			return self.myUser.code;
		endif;
		return self.name;
		
	elseif _attrName = ETRow_NumItems then
		str := self.numberOfItems.asStringJMT;	// 17/02/2010 cnwcs5 
		return str;
	
	elseif _attrName = ETRow_InvoiceLines then		// Nov 2010 CCMS 1043
		str := self.getInvoiceLineCount.asStringJMT();
		return str;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFieldProperties" id="a368c42a-f309-4460-991c-1c756fda1056">
        <source>getFieldProperties( _queryProperties : CM_QueryPropertyArray input );
/*
Purpose:			
Parameters:			
Return Value:		

Date				Who		Reason
07 December 2009	cnwndl1	Initial creation	CCMS 1023
17/12/2009			cnwcs5	Changed parameter usage from io to input
*/

vars

begin

	_queryProperties.clear();
	
	if self.myOutputFormat_SS &lt;&gt; null then
		self.myOutputFormat_SS.getFieldProperties( _queryProperties );
	endif;
	
epilog

end;</source>
        <Parameter name="_queryProperties" type="CM_QueryPropertyArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFirstInvoice" id="7faa68ce-3e63-4864-a16c-a7eea5e5a983">
        <source>getFirstInvoice():CM_Invoice;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

	dos		: CM_DynamicObject_Snapshot;
	invLine	: CM_InvoiceLine;
	
begin

	foreach dos in self.allSnapshotData do
		foreach invLine in dos.allInvoiceLines do 
			return invLine.invoice;
		endforeach;
	endforeach;
	
	return null;
	
end;</source>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
