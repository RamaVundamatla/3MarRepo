    <JadeMethod name="doClickSearch" id="8bcd4218-2cba-4c0a-8257-8751690a1147">
        <source>doClickSearch();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

	text : String;
	iter : Iterator;
	startObject : CM_BookingRef;
	textLength : Integer;
	bookingRefLength : Integer;
	booking : CM_BookingRef;
	index : Integer;

begin

	self.tblBookings.rows := self.tblBookings.fixedRows;

	text := self.txtBookingFilt.text.trimBlanks.toUpper;
	if text = null or text = self.lblBookingFilt.caption.toUpper.trimBlanks then
		return;
	endif;

	iter := self.myTerminal.allBookingRefsByStatusRef.createIterator;
	startObject := self.myTerminal.allBookingRefsByStatusRef.getAtKeyGeq(1,text);
	if startObject = null then
		return;
	endif;
	
	textLength := text.length;
	iter.startAtObject( startObject );
	while iter.next( booking ) do
		if booking.status &lt;&gt; 1 then
			break;
		endif;
		bookingRefLength := booking.bookingReference.length;
		if bookingRefLength &lt; textLength then
			break;
		endif;
		if booking.bookingReference[1:textLength] &lt;&gt; text then
			break;
		endif;
		index := self.tblBookings.addItem( "0" &amp; Tab &amp; booking.bookingReference );
		self.tblBookings.accessRow(index).itemObject := booking;
	endwhile;

epilog

	//12 Dec 2016	NDL	TFS 3000 / 2549
	if textLength &gt; 0 and self.tblBookings.rows = self.tblBookings.fixedRows then
		self.msgBox(app.getErrorString1(Booking_found_startin_with,text), app.getErrorString(Warning), MsgBox_OK_Only, false);
	endif;
		
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="788cd138-07c9-4057-b482-72b2209ad3b2">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin
	
	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.resizedMargin - stdHeight;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtBookingFilt.setAndIncrementTabIndex( tabIndex );
		self.txtBookingFilt.visible := true;
	endif;
	self.txtBookingFilt.move( 	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnBookingFilt.setAndIncrementTabIndex( tabIndex );
		self.btnBookingFilt.visible := true;
	endif;
	self.btnBookingFilt.move(	self.txtBookingFilt.left + self.txtBookingFilt.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtBookingFilt.height + self.resizedMargin;
	cWidth := stdWidth;
	cHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - stdHeight - self.resizedMargin - self.resizedMargin - self.resizedMargin);
	if _initialSetup then
		self.tblBookings.setAndIncrementTabIndex( tabIndex );
		self.tblBookings.visible := true;
	endif;
	self.tblBookings.move(	self.resizedMargin, 
							cTop, 
							stdWidth, 
							cHeight);
							
	if _initialSetup then
		self.setupTable();
	endif;
	self.tblBookings.cnAdjustColumnWidths();
	
	cTop := cTop + self.tblBookings.height + self.resizedMargin;
	if _initialSetup then
		self.cmbLocation.setAndIncrementTabIndex( tabIndex );
		self.cmbLocation.visible := true;
	endif;
	self.cmbLocation.move( 	self.resizedMargin,
							cTop,
							stdWidth,
							stdHeight );
	
	
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="641654c4-59c8-45ca-91a2-c05f24d0ca2c">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation			TFS 2811 / 2549

*/

vars

	size : Integer;
	rowIndex : Integer;
	obj : CM_BookingRef;
	allBookings : CM_BookingRefSet;
	selected : Boolean;
	msg : String;

begin

	create allBookings transient;
	size := self.tblBookings.rows;
	foreach rowIndex in 1 to size do
		obj := self.tblBookings.accessRow(rowIndex).itemObject.CM_BookingRef;
		if obj = null then
			continue;
		endif;
		selected := self.tblBookings.accessCell(rowIndex,1).text = "1";
		if not selected then
			continue;
		endif;
		allBookings.add(obj);
	endforeach;
	
	if allBookings.isEmpty then
		msg := app.getErrorString(Bookings_selected_process);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	self.myMobileGenericAgent.setAllSelectedBookings( allBookings );
	self.myMobileGenericAgent.setMyLocationsController( self.cmbLocation.listObject.CM_LocationsController );
	self.myMobileGenericAgent.setDriver( self.txtBookingFilt.text );
		
	self.gotoForm( MOB_HHMultiBookingStore, false );
	
epilog

	delete allBookings;

end;

</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnThree" id="b6ec8fd0-d313-4d7a-8c9a-a347e63179ce">
