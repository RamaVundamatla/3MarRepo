        <source>uPurgeALLContracts() updating;
/*
Purpose:			

Date		Who		Reason
16 January 2023	navab1	TFS CR 55644 TASK 55684
*/

vars
	oArray : ObjectArray;

begin
	create oArray transient;
	CM_InvoiceContract.allInstances(oArray,0,false);
	
	beginTransaction;
	oArray.purge();
	commitTransaction;
epilog
	delete oArray;
end;</source>
