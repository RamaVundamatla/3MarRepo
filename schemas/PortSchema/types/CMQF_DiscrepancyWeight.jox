<Class name="CMQF_DiscrepancyWeight" id="ff759e17-3d31-4211-a769-755ad30f632f">
    <superclass name="CMQF_Discrepancy"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="43e14d4e-f5db-4b4c-82f9-340e0f321659">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 November 2008
//
// Implemented version: 7.7.1
// CCMS1765 GDANSK - Maersk reporting requirements. 
//----------------------------------------------------------------------
vars
	collection : CM_TITransactionSet;
	txn			: CM_TITransaction;
	i 			: Integer;
	field,
	oldField,
	newField	: String;
begin
	create collection transient;
	self.initiateFilterObjects(collection);
	foreach txn in collection do 
		if self.checkCommonFilters(txn) then
			foreach i in 1 to txn.CM_Edit.fieldsValues.size do
				txn.CM_Edit.getFieldValues(i, field, oldField, newField);
				//if field = CM_TrackedItem::weight.name then				//-cnwml2 MSL CCMS 1017
				if field = CM_TrackedItem::totalWeight.name then			//+cnwml2 MSL CCMS 1017
					_collection.add(txn);
					break;
				endif;
			endforeach;
		endif;
	endforeach;
epilog
	delete collection;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="386e2a6f-d313-49c2-8fc3-fa74cbb19574">
        <updating/>
        <source>initFields() updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 November 2008
//
// Implemented version: 7.7.1
// CCMS1765 GDANSK - Maersk reporting requirements. 
//----------------------------------------------------------------------
vars

begin
	self.allTxnTypes.add(TRANS_TYPE_EDIT);
epilog
end;</source>
    </JadeMethod>
</Class>
