    <JadeMethod name="resetForm" id="2c4559c8-a59d-41bf-8ab5-c9e99937441a">
        <updating/>
        <source>resetForm() updating;
// -----------------------------------------------------------------------------
// Created:		10 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.lstCargoIDvalues.clearTable();
	self.lstCargoIDvalues.userObject := null;
	self.allSearchTIs.clear();

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAvailableTIs" id="f9687b08-b1b8-46e7-9513-9143a08f9a1c">
        <source>setAvailableTIs(_bulkRelease : CM_BulkRelease);
// --------------------------------------------------------------------------------
// Created:		6 April 2010 by cnwjo3
//
// Purpose:		When a release by TI is being used then we need to display all the available
//				TIs in the lstCargoIDvalues depending on what is selected in cmbType (cargo types).
//				Unless its a Container.
//				par 23536

// 29 Aug 2013 cnwer1 par 32330
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// 18 Aug 2017	jlgrh7  TFS5455 STWO - Parsys B: release request is showing Transhipment cargo which is not at all on the release notes
// 16 May 2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
// 23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//
vars
	allTIs : CM_TIArray;
	ti ,bbTI: CM_TrackedItem;
	bbTIs,tisAlreadySelected : CM_TISet;
	gte : CMGTE_Entity;
	rel : CMGTE_Release;
	remaining : Integer;
	pos : Integer;								// TFS 38501
	removeTIs : CM_TIArray;						// TFS 38501
begin
	
	
	self.allSearchTIs.clear();
	self.lstCargoIDvalues.clear();
	create tisAlreadySelected transient;
	//get tis already selected in other gtes for this vvr 
	if self.myCurrentVehicleVisit &lt;&gt; null then
		foreach gte in self.myCurrentVehicleVisit.allGateEntities do
			if gte.isKindOf(CMGTE_Release) and gte &lt;&gt; self.myRealGTEEntity then
				rel := gte.CMGTE_Release;
				if rel.myTrackedItem &lt;&gt; null then
					tisAlreadySelected.add(rel.myTrackedItem);
				endif;
			endif;
		endforeach;
	endif;	
	
	
	create allTIs transient;
	create bbTIs transient;
	//build up a list of TIs to add to the cargo id listbox
	
	foreach ti in _bulkRelease.allTrackedItemsAssigned do
	//if releaseRequest is not null then this ti has already been set to another release request (way bill!)
			if self.cmbType.listIndex &gt; 0 then
				if self.cmbType.getObject() &lt;&gt; ti.myCargoType then
					continue;				
				endif;
			endif;		
		
			if  ti.myCargoType.isBreakBulkMulti   then
				if  (ti.hasBulkReleaseWithRemaining(_bulkRelease,remaining) and remaining = 0) then			
					continue;
				endif;
					
				bbTIs.clear;
				self.myTerminal.lookupAllOnsiteTrackedItems(ti.myCargoType.id, ti.id, bbTIs, false, null);		
				foreach bbTI in bbTIs where not self.allSearchTIs.includes(bbTI) and  not tisAlreadySelected.includes(bbTI)  do
					if bbTI.id &lt;&gt; ti.id then	//04 Jul 2016	NDL	TFS 2257 - Must be an exact match..
						continue;
					endif;
					if bbTI.myPrimaryActualLocation &lt;&gt; null and bbTI.myPrimaryActualLocation.isKindOf(CM_VehicleController) then
						continue;
					endif;
					allTIs.add(bbTI);
				endforeach;
				
			if _bulkRelease.myVoyage &lt;&gt; null and not _bulkRelease.myVoyage.isNullVoyage then
					bbTIs.clear;
					_bulkRelease.myVoyage.lookupAllTrackedItems(ti.id, ti.myCargoType.id, false, false, bbTIs, null);		
					foreach bbTI in bbTIs where not self.allSearchTIs.includes(bbTI) and  not tisAlreadySelected.includes(bbTI)  do										
						if bbTI.id &lt;&gt; ti.id then																																														//+TFS5455  Must be exact match with Release's TI's ID		
							continue;
						endif;
					allTIs.add(bbTI);
					endforeach;
			endif;
				
			else
				if  ti.releaseRequest = null  and not tisAlreadySelected.includes(ti)  then
					allTIs.add(ti);
				endif;
			endif;
	
	endforeach;
	
	// TFS 38501 If this release is for a work order, filter by the TIs on the work order
	if self.myWorkOrder &lt;&gt; null then
		create removeTIs transient;
		foreach ti in allTIs do
			pos := self.myWorkOrder.CM_WorkOrderTI.mySource.tiTextList.pos(ti.id, 1);
			if pos = 0 then
				removeTIs.addExclusive(ti);
			endif;
			//if self.myReserveDetail &lt;&gt; null and not self.myReserveDetail.allTrackedItems.includes(ti) then
			if self.myReserveDetail &lt;&gt; null and not self.myReserveDetail.includeTrackedItem(ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
				removeTIs.addExclusive(ti);
			endif;
		endforeach;
		foreach ti in removeTIs do
			allTIs.remove(ti);
		endforeach;
	endif;
	// TFS 38501 end
	
	//this adds the array to the cargo id list box
	self.IF_CMUI_TrackedItems.saveSelectedTrackedItems(allTIs);
	
	//19 Jul 2018	NDL	TFS 38617
	if allTIs.size &gt; 1 and self.myTerminal.getConfig(UseFilterForReleaseById).Boolean then
		self.btnCargoIDsearch.enabled := true;
	endif;
	
epilog
	delete allTIs;
	delete bbTIs;
	delete tisAlreadySelected;
	delete removeTIs;					// TFS 38501
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setByTypeByWeight" id="0fc36c92-56a7-48ce-ac0c-b13277392c5a">
        <source>setByTypeByWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 December 2023	navsp1	Initial creation TFS 61547
17/10/2024			navcs2	MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes
25/11/2024			navcs2	MTN-33452 EUP | Release Weight field is missing on the Release Cargo form
04/12/2024			navbs1  Bug MTN-33546: MTN - Road Gate - Release Empty / Full unknown textbox issue
19/02/2025			navcs2  MTN-34062 - EUP | Release by Weight - further issues
*/

vars

begin
	if not self.isGeneralCargo then 				//04.12.2024  navbs1  #33546
		//releaseQty and releaseWeight are applicable only for General cargo
		return;
	endif;
	//if self.isGeneralCargo and self.myBulkRelease &lt;&gt; null and self.myBulkRelease.releaseByType and self.myReserveDetail &lt;&gt; null then			//01.Feb.24 navsp1 TFS 62206		//04.12.2024  navbs1  #33546
	if self.myBulkRelease &lt;&gt; null and self.myBulkRelease.releaseByType and self.myReserveDetail &lt;&gt; null then																		//04.12.2024  navbs1  #33546
		if self.myCurrentVehicleVisit &lt;&gt; null and self.myCurrentVehicleVisit.myVehicleBookingTimeslot = null then
			if self.isByTypeByWeight then
				if self.chkAnyId.getBoolean then 	
					self.txtReleaseWeight.visible := true;
					self.txtReleaseQty.visible:= false;
				else
					self.chkAnyAmount.setValue(false);
					self.txtReleaseWeight.visible := true;
					self.txtReleaseQty.visible:= true;
				endif;
			else//Release by quantity												//26.Jan.24 navsp1 TFS 62064
				if self.myVbsti &lt;&gt; null and self.myVbsti.maxWeight &gt; 0 then			// 25/11/2024 navcs2	MTN-33452   	17/10/2024	navcs2	MTN-14819
					if self.chkAnyId.getBoolean then 								// 19/02/2025 navcs2 	MTN-34062
						self.txtReleaseWeight.visible := true;						// 25/11/2024 navcs2	MTN-33452		19/02/2025 navcs2 MTN-34062
						self.txtReleaseWeight.enabled := true;
						self.txtReleaseQty.visible:= false;							// 17/10/2024 navcs2	MTN-14819		19/02/2025 navcs2 MTN-34062
					else															// 19/02/2025 navcs2 	MTN-34062
						self.txtReleaseWeight.visible := false;													
						self.txtReleaseQty.enabled:= true;
					endif;
				else																
					if self.chkAnyId.getBoolean then 								
						self.txtReleaseWeight.visible := true;								//19/02/2025 navcs2 MTN-34062
						self.txtReleaseQty.enabled:= false;									//19/02/2025 navcs2 MTN-34062
					else																	//19/02/2025 navcs2 MTN-34062
						self.txtReleaseWeight.visible := false;								//19/02/2025 navcs2 MTN-34062
						self.txtReleaseQty.visible:= true;									//19/02/2025 navcs2 MTN-34062
						self.txtReleaseQty.enabled:= true;									//19/02/2025 navcs2 MTN-34062
					endif;
						
				endif;
			// 10/08/2024 navcs2  MTN-14819
				//self.txtReleaseQty.enabled := true;				//10.Jan.24 navsp1 TFS 61547 / Task 61999				// 10/08/2024 navcs2  MTN-14819
				//self.txtReleaseWeight.enabled 	:= true;				//10.Jan.24 navsp1 TFS 61547 / Task 61999		
			endif;
		endif;
	else
		self.txtReleaseQty.visible := true;
		self.txtReleaseWeight.visible 	:= false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCargoID" id="976c91f1-7982-42f4-9aff-5ea6cab48f60">
        <updating/>
        <source>setCargoID(_id : String) updating, protected;

/*

Purpose:			
	Every change to the cargo id should be pushed through this method, so that the other logic fires.
Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwjk3	Initial creation

*/

vars

begin
	self.txtCargoIDvalue.text := _id;
		
	if _id = null then
		self.lstCargoIDvalues.clearSelected();
		self.enableByTypeFields(true);
	else
		self.lstCargoIDvalues.setSelectedString(_id);
		self.clearByTypeFields();
		self.enableByTypeFields(false);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="setContainerAdditionalDetails" id="a505f776-c229-4377-a0a5-0b0dabb5b85d">
        <source>setContainerAdditionalDetails(_item : Object) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/08/2009	cnwjk3	Initial creation
01/07/2013	cnwdap1	PAR #30344 Don't set remarks and client ref from a TI - the Remarks and Client Ref
					fields are there to be updated from the GTE release object TO the TI, not the other way round
27/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - changed txtWeight and txtVolume to measurement tables
20/08/2019	jlgmd1	TFS #46127 Fixed  Road Gate Update Released Cargo – No Updating At All - not preventing updates
*/
vars
	gteRelease	: CMGTE_Release;
	ti			: CM_TrackedItem;
	weight		: String;																			// PAR #33606
	volume		: String;																			// PAR #33606
	terminal	: CM_Terminal;
	urc			: Integer;
begin
	weight := app.getDefaultMeasurementForType(Type_Weight).shortName;								// PAR #33606
	volume := app.getDefaultMeasurementForType(Type_Volume).shortName;								// PAR #33606
	
	// TFS46127
	terminal := _item.getMyTerminal();
	if terminal &lt;&gt; null then
		urc := terminal.getConfig(UpdateReleasedCargo).Integer;
	endif;
	
	if _item.isKindOf(CM_TrackedItem) then
		// None from the container itself
		ti := _item.CM_TrackedItem;
		self.txtDescription.setValue(ti.description);
		//self.txtRemarks.setValue(ti.remarks);										// PAR #30344
		//self.txtWeight.setValue(ti.totalWeight.asStringWeightJMT());		//+cnwml2 MSL CCMS 1017	// PAR #33606
		//ti.myCargoType.getBulkTrackByDisplayForWeight
		self.tblWeight.setValues(app.convertMeasurementForDisplay(weight, ti.totalWeight) &amp; Space &amp; weight);	// PAR #33606
		//self.txtVolume.setValue(ti.getMyTotalVolume);												// PAR #33606
		self.tblVolume.setValues(app.convertMeasurementForDisplay(volume, ti.getMyTotalVolume) &amp; Space &amp; volume);	// PAR #33606
		self.txtQuantity.setValue(ti.quantity);
		self.txtLength.setValue(ti.length);
		self.txtWidth.setValue(ti.width);
		self.txtHeight.setValue(ti.height);
		self.txtMarkNumber.setValue(ti.markNumber);
		//self.txtClientRef.setValue( ti.clientRef); //cnwrd1 par 23337 20.5.2010	// PAR #30344
		
	elseif _item.isKindOf(CMGTE_Release) then		
		gteRelease := _item.CMGTE_Release;
		self.txtDescription.setValue(gteRelease.description);
		//self.txtRemarks.setValue(gteRelease.remarks);	
		self.txtQuantity.setValue(gteRelease.quantity);
		self.txtLength.setValue(gteRelease.length);
		self.txtWidth.setValue(gteRelease.width);
		self.txtHeight.setValue(gteRelease.height);
		self.txtColour.setValue(gteRelease.colour);
		self.txtMarkNumber.setValue(gteRelease.markNumber);
		self.txtYardInstruct.setValue(gteRelease.yardInstructions);
		//self.txtClientRef.setValue( gteRelease.clientRef); //cnwrd1 par 23337 20.5.2010
		
		// TFS46127
		// Only populate the 'Update Release Cargo With' section if our terminal config says we should
		if urc &lt;&gt; UpdateNone then
			self.txtRemarks.setValue(gteRelease.remarks);
			self.txtClientRef.setValue( gteRelease.clientRef);
		endif;
		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setContainerMainDetails" id="a1c18c6d-a617-4c4c-b1c8-7b20163ac679">
        <updating/>
        <source>setContainerMainDetails(_item : Object) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/08/2009	cnwjk3	Initial creation
11/02/2011	cnwdap1	PAR #26929 Protect against setting self.myBulkRelease to an invalid object
26/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
*/
vars
	gteRelease	: CMGTE_Release;
	weightDisplay : String;
begin
	if _item.isKindOf(CM_TrackedItem) then
		// None from the container itself
	elseif _item.isKindOf(CMGTE_Release) then
		gteRelease := _item.CMGTE_Release;
		if app.isValidObject(gteRelease.myBulkRelease) then		// PAR #26929
			self.myBulkRelease := gteRelease.myBulkRelease;
			self.myReserveDetail := gteRelease.myReserveDetail;
		endif;													// PAR #26929
		if self.myBulkRelease &lt;&gt; null then
			self.doLoadReleaseItems(self.myBulkRelease, self.myReserveDetail);
			self.txtRelease.setValue(self.myBulkRelease.code);
		endif;
		
		//epr CCMS 2274 6/9/13 par 32408 
		if gteRelease.myCargoType &lt;&gt; null and gteRelease.myCargoType.isBreakBulkMulti and gteRelease.isReleaseById then
			self.txtNumItemsBB.setValue(gteRelease.numItems);	
		else
			self.txtNumItems.setValue(gteRelease.numItems);
		endif;
		//cnwrd1 par 26664 17.5.2011
		if self.updateMode = self.Mode_Update then
			self.txtNumItems.enabled := false;
		else
			self.txtNumItems.enabled := true;
		endif;
		
		if gteRelease.myCargoType &lt;&gt; null then																									//PAR #33606
			//epr par 34406 26/6/14
			weightDisplay:=gteRelease.myCargoType.getBulkTrackByDisplayForWeight(gteRelease.weight, gteRelease.getDensity,true);
			if gteRelease.myCargoType.isBulkByVolume then
				if gteRelease.isReleaseById then
					self.tblTotalVolume.setValues(weightDisplay);	//PAR #33606
				else
					self.tblVolume.setValues(weightDisplay);
				endif;
			else
				if gteRelease.isReleaseById then
					self.tblTotalWeight.setValues(weightDisplay);	//PAR #33606
				else
					self.tblWeight.setValues(weightDisplay);
				endif;
			endif;		
		endif;		
		//PAR #33606
		
		//jlier1 TFS 28/6/22
		if not self.tblWeightRequested.isHidden then
			self.tblWeightRequested.setValueDefault(gteRelease.weightRequested.asStringJMT);
		endif;
		
		if gteRelease.myParent &lt;&gt; null then
			self.cmbPackTo.setForObject(gteRelease.myParent);		
		endif;
		
		if gteRelease.releaseWeight &gt; 0 then		//13.dec.2023 navsp1 TFS 61547
			self.txtReleaseWeight.setValueDefault(gteRelease.releaseWeight.asStringJMT);		//29.Jan.24 navsp1 TFS 62064
		endif;
		if gteRelease.releaseQuantity &gt; 0 then		//13.dec.2023 navsp1 TFS 61547
			self.txtReleaseQty.setValue(gteRelease.releaseQuantity);
		endif;
		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setContainerReleaseByIDDetails" id="e1614096-81b7-4a73-b8db-c21b0d53757c">
        <updating/>
        <source>setContainerReleaseByIDDetails(_item : Object) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/08/2009	cnwjk3	Initial creation
26/08/2013	cnwdap1	PAR #32331 Don't default the total quantity, mae the user enter it instead
25/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
31/07/2014	cnwdap1	PAR #34663 Default total quantity released to TI quantity when releasing by ID
12/10/2016	cnwdap1	TFS 2791 New config option for defaulting quantity / weight / volume
*/
vars
	gteRelease	: CMGTE_Release;
	ti			: CM_TrackedItem;
	reserveTI 	: CM_ReserveTI;
	cargoType	: CM_CargoType;							// PAR #33606
		weightDisplay : String;
begin
	if _item.isKindOf(CM_TrackedItem) then		
		ti := _item.CM_TrackedItem;
		self.setCargoID(ti.id);
		
		if ti.id &lt;&gt; null then//cnwas3 par 21204
			self.cmbType.setForObject(app.myRoot.allCargoTypesById[ti.cargoType]);//cnwas3 par 21204
		endif;
		
		//epr par 32445 17/10/13
		if ti.isKindOf(CM_BreakBulkGeneric) and ti.myCargoType.isBreakBulkMulti then
			self.txtNumItemsBB.isHidden := false;
			self.txtNumItemsBB.enabled:=true;
			if self.updateMode = self.Mode_Update and self.myRealGTEEntity &lt;&gt; null and self.myRealGTEEntity.isKindOf(CMGTE_Release) then
				self.txtNumItemsBB.setValue( self.myRealGTEEntity.CMGTE_Release.numItems);	
			elseif self.updateMode = self.Mode_Add then										// PAR #34663
				if ti.totalQuantity &gt; 1 then												// PAR #34701
					if self.myTerminal.getConfig(ForceUEMoveAmountAtExit).Boolean then	// TFS 2791
						//self.txtNumItemsBB.setValue( 0 );								// TFS 2791
						self.txtNumItemsBB.setValue( null );							// TFS 2791
					else																// TFS 2791
						self.txtNumItemsBB.setValue( ti.totalQuantity );				// TFS 2791
					endif;																// TFS 2791
				else	
					self.txtNumItemsBB.setValue( 1 );										
				endif;
			endif;
			self.txtCargoIDvalue.text := ti.id &amp; ' ' &amp; ti.getPrimaryLocationId(REAL_MODE).trimWhiteSpace();		//cnwmc5 - 12 Dec 2013 - PAR 33179
		else
			self.txtNumItemsBB.enabled:=false;
		endif;
		// PAR #33606 Bulk - show hide total weight / total volume as appropriate	// PAR #33606
		if ti.isKindOf(CM_Bulk) and ti.myCargoType.isBulkMulti then					// PAR #33606
			cargoType := ti.myCargoType;											// PAR #33606
			//epr TFS 41398 21/2/19
			// PAR #33606
			weightDisplay:=cargoType.getBulkTrackByDisplayForWeight(ti.totalWeight, ti.getDensity,true);
			self.txtNumItemsBB.setValue(null);									// TFS 2791
			if cargoType.isTrackByWeight then										// PAR #33606
				self.tblTotalWeight.isHidden := false;								// PAR #33606
				self.tblTotalWeight.enabled := true;								// PAR #33606
				self.tblTotalVolume.isHidden := true;								// PAR #33606
				self.tblTotalVolume.enabled := false;								// PAR #33606
				self.tblTotalVolume.setValue(null);									// TFS 2791		
				if not self.myTerminal.getConfig(ForceUEMoveAmountAtExit).Boolean then	// TFS 2791
					self.tblTotalWeight.setValues(weightDisplay);						// TFS 2791
				endif;																	// TFS 2791
			else																	// PAR #33606
				self.tblTotalWeight.isHidden := true;								// PAR #33606
				self.tblTotalWeight.enabled := false;								// PAR #33606
				self.tblTotalVolume.isHidden := false;								// PAR #33606
				self.tblTotalVolume.enabled := true;								// PAR #33606
				self.tblTotalWeight.setValue(null);									// TFS 2791
				if not self.myTerminal.getConfig(ForceUEMoveAmountAtExit).Boolean then	// TFS 2791
					self.tblTotalVolume.setValues(weightDisplay);						// TFS 2791

				endif;																	// TFS 2791
			endif;																		// PAR #33606
		elseif ti.myCargoType.isBreakBulkMulti then										// TFS 2791
			self.tblTotalWeight.setValue(null);											// TFS 2791
			self.tblTotalVolume.setValue(null);											// TFS 2791
		endif;
		self.onTxtNumItemsBBLostFocus();
	elseif _item.isKindOf(CMGTE_Release) then		
		gteRelease := _item.CMGTE_Release;
		self.setCargoID(gteRelease.id);
		
		if gteRelease.id &lt;&gt; null then
			self.cmbType.setForObject(app.myRoot.allCargoTypesById[gteRelease.cargoType]);
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setContainerReleaseByTypeDtls" id="c691cc32-9a21-46e7-896a-7fbd795aa4da">
        <updating/>
        <source>setContainerReleaseByTypeDtls(_item : Object) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/08/2009	cnwjk3	Initial creation
14/04/2010	cnwdap1	PAR #23565 show freight forwarder
23/08/2013	cnwdap1	PAR #32331 Show Description and Colour
15/03/2016	cnwdap1	PAR #37606 Not available for entry stuff
10/7/17 	jlgns1  TFS 4573   Release Full Container Issue
*/

vars
	gteRelease	: CMGTE_Release;
	ti			: CM_TrackedItem;
	str			: String;
	isoType		: CM_ISOType;							// PAR #37606
	consignee	: CM_ConsigneeConsignor;				// PAR #37606
begin
	if _item.isKindOf(CM_TrackedItem) then
		ti := _item.CM_TrackedItem;
		
		if ti.isKindOf(CM_Container) then
			self.cmbISOGroup.setForObject(app.myRoot.allISOTypeGroups[ti.CM_Container.isoGroup]);
			//self.cmbISOType.setForObject(app.myRoot.allISOTypes[ti.CM_Container.isoType]);				// PAR #37606
			isoType := app.myRoot.allISOTypes[ti.CM_Container.isoType];										// PAR #37606
			if isoType &lt;&gt; null and isoType.isNotAvailableForEntry then										// PAR #37606
				self.cmbISOType.getEmbeddedControl.ComboBox.listIndex := self.cmbISOType.addItemObject(isoType.code &amp; Tab &amp; isoType.description, isoType);	// PAR #37606
			else																							// PAR #37606
				self.cmbISOType.setForObject(isoType);														// PAR #37606
			endif;																							// PAR #37606
			self.chkHeavyDuty.setValue(ti.CM_Container.isHeavyDuty);
			self.chkClean.setValue(ti.CM_Container.isClean);
		endif;
		self.cmbOperatorCode.setObject(ti.myOperator);
		self.cmbCommodity.setForObject(app.myRoot.allCommodities[ti.commodity]);
		self.cmbVoyageCode.setObject(ti.myVoyage);
		self.txtHouseBOL.setValue(ti.billOfLading);
		self.cmbConsignee.setForObject(ti.myConsignee);
		if ti.myConsignee &lt;&gt; null and  ti.myConsignee.isNotAvailableForEntry then							// PAR #37606
			self.cmbConsignee.getEmbeddedControl.ComboBox.listIndex := self.cmbConsignee.addItemObject(ti.myConsignee.description, ti.myConsignee);			// PAR #37606
		endif;																								// PAR #37606
		self.cmbSubTerminal.setForObject(ti.mySubTerminal);
		self.cmbImexStatus.setForObject(ti.getImExStatusObject);	//	TFS 4573
		
		self.cmbTiType.setForObject(app.myRoot.allCargoTypesById[ti.cargoType]);
		self.onCargoTypeChange(); // Populate the sub cargo combo
		self.cmbSubCargo.setForObject(ti.myProduct);
		self.txtMark.setValue(ti.mark);
		
		// PAR #23565
		self.cmbFreightFwdr.setValue(ti.freightForwarderCode);
		
		self.txtDescription.setValue(ti.description);																	// PAR #32331
		if ti.isKindOf(CM_BreakBulkGeneric) then																		// PAR #32331
			self.myAssistant.setColourDetails(ti.CM_BreakBulkGeneric.colour, self.lstColourList, self.txtColourList);	// PAR #32331
		endif;																											// PAR #32331

	elseif _item.isKindOf(CMGTE_Release) then
		gteRelease := _item.CMGTE_Release;
		self.cmbOperatorCode.setObject(app.myRoot.allOperators[gteRelease.operatorCode]);
		self.cmbTiType.setForObject(app.myRoot.allCargoTypesById[gteRelease.cargoType]);
		self.onCargoTypeChange(); // Populate the sub cargo combo
		self.cmbSubCargo.setForObject(gteRelease.myProduct);
		self.txtMark.setValue(gteRelease.mark);
		self.cmbISOGroup.setForObject(app.myRoot.allISOTypeGroups[gteRelease.isoGroup]);
		//self.cmbISOType.setForObject(app.myRoot.allISOTypes[gteRelease.isoType]);							// PAR #37606
		isoType := app.myRoot.allISOTypes[gteRelease.isoType];												// PAR #37606
		if isoType &lt;&gt; null and isoType.isNotAvailableForEntry then											// PAR #37606
			self.cmbISOType.getEmbeddedControl.ComboBox.listIndex := self.cmbISOType.addItemObject(isoType.code &amp; Tab &amp; isoType.description, isoType);	// PAR #37606
		else																								// PAR #37606
			self.cmbISOType.setForObject(isoType);															// PAR #37606
		endif;																								// PAR #37606
		self.cmbImexStatus.setForObject(app.myRoot.allImexStatuses[gteRelease.imexStatus]);
		self.chkHeavyDuty.setValue(gteRelease.heavyRated);
		self.chkClean.setValue(gteRelease.clean);
		self.cmbCommodity.setForObject(app.myRoot.allCommodities[gteRelease.commodity]);
		self.cmbVoyageCode.setObject(self.myTerminal.lookupVoyage(gteRelease.voyageCode, null, false));
		self.txtHouseBOL.setValue(gteRelease.billOfLading);
		self.myBOLDtl := gteRelease.myBOLDtl;	//08 Oct 2020 NDL	TFS 49189
		//self.cmbConsignee.setForObject(app.myRoot.allConsigneeConsignors[gteRelease.consigneeCode]);		// PAR #37606
		consignee := app.myRoot.allConsigneeConsignors[gteRelease.consigneeCode];							// PAR #37606
		if consignee &lt;&gt; null and consignee.isNotAvailableForEntry then										// PAR #37606
			self.cmbConsignee.getEmbeddedControl.ComboBox.listIndex := self.cmbConsignee.addItemObject(consignee.description, consignee);	// PAR #37606
		else																								// PAR #37606
			self.cmbConsignee.setForObject(consignee);														// PAR #37606
		endif;																								// PAR #37606
		self.cmbSubTerminal.setForObject(gteRelease.mySubTerminalSource);
		self.myAssistant.setListTableMTGrade(self.lstMTGrade, gteRelease.allAvailabilityGrades);
		str := self.lstMTGrade.getSelectedString(CM_MTGrade::description.name);
		str := self.truncateDisplayString(str, -1);
		self.txtMTGrades.text := str;
		self.idMask := gteRelease.idMask;
		self.lblIDsMask.caption := self.truncateDisplayString(self.idMask, MAX_IDMASK_DISPLAY_LEN);
		
		self.chkBestPick.setValue(gteRelease.getBestPick());	// CCMS 1101
		
		// PAR #23565
		self.cmbFreightFwdr.setValue(gteRelease.freightForwarderCode);
		
		self.cmbTermArea.setForObject(self.myTerminal.lookupTerminalArea(_item.CMGTE_Release.yardLocationTxt));	// 05/02/2010 cnwjre1 CCMS 1101
		
		// cnwrd1 par 24169 9.6.2010
		self.allSelectedTAs.clear(); // cnwrd1 par 24169 9.6.2010
		gteRelease.allSourceTAs.copy ( self.allSelectedTAs);
		self.allSelectedTAGridObjs.clear(); //cnwrd1 par 28628 5.12.2011
		gteRelease.allSourceTAGridObjs.copy ( self.allSelectedTAGridObjs);
		
		self.isFIFO := gteRelease.CMGTE_Release.isFIFO;				
		self.isBestPick := gteRelease.getBestPick();
		self.yardSourcetxt := gteRelease.getSourceTAText();
		self.lblYardSourcMask.caption :=  self.truncateDisplayString(self.yardSourcetxt, MAX_IDMASK_DISPLAY_LEN);
		
		// cnwrd1 par 24169 9.6.2010
		
		self.txtDescription.setValue(gteRelease.description);											// PAR #32331
		self.myAssistant.setColourDetails(gteRelease.colour, self.lstColourList, self.txtColourList);	// PAR #32331
		
		self.chkAnyId.setValue( gteRelease.getIsAnyId );	//01 Aug 2014	NDL Par 34675
		if gteRelease.getIsAnyId then
			self.switchToReleaseByIdMulti;
			self.chkAnyAmount.setValue( gteRelease.getIsAnyAmount );	//21 Mar 2017	NDL TFS 3813
		endif;
		
		//16 Jan 2019	NDL	TFS 42921
		if gteRelease.myReserveDetail &lt;&gt; null then
			self.txtExtra.setValue( gteRelease.myReserveDetail.getExtraCritForRoadGateSTW );	
		endif;
		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setContainerUpdateDetails" id="67e1c1c5-946b-4708-9a53-e9f1c6bff7d5">
        <source>setContainerUpdateDetails(_item : Object) protected;
/*
Date		Who		Reason
10 August 2009	cnwjk3	Initial creation
21/02/2012	cnwcs5	par 29146 - operator import PIN not be populated 
04/09/2013	cnwer1	PAR #32399 - only override from ti if no gte entity already
11/11/2013  cnwgb1  PAR 31849 - Never Ever show Operator Import PIN on this form
28/10/2014 	cnwma1 	PAR #35088  Delivery Release Reason for terminal receive and release
05/11/2014  cnwma1  PAR #35150  Destination Terminal is Blanked Out when confirming released cargo
08/08/2018	jlgmd1	TFS #39693  Fix error 4 from killing the entire form
02/10/2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
22/04/2024	jlizm1	TFS 62856 Shipment Number field

*/

vars

	gteRelease	: CMGTE_Release;
	ti			: CM_TrackedItem;
	bulkRel 	: CM_BulkRelease;
	invalidObj	: Boolean;
	
begin

	// Don't die if our Release Request has been deleted
	on Exception do app.handleDeletedObject(exception, bulkRel, invalidObj);

	if _item.isKindOf(CM_TrackedItem) and self.myRealGTEEntity = null then
		ti := _item.CM_TrackedItem;


		//epr par 32667 3/10/13
		if not  ti.myCargoType.isBreakBulkMulti then			
			if self.myBulkRelease &lt;&gt; null then															// cnwma1 PAR #35088 28/10/2014
				self.txtRemarks.setValue(myBulkRelease.cargoRemarks);
				self.cmbDelReason.setForText(app.deliveryReasonEnumToString(self.myBulkRelease.deliveryReasonCode));
				self.txtDeliveryRelNo.setValue(self.myBulkRelease.deliveryReleaseNumber);				//+cnwml2 PAR25757			//cnwmc5 - 4 Sep 2015 - PAR 36708
				self.cmbDestTerminal.setForObject(self.myBulkRelease.myTransferToTerminal); 		    // cnwma1 05/11/2014 PAR #35150
			else
				self.txtRemarks.setValue(ti.remarks);
				self.cmbDelReason.setForText(app.deliveryReasonEnumToString(ti.deliveryReleaseReason));
				self.txtDeliveryRelNo.setValue(ti.deliveryRelease);
				self.cmbStevedore.setForObject(app.myRoot.allStevedores[ti.stevedoreCodeRelease]);      //04.11.2020 cnwma1 TFS #50112
			endif;
			//epr par 36674 1/9/15 don't update the consignee here 
		endif;
		
		self.txtEquipXchg.setValue(ti.eirNumber);
		self.txtCustomsRelNo.setValue(ti.customsEntryNumber);
		self.txtConsignVoy.setValue(ti.consignorVoyageCode);
		self.txtClientRef.setValue( ti.clientRef); 						//cnwrd1 par 23337 20.5.2010
		
		//03 May 2018	NDL	TFS 37795
		if not _item.CM_TrackedItem.allBulkReleasesAssigned.isEmpty then
			bulkRel := _item.CM_TrackedItem.allBulkReleasesAssigned.first;
		endif;
		if bulkRel &lt;&gt; null then
			self.txtAddRemarks1.setValue( bulkRel.remarksAdditional1 ); 	
			self.txtAddRemarks2.setValue( bulkRel.remarksAdditional2 );
		endif;

	elseif _item.isKindOf(CMGTE_Release) then
		gteRelease := _item.CMGTE_Release;

		self.cmbUpdateConsign.setForObject(app.myRoot.allConsigneeConsignors[gteRelease.updateConsigneeCode]);
		self.cmbStevedore.setForObject(app.myRoot.allStevedores[gteRelease.stevedoreCode]);		               //02.10.2020 cnwma1 TFS #50112
		self.cmbDestTerminal.setForObject(gteRelease.myTransferToTerminal);		
		self.txtRemarks.setValue(gteRelease.remarks);	//cnwmc5 - 19 May 2014 - PAR 34173
		self.cmbDelReason.setForText(gteRelease.deliveryReason);
		self.txtEquipXchg.setValue(gteRelease.eirNumber);
		self.txtCustomsRelNo.setValue(gteRelease.customEntryNumber);
		self.txtDeliveryRelNo.setValue(gteRelease.deliveryReleaseNumber);		//+cnwml2 PAR25757
		self.txtConsignVoy.setValue(gteRelease.consignorVoyageCode);
		self.txtClientRef.setValue( gteRelease.clientRef); //cnwrd1 par 23337 20.5.2010
		self.txtShipmentNumber.setValue(gteRelease.shipmentNumber);
		
		//03 May 2018	NDL	TFS 37795
		bulkRel := _item.CMGTE_Release.myBulkRelease;
		if bulkRel &lt;&gt; null then
			self.txtAddRemarks1.setValue( bulkRel.remarksAdditional1 ); 	
			self.txtAddRemarks2.setValue( bulkRel.remarksAdditional2 );
		endif;
		
	endif;
	
	//22 Aug 2019	NDL	TFS 46168
	if self.lstCargoIDvalues.allSelectedObjects.size() &gt; 1 then
		self.setUpdateReleaseDetailsMulti( _item );
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromBOLDetail" id="f8cef133-9db8-4e61-bc56-33fff7101f17">
        <updating/>
        <source>setFieldsFromBOLDetail() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2020	jlgndl1	Initial creation	TFS 49189
16 Nov 2020 cnwma1 Bug 50343: Bug from Functional Review of 49179 - Road Gate &amp; Vehicle Visit
*/

vars

	cargoType : CM_CargoType;
	commodity : CM_Commodity;
	consignee : CM_ConsigneeConsignor;
	voyage 	  : CM_Voyage;
	opening   : Boolean;
	operator  : CM_Operator;
	ti        : CM_TrackedItem;
	stevedore : CM_Stevedore;
begin

	inheritMethod();

	if self.myBOLDtl = null then
		return;
	endif;
	
	if self.myTerminal.roadProcessIsASPA then	
		self.chkAnyId.isHidden := true;
		self.chkAnyId.setValue(false);	
		self.chkAnyId.visible := false;
		self.chkAnyAmount.isHidden := true;
		self.chkAnyAmount.setValue(false);
		self.chkAnyAmount.visible := false;
	
		self.lblReleaseById.visible := false;
		self.cmbReleaseJobs.visible := false;
		self.txtRelease.visible := false;
		self.cmbReleaseItem.visible := false;
		self.grpAdditionalRel.visible := false;
		self.lblYardSource.visible := false;
		self.chkBestPick.visible := false;
		
		self.doOpenCloseSection(self.lblReleaseById, self.lblReleaseByType, self.btnReleaseById, opening);
		
		//16.11.2020 cnwma1 #50343
		if self.myBOLDtl &lt;&gt; null and not self.myBOLDtl.allTrackedItems.isEmpty then
			ti := self.myBOLDtl.allTrackedItems.first;
			if ti.stevedoreCodeRelease &lt;&gt; null then
				stevedore := app.myRoot.allStevedores[ti.stevedoreCodeRelease];
				self.cmbStevedore.getEmbeddedControl.ComboBox.listObject := stevedore;
			endif;
		endif;
		//16.11.2020 cnwma1 #50343
	endif;
	
	cargoType := self.myBOLDtl.myCargoType;
	commodity := self.myBOLDtl.getMyCommodity;
	if self.myBOLDtl.consigneeCode &lt;&gt; null then
		consignee := app.myRoot.allConsigneeConsignors[self.myBOLDtl.consigneeCode];
	endif;
	if self.myBOL &lt;&gt; null then
		voyage := self.myBOL.getMyVoyage;
		operator := self.myBOL.myOperator;	//03 Nov 2020	TFS 50254
	endif;
	
	self.cmbCommodity.setForObject( commodity );
	if voyage &lt;&gt; null then
		self.cmbVoyageCode.setObject( voyage );
		self.cmbVoyageCode.enabled := false;
	endif;
	if operator &lt;&gt; null then		//03 Nov 2020	TFS 50254
		self.cmbOperatorCode.setObject(operator);
	endif;
	if self.myBOL &lt;&gt; null then
		self.txtHouseBOL.setValue( self.myBOL.number );
		self.txtHouseBOL.setIsEnabled( false );
	endif;
	self.cmbConsignee.setForObject(consignee);
	if consignee &lt;&gt; null then	
		if consignee &lt;&gt; null and  consignee.isNotAvailableForEntry then							
			self.cmbConsignee.getEmbeddedControl.ComboBox.listIndex := self.cmbConsignee.addItemObject(consignee.description, consignee);
		endif;	
	endif;
	
	self.cmbTiType.setForObject( cargoType );
	self.onCargoTypeChange(); // Populate the sub cargo combo
		
	self.txtMark.setValue( self.myBOLDtl.markNumber );
		
	if self.myBOLDtl.colour &lt;&gt; null and cargoType.myClassToCreate = CM_BreakBulkGeneric then																		// PAR #32331
		self.myAssistant.setColourDetails( self.myBOLDtl.colour, self.lstColourList, self.txtColourList );
	endif;
	
	if self.myTerminal.getConfig(ForceUEMoveAmountAtExit).Boolean then						
		self.tblWeight.setValue(null);														
		self.txtNumItems.setValue(null);													
		self.tblVolume.setValue(null);
		self.txtNumItemsBB.setValue(null);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFieldsFromBulkRelease" id="aac67460-d880-44e1-aff2-9a244eddcf99">
        <updating/>
        <source>setFieldsFromBulkRelease() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/07/2009	cnwjk3	Initial creation
11/10/2016	cnwdap1	TFS 2791 Clear weight/quantity/volume if "Force User entry" config option is set
*/
vars
	cargoType 	: CM_CargoType;
	msg : String;

begin
	inheritMethod();

	if self.myBulkRelease = null or self.myReserveDetail = null then
		return;
	endif;
	
	//14 Feb 2017	NDL	TFS 3368
	if not self.myBulkRelease.validateExpiryDateNow( msg ) then
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	if msg &lt;&gt; null then
		if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;

	cargoType := self.myReserveDetail.getCargoType();
	
//	if cargoType = null then
	if cargoType = null and self.myReserveDetail.myBOLIn = null then	//18 Feb 2014	NDL	Par 33524
		app.raiseCMException(ERROR_UNDETERMINED_CARGO_RR,null,null); //epr par 36593 9/10/15
	endif;
	
//	if cargoType.id = TI_CargoType_Container then
	if ( cargoType = null and self.myReserveDetail.myBOLIn &lt;&gt; null ) or cargoType.id = TI_CargoType_Container then		//18 Feb 2014	NDL	Par 33524
		if self.myBulkRelease.fullRelease then
			self.setIsFullContainer();
			if self.currentEntTableDef &lt;&gt; ETDef_ReleaseContainerFull then
				self.initFieldsForEntDefName(ETDef_ReleaseContainerFull, true);
			endif;
		else
			self.setIsEmptyContainer();
			if  self.currentEntTableDef &lt;&gt; ETDef_ReleaseContainerEmpty then
				self.initFieldsForEntDefName(ETDef_ReleaseContainerEmpty, true);
			endif;
		endif;
	else
		self.setIsGeneralCargo();
		//jlier1 TFS 53678 28/5/22
		if self.myBulkRelease.context = RelReqContext_CargoGroupReview or  self.currentEntTableDef &lt;&gt; ETDef_ReleaseGeneralCargo then
			self.initFieldsForEntDefName(ETDef_ReleaseGeneralCargo, true);
		endif;
	endif;
	
	self.doSetCaption();
	self.doShowPicture();

	self.txtRelease.setValue(self.myBulkRelease.code);
	self.doLoadReleaseItems(self.myBulkRelease, self.myReserveDetail);
	if self.myBulkRelease.releaseByType then
		self.txtCargoID.enabled := true;
		setFieldsFromBulkReleaseByType(self.myBulkRelease, self.myReserveDetail.CM_ReserveSelection);
	else
		self.txtCargoID.enabled := false;
		setFieldsFromBulkReleaseById(self.myBulkRelease, self.myReserveDetail.CM_ReserveTI);		
	endif;
	
	if self.myTI = null then								// 25/9/19 MAP TFS46539
		if self.myBulkRelease.isForMTs then					// 19/10/2011 cnwmh5 #28475
			self.restoreIMEXStatus(self.cmbImexStatus, TI_IMEX_STATUS_STORAGE, true);	
		else
			self.restoreIMEXStatus(self.cmbImexStatus, TI_IMEX_STATUS_IMPORT, true);
		endif;
	else
		self.restoreIMEXStatus(self.cmbImexStatus, self.myTI.getImExStatus(), true);
	endif;
	
	// TFS 2791 if 'Force User entry of 'Amount' at Gate Out for Bulk/Break-Bulk' is set,	// TFS 2791
	// clear weight/quantity/volume fields													// TFS 2791
	if self.myTerminal.getConfig(ForceUEMoveAmountAtExit).Boolean then						// TFS 2791
		self.tblWeight.setValue(null);														// TFS 2791
		self.txtNumItems.setValue(null);													// TFS 2791
		self.tblVolume.setValue(null);														// TFS 2791
	endif;																					// TFS 2791
	
	//03 May 2018	NDL	TFS 37795
	self.txtAddRemarks1.setValue( self.myBulkRelease.remarksAdditional1 ); 	
	self.txtAddRemarks2.setValue( self.myBulkRelease.remarksAdditional2 );
	
	setByTypeByWeight();															//10.Jan.24 navsp1 TFS 61547 / Task 61999
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFieldsFromBulkReleaseById" id="5fe6e111-2fb7-4d4d-bced-7ccc9007c52e">
        <updating/>
        <source>setFieldsFromBulkReleaseById(_bulkRelease: CM_BulkRelease; _reserve: CM_ReserveTI) updating, protected;
/*
Date		Who		Reason
15 June 2009	cnwjk3	Initial creation
7 April 2010	cnwjo3	Tidy up and changes for par 23536
14 April 2010	cnwdap1	PAR #23565 Show freight forwarder
26 Aug 2013		cnwdap1	PAR #32331 Don't show total quantity for Break-Bulk, make user enter the required quantity
29 Aug 2013 	cnwer1	PAR 32330 
28 oct 2014		cnwma1  PAR #35088  Delivery Release Reason for terminal receive and release
15 May 2018		jlgdap1	TFS 38501 PEL1 Work Order Changes
20 Aug 2019		jlgmd1	TFS #46127	Fixed  Road Gate Update Released Cargo – No Updating At All - not preventing updates
04 Nov 2019		jlgzm1	TFS 47286 Road Gate not autocompleting TI info when entering Pin &amp; cargoId
*/
vars
	ti			: CM_TrackedItem;
	allCT 		: CM_CargoTypeSet;
	autoSelect 	: CM_TIArray;
	terminal	: CM_Terminal;
	urc			: Integer;
begin
	inheritMethod(_bulkRelease, _reserve);
	
	ti := _reserve.getTI();
	if ti = null then
		return;
	endif;
	
	terminal := _bulkRelease.getMyTerminal();
	if terminal &lt;&gt; null then
		urc := terminal.getConfig(UpdateReleasedCargo).Integer;
	endif;
	
	// For Release by ID, we only want to pre-fill the 'Update Released Cargo With' fields
	// But we may want to pre-fill the Release By Type fileds for information purposes??
	
	// Only populate the 'Update Release Cargo With' section if our terminal config says we should
	if urc &lt;&gt; UpdateNone then		// TFS 46127
		if _bulkRelease.myConsignee &lt;&gt; null then
			//epr par 36674 1/9/15  only the update consignee not the ti consignee
			self.cmbUpdateConsign.setForObject(_bulkRelease.myConsignee);
		endif;
		
		self.cmbDestTerminal.setForObject(_bulkRelease.myTransferToTerminal);
		self.cmbDelReason.setForText(_bulkRelease.deliveryReasonDescr);
		self.txtDeliveryRelNo.setValue(_bulkRelease.deliveryReleaseNumber);	// cnwma1 PAR #35088 28/10/2014
		self.txtConsignVoy.setValue(_bulkRelease.consignorVoyageCode);
		self.cmbFreightFwdr.setValue(_bulkRelease.freightForwarderCode);
		self.txtRemarks.setValue(_bulkRelease.cargoRemarks);			//cnwmc5 - 19 May 2014 - PAR 34173
	endif;
		
	self.txtCargoID.enabled := true;
	self.cmbType.enabled := true;

	create allCT transient;
	self.cmbType.clear();
	//cnwjo3 par 23536
	self.lstCargoIDvalues.userObject:=null;
	self.setAvailableTIs(_bulkRelease);
	//endif;
	//cnwjo3 par 23536, add all the Cargo Types to the cmbTypes combo box
	foreach ti in self.allSearchTIs do
		if not allCT.includes(ti.myCargoType) then
			self.cmbType.addItemObject(ti.myCargoType.description,ti.myCargoType);
			allCT.add(ti.myCargoType);
		endif;
	endforeach;
	
	self.cmbType.isHidden:=false;
	
	//if self.allSearchTIs.size = 1 then																// TFS 38501
	if self.allSearchTIs.size = 1 or (not self.allSearchTIs.isEmpty and self.myWorkOrder &lt;&gt; null) then	// TFS 38501
		self.lstCargoIDvalues.setSelected(self.allSearchTIs);		
		//epr par 36674 1/9/15 will do a better job in method below
		
		// TFS 1622 PAR 37593  put this back so it works for MESSINA PAR25757
		// PENN using cargo assigned to a bulk release, these assigned get copied to 'allSearchTIs' if there was only 1 cargo assigned to the BR then this following code kicks in
		// PENN they did not want this they want the delivery rel no on the BR
		// MESSINA not using bulk release they click 'release full' and enter a container Id, this means there is only 1 TI in the 'allSearchTIs'
		// MESSINA want this as they want the delivery rel no on the TI so it flows on and clears a stop
		
		ti := self.allSearchTIs.first;
		if ti &lt;&gt; null 
		and self.myBulkRelease = null 	// TFS 1622 PAR 37593 This means 'Not assigned to a bulk release'. Added this so it works for PENN and MESSINA
		and urc &lt;&gt; UpdateNone then		// TFS 46127
			self.txtCustomsRelNo.setValue(ti.customsEntryNumber);
			self.txtDeliveryRelNo.setValue(ti.deliveryRelease);			//+cnwml2 PAR25757
			self.txtEquipXchg.setValue(ti.eirNumber);
		endif;
		
		self.lstCargoIDvalues.visible := true;	// TFS 47286 lostFocus won't do anything if lstCargoIDvalues is not visible
		self.myTI := null;						// TFS 47286 clearing myTI forces lostFocus to populate tracked item details
		self.txtCargoID.hasLostFocus(self.txtCargoID);
		return;
	endif;
	
	//25 Feb 2019	NDL	TFS 43491
	if self.myTI &lt;&gt; null and self.allSearchTIs.includes( self.myTI ) then
		create autoSelect transient;
		autoSelect.add( self.myTI );
		self.lstCargoIDvalues.setSelected( autoSelect );
		self.myTI := null;		// 18/9/19 MAP TFS46539  clearing myTI forces lostFocus to populate tracked item details
		self.txtCargoID.hasLostFocus(self.txtCargoID);
		return;
	endif;
	
	self.txtCargoID.hasGotFocus(self.txtCargoID);
	
epilog
	delete allCT;
	delete autoSelect;
end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserve" type="CM_ReserveTI"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromBulkReleaseByType" id="690911f5-d334-4042-bad2-cee90df2c05b">
        <updating/>
        <source>setFieldsFromBulkReleaseByType(_bulkRelease: CM_BulkRelease; _reserve: CM_ReserveSelection) updating, protected;
/*
Date		Who		Reason
15/07/2009	cnwjk3	Initial creation
14/04/2010	cnwdap1	PAR #23565 Show Freight Forwarder
19/09/2012	cnwcs5	par 30390 - removed consignorVoyageCode, freightForwarderCode
23/08/2013	cnwdap1	PAR #32331 Added Colour
27/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - txtWeight and txtVolume are not measurement tables
28/10/2014  cnwma1  PAR #35088  Delivery Release Reason for terminal receive and release
15/03/2016	cnwdap1	PAR #37606 "Not available for entry" iso type and consignee
12/10/2016	cnwdap1	TFS 2791 New config option for defaulting quantity / weight / volume
20/08/2019	jlgmd1	TFS #46127	Fixed  Road Gate Update Released Cargo – No Updating At All - not preventing updates
*/

vars
	intArray	: IntegerArray;
	str			: String;
	weightConv	: String;								// PAR #33606
	cargoType 	: CM_CargoType;
	isotype		: CM_ISOType;							// PAR #37606
	isoString	: String;								// PAR #37606
	consignee	: CM_ConsigneeConsignor;				// PAR #37606
	terminal	: CM_Terminal;
	urc			: Integer;
begin
	inheritMethod(_bulkRelease, _reserve);
	
	// TFS 46127
	terminal := _bulkRelease.getMyTerminal();
	if terminal &lt;&gt; null then
		urc := terminal.getConfig(UpdateReleasedCargo).Integer;
	endif;
	
	self.setCargoID(null);  // By Type remember...
	
	// Set fields from the bulk release
	// NOTE: Bulk release details take precedence over TI details
	self.cmbOperatorCode.setObject(_bulkRelease.myOperator);
	self.cmbSubTerminal.setForObject(_bulkRelease.mySubTerminal);	
	self.cmbVoyageCode.setObject(_bulkRelease.myVoyage);
	self.cmbConsignee.setForObject(_bulkRelease.myConsignee);
	// May 2011 cnwjre1 27097 CCMS 2043
	self.chkHiLoCube.setValue(_bulkRelease.canBeHiLoCube);
	// PAR #23565 set freight forwarder
	self.cmbFreightFwdr.setValue(_bulkRelease.freightForwarderCode);
	
	if _bulkRelease.myConsignee &lt;&gt; null and _bulkRelease.myConsignee.isNotAvailableForEntry then												// PAR #37606
		consignee := _bulkRelease.myConsignee;																									// PAR #37606
		self.cmbConsignee.getEmbeddedControl.ComboBox.listIndex := self.cmbConsignee.addItemObject(consignee.description, consignee);			// PAR #37606
		if urc &lt;&gt; UpdateNone then
			self.cmbUpdateConsign.getEmbeddedControl.ComboBox.listIndex := self.cmbUpdateConsign.addItemObject(consignee.description, consignee);	// PAR #37606
		endif;
	endif;																																		// PAR #37606
	
	// Only populate the 'Update Release Cargo With' section if our terminal config says we should
	if urc &lt;&gt; UpdateNone then		// TFS 46127
		self.cmbUpdateConsign.setForObject(_bulkRelease.myConsignee);
		self.cmbDestTerminal.setForObject(_bulkRelease.myTransferToTerminal);
		self.cmbDelReason.setForText(_bulkRelease.deliveryReasonDescr);
		self.txtDeliveryRelNo.setValue(_bulkRelease.deliveryReleaseNumber);	// cnwma1 PAR #35088 28/10/2014
		self.txtConsignVoy.setValue(_bulkRelease.consignorVoyageCode);
		//self.txtRemarks.setValue(_bulkRelease.cargoRemarks);			//cnwmc5 - 19 May 2014 - PAR 34173		// This is always overwritten by _reserve.remarks
	endif;
	
	// Set fields from the reserve detail
	self.cmbTiType.setForObject(_reserve.myCargoType);

	self.onCargoTypeChange(); // Populate the sub cargo combo
	self.cmbSubCargo.setForObject(_reserve.myProduct);
	
	self.cmbISOType.setForObject(_reserve.myISOType);
	isotype := _reserve.myISOType;																// PAR #37606
	if isotype &lt;&gt; null and isotype.isNotAvailableForEntry then									// PAR #37606
		isoString := isotype.code &amp; Tab &amp; isotype.description;									// PAR #37606
		self.cmbISOType.getEmbeddedControl.ComboBox.listIndex := self.cmbISOType.addItemObject(isoString, isotype);	// PAR #37606
	endif;																						// PAR #37606
	self.cmbISOGroup.setForObject(_reserve.myISOGroup);
	
	if _reserve.myBOLIn &lt;&gt; null then
		self.txtHouseBOL.setValue(_reserve.myBOLIn.number);	
	else
		self.txtHouseBOL.setValue(null);			//+cnwml2 PAR21161
	endif;
	
	self.chkClean.setValue(_reserve.clean);
	self.chkHeavyDuty.setValue(_reserve.heavyRated);
	self.txtMark.setValue(_reserve.markSelection);
	self.txtDescription.setValue(_reserve.descriptionSelection);
	
	// TFS 46127
	if urc &lt;&gt; UpdateNone then
		self.txtRemarks.setValue(_reserve.remarks);		// This will always overwrite the remarks set on the _bulkRelease (for some reason)
	endif;
	
	self.txtExtra.setValue( _reserve.getExtraCritForRoadGateSTW );	//16 Jan 2019	NDL	TFS 42921
	
	// TFS 2791 clear both weight and volume fields before we start, 	// TFS 2791
	// so we don't pick up stuff from a previous selection				// TFS 2791
	self.tblWeight.setValue(null);										// TFS 2791
	self.tblVolume.setValue(null);										// TFS 2791
	//epr par 34406 24/6/14
	cargoType:=_reserve.getCargoType;
	if cargoType &lt;&gt; null and cargoType.isBulkMulti then
		weightConv:=cargoType.getBulkTrackByDisplayForWeight(_reserve.getWeightOutstanding,_reserve.getDensity,true);
		if cargoType.isBulkByWeight then
			self.tblWeight.setValues(weightConv);
		else
			self.tblVolume.setValues(weightConv);
		endif;
	elseif cargoType &lt;&gt; null and cargoType.isBreakBulkMulti then		// TFS 2791
		self.txtNumItems.setValue(_reserve.totalRequested);				// TFS 2791
	endif;

	if _bulkRelease.context = RelReqContext_CargoGroupReview then // 22 February 2023	navab1	TFS 56532
		self.tblWeightRequested.setValue(_reserve.weightRequested); // 22 February 2023	navab1	TFS 56532
	
	endif;

	self.txtQuantity.setValue(_reserve.quantitySelection);
	self.txtLength.setValue(_reserve.lengthSelection);
	self.txtWidth.setValue(_reserve.widthSelection);
	self.txtHeight.setValue(_reserve.heightSelection);
	self.txtColour.setValue(_reserve.colour);
	self.txtMarkNumber.setValue(_reserve.markNumber);
	self.txtYardInstruct.setValue(_reserve.yardInstruction);
	//self.cmbTermArea.setForObject(_reserve.getTerminalArea());	// 15/02/2010 cnwjre1	CCMS 1101  // 01/07/2015 cnwma1 PAR #36555
	self.allSelectedTAs.clear(); //cnwrd1 9.6.2010
	
	if _reserve.getTerminalArea() &lt;&gt; null then // adm 050710 Par 24631
		//self.allSelectedTAs.add(_reserve.getTerminalArea()); //cnwrd1 9.6.2010  // 01/07/2015 cnwma1 PAR #36555
		_reserve.allTerminalAreas.copy(self.allSelectedTAs);      				  // 01/07/2015 cnwma1 PAR #36555
	endif;
	
	self.myAssistant.setListTableMTGrade(self.lstMTGrade, _reserve.allAvailabilityGrades);
	
	str := self.lstMTGrade.getSelectedString(CM_MTGrade::description.name);
	str := self.truncateDisplayString(str, -1);

	self.txtMTGrades.text 	:= str;
	self.idMask 			:= _reserve.getIdsAsString();
	self.lblIDsMask.caption := self.truncateDisplayString(self.idMask, MAX_IDMASK_DISPLAY_LEN);
	self.isBestPick 		:= _reserve.bestPick;		//+cnwml2 PAR25817

	//+cnwml2 PAR25398
	self.yardSourcetxt := self.getYardSourceText(self.isBestPick);	//+cnwml2 PAR25817
	self.lblYardSourcMask.caption :=  self.truncateDisplayString(self.yardSourcetxt, MAX_IDMASK_DISPLAY_LEN);
	
	self.myAssistant.setColourDetails(_reserve.colour, self.lstColourList, self.txtColourList);		// PAR #32331
	
	
epilog
	delete intArray;
end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserve" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromItem" id="bc93351e-f753-4ba2-99f0-4df7dee03b50">
        <updating/>
        <source>setFieldsFromItem(_item : Object) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10/08/2009	cnwjk3	Initial creation
01/07/2013	cnwdap1	PAR #30344 CCMS GTL 2226 Dont overwrite "Update..." details with TI details
					 - the "Update..." details are things we're going to update from the GTE release object
					 to the TI, so makes no point putting the TI details back in there
04/09/2013	cnwer1	PAR #32399 - undid the above change have to poluate from ti details
*/

vars

begin
	self.setContainerMainDetails(_item);
	self.setContainerReleaseByIDDetails(_item);
	self.setContainerReleaseByTypeDtls(_item);
	self.setContainerAdditionalDetails(_item);
	//epr par 32399 4/9/13 we need to populate these fields from the ti - the issue with this par was the customs release number was
	// not populated so that cleared it on the ti and meant the stop was put back on 
//	if not _item.isKindOf(CM_TrackedItem) then			// PAR #30344
	self.setContainerUpdateDetails(_item);
//	endif;												// PAR #30344
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setMyCarrier" id="a9cd2d91-d883-4468-bf50-adbbb794922c">
        <updating/>
        <source>setMyCarrier(_carrier : CM_Carrier)updating;
//30 July 2010	cnwml2


vars

begin
	self.myCarrier := _carrier;
epilog

end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="setReleaseByTypeCaption" id="0d7c984f-0a77-4d94-a529-5ee83729ac7b">
        <source>setReleaseByTypeCaption();
/*

Date		Who		Reason
01 September 2015	cnwer1	Initial creation PAR 36674

*/

vars
	translation	: XLAT_Translation;
	entRow 	: EntTableRow;
begin

	if self.myTI = null then
		entRow:= self.allEntTableRows.getEntRowNamed(ETRow_ReleaseByType);
		if entRow = null then
			return;
		endif;
		translation := entRow.getTranslation(app.myCurrentLocale);
		if translation= null then
			self.lblReleaseByType.setMyCaption(entRow.getHeadingUnaltered);
		else
			self.lblReleaseByType.setMyCaption(entRow.getTranslation(app.myCurrentLocale).text);
		endif;
	else
		self.lblReleaseByType.setMyCaption(app.getErrorString(Cargo_Details));
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setUpdateReleaseDetailsMulti" id="97c8b682-0eb1-4cba-95e2-750b6143d4da">
        <source>setUpdateReleaseDetailsMulti(_item : Object) protected;
/*
Date		Who		Reason
10 August 2009	cnwjk3	Initial creation
21/02/2012	cnwcs5	par 29146 - operator import PIN not be populated 
04/09/2013	cnwer1	PAR #32399 - only override from ti if no gte entity already
11/11/2013  cnwgb1  PAR 31849 - Never Ever show Operator Import PIN on this form
28/10/2014 	cnwma1 	PAR #35088  Delivery Release Reason for terminal receive and release
05/11/2014  cnwma1  PAR #35150  Destination Terminal is Blanked Out when confirming released cargo
08/08/2018	jlgmd1	TFS #39693  Fix error 4 from killing the entire form
20/08/2019	jlgmd1	TFS #46127	Fixed  Road Gate Update Released Cargo – No Updating At All - not preventing updates
22/08/2019	NDL		TFS Re-write to meet the new understanding of the config rules.

*/

vars
//	gteRelease			: CMGTE_Release;
	ti					: CM_TrackedItem;
	bulkRel 			: CM_BulkRelease;
//	invalidObj,
	found				: Boolean;
	terminal			: CM_Terminal;
	urc,
	idx					: Integer;
	consignees			: ObjectArray;
	consigneeCount		: IntegerArray;
	maxConsigneeCount	: Integer;
	modeConsignee		: Object;
	destTerminals		: StringArray;
	destTerminalCount	: IntegerArray;
	maxDestTerminalCount: Integer;
	modeDestTerminal	: String;
	delRelNums			: StringArray;
	delRelCount			: IntegerArray;
	maxDelRelCount		: Integer;
	modeDelRelNumber	: String;
	delRelReasons		: IntegerArray;
	delRelReasonCount	: IntegerArray;
	maxDelRelReasonCount: Integer;
	modeDelRelReason	: Integer;
	remarks				: StringArray;
	remarksCount		: IntegerArray;
	maxRemarksCount		: Integer;
	modeRemark			: String;
	clientRefs			: StringArray;
	clientRefCount		: IntegerArray;
	maxClientRefCount	: Integer;
	modeClientRef		: String;
	custRelNums			: StringArray;
	custRelCount		: IntegerArray;
	maxCustRelCount		: Integer;
	modeCustRelNum		: String;
	consVoyages			: StringArray;
	consVoyageCount		: IntegerArray;
	maxConsVoyageCount	: Integer;
	modeConsVoyage		: String;
	eirNumbers			: StringArray;
	eirCount			: IntegerArray;
	maxEirCount			: Integer;
	modeEirNumber		: String;
	opImpRelPins		: StringArray;
	opImpRelPinCount	: IntegerArray;
	maxOpImpRelPinCount	: Integer;
	modeOpImpRelPin		: String;
	addRemarks1			: StringArray;
	addRemarks1Count	: IntegerArray;
	maxAddRemarks1Count	: Integer;
	modeAddRemarks1		: String;
	addRemarks2			: StringArray;
	addRemarks2Count	: IntegerArray;
	maxAddRemarks2Count	: Integer;
	modeAddRemarks2		: String;
	obj					: Object;
	opImpRelPin			: String;
	firstTi 			: CM_TrackedItem;
begin
	
	if _item.isKindOf(CMGTE_Release) then
		//just re-loading existing data, don't do anything special
		return;
	elseif _item.isKindOf(CM_TrackedItem) then
		ti := _item.CM_TrackedItem;
	endif;
	
	if self.lstCargoIDvalues.allSelectedObjects.size() &lt; 2 then
		//The user has not multi-selected cargo, so nothing special to do.
		return;
	else
		firstTi := self.lstCargoIDvalues.allSelectedObjects.first.CM_TrackedItem;
		if not firstTi.allBulkReleasesAssigned.isEmpty then
			bulkRel := firstTi.allBulkReleasesAssigned.first;
		endif;
		if bulkRel &lt;&gt; null then
			// there is a bulk release, so the multi select ti rules do not apply, Bulk Release values take priority
			return;
		endif;
	endif;
	
	terminal := _item.getMyTerminal();
	if terminal &lt;&gt; null then
		urc := terminal.getConfig(UpdateReleasedCargo).Integer;	
	else
		// No terminal, should never happen, but given it has, so we don't really know what they want.
		return;
	endif;

	// OK we are in multiselect mode, and not using a bulk release, time to work out what to pre-fill in the 'Updae Released Cargo With:' fields.
		
	if urc = UpdateNone then	//1	"No Updating At All" 
		//The 'Update Released Cargo frame should be disabled, and the attributes should all be empty.
		self.clearUpdReleasedCargoFields( null, false );
		return;
	endif;
	
	if urc = UpdateDefaultFirst then	//2	"Update With Default Values - First"
		//The 'Update Released Cargo frame should be enabled, and pre-filled with the values from the first ti.
		self.clearUpdReleasedCargoFields( firstTi, true );
		return;
	endif;
	
	if urc = UpdateDefaultSingle then	//3	"Update With Default Values - Single"
		//The 'Update Released Cargo frame should be enabled, but not pre-filled. This one means that 'Multi-select' is turned off,
		//so technically the user can never get to here anyway
		// and if they did, we would be only pre-setting the values to the same as they already were!
		return;
	endif;
	
	if urc = UpdateDefaultNo then	//5	"Update With No Default Values"
		//The 'Update Released Cargo frame should be enabled, but the attributes should all be empty.
		self.clearUpdReleasedCargoFields( null, true );
		return;
	endif;
	
	if urc = UpdateDefaultMost then	//4	"Update With Default Values - Most"
		//The 'Update Released Cargo frame should be enabled, and pre-filled with the most commonly used values from the selected tis.		
		
		self.clearUpdReleasedCargoFields( null, true );
		
		create consignees transient;
		create consigneeCount transient;
		create destTerminals transient;
		create destTerminalCount transient;
		create delRelNums transient;
		create delRelCount transient;
		create delRelReasons transient;
		create delRelReasonCount transient;
		create remarks transient;
		create remarksCount transient;
		create clientRefs transient;
		create clientRefCount transient;
		create custRelNums transient;
		create custRelCount transient;
		create consVoyages transient;
		create consVoyageCount transient;
		create eirNumbers transient;
		create eirCount transient;
		create opImpRelPins transient;
		create opImpRelPinCount transient;
		create addRemarks1 transient;
		create addRemarks1Count transient;
		create addRemarks2 transient;
		create addRemarks2Count transient;

		foreach obj in self.lstCargoIDvalues.allSelectedObjects do
			ti := obj.CM_TrackedItem;

			found := false;
			foreach idx in 1 to consignees.size() do
				if consignees[idx] = ti.myConsignee then
					consigneeCount[idx] := consigneeCount[idx] + 1;
					found := true;
					if consigneeCount[idx] &gt; maxConsigneeCount then
						maxConsigneeCount := consigneeCount[idx];
						modeConsignee := consignees[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.myConsignee &lt;&gt; null then
				consignees.add(ti.myConsignee);
				consigneeCount.add(1);
			endif;

			found := false;
			foreach idx in 1 to destTerminals.size() do
				if destTerminals[idx] = ti.destinationTerminal then
					destTerminalCount[idx] := destTerminalCount[idx] + 1;
					found := true;
					if destTerminalCount[idx] &gt; maxDestTerminalCount then
						maxDestTerminalCount := destTerminalCount[idx];
						modeDestTerminal := destTerminals[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.destinationTerminal &lt;&gt; null then
				destTerminals.add(ti.destinationTerminal);
				destTerminalCount.add(1);
			endif;

			found := false;
			foreach idx in 1 to delRelNums.size() do
				if delRelNums[idx] = ti.deliveryRelease then
					delRelCount[idx] := delRelCount[idx] + 1;
					found := true;
					if delRelCount[idx] &gt; maxDelRelCount then
						maxDelRelCount := delRelCount[idx];
						modeDelRelNumber := delRelNums[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.deliveryRelease &lt;&gt; null then
				delRelNums.add(ti.deliveryRelease);
				delRelCount.add(1);
			endif;

			found := false;
			foreach idx in 1 to delRelReasons.size() do
				if delRelReasons[idx] = ti.deliveryReleaseReason then
					delRelReasonCount[idx] := delRelReasonCount[idx] + 1;
					found := true;
					if delRelReasonCount[idx] &gt; maxDelRelReasonCount then
						maxDelRelReasonCount := delRelReasonCount[idx];
						modeDelRelReason := delRelReasons[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.deliveryReleaseReason &lt;&gt; null then
				delRelReasons.add(ti.deliveryReleaseReason);
				delRelReasonCount.add(1);
			endif;

			found := false;
			foreach idx in 1 to remarks.size() do
				if remarks[idx] = ti.remarks then
					remarksCount[idx] := remarksCount[idx] + 1;
					found := true;
					if remarksCount[idx] &gt; maxRemarksCount then
						maxRemarksCount := remarksCount[idx];
						modeRemark := remarks[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.remarks &lt;&gt; null then
				remarks.add(ti.remarks);
				remarksCount.add(1);
			endif;

			found := false;
			foreach idx in 1 to clientRefs.size() do
				if clientRefs[idx] = ti.clientRef then
					clientRefCount[idx] := clientRefCount[idx] + 1;
					found := true;
					if clientRefCount[idx] &gt; maxClientRefCount then
						maxClientRefCount := clientRefCount[idx];
						modeClientRef := clientRefs[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.clientRef &lt;&gt; null then
				clientRefs.add(ti.clientRef);
				clientRefCount.add(1);
			endif;

			found := false;
			foreach idx in 1 to custRelNums.size() do
				if custRelNums[idx] = ti.customsEntryNumber then
					custRelCount[idx] := custRelCount[idx] + 1;
					found := true;
					if custRelCount[idx] &gt; maxCustRelCount then
						maxCustRelCount := custRelCount[idx];
						modeCustRelNum := custRelNums[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.customsEntryNumber &lt;&gt; null then
				custRelNums.add(ti.customsEntryNumber);
				custRelCount.add(1);
			endif;

			found := false;
			foreach idx in 1 to consVoyages.size() do
				if consVoyages[idx] = ti.consignorVoyageCode then
					consVoyageCount[idx] := consVoyageCount[idx] + 1;
					found := true;
					if consVoyageCount[idx] &gt; maxConsVoyageCount then
						maxConsVoyageCount := consVoyageCount[idx];
						modeConsVoyage := consVoyages[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.consignorVoyageCode &lt;&gt; null then
				consVoyages.add(ti.consignorVoyageCode);
				consVoyageCount.add(1);
			endif;

			found := false;
			foreach idx in 1 to eirNumbers.size() do
				if eirNumbers[idx] = ti.eirNumber then
					eirCount[idx] := eirCount[idx] + 1;
					found := true;
					if eirCount[idx] &gt; maxEirCount then
						maxEirCount := eirCount[idx];
						modeEirNumber := eirNumbers[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.eirNumber &lt;&gt; null then
				eirNumbers.add(ti.eirNumber);
				eirCount.add(1);
			endif;

			found := false;
			opImpRelPin := ti.getOperatorImportReleasePIN();
			foreach idx in 1 to opImpRelPins.size() do
				if opImpRelPins[idx] = opImpRelPin then
					opImpRelPinCount[idx] := opImpRelPinCount[idx] + 1;
					found := true;
					if opImpRelPinCount[idx] &gt; maxOpImpRelPinCount then
						maxOpImpRelPinCount := opImpRelPinCount[idx];
						modeOpImpRelPin := opImpRelPins[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and opImpRelPin &lt;&gt; null then
				opImpRelPins.add(opImpRelPin);
				opImpRelPinCount.add(1);
			endif;

			found := false;
			foreach idx in 1 to addRemarks1.size() do
				if addRemarks1[idx] = ti.remarksAdditional1 then
					addRemarks1Count[idx] := addRemarks1Count[idx] + 1;
					found := true;
					if addRemarks1Count[idx] &gt; maxAddRemarks1Count then
						maxAddRemarks1Count := addRemarks1Count[idx];
						modeAddRemarks1 := addRemarks1[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.remarksAdditional1 &lt;&gt; null then
				addRemarks1.add(ti.remarksAdditional1);
				addRemarks1Count.add(1);
			endif;

			found := false;
			foreach idx in 1 to addRemarks2.size() do
				if addRemarks2[idx] = ti.remarksAdditional2 then
					addRemarks2Count[idx] := addRemarks2Count[idx] + 1;
					found := true;
					if addRemarks2Count[idx] &gt; maxAddRemarks2Count then
						maxAddRemarks2Count := addRemarks2Count[idx];
						modeAddRemarks2 := addRemarks2[idx];
					endif;
					break;
				endif;
			endforeach;
			if not found and ti.remarksAdditional2 &lt;&gt; null then
				addRemarks2.add(ti.remarksAdditional2);
				addRemarks2Count.add(1);
			endif;
		endforeach;

		self.cmbUpdateConsign.setForObject(modeConsignee);
		self.cmbDestTerminal.setForObject(app.myRoot.allTerminals[modeDestTerminal]);
		self.txtDeliveryRelNo.setValue(modeDelRelNumber);
		self.cmbDelReason.setForText(app.deliveryReasonEnumToString(modeDelRelReason));
		self.txtRemarks.setValue(modeRemark);
		self.txtClientRef.setValue(modeClientRef);
		self.txtCustomsRelNo.setValue(modeCustRelNum);
		self.txtConsignVoy.setValue(modeConsVoyage);
		self.txtEquipXchg.setValue(modeEirNumber);
		self.txtOpImportPIN.setValue(modeOpImpRelPin);
		self.txtAddRemarks1.setValue(modeAddRemarks1);
		self.txtAddRemarks2.setValue(modeAddRemarks2);
		
		return;
		
	endif;
		
epilog

	delete consignees;
	delete consigneeCount;
	delete destTerminals;
	delete destTerminalCount;
	delete delRelNums;
	delete delRelCount;
	delete delRelReasons;
	delete delRelReasonCount;
	delete remarks;
	delete remarksCount;
	delete clientRefs;
	delete clientRefCount;
	delete custRelNums;
	delete custRelCount;
	delete consVoyages;
	delete consVoyageCount;
	delete eirNumbers;
	delete eirCount;
	delete opImpRelPins;
	delete opImpRelPinCount;
	delete addRemarks1;
	delete addRemarks1Count;
	delete addRemarks2;
	delete addRemarks2Count;
		
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setVehicleBookingTimeSlotItem" id="3dc63a66-2c79-4032-a8f7-eccec034b339">
        <updating/>
        <source>setVehicleBookingTimeSlotItem(_vbsti : CM_VehicleBookingTimeSlotItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 July 2024	navpw1	Initial creation TFS: 61525 (61527)

*/

begin
	self.myVbsti := _vbsti;
	
end;</source>
