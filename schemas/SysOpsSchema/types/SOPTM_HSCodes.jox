    <JadeMethod name="loadDataForFirstTime" id="eedf6149-3fd7-4ef6-a8bf-de136e1ddbb1">
        <updating/>
        <source>loadDataForFirstTime() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	jlier1	Initial creation 55583

*/

vars

begin
	
	if self.allHSCodes.first &lt;&gt; null then
		return;
	endif;
			
	app.myRoot.allHSSections.copy(self.allHSCodes);
	app.myRoot.allHSChapters.copy(self.allHSCodes);
	app.myRoot.allHSHeadings.copy(self.allHSCodes);
	app.myRoot.allHSCodes.copy(self.allHSCodes);
	app.myRoot.allHSSubCodes.copy(self.allHSCodes);
	app.myRoot.allHSTaricCodes.copy(self.allHSCodes); //01/08/2024	navkc1 Bug 65204
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="c2002c3d-531b-4e90-bbf6-a187d38c811c">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	jlier1	Initial creation 55583

*/

vars
	theForm		: SOP_TableMaintForm;
begin
	
	theForm:=self.myForm;
	theForm.tblInput1.userInputEnabled := true;	
	theForm.tblInput1.disableRowByName(ETRow_Type); //epr TFS 2328 14/7/16
	theForm.tblInput1.enableRowByName(ETRow_HsCode);	
	theForm.tblInput1.enableRowByName(ETRow_HsCodeDescription);
	theForm.tblInput1.enableRowByName(ETRow_UnitQuantity);
	theForm.tblInput1.enableRowByName(ETRow_NotAvailableForEntry);
	theForm.tblInput1.enableRowByName(ETRow_ExternalRef1);
	theForm.tblInput1.enableRowByName(ETRow_ExternalRef2);
	theForm.tblInput1.enableRowByName(ETRow_ExternalRef3);
	
	if theForm.mode = theForm.Mode_Update then
		if theForm.myCurrentObject.isKindOf(CM_HSCodeSection) or	
			theForm.myCurrentObject.isKindOf(CM_HSCodeChapter) or
			theForm.myCurrentObject.isKindOf(CM_HSCodeHeading) then
			theForm.tblInput1.disableRowByName(ETRow_HsCode);	
			theForm.tblInput1.disableRowByName(ETRow_UnitQuantity);	
		endif;
	elseif theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.enableRowByName(ETRow_Type);
		self.setupTypeComboBox();
		self.myForm.tblInput1.showRowByName(ETRow_UnitQuantity,false);
		self.myForm.tblInput1.showRowByName(ETRow_ExternalRef1,false);
		self.myForm.tblInput1.showRowByName(ETRow_ExternalRef2,false);
		self.myForm.tblInput1.showRowByName(ETRow_ExternalRef3,false);
	endif;
epilog

end;</source>
    </JadeMethod>
