    <JadeMethod name="addToolbarControls" id="aca2df5f-889c-49a7-a827-cc455e201c93">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2009	#cnwdz2	 par21808

*/

vars
	toolbarObj	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbarObj	:=	self.frmToolbar;
	toolbarObj.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);	
	toolbarObj.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);		
	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	
	toolbarObj.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);				
	toolbarObj.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);				
	toolbarObj.addButton(self.btnSave, CMUI_Toolbar.Control_Alignment_Left);	
	toolbarObj.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbarObj.addFrame(self.frmALL, CMUI_Toolbar.Control_Alignment_Left);	//19 Aug 2013	NDL	Par 31910
	toolbarObj.addButton(self.btnPrintAll, CMUI_Toolbar.Control_Alignment_Left);	//19 Aug 2013	NDL	Par 31910
	toolbarObj.addButton(self.btnExportAll, CMUI_Toolbar.Control_Alignment_Left);	//19 Aug 2013	NDL	Par 31910	
	toolbarObj.addButton(self.btnDeleteAll, CMUI_Toolbar.Control_Alignment_Left);	//19 Aug 2013	NDL	Par 31910
	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbarObj.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	self.btnCancelBase.enabled 	:= false;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
