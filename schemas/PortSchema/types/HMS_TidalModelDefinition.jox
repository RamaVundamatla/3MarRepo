    <JadeMethod name="getMaxDraughtFromDate" id="e4f1c06c-5d77-4ae1-a2ef-4a7533a2abbe">
        <source>getMaxDraughtFromDate(_fromDate : TimeStamp; _maxDate : TimeStamp output;maxValue : Decimal output) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2008	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	tidalData,
	maxTidalData : HMS_TidalData;
	value : Decimal[16,2];
begin

	iter :=self.allHMSTidalData.createIterator;
	self.allHMSTidalData.startKeyGeq(_fromDate,iter);
	while iter.next(tidalData) do
		value:=tidalData.getValue;
		if maxValue = null or value &gt; maxValue then
			maxValue:=value;
			maxTidalData:=tidalData;
			_maxDate:=tidalData.ts;
		endif;
	endwhile;	
	
	return self.getAvailableDraft(maxTidalData);
epilog
	delete iter;
end;</source>
        <Parameter name="_fromDate" type="TimeStamp"/>
        <Parameter name="_maxDate" type="TimeStamp" usage="output"/>
        <Parameter name="maxValue" type="Decimal" usage="output"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getOldRvLocForDll" id="0bf1cb76-6fa3-4357-94e1-f1e8a82cbd82">
        <source>getOldRvLocForDll() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	12 October 2006 By cnwth2

Purpose:	Returns the Integer for the call to the dll rvtide.dll

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.description = 'Tauranga Entrance  ADCP' then	//This is current
		return 1;
		
	// Following are for tidal height
	elseif self.description = 'Tauranga, A Bouy' then
		return 1;
	elseif self.description = 'Tauranga, Tug Berth' then
		return 2;
	elseif self.description = 'Tauranga, Sulpher Point' then
		return 3;
	endif;
	
	return -1;
	
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTidalDataClassForType" id="023ae701-e9db-46f5-b4dc-091d336dad90">
        <source>getTidalDataClassForType(_type : Integer) : Class;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _type = HMS_TidalDataType_Current then
		return HMS_CurrentTidalData;
	elseif _type = HMS_TidalDataType_Height then
		return HMS_DraftTidalData;
	elseif _type = HMS_TidalDataType_HiLo then
		return HMS_HiLoTidalData;
	//daylight data not yet handled
	//elseif _type = HMS_TidalDataType_Daylight then
	
	endif;
end;


</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getTidalDataForDate" id="db30d515-2da2-429c-9f74-8ee2f0f41940">
        <source>getTidalDataForDate(_tideTS:TimeStamp; _isPrevious:Boolean):HMS_TidalData;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns a reference to a Tidal Data object immediately prior to or
//				immediately after the specified date/time.
//
// Parameters:	_tideTS - The date/time of the tide.
//				_isPrevious - True if the previous tide is required, otherwise the
//					next tide will be used.
//
// Returns:		A reference to a Tidal Data object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tidalDataObj	: HMS_TidalData;
	iteratorObj		: Iterator;
	
begin
	iteratorObj	:=	self.allHMSTidalData.createIterator();
	
	if _isPrevious then
		self.allHMSTidalData.startKeyLeq(_tideTS, iteratorObj);
		
		while iteratorObj.back(tidalDataObj) do
			break;
		endwhile;
		
		return tidalDataObj;
	else
		self.allHMSTidalData.startKeyGeq(_tideTS, iteratorObj);
		
		while iteratorObj.next(tidalDataObj) do
			break;
		endwhile;
		
		return tidalDataObj;
	endif;
	
	return null;
epilog
	delete iteratorObj;
end;</source>
        <Parameter name="_tideTS" type="TimeStamp"/>
        <Parameter name="_isPrevious" type="Boolean"/>
        <ReturnType type="HMS_TidalData"/>
    </JadeMethod>
    <JadeMethod name="getTideHeightForTime" id="36e3c6ce-13a0-4145-9942-013fe2ecaeed">
        <source>getTideHeightForTime(_timeToCheck : TimeStamp) : Decimal;
// ---------------------------------------------------------------------------
// Created:     28 December 2007 by cnwrs2
//
// Purpose:    
/*

Date		Who		Reason
11 Apr 2008	cnwrs2	PAR  16520 - round to 2 decimal places
02 May 2008	cnwkpd1	PAR #16642 - signature change to return a Decimal, to correct issues with
					Real imprecision

*/

vars
	dict				: HMS_TidalDataByTSDict;
	iter				: Iterator;
	thisTidalData,
	prevTidalData		: HMS_TidalData;
	tsKey				: TimeStamp;
	differenceMinutes	: Integer;
	prevHeight,
	thisHeight			: Decimal[10,2];			// PAR #16642
	
begin
	if (not self.dataType = HMS_TidalDataType_Height) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Method called for incorrect data type');
		return null;
	endif;

	dict := self.allHMSTidalData;
	iter := dict.createIterator();
	dict.startKeyLeq(_timeToCheck, iter);

	
	while iter.next(thisTidalData) do
		dict.getIteratorKeys(tsKey, iter);
		
		if thisTidalData.ts = _timeToCheck then
			return self.getAvailableDraft(thisTidalData);
		endif;
		
		if prevTidalData &lt;&gt; null then
		
			prevHeight := self.getAvailableDraft(prevTidalData);
			thisHeight := self.getAvailableDraft(thisTidalData);
		
			return self.getDraftAtTimeWithData(_timeToCheck, prevTidalData.ts, prevHeight, thisTidalData.ts, thisHeight);
		endif;
		
		prevTidalData := thisTidalData;
	endwhile;

	return null;

epilog
	delete iter;
end;</source>
        <Parameter name="_timeToCheck" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTideTypeAndHeight" id="6c5d4652-d29c-42ff-85b0-44c433c3dda1">
        <source>getTideTypeAndHeight(_checkTime : TimeStamp; _tideType : Integer output; 
			_tidalHeight : Decimal output;
			_errStr : String output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 December 2007 by cnwrs2
//
// Purpose:     Returns false if no or insufficient tidal data found
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 May 2008	cnwkpd1	PAR #16642 - signature change to return a Decimal for tidalHeight, to correct issues with
					Real imprecision

*/

vars
	prevTidalData,
	nextTidalData	: HMS_HiLoTidalData;

begin

	if self.dataType &lt;&gt; HMS_TidalDataType_HiLo then
		// Tidal Model (' &amp; self.code &amp; ') is not HiLo Type - cannot get tide type and height
		_errStr := app.getErrorString1(Tidal_model_not_hilo_type, self.code);
		return false;
	endif;
	
	prevTidalData := self.allHMSTidalData.getAtKeyLeq(_checkTime).HMS_HiLoTidalData;
	nextTidalData := self.allHMSTidalData.getAtKeyGtr(_checkTime).HMS_HiLoTidalData;
	if prevTidalData = null or nextTidalData = null then
		// Tidal Model (' &amp; self.code &amp; ') has no data for &amp; _checkTime.asStringJMT &amp; '.'
		_errStr := app.getErrorString2(Tidal_model_has_no_data, self.code, _checkTime.asStringJMT);
		return false;
	endif;

	_tideType := prevTidalData.tideType;

	if _tideType = HMS_TideType_Low and
	   nextTidalData.tideType = HMS_TideType_High then
		if prevTidalData.ts &lt;&gt; _checkTime then
			_tideType := HMS_TideType_Flood;
		endif;
	elseif _tideType = HMS_TideType_High and
	   nextTidalData.tideType = HMS_TideType_Low then
		if prevTidalData.ts &lt;&gt; _checkTime then
			_tideType := HMS_TideType_Ebb;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name,
			'Inconsistent tidal data for ' &amp; _checkTime.asStringJMT);
		return false;
	endif;
	
	_tidalHeight := (prevTidalData.getValue - nextTidalData.getValue).abs;		// PAR #16642
		
	return true;

end;</source>
        <Parameter name="_checkTime" type="TimeStamp"/>
        <Parameter name="_tideType" type="Integer" usage="output"/>
        <Parameter name="_tidalHeight" type="Decimal" usage="output"/>
        <Parameter name="_errStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTidalData" id="16199234-bfde-4668-aa9e-f6f3ee7eff8d">
        <source>hasTidalData() : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return (not self.allHMSTidalData.isEmpty);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTidalDataForDateTime" id="2c7eae29-dd68-4858-bf19-acbc8d183a2e">
        <source>hasTidalDataForDateTime(_timestamp:TimeStamp):Boolean;
// --------------------------------------------------------------------------------
// Created:		12 October 2007 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified timestamp
//				is covered by the receiver's known tidal data.
//
// Parameters:	_timestamp - The timestamp to check.
//
// Returns:		True if the timestamp is covered by the tidal data, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	firstDataObj	: HMS_TidalData;
	lastDataObj		: HMS_TidalData;
	
begin

	if (not _timestamp.isValid) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid null timestamp passed to method');
		return false;
	endif;

	firstDataObj	:=	self.allHMSTidalData.first();
	lastDataObj		:=	self.allHMSTidalData.last();
	
	if firstDataObj = null or lastDataObj = null then
		return false;
	else
		return (_timestamp &gt;= firstDataObj.ts and _timestamp &lt;= lastDataObj.ts);
	endif;
end;</source>
        <Parameter name="_timestamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFloodTideAtTime" id="5632f46b-37d6-49aa-967c-8a06f5d98cf2">
        <source>isFloodTideAtTime(_atTime : TimeStamp; _nextFloodTime : TimeStamp output) : Boolean;
/*

Purpose:		Potentially the time can either be on high or low tide or in the middle

				- if the previous hilo is a low tide and the next a high tide then its a FLOOD Tide
				- if the previous hilo tide is a high tide and the next is a low tide then its a EBB Tide


Return Value:		


Date		Who		Reason
14 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
	iter : Iterator;
	hmsTidalData : HMS_TidalData;
	hiloTidalData : HMS_HiLoTidalData;
	result : Boolean;
begin
	
	if self.dataType &lt;&gt; HMS_TidalDataType_HiLo then
		// NOT A HILO tidal model so return false
		_nextFloodTime:=null;
		return false;
	endif;

	iter:=self.allHMSTidalData.createIterator;
	
	self.allHMSTidalData.startKeyGeq(_atTime, iter);
	
	iter.next(hmsTidalData);

	if hmsTidalData = null then
		_nextFloodTime:=null;
		return false;
	endif;
	//iter.next(hmsTidalData);
	
	hiloTidalData:=hmsTidalData.HMS_HiLoTidalData;
	if hmsTidalData.ts = _atTime then
		//is on a hi or low tide
		result:=false;
		// Get the next flood time
		//if it is a low tide can just add a minute
		if 	hiloTidalData.isLowTide then
			_nextFloodTime:=hmsTidalData.ts.addMinutes(1);
			return result;
		else
		//else its a high tide have to get the next low tide and add a minute
			iter.next(hmsTidalData);
			if hmsTidalData = null then
				_nextFloodTime:=null;
				return false;
			endif;
			_nextFloodTime:=hmsTidalData.ts.addMinutes(1);
			return result;
		endif;	
	else
		
		if not hiloTidalData.isLowTide then
			//if its a low tide just return atTime 
			_nextFloodTime:=_atTime;//hmsTidalData.ts; 
			return true;
		else	
		//if its a high tide then it is a flood tide can return true and _nextFloodTime = _atTime
			_nextFloodTime:=hmsTidalData.ts.addMinutes(1);
			return false;
		endif;
	endif;
	
	
	

	return false;
epilog
	delete iter;
end;</source>
        <Parameter name="_atTime" type="TimeStamp"/>
        <Parameter name="_nextFloodTime" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTideStateAtTime" id="ade59997-3195-4003-ac73-894ba7321b8c">
        <source>isTideStateAtTime(_tideState : Integer; _atTime : TimeStamp; _nextTideStateTime : TimeStamp output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 June 2008	cnwer1	Initial creation

*/

vars
	prevTidalData,
	nextTidalData,tidalData	: HMS_HiLoTidalData;
	getNextTide : Boolean;
	iter : Iterator;
begin
	prevTidalData :=self.allHMSTidalData.getAtKeyLeq(_atTime).HMS_HiLoTidalData; //i.e LOW WATER
	nextTidalData := self.allHMSTidalData.getAtKeyGtr(_atTime).HMS_HiLoTidalData; //i.e HIGH WATER
	if  _tideState = HMS_CheckPoint.TideState_Flood then
		if  nextTidalData.tideType = HMS_TideType_High and _atTime &lt;&gt; nextTidalData.ts  and _atTime &lt;&gt; prevTidalData.ts  then
			return true;
		endif;
	elseif  _tideState = HMS_CheckPoint.TideState_Ebb then
		if  nextTidalData.tideType = HMS_TideType_Low then
			return true;
		endif;
	endif;
	
	// IS A EBB TIDE
	prevTidalData:=nextTidalData;
	iter:= self.allHMSTidalData.createIterator;
	iter.startAtObject(nextTidalData);
	iter.next(tidalData);
	if tidalData &lt;&gt; null then
		nextTidalData:=tidalData;
		_nextTideStateTime:=nextTidalData.ts.cnEcAddMinutes(1);
	endif;

	return false;
epilog
	delete iter;
end;</source>
        <Parameter name="_tideState" type="Integer"/>
        <Parameter name="_atTime" type="TimeStamp"/>
        <Parameter name="_nextTideStateTime" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="minutesToNextHiLoTide" id="e2db9c26-f870-46af-8ad4-fdd3c78032e0">
        <source>minutesToNextHiLoTide(_time: TimeStamp; _highTide: Boolean): Integer;
//21 September 2008	cnwdw1	
//
vars
	iter : Iterator;
	hmsTidalData : HMS_TidalData;
	hiloTidalData : HMS_HiLoTidalData;
begin
	if self.dataType &lt;&gt; HMS_TidalDataType_HiLo then
		// NOT A HILO tidal model so return false
		return -1;
	endif;

	iter:=self.allHMSTidalData.createIterator;
	
	self.allHMSTidalData.startKeyGeq(_time, iter);
	
	iter.next(hmsTidalData);

	if hmsTidalData = null then
		return -1;
	endif;
		
	hiloTidalData:=hmsTidalData.HMS_HiLoTidalData;
	if hiloTidalData.isLowTide and _highTide or
	   hiloTidalData.isHighTide and not _highTide then
		// move to next tide
		iter.next(hmsTidalData);
	endif;
	
	return (((hmsTidalData.ts - _time).getMilliseconds) / 60000).Integer;
epilog
	delete iter;
end;</source>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_highTide" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="bb2e324e-7fb6-4a18-acc4-100a91b94e06">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
20/04/2011	 cnwmh5	 	 PAR #27401 - Add code to handle prossible exceptions occurring when
						 trying to create the proxy	
----------   ----------  --------------------------------------------------
*/
vars
	newObj				: SelfType;
	completedOK			: Boolean;
begin
	newObj := inheritMethod();
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return newObj;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete newObj;
	endif;	
end;


</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
