    <JadeMethod name="enqTIsForCranePickup" id="f15f4e0b-c62a-436b-b4f1-b7afd5790ba1">
        <source>enqTIsForCranePickup(	_tiID, _twinTiID : String;
						_ti,_twinTI : CM_TrackedItem io; 
						_errorMsgs: DTO_HandHeldGateErrorDict input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2009	cnwer1	Initial creation

*/

vars
	allValidTIs : CM_TISet;
begin
	
	create allValidTIs transient;
	
	_ti:=self.myMachine.isValidOnQueueVoyageTIID(_tiID,allValidTIs);	//22 Dec 2010	NDL	Par 26471
	
	allValidTIs.clear;
	_twinTI:=self.myMachine.isValidOnQueueVoyageTIID(_twinTiID,allValidTIs);	//22 Dec 2010	NDL	Par 26471
	
	if _ti= null or (_twinTiID &lt;&gt; null and _twinTI = null) then
		return false;
	endif;
	
	return true;
epilog
	delete allValidTIs;
end;</source>
        <Parameter name="_tiID" type="String"/>
        <Parameter name="_twinTiID" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_twinTI" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enqTrackedItem" id="dae3d83f-c9ac-4ffb-9672-5f3fcac1c710">
        <updating/>
        <source>enqTrackedItem(_tiId	: String; _dto : DTO_EnquiryGradingTasks input; _trackedItem : CM_TrackedItem output; _errorMsgs: DTO_HandHeldGateErrorDict input) : Boolean updating;
// -------------------------------------------
// Created 16 June 2008 concms1 PAR 17123 (CCMS 1671) DCT Gdansk
// -------------------------------------------
vars


begin
	app.myPassport.clearErrorsWarnings;
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	app.myTrxRT.trxEnqTrackedItem(_tiId, self.myMediator, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		self.createErrorsFromPassport(_errorMsgs);
		return false;
	endif;
	
	_trackedItem :=self.myMediator.myCurrentTi;
	_dto.setFromTI(self.myMediator.myCurrentTi);
			
	return true;
epilog

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getRelatedTask" id="35596182-a8ff-4bcd-b609-409b16564e33">
        <updating/>
        <source>getRelatedTask() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2009	cnwer1	Initial creation

*/

vars
	task: CM_RTQueueTask;
	entry : CM_RTQueueEntry;
begin
	task := self.getCurrentTask;
	entry := task.myEntry;
	self.myRelatedTask:=entry.getNextEntryFirstTask;
	if self.myRelatedTask = null then
		self.myRelatedTask:=entry.getPreviousEntryFirstTask;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
