Return Value:		


Date		Who		Reason
02 March 2007	cnwer1	Initial creation - PAR#xxxx
//21 02 17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/
vars

	tableItemRT : SOPTM_RTDevices;
	tableItemWB : SOPTM_WeighBridge;
begin
	if self.myCurrentTableItem = null then
		return;
	endif;
	
	if 	self.myCurrentTableItem.isKindOf(SOPTM_RTDevices) then 
		tableItemRT := self.myCurrentTableItem.SOPTM_RTDevices;
		tableItemRT.doEditSerialConnection();

	elseif self.myCurrentTableItem.isKindOf(SOPTM_WeighBridge) then //TFS3153
		tableItemWB := self.myCurrentTableItem.SOPTM_WeighBridge;	//TFS3153
		tableItemWB.doEditSerialConnection();						//TFS3153
	endif;															//TFS3153
	

epilog

end;</source>
