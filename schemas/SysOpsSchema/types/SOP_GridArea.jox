    <JadeMethod name="maxRowHeight" id="a4bbf8b8-83c1-4f42-aa5e-a28a6fa93ff7">
        <methodInvocation>mapping</methodInvocation>
        <source>maxRowHeight(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpGridRow	: CMUI_GridRow;
	gridArea		: CM_GridArea;
begin

	if set then
//		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	gridArea := self.getGridArea;
	if gridArea &lt;&gt; null then
		_value := gridArea.heightOfStack;
	endif;
	
	//foreach tmpGridRow in self.allGridRows do	
	//	_value := _value.max(tmpGridRow.SOP_GridRow.maxHeight);
	//endforeach;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="relabelColumns" id="4c527739-26f6-4851-a7e4-8494784c0664">
        <source>relabelColumns(_gridArea : CM_GridArea);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	gridColumn				: CMUI_GridColumn;
	gridPoint				: CMUI_GridPoint;
	pxyColumn				: CM_GridColumn;
	gridController			: CM_GridController;
begin
	
	//dettach from everything parent - avoids duplicate key
	foreach gridColumn in self.allGridColumns do
		pxyColumn := gridColumn.myGridCol;
		pxyColumn.setGridAreaForProxy(null);
		foreach gridController in pxyColumn.allControllersByRow do
			gridController.setMyGridArea(null);
		endforeach;
	endforeach;
	//set new labels
	foreach gridColumn in self.allGridColumns do
		pxyColumn := gridColumn.myGridCol;
		pxyColumn.setColumnLabel(gridColumn.label);
		pxyColumn.setGridAreaForProxy(_gridArea);
	endforeach;

	
end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="relabelGridControllers" id="8e4ca53a-821b-4544-8a4b-91853fd66319">
        <source>relabelGridControllers(_pxyGridArea : CM_GridArea);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2009	cnwer1	Initial creation

*/

vars
	gridColumn				: CMUI_GridColumn;
	pxyColumn				: CM_GridColumn;
	gridController			: CM_GridController;
	newName : String;
begin

//set new labels
	foreach gridColumn in self.allGridColumns do
		pxyColumn := gridColumn.myGridCol;
		foreach gridController in pxyColumn.allControllersByRow do
			
				newName:= gridController.myGridRow.label &amp; gridController.myGridColumn.label;
				
				//have to check that there are no duplicates 
				/*
					users can't enter duplicate rows or duplicate column labels however the combination could produce an error
						e.g. ROWS M &amp; M1 and COLUMNS 1 and 11 would end in controllers
						M1, M11
						M11, M111 
						
						M11 is a duplicate will give 1310 crash
				*/
				if _pxyGridArea.allGridControllersByName[newName] &lt;&gt; null then
					//just testing will change the error message
					app.raiseCMException2(Already_exists_valid, newName," grid controller",null,null);
					return;
				endif;
				
				
				gridController.setName();
				if gridColumn.SOP_GridColumn.label40ftold &lt;&gt; null then
					gridController.setId40ft(gridController.myGridRow.label &amp; gridColumn.SOP_GridColumn.label40ftold);
				endif;
				gridController.setMyGridArea(_pxyGridArea);
			endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_pxyGridArea" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="relabelRows" id="d5b0c451-1768-40f7-b39d-e2ca9d26fd6f">
        <source>relabelRows(_pxyGridArea : CM_GridArea);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	gridRow					: CMUI_GridRow;
	gridPoint				: CMUI_GridPoint;
	pxyRow					: CM_GridRow;
	newName 				: String;
	gridController			: CM_GridController;
begin
	//dettach from everything parent - avoids duplicate key
	foreach gridRow in self.allGridRows do
		pxyRow := gridRow.myGridRow;
		pxyRow.setGridAreaForProxy(null);
		foreach gridController in pxyRow.allControllersByColumn do
			gridController.setMyGridArea(null);
		endforeach;
	endforeach;
	//set new labels
	foreach gridRow in self.allGridRows do
		pxyRow := gridRow.myGridRow;
		pxyRow.setRowLabel(gridRow.label);
		pxyRow.setGridAreaForProxy(_pxyGridArea);
	endforeach;

end;


</source>
        <Parameter name="_pxyGridArea" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="selectSinglePoint" id="e042ccb3-ac40-45f7-89e7-29b4c0f6bea5">
        <updating/>
        <source>selectSinglePoint(x: Real; y: Real): CMUI_GridPoint updating;
// ---------------------------------------------------------------------------
// Created:		12 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
	
vars
	thePoint : CMUI_GridPoint;
begin
	self.selectedColumn := 0;
	self.selectedRow := 0;
//	self.drawSelf();
	thePoint :=  inheritMethod(x, y);
	return thePoint;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="selectedAreaIncludes" id="27a35b0d-61b3-47b2-b2d8-5238a3c0c4c8">
        <source>selectedAreaIncludes(_gridPoint : SOP_GridPoint) : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	selectedCol,
	selectedRo 	: Integer;
	gridCol		: CMUI_GridColumn;
	gridRow		: CMUI_GridRow;
begin
	
	if self.allSelectedPoints.includes(_gridPoint) then
		return true;
	endif;

	selectedCol := self.selectedColumn;
	
	if selectedCol &gt; 0 then
		gridCol := self.allGridColumns[selectedCol];
		if gridCol &lt;&gt; null and gridCol.allGridPointsByRow.includes(_gridPoint) then
			return true;
		endif;
	endif;
	
	selectedRo := self.selectedRow;
	
	if selectedRo &gt; 0 then
		gridRow := self.allGridRows[selectedRo];
		if gridRow &lt;&gt; null and gridRow.allGridPointsByColumn.includes(_gridPoint) then
			return true;
		endif;
	endif;
					
	return false;
end;</source>
        <Parameter name="_gridPoint" type="SOP_GridPoint"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5ce87a2b-706a-4807-a5df-66b98d894b56">
        <updating/>
        <source>setForCreate(_cmifTerminalArea : CMIF_TerminalArea input; pAssistant: CMUI_Assistant) updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	gridRow					: CM_GridRow;
	gridCol					: CM_GridColumn;
	gridController			: CM_GridController;
	theWidth				: Integer;
	sopGridRow				: SOP_GridRow;
	sopGridCol				: SOP_GridColumn;
	sopGridPoint			: SOP_GridPoint;
	picture					: Picture;
	pxyTA					: CM_GridArea;
begin

	beginLoad;
	pxyTA := _cmifTerminalArea.myPxyTerminalArea.CM_GridArea;
	self.label			:= _cmifTerminalArea.id;
	//self.maxRowHeight 	:= _cmifTerminalArea.height;
	if self.myAssistant	= null then
		self.myAssistant := pAssistant;
	endif;
	self.type := _cmifTerminalArea.taType;
	
	_cmifTerminalArea.createTerminalArea();
	
	foreach gridRow in pxyTA.allGridRows do
		create sopGridRow transient;
		sopGridRow.setForCreate(self, gridRow);
	endforeach;

	foreach gridCol in pxyTA.allGridColumns do
		create sopGridCol transient;
		sopGridCol.setForCreate(self, gridCol);
	endforeach;

	foreach gridController in pxyTA.allGridControllersByRowColumn do
		create sopGridPoint transient;
		sopGridPoint.setForCreate(self, gridController, null);
	endforeach;


epilog
	endLoad;

end;</source>
        <Parameter name="_cmifTerminalArea" type="CMIF_TerminalArea" usage="input"/>
        <Parameter name="pAssistant" type="CMUI_Assistant"/>
    </JadeMethod>
    <JadeMethod name="setForDraw" id="33a33a55-a1e3-4ca1-9549-4bcdefb50c17">
        <updating/>
        <source>setForDraw(_gridArea : CM_GridArea; _assistant : CMUI_Assistant; _form : SOP_TerminalAreaDefForm) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridRow		: CM_GridRow;
	gridCol		: CM_GridColumn;
	gridController	: CM_GridController;
	sopGridRow		: SOP_GridRow;
	sopGridCol		: SOP_GridColumn;
	sopGridPoint	: SOP_GridPoint;
	picture			: Picture;
	pictureType		: Integer;
	loadState : Boolean;
begin

	app.cmsBeginLoad(loadState);
	
	self.label			:= _gridArea.id;
	self.type			:= _gridArea.type;
	self.myAssistant	:= _assistant;
	//self.maxRowHeight 	:= _gridArea.heightOfStack;
	foreach gridRow in _gridArea.allGridRows do
		create sopGridRow transient;
		sopGridRow.setForCreate(self, gridRow);
	endforeach;

	foreach gridCol in _gridArea.allGridColumns do
		create sopGridCol transient;
		sopGridCol.setForCreate(self, gridCol);
	endforeach;

	foreach gridController in _gridArea.allGridControllersByRowColumn do
		create sopGridPoint transient;
		
		pictureType := gridController.getLocationDisplay();
		picture := _form.getPicture(pictureType);
		sopGridPoint.setForDraw(self, gridController, picture);
	endforeach;


epilog
	app.cmsEndLoad(loadState);

end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
        <Parameter name="_assistant" type="CMUI_Assistant"/>
        <Parameter name="_form" type="SOP_TerminalAreaDefForm"/>
    </JadeMethod>
    <JadeMethod name="setGridRowColPositions" id="f239b987-df10-4459-8599-486a79664b92">
        <updating/>
        <source>setGridRowColPositions() updating;//, serverExecution;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow			: CMUI_GridRow;
	tmpCol			: CMUI_GridColumn;
	sopGridRow		: SOP_GridRow;
	sopGridCol		: SOP_GridColumn;
	lastPos,
	theRowHeight,
	theColWidth,
	tmpPos1,
	tmpPos2			: Real;	
	count 			: Integer;
	spacing			: Integer;

begin


	theRowHeight := RowHeight *  self.scaleYFactor;
	theColWidth	 := ColWidth * self.scaleXFactor;
	if type = TA_TYPE_FORK_LIFT_STACK or type = TA_TYPE_LOGAREA then
		spacing := 0;
		if type = TA_TYPE_LOGAREA then
			theRowHeight := theRowHeight * 2;
		endif;
	else
		spacing := (RowSpacing * (self.scaleXFactor - 1)).Integer;
	endif;

	if flipVertical then
		foreach tmpRow in self.allGridRows reversed do
			count := count + 1;
			sopGridRow := tmpRow.SOP_GridRow;
			tmpPos1 := TopMargin + ((count - 1) * theRowHeight) + ((count - 1) * spacing);
			tmpPos2 := tmpPos1 + theRowHeight;
			sopGridRow.setYPos(tmpPos1, tmpPos2);
		endforeach;
	else
		foreach tmpRow in self.allGridRows do
			count := count + 1;
			sopGridRow := tmpRow.SOP_GridRow;
			tmpPos1 := TopMargin + ((count - 1) * theRowHeight) + ((count - 1) * spacing);
//			tmpPos1 := TopMargin + ((sopGridRow.row - 1) * theRowHeight) + ((sopGridRow.row - 1) * spacing);
			tmpPos2 := tmpPos1 + theRowHeight;
			sopGridRow.setYPos(tmpPos1, tmpPos2);
		endforeach;
	endif;
	
	self.totalPointHeight := tmpPos2 + BottomMargin;

	if flipHorizontal then
		foreach tmpCol in self.allGridColumns reversed do
			sopGridCol := tmpCol.SOP_GridColumn;
			theColWidth := ColWidth * self.scaleXFactor * sopGridCol.maxWidth;
			
			if lastPos = 0 then
				lastPos := LeftMargin;
			endif;
			tmpPos1 := lastPos;
			
			tmpPos2 := tmpPos1 + theColWidth;
			sopGridCol.setXPos(tmpPos1, tmpPos2);
			
			lastPos := tmpPos2;
		endforeach;
	else
		foreach tmpCol in self.allGridColumns do
			sopGridCol := tmpCol.SOP_GridColumn;
			theColWidth := ColWidth * self.scaleXFactor * sopGridCol.maxWidth;
			
			if lastPos = 0 then
				lastPos := LeftMargin;
			endif;
			tmpPos1 := lastPos;
			
			tmpPos2 := tmpPos1 + theColWidth;
			sopGridCol.setXPos(tmpPos1, tmpPos2);
			
			lastPos := tmpPos2;
		endforeach;
	endif;

	self.totalPointWidth := tmpPos2 + RightMargin;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSelected" id="26a3dd7c-24be-4d8d-bec9-9fae125401f7">
        <updating/>
        <source>setSelected(_row, _column : Integer) updating;

vars

begin

	self.selectedRow := _row;
	self.selectedColumn := _column;

end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateForCol" id="e498810e-896e-4286-9add-7fe4bb99ff2d">
        <source>updateForCol(_cmifTA : CMIF_GridArea input);

vars

	theCol, theRow				: Integer;
	sopGridCol					: SOP_GridColumn;
	sopGridPoint				: SOP_GridPoint;	
	lastColNum					: String;
	pxyGridRow					: CM_GridRow;
	pxyGridCol					: CM_GridColumn;
	label,
	ident40Ft					: String;
	pxyGridArea					: CM_GridArea;
	pxyGridController			: CM_GridController;
	 				
begin
	
	pxyGridArea := _cmifTA.myPxyTerminalArea.CM_GridArea;
	
	beginLoad;
	if _cmifTA.numColumns &gt; self.allGridColumns.size then
		if self.allGridColumns.size &gt; 0 then
			lastColNum := self.allGridColumns.last.label.String;
		endif;
		
		foreach theCol in self.allGridColumns.size + 1 to _cmifTA.numColumns do
			_cmifTA.getNextColLabelNum(lastColNum);
			label := _cmifTA.prefixColumnLabel &amp; lastColNum;
			pxyGridCol := _cmifTA.addColumn(theCol, label);
			
			create sopGridCol transient;
			sopGridCol.setForCreate(self, pxyGridCol);
			
			ident40Ft:=_cmifTA.get40ftColId( pxyGridCol.label);
			sopGridCol.set40ftLabel(ident40Ft);
			foreach pxyGridRow in pxyGridArea.allGridRows do
				sopGridPoint:=self.allGridPoints[pxyGridRow.row,pxyGridCol.column].SOP_GridPoint;
				if sopGridPoint = null then
					create sopGridPoint transient;
					pxyGridController := _cmifTA.addGridController(PAD_AVAILABLE, NORMAL_USE, pxyGridRow, pxyGridCol, ident40Ft);
					sopGridPoint.setForCreate(self, pxyGridController, null);
				endif;
			endforeach;
		endforeach;
	else
		theCol := self.allGridColumns.size;
		while theCol &gt; _cmifTA.numColumns do
			sopGridCol := self.allGridColumns.getAtKey(theCol).SOP_GridColumn;
			if sopGridCol &lt;&gt; null then
				delete sopGridCol.myGridCol;
				delete sopGridCol;
			endif;
			theCol := theCol - 1;
		endwhile;
	endif;

epilog
	endLoad;

end;</source>
        <Parameter name="_cmifTA" type="CMIF_GridArea" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateForHeight" id="9e6ad5be-dfba-435c-b0f3-2f8ceca2383c">
        <updating/>
        <source>updateForHeight(_height : Integer) updating;

vars
	pxyGridArea		: CM_GridArea;
begin

	pxyGridArea := self.getGridArea;
	if pxyGridArea &lt;&gt; null then
		pxyGridArea.setHeightOfStack(_height);
	endif;
	
end;</source>
        <Parameter name="_height" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateForRow" id="38a285d5-334f-4f89-995f-7dbdab17bb3e">
        <source>updateForRow(_cmifTA : CMIF_GridArea input);

vars
	theRow						: Integer;
	sopGridRow					: SOP_GridRow;
	sopGridPoint				: SOP_GridPoint;
	lastRowNum					: String;
	ident40Ft					: String;
	label 						: String;
	pxyGridCol	 				: CM_GridColumn;
	pxyGridRow 					: CM_GridRow;
	pxyGridArea 				: CM_GridArea;
	pxyGridController			: CM_GridController;
	laneStr						: String;
begin
	
	pxyGridArea := _cmifTA.myPxyTerminalArea.CM_GridArea;
	
	beginLoad;
	if _cmifTA.numRows &gt; self.allGridRows.size  then

		if self.allGridRows.size &gt; 0 then
			lastRowNum := self.allGridRows.last.label.String;
		endif;
		
		foreach theRow in self.allGridRows.size + 1 to _cmifTA.numRows do
			_cmifTA.getNextRowLabelNum(lastRowNum);
			ident40Ft := _cmifTA.get40ftColId(lastRowNum);
			label := _cmifTA.prefixRowLabel &amp; lastRowNum;
			create sopGridRow transient;
			pxyGridRow := _cmifTA.addRow(theRow, label);
			sopGridRow.setForCreate(self, pxyGridRow);
			
			foreach pxyGridCol in pxyGridArea.allGridColumns do
				ident40Ft:=_cmifTA.get40ftColId( pxyGridCol.label);
				sopGridPoint:=self.allGridPoints[pxyGridRow.row,pxyGridCol.column].SOP_GridPoint;
				if sopGridPoint = null then
					create sopGridPoint transient;
					pxyGridController := _cmifTA.addGridController(PAD_AVAILABLE, NORMAL_USE, pxyGridRow, pxyGridCol, ident40Ft);
					sopGridPoint.setForCreate(self, pxyGridController,null);
				endif;
			endforeach;
		endforeach;

	else
		theRow := pxyGridArea.allGridRows.size;
		while theRow &gt; _cmifTA.numRows do
			sopGridRow := self.allGridRows.getAtKey(theRow).SOP_GridRow;
			if sopGridRow &lt;&gt; null then
				delete sopGridRow.myGridRow;
				delete sopGridRow;
			endif;
			theRow := theRow - 1;
		endwhile;
	endif;

epilog
	endLoad;
end;</source>
        <Parameter name="_cmifTA" type="CMIF_GridArea" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateColumnLabels" id="cb17d142-a949-4302-9f5c-5e62f51cb568">
        <source>validateColumnLabels() :Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2009	cnwer1	Initial creation

*/

vars
	gridColumn				: CMUI_GridColumn;
	allLabels 				: StringArray;
	sopGridColumn			: SOP_GridColumn;

begin
	
	//validate the id 40ft and id 20ft are unique
	
	create allLabels transient;
	foreach gridColumn in self.allGridColumns do
		sopGridColumn:=gridColumn.SOP_GridColumn;
		if not allLabels.includes( gridColumn.label) then
			allLabels.add(gridColumn.label);
		else
			//raise exception
			//app.raiseCMException(LabelsMustBeUnique,null, null);
			return false;
		endif;
		if sopGridColumn.label40ftold &lt;&gt; null then
			if not allLabels.includes( sopGridColumn.label40ftold) then
				allLabels.add(sopGridColumn.label40ftold);
			else
				//raise exception
				//app.raiseCMException(LabelsMustBeUnique,null, null);
				return false;
			endif;
		endif;
	endforeach;
	
	return true;
epilog
	delete allLabels;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
