    <JadeMethod name="displayDocketLocations" id="3b4fd99a-b506-4e41-95bf-680f9b61c3a5">
        <updating/>
        <source>displayDocketLocations(_bolIn : CM_BOLIn input) updating;
// ---------------------------------------------------------------------------
// Created:     30 September 2002 by cnwth2
//
// Purpose:     Displays a list of the location(s) of the trackedItems for the entered docket.
//				Using the CMIF_DocketLocationHelper class
// ----------   ----------  --------------------------------------------------
vars
	locHelper		: CMIF_DocketLocationHelper;
	ti				: CM_TrackedItem;
	idx				: Integer;
	timeStamp		: TimeStamp;
	bolTerminal		: CM_BOLTerminal;
	tmpLoc			: CM_LocationsController;

begin

	self.allDocketLocationHelpers.purge();

	self.tblSelectData.rows := self.tblSelectData.fixedRows;
	self.txtDetails.text := null;	
	if _bolIn = null then
		return;
	endif;
	
	bolTerminal := _bolIn.getBOLTerminal(self.myTerminal, false);
	if bolTerminal = null then
		return;
	endif;
	
	if (not bolTerminal.allTrackedItems.isEmpty) then
		foreach ti in bolTerminal.allTrackedItems do
			tmpLoc := ti.getPrimaryLocation(REAL_MODE);
			if tmpLoc = null then
				continue;
			endif;
			locHelper := self.allDocketLocationHelpers[tmpLoc];
			if locHelper &lt;&gt; null then
				locHelper.addTI(ti);
			else
				create locHelper transient;
				locHelper.addTI(ti);
				locHelper.myBOL := _bolIn;
				locHelper.myLocationsController := tmpLoc;
				self.allDocketLocationHelpers.add(locHelper);
			endif;
		endforeach;
		
		foreach locHelper in self.allDocketLocationHelpers do
			idx := tblSelectData.addItem(locHelper.myLocationsController.getID &amp; Tab &amp;
								locHelper.allTIs.size.String);
			tblSelectData.accessRow(idx).itemObject := locHelper;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_bolIn" type="CM_BOLIn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displaySOHLocations" id="4451502b-c749-434c-a534-f6d7f6302832">
        <updating/>
        <source>displaySOHLocations(_location : CM_LocationsController input) updating;
// ---------------------------------------------------------------------------
// Created:     27 September 2002 by cnwth2
//
// Purpose:		Displays SOHLocations for the selected LocationsController, 
//				and its TI summary in the txtDetail     
//
// ----------   ----------  --------------------------------------------------
vars
	lc			: CM_LocationsController;
	sohLocDict	: CM_SOHLocationsByProduct;
	sohLoc		: CM_SOHLocation;
	pro			: CM_Product;
	idx			: Integer;

begin
	
	self.tblSelectData.rows := self.tblSelectData.fixedRows;
	lc := self.cmbLocation.listObject.CM_LocationsController;
	
	if lc = null then
		return;
	endif;
	
	foreach sohLoc in lc.allProductLocations do
		if sohLoc.allTrackedItems.isEmpty then
			continue;
		endif;
		
		pro := sohLoc.myProduct;
		if pro = null then
			continue;
		endif;
		
		idx := self.tblSelectData.addItem(sohLoc.allTrackedItems.size.String &amp; Tab &amp;
											pro.myCargoType.description &amp; Tab &amp;
											pro.code &amp; Tab &amp;
											pro.description);									
		self.tblSelectData.accessRow(idx).itemObject := sohLoc;
	endforeach;

end;</source>
        <Parameter name="_location" type="CM_LocationsController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displaySelectedData" id="f2e594a3-6c76-42cb-b7ec-492e0effb812">
        <updating/>
        <source>displaySelectedData() updating;
// ---------------------------------------------------------------------------
// Created:     30 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	locHelper			: CMIF_DocketLocationHelper;
	sohLocation				: CM_SOHLocation;
	details				: String;
	pro					: CM_Product;
	ti					: CM_TrackedItem;
	
begin
	if self.selection = DOCKET then
		locHelper := self.tblSelectData.accessRow(self.tblSelectData.row).itemObject.CMIF_DocketLocationHelper;
		if locHelper = null then
			return;
		endif;
		self.myDocketLocationHelper := locHelper;
		foreach ti in locHelper.allTIs do
			pro := ti.myProduct;
			if pro &lt;&gt; null then
				details := details &amp; 'Item ID: ' &amp; ti.id &amp; Tab &amp; 'Product: ' &amp; pro.code &amp; CrLf;
			else
				details := details &amp; 'Item ID: ' &amp; ti.id &amp; CrLf;
			endif;
			
		endforeach;
	elseif self.selection = LOCATION then
		sohLocation	:= self.tblSelectData.accessRow(self.tblSelectData.row).itemObject.CM_SOHLocation;
		if sohLocation = null then
			return;
		endif;
		self.mySOHLocation := sohLocation;
		self.allTrackedItems.clear;
		self.mySOHLocation.allTrackedItems.copy(self.allTrackedItems);
		pro := sohLocation.myProduct;
		
		if pro &lt;&gt; null then
			details := 'Number Of Items: ' &amp; sohLocation.allTrackedItems.size.String &amp; CrLf &amp;
					app.getErrorString(Cargo_subtype_code) &amp; ': ' &amp; pro.code &amp; CrLf &amp;
					app.getErrorString(Cargo_subtype_description) &amp; ': ' &amp; pro.description;
		else
			details := 'Number Of Items: ' &amp; sohLocation.allTrackedItems.size.String;
			
		endif;
	endif;
	self.txtDetails.text := details;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySingleItem" id="123f5357-3065-47ea-aa35-c6884543fa3a">
        <updating/>
        <source>displaySingleItem() updating;
// ---------------------------------------------------------------------------
// Created:     27 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars


	itemId 		: String;
	ti			: CM_TrackedItem;
	display		: String;
	row			: Integer;
	location	: CM_LocationsController;
	op			: CM_Operator;
	opTerm		: CM_OperatorTerminal;
	cargoType	: CM_CargoType;
	proStr,
	proTypeStr	: String;
begin

	// Turn off split container.
	splitContainer.setLeftToRightRatioAndResize(1);
	self.txtDetails.text := null;
	op := cmbOperator.listObject.CM_Operator;
	if op = null then // PAR 16293
		return;
	endif;
	
	cargoType := cmbCargoType.listObject.CM_CargoType;
	opTerm := op.allOperatorTerminals[self.myTerminal];
	
	if op = null or
	   opTerm = null or
	   cargoType = null then
		return;
	endif;
	
	itemId := cmbTI.text;
	ti := opTerm.allOnsiteTIsByCargoTypeId[cargoType.id, itemId];
	
	if ti = null then
		return;
	endif;
	self.myTrackedItem := ti;
	location := ti.getPrimaryLocation(REAL_MODE);
	if location &lt;&gt; null then
		display := display &amp; app.getString(Location) &amp; Tab &amp; Tab &amp;  '(' &amp; location.getID &amp; ')' &amp; CrLf;
	endif;
	if ti.myProduct &lt;&gt; null then
		proStr := ti.myProduct.code;
		proTypeStr := ti.myProduct.myCargoType.description;
	else
		proStr :=  app.getErrorString(Cargo_subtype_not_found);
		proTypeStr := '';	
	endif;
	display := display &amp; app.getErrorString(CargoType) &amp; Tab &amp; proTypeStr &amp; CrLf;
	display := display &amp; app.getErrorString(Product) &amp; Tab &amp; proStr &amp; CrLf;
	display := display &amp; app.getString(Quantity) &amp; Tab &amp; ti.quantity.String &amp; CrLf;
	//display := display &amp; 'Weight' &amp; Tab &amp; ti.weight.asStringWeightJMT();									//-cnwml2 MSL CCMS 1017
	display := display &amp; app.getString(CM_Total_Weight) &amp; Tab &amp; ti.totalWeight.asStringWeightJMT();			//+cnwml2 MSL CCMS 1017
	
	txtDetails.text := display;
	self.myTrackedItem := ti;
	self.tblSelectData.tabStop := false;
	return;

	// Try again.
	if itemId &lt;&gt; self.prevSearch then
		self.tblSelection.goToRowByName(ETRow_Id);
		self.tblSelection.setFocus;
	self.prevSearch := itemId;
		app.raiseCMException1(LogNotFound, itemId, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOperatorClick" id="e8176338-981a-4e28-ac56-d7ccc9de7e66">
        <updating/>
        <source>doOperatorClick() updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	app.setMyCurrentOperator(self.cmbOperator.listObject.CM_Operator);
	if self.optSingleItem.value then
		self.populateTIsByCargoType();
	elseif self.optDocket.value then
		self.populateDocketsByOperator();
	endif;
	
	self.zStartSearch();
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doOptDocketClick" id="f96a8bef-4d3a-4aae-af6d-503590ed577f">
        <updating/>
        <source>doOptDocketClick() updating;
// ---------------------------------------------------------------------------
// Created:     27 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.allTrackedItems.clear();
	self.selection := DOCKET;
	self.tblSelection.visible := true;
	self.tblSelectData.visible := true;
	self.txtDetails.visible := true;
	self.txtDetails.text := null;
	self.tblSelection.showHideRowsByViewName("DocketView", CM_EntryTable.ShowHideRows, false); 
	self.tblSelection.optimiseHeadingColumn();
	self.tblSelection.adjustHeight(1000);
	self.setDistances();
	self.resize();
	self.zClearSelectionDataTable();
	self.tblSelection.goToRowByName(ETRow_MyOperator);
	self.tblSelection.setFocus;
	
	splitContainer.setLeftToRightRatioAndResize(50);
	self.tblSelectData.rows := 1;
	self.tblSelectData.fixedRows := 1;
	self.tblSelectData.accessRow(1).backColor := self.colorHeadingColumn;
	self.tblSelectData.columns := 3;
	self.tblSelectData.setColumnHeadingsFromDef(ETDef_DocketLocationData, false);
	self.populateDocketsByOperator();
	self.zStartSearch();
end;</source>
    </JadeMethod>
