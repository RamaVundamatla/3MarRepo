    <JadeMethod name="create" id="7bd8fc5c-1c14-4503-9651-2aa4ceb25095">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

