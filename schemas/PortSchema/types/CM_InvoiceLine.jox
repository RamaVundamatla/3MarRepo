        <source>getTaxGLCodes(_taxGLCodes : StringArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export
20-04-2023 	navtnr20 Task 57620: EUP - Invoice Line Type / Services Configuration Updated Requirements
*/

vars
	charge : CM_Charge;
	taxStr : String;
begin
	_taxGLCodes.clear();
	foreach charge in self.charges do
		// ### TFS 55744 06DEC2022 NAVAB1
		taxStr:= charge.getTaxGLCode();
		if taxStr &lt;&gt; null then //	navtnr20 20-04-2023 TFS 57620
			if _taxGLCodes.cnFind(taxStr) = 0 then	//navtnr20 20-04-2023 TFS 57620
				_taxGLCodes.add(taxStr);
			endif;
		endif;
		// ### TFS 55744 06DEC2022 NAVAB1 _taxGLCodes.add(charge.getTaxGLCode());
	endforeach;
epilog

end;</source>
        <Parameter name="_taxGLCodes" type="StringArray" usage="io"/>
    </JadeMethod>
