    <JadeMethod name="setForDelete" id="d138707a-40c5-4989-beae-8c3ed401b97e">
        <updating/>
        <source>setForDelete(_reason: String) updating;
vars
	swept:Boolean;
begin
	inheritMethod(_reason);
	if self.myTrackedItem.cargoType = TI_CargoType_Container then
		self.myTrackedItem.setSweptDetails(swept); //set the container dirty
	endif;
end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="4e9e86b4-907c-48cb-95f7-e201b2d82401">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars
	isSwept: Boolean;
begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	

	isSwept := true;
	self.myTrackedItem.setSweptDetails(isSwept);
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
