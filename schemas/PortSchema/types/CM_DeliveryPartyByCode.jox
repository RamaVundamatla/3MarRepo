<CollClass name="CM_DeliveryPartyByCode" id="2c1353e3-a300-4fb2-a0d6-cb033add2161">
    <loadFactor>66</loadFactor>
    <memberType name="CM_DeliveryParty"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="contacts"/>
    <MemberKey>
        <property name="CM_DeliveryParty::code"/>
    </MemberKey>
    <JadeMethod name="getDeliveryPartyByName" id="dbf9ffae-b771-4aec-ad6d-44eef0dcf684">
        <source>getDeliveryPartyByName(_deliveryPartyName : String) : CM_DeliveryParty;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2022	navpw1	Initial creation TFS: 53953

*/

vars
	deliveryParty : CM_DeliveryParty;
	
begin
	foreach deliveryParty in self do
		if deliveryParty.name &lt;&gt; _deliveryPartyName then
			continue;
		endif;
		
		return deliveryParty;
		
	endforeach;
	
	return null;

end;</source>
        <Parameter name="_deliveryPartyName" type="String"/>
        <ReturnType type="CM_DeliveryParty"/>
    </JadeMethod>
</CollClass>
