    <JadeMethod name="setIconPositions" id="50ea1e44-1681-4767-a50c-1b7800eba025">
        <updating/>
        <source>setIconPositions(_x1,_y1,_x2,_y2: Real) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	ColWidth		: Integer = 24;

vars
	yOffset,
	theX, theY,theCharacterWidth,theWidth, startX		: Integer; 
	tmpY,
	tmpScaleFactor,theFontSize: Real;
begin
	self.attrMaxNum := 3;
	
	tmpScaleFactor := self.scaleFactor;
	theCharacterWidth := (18 * tmpScaleFactor).Integer;

	if tmpScaleFactor = ScaleFactor_1 then
		yOffset := 0;
	elseif tmpScaleFactor = ScaleFactor_1_5 then
		yOffset := -0;
	elseif tmpScaleFactor = ScaleFactor_2 then
		yOffset := 0;
	elseif tmpScaleFactor = ScaleFactor_3 then
		yOffset := 6;
	elseif tmpScaleFactor = ScaleFactor_4 then
		yOffset := 8;
	endif;
	tmpY :=(_y1 - self.y1) + yOffset;
	startX := _x1.Integer;
	self.attrX1 := startX;
	self.attrY1 := tmpY;
	self.attrX2 := startX + theCharacterWidth;
	self.attrY2 := tmpY;
	self.attrX3 := startX + (theCharacterWidth * 2);
	self.attrY3 := tmpY;
	self.attrX4 := startX + (theCharacterWidth * 3);
	self.attrY4 := tmpY;
	self.attrX5 := startX + (theCharacterWidth * 4);
	self.attrY5 := tmpY;

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setTmpPointArray" id="e7de9e27-617c-4a0b-a230-7769efca30be">
        <source>setTmpPointArray();
// ---------------------------------------------------------------------------
// Created:		30 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpPoint : Point;
begin
		self.tmpPointArray.clear;
		tmpPoint.set(self.x1.Integer,self.y1.Integer);
		self.tmpPointArray.add(tmpPoint);
		tmpPoint.set(self.x2.Integer,self.y1.Integer);
		self.tmpPointArray.add(tmpPoint);
		tmpPoint.set(self.x2.Integer,self.y2.Integer);
		self.tmpPointArray.add(tmpPoint);
		tmpPoint.set(self.x1.Integer,self.y2.Integer);
		self.tmpPointArray.add(tmpPoint);
		tmpPoint.set(self.x1.Integer,self.y1.Integer);
		self.tmpPointArray.add(tmpPoint);

end;</source>
    </JadeMethod>
