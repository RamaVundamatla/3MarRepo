    <JadeMethod name="importBlockStack" id="4f336489-b8ec-450b-8ef3-b5f2701e9a13">
        <source>importBlockStack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation

*/

vars
    agent: CM_DataImportAgent;
    exportClass: CM_ExportImportClass;
    resultJson: String;
	isFound : Boolean;
	dataEntity : String;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("NAVIV1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals['DAVE']);
   
   dataEntity := "Block Stack Definition";
   
	foreach exportClass in app.myRoot.allExportImportClasses do
		if exportClass.displayName = dataEntity then
			isFound := true;
			break;
		endif;
	endforeach;
   
    
    if isFound = false or exportClass = null then
        return;
    endif;
    
    create agent transient;
    agent.setExportImportClass(exportClass);
	
    // Import from file
	agent.importFromXml("c:\users\naviv1\BSTest.xml");
    
    write resultJson;
epilog
    delete agent;
end;</source>
    </JadeMethod>
