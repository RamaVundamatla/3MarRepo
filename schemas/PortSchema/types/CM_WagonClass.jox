    <JadeMethod name="maxCargoHeight" id="0acbddc9-b5dc-4d21-8182-5fa2ccb3e003">
        <methodInvocation>mapping</methodInvocation>
        <source>maxCargoHeight(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	well : CM_WagonWellDefinition;
	wellsMaxCargoHeight : Decimal [16,4];
	realWagonClass : CM_WagonClass;

begin

	if self.isWellcar then
		if not set then
			if self.isTransient then
				realWagonClass := self.pxyGetRealObject;
			else
				realWagonClass := self;
			endif;
			if realWagonClass &lt;&gt; null then
				foreach well in realWagonClass.allWagonWellDefArray do
					if ( well.deckHeight + well.maxCargoHeight ) &gt; wellsMaxCargoHeight then
						wellsMaxCargoHeight := well.deckHeight + well.maxCargoHeight;
					endif;
				endforeach;
			endif;
			_value := wellsMaxCargoHeight;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="maxLoadWeight" id="26ddd895-6f8f-477d-b6e6-1aab98e94de8">
        <methodInvocation>mapping</methodInvocation>
        <source>maxLoadWeight(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	well : CM_WagonWellDefinition;
	loadWeight : Decimal [16,4];
	realWagonClass : CM_WagonClass;

begin

	if self.isWellcar then
		if not set then
			if self.isTransient then
				realWagonClass := self.pxyGetRealObject;
			else
				realWagonClass := self;
			endif;
			if realWagonClass &lt;&gt; null then
				foreach well in realWagonClass.allWagonWellDefArray do
					loadWeight := loadWeight + well.maxLoadWeight;
				endforeach;
			endif;
			_value := loadWeight;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="overallLength" id="84f69c09-fd80-4743-9be6-a1a13e8740b5">
        <methodInvocation>mapping</methodInvocation>
        <source>overallLength(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 December 2014	cnwndl1	Initial creation

*/

vars

	length : Decimal [16,4];
	well : CM_WagonWellDefinition;

begin

	if self.isWellcar and not set then
		foreach well in self.allWagonWellDefArray do
			length := length + well.overallLength;
		endforeach;
		_value := length;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1f39fb73-5dab-42fa-ad32-43feb5608aea">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpWagonClass : CM_WagonClass;
	completedOK		: Boolean;
begin
	tmpWagonClass := inheritMethod();
	
	self.allConsigneeCodesRestricted.copy(tmpWagonClass.allConsigneeCodesRestricted);
	
	self.allSelectedSealTypes.copy( tmpWagonClass.allSelectedSealTypes );	//10 Mar 2015	NDL	Par 35828
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpWagonClass;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpWagonClass;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="02ad92dc-d099-40bd-885a-cc234a5eca9c">
        <updating/>
        <source>setForCreate(pProxyWagonClass:CM_WagonClass) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	setForUpdate(pProxyWagonClass);
	
	// PAR 18015
	if self.maxNumInStack = 0 then
		self.maxNumInStack := 1;
	endif;
	self.myRoot := app.myRoot;
	
 // ### TFS 52914 04MAR2022 NAVAB1	if app.myPassport.isOpsViewEnabled(null) then // ### TFS 51855 10JAN2022 NAVAB1
 // ### TFS 52914 04MAR2022 NAVAB1		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_WAGONCLASS, self); // ### TFS 51855 10JAN2022 NAVAB1
 // ### TFS 52914 04MAR2022 NAVAB1	endif;

end;</source>
        <Parameter name="pProxyWagonClass" type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="df9bc92b-8536-4973-bd27-0df0bd06f05e">
        <updating/>
        <source>setForUpdate(pProxyWagonClass:CM_WagonClass) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	13/09/2001	dwq		Added locationIds to the update
// ---------------------------------------------------------------------------
vars
	unitsToAdd : Integer; // cnwrd1 4.11.08 par #18412
	rule : CM_WagonPositionalRule;
	pxyRule : CM_WagonPositionalRule;
	
	wagonWellDef : CM_WagonWellDefinition;
	wellId : String;
	index : Integer;
	locIndex : Integer;
	localArray : CM_WagonWellDefArray;


	isUpdate : Boolean;
begin
	isUpdate := pProxyWagonClass.pxyGetRealObject() &lt;&gt; null; // ### TFS 51855 06JAN2022 NAVAB1


	self.code	:= pProxyWagonClass.code[ 1 : self.Max_WagonClass_Size ].toUpper.trimBlanks;
	self.maxLoadWeight := pProxyWagonClass.maxLoadWeight;
	self.tareWeight := pProxyWagonClass.tareWeight;
	self.myCarrier := pProxyWagonClass.myCarrier;
	self.isNotAvailableForEntry := pProxyWagonClass.isNotAvailableForEntry;
	
	//18 Mar 2013	NDL	Par 31278	
	self.wagonType := pProxyWagonClass.wagonType;
	
	self.locationIds.clear;
	
	self.tierIds.clear();
	if not pProxyWagonClass.tierIds.isEmpty then
		 pProxyWagonClass.tierIds.copy( self.tierIds );
	endif;
	
	//18 Mar 2013	NDL	Par 31278
	if self.isBoxcar then
		self.internalHeight := pProxyWagonClass.internalHeight;	
		self.internalLength := pProxyWagonClass.internalLength;	
		self.internalWidth := pProxyWagonClass.internalWidth;
		self.overallHeight := pProxyWagonClass.overallHeight;	
		self.overallLength := pProxyWagonClass.overallLength;	
		self.overallWidth := pProxyWagonClass.overallWidth;
		self.acceptsGenerator := false;
		self.doorsAccessible := false;
		self.maxNumInStack := 1;
		self.deckHeight := 0;
		self.maxCargoHeight := 0;
		
		self.lenInUnits := 1;
		self.locationIds.add( "1" );
		self.numOfTwenty := pProxyWagonClass.numOfTwenty; // TFS 49523
			
	elseif self.isFlatcar then
		//Flatcars do not have internal dimensions.
		self.internalHeight := 0;	
		self.internalLength := 0;	
		self.internalWidth := 0;
		self.overallHeight := 0;	
		self.overallLength := 0;	
		self.overallWidth := 0;
		self.acceptsGenerator := pProxyWagonClass.acceptsGenerator;
		self.doorsAccessible := pProxyWagonClass.doorsAccessible;
		self.maxNumInStack := pProxyWagonClass.maxNumInStack;
		self.deckHeight := pProxyWagonClass.deckHeight;
		self.maxCargoHeight := pProxyWagonClass.maxCargoHeight;
		
		
		// cnwrd1 4.11.08 par #18412
		if self.lenInUnits &lt; pProxyWagonClass.lenInUnits then
			unitsToAdd := pProxyWagonClass.lenInUnits - self.lenInUnits ;
		endif;
		
		self.lenInUnits := pProxyWagonClass.lenInUnits;
		if pProxyWagonClass.locationIds &lt;&gt; null then
			pProxyWagonClass.locationIds.copy(self.locationIds);
		endif;
	
	elseif self.isWellcar then
		//09 Dec 2014	NDL	Par 35346
	
		self.internalHeight := 0;	
		self.internalLength := 0;	
		self.internalWidth := 0;
		self.overallHeight := 0;	
		self.overallLength := 0;	
		self.overallWidth := 0;
		self.acceptsGenerator := false;
		self.doorsAccessible := false;
		self.maxNumInStack := pProxyWagonClass.maxNumInStack;
		self.deckHeight := 0;
		self.maxCargoHeight := 0;
		self.lenInUnits := 0;
		
		if pProxyWagonClass.locationIds &lt;&gt; null then
			pProxyWagonClass.locationIds.copy(self.locationIds);
		endif;
		
		foreach index in 1 to self.allWagonWellDefArray.size reversed do
			wagonWellDef := self.allWagonWellDefArray[index];
			if not self.locationIds.includes( wagonWellDef.wellId ) then
				delete wagonWellDef;
			endif;
		endforeach;
		
		create localArray transient;
		foreach wellId in self.locationIds do
			index := self.allWagonWellDefArray.getWagonWellDefIndex( wellId );
			if index &lt; 1 then
				create wagonWellDef;
				wagonWellDef.setDefaultValueOnCreate( self, wellId );
				index := self.allWagonWellDefArray.getWagonWellDefIndex( wellId );
			else
				wagonWellDef := self.allWagonWellDefArray[index];
			endif;
			localArray.add( wagonWellDef );
		endforeach;
		
		//reset the order in case its changed
		foreach wagonWellDef in localArray do
			wagonWellDef.setMyWagonClass( null );
		endforeach;
		foreach wagonWellDef in localArray do
			wagonWellDef.setMyWagonClass( self );
		endforeach;
	
	elseif self.isSkeletonCar then		// TFS 2533
		self.internalHeight := 0;	
		self.internalLength := 0;	
		self.internalWidth := 0;
		self.overallHeight := 0;	
		self.overallLength := pProxyWagonClass.overallLength;	
		self.overallWidth := pProxyWagonClass.overallWidth;
		self.acceptsGenerator := false;
		self.doorsAccessible := false;
		self.maxNumInStack := 1;
		self.deckHeight := pProxyWagonClass.deckHeight;
		self.maxCargoHeight := pProxyWagonClass.maxCargoHeight;
		
		self.lenInUnits := 1;
		self.locationIds.add("1");

	endif;
	
	
	self.allConsigneeCodesRestricted.purge;
	pProxyWagonClass.allConsigneeCodesRestricted.copy(self.allConsigneeCodesRestricted);
	
	// cnwrd1 4.11.08 par #18412
	if unitsToAdd &gt; 0 then
		self.updatePersistentWagonLocCont( self.lenInUnits );
	endif;
	
	if self.isFlatcar then
	
		//06 Apr 2010	NDl	Par 22342
		foreach rule in self.allWagonPositionalRules do	// clear any existing rules
			delete rule;
		endforeach;
		foreach pxyRule in pProxyWagonClass.allWagonPositionalRules do	// add the new ones.
			app.myUtilityCA.utlCreateWagonPositionalRule(pxyRule, rule, app.myPassport);
		endforeach;
	
	endif;
	
	if self.tierIds.isEmpty and self.maxNumInStack &gt; 0 then
		foreach index in 1 to self.maxNumInStack do
			self.tierIds.add( index.String );
		endforeach;
	endif;
	
	//10 Mar 2015	NDL	Par 35828
	self.allSelectedSealTypes.clear();
	if pProxyWagonClass.allSelectedSealTypes &lt;&gt; null and not pProxyWagonClass.allSelectedSealTypes.isEmpty then
		pProxyWagonClass.allSelectedSealTypes.copy( self.allSelectedSealTypes );
	endif;

	
 // ### TFS 52914 04MAR2022 NAVAB1	if isUpdate
 // ### TFS 52914 04MAR2022 NAVAB1	and app.myPassport.isOpsViewEnabled(null) then // ### TFS 51855 10JAN2022 NAVAB1
 // ### TFS 52914 04MAR2022 NAVAB1		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_WAGONCLASS, self); // ### TFS 51855 10JAN2022 NAVAB1
 // ### TFS 52914 04MAR2022 NAVAB1	endif;
	
epilog

	delete localArray;
	
end;</source>
        <Parameter name="pProxyWagonClass" type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="cc21cc3b-a9f5-40bc-97d4-fc9224834f8a">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e30d1449-da46-4b97-96c2-2cc6176048f2">
        <updating/>
        <source>setProxy(	pCode : String;
			pAcceptsGenerator : Boolean; 
			pDoorsAccessible : Boolean; 
			_isNotAvailableForEntry	: Boolean; 
			//pMaxLoadWeight : Integer;							// PAR #311335
			pMaxLoadWeight : Decimal;							// PAR #311335
			pMaxNumInStack : Integer;
			pLenInUnits : Integer;
			pLocationIds : StringArray;
			pConsigneeRestrictions	: CM_ConsignCodeArray;
			pDeckHeight : Decimal;
			pMaxCargoHeight : Decimal;
			pTareWeight : Decimal;
			pMyCarrier : CM_Carrier;
			pInternalHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
			pInternalLength : Decimal;	//18 Mar 2013	NDL	Par 31278
			pInternalWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
			pOverallHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
			pOverallLength : Decimal;	//18 Mar 2013	NDL	Par 31278
			pOverallWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
			pWagonType : Integer;	//18 Mar 2013	NDL	Par 31278
			pTierIds : StringArray;	//Par 35346 / CCMS 1408
			pSealTypes : CM_SealTypeDict;	//10 Mar 2015	NDL	Par 35828
			pWagonGraphic : Integer // TFS 49523
			) updating;
//
// Changed On	By	 			Reason
// ----------	--------		-------------------------------------------------------------
// 11/03/2013	cnwdap1			PAR #31155 CCMS SFW 1321 Imperial Measurements - changed max weight parameter from integer to decimal
vars
	numUnits:Integer;
	index : Integer;
begin
	self.raiseExceptionIfNotTransient(method);

	self.code	:= pCode[ 1 : self.Max_WagonClass_Size ].toUpper.trimBlanks;
	
	self.acceptsGenerator := pAcceptsGenerator;
	self.allConsigneeCodesRestricted.purge;
	pConsigneeRestrictions.copy(self.allConsigneeCodesRestricted);

	self.doorsAccessible := pDoorsAccessible;
	self.locationIds.clear;
	if(pLocationIds &lt;&gt; null) then
		pLocationIds.copy(self.locationIds);
	endif;
	self.maxLoadWeight := pMaxLoadWeight;
	self.maxNumInStack := pMaxNumInStack;
	self.lenInUnits := pLenInUnits;
	
	//08 Jul 2009	NDL	CCMS 1067
	self.deckHeight := pDeckHeight;
	self.maxCargoHeight := pMaxCargoHeight;
	self.tareWeight := pTareWeight;
	self.myCarrier := pMyCarrier;
	
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	
	//18 Mar 2013	NDL	Par 31278
	self.internalHeight := pInternalHeight;	
	self.internalLength := pInternalLength;	
	self.internalWidth := pInternalWidth;	
	self.overallHeight := pOverallHeight;	
	self.overallLength := pOverallLength;	
	self.overallWidth := pOverallWidth;	
	self.wagonType := pWagonType;
	self.numOfTwenty := pWagonGraphic; // TFS 49523
	self.tierIds.clear;
	if(pTierIds &lt;&gt; null) then
		pTierIds.copy(self.tierIds);
	endif;
	
	if self.tierIds.isEmpty and self.maxNumInStack &gt; 0 then
		foreach index in 1 to self.maxNumInStack do
			self.tierIds.add( index.String );
		endforeach;
	endif;
	
	//10 Mar 2015	NDL	Par 35828
	self.allSelectedSealTypes.clear();
	if pSealTypes &lt;&gt; null and not pSealTypes.isEmpty then
		pSealTypes.copy( self.allSelectedSealTypes );
	endif;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pAcceptsGenerator" type="Boolean"/>
        <Parameter name="pDoorsAccessible" type="Boolean"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="pMaxLoadWeight" type="Decimal"/>
        <Parameter name="pMaxNumInStack" type="Integer"/>
        <Parameter name="pLenInUnits" type="Integer"/>
        <Parameter name="pLocationIds" type="StringArray"/>
        <Parameter name="pConsigneeRestrictions" type="CM_ConsignCodeArray"/>
        <Parameter name="pDeckHeight" type="Decimal"/>
        <Parameter name="pMaxCargoHeight" type="Decimal"/>
        <Parameter name="pTareWeight" type="Decimal"/>
        <Parameter name="pMyCarrier" type="CM_Carrier"/>
        <Parameter name="pInternalHeight" type="Decimal"/>
        <Parameter name="pInternalLength" type="Decimal"/>
        <Parameter name="pInternalWidth" type="Decimal"/>
        <Parameter name="pOverallHeight" type="Decimal"/>
        <Parameter name="pOverallLength" type="Decimal"/>
        <Parameter name="pOverallWidth" type="Decimal"/>
        <Parameter name="pWagonType" type="Integer"/>
        <Parameter name="pTierIds" type="StringArray"/>
        <Parameter name="pSealTypes" type="CM_SealTypeDict"/>
        <Parameter name="pWagonGraphic" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tareWeight" id="14b82680-9e6f-422a-8b16-ecd30024a333">
        <methodInvocation>mapping</methodInvocation>
        <source>tareWeight(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	well : CM_WagonWellDefinition;
	wellsTareWeight : Decimal [16,4];
	realWagonClass : CM_WagonClass;

begin

	if self.isWellcar then
		if not set then
			if self.isTransient then
				realWagonClass := self.pxyGetRealObject;
			else
				realWagonClass := self;
			endif;
		
			if realWagonClass &lt;&gt; null then
				foreach well in realWagonClass.allWagonWellDefArray do
					wellsTareWeight := wellsTareWeight + well.tareWeight;
				endforeach;
			endif;
			_value := wellsTareWeight;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="twistLocksRequired" id="ce43ffcd-7149-4899-b081-f0acc16c5071">
        <source>twistLocksRequired() : Boolean;
/*
Purpose: OpsView			

Date		Who		Reason
13 December 2021	navab1	TFS 51855
*/

vars

begin
	if self.isFlatcar then
		return true;
	elseif self.isWellcar then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updatePersistentWagonLocCont" id="48b568b4-33ef-48ac-b0f7-a4d041f08042">
        <source>updatePersistentWagonLocCont( _newLocCount : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2008	cnwrd1	Initial creation
// cnwrd1 4.11.08 par #18412
*/

vars
	wIter : Iterator;
	theWagon : CM_Wagon;
	previousController,
	wagonController 	: CM_WagonController;
	loc, startPos : Integer;
begin

// to update all the persistent existing wagons of this class.

wIter := self.allWagons.createIterator;

	while wIter.next(theWagon) do
			
//	if theWagon.allLocationsControllers.size &lt; _newLocCount then
	if theWagon.allLocationsControllersArray.size &lt; _newLocCount then	//04 Dec 2014	NDL	Par 35345
	
		//need to add some
		//previousController := theWagon.allLocationsControllers.last;
		//startPos := theWagon.allLocationsControllers.size + 1;
		previousController := theWagon.allLocationsControllersArray.last;	//04 Dec 2014	NDL	Par 35345
		startPos := theWagon.allLocationsControllersArray.size + 1;	//04 Dec 2014	NDL	Par 35345
		foreach loc in startPos to _newLocCount do
			create wagonController as theWagon.getLocationContClassToCreate persistent;
			wagonController.setForCreate(theWagon.id &amp; theWagon.myWagonClass.locationIds[loc].trimBlanks,
										 true, theWagon, previousController);
			previousController := wagonController;	
		endforeach;
	
	endif;
			
	endwhile;
epilog

	delete wIter;

end;</source>
        <Parameter name="_newLocCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6fd141f6-5885-4a0f-9bd4-1d8654631be2">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allWagonClasses[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="6f8308e0-0603-46b8-adff-8b9ec02f87d9">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/04/2009	cnwrl1		PAR 19374 - Allow Wagon Class to be deleted.
// ---------------------------------------------------------------------------

vars
//	cm_Terminal		: CM_Terminal;
//	tempStr			: String;
//	iter1			: Iterator;
	whereUsed : String;
	
begin
	
	// cannot delete the wagon class if there are still wagons attached.
	if not self.allWagons.isEmpty then
		app.raiseCMException2( ObjectStillHasEntries, self.code, app.getErrorString(Wagon), null, null );
	endif;
	
	// need to check that this wagon class is NOT the default for any terminal.
/*	iter1	:= app.myRoot.allTerminals.createIterator;
	while iter1.next( cm_Terminal ) do : cond_loop
		tempStr	:= cm_Terminal.getConfig( DefWagonClass ).String;
		if tempStr = self.code then
			app.raiseCMException3(	ERR_USED_IN_CONFIG,
									app.getErrorString(Wagon_class),
									self.code,
									app.getErrorString(Terminal) &amp; " " &amp; cm_Terminal.code,
									null,
									null );
		endif;
	endwhile cond_loop;*/
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
epilog
//	delete iter1;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a1f5195f-e3dc-4e3a-90fc-e01294aa7dca">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	whereUsed : String;

begin

	self.validateMe;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="4c5d6737-0da7-457b-9be0-6cf707214114">
        <source>validateMe() protected;

vars

	lLoc : Integer;
	rule : CM_WagonPositionalRule;
	pos : Integer;
	wellId : String;
	index : Integer;
	teirId : String;
	
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Wagon_class_code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Wagon_class_code), null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.wagonType = 0 then
		app.raiseCMException(Wagon_type_not_selecte, null, null);
		return;
	endif;
	
	if self.isFlatcar then
	//16 Dec 2010	NDL	Par 26340
	
		if self.lenInUnits &lt; 2 or  self.lenInUnits &gt; 20 then
			app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Number_ten_foot_units), app.getErrorString2(Enter_value_between,"2","20"), null, null);
		endif; 
		if self.maxNumInStack &lt; 1 or  self.maxNumInStack &gt; 2 then
			app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Max_Number_in_stack), app.getErrorString2(Enter_value_between,"1","2"), null, null);
		endif;
		
		if self.locationIds.size &lt;&gt; self.lenInUnits then
			app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Location_ids), app.getErrorString(Enter_listof_of_labels), null, null);
			return;
		endif;
	
	endif;


	//PAR17428 conks1 - 01/10/2008 - prevent users from being able to add values that will automatically be invalid when creating
	//a wagon using a wagon class.
	if not self.isWellcar then
		foreach lLoc in 1 to self.lenInUnits do
			if (self.code &amp; self.locationIds[lLoc].trimBlanks).length &gt;= 19 then
				app.raiseCMException2(ERR_INVALID_VALUE, self.code &amp;  self.locationIds[lLoc].trimBlanks,
				app.getErrorString(Total_length_less_than_19), null, null);
				break;
			endif;
		endforeach;
	endif;

	if self.isFlatcar then
		foreach rule in self.allWagonPositionalRules do
			rule.validateForUpdate();
		endforeach;
	endif;
	
	if self.isBoxcar then
		if self.overallHeight &gt; 0 then
			if self.internalHeight &gt; self.overallHeight then
				app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Internal_height), app.getErrorString(Overall_height), null, null);
			endif;
		endif;
		if self.overallLength &gt; 0 then
			if self.internalLength &gt; self.overallLength then
				app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Internal_length), app.getErrorString(Overall_length), null, null);
			endif;
		endif;
		if self.overallWidth &gt; 0 then
			if self.internalWidth &gt; self.overallWidth then
				app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Internal_width), app.getErrorString(Overall_width), null, null);
			endif;
		endif;
		if self.internalHeight &lt;= 0 then
			app.raiseCMException1(Must_greater_than_zero, app.getErrorString(Internal_height), null, null);
		endif;
		if self.internalLength &lt;= 0 then
			app.raiseCMException1(Must_greater_than_zero, app.getErrorString(Internal_length), null, null);
		endif;
		if self.internalWidth &lt;= 0 then
			app.raiseCMException1(Must_greater_than_zero, app.getErrorString(Internal_width), null, null);
		endif;
	endif;
	
	if self.isWellcar then	//Par 35346 / CCMS 1408
		if self.maxNumInStack &lt; 1 or  self.maxNumInStack &gt; 2 then
			app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Max_Number_in_stack), app.getErrorString2(Enter_value_between,"1","2"), null, null);
		endif;
		if self.locationIds.size &lt; 1 or self.locationIds.size &gt; 5 then
			app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Well_ids), app.getErrorString2(Enter_value_between,"1","5"), null, null);
			return;
		endif;
		foreach pos in 1 to self.locationIds.size reversed do
			wellId := self.locationIds[pos];
			if wellId.length &gt; 1 then
				app.raiseCMException1(Well_long_only_charact, wellId, null, null);
				return;
			endif;
			index := self.locationIds.indexOf( wellId );
			if index &lt;&gt; pos then
				app.raiseCMException1(Well_already_used, wellId, null, null);
				return;
			endif;
		endforeach;
		
		if self.maxNumInStack &lt;&gt; self.tierIds.size then
			app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(TierIds), app.getErrorString(Enter_listof_of_labels), null, null);
			return;
		endif;
		
		foreach pos in 1 to self.tierIds.size reversed do
			teirId := self.tierIds[pos];
			if teirId.length &gt; 1 then
				app.raiseCMException1(Tier_long_only_charact, teirId, null, null);
				return;
			endif;
			index := self.tierIds.indexOf( teirId );
			if index &lt;&gt; pos then
				app.raiseCMException1(Well_already_used, teirId, null, null);
				return;
			endif;
		endforeach;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
