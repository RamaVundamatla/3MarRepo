<Class name="CurrencyFormat">
    <JadeMethod name="jssCopyInfo" id="96eac4b4-2225-4d2d-af6d-d31fe73d15ba">
        <updating/>
        <source>jssCopyInfo(pTheCurrencyFormat : CurrencyFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(pTheCurrencyFormat);
	
	self.intlCurrencySymbol			:=	pTheCurrencyFormat.intlCurrencySymbol;
	self.intlDecimalPlaces			:=	pTheCurrencyFormat.intlDecimalPlaces;
	self.negSymbolPrecedesAmount	:=	pTheCurrencyFormat.negSymbolPrecedesAmount;
	self.negSymbolSeparated			:=	pTheCurrencyFormat.negSymbolSeparated;
	self.negativeSignPosition		:=	pTheCurrencyFormat.negativeSignPosition;
	self.posSymbolPrecedesAmount	:=	pTheCurrencyFormat.posSymbolPrecedesAmount;
	self.posSymbolSeparated			:=	pTheCurrencyFormat.posSymbolSeparated;
	self.positiveFormat				:=	pTheCurrencyFormat.positiveFormat;
	self.symbol						:=	pTheCurrencyFormat.symbol;
end;</source>
        <Parameter name="pTheCurrencyFormat" type="CurrencyFormat"/>
    </JadeMethod>
</Class>
