    <JadeMethod name="getMatchingCriteria" id="82f43d8f-f6e2-4395-a0e3-877e7c8c0278">
        <source>getMatchingCriteria(_objSet : ObjectSet io;_yaCriteriaType :Integer) : Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jan 2024 navma1  Bug 61963: FR | 57937 - [TKT: 61898] - Kiosk - US.110 'a' - UNDG Code criteria

*/

vars
	iter 				: Iterator;
	criteria 			: CM_YACriteria;
	root				: CM_Root;
	obj					: Object;	
begin
	if self.myReleaseCriteria = null then
		return null;
	endif;
	
	iter := self.myReleaseCriteria.allCriteria.createIterator;
	
	root := app.myRoot;
	
	while iter.next( criteria ) do
		if criteria.myYACriteriaType = null  then
			continue;
		endif;
		
		if criteria.myYACriteriaType.type =_yaCriteriaType then
			if criteria.myYAData.isKindOf(CM_YADataString) then
				return criteria.myYAData.CM_YADataString.value;
				
			elseif criteria.myYAData.isKindOf(CM_YADataBoolean) then
				return criteria.myYAData.CM_YADataBoolean.value;          // CM_YADataObjects 1 = 'Yes' , 2 ='No'
				
			elseif criteria.myYAData.isKindOf(CM_YADataObjects) then
				foreach obj in criteria.myYAData.CM_YADataObjects.allObjects do
					_objSet.addNoDuplicates(obj,false);
				endforeach;
			endif;
		endif; 
	endwhile;
	
	return null;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_objSet" type="ObjectSet" usage="io"/>
        <Parameter name="_yaCriteriaType" type="Integer"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getMatchingCriteriaObjects" id="4aad69fd-a4e8-418e-b534-84594c462666">
        <source>getMatchingCriteriaObjects(_objSet : ObjectSet io ; _yaCriteriaType :Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023 navma1  ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit
19 Sep 2023	navma1  ChangeRequest 60527: EUP | Mobile DD - [BackEnd] Truck Jobs - Receive Jobs
22 Jan 2024 navma1  Bug 61963: FR | 57937 - [TKT: 61898] - Kiosk - US.110 'a' - UNDG Code criteria
*/

vars
	iter 				: Iterator;
	criteria 			: CM_YACriteria;
	root				: CM_Root;
	obj					: Object;				
begin
	
	
	if self.myReleaseCriteria = null then
		return ;
	endif;
	
	iter := self.myReleaseCriteria.allCriteria.createIterator;
	
	root := app.myRoot;
	
	while iter.next( criteria ) do
		if criteria.myYACriteriaType = null  then
			continue;
		endif;
		
		if criteria.myYACriteriaType.type =_yaCriteriaType then
			if criteria.myYAData.isKindOf(CM_YADataObjects) then
				foreach obj in criteria.myYAData.CM_YADataObjects.allObjects do
					_objSet.addNoDuplicates(obj,false);
				endforeach;
			endif;
		endif; 
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_objSet" type="ObjectSet" usage="io"/>
        <Parameter name="_yaCriteriaType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="f09d6fb0-ae4a-46aa-8aba-bdbb302fbb4c">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/12/2013	cnwdap1		Initial creation PAR #33169
// 27/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
// 20/02/2019 	cnwer1		TFS 41298 
//
vars
	cargoType : CM_CargoType;
	measure	: CM_MeasurementType;
	volume 	: Decimal [22,10];
	value	: String;
	measureProduct : CM_Product;
	measureType : String;
begin
	measureProduct := self.getProductForMeasurementConv();
	measureType:=_measureType;
	if _attrName = ETRow_MyLength then
		if measureProduct &lt;&gt; null then
			measure:= measureProduct.getDefaultMeasurementForType(Type_Length);
			if measure &lt;&gt; null then
				measureType:=measure.shortName;
			endif;
		endif;
		return app.convertMeasurementForDisplay(_measureType, self.lengthSelection)  &amp; Space &amp;  measureType;	
	elseif _attrName = ETRow_MyHeight then
		if measureProduct &lt;&gt; null then
			measure:= measureProduct.getDefaultMeasurementForType(Type_Height);
			if measure &lt;&gt; null then
				measureType:=measure.shortName;
			endif;
		endif;
		return app.convertMeasurementForDisplay(_measureType, self.heightSelection)  &amp; Space &amp;  measureType;	
	elseif _attrName = ETRow_MyWidth then
		if measureProduct &lt;&gt; null then
			measure:= measureProduct.getDefaultMeasurementForType(Type_Width);
			if measure &lt;&gt; null then
				measureType:=measure.shortName;
			endif;
		endif;
		
		return app.convertMeasurementForDisplay(_measureType, self.widthSelection)  &amp; Space &amp;  measureType;	
	//elseif _attrName = ETRow_MyWeight then
	elseif _attrName = ETRow_MyWeight then	//31 May 2016	NDL	TFS 2009
		if measureProduct &lt;&gt; null then
			measure:= measureProduct.getDefaultMeasurementForType(Type_Weight);
			if measure &lt;&gt; null then
				measureType:=measure.shortName;
			endif;
		endif;
		return app.convertMeasurementForDisplay(measureType, self.weightSelection)  &amp; Space &amp;  measureType;	 
	elseif _attrName = ETRow_MyVolume then
		if measureProduct &lt;&gt; null then
			measure:= measureProduct.getDefaultMeasurementForType(Type_Volume);
			if measure &lt;&gt; null then
				measureType:=measure.shortName;
			endif;
		endif;
		return app.convertMeasurementForDisplay(measureType, self.volumeSelection)  &amp; Space &amp;  measureType;
	elseif _attrName = ETRow_MyDensity then		
		if measureProduct &lt;&gt; null then
			measure:= measureProduct.getDefaultMeasurementForType(Type_Density);
			if measure &lt;&gt; null then
				measureType:=measure.shortName;
			endif;
		endif;
		// PAR #33606
		return app.convertMeasurementForDisplay(measureType, self.densitySelection) &amp; Space &amp;  measureType;		// PAR #33606

	endif;
		
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyCargoGroupId" id="62db481d-b422-42e4-b7be-e939ac3ccba6">
        <source>getMyCargoGroupId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2015	cnwndl1	Initial creation	Par 37033
22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group

*/

vars
	cargoGroup : CM_CargoGroup;
	
begin

	cargoGroup := self.myCargoGroup;
	
	if cargoGroup &lt;&gt; null then
		return cargoGroup.id;
	endif;
	
	return self.getMyCargoGroupIdCriteria();
	
epilog

	

end;</source>
