//24 November 2009	cnwml2
/**************************************************************************************
***** Changes
Date				Name		TFS#		Description
=======================================================================================
21/09/2018			jlgka1		40200		Add checking if myTiMaster is not null 
											before returning the value.
***************************************************************************************/

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	else
		if self.myTiMaster &lt;&gt; null then
			_value := self.myTiMaster.CM_TIMasterTILC.onHireDate;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Date" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ca18147e-b800-4846-af88-2113a801ae10">
        <source>pxyCreateUpdateProxy(): SelfType;
/* ---------------------------------------------------------------------------
Created:	28 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
// 20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
//						trying to create the proxy
------------------------------------------------------------------------------*/
vars
	proxyTI		: CM_TILC;
	proxyGenerator : CM_Generator;
	completedOK		: Boolean;
	tilcLC : CM_TILCController;
begin

	proxyTI := inheritMethod();

	//set TILCType 19352
	proxyTI.myTILCType := self.myTILCType;
	
	//15/10/2025	navkc1 JIRA 36057
	if self.myTILCType &lt;&gt; null and self.myTILCType.allowUpdateTotalWeight then
		proxyTI.updateTILCTotalWeightConfig(true);
	endif;
	
	
		//don't need to set allLCs
	if self.myGenerator &lt;&gt; null then
		proxyGenerator := self.myGenerator.pxyCreateUpdateProxy();
		proxyTI.attachGenerator(proxyGenerator, null);
	endif;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyTI;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyTI;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAvailabilityGrade" id="eeac9471-6f58-4dd6-ab74-35df68838748">
        <updating/>
        <source>setAvailabilityGrade(_newGrade: Integer; _tiUpdateCntrl: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
/*

Date		Who		Reason
19 August 2013	cnwer1	Initial creation PAR

*/

vars

begin
	self.raiseExceptionIfTransient(method);
	
	exclusiveLock(self);

	if self.availabilityGrade = _newGrade then
		return;
	endif;
			
	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrl, _passport);
	endif;
	
	self.availabilityGrade := _newGrade;
	
	if (not self.isTransient) then
		self.endUpdate(_tiUpdateCntrl, _passport);
	endif;	

epilog

end;</source>
        <Parameter name="_newGrade" type="Integer"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setContentsStatus" id="3bbc67a1-64ad-4fdf-9e38-14fb23240ab5">
        <updating/>
        <source>setContentsStatus(_contentStatus: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2022	jlier1	Initial creation 54700

*/

vars

begin
	if self.contentsStatus = _contentStatus then
		return;
	endif;
	
	//jlier1 TFS 61160 21/11/23
	if not self.isTransient and  self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		if _contentStatus = TI_CONTENTS_STATUS_FULLLASHED or _contentStatus = TI_CONTENTS_STATUS_PRTLOADLASH then
			app.raiseCMException2( Cargo_empty_to_lashed, self.id, app.myRoot.allContentsStatuses[_contentStatus].description,null,null);
			return;		
		endif;
	
	endif;
	
	self.contentsStatus := _contentStatus;
	
	

end;</source>
        <Parameter name="_contentStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDefaultAvailabilityGrade" id="65eeb1fc-ce2e-48ce-8935-0b2e1b5dac5f">
        <updating/>
        <source>setDefaultAvailabilityGrade() updating;
/*

Date		Who		Reason
20 August 2013	cnwer1	Initial creation PAR

*/

vars
	theAvailabilityGrade : Integer;
begin

	if 	self.site &lt;&gt; TI_SITE_ONSITE or
		self.priorLocation &lt;&gt; null then
		return;		//must be empty and moved onsite from offsite
	endif;

	//Set the availability grade to default value if not already set
	if self.availabilityGrade = 0 then
	// CCMS 1235
		theAvailabilityGrade := self.myTerminal.getConfig(DefAvailabilityGrade).Integer;
		self.availabilityGrade := theAvailabilityGrade;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFloorType" id="3162b820-521e-469c-a197-b382080d2503">
        <updating/>
        <source>setFloorType(_floorType : Integer) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 February 2023
TFS#		: 56496
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.floorType := _floorType;
end;</source>
        <Parameter name="_floorType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="33d80d12-2a79-4b0b-aefb-9f26f199db04">
        <updating/>
        <source>setForCreate(_pxyTI: CM_TILC; _passport: CM_Passport input) updating;
/*

Date		Who		Reason
12 April 2007	cnwer1	Initial creation - PAR#xxxx
10 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
22 Feb 2023	jlika1	TFS 56496 - CUX - Add attribute to cargo (to allow for conversions of MAFI types)
11/07/2024	navcs2	Defect 65133: CUX | Change of trailer Type through EDI not updating Trailer dimension Details
24/07/2024	navlw1 	TFS 65323: CUX - Contents Status is Empty for MAFI's with Attachments (onboard cargo)
23 Sep 2024 navlc30 Bug 66251: CUX - Go Live 02 issue - Stops not applied when creating cargo via /cargo API
29/05/2025 	navcs2 	MTN-34844 Development - Portschema Implementation
*/
vars
	realGenerator, pxyGen : CM_Generator;
	lc :  CM_TILCRow;
	count : Integer;
begin
	self.myTILCType := _pxyTI.myTILCType;
	
	//15/10/2025	navkc1 JIRA 36057
	if _pxyTI.myTILCType &lt;&gt; null and _pxyTI.myTILCType.allowUpdateTotalWeight then
		self.updateTILCTotalWeightConfig(true);
	endif;
	
	
	self.setCargoType(_pxyTI.cargoType);
	
	
	foreach count in 1 to self.myTILCType.numControllers do
		create lc  persistent;
		lc.setMYTILC(self);
	endforeach; 
	
	self.contentsStatus:=_pxyTI.contentsStatus; //jlier1	TFS 54675 8/11/22				//23.09.2024 navlc30 #66251	
	
	inheritMethod(_pxyTI, _passport);
	
	pxyGen := _pxyTI.getGenerator();
	
	if pxyGen &lt;&gt; null then
		realGenerator := pxyGen.pxyGetRealObject();
		if realGenerator = null then
			realGenerator := self.myTerminal.createTrackedItem(pxyGen, _passport).CM_Generator;
		endif;
		self.attachGenerator(realGenerator, _passport);
	endif;
	self.availabilityGrade:=_pxyTI.availabilityGrade;
	//self.contentsStatus:=_pxyTI.contentsStatus; //jlier1	TFS 54675 8/11/22				//23.09.2024 navlc30 #66251
	if self.myTiMaster &lt;&gt; null and self.myTiMaster.isMAFI then								//29/05/2025 	navcs2 	MTN-34844
		self.floorType := self.myTiMaster.CM_TIMasterTILC.floorType;						//29/05/2025 	navcs2 	MTN-34844
	else																					//29/05/2025 	navcs2 	MTN-34844
		self.floorType := _pxyTI.floorType;													//29/05/2025 	navcs2 	MTN-34844
	endif;																					//29/05/2025 	navcs2 	MTN-34844
	//self.autoCreateTIMaster(); // TFS 46767 - 31/10/2019 disable autocreation for 090
	
	/* Below ContentsStatus code moved to updateContentsStatus								//24.09.2024 navlc30 #66251
	// start navlw1 #65323
	if self.allChildren.isNotEmpty then
		foreach ti in self.allChildren discreteLock do
			if not ti.isContainer then
				self.contentsStatus := TI_CONTENTS_STATUS_PRTLOAD;
			endif;
			if ti.isContainer then
				self.contentsStatus := TI_CONTENTS_STATUS_FCL;
				break;
			endif;
		endforeach;
	elseif self.allLCs.isNotEmpty then
		create tis transient;
		self.getAllOnboardTIs(tis);
		foreach ti in tis do
			if not ti.isContainer then
				self.contentsStatus := TI_CONTENTS_STATUS_PRTLOAD;
			endif;
			if ti.isContainer then
				self.contentsStatus := TI_CONTENTS_STATUS_FCL;
				break;
			endif;
		endforeach;
	endif;
	// end navlw1 #65323
	
	if self.contentsStatus = TI_CONTENTS_STATUS_NULL then // ### TFS BUG 57408 14APR2023 NAVAB1
		self.contentsStatus := TI_CONTENTS_STATUS_EMPTY; // ### TFS BUG 57408 14APR2023 NAVAB1
	endif;*/
	
	//11/07/2024	navcs2	Defect 65133 Start
	if self.myTILCType &lt;&gt; null then
		self.updateDimensions();
	endif;
	//11/07/2024	navcs2	Defect 65133 End
epilog
	//delete tis;					//24.09.2024 navlc30 #66251
end;</source>
        <Parameter name="_pxyTI" type="CM_TILC"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateActual" id="d89bcff9-c5e1-43c1-81b2-c2010145c32c">
        <updating/>
        <source>setForUpdateActual( _pxyTI : CM_TILC; _tiUpdateCntrlr : CMIF_TIUpdateController input; _passport : CM_Passport input ) updating, protected;

/*
Date			Who		Reason
29 July 2010	cnwrl1	Initial creation as part of PAR 23526 - CCMS 1075 - EDI Cargo Field Update needs additional fields.
14 March 2014	cnwmc5	PAR 33659
31 Aug	2022	jlier1 TFS 54700
22 Feb 2023	jlika1	TFS 56496 - CUX - Add attribute to cargo (to allow for conversions of MAFI types)
01/07/2024	navcs2	Bug 64926: CUX | Change of Trailer Type not updating the Trailer Details correctly
18 Sep 2024		jlizm1	TFS 66132 MAFI Height being reset after any edit

*/
	
vars
	resetDimensions	: Boolean;
	changedType 	: Boolean;
	changedLength 	: Boolean;
	changedWidth 	: Boolean;
	changedHeight 	: Boolean;
	
begin
	changedType := self.myTILCType &lt;&gt; _pxyTI.myTILCType;
	if changedType then
		// if trailer type is changed, reset dimensions to new type's defaults
		// unless we've modified dimensions manually, then keep what was entered
		changedLength 	:= _pxyTI.length &lt;&gt; self.length;
		changedWidth 	:= _pxyTI.width &lt;&gt; self.width;
		changedHeight	:= _pxyTI.height &lt;&gt; self.height;
		
		if not (changedLength or changedWidth or changedHeight) then
			resetDimensions := true;
		endif;
	endif;
	
	self.setMyTypeWithLCs( _pxyTI.myTILCType );		//cnwmc5 - 14 March 2014 - PAR 33659
	inheritMethod( _pxyTI, _tiUpdateCntrlr, _passport );
	self.availabilityGrade:=_pxyTI.availabilityGrade;
	self.setContentsStatus(_pxyTI.contentsStatus); //jlier1 TFS 61160 14/11/23
	self.overHeight:=_pxyTI.overHeight;
	self.overWidth:=_pxyTI.overWidth;
	self.overLength:=_pxyTI.overLength;
	self.floorType := _pxyTI.floorType;
	
	if resetDimensions then																							// 01/07/2024	navcs2	Bug 64926
		self.updateDimensions();																					// 01/07/2024	navcs2	Bug 64926
	endif;																											// 01/07/2024	navcs2	Bug 64926
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_TILC"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setGeneratorForUpdate" id="d4e4534a-caa0-476e-ac2b-beb1ac8c0316">
        <updating/>
        <source>setGeneratorForUpdate( pProxyGenerator : CM_Generator; originalState : Integer;
		_tiUpdateCntrlr : CMIF_TIUpdateController input; _passport : CM_Passport input) updating, protected;
/* ---------------------------------------------------------------------------
Created:	27 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	prxyGenerator : CM_Generator;
	origGenerator : CM_Generator;
	realGenerator : CM_Generator;
	aGenerator : CM_Generator;
	expectedEdition	: Integer;
	
begin

	if self.myGenerator = null and pProxyGenerator = null then
		// no work to do
		return;
	endif;

	if self.myGenerator &lt;&gt; null then
		origGenerator := self.myGenerator;	// detachment looks here
	endif;

	if pProxyGenerator = null then		// detach comes here
		// We must detach the original generator
		if origGenerator &lt;&gt; null then
			exclusiveLock(origGenerator);
			self.detachGenerator(_passport);		
		endif;
		return;	//leaves when detach
	endif;

	if pProxyGenerator.cargoType &lt;&gt; TI_CargoType_Generator then
		app.raiseCMException(ERR_TI_NOT_GENERATOR, "", null);
		return;
	endif;

	if realGenerator = null then	// attachment comes here
		if pProxyGenerator.isTransient then
			//See if the generator is part of a proxy / persistent pair
			pProxyGenerator.pxyGetRealObjectAndEdition(realGenerator, expectedEdition);
			//if realGenerator = null then
				//Try a lookup
			//	realGenerator := self.myTerminal.lookupTrackedItem(pProxyGenerator.id, pProxyGenerator.cargoType, originalState, null, false).CM_Generator;
			//endif;
		else
			app.raiseCMException1(NotAProxyObject,"Generator " &amp; pProxyGenerator.id, "", null);
		endif;
	endif;

	if realGenerator = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;

	else
		if realGenerator &lt;&gt; null then // attachment comes here
		
			exclusiveLock(realGenerator);
			
			if realGenerator &lt;&gt; origGenerator then	
				// RJS TODO - need to move orig to default location
				self.attachGenerator(realGenerator, _passport);	// attachment case
			endif;
		endif;
		aGenerator := pProxyGenerator;
		aGenerator.setPropertyValue("isValid", true);
		realGenerator.setFromPxy(pProxyGenerator, _tiUpdateCntrlr, _passport);
	endif;



end;</source>
        <access>protected</access>
        <Parameter name="pProxyGenerator" type="CM_Generator"/>
        <Parameter name="originalState" type="Integer"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementValue" id="4713cbb3-b444-43fa-8d8d-161c8d1ec7f8">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2022	jlier1	Initial creation 54700
29/04/2024	jlika1	TFS 63742 CUX - 14075 error in MTN When we click on MAFI with long characters in Height field
*/

vars
	precisionError		: Boolean;
begin
	on Exception do app.handlePrecisionError(exception, precisionError);
    	
	if _entRowName = ETRow_OverHeight then
		self.overHeight:=_value;
	elseif _entRowName = ETRow_OverWidth then
		self.overWidth:=_value;
	elseif _entRowName = ETRow_OverLength then
		self.overLength:=_value;
	else
		inheritMethod(_entRowName, _value);
	endif;
	
	if precisionError then				
		app.raiseCMException1(Many_digits_field_value, _entRowName, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
