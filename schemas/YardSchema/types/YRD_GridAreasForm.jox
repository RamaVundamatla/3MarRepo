// ---------------------------------------------------------------------------
// Created:     13 February 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if _theTI = null then
		return false;
	endif;

	if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
		return _theTI.canShiftRight(REAL_MODE);
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
		return _theTI.canShiftRight(QUEUE_MODE);
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
		return _theTI.canShiftRight(PLANNING_MODE);
	endif;
		
	return false;

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearYAMFilter" id="20e1c05b-0bb3-4529-9426-8f1e6c3408eb">
        <source>clearYAMFilter( _rebuildTable : Boolean );


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin
	
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		self.allColumnFilters.replaceAllFiltersForTable( self.tblYAM, null );
	endif;
	
	if _rebuildTable then
		self.tblYAM.applyColumnFilter( null );
	endif;

epilog

end;</source>
        <Parameter name="_rebuildTable" type="Boolean"/>
    </JadeMethod>
