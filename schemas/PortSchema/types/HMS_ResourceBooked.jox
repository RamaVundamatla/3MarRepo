<Class name="HMS_ResourceBooked" id="9b3c6743-eb92-4dab-9d88-026647bc1b4c">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <ImplicitInverseRef name="myResourceUsed" id="95c4d2cd-4a9c-4267-961b-433c8053bdec">
        <embedded/>
        <type name="HMS_ResourceUsed"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createPropertyChanges" id="711d1543-a71e-49ea-b16d-a267988264b3">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	propertyChange:	HMS_PropertyChange;
begin
	inheritMethod(_cmifTrans);
	create propertyChange;
	if self.myResourceUsed.myResource &lt;&gt; null then
	   	propertyChange.set(self, self.myResourceUsed.myResource.myResourceType.description &amp; ": " &amp; self.myResourceUsed.myResource.description, "NOT Booked", "Booked");
	elseif self.myResourceUsed.myResourceType &lt;&gt; null then
	   	propertyChange.set(self, self.myResourceUsed.myResourceType.description, "NOT Booked", "Booked");	   	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setGeneralProperties" id="2b813dfa-e905-4d3e-a2f3-65d2d1706c36">
        <updating/>
        <source>setGeneralProperties(_transController: CMIF_HMS_TransactionController; _passport: CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_transController, _passport);
	self.myResourceUsed := _transController.myResourceUsed;
end;</source>
        <access>protected</access>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="781191b1-d0a5-4848-8c04-1d27463cf164">
        <updating/>
        <source>setTypeDetails() updating, protected;

vars

begin
 	// Set type and typeString
	type:=TRANS_TYPE_ResourceBooked;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="e2a06a88-a649-4e8d-b368-ebeb90c44af1">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myVoyageMovement = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Movement', 'Null', null, null);
		return false;
	endif;	

	if _transController.myResourceUsed = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Resource', 'Null', null, null);
		return false;
	endif;	
	return rtnValue;			
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
