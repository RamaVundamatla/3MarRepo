    <JadeMethod name="getObjects" id="1ecca381-7f1c-4272-a148-9795d3780030">
        <source>getObjects(objects: ObjectLongNameDict input);
//26 August 2008	consw1	
// Return a dict of objects for this criteria type
vars
	cons: CM_ConsigneeConsignor;
begin
	foreach cons in app.myRoot.allConsigneeConsignors do
		//+cnwml2 PAR25402
		if cons.isConsignee then
			objects[cons.getYAIdentifier] := cons;
		endif;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
