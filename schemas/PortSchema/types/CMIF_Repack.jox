    </PrimAttribute>
    <JadeMethod name="setFullAndEmpty" id="f0b20f86-4296-4016-ae4e-cc559bcf6d81">
        <updating/>
        <source>setFullAndEmpty(_emptyContainer, _fullContainer : CM_Container ) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 25 November 2003
//
//********************************************************************
vars

begin
	if _emptyContainer = null or _fullContainer = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(AFullAndEmptyContainerRequired));
	else
		self.myProxyEmptyContainer := _emptyContainer;
		self.myProxyFullContainer := _fullContainer;		
	endif;
	
end;</source>
        <Parameter name="_emptyContainer" type="CM_Container"/>
        <Parameter name="_fullContainer" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="updateEmptyToFull" id="1aa8cafb-f8ba-4733-b54a-3ec36acec263">
        <source>updateEmptyToFull();
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 25 November 2003
//
//********************************************************************
vars
	contBeingFilled : CM_Container;
	contBeingEmptied : CM_Container;
begin
	contBeingFilled := self.myProxyEmptyContainer;
	contBeingEmptied := self.myProxyFullContainer;
	

	
end;</source>
    </JadeMethod>
</Class>
