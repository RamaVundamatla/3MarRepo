        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resize" id="929a8507-06e1-48d1-9597-1b967e8f8a07">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		23 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/07/1999	cnwdad1		Added logic to also reposition the 'Find' button.
//
// --------------------------------------------------------------------------------
begin
	btnClose.move(((self.width - btnClose.width) - 18), ((self.height - btnClose.height) - 36), btnClose.width, btnClose.height);
	btnBrowse.move(((btnClose.left - btnBrowse.width) - 6), ((self.height - btnBrowse.height) - 36), btnBrowse.width, btnBrowse.height);
	btnRefresh.move(((btnBrowse.left - btnRefresh.width) - 6), ((self.height - btnRefresh.height) - 36), btnRefresh.width, btnRefresh.height);
	btnFind.move(btnFind.left, ((self.height - btnFind.height) - 36), btnFind.width, btnFind.height);
	lstClasses.move(lstClasses.left, lstClasses.top, (self.width - (lstClasses.left * 3) + 2), (btnClose.top - 12));
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="87060242-65a7-4f32-8e45-df984af3c797">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	index	: Integer;

begin
	if (app.isValidObject(theObject)) then
		index	:=	lstClasses.findObject(theObject.class());

		if (index &lt;&gt; CNEC_NULL_INDEX) then
			lstClasses.itemText[index]	:=	theObject.class().name &amp; " (" &amp; theObject.class().instances.size.String &amp; ")";
		endif;
	else
		self.loadClasses();
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="3411ce6d-2d71-4f91-90bf-2b2508583d49">
